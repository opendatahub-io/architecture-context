# Required environment variables for Vertex AI
CLAUDE_CODE_USE_VERTEX=1
CLOUD_ML_REGION=us-east5
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id

# Note: You also need to authenticate with GCP:
# gcloud auth application-default login

# Optional: GitHub Personal Access Token for gh-org-clone
# This is recommended to avoid API rate limits when cloning many repositories
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_token_here
