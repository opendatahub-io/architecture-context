graph TD
    subgraph "Service Accounts"
        SA1["modelmesh-controller<br/>Namespace: modelmesh-serving"]
        SA2["modelmesh-serving-sa<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB1[modelmesh-controller-rolebinding]
        CRB2[leader-election-rolebinding]
        CRB3[modelmesh-controller-proxy-rolebinding]
    end

    subgraph "ClusterRole Permissions"
        CR1[modelmesh-controller-role]
        CR2[leader-election-role]
        CR3[modelmesh-controller-proxy-role]
    end

    subgraph "User Roles"
        UR1[inferenceservice-editor-role]
        UR2[predictor-editor-role]
        UR3[servingruntime-editor-role]
    end

    subgraph "Core API Resources"
        Core1[ConfigMaps]
        Core2[Secrets]
        Core3[Services]
        Core4[Namespaces]
        Core5[Endpoints]
        Core6[PersistentVolumeClaims]
    end

    subgraph "Apps API Resources"
        Apps1[Deployments]
        Apps2["Deployments/Finalizers"]
    end

    subgraph "KServe CRDs"
        KServe1["serving.kserve.io<br/>Predictor"]
        KServe2["serving.kserve.io<br/>ServingRuntime"]
        KServe3["serving.kserve.io<br/>ClusterServingRuntime"]
        KServe4["serving.kserve.io<br/>InferenceService"]
    end

    subgraph "Other Resources"
        Other1["autoscaling<br/>HorizontalPodAutoscaler"]
        Other2["monitoring.coreos.com<br/>ServiceMonitor"]
    end

    %% Service Account to RoleBindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA1 -->|bound via| CRB3

    %% RoleBindings to ClusterRoles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% ClusterRole permissions to Core resources
    CR1 -->|get,list,watch,create,update,patch,delete| Core1
    CR1 -->|get,list,watch,create,update,patch,delete| Core2
    CR1 -->|get,list,watch,create,update,patch,delete| Core3
    CR1 -->|get,list,watch,create,update,patch,delete| Core4
    CR1 -->|get,list,watch| Core5
    CR1 -->|get,list,watch| Core6

    %% ClusterRole permissions to Apps resources
    CR1 -->|get,list,watch,create,update,patch,delete| Apps1
    CR1 -->|get,list,watch,create,update,patch,delete| Apps2

    %% ClusterRole permissions to KServe CRDs
    CR1 -->|get,list,watch,create,update,patch,delete| KServe1
    CR1 -->|get,list,watch,create,update,patch,delete| KServe2
    CR1 -->|get,list,watch,create,update,patch,delete| KServe3
    CR1 -->|get,list,watch,create,update,patch,delete| KServe4

    %% Status and finalizers
    CR1 -->|get,patch,update| KServe1
    CR1 -->|get,patch,update| KServe2
    CR1 -->|get,patch,update| KServe3
    CR1 -->|get,patch,update| KServe4

    %% Other resources
    CR1 -->|get,list,watch,create,update,delete| Other1
    CR1 -->|get,list,watch,create,update,patch,delete| Other2

    %% User roles
    UR1 -->|get,list,watch,create,update,patch,delete| KServe4
    UR2 -->|get,list,watch,create,update,patch,delete| KServe1
    UR3 -->|get,list,watch,create,update,patch,delete| KServe2

    %% OpenShift SCC
    subgraph "OpenShift SCC"
        SCC[restricted SCC]
    end

    SA2 -->|assigned| SCC

    %% Styling
    style SA1 fill:#4a90e2,color:#fff
    style SA2 fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623,color:#000
    style CR2 fill:#f5a623,color:#000
    style CR3 fill:#f5a623,color:#000
    style UR1 fill:#95a5a6,color:#fff
    style UR2 fill:#95a5a6,color:#fff
    style UR3 fill:#95a5a6,color:#fff
    style KServe1 fill:#7ed321,color:#000
    style KServe2 fill:#7ed321,color:#000
    style KServe3 fill:#7ed321,color:#000
    style KServe4 fill:#7ed321,color:#000
    style SCC fill:#e74c3c,color:#fff
