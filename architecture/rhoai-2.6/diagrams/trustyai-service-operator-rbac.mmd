graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Operator Namespace]
        SA_Proxy[instance-proxy<br/>Per TrustyAIService]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>Cluster-wide]
        CRB_Proxy[proxy-rolebinding<br/>Cluster-wide]
        CRB_Instance[instance-namespace-proxy-rolebinding<br/>Cluster-wide]
    end

    subgraph "Roles & ClusterRoles"
        CR_Manager[ClusterRole: manager-role]
        CR_Proxy[ClusterRole: proxy-role]
        R_LeaderElection[Role: leader-election-role<br/>Operator Namespace]
    end

    subgraph "API Resources - TrustyAI"
        TrustyAI_CRD[trustyai.opendatahub.io<br/>- trustyaiservices<br/>- trustyaiservices/status<br/>- trustyaiservices/finalizers]
    end

    subgraph "API Resources - Apps"
        Apps_Resources[apps<br/>- deployments<br/>- deployments/status<br/>- deployments/finalizers]
    end

    subgraph "API Resources - Core"
        Core_Resources[core<br/>- services<br/>- pods<br/>- configmaps<br/>- secrets<br/>- serviceaccounts<br/>- persistentvolumeclaims<br/>- persistentvolumes<br/>- events]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_Resources[monitoring.coreos.com<br/>- servicemonitors]
    end

    subgraph "API Resources - OpenShift"
        Route_Resources[route.openshift.io<br/>- routes]
    end

    subgraph "API Resources - KServe"
        KServe_Resources[serving.kserve.io<br/>- inferenceservices<br/>- inferenceservices/finalizers<br/>- servingruntimes<br/>- servingruntimes/status]
    end

    subgraph "API Resources - RBAC"
        RBAC_Resources[rbac.authorization.k8s.io<br/>- clusterrolebindings]
    end

    subgraph "API Resources - Auth"
        Auth_Resources["authentication.k8s.io<br/>- tokenreviews<br/><br/>authorization.k8s.io<br/>- subjectaccessreviews"]
    end

    subgraph "API Resources - Leader Election"
        LeaderElection_Resources["coordination.k8s.io<br/>- leases<br/><br/>core<br/>- configmaps<br/>- events"]
    end

    %% Service Account bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Proxy
    SA_Proxy -->|bound via| CRB_Instance

    %% ClusterRoleBinding to ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    CRB_Instance -->|grants| CR_Proxy

    %% Leader Election Role Binding
    SA_Controller -->|bound via RoleBinding| R_LeaderElection

    %% Manager role permissions
    CR_Manager -->|create,delete,get,list,patch,update,watch| TrustyAI_CRD
    CR_Manager -->|create,delete,get,list,patch,update,watch| Apps_Resources
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Resources
    CR_Manager -->|create,list,watch| Monitoring_Resources
    CR_Manager -->|create,delete,get,list,patch,update,watch| Route_Resources
    CR_Manager -->|create,delete,get,list,patch,update,watch| KServe_Resources
    CR_Manager -->|create,delete,get,list,update,watch| RBAC_Resources

    %% Proxy role permissions
    CR_Proxy -->|create| Auth_Resources

    %% Leader Election role permissions
    R_LeaderElection -->|create,delete,get,list,patch,update,watch| LeaderElection_Resources

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Proxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style TrustyAI_CRD fill:#7ed321,stroke:#333,stroke-width:2px
    style Apps_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style Core_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style Monitoring_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style Route_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style RBAC_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style Auth_Resources fill:#7ed321,stroke:#333,stroke-width:2px
    style LeaderElection_Resources fill:#7ed321,stroke:#333,stroke-width:2px
