graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.3 Termination<br/>Optional Bearer Token"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        VirtualService["Istio VirtualService<br/>{isvc-name}<br/>Authorization Policy<br/>Authorino (RHOAI)"]

        subgraph NS_KnativeServing["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>Serverless activation"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            KnativeService["Knative Service<br/>{isvc-name}-predictor<br/>ClusterIP: 80/TCP → 8080/TCP<br/>SA: {isvc-name}-sa"]

            subgraph Pod["Pod: {isvc-name}-predictor-xxxxx"]
                direction TB
                StorageInit["storage-initializer<br/>Init Container<br/>Downloads models"]
                Agent["agent<br/>Sidecar Container<br/>Port: 9081/TCP<br/>Logging & Batching"]
                ModelServer["Model Server<br/>sklearn/xgboost/tensorflow<br/>Port: 8080/TCP HTTP<br/>Port: 8081/TCP gRPC"]

                Agent -->|"8080/TCP<br/>HTTP<br/>localhost"| ModelServer
            end

            KnativeService --> Pod
        end

        VirtualService -->|"80/TCP<br/>HTTP<br/>mTLS STRICT<br/>Istio AuthZ Policy"| KnativeService
        KnativeService -->|"9081/TCP<br/>HTTP"| Activator
        Activator -->|"9081/TCP<br/>HTTP"| Agent
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        subgraph NS_KServe["Namespace: kserve"]
            Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Metrics: 8443/TCP HTTPS"]
            Webhook["kserve-webhook-server<br/>Service: 443/TCP → 9443/TCP<br/>TLS 1.2+ mTLS"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.3<br/>ServiceAccount Token Auth"]

        Controller -->|"Watch CRDs<br/>Create Resources<br/>SA Token"| K8sAPI
        K8sAPI -->|"Admission Webhooks<br/>mTLS"| Webhook
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS Signature v4"]
        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS TLS1.2+<br/>Storage Account Key"]
        Registry["Container Registry<br/>quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secret"]
        Eventing["Knative Eventing Broker<br/>80/TCP HTTP"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Optional Bearer Token"| Gateway
    Gateway -->|"HTTP/80<br/>mTLS STRICT<br/>Istio Peer Auth"| VirtualService

    %% Storage initialization
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / GCP SA"| S3
    StorageInit -.->|"HTTPS/443<br/>TLS 1.2+"| GCS
    StorageInit -.->|"HTTPS/443<br/>TLS 1.2+"| Azure

    %% Eventing
    Agent -.->|"HTTP/80<br/>CloudEvents<br/>Async logs"| Eventing

    %% Container pulls
    Pod -.->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| Registry

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Optional mTLS"| Controller
    Prometheus -->|"HTTP/8080"| ModelServer

    %% User interaction
    User[Data Scientist] -->|"kubectl apply<br/>HTTPS/443<br/>Bearer Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#333
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#333
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px,color:#333
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:3px,color:#333
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:3px,color:#333

    class Client,User external
    class Gateway ingress
    class VirtualService,KnativeService,Activator,Pod,Agent,ModelServer,StorageInit servicemesh
    class Controller,Webhook,K8sAPI controlplane
    class S3,GCS,Azure,Registry,Eventing externalservice
    class Prometheus monitoring
