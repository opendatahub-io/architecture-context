%% CodeFlare Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "CodeFlare Operator"
        Manager["codeflare-operator manager<br/>(Go Binary, controller-runtime)"]
        MCAD["MCAD Queue Controller<br/>(mcad.NewJobController)"]
        InstaScale["InstaScale Controller<br/>(instascale.AppWrapperReconciler)<br/><i>optional, disabled by default</i>"]
        Config["codeflare-operator-config<br/>(ConfigMap)"]

        Manager -->|starts| MCAD
        Manager -->|optionally starts| InstaScale
        Manager -->|reads| Config
    end

    %% CRDs
    User[User / SDK] -->|creates| AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta1)"]
    User -->|creates| SchedulingSpecCR["SchedulingSpec CR<br/>(workload.codeflare.dev/v1beta1)"]
    User -->|creates| QuotaSubtreeCR["QuotaSubtree CR<br/>(quota.codeflare.dev/v1alpha1)"]

    AppWrapperCR -->|watched by| MCAD
    SchedulingSpecCR -->|used by| MCAD
    QuotaSubtreeCR -->|managed by| MCAD

    %% MCAD creates resources
    MCAD -->|creates/manages| Pods[Pods]
    MCAD -->|creates/manages| RayCluster["RayCluster CR<br/>(ray.io)"]
    MCAD -->|creates/manages| Deployments[Deployments]
    MCAD -->|creates/manages| Services[Services]

    %% InstaScale interactions
    InstaScale -->|creates| MachineSets["MachineSets<br/>(machine.openshift.io)"]

    %% External dependencies
    Manager -->|depends on| K8sAPI["Kubernetes API Server"]
    InstaScale -->|depends on| MachineAPI["OpenShift Machine API"]

    %% Integration points
    ODHOperator["ODH / RHODS Operator"] -->|deploys via<br/>DataScienceCluster CR| Manager
    Prometheus["Prometheus"] -->|scrapes /metrics<br/>8080/TCP| Manager
    KubeRay["KubeRay Operator"] -.->|manages RayClusters<br/>created by MCAD| RayCluster

