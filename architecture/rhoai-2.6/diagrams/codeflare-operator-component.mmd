    style QuotaSubtreeCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style MachineAPI fill:#e8e8e8,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333
