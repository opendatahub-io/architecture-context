/*
 * KServe C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.6/kserve.md
 */

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys ML models using InferenceService resources"
        externalClient = person "External Client" "Sends inference requests to deployed models"

        kserve = softwareSystem "KServe" "Kubernetes-native platform for serverless ML model serving with support for Knative, raw deployments, and ModelMesh" {
            controllerManager = container "KServe Controller Manager" "Reconciles InferenceService, TrainedModel, and InferenceGraph CRDs; manages Knative Services, Deployments, VirtualServices" "Go Operator (controller-runtime v0.14.6)"
            webhookServer = container "Webhook Server" "Validates and mutates InferenceService, ServingRuntime, TrainedModel, InferenceGraph resources; injects storage-initializer and agent sidecars" "Go Admission Webhook (9443/TCP TLS)"
            kserveAgent = container "KServe Agent" "Model puller, logger, and batcher sidecar injected into inference pods" "Go Sidecar (9081/TCP)"
            kserveRouter = container "KServe Router" "InferenceGraph DAG request router deployed as Knative Service" "Go Service"
            storageInitializer = container "Storage Initializer" "Downloads model artifacts from cloud storage (S3, GCS, Azure, PVC) before model server starts" "Go Init Container"
        }

        knativeServing = softwareSystem "Knative Serving" "Serverless autoscaling platform providing scale-to-zero and revision management" "External"
        istio = softwareSystem "Istio" "Service mesh for traffic management, mTLS, and ingress gateway" "External"
        modelMesh = softwareSystem "ModelMesh" "Multi-model serving controller for shared model serving infrastructure" "Internal RHOAI"
        openShift = softwareSystem "OpenShift" "Container platform providing serving certificate injection and platform services" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        s3Storage = softwareSystem "S3 Storage" "AWS S3 model artifact storage" "External Cloud"
        gcsStorage = softwareSystem "GCS Storage" "Google Cloud Storage for model artifacts" "External Cloud"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"

        # User interactions
        user -> kserve "Creates InferenceService, ServingRuntime, InferenceGraph via kubectl" "HTTPS/443"
        externalClient -> kserve "Sends inference requests (predict/explain)" "HTTPS/443 via Istio Gateway"

        # KServe internal
        controllerManager -> webhookServer "Registers admission webhooks"

        # External dependencies
        kserve -> knativeServing "Creates Knative Services for serverless auto-scaling" "HTTPS/443 (CRD API)"
        kserve -> istio "Creates VirtualServices for traffic routing and mTLS" "HTTPS/443 (CRD API)"
        kserve -> modelMesh "Delegates InferenceService when deploymentMode=ModelMesh"
        kserve -> openShift "Uses serving-cert annotation for webhook TLS certificates"
        kserve -> prometheus "Exposes controller metrics" "HTTPS/8443"
        kserve -> k8sAPI "Manages CRDs, Deployments, Services, ConfigMaps" "HTTPS/443 TLS 1.2+"
        kserve -> s3Storage "Downloads model artifacts via storage initializer" "HTTPS/443 TLS 1.2+ (AWS IAM)"
        kserve -> gcsStorage "Downloads model artifacts via storage initializer" "HTTPS/443 TLS 1.2+ (GCP SA)"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
            description "KServe system context showing external dependencies and integrations"
        }

        container kserve "Containers" {
            include *
            autoLayout
            description "KServe internal container architecture"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Cloud" {
                background #d4a017
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
