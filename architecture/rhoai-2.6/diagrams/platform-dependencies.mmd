graph LR
    subgraph "Platform Core"
        RHODSOp[RHODS Operator<br/>v1.6.0<br/>Platform Orchestrator]
    end

    subgraph "User Interface"
        Dashboard[ODH Dashboard<br/>v1.27.0<br/>Web UI]
    end

    subgraph "Development Environment"
        NotebookCtrl[Notebook Controller<br/>v1.27.0<br/>Workbench Management]
        NotebookImages[Notebook Images<br/>v1.1.1-312<br/>Jupyter/code-server/RStudio]
    end

    subgraph "ML Pipelines"
        DSPOp[Data Science Pipelines Operator<br/>rhoai-2.6<br/>Pipeline Infrastructure]
        DSPA[DataSciencePipelinesApplication]
        MLMD[ML Metadata<br/>Lineage Tracking]
    end

    subgraph "Model Serving - Single Model"
        KServe[KServe Operator<br/>v0.11.1<br/>Serverless Serving]
    end

    subgraph "Model Serving - Multi-Model"
        ModelMesh[ModelMesh Serving<br/>v1.27.0<br/>High-Density Serving]
    end

    subgraph "Integration Layer"
        ModelController[ODH Model Controller<br/>v1.27.0<br/>OpenShift Bridge]
    end

    subgraph "Distributed Computing"
        CodeFlare[CodeFlare Operator<br/>Workload Orchestration]
        MCAD[MCAD<br/>Queue Controller]
        InstaScale[InstaScale<br/>Auto-Scaler]
        KubeRay[KubeRay Operator<br/>Ray Cluster Manager]
    end

    subgraph "Model Monitoring"
        TrustyAI[TrustyAI Service Operator<br/>Fairness Monitoring]
    end

    subgraph "Platform Monitoring"
        Prometheus[Prometheus<br/>Metrics Collection]
        Alertmanager[Alertmanager<br/>Alert Management]
    end

    %% External OpenShift Platform Dependencies
    subgraph "OpenShift Platform"
        K8sAPI[Kubernetes API Server<br/>1.24+]
        OAuthServer[OpenShift OAuth<br/>Authentication]
        Routes[OpenShift Routes<br/>Ingress]
        ServiceCA[Service CA<br/>TLS Certificates]
        SCC[Security Context Constraints<br/>Pod Security]
    end

    %% External Component Dependencies
    subgraph "External Components - Required"
        Tekton[OpenShift Pipelines<br/>Tekton 1.8+<br/>Pipeline Execution]
    end

    subgraph "External Components - Optional"
        Istio[OpenShift Service Mesh<br/>Istio 1.15+<br/>mTLS & Traffic Mgmt]
        Knative[Knative Serving<br/>1.12+<br/>Serverless Platform]
        CertManager[cert-manager<br/>1.13+<br/>Certificate Automation]
        Volcano[Volcano Scheduler<br/>Gang Scheduling]
        Authorino[Authorino<br/>External Authorization]
    end

    %% External Storage & Services
    subgraph "External Services"
        S3[S3-Compatible Storage<br/>Model & Data Artifacts]
        Registry[Container Registries<br/>quay.io, registry.redhat.io]
        ExternalDB[External Databases<br/>PostgreSQL/MySQL<br/>Optional]
        etcd[etcd Cluster<br/>ModelMesh State<br/>Optional]
        CloudAPI[Cloud Provider API<br/>InstaScale Node Scaling<br/>Optional]
    end

    %% Platform Orchestration Dependencies
    RHODSOp -->|deploys & manages| Dashboard
    RHODSOp -->|deploys & manages| NotebookCtrl
    RHODSOp -->|deploys & manages| DSPOp
    RHODSOp -->|deploys & manages| KServe
    RHODSOp -->|deploys & manages| ModelMesh
    RHODSOp -->|deploys & manages| ModelController
    RHODSOp -->|deploys & manages| CodeFlare
    RHODSOp -->|deploys & manages| KubeRay
    RHODSOp -->|deploys & manages| TrustyAI
    RHODSOp -->|deploys & manages| Prometheus
    RHODSOp -->|deploys & manages| Alertmanager
    RHODSOp -->|reconciles via| K8sAPI

    %% Dashboard Dependencies
    Dashboard -->|API calls| DSPA
    Dashboard -->|queries lineage| MLMD
    Dashboard -->|authenticates via| OAuthServer
    Dashboard -->|ingress via| Routes

    %% Notebook Dependencies
    NotebookCtrl -->|creates pods with| NotebookImages
    NotebookCtrl -->|integrates auth| OAuthServer
    NotebookCtrl -->|creates ingress| Routes
    NotebookCtrl -->|TLS certs from| ServiceCA
    NotebookCtrl -->|pipeline integration| DSPA
    NotebookImages -->|pulls from| Registry
    NotebookImages -->|accesses data| S3

    %% Pipeline Dependencies
    DSPOp -->|creates| DSPA
    DSPA -->|executes via| Tekton
    DSPA -->|stores metadata| ExternalDB
    DSPA -->|stores artifacts| S3
    DSPA -->|lineage tracking| MLMD
    DSPA -->|TLS certs from| ServiceCA
    DSPA -->|authenticates via| OAuthServer

    %% KServe Dependencies
    KServe -->|requires| Knative
    KServe -->|requires| Istio
    KServe -->|integrates via| ModelController
    KServe -->|loads models from| S3
    KServe -->|optional cert mgmt| CertManager
    KServe -->|pulls images from| Registry

    %% ModelMesh Dependencies
    ModelMesh -->|state storage| etcd
    ModelMesh -->|integrates via| ModelController
    ModelMesh -->|loads models from| S3
    ModelMesh -->|pulls images from| Registry

    %% Model Controller Dependencies
    ModelController -->|creates| Routes
    ModelController -->|configures| Istio
    ModelController -->|creates ServiceMonitors| Prometheus
    ModelController -->|watches KServe| K8sAPI
    ModelController -->|watches ModelMesh| K8sAPI

    %% Distributed Computing Dependencies
    CodeFlare -->|embeds| MCAD
    CodeFlare -->|optionally uses| InstaScale
    CodeFlare -->|creates RayClusters via| KubeRay
    InstaScale -->|scales nodes via| CloudAPI
    KubeRay -->|optional scheduler| Volcano
    KubeRay -->|creates pods| K8sAPI
    KubeRay -->|accesses data| S3
    KubeRay -->|pulls images from| Registry

    %% TrustyAI Dependencies
    TrustyAI -->|watches & patches| KServe
    TrustyAI -->|exports metrics to| Prometheus
    TrustyAI -->|authenticates via| OAuthServer
    TrustyAI -->|TLS certs from| ServiceCA

    %% Monitoring Dependencies
    Prometheus -->|scrapes| Dashboard
    Prometheus -->|scrapes| DSPA
    Prometheus -->|scrapes| KServe
    Prometheus -->|scrapes| ModelMesh
    Prometheus -->|scrapes| TrustyAI
    Prometheus -->|sends alerts to| Alertmanager
    Prometheus -->|authenticates via| OAuthServer

    %% Platform-Wide Dependencies
    Dashboard -->|enforces| SCC
    NotebookCtrl -->|enforces| SCC
    DSPA -->|enforces| SCC
    KServe -->|enforces| SCC
    ModelMesh -->|enforces| SCC
    KubeRay -->|enforces| SCC
    TrustyAI -->|enforces| SCC

