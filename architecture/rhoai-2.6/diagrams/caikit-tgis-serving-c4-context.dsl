// C4 Context Diagram: caikit-tgis-serving
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/caikit-tgis-serving.md

workspace {
    model {
        user = person "Data Scientist / Client" "Sends inference requests to deployed LLM models"

        caikitTgisServing = softwareSystem "Caikit-TGIS-Serving" "Container image combining Caikit AI toolkit with TGIS for LLM inference on RHOAI/ODH platform via KServe" {
            caikitHTTP = container "Caikit HTTP Server" "HTTP inference endpoint for text generation" "Python / Port 8080"
            caikitGRPC = container "Caikit gRPC Server" "gRPC inference endpoint (caikit.runtime.Nlp)" "Python / Port 8085"
            tgis = container "TGIS Backend" "Text Generation Inference Server - loads and runs LLM weights" "Container Sidecar / Port 8033"
            metricsEndpoint = container "Metrics Endpoint" "Prometheus metrics scraping endpoint" "Python / Port 8086"
        }

        kserve = softwareSystem "KServe" "Orchestrates model deployment lifecycle via ServingRuntime and InferenceService CRDs" "Internal RHOAI"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for mTLS, traffic management, and ingress gateway" "External"
        knative = softwareSystem "OpenShift Serverless (Knative Serving)" "Serverless autoscaling and traffic routing" "External"
        authorino = softwareSystem "Authorino" "Optional token-based auth for inference endpoints" "Internal RHOAI"
        s3 = softwareSystem "S3/Minio Storage" "Model artifact storage and retrieval" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model download source (optional)" "External"
        prometheus = softwareSystem "Prometheus (OpenShift UWM)" "Metrics collection and monitoring" "External"

        // User interactions
        user -> caikitTgisServing "Sends inference requests via HTTP/gRPC" "HTTPS/443"

        // Internal container interactions
        caikitHTTP -> tgis "Forwards inference requests" "gRPC/8033 plaintext localhost"
        caikitGRPC -> tgis "Forwards inference requests" "gRPC/8033 plaintext localhost"

        // External system interactions
        caikitTgisServing -> istio "Traffic routed through Istio sidecar and gateway" "mTLS STRICT"
        caikitTgisServing -> knative "Deployed as Knative Service for autoscaling" "HTTP/gRPC"
        kserve -> caikitTgisServing "Manages lifecycle via ServingRuntime/InferenceService CRDs" "Kubernetes API"
        authorino -> caikitTgisServing "Enforces optional token-based auth" "AuthorizationPolicy"
        tgis -> s3 "Downloads model artifacts at startup" "S3 API/9000"
        caikitTgisServing -> huggingface "Optional model download" "HTTPS/443"
        prometheus -> caikitTgisServing "Scrapes metrics" "HTTP/8086"
    }

    views {
        systemContext caikitTgisServing "SystemContext" {
            include *
            autoLayout
        }

        container caikitTgisServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
