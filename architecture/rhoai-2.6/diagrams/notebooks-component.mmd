graph TB
    subgraph "Notebook Images Component"
        subgraph "Base Images"
            BaseUBI8[Base UBI8 Python 3.8]
            BaseUBI9[Base UBI9 Python 3.9]
            BaseC9S[Base C9S Python 3.9]
        end

        subgraph "Jupyter Notebooks"
            JupyterMinimal[Jupyter Minimal<br/>JupyterLab 3.x]
            JupyterDS[Jupyter Data Science<br/>ML libs + Elyra + DBs]
            JupyterPyTorch[Jupyter PyTorch]
            JupyterTF[Jupyter TensorFlow]
            JupyterTrustyAI[Jupyter TrustyAI]
        end

        subgraph "CUDA GPU Images"
            CUDABase[CUDA Base<br/>CUDA 11.8 + cuDNN 8.9]
            CUDAMinimal[CUDA Jupyter Minimal]
            CUDADS[CUDA Data Science]
            CUDAPyTorch[CUDA PyTorch]
            CUDATF[CUDA TensorFlow]
        end

        subgraph "Habana AI Images"
            Habana19[Habana 1.9.0]
            Habana110[Habana 1.10.0]
            Habana111[Habana 1.11.0]
        end

        subgraph "Runtime Images"
            RuntimeMinimal[Runtime Minimal<br/>No Jupyter]
            RuntimeDS[Runtime Data Science]
            RuntimePyTorch[Runtime PyTorch]
        end

        subgraph "IDE Images"
            CodeServer[Code-server<br/>VS Code + NGINX]
            RStudio[RStudio Server]
        end

        %% Build Dependencies
        BaseUBI8 --> JupyterMinimal
        BaseUBI8 --> CUDABase
        BaseUBI8 --> RuntimeMinimal
        BaseUBI9 --> JupyterMinimal
        BaseUBI9 --> CUDABase
        BaseUBI9 --> RuntimeMinimal
        BaseC9S --> CodeServer
        BaseC9S --> RStudio

        JupyterMinimal --> JupyterDS
        JupyterDS --> JupyterPyTorch
        JupyterDS --> JupyterTF
        JupyterDS --> JupyterTrustyAI
        JupyterDS --> Habana19
        JupyterDS --> Habana110
        JupyterDS --> Habana111

        CUDABase --> CUDAMinimal
        CUDAMinimal --> CUDADS
        CUDADS --> CUDAPyTorch
        CUDADS --> CUDATF

        BaseUBI8 --> RuntimeMinimal
        RuntimeMinimal --> RuntimeDS
        RuntimeDS --> RuntimePyTorch
    end

    subgraph "External Dependencies"
        UBI8[UBI8 Python 3.8<br/>registry.access.redhat.com]
        UBI9[UBI9 Python 3.9<br/>registry.access.redhat.com]
        C9S[CentOS Stream 9<br/>quay.io/centos]
        NVIDIASDK[NVIDIA CUDA 11.8<br/>cuDNN 8.9]
        JupyterLab[JupyterLab 3.2-3.6]
        Elyra[Elyra 3.15]
    end

    subgraph "RHOAI Platform Integration"
        NotebookController[Notebook Controller<br/>Spawns StatefulSets]
        DSPipelines[Data Science Pipelines<br/>Executes Runtimes]
        Dashboard[RHOAI Dashboard<br/>Image Selection]
        ImageStreams[OpenShift ImageStreams<br/>Image Distribution]
        ModelRegistry[Model Registry]
    end

    subgraph "Image Registry"
        QuayIO[quay.io/modh/*<br/>Image Storage]
    end

    %% External Dependencies
    UBI8 -.->|base image| BaseUBI8
    UBI9 -.->|base image| BaseUBI9
    C9S -.->|base image| BaseC9S
    NVIDIASDK -.->|libraries| CUDABase
    JupyterLab -.->|installed in| JupyterMinimal
    Elyra -.->|installed in| JupyterDS

    %% Registry
    JupyterDS -->|pushed to| QuayIO
    CUDAPyTorch -->|pushed to| QuayIO
    RuntimeDS -->|pushed to| QuayIO
    CodeServer -->|pushed to| QuayIO

    %% Platform Integration
    QuayIO -->|imported by| ImageStreams
    ImageStreams -->|referenced by| NotebookController
    ImageStreams -->|displayed in| Dashboard
    NotebookController -->|spawns| JupyterDS
    NotebookController -->|spawns| CUDAPyTorch
    DSPipelines -->|executes| RuntimeDS
    JupyterDS -->|registers models| ModelRegistry

    %% Styling
    style BaseUBI8 fill:#f5a623,stroke:#333
    style BaseUBI9 fill:#f5a623,stroke:#333
    style BaseC9S fill:#f5a623,stroke:#333
    style JupyterDS fill:#4a90e2,stroke:#333,stroke-width:3px
    style CUDAPyTorch fill:#4a90e2,stroke:#333
    style RuntimeDS fill:#7ed321,stroke:#333
    style NotebookController fill:#e8e8e8,stroke:#333
    style DSPipelines fill:#e8e8e8,stroke:#333
    style Dashboard fill:#e8e8e8,stroke:#333
    style QuayIO fill:#d0021b,stroke:#333
