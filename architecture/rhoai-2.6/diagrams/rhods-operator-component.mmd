graph TB
    subgraph "RHODS Operator"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        SecretGen[SecretGenerator Controller]
        FeatureFramework[Feature Framework]
        ComponentMgrs[Component Managers]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS]

        DSCController -->|uses| FeatureFramework
        DSCController -->|delegates| ComponentMgrs
        DSCIController -->|uses| FeatureFramework
    end

    subgraph "Monitoring Stack"
        Prometheus[Prometheus<br/>9090/TCP HTTP + OAuth]
        Alertmanager[Alertmanager<br/>9093/TCP HTTP + OAuth]
        Blackbox[Blackbox Exporter<br/>9115/TCP HTTP]
    end

    subgraph "Custom Resources"
        DSCCR[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCICR[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FeatureTrackerCR[FeatureTracker CR<br/>features.opendatahub.io/v1]
    end

    subgraph "Managed Components"
        Dashboard[ODH Dashboard]
        Workbenches[Workbenches<br/>Jupyter Notebooks]
        Pipelines[Data Science Pipelines<br/>Kubeflow]
        KServe[KServe<br/>Single-model serving]
        ModelMesh[ModelMesh Serving<br/>Multi-model serving]
        CodeFlare[CodeFlare<br/>Distributed workloads]
        Ray[Ray<br/>Distributed compute]
        TrustyAI[TrustyAI<br/>Model monitoring]
    end

    subgraph "Platform Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        OpenShiftOAuth[OpenShift OAuth]
        ServiceMesh[Service Mesh<br/>Optional]
        PrometheusOp[Prometheus Operator<br/>Optional]
    end

    User[Platform Admin] -->|creates| DSCCR
    User -->|creates| DSCICR

    DSCCR -->|watched by| DSCController
    DSCICR -->|watched by| DSCIController

    K8sAPI -->|validates via| WebhookServer

    DSCController -->|deploys| Dashboard
    DSCController -->|deploys| Workbenches
    DSCController -->|deploys| Pipelines
    DSCController -->|deploys| KServe
    DSCController -->|deploys| ModelMesh
    DSCController -->|deploys| CodeFlare
    DSCController -->|deploys| Ray
    DSCController -->|deploys| TrustyAI

    DSCIController -->|creates namespaces| K8sAPI
    DSCIController -->|configures| ServiceMesh
    DSCIController -->|deploys| Prometheus
    DSCIController -->|deploys| Alertmanager
    DSCIController -->|deploys| Blackbox

    SecretGen -->|generates| OpenShiftOAuth
    SecretGen -->|creates secrets| K8sAPI

    FeatureFramework -->|creates| FeatureTrackerCR

    ComponentMgrs -->|applies manifests| K8sAPI
    ComponentMgrs -->|integrates| PrometheusOp

    Prometheus -->|scrapes| DSCController
    Prometheus -->|scrapes| Dashboard
    Prometheus -->|scrapes| KServe

    style DSCController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCIController fill:#4a90e2,stroke:#333,stroke-width:2px
    style SecretGen fill:#4a90e2,stroke:#333,stroke-width:2px
    style WebhookServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSCCR fill:#f5a623,stroke:#333,stroke-width:2px
    style DSCICR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ServiceMesh fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style Workbenches fill:#7ed321,stroke:#333,stroke-width:2px
    style Pipelines fill:#7ed321,stroke:#333,stroke-width:2px
