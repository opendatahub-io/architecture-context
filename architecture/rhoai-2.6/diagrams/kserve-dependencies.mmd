graph LR
    KServe[KServe Operator]

    %% External Dependencies (Required)
    KServe -->|"orchestration<br/>1.23+ REQUIRED"| Kubernetes[Kubernetes 1.23+]

    %% External Dependencies (Optional)
    KServe -->|"traffic mgmt<br/>routing & mTLS<br/>1.15+ OPTIONAL"| Istio[Istio 1.15+]
    KServe -->|"serverless<br/>autoscaling<br/>0.26+ OPTIONAL"| Knative[Knative Serving 0.26+]
    KServe -->|"TLS certs<br/>webhooks<br/>1.9+ OPTIONAL"| CertManager[cert-manager 1.9+]

    %% Internal ODH Dependencies
    KServe -->|"VirtualService CRDs<br/>traffic routing"| ServiceMesh[ServiceMesh - Istio]
    KServe -->|"AuthorizationPolicy<br/>external authz"| Authorino[Authorino]
    KServe -->|"HTTP/S3 API<br/>model artifacts"| S3[S3 Storage]
    KServe -.->|"REST API<br/>model metadata<br/>OPTIONAL"| ModelRegistry[Model Registry]

    %% Integration Points (Components that consume KServe)
    Dashboard[ODH Dashboard] -->|"UI management<br/>InferenceService CRUD"| KServe
    Pipelines[Data Science Pipelines] -->|"auto-deploy<br/>InferenceService"| KServe

    %% External Services
    KServe -->|"S3 API 443/TCP<br/>model storage"| CloudStorage[S3/GCS/Azure Storage]
    KServe -->|"Docker Registry API<br/>443/TCP"| ContainerRegistry[Container Registry]
    KServe -.->|"CloudEvents<br/>80/TCP HTTP"| KnativeEventing[Knative Eventing]

    %% Monitoring
    Prometheus[Prometheus] -->|"scrape metrics<br/>8080/TCP, 8443/TCP"| KServe

    %% API Server Interaction
    KServe -->|"CRD watch/create<br/>443/TCP HTTPS"| K8sAPI[Kubernetes API Server]

    %% Deployment Mode Dependencies
    subgraph "Deployment Modes"
        direction TB
        ServerlessMode[Serverless Mode<br/>default]
        RawMode[RawDeployment Mode]
        ModelMeshMode[ModelMesh Mode]
    end

    ServerlessMode -.->|requires| Knative
    ServerlessMode -.->|requires| Istio
    RawMode -.->|only requires| Kubernetes
    ModelMeshMode -.->|separate component| ModelMesh[ModelMesh Serving]

    KServe -.-> ServerlessMode
    KServe -.-> RawMode
    KServe -.-> ModelMeshMode

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style Kubernetes fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style Istio fill:#466bb0,stroke:#333,stroke-width:2px,color:#fff
    style Knative fill:#0865ad,stroke:#333,stroke-width:2px,color:#fff
    style CertManager fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Authorino fill:#7ed321,stroke:#333,stroke-width:2px
    style S3 fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style Pipelines fill:#7ed321,stroke:#333,stroke-width:2px

    %% External Services
    style CloudStorage fill:#f5a623,stroke:#333,stroke-width:2px
    style ContainerRegistry fill:#f5a623,stroke:#333,stroke-width:2px
    style KnativeEventing fill:#f5a623,stroke:#333,stroke-width:2px
    style Prometheus fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px

    %% Deployment Modes
    style ServerlessMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RawMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ModelMeshMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ModelMesh fill:#999,stroke:#333,stroke-width:2px
