/*
 * KubeRay Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.6/kuberay.md
 */

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Ray clusters, jobs, and serve deployments"
        client = person "External Client" "Sends inference requests to Ray Serve endpoints"

        kuberay = softwareSystem "KubeRay Operator" "Kubernetes operator managing Ray cluster lifecycle, job submission, and serve deployments" {
            rayClusterCtrl = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker Pods, Services, Routes/Ingress, autoscaler RBAC" "Go Controller"
            rayJobCtrl = container "RayJob Controller" "Reconciles RayJob CRs: manages RayCluster lifecycle, submits jobs via Dashboard API, creates K8s batch Jobs" "Go Controller"
            rayServiceCtrl = container "RayService Controller" "Reconciles RayService CRs: manages active/pending clusters for zero-downtime serve deployments" "Go Controller"
            dashboardClient = container "Ray Dashboard HTTP Client" "HTTP client for Ray Dashboard REST API (job submission, serve management, status polling)" "Go Utility"
            batchSchedulerMgr = container "Batch Scheduler Manager" "Optional Volcano batch scheduler integration for gang scheduling" "Go Plugin"
        }

        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster API for managing all resources" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys kuberay-operator via kustomize overlay" "Internal RHOAI"
        openshiftRouter = softwareSystem "OpenShift Router" "Routes external traffic to cluster services" "External"
        volcanoScheduler = softwareSystem "Volcano Scheduler" "Gang scheduling for distributed workloads (optional)" "External"

        rayCluster = softwareSystem "Ray Cluster" "Distributed computing cluster with head and worker nodes" {
            headPod = container "Ray Head Pod" "Head node with Dashboard API (8265), Serve (8000), GCS (6379), Client (10001)" "Ray Process"
            workerPods = container "Ray Worker Pods" "Worker nodes for distributed task execution" "Ray Process"
        }

        # User interactions
        user -> kuberay "Creates RayCluster/RayJob/RayService CRs" "kubectl/oc"
        client -> rayCluster "Inference requests" "HTTP/8000"

        # KubeRay internal
        rayJobCtrl -> dashboardClient "Uses for job submission"
        rayServiceCtrl -> dashboardClient "Uses for serve deployment"

        # KubeRay to external
        kuberay -> kubernetesAPI "CRUD on Pods, Services, Routes, Ingresses, RBAC, CRDs" "HTTPS/443"
        dashboardClient -> rayCluster "Job submission, serve management, status polling" "HTTP/8265"
        kuberay -> volcanoScheduler "Gang scheduling (optional)" ""

        # External to KubeRay
        prometheus -> kuberay "Scrapes operator metrics" "HTTP/8080"
        rhoaiOperator -> kuberay "Deploys operator" "Kustomize"
        openshiftRouter -> rayCluster "Routes dashboard traffic" "HTTP/8265"

        # Ray cluster internal
        headPod -> workerPods "Distributes tasks" "TCP/6379"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        container rayCluster "RayClusterContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
