%% TrustyAI Explainability - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Permissions["Granted Permissions"]
        Verbs["create, delete, get,<br/>list, patch, update, watch"]
    end

    subgraph AuthEndpoints["Authentication at Endpoints"]
        direction LR
        NoAuth["/consumer/*, /metrics/*,<br/>/explainers/*, /info/*,<br/>/data/*<br/>Auth: None"]
        BearerAuth["/q/metrics<br/>Auth: Bearer Token (SA)<br/>via ServiceMonitor"]
    end

    subgraph InitContainerRBAC["Init Container"]
        InitSA["config-map-overrider<br/>(ose-cli init container)"]
        InitPurpose["Creates model-serving-config<br/>ConfigMap with payload<br/>processor URL"]
    end

    %% RBAC Flow
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permissions"| Verbs
    Verbs -->|"on resources"| ConfigMaps

    %% Init container uses SA
    SA -.->|"used by"| InitSA
    InitSA -->|"purpose"| InitPurpose

    %% Auth endpoints
    SA -.->|"bearerTokenFile"| BearerAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Verbs fill:#e8e8e8,stroke:#333
    style NoAuth fill:#f8cecc,stroke:#b85450
    style BearerAuth fill:#d5e8d4,stroke:#82b366
    style InitSA fill:#ffe0b2,stroke:#e65100
    style InitPurpose fill:#fff9c4,stroke:#f57f17
