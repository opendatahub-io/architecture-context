// Data Science Pipelines Tekton - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/data-science-pipelines-tekton.md

workspace {
    model {
        user = person "Data Scientist" "Defines, compiles, uploads, and executes ML pipelines using KFP SDK or UI"

        dsp = softwareSystem "Data Science Pipelines Tekton" "Kubeflow Pipelines implementation using Tekton as the pipeline execution backend for ML workflows" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API server for pipeline CRUD, run management, experiment tracking, and job scheduling" "Go Service" "8888/TCP REST, 8887/TCP gRPC"
            pipelineUI = container "ds-pipeline-ui" "Web UI for pipeline visualization, run monitoring, and management" "Node.js + oauth-proxy"
            persistenceAgent = container "ds-pipeline-persistenceagent" "Watches Tekton PipelineRuns/TaskRuns and syncs status back to API server" "Go Service"
            scheduledWorkflow = container "ds-pipeline-scheduledworkflow" "Manages ScheduledWorkflow CRD for recurring/scheduled pipeline executions" "Go Controller"
            vizServer = container "ds-pipeline-visualizationserver" "Renders pipeline output visualizations (charts, tables, TensorBoard)" "Python Service"
            viewerCRD = container "ds-pipeline-viewer-crd" "Manages Viewer CRD to create TensorBoard and other visualization deployments" "Go Controller"
            metadataEnvoy = container "metadata-envoy-deployment" "Envoy proxy fronting the metadata gRPC service" "Envoy Proxy"
            metadataGRPC = container "metadata-grpc-deployment" "MLMD gRPC server for storing and retrieving ML artifact metadata" "C++ ml-metadata"
            metadataWriter = container "metadata-writer" "Writes pipeline execution metadata to MLMD store" "Python Service"
            pipelineLoopCtrl = container "tekton-pipelineloop-controller" "Custom Tekton controller implementing PipelineLoop CRD for loop/iteration constructs" "Go Controller (Knative-based)"
            kfpSDK = container "KFP-Tekton SDK" "DSL compiler that translates Kubeflow Pipeline definitions to Tekton PipelineRun YAML" "Python SDK"
        }

        tekton = softwareSystem "Tekton Pipelines" "Pipeline execution engine (PipelineRun, TaskRun CRDs)" "External"
        mysql = softwareSystem "MySQL/MariaDB" "Persistent storage for pipelines, runs, experiments, jobs metadata" "External"
        minio = softwareSystem "MinIO/S3" "Artifact storage for pipeline outputs and logs" "External"
        k8s = softwareSystem "Kubernetes API" "Container orchestration platform" "External"
        oauthProxy = softwareSystem "OpenShift OAuth" "Authentication for pipeline UI" "External"
        dashboard = softwareSystem "ODH Dashboard" "Dashboard tile and quick-start integration" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "External"
        seldon = softwareSystem "Seldon Core" "Pipeline runner can create model serving deployments" "External"

        // User interactions
        user -> kfpSDK "Defines pipelines using Python DSL"
        user -> pipelineUI "Manages pipelines via browser" "HTTPS/8443"
        kfpSDK -> apiServer "Uploads compiled pipeline YAML" "HTTP/8888"

        // Internal flows
        pipelineUI -> apiServer "REST API calls" "HTTP/8888"
        persistenceAgent -> apiServer "Reports run status" "HTTP/8888"
        apiServer -> vizServer "Requests visualizations" "HTTP/8888"
        metadataWriter -> metadataEnvoy "Writes ML metadata" "gRPC/9090"
        metadataEnvoy -> metadataGRPC "Proxies gRPC" "gRPC/8080"

        // External dependencies
        apiServer -> mysql "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores artifacts" "HTTP/9000"
        apiServer -> k8s "Creates PipelineRuns" "HTTPS/443"
        metadataGRPC -> mysql "Stores ML metadata" "MySQL/3306"
        persistenceAgent -> k8s "Watches PipelineRuns/TaskRuns" "HTTPS/443"
        scheduledWorkflow -> k8s "Watches ScheduledWorkflows, creates PipelineRuns" "HTTPS/443"
        pipelineLoopCtrl -> k8s "Watches PipelineLoops, creates Runs" "HTTPS/443"
        metadataWriter -> k8s "Watches PipelineRuns" "HTTPS/443"
        viewerCRD -> k8s "Watches Viewer CRs" "HTTPS/443"
        pipelineUI -> oauthProxy "Authentication" "HTTPS/8443"

        // Integration points
        dashboard -> pipelineUI "UI integration" "OdhApplication CR"
        prometheus -> apiServer "Scrapes metrics" "HTTP/8888 /metrics"
        dsp -> tekton "Executes pipelines" "CRD-based"
        dsp -> seldon "Creates model deployments" "CRD-based"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
