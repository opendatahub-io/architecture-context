graph TD
    subgraph "Service Accounts"
        SA[odh-model-controller<br/>NS: redhat-ods-applications]
        PromSA[prometheus-custom<br/>NS: openshift-monitoring]
        NSSSA["namespace-sa<br/>NS: user namespace<br/>(ModelMesh mode)"]
    end

    subgraph "ClusterRole Bindings"
        CRB[odh-model-controller-rolebinding<br/>ClusterRoleBinding]
        LECRB[odh-model-controller-leader-election-rolebinding<br/>RoleBinding<br/>NS: redhat-ods-applications]
        PromRB[prometheus-ns-access<br/>RoleBinding<br/>NS: each InferenceService namespace]
        MMCRB["namespace-prometheus-crb<br/>ClusterRoleBinding<br/>(ModelMesh mode)"]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-model-controller-role<br/>ClusterRole]
        LECR[odh-model-controller-leader-election-role<br/>Role]
        PromCR[prometheus-ns-access<br/>ClusterRole]
        MMCR[prometheus-reader<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        ConfigMaps["core/v1<br/>ConfigMaps<br/>create,get,list,patch,update,watch"]
        Endpoints["core/v1<br/>Endpoints<br/>create,get,list,patch,update,watch"]
        Namespaces["core/v1<br/>Namespaces<br/>create,get,list,patch,update,watch"]
        Pods["core/v1<br/>Pods<br/>create,get,list,patch,update,watch"]
        Secrets["core/v1<br/>Secrets<br/>create,get,list,patch,update,watch"]
        ServiceAccounts["core/v1<br/>ServiceAccounts<br/>create,get,list,patch,update,watch"]
        Services["core/v1<br/>Services<br/>create,get,list,patch,update,watch"]
    end

    subgraph "API Resources - Apps"
        Deployments["apps/v1<br/>Deployments<br/>get,list,delete"]
        StatefulSets["apps/v1<br/>StatefulSets<br/>get,list,delete"]
    end

    subgraph "API Resources - KServe"
        InferenceServices["serving.kserve.io/v1beta1<br/>InferenceServices<br/>InferenceServices/finalizers<br/>get,list,watch"]
        ServingRuntimes["serving.kserve.io/v1alpha1<br/>ServingRuntimes<br/>ServingRuntimes/finalizers<br/>create,delete,get,list,patch,update,watch"]
    end

    subgraph "API Resources - Istio"
        VirtualServices["networking.istio.io<br/>VirtualServices<br/>VirtualServices/finalizers<br/>create,delete,get,list,patch,update,watch"]
        PeerAuth["security.istio.io<br/>PeerAuthentications<br/>create,delete,get,list,patch,update,watch"]
        Telemetries["telemetry.istio.io<br/>Telemetries<br/>create,delete,get,list,patch,update,watch"]
    end

    subgraph "API Resources - Maistra"
        SMM["maistra.io<br/>ServiceMeshMembers<br/>ServiceMeshMembers/finalizers<br/>create,delete,get,list,patch,update,use,watch"]
        SMMR["maistra.io<br/>ServiceMeshMemberRolls<br/>create,delete,get,list,patch,update,use,watch"]
        SMCP["maistra.io<br/>ServiceMeshControlPlanes<br/>create,delete,get,list,patch,update,use,watch"]
    end

    subgraph "API Resources - OpenShift"
        Routes["route.openshift.io<br/>Routes<br/>Routes/custom-host<br/>create,delete,get,list,patch,update,watch"]
        Projects["project.openshift.io<br/>Projects<br/>get"]
    end

    subgraph "API Resources - RBAC"
        CRBs["rbac.authorization.k8s.io<br/>ClusterRoleBindings<br/>create,delete,get,list,patch,update,watch"]
        RBs["rbac.authorization.k8s.io<br/>RoleBindings<br/>create,delete,get,list,patch,update,watch"]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies["networking.k8s.io<br/>NetworkPolicies<br/>create,delete,get,list,patch,update,watch"]
        Ingresses["networking.k8s.io, extensions<br/>Ingresses<br/>get,list,watch"]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors<br/>create,delete,get,list,patch,update,watch"]
        PodMonitors["monitoring.coreos.com<br/>PodMonitors<br/>create,delete,get,list,patch,update,watch"]
    end

    subgraph "API Resources - Leader Election"
        LEConfigMaps["core/v1<br/>ConfigMaps<br/>get,list,watch,create,update,patch"]
        LEEvents["core/v1<br/>Events<br/>create,patch"]
        LELeases["coordination.k8s.io/v1<br/>Leases<br/>get,list,watch,create,update,patch"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LECRB
    PromSA -->|bound via| PromRB
    NSSSA -->|bound via| MMCRB

    %% Bindings to Roles
    CRB -->|grants| CR
    LECRB -->|grants| LECR
    PromRB -->|grants| PromCR
    MMCRB -->|grants| MMCR

    %% Main ClusterRole Permissions
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Endpoints
    CR -->|permissions| Namespaces
    CR -->|permissions| Pods
    CR -->|permissions| Secrets
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Services
    CR -->|permissions| Deployments
    CR -->|permissions| StatefulSets
    CR -->|permissions| InferenceServices
    CR -->|permissions| ServingRuntimes
    CR -->|permissions| VirtualServices
    CR -->|permissions| PeerAuth
    CR -->|permissions| Telemetries
    CR -->|permissions| SMM
    CR -->|permissions| SMMR
    CR -->|permissions| SMCP
    CR -->|permissions| Routes
    CR -->|permissions| Projects
    CR -->|permissions| CRBs
    CR -->|permissions| RBs
    CR -->|permissions| NetworkPolicies
    CR -->|permissions| Ingresses
    CR -->|permissions| ServiceMonitors
    CR -->|permissions| PodMonitors

    %% Leader Election Role Permissions
    LECR -->|permissions| LEConfigMaps
    LECR -->|permissions| LEEvents
    LECR -->|permissions| LELeases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style PromSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NSSSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:3px
    style LECR fill:#f5a623,stroke:#333,stroke-width:2px
    style PromCR fill:#f5a623,stroke:#333,stroke-width:2px
    style MMCR fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB fill:#7ed321,stroke:#333,stroke-width:3px
    style LECRB fill:#7ed321,stroke:#333,stroke-width:2px
    style PromRB fill:#7ed321,stroke:#333,stroke-width:2px
    style MMCRB fill:#7ed321,stroke:#333,stroke-width:2px
    style InferenceServices fill:#e8e8e8,stroke:#333
    style ServingRuntimes fill:#e8e8e8,stroke:#333
