// C4 Context Diagram: Notebooks (Workbench Images)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/notebooks-downstream-z-test.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates notebooks, runs experiments, submits pipelines"

        notebookImages = softwareSystem "Notebooks Workbench Images" "Pre-built Jupyter, code-server, RStudio, and Elyra runtime container images for RHOAI workbenches" {
            jupyterImages = container "Jupyter Notebook Images" "JupyterLab 3.5/3.6 with data science libraries" "Container Image"
            gpuImages = container "GPU-Accelerated Images" "PyTorch 2.0 / TensorFlow 2.13 + CUDA 11.8" "Container Image"
            codeServerImage = container "code-server Image" "VS Code web IDE with NGINX reverse proxy" "Container Image"
            rstudioImage = container "RStudio Image" "RStudio Server workbench" "Container Image"
            runtimeImages = container "Elyra Pipeline Runtimes" "Minimal runtime images for pipeline execution" "Container Image"
            imageStreams = container "ImageStream Manifests" "OpenShift ImageStream definitions with N/N-1/N-2 version tags" "Kustomize/YAML"
            digestUpdater = container "Digest Updater" "Automated image digest update workflow" "GitHub Actions"
        }

        // Internal ODH Systems
        notebookController = softwareSystem "ODH Notebook Controller" "Manages notebook workbench lifecycle, creates pods/routes/oauth-proxy" "Internal ODH"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for managing RHOAI resources" "Internal ODH"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration (Tekton-based)" "Internal ODH"

        // External Systems
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller with TLS edge termination" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authentication provider for workbench access" "External"
        openshiftAPI = softwareSystem "OpenShift API Server" "Kubernetes/OpenShift API for oc CLI access" "External"
        quayRegistry = softwareSystem "quay.io/modh" "Container image registry for notebook images" "External"
        pypi = softwareSystem "PyPI" "Python package registry" "External"
        databases = softwareSystem "Database Servers" "MongoDB, PostgreSQL, MSSQL, Kafka" "External"

        // Relationships
        dataScientist -> notebookImages "Uses workbench via browser" "HTTPS/443"
        notebookController -> imageStreams "Reads ImageStream tags to launch workbench pods"
        dashboard -> imageStreams "Reads annotations to display image catalog"
        jupyterImages -> dsPipelines "Submits pipelines via Elyra" "HTTPS/443"
        runtimeImages -> dsPipelines "Executes pipeline steps"
        digestUpdater -> quayRegistry "Fetches latest image digests" "HTTPS/443"
        digestUpdater -> imageStreams "Updates image digest references"

        notebookImages -> openshiftAPI "oc CLI commands from notebooks" "HTTPS/443"
        notebookImages -> pypi "pip install packages" "HTTPS/443"
        notebookImages -> databases "Database queries from notebooks" "TCP various ports"

        notebookController -> openshiftRouter "Creates Routes for workbenches"
        notebookController -> openshiftOAuth "Configures oauth-proxy sidecar"
    }

    views {
        systemContext notebookImages "SystemContext" {
            include *
            autoLayout
        }

        container notebookImages "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #5ba8f7
                color #ffffff
            }
        }
    }
}
