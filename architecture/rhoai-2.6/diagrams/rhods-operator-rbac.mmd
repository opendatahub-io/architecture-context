graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: redhat-ods-operator]
        SA_Prometheus[prometheus<br/>Namespace: redhat-ods-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[controller-manager-role-binding<br/>Scope: Cluster]
        CRB_PromCluster[prometheus-cluster-monitor<br/>Scope: Cluster]
    end

    subgraph "Role Bindings (Namespace)"
        RB_Leader[leader-election-role-binding<br/>Namespace: redhat-ods-operator]
        RB_Prom[prometheus-scraper<br/>Namespace: redhat-ods-monitoring]
    end

    subgraph "ClusterRole: controller-manager-role"
        CR_Controller[controller-manager-role]

        subgraph "RHOAI CRDs - Full Control"
            Perm_DSC["datasciencecluster.opendatahub.io/*<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_DSCI["dscinitialization.opendatahub.io/*<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_Features["features.opendatahub.io/*<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph "Core Resources - Full Control"
            Perm_Core["core: secrets, configmaps,<br/>serviceaccounts, namespaces<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_Apps["apps: deployments, statefulsets,<br/>replicasets<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph "RBAC - Full Control"
            Perm_RBAC["rbac.authorization.k8s.io:<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>Verbs: * (all)"]
        end

        subgraph "OpenShift Resources - Full Control"
            Perm_Routes["route.openshift.io: routes<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_OAuth["oauth.openshift.io: oauthclients<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_SCC["security.openshift.io:<br/>securitycontextconstraints<br/>(anyuid, restricted)<br/>Verbs: * (all)"]
        end

        subgraph "Networking - Full Control"
            Perm_NetPol["networking.k8s.io: networkpolicies<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph "Monitoring - Full Control"
            Perm_Monitoring["monitoring.coreos.com:<br/>servicemonitors, podmonitors,<br/>prometheusrules<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph "Component CRDs - Full Control"
            Perm_KServe["serving.kserve.io:<br/>inferenceservices, servingruntimes,<br/>clusterservingruntimes<br/>Verbs: create, delete, list,<br/>patch, update, watch"]
            Perm_Knative["serving.knative.dev: services<br/>operator.knative.dev: knativeservings<br/>Verbs: * (all)"]
            Perm_ServiceMesh["maistra.io: servicemeshcontrolplanes,<br/>servicemeshmemberrolls, servicemeshmembers<br/>Verbs: create, get, list, patch,<br/>update, use, watch"]
            Perm_Istio["networking.istio.io:<br/>gateways, virtualservices<br/>Verbs: * (all)"]
            Perm_Ray["ray.io: rayclusters, rayjobs,<br/>rayservices<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_Kubeflow["kubeflow.org: *<br/>Verbs: * (all)"]
            Perm_Tekton["tekton.dev: *<br/>Verbs: * (all)"]
            Perm_TrustyAI["trustyai.opendatahub.io:<br/>trustyaiservices<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
            Perm_DSP["datasciencepipelinesapplications<br/>.opendatahub.io:<br/>datasciencepipelinesapplications<br/>Verbs: create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph "CRD Management"
            Perm_CRD["apiextensions.k8s.io:<br/>customresourcedefinitions<br/>Verbs: create, delete, get, list,<br/>patch, watch"]
        end

        CR_Controller --- Perm_DSC
        CR_Controller --- Perm_DSCI
        CR_Controller --- Perm_Features
        CR_Controller --- Perm_Core
        CR_Controller --- Perm_Apps
        CR_Controller --- Perm_RBAC
        CR_Controller --- Perm_Routes
        CR_Controller --- Perm_OAuth
        CR_Controller --- Perm_SCC
        CR_Controller --- Perm_NetPol
        CR_Controller --- Perm_Monitoring
        CR_Controller --- Perm_KServe
        CR_Controller --- Perm_Knative
        CR_Controller --- Perm_ServiceMesh
        CR_Controller --- Perm_Istio
        CR_Controller --- Perm_Ray
        CR_Controller --- Perm_Kubeflow
        CR_Controller --- Perm_Tekton
        CR_Controller --- Perm_TrustyAI
        CR_Controller --- Perm_DSP
        CR_Controller --- Perm_CRD
    end

    subgraph "ClusterRole: cluster-monitoring-view"
        CR_MonView[cluster-monitoring-view<br/>Read-only cluster metrics]
    end

    subgraph "Role: leader-election-role"
        R_Leader[leader-election-role<br/>Namespace: redhat-ods-operator<br/>Resources: leases, configmaps<br/>Verbs: get, create, update]
    end

    subgraph "Role: rhods-prometheus-role"
        R_Prom[rhods-prometheus-role<br/>Namespace: redhat-ods-monitoring<br/>Resources: endpoints, services, pods<br/>Verbs: get, list, watch]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Controller

    SA_Prometheus -->|bound via| CRB_PromCluster
    CRB_PromCluster -->|grants| CR_MonView

    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    SA_Prometheus -->|bound via| RB_Prom
    RB_Prom -->|grants| R_Prom

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Prometheus fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CRB_Controller fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_PromCluster fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style RB_Prom fill:#f5a623,stroke:#333,stroke-width:2px

    style CR_Controller fill:#7ed321,stroke:#333,stroke-width:3px
    style CR_MonView fill:#7ed321,stroke:#333,stroke-width:2px
    style R_Leader fill:#7ed321,stroke:#333,stroke-width:2px
    style R_Prom fill:#7ed321,stroke:#333,stroke-width:2px

    style Perm_DSC fill:#d5e8d4,stroke:#82b366
    style Perm_DSCI fill:#d5e8d4,stroke:#82b366
    style Perm_Features fill:#d5e8d4,stroke:#82b366
    style Perm_Core fill:#dae8fc,stroke:#6c8ebf
    style Perm_Apps fill:#dae8fc,stroke:#6c8ebf
    style Perm_RBAC fill:#f8cecc,stroke:#b85450
    style Perm_Routes fill:#ffe6cc,stroke:#d79b00
    style Perm_OAuth fill:#ffe6cc,stroke:#d79b00
    style Perm_SCC fill:#f8cecc,stroke:#b85450
    style Perm_NetPol fill:#dae8fc,stroke:#6c8ebf
    style Perm_Monitoring fill:#e1d5e7,stroke:#9673a6
