// ODH Dashboard - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/odh-dashboard.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates notebooks, manages projects, deploys models"
        platformAdmin = person "Platform Admin" "Configures cluster settings, manages groups and accelerators"

        odhDashboard = softwareSystem "ODH Dashboard" "Web-based dashboard for managing Open Data Hub / RHOAI platform resources" {
            oauthProxy = container "oauth-proxy" "OpenShift OAuth authentication proxy with TLS termination" "ose-oauth-proxy sidecar" "Sidecar"
            backend = container "Dashboard Backend" "REST API server, K8s API proxy, WebSocket proxy, CRD watcher" "Node.js / Fastify"
            frontend = container "Dashboard Frontend" "Single-page application for managing data science resources" "React / PatternFly 5"
            wsProxy = container "WebSocket Proxy" "Proxies WebSocket connections to K8s API for real-time resource watching" "Node.js"
            resourceWatchers = container "Resource Watchers" "Background watchers for CRDs (applications, documents, quickstarts, config)" "Node.js"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for all resource operations" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "OpenShift identity provider and OAuth server" "External"
        thanosQuerier = softwareSystem "Thanos Querier" "Prometheus metrics aggregation (openshift-monitoring)" "External"
        notebookController = softwareSystem "ODH Notebook Controller" "Manages Jupyter notebook pod lifecycle" "Internal ODH"
        kserve = softwareSystem "KServe / ModelMesh" "Model serving runtime management" "Internal ODH"
        dsc = softwareSystem "DataScienceCluster" "Cluster-level data science configuration" "Internal ODH"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager for checking operator availability" "External"
        openshiftConsole = softwareSystem "OpenShift Console" "Cluster console for branding config and console links" "External"

        // User interactions
        dataScientist -> odhDashboard "Manages notebooks, projects, model serving via browser"
        platformAdmin -> odhDashboard "Configures cluster settings, accelerator profiles, admin groups"

        // Container-level interactions
        dataScientist -> oauthProxy "HTTPS/443 via OpenShift Route (TLS reencrypt)"
        platformAdmin -> oauthProxy "HTTPS/443 via OpenShift Route (TLS reencrypt)"
        oauthProxy -> openshiftOAuth "OAuth2 authentication" "HTTPS/443"
        oauthProxy -> backend "Forwards requests with access token" "HTTP/8080"
        backend -> frontend "Serves static SPA assets" "HTTP"
        backend -> wsProxy "Handles WebSocket upgrade" "WS/8080"
        backend -> resourceWatchers "Provides cached CRD state"

        // External integrations
        backend -> k8sAPI "All resource CRUD, CRD operations" "HTTPS/443"
        wsProxy -> k8sAPI "WebSocket watch streams" "WSS/443"
        resourceWatchers -> k8sAPI "Watch CRDs (OdhApplication, OdhDocument, OdhQuickStart, OdhDashboardConfig, AcceleratorProfile)" "HTTPS/443"
        backend -> thanosQuerier "PVC, bias, model serving metric queries" "HTTPS/9092"

        // Internal ODH integrations
        odhDashboard -> notebookController "Creates/manages kubeflow.org/Notebook CRs" "HTTPS/443 (via K8s API)"
        odhDashboard -> kserve "Manages serving.kserve.io/ServingRuntime CRs" "HTTPS/443 (via K8s API)"
        odhDashboard -> dsc "Reads DataScienceCluster status" "HTTPS/443 (via K8s API)"
        odhDashboard -> olm "Checks operator availability (e.g., Pipelines)" "HTTPS/443 (via K8s API)"
        odhDashboard -> openshiftConsole "Reads branding config, ConsoleLinks" "HTTPS/443 (via K8s API)"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Sidecar" {
                background #e8a838
                color #ffffff
            }
        }
    }
}
