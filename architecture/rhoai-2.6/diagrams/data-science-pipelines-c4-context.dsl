// Data Science Pipelines (KFP-Tekton) - C4 Context Diagram
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates, uploads, and manages ML pipelines and runs"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines with Tekton backend for building, deploying, and managing portable ML workflows on OpenShift" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API server for pipeline, run, experiment, job management" "Go Service" "8888/HTTP, 8887/gRPC"
            persistenceAgent = container "Persistence Agent" "Watches Tekton PipelineRuns and persists status to API server" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages ScheduledWorkflow CRDs to create PipelineRuns on schedule" "Go Controller"
            pipelineUI = container "ds-pipeline-ui" "Web UI for pipeline management with oauth-proxy sidecar" "React/TypeScript" "8443/HTTPS"
            viewerController = container "Viewer Controller" "Reconciles Viewer CRDs, creates TensorBoard instances" "Go Controller (controller-runtime)"
            vizServer = container "Visualization Server" "Generates visualizations from pipeline output artifacts" "Python Service" "8888/HTTP"
            metadataGRPC = container "ML Metadata Server" "Artifact lineage tracking via gRPC" "gRPC Service" "8080/gRPC"
            metadataEnvoy = container "Metadata Envoy Proxy" "gRPC-Web proxy fronting MLMD gRPC service" "Envoy" "9090/gRPC-Web"
            metadataWriter = container "Metadata Writer" "Writes pipeline execution metadata to MLMD" "Python Service"
            cacheServer = container "Cache Server" "Mutating admission webhook for pipeline step caching" "Go Webhook" "443/HTTPS"
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine (replaces Argo)" "External"
        mysql = softwareSystem "MySQL/MariaDB" "Pipeline metadata and run status storage" "External"
        minio = softwareSystem "MinIO/S3" "Pipeline artifact and log storage" "External"
        openShiftOAuth = softwareSystem "OpenShift OAuth" "User authentication via oauth-proxy sidecar" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "Integration tile for Data Science Pipelines" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "External"
        seldon = softwareSystem "Seldon Core" "ML model deployment from pipelines" "External"
        istio = softwareSystem "Istio Service Mesh" "Multi-user mode access control (optional)" "External"
        k8sAPI = softwareSystem "Kubernetes API" "CRD management, pod operations" "External"

        // User interactions
        user -> dsp "Creates and manages pipelines via UI or SDK"
        user -> pipelineUI "Accesses pipeline UI" "HTTPS/443 via OpenShift Route"

        // Internal flows
        pipelineUI -> apiServer "Calls pipeline APIs" "HTTP/8888"
        persistenceAgent -> apiServer "Reports PipelineRun status" "HTTP/8888"
        metadataWriter -> metadataGRPC "Writes execution metadata" "gRPC/8080"
        metadataEnvoy -> metadataGRPC "Proxies gRPC-Web requests" "gRPC/8080"

        // External dependencies
        apiServer -> tekton "Creates and manages PipelineRuns" "HTTPS/443"
        apiServer -> mysql "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores pipeline artifacts" "HTTP/9000"
        apiServer -> k8sAPI "CRD management, pod operations" "HTTPS/443"
        persistenceAgent -> k8sAPI "Watches PipelineRuns" "HTTPS/443"
        scheduledWorkflow -> k8sAPI "Watches ScheduledWorkflows, creates PipelineRuns" "HTTPS/443"
        metadataGRPC -> mysql "Stores artifact metadata" "MySQL/3306"
        pipelineUI -> openShiftOAuth "User authentication" "HTTPS/8443"
        odhDashboard -> dsp "Shows integration tile" "OdhApplication CR"
        prometheus -> apiServer "Scrapes metrics" "HTTP/8888 /metrics"
        dsp -> seldon "Deploys models from pipelines" "CRD"
        dsp -> istio "Multi-user access control" "AuthorizationPolicy/mTLS"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
