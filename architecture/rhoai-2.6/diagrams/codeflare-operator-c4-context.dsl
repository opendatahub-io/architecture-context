// CodeFlare Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed AI/ML workloads via AppWrapper CRs"

        codeflarOperator = softwareSystem "CodeFlare Operator" "Meta-operator embedding MCAD and InstaScale controllers for distributed AI/ML workload scheduling and cluster auto-scaling" {
            manager = container "codeflare-operator manager" "Single Go binary embedding MCAD and InstaScale controllers" "Go Binary (controller-runtime)"
            mcadController = container "MCAD Queue Controller" "Manages AppWrapper scheduling, queuing, dispatching, and quota enforcement" "Embedded Controller (mcad.NewJobController)"
            instascaleController = container "InstaScale Controller" "Watches AppWrappers and auto-scales cluster via OpenShift Machine API" "Embedded Controller (optional)"
            config = container "codeflare-operator-config" "Operator configuration including MCAD settings, InstaScale settings" "ConfigMap"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        machineAPI = softwareSystem "OpenShift Machine API" "Machine lifecycle management for cluster auto-scaling" "External"
        kuberay = softwareSystem "KubeRay Operator" "Manages RayCluster CRs for distributed Ray workloads" "Internal ODH"
        odhOperator = softwareSystem "ODH / RHODS Operator" "Deploys and manages CodeFlare Operator lifecycle" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        cloudProvider = softwareSystem "Cloud Provider" "AWS/Azure/GCP compute infrastructure" "External"

        // User interactions
        user -> codeflarOperator "Creates AppWrapper CRs via kubectl/SDK"

        // Operator internal relationships
        manager -> mcadController "Starts MCAD controller"
        manager -> instascaleController "Optionally starts InstaScale controller"
        manager -> config "Reads configuration"

        // External integrations
        mcadController -> k8sAPI "Watches/manages AppWrappers, creates Pods, Services, Deployments" "HTTPS/443"
        instascaleController -> k8sAPI "Watches AppWrappers, reads Nodes" "HTTPS/443"
        instascaleController -> machineAPI "Creates/deletes MachineSets for auto-scaling" "HTTPS/443"
        machineAPI -> cloudProvider "Provisions compute nodes" "HTTPS/443"
        mcadController -> kuberay "Dispatches RayCluster CRs embedded in AppWrappers" "CRD"
        odhOperator -> codeflarOperator "Deploys via DataScienceCluster CR codeflare component"
        prometheus -> codeflarOperator "Scrapes metrics" "HTTP/8080"
    }

    views {
        systemContext codeflarOperator "SystemContext" {
            include *
            autoLayout
        }

        container codeflarOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
