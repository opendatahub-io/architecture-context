graph TD
    subgraph "Service Accounts"
        SA_Operator[kuberay-operator<br/>Namespace: opendatahub]
        SA_APIServer[kuberay-apiserver<br/>Namespace: ray-system<br/>OPTIONAL]
        SA_RayCluster["&lt;raycluster&gt;-sa<br/>Namespace: &lt;user-namespace&gt;<br/>Auto-created"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[kuberay-operator<br/>ClusterRoleBinding]
        CRB_APIServer[kuberay-apiserver<br/>ClusterRoleBinding<br/>OPTIONAL]
    end

    subgraph "ClusterRoles"
        CR_Operator[kuberay-operator<br/>ClusterRole]
        CR_APIServer[kuberay-apiserver<br/>ClusterRole<br/>OPTIONAL]
    end

    subgraph "API Resources - ray.io"
        direction TB
        RayCluster_API["RayCluster<br/>ray.io/v1"]
        RayJob_API["RayJob<br/>ray.io/v1"]
        RayService_API["RayService<br/>ray.io/v1"]
        Status_API["Status Subresources<br/>rayclusters/status<br/>rayjobs/status<br/>rayservices/status"]
        Finalizers_API["Finalizers<br/>rayclusters/finalizers<br/>rayjobs/finalizers<br/>rayservices/finalizers"]
    end

    subgraph "API Resources - Core"
        direction TB
        Pods[Pods<br/>core/v1]
        Services[Services<br/>core/v1]
        Events[Events<br/>core/v1]
        SvcAccounts[ServiceAccounts<br/>core/v1]
        ConfigMaps[ConfigMaps<br/>core/v1]
        Namespaces[Namespaces<br/>core/v1]
    end

    subgraph "API Resources - Other"
        direction TB
        Jobs[Jobs<br/>batch/v1]
        Roles[Roles<br/>rbac.authorization.k8s.io]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
        Ingresses[Ingresses<br/>networking.k8s.io/v1]
        Routes[Routes<br/>route.openshift.io/v1]
        Leases[Leases<br/>coordination.k8s.io/v1]
    end

    %% Service Account to Bindings
    SA_Operator -->|bound via| CRB_Operator
    SA_APIServer -.->|bound via| CRB_APIServer

    %% Bindings to Roles
    CRB_Operator -->|grants| CR_Operator
    CRB_APIServer -.->|grants| CR_APIServer

    %% Operator Permissions - Ray CRDs
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| RayCluster_API
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| RayJob_API
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| RayService_API
    CR_Operator -->|get,patch,update| Status_API
    CR_Operator -->|update| Finalizers_API

    %% Operator Permissions - Core Resources
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Pods
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Services
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Events
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| SvcAccounts

    %% Operator Permissions - Other Resources
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Jobs
    CR_Operator -->|create,delete,get,list<br/>update,watch| Roles
    CR_Operator -->|create,delete,get,list<br/>update,watch| RoleBindings
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Ingresses
    CR_Operator -->|create,delete,get,list<br/>patch,update,watch| Routes
    CR_Operator -->|create,get,list,update| Leases

    %% APIServer Permissions
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| RayCluster_API
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| RayJob_API
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| RayService_API
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| ConfigMaps
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| Namespaces
    CR_APIServer -.->|create,delete,get,list<br/>patch,update,watch| Events

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#e74c3c,stroke:#333,stroke-width:2px
    classDef resource fill:#7ed321,stroke:#333,stroke-width:2px
    classDef optional fill:#9b59b6,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5

    class SA_Operator,SA_APIServer,SA_RayCluster serviceaccount
    class CRB_Operator,CRB_APIServer binding
    class CR_Operator,CR_APIServer role
    class RayCluster_API,RayJob_API,RayService_API,Status_API,Finalizers_API resource
    class Pods,Services,Events,SvcAccounts,ConfigMaps,Namespaces resource
    class Jobs,Roles,RoleBindings,Ingresses,Routes,Leases resource
    class SA_APIServer,CRB_APIServer,CR_APIServer optional

    %% OpenShift SCC
    subgraph "OpenShift Security Context Constraints"
        SCC[run-as-ray-user<br/>MustRunAs UID 1000]
    end

    SA_RayCluster -.->|uses| SCC

    style SCC fill:#cc0000,stroke:#333,stroke-width:2px
