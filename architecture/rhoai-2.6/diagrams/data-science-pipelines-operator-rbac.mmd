        RB_Leader[RoleBinding:<br/>leader-election-rolebinding]
        R_Leader[Role:<br/>leader-election-role]
    end

    subgraph "DSPA Namespace RBAC"
        SA_API[ServiceAccount:<br/>ds-pipeline-NAME]
        SA_Runner[ServiceAccount:<br/>pipeline-runner-NAME]
