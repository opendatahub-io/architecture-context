        R_PA[Role:<br/>ds-pipeline-persistenceagent-NAME]
        R_SWC[Role:<br/>ds-pipeline-scheduledworkflow-NAME]
        R_MLMD[Role:<br/>ds-pipeline-metadata-writer-NAME]
    end

    subgraph "ClusterRole: manager-role Permissions"
        direction TB
        Perm1[datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>Verbs: create, delete, get, list, patch, update, watch]
        Perm2[apps, extensions<br/>deployments, replicasets<br/>Verbs: * all]
        Perm3[Core API<br/>configmaps, secrets, services, pods, events<br/>Verbs: create, delete, get, list, patch, update, watch]
        Perm4[rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles, clusterrolebindings<br/>Verbs: create, delete, get, list, update, watch, patch]
        Perm5[route.openshift.io<br/>routes<br/>Verbs: create, delete, get, list, patch, update, watch]
        Perm6[tekton.dev, custom.tekton.dev<br/>All Tekton resources<br/>Verbs: * all]
        Perm7[networking.k8s.io<br/>networkpolicies<br/>Verbs: create, delete, get, list, patch, update, watch]
        Perm8[monitoring.coreos.com<br/>servicemonitors<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "Role: ds-pipeline-NAME Permissions"
        direction TB
        PermAPI1[tekton.dev<br/>tasks, pipelineruns, taskruns, conditions, runs, customruns<br/>Verbs: create, delete, get, list, watch, update, patch]
        PermAPI2[custom.tekton.dev<br/>pipelineloops<br/>Verbs: create, delete, get, list, watch, update, patch]
        PermAPI3[argoproj.io<br/>workflows<br/>Verbs: create, delete, get, list, watch, update, patch]
    end

    subgraph "Role: pipeline-runner-NAME Permissions"
        direction TB
        PermRunner1[tekton.dev<br/>pipelineruns, taskruns, runs, customruns<br/>Verbs: create, delete, get, list, watch, update, patch]
        PermRunner2[Core API<br/>pods, pods/log<br/>Verbs: get, list, watch]
    end

    subgraph "Aggregate ClusterRole"
        CR_Aggregate[ClusterRole:<br/>aggregate-dspa-admin-edit]
        PermAgg[datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>Verbs: get, list, watch, create, update, patch, delete]
    end

    %% Operator RBAC Bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -.->|permissions| Perm1
    CR_Manager -.->|permissions| Perm2
    CR_Manager -.->|permissions| Perm3
    CR_Manager -.->|permissions| Perm4
    CR_Manager -.->|permissions| Perm5
    CR_Manager -.->|permissions| Perm6
    CR_Manager -.->|permissions| Perm7
    CR_Manager -.->|permissions| Perm8

    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% DSPA Namespace Bindings
    SA_API -->|bound via| RB_API
    RB_API -->|grants| R_API
    R_API -.->|permissions| PermAPI1
    R_API -.->|permissions| PermAPI2
    R_API -.->|permissions| PermAPI3

    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -.->|permissions| PermRunner1
    R_Runner -.->|permissions| PermRunner2

    SA_UI -->|bound via| RB_UI
    RB_UI -->|grants| R_UI

    SA_PA -->|bound via| RB_PA
    RB_PA -->|grants| R_PA

    SA_SWC -->|bound via| RB_SWC
    RB_SWC -->|grants| R_SWC

    SA_MLMD -->|bound via| RB_MLMD
    RB_MLMD -->|grants| R_MLMD

    %% Aggregate Role
    CR_Aggregate -.->|aggregates to| PermAgg

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef clusterrole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef role fill:#ffcc80,stroke:#333,stroke-width:2px,color:#000
    classDef binding fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef permission fill:#e1bee7,stroke:#333,stroke-width:1px,color:#000

    class SA_Controller,SA_API,SA_Runner,SA_UI,SA_PA,SA_SWC,SA_MLMD serviceaccount
    class CR_Manager,CR_Aggregate clusterrole
    class R_Leader,R_API,R_Runner,R_UI,R_PA,R_SWC,R_MLMD role
    class CRB_Manager,RB_Leader,RB_API,RB_Runner,RB_UI,RB_PA,RB_SWC,RB_MLMD binding
    class Perm1,Perm2,Perm3,Perm4,Perm5,Perm6,Perm7,Perm8,PermAPI1,PermAPI2,PermAPI3,PermRunner1,PermRunner2,PermAgg permission
