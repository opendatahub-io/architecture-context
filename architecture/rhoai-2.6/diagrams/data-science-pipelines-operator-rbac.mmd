        RB_Runner[RoleBinding:<br/>pipeline-runner-NAME]
        RB_UI[RoleBinding:<br/>ds-pipeline-ui-NAME-binding]
        RB_PA[RoleBinding:<br/>ds-pipeline-persistenceagent-NAME]
        RB_SWC[RoleBinding:<br/>ds-pipeline-scheduledworkflow-NAME]
        RB_MLMD[RoleBinding:<br/>ds-pipeline-metadata-writer-NAME]

