// C4 Context Diagram - odh-manifests
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/odh-manifests.md

workspace {
    model {
        // Users
        dataScientist = person "Data Scientist" "Creates notebooks, deploys models, runs pipelines"
        mlEngineer = person "ML Engineer" "Configures model serving and pipelines"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform configuration"

        // Main System
        odhManifests = softwareSystem "ODH Manifests (RHOAI 2.6)" "Kustomize manifest collection defining deployment configuration for all RHOAI platform components" {
            dashboard = container "odh-dashboard" "Web UI with OAuth proxy for RHOAI platform management" "Go + oauth-proxy"
            notebookController = container "odh-notebook-controller" "Manages Notebook CRs, creates Routes and oauth-proxy per notebook" "Go Operator"
            kfNotebookController = container "kf-notebook-controller" "Kubeflow Notebook controller managing StatefulSets" "Go Operator"
            dspo = container "data-science-pipelines-operator" "Manages DataSciencePipelinesApplication CRs" "Go Operator"
            modelMesh = container "model-mesh (odh-modelmesh-controller)" "ModelMesh controller for model serving with InferenceService, ServingRuntime, Predictor CRs" "Go Operator"
            odhModelController = container "odh-model-controller" "Manages InferenceService routing via Istio VirtualServices" "Go Operator"
            kserve = container "kserve" "KServe controller for serverless ML inference" "Go Operator"
            trustyai = container "trustyai-service-operator" "TrustyAI operator for model explainability and fairness" "Go Operator"
            codeflare = container "codeflare-stack" "MCAD + CodeFlare for distributed training with Ray" "Go Operator"
            ray = container "ray (KubeRay)" "KubeRay operator for managing Ray clusters, jobs, services" "Go Operator"
            monitoring = container "monitoring" "Prometheus, Alertmanager, blackbox-exporter, Segment telemetry" "Prometheus Stack"
        }

        // External Dependencies
        openshift = softwareSystem "OpenShift Container Platform" "Platform runtime providing Routes, OAuth, image streams, API server" "External"
        kustomize = softwareSystem "Kustomize" "Manifest rendering and overlay composition engine" "External"
        kfdefOperator = softwareSystem "KfDef / rhods-operator" "Consumes odh-manifests to deploy components via KfDef CRs" "External"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for model serving traffic management" "External"
        tekton = softwareSystem "Tekton / OpenShift Pipelines" "Pipeline execution backend for DSPO" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management for webhooks" "External"
        strimzi = softwareSystem "Strimzi Kafka Operator" "Kafka cluster management (optional)" "External"
        segmentAnalytics = softwareSystem "Segment Analytics" "Platform usage telemetry collection" "External"
        containerRegistries = softwareSystem "Container Registries" "Image pulling for notebook/model containers" "External"

        // Relationships - Users
        dataScientist -> dashboard "Accesses via browser" "HTTPS/443 OpenShift OAuth"
        dataScientist -> notebookController "Creates Notebooks" "via Dashboard UI"
        mlEngineer -> modelMesh "Deploys models" "InferenceService CR"
        mlEngineer -> dspo "Configures pipelines" "DataSciencePipelinesApplication CR"
        platformAdmin -> dashboard "Manages platform" "HTTPS/443 OpenShift OAuth"

        // Relationships - Internal
        dashboard -> openshift "Auth via OAuth, API access" "HTTPS/6443 SA Token"
        notebookController -> openshift "Creates Routes, oauth-proxy" "HTTPS/6443 SA Token"
        kfNotebookController -> openshift "Creates StatefulSets" "HTTPS/6443 SA Token"
        dspo -> tekton "Pipeline execution" "Tekton CRD API"
        odhModelController -> istio "Creates VirtualServices" "HTTPS/6443 SA Token"
        modelMesh -> openshift "Manages deployments" "HTTPS/6443 SA Token"
        kserve -> openshift "Manages inference services" "HTTPS/6443 SA Token"
        trustyai -> openshift "Manages TrustyAI services" "HTTPS/6443 SA Token"
        codeflare -> ray "Distributed training" "Ray API"
        monitoring -> segmentAnalytics "Usage telemetry" "HTTPS/443 API Key"
        monitoring -> dashboard "Scrapes metrics" "HTTP/8080"
        monitoring -> modelMesh "Scrapes metrics" "HTTPS/8443"
        monitoring -> dspo "Scrapes metrics" "HTTP/8080"

        // Relationships - External
        kfdefOperator -> odhManifests "Consumes manifests" "KfDef CR"
        odhManifests -> kustomize "Rendered by" "Kustomize overlays"
        odhManifests -> containerRegistries "Pulls images" "HTTPS/443 Pull Secret"
    }

    views {
        systemContext odhManifests "SystemContext" {
            include *
            autoLayout
        }

        container odhManifests "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
