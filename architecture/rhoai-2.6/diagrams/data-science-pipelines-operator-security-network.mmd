%% Data Science Pipelines Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Dashboard Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS Reencrypt"]
    end

    subgraph OAuthBoundary["OAUTH BOUNDARY"]
        OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS: service-serving-cert<br/>AuthZ: SAR check on Route"]
    end

    subgraph AppLayer["APPLICATION LAYER (NetworkPolicy Protected)"]
        direction TB

        subgraph APISvc["API Server Pod"]
            APIServer["DS Pipeline API Server<br/>REST: 8888/TCP HTTP<br/>gRPC: 8887/TCP<br/>NetworkPolicy: DSPA + monitoring only"]
        end

        subgraph DataStores["Data Stores"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>Auth: Password<br/>Secret: ds-pipeline-db-{name}"]
            Minio["Minio<br/>9000/TCP S3 HTTP<br/>Auth: AccessKey/SecretKey<br/>Secret: mlpipeline-minio-artifact"]
        end

        subgraph Processing["Processing Components"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent"]
            SW["Scheduled Workflow<br/>SA: ds-pipeline-scheduledworkflow"]
        end

        subgraph MLMDZone["MLMD Zone"]
            Envoy["MLMD Envoy Proxy<br/>9090/TCP gRPC<br/>NetworkPolicy: dashboard + DSPA only"]
            MLMDServer["MLMD gRPC Server<br/>8080/TCP gRPC"]
            MLMDWriter["MLMD Writer"]
        end
    end

    subgraph InternalIntegrations["INTERNAL INTEGRATIONS"]
        Dashboard["ODH Dashboard"]
        Monitoring["OpenShift Monitoring<br/>Namespaces: openshift-user-workload-monitoring<br/>redhat-ods-monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount token"]
        Tekton["Tekton Pipelines<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount"]
        ExtDB["External Database<br/>3306/TCP MySQL<br/>TLS + CA bundle<br/>Auth: Username/Password"]
        ExtS3["External S3 Storage<br/>443/TCP HTTPS<br/>TLS + CA bundle<br/>Auth: AccessKey or IAM"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>OAuth token"| Router
    Router -->|"HTTPS/8443<br/>TLS reencrypt"| OAuthProxy
    OAuthProxy -->|"HTTP/8888<br/>plaintext (localhost)<br/>No auth"| APIServer

    %% Internal data flows
    APIServer -->|"MySQL/3306<br/>plaintext<br/>Password"| MariaDB
    APIServer -->|"S3/9000<br/>HTTP<br/>AccessKey/SecretKey"| Minio
    PA -->|"HTTP/8888<br/>plaintext"| APIServer
    Envoy -->|"gRPC/8080<br/>plaintext"| MLMDServer
    MLMDWriter -->|"gRPC/8080"| MLMDServer
    MLMDServer -->|"MySQL/3306<br/>Password"| MariaDB

    %% Internal integrations
    Dashboard -->|"gRPC/9090<br/>plaintext<br/>NetworkPolicy"| Envoy
    Monitoring -->|"HTTP/8888,8887<br/>plaintext<br/>ServiceMonitor"| APIServer

    %% Egress
    APIServer -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| Tekton
    APIServer -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    APIServer -.->|"MySQL/3306<br/>TLS + CA"| ExtDB
    APIServer -.->|"HTTPS/443<br/>TLS + CA"| ExtS3

