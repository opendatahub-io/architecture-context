graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Router["OpenShift Router<br/>443/TCP"]
        Route["ds-pipeline Route<br/>8443/TCP HTTPS<br/>Reencrypt TLS 1.2+"]
    end

    subgraph AppLayer["APPLICATION LAYER (Namespace: USER_NAMESPACE)"]
        direction TB

        subgraph APIServerPod["API Server Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+ Service CA<br/>Auth: Bearer Token JWT"]
            APIServer["DSP API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>SA: ds-pipeline-NAME"]
        end

        subgraph Storage["Data Storage"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>No encryption<br/>Auth: DB credentials"]
            Minio["Minio<br/>9000/TCP HTTP<br/>No encryption<br/>Auth: S3 credentials"]
        end

        subgraph Controllers["Controller Components"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-NAME"]
            SWC["Scheduled Workflow Controller<br/>SA: ds-pipeline-scheduledworkflow-NAME"]
        end

        subgraph MLMDComponents["MLMD Components (Optional)"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP gRPC<br/>No encryption<br/>Auth: Network Policy"]
            MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC<br/>No encryption<br/>Auth: None"]
            MLMDWriter["MLMD Writer<br/>SA: ds-pipeline-metadata-writer-NAME"]
        end

        subgraph UI["UI Component (Optional)"]
            MLUI["ML Pipelines UI<br/>8443/TCP HTTPS<br/>OAuth Proxy"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        Tekton["Tekton API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        ExternalDB["External Database<br/>MySQL/PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+ optional<br/>Auth: DB credentials"]
        ExternalS3["External S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM/S3 keys"]
    end

    subgraph ODH["ODH NAMESPACE"]
        Dashboard["ODH Dashboard<br/>app=odh-dashboard"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| Router
    Router -->|HTTPS/8443<br/>Reencrypt<br/>Service CA cert| Route

    %% Ingress to Application
    Route -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| OAuthProxy
    OAuthProxy -->|HTTP/8888<br/>Localhost<br/>Verified| APIServer

    %% API Server to Storage
    APIServer -->|MySQL/3306<br/>No encryption<br/>Secret: mariadb-NAME| MariaDB
    APIServer -->|HTTP/9000 or HTTPS/443<br/>Secret: storage credentials| Minio

    %% API Server to Tekton
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| Tekton

    %% Persistence Agent Flows
    PA -->|HTTPS/443<br/>TLS 1.2+<br/>Watch PipelineRuns| Tekton
    PA -->|HTTP/8888<br/>TLS internal<br/>ServiceAccount auth| APIServer
    PA -->|MySQL/3306<br/>DB credentials| MariaDB
    PA -->|HTTP or HTTPS/9000 or 443<br/>Archive artifacts| Minio

    %% Scheduled Workflow Flows
    SWC -->|HTTPS/443<br/>TLS 1.2+<br/>Create PipelineRuns| Tekton
    SWC -->|HTTP/8888<br/>TLS internal<br/>ServiceAccount auth| APIServer

    %% MLMD Flows
    Dashboard -->|gRPC/9090<br/>No encryption<br/>Network Policy| MLMDEnvoy
    MLMDEnvoy -->|gRPC/8080<br/>Internal proxy| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>DB credentials| MariaDB
    MLMDWriter -->|gRPC/8080<br/>No auth| MLMDgRPC
    MLMDWriter -->|HTTPS/443<br/>Watch Tekton| Tekton

    %% External Services (optional)
    APIServer -.->|MySQL/PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+ optional<br/>Secret: db credentials| ExternalDB
    APIServer -.->|HTTPS/443<br/>TLS 1.2+<br/>Secret: S3/IAM creds| ExternalS3

    %% Dashboard to UI
    Dashboard -.->|HTTPS/8443<br/>OAuth| MLUI

    %% Network Policy Annotations
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef odh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Router,Route ingress
    class OAuthProxy,APIServer,PA,SWC,MLMDEnvoy,MLMDgRPC,MLMDWriter,MLUI application
    class MariaDB,Minio storage
    class Tekton,K8sAPI cluster
    class ExternalDB,ExternalS3 externalservice
    class Dashboard odh
