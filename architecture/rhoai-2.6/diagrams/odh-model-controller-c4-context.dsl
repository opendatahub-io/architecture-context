// ODH Model Controller - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys ML models via InferenceService CRs"
        externalClient = person "External Client" "Sends inference requests to deployed models"

        odhModelController = softwareSystem "ODH Model Controller" "Manages OpenShift-specific resources (Routes, NetworkPolicies, Service Mesh, monitoring) for KServe and ModelMesh InferenceService deployments" {
            isvcController = container "InferenceService Controller" "Watches InferenceService CRs and delegates to KServe or ModelMesh sub-reconcilers based on deployment mode annotation" "Go Controller (controller-runtime)"
            storageSecretController = container "StorageSecret Controller" "Watches ODH-managed data connection secrets and aggregates them into storage-config secret" "Go Controller"
            monitoringController = container "Monitoring Controller" "Manages Prometheus RoleBindings for namespace-level metrics access" "Go Controller"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService and ServingRuntime CRDs" "Internal ODH"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform with modelmesh-serving Service on ports 8008/8443" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "UI for managing data connections and model serving configurations" "Internal ODH"

        istio = softwareSystem "OpenShift Service Mesh (Istio/Maistra)" "Service mesh providing mTLS, traffic management via ServiceMeshMemberRoll and PeerAuthentication" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller managing OpenShift Route CRs for external access" "External"
        prometheus = softwareSystem "Prometheus (OpenShift Monitoring)" "Metrics collection via ServiceMonitor and PodMonitor CRs" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core API server for all resource CRUD operations" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management" "External"

        // User interactions
        user -> kserve "Creates InferenceService / ServingRuntime CRs via kubectl/Dashboard"
        user -> odhDashboard "Configures data connections (storage secrets)"
        externalClient -> openshiftRouter "Sends inference requests" "HTTPS/443"

        // Controller watches
        odhModelController -> k8sAPI "Watches InferenceService, ServingRuntime, Secrets; CRUD Routes, NetworkPolicies, PeerAuth, SMMR, Telemetry, ServiceMonitors, PodMonitors, RoleBindings" "HTTPS/6443"
        odhModelController -> istio "Manages ServiceMeshMemberRoll, PeerAuthentication, Telemetry CRs" "via K8s API"
        odhModelController -> prometheus "Creates ServiceMonitor, PodMonitor, RoleBinding CRs" "via K8s API"

        // Routing
        openshiftRouter -> istio "KServe Routes: TLS Passthrough to istio-ingressgateway" "HTTPS TLS Passthrough"
        openshiftRouter -> modelMesh "ModelMesh Routes: Edge (8008) or Reencrypt (8443)" "HTTP/HTTPS"
        istio -> kserve "Routes traffic to KServe Predictor Pods" "HTTP/8012 mTLS"

        // Monitoring
        prometheus -> kserve "Scrapes inference metrics" "HTTP/8086, HTTP/3000"
        prometheus -> odhModelController "Scrapes controller metrics" "HTTP/8080"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
