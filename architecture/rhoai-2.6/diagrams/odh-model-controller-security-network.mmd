%% ODH Model Controller - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        direction TB
        KServeRoute["OpenShift Route (KServe)<br/>Namespace: istio-system<br/>443/TCP TLS Passthrough"]
        MMRouteEdge["OpenShift Route (ModelMesh)<br/>Namespace: {isvc-ns}<br/>443/TCP TLS Edge → 8008"]
        MMRouteReencrypt["OpenShift Route (ModelMesh+Auth)<br/>Namespace: {isvc-ns}<br/>443/TCP TLS Reencrypt → 8443"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_Istio["Namespace: istio-system"]
            IstioGW["Istio Ingress Gateway<br/>SA: istio-ingressgateway"]
            SMMR["ServiceMeshMemberRoll"]
        end

        subgraph NS_ISVC["Namespace: {isvc-namespace}"]
            Predictor["KServe Predictor Pod<br/>PeerAuth: mTLS STRICT<br/>Metrics: PERMISSIVE 8086/3000"]
            PeerAuth["PeerAuthentication"]
            NetPol["NetworkPolicies<br/>monitoring / ingress / ODH"]
            IstioTelemetry["Istio Telemetry"]
        end
    end

    subgraph ControllerPlane["CONTROLLER PLANE (opendatahub)"]
        Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>Replicas: 3<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
    end

    subgraph ModelMeshNS["MODELMESH SERVICE"]
        ModelMesh["modelmesh-serving<br/>8008/TCP HTTP (no auth)<br/>8443/TCP HTTPS (auth)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Namespace: openshift-user-workload-monitoring<br/>SA: prometheus-custom"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+"]
    end

    %% External access flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| KServeRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| MMRouteEdge
    Client -->|"HTTPS/443<br/>TLS 1.2+"| MMRouteReencrypt

    %% KServe flow
    KServeRoute -->|"HTTPS TLS Passthrough"| IstioGW
    IstioGW -->|"HTTP/8012<br/>mTLS (Istio)<br/>PeerAuthentication"| Predictor

    %% ModelMesh flows
    MMRouteEdge -->|"HTTP/8008<br/>TLS Edge"| ModelMesh
    MMRouteReencrypt -->|"HTTPS/8443<br/>TLS Reencrypt<br/>auth-delegator"| ModelMesh

    %% Controller flows
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI

    %% Monitoring flows
    Prometheus -->|"HTTP/8086<br/>plaintext<br/>PeerAuth PERMISSIVE"| Predictor
    Prometheus -->|"HTTP/3000<br/>plaintext<br/>PeerAuth PERMISSIVE"| Predictor
    Prometheus -->|"HTTP/8080<br/>plaintext"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
