graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ Edge Termination<br/>Route (per InferenceService)"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio - Optional)"]
        direction TB
        IstioGW["Istio Ingress Gateway<br/>NS: istio-system<br/>SA: istio-ingressgateway<br/>VirtualService routing"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER"]
        direction TB

        subgraph KServeMode["KServe Serverless Mode"]
            ISVCKServe["InferenceService Pod<br/>NS: {user-namespace}<br/>SA: {default or custom}<br/>Runtime: Knative Serving v0.39.3<br/>Ports:<br/>- 8080/TCP (inference, HTTP, mTLS opt)<br/>- 8080/TCP (metrics, HTTP)<br/>Envoy Sidecar:<br/>- 15020/TCP (Istio metrics)"]
        end

        subgraph ModelMeshMode["ModelMesh Mode"]
            ISVCMM["InferenceService Pod<br/>NS: {user-namespace}<br/>SA: {namespace}-sa<br/>Runtime: ModelMesh Serving<br/>Ports:<br/>- 8080/TCP (inference, HTTP)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Object Storage<br/>s3.amazonaws.com or custom<br/>TLS 1.2+<br/>AWS Signature v4"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        direction TB
        Prom["Prometheus<br/>NS: openshift-monitoring<br/>SA: prometheus-custom"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB
        Controller["odh-model-controller<br/>NS: redhat-ods-applications<br/>SA: odh-model-controller<br/>Replicas: 3 (leader election)<br/>Ports:<br/>- 8080/TCP (metrics, HTTP)<br/>- 8081/TCP (health, HTTP)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.3"]
    end

    %% External flow
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| Router
    Router -->|"HTTP/8080<br/>No encryption"| IstioGW

    %% Service Mesh to Apps
    IstioGW -->|"HTTP/8080<br/>mTLS (PERMISSIVE/STRICT)<br/>Bearer Token (optional)"| ISVCKServe
    Router -->|"HTTP/8080<br/>No mTLS"| ISVCMM

    %% Apps to S3
    ISVCKServe -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Signature v4"| S3
    ISVCMM -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Signature v4"| S3

    %% Monitoring flows
    Prom -->|"HTTP/8080<br/>Bearer Token (SA)<br/>ServiceMonitor"| ISVCKServe
    Prom -->|"HTTP/15020<br/>Bearer Token (SA)<br/>PodMonitor"| ISVCKServe
    Prom -->|"HTTP/8080<br/>Bearer Token (SA)"| ISVCMM

    %% Control plane
    Controller -->|"HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token<br/>Watch/Create Resources"| K8sAPI

    %% Network Policies (annotations)
    ISVCKServe -.->|"NetworkPolicy:<br/>allow-from-openshift-monitoring-ns<br/>allow-from-openshift-ingress<br/>allow-from-application-namespaces"| ISVCKServe
    ISVCMM -.->|"NetworkPolicy:<br/>allow-from-openshift-ingress"| ISVCMM

    %% Service Mesh Security (annotations)
    IstioGW -.->|"PeerAuthentication: {ns}-peer-authn<br/>Telemetry: {ns}-metrics-telemetry<br/>ServiceMeshMemberRoll"| ISVCKServe

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#e1f5ff,stroke:#0088cc,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Router ingress
    class IstioGW servicemesh
    class ISVCKServe,ISVCMM application
    class S3 externalservice
    class Prom monitoring
    class Controller,K8sAPI controlplane
