---
title: "ModelMesh Security Network - Generated by Claude Opus 4.6"
---
graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Inference Client / Controller"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Headless ClusterIP)"]
        direction TB

        subgraph Pod1["ModelMesh Pod"]
            direction TB
            MMApi["ModelMeshApi<br/>gRPC Server<br/>Port 8033/TCP<br/>Optional TLS/mTLS"]
            MMCore["ModelMesh Core<br/>Distributed LRU Cache<br/>Leader Election"]
            ProbeServer["Health/PreStop Server<br/>Port 8089/TCP<br/>HTTP (no TLS)"]
            MetricsServer["Prometheus Metrics<br/>Port 2112/TCP<br/>HTTPS (self-signed)"]

            MMApi --> MMCore
        end

        subgraph RuntimeContainer["Colocated Runtime Container"]
            Runtime["Model Runtime<br/>(triton/mlserver)<br/>Port 8085/TCP or UDS<br/>gRPC plaintext"]
        end

        subgraph OtherPods["Other ModelMesh Pods"]
            OtherMM["ModelMesh Pod N<br/>Port 8080/TCP<br/>Thrift/litelinks<br/>Optional TLS/mTLS"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd Cluster<br/>Port 2379/TCP<br/>gRPC + TLS<br/>Certificate Auth"]
        Prometheus["Prometheus<br/>Scraper"]
        StatsD["StatsD/Datadog<br/>Port 8125/UDP<br/>plaintext<br/>(Optional)"]
    end

    %% External to cluster flows
    Client -->|"gRPC/8033<br/>Optional TLS<br/>Optional mTLS<br/>(MM_TLS_CLIENT_AUTH)"| MMApi

    %% Internal flows
    MMCore -->|"gRPC/8085 or UDS<br/>plaintext<br/>No Auth"| Runtime
    MMCore <-->|"Thrift/8080<br/>Optional TLS/mTLS<br/>Certificate Auth"| OtherMM

    %% External service flows
    MMCore -->|"gRPC/2379<br/>TLS<br/>Certificate Auth"| etcd
    Prometheus -->|"HTTPS/2112<br/>Self-signed TLS<br/>No Auth"| MetricsServer
    MMCore -.->|"UDP/8125<br/>plaintext"| StatsD

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e6e6e6,stroke:#666,stroke-width:2px

    class Client external
    class MMApi,MMCore,ProbeServer,MetricsServer ingress
    class OtherMM internal
    class Runtime runtime
    class etcd,Prometheus,StatsD externalservice
