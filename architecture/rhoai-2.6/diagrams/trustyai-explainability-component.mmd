%% TrustyAI Explainability - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus REST)"]
            ConsumerEP["Consumer Endpoints<br/>/consumer/kserve/v2"]
            MetricsEP["Metrics Endpoints<br/>/metrics/group/fairness/*<br/>/metrics/drift/*"]
            ExplainerEP["Explainer Endpoints<br/>/explainers/local/*<br/>/explainers/global/*"]
            DataEP["Data Endpoints<br/>/data/download, /data/upload"]
            InfoEP["Info Endpoints<br/>/info, /info/tags, /info/names"]
            HealthEP["Health & Metrics<br/>/q/health/*, /q/metrics"]
        end

        subgraph Reconcilers["Payload Reconcilers"]
            MMReconciler["ModelMesh Inference<br/>Payload Reconciler"]
            KSReconciler["KServe Inference<br/>Payload Reconciler"]
        end

        subgraph Scheduler["Metrics Scheduler"]
            PromScheduler["PrometheusScheduler<br/>(Quarkus @Scheduled)"]
            PromPublisher["Prometheus Publisher<br/>(Micrometer Gauge)"]
        end

        subgraph CoreLib["explainability-core (Java Library)"]
            Fairness["Fairness Metrics<br/>SPD, DIR"]
            Drift["Drift Detectors<br/>KS Test, Meanshift,<br/>Fourier MMD"]
            Explainers["Explainers<br/>LIME, SHAP, CF,<br/>PDP, TSSaliency"]
        end

        subgraph Connectors["explainability-connectors"]
            GRPCClient["KServe v2 gRPC Client<br/>(Protobuf stubs)"]
        end

        subgraph ArrowLib["explainability-arrow"]
            Arrow["Apache Arrow<br/>Java-Python Interop"]
        end
    end

    subgraph Storage["Data Storage"]
        PVC["PVC Storage<br/>/inputs mount"]
        MinIO["MinIO (Optional)<br/>9000/TCP"]
        Memory["In-Memory Store"]
    end

    %% Internal flows
    ConsumerEP -->|partial payloads| MMReconciler
    ConsumerEP -->|full payloads| MMReconciler
    KSReconciler -->|CloudEvent payloads| KSReconciler
    MMReconciler -->|stores predictions| PVC
    KSReconciler -->|stores predictions| PVC
    MMReconciler -.->|optional| MinIO
    KSReconciler -.->|optional| MinIO

    MetricsEP -->|calculates| Fairness
    MetricsEP -->|calculates| Drift
    ExplainerEP -->|runs| Explainers
    ExplainerEP -->|calls model| GRPCClient

    PromScheduler -->|reads data| PVC
    PromScheduler -->|computes metrics| Fairness
    PromScheduler -->|publishes| PromPublisher

    %% External interactions
    ModelMesh["ModelMesh Serving"] -->|HTTP POST payloads| ConsumerEP
    KServeEvents["KServe CloudEvents"] -->|inference events| KSReconciler
    User["User / Dashboard"] -->|REST API calls| MetricsEP
    User -->|explanation requests| ExplainerEP
    User -->|data management| DataEP
    GRPCClient -->|gRPC inference| ModelServer["Model Server<br/>(KServe/ModelMesh)"]
    Prometheus["Prometheus"] -->|scrapes /q/metrics| HealthEP
    TrustyAIOp["TrustyAI Operator"] -.->|manages via CR| TrustyAI

    InitContainer["config-map-overrider<br/>(Init Container)"] -->|creates ConfigMap| ConfigMap["model-serving-config<br/>ConfigMap"]

