%% Kubeflow Notebook Controller - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>(per Notebook)<br/>443/TCP HTTPS<br/>TLS Edge or Reencrypt"]
    end

    subgraph OAuthFlow["AUTHENTICATION"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OpenShift Credentials"]
    end

    subgraph NotebookNS["NOTEBOOK NAMESPACE (per user)"]
        direction TB
        OAuthProxy["oauth-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS (service-ca cert)<br/>OAuth + SAR Check"]
        NotebookPod["Notebook Container<br/>8888/TCP HTTP<br/>Jupyter Server"]
        NP1["NetworkPolicy: ctrl-np<br/>8888/TCP from controller NS"]
        NP2["NetworkPolicy: oauth-np<br/>8443/TCP from all NS"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB
        ODHCtrl["ODH Notebook Controller<br/>SA: controller-manager<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        WebhookSvc["Mutating Webhook<br/>8443/TCP HTTPS<br/>TLS (service-ca cert)<br/>Failure Policy: Fail"]
        KFCtrl["KF Notebook Controller<br/>SA: manager<br/>Metrics: 8080/TCP"]
        Culler["Culling Controller<br/>Polls /api/kernels<br/>/api/terminals"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        ServiceCA["OpenShift service-ca<br/>Auto TLS Provisioning"]
    end

    %% External access flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| Route
    User -->|"OAuth Login<br/>HTTPS/443<br/>TLS 1.2+"| OAuthServer
    OAuthServer -->|"OAuth callback<br/>with token"| OAuthProxy

    %% Route to notebook
    Route -->|"Reencrypt<br/>HTTPS/8443<br/>TLS"| OAuthProxy
    OAuthProxy -->|"HTTP/8888<br/>localhost<br/>No encryption"| NotebookPod

    %% Controller flows
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD: Routes, Services,<br/>Secrets, SA, NP, CM"| K8sAPI
    KFCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD: StatefulSets,<br/>Services"| K8sAPI
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReview"| K8sAPI
    K8sAPI -->|"HTTPS/8443<br/>TLS<br/>K8s CA cert"| WebhookSvc

    %% Culler polling
    Culler -.->|"HTTP/8888<br/>Poll Jupyter API"| NotebookPod

    %% TLS provisioning
    ServiceCA -.->|"Provisions TLS certs"| OAuthProxy
    ServiceCA -.->|"Provisions TLS certs"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e6d5f7,stroke:#9673a6,stroke-width:2px
    classDef notebook fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Route ingress
    class OAuthServer auth
    class OAuthProxy,NotebookPod notebook
    class NP1,NP2 netpol
    class ODHCtrl,WebhookSvc,KFCtrl,Culler controller
    class K8sAPI,ServiceCA cluster
