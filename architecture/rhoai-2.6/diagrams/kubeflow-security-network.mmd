graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.2+ (edge/re-encrypt)"]
    end

    subgraph UserNamespace["USER NAMESPACE: user-namespace"]
        direction TB

        subgraph NotebookService["Service: notebook-name-tls"]
            Service["ClusterIP<br/>443/TCP → 8443/TCP"]
        end

        subgraph NotebookPod["Notebook Pod: notebook-name-0"]
            direction LR
            OAuth["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>Image: ose-oauth-proxy"]
            NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>Image: Jupyter notebook"]

            OAuth -->|HTTP/8888<br/>localhost| NotebookContainer
        end

        subgraph NetworkPolicies["NetworkPolicies"]
            CtrlNP["ctrl-np: Allow TCP/8888<br/>from controller namespace"]
            OAuthNP["oauth-np: Allow TCP/8443<br/>from all"]
        end

        Service --> OAuth
    end

    subgraph ControllerNamespace["CONTROLLER NAMESPACE: redhat-ods-applications"]
        direction TB

        Controller["ODH Notebook Controller<br/>SA: manager<br/>Replicas: 1<br/>runAsNonRoot"]

        WebhookSvc["Webhook Service<br/>443/TCP → 8443/TCP<br/>ClusterIP"]

        WebhookServer["Webhook Server<br/>8443/TCP HTTPS<br/>TLS (service-ca)"]

        MetricsServer["Metrics Server<br/>8080/TCP HTTP<br/>Internal only"]

        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]

        Controller --> WebhookServer
        Controller --> MetricsServer
        Controller --> HealthProbes
        WebhookSvc --> WebhookServer
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]

        ServiceCA["Service CA Operator<br/>TLS Certificate Provisioning<br/>90-day rotation"]

        KubeflowController["Kubeflow Notebook Controller<br/>Creates StatefulSets"]
    end

    %% User flows
    User -->|"HTTPS/443<br/>TLS 1.2+ (edge)<br/>No auth initially"| Router
    Router -->|"HTTPS/443<br/>TLS 1.2+ (re-encrypt)"| Service

    %% OAuth authentication flow
    OAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Account Token"| OAuthServer
    OAuth -->|"HTTPS/6443<br/>TLS 1.2+<br/>SubjectAccessReview<br/>User OAuth Token"| K8sAPI

    %% Controller flows
    Controller -->|"Watch/Create<br/>HTTPS/6443<br/>TLS 1.2+<br/>Service Account Token"| K8sAPI
    K8sAPI -->|"Watch notifications<br/>HTTP/2 TLS 1.2+"| Controller

    %% Webhook flows
    K8sAPI -->|"POST /mutate-notebook-v1<br/>HTTPS/443<br/>mTLS (client cert)"| WebhookSvc
    WebhookServer -->|"Read Proxy CR<br/>HTTPS/6443<br/>Service Account Token"| K8sAPI

    %% Certificate provisioning
    ServiceCA -.->|"Provisions TLS certs<br/>service.beta.openshift.io<br/>/serving-cert-secret-name"| Service
    ServiceCA -.->|"Provisions TLS certs"| WebhookSvc

    %% Dependencies
    KubeflowController -.->|"Creates StatefulSets<br/>for notebooks"| NotebookPod
    Controller -.->|"Watches Notebook CRs<br/>created by"| KubeflowController

    %% NetworkPolicy enforcement
    CtrlNP -.->|"Allows controller access"| NotebookContainer
    OAuthNP -.->|"Allows external access"| OAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef usernamespace fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controllernamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router ingress
    class Service,OAuth,NotebookContainer,NotebookPod usernamespace
    class Controller,WebhookServer,MetricsServer,HealthProbes,WebhookSvc controllernamespace
    class OAuthServer,K8sAPI,ServiceCA,KubeflowController externalservice
    class CtrlNP,OAuthNP security
