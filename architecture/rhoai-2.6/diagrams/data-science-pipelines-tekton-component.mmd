    User["User / Data Scientist"]

    %% Relationships
    User -->|"creates pipelines"| KFPSDK
    KFPSDK -->|"compiles to Tekton YAML"| APIServer
    User -->|"manages via browser"| UI
    UI -->|"REST API calls"| APIServer

    APIServer -->|"stores metadata"| MySQL
    APIServer -->|"stores artifacts"| MinIO
    APIServer -->|"creates"| PipelineRunCR
    APIServer -->|"manages"| ScheduledWorkflowCR

    PipelineRunCR -->|"executed by"| Tekton
    ScheduledWorkflowCR -->|"watched by"| ScheduledWF
    ScheduledWF -->|"creates"| PipelineRunCR

    PersistenceAgent -->|"watches"| PipelineRunCR
    PersistenceAgent -->|"syncs status to"| APIServer

    PipelineLoopCR -->|"watched by"| PipelineLoop
    ViewerCR -->|"watched by"| ViewerCRD
    ViewerCRD -->|"creates viz deployments"| VizServer

    MetadataWriter -->|"watches"| PipelineRunCR
    MetadataWriter -->|"writes to"| MetadataEnvoy
    MetadataEnvoy -->|"proxies to"| MetadataGRPC
    MetadataGRPC -->|"stores in"| MySQL

    APIServer -->|"requests viz"| VizServer

    Dashboard -->|"integrates"| UI
    UI -->|"auth via"| OAuthProxy
    Prometheus -->|"scrapes /metrics"| APIServer

