// Data Science Pipelines Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // People
        dataScientist = person "Data Scientist" "Creates and runs ML pipelines via DS Pipelines"
        platformAdmin = person "Platform Admin" "Deploys and manages DSPA instances"

        // Primary System
        dspo = softwareSystem "Data Science Pipelines Operator" "Deploys and manages Kubeflow Pipelines stacks on OpenShift" {
            controller = container "DSPA Controller" "Watches DSPA CRs, reconciles pipeline sub-components, performs health checks" "Go Operator (controller-runtime / Kubebuilder v3)"
            apiServer = container "DS Pipeline API Server" "KFP REST (8888) and gRPC (8887) API using Tekton runtime" "Go Service"
            oauthProxy = container "OAuth Proxy Sidecar" "OpenShift OAuth proxy fronting API server on 8443/TCP" "oauth-proxy"
            persistenceAgent = container "Persistence Agent" "Records pipeline run status and metadata to database" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages cron-scheduled pipeline runs via ScheduledWorkflow CRDs" "Go Service"
            mariaDB = container "MariaDB" "Default database backend for pipeline metadata" "MariaDB 3306/TCP" "Database"
            minio = container "Minio" "Default S3-compatible object store for pipeline artifacts" "Minio 9000/TCP" "Database"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD gRPC server on 9090/TCP" "Envoy"
            mlmdGrpc = container "MLMD gRPC Server" "ML Metadata gRPC service for artifact/execution tracking" "Go Service"
            mlmdWriter = container "MLMD Writer" "Writes ML metadata from pipeline runs to MLMD gRPC server" "Go Service"
            pipelineUI = container "ML Pipeline UI" "KFP web UI with OAuth proxy (experimental/unsupported)" "React UI"
        }

        // External Systems
        tekton = softwareSystem "Tekton Pipelines" "Pipeline runtime for executing KFP pipelines" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authentication for external API access" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "External ingress via Routes (reencrypt TLS)" "External"
        openshiftCerts = softwareSystem "OpenShift Service Serving Certs" "Auto-provisioned TLS certificates" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Core Kubernetes API server" "External"

        // Internal ODH Systems
        odhDashboard = softwareSystem "ODH Dashboard" "Pipeline metadata and artifact visualization" "Internal ODH"
        openshiftMonitoring = softwareSystem "OpenShift Monitoring" "Prometheus metrics collection via ServiceMonitor" "Internal ODH"

        // Optional External Services
        externalDB = softwareSystem "External Database" "External SQL database (optional, replaces MariaDB)" "External"
        externalS3 = softwareSystem "External S3 Storage" "External S3-compatible storage (optional, replaces Minio)" "External"

        // CodeFlare / Ray integration
        codeflare = softwareSystem "CodeFlare / MCAD" "AppWrapper resource management for distributed workloads" "External"
        ray = softwareSystem "Ray" "RayCluster/RayJob/RayService management" "External"

        // Relationships - People
        dataScientist -> dspo "Submits pipeline runs via API" "HTTPS/443"
        platformAdmin -> dspo "Creates DSPA custom resources" "kubectl"

        // Relationships - Internal
        controller -> apiServer "Deploys and reconciles"
        controller -> persistenceAgent "Deploys"
        controller -> scheduledWorkflow "Deploys"
        controller -> mariaDB "Deploys (conditionally) + health checks" "MySQL/3306"
        controller -> minio "Deploys (conditionally) + health checks" "S3/9000"
        controller -> mlmdEnvoy "Deploys (conditionally)"
        controller -> mlmdGrpc "Deploys (conditionally)"
        controller -> mlmdWriter "Deploys (conditionally)"
        controller -> pipelineUI "Deploys (conditionally)"

        oauthProxy -> apiServer "Forwards authenticated requests" "HTTP/8888 localhost"
        apiServer -> mariaDB "Stores pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores pipeline artifacts" "S3/9000"
        persistenceAgent -> apiServer "Reports run status" "HTTP/8888"
        mlmdEnvoy -> mlmdGrpc "Proxies gRPC" "gRPC/8080"
        mlmdWriter -> mlmdGrpc "Writes metadata" "gRPC/8080"
        mlmdGrpc -> mariaDB "Queries/stores metadata" "MySQL/3306"

        // Relationships - External
        dspo -> tekton "Creates PipelineRuns and TaskRuns" "HTTPS/443"
        dspo -> k8sAPI "CR reconciliation, resource management" "HTTPS/443"
        dspo -> codeflare "AppWrapper management" "HTTPS/443"
        dspo -> ray "Ray resource management" "HTTPS/443"
        openshiftRouter -> oauthProxy "Routes external traffic" "HTTPS/8443 reencrypt"
        oauthProxy -> openshiftOAuth "Validates OAuth tokens" "HTTPS"
        openshiftCerts -> oauthProxy "Provisions TLS certificates"
        dspo -> externalDB "Pipeline metadata (optional)" "MySQL/3306 TLS"
        dspo -> externalS3 "Pipeline artifacts (optional)" "HTTPS/443"

        // Relationships - Internal ODH
        odhDashboard -> mlmdEnvoy "Accesses pipeline metadata" "gRPC/9090"
        openshiftMonitoring -> apiServer "Scrapes Prometheus metrics" "HTTP/8888"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Database" {
                shape cylinder
            }
        }
    }
}
