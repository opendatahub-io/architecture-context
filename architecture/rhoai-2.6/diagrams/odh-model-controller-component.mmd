graph TB
    subgraph "odh-model-controller Component"
        direction TB
        Manager[Manager Pod<br/>3 replicas, leader election]

        subgraph "Controllers"
            OSReconciler[OpenshiftInferenceService<br/>Reconciler]
            KServeReconciler[KserveInferenceService<br/>Reconciler]
            MMReconciler[ModelMeshInferenceService<br/>Reconciler]
            StorageReconciler[StorageSecret<br/>Reconciler]
            MonitoringReconciler[Monitoring<br/>Reconciler]
        end

        Manager --> OSReconciler
        OSReconciler -->|KServe mode| KServeReconciler
        OSReconciler -->|ModelMesh mode| MMReconciler
        Manager --> StorageReconciler
        Manager --> MonitoringReconciler
    end

    subgraph "Watched CRDs"
        ISVC[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRT[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        DataConnSecret[Data Connection Secrets<br/>opendatahub.io/managed: true]
    end

    subgraph "Created Resources (KServe Mode)"
        Route[OpenShift Route<br/>HTTPS/443]
        VirtualService[Istio VirtualService<br/>Traffic routing]
        PeerAuth[PeerAuthentication<br/>mTLS PERMISSIVE/STRICT]
        Telemetry[Telemetry<br/>Prometheus metrics]
        ServiceMon[ServiceMonitor<br/>Metrics scraping]
        NetPol[NetworkPolicy<br/>Traffic control]
        SMMR[ServiceMeshMemberRoll<br/>Namespace registration]
        MetricsSvc[Metrics Service<br/>8080/TCP]
    end

    subgraph "Created Resources (ModelMesh Mode)"
        MMRoute[OpenShift Route<br/>HTTPS/443]
        MMSA[ServiceAccount<br/>namespace-sa]
        MMCRB[ClusterRoleBinding<br/>prometheus-reader]
    end

    subgraph "Created Resources (All Modes)"
        StorageConfig[storage-config Secret<br/>Aggregated S3 credentials]
        PrometheusRB[RoleBinding<br/>prometheus-ns-access]
    end

    subgraph "External Dependencies"
        Istio[Istio<br/>v1.17.4]
        Knative[Knative Serving<br/>v0.39.3]
        PrometheusOp[Prometheus Operator<br/>v0.64.1]
        OSMesh[OpenShift Service Mesh<br/>Maistra v1+]
    end

    subgraph "Internal ODH Components"
        Dashboard[ODH Dashboard<br/>Creates data connections]
        KServeCtrl[KServe Controller<br/>Creates InferenceServices]
    end

    %% Watches
    ISVC -.->|watched by| OSReconciler
    ServingRT -.->|read by| KServeReconciler
    DataConnSecret -.->|watched by| StorageReconciler

    %% KServe mode creates
    KServeReconciler -->|creates| Route
    KServeReconciler -->|creates| VirtualService
    KServeReconciler -->|creates| PeerAuth
    KServeReconciler -->|creates| Telemetry
    KServeReconciler -->|creates| ServiceMon
    KServeReconciler -->|creates| NetPol
    KServeReconciler -->|creates| SMMR
    KServeReconciler -->|creates| MetricsSvc

    %% ModelMesh mode creates
    MMReconciler -->|creates| MMRoute
    MMReconciler -->|creates| MMSA
    MMReconciler -->|creates| MMCRB

    %% All modes
    StorageReconciler -->|creates/updates| StorageConfig
    MonitoringReconciler -->|creates| PrometheusRB

    %% External dependencies
    VirtualService -.->|requires| Istio
    Route -.->|requires| Knative
    ServiceMon -.->|requires| PrometheusOp
    SMMR -.->|requires| OSMesh

    %% Internal integration
    Dashboard -->|creates| DataConnSecret
    KServeCtrl -->|creates| ISVC

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px
    style OSReconciler fill:#4a90e2,stroke:#333
    style KServeReconciler fill:#4a90e2,stroke:#333
    style MMReconciler fill:#4a90e2,stroke:#333
    style StorageReconciler fill:#4a90e2,stroke:#333
    style MonitoringReconciler fill:#4a90e2,stroke:#333
    style ISVC fill:#f5a623,stroke:#333
    style ServingRT fill:#f5a623,stroke:#333
    style DataConnSecret fill:#f5a623,stroke:#333
    style Istio fill:#999,stroke:#333
    style Knative fill:#999,stroke:#333
    style PrometheusOp fill:#999,stroke:#333
    style OSMesh fill:#999,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style KServeCtrl fill:#7ed321,stroke:#333
