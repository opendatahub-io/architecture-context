graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CodeFlare SDK]
        PrometheusExt[Prometheus External]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]

        subgraph OpNamespace["NAMESPACE: opendatahub"]
            direction TB

            subgraph ManagerPod["Manager Deployment Pod<br/>SA: controller-manager<br/>User: 65532:65532<br/>Security: non-root, no caps"]
                MCAD["MCAD Queue Controller<br/>Embedded v1.38.1"]
                InstaScale["InstaScale Controller<br/>Optional - Disabled"]
            end

            MetricsService["Metrics Service<br/>ClusterIP<br/>8080/TCP HTTP<br/>No Auth"]
            ManagerPod -->|exposes| MetricsService
        end

        subgraph UserNamespaces["USER NAMESPACES"]
            AppWrappers[AppWrapper CRs<br/>workload.codeflare.dev]
            QuotaSubtrees[QuotaSubtree CRs<br/>quota.codeflare.dev]
            WrappedResources["Wrapped Resources<br/>Pods, Jobs, Deployments<br/>RayClusters<br/>Routes/Ingresses"]
        end

        subgraph MachineAPINamespace["OPENSHIFT MACHINE API"]
            MachineSets[MachineSets<br/>machine.openshift.io]
        end
    end

    subgraph CloudProvider["EXTERNAL SERVICES"]
        CloudAPI[Cloud Provider API<br/>AWS/Azure/GCP<br/>443/TCP HTTPS TLS1.2+]
    end

    %% External to API Server
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    PrometheusExt -->|HTTP/8080<br/>No Auth| MetricsService

    %% API Server to Controllers
    K8sAPI <-->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| MCAD
    K8sAPI <-->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| InstaScale

    %% Controllers to Resources
    MCAD -->|watch/manage| AppWrappers
    MCAD -->|watch/manage| QuotaSubtrees
    MCAD -->|create/manage| WrappedResources
    InstaScale -->|watch| AppWrappers
    InstaScale -->|scale| MachineSets

    %% Machine API to Cloud
    MachineSets -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud Credentials| CloudAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326ce5,stroke:#326ce5,stroke-width:2px,color:#fff
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef crd fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cloud fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,PrometheusExt external
    class K8sAPI k8s
    class MCAD,InstaScale,ManagerPod operator
    class MetricsService service
    class AppWrappers,QuotaSubtrees,WrappedResources,MachineSets crd
    class CloudAPI cloud
