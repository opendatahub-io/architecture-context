%% CodeFlare Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["codeflare-operator manager<br/>SA: controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
            ConfigMap["codeflare-operator-config<br/>(ConfigMap)"]
            Operator -->|reads| ConfigMap
        end

        subgraph EmbeddedControllers["Embedded Controllers"]
            MCAD["MCAD Queue Controller<br/>(embedded in operator binary)"]
            InstaScale["InstaScale Controller<br/>(optional, embedded)"]
        end

        Operator -->|starts| MCAD
        Operator -->|optionally starts| InstaScale

        subgraph Monitoring["Monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor"]
        end

        Prometheus -->|"HTTP/8080<br/>No Auth<br/>ClusterIP only"| Operator
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph MachineAPIZone["OPENSHIFT MACHINE API"]
        MachineAPI["Machine API Controllers<br/>machine.openshift.io"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        CloudProvider["Cloud Provider API<br/>(AWS/Azure/GCP)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% Flows
    MCAD -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>AppWrappers, Pods, Services"| K8sAPI
    InstaScale -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>MachineSets, Nodes"| K8sAPI
    InstaScale -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>Create/Delete MachineSets"| MachineAPI
    MachineAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud Credentials"| CloudProvider

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,color:#fff,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef config fill:#b8d4f0,stroke:#333

    class Operator,MCAD,InstaScale operator
    class K8sAPI controlplane
    class MachineAPI controlplane
    class CloudProvider external
    class Prometheus monitoring
    class ConfigMap config
