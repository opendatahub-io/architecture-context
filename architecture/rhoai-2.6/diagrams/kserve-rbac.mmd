graph TD
    subgraph "Service Accounts"
        SA[kserve-controller-manager<br/>namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kserve-manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[kserve-proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader[kserve-leader-election-rolebinding<br/>RoleBinding - namespace: kserve]
    end

    subgraph "ClusterRole"
        CR_Manager[kserve-manager-role<br/>ClusterRole]
        CR_Proxy[kserve-proxy-role<br/>ClusterRole]
    end

    subgraph "Role"
        R_Leader[leader-election-role<br/>Role - namespace: kserve]
    end

    subgraph "KServe CRD Resources"
        direction TB
        IS[serving.kserve.io<br/>InferenceService<br/>inferenceservices/finalizers<br/>inferenceservices/status]
        IG[serving.kserve.io<br/>InferenceGraph<br/>inferencegraphs/finalizers<br/>inferencegraphs/status]
        TM[serving.kserve.io<br/>TrainedModel<br/>trainedmodels/status]
        SR[serving.kserve.io<br/>ServingRuntime<br/>servingruntimes/finalizers<br/>servingruntimes/status]
        CSR[serving.kserve.io<br/>ClusterServingRuntime<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status]
        CSC[serving.kserve.io<br/>ClusterStorageContainer]
    end

    subgraph "Knative Resources"
        KS[serving.knative.dev<br/>Service<br/>services/finalizers<br/>services/status]
    end

    subgraph "Istio Resources"
        VS[networking.istio.io<br/>VirtualService<br/>virtualservices/finalizers<br/>virtualservices/status]
    end

    subgraph "Kubernetes Core Resources"
        direction TB
        Deploy[apps<br/>Deployment]
        HPA[autoscaling<br/>HorizontalPodAutoscaler]
        Svc[core<br/>Service]
        Secret[core<br/>Secret]
        CM[core<br/>ConfigMap]
        NS[core<br/>Namespace]
        Pod[core<br/>Pod]
        SvcAcct[core<br/>ServiceAccount]
        Event[core<br/>Event]
        Ingress[networking.k8s.io<br/>Ingress]
    end

    subgraph "Admission Registration"
        MWC[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration]
        VWC[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| CRB_Proxy
    SA -->|bound via| RB_Leader

    %% Role Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    %% ClusterRole Permissions - KServe CRDs
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| IS
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| IG
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| TM
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| SR
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| CSR
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| CSC

    %% ClusterRole Permissions - Knative
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| KS

    %% ClusterRole Permissions - Istio
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| VS

    %% ClusterRole Permissions - K8s Core
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Deploy
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| HPA
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Svc
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Secret
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| CM
    CR_Manager -->|"get, list, watch"| NS
    CR_Manager -->|"get, list, watch"| Pod
    CR_Manager -->|"get, list, watch"| SvcAcct
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Event
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Ingress

    %% ClusterRole Permissions - Admission
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| MWC
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| VWC

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB_Manager fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Proxy fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style RB_Leader fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    %% KServe CRDs
    style IS fill:#7ed321,stroke:#333,stroke-width:2px
    style IG fill:#7ed321,stroke:#333,stroke-width:2px
    style TM fill:#7ed321,stroke:#333,stroke-width:2px
    style SR fill:#7ed321,stroke:#333,stroke-width:2px
    style CSR fill:#7ed321,stroke:#333,stroke-width:2px
    style CSC fill:#7ed321,stroke:#333,stroke-width:2px

    %% External CRDs
    style KS fill:#50e3c2,stroke:#333,stroke-width:2px
    style VS fill:#50e3c2,stroke:#333,stroke-width:2px

    %% Core resources
    style Deploy fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style HPA fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style Svc fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style Secret fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style CM fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style NS fill:#d0d0d0,stroke:#333,stroke-width:2px
    style Pod fill:#d0d0d0,stroke:#333,stroke-width:2px
    style SvcAcct fill:#d0d0d0,stroke:#333,stroke-width:2px
    style Event fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style Ingress fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff

    %% Admission
    style MWC fill:#ff6f61,stroke:#333,stroke-width:2px,color:#fff
    style VWC fill:#ff6f61,stroke:#333,stroke-width:2px,color:#fff
