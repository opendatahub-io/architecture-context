graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientists<br/>External Clients"]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Routes)"]
        Router["OpenShift Router / HAProxy<br/>443/TCP → internal ports<br/>TLS Edge/Re-encrypt/Passthrough"]
    end

    subgraph ControlPlane["CONTROL PLANE (redhat-ods-operator)"]
        RHODSOp["RHODS Operator<br/>SA: rhods-operator<br/>Replicas: 1"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>ServiceAccount JWT Auth"]
    end

    subgraph AppServices["APPLICATION SERVICES (redhat-ods-applications)"]
        Dashboard["ODH Dashboard<br/>8080/TCP → 443/TCP<br/>SA: odh-dashboard<br/>Replicas: 2<br/>OAuth Proxy Sidecar"]

        NotebookCtrl["Notebook Controller<br/>SA: notebook-controller<br/>Replicas: 1"]

        ModelCtrl["ODH Model Controller<br/>SA: odh-model-controller<br/>Replicas: 3<br/>Creates Routes/ServiceMonitors"]

        DSPOp["Data Science Pipelines Operator<br/>NS: openshift-operators<br/>Global scope"]

        KServeOp["KServe Operator<br/>SA: kserve-controller-manager"]

        ModelMeshOp["ModelMesh Controller<br/>SA: modelmesh-controller"]

        CodeFlareOp["CodeFlare Operator<br/>NS: openshift-operators<br/>Manages AppWrappers"]

        KubeRayOp["KubeRay Operator<br/>NS: openshift-operators<br/>Manages RayClusters"]

        TrustyAIOp["TrustyAI Operator<br/>NS: openshift-operators<br/>Watches InferenceServices"]
    end

    subgraph Monitoring["MONITORING (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>9090/TCP metrics<br/>443/TCP UI (OAuth)<br/>StatefulSet 40Gi PVC"]

        Alertmanager["Alertmanager<br/>9093/TCP internal<br/>443/TCP UI (OAuth)<br/>StatefulSet 1Gi PVC"]

        Blackbox["Blackbox Exporter<br/>9115/TCP<br/>Health probes"]
    end

    subgraph ServiceMesh["SERVICE MESH (istio-system - OPTIONAL)"]
        IstioCP["Istio Control Plane<br/>ServiceMeshControlPlane<br/>mTLS: PERMISSIVE/STRICT"]

        IstioGW["Istio Ingress Gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.3 Termination<br/>VirtualService Routing"]
    end

    subgraph UserWorkloads["USER WORKLOADS ({user-namespace})"]
        direction TB

        subgraph NotebookPod["Notebook StatefulSet"]
            NotebookContainer["Notebook Container<br/>8888/TCP<br/>Jupyter/code-server/RStudio"]
            OAuthProxy1["OAuth Proxy Sidecar<br/>8443/TCP HTTPS"]
        end

        subgraph DSPStack["Data Science Pipeline Application"]
            DSPAPIServer["DSP API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC"]
            MariaDB["MariaDB<br/>3306/TCP<br/>StatefulSet PVC"]
            MinIO["MinIO<br/>9000/TCP S3 API"]
            MLMDgRPC["MLMD gRPC<br/>8080/TCP"]
            MLMDEnvoy["MLMD Envoy<br/>9090/TCP<br/>Dashboard access"]
        end

        subgraph KServeIS["KServe InferenceService"]
            StorageInit["Storage Initializer<br/>initContainer<br/>Downloads from S3"]
            Predictor["Predictor Container<br/>8080/TCP HTTP<br/>8081/TCP gRPC"]
            IstioSidecar["Istio Sidecar<br/>mTLS enforcement"]
        end

        subgraph ModelMeshIS["ModelMesh Serving"]
            ModelMeshContainer["ModelMesh<br/>8033/TCP internal<br/>8085/TCP gRPC mgmt"]
            RESTProxy["REST Proxy<br/>8008/TCP HTTP"]
            StorageHelper["Storage Helper<br/>8086/TCP gRPC<br/>Downloads from S3"]
            RuntimeAdapter["Runtime Adapter<br/>Triton/MLServer/OpenVINO"]
        end

        subgraph RayClusterPods["RayCluster"]
            RayHead["Ray Head<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
            RayWorkers["Ray Workers<br/>6379/TCP GCS<br/>N replicas"]
        end

        subgraph TrustyAIPod["TrustyAI Service"]
            TrustyAIContainer["TrustyAI Container<br/>8080/TCP HTTP<br/>/q/metrics"]
            OAuthProxy2["OAuth Proxy Sidecar<br/>8443/TCP HTTPS"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>AWS S3/MinIO/GCS/Azure<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM Auth"]

        Registry["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+"]

        ExternalDB["External Databases<br/>MySQL 3306/PostgreSQL 5432<br/>TLS 1.2+ optional"]

        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS"]

        CloudAPI["Cloud Provider APIs<br/>InstaScale<br/>443/TCP HTTPS"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth)"| Router

    %% Ingress to Services
    Router -->|"OAuth Proxy"| Dashboard
    Router -->|"Re-encrypt TLS"| NotebookContainer
    Router -->|"Re-encrypt TLS"| DSPAPIServer
    Router -->|"Edge TLS"| Predictor
    Router -->|"Edge TLS"| RESTProxy
    Router -->|"Passthrough TLS"| TrustyAIContainer
    Router -->|"OAuth Proxy"| Prometheus
    Router -->|"OAuth Proxy"| Alertmanager

    %% Control Plane
    RHODSOp -->|"HTTPS/6443<br/>ServiceAccount JWT"| K8sAPI
    RHODSOp -->|"Deploys"| Dashboard
    RHODSOp -->|"Deploys"| NotebookCtrl
    RHODSOp -->|"Deploys"| ModelCtrl
    RHODSOp -->|"Deploys"| DSPOp
    RHODSOp -->|"Deploys"| KServeOp
    RHODSOp -->|"Deploys"| ModelMeshOp
    RHODSOp -->|"Deploys"| CodeFlareOp
    RHODSOp -->|"Deploys"| KubeRayOp
    RHODSOp -->|"Deploys"| TrustyAIOp

    %% Application Services
    Dashboard -->|"gRPC/9090"| MLMDEnvoy
    Dashboard -->|"HTTP"| DSPAPIServer
    NotebookCtrl -->|"Watches CRs"| K8sAPI
    NotebookCtrl -->|"Creates StatefulSets"| NotebookPod
    KServeOp -->|"Creates"| KServeIS
    KServeOp -->|"Uses"| IstioCP
    ModelMeshOp -->|"Creates"| ModelMeshIS
    ModelCtrl -->|"Watches InferenceServices"| K8sAPI
    ModelCtrl -->|"Creates Routes"| Router
    ModelCtrl -->|"Creates ServiceMonitors"| Prometheus
    DSPOp -->|"Creates DSPA"| DSPStack
    CodeFlareOp -->|"Creates AppWrapper"| RayClusterPods
    KubeRayOp -->|"Manages"| RayClusterPods
    TrustyAIOp -->|"Watches InferenceServices"| K8sAPI
    TrustyAIOp -->|"Creates"| TrustyAIPod

    %% Service Mesh
    IstioGW -->|"mTLS STRICT<br/>Service Identity"| Predictor
    IstioCP -->|"Configures"| IstioSidecar

    %% Monitoring
    Prometheus -->|"Scrape metrics"| Dashboard
    Prometheus -->|"Scrape metrics"| DSPAPIServer
    Prometheus -->|"Scrape metrics"| Predictor
    Prometheus -->|"Scrape metrics"| RESTProxy
    Prometheus -->|"Scrape metrics"| TrustyAIContainer
    Prometheus -->|"Send alerts"| Alertmanager

    %% User Workloads to External
    NotebookContainer -->|"HTTPS/443<br/>AWS IAM"| S3
    NotebookContainer -->|"HTTPS/443"| PyPI
    StorageInit -->|"HTTPS/443<br/>AWS IAM"| S3
    StorageHelper -->|"HTTPS/443<br/>AWS IAM"| S3
    DSPAPIServer -->|"MySQL/3306<br/>TLS optional"| MariaDB
    DSPAPIServer -->|"S3 API/9000"| MinIO
    DSPAPIServer -->|"MySQL/3306<br/>TLS optional"| ExternalDB
    ModelMeshContainer -->|"HTTPS/2379<br/>TLS 1.2+"| ExternalDB
    RHODSOp -->|"HTTPS/443"| Registry
    NotebookContainer -->|"HTTPS/443"| Registry
    CodeFlareOp -->|"HTTPS/443"| CloudAPI

    %% TrustyAI monitoring
    Predictor -->|"HTTP/8080<br/>Inference payloads"| TrustyAIContainer

    %% Styling - Trust Zones
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef controlplane fill:#ffcccc,stroke:#cc0000,stroke-width:3px
    classDef appservices fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef monitoring fill:#e6ccff,stroke:#9933ff,stroke-width:2px
    classDef servicemesh fill:#ccffcc,stroke:#00cc00,stroke-width:2px
    classDef userworkloads fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservices fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class RHODSOp,K8sAPI controlplane
    class Dashboard,NotebookCtrl,ModelCtrl,DSPOp,KServeOp,ModelMeshOp,CodeFlareOp,KubeRayOp,TrustyAIOp appservices
    class Prometheus,Alertmanager,Blackbox monitoring
    class IstioCP,IstioGW servicemesh
    class NotebookContainer,OAuthProxy1,DSPAPIServer,MariaDB,MinIO,MLMDgRPC,MLMDEnvoy,StorageInit,Predictor,IstioSidecar,ModelMeshContainer,RESTProxy,StorageHelper,RuntimeAdapter,RayHead,RayWorkers,TrustyAIContainer,OAuthProxy2 userworkloads
    class S3,Registry,ExternalDB,PyPI,CloudAPI externalservices
