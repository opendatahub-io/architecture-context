%% Data Science Pipelines Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "DSPO Controller"
        Controller["DSPA Controller<br/>(controller-manager)"]
    end

    subgraph "DS Pipelines Stack (per DSPA instance)"
        direction TB

        subgraph "API Layer"
            APIServer["DS Pipeline API Server<br/>REST 8888/TCP | gRPC 8887/TCP"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS"]
            OAuthProxy -->|localhost| APIServer
        end

        subgraph "Processing Components"
            PersistenceAgent["Persistence Agent<br/>Records run status"]
            ScheduledWorkflow["Scheduled Workflow<br/>Controller"]
            MLMDWriter["MLMD Writer"]
        end

        subgraph "ML Metadata"
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP gRPC"]
            MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC"]
            MLMDEnvoy -->|proxy| MLMDgRPC
        end

        subgraph "Data Stores"
            MariaDB["MariaDB<br/>3306/TCP"]
            Minio["Minio<br/>9000/TCP S3"]
        end

        subgraph "UI (Experimental)"
            MLUI["ML Pipeline UI<br/>+ OAuth Proxy"]
        end
    end

    %% CRDs
    User[User / Dashboard] -->|creates| DSPACR["DSPA CR<br/>(DataSciencePipelinesApplication)"]
    DSPACR -->|watched by| Controller

    %% Controller creates sub-components
    Controller -->|"deploys & reconciles"| APIServer
    Controller -->|deploys| PersistenceAgent
    Controller -->|deploys| ScheduledWorkflow
    Controller -->|deploys| MLMDEnvoy
    Controller -->|deploys| MLMDgRPC
    Controller -->|deploys| MLMDWriter
    Controller -->|conditionally deploys| MariaDB
    Controller -->|conditionally deploys| Minio
    Controller -->|conditionally deploys| MLUI
    Controller -->|"health checks"| MariaDB
    Controller -->|"health checks"| Minio

    %% Data flows
    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    PersistenceAgent -->|reads status| APIServer
    MLMDgRPC -->|stores metadata| MariaDB
    MLMDWriter -->|writes metadata| MLMDgRPC

    %% External dependencies
    APIServer -->|creates PipelineRuns| Tekton["Tekton Pipelines"]
    ScheduledWorkflow -->|manages| SWF_CRD["ScheduledWorkflow CRDs"]
    Controller -->|K8s API| K8sAPI["Kubernetes API"]

    %% External integrations
    Dashboard["ODH Dashboard"] -->|gRPC 9090| MLMDEnvoy
    Prometheus["OpenShift Monitoring"] -->|scrapes metrics| APIServer
    OSRouter["OpenShift Router"] -->|HTTPS 443| OAuthProxy

