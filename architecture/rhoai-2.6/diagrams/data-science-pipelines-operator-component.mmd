graph TB
    subgraph "Data Science Pipelines Operator"
        Controller[DSPO Controller Manager<br/>Reconciles DataSciencePipelinesApplication CRs]
    end

    User[Data Scientist] -->|creates| DSPA_CR[DataSciencePipelinesApplication CR]
    DSPA_CR -->|watched by| Controller

    subgraph "DSPA Instance (per namespace)"
        APIServer[API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP HTTPS OAuth]
        PersistenceAgent[Persistence Agent<br/>Syncs Tekton status]
        ScheduledWorkflow[Scheduled Workflow Controller<br/>Cron-based execution]
        OAuthProxy[OAuth Proxy Sidecar<br/>8443/TCP]

        APIServer -->|sidecars with| OAuthProxy
    end

    subgraph "Optional Components"
        MariaDB[MariaDB<br/>3306/TCP MySQL]
        Minio[Minio<br/>9000/TCP S3 API]
        UI[ML Pipelines UI<br/>8443/TCP HTTPS]
        MLMDgRPC[MLMD gRPC Server<br/>8080/TCP]
        MLMDEnvoy[MLMD Envoy Proxy<br/>9090/TCP]
        MLMDWriter[MLMD Writer]
    end

    Controller -->|creates| APIServer
    Controller -->|creates| PersistenceAgent
    Controller -->|creates| ScheduledWorkflow
    Controller -->|creates| MariaDB
    Controller -->|creates| Minio
    Controller -->|creates| UI
    Controller -->|creates| MLMDgRPC
    Controller -->|creates| MLMDEnvoy
    Controller -->|creates| MLMDWriter

    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|creates| TektonPR[Tekton PipelineRuns]
    PersistenceAgent -->|watches| TektonPR
    PersistenceAgent -->|updates status| MariaDB
    ScheduledWorkflow -->|triggers| APIServer

    MLMDWriter -->|writes lineage| MLMDgRPC
    MLMDgRPC -->|stores in| MariaDB
    MLMDEnvoy -->|proxies to| MLMDgRPC

    Dashboard[ODH Dashboard] -->|visualizes| UI
    Dashboard -->|queries lineage| MLMDEnvoy

    subgraph "External Dependencies"
        Tekton[OpenShift Pipelines<br/>Tekton 1.8+]
        OpenShift[OpenShift 4.9+<br/>Routes, OAuth, Service CA]
        ExternalDB[(External Database<br/>MySQL/PostgreSQL)]
        ExternalS3[(External S3 Storage<br/>AWS/Compatible)]
    end

    Controller -->|depends on| OpenShift
    APIServer -->|creates workflows| Tekton
    PersistenceAgent -->|watches| Tekton
    ScheduledWorkflow -->|creates runs| Tekton

    APIServer -.->|optional| ExternalDB
    APIServer -.->|optional| ExternalS3

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style PersistenceAgent fill:#4a90e2,stroke:#333,stroke-width:2px
    style ScheduledWorkflow fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSPA_CR fill:#f5a623,stroke:#333,stroke-width:2px
    style MariaDB fill:#7ed321,stroke:#333,stroke-width:2px
    style Minio fill:#7ed321,stroke:#333,stroke-width:2px
    style UI fill:#7ed321,stroke:#333,stroke-width:2px
    style MLMDgRPC fill:#7ed321,stroke:#333,stroke-width:2px
    style MLMDEnvoy fill:#7ed321,stroke:#333,stroke-width:2px
    style MLMDWriter fill:#7ed321,stroke:#333,stroke-width:2px
    style Tekton fill:#999,stroke:#333,stroke-width:2px
    style OpenShift fill:#999,stroke:#333,stroke-width:2px
    style ExternalDB fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style ExternalS3 fill:#e8e8e8,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
