        TektonAPI["Tekton API<br/>443/TCP HTTPS<br/>TLS<br/>SA token"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OpenShift OAuth"| Route

    %% Ingress to UI
    Route -->|"HTTPS/8443<br/>TLS (serving cert)<br/>OAuth"| OAuthProxy
    OAuthProxy --> DSPUI

    %% UI to API
    DSPUI -->|"HTTP/8888<br/>plaintext<br/>internal"| APIServer

    %% API to Data Stores
    APIServer -->|"MySQL/3306<br/>plaintext<br/>Username/Password"| MySQL
    APIServer -->|"HTTP/9000<br/>configurable<br/>AccessKey/SecretKey"| MinIO
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA token"| TektonAPI

    %% Controllers
    PersAgent -->|"HTTPS/443<br/>TLS, SA token"| K8sAPI
    PersAgent -->|"HTTP/8888<br/>plaintext"| APIServer
    SchedWF -->|"HTTPS/443<br/>TLS, SA token"| K8sAPI

    %% MLMD
    MetaWriter -->|"gRPC/8080<br/>plaintext"| MetaGRPC
    MetaEnvoy -->|"gRPC/8080<br/>plaintext"| MetaGRPC
    MetaGRPC -->|"MySQL/3306<br/>plaintext<br/>Username/Password"| MySQL

