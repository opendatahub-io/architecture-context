graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User/Client]
    end

    subgraph Ingress["INGRESS (Optional - Service Mesh)"]
        Gateway["Istio Gateway<br/>443/TCP → 8008/TCP<br/>TLS 1.3<br/>RequestAuthentication (optional)"]
    end

    subgraph RuntimePod["MODEL SERVING RUNTIME POD<br/>Namespace: {user-namespace}<br/>SA: modelmesh-serving-sa"]
        direction TB
        RESTProxy["REST Proxy<br/>8008/TCP HTTP<br/>plaintext"]
        ModelMesh["ModelMesh<br/>8085/TCP gRPC<br/>mTLS optional"]
        RuntimeAdapter["Runtime Adapter<br/>8085/TCP gRPC<br/>pod-local"]
        ModelRuntime["Model Runtime<br/>8001/TCP gRPC<br/>pod-local<br/>Triton/MLServer/OpenVINO"]
        StorageHelper["Storage Helper<br/>8086/TCP gRPC"]
    end

    subgraph ControlPlane["CONTROL PLANE<br/>Namespace: modelmesh-serving"]
        direction TB

        subgraph Controller["modelmesh-controller Deployment"]
            ControllerPod["Controller Pod<br/>SA: modelmesh-controller<br/>Replicas: 1 (leader election)"]
        end

        WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS 1.2+"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        etcd["etcd Cluster<br/>2379/TCP gRPC/HTTPS<br/>TLS 1.2+<br/>Client cert auth"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        K8sAPI["K8s API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        Prometheus["Prometheus<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secrets"]
    end

    %% External ingress flow
    Client -->|HTTPS/443<br/>TLS 1.3<br/>Bearer Token| Gateway
    Gateway -->|HTTP/8008<br/>plaintext| RESTProxy

    %% Runtime pod internal flow
    RESTProxy -->|gRPC/8085<br/>mTLS optional| ModelMesh
    ModelMesh -->|gRPC/8085<br/>pod-local| RuntimeAdapter
    RuntimeAdapter -->|gRPC/8001<br/>pod-local| ModelRuntime

    %% Storage flow
    ModelMesh -->|gRPC/8086<br/>pod-local| StorageHelper
    StorageHelper -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    %% Controller flows
    ControllerPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA token| K8sAPI
    ControllerPod -->|gRPC/HTTPS/2379<br/>TLS 1.2+<br/>Client cert| etcd
    ModelMesh -->|gRPC/HTTPS/2379<br/>TLS 1.2+<br/>Client cert| etcd

    %% Webhook flow
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+<br/>API Server mTLS| WebhookSvc

    %% Metrics flow
    Prometheus -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| MetricsSvc

    %% Image pulls
    ControllerPod -.->|HTTPS/443<br/>Pull secrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class RESTProxy,ModelMesh,RuntimeAdapter,ModelRuntime,StorageHelper runtime
    class ControllerPod,WebhookSvc,MetricsSvc controlplane
    class etcd,S3,K8sAPI,Prometheus,Registry externalservice
