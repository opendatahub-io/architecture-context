graph TD
    subgraph AuthFlow ["Authentication Flow"]
        direction TB
        User["User Browser"]
        Route["OpenShift Route<br/>TLS Edge Termination"]
        OAuthProxy["oauth-proxy Sidecar<br/>Port: 8443/TCP<br/>Auth: OAuth2 - OpenShift"]
        NotebookPod["Notebook Container<br/>Port: 8888/TCP<br/>Token auth disabled<br/>UID: 1001 non-root"]
    end

    subgraph RBACMgmt ["RBAC Management - External"]
        direction TB
        Controller["ODH Notebook Controller<br/>manages RBAC"]
        SA["ServiceAccount<br/>per notebook pod"]
        RoleBinding["RoleBinding<br/>created by controller"]
    end

    subgraph SecurityCtx ["Runtime Security Context"]
        direction TB
        NonRoot["Non-root UID 1001"]
        EmptyToken["Token auth disabled<br/>Password auth disabled"]
        OAuthEnforced["OAuth2 Enforced<br/>by oauth-proxy sidecar"]
    end

    subgraph ISRBAC ["ImageStream RBAC"]
        direction TB
        KustomizeSA["Kustomize ServiceAccount"]
        ISRole["Role: ImageStream CRUD"]
        ISResources["Resources:<br/>ImageStreams in<br/>redhat-ods-applications"]
    end

    User -->|"HTTPS/443"| Route
    Route -->|"HTTPS/8443<br/>OAuth2 token"| OAuthProxy
    OAuthProxy -->|"HTTP/8888<br/>plaintext localhost<br/>No auth trusted"| NotebookPod

    Controller -->|"creates"| SA
    Controller -->|"creates"| RoleBinding
    RoleBinding -->|"binds"| SA

    NotebookPod --- NonRoot
    NotebookPod --- EmptyToken
    OAuthProxy --- OAuthEnforced

    KustomizeSA -->|"bound via"| ISRole
    ISRole -->|"get,list,create,update"| ISResources

