graph TD
    subgraph "RBAC Note"
        Note["ℹ️ Notebook Images Component<br/>does not define ClusterRoles or RoleBindings.<br/>RBAC is managed by the Notebook Controller."]
    end

    subgraph "Runtime RBAC (Managed by Notebook Controller)"
        SA["{workbench-name}-sa<br/>ServiceAccount<br/>Created per workbench"]
    end

    subgraph "User Permissions (Managed by OpenShift)"
        UserRole["User must have:<br/>- Workbench ownership OR<br/>- Namespace edit permissions"]
    end

    subgraph "ServiceAccount Permissions"
        K8sAPI["Kubernetes API Resources"]
        Secrets["Secrets<br/>- {workbench}-notebook-token<br/>- aws-connection-{name}<br/>- generic-s3-secret"]
        ConfigMaps["ConfigMaps<br/>- Jupyter config<br/>- Custom configs"]
        PVCs["PersistentVolumeClaims<br/>- Workbench storage"]
    end

    subgraph "External API Access"
        DSP_API["Data Science Pipeline API<br/>Bearer Token Auth"]
        ModelReg_API["Model Registry API<br/>ServiceAccount Token"]
    end

    subgraph "Notebook Controller Permissions"
        Controller["Notebook Controller<br/>ServiceAccount"]
        ControllerPerms["Permissions:<br/>- Create/Delete StatefulSets<br/>- Create/Delete Services<br/>- Create/Delete ServiceAccounts<br/>- Mount Secrets/ConfigMaps"]
    end

    %% Relationships
    SA -->|read| Secrets
    SA -->|read| ConfigMaps
    SA -.->|read/write| PVCs
    SA -->|API calls| K8sAPI
    SA -->|authenticate| DSP_API
    SA -->|authenticate| ModelReg_API

    Controller -->|manages| SA
    Controller -->|creates| ControllerPerms

    UserRole -.->|access control| SA

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#000
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#7ed321,stroke:#333,color:#000
    style UserRole fill:#f5a623,stroke:#333,color:#000
    style Secrets fill:#d5e8d4,stroke:#82b366
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style PVCs fill:#d5e8d4,stroke:#82b366
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style DSP_API fill:#dae8fc,stroke:#6c8ebf
    style ModelReg_API fill:#dae8fc,stroke:#6c8ebf
    style ControllerPerms fill:#e1d5e7,stroke:#9673a6
