/*
 * C4 Context Diagram - Red Hat OpenShift AI 2.6 Platform
 * Generated by: Claude Opus 4.6
 *
 * View with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace platform-c4-context.dsl -format png
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Develops models, runs notebooks, deploys inference services"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform lifecycle via DataScienceCluster CRs"
        mlEngineer = person "ML Engineer" "Builds and orchestrates ML pipelines, manages model serving"
        securityTeam = person "Security / SRE" "Monitors fairness metrics, manages platform security"

        rhoai = softwareSystem "Red Hat OpenShift AI 2.6" "Enterprise AI/ML platform on OpenShift" {
            rhodsOperator = container "rhods-operator" "Platform orchestrator managing all RHOAI components via DSCInitialization and DataScienceCluster CRs" "Go Operator (OLM)"
            odhManifests = container "odh-manifests" "Kustomize-based deployment manifests for all platform components" "Kustomize Manifests"
            odhDashboard = container "ODH Dashboard" "Web UI and API backend for managing data science resources (notebooks, models, pipelines)" "Node.js + React"
            notebookController = container "Notebook Controller" "Manages Jupyter/VS Code/RStudio notebook server lifecycle with OAuth proxy" "Go Operator"
            kserveController = container "KServe Controller" "Single-model serverless inference with Knative and Istio integration" "Go Operator"
            modelmeshServing = container "ModelMesh Serving" "Multi-model serving controller with distributed LRU cache and routing" "Go Operator + Java Sidecar"
            odhModelController = container "ODH Model Controller" "OpenShift-specific Route, NetworkPolicy, and Service Mesh management for model serving" "Go Operator"
            dsPipelinesOperator = container "DS Pipelines Operator" "Manages Data Science Pipelines application deployments" "Go Operator"
            dsPipelines = container "Data Science Pipelines" "Kubeflow Pipelines API server with Tekton backend for ML workflow orchestration" "Go + Python"
            codeflareOperator = container "CodeFlare Operator" "MCAD and InstaScale for distributed AI/ML workload scheduling" "Go Operator"
            kuberayOperator = container "KubeRay Operator" "Ray cluster lifecycle management (RayCluster, RayJob, RayService)" "Go Operator"
            trustyaiOperator = container "TrustyAI Operator" "Manages TrustyAI service lifecycle and model serving integration" "Go Operator"
            trustyaiService = container "TrustyAI Service" "AI fairness metrics (SPD, DIR), bias tracking, drift detection, LIME/SHAP explainability" "Quarkus 3.2.7"
            caikitTgis = container "Caikit-TGIS Serving" "LLM inference runtime combining Caikit framework with TGIS backend" "Python + gRPC"
            notebooks = container "Notebook Images" "Pre-built Jupyter, VS Code, RStudio workbench container images with ML frameworks" "Container Images"
            monitoring = container "Platform Monitoring" "Prometheus, Alertmanager, Blackbox Exporter for platform health" "Prometheus Stack"
        }

        ocp = softwareSystem "OpenShift Container Platform" "Base Kubernetes platform with Routes, OAuth, OLM, and container runtime" "External"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for traffic management, mTLS enforcement, and network policies" "External"
        knative = softwareSystem "OpenShift Serverless (Knative)" "Serverless autoscaling platform with scale-to-zero capability" "External"
        tekton = softwareSystem "Tekton Pipelines" "Cloud-native CI/CD pipeline execution engine" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Object storage for model artifacts and pipeline data (AWS S3, MinIO, Ceph)" "External"
        etcd = softwareSystem "etcd" "Distributed key-value store for ModelMesh coordination" "External"
        mariadb = softwareSystem "MySQL/MariaDB" "Relational database for pipeline metadata storage" "External"
        pagerduty = softwareSystem "PagerDuty / Monitoring" "Alert escalation and dead-man's switch services (Managed RHOAI)" "External"

        /* Person interactions */
        platformAdmin -> rhoai "Configures platform via DataScienceCluster CR"
        dataScientist -> odhDashboard "Creates notebooks, deploys models" "HTTPS/443 OAuth"
        dataScientist -> notebooks "Develops and trains ML models" "HTTPS/443 OAuth"
        mlEngineer -> dsPipelines "Manages ML pipelines" "HTTPS/443 OAuth"
        mlEngineer -> kserveController "Deploys InferenceServices" "kubectl/HTTPS"
        securityTeam -> trustyaiService "Monitors fairness metrics" "HTTPS/443"
        securityTeam -> monitoring "Reviews platform health" "HTTPS/443 OAuth"

        /* Internal container relationships */
        rhodsOperator -> odhManifests "Renders deployment manifests" "Kustomize"
        rhodsOperator -> odhDashboard "Manages lifecycle"
        rhodsOperator -> notebookController "Manages lifecycle"
        rhodsOperator -> kserveController "Manages lifecycle"
        rhodsOperator -> modelmeshServing "Manages lifecycle"
        rhodsOperator -> odhModelController "Manages lifecycle"
        rhodsOperator -> dsPipelinesOperator "Manages lifecycle"
        rhodsOperator -> codeflareOperator "Manages lifecycle"
        rhodsOperator -> kuberayOperator "Manages lifecycle"
        rhodsOperator -> trustyaiOperator "Manages lifecycle"

        odhDashboard -> notebookController "Creates Notebook CRs"
        odhDashboard -> kserveController "Views InferenceService status"
        odhDashboard -> modelmeshServing "Views InferenceService status"
        odhDashboard -> dsPipelinesOperator "Pipeline metadata via MLMD Envoy"

        notebookController -> notebooks "Creates StatefulSets with workbench images" "ImageStreams"

        kserveController -> caikitTgis "Uses as serving runtime" "gRPC/8033"
        odhModelController -> kserveController "Creates Routes, NetworkPolicies, PeerAuth"
        odhModelController -> modelmeshServing "Creates Routes, ServiceAccounts"

        dsPipelinesOperator -> dsPipelines "Deploys pipeline stack"

        codeflareOperator -> kuberayOperator "Schedules workloads to Ray" "AppWrapper → RayCluster"

        trustyaiOperator -> trustyaiService "Deploys TrustyAI instances"
        trustyaiService -> modelmeshServing "Receives inference payloads" "HTTP/80"
        trustyaiService -> kserveController "Receives inference logs" "HTTP/80"

        /* External dependencies */
        rhoai -> ocp "Runs on OpenShift" "Routes, OAuth, OLM"
        kserveController -> istio "Traffic routing, mTLS enforcement" "VirtualService, PeerAuth"
        kserveController -> knative "Serverless autoscaling, scale-to-zero" "Knative Service"
        odhModelController -> istio "ServiceMeshMemberRoll management"
        dsPipelines -> tekton "Executes pipeline steps" "PipelineRun/TaskRun"
        kserveController -> s3Storage "Downloads model artifacts" "HTTPS/443"
        modelmeshServing -> s3Storage "Downloads model artifacts" "HTTPS/443"
        modelmeshServing -> etcd "Distributed coordination" "gRPC/2379 TLS"
        dsPipelines -> mariadb "Pipeline metadata storage" "MySQL/3306"
        dsPipelines -> s3Storage "Pipeline artifact storage" "HTTPS/443"
        monitoring -> pagerduty "Alert escalation (Managed RHOAI)" "HTTPS/443"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
        }
    }
}
