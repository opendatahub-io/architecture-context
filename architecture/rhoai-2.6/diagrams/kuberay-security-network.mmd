graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
        APIClient[API Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressRoute["Ingress/Route<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Optional TLS"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: opendatahub"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP Metrics (HTTP)<br/>8082/TCP Health (HTTP)<br/>runAsNonRoot: true"]
            Prometheus["Prometheus (optional)<br/>Scrapes metrics"]
        end

        subgraph NS_APIServer["Namespace: ray-system (optional)"]
            APIServer["KubeRay APIServer<br/>SA: kuberay-apiserver<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>K8s RBAC"]
        end

        subgraph NS_User["Namespace: &lt;user-namespace&gt;"]
            HeadPod["Ray Head Pod<br/>SA: &lt;raycluster&gt;-sa<br/>UID 1000 (SCC)<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
            WorkerPods["Ray Worker Pods<br/>SA: &lt;raycluster&gt;-sa<br/>UID 1000<br/>Autoscaling"]
            ServePod["Ray Serve Pod<br/>8000/TCP HTTP"]

            HeadSvc["ClusterIP Service<br/>&lt;raycluster&gt;-head-svc<br/>6379/8265/10001"]
            ServeSvc["ClusterIP Service<br/>&lt;rayservice&gt;-serve-svc<br/>8000/TCP"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
        Storage["S3/GCS (optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Cloud Auth"]
        Volcano["Volcano Scheduler (optional)<br/>via K8s API"]
    end

    %% External flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>App Auth| IngressRoute
    APIClient -->|HTTP/8888<br/>gRPC/8887<br/>K8s RBAC| APIServer

    %% Ingress flows
    IngressRoute -->|HTTP/8265<br/>No Auth| HeadSvc
    IngressRoute -->|HTTP/8000<br/>No Auth| ServeSvc

    %% Operator flows
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    Prometheus -->|HTTP/8080<br/>No Auth| Operator

    %% APIServer flows
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% K8s API flows
    K8sAPI -->|Watch Events<br/>TLS 1.2+| Operator
    K8sAPI -->|Create Pods/Services| HeadPod
    K8sAPI -->|Create Pods| WorkerPods
    K8sAPI -->|Create Pods| ServePod

    %% Ray cluster internal flows
    WorkerPods -->|TCP/6379<br/>GCS Protocol<br/>No Encryption<br/>No Auth| HeadPod
    ServePod -->|TCP/6379<br/>GCS Protocol<br/>No Encryption| HeadPod
    HeadPod --> HeadSvc
    ServePod --> ServeSvc

    %% External service flows
    HeadPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry
    WorkerPods -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry
    HeadPod -.->|HTTPS/443<br/>TLS 1.2+<br/>Cloud Auth| Storage
    WorkerPods -.->|HTTPS/443<br/>TLS 1.2+<br/>Cloud Auth| Storage
    Operator -.->|HTTPS/443<br/>Gang Scheduling| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#2e5c8a,stroke-width:3px
    classDef raypod fill:#7ed321,stroke:#5a9c18,stroke-width:2px

    class Client,APIClient external
    class IngressRoute ingress
    class Operator operator
    class APIServer,K8sAPI,Prometheus internal
    class HeadPod,WorkerPods,ServePod,HeadSvc,ServeSvc raypod
    class Registry,Storage,Volcano externalservice
