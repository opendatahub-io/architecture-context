graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router / Istio Gateway<br/>443/TCP to 8888/TCP<br/>HTTPS TLS 1.2+<br/>OAuth Bearer Token"]
        OAuth["OAuth Proxy - optional<br/>8888/TCP HTTP<br/>JWT Validation"]
    end

    subgraph ServiceMesh["SERVICE MESH - mTLS Optional PERMISSIVE"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            NotebookSvc["Notebook Service ClusterIP<br/>8888/TCP HTTP<br/>Selector: notebook-name"]
            NotebookPod["Notebook Pod StatefulSet<br/>workbench-name-0<br/>SA: workbench-name-sa<br/>Image: quay.io/modh/...:2023.2<br/>User: UID 1001 GID 0<br/>SELinux: container_t"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Quay["Quay.io Registry<br/>quay.io/modh/*<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"]
        PyPI["PyPI<br/>pypi.org<br/>HTTPS/443<br/>TLS 1.2+<br/>Public"]
        S3["S3 Storage<br/>AWS S3 / MinIO<br/>HTTPS/443<br/>TLS 1.2+<br/>AWS Signature v4"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Username/Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/Password"]
        MSSQL["MS SQL Server<br/>1433/TCP TDS<br/>TLS optional<br/>Username/Password"]
    end

    subgraph InternalServices["INTERNAL RHOAI SERVICES"]
        DSP["Data Science Pipeline API<br/>8888/TCP HTTP<br/>mTLS if Service Mesh<br/>Bearer Token"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP<br/>mTLS if Service Mesh<br/>ServiceAccount Token"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    %% Ingress Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token| Router
    Router -->|HTTP/8888<br/>Bearer Token validation| OAuth
    OAuth -->|HTTP/8888<br/>mTLS optional<br/>Session Cookie| NotebookSvc
    NotebookSvc -->|HTTP/8888<br/>Jupyter Token or Cookie| NotebookPod

    %% Egress - External Services
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Quay
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>Public| PyPI
    NotebookPod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Signature v4| S3
    NotebookPod -.->|27017/TCP<br/>TLS optional<br/>Username and Password| MongoDB
    NotebookPod -.->|5432/TCP<br/>TLS optional<br/>Username and Password| PostgreSQL
    NotebookPod -.->|1433/TCP TDS<br/>TLS optional<br/>Username and Password| MSSQL

    %% Egress - Internal Services
    NotebookPod -->|HTTP/8888<br/>mTLS optional<br/>Bearer Token| DSP
    NotebookPod -->|HTTP/8080<br/>mTLS optional<br/>SA Token| ModelRegistry
    NotebookPod -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Router,OAuth ingress
    class NotebookSvc,NotebookPod servicemesh
    class Quay,PyPI,S3,MongoDB,PostgreSQL,MSSQL externalservice
    class DSP,ModelRegistry,K8sAPI internalservice
