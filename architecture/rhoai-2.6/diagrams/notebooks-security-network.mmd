%% Security Network Diagram for Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.6/notebooks.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ - Edge TLS Termination)"]
        Route["OpenShift Route<br/>443/TCP HTTPS<br/>TLS Edge Termination<br/>Auth: Redirect to OAuth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_Notebook["Namespace: {user-namespace}"]
            OAuthProxy["oauth-proxy Sidecar<br/>8443/TCP HTTPS<br/>Auth: OAuth2 (OpenShift)<br/>SA: notebook-controller"]

            subgraph NotebookPod["Notebook Pod (UID: 1001)"]
                Jupyter["JupyterLab Container<br/>8888/TCP HTTP<br/>ServerApp.token='' (empty)<br/>Auth: None (trusted by oauth-proxy)"]
                CodeSrv["code-server Container<br/>8585/TCP HTTP<br/>NGINX reverse proxy<br/>Auth: None (trusted by oauth-proxy)"]
                RSrv["RStudio Container<br/>8787/TCP HTTP<br/>NGINX reverse proxy<br/>Auth: None (trusted by oauth-proxy)"]
            end

            NotebookSvc["{notebook-name}-notebook<br/>Service: ClusterIP<br/>8888/TCP HTTP<br/>Auth: None (in-cluster)"]
        end

        subgraph NS_DSP["Namespace: {dsp-namespace}"]
            DSPipelines["Data Science Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
        end

        subgraph NS_RHOAI["Namespace: redhat-ods-applications"]
            Dashboard["ODH Dashboard<br/>K8s API<br/>TLS 1.2+"]
            NotebookCtrl["ODH Notebook Controller<br/>K8s API<br/>TLS 1.2+"]
        end

        OSAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Quay["quay.io/modh/*<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS Credentials"]
        PyPI["PyPI / pip repos<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None"]
        Kafka["Kafka Brokers<br/>9092/TCP<br/>TLS optional<br/>Auth: SASL optional"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Auth: Credentials"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Auth: Credentials"]
        MSSQL["MSSQL Server<br/>1433/TCP<br/>TLS optional<br/>Auth: Credentials"]
    end

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS Edge<br/>Redirect to OAuth"| Route
    Route -->|"HTTPS/8443<br/>TLS<br/>OAuth2 Token"| OAuthProxy
    OAuthProxy -->|"HTTP/8888<br/>plaintext (localhost)<br/>No auth (trusted)"| Jupyter

    %% Service routing
    NotebookSvc -->|"HTTP/8888"| Jupyter
    NotebookSvc -->|"HTTP/8585"| CodeSrv
    NotebookSvc -->|"HTTP/8787"| RSrv

    %% Internal flows
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| DSPipelines
    NotebookCtrl -->|"K8s API<br/>reads ImageStreams"| OSAPI
    Dashboard -->|"K8s API<br/>reads ImageStream annotations"| OSAPI

    %% Egress flows
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Creds"| S3
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    Jupyter -->|"TCP/9092<br/>TLS/SASL optional"| Kafka
    Jupyter -->|"TCP/27017<br/>TLS optional"| MongoDB
    Jupyter -->|"TCP/5432<br/>TLS optional"| PostgreSQL
    Jupyter -->|"TCP/1433<br/>TLS optional"| MSSQL
    OSAPI -->|"HTTPS/443<br/>TLS 1.2+"| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef notebook fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Route ingress
    class OAuthProxy,Jupyter,CodeSrv,RSrv,NotebookSvc notebook
