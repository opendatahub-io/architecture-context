%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.6/kuberay.md

graph TB
    subgraph "KubeRay Operator"
        direction TB
        Operator[kuberay-operator<br/>Go Operator<br/>controller-runtime v0.16.3]
        RCCtrl[RayCluster Controller]
        RJCtrl[RayJob Controller]
        RSCtrl[RayService Controller]
        DashClient[Ray Dashboard<br/>HTTP Client]
        BatchMgr[Batch Scheduler<br/>Manager<br/>optional]

        Operator --> RCCtrl
        Operator --> RJCtrl
        Operator --> RSCtrl
        RJCtrl --> DashClient
        RSCtrl --> DashClient
        Operator -.-> BatchMgr
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| RayClusterCR[RayCluster CR<br/>ray.io/v1]
    User -->|creates| RayJobCR[RayJob CR<br/>ray.io/v1]
    User -->|creates| RayServiceCR[RayService CR<br/>ray.io/v1]

    RayClusterCR -->|watched by| RCCtrl
    RayJobCR -->|watched by| RJCtrl
    RayServiceCR -->|watched by| RSCtrl

    %% Resources created by RayCluster Controller
    RCCtrl -->|creates| HeadPod[Ray Head Pod]
    RCCtrl -->|creates| WorkerPods[Ray Worker Pods]
    RCCtrl -->|creates| HeadSvc[Head Service<br/>ports: 6379, 8265,<br/>8000, 8080, 10001]
    RCCtrl -->|creates| RouteIngress[Route / Ingress<br/>dashboard:8265]
    RCCtrl -->|creates| AutoscalerRBAC[Autoscaler RBAC<br/>Role + RoleBinding]

    %% Resources created by RayJob Controller
    RJCtrl -->|creates/manages| RayClusterCR
    RJCtrl -->|creates| BatchJob[K8s Batch Job<br/>job submission]
    DashClient -->|HTTP 8265| HeadPod

    %% Resources created by RayService Controller
    RSCtrl -->|creates| ActiveCluster[Active RayCluster]
    RSCtrl -->|creates| PendingCluster[Pending RayCluster<br/>zero-downtime upgrade]
    RSCtrl -->|creates| ServeSvc[Serve Service<br/>port: 8000]

    %% External dependencies
    Operator -->|depends on| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
    BatchMgr -.->|optional| Volcano[Volcano Scheduler]

    %% Integration points
    Prometheus[Prometheus] -->|scrapes 8080| Operator
    RHOAIOp[RHOAI Operator] -->|deploys via kustomize| Operator
    OSRouter[OpenShift Router] -->|routes traffic| RouteIngress

