graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator<br/>Port: 8080/TCP Metrics<br/>Port: 8082/TCP Health]
        RayClusterCtrl[RayCluster Controller]
        RayJobCtrl[RayJob Controller]
        RayServiceCtrl[RayService Controller]

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
    end

    subgraph "Optional API Server"
        APIServer[KubeRay APIServer<br/>Port: 8888/TCP HTTP<br/>Port: 8887/TCP gRPC]
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Cluster Resources"
        HeadPod[Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client]
        WorkerPods[Ray Worker Pods<br/>Autoscaling: min/max replicas]
        HeadService["&lt;raycluster&gt;-head-svc<br/>ClusterIP"]

        HeadPod --> HeadService
        WorkerPods -->|connects to| HeadPod
    end

    subgraph "Ray Service Resources"
        ServePod[Ray Serve Pod]
        ServeService["&lt;rayservice&gt;-serve-svc<br/>8000/TCP HTTP<br/>ClusterIP"]

        ServePod --> ServeService
    end

    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    Client[API Client] -->|HTTP/gRPC| APIServer
    APIServer -->|creates| RayClusterCR
    APIServer -->|creates| RayJobCR
    APIServer -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadService

    RayJobCtrl -->|creates| RayClusterCR
    RayJobCtrl -->|submits job to| HeadPod

    RayServiceCtrl -->|creates| RayClusterCR
    RayServiceCtrl -->|creates| ServePod
    RayServiceCtrl -->|creates| ServeService

    Operator -->|integrates| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
    Operator -->|metrics| Prometheus[Prometheus<br/>Scrapes 8080/TCP]

    HeadPod -->|pulls from| Registry[Container Registry<br/>443/TCP HTTPS]
    WorkerPods -->|pulls from| Registry

    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style APIServer fill:#9b59b6,stroke:#333,stroke-width:2px
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style HeadPod fill:#7ed321,stroke:#333,stroke-width:2px
    style WorkerPods fill:#7ed321,stroke:#333,stroke-width:2px
    style ServePod fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Registry fill:#e8e8e8,stroke:#333
