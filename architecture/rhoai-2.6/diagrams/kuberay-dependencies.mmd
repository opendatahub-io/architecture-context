graph LR
    KubeRay[KubeRay Operator]

    %% External Dependencies - Required
    KubeRay -->|platform| K8s[Kubernetes 1.28.3+<br/>REQUIRED]
    KubeRay -->|manages| Ray[Ray 2.7.0+<br/>REQUIRED]

    %% External Dependencies - Optional
    KubeRay -.->|ingress| Routes[OpenShift Routes v1<br/>OPTIONAL]
    KubeRay -.->|gang scheduling| Volcano[Volcano Scheduler<br/>OPTIONAL]
    KubeRay -.->|monitoring| Prom[Prometheus<br/>OPTIONAL]

    %% Internal ODH/RHOAI Dependencies
    KubeRay -.->|UI integration| Dashboard[ODH Dashboard<br/>INTERNAL]
    KubeRay -->|metrics export| MonStack[Monitoring Stack<br/>INTERNAL]

    %% External Services
    KubeRay -->|image pull| Registry[Container Registry<br/>EXTERNAL]
    KubeRay -->|API operations| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]

    %% Ray Ecosystem
    Ray -->|data storage| S3[S3/GCS Storage<br/>OPTIONAL]
    Ray -->|container images| Registry

    %% Integration Points
    subgraph "Integration Points"
        direction TB
        Dashboard -.->|UI management| KubeRay
        Pipelines[Data Science Pipelines] -.->|auto deploy| KubeRay
        ODHOps[ODH Operator] -.->|deployment| KubeRay
    end

    %% Component relationships
    subgraph "KubeRay Components"
        direction TB
        KubeRay --> OperatorPod[kuberay-operator pod]
        KubeRay -.-> APIServerPod[kuberay-apiserver pod<br/>OPTIONAL]
    end

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px
    style K8s fill:#326ce5,stroke:#333,stroke-width:3px
    style Ray fill:#00add8,stroke:#333,stroke-width:3px
    style Routes fill:#cc0000,stroke:#333
    style Volcano fill:#999,stroke:#333
    style Prom fill:#e6522c,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style MonStack fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style ODHOps fill:#7ed321,stroke:#333
    style Registry fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OperatorPod fill:#4a90e2,stroke:#333
    style APIServerPod fill:#9b59b6,stroke:#333

    %% Legend
    subgraph Legend
        Required[Required Dependency]
        Optional[Optional Dependency]
        Internal[Internal ODH/RHOAI]
        External[External Service]
    end

    style Required fill:#326ce5,stroke:#333
    style Optional fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Internal fill:#7ed321,stroke:#333
    style External fill:#f5a623,stroke:#333
