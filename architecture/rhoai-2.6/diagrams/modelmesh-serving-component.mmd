        Controller --> Webhook
    end

    subgraph "Runtime Deployment Pod"
        direction TB
        MMSidecar["ModelMesh Sidecar (mm)<br/>gRPC 8033/TCP<br/>Model Routing & Caching"]
        RuntimeContainer["Runtime Container<br/>(Model Server)"]
        OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS"]
        RESTProxy["REST Proxy<br/>(optional)"]
        StorageHelper["Storage Helper / Puller<br/>(optional)"]

        OAuthProxy -->|"plaintext in-pod"| RESTProxy
        RESTProxy -->|"gRPC in-pod"| MMSidecar
        MMSidecar -->|"gRPC/Unix socket"| RuntimeContainer
        MMSidecar -->|"gRPC 8086"| StorageHelper
    end

    %% CRDs
    User[Data Scientist / Client] -->|creates| ServingRuntimeCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| ClusterSRCR["ClusterServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| PredictorCR["Predictor CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]

    ServingRuntimeCR -->|watched by| SRReconciler
    ClusterSRCR -->|watched by| SRReconciler
    PredictorCR -->|watched by| PredReconciler
    InferenceServiceCR -->|watched by| PredReconciler

    %% Reconciler actions
    SRReconciler -->|"creates/manages"| RuntimeDeployment["Runtime Deployment"]
    SRReconciler -->|"manages"| HPA["HorizontalPodAutoscaler"]
    SvcReconciler -->|"creates/manages"| MMService["modelmesh-serving Service<br/>ClusterIP"]
    SvcReconciler -->|"creates"| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    PredReconciler -->|"gRPC: SetVModel/DeleteVModel"| MMSidecar

    RuntimeDeployment -->|contains| MMSidecar
    RuntimeDeployment -->|contains| RuntimeContainer
    RuntimeDeployment -->|contains| OAuthProxy
    RuntimeDeployment -->|contains| RESTProxy
    RuntimeDeployment -->|contains| StorageHelper

    %% External dependencies
    Controller -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    MMSidecar -->|"2379/TCP gRPC"| etcd["etcd Cluster"]
    StorageHelper -->|"443/TCP HTTPS"| ObjectStorage["Object Storage<br/>(S3/GCS/Azure)"]

