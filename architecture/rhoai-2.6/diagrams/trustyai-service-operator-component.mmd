graph TB
    subgraph "TrustyAI Service Operator"
        OperatorManager[Operator Manager<br/>Controller]
        HealthProbes[Health Probes<br/>8081/TCP]
        MetricsEndpoint[Metrics Endpoint<br/>8080/TCP]

        OperatorManager -->|exposes| HealthProbes
        OperatorManager -->|exposes| MetricsEndpoint
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
    end

    subgraph "Managed TrustyAI Service Instance"
        TrustyAIDeployment[TrustyAI Service Deployment]
        OAuthProxy[OAuth Proxy Sidecar<br/>8443/TCP HTTPS]
        TrustyAIContainer[TrustyAI Container<br/>8080/TCP HTTP]
        PVC[Persistent Volume Claim<br/>ReadWriteOnce]

        TrustyAIDeployment -->|contains| OAuthProxy
        TrustyAIDeployment -->|contains| TrustyAIContainer
        TrustyAIContainer -->|mounts| PVC
    end

    subgraph "Network Resources"
        Service[ClusterIP Service<br/>80/TCP, 443/TCP]
        TLSService[TLS Service<br/>443/TCP]
        Route[OpenShift Route<br/>443/TCP HTTPS TLS Passthrough]
        ServiceMonitor[ServiceMonitor<br/>Prometheus Integration]
    end

    subgraph "External Dependencies"
        KServe[KServe<br/>InferenceService CRDs]
        ModelMesh[Model Mesh]
        PrometheusOp[Prometheus Operator]
        OpenShiftOAuth[OpenShift OAuth Server]
        OpenShiftRouter[OpenShift Router]
    end

    User[User] -->|creates| TrustyAIServiceCR
    TrustyAIServiceCR -->|watched by| OperatorManager

    OperatorManager -->|creates/manages| TrustyAIDeployment
    OperatorManager -->|creates| Service
    OperatorManager -->|creates| TLSService
    OperatorManager -->|creates| Route
    OperatorManager -->|creates| ServiceMonitor
    OperatorManager -->|creates| PVC

    OperatorManager -->|watches| KServe
    OperatorManager -->|patches env vars| ModelMesh

    Route -->|routes to| OAuthProxy
    OAuthProxy -->|authenticates via| OpenShiftOAuth
    OAuthProxy -->|proxies to| TrustyAIContainer

    PrometheusOp -->|scrapes via| ServiceMonitor
    ServiceMonitor -->|monitors| Service
    Service -->|targets| TrustyAIContainer

    OpenShiftRouter -->|terminates TLS| Route

    KServe -->|sends inference data| TrustyAIContainer

    style OperatorManager fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrustyAIDeployment fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAIContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe fill:#e8e8e8,stroke:#333,stroke-width:2px
    style ModelMesh fill:#e8e8e8,stroke:#333,stroke-width:2px
    style PrometheusOp fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OpenShiftOAuth fill:#e8e8e8,stroke:#333,stroke-width:2px
    style OpenShiftRouter fill:#e8e8e8,stroke:#333,stroke-width:2px
