graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[codeflare-operator-<br/>manager-rolebinding]
        CRB2[codeflare-operator-<br/>instascale-rolebinding]
        CRB3[codeflare-operator-<br/>mcad-controller-ray-<br/>clusterrolebinding]
        CRB4[codeflare-operator-<br/>leader-election-rolebinding]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[instascale-role]
        CR3[mcad-controller-<br/>ray-clusterrole]
        CR4[leader-election-role]
    end

    subgraph "API Resources - CodeFlare CRDs"
        R1[workload.codeflare.dev<br/>AppWrapper<br/>SchedulingSpec]
        R2[quota.codeflare.dev<br/>QuotaSubtree]
    end

    subgraph "API Resources - Core Kubernetes"
        R3[core<br/>Pods, Services<br/>ConfigMaps, Secrets<br/>ServiceAccounts, PVs, PVCs<br/>Nodes, Events]
        R4[apps<br/>Deployments<br/>ReplicaSets<br/>StatefulSets]
        R5[batch<br/>Jobs]
        R6[coordination.k8s.io<br/>Leases]
        R7[scheduling.sigs.k8s.io<br/>PodGroups]
    end

    subgraph "API Resources - Ray Integration"
        R8[ray.io<br/>RayClusters]
        R9[networking.k8s.io<br/>Ingresses]
        R10[route.openshift.io<br/>Routes]
    end

    subgraph "API Resources - Machine API"
        R11[machine.openshift.io<br/>Machines<br/>MachineSets]
        R12[config.openshift.io<br/>ClusterVersions]
    end

    %% Service Account to ClusterRoleBindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4

    %% ClusterRoleBindings to ClusterRoles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    CRB4 -->|grants| CR4

    %% manager-role permissions
    CR1 -->|create,delete,deletecollection<br/>get,list,patch,update,watch| R1
    CR1 -->|create,delete,deletecollection<br/>get,list,patch,update,watch| R2
    CR1 -->|create,delete,get,list<br/>patch,update,watch| R3
    CR1 -->|create pods/binding<br/>create bindings| R3
    CR1 -->|create,patch,update events| R3
    CR1 -->|create,delete,get,list<br/>patch,update,watch| R4
    CR1 -->|create,delete,list<br/>patch,update,watch| R5
    CR1 -->|create,get,update| R6
    CR1 -->|create,delete,deletecollection<br/>get,list,patch,update,watch| R7
    CR1 -->|get,list| R12

    %% instascale-role permissions
    CR2 -->|get,list,patch,update| R3
    CR2 -->|get secrets| R3
    CR2 -->|create,delete,get,list<br/>patch,update,watch| R11
    CR2 -->|get,list,watch| R12

    %% mcad-controller-ray-clusterrole permissions
    CR3 -->|create,delete,get,list<br/>patch,update,watch| R8
    CR3 -->|create,delete,get,list<br/>patch,update,watch| R9
    CR3 -->|create,delete,get,list<br/>patch,update,watch| R10

    %% leader-election-role permissions
    CR4 -->|get,list,watch,create<br/>update,patch,delete| R3
    CR4 -->|get,list,watch,create<br/>update,patch,delete| R6

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623,color:#000
    style CR2 fill:#f5a623,color:#000
    style CR3 fill:#f5a623,color:#000
    style CR4 fill:#f5a623,color:#000
    style R1 fill:#7ed321,color:#000
    style R2 fill:#7ed321,color:#000
    style R3 fill:#7ed321,color:#000
    style R4 fill:#7ed321,color:#000
    style R5 fill:#7ed321,color:#000
    style R6 fill:#7ed321,color:#000
    style R7 fill:#7ed321,color:#000
    style R8 fill:#7ed321,color:#000
    style R9 fill:#7ed321,color:#000
    style R10 fill:#7ed321,color:#000
    style R11 fill:#7ed321,color:#000
    style R12 fill:#7ed321,color:#000
