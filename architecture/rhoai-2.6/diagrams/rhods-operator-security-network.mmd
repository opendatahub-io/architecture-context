graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Platform Admin /<br/>Data Scientists]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Edge TLS)"]
        PromRoute["Prometheus Route<br/>prometheus-redhat-ods-monitoring.cluster-domain<br/>443/TCP → 9090/TCP<br/>TLS 1.2+ edge termination<br/>OpenShift OAuth"]
        AlertRoute["Alertmanager Route<br/>alertmanager-redhat-ods-monitoring.cluster-domain<br/>443/TCP → 9093/TCP<br/>TLS 1.2+ edge termination<br/>OpenShift OAuth"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account Token / kubeconfig"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB
        Operator["RHODS Operator Pod<br/>SA: controller-manager<br/>SecurityContext: runAsNonRoot=true<br/>SCC: restricted"]

        subgraph OperatorPorts["Exposed Ports"]
            Metrics["8080/TCP HTTP<br/>/metrics<br/>Auth: None (NetworkPolicy)"]
            Health["8081/TCP HTTP<br/>/healthz, /readyz<br/>Auth: None (kubelet)"]
            Webhook["9443/TCP HTTPS<br/>/validate-*, /mutate-*<br/>Auth: mTLS (K8s API cert)"]
        end

        Operator --- OperatorPorts
    end

    subgraph MonitoringNS["MONITORING NAMESPACE (redhat-ods-monitoring)"]
        direction TB
        Prometheus["Prometheus<br/>SA: prometheus<br/>9090/TCP HTTP<br/>OAuth proxy for external"]
        Alertmanager["Alertmanager<br/>9093/TCP HTTP<br/>OAuth proxy for external"]
        Blackbox["Blackbox Exporter<br/>Probe: 9114/TCP HTTP<br/>Metrics: 9115/TCP HTTP"]
    end

    subgraph ApplicationsNS["APPLICATIONS NAMESPACE (redhat-ods-applications)"]
        Components["Managed Components<br/>Dashboard, Workbenches,<br/>KServe, ModelMesh,<br/>Pipelines, Ray, etc.<br/>NetworkPolicy: monitoring,<br/>same namespace, service mesh"]
    end

    subgraph ServiceMeshNS["SERVICE MESH (Optional)"]
        ServiceMesh["Service Mesh Control Plane<br/>Namespace: istio-system<br/>mTLS STRICT mode<br/>AuthorizationPolicy<br/>Service Identity"]
    end

    subgraph EgressExternal["EGRESS (External Services)"]
        OAuth["OpenShift OAuth<br/>443/TCP HTTPS TLS1.2+<br/>OAuth client registration"]
        Quay["quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Public container images"]
        RedHat["registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Red Hat images<br/>Auth: Pull Secret"]
        GitHub["github.com (dev mode)<br/>443/TCP HTTPS TLS1.2+<br/>Manifest downloads"]
    end

    %% External flows
    Admin -->|kubectl apply<br/>kubeconfig credentials<br/>HTTPS/443 TLS1.2+| K8sAPI
    Admin -->|Web UI access<br/>OpenShift OAuth<br/>HTTPS/443 TLS1.2+| PromRoute
    Admin -->|Web UI access<br/>OpenShift OAuth<br/>HTTPS/443 TLS1.2+| AlertRoute

    %% Ingress to monitoring
    PromRoute -->|HTTP/9090<br/>oauth-proxy| Prometheus
    AlertRoute -->|HTTP/9093<br/>oauth-proxy| Alertmanager

    %% Control plane interactions
    K8sAPI -->|Webhook validation<br/>HTTPS/9443<br/>mTLS - API client cert| Webhook
    Operator -->|Reconcile resources<br/>HTTPS/6443 TLS1.2+<br/>SA Token| K8sAPI

    %% Monitoring flows
    Prometheus -->|Scrape metrics<br/>HTTP/8080<br/>None - NetworkPolicy| Metrics
    Prometheus -->|Scrape components<br/>HTTP/varies<br/>SA Token| Components

    %% Operator to external
    Operator -->|Create OAuth clients<br/>HTTPS/443 TLS1.2+| OAuth
    Operator -->|Pull images<br/>HTTPS/443 TLS1.2+| Quay
    Operator -->|Pull images<br/>HTTPS/443 TLS1.2+<br/>Pull Secret| RedHat
    Operator -.->|Download manifests<br/>HTTPS/443 TLS1.2+<br/>dev mode only| GitHub

    %% Service mesh integration
    Components -.->|mTLS STRICT<br/>Service Identity<br/>when enabled| ServiceMesh
    Operator -.->|Configure mesh<br/>HTTPS/6443 TLS1.2+<br/>SA Token| ServiceMesh

    %% Network policy boundaries
    Prometheus -->|NetworkPolicy:<br/>redhat-ods-monitoring| OperatorNS
    Components -->|NetworkPolicy:<br/>monitoring, mesh| MonitoringNS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef applications fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Admin external
    class PromRoute,AlertRoute ingress
    class K8sAPI controlplane
    class Operator,OperatorPorts,Metrics,Health,Webhook operator
    class Prometheus,Alertmanager,Blackbox monitoring
    class Components applications
    class ServiceMesh servicemesh
    class OAuth,Quay,RedHat,GitHub egress
