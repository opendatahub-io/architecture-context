graph TD
    subgraph "Service Accounts"
        SA_Manager[manager<br/>Namespace: redhat-ods-applications]
        SA_Notebook["notebook-name-sa<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_LeaderElection[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_NotebooksEdit[notebooks-edit<br/>ClusterRole]
        CR_NotebooksView[notebooks-view<br/>ClusterRole]
    end

    subgraph "API Resources - kubeflow.org"
        API_Notebooks["Notebooks<br/>notebooks, notebooks/status,<br/>notebooks/finalizers"]
    end

    subgraph "API Resources - route.openshift.io"
        API_Routes[Routes]
    end

    subgraph "API Resources - core"
        API_Services[Services]
        API_ServiceAccounts[ServiceAccounts]
        API_Secrets[Secrets]
        API_ConfigMaps[ConfigMaps]
        API_Events[Events]
    end

    subgraph "API Resources - config.openshift.io"
        API_Proxies[Proxies]
    end

    subgraph "API Resources - networking.k8s.io"
        API_NetworkPolicies[NetworkPolicies]
    end

    subgraph "API Resources - coordination.k8s.io"
        API_Leases[Leases]
    end

    %% Service Account to Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| RB_LeaderElection

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    RB_LeaderElection -->|grants| CR_LeaderElection

    %% manager-role permissions
    CR_Manager -->|get, list, watch,<br/>patch, update| API_Notebooks
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_Routes
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_Services
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_ServiceAccounts
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_Secrets
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_ConfigMaps
    CR_Manager -->|get, list, watch| API_Proxies
    CR_Manager -->|get, list, watch,<br/>create, update, patch| API_NetworkPolicies

    %% leader-election-role permissions
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| API_ConfigMaps
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| API_Events
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| API_Leases

    %% User-facing roles (not bound by controller)
    CR_NotebooksEdit -.->|get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update| API_Notebooks
    CR_NotebooksView -.->|get, list, watch| API_Notebooks

    %% Notebook ServiceAccount (used by OAuth proxy)
    SA_Notebook -.->|OAuth proxy uses for<br/>authentication| OAuthAnnotation[ServiceAccount Annotations:<br/>serviceaccounts.openshift.io/<br/>oauth-redirectreference.first]

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Notebook fill:#7ed321,stroke:#333,stroke-width:2px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_NotebooksEdit fill:#d3d3d3,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style CR_NotebooksView fill:#d3d3d3,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style API_Notebooks fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Routes fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Services fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_ServiceAccounts fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Secrets fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_ConfigMaps fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Proxies fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_NetworkPolicies fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Events fill:#e1f5ff,stroke:#333,stroke-width:1px
    style API_Leases fill:#e1f5ff,stroke:#333,stroke-width:1px
