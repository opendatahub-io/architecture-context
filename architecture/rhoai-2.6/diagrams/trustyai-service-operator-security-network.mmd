graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[External User]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS Passthrough"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL - Trusted"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>Image: quay.io/trustyai/trustyai-service-operator<br/>Replicas: 1<br/>Security: runAsNonRoot, no privs"]
            OperatorHealth["Health Probes<br/>8081/TCP HTTP"]
            OperatorMetrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>Bearer Token Auth"]

            Operator -->|exposes| OperatorHealth
            Operator -->|exposes| OperatorMetrics
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>ServiceAccount Tokens"]

        subgraph UserNS["Namespace: user-namespace"]
            direction TB

            subgraph TrustyAIPod["TrustyAI Service Pod"]
                OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS TLS1.2+<br/>serving-cert"]
                TrustyAIContainer["TrustyAI Service Container<br/>8080/TCP HTTP<br/>Image: quay.io/trustyai/trustyai-service"]

                OAuthProxy -->|localhost<br/>8080/TCP HTTP<br/>localhost trust| TrustyAIContainer
            end

            PVC["Persistent Volume<br/>ReadWriteOnce<br/>Size: configurable"]
            TrustyAIContainer -->|filesystem<br/>Pod UID/GID| PVC

            ServiceMetrics["Service: instance-name<br/>80/TCP to 8080<br/>HTTP, TLS re-encrypt"]
            ServiceTLS["Service: instance-name-tls<br/>443/TCP to 8443<br/>HTTPS TLS1.2+, OAuth"]

            ServiceMetrics -->|targets| TrustyAIContainer
            ServiceTLS -->|targets| OAuthProxy
        end

        subgraph Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>Metrics Scraper"]
        end

        subgraph InferenceNS["Namespace: Various - InferenceServices"]
            InferencePod["InferenceService Pod<br/>KServe Managed"]
        end

        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS1.2+<br/>User Authentication"]

        OperatorMetricsService["Service: controller-manager-metrics<br/>8080/TCP HTTP<br/>Bearer Token"]
        OperatorMetricsService -->|targets| OperatorMetrics
    end

    %% External flows
    User -->|HTTPS/443<br/>TLS 1.2+| Router
    Router -->|TLS Passthrough<br/>8443/TCP HTTPS<br/>TLS 1.2+ serving-cert| OAuthProxy

    %% OAuth flow
    OAuthProxy -->|OAuth Redirect<br/>443/TCP HTTPS<br/>TLS 1.2+| OAuthServer
    OAuthProxy -->|SubjectAccessReview<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Operator flows
    Operator -->|Watch/Reconcile CRDs<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Operator -->|Create/Manage Resources<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Monitoring flows
    Prometheus -->|Scrape /q/metrics<br/>80/TCP HTTP<br/>No Auth - skip-auth-regex| ServiceMetrics
    Prometheus -->|Scrape /metrics<br/>8080/TCP HTTP<br/>Bearer Token| OperatorMetricsService

    %% InferenceService integration
    InferencePod -->|Send Inference Data<br/>8080/TCP HTTP<br/>No Auth| TrustyAIContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef oauth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef inference fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router ingress
    class Operator,OperatorHealth,OperatorMetrics,OperatorMetricsService operator
    class K8sAPI,ServiceMetrics,ServiceTLS,PVC internal
    class OAuthProxy,OAuthServer oauth
    class TrustyAIContainer,TrustyAIPod internal
    class Prometheus monitoring
    class InferencePod inference
