    subgraph Application["APPLICATION (Namespace-scoped)"]
        direction TB
        OAuthProxy["OAuth Proxy Sidecar<br/>ose-oauth-proxy<br/>8443/TCP HTTPS<br/>TLS: serving cert<br/>Auth: OpenShift OAuth SAR"]
        TrustyAI["TrustyAI Service Container<br/>quay.io/trustyai/trustyai-service<br/>8080/TCP HTTP<br/>Endpoints: /q/metrics, /consumer/kserve/v2"]
    end

