    end

    subgraph Internal["KUBERNETES API & INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        ModelMesh["ModelMesh Serving<br/>(MM_PAYLOAD_PROCESSORS)"]
        KServeRouter["KServe Router<br/>(InferenceLogger)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>OpenShift Monitoring<br/>ServiceMonitor discovery"]
    end

    %% External access flow
    Client -->|"HTTPS/443<br/>TLS Passthrough"| Route
    Route -->|"HTTPS/8443<br/>TLS serving cert<br/>OAuth SAR: pods/get"| OAuthProxy
    OAuthProxy -->|"HTTP/8080<br/>plaintext localhost<br/>pre-authenticated"| TrustyAI

    %% Operator to K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>CRUD resources"| K8sAPI

    %% ModelMesh/KServe to TrustyAI
    ModelMesh -->|"HTTP/80<br/>plaintext<br/>No auth<br/>/consumer/kserve/v2"| TrustyAI
    KServeRouter -->|"HTTP/80<br/>plaintext<br/>No auth<br/>InferenceLogger URL"| TrustyAI

    %% Prometheus scraping
    Prometheus -->|"HTTP/80<br/>plaintext<br/>No auth<br/>/q/metrics"| TrustyAI
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>/metrics"| Operator

