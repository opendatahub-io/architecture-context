/*
 * C4 Context Diagram for Notebooks (Workbench Images)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.6/notebooks.md
 *
 * View with: https://structurizr.com/dsl or
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs notebook workbenches for ML/AI development"
        mlEngineer = person "ML Engineer" "Builds and deploys ML pipelines using Elyra in notebooks"
        platformAdmin = person "Platform Admin" "Deploys and manages notebook ImageStreams via Kustomize"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images for Jupyter, code-server, RStudio, and pipeline runtimes used as RHOAI workbenches" {
            jupyterMinimal = container "Jupyter Minimal Notebook" "Minimal JupyterLab 3.6 + Notebook 6.5 environment" "Container Image (UBI9)"
            jupyterDataScience = container "Jupyter Data Science Notebook" "Data science notebook with Elyra 3.15, Boto3, scikit-learn, Pandas, DB clients" "Container Image (UBI9)"
            jupyterPyTorch = container "Jupyter PyTorch Notebook" "CUDA-enabled notebook with PyTorch 2.0, Tensorboard" "Container Image (UBI9 + CUDA)"
            jupyterTensorFlow = container "Jupyter TensorFlow Notebook" "CUDA-enabled notebook with TensorFlow 2.13, Tensorboard" "Container Image (UBI9 + CUDA)"
            jupyterTrustyAI = container "Jupyter TrustyAI Notebook" "Data science notebook with TrustyAI Explainability Toolkit 0.3" "Container Image (UBI9)"
            jupyterHabana = container "Jupyter HabanaAI Notebook" "Data science notebook with Habana Gaudi SDK" "Container Image (UBI8)"
            codeServer = container "code-server Workbench" "VS Code in browser (code-server 4.16) with NGINX reverse proxy" "Container Image (C9S)"
            rstudio = container "RStudio Workbench" "RStudio Server 2023.06 with R 4.3.1 and NGINX reverse proxy" "Container Image (C9S)"
            runtimeImages = container "Pipeline Runtime Images" "Minimal, Data Science, PyTorch, TensorFlow runtimes for Elyra pipelines" "Container Images (UBI9)"
            imageStreams = container "ImageStream Manifests" "OpenShift ImageStream definitions registering notebook images" "Kustomize/YAML"
            buildSystem = container "Makefile Build System" "Orchestrates layered image builds with dependency ordering" "Makefile"
        }

        notebookController = softwareSystem "ODH Notebook Controller" "Launches notebook pods using images from ImageStreams, injects oauth-proxy sidecar" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Reads ImageStream annotations to display available workbench types in UI" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "Pipeline orchestration platform for ML workflows" "Internal RHOAI"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authenticates users accessing notebook workbenches" "OpenShift Platform"
        openshiftAPI = softwareSystem "OpenShift API Server" "Kubernetes/OpenShift API for ImageStream and pod management" "OpenShift Platform"
        imageRegistry = softwareSystem "OpenShift Image Registry" "Stores and serves notebook container images" "OpenShift Platform"

        quay = softwareSystem "Quay.io (quay.io/modh)" "Public container registry hosting pre-built notebook images" "External"
        s3 = softwareSystem "S3-compatible Storage" "Object storage for data access via Boto3" "External"
        pypi = softwareSystem "PyPI" "Python package index for runtime pip installations" "External"
        kafka = softwareSystem "Kafka Brokers" "Message brokers for Kafka integration" "External"
        databases = softwareSystem "Databases (MongoDB, PostgreSQL, MSSQL)" "Data stores accessed from notebooks" "External"
        nvidia = softwareSystem "NVIDIA CUDA/cuDNN" "GPU compute libraries for PyTorch/TensorFlow notebooks" "External"

        /* Relationships */
        dataScientist -> notebooks "Runs workbenches via Dashboard UI"
        mlEngineer -> notebooks "Submits pipelines via Elyra"
        platformAdmin -> imageStreams "Deploys ImageStreams via Kustomize"

        notebookController -> imageStreams "Reads ImageStreams to get image references" "K8s API / TLS 1.2+"
        odhDashboard -> imageStreams "Reads annotations for workbench image selector" "K8s API / TLS 1.2+"
        jupyterDataScience -> dsPipelines "Submits pipelines via Elyra/kfp-tekton SDK" "HTTPS/443 Bearer Token"
        runtimeImages -> s3 "Downloads/uploads pipeline artifacts" "HTTPS/443 AWS Credentials"

        notebooks -> s3 "Data access via Boto3" "HTTPS/443"
        notebooks -> pypi "Runtime pip package installation" "HTTPS/443"
        notebooks -> kafka "Kafka integration via kafka-python" "TCP/9092"
        notebooks -> databases "Database access via PyMongo/psycopg/pyodbc" "TCP (various ports)"

        buildSystem -> quay "Pushes built images" "HTTPS/443"
        imageStreams -> quay "References pre-built images by SHA256" "HTTPS/443"
        imageStreams -> openshiftAPI "Registers ImageStreams" "HTTPS/6443"

        notebookController -> openshiftOAuth "Configures oauth-proxy sidecar"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "OpenShift Platform" {
                background #e74c3c
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
