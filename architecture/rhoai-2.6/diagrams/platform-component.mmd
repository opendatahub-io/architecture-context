graph TB
    subgraph "RHOAI Platform 2.6"
        subgraph "Platform Orchestration"
            RHODSOp[RHODS Operator<br/>v1.6.0]
            DSC[DataScienceCluster CRD]
            DSCInit[DSCInitialization CRD]
        end

        subgraph "User Interface"
            Dashboard[ODH Dashboard<br/>v1.27.0]
            DashboardConfig[OdhDashboardConfig CRD]
        end

        subgraph "Notebook Development"
            NotebookController[Notebook Controller<br/>v1.27.0]
            NotebookCR[Notebook CRD<br/>kubeflow.org]
            NotebookImages[Notebook Images<br/>Jupyter/VS Code/RStudio]
        end

        subgraph "ML Pipelines"
            DSPOperator[Data Science Pipelines Operator<br/>rhoai-2.6]
            DSPA[DataSciencePipelinesApplication CRD]
            DSPAPIServer[DSP API Server]
            MLMD[ML Metadata gRPC]
            TektonPipeline[Tekton PipelineRun]
        end

        subgraph "Model Serving - Single Model"
            KServe[KServe Operator<br/>v0.11.1]
            InferenceService[InferenceService CRD<br/>serving.kserve.io]
            ServingRuntime[ServingRuntime CRD]
            KnativeService[Knative Service]
        end

        subgraph "Model Serving - Multi-Model"
            ModelMesh[ModelMesh Serving<br/>v1.27.0]
            Predictor[Predictor CRD]
            ModelMeshPod[ModelMesh Pods]
            etcd[etcd Registry]
        end

        subgraph "Model Integration"
            ODHModelController[ODH Model Controller<br/>v1.27.0]
            Routes[OpenShift Routes]
            ServiceMonitors[ServiceMonitors]
        end

        subgraph "Distributed Computing"
            CodeFlare[CodeFlare Operator]
            AppWrapper[AppWrapper CRD]
            MCAD[MCAD Queue Controller]
            KubeRay[KubeRay Operator]
            RayCluster[RayCluster CRD]
        end

        subgraph "Model Monitoring"
            TrustyAI[TrustyAI Service Operator]
            TrustyAIService[TrustyAIService CRD]
            TrustyAIPod[TrustyAI Pod]
        end

        subgraph "Platform Monitoring"
            Prometheus[Prometheus]
            Alertmanager[Alertmanager]
            Grafana[Grafana]
        end
    end

    subgraph "External Dependencies"
        OCP[OpenShift Platform<br/>OAuth, Routes, Service CA]
        Istio[Service Mesh<br/>Istio/Envoy]
        Knative[Knative Serving]
        Tekton[OpenShift Pipelines<br/>Tekton]
        S3[S3-Compatible Storage]
        K8sAPI[Kubernetes API Server]
    end

    %% Orchestration flows
    RHODSOp -->|manages| DSC
    RHODSOp -->|initializes| DSCInit
    RHODSOp -->|deploys| Dashboard
    RHODSOp -->|deploys| NotebookController
    RHODSOp -->|deploys| DSPOperator
    RHODSOp -->|deploys| KServe
    RHODSOp -->|deploys| ModelMesh
    RHODSOp -->|deploys| ODHModelController
    RHODSOp -->|deploys| CodeFlare
    RHODSOp -->|deploys| KubeRay
    RHODSOp -->|deploys| TrustyAI

    %% Dashboard flows
    Dashboard -->|manages| DashboardConfig
    Dashboard -->|calls| DSPAPIServer
    Dashboard -->|calls| MLMD

    %% Notebook flows
    NotebookController -->|watches| NotebookCR
    NotebookController -->|creates| NotebookImages
    NotebookController -->|integrates| OCP
    NotebookController -->|calls| DSPAPIServer

    %% Pipeline flows
    DSPOperator -->|creates| DSPA
    DSPA -->|deploys| DSPAPIServer
    DSPA -->|deploys| MLMD
    DSPAPIServer -->|creates| TektonPipeline
    TektonPipeline -->|depends on| Tekton

    %% KServe flows
    KServe -->|watches| InferenceService
    KServe -->|uses| ServingRuntime
    KServe -->|creates| KnativeService
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    KServe -->|integrates| ODHModelController

    %% ModelMesh flows
    ModelMesh -->|watches| Predictor
    ModelMesh -->|creates| ModelMeshPod
    ModelMesh -->|uses| etcd
    ModelMesh -->|integrates| ODHModelController

    %% Model Controller flows
    ODHModelController -->|watches| InferenceService
    ODHModelController -->|watches| Predictor
    ODHModelController -->|creates| Routes
    ODHModelController -->|creates| ServiceMonitors
    ODHModelController -->|configures| Istio

    %% Distributed computing flows
    CodeFlare -->|manages| AppWrapper
    CodeFlare -->|embeds| MCAD
    AppWrapper -->|creates| RayCluster
    KubeRay -->|watches| RayCluster

    %% TrustyAI flows
    TrustyAI -->|watches| InferenceService
    TrustyAI -->|creates| TrustyAIService
    TrustyAIService -->|deploys| TrustyAIPod
    TrustyAIPod -->|exports metrics| Prometheus

    %% Monitoring flows
    Prometheus -->|scrapes| Dashboard
    Prometheus -->|scrapes| DSPAPIServer
    Prometheus -->|scrapes| InferenceService
    Prometheus -->|scrapes| ModelMeshPod
    Prometheus -->|sends alerts| Alertmanager

    %% External dependencies
    Dashboard -->|authenticates via| OCP
    NotebookImages -->|accesses| S3
    DSPAPIServer -->|stores artifacts| S3
    InferenceService -->|loads models from| S3
    ModelMeshPod -->|loads models from| S3
    RHODSOp -->|reconciles via| K8sAPI

    %% Styling
    style RHODSOp fill:#d63031,stroke:#2d3436,stroke-width:3px,color:#fff
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookController fill:#4a90e2,stroke:#333,stroke-width:2px
    style DSPOperator fill:#4a90e2,stroke:#333,stroke-width:2px
    style KServe fill:#4a90e2,stroke:#333,stroke-width:2px
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:2px
    style ODHModelController fill:#e74c3c,stroke:#333,stroke-width:3px
    style CodeFlare fill:#4a90e2,stroke:#333,stroke-width:2px
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:2px
    style Prometheus fill:#9b59b6,stroke:#333,stroke-width:2px
    style OCP fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Istio fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Knative fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Tekton fill:#e8e8e8,stroke:#333,stroke-width:2px
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px
