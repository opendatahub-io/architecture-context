    end

    subgraph ModelServing["Model Serving"]
        KServe[KServe Controller<br/>Serverless Inference]
        OdhModelCtrl[ODH Model Controller<br/>Route/NetworkPolicy Mgmt]
        MMServing[ModelMesh Serving<br/>Multi-Model Controller]
        ModelMesh[ModelMesh Sidecar<br/>LRU Cache + Routing]
        MMAdapter[Runtime Adapter<br/>Storage Puller]
        RestProxy[REST Proxy<br/>REST-to-gRPC]
        CaikitTGIS[Caikit-TGIS<br/>LLM Runtime]
        TGIS[TGIS<br/>Text Generation]
    end

    subgraph DistributedCompute["Distributed Computing"]
        KubeRay[KubeRay Operator<br/>Ray Cluster Lifecycle]
    end

    subgraph AIGovernance["AI Governance"]
        TrustyAI[TrustyAI Service<br/>Fairness + Explainability]
    end

    subgraph Pipelines["ML Pipelines"]
        DSPipelines[DS Pipelines<br/>API Server + UI]
        DSPTekton[DS Pipelines Tekton<br/>KFP-Tekton Engine]
    end

    subgraph UserWorkloads["User Namespace Workloads"]
        Notebooks[Notebook Pods<br/>Jupyter/VS Code/RStudio]
        InferSvc[InferenceService CRs]
        RayClusters[Ray Clusters]
        TrustyAISvc[TrustyAI Instances]
    end

    subgraph ExternalDeps["External Platform Dependencies"]
        Istio[OpenShift Service Mesh<br/>Istio/Maistra]
        Knative[OpenShift Serverless<br/>Knative Serving]
        Tekton[Tekton Pipelines]
        OCP[OpenShift Platform<br/>Routes, OAuth, OLM]
    end

    %% Platform operator deploys all
    RhodsOp -->|manages lifecycle| Dashboard
    RhodsOp -->|manages lifecycle| NotebookCtrl
    RhodsOp -->|manages lifecycle| KServe
    RhodsOp -->|manages lifecycle| MMServing
    RhodsOp -->|manages lifecycle| OdhModelCtrl
    RhodsOp -->|manages lifecycle| DSPO
    RhodsOp -->|manages lifecycle| CodeFlareOp
    RhodsOp -->|manages lifecycle| KubeRay
    RhodsOp -->|manages lifecycle| TrustyAIOp

    %% CRD relationships
    RhodsOp -->|watches| DSCCluster[DataScienceCluster CR]
    RhodsOp -->|watches| DSCInit[DSCInitialization CR]
    DSCCluster -->|created by| User[Platform Admin]
    DSCInit -->|created by| User

    %% Dashboard integrations
    Dashboard -->|manages| NotebookCtrl
    Dashboard -->|status| KServe
    Dashboard -->|status| MMServing
    Dashboard -->|metadata via MLMD| DSPO

    %% Model serving chain
    KServe -->|requires| Istio
    KServe -->|requires| Knative
    KServe -->|uses runtime| CaikitTGIS
    CaikitTGIS -->|backend| TGIS
    OdhModelCtrl -->|manages Routes for| KServe
    OdhModelCtrl -->|manages Routes for| MMServing
    MMServing -->|deploys| ModelMesh
    MMServing -->|deploys| MMAdapter
    MMServing -->|deploys| RestProxy

    %% Pipelines
    DSPO -->|deploys| DSPipelines
    DSPipelines -->|executes via| DSPTekton
    DSPTekton -->|creates| Tekton

    %% Distributed
    CodeFlareOp -->|schedules to| KubeRay

    %% TrustyAI
    TrustyAIOp -->|deploys| TrustyAI
    TrustyAI -->|payload logging| MMServing
    TrustyAI -->|inference logger| KServe

    %% User workloads
    NotebookCtrl -->|creates| Notebooks
    KServe -->|creates| InferSvc
    KubeRay -->|creates| RayClusters
    TrustyAIOp -->|creates| TrustyAISvc

