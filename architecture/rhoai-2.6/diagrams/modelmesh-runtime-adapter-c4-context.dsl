// C4 Context Diagram - modelmesh-runtime-adapter
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/modelmesh-runtime-adapter.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys and manages ML models via ModelMesh Serving"

        modelMeshServing = softwareSystem "ModelMesh Serving" "Orchestrates model placement and routing across model server Pods" "Internal ODH"

        runtimeAdapter = softwareSystem "ModelMesh Runtime Adapter" "Sidecar that pulls model artifacts and adapts ModelMesh protocol to native runtime APIs" {
            puller = container "model-serving-puller" "Downloads model artifacts from cloud storage; proxies ModelRuntime gRPC" "Go gRPC Service" "Sidecar"
            pullmanLib = container "pullman" "Pluggable storage provider framework (S3, GCS, Azure, HTTP, PVC)" "Go Library"
            tritonAdapter = container "triton-adapter" "Adapts ModelRuntime to Triton gRPC API" "Go gRPC Service" "Sidecar"
            mlserverAdapter = container "mlserver-adapter" "Adapts ModelRuntime to MLServer gRPC API" "Go gRPC Service" "Sidecar"
            ovmsAdapter = container "ovms-adapter" "Adapts ModelRuntime to OVMS REST API" "Go gRPC Service" "Sidecar"
            torchserveAdapter = container "torchserve-adapter" "Adapts ModelRuntime to TorchServe gRPC API" "Go gRPC Service" "Sidecar"

            puller -> pullmanLib "Uses for storage access"
            puller -> tritonAdapter "Forwards model lifecycle requests" "gRPC/8085"
            puller -> mlserverAdapter "Forwards model lifecycle requests" "gRPC/8085"
            puller -> ovmsAdapter "Forwards model lifecycle requests" "gRPC/8085"
            puller -> torchserveAdapter "Forwards model lifecycle requests" "gRPC/8085"
        }

        triton = softwareSystem "NVIDIA Triton Inference Server" "High-performance inference runtime" "External Runtime"
        mlserver = softwareSystem "Seldon MLServer" "Python-based inference runtime" "External Runtime"
        ovms = softwareSystem "OpenVINO Model Server" "Intel optimized inference runtime" "External Runtime"
        torchserve = softwareSystem "PyTorch TorchServe" "PyTorch model serving runtime" "External Runtime"

        s3 = softwareSystem "S3 / IBM COS" "S3-compatible object storage for model artifacts" "External Storage"
        gcs = softwareSystem "Google Cloud Storage" "GCS storage for model artifacts" "External Storage"
        azureBlob = softwareSystem "Azure Blob Storage" "Azure storage for model artifacts" "External Storage"

        // Relationships
        dataScientist -> modelMeshServing "Deploys models via InferenceService CR"
        modelMeshServing -> runtimeAdapter "Sends model lifecycle commands" "gRPC/8084"

        tritonAdapter -> triton "Load/unload models, query status" "gRPC/8001"
        mlserverAdapter -> mlserver "Load/unload models, query readiness" "gRPC/8001"
        ovmsAdapter -> ovms "Config reload, query status" "HTTP/8001"
        torchserveAdapter -> torchserve "Register/unregister models" "gRPC/7071"

        pullmanLib -> s3 "Downloads model artifacts" "HTTPS/443"
        pullmanLib -> gcs "Downloads model artifacts" "HTTPS/443"
        pullmanLib -> azureBlob "Downloads model artifacts" "HTTPS/443"
    }

    views {
        systemContext runtimeAdapter "SystemContext" {
            include *
            autoLayout
        }

        container runtimeAdapter "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External Runtime" {
                background #f5a623
                color #ffffff
            }
            element "External Storage" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Sidecar" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
