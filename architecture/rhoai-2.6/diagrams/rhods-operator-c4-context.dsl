/*
 * C4 Context Diagram: rhods-operator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.6/rhods-operator.md
 */

workspace {
    model {
        admin = person "Cluster Admin" "Manages RHOAI platform via DataScienceCluster and DSCInitialization CRs"
        dataScientist = person "Data Scientist" "Uses AI/ML components deployed by the operator"

        rhodsOperator = softwareSystem "rhods-operator" "Central RHOAI platform operator managing lifecycle of all AI/ML components" {
            dscController = container "DataScienceCluster Controller" "Reconciles DataScienceCluster CRs; enables/disables AI/ML components" "Go Controller (controller-runtime)"
            dsciController = container "DSCInitialization Controller" "Platform initialization: namespaces, monitoring, Service Mesh, network policies" "Go Controller (controller-runtime)"
            secretGenerator = container "SecretGenerator Controller" "Generates random secrets and creates OAuthClient CRs" "Go Controller (controller-runtime)"
            featureSystem = container "Feature System" "Template-based deployment for Service Mesh and Serverless configuration" "Go Package (pkg/feature)"
            monitoringStack = container "Monitoring Stack" "Prometheus, Alertmanager, Blackbox Exporter for platform monitoring" "Kustomize Manifests"
            componentModules = container "Component Modules" "Dashboard, Workbenches, ModelMesh, KServe, DSP, CodeFlare, Ray, TrustyAI" "Go Components"
            manifests = container "Manifests Store" "Kustomize manifests baked into /opt/manifests at build time" "Filesystem"
        }

        k8sAPI = softwareSystem "Kubernetes API" "OpenShift/Kubernetes API Server" "External"
        olm = softwareSystem "OpenShift OLM" "Operator Lifecycle Manager for installation and updates" "External"
        serviceMesh = softwareSystem "Service Mesh Operator" "Istio/Maistra for mesh networking (required for KServe)" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform (required for KServe)" "External"
        promOperator = softwareSystem "Prometheus Operator" "Monitoring CRD management (ServiceMonitor, PrometheusRule)" "External"
        console = softwareSystem "OpenShift Console" "Web console for cluster management" "External"
        oauth = softwareSystem "OpenShift OAuth" "Authentication provider for Dashboard and monitoring UIs" "External"
        addonOperator = softwareSystem "Addon Operator" "Managed RHOAI addon detection and parameters" "External"

        odhManifests = softwareSystem "odh-manifests" "Component manifest repository fetched at build time" "Internal ODH"
        odhModelController = softwareSystem "odh-model-controller" "Model controller deployed alongside KServe" "Internal ODH"

        pagerduty = softwareSystem "PagerDuty" "Alert escalation service (Managed RHOAI)" "External Service"
        deadmanssnitch = softwareSystem "DeadMansSnitch" "Alertmanager dead man's switch" "External Service"
        smtpServer = softwareSystem "SMTP Server" "Alert email notifications (Managed RHOAI)" "External Service"
        github = softwareSystem "GitHub" "DevFlags manifest download at runtime" "External Service"

        /* Relationships */
        admin -> rhodsOperator "Creates DataScienceCluster & DSCInitialization CRs via kubectl"
        dataScientist -> rhodsOperator "Uses deployed AI/ML components"

        dscController -> componentModules "Iterates and reconciles each component"
        componentModules -> manifests "Reads Kustomize manifests"
        dscController -> k8sAPI "Deploys component resources" "HTTPS/6443"
        dsciController -> k8sAPI "Creates namespaces, NetworkPolicies, monitoring" "HTTPS/6443"
        dsciController -> featureSystem "Loads feature templates"
        dsciController -> monitoringStack "Deploys monitoring stack"
        featureSystem -> serviceMesh "Creates ServiceMeshControlPlane CR" "K8s API"
        featureSystem -> knative "Creates KnativeServing CR" "K8s API"
        secretGenerator -> oauth "Creates OAuthClient CRs" "K8s API"

        olm -> rhodsOperator "Manages operator lifecycle via CSV"
        rhodsOperator -> console "Creates ConsoleLink CRs" "K8s API"
        rhodsOperator -> promOperator "Creates ServiceMonitor, PrometheusRule CRs" "K8s API"
        rhodsOperator -> addonOperator "Reads Addon CR for platform detection" "K8s API"
        rhodsOperator -> odhModelController "Deploys as KServe subcomponent" "Kustomize"

        monitoringStack -> pagerduty "Alert escalation" "HTTPS/443"
        monitoringStack -> deadmanssnitch "Dead man's switch" "HTTPS/443"
        monitoringStack -> smtpServer "Email notifications" "SMTP/STARTTLS"
        rhodsOperator -> github "DevFlags manifest download" "HTTPS/443"

        odhManifests -> manifests "Baked into image at build time" "get_all_manifests.sh"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
