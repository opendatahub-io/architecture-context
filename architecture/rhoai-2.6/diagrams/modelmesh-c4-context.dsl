// ModelMesh C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.6/modelmesh.md

workspace {
    model {
        client = person "Inference Client" "Sends model inference requests and model management commands"
        controller = person "modelmesh-serving Controller" "Deploys, configures, and manages ModelMesh pods"

        modelmesh = softwareSystem "ModelMesh" "Distributed LRU cache and routing layer for high-scale, high-density model serving" {
            modelmeshApi = container "ModelMeshApi" "External gRPC API server exposing model management and inference proxying" "Java / gRPC / Netty" "Port 8033/TCP"
            modelmeshCore = container "ModelMesh Core" "Distributed LRU cache, model placement, inter-pod routing, leader election" "Java / ThriftService"
            sidecarModelMesh = container "SidecarModelMesh" "Sidecar communicating with colocated model runtime via gRPC ModelRuntime API" "Java"
            vmodelManager = container "VModelManager" "Virtual model alias management for blue-green model transitions" "Java"
            dataplaneApiConfig = container "DataplaneApiConfig" "Configurable dataplane RPC routing and filtering for inference methods" "Java"
            typeConstraintMgr = container "TypeConstraintManager" "Model type constraint management for heterogeneous deployments" "Java"
            payloadProcessor = container "PayloadProcessor" "Pluggable payload logging and processing for request/response inspection" "Java"
            metricsServer = container "Prometheus Metrics Server" "Exposes Prometheus metrics via HTTPS endpoint" "Java / Netty" "Port 2112/TCP"
            preStopServer = container "PreStop/Health Server" "Kubernetes readiness, liveness probes and preStop hook" "Java / HTTP" "Port 8089/TCP"
        }

        etcd = softwareSystem "etcd" "Distributed KV store for model registry, instance tracking, leader election, dynamic configuration" "External"
        modelRuntime = softwareSystem "Model Runtime" "Colocated model serving runtime (Triton, MLServer, custom) implementing ModelRuntime gRPC API" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        statsd = softwareSystem "StatsD/Datadog" "Alternative metrics reporting backend" "External"
        modelmeshServing = softwareSystem "modelmesh-serving" "Kubernetes controller managing ServingRuntimes and InferenceServices" "Internal RHOAI"

        // Relationships - External
        client -> modelmesh "Sends inference requests and model management RPCs" "gRPC/8033 Optional TLS/mTLS"
        controller -> modelmesh "Deploys and configures" "Kubernetes API"

        // Relationships - Internal containers
        modelmeshApi -> modelmeshCore "Routes requests"
        modelmeshCore -> sidecarModelMesh "Delegates model lifecycle"
        modelmeshCore -> vmodelManager "Manages virtual model aliases"
        modelmeshCore -> dataplaneApiConfig "Configures dataplane routing"
        modelmeshCore -> typeConstraintMgr "Enforces type constraints"
        modelmeshCore -> payloadProcessor "Processes payloads"

        // Relationships - External systems
        modelmesh -> etcd "Model registry, leader election, coordination" "gRPC/2379 TLS + Certificate Auth"
        sidecarModelMesh -> modelRuntime "Model load/unload/inference" "gRPC/8085 or UDS plaintext"
        prometheus -> modelmesh "Scrapes metrics" "HTTPS/2112 Self-signed TLS"
        modelmesh -> statsd "Reports metrics (optional)" "UDP/8125 plaintext"
        modelmeshServing -> modelmesh "Deploys and manages pods" "Kubernetes API"
    }

    views {
        systemContext modelmesh "SystemContext" {
            include *
            autoLayout
        }

        container modelmesh "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
