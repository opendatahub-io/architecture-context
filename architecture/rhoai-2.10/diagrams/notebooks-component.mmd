graph TB
    subgraph "Notebook Images Component"
        direction TB

        subgraph "Base Images"
            UBI9[UBI9 Python 3.9<br/>Base Image]
            UBI8[UBI8 Python 3.8<br/>Base Image]
            CUDABase[CUDA UBI9<br/>NVIDIA GPU Base]
            IntelBase[Intel GPU UBI9<br/>Intel Arc/Flex Base]
        end

        subgraph "Core Jupyter Images"
            JupyterMin[Jupyter Minimal<br/>JupyterLab 3.x + Python Kernel]
            JupyterDS[Jupyter Data Science<br/>pandas, scikit-learn, matplotlib]
            JupyterPyTorch[Jupyter PyTorch<br/>PyTorch 2.x + CUDA]
            JupyterTF[Jupyter TensorFlow<br/>TensorFlow 2.x + CUDA]
            JupyterTrust[Jupyter TrustAI<br/>AI Explainability Tools]
        end

        subgraph "Specialized Images"
            JupyterHabana[Jupyter Habana<br/>Gaudi 1.9-1.13<br/>Deactivated in 2.10]
            JupyterIntelTF[Intel TensorFlow<br/>Intel GPU Extensions]
            JupyterIntelPT[Intel PyTorch<br/>Intel GPU Extensions]
        end

        subgraph "Alternative IDEs"
            CodeServer[Code Server<br/>VS Code Server 4.x]
            RStudio[RStudio Server<br/>R 4.3]
        end

        subgraph "Runtime Images"
            RuntimeMin[Runtime Minimal<br/>Elyra Pipeline Base]
            RuntimeDS[Runtime Data Science<br/>Pipeline + Libraries]
            RuntimeTF[Runtime TensorFlow<br/>Pipeline + TF]
            RuntimePT[Runtime PyTorch<br/>Pipeline + PyTorch]
        end
    end

    subgraph "ODH Platform Components"
        Controller[ODH Notebook Controller]
        Dashboard[ODH Dashboard]
        KFP[Kubeflow Pipelines]
        ModelRegistry[Model Registry]
    end

    subgraph "External Dependencies"
        Quay[Quay.io Registry]
        S3[S3 Object Storage]
        K8sAPI[Kubernetes API]
        PyPI[PyPI/Conda Repos]
    end

    subgraph "User Interaction"
        User[Data Scientist]
        Browser[Web Browser]
    end

    %% Build Chain - UBI9
    UBI9 --> JupyterMin
    JupyterMin --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTF
    JupyterDS --> JupyterTrust

    %% Build Chain - CUDA
    CUDABase --> JupyterPyTorch
    CUDABase --> JupyterTF

    %% Build Chain - Intel
    IntelBase --> JupyterIntelTF
    IntelBase --> JupyterIntelPT

    %% Build Chain - Habana
    UBI8 --> JupyterHabana

    %% Alternative IDEs
    UBI9 --> CodeServer
    UBI9 --> RStudio

    %% Runtime Images
    UBI9 --> RuntimeMin
    RuntimeMin --> RuntimeDS
    RuntimeDS --> RuntimeTF
    RuntimeDS --> RuntimePT

    %% ODH Integration
    Controller -->|creates StatefulSets using| JupyterMin
    Controller -->|creates StatefulSets using| JupyterDS
    Controller -->|creates StatefulSets using| CodeServer
    Controller -->|creates StatefulSets using| RStudio
    Dashboard -->|presents ImageStreams to| User
    KFP -->|executes pipelines in| RuntimeDS
    KFP -->|executes pipelines in| RuntimeTF

    %% External Dependencies
    Quay -->|provides base images| UBI9
    Quay -->|provides base images| UBI8
    Quay -->|provides base images| CUDABase
    JupyterDS -->|accesses data| S3
    JupyterDS -->|oc CLI commands| K8sAPI
    JupyterDS -->|pip install packages| PyPI

    %% User Flow
    User -->|selects workbench| Dashboard
    User -->|develops models| Browser
    Browser -->|connects to| JupyterDS

    %% Data Flow
    JupyterDS -.->|trains models for| ModelRegistry
    RuntimeDS -->|reads/writes artifacts| S3

    %% Styling
    style UBI9 fill:#f5a623,stroke:#333,stroke-width:2px
    style UBI8 fill:#f5a623,stroke:#333,stroke-width:2px
    style CUDABase fill:#76b900,stroke:#333,stroke-width:2px
    style IntelBase fill:#0071c5,stroke:#333,stroke-width:2px
    style JupyterMin fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterDS fill:#4a90e2,stroke:#333,stroke-width:2px
    style JupyterPyTorch fill:#ee4c2c,stroke:#333,stroke-width:2px
    style JupyterTF fill:#ff6f00,stroke:#333,stroke-width:2px
    style JupyterTrust fill:#9013fe,stroke:#333,stroke-width:2px
    style JupyterHabana fill:#999,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    style Controller fill:#7ed321,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style KFP fill:#7ed321,stroke:#333,stroke-width:2px
    style Quay fill:#e8e8e8,stroke:#333,stroke-width:2px
    style S3 fill:#e8e8e8,stroke:#333,stroke-width:2px
    style User fill:#fff,stroke:#333,stroke-width:2px
