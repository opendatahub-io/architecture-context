graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>openshift-operators namespace]
    end

    subgraph "ClusterRole Bindings"
        CRB[controller-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole: controller-manager-role"
        CR[controller-manager-role<br/>ClusterRole]
    end

    subgraph "Platform CRD Permissions"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>all verbs + finalizers + status]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization<br/>all verbs + finalizers + status]
        FT[features.opendatahub.io<br/>FeatureTracker<br/>all verbs + status]
    end

    subgraph "Core Resource Permissions"
        NS[Namespaces<br/>all verbs + finalizers]
        CM[ConfigMaps<br/>all verbs + status]
        SEC[Secrets<br/>all verbs + finalizers]
        SVC[Services<br/>all verbs + finalizers]
        SA2[ServiceAccounts<br/>all verbs]
    end

    subgraph "Workload Resource Permissions"
        DEP[Deployments<br/>apps<br/>all verbs + finalizers]
        STS[StatefulSets<br/>apps<br/>all verbs]
        JOBS[Jobs<br/>batch<br/>all verbs + status]
    end

    subgraph "RBAC Resource Permissions"
        ROLES[Roles & RoleBindings<br/>rbac.authorization.k8s.io<br/>all verbs]
        CROLES[ClusterRoles & ClusterRoleBindings<br/>rbac.authorization.k8s.io<br/>all verbs]
    end

    subgraph "OpenShift Resource Permissions"
        ROUTES[Routes<br/>route.openshift.io<br/>all verbs]
    end

    subgraph "Networking Permissions"
        NETPOL[NetworkPolicies<br/>networking.k8s.io<br/>all verbs]
    end

    subgraph "Admission Webhook Permissions"
        MWH[MutatingWebhookConfigurations<br/>admissionregistration.k8s.io<br/>all verbs]
        VWH[ValidatingWebhookConfigurations<br/>admissionregistration.k8s.io<br/>all verbs]
    end

    subgraph "API Extension Permissions"
        CRD[CustomResourceDefinitions<br/>apiextensions.k8s.io<br/>create, delete, get, list, patch, watch]
    end

    subgraph "OLM Permissions"
        SUB[Subscriptions<br/>operators.coreos.com<br/>all verbs]
        CSV[ClusterServiceVersions<br/>operators.coreos.com<br/>all verbs]
    end

    subgraph "Service Mesh Permissions"
        SMCP[ServiceMeshControlPlanes<br/>maistra.io<br/>all verbs]
        SMMR[ServiceMeshMemberRolls<br/>maistra.io<br/>all verbs]
        SMM[ServiceMeshMembers<br/>maistra.io<br/>all verbs]
    end

    subgraph "KServe Permissions"
        ISVC[InferenceServices<br/>serving.kserve.io<br/>all verbs]
        SR[ServingRuntimes<br/>serving.kserve.io<br/>all verbs]
    end

    subgraph "Knative Permissions"
        KSVC[Services<br/>serving.knative.dev<br/>all verbs]
        KNSERV[KnativeServings<br/>serving.knative.dev<br/>all verbs]
    end

    subgraph "Authorino Permissions"
        AC[AuthConfigs<br/>authorino.kuadrant.io<br/>all verbs]
    end

    subgraph "Monitoring Permissions"
        SM[ServiceMonitors<br/>monitoring.coreos.com<br/>all verbs]
        PROM[Prometheuses<br/>monitoring.coreos.com<br/>all verbs]
        AM[Alertmanagers<br/>monitoring.coreos.com<br/>all verbs]
    end

    subgraph "Cert Manager Permissions"
        CERT[Certificates<br/>cert-manager.io<br/>create, patch]
        ISS[Issuers<br/>cert-manager.io<br/>create, patch]
    end

    subgraph "Additional ClusterRoles"
        EditorDSC[datasciencecluster-editor-role<br/>create, delete, get, list, patch, update, watch]
        ViewerDSC[datasciencecluster-viewer-role<br/>get, list, watch]
        EditorDSCI[dscinitialization-editor-role<br/>create, delete, get, list, patch, update, watch]
        ViewerDSCI[dscinitialization-viewer-role<br/>get, list, watch]
    end

    %% Service Account to Binding
    SA -->|bound via| CRB

    %% Binding to Role
    CRB -->|grants| CR

    %% Role to Permissions
    CR -->|all verbs| DSC
    CR -->|all verbs| DSCI
    CR -->|all verbs| FT
    CR -->|all verbs| NS
    CR -->|all verbs| CM
    CR -->|all verbs| SEC
    CR -->|all verbs| SVC
    CR -->|all verbs| SA2
    CR -->|all verbs| DEP
    CR -->|all verbs| STS
    CR -->|all verbs| JOBS
    CR -->|all verbs| ROLES
    CR -->|all verbs| CROLES
    CR -->|all verbs| ROUTES
    CR -->|all verbs| NETPOL
    CR -->|all verbs| MWH
    CR -->|all verbs| VWH
    CR -->|limited| CRD
    CR -->|all verbs| SUB
    CR -->|all verbs| CSV
    CR -->|all verbs| SMCP
    CR -->|all verbs| SMMR
    CR -->|all verbs| SMM
    CR -->|all verbs| ISVC
    CR -->|all verbs| SR
    CR -->|all verbs| KSVC
    CR -->|all verbs| KNSERV
    CR -->|all verbs| AC
    CR -->|all verbs| SM
    CR -->|all verbs| PROM
    CR -->|all verbs| AM
    CR -->|limited| CERT
    CR -->|limited| ISS

    %% Additional roles
    EditorDSC -.->|grants edit access| DSC
    ViewerDSC -.->|grants view access| DSC
    EditorDSCI -.->|grants edit access| DSCI
    ViewerDSCI -.->|grants view access| DSCI

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style DSC fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style DSCI fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style FT fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style NS fill:#d4e6f1,stroke:#333
    style CM fill:#d4e6f1,stroke:#333
    style SEC fill:#d4e6f1,stroke:#333
    style SVC fill:#d4e6f1,stroke:#333
    style SA2 fill:#d4e6f1,stroke:#333
    style DEP fill:#fce4d6,stroke:#333
    style STS fill:#fce4d6,stroke:#333
    style JOBS fill:#fce4d6,stroke:#333
    style ROLES fill:#e8daef,stroke:#333
    style CROLES fill:#e8daef,stroke:#333
    style EditorDSC fill:#e8daef,stroke:#333
    style ViewerDSC fill:#e8daef,stroke:#333
    style EditorDSCI fill:#e8daef,stroke:#333
    style ViewerDSCI fill:#e8daef,stroke:#333
