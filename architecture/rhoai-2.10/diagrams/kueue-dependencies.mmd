    style KubeflowTraining fill:#7ed321,stroke:#333,stroke-width:2px
    style RayOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style MonitoringStack fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style Workbenches fill:#7ed321,stroke:#333,stroke-dasharray: 5 5

