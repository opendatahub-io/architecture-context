graph TB
    subgraph External["EXTERNAL - User Access"]
        User[User/ODH Dashboard]
    end

    subgraph K8sAPIServer["KUBERNETES API SERVER - Trusted"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE - opendatahub/mesh-namespace"]
        direction TB

        Controller["ODH Model Controller<br/>SA: odh-model-controller<br/>Replicas: 3 (leader election)<br/>SecurityContext: runAsNonRoot=true"]

        subgraph Endpoints["Exposed Endpoints"]
            MetricsSvc["Metrics Service - ClusterIP<br/>8080/TCP HTTP<br/>Endpoint: /metrics<br/>Auth: None - Internal"]
            WebhookSvc["Webhook Service - ClusterIP<br/>443→9443/TCP HTTPS<br/>TLS: OpenShift Service CA<br/>Auth: K8s API Server mTLS<br/>NetworkPolicy: API Server only"]
            HealthSvc["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz<br/>Auth: None"]
        end

        Controller --- MetricsSvc
        Controller --- WebhookSvc
        Controller --- HealthSvc
    end

    subgraph UserNS["USER NAMESPACES - Inference Namespaces"]
        direction TB

        subgraph ManagedResources["Controller Creates/Manages"]
            Routes["OpenShift Routes<br/>route.openshift.io/v1"]
            VirtualServices["Istio VirtualServices<br/>networking.istio.io/v1beta1"]
            AuthConfigs["Authorino AuthConfigs<br/>authorino.kuadrant.io/v1beta2"]
            NetworkPolicies["NetworkPolicies<br/>networking.k8s.io"]
            PeerAuths["PeerAuthentications<br/>security.istio.io/v1beta1"]
            Telemetries["Telemetries<br/>telemetry.istio.io/v1alpha1"]
            ServiceMonitors["ServiceMonitors<br/>monitoring.coreos.com/v1"]
            PodMonitors["PodMonitors<br/>monitoring.coreos.com/v1"]
            StorageConfig["storage-config Secret<br/>Aggregated S3 credentials"]
            CustomCA["odh-kserve-custom-ca-bundle<br/>ConfigMap - CA certs"]
            PrometheusRB["RoleBindings<br/>Prometheus access"]
        end
    end

    subgraph MeshNS["SERVICE MESH CONTROL PLANE NAMESPACE - istio-system"]
        SMMR["ServiceMeshMemberRoll<br/>maistra.io/v1"]
        SMM["ServiceMeshMember<br/>maistra.io/v1"]
    end

    subgraph ExternalIntegrations["EXTERNAL INTEGRATIONS - Optional"]
        Istio["Istio Control Plane<br/>v1.17+<br/>Service mesh, mTLS, telemetry"]
        Authorino["Authorino<br/>v0.15.0<br/>Authorization service"]
        Prometheus["Prometheus Operator<br/>v0.64.1<br/>Monitoring stack"]
        ModelRegistry["Model Registry - Optional<br/>8080/TCP gRPC<br/>TLS optional<br/>Model metadata"]
    end

    %% User to API Server
    User -->|HTTPS/6443<br/>TLS1.2+<br/>User Token| APIServer

    %% API Server to Controller (Watch)
    APIServer -->|Watch Stream<br/>TLS1.2+<br/>ServiceAccount Token| Controller

    %% Controller to API Server (API Calls)
    Controller -->|API Calls<br/>HTTPS/6443<br/>TLS1.2+<br/>ServiceAccount Token| APIServer

    %% API Server to Webhook
    APIServer -->|POST /validate-*<br/>443/TCP HTTPS<br/>TLS Service CA<br/>mTLS| WebhookSvc

    %% Controller to User Namespaces
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+<br/>ServiceAccount+RBAC| Routes
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| VirtualServices
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| AuthConfigs
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| NetworkPolicies
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| PeerAuths
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| Telemetries
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| ServiceMonitors
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| PodMonitors
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| StorageConfig
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| CustomCA
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| PrometheusRB

    %% Controller to Service Mesh Namespace
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+<br/>ServiceAccount+RBAC| SMMR
    Controller -->|Create/Manage<br/>API Calls<br/>TLS1.2+| SMM

    %% Prometheus scraping metrics
    Prometheus -.->|Scrape /metrics<br/>8080/TCP HTTP| MetricsSvc

    %% External integrations
    VirtualServices -.->|Uses| Istio
    PeerAuths -.->|Uses| Istio
    Telemetries -.->|Uses| Istio
    AuthConfigs -.->|Uses| Authorino
    ServiceMonitors -.->|Uses| Prometheus
    PodMonitors -.->|Uses| Prometheus
    Controller -.->|Optional<br/>8080/TCP gRPC<br/>TLS optional| ModelRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef apiserver fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:3px
    classDef endpoints fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef managed fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integrations fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class APIServer apiserver
    class Controller controller
    class MetricsSvc,WebhookSvc,HealthSvc endpoints
    class Routes,VirtualServices,AuthConfigs,NetworkPolicies,PeerAuths,Telemetries,ServiceMonitors,PodMonitors,StorageConfig,CustomCA,PrometheusRB,SMMR,SMM managed
    class Istio,Authorino,Prometheus,ModelRegistry integrations
