    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_SA
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_PVC
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_Pods
