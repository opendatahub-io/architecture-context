graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>Namespace: operator-namespace"]
        SA_Pipeline["ds-pipeline-(name)<br/>Namespace: user-namespace"]
        SA_Runner["pipeline-runner-(name)<br/>Namespace: user-namespace"]
        SA_MLMD["ds-pipeline-metadata-grpc-(name)<br/>Namespace: user-namespace"]
        SA_Writer["ds-pipeline-metadata-writer-(name)<br/>Namespace: user-namespace"]
        SA_Persistence["ds-pipeline-persistenceagent-(name)<br/>Namespace: user-namespace"]
        SA_Scheduled["ds-pipeline-scheduledworkflow-(name)<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole"
        CR_Manager["manager-role<br/>ClusterRole"]
    end

    subgraph "ClusterRoleBinding"
        CRB_Manager["manager-rolebinding"]
    end

    subgraph "Namespace Roles (per DSPA)"
        Role_Pipeline["ds-pipeline-(name)<br/>Role"]
        Role_Runner["pipeline-runner-(name)<br/>Role"]
        Role_MLMD["ds-pipeline-metadata-grpc-(name)<br/>Role"]
        Role_Writer["ds-pipeline-metadata-writer-(name)<br/>Role"]
        Role_Persistence["ds-pipeline-persistenceagent-(name)<br/>Role"]
        Role_Scheduled["ds-pipeline-scheduledworkflow-(name)<br/>Role"]
    end

    subgraph "Namespace RoleBindings (per DSPA)"
        RB_Pipeline["ds-pipeline-(name)"]
        RB_Runner["pipeline-runner-(name)"]
        RB_MLMD["ds-pipeline-metadata-grpc-(name)"]
        RB_Writer["ds-pipeline-metadata-writer-(name)"]
        RB_Persistence["ds-pipeline-persistenceagent-(name)"]
        RB_Scheduled["ds-pipeline-scheduledworkflow-(name)"]
    end

    subgraph "API Resources - DSPA CRD"
        DSPA_CR["datasciencepipelinesapplications<br/>opendatahub.io"]
        DSPA_Status["datasciencepipelinesapplications/status"]
        DSPA_Finalizers["datasciencepipelinesapplications/finalizers"]
    end

    subgraph "API Resources - Core"
        Core_ConfigMaps["configmaps"]
        Core_Secrets["secrets"]
        Core_Services["services"]
        Core_SA["serviceaccounts"]
        Core_PVC["persistentvolumeclaims"]
        Core_Pods["pods"]
    end

    subgraph "API Resources - Apps"
        Apps_Deployments["deployments"]
        Apps_ReplicaSets["replicasets"]
    end

    subgraph "API Resources - RBAC"
        RBAC_Roles["roles"]
        RBAC_RoleBindings["rolebindings"]
        RBAC_ClusterRoles["clusterroles"]
        RBAC_ClusterRoleBindings["clusterrolebindings"]
    end

    subgraph "API Resources - OpenShift"
        Routes["routes<br/>route.openshift.io"]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies["networkpolicies<br/>networking.k8s.io"]
    end

    subgraph "API Resources - Argo"
        Argo_Workflows["workflows<br/>argoproj.io"]
        Argo_Results["workflowtaskresults<br/>argoproj.io"]
    end

    subgraph "API Resources - Tekton"
        Tekton_PipelineRuns["pipelineruns<br/>tekton.dev"]
        Tekton_TaskRuns["taskruns<br/>tekton.dev"]
        Tekton_Tasks["tasks<br/>tekton.dev"]
        Tekton_Conditions["conditions<br/>tekton.dev"]
        Tekton_Runs["runs<br/>tekton.dev"]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors["servicemonitors<br/>monitoring.coreos.com"]
    end

    subgraph "API Resources - Other"
        Jobs["jobs<br/>batch"]
        Kubeflow["all resources<br/>kubeflow.org"]
        Ray["rayclusters, rayjobs, rayservices<br/>ray.io"]
        Seldon["seldondeployments<br/>machinelearning.seldon.io"]
    end

    %% ServiceAccount to RoleBinding/ClusterRoleBinding
    SA_Controller -->|bound via| CRB_Manager
    SA_Pipeline -->|bound via| RB_Pipeline
    SA_Runner -->|bound via| RB_Runner
    SA_MLMD -->|bound via| RB_MLMD
    SA_Writer -->|bound via| RB_Writer
    SA_Persistence -->|bound via| RB_Persistence
    SA_Scheduled -->|bound via| RB_Scheduled

    %% RoleBinding/ClusterRoleBinding to Role/ClusterRole
    CRB_Manager -->|grants| CR_Manager
    RB_Pipeline -->|grants| Role_Pipeline
    RB_Runner -->|grants| Role_Runner
    RB_MLMD -->|grants| Role_MLMD
    RB_Writer -->|grants| Role_Writer
    RB_Persistence -->|grants| Role_Persistence
    RB_Scheduled -->|grants| Role_Scheduled

    %% ClusterRole permissions
    CR_Manager -->|create,delete,get,list,patch,update,watch| DSPA_CR
    CR_Manager -->|create,delete,get,list,patch,update,watch| DSPA_Status
    CR_Manager -->|create,delete,get,list,patch,update,watch| DSPA_Finalizers
    CR_Manager -->|create,delete,get,list,patch,update,watch| Core_ConfigMaps
