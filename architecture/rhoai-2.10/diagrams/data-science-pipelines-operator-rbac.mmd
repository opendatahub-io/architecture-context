    CR_Manager -->|create,delete,get,list,patch,update,watch| Apps_ReplicaSets
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_Roles
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_RoleBindings
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_ClusterRoles
    CR_Manager -->|create,delete,get,list,patch,update,watch| RBAC_ClusterRoleBindings
    CR_Manager -->|create,delete,get,list,patch,update,watch| Routes
    CR_Manager -->|create,delete,get,list,patch,update,watch| NetworkPolicies
    CR_Manager -->|create,patch,get,list,watch| Argo_Workflows
    CR_Manager -->|create,patch,get,list,watch| Argo_Results
    CR_Manager -->|all verbs| Tekton_PipelineRuns
    CR_Manager -->|all verbs| Tekton_TaskRuns
    CR_Manager -->|all verbs| Tekton_Tasks
    CR_Manager -->|all verbs| Tekton_Conditions
    CR_Manager -->|all verbs| Tekton_Runs
    CR_Manager -->|create,delete,get,list,patch,update,watch| ServiceMonitors
    CR_Manager -->|all verbs| Jobs
    CR_Manager -->|all verbs| Kubeflow
    CR_Manager -->|create,delete,get,list,patch| Ray
    CR_Manager -->|all verbs| Seldon

