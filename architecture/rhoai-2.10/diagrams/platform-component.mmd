graph TB
    subgraph "RHOAI Platform Control Plane"
        RHODS[RHODS Operator<br/>Platform Orchestrator]
        Dashboard[ODH Dashboard<br/>Web UI & API Gateway]
    end

    subgraph "Workbench Management"
        NotebookCtrl[Notebook Controller<br/>Lifecycle Manager]
        NotebookImages[Notebook Images<br/>Jupyter/VS Code/RStudio]
    end

    subgraph "Model Serving"
        KServe[KServe Operator<br/>Serverless Serving]
        ModelMesh[ModelMesh Serving<br/>High-Density Serving]
        ModelCtrl[ODH Model Controller<br/>OpenShift Integration]
    end

    subgraph "ML Workflows"
        DSP[Data Science Pipelines<br/>Kubeflow Pipelines v1/v2]
    end

    subgraph "Distributed Training"
        TrainingOp[Training Operator<br/>PyTorch/TF/MPI/XGBoost]
    end

    subgraph "Distributed Computing"
        CodeFlare[CodeFlare Operator<br/>Ray & AppWrapper]
        KubeRay[KubeRay Operator<br/>Ray Clusters]
    end

    subgraph "Workload Management"
        Kueue[Kueue<br/>Job Queueing & Quotas]
    end

    subgraph "AI Governance"
        TrustyAI[TrustyAI Service<br/>Fairness & Explainability]
    end

    subgraph "Platform Infrastructure"
        Istio[Istio Service Mesh<br/>Traffic & mTLS]
        Knative[Knative Serving<br/>Serverless Autoscaling]
        Prometheus[Prometheus<br/>Monitoring]
        Authorino[Authorino<br/>Auth Policies]
        S3[S3 Storage<br/>Models & Artifacts]
    end

    %% Platform orchestration
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| NotebookCtrl
    RHODS -->|deploys| DSP
    RHODS -->|deploys| KServe
    RHODS -->|deploys| ModelMesh
    RHODS -->|deploys| ModelCtrl
    RHODS -->|deploys| TrainingOp
    RHODS -->|deploys| CodeFlare
    RHODS -->|deploys| KubeRay
    RHODS -->|deploys| Kueue
    RHODS -->|deploys| TrustyAI

    %% Dashboard interactions
    Dashboard -->|creates| NotebookCtrl
    Dashboard -->|creates| DSP
    Dashboard -->|creates| KServe
    Dashboard -->|queries| Prometheus

    %% Workbench
    NotebookCtrl -->|uses images| NotebookImages
    NotebookCtrl -->|routing| Istio

    %% Model Serving dependencies
    KServe -->|autoscaling| Knative
    KServe -->|traffic mgmt| Istio
    KServe -->|extends| ModelCtrl
    KServe -->|storage| S3
    ModelMesh -->|extends| ModelCtrl
    ModelMesh -->|storage| S3
    ModelMesh -->|monitoring| TrustyAI
    ModelCtrl -->|auth policies| Authorino
    ModelCtrl -->|metrics| Prometheus
    ModelCtrl -->|networking| Istio

    %% Pipelines
    DSP -->|deploys models| KServe
    DSP -->|storage| S3

    %% Training
    TrainingOp -->|queueing| Kueue
    TrainingOp -->|storage| S3

    %% Distributed computing
    CodeFlare -->|manages| KubeRay
    CodeFlare -->|queueing| Kueue
    KubeRay -->|metrics| Prometheus

    %% Workload management
    Kueue -->|admits| TrainingOp
    Kueue -->|admits| CodeFlare

