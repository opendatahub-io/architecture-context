    style ModelMesh fill:#2ecc71,stroke:#333,stroke-width:2px
    style ModelCtrl fill:#2ecc71,stroke:#333,stroke-width:2px
    style DSP fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style TrainingOp fill:#f39c12,stroke:#333,stroke-width:2px
    style Kueue fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style Istio fill:#95a5a6,stroke:#333,stroke-width:2px
    style Knative fill:#95a5a6,stroke:#333,stroke-width:2px
    style Prometheus fill:#95a5a6,stroke:#333,stroke-width:2px
    style Authorino fill:#95a5a6,stroke:#333,stroke-width:2px
    style S3 fill:#f1c40f,stroke:#333,stroke-width:2px
