graph TB
    subgraph "KubeRay Operator"
        Operator[KubeRay Operator<br/>Port: 8080/8081]
        RayClusterController[RayCluster Controller]
        RayJobController[RayJob Controller]
        RayServiceController[RayService Controller]
        AdmissionWebhook[Admission Webhook<br/>Port: 443]
        MetricsServer[Metrics Server<br/>8080/TCP]
        BatchSchedulerMgr[Batch Scheduler Manager]
        ServiceBuilder[Service Builder]
        RBACManager[RBAC Manager]
        RouteManager[Route Manager<br/>OpenShift]

        Operator --> RayClusterController
        Operator --> RayJobController
        Operator --> RayServiceController
        Operator --> AdmissionWebhook
        Operator --> MetricsServer
        Operator --> BatchSchedulerMgr
        Operator --> ServiceBuilder
        Operator --> RBACManager
        Operator --> RouteManager
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Infrastructure"
        HeadPod[Ray Head Pod<br/>User: 1000]
        WorkerPods[Ray Worker Pods<br/>User: 1000<br/>Autoscaled]
        HeadService[Head Service<br/>6379,8265,10001,8080]
        ServeService[Serve Service<br/>8000/TCP]
        JobSubmitterPod[Job Submitter Pod<br/>K8s Job]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        Istio[OpenShift Routes]
        Volcano[Volcano Scheduler<br/>Optional]
        Redis[External Redis<br/>6379/TCP Optional]
        Registry[Container Registry<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Scrape 8080]
    end

    subgraph "ODH Integration"
        ODHDashboard[ODH Dashboard]
        ODHMonitoring[ODH Monitoring]
    end

    %% CR Relationships
    User[User/ODH Dashboard] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    RayClusterCR -->|watched by| RayClusterController
    RayJobCR -->|watched by| RayJobController
    RayServiceCR -->|watched by| RayServiceController

    %% Validation
    RayClusterCR -.->|validates| AdmissionWebhook

    %% Resource Creation
    RayClusterController -->|creates| HeadPod
    RayClusterController -->|creates| WorkerPods
    RayClusterController -->|creates| HeadService
    RayServiceController -->|creates| ServeService
    RayJobController -->|creates| JobSubmitterPod

    %% Dependencies
    Operator -->|API calls| K8sAPI
    RBACManager -->|creates SA/Roles| K8sAPI
    RouteManager -->|creates routes| Istio
    BatchSchedulerMgr -.->|optional| Volcano
    HeadPod -.->|GCS fault tolerance| Redis
    HeadPod -->|pulls images| Registry
    WorkerPods -->|pulls images| Registry
    MetricsServer -->|scraped by| Prometheus

    %% ODH Integration
    ODHDashboard -->|UI management| Operator
    ODHMonitoring -->|collects metrics| MetricsServer

    %% Ray Internal
    WorkerPods -->|connects to GCS<br/>6379/TCP| HeadPod
    JobSubmitterPod -->|submits job<br/>8265/TCP| HeadPod

    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px
    style RayClusterController fill:#4a90e2,stroke:#333
    style RayJobController fill:#4a90e2,stroke:#333
    style RayServiceController fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Volcano fill:#999,stroke:#333
    style Redis fill:#999,stroke:#333
    style Registry fill:#999,stroke:#333
    style ODHDashboard fill:#7ed321,stroke:#333
    style ODHMonitoring fill:#7ed321,stroke:#333
