graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        ExtUser[External User]
        Dashboard[ODH Dashboard<br/>jupyter-web-app]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.3<br/>OAuth2 (optional)"]
    end

    subgraph ControlPlane["CONTROL PLANE (Cluster Admin)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
    end

    subgraph ControllerNamespace["Namespace: notebook-controller-system"]
        direction TB
        Controller["Notebook Controller<br/>SA: service-account<br/>Image: notebook-controller"]
        NotebookRec["Notebook Reconciler"]
        CullingRec["Culling Reconciler"]
        Metrics["Metrics :8080/TCP<br/>HTTP (no auth)"]
        Health["Health :8081/TCP<br/>HTTP (no auth)"]

        Controller -->|runs| NotebookRec
        Controller -->|runs| CullingRec
        Controller -->|exposes| Metrics
        Controller -->|exposes| Health
    end

    subgraph UserNamespace["Namespace: {user-namespace}"]
        direction TB
        StatefulSet["StatefulSet<br/>{notebook-name}"]
        NotebookPod["Notebook Pod<br/>Port: 8888/TCP HTTP<br/>Image: {jupyter-image}"]
        NotebookSvc["Service: {notebook-name}<br/>80/TCP → 8888/TCP<br/>mTLS (Istio optional)"]
        VirtualSvc["VirtualService<br/>notebook-{namespace}-{name}<br/>443/TCP HTTPS"]

        StatefulSet -->|manages| NotebookPod
        NotebookSvc -->|routes to| NotebookPod
        VirtualSvc -->|references| NotebookSvc
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics scrape"]
    end

    %% External Flows
    ExtUser -->|HTTPS/443<br/>TLS 1.3<br/>OAuth2/None| Gateway
    Dashboard -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI

    %% Gateway to Service
    Gateway -->|HTTP/80<br/>mTLS STRICT<br/>Istio Peer Auth| NotebookSvc

    %% Controller to API
    NotebookRec -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token| K8sAPI
    CullingRec -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token| K8sAPI

    %% Controller to Notebook
    NotebookRec -->|creates via API| StatefulSet
    NotebookRec -->|creates via API| NotebookSvc
    NotebookRec -->|creates via API| VirtualSvc

    %% Culling to Notebook
    CullingRec -->|HTTP/80<br/>GET /api/kernels<br/>GET /api/terminals<br/>No auth| NotebookSvc

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>GET /metrics<br/>No auth| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef usernamespace fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class ExtUser,Dashboard external
    class Gateway ingress
    class K8sAPI controlplane
    class Controller,NotebookRec,CullingRec,Metrics,Health controller
    class StatefulSet,NotebookPod,NotebookSvc,VirtualSvc usernamespace
    class Prometheus monitoring
