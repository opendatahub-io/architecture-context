graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller<br/>Port: 8080/TCP metrics<br/>Port: 8081/TCP health]
    end

    subgraph "Managed TrustyAI Service Instance"
        TrustyAIService[TrustyAI Service<br/>Quarkus App<br/>Port: 8080/TCP]
        OAuthProxy[OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS]
        PVC[PersistentVolumeClaim<br/>Storage for inference data]

        OAuthProxy -->|localhost:8080| TrustyAIService
        TrustyAIService -->|reads/writes| PVC
    end

    subgraph "Kubernetes Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
        Service1["Service: instance-name<br/>ClusterIP 80:8080"]
        Service2["Service: instance-name-tls<br/>ClusterIP 443:8443"]
        Route[OpenShift Route<br/>HTTPS Re-encrypt]
        ServiceMonitor[ServiceMonitor<br/>Prometheus CRD]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        OAuthServer[OpenShift OAuth Server]
        ServiceCA[service-ca]
    end

    subgraph "Integration Points"
        InferenceService[KServe InferenceService]
        ServingRuntime[KServe ServingRuntime]
        ModelMeshDep[ModelMesh Deployment]
    end

    User[User/Admin] -->|creates| TrustyAIServiceCR
    TrustyAIServiceCR -->|watched by| Controller

    Controller -->|creates/manages| Service1
    Controller -->|creates/manages| Service2
    Controller -->|creates/manages| Route
    Controller -->|creates/manages| TrustyAIService
    Controller -->|creates/manages| OAuthProxy
    Controller -->|creates/manages| PVC
    Controller -->|creates/manages| ServiceMonitor

    Controller -->|watches/patches| InferenceService
    Controller -->|watches| ServingRuntime
    Controller -->|patches env vars| ModelMeshDep

    Controller -->|API calls| K8sAPI
    OAuthProxy -->|validates tokens| OAuthServer
    Service2 -->|TLS cert injection| ServiceCA

    Route -->|external access| Service2
    Service1 -->|internal access| TrustyAIService
    Service2 -->|authenticated access| OAuthProxy

    ModelMeshDep -->|forwards payloads| Service1
    ServiceMonitor -->|scrapes metrics| Service1

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333
    style OAuthServer fill:#999,stroke:#333
    style ServiceCA fill:#999,stroke:#333
    style InferenceService fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style ModelMeshDep fill:#7ed321,stroke:#333
