graph TB
    subgraph "RHODS Operator (openshift-operators namespace)"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        FeatureController[FeatureTracker Controller]
        SecretGen[SecretGenerator Controller]
        CertGen[CertConfigMapGenerator Controller]
        StatusController[Status Controller]
        WebhookServer[Webhook Server<br/>9443/TCP HTTPS]
        MetricsServer[Metrics Server<br/>8080/TCP HTTP]

        DSCController -.->|shares manager| StatusController
        DSCIController -.->|shares manager| StatusController
        FeatureController -.->|shares manager| StatusController
        SecretGen -.->|generates| Secrets
        CertGen -.->|generates| CertConfigMaps
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR<br/>datasciencecluster.opendatahub.io/v1]
        DSCI[DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1]
        FeatureTracker[FeatureTracker CR<br/>features.opendatahub.io/v1]
    end

    subgraph "Managed Components"
        Dashboard[ODH Dashboard]
        Workbenches[Notebook Controller]
        DSP[Data Science Pipelines]
        KServe[KServe]
        ModelMesh[ModelMesh Serving]
        CodeFlare[CodeFlare Operator]
        KubeRay[KubeRay Operator]
        TrustyAI[TrustyAI Operator]
        TrainingOp[Training Operator]
        Kueue[Kueue]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        ServiceMesh[OpenShift Service Mesh]
        Serverless[OpenShift Serverless]
        Authorino[Authorino Operator]
        Prometheus[Prometheus Operator]
        GitHub[GitHub<br/>443/TCP HTTPS]
    end

    subgraph "Platform Infrastructure"
        AppsNS[redhat-ods-applications]
        MonitoringNS[redhat-ods-monitoring]
        IstioNS[istio-system]
        Secrets[Secrets & ConfigMaps]
        CertConfigMaps[TLS Certificate ConfigMaps]
    end

    %% User interactions
    User[Administrator] -->|creates| DSC
    User -->|creates| DSCI

    %% Controller watching CRs
    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController
    FeatureTracker -->|watched by| FeatureController

    %% DSC Controller manages components
    DSCController -->|deploys| Dashboard
    DSCController -->|deploys| Workbenches
    DSCController -->|deploys| DSP
    DSCController -->|deploys| KServe
    DSCController -->|deploys| ModelMesh
    DSCController -->|deploys| CodeFlare
    DSCController -->|deploys| KubeRay
    DSCController -->|deploys| TrustyAI
    DSCController -->|deploys| TrainingOp
    DSCController -->|deploys| Kueue

    %% DSCI Controller manages infrastructure
    DSCIController -->|creates| AppsNS
    DSCIController -->|creates| MonitoringNS
    DSCIController -->|creates| IstioNS

    %% External integrations
    DSCController -->|fetches manifests| GitHub
    DSCIController -->|configures| ServiceMesh
    DSCController -->|via API| K8sAPI
    DSCIController -->|via API| K8sAPI
    DSCIController -->|configures| Prometheus
    KServe -.->|requires| ServiceMesh
    KServe -.->|requires| Serverless
    KServe -.->|requires| Authorino

    %% Webhook interactions
    K8sAPI -->|conversion webhook| WebhookServer

    %% Metrics
    Prometheus -.->|scrapes metrics| MetricsServer

