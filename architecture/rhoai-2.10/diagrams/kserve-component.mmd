    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style TrainedModelCR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceGraphCR fill:#f5a623,stroke:#333,stroke-width:2px

    style KnativeService fill:#7ed321,stroke:#333,stroke-width:2px
    style Deployment fill:#7ed321,stroke:#333,stroke-width:2px
    style VirtualService fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelServer fill:#7ed321,stroke:#333,stroke-width:2px

    style Istio fill:#999,stroke:#333,stroke-width:2px
    style Knative fill:#999,stroke:#333,stroke-width:2px
