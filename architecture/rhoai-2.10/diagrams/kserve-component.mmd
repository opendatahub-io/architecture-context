graph TB
    subgraph "KServe Component"
        Controller[kserve-controller-manager<br/>Controller]
        Webhook[kserve-webhook-server<br/>Admission Webhook]
        Agent[kserve-agent<br/>Sidecar Container]
        Router[kserve-router<br/>Inference Router]
        StorageInit[storage-initializer<br/>Init Container]

        Controller -->|manages lifecycle| InferenceServiceCR
        Webhook -->|validates/mutates| InferenceServiceCR
        Webhook -->|injects| Agent
    end

    subgraph "Custom Resources"
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
        TrainedModelCR[TrainedModel CR<br/>serving.kserve.io/v1alpha1]
        InferenceGraphCR[InferenceGraph CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Created Resources"
        KnativeService[Knative Service<br/>Serverless Mode]
        Deployment[Kubernetes Deployment<br/>RawDeployment Mode]
        VirtualService[Istio VirtualService<br/>Traffic Routing]
        ModelServer[Model Server Pod<br/>Framework Runtime]
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh<br/>1.16+]
        Knative[Knative Serving<br/>1.8+]
        CertManager[cert-manager<br/>1.9+]
        K8sAPI[Kubernetes API<br/>1.24+]
    end

    subgraph "Internal ODH Dependencies"
        ServiceMesh[Service Mesh<br/>VirtualService CRD]
        ModelRegistry[Model Registry<br/>API - future]
        DSPipelines[Data Science Pipelines<br/>Model Deployment]
    end

    subgraph "External Services"
        S3[S3 Storage<br/>Model Artifacts]
        GCS[Google Cloud Storage<br/>Model Artifacts]
    end

    subgraph "Model Server Runtimes"
        SKLearn[sklearn-server]
        XGBoost[xgboost-server]
        TensorFlow[tensorflow-serving]
        PyTorch[torchserve]
        HuggingFace[huggingface-server]
        Triton[triton-server]
    end

    User[User/CI] -->|creates| InferenceServiceCR
    User -->|creates| ServingRuntimeCR
    User -->|creates| TrainedModelCR
    User -->|creates| InferenceGraphCR

    Controller -->|watches| InferenceServiceCR
    Controller -->|watches| ServingRuntimeCR
    Controller -->|watches| TrainedModelCR
    Controller -->|watches| InferenceGraphCR

    Controller -->|creates| KnativeService
    Controller -->|creates| Deployment
    Controller -->|creates| VirtualService

    KnativeService -->|provisions| ModelServer
    Deployment -->|provisions| ModelServer

    StorageInit -->|downloads from| S3
    StorageInit -->|downloads from| GCS
    ModelServer -->|uses| StorageInit

    ModelServer -->|runs| SKLearn
    ModelServer -->|runs| XGBoost
    ModelServer -->|runs| TensorFlow
    ModelServer -->|runs| PyTorch
    ModelServer -->|runs| HuggingFace
    ModelServer -->|runs| Triton

    Agent -->|attached to| ModelServer
    Router -->|orchestrates| InferenceGraphCR

    Controller -->|depends on| Istio
    Controller -->|depends on| Knative
    Controller -->|depends on| CertManager
    Controller -->|uses| K8sAPI

    Controller -->|integrates| ServiceMesh
    Controller -.->|future integration| ModelRegistry
    DSPipelines -->|deploys models via| Controller

    Webhook -->|uses certificates from| CertManager

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style Agent fill:#4a90e2,stroke:#333,stroke-width:2px
    style Router fill:#4a90e2,stroke:#333,stroke-width:2px
