graph TB
    subgraph "ODH Model Controller"
        direction TB
        InferenceServiceCtrl[InferenceService Controller]
        StorageSecretCtrl[StorageSecret Controller]
        CustomCACertCtrl[KServeCustomCACert Controller]
        MonitoringCtrl[Monitoring Controller]
        ModelRegistryCtrl[ModelRegistry InferenceService Controller]
        KnativeValidator[Knative Service Validator<br/>Webhook 9443/TCP]

        InferenceServiceCtrl -->|routes to| KServeServerlessRec[KServe Serverless Reconciler]
        InferenceServiceCtrl -->|routes to| KServeRawRec[KServe Raw Reconciler]
        InferenceServiceCtrl -->|routes to| ModelMeshRec[ModelMesh Reconciler]

        subgraph "KServe Sub-Reconcilers"
            RouteRec[Route Reconciler]
            AuthConfigRec[AuthConfig Reconciler]
            NetworkPolicyRec[NetworkPolicy Reconciler]
            PeerAuthRec[PeerAuthentication Reconciler]
            TelemetryRec[Telemetry Reconciler]
            SMMRRec[SMMR Reconciler]
            ServiceMonitorRec[ServiceMonitor Reconciler]
            PodMonitorRec[PodMonitor Reconciler]
            MetricsServiceRec[Metrics Service Reconciler]
            PrometheusRBRec[Prometheus RoleBinding Reconciler]
        end

        subgraph "ModelMesh Sub-Reconcilers"
            MMRouteRec[Route Reconciler]
            MMSARec[ServiceAccount Reconciler]
            MMCRBRec[ClusterRoleBinding Reconciler]
        end

        KServeServerlessRec --> RouteRec
        KServeServerlessRec --> AuthConfigRec
        KServeServerlessRec --> NetworkPolicyRec
        KServeServerlessRec --> PeerAuthRec
        KServeServerlessRec --> TelemetryRec
        KServeServerlessRec --> SMMRRec
        KServeServerlessRec --> ServiceMonitorRec
        KServeServerlessRec --> PodMonitorRec
        KServeServerlessRec --> MetricsServiceRec
        KServeServerlessRec --> PrometheusRBRec

        ModelMeshRec --> MMRouteRec
        ModelMeshRec --> MMSARec
        ModelMeshRec --> MMCRBRec
    end

    subgraph "Watched CRDs"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
        DataConnectionSecret[Data Connection Secret<br/>opendatahub.io/managed=true]
        TrustedCABundle[odh-trusted-ca-bundle<br/>ConfigMap]
        KnativeService[Knative Service<br/>serving.knative.dev/v1]
    end

    subgraph "Created Resources"
        Route[OpenShift Route<br/>route.openshift.io/v1]
        VirtualService[Istio VirtualService<br/>networking.istio.io/v1beta1]
        AuthConfig[Authorino AuthConfig<br/>authorino.kuadrant.io/v1beta2]
        PeerAuth[Istio PeerAuthentication<br/>security.istio.io/v1beta1]
        Telemetry[Istio Telemetry<br/>telemetry.istio.io/v1alpha1]
        NetworkPolicy[NetworkPolicy<br/>networking.k8s.io]
        ServiceMonitor[ServiceMonitor<br/>monitoring.coreos.com/v1]
        PodMonitor[PodMonitor<br/>monitoring.coreos.com/v1]
        SMMR[ServiceMeshMemberRoll<br/>maistra.io/v1]
        StorageConfig[storage-config Secret<br/>Aggregated S3 credentials]
        CustomCAConfigMap[odh-kserve-custom-ca-bundle<br/>ConfigMap]
        PrometheusRB[Prometheus RoleBinding<br/>rbac.authorization.k8s.io]
    end

    subgraph "External Dependencies"
        KServe[KServe v0.11.0]
        Istio[Istio v1.17+]
        Authorino[Authorino v0.15.0]
        Prometheus[Prometheus Operator v0.64.1]
        Knative[Knative Serving v0.37.1]
        ModelRegistry[Model Registry v0.1.1]
    end

    subgraph "Internal ODH Dependencies"
        Dashboard[ODH Dashboard<br/>Serving Runtime Templates]
        DSC[DataScienceCluster<br/>Feature Flags]
        DSCI[DSCInitialization<br/>Authorino/Mesh Config]
    end

    %% Watched CRDs trigger controllers
    InferenceServiceCR -->|watched by| InferenceServiceCtrl
    ServingRuntimeCR -->|watched by| InferenceServiceCtrl
    DataConnectionSecret -->|watched by| StorageSecretCtrl
    TrustedCABundle -->|watched by| CustomCACertCtrl
    KnativeService -->|validated by| KnativeValidator

    %% Controllers create resources
    RouteRec -->|creates| Route
    AuthConfigRec -->|creates| AuthConfig
    NetworkPolicyRec -->|creates| NetworkPolicy
    PeerAuthRec -->|creates| PeerAuth
    TelemetryRec -->|creates| Telemetry
    SMMRRec -->|creates| SMMR
    ServiceMonitorRec -->|creates| ServiceMonitor
    PodMonitorRec -->|creates| PodMonitor
    StorageSecretCtrl -->|creates| StorageConfig
    CustomCACertCtrl -->|creates| CustomCAConfigMap
    MonitoringCtrl -->|creates| PrometheusRB
    InferenceServiceCtrl -->|creates| VirtualService

    %% External dependencies
    InferenceServiceCR -.->|provided by| KServe
    Route -.->|uses| Istio
    VirtualService -.->|uses| Istio
    PeerAuth -.->|uses| Istio
    Telemetry -.->|uses| Istio
    AuthConfig -.->|uses| Authorino
    ServiceMonitor -.->|uses| Prometheus
    PodMonitor -.->|uses| Prometheus
    KnativeService -.->|provided by| Knative
    ModelRegistryCtrl -.->|integrates with| ModelRegistry

    %% Internal ODH dependencies
    InferenceServiceCtrl -.->|reads| Dashboard
    InferenceServiceCtrl -.->|reads| DSC
    InferenceServiceCtrl -.->|reads| DSCI

