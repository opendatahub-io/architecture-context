graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>odh-dashboard<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt<br/>HSTS Enabled"]
    end

    subgraph ApplicationPod["APPLICATION POD (Trusted - Internal Cluster Network)"]
        direction TB

        subgraph Service["Service: odh-dashboard (ClusterIP)"]
            ServicePort["8443/TCP → 8443"]
        end

        subgraph Pod["Pod: odh-dashboard (2 replicas, anti-affinity)"]
            direction TB

            subgraph OAuthContainer["Container: oauth-proxy"]
                OAuthProxy["OAuth Proxy<br/>Port: 8443/TCP HTTPS<br/>TLS 1.2+<br/>Resources: 500m-1000m CPU, 1-2Gi mem<br/>Health: /oauth/healthz"]
                OAuthVolumes["Volumes:<br/>- dashboard-proxy-tls (TLS)<br/>- oauth-config (cookie secret)<br/>- oauth-client (client secret)"]
            end

            subgraph BackendContainer["Container: odh-dashboard"]
                Backend["Backend<br/>Node.js/Fastify<br/>Port: 8080/TCP HTTP<br/>SA: odh-dashboard<br/>Resources: 500m-1000m CPU, 1-2Gi mem<br/>Health: /api/health"]
                BackendVolumes["Volumes:<br/>- odh-trusted-ca-bundle<br/>- odh-ca-bundle"]
            end
        end
    end

    subgraph Authentication["AUTHENTICATION & AUTHORIZATION"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>Client: dashboard-oauth-client<br/>Scope: user:full<br/>Cookie Expiry: 23h<br/>Delegation: projects/list"]
    end

    subgraph InternalServices["INTERNAL CLUSTER SERVICES"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS 1.2+<br/>Service Account Token"]

        Prometheus["Prometheus Service<br/>9091/TCP HTTP<br/>Bearer Token (user)"]

        ModelRegistry["Model Registry Service<br/>{namespace}<br/>Variable port HTTP/HTTPS<br/>Bearer Token"]

        Pipelines["Data Science Pipelines<br/>{namespace}<br/>Variable port HTTP/HTTPS<br/>Bearer Token"]

        TrustyAI["TrustyAI Service<br/>{namespace}<br/>Variable port HTTP/HTTPS<br/>Bearer Token"]
    end

    %% External Flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie| Route

    %% Route to Service
    Route -->|HTTPS/8443<br/>TLS Reencrypt| ServicePort
    ServicePort --> OAuthProxy

    %% OAuth Flow
    OAuthProxy <-->|HTTPS/443<br/>TLS 1.2+<br/>Client Secret| OAuthServer

    %% OAuth to Backend (localhost)
    OAuthProxy -->|HTTP/8080<br/>⚠️ Unencrypted<br/>localhost only<br/>Bearer Token Injected| Backend

    %% Backend to Services
    Backend -->|HTTPS/443<br/>TLS 1.2+<br/>Service Account Token| K8sAPI
    Backend -->|HTTP/9091<br/>Bearer Token| Prometheus
    Backend -->|HTTP/HTTPS<br/>Variable<br/>Bearer Token| ModelRegistry
    Backend -->|HTTP/HTTPS<br/>Variable<br/>Bearer Token| Pipelines
    Backend -->|HTTP/HTTPS<br/>Variable<br/>Bearer Token| TrustyAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Route ingress
    class ServicePort,OAuthProxy,Backend,OAuthContainer,BackendContainer,Pod,Service,ApplicationPod application
    class OAuthServer,Authentication auth
    class K8sAPI,Prometheus,ModelRegistry,Pipelines,TrustyAI,InternalServices internal
