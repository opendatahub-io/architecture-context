graph TB
    subgraph External["EXTERNAL (Cluster Users)"]
        User[User/Application]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>User creds / ServiceAccount"]
    end

    subgraph Namespace_OpenDataHub["NAMESPACE: opendatahub"]
        direction TB

        subgraph Services["Services (ClusterIP)"]
            WebhookSvc["kueue-webhook-service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS 1.2+"]
            MetricsSvc["kueue-metrics-service<br/>8080/TCP → 8080/TCP<br/>HTTP (no auth)"]
            MetricsAuthSvc["kueue-controller-manager-metrics-service<br/>8443/TCP → 8443/TCP<br/>HTTPS TLS 1.2+ (Bearer + RBAC)"]
            VisibilitySvc["kueue-visibility-server<br/>443/TCP → 8082/TCP<br/>HTTPS TLS 1.2+<br/>(Optional)"]
        end

        subgraph Pod["kueue-controller-manager Pod"]
            direction LR
            Manager["Container: manager<br/>━━━━━━━━━━━━━━━<br/>Webhook: 9443/TCP HTTPS<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Visibility: 8082/TCP HTTPS"]
            RBACProxy["Container: kube-rbac-proxy<br/>━━━━━━━━━━━━━━━<br/>Metrics: 8443/TCP HTTPS<br/>Auth: Bearer + RBAC"]
        end

        subgraph Secrets["Secrets"]
            WebhookCert["kueue-webhook-server-cert<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-rotate: Yes"]
            VisibilityCert["kueue-visibility-server-cert<br/>Type: kubernetes.io/tls<br/>(Optional)"]
        end

        WebhookSvc -.->|maps to| Manager
        MetricsSvc -.->|maps to| Manager
        MetricsAuthSvc -.->|maps to| RBACProxy
        VisibilitySvc -.->|maps to| Manager

        Manager -.->|uses cert| WebhookCert
        Manager -.->|uses cert| VisibilityCert
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
        ClusterAutoscaler["Cluster Autoscaler<br/>Node Provisioning<br/>(Optional)"]
    end

    subgraph RBAC["RBAC Configuration"]
        SA["ServiceAccount:<br/>kueue-controller-manager"]
        ManagerRole["ClusterRole:<br/>kueue-manager-role<br/>━━━━━━━━━━━━━━━<br/>• batch, kueue.x-k8s.io<br/>• kubeflow.org, ray.io<br/>• autoscaling.x-k8s.io<br/>• Full CRUD access"]
        UserRole["ClusterRole:<br/>kueue-batch-user-role<br/>━━━━━━━━━━━━━━━<br/>• localqueues, workloads<br/>• get, list, watch only"]
    end

    SA -->|bound to| ManagerRole
    Pod -.->|uses| SA

    %% Flow connections
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| K8sAPI
    K8sAPI -->|"POST /mutate-*<br/>HTTPS/443 (→9443)<br/>TLS 1.2+<br/>API Server cert"| WebhookSvc
    Manager -->|"API calls<br/>HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Manager -->|"Create ProvisioningRequest<br/>HTTPS/6443<br/>autoscaling.x-k8s.io"| K8sAPI
    K8sAPI -.->|"ProvisioningRequest<br/>events"| ClusterAutoscaler
    Prometheus -->|"GET /metrics<br/>HTTP/8080<br/>No auth"| MetricsSvc
    Prometheus -->|"GET /metrics<br/>HTTPS/8443<br/>Bearer Token"| MetricsAuthSvc

    %% Network Policy
    subgraph NetworkPolicy["NetworkPolicy: kueue-webhook-server"]
        NPRule["Ingress: Allow 9443/TCP from any<br/>Selector: app.kubernetes.io/name=kueue"]
    end

    NPRule -.->|protects| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef namespace fill:#e8f5e9,stroke:#4caf50,stroke-width:3px
    classDef service fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef pod fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef secret fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef externalservice fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    classDef rbac fill:#e0f2f1,stroke:#00897b,stroke-width:2px
    classDef netpol fill:#ffebee,stroke:#c62828,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Namespace_OpenDataHub namespace
    class WebhookSvc,MetricsSvc,MetricsAuthSvc,VisibilitySvc service
    class Pod,Manager,RBACProxy pod
    class WebhookCert,VisibilityCert secret
    class Prometheus,ClusterAutoscaler externalservice
    class SA,ManagerRole,UserRole rbac
    class NetworkPolicy,NPRule netpol
