graph TD
    subgraph "Service Accounts"
        SA1[modelmesh-controller<br/>Controller ServiceAccount]
        SA2[modelmesh-serving-sa<br/>Runtime ServiceAccount]
    end

    subgraph "ClusterRole Bindings"
        CRB1[modelmesh-controller-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB1[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: controller-namespace]
        RB2[restricted-scc-rolebinding<br/>RoleBinding<br/>Namespace: controller-namespace]
    end

    subgraph "ClusterRole Permissions"
        CR1[modelmesh-controller-role<br/>ClusterRole]
    end

    subgraph "Role Permissions (Namespace-scoped)"
        R1[leader-election-role<br/>Role]
        R2[restricted-scc-role<br/>ClusterRole]
    end

    subgraph "API Resources - Core"
        Core1[configmaps<br/>API: '']
        Core2[secrets<br/>API: '']
        Core3[services<br/>API: '']
        Core4[namespaces<br/>API: '']
        Core5[endpoints<br/>API: '']
        Core6[pvcs<br/>API: '']
        Core7[events<br/>API: '']
    end

    subgraph "API Resources - Apps"
        Apps1[deployments<br/>API: apps]
    end

    subgraph "API Resources - KServe/ModelMesh"
        KServe1[predictors<br/>API: serving.kserve.io]
        KServe2[servingruntimes<br/>API: serving.kserve.io]
        KServe3[clusterservingruntimes<br/>API: serving.kserve.io]
        KServe4[inferenceservices<br/>API: serving.kserve.io]
        KServe5[predictors/status<br/>API: serving.kserve.io]
        KServe6[servingruntimes/status<br/>API: serving.kserve.io]
        KServe7[clusterservingruntimes/status<br/>API: serving.kserve.io]
        KServe8[inferenceservices/status<br/>API: serving.kserve.io]
    end

    subgraph "API Resources - Autoscaling"
        Auto1[horizontalpodautoscalers<br/>API: autoscaling]
    end

    subgraph "API Resources - Monitoring"
        Mon1[servicemonitors<br/>API: monitoring.coreos.com]
    end

    subgraph "API Resources - Coordination"
        Coord1[leases<br/>API: coordination.k8s.io]
    end

    %% Service Account to RoleBinding connections
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| RB1
    SA2 -->|bound via| RB2

    %% RoleBinding to Role connections
    CRB1 -->|grants| CR1
    RB1 -->|grants| R1
    RB2 -->|grants| R2

    %% ClusterRole to Resources - Core resources
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core3
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core4
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core5
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Core6

    %% ClusterRole to Resources - Apps
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Apps1

    %% ClusterRole to Resources - KServe CRDs
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KServe1
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KServe2
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KServe3
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| KServe4

    %% ClusterRole to Resources - Status subresources
    CR1 -->|get, patch, update| KServe5
    CR1 -->|get, patch, update| KServe6
    CR1 -->|get, patch, update| KServe7
    CR1 -->|get, patch, update| KServe8

    %% ClusterRole to Resources - Autoscaling
    CR1 -->|create, delete, get, list,<br/>watch, update| Auto1

    %% ClusterRole to Resources - Monitoring
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Mon1

    %% Role to Resources - Leader election
    R1 -->|get, list, watch, create,<br/>update, patch, delete| Core1
    R1 -->|get, list, watch, create,<br/>update, patch, delete| Coord1
    R1 -->|create, patch| Core7

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA2 fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px
    style R2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style RB1 fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style RB2 fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style KServe1 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe2 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe3 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe4 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe5 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe6 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe7 fill:#7ed321,stroke:#333,stroke-width:2px
    style KServe8 fill:#7ed321,stroke:#333,stroke-width:2px
    style Apps1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style Auto1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style Mon1 fill:#50e3c2,stroke:#333,stroke-width:2px
