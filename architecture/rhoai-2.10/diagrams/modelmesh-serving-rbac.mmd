    style Core2 fill:#b8e986,stroke:#333,stroke-width:2px
    style Core3 fill:#b8e986,stroke:#333,stroke-width:2px
    style Core4 fill:#b8e986,stroke:#333,stroke-width:2px
    style Core5 fill:#b8e986,stroke:#333,stroke-width:2px
    style Core6 fill:#b8e986,stroke:#333,stroke-width:2px
    style Core7 fill:#b8e986,stroke:#333,stroke-width:2px
