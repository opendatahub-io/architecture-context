graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[odh-model-controller<br/>Namespace: opendatahub/mesh-namespace]
        PrometheusSA[prometheus-custom<br/>Namespace: monitoring]
    end

    subgraph ClusterRoles["Cluster Roles"]
        ControllerRole[odh-model-controller-role<br/>ClusterRole]
        PrometheusRole[prometheus-ns-access<br/>ClusterRole]
    end

    subgraph NamespacedRoles["Namespaced Roles"]
        LeaderElectionRole[leader-election-role<br/>Role in mesh-namespace]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        ControllerCRB[odh-model-controller-rolebinding-mesh-ns<br/>ClusterRoleBinding]
    end

    subgraph NamespacedRoleBindings["Namespaced Role Bindings"]
        LeaderElectionRB[leader-election-rolebinding<br/>RoleBinding in mesh-namespace]
        PrometheusRB[prometheus-ns-access<br/>RoleBinding in inference namespaces<br/>Created by controller]
    end

    subgraph APIResources["API Resources - serving.kserve.io"]
        InferenceServices[InferenceService<br/>Verbs: get, list, watch, update<br/>+ finalizers]
        ServingRuntimes[ServingRuntime<br/>Verbs: get, list, watch,<br/>create, update, patch, delete<br/>+ finalizers]
    end

    subgraph IstioResources["API Resources - Istio"]
        VirtualServices[VirtualService<br/>networking.istio.io<br/>Full CRUD]
        PeerAuthentications[PeerAuthentication<br/>security.istio.io<br/>Full CRUD]
        AuthzPolicies[AuthorizationPolicy<br/>security.istio.io<br/>READ ONLY: get, list]
        Telemetries[Telemetry<br/>telemetry.istio.io<br/>Full CRUD]
    end

    subgraph MaistraResources["API Resources - Maistra"]
        SMM[ServiceMeshMember<br/>maistra.io<br/>Full CRUD + finalizers]
        SMMR[ServiceMeshMemberRoll<br/>maistra.io<br/>Full CRUD]
        SMCP[ServiceMeshControlPlane<br/>maistra.io<br/>Verbs: get, list, watch,<br/>create, update, patch, use]
    end

    subgraph OpenShiftResources["API Resources - OpenShift"]
        Routes[Route<br/>route.openshift.io<br/>Full CRUD]
        CustomHostRoutes[Route custom-host<br/>route.openshift.io<br/>Verb: create]
    end

    subgraph NetworkingResources["API Resources - Networking"]
        NetworkPolicies[NetworkPolicy<br/>networking.k8s.io<br/>Full CRUD]
        Ingresses[Ingress<br/>networking.k8s.io<br/>Full CRUD]
    end

    subgraph RBACResources["API Resources - RBAC"]
        ClusterRoleBindingsRes[ClusterRoleBinding<br/>rbac.authorization.k8s.io<br/>Full CRUD]
        RoleBindingsRes[RoleBinding<br/>rbac.authorization.k8s.io<br/>Full CRUD]
    end

    subgraph MonitoringResources["API Resources - Monitoring"]
        ServiceMonitors[ServiceMonitor<br/>monitoring.coreos.com<br/>Full CRUD]
        PodMonitors[PodMonitor<br/>monitoring.coreos.com<br/>Full CRUD]
    end

    subgraph CoreResources["API Resources - Core"]
        Services[Service<br/>Full CRUD]
        Secrets[Secret<br/>Full CRUD]
        ConfigMaps[ConfigMap<br/>Full CRUD]
        ServiceAccountsRes[ServiceAccount<br/>Full CRUD]
        Namespaces[Namespace<br/>Verbs: get, list, watch,<br/>create, update, patch]
        Pods[Pod<br/>Verbs: get, list, watch,<br/>create, update, patch]
        Endpoints[Endpoint<br/>Verbs: get, list, watch,<br/>create, update, patch]
    end

    subgraph AuthorinoResources["API Resources - Authorino"]
        AuthConfigs[AuthConfig<br/>authorino.kuadrant.io<br/>Full CRUD]
    end

    subgraph ODHResources["API Resources - ODH (Read-Only)"]
        DSCs[DataScienceCluster<br/>datasciencecluster.opendatahub.io<br/>READ ONLY: get, list, watch]
        DSCIs[DSCInitialization<br/>dscinitialization.opendatahub.io<br/>READ ONLY: get, list, watch]
    end

    subgraph LeaderElectionResources["API Resources - Leader Election"]
        LEConfigMaps[ConfigMap<br/>core<br/>Full CRUD]
        LEEvents[Event<br/>core<br/>Full CRUD]
        LELeases[Lease<br/>coordination.k8s.io<br/>Full CRUD]
    end

    %% Service Account to Role Bindings
    SA -->|bound via| ControllerCRB
    SA -->|bound via| LeaderElectionRB
    PrometheusSA -->|bound via| PrometheusRB

    %% Role Bindings to Roles
    ControllerCRB -->|grants| ControllerRole
    LeaderElectionRB -->|grants| LeaderElectionRole
    PrometheusRB -->|grants| PrometheusRole

    %% Controller Role Permissions
    ControllerRole -->|get, list, watch, update + finalizers| InferenceServices
    ControllerRole -->|get, list, watch, create, update, patch, delete + finalizers| ServingRuntimes

    ControllerRole -->|get, list, watch, create, update, patch, delete| VirtualServices
    ControllerRole -->|get, list, watch, create, update, patch, delete| PeerAuthentications
    ControllerRole -->|get, list - READ ONLY| AuthzPolicies
    ControllerRole -->|get, list, watch, create, update, patch, delete| Telemetries

    ControllerRole -->|get, list, watch, create, update, patch, delete + finalizers| SMM
    ControllerRole -->|get, list, watch, create, update, patch, delete| SMMR
    ControllerRole -->|get, list, watch, create, update, patch, use| SMCP

    ControllerRole -->|get, list, watch, create, update, patch, delete| Routes
    ControllerRole -->|create| CustomHostRoutes

    ControllerRole -->|get, list, watch, create, update, patch, delete| NetworkPolicies
    ControllerRole -->|get, list, watch, create, update, patch, delete| Ingresses

    ControllerRole -->|get, list, watch, create, update, patch, delete| ClusterRoleBindingsRes
    ControllerRole -->|get, list, watch, create, update, patch, delete| RoleBindingsRes

    ControllerRole -->|get, list, watch, create, update, patch, delete| ServiceMonitors
    ControllerRole -->|get, list, watch, create, update, patch, delete| PodMonitors

    ControllerRole -->|get, list, watch, create, update, patch, delete| Services
    ControllerRole -->|get, list, watch, create, update, patch, delete| Secrets
    ControllerRole -->|get, list, watch, create, update, patch, delete| ConfigMaps
    ControllerRole -->|get, list, watch, create, update, patch, delete| ServiceAccountsRes
    ControllerRole -->|get, list, watch, create, update, patch| Namespaces
    ControllerRole -->|get, list, watch, create, update, patch| Pods
    ControllerRole -->|get, list, watch, create, update, patch| Endpoints

    ControllerRole -->|get, list, watch, create, update, patch, delete| AuthConfigs

    ControllerRole -->|get, list, watch - READ ONLY| DSCs
    ControllerRole -->|get, list, watch - READ ONLY| DSCIs

    %% Leader Election Role Permissions
    LeaderElectionRole -->|get, list, watch, create, update, patch, delete| LEConfigMaps
    LeaderElectionRole -->|get, list, watch, create, update, patch, delete| LEEvents
    LeaderElectionRole -->|get, list, watch, create, update, patch, delete| LELeases

    %% Prometheus Role (created in inference namespaces)
    PrometheusRole -.->|grants NS-scoped access| PrometheusRB

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef binding fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef resource fill:#e8e8e8,stroke:#666,stroke-width:1px,color:#000
    classDef readonly fill:#d5e8d4,stroke:#82b366,stroke-width:1px,color:#000

    class SA,PrometheusSA serviceaccount
    class ControllerRole,PrometheusRole,LeaderElectionRole role
    class ControllerCRB,LeaderElectionRB,PrometheusRB binding
    class InferenceServices,ServingRuntimes,VirtualServices,PeerAuthentications,Telemetries,SMM,SMMR,SMCP,Routes,CustomHostRoutes,NetworkPolicies,Ingresses,ClusterRoleBindingsRes,RoleBindingsRes,ServiceMonitors,PodMonitors,Services,Secrets,ConfigMaps,ServiceAccountsRes,Namespaces,Pods,Endpoints,AuthConfigs,LEConfigMaps,LEEvents,LELeases resource
