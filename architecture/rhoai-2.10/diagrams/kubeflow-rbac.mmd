graph TD
    subgraph "Service Accounts"
        SA[service-account<br/>notebook-controller-system]
    end

    subgraph "ClusterRole Bindings"
        CRB1[leader-election-role-binding]
        CRB2[auth-proxy-role-binding]
        CRB3[role-binding]
    end

    subgraph "ClusterRoles"
        CR1[leader-election-role]
        CR2[proxy-role]
        CR3[role]
        CR4[kubeflow-notebooks-edit]
        CR5[kubeflow-notebooks-view]
    end

    subgraph "API Resources - Core"
        direction TB
        Services[core/Services]
        Pods[core/Pods]
        Events[core/Events]
    end

    subgraph "API Resources - Apps"
        StatefulSets[apps/StatefulSets]
    end

    subgraph "API Resources - Kubeflow"
        direction TB
        Notebooks[kubeflow.org/Notebook]
        NotebooksFinalizers[kubeflow.org/Notebook/finalizers]
        NotebooksStatus[kubeflow.org/Notebook/status]
    end

    subgraph "API Resources - Istio"
        VirtualServices[networking.istio.io/VirtualService]
    end

    subgraph "API Resources - Auth"
        direction TB
        TokenReviews[authentication.k8s.io/TokenReview]
        SubjectAccessReviews[authorization.k8s.io/SubjectAccessReview]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% Role: role (main controller permissions)
    CR3 -->|"* (all verbs)"| StatefulSets
    CR3 -->|"* (all verbs)"| Services
    CR3 -->|get,list,watch,delete| Pods
    CR3 -->|get,list,watch,create,patch| Events
    CR3 -->|"* (all verbs)"| Notebooks
    CR3 -->|"* (all verbs)"| NotebooksFinalizers
    CR3 -->|"* (all verbs)"| NotebooksStatus
    CR3 -->|"* (all verbs)"| VirtualServices

    %% Role: proxy-role (auth proxy)
    CR2 -->|create| TokenReviews
    CR2 -->|create| SubjectAccessReviews

    %% Role: kubeflow-notebooks-edit (user role)
    CR4 -->|get,list,watch,create,delete,<br/>deletecollection,patch,update| Notebooks
    CR4 -->|get,list,watch,create,delete,<br/>deletecollection,patch,update| NotebooksStatus

    %% Role: kubeflow-notebooks-view (user role)
    CR5 -->|get,list,watch| Notebooks
    CR5 -->|get,list,watch| NotebooksStatus

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR4 fill:#7ed321,stroke:#333,stroke-width:2px
    style CR5 fill:#7ed321,stroke:#333,stroke-width:2px
    style CRB1 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB2 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Services fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Pods fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Events fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style StatefulSets fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Notebooks fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style NotebooksFinalizers fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style NotebooksStatus fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style VirtualServices fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style TokenReviews fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style SubjectAccessReviews fill:#fff2cc,stroke:#d6b656,stroke-width:2px
