graph TD
    subgraph "Service Accounts"
        SA[ServiceAccount<br/>training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[ClusterRoleBinding<br/>training-operator]
    end

    subgraph "ClusterRole: training-operator"
        CR[ClusterRole<br/>training-operator<br/>Cluster-scoped permissions]
    end

    subgraph "API Resources - Core"
        ConfigMaps[core/ConfigMaps<br/>create, list, update, watch]
        Events[core/Events<br/>create, delete, get, list,<br/>patch, update, watch]
        Pods[core/Pods<br/>create, delete, get, list,<br/>patch, update, watch]
        PodsExec[core/Pods/exec<br/>create]
        ServiceAccounts[core/ServiceAccounts<br/>create, get, list, watch]
        Services[core/Services<br/>create, delete, get,<br/>list, watch]
    end

    subgraph "API Resources - Autoscaling"
        HPA[autoscaling/HorizontalPodAutoscalers<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "API Resources - Training Jobs (kubeflow.org/v1)"
        PyTorchJob[PyTorchJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        TFJob[TFJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        MPIJob[MPIJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        XGBoostJob[XGBoostJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        MXJob[MXJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
        PaddleJob[PaddleJob + status + finalizers<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "API Resources - Gang Scheduling"
        VolcanoPodGroup[scheduling.volcano.sh/PodGroups<br/>create, delete, get, list,<br/>patch, update, watch]
        K8sPodGroup[scheduling.x-k8s.io/PodGroups<br/>create, delete, get, list,<br/>patch, update, watch]
    end

    subgraph "API Resources - RBAC Management"
        Roles[rbac.authorization.k8s.io/Roles<br/>create, list, update, watch]
        RoleBindings[rbac.authorization.k8s.io/RoleBindings<br/>create, list, update, watch]
    end

    subgraph "User Roles"
        EditRole[ClusterRole<br/>training-edit<br/>User role: create/manage jobs]
        ViewRole[ClusterRole<br/>training-view<br/>User role: view jobs only]
    end

    %% Service Account → Binding → Role
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% ClusterRole permissions
    CR -->|permissions| ConfigMaps
    CR -->|permissions| Events
    CR -->|permissions| Pods
    CR -->|permissions| PodsExec
    CR -->|permissions| ServiceAccounts
    CR -->|permissions| Services
    CR -->|permissions| HPA
    CR -->|permissions| PyTorchJob
    CR -->|permissions| TFJob
    CR -->|permissions| MPIJob
    CR -->|permissions| XGBoostJob
    CR -->|permissions| MXJob
    CR -->|permissions| PaddleJob
    CR -->|permissions| VolcanoPodGroup
    CR -->|permissions| K8sPodGroup
    CR -->|permissions| Roles
    CR -->|permissions| RoleBindings

    %% User roles
    EditRole -.->|manage| PyTorchJob
    EditRole -.->|manage| TFJob
    EditRole -.->|manage| MPIJob
    EditRole -.->|manage| XGBoostJob
    EditRole -.->|manage| MXJob
    EditRole -.->|manage| PaddleJob

    ViewRole -.->|read-only| PyTorchJob
    ViewRole -.->|read-only| TFJob
    ViewRole -.->|read-only| MPIJob
    ViewRole -.->|read-only| XGBoostJob
    ViewRole -.->|read-only| MXJob
    ViewRole -.->|read-only| PaddleJob

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style HPA fill:#82b366,stroke:#333,color:#fff
    style PyTorchJob fill:#50e3c2,stroke:#333
    style TFJob fill:#50e3c2,stroke:#333
    style MPIJob fill:#50e3c2,stroke:#333
    style XGBoostJob fill:#50e3c2,stroke:#333
    style MXJob fill:#50e3c2,stroke:#333
    style PaddleJob fill:#50e3c2,stroke:#333
    style VolcanoPodGroup fill:#9673a6,stroke:#333,color:#fff
    style K8sPodGroup fill:#9673a6,stroke:#333,color:#fff
    style Roles fill:#d6b656,stroke:#333
    style RoleBindings fill:#d6b656,stroke:#333
    style EditRole fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style ViewRole fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
