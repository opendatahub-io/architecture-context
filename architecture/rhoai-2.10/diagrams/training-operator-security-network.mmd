graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>kubectl / Python SDK"]
    end

    subgraph ControlPlane["CLUSTER CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>AuthN: mTLS/Bearer<br/>AuthZ: RBAC"]
        Webhook["Admission Webhook<br/>9443/TCP HTTPS TLS<br/>Kubernetes API auth"]
        K8sAPI -->|validates CRs| Webhook
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["Training Operator Controller<br/>SA: training-operator<br/>UID: 65532 (non-root)<br/>Istio injection: disabled"]
        MetricsPort["Metrics Endpoint<br/>8080/TCP HTTP<br/>No encryption, No auth"]
        HealthPort["Health Probes<br/>8081/TCP HTTP<br/>No encryption, No auth"]

        Operator -->|exposes| MetricsPort
        Operator -->|exposes| HealthPort
    end

    subgraph UserNS["USER NAMESPACES (training jobs)"]
        direction TB

        subgraph PyTorchWorkers["PyTorch Job"]
            PTMaster["Master Pod<br/>MASTER_ADDR"]
            PTWorker1["Worker Pod 1<br/>RANK=1"]
            PTWorker2["Worker Pod 2<br/>RANK=2"]
            PTMaster -->|torchrun protocol<br/>TCP dynamic ports<br/>No encryption*| PTWorker1
            PTMaster -->|torchrun protocol<br/>TCP dynamic ports<br/>No encryption*| PTWorker2
        end

        subgraph TFWorkers["TensorFlow Job"]
            TFChief["Chief<br/>TF_CONFIG"]
            TFPS["Parameter Server<br/>2222/TCP gRPC"]
            TFWorker["Worker<br/>2222/TCP gRPC"]
            TFChief -->|gRPC<br/>No encryption*| TFPS
            TFChief -->|gRPC<br/>No encryption*| TFWorker
        end

        subgraph MPIWorkers["MPI Job"]
            Launcher["Launcher Pod<br/>mpirun"]
            MPIWorker1["Worker 1<br/>SSH 2222/TCP"]
            MPIWorker2["Worker 2<br/>SSH 2222/TCP"]
            Launcher -->|SSH + MPI<br/>SSH key auth| MPIWorker1
            Launcher -->|SSH + MPI<br/>SSH key auth| MPIWorker2
        end
    end

    subgraph Monitoring["MONITORING (opendatahub)"]
        Prometheus["Prometheus<br/>PodMonitor"]
    end

    subgraph GangScheduler["GANG SCHEDULERS (Optional)"]
        SchedulerPlugins["scheduler-plugins v0.25.7+<br/>scheduling.x-k8s.io/PodGroup<br/>Default"]
        VolcanoScheduler["Volcano<br/>scheduling.volcano.sh/PodGroup<br/>Optional"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io, docker.io<br/>443/TCP HTTPS TLS1.2+<br/>Image pull secrets"]
    end

    %% User flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig auth| K8sAPI

    %% Operator flows
    K8sAPI -->|Watch CRDs<br/>HTTPS TLS1.2+<br/>ServiceAccount token| Operator
    Operator -->|Create pods/services<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount token| K8sAPI
    Operator -->|Create PodGroups<br/>HTTPS/6443 TLS1.2+| SchedulerPlugins
    Operator -.->|Alternative| VolcanoScheduler

    %% Worker deployment
    K8sAPI -->|Schedule pods| PyTorchWorkers
    K8sAPI -->|Schedule pods| TFWorkers
    K8sAPI -->|Schedule pods| MPIWorkers

    %% Monitoring
    Prometheus -->|Scrape /metrics<br/>HTTP/8080<br/>No encryption, No auth| MetricsPort

    %% Container images
    Operator -->|Pull images<br/>HTTPS/443 TLS1.2+<br/>Image pull secrets| Registry
    PyTorchWorkers -.->|Pull images| Registry
    TFWorkers -.->|Pull images| Registry
    MPIWorkers -.->|Pull images| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef workers fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduler fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI,Webhook controlplane
    class Operator,MetricsPort,HealthPort operator
    class PyTorchWorkers,TFWorkers,MPIWorkers,PTMaster,PTWorker1,PTWorker2,TFChief,TFPS,TFWorker,Launcher,MPIWorker1,MPIWorker2 workers
    class Prometheus monitoring
    class SchedulerPlugins,VolcanoScheduler scheduler
    class Registry externalservice

    %% Legend
    subgraph Legend["LEGEND"]
        L1["* May use service mesh mTLS if Istio/Linkerd enabled"]
    end

    class Legend external
