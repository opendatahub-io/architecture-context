        RHODS[RHODS Operator<br/>Platform Orchestrator]
        Dashboard[ODH Dashboard<br/>Web UI & API]
    end

    subgraph "Workbench Components"
        NotebookCtrl[Notebook Controller]
        NotebookImages[Notebook Images]
    end

    subgraph "Model Serving Components"
        KServe[KServe]
        ModelMesh[ModelMesh Serving]
        ModelCtrl[ODH Model Controller]
    end

    subgraph "ML Workflow Components"
        DSP[Data Science Pipelines]
    end

    subgraph "Training Components"
        TrainingOp[Training Operator]
    end

    subgraph "Distributed Computing Components"
        CodeFlare[CodeFlare Operator]
        KubeRay[KubeRay Operator]
    end

    subgraph "Workload Management"
        Kueue[Kueue]
