graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Administrator/GitOps Client]
        PrometheusExt[Prometheus<br/>ServiceAccount Token]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>User/ServiceAccount Auth"]
    end

    subgraph OperatorPod["OPERATOR POD (openshift-operators)"]
        direction TB

        subgraph Controllers["Controllers (ServiceAccount: controller-manager)"]
            DSCController[DataScienceCluster Controller]
            DSCIController[DSCInitialization Controller]
            FeatureController[FeatureTracker Controller]
            SecretGen[SecretGenerator]
            CertGen[CertConfigMapGenerator]
            StatusController[Status Controller]
        end

        RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>ServiceAccount Token Auth"]
        MetricsEndpoint["Metrics Endpoint<br/>8080/TCP HTTP<br/>localhost only"]
        HealthEndpoints["Health Endpoints<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS 1.2+ mTLS"]

        RBACProxy -->|proxies to| MetricsEndpoint
    end

    subgraph K8sResources["KUBERNETES CLUSTER RESOURCES"]
        direction TB

        subgraph Namespaces["Namespaces (Created by DSCI)"]
            AppsNS[redhat-ods-applications]
            MonNS[redhat-ods-monitoring]
            IstioNS[istio-system]
            AuthNS[redhat-ods-applications-auth-provider]
        end

        subgraph Components["Managed Components"]
            Dashboard[ODH Dashboard]
            Notebooks[Notebook Controller]
            DSP[Data Science Pipelines]
            KServe[KServe]
            ModelMesh[ModelMesh]
            CodeFlare[CodeFlare]
            KubeRay[KubeRay]
            TrustyAI[TrustyAI]
            Training[Training Operator]
            Kueue[Kueue]
        end

        subgraph ServiceMesh["Service Mesh & Dependencies"]
            SMCP[ServiceMeshControlPlane]
            SMMR[ServiceMeshMemberRoll]
            Authorino[Authorino]
            Knative[KnativeServing]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub (github.com)<br/>443/TCP HTTPS TLS1.2+<br/>Manifest fetch"]
        Quay["quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Container images"]
        RedHatReg["registry.access.redhat.com<br/>443/TCP HTTPS TLS1.2+<br/>Base images"]
    end

    %% External to Control Plane
    Admin -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI
    PrometheusExt -->|HTTPS/8443<br/>TLS 1.2+<br/>ServiceAccount Token| RBACProxy

    %% Control Plane to Operator
    K8sAPI -->|In-Memory<br/>Watch events| Controllers
    K8sAPI -->|HTTPS/9443<br/>TLS 1.2+ mTLS<br/>Conversion webhook| WebhookServer

    %% Operator to Control Plane
    Controllers -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    %% Operator creates resources
    DSCController -.->|deploys via K8s API| Components
    DSCIController -.->|creates via K8s API| Namespaces
    DSCIController -.->|creates via K8s API| ServiceMesh

    %% External service connections
    Controllers -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| GitHub
    K8sResources -.->|pull images| Quay
    K8sResources -.->|pull images| RedHatReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sresources fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Admin,PrometheusExt external
    class K8sAPI controlplane
    class Controllers,RBACProxy,MetricsEndpoint,HealthEndpoints,WebhookServer operator
    class Namespaces,Components,ServiceMesh k8sresources
    class GitHub,Quay,RedHatReg externalservice
