graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Admin Browser]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>AuthN: Bearer/SA tokens"]
    end

    subgraph OperatorNamespace["OPERATOR NAMESPACE<br/>trustyai-service-operator-system"]
        Controller["TrustyAI Service Operator<br/>SA: controller-manager<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (health)<br/>Security: runAsNonRoot, no privileges"]
    end

    subgraph UserNamespace["USER NAMESPACE (per TrustyAIService)"]
        direction TB

        subgraph Deployment["TrustyAI Service Deployment"]
            direction LR
            TrustyAI["TrustyAI Service<br/>Port: 8080/TCP HTTP<br/>Storage: PVC /inputs<br/>Image: quay.io/trustyai/trustyai-service"]
            OAuthProxy["OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS TLS1.2+<br/>Image: ose-oauth-proxy<br/>Auth: OAuth + SAR"]

            OAuthProxy -->|localhost:8080<br/>HTTP plaintext| TrustyAI
        end

        Service1["Service: instance-name<br/>ClusterIP<br/>80/TCP → 8080/TCP<br/>HTTP, No Auth"]
        Service2["Service: instance-name-tls<br/>ClusterIP<br/>443/TCP → 8443/TCP<br/>HTTPS TLS1.2+, OAuth"]

        Service1 -->|internal| TrustyAI
        Service2 -->|authenticated| OAuthProxy
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["Route: instance-name<br/>443/TCP HTTPS<br/>TLS Mode: Re-encrypt<br/>Router Cert → service-ca Cert"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS1.2+<br/>Token validation + SAR"]
        ServiceCA["service-ca Controller<br/>Auto TLS cert injection"]
        Registry["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS"]
    end

    subgraph Integration["INTEGRATION (ModelMesh)"]
        ModelMesh["ModelMesh Pod<br/>label: modelmesh-service=<br/>modelmesh-serving<br/>Env: MM_PAYLOAD_PROCESSORS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape"]
        ServiceMonitor["ServiceMonitor CR<br/>scrape /q/metrics"]
    end

    subgraph Storage["STORAGE"]
        PVC["PersistentVolumeClaim<br/>Size: configurable<br/>Access: ReadWriteOnce"]
    end

    %% External User Flow
    User -->|HTTPS/443<br/>TLS1.2+<br/>Bearer Token optional| Route
    Route -->|HTTPS/443<br/>service-ca cert| Service2

    %% Operator Flows
    User -->|kubectl apply<br/>6443/TCP HTTPS<br/>Bearer Token| K8sAPI
    K8sAPI -->|Watch events| Controller
    Controller -->|CRUD operations<br/>6443/TCP HTTPS<br/>SA Token| K8sAPI
    Controller -->|Image metadata<br/>443/TCP HTTPS| Registry

    %% OAuth Flow
    OAuthProxy -->|Validate token<br/>443/TCP HTTPS TLS1.2+<br/>OAuth 2.0| OAuthServer

    %% TLS Certificate
    ServiceCA -.->|Inject cert<br/>Secret: instance-tls| Service2

    %% ModelMesh Integration
    ModelMesh -->|Forward payloads<br/>80/TCP HTTP<br/>No Auth| Service1

    %% Metrics
    Prometheus -->|Scrape metrics<br/>80/TCP HTTP<br/>No Auth| Service1
    ServiceMonitor -.->|Config| Prometheus

    %% Storage
    TrustyAI -->|Read/Write<br/>Inference data| PVC

    %% Operator Creates Resources
    Controller -.->|creates| Service1
    Controller -.->|creates| Service2
    Controller -.->|creates| Route
    Controller -.->|creates| Deployment
    Controller -.->|creates| ServiceMonitor
    Controller -.->|creates| PVC
    Controller -.->|patches env| ModelMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0078d4,stroke-width:2px
    classDef operator fill:#fff4e6,stroke:#ff9800,stroke-width:2px
    classDef workload fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    classDef integration fill:#e0f7fa,stroke:#00bcd4,stroke-width:2px
    classDef monitoring fill:#fff9c4,stroke:#fbc02d,stroke-width:2px
    classDef storage fill:#fce4ec,stroke:#e91e63,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller operator
    class TrustyAI,OAuthProxy,Service1,Service2,Deployment workload
    class Route ingress
    class OAuthServer,ServiceCA,Registry externalservice
    class ModelMesh integration
    class Prometheus,ServiceMonitor monitoring
    class PVC storage
