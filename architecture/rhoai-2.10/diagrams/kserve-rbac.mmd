    style Event fill:#fff9c4,stroke:#333,stroke-width:2px,color:#000
    style SvcAcct fill:#fff9c4,stroke:#333,stroke-width:2px,color:#000

    style HPA fill:#dcedc8,stroke:#333,stroke-width:2px,color:#000
    style Ingress fill:#f0f4c3,stroke:#333,stroke-width:2px,color:#000

    style MWC fill:#ffccbc,stroke:#333,stroke-width:2px,color:#000
    style VWC fill:#ffccbc,stroke:#333,stroke-width:2px,color:#000

    style TR fill:#d1c4e9,stroke:#333,stroke-width:2px,color:#000
    style SAR fill:#d1c4e9,stroke:#333,stroke-width:2px,color:#000

    style Lease fill:#c8e6c9,stroke:#333,stroke-width:2px,color:#000
