graph TD
    subgraph "Service Account"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager[kserve-manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy[kserve-proxy-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB_Leader[kserve-leader-election-rolebinding<br/>RoleBinding - Namespace: kserve]
    end

    subgraph "Cluster Roles"
        CR_Manager[kserve-manager-role<br/>ClusterRole]
        CR_Proxy[kserve-proxy-role<br/>ClusterRole]
    end

    subgraph "Roles"
        R_Leader[kserve-leader-election-role<br/>Role - Namespace: kserve]
    end

    subgraph "KServe API Resources"
        direction TB
        IS[serving.kserve.io<br/>InferenceService<br/>+ finalizers, status]
        SR[serving.kserve.io<br/>ServingRuntime<br/>+ finalizers, status]
        TM[serving.kserve.io<br/>TrainedModel<br/>+ status]
        IG[serving.kserve.io<br/>InferenceGraph<br/>+ finalizers, status]
        CSC[serving.kserve.io<br/>ClusterStorageContainer]
    end

    subgraph "Knative API Resources"
        KS[serving.knative.dev<br/>Service<br/>+ finalizers, status]
    end

    subgraph "Istio API Resources"
        VS[networking.istio.io<br/>VirtualService<br/>+ finalizers, status]
    end

    subgraph "Kubernetes Core Resources"
        direction TB
        Deploy[apps<br/>Deployment]
        SVC[core<br/>Service]
        CM[core<br/>ConfigMap]
        Secret[core<br/>Secret]
        Pod[core<br/>Pod]
        NS[core<br/>Namespace]
        Event[core<br/>Event]
        SvcAcct[core<br/>ServiceAccount<br/>verbs: get only]
    end

    subgraph "Autoscaling Resources"
        HPA[autoscaling<br/>HorizontalPodAutoscaler]
    end

    subgraph "Networking Resources"
        Ingress[networking.k8s.io<br/>Ingress]
    end

    subgraph "Admission Registration"
        MWC[admissionregistration.k8s.io<br/>MutatingWebhookConfiguration]
        VWC[admissionregistration.k8s.io<br/>ValidatingWebhookConfiguration]
    end

    subgraph "Authentication & Authorization"
        TR[authentication.k8s.io<br/>TokenReview]
        SAR[authorization.k8s.io<br/>SubjectAccessReview]
    end

    subgraph "Coordination Resources"
        Lease[coordination.k8s.io<br/>Lease<br/>Leader election]
        CMLE[core<br/>ConfigMap<br/>Leader election]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| CRB_Proxy
    SA -->|bound via| RB_Leader

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Leader -->|grants| R_Leader

    %% Manager Role Permissions
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| IS
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| SR
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| TM
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| IG
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| CSC
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| KS
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| VS
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| Deploy
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| SVC
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| CM
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| Secret
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| Pod
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| NS
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| Event
    CR_Manager -->|"get"| SvcAcct
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| HPA
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| Ingress
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| MWC
    CR_Manager -->|"create, delete, get<br/>list, patch, update, watch"| VWC

    %% Proxy Role Permissions
    CR_Proxy -->|"create"| TR
    CR_Proxy -->|"create"| SAR

    %% Leader Election Role Permissions
    R_Leader -->|"create, get, update"| CMLE
    R_Leader -->|"create, get, update"| Lease

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB_Proxy fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style RB_Leader fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CR_Manager fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style CR_Proxy fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style R_Leader fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style IS fill:#e1bee7,stroke:#333,stroke-width:2px,color:#000
    style SR fill:#e1bee7,stroke:#333,stroke-width:2px,color:#000
    style TM fill:#e1bee7,stroke:#333,stroke-width:2px,color:#000
