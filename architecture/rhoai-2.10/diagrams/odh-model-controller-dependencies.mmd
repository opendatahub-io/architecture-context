graph LR
    ODHModelController[ODH Model Controller<br/>v1.27.0-rhods-341]

    %% External Dependencies (Required and Optional)
    subgraph ExternalDeps["External Dependencies"]
        KServe[KServe v0.11.0<br/>REQUIRED<br/>InferenceService CRD]
        Istio[Istio v1.17+<br/>OPTIONAL<br/>Service mesh, mTLS, telemetry]
        Authorino[Authorino v0.15.0<br/>OPTIONAL<br/>AuthN/AuthZ service]
        ServiceMesh[OpenShift Service Mesh v2.x<br/>OPTIONAL<br/>Maistra Istio distribution]
        PrometheusOp[Prometheus Operator v0.64.1<br/>OPTIONAL<br/>Monitoring CRDs]
        Knative[Knative Serving v0.37.1<br/>OPTIONAL<br/>Serverless platform]
        ModelRegistry[Model Registry v0.1.1<br/>OPTIONAL<br/>Model metadata registry]
    end

    %% Internal ODH Dependencies
    subgraph InternalDeps["Internal ODH Dependencies"]
        KServeController[KServe Controller<br/>Watches InferenceService CRD]
        ModelMesh[ModelMesh Serving<br/>Watches Predictor CRD]
        Dashboard[ODH Dashboard<br/>Serving runtime templates]
        DSC[DataScienceCluster<br/>Feature flags config]
        DSCI[DSCInitialization<br/>Authorino/Mesh settings]
    end

    %% Integration Points
    subgraph IntegrationPoints["Integration Points"]
        K8sAPI[Kubernetes API Server<br/>Watch/Create resources]
        PrometheusService[Prometheus<br/>Metrics scraping]
        AuthorinoService[Authorino Service<br/>AuthConfig enforcement]
        IstioCP[Istio Control Plane<br/>Traffic management]
        OpenShiftRouter[OpenShift Router<br/>External ingress]
    end

    %% External Services
    subgraph ExternalServices["External Services"]
        S3[S3 Storage<br/>Model artifacts]
    end

    %% Dependencies from Controller
    ODHModelController -->|requires| KServe
    ODHModelController -->|optional| Istio
    ODHModelController -->|optional| Authorino
    ODHModelController -->|optional| ServiceMesh
    ODHModelController -->|optional| PrometheusOp
    ODHModelController -->|optional| Knative
    ODHModelController -->|optional| ModelRegistry

    %% Internal dependencies
    ODHModelController -->|watches CRDs| KServeController
    ODHModelController -->|watches CRDs| ModelMesh
    ODHModelController -->|reads ConfigMaps| Dashboard
    ODHModelController -->|reads config| DSC
    ODHModelController -->|reads config| DSCI

    %% Integration points
    ODHModelController -->|API calls 6443/TCP| K8sAPI
    ODHModelController -->|exposes /metrics 8080/TCP| PrometheusService
    ODHModelController -->|creates AuthConfigs| AuthorinoService
    ODHModelController -->|creates VirtualServices| IstioCP
    ODHModelController -->|creates Routes| OpenShiftRouter

    %% Downstream integrations (what depends on controller's outputs)
    Dashboard -->|UI management| ODHModelController
    PrometheusService -->|scrapes metrics| ODHModelController

    %% External service access (indirect, via managed InferenceServices)
    KServe -.->|model storage| S3
    ModelMesh -.->|model storage| S3

