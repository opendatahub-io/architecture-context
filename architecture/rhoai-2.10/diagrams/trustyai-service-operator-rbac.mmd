graph TD
    subgraph "Operator Service Account"
        SA_Operator[controller-manager<br/>Namespace: trustyai-service-operator-system]
    end

    subgraph "OAuth Proxy Service Account (per instance)"
        SA_Proxy["{instance-name}-proxy<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_Proxy["{instance-name}-{namespace}-proxy-rolebinding<br/>ClusterRoleBinding"]
        RB_Leader[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole: manager-role"
        direction TB
        CR_Manager[manager-role<br/>ClusterRole]

        Perm_Core["Core Resources:<br/>• configmaps: create,delete,get,list,patch,update,watch<br/>• events: create,patch,update<br/>• pods: create,delete,get,list,patch,update,watch<br/>• secrets: create,delete,get,list,patch,update,watch<br/>• serviceaccounts: create,delete,get,list,update,watch<br/>• services: create,delete,get,list,patch,update,watch<br/>• persistentvolumeclaims: create,delete,get,list,patch,update,watch<br/>• persistentvolumes: get,list,watch"]

        Perm_Apps["Apps Resources:<br/>• deployments: create,delete,get,list,patch,update,watch<br/>• deployments/finalizers: update<br/>• deployments/status: get,patch,update"]

        Perm_Coordination["Coordination Resources:<br/>• leases: create,get,update"]

        Perm_Monitoring["Monitoring Resources:<br/>• servicemonitors: create,list,watch"]

        Perm_RBAC["RBAC Resources:<br/>• clusterrolebindings: create,delete,get,list,update,watch"]

        Perm_Route["Route Resources:<br/>• routes: create,delete,get,list,patch,update,watch"]

        Perm_KServe["KServe Resources:<br/>• inferenceservices: get,list,patch,update,watch<br/>• inferenceservices/finalizers: delete,get,list,patch,update,watch<br/>• servingruntimes: create,delete,get,list,patch,update,watch<br/>• servingruntimes/status: get,patch,update"]

        Perm_TrustyAI["TrustyAI Resources:<br/>• trustyaiservices: create,delete,get,list,patch,update,watch<br/>• trustyaiservices/finalizers: update<br/>• trustyaiservices/status: get,patch,update"]

        CR_Manager -->|grants| Perm_Core
        CR_Manager -->|grants| Perm_Apps
        CR_Manager -->|grants| Perm_Coordination
        CR_Manager -->|grants| Perm_Monitoring
        CR_Manager -->|grants| Perm_RBAC
        CR_Manager -->|grants| Perm_Route
        CR_Manager -->|grants| Perm_KServe
        CR_Manager -->|grants| Perm_TrustyAI
    end

    subgraph "ClusterRole: proxy-role"
        CR_Proxy[trustyai-service-operator-proxy-role<br/>ClusterRole]

        Perm_OAuth["OAuth Resources:<br/>• tokenreviews: create<br/>• subjectaccessreviews: create"]

        CR_Proxy -->|grants| Perm_OAuth
    end

    subgraph "Role: leader-election-role"
        R_Leader[leader-election-role<br/>Role<br/>Namespace: trustyai-service-operator-system]

        Perm_Leader["Leader Election:<br/>• configmaps: get,list,watch,create,update,patch,delete<br/>• leases: get,list,watch,create,update,patch,delete<br/>• events: create,patch"]

        R_Leader -->|grants| Perm_Leader
    end

    subgraph "ClusterRole: metrics-reader"
        CR_Metrics[metrics-reader<br/>ClusterRole]

        Perm_Metrics["Non-resource URL:<br/>• /metrics: get"]

        CR_Metrics -->|grants| Perm_Metrics
    end

    subgraph "User Authentication"
        User[User/Browser]
        UserAuth["OAuth Proxy Authorization:<br/>Requires namespace.pods.get permission<br/>Enforced via Subject Access Review (SAR)"]

        User -->|authenticates via| UserAuth
    end

    %% Bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| RB_Leader
    CRB_Manager -->|grants| CR_Manager
    RB_Leader -->|grants| R_Leader

    SA_Proxy -->|bound via| CRB_Proxy
    CRB_Proxy -->|grants| CR_Proxy

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Proxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Proxy fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Metrics fill:#f5a623,stroke:#333,stroke-width:2px
    style Perm_Core fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Apps fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Coordination fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Monitoring fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_RBAC fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Route fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_KServe fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_TrustyAI fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_OAuth fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Leader fill:#7ed321,stroke:#333,stroke-width:1px
    style Perm_Metrics fill:#7ed321,stroke:#333,stroke-width:1px
    style User fill:#08427b,stroke:#333,stroke-width:2px,color:#fff
    style UserAuth fill:#e6522c,stroke:#333,stroke-width:2px
