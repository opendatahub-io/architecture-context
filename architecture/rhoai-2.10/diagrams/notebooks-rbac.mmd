graph TD
    subgraph "User Identity"
        User[OpenShift User<br/>Data Scientist]
        OAuthToken[OpenShift OAuth Token<br/>Bearer Token]
    end

    subgraph "Namespace: {user-namespace}"
        direction TB

        subgraph "Pod RBAC"
            SA[ServiceAccount: default<br/>or custom per-user SA]
            SAToken[ServiceAccount Token<br/>Auto-mounted at:<br/>/var/run/secrets/kubernetes.io/serviceaccount]
        end

        subgraph "User RoleBindings (Managed by ODH Controller)"
            RB1[RoleBinding: user-notebooks-admin<br/>Grants: User → Role]
        end

        subgraph "User Permissions in Namespace"
            Role1[Role: notebook-user<br/>Typical Permissions]
        end

        subgraph "Resources"
            Pods[Pods<br/>verbs: create, delete, list, get]
            Services[Services<br/>verbs: create, delete, list, get]
            Routes[Routes<br/>verbs: create, delete, list, get]
            Secrets[Secrets<br/>verbs: get, list<br/>for mounted secrets]
            ConfigMaps[ConfigMaps<br/>verbs: get, list]
        end
    end

    subgraph "Cluster-Level Resources"
        ImageStreams[ImageStreams<br/>verbs: get, list<br/>for notebook selection]
        ClusterAPI[Kubernetes API<br/>Limited access via SA token]
    end

    subgraph "Authentication Flow"
        OAuthProxy[OAuth Proxy Sidecar<br/>Validates OpenShift OAuth token]
        JupyterPod[JupyterLab Pod<br/>Uses ServiceAccount token for API calls]
    end

    %% User to OAuth
    User -->|authenticates| OAuthToken
    OAuthToken -->|validated by| OAuthProxy

    %% User RBAC
    User -.->|granted via| RB1
    RB1 -->|binds| Role1
    Role1 -->|allows| Pods
    Role1 -->|allows| Services
    Role1 -->|allows| Routes
    Role1 -->|allows| Secrets
    Role1 -->|allows| ConfigMaps

    %% ServiceAccount RBAC
    SA -->|generates| SAToken
    SAToken -->|mounted in| JupyterPod
    JupyterPod -->|uses token to call| ClusterAPI

    %% Minimal SA permissions (default)
    SA -.->|can list| ImageStreams
    SA -.->|can get| Secrets
    SA -.->|can get| ConfigMaps

    %% OAuth Proxy protects access
    OAuthProxy -->|if authorized, proxies to| JupyterPod

    %% Styling
    style User fill:#08427b,stroke:#333,stroke-width:2px,color:#fff
    style OAuthToken fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA fill:#f5a623,stroke:#333,stroke-width:3px
    style SAToken fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    style JupyterPod fill:#7ed321,stroke:#333,stroke-width:2px
    style RB1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style Role1 fill:#50e3c2,stroke:#333,stroke-width:2px
    style Pods fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Services fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Routes fill:#e8e8e8,stroke:#333,stroke-width:1px
    style Secrets fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    style ConfigMaps fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ImageStreams fill:#e8e8e8,stroke:#333,stroke-width:1px
    style ClusterAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% Notes
    subgraph Notes[" "]
        direction TB
        Note1["NOTE: This component does not define ClusterRoles or RoleBindings.<br/>RBAC is managed by ODH Notebook Controller at pod creation time."]
        Note2["OAuth Proxy enforces authentication (OpenShift user must be authorized for namespace).<br/>JupyterLab token/password auth is DISABLED."]
        Note3["ServiceAccount has minimal permissions (typically 'default' SA with no special grants).<br/>User permissions determine what operations can be performed in namespace."]
    end

    style Notes fill:#fffacd,stroke:#333,stroke-width:1px
    style Note1 fill:#fffacd,stroke:none,color:#333
    style Note2 fill:#fffacd,stroke:none,color:#333
    style Note3 fill:#fffacd,stroke:none,color:#333
