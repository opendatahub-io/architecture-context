graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route/Ingress<br/>443/TCP → 8265/8000<br/>TLS 1.2+<br/>Optional Auth"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Restricted)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>User: 65532<br/>seccomp: runtime/default<br/>Caps: Not set<br/>allowPrivEsc: false"]

            Webhook["Admission Webhook<br/>443/TCP HTTPS TLS 1.2+"]

            MetricsOp["Metrics Endpoint<br/>8080/TCP HTTP<br/>No Auth"]
            HealthOp["Health Checks<br/>8081/TCP HTTP"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            HeadPod["Ray Head Pod<br/>SA: {cluster}-sa<br/>User: 1000<br/>seccomp: runtime/default<br/>Caps: DROP ALL<br/>allowPrivEsc: false"]

            WorkerPods["Ray Worker Pods<br/>SA: {cluster}-sa<br/>User: 1000<br/>Autoscaled<br/>seccomp: runtime/default<br/>Caps: DROP ALL"]

            HeadSvc["Head Service<br/>{cluster}-head-svc<br/>6379: GCS (optional pwd)<br/>8265: Dashboard (HTTP)<br/>10001: Client (TCP)<br/>8080: Metrics"]

            ServeSvc["Serve Service<br/>{service}-serve-svc<br/>8000/TCP HTTP<br/>Optional TLS"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token (JWT)<br/>RBAC: kuberay-operator"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Pull Credentials"]

        Redis["External Redis<br/>Optional<br/>6379/TCP TCP<br/>Optional TLS<br/>Redis Password"]

        Prometheus["Prometheus<br/>Scrape 8080/TCP<br/>HTTP No Auth"]

        Volcano["Volcano Scheduler<br/>Optional<br/>Gang Scheduling"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Optional Bearer"| Route

    %% Ingress to Services
    Route -->|"HTTP/8265<br/>Optional TLS/Auth<br/>Dashboard"| HeadSvc
    Route -->|"HTTP/8000<br/>Optional TLS/Auth<br/>Serve"| ServeSvc

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|Creates| Webhook
    Operator -->|Exposes| MetricsOp
    Operator -->|Exposes| HealthOp

    %% Operator manages resources
    Operator -.->|Creates/Manages| HeadPod
    Operator -.->|Creates/Manages| WorkerPods
    Operator -.->|Creates| HeadSvc
    Operator -.->|Creates| ServeSvc

    %% Webhook validation
    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+"| Webhook

    %% Ray internal communication
    WorkerPods -->|"TCP/6379<br/>GCS<br/>Optional Password"| HeadPod
    WorkerPods -->|"TCP (various)<br/>Ray internal<br/>No encryption"| HeadPod

    %% Head to service
    HeadPod -.->|Backs| HeadSvc
    HeadPod -.->|Backs| ServeSvc

    %% External dependencies
    HeadPod -.->|"TCP/6379<br/>Optional TLS<br/>GCS Fault Tolerance"| Redis
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Images"| Registry
    HeadPod -->|"HTTPS/443<br/>Pull Images"| Registry
    WorkerPods -->|"HTTPS/443<br/>Pull Images"| Registry

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>Scrape<br/>No Auth"| MetricsOp
    Prometheus -->|"HTTP/8080<br/>Scrape"| HeadPod

    %% Optional integrations
    Operator -.->|"Optional<br/>Gang Scheduling"| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#cce5ff,stroke:#0066cc,stroke-width:2px
    classDef ray fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class Operator,Webhook,MetricsOp,HealthOp operator
    class HeadPod,WorkerPods ray
    class HeadSvc,ServeSvc,K8sAPI service
    class Registry,Redis,Prometheus,Volcano externalservice
