graph TD
    subgraph "Service Accounts"
        SA[kueue-controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "Cluster Role Bindings"
        ManagerCRB[kueue-manager-rolebinding<br/>Type: ClusterRoleBinding]
        UserCRB[kueue-batch-user-rolebinding<br/>Type: ClusterRoleBinding]
    end

    subgraph "Role Bindings (Namespace: opendatahub)"
        LeaderElectionRB[kueue-leader-election-rolebinding<br/>Type: RoleBinding]
        AuthProxyRB[kueue-auth-proxy-rolebinding<br/>Type: RoleBinding]
    end

    subgraph "Cluster Roles"
        ManagerRole[kueue-manager-role<br/>━━━━━━━━━━━━━━━<br/>Full controller permissions]
        UserRole[kueue-batch-user-role<br/>━━━━━━━━━━━━━━━<br/>Basic user access]
        LeaderElectionRole[kueue-leader-election-role<br/>━━━━━━━━━━━━━━━<br/>Leader election]
        AuthProxyRole[kueue-auth-proxy-role<br/>━━━━━━━━━━━━━━━<br/>Metrics proxy]
    end

    subgraph "API Resources - Core (v1)"
        Events[events<br/>Verbs: create, patch, update]
        LimitRanges[limitranges<br/>Verbs: get, list, watch]
        Namespaces[namespaces<br/>Verbs: get, list, watch]
        Pods[pods, pods/finalizers, pods/status<br/>Verbs: delete, get, list, patch, update, watch]
        Secrets[secrets<br/>Verbs: get, list, update, watch]
    end

    subgraph "API Resources - Batch (batch)"
        Jobs[jobs, jobs/finalizers, jobs/status<br/>Verbs: get, list, patch, update, watch]
    end

    subgraph "API Resources - Kueue (kueue.x-k8s.io)"
        ClusterQueue[clusterqueues<br/>Verbs: get, list, watch, create, update, patch, delete]
        LocalQueue[localqueues<br/>Verbs: get, list, watch, create, update, patch, delete]
        Workload[workloads<br/>Verbs: get, list, watch, create, update, patch, delete]
        ResourceFlavor[resourceflavors<br/>Verbs: get, list, watch, create, update, patch, delete]
        AdmissionCheck[admissionchecks<br/>Verbs: get, list, watch, create, update, patch, delete]
        WorkloadPriority[workloadpriorityclasses<br/>Verbs: get, list, watch, create, update, patch, delete]
        ProvisioningConfig[provisioningrequestconfigs<br/>Verbs: get, list, watch, create, update, patch, delete]
        KueueStatus[*/status<br/>Verbs: get, update, patch]
        KueueFinalizers[*/finalizers<br/>Verbs: update]
    end

    subgraph "API Resources - Kubeflow (kubeflow.org)"
        TFJobs[tfjobs<br/>Verbs: get, list, watch, update, patch]
        PyTorchJobs[pytorchjobs<br/>Verbs: get, list, watch, update, patch]
        MPIJobs[mpijobs<br/>Verbs: get, list, watch, update, patch]
        MXJobs[mxjobs<br/>Verbs: get, list, watch, update, patch]
        XGBoostJobs[xgboostjobs<br/>Verbs: get, list, watch, update, patch]
        PaddleJobs[paddlejobs<br/>Verbs: get, list, watch, update, patch]
    end

    subgraph "API Resources - Ray (ray.io)"
        RayJobs[rayjobs<br/>Verbs: get, list, watch, update, patch]
        RayClusters[rayclusters<br/>Verbs: get, list, watch, update, patch]
    end

    subgraph "API Resources - JobSet (jobset.x-k8s.io)"
        JobSets[jobsets<br/>Verbs: get, list, watch, update, patch]
    end

    subgraph "API Resources - Autoscaling (autoscaling.x-k8s.io)"
        ProvisioningRequests[provisioningrequests<br/>Verbs: create, delete, get, list, patch, update, watch]
    end

    subgraph "API Resources - Admission (admissionregistration.k8s.io)"
        MutatingWebhooks[mutatingwebhookconfigurations<br/>Verbs: get, list, update, watch]
        ValidatingWebhooks[validatingwebhookconfigurations<br/>Verbs: get, list, update, watch]
    end

    subgraph "User Access"
        AuthenticatedUsers[system:authenticated<br/>All authenticated users]
    end

    subgraph "Aggregate Roles (for admins)"
        BatchAdminRole[kueue-batch-admin-role<br/>━━━━━━━━━━━━━━━<br/>All Kueue resources<br/>All verbs]
        ClusterQueueViewerRole[kueue-clusterqueue-viewer-role<br/>━━━━━━━━━━━━━━━<br/>ClusterQueues<br/>get, list, watch]
    end

    %% Bindings
    SA -->|bound via| ManagerCRB
    SA -->|bound via| LeaderElectionRB
    SA -->|bound via| AuthProxyRB
    AuthenticatedUsers -->|bound via| UserCRB

    ManagerCRB -->|grants| ManagerRole
    UserCRB -->|grants| UserRole
    LeaderElectionRB -->|grants| LeaderElectionRole
    AuthProxyRB -->|grants| AuthProxyRole

    %% Manager Role Permissions
    ManagerRole -->|create, patch, update| Events
    ManagerRole -->|get, list, watch| LimitRanges
    ManagerRole -->|get, list, watch| Namespaces
    ManagerRole -->|delete, get, list, patch, update, watch| Pods
    ManagerRole -->|get, list, update, watch| Secrets
    ManagerRole -->|get, list, patch, update, watch| Jobs
    ManagerRole -->|full CRUD| ClusterQueue
    ManagerRole -->|full CRUD| LocalQueue
    ManagerRole -->|full CRUD| Workload
    ManagerRole -->|full CRUD| ResourceFlavor
    ManagerRole -->|full CRUD| AdmissionCheck
    ManagerRole -->|full CRUD| WorkloadPriority
    ManagerRole -->|full CRUD| ProvisioningConfig
    ManagerRole -->|update| KueueStatus
    ManagerRole -->|update| KueueFinalizers
    ManagerRole -->|get, list, watch, update, patch| TFJobs
    ManagerRole -->|get, list, watch, update, patch| PyTorchJobs
    ManagerRole -->|get, list, watch, update, patch| MPIJobs
    ManagerRole -->|get, list, watch, update, patch| MXJobs
    ManagerRole -->|get, list, watch, update, patch| XGBoostJobs
    ManagerRole -->|get, list, watch, update, patch| PaddleJobs
    ManagerRole -->|get, list, watch, update, patch| RayJobs
    ManagerRole -->|get, list, watch, update, patch| RayClusters
    ManagerRole -->|get, list, watch, update, patch| JobSets
    ManagerRole -->|full CRUD| ProvisioningRequests
    ManagerRole -->|get, list, update, watch| MutatingWebhooks
    ManagerRole -->|get, list, update, watch| ValidatingWebhooks

    %% User Role Permissions (limited)
    UserRole -->|get, list, watch| LocalQueue
    UserRole -->|get, list, watch| Workload

