graph TD
    subgraph "Service Accounts"
        SA_Operator[kuberay-operator<br/>Namespace: opendatahub]
        SA_Ray["{cluster-name}-sa<br/>Namespace: {user-namespace}<br/>Created by operator"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[kuberay-operator<br/>ClusterRoleBinding]
        RB_Leader[leader-election-role-binding<br/>RoleBinding<br/>Namespace: opendatahub]
    end

    subgraph "Roles"
        CR_Operator[kuberay-operator<br/>ClusterRole]
        R_Leader[leader-election-role<br/>Role<br/>Namespace: opendatahub]
    end

    subgraph "Core API Resources"
        Pods[pods, pods/status<br/>create, delete, deletecollection<br/>get, list, patch, update, watch]
        Services[services, services/status<br/>create, delete, get, list<br/>patch, update, watch]
        SA_Resources[serviceaccounts<br/>create, delete, get, list, watch]
        Endpoints[endpoints<br/>get, list]
        Events[events<br/>create, delete, get, list<br/>patch, update, watch]
    end

    subgraph "Batch API"
        Jobs[jobs<br/>batch<br/>create, delete, get, list<br/>patch, update, watch]
    end

    subgraph "Coordination API"
        Leases[leases<br/>coordination.k8s.io<br/>create, get, list, update]
    end

    subgraph "Networking API"
        Ingresses[ingresses, ingressclasses<br/>networking.k8s.io<br/>create, delete, get, list<br/>patch, update, watch]
        IngressesExt[ingresses<br/>extensions<br/>create, delete, get, list<br/>patch, update, watch]
    end

    subgraph "OpenShift API"
        Routes[routes<br/>route.openshift.io<br/>create, delete, get, list<br/>patch, update, watch]
    end

    subgraph "RBAC API"
        RBACResources[roles, rolebindings<br/>rbac.authorization.k8s.io<br/>create, delete, get, list<br/>update, watch]
    end

    subgraph "Ray CRDs"
        RayClusters[rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers<br/>ray.io<br/>ALL VERBS]
        RayJobs[rayjobs<br/>rayjobs/status<br/>rayjobs/finalizers<br/>ray.io<br/>ALL VERBS]
        RayServices[rayservices<br/>rayservices/status<br/>rayservices/finalizers<br/>ray.io<br/>ALL VERBS]
    end

    %% Bindings
    SA_Operator -->|bound via| CRB_Operator
    SA_Operator -->|bound via| RB_Leader
    CRB_Operator -->|grants| CR_Operator
    RB_Leader -->|grants| R_Leader

    %% Permissions - Core
    CR_Operator -->|permissions| Pods
    CR_Operator -->|permissions| Services
    CR_Operator -->|permissions| SA_Resources
    CR_Operator -->|permissions| Endpoints
    CR_Operator -->|permissions| Events

    %% Permissions - Batch
    CR_Operator -->|permissions| Jobs

    %% Permissions - Coordination
    CR_Operator -->|permissions| Leases

    %% Permissions - Networking
    CR_Operator -->|permissions| Ingresses
    CR_Operator -->|permissions| IngressesExt

    %% Permissions - OpenShift
    CR_Operator -->|permissions| Routes

    %% Permissions - RBAC
    CR_Operator -->|permissions| RBACResources

    %% Permissions - Ray CRDs
    CR_Operator -->|permissions| RayClusters
    CR_Operator -->|permissions| RayJobs
    CR_Operator -->|permissions| RayServices

    %% Ray SA Usage
    SA_Ray -.->|used by| RayPods[Ray Head/Worker Pods<br/>User: 1000<br/>Caps: DROP ALL]

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    style SA_Ray fill:#85bbf0,color:#000,stroke:#333,stroke-width:2px
    style CR_Operator fill:#f5a623,color:#000,stroke:#333,stroke-width:2px
    style R_Leader fill:#f5a623,color:#000,stroke:#333,stroke-width:2px
    style CRB_Operator fill:#d5e8d4,color:#000,stroke:#333
    style RB_Leader fill:#d5e8d4,color:#000,stroke:#333

    style Pods fill:#7ed321,color:#000,stroke:#333
    style Services fill:#7ed321,color:#000,stroke:#333
    style SA_Resources fill:#7ed321,color:#000,stroke:#333
    style Endpoints fill:#7ed321,color:#000,stroke:#333
    style Events fill:#7ed321,color:#000,stroke:#333
    style Jobs fill:#7ed321,color:#000,stroke:#333
    style Leases fill:#7ed321,color:#000,stroke:#333
    style Ingresses fill:#7ed321,color:#000,stroke:#333
    style IngressesExt fill:#7ed321,color:#000,stroke:#333
    style Routes fill:#7ed321,color:#000,stroke:#333
    style RBACResources fill:#7ed321,color:#000,stroke:#333
    style RayClusters fill:#7ed321,color:#000,stroke:#333
    style RayJobs fill:#7ed321,color:#000,stroke:#333
    style RayServices fill:#7ed321,color:#000,stroke:#333
    style RayPods fill:#cce5ff,color:#000,stroke:#333
