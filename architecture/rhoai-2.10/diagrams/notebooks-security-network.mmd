graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist<br/>Web Browser]
    end

    subgraph Ingress["INGRESS (DMZ - Edge Termination)"]
        Route["OpenShift Route<br/>{workbench-name}-{namespace}.apps.{cluster}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge/Reencrypt"]
    end

    subgraph PodNetwork["POD NETWORK (Trusted - Same Pod)"]
        direction TB

        subgraph WorkbenchPod["Pod: {workbench-name}<br/>NS: {user-namespace}<br/>SA: default"]
            direction LR
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth2<br/>Bearer Token Validation"]
            JupyterLab["JupyterLab Container<br/>8888/TCP HTTP<br/>User: 1001 (jovyan)<br/>Token Auth: DISABLED<br/>Base URL: /notebook/{ns}/{user}"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>api.{cluster}:6443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token<br/>/var/run/secrets/kubernetes.io/serviceaccount"]

        S3["S3 Object Storage<br/>s3.amazonaws.com:443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: AWS SigV4<br/>Secret: {user-aws-credentials}"]

        PyPI["PyPI/Conda Repos<br/>pypi.org:443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: None (public)"]

        Git["Git Repositories<br/>github.com/gitlab.com:443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: SSH Key / Token<br/>Secret: {user-git-credentials}"]

        Quay["Quay.io Registry<br/>quay.io/modh:443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Pull Secret<br/>Used by: ImageStream Controller"]
    end

    subgraph Secrets["SECRETS (Kubernetes)"]
        direction TB
        OAuthSecret["notebook-{user}-oauth-config<br/>Type: Opaque<br/>OAuth proxy config"]
        AWSSecret["{user-aws-credentials}<br/>Type: Opaque<br/>AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY"]
        GitSecret["{user-git-credentials}<br/>Type: kubernetes.io/ssh-auth<br/>SSH private key"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie| Route

    %% Ingress to Pod
    Route -->|HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token| OAuthProxy

    %% Within Pod (trusted network)
    OAuthProxy -->|HTTP/8888<br/>No Encryption<br/>No Auth<br/>Trusted Pod Network| JupyterLab

    %% Secret Mounts
    OAuthSecret -.->|Mounted Volume| OAuthProxy
    AWSSecret -.->|Mounted Volume| JupyterLab
    GitSecret -.->|Mounted Volume| JupyterLab

    %% Egress from JupyterLab
    JupyterLab -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>oc CLI commands| K8sAPI
    JupyterLab -->|HTTPS/443<br/>TLS 1.2+<br/>AWS SigV4<br/>boto3/s3fs| S3
    JupyterLab -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>pip install| PyPI
    JupyterLab -->|HTTPS/443<br/>TLS 1.2+<br/>SSH Key/Token<br/>git clone| Git

    %% Image pull (build-time, not runtime)
    Quay -.->|Image pull at deployment<br/>HTTPS/443 TLS 1.2+<br/>Pull Secret| WorkbenchPod

    %% Styling
    classDef external fill:#ffcccc,stroke:#cc0000,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#000
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef secrets fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000

    class User external
    class Route ingress
    class WorkbenchPod,OAuthProxy,JupyterLab podnetwork
    class K8sAPI,S3,PyPI,Git,Quay externalservice
    class OAuthSecret,AWSSecret,GitSecret secrets

    %% Legend
    subgraph Legend["LEGEND"]
        direction LR
        L1[External/Untrusted]
        L2[Ingress/DMZ]
        L3[Pod Network/Trusted]
        L4[External Services]
        L5[Secrets]

        class L1 external
        class L2 ingress
        class L3 podnetwork
        class L4 externalservice
        class L5 secrets
    end
