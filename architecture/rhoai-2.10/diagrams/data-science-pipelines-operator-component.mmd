graph TB
    subgraph "Data Science Pipelines Operator"
        Controller[DSPO Controller Manager<br/>Go Operator]
    end

    subgraph "Deployed Pipeline Stack (per namespace)"
        subgraph "Core Services"
            APIServer[DS Pipelines API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP HTTPS OAuth]
            PersistenceAgent[Persistence Agent<br/>Workflow State Sync]
            ScheduledWorkflow[Scheduled Workflow Controller<br/>Cron-based Execution]
        end

        subgraph "Execution Engine (v2)"
            ArgoController[Workflow Controller<br/>Argo Workflows]
        end

        subgraph "Optional Components"
            MLMD[ML Metadata<br/>gRPC 8080/TCP]
            MLMDEnvoy[MLMD Envoy Proxy<br/>gRPC 9090/TCP]
            UI[ML Pipelines UI<br/>8443/TCP HTTPS]
        end

        subgraph "Optional Storage"
            MariaDB[(MariaDB<br/>3306/TCP)]
            Minio[(Minio S3<br/>9000/TCP)]
        end
    end

    subgraph "Custom Resources"
        DSPA[DataSciencePipelinesApplication CR<br/>v1alpha1]
        WorkflowCR[Argo Workflow CR<br/>v1alpha1]
    end

    subgraph "External Dependencies"
        ArgoWorkflows[Argo Workflows<br/>3.x]
        OAuthProxy[OAuth Proxy<br/>v4.12.0+]
        ExternalDB[(External DB<br/>MySQL/MariaDB)]
        ExternalS3[(External S3<br/>AWS/Compatible)]
    end

    subgraph "ODH Integration"
        Dashboard[ODH Dashboard]
        ODHOperator[opendatahub-operator]
    end

    %% User interactions
    User[User] -->|creates| DSPA
    User -->|submits pipelines| APIServer
    User -->|views UI| UI

    %% Operator reconciliation
    DSPA -->|watched by| Controller
    Controller -->|deploys| APIServer
    Controller -->|deploys| PersistenceAgent
    Controller -->|deploys| ScheduledWorkflow
    Controller -->|deploys optional| MLMD
    Controller -->|deploys optional| MLMDEnvoy
    Controller -->|deploys optional| UI
    Controller -->|deploys optional| MariaDB
    Controller -->|deploys optional| Minio
    Controller -->|manages| OAuthProxy

    %% API Server interactions
    APIServer -->|stores metadata| MariaDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|submits workflows| ArgoController
    APIServer -->|queries lineage| MLMDEnvoy
    APIServer -->|uses external DB| ExternalDB
    APIServer -->|uses external S3| ExternalS3

    %% Workflow execution
    ScheduledWorkflow -->|triggers| APIServer
    ArgoController -->|creates| WorkflowCR
    WorkflowCR -->|executes as| WorkflowPod[Workflow Pods]
    WorkflowPod -->|reads/writes| Minio
    WorkflowPod -->|tracks metadata| MLMD
    WorkflowPod -->|uses external S3| ExternalS3

    %% Persistence and metadata
    PersistenceAgent -->|syncs workflow state| MariaDB
    MLMD -->|stores metadata| MariaDB
    MLMDEnvoy -->|proxies to| MLMD
    UI -->|calls| APIServer
    UI -->|displays artifacts| Minio
    UI -->|shows lineage| MLMDEnvoy

    %% ODH integration
    ODHOperator -->|deploys| Controller
    Dashboard -->|lists DSPAs| Controller
    Dashboard -->|provides links| UI

    %% Dependencies
    ArgoController -.->|requires| ArgoWorkflows

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style DSPA fill:#f5a623,stroke:#333,stroke-width:2px
    style WorkflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style ArgoController fill:#4a90e2,stroke:#333,stroke-width:2px
    style ArgoWorkflows fill:#999,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#999,stroke:#333,stroke-width:2px
    style ExternalDB fill:#999,stroke:#333,stroke-width:2px
    style ExternalS3 fill:#999,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style MariaDB fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Minio fill:#e8e8e8,stroke:#333,stroke-width:2px
