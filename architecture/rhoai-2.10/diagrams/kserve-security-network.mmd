graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>NS: istio-system<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ Termination<br/>Istio AuthorizationPolicy"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>SA: activator<br/>8012/TCP HTTP mTLS<br/>Scale-to-zero mgmt"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph PredictorPod["Predictor Pod<br/>SA: {isvc-name}-sa<br/>Knative Service: {isvc-name}-predictor"]
                direction TB
                StorageInit["Init Container<br/>storage-initializer<br/>CPU: 100m-1<br/>Mem: 100Mi-1Gi"]
                ModelServer["Main Container<br/>Model Server<br/>8080/TCP HTTP<br/>V1/V2 Protocol"]
                Agent["Sidecar: kserve-agent<br/>8080/TCP localhost<br/>Logging/Batching"]
                IstioProxy["Sidecar: istio-proxy<br/>Inbound: 15006/TCP<br/>Outbound: 15001/TCP<br/>Pilot: 15012/TCP gRPC mTLS"]

                StorageInit -.->|mount volume| ModelServer
                Agent <-->|HTTP localhost<br/>no encryption| ModelServer
                IstioProxy -->|intercepts| ModelServer
            end
        end

        subgraph NS_KServe["Namespace: kserve"]
            Controller["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>CPU: 100m, Mem: 200Mi-300Mi<br/>Metrics: 8080/TCP /metrics<br/>Health: 8081/TCP"]
            Webhook["kserve-webhook-server<br/>9443/TCP HTTPS TLS1.2+<br/>mTLS (K8s API)<br/>Cert: kserve-webhook-server-cert"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM/Access Key<br/>Creds: storage-config secret"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>Auth: GCP Service Account JSON<br/>Creds: storage-config secret"]
        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>6443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
        KnativeAPI["Knative API<br/>6443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
        IstioAPI["Istio API<br/>6443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/8012<br/>mTLS STRICT<br/>Service Identity"| Activator

    %% Activator to Predictor
    Activator -->|"HTTP/8080<br/>mTLS (Istio)<br/>Service Identity"| PredictorPod

    %% Storage Initializer to External Services
    StorageInit -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM/Access Key"| S3
    StorageInit -.->|"HTTPS/443<br/>TLS 1.2+<br/>GCP Service Account"| GCS

    %% Controller to APIs
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| KnativeAPI
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| IstioAPI

    %% Webhook interactions
    K8sAPI <-->|"HTTPS/9443<br/>TLS 1.2+ mTLS<br/>CA Bundle validation"| Webhook

    %% Istio mesh communication
    IstioProxy -.->|"gRPC/15012<br/>mTLS<br/>Config & Certs"| IstioAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#000
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef pod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000
    classDef container fill:#f5f5f5,stroke:#666,stroke-width:1px,color:#000

    class Client external
    class Gateway ingress
    class Activator,NS_Knative,NS_User,NS_KServe servicemesh
    class PredictorPod pod
    class StorageInit,ModelServer,Agent,IstioProxy container
    class Controller,Webhook controlplane
    class S3,GCS,K8sAPI,KnativeAPI,IstioAPI externalservice

    %% Trust boundaries (visual grouping)
    style External fill:#ffebee,stroke:#c62828,stroke-width:4px
    style Ingress fill:#fff3e0,stroke:#e65100,stroke-width:4px
    style ServiceMesh fill:#e8f5e9,stroke:#2e7d32,stroke-width:4px
    style ExternalServices fill:#fffde7,stroke:#f57f17,stroke-width:4px
