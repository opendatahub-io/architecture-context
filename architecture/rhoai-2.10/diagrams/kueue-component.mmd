graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[kueue-webhook-server<br/>Webhook Server]
        Visibility[kueue-visibility-server<br/>APIServer Extension<br/>Optional]
        QueueMgr[Queue Manager<br/>FIFO/Priority Strategies]
        Scheduler[Scheduler<br/>Admission Decisions]
        JobFramework[Job Framework<br/>Pluggable Integration]

        Controller -->|includes| QueueMgr
        Controller -->|includes| Scheduler
        Controller -->|includes| JobFramework
    end

    subgraph "Custom Resources"
        ClusterQueue[ClusterQueue<br/>Cluster-wide quotas]
        LocalQueue[LocalQueue<br/>Namespace queues]
        Workload[Workload<br/>Job representation]
        ResourceFlavor[ResourceFlavor<br/>Resource types]
        AdmissionCheck[AdmissionCheck<br/>Admission policies]
        WorkloadPriority[WorkloadPriorityClass<br/>Priority values]
        ProvisioningConfig[ProvisioningRequestConfig<br/>Autoscaler config]
    end

    subgraph "Job Types Supported"
        BatchJob[Kubernetes Job<br/>batch/v1]
        KubeflowJob[Kubeflow Jobs<br/>TF, PyTorch, MPI]
        RayJob[Ray Job/Cluster<br/>ray.io/v1]
        JobSet[JobSet<br/>jobset.x-k8s.io]
    end

    User[User/Application] -->|creates| BatchJob
    User -->|creates| KubeflowJob
    User -->|creates| RayJob
    User -->|creates| JobSet

    BatchJob -->|intercepted by| Webhook
    KubeflowJob -->|intercepted by| Webhook
    RayJob -->|intercepted by| Webhook
    JobSet -->|intercepted by| Webhook

    Webhook -->|creates| Workload
    Webhook -->|injects queue| BatchJob

    Controller -->|watches| ClusterQueue
    Controller -->|watches| LocalQueue
    Controller -->|watches| Workload
    Controller -->|watches| ResourceFlavor
    Controller -->|watches| AdmissionCheck

    QueueMgr -->|queues| Workload
    Scheduler -->|admits| Workload
    Scheduler -->|evaluates| ClusterQueue

    Controller -->|unsuspends| BatchJob
    Controller -->|creates pods for| BatchJob

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus<br/>Metrics]
        ClusterAutoscaler[Cluster Autoscaler<br/>Optional]
    end

    Controller -->|API calls| K8sAPI
    Webhook -->|validates via| K8sAPI
    Webhook -->|cert from| CertManager
    Controller -->|creates| ProvisioningConfig
    ProvisioningConfig -->|provisions via| ClusterAutoscaler
    Controller -->|exposes metrics to| Prometheus

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style QueueMgr fill:#5da5da,stroke:#333
    style Scheduler fill:#5da5da,stroke:#333
    style Workload fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterQueue fill:#f5a623,stroke:#333
    style LocalQueue fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333
    style BatchJob fill:#7ed321,stroke:#333
    style KubeflowJob fill:#7ed321,stroke:#333
    style RayJob fill:#7ed321,stroke:#333
