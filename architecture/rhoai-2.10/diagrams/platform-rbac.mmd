graph TD
    subgraph "Service Accounts"
        SA_RHODS[rhods-operator]
        SA_Dashboard[odh-dashboard]
        SA_Notebook[notebook-controller-manager]
        SA_KServe[kserve-controller-manager]
        SA_Model[odh-model-controller]
        SA_Training[training-operator]
        SA_Kueue[kueue-controller-manager]
        SA_KubeRay[kuberay-operator]
        SA_CodeFlare[codeflare-operator]
        SA_TrustyAI[trustyai-operator]
    end

    subgraph "ClusterRole Bindings"
        CRB_RHODS[rhods-operator-binding]
        CRB_Dashboard[odh-dashboard-manager-binding]
        CRB_Notebook[notebook-controller-manager-binding]
        CRB_KServe[kserve-manager-rolebinding]
        CRB_Model[odh-model-controller-binding]
        CRB_Training[training-operator-manager-binding]
        CRB_Kueue[kueue-manager-rolebinding]
        CRB_KubeRay[kuberay-operator-binding]
        CRB_CodeFlare[codeflare-operator-binding]
        CRB_TrustyAI[trustyai-operator-binding]
    end

    subgraph "ClusterRoles"
        CR_RHODS[rhods-operator-role<br/>Platform Orchestration]
        CR_Dashboard[odh-dashboard-manager<br/>Resource Management]
        CR_Notebook[notebook-controller-manager<br/>Notebook Lifecycle]
        CR_KServe[kserve-manager-role<br/>Serving Management]
        CR_Model[odh-model-controller<br/>Serving Integration]
        CR_Training[training-operator-manager<br/>Training Jobs]
        CR_Kueue[kueue-manager-role<br/>Workload Admission]
        CR_KubeRay[kuberay-operator<br/>Ray Clusters]
        CR_CodeFlare[codeflare-operator<br/>Distributed Workloads]
        CR_TrustyAI[trustyai-operator<br/>Model Monitoring]
    end

    subgraph "API Resources"
        direction TB

        subgraph "Platform CRDs"
            DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
            DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
            FT[features.opendatahub.io<br/>FeatureTracker]
        end

        subgraph "Workbench CRDs"
            Notebook[kubeflow.org<br/>Notebook]
        end

        subgraph "Serving CRDs"
            ISVC[serving.kserve.io<br/>InferenceService]
            SR[serving.kserve.io<br/>ServingRuntime]
            TM[serving.kserve.io<br/>TrainedModel]
            IG[serving.kserve.io<br/>InferenceGraph]
            Predictor[serving.kserve.io<br/>Predictor]
        end

        subgraph "Pipeline CRDs"
            DSPA[datasciencepipelinesapplications<br/>DataSciencePipelinesApplication]
        end

        subgraph "Training CRDs"
            PyTorchJob[kubeflow.org<br/>PyTorchJob]
            TFJob[kubeflow.org<br/>TFJob]
            MPIJob[kubeflow.org<br/>MPIJob]
            XGBoostJob[kubeflow.org<br/>XGBoostJob]
            MXJob[kubeflow.org<br/>MXJob]
            PaddleJob[kubeflow.org<br/>PaddleJob]
        end

        subgraph "Ray CRDs"
            RayCluster[ray.io<br/>RayCluster]
            RayJob[ray.io<br/>RayJob]
            RayService[ray.io<br/>RayService]
        end

        subgraph "CodeFlare CRDs"
            AppWrapper[workload.codeflare.dev<br/>AppWrapper]
        end

        subgraph "Kueue CRDs"
            ClusterQueue[kueue.x-k8s.io<br/>ClusterQueue]
            LocalQueue[kueue.x-k8s.io<br/>LocalQueue]
            Workload[kueue.x-k8s.io<br/>Workload]
            ResourceFlavor[kueue.x-k8s.io<br/>ResourceFlavor]
        end

        subgraph "TrustyAI CRDs"
            TrustyAIService[trustyai.opendatahub.io<br/>TrustyAIService]
        end

        subgraph "Core K8s Resources"
            NS[Namespace]
            Deploy[Deployment]
            STS[StatefulSet]
            SVC[Service]
            Routes[Route]
        end

        subgraph "Istio Resources"
            VS[VirtualService]
            PA[PeerAuthentication]
            AP[AuthorizationPolicy]
        end

        subgraph "Monitoring Resources"
            SM[ServiceMonitor]
            PM[PodMonitor]
        end
    end

    %% Service Account to ClusterRoleBinding
    SA_RHODS -->|bound via| CRB_RHODS
    SA_Dashboard -->|bound via| CRB_Dashboard
