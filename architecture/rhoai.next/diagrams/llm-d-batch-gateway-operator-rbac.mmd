        RefGrants["gateway.networking.k8s.io<br/>ReferenceGrants<br/>get,list,watch"]
        SvcMonitors["monitoring.coreos.com<br/>ServiceMonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
        PodMonitors["monitoring.coreos.com<br/>PodMonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
        PromRules["monitoring.coreos.com<br/>PrometheusRules<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        Leases["coordination.k8s.io<br/>Leases<br/>get,list,watch,create,<br/>update,patch,delete"]
        LeaderEvents["core<br/>Events<br/>create,patch"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB
    CRB -->|grants| CR
    RB -->|grants| LeaderRole

    %% ClusterRole permissions
    CR -->|manages| ConfigMaps
    CR -->|manages| ServiceAccts
    CR -->|manages| Services
    CR -->|manages| Events
    CR -->|manages| Secrets
    CR -->|manages| Deployments
