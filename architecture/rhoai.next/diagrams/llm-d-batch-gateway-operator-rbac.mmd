        Events["core<br/>Events<br/>create,patch"]
        Secrets["core<br/>Secrets<br/>create,get,list,<br/>patch,watch"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>Deployments<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph BatchResources["batch.llm-d.ai Resources"]
        LLMBatchGW["batch.llm-d.ai<br/>LLMBatchGateways<br/>get,list,patch,<br/>update,watch"]
        LLMBatchGWStatus["batch.llm-d.ai<br/>LLMBatchGateways/status<br/>get,patch,update"]
        LLMBatchGWFinalizers["batch.llm-d.ai<br/>LLMBatchGateways/finalizers<br/>update"]
    end

    subgraph OptionalResources["Optional API Resources"]
        Certificates["cert-manager.io<br/>Certificates<br/>create,delete,get,list,<br/>patch,update,watch"]
