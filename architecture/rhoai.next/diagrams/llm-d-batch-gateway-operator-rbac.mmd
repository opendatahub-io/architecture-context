        ViewCR["llmbatchgateway-view<br/>(Aggregate ClusterRole)"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        LeaderRole["leader-election-role<br/>(Role)"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>ConfigMaps<br/>create,delete,get,list,<br/>patch,update,watch"]
