graph TB
    subgraph Operator["RHODS Operator (manager)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
            SetupCtrl["Setup Controller"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway Controller"]
            AuthCtrl["Auth Controller"]
            MonitoringCtrl["Monitoring Controller"]
            CertCMCtrl["CertConfigMapGenerator<br/>Controller"]
        end

        subgraph ComponentControllers["Component Controllers (16)"]
            Dashboard["Dashboard"]
            KServe["KServe"]
            Kueue["Kueue"]
            Ray["Ray"]
            TrustyAI["TrustyAI"]
            ModelRegistry["ModelRegistry"]
            TrainingOp["TrainingOperator"]
            Trainer["Trainer"]
            DSP["DataSciencePipelines"]
            Feast["FeastOperator"]
            LlamaStack["LlamaStackOperator"]
            MLflow["MLflowOperator"]
            Spark["SparkOperator"]
            MaaS["ModelsAsService"]
            ModelCtrl["ModelController"]
            Workbenches["Workbenches"]
        end

        Webhooks["Admission Webhooks<br/>(DSC, DSCI, HardwareProfile,<br/>Kueue, Notebooks, InferenceService)"]
    end

    subgraph CloudMgr["Cloud Manager (cloudmanager)"]
        AzureCtrl["AzureKubernetesEngine<br/>Controller"]
        CoreWeaveCtrl["CoreWeaveKubernetesEngine<br/>Controller"]
    end

    %% CRDs
    DSCI_CR["DSCInitialization CR"]
    DSC_CR["DataScienceCluster CR"]
    CompCRs["Component CRs<br/>(Dashboard, KServe,<br/>Kueue, etc.)"]
    SvcCRs["Service CRs<br/>(Auth, Monitoring,<br/>GatewayConfig)"]
    HWProfile["HardwareProfile CR"]

    %% Flows
    Admin["Admin / OLM"] -->|creates| DSCI_CR
    Admin -->|creates| DSC_CR
    DSCI_CR -->|watched by| DSCICtrl
    DSC_CR -->|watched by| DSCCtrl
    DSCICtrl -->|creates| SvcCRs
    DSCCtrl -->|creates| CompCRs
    SvcCRs -->|watched by| GatewayCtrl
    SvcCRs -->|watched by| AuthCtrl
    SvcCRs -->|watched by| MonitoringCtrl
    CompCRs -->|watched by| ComponentControllers

    %% Gateway outputs
    GatewayCtrl -->|creates| GW["Gateway API<br/>(GatewayClass, Gateway,<br/>HTTPRoute)"]
    GatewayCtrl -->|creates| Envoy["Envoy Proxy +<br/>EnvoyFilter"]
    GatewayCtrl -->|creates| AuthProxy["kube-auth-proxy<br/>Deployment"]
    GatewayCtrl -->|creates| NP["NetworkPolicies"]
    GatewayCtrl -->|creates| DR["DestinationRules<br/>(mTLS)"]

    %% Auth outputs
    AuthCtrl -->|creates| RBAC["Roles &<br/>ClusterRoles"]

    %% Monitoring outputs
    MonitoringCtrl -->|creates| Prom["MonitoringStack<br/>(Prometheus)"]
    MonitoringCtrl -->|creates| Thanos["ThanosQuerier"]
    MonitoringCtrl -->|creates| OTel["OpenTelemetry<br/>Collector"]
    MonitoringCtrl -->|creates| Tempo["Tempo"]
    MonitoringCtrl -->|creates| Perses["Perses"]

    %% Component controller outputs
    ComponentControllers -->|deploys manifests via| K8sAPI["Kubernetes API"]

    %% Webhook flow
    K8sAPI -->|admission review| Webhooks

    %% Styling
    style Operator fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style CloudMgr fill:#fce4ec,stroke:#c62828,stroke-width:2px
    style CoreControllers fill:#e8eaf6,stroke:#283593,stroke-width:2px
    style ServiceControllers fill:#e0f2f1,stroke:#00695c,stroke-width:2px
    style ComponentControllers fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style DSCI_CR fill:#f5a623,stroke:#333
    style DSC_CR fill:#f5a623,stroke:#333
    style CompCRs fill:#f5a623,stroke:#333
    style SvcCRs fill:#f5a623,stroke:#333
    style HWProfile fill:#f5a623,stroke:#333
    style GW fill:#7ed321,stroke:#333
    style Envoy fill:#7ed321,stroke:#333
    style AuthProxy fill:#7ed321,stroke:#333
    style Prom fill:#7ed321,stroke:#333
    style Thanos fill:#7ed321,stroke:#333
    style OTel fill:#7ed321,stroke:#333
    style Tempo fill:#7ed321,stroke:#333
    style Perses fill:#7ed321,stroke:#333
    style RBAC fill:#7ed321,stroke:#333
    style NP fill:#7ed321,stroke:#333
    style DR fill:#7ed321,stroke:#333
    style Admin fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
