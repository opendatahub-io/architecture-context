graph TB
    subgraph Operator["rhods-operator (manager)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway<br/>Controller"]
            AuthCtrl["Auth<br/>Controller"]
            MonitoringCtrl["Monitoring<br/>Controller"]
            CertCtrl["CertConfigMap<br/>Generator"]
            SetupCtrl["Setup<br/>Controller"]
        end

        subgraph Registries["Plugin Registries"]
            CompRegistry["Component Registry<br/>(16 components)"]
            SvcRegistry["Service Registry<br/>(5 services)"]
        end
    end

    subgraph CloudMgr["cloudmanager"]
        AzureCtrl["Azure AKS<br/>Controller"]
        CoreWeaveCtrl["CoreWeave<br/>Controller"]
    end

    %% CRDs
    DSCI_CR["DSCInitialization CR"]
    DSC_CR["DataScienceCluster CR"]

    %% Component CRDs
    subgraph ComponentCRDs["Component CRDs"]
        Dashboard_CR["Dashboard"]
        Kserve_CR["Kserve"]
        Kueue_CR["Kueue"]
        Workbenches_CR["Workbenches"]
        ModelReg_CR["ModelRegistry"]
        DSP_CR["DataScience<br/>Pipelines"]
        TrustyAI_CR["TrustyAI"]
        Ray_CR["Ray"]
        TrainingOp_CR["Training<br/>Operator"]
        Trainer_CR["Trainer"]
        Feast_CR["FeastOperator"]
        LlamaStack_CR["LlamaStack<br/>Operator"]
        MLflow_CR["MLflow<br/>Operator"]
        ModelCtrl_CR["Model<br/>Controller"]
        MaaS_CR["ModelsAs<br/>Service"]
        Spark_CR["Spark<br/>Operator"]
    end

    %% Service CRDs
    Auth_CR["Auth CR"]
    Gateway_CR["GatewayConfig CR"]
    Monitoring_CR["Monitoring CR"]

    %% Flows
    DSCI_CR -->|watched by| DSCICtrl
    DSC_CR -->|watched by| DSCCtrl

    DSCICtrl -->|creates| Auth_CR
    DSCICtrl -->|creates| Gateway_CR
    DSCICtrl -->|creates| Monitoring_CR

    DSCCtrl -->|iterates via| CompRegistry
    CompRegistry -->|creates| ComponentCRDs

    Auth_CR -->|watched by| AuthCtrl
    Gateway_CR -->|watched by| GatewayCtrl
    Monitoring_CR -->|watched by| MonitoringCtrl

    %% Gateway outputs
    GatewayCtrl -->|creates| GW["Gateway API<br/>(Envoy)"]
    GatewayCtrl -->|creates| AuthProxy["kube-auth-proxy<br/>(OAuth2/OIDC)"]
    GatewayCtrl -->|creates| EF["EnvoyFilter<br/>(ext_authz)"]
    GatewayCtrl -->|creates| Routes["OpenShift<br/>Routes"]

    %% Monitoring outputs
    MonitoringCtrl -->|creates| MonStack["MonitoringStack<br/>(Prometheus)"]
    MonitoringCtrl -->|creates| Thanos["ThanosQuerier"]
    MonitoringCtrl -->|creates| Tempo["Tempo"]
    MonitoringCtrl -->|creates| OTEL["OTEL Collector"]
    MonitoringCtrl -->|creates| Perses["Perses"]

    %% Cloud Manager
    AzureCtrl -->|manages| AzureCR["AzureKubernetes<br/>Engine CR"]
    CoreWeaveCtrl -->|manages| CoreWeaveCR["CoreWeaveKubernetes<br/>Engine CR"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CoreControllers fill:#3a7bd5,stroke:#333,color:#fff
    style ServiceControllers fill:#3a7bd5,stroke:#333,color:#fff
    style Registries fill:#3a7bd5,stroke:#333,color:#fff
    style CloudMgr fill:#6c5ce7,stroke:#333,color:#fff
    style ComponentCRDs fill:#f5a623,stroke:#333
    style DSCI_CR fill:#f5a623,stroke:#333
    style DSC_CR fill:#f5a623,stroke:#333
    style Auth_CR fill:#f5a623,stroke:#333
    style Gateway_CR fill:#f5a623,stroke:#333
    style Monitoring_CR fill:#f5a623,stroke:#333
    style GW fill:#7ed321,stroke:#333
    style AuthProxy fill:#7ed321,stroke:#333
    style EF fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style MonStack fill:#7ed321,stroke:#333
    style Thanos fill:#7ed321,stroke:#333
    style Tempo fill:#7ed321,stroke:#333
    style OTEL fill:#7ed321,stroke:#333
    style Perses fill:#7ed321,stroke:#333
