graph TB
    subgraph Operator["RHODS Operator (manager)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
            SetupCtrl["Setup Controller<br/>(Uninstall/Cleanup)"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway Controller<br/>(Ingress Stack)"]
            AuthCtrl["Auth Controller<br/>(Platform RBAC)"]
            MonitoringCtrl["Monitoring Controller<br/>(Observability Stack)"]
            CertCMCtrl["CertConfigMapGenerator<br/>(CA Bundle Distribution)"]
        end

        subgraph ComponentControllers["Component Controllers (16)"]
            DashboardCtrl["Dashboard"]
            KServeCtrl["KServe"]
            KueueCtrl["Kueue"]
            RayCtrl["Ray"]
            TrustyAICtrl["TrustyAI"]
            ModelRegCtrl["ModelRegistry"]
            TrainingOpCtrl["TrainingOperator"]
            TrainerCtrl["Trainer"]
            DSPCtrl["DataSciencePipelines"]
            FeastCtrl["FeastOperator"]
            LlamaCtrl["LlamaStackOperator"]
            MLflowCtrl["MLflowOperator"]
            SparkCtrl["SparkOperator"]
            MaaSCtrl["ModelsAsService"]
            ModelCtrlCtrl["ModelController"]
            WorkbenchCtrl["Workbenches"]
        end

        Webhooks["Admission Webhooks<br/>(7 mutating, 6 validating,<br/>1 conversion)"]
    end

    subgraph CloudManager["Cloud Manager (cloudmanager)"]
        AzureCtrl["AzureKubernetesEngine<br/>Controller"]
        CoreWeaveCtrl["CoreWeaveKubernetesEngine<br/>Controller"]
    end

    %% CRDs
    DSCICR["DSCInitialization CR<br/>(v1/v2, Cluster)"]
    DSCCR["DataScienceCluster CR<br/>(v1/v2, Cluster)"]
    ComponentCRs["Component CRs<br/>(16 types, v1alpha1)"]
    ServiceCRs["Service CRs<br/>(Auth, Monitoring,<br/>GatewayConfig)"]
    HWProfile["HardwareProfile CR<br/>(v1, Namespaced)"]

    %% Gateway infrastructure
    subgraph GatewayInfra["Gateway Infrastructure"]
        GatewayAPI["Gateway API<br/>(GatewayClass, Gateway,<br/>HTTPRoute)"]
        EnvoyProxy["Envoy Proxy<br/>(Data Plane)"]
        KubeAuthProxy["kube-auth-proxy<br/>(OAuth2/OIDC)"]
        EnvoyFilter["EnvoyFilter<br/>(ext_authz)"]
    end

    %% Monitoring infrastructure
    subgraph MonitoringInfra["Monitoring Infrastructure"]
        MonStack["MonitoringStack<br/>(Prometheus)"]
        Thanos["ThanosQuerier"]
        OTelCollector["OpenTelemetry<br/>Collector"]
        Tempo["Tempo<br/>(Traces)"]
        Perses["Perses<br/>(Visualization)"]
    end

    %% Flows
    Admin["Platform Admin"] -->|creates| DSCICR
    Admin -->|creates| DSCCR
    DSCICR -->|watched by| DSCICtrl
    DSCCR -->|watched by| DSCCtrl
    DSCICtrl -->|creates| ServiceCRs
    DSCCtrl -->|creates| ComponentCRs
    ServiceCRs -->|watched by| GatewayCtrl
    ServiceCRs -->|watched by| AuthCtrl
    ServiceCRs -->|watched by| MonitoringCtrl
    ComponentCRs -->|watched by| ComponentControllers
    GatewayCtrl -->|deploys| GatewayInfra
    MonitoringCtrl -->|deploys| MonitoringInfra
    CertCMCtrl -->|distributes CA bundles| UserNS["User Namespaces"]

    %% External dependencies
    GatewayCtrl -->|creates CRs| Istio["Istio/Sail Operator"]
    GatewayCtrl -->|creates Routes| Router["OpenShift Router"]
    GatewayCtrl -->|creates OAuthClient| OAuth["OpenShift OAuth Server"]
    MonitoringCtrl -->|creates CRs| COO["Cluster Observability<br/>Operator"]
    MonitoringCtrl -->|creates CRs| OTelOp["OpenTelemetry Operator"]
    MonitoringCtrl -->|creates CRs| TempoOp["Tempo Operator"]
    MonitoringCtrl -->|creates CRs| PersesOp["Perses Operator"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style CloudManager fill:#4a90e2,stroke:#333,color:#fff
    style CoreControllers fill:#5ba0f2,stroke:#333,color:#fff
    style ServiceControllers fill:#5ba0f2,stroke:#333,color:#fff
    style ComponentControllers fill:#5ba0f2,stroke:#333,color:#fff
    style GatewayInfra fill:#d5e8d4,stroke:#82b366
    style MonitoringInfra fill:#d5e8d4,stroke:#82b366
    style DSCICR fill:#f5a623,stroke:#333
    style DSCCR fill:#f5a623,stroke:#333
    style ComponentCRs fill:#f5a623,stroke:#333
    style ServiceCRs fill:#f5a623,stroke:#333
    style HWProfile fill:#f5a623,stroke:#333
    style Admin fill:#e8e8e8,stroke:#333
    style Istio fill:#999,stroke:#333
    style Router fill:#999,stroke:#333
    style OAuth fill:#999,stroke:#333
    style COO fill:#999,stroke:#333
    style OTelOp fill:#999,stroke:#333
    style TempoOp fill:#999,stroke:#333
    style PersesOp fill:#999,stroke:#333
