graph TB
    subgraph Operator["RHODS Operator (manager)"]
        direction TB
        DSCICtrl["DSCInitialization<br/>Controller"]
        DSCCtrl["DataScienceCluster<br/>Controller"]
        GWCtrl["Gateway<br/>Controller"]
        AuthCtrl["Auth<br/>Controller"]
        MonCtrl["Monitoring<br/>Controller"]
        CertCtrl["CertConfigMapGenerator<br/>Controller"]
        SetupCtrl["Setup<br/>Controller"]
        Webhooks["Admission Webhooks<br/>(Validation + Mutation)"]
    end

    subgraph Components["Component Controllers (16)"]
        direction LR
        Dashboard["Dashboard"]
        KServe["KServe"]
        Kueue["Kueue"]
        Ray["Ray"]
        TrustyAI["TrustyAI"]
        ModelReg["ModelRegistry"]
        TrainingOp["TrainingOperator"]
        Trainer["Trainer"]
        DSP["DataSciencePipelines"]
        Feast["FeastOperator"]
        LlamaStack["LlamaStackOperator"]
        MLflow["MLflowOperator"]
        Spark["SparkOperator"]
        MaaS["ModelsAsService"]
        ModelCtrl["ModelController"]
        Workbenches["Workbenches"]
    end

    subgraph CloudMgr["Cloud Manager (cloudmanager)"]
        AzureCtrl["AzureKubernetesEngine<br/>Controller"]
        CWCtrl["CoreWeaveKubernetesEngine<br/>Controller"]
    end

    subgraph GatewayStack["Gateway Infrastructure"]
        GWClass["GatewayClass"]
        GW["Gateway<br/>(Envoy Proxy)"]
        HTTPRoutes["HTTPRoutes<br/>(per-component)"]
        EF["EnvoyFilter<br/>(ext_authz)"]
        KAP["kube-auth-proxy<br/>8443/TCP"]
        DR["DestinationRules<br/>(mTLS)"]
        NP["NetworkPolicies"]
        Redirects["nginx Redirects<br/>(legacy URLs)"]
    end

    subgraph MonStack["Monitoring Stack"]
        Prom["MonitoringStack<br/>(Prometheus)"]
        Thanos["ThanosQuerier"]
        OTel["OpenTelemetryCollector"]
        Tempo["Tempo<br/>(Traces)"]
        Perses["Perses<br/>(Visualization)"]
        KRP["kube-rbac-proxy<br/>(namespace/cluster)"]
    end

    %% CRDs
    DSCI_CR["DSCInitialization CR"]
    DSC_CR["DataScienceCluster CR"]
    CompCRs["Component CRs<br/>(Dashboard, KServe, etc.)"]

    %% Admin creates CRs
    Admin["Platform Admin"] -->|creates| DSCI_CR
    Admin -->|creates| DSC_CR

    %% CR flows
    DSCI_CR -->|watched by| DSCICtrl
    DSC_CR -->|watched by| DSCCtrl
    DSCICtrl -->|creates| GWCtrl
    DSCICtrl -->|creates| AuthCtrl
    DSCICtrl -->|creates| MonCtrl

    DSCCtrl -->|creates| CompCRs
    CompCRs -->|watched by| Components

    %% Gateway controller creates infrastructure
    GWCtrl -->|deploys| GWClass
    GWCtrl -->|deploys| GW
    GWCtrl -->|deploys| HTTPRoutes
    GWCtrl -->|deploys| EF
    GWCtrl -->|deploys| KAP
    GWCtrl -->|deploys| DR
    GWCtrl -->|deploys| NP
    GWCtrl -->|deploys| Redirects

    %% Monitoring controller creates stack
    MonCtrl -->|deploys| Prom
    MonCtrl -->|deploys| Thanos
    MonCtrl -->|deploys| OTel
    MonCtrl -->|deploys| Tempo
    MonCtrl -->|deploys| Perses
    MonCtrl -->|deploys| KRP

    %% Auth controller creates RBAC
    AuthCtrl -->|creates| RBAC["Roles &<br/>RoleBindings"]

    %% CertConfigMap distributes CA
    CertCtrl -->|distributes| CABundle["odh-trusted-ca-bundle<br/>ConfigMaps"]

    %% External dependencies
    GW -->|traffic routing| Istio["Istio/Sail"]
    KAP -->|authenticates| OAuth["OAuth/OIDC<br/>Provider"]
    Components -->|applies manifests| K8sAPI["Kubernetes API"]
    CloudMgr -->|Helm charts| CertMgr["cert-manager"]
    CloudMgr -->|Helm charts| Istio

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style Components fill:#7ed321,stroke:#333,color:#fff
    style CloudMgr fill:#9b59b6,stroke:#333,color:#fff
    style GatewayStack fill:#f5a623,stroke:#333,color:#000
    style MonStack fill:#e74c3c,stroke:#333,color:#fff
    style Admin fill:#f9f9f9,stroke:#999
    style DSCI_CR fill:#ffeaa7,stroke:#d6b656
    style DSC_CR fill:#ffeaa7,stroke:#d6b656
    style CompCRs fill:#ffeaa7,stroke:#d6b656
    style RBAC fill:#dfe6e9,stroke:#636e72
    style CABundle fill:#dfe6e9,stroke:#636e72
    style Istio fill:#999,stroke:#333,color:#fff
    style OAuth fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CertMgr fill:#999,stroke:#333,color:#fff
