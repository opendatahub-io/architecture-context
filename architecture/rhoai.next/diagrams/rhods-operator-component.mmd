graph TB
    subgraph "rhods-operator (RHOAI Platform Operator)"
        direction TB

        subgraph "Core Controllers"
            DSCICtrl["DSCInitialization Controller<br/>Platform infrastructure setup"]
            DSCCtrl["DataScienceCluster Controller<br/>Component lifecycle orchestration"]
        end

        subgraph "Service Controllers"
            GatewayCtrl["Gateway Controller<br/>Ingress stack: Gateway API, Envoy,<br/>kube-auth-proxy, dashboard redirects"]
            AuthCtrl["Auth Controller<br/>RBAC group bindings<br/>(admin/allowed groups)"]
            MonitoringCtrl["Monitoring Controller<br/>Prometheus, Tempo,<br/>OpenTelemetry, Perses"]
        end

        subgraph "Component Controllers (15)"
            Dashboard["Dashboard"]
            Workbenches["Workbenches"]
            KServe["KServe"]
            Kueue["Kueue"]
            Ray["Ray"]
            TrustyAI["TrustyAI"]
            ModelRegistry["Model Registry"]
            DSP["Data Science Pipelines"]
            TrainingOp["Training Operator"]
            Trainer["Trainer"]
            Feast["Feast Operator"]
            OGX["OGX"]
            MLflow["MLflow Operator"]
            Spark["Spark Operator"]
            MaaS["ModelsAsService"]
            ModelCtrl["Model Controller"]
        end

        WebhookServer["Webhook Server<br/>12 active webhooks:<br/>validation, defaulting,<br/>HW profile injection,<br/>connection injection"]
    end

    subgraph "Cloud Manager (xKS only)"
        CloudMgr["cloudmanager<br/>Dependency bootstrapper<br/>for Azure AKS, CoreWeave"]
    end

    %% User interaction
    User[User / Admin] -->|creates| DSCICR["DSCInitialization CR<br/>(cluster singleton)"]
    User -->|creates| DSCCR["DataScienceCluster CR<br/>(cluster singleton)"]

    %% Controller hierarchy
    DSCICR -->|watched by| DSCICtrl
    DSCICtrl -->|creates singleton CRs| AuthCR["Auth CR"]
    DSCICtrl -->|creates singleton CRs| GatewayCR["GatewayConfig CR"]
    DSCICtrl -->|creates singleton CRs| MonitorCR["Monitoring CR"]

    AuthCR -->|watched by| AuthCtrl
    GatewayCR -->|watched by| GatewayCtrl
    MonitorCR -->|watched by| MonitoringCtrl

    DSCCR -->|watched by| DSCCtrl
    DSCCtrl -->|creates per-component CRs| ComponentCRs["Component CRs<br/>(Dashboard, Kserve, Kueue, ...)"]
    ComponentCRs -->|watched by| Dashboard
    ComponentCRs -->|watched by| KServe
    ComponentCRs -->|watched by| Kueue

    %% Webhook interactions
    DSCCR -->|validated by| WebhookServer
    DSCICR -->|validated by| WebhookServer

    %% Gateway outputs
    GatewayCtrl -->|creates| Gateway["Gateway API<br/>Gateway Resource"]
    GatewayCtrl -->|deploys| AuthProxy["kube-auth-proxy<br/>OAuth2/OIDC auth"]
    GatewayCtrl -->|creates| EnvoyFilter["EnvoyFilter<br/>ext_authz"]
    GatewayCtrl -->|creates| DashRedirect["Dashboard Redirect<br/>nginx (301 redirects)"]

    %% Monitoring outputs
    MonitoringCtrl -->|deploys| MonStack["MonitoringStack<br/>(Prometheus)"]
    MonitoringCtrl -->|deploys| Tempo["Tempo<br/>(Tracing)"]
    MonitoringCtrl -->|deploys| OTEL["OpenTelemetry<br/>Collector"]
    MonitoringCtrl -->|deploys| Perses["Perses<br/>(Visualization)"]

    %% Cloud manager
    CloudMgr -->|Helm install| CertMgr["cert-manager"]
    CloudMgr -->|Helm install| Sail["Sail Operator (Istio)"]
    CloudMgr -->|Helm install| LWS["LeaderWorkerSet"]
    CloudMgr -->|Helm install| GatewayAPICRDs["Gateway API CRDs"]

    %% External dependencies
    KServe -->|depends on| CertMgr
    KServe -->|depends on| Sail
    GatewayCtrl -->|depends on| Sail

    %% Styling
    style DSCICtrl fill:#4a90e2,color:#fff
    style DSCCtrl fill:#4a90e2,color:#fff
    style GatewayCtrl fill:#e67e22,color:#fff
    style AuthCtrl fill:#e67e22,color:#fff
    style MonitoringCtrl fill:#e67e22,color:#fff
    style WebhookServer fill:#9b59b6,color:#fff
    style CloudMgr fill:#2ecc71,color:#fff
    style DSCICR fill:#f5a623
    style DSCCR fill:#f5a623
    style AuthCR fill:#f5a623
    style GatewayCR fill:#f5a623
    style MonitorCR fill:#f5a623
    style ComponentCRs fill:#f5a623
    style CertMgr fill:#999,color:#fff
    style Sail fill:#999,color:#fff
    style LWS fill:#999,color:#fff
    style GatewayAPICRDs fill:#999,color:#fff
