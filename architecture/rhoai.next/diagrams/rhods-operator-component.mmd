graph TB
    subgraph Operator["rhods-operator (manager)"]
        direction TB

        subgraph Controllers["Core Controllers"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
            GatewayCtrl["Gateway<br/>Controller"]
            AuthCtrl["Auth<br/>Controller"]
            MonitoringCtrl["Monitoring<br/>Controller"]
            CertCtrl["CertConfigMapGenerator<br/>Controller"]
            SetupCtrl["Setup<br/>Controller"]
        end

        subgraph Registries["Plugin Registries"]
            CompReg["Component Registry<br/>(16 components)"]
            SvcReg["Service Registry<br/>(5 services)"]
        end
    end

    subgraph CloudMgr["cloudmanager"]
        AzureCtrl["Azure AKS<br/>Controller"]
        CoreWeaveCtrl["CoreWeave<br/>Controller"]
    end

    %% CRDs
    DSCI_CR["DSCInitialization CR"]
    DSC_CR["DataScienceCluster CR"]

    subgraph ComponentCRs["Component CRDs (16)"]
        DashboardCR["Dashboard"]
        KServeCR["Kserve"]
        KueueCR["Kueue"]
        WorkbenchCR["Workbenches"]
        ModelRegCR["ModelRegistry"]
        DSPCR["DataSciencePipelines"]
        TrustyAICR["TrustyAI"]
        RayCR["Ray"]
        TrainingCR["TrainingOperator"]
        TrainerCR["Trainer"]
        FeastCR["FeastOperator"]
        LlamaCR["LlamaStackOperator"]
        MLflowCR["MLflowOperator"]
        ModelCtrlCR["ModelController"]
        MaaSCR["ModelsAsService"]
        SparkCR["SparkOperator"]
    end

    subgraph ServiceCRs["Service CRDs"]
        AuthCR["Auth CR"]
        GatewayCR["GatewayConfig CR"]
        MonitoringCR["Monitoring CR"]
    end

    %% Admin creates top-level CRs
    Admin[Cluster Admin] -->|creates| DSCI_CR
    Admin -->|creates| DSC_CR

    %% DSCI provisions infrastructure + service CRs
    DSCI_CR -->|watched by| DSCICtrl
    DSCICtrl -->|creates| AuthCR
    DSCICtrl -->|creates| GatewayCR
    DSCICtrl -->|creates| MonitoringCR

    %% Service CRs trigger service controllers
    AuthCR -->|watched by| AuthCtrl
    GatewayCR -->|watched by| GatewayCtrl
    MonitoringCR -->|watched by| MonitoringCtrl

    %% DSC manages component CRs
    DSC_CR -->|watched by| DSCCtrl
    DSCCtrl -->|iterates| CompReg
    CompReg -->|creates| ComponentCRs

    %% Service registry
    SvcReg -->|manages| AuthCtrl
    SvcReg -->|manages| GatewayCtrl
    SvcReg -->|manages| MonitoringCtrl
    SvcReg -->|manages| CertCtrl
    SvcReg -->|manages| SetupCtrl

    %% External dependencies
    GatewayCtrl -->|creates| GatewayAPI["Gateway API<br/>(Envoy)"]
    GatewayCtrl -->|creates| AuthProxy["kube-auth-proxy"]
    GatewayCtrl -->|creates| EnvoyFilter["EnvoyFilter"]
    GatewayCtrl -->|creates| Routes["OpenShift Routes"]

    MonitoringCtrl -->|creates| MonStack["MonitoringStack<br/>(Prometheus)"]
    MonitoringCtrl -->|creates| Thanos["ThanosQuerier"]
    MonitoringCtrl -->|creates| Tempo["Tempo"]
    MonitoringCtrl -->|creates| OTEL["OTEL Collector"]
    MonitoringCtrl -->|creates| Perses["Perses"]

    AuthCtrl -->|manages| RBAC["Platform RBAC<br/>(Roles, Bindings)"]

    %% Cloud manager CRDs
    AzureCR["AzureKubernetesEngine CR"] -->|watched by| AzureCtrl
    CoreWeaveCR["CoreWeaveKubernetesEngine CR"] -->|watched by| CoreWeaveCtrl

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Controllers fill:#3a7bd5,stroke:#333,color:#fff
    style Registries fill:#2d6bc4,stroke:#333,color:#fff
    style CloudMgr fill:#6c8ebf,stroke:#333,color:#fff
    style ComponentCRs fill:#f5a623,stroke:#333
    style ServiceCRs fill:#f5a623,stroke:#333
    style DSCI_CR fill:#f5a623,stroke:#333
    style DSC_CR fill:#f5a623,stroke:#333
    style GatewayAPI fill:#7ed321,stroke:#333
    style AuthProxy fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style MonStack fill:#9b59b6,stroke:#333,color:#fff
    style Thanos fill:#9b59b6,stroke:#333,color:#fff
    style Tempo fill:#9b59b6,stroke:#333,color:#fff
    style OTEL fill:#9b59b6,stroke:#333,color:#fff
    style Perses fill:#9b59b6,stroke:#333,color:#fff
    style RBAC fill:#e74c3c,stroke:#333,color:#fff
    style Admin fill:#e8e8e8,stroke:#333
