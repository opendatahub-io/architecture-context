graph TB
    subgraph RhodsOperator["rhods-operator (Main Binary)"]
        direction TB

        subgraph Controllers["Controllers"]
            DSCCtrl["DSC Controller<br/>Reconciles DataScienceCluster CRs"]
            DSCICtrl["DSCI Controller<br/>Reconciles DSCInitialization CRs"]
            GatewayCtrl["Gateway Controller<br/>Deploys Gateway API ingress stack"]
            AuthCtrl["Auth Controller<br/>Manages RBAC groups & bindings"]
            MonitoringCtrl["Monitoring Controller<br/>Deploys MonitoringStack, Prometheus,<br/>Thanos, OTel, Perses"]
            CertCMCtrl["CertConfigMapGenerator<br/>Distributes trusted CA bundles"]
            SetupCtrl["Setup Controller<br/>Handles operator uninstallation"]
            ModulesCtrl["Modules Controller<br/>Manages dependency operators"]
        end

        subgraph ComponentControllers["Component Controllers (16+)"]
            DashboardComp["Dashboard"]
            KServeComp["KServe"]
            KueueComp["Kueue"]
            WorkbenchesComp["Workbenches"]
            DSPComp["DataSciencePipelines"]
            RayComp["Ray"]
            TrustyAIComp["TrustyAI"]
            ModelRegComp["ModelRegistry"]
            ModelCtrlComp["ModelController"]
            TrainingComp["TrainingOperator"]
            TrainerComp["Trainer"]
            FeastComp["FeastOperator"]
            OGXComp["OGX"]
            MLflowComp["MLflowOperator"]
            SparkComp["SparkOperator"]
            MaaSComp["ModelsAsService"]
        end

        subgraph Webhooks["Webhook System (14 webhooks)"]
            SingletonWH["Singleton Enforcement<br/>(DSC/DSCI)"]
            DefaultingWH["Defaulting Webhooks<br/>(DSC v1/v2)"]
            HWProfileWH["HardwareProfile Injection<br/>(Notebooks, ISVCs)"]
            ConnectionWH["Connection Injection<br/>(Notebooks, ISVCs, LLMISVCs)"]
            MonitoringWH["Monitoring Label Injection<br/>(PodMonitors, ServiceMonitors)"]
            DeprecationWH["Deprecation Webhooks<br/>(AcceleratorProfile, HardwareProfile)"]
            ConversionWH["CRD Conversion<br/>(DSCI v1 ↔ v2)"]
        end
    end

    subgraph CloudManager["Cloud Manager (Separate Binary)"]
        AWSCtrl["AWS Engine Controller"]
        AzureCtrl["Azure Engine Controller"]
        CoreWeaveCtrl["CoreWeave Engine Controller"]
        HelmEngine["Helm Chart Renderer"]
        AWSCtrl --> HelmEngine
        AzureCtrl --> HelmEngine
        CoreWeaveCtrl --> HelmEngine
    end

    %% CRD relationships
    User["User / Admin"] -->|creates| DSCCR["DataScienceCluster CR"]
    User -->|creates| DSCICR["DSCInitialization CR"]
    DSCCR -->|watched by| DSCCtrl
    DSCICR -->|watched by| DSCICtrl

    %% DSC Controller creates component CRs
    DSCCtrl -->|creates| ComponentCRs["Component CRs<br/>(Dashboard, KServe, Kueue, etc.)"]
    ComponentCRs -->|watched by| ComponentControllers

    %% DSCI Controller bootstraps platform
    DSCICtrl -->|creates| ServiceCRs["Service CRs<br/>(Auth, GatewayConfig, Monitoring)"]
    ServiceCRs -->|watched by| GatewayCtrl
    ServiceCRs -->|watched by| AuthCtrl
    ServiceCRs -->|watched by| MonitoringCtrl

    %% Gateway stack
    GatewayCtrl -->|deploys| GatewayStack["Gateway API Stack<br/>Gateway, EnvoyFilter,<br/>kube-auth-proxy, HTTPRoutes"]

    %% External dependencies
    DSCCtrl -->|API calls| K8sAPI["Kubernetes API<br/>6443/TCP"]
    GatewayCtrl -->|creates| IstioRes["Istio Resources<br/>EnvoyFilter, DestinationRule"]
    MonitoringCtrl -->|creates| MonRes["Monitoring Resources<br/>MonitoringStack, PrometheusRule,<br/>OTel Collector"]
    Webhooks -->|validates via| K8sAPI
    CloudManager -->|deploys via| HelmCharts["Helm Charts<br/>(cert-manager, Istio, LWS)"]

    %% Styling
    style RhodsOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style CloudManager fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style Controllers fill:#e8f5e9,stroke:#82b366
    style ComponentControllers fill:#fce4ec,stroke:#e57373
    style Webhooks fill:#f3e5f5,stroke:#ab47bc
    style DSCCtrl fill:#4a90e2,color:#fff
    style DSCICtrl fill:#4a90e2,color:#fff
    style GatewayCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#4a90e2,color:#fff
    style MonitoringCtrl fill:#4a90e2,color:#fff
    style User fill:#fff,stroke:#333
    style DSCCR fill:#f5a623,color:#333
    style DSCICR fill:#f5a623,color:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style GatewayStack fill:#7ed321,color:#333
