graph TB
    subgraph Operator["rhods-operator (manager binary)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCCtrl["DSC Controller<br/>Orchestrates component lifecycle"]
            DSCICtrl["DSCI Controller<br/>Platform infrastructure init"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway Controller<br/>Ingress stack: Gateway API,<br/>Envoy, kube-auth-proxy"]
            AuthCtrl["Auth Controller<br/>RBAC groups/roles"]
            MonitoringCtrl["Monitoring Controller<br/>Prometheus, Thanos,<br/>Tempo, OTel, Perses"]
            CertCMCtrl["CertConfigMapGenerator<br/>CA bundle distribution"]
            ModulesCtrl["Modules Controller<br/>Module operator lifecycle"]
        end

        subgraph ComponentControllers["Component Controllers (16)"]
            Dashboard["Dashboard"]
            Workbenches["Workbenches"]
            KServe["KServe"]
            KueueComp["Kueue"]
            RayComp["Ray"]
            DSP["DataScience<br/>Pipelines"]
            TrustyAI["TrustyAI"]
            ModelReg["Model<br/>Registry"]
            ModelCtrl["Model<br/>Controller"]
            MaaS["ModelsAs<br/>Service"]
            Feast["Feast<br/>Operator"]
            OGX["OGX"]
            MLflow["MLflow<br/>Operator"]
            Spark["Spark<br/>Operator"]
            TrainingOp["Training<br/>Operator"]
            Trainer["Trainer"]
        end

        subgraph Webhooks["Admission Webhooks (12)"]
            ValWebhooks["Validating:<br/>DSC v1/v2 singleton,<br/>DSCI v1/v2 singleton,<br/>HardwareProfile,<br/>AcceleratorProfile"]
            MutWebhooks["Mutating:<br/>HW Profile injection,<br/>Connection injection,<br/>Monitoring labels,<br/>DSC defaults"]
            ConvWebhook["Conversion:<br/>DSCI v1↔v2"]
        end
    end

    subgraph CloudMgr["cloudmanager binary"]
        AWSCtrl["AWS Controller"]
        AzureCtrl["Azure Controller"]
        CoreWeaveCtrl["CoreWeave Controller"]
    end

    %% Primary CRs
    DSCCR["DataScienceCluster CR<br/>(v1, v2)"]
    DSCICR["DSCInitialization CR<br/>(v1, v2)"]
    PlatformCR["Platform CR<br/>(vanilla K8s mode)"]

    %% User interactions
    User["Platform Admin"] -->|creates| DSCCR
    User -->|creates| DSCICR

    %% Core controller flows
    DSCCR -->|watched by| DSCCtrl
    DSCICR -->|watched by| DSCICtrl
    PlatformCR -->|watched by| ModulesCtrl

    %% DSC drives components
    DSCCtrl -->|enables/disables| Dashboard
    DSCCtrl -->|enables/disables| Workbenches
    DSCCtrl -->|enables/disables| KServe
    DSCCtrl -->|enables/disables| KueueComp
    DSCCtrl -->|enables/disables| RayComp
    DSCCtrl -->|enables/disables| DSP
    DSCCtrl -->|enables/disables| TrustyAI
    DSCCtrl -->|enables/disables| ModelReg
    DSCCtrl -->|enables/disables| ModelCtrl
    DSCCtrl -->|enables/disables| MaaS
    DSCCtrl -->|enables/disables| Feast
    DSCCtrl -->|enables/disables| OGX
    DSCCtrl -->|enables/disables| MLflow
    DSCCtrl -->|enables/disables| Spark
    DSCCtrl -->|enables/disables| TrainingOp
    DSCCtrl -->|enables/disables| Trainer

    %% DSCI drives services
    DSCICtrl -->|configures| GatewayCtrl
    DSCICtrl -->|configures| AuthCtrl
    DSCICtrl -->|configures| MonitoringCtrl
    DSCICtrl -->|configures| CertCMCtrl

    %% External dependencies
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    CertMgr["cert-manager"]
    Istio["Istio / Sail Operator"]
    GatewayAPI["Gateway API CRDs"]
    OLM["OLM"]

    GatewayCtrl -->|creates| GatewayAPI
    GatewayCtrl -->|creates EnvoyFilter| Istio
    GatewayCtrl -->|requests certs| CertMgr
    DSCCtrl -->|deploys via SSA| K8sAPI
    CloudMgr -->|manages via Helm| CertMgr
    CloudMgr -->|manages via Helm| Istio

    %% Styling
    style Operator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CoreControllers fill:#bbdefb,stroke:#1565c0
    style ServiceControllers fill:#bbdefb,stroke:#1565c0
    style ComponentControllers fill:#c8e6c9,stroke:#2e7d32
    style Webhooks fill:#fff3e0,stroke:#e65100
    style CloudMgr fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    style DSCCR fill:#fff9c4,stroke:#f9a825
    style DSCICR fill:#fff9c4,stroke:#f9a825
    style PlatformCR fill:#fff9c4,stroke:#f9a825
    style K8sAPI fill:#e0e0e0,stroke:#616161
    style CertMgr fill:#e0e0e0,stroke:#616161
    style Istio fill:#e0e0e0,stroke:#616161
    style GatewayAPI fill:#e0e0e0,stroke:#616161
    style OLM fill:#e0e0e0,stroke:#616161
    style User fill:#e1f5fe,stroke:#0277bd
