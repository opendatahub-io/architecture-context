graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client<br/>Authorization header (passthrough)<br/>x-forwarded-* headers"]
    end

    subgraph GatewayZone["GATEWAY SERVICE"]
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>Rust/axum<br/>Listen: 0.0.0.0:8090/TCP<br/>Protocol: HTTP (plaintext)<br/>No local auth enforcement"]

        subgraph ConfigMount["Configuration"]
            Config["YAML Config File<br/>/app/config/config.yaml<br/>Routes, Detectors, Orchestrator"]
        end

        subgraph TLSMount["TLS Secrets (Volume Mounts)"]
            ClientCert["tls.crt + tls.key<br/>/etc/tls/private/<br/>kubernetes.io/tls<br/>cert-manager"]
            CACert["service-ca.crt<br/>/etc/tls/ca/<br/>service-ca-operator"]
        end
    end

    subgraph InternalPlatform["INTERNAL PLATFORM (TrustyAI Stack)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP (configurable)<br/>HTTP or HTTPS<br/>Validates Authorization"]

        subgraph OrchestratorBackends["Orchestrator Backends (Indirect)"]
            Detectors["Content Detectors<br/>(e.g., regex-detector)<br/>Input/Output detection"]
            ModelServer["vLLM Model Server<br/>LLM inference backend"]
        end
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization passthrough<br/>POST /{route}/v1/chat/completions"| Gateway

    Config -.->|"file mount"| Gateway
    ClientCert -.->|"PKCS#12 identity<br/>(PEM → PKCS#12 via openssl)"| Gateway
    CACert -.->|"CA trust bundle"| Gateway

    Gateway -->|"HTTP(S)/8085<br/>Optional mTLS<br/>Authorization forwarded<br/>POST /api/v2/chat/completions-detection"| Orchestrator

    Orchestrator -->|"internal"| Detectors
    Orchestrator -->|"internal"| ModelServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tls fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway gateway
    class Config config
    class ClientCert,CACert tls
    class Orchestrator internal
    class Detectors,ModelServer backend
