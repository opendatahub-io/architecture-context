graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph GatewayZone["GATEWAY SERVICE (ClusterIP)"]
        Gateway["vllm-orchestrator-gateway<br/>Rust/axum<br/>8090/TCP HTTP<br/>No Auth (passthrough only)<br/>Image: odh-trustyai-vllm-orchestrator-gateway-rhel9"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP (default)<br/>POST /api/v2/chat/completions-detection"]

        Detectors["Guardrails Detectors<br/>(e.g., regex-language)<br/>Indirect via orchestrator"]

        vLLM["vLLM / Model Server<br/>Indirect via orchestrator"]
    end

    subgraph CertInfra["CERTIFICATE INFRASTRUCTURE"]
        ServiceCA["OpenShift service-ca<br/>/etc/tls/ca/service-ca.crt"]
        CertManager["Platform / cert-manager<br/>/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key"]
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header (optional)"| Gateway

    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Authorization passthrough<br/>+ X-Forwarded-* headers"| Orchestrator

    Orchestrator -->|"Internal"| Detectors
    Orchestrator -->|"Internal"| vLLM

    %% Certificate flows
    CertManager -.->|"Client cert + key<br/>(when present → mTLS)"| Gateway
    ServiceCA -.->|"CA cert<br/>(when present → verify server)"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#4a90e2,stroke:#2a6cb8,stroke-width:2px,color:#fff
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef certs fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway gateway
    class Orchestrator,Detectors,vLLM internal
    class ServiceCA,CertManager certs
