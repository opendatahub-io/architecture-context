graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client<br/>OpenAI-compatible"]
    end

    subgraph GatewayZone["GATEWAY SERVICE"]
        Gateway["vLLM Orchestrator Gateway<br/>Rust/axum<br/>Listen: 0.0.0.0:8090<br/>Image: UBI9-minimal"]
    end

    subgraph Secrets["MOUNTED SECRETS"]
        TLSCert["tls.crt + tls.key<br/>/etc/tls/private/<br/>kubernetes.io/tls<br/>cert-manager"]
        CACert["service-ca.crt<br/>/etc/tls/ca/<br/>service-ca-operator"]
    end

    subgraph Internal["INTERNAL SERVICES (TrustyAI Stack)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>/api/v2/chat/completions-detection<br/>Default: 8085/TCP"]

        subgraph OrchestratorBackends["Orchestrator Backends (indirect)"]
            Detectors["Content Detectors<br/>e.g., regex-detector<br/>Input/Output detection"]
            vLLM["vLLM Model Server<br/>LLM Inference"]
        end

        Orchestrator -->|invokes| Detectors
        Orchestrator -->|routes to| vLLM
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Auth: passthrough<br/>POST /{route}/v1/chat/completions"| Gateway

    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Auth: forwarded + client cert<br/>POST /api/v2/chat/completions-detection"| Orchestrator

    %% Secret mounts
    TLSCert -.->|"mTLS client identity<br/>PKCS#12 via OpenSSL"| Gateway
    CACert -.->|"CA trust for<br/>orchestrator server cert"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#4a90e2,stroke:#2c5fa1,stroke-width:2px,color:#fff
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secret fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef indirect fill:#e8e8e8,stroke:#999,stroke-width:1px

    class Client external
    class Gateway gateway
    class Orchestrator internal
    class Detectors,vLLM indirect
    class TLSCert,CACert secret
