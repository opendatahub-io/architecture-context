graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS / TLS TERMINATION (Expected)"]
        direction TB
        TLSTermination["Platform Ingress<br/>(Gateway API / kube-rbac-proxy)<br/>TLS Termination + AuthN<br/>(managed externally)"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER (Internal)"]
        direction TB

        subgraph NS_Gateway["Namespace: (deployment-managed)"]
            Gateway["vllm-orchestrator-gateway<br/>Port: 8090/TCP<br/>Protocol: HTTP (plaintext)<br/>Auth: None (pass-through)<br/>Image: Rust binary on UBI 9"]
        end

        subgraph TLS_Mounts["TLS Materials (Kubernetes Volume Mounts)"]
            ClientCert["/etc/tls/private/tls.crt<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager"]
            ClientKey["/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager"]
            CACert["/etc/tls/ca/service-ca.crt<br/>Type: Opaque<br/>Provisioned by: OpenShift Service CA"]
        end

        Gateway -.->|"reads if present"| ClientCert
        Gateway -.->|"reads if present"| ClientKey
        Gateway -.->|"reads if present"| CACert
    end

    subgraph Backend["BACKEND SERVICES (Internal)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>Port: 8085/TCP (configurable)<br/>Protocol: HTTP or HTTPS<br/>Conditional mTLS"]

        subgraph OrchestratorBackends["Orchestrator Backends (Indirect)"]
            vLLM["vLLM Inference Server<br/>(via orchestrator)"]
            Detectors["Content Detectors<br/>(e.g., regex detector)<br/>(via orchestrator)"]
        end

        Orchestrator -->|"inference requests"| vLLM
        Orchestrator -->|"detection requests"| Detectors
    end

    %% Flows
    Client -->|"HTTPS (expected)<br/>TLS Termination<br/>Bearer Token"| TLSTermination
    TLSTermination -->|"HTTP/8090<br/>Plaintext<br/>Authorization header"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Conditional mTLS<br/>Authorization header forwarded<br/>x-forwarded-* forwarded<br/>mTLS client cert (if present)"| Orchestrator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secrets fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray:5 5

    class Client external
    class TLSTermination ingress
    class Gateway application
    class Orchestrator,vLLM,Detectors backend
    class ClientCert,ClientKey,CACert secrets
