graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client<br/>OpenAI-compatible"]
    end

    subgraph GatewayZone["GATEWAY SERVICE (Internal)"]
        Gateway["vllm-orchestrator-gateway<br/>Rust/axum<br/>0.0.0.0:8090/TCP<br/>HTTP (plaintext)<br/>Auth: Passthrough"]
        ConfigMount["Config File<br/>/app/config/config.yaml<br/>Routes + Detectors"]
        TLSMount["TLS Secrets<br/>/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key<br/>/etc/tls/ca/service-ca.crt"]
        ConfigMount -.->|"file mount"| Gateway
        TLSMount -.->|"volume mount<br/>PKCS#12 identity"| Gateway
    end

    subgraph PlatformServices["INTERNAL PLATFORM (TrustyAI Stack)"]
        direction TB
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP (configurable)<br/>HTTP or HTTPS<br/>/api/v2/chat/completions-detection"]

        subgraph OrchestratorBackends["Orchestrator Backends"]
            Detectors["Content Detectors<br/>(e.g., regex-detector)<br/>Input/Output detection"]
            vLLM["vLLM Model Server<br/>LLM inference"]
        end

        Orchestrator -->|"invokes"| Detectors
        Orchestrator -->|"routes inference"| vLLM
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Optional Auth header"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Auth header forwarded<br/>x-forwarded-* headers"| Orchestrator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway gateway
    class Orchestrator,Detectors,vLLM platform
    class ConfigMount config
    class TLSMount secrets
