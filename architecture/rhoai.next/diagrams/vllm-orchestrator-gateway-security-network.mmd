graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph GatewayZone["GATEWAY SERVICE (Internal - ClusterIP)"]
        Gateway["vllm-orchestrator-gateway<br/>Port: 8090/TCP<br/>Protocol: HTTP (plaintext)<br/>Runtime: Rust / axum<br/>No /healthz endpoint"]
    end

    subgraph BackendZone["BACKEND SERVICES (Internal - Cluster Network)"]
        direction TB

        Orchestrator["FMS Guardrails Orchestrator<br/>Port: 8085/TCP (configurable)<br/>POST /api/v2/chat/completions-detection<br/>HTTP or HTTPS"]

        subgraph IndirectServices["Indirect Services (called by orchestrator)"]
            Detectors["Detector Services<br/>(e.g., guardrails-regex-detector)<br/>Content safety / PII detection"]
            ModelServer["vLLM Model Server<br/>(e.g., Qwen2.5)<br/>LLM inference"]
        end

        Orchestrator -.->|"indirect"| Detectors
        Orchestrator -.->|"indirect"| ModelServer
    end

    subgraph ConfigSources["CONFIGURATION (Volume Mounts)"]
        ConfigMap["ConfigMap<br/>config.yaml<br/>Routes & detector pipelines"]
        TLSCert["Secret: tls.crt<br/>/etc/tls/private/tls.crt<br/>kubernetes.io/tls"]
        TLSKey["Secret: tls.key<br/>/etc/tls/private/tls.key<br/>kubernetes.io/tls"]
        CACert["Secret: service-ca.crt<br/>/etc/tls/ca/service-ca.crt<br/>Opaque"]
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header<br/>(pass-through)"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Forwarded Authorization<br/>+ X-Forwarded-* headers"| Orchestrator

    ConfigMap -.->|"volume mount"| Gateway
    TLSCert -.->|"volume mount"| Gateway
    TLSKey -.->|"volume mount"| Gateway
    CACert -.->|"volume mount"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef indirect fill:#f5f5f5,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway gateway
    class Orchestrator backend
    class Detectors,ModelServer indirect
    class ConfigMap,TLSCert,TLSKey,CACert config
