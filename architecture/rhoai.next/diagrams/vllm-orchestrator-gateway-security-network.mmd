graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph ApplicationLayer["APPLICATION LAYER"]
        Gateway["vLLM Orchestrator Gateway<br/>Container Port: 8090/TCP<br/>Rust / axum 0.7.9<br/>No local auth enforcement"]

        subgraph ConfigMounts["Configuration & Secrets"]
            Config["config.yaml<br/>(GATEWAY_CONFIG env var)"]
            TLSCert["/etc/tls/private/tls.crt<br/>X.509 PEM Client Cert"]
            TLSKey["/etc/tls/private/tls.key<br/>PEM Private Key"]
            CACert["/etc/tls/ca/service-ca.crt<br/>X.509 PEM CA Cert"]
        end

        Config -->|"read at startup"| Gateway
        TLSCert -->|"mTLS identity"| Gateway
        TLSKey -->|"mTLS identity"| Gateway
        CACert -->|"custom CA trust"| Gateway
    end

    subgraph BackendServices["BACKEND SERVICES (Internal)"]
        direction TB

        Orchestrator["FMS Guardrails Orchestrator<br/>Port: 8085/TCP (configurable)<br/>Endpoint: /api/v2/chat/completions-detection"]

        Detectors["Guardrails Detectors<br/>(e.g., regex-detector, PII)<br/>Invoked by Orchestrator only"]

        LLM["vLLM / LLM Inference Server<br/>Invoked by Orchestrator only"]

        Orchestrator -->|"content analysis"| Detectors
        Orchestrator -->|"text generation"| LLM
    end

    %% Network Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Auth: pass-through<br/>POST /{route}/v1/chat/completions"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Auth: forwarded header + client cert<br/>POST /api/v2/chat/completions-detection"| Orchestrator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secrets fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway application
    class Orchestrator,Detectors,LLM backend
    class Config,TLSCert,TLSKey,CACert secrets
