graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(OpenAI-compatible)"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (No Auth Enforcement)"]
        Gateway["vllm-orchestrator-gateway<br/>8090/TCP HTTP (plaintext)<br/>Rust / axum 0.7.9<br/>Image: odh-trustyai-vllm-orchestrator-gateway-rhel9<br/>Auth: NONE (passthrough only)"]
    end

    subgraph InternalPlatform["INTERNAL PLATFORM SERVICES"]
        direction TB

        subgraph OrchestratorZone["Orchestrator Zone"]
            Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP (configurable)<br/>HTTP or HTTPS<br/>Optional mTLS server"]
        end

        subgraph BackendZone["Backend Services (Indirect)"]
            Detectors["Guardrails Detectors<br/>(e.g., regex-language)<br/>Content detection"]
            ModelServer["vLLM / Model Server<br/>LLM inference backend"]
        end
    end

    subgraph CertMounts["CERTIFICATE MOUNTS"]
        TLSCert["/etc/tls/private/tls.crt<br/>Client TLS cert<br/>cert-manager (inferred)"]
        TLSKey["/etc/tls/private/tls.key<br/>Client TLS key<br/>cert-manager (inferred)"]
        CACert["/etc/tls/ca/service-ca.crt<br/>CA cert<br/>OpenShift service-ca (inferred)"]
    end

    %% Network Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header (optional)"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>Authorization passthrough<br/>X-Forwarded-* headers"| Orchestrator
    Orchestrator -->|"Detector evaluation<br/>(indirect)"| Detectors
    Orchestrator -->|"LLM inference<br/>(indirect)"| ModelServer

    %% Certificate references
    Gateway -.->|"reads if present<br/>(opportunistic mTLS)"| TLSCert
    Gateway -.->|"reads if present"| TLSKey
    Gateway -.->|"reads if present<br/>(CA validation)"| CACert

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#e8e8e8,stroke:#666,stroke-width:1px
    classDef certs fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class Gateway gateway
    class Orchestrator internal
    class Detectors,ModelServer backend
    class TLSCert,TLSKey,CACert certs
