graph TB
    subgraph Orchestration["ORCHESTRATION (Cluster Internal)"]
        Operator["TrustyAI LMEval Operator<br/>Watches: LMEvalJob CR<br/>Creates: K8s Job"]
    end

    subgraph BatchJob["BATCH JOB POD (Ephemeral)"]
        direction TB

        subgraph PodMeta["Pod Configuration"]
            PodInfo["User: 65532:65532 (non-root)<br/>Entrypoint: python main.py"]
        end

        subgraph Mounts["Mounted Volumes"]
            JobSpec["/meta/job.json<br/>(ConfigMap)"]
            DockerAuth["/tmp/.docker/config.json<br/>(OCI Auth)"]
            TestData["/test_data<br/>(Offline datasets, optional)"]
        end

        subgraph Components["Components"]
            Adapter["LMEval Adapter<br/>(main.py)"]
            LMEval["lm_eval Library"]
            OCIPub["OCI Publisher<br/>(oci.py + skopeo)"]
            S3Down["S3 Downloader<br/>(s3_downloader.py)"]
        end
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        InferenceEP["Inference Endpoint<br/>(vLLM / TGI)<br/>HTTP/HTTPS<br/>TLS 1.2+ (custom CA)<br/>Bearer Token"]
        MLflow["MLflow Tracking<br/>HTTP/HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OCIReg["OCI Registry (Quay)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>AWS IAM"]
    end

    %% Orchestration flow
    Operator -->|Creates K8s Job<br/>ServiceAccount RBAC| BatchJob

    %% Egress flows
    Adapter -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Status callbacks| EvalHub
    LMEval -->|HTTP or HTTPS<br/>TLS 1.2+ custom CA<br/>Bearer Token<br/>POST /v1/completions<br/>up to 128 concurrent| InferenceEP
    OCIPub -->|HTTPS/443<br/>TLS 1.2+<br/>Docker auth config<br/>OCI artifact push| OCIReg
    LMEval -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token HF_TOKEN<br/>Datasets + tokenizers| HFHub
    S3Down -->|HTTPS/443<br/>TLS 1.2+ custom CA<br/>AWS IAM creds<br/>Offline test data| S3
    Adapter -->|HTTP or HTTPS<br/>TLS 1.2+<br/>Evaluation metrics| MLflow

    %% Styling
    classDef orchestration fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef batchjob fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef config fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Operator orchestration
    class Adapter,LMEval,OCIPub,S3Down,PodInfo batchjob
    class JobSpec,DockerAuth,TestData config
    class EvalHub,InferenceEP,MLflow internal
    class OCIReg,HFHub,S3 external
