graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        Operator["trustyai-service-operator<br/>Creates Jobs from LMEvalJob CRDs"]
        K8sAPI["Kubernetes API Server"]
    end

    subgraph BatchJob["BATCH JOB POD (Egress Only — No Ingress)"]
        direction TB

        subgraph Container["lmes-job Container"]
            JobRunner["lm-evaluation-harness<br/>Image: odh-ta-lmes-job<br/>Base: UBI 9 / Python 3.11<br/>No exposed ports"]
        end

        ConfigMap["ConfigMap<br/>/meta/job.json"]
        TestData["Volume: /test_data<br/>(offline mode)"]
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Config Auth"]
        MLflow["MLflow Tracking Server<br/>Configurable port<br/>HTTPS TLS 1.2+"]
        ModelEndpoint["Model Inference Endpoint<br/>(vLLM / TGI / OpenAI-compat)<br/>443 or 8080/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token (OPENAI_API_KEY)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
        S3["S3/COS Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / IBM COS"]
        WandB["W&B (optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>wandb API key"]
    end

    %% Control Plane flows
    Operator -->|"HTTPS/443<br/>TLS 1.3<br/>ServiceAccount Token"| K8sAPI
    K8sAPI -->|"Creates Job + ConfigMap"| BatchJob

    %% Egress flows from batch job
    JobRunner -->|"POST /v1/completions<br/>HTTPS TLS 1.2+<br/>Bearer Token<br/>Custom CA supported<br/>Concurrent: 1-128"| ModelEndpoint
    JobRunner -->|"POST status/results<br/>HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| EvalHub
    JobRunner -->|"OCI Push<br/>HTTPS/443<br/>TLS 1.2+<br/>Registry Auth"| OCI
    JobRunner -->|"Log metrics<br/>HTTPS TLS 1.2+<br/>Configurable auth"| MLflow
    JobRunner -->|"GET datasets<br/>HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    JobRunner -.->|"S3 API (via init container)<br/>HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    JobRunner -.->|"Optional<br/>HTTPS/443<br/>TLS 1.2+"| WandB

    %% Local mounts
    ConfigMap -.->|"Filesystem<br/>Mounted volume"| JobRunner
    TestData -.->|"Filesystem<br/>Offline mode"| JobRunner

    %% Styling
    classDef controlplane fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef batchjob fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef config fill:#f5a623,stroke:#333,stroke-width:1px

    class Operator,K8sAPI controlplane
    class JobRunner batchjob
    class EvalHub,OCI,MLflow,ModelEndpoint internal
    class HFHub,S3,WandB external
    class ConfigMap,TestData config
