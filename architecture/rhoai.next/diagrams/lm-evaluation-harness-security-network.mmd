graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["TrustyAI LMEval Operator<br/>Watches LMEvalJob CRs"]
        end

        subgraph UserNS["Namespace: user-namespace"]
            direction TB
            subgraph JobPod["LMEval Job Pod (batch)<br/>User: 65532:65532 (non-root)<br/>No inbound ports"]
                InitContainer["Init Container<br/>(S3 Downloader)<br/>offline mode only"]
                MainContainer["Main Container<br/>(LMEval Adapter + lm_eval)<br/>Entrypoint: python main.py"]
            end
            ConfigMap["/meta/job.json<br/>ConfigMap"]
            ModelSecret["model.auth.secret_ref<br/>API Key + HF Token"]
            DockerConfig["/tmp/.docker/config.json<br/>OCI Registry Auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress Only)"]
        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Inference["Inference Endpoint<br/>(vLLM / TGI)<br/>HTTP/HTTPS<br/>TLS 1.2+ (custom CA)<br/>Bearer Token"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        OCIRegistry["OCI Registry (Quay)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Auth"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>AWS IAM"]
        MLflow["MLflow Server<br/>HTTP/HTTPS<br/>TLS 1.2+<br/>configurable auth"]
    end

    %% Operator flow
    Operator -->|"Creates K8s Job"| JobPod

    %% ConfigMap and Secrets
    ConfigMap -->|"job spec"| MainContainer
    ModelSecret -->|"credentials"| MainContainer
    DockerConfig -->|"registry auth"| MainContainer

    %% Egress flows
    MainContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Status callbacks"| EvalHub
    MainContainer -->|"HTTP(S)/configurable<br/>TLS 1.2+ custom CA<br/>Bearer Token<br/>Evaluation prompts"| Inference
    MainContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Datasets + tokenizers"| HFHub
    MainContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker auth<br/>skopeo push"| OCIRegistry
    MainContainer -->|"HTTP(S)/configurable<br/>TLS 1.2+<br/>Metrics export"| MLflow
    InitContainer -->|"HTTPS/443<br/>TLS 1.2+ custom CA<br/>AWS IAM<br/>Offline test data"| S3

    %% Styling
    classDef cluster fill:#f0f0f0,stroke:#666,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef job fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef external fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Operator operator
    class InitContainer,MainContainer job
    class ConfigMap config
    class ModelSecret,DockerConfig secret
    class EvalHub,Inference,HFHub,OCIRegistry,S3,MLflow external
