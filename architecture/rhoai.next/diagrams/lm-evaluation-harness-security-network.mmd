graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph OperatorNS["Namespace: operator"]
            TrustyAI["TrustyAI Operator<br/>SA: trustyai-controller-manager<br/>Creates K8s Jobs"]
        end

        subgraph UserNS["Namespace: {user-namespace}"]
            subgraph JobPod["Batch Job Pod<br/>UID: 65532 (non-root) | CPU-only"]
                direction TB
                Adapter["LMEval EvalHub Adapter<br/>main.py<br/>CWE-22 path validation<br/>Credential redaction"]
                Harness["lm-evaluation-harness<br/>150+ benchmarks<br/>local-completions backend"]
                OCI["OCI Artifact Builder<br/>olot + skopeo"]
            end
            JobSpec["ConfigMap: job.json<br/>Mounted at /meta/job.json"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        ModelEndpoint["Model Inference Endpoint<br/>443/TCP HTTPS<br/>TLS (custom CA)<br/>Auth: Bearer (OPENAI_API_KEY)"]
        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer (HF_TOKEN)"]
        OCIRegistry["OCI Registry (Quay.io)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Docker config"]
        MLflow["MLflow Server<br/>443/TCP HTTPS<br/>TLS<br/>Auth: EvalHub SDK"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS (custom CA)<br/>Auth: AWS IAM"]
    end

    %% Internal flows
    TrustyAI -->|"Creates Job<br/>K8s API / ServiceAccount"| JobPod
    TrustyAI -->|"Mounts"| JobSpec
    JobSpec -->|"File I/O<br/>Path validated"| Adapter

    %% Egress flows
    Harness -->|"HTTPS/443<br/>TLS (custom CA)<br/>Bearer Token<br/>POST /v1/completions"| ModelEndpoint
    Adapter -->|"HTTPS/443<br/>TLS<br/>Bearer Token<br/>Status callbacks"| EvalHub
    Harness -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN<br/>Tokenizers + datasets"| HFHub
    OCI -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker auth<br/>skopeo push"| OCIRegistry
    Adapter -->|"HTTPS/443<br/>TLS<br/>EvalHub SDK<br/>Experiment runs"| MLflow
    Adapter -->|"HTTPS/443<br/>TLS (custom CA)<br/>AWS IAM<br/>Asset download"| S3

    %% Styling
    classDef cluster fill:#f0f0f0,stroke:#666,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef configmap fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class TrustyAI operator
    class Adapter,Harness,OCI internal
    class JobSpec configmap
    class ModelEndpoint,EvalHub,HFHub,OCIRegistry,MLflow,S3 external
