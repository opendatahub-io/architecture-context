graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph LlamaStackZone["LLAMA STACK SERVER (ClusterIP - Internal)"]
        direction TB
        LSServer["Llama Stack Server<br/>8321/TCP HTTP<br/>Plaintext<br/>No Auth (delegated)"]

        subgraph InlineZone["Inline Mode (in-process)"]
            InlineProvider["Inline Provider"]
            InferenceAPI["Inference API<br/>(LLM + Embeddings)"]
            DatasetIOAPI["DatasetIO API"]
        end

        subgraph RemoteZone["Remote Mode"]
            RemoteProvider["Remote Provider"]
        end
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (Internal)"]
        KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        KFPPod["KFP Pipeline Pod<br/>Image: ConfigMap-resolved<br/>Secrets mounted as env vars"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>(MinIO / AWS S3)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>Plaintext<br/>No Auth"| LSServer

    %% Inline flows (in-process)
    LSServer --> InlineProvider
    InlineProvider --> InferenceAPI
    InlineProvider --> DatasetIOAPI

    %% Remote flows
    LSServer --> RemoteProvider
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>(OpenShift OAuth)"| KFPAPI
    KFPAPI -->|"Launches"| KFPPod

    %% KFP Pod egress
    KFPPod -->|"HTTP/8321<br/>Configurable<br/>No Auth"| LSServer
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (Secret)"| S3

    %% Remote Provider egress
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RemoteProvider -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inline fill:#e1f5fe,stroke:#0288d1,stroke-width:1px
    classDef remote fill:#fff3e0,stroke:#ef6c00,stroke-width:1px
    classDef kfp fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class LSServer llamastack
    class InlineProvider,InferenceAPI,DatasetIOAPI inline
    class RemoteProvider remote
    class KFPAPI,KFPPod kfp
    class S3,K8sAPI externalservice
