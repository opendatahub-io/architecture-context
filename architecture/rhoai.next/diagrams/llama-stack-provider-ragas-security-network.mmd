graph TB
    subgraph External["CLIENT (External or Cluster-Internal)"]
        Client["Client Application"]
    end

    subgraph HostProcess["HOST PROCESS (Llama Stack Server)"]
        direction TB
        LLS["Llama Stack Server<br/>8321/TCP HTTP<br/>Auth: Host-managed"]

        subgraph InlineZone["Inline Mode (in-process)"]
            InlineProvider["Ragas Inline Provider<br/><i>inline::trustyai_ragas</i><br/>No network calls"]
            InlineWrappers["LLM + Embedding Wrappers<br/>In-process API calls"]
            InlineProvider --> InlineWrappers
        end

        subgraph RemoteZone["Remote Mode (KFP client)"]
            RemoteProvider["Ragas Remote Provider<br/><i>remote::trustyai_ragas</i><br/>Token: SecretStr (redacted)"]
        end

        LLS --> InlineProvider
        LLS --> RemoteProvider
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (Data Science Pipelines)"]
        direction TB
        KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]

        subgraph Pods["Ephemeral Pipeline Pods"]
            Pod1["retrieve_data Pod<br/>Image: ragas-provider-image<br/>(from ConfigMap)"]
            Pod2["run_ragas Pod<br/>Image: ragas-provider-image<br/>Env: S3 creds from Secret"]
        end

        KFPAPI --> Pod1
        KFPAPI --> Pod2
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>No TLS<br/>Auth: delegated"| LLS

    %% Remote Provider outbound
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>(OpenShift OAuth)"| KFPAPI
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3fs)"| S3
    RemoteProvider -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% KFP Pods outbound
    Pod1 -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LLS
    Pod2 -->|"HTTP/8321<br/>No TLS<br/>No Auth"| LLS
    Pod2 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (env vars)"| S3

    %% Styling
    classDef client fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef host fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inline fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef kfp fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client client
    class LLS host
    class InlineProvider,InlineWrappers inline
    class RemoteProvider remote
    class KFPAPI kfp
    class Pod1,Pod2 pod
    class S3,K8sAPI extservice
