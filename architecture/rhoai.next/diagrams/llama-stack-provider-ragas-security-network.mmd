graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS)"]
        Gateway["RHOAI Platform Gateway<br/>443/TCP → 8321/TCP<br/>TLS termination<br/>Platform RBAC"]
    end

    subgraph Application["APPLICATION (Llama Stack Server Pod)"]
        direction TB

        subgraph LlamaStack["Llama Stack Server :8321/TCP HTTP"]
            EvalAPI["Eval API<br/>/alpha/eval/*"]
            BenchmarkAPI["Benchmarks API<br/>/benchmarks/register"]
        end

        subgraph InlineProvider["Inline Provider (in-process)"]
            InlineEval["RagasEvaluatorInline<br/>In-process LLM/embed calls"]
        end

        subgraph RemoteProvider["Remote Provider (KFP)"]
            RemoteEval["RagasEvaluatorRemote<br/>Pipeline submission + S3 results"]
        end
    end

    subgraph InferenceBackends["INFERENCE BACKENDS"]
        Ollama["Ollama<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
        vLLM["vLLM<br/>8443/TCP HTTPS<br/>TLS configurable<br/>Bearer Token"]
    end

    subgraph PlatformServices["PLATFORM SERVICES (Remote Mode)"]
        KFP["Kubeflow Pipelines API<br/>443/TCP HTTPS<br/>TLS<br/>Bearer Token"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>SA Token / kubeconfig"]
    end

    subgraph KFPExecution["KFP PIPELINE PODS (Remote Mode)"]
        RetrieveData["KFP: retrieve_data<br/>→ 8321/TCP HTTP"]
        RunRagas["KFP: run_ragas_evaluation<br/>→ 8321/TCP HTTP<br/>→ 443/TCP HTTPS (S3)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS<br/>Platform RBAC"| Gateway
    Gateway -->|"HTTP/8321<br/>Plaintext<br/>No app-level auth"| EvalAPI

    EvalAPI --> InlineEval
    EvalAPI --> RemoteEval

    InlineEval -->|"HTTP/11434<br/>No encryption"| Ollama
    InlineEval -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| vLLM

    RemoteEval -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| KFP
    RemoteEval -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    KFP -.->|"schedules"| RetrieveData
    KFP -.->|"schedules"| RunRagas
    RetrieveData -->|"HTTP/8321"| EvalAPI
    RunRagas -->|"HTTP/8321"| EvalAPI
    RunRagas -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inference fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kfppod fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class EvalAPI,BenchmarkAPI,InlineEval,RemoteEval application
    class Ollama,vLLM inference
    class KFP,K8sAPI platform
    class RetrieveData,RunRagas kfppod
    class S3 externalservice
