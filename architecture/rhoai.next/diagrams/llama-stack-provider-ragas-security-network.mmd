graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph LLSProcess["Llama Stack Server Process"]
            direction TB

            subgraph InlineZone["Inline Provider Zone (in-process)"]
                InlineProvider["Ragas Inline Provider<br/><i>inline::trustyai_ragas</i><br/>max_workers=1"]
                LLMWrapper["LlamaStackInlineLLM"]
                EmbWrapper["LlamaStackInlineEmbeddings"]
                InlineProvider --> LLMWrapper
                InlineProvider --> EmbWrapper
            end

            subgraph RemoteZone["Remote Provider Zone (in-process)"]
                RemoteProvider["Ragas Remote Provider<br/><i>remote::trustyai_ragas</i><br/>SecretStr token handling"]
            end

            InferenceAPI["Inference API<br/>(in-process)"]
            DatasetIO["DatasetIO API<br/>(in-process)"]

            LLMWrapper --> InferenceAPI
            EmbWrapper --> InferenceAPI
            InlineProvider --> DatasetIO
        end

        subgraph KFPPods["KFP Pipeline Pods (Ephemeral)"]
            Pod1["retrieve_data<br/>SA: pipeline runner"]
            Pod2["run_ragas<br/>SA: pipeline runner<br/>Secret env: S3 creds"]
            Pod1 --> Pod2
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        KFPAPI["Kubeflow Pipelines API<br/>443/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token (OAuth)"]
        S3["S3 Object Storage<br/>443/TCP<br/>HTTPS TLS 1.2+<br/>AWS IAM credentials"]
    end

    subgraph DevOnly["DEV ONLY (non-production)"]
        Ollama["Ollama Server<br/>11434/TCP<br/>HTTP<br/>No Auth"]
    end

    %% Remote Provider egress
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SecretStr)"| KFPAPI
    RemoteProvider -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3fs)"| S3

    %% KFP Pod egress
    Pod1 -->|"HTTP/8321<br/>No encryption<br/>No auth"| LLSProcess
    Pod2 -->|"HTTP/8321<br/>No encryption<br/>No auth"| LLSProcess
    Pod2 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (env vars)"| S3

    %% Dev only
    LLSProcess -.->|"HTTP/11434<br/>No encryption<br/>No auth<br/>(dev only)"| Ollama

    %% Styling
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef inprocess fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef ephemeral fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000
    classDef devonly fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray:5 5,color:#000

    class InlineProvider,RemoteProvider inprocess
    class LLMWrapper,EmbWrapper,InferenceAPI,DatasetIO inprocess
    class Pod1,Pod2 ephemeral
    class K8sAPI,KFPAPI,S3 external
    class Ollama devonly
