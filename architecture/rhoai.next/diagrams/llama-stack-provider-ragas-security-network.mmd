graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client"]
    end

    subgraph LlamaStack["LLAMA STACK SERVER (Cluster-Internal)"]
        direction TB
        LLS["Llama Stack Server<br/>8321/TCP HTTP<br/>Eval API: /alpha/eval/*"]

        subgraph InlineMode["INLINE MODE (in-process, no network)"]
            InlineProvider["Ragas Inline Provider<br/>max_workers=1<br/>asyncio.to_thread()"]
            LLMWrap["LlamaStackInlineLLM"]
            EmbedWrap["LlamaStackInlineEmbeddings"]
            DatasetIO["DatasetIO API"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph RemoteMode["REMOTE MODE"]
            RemoteProvider["Ragas Remote Provider<br/>Token: Pydantic SecretStr"]
        end

        subgraph DSPNamespace["DSP Pipeline Namespace"]
            KFP["Kubeflow Pipelines API<br/>/apis/v2beta1/*<br/>Bearer Token auth"]
            Pod1["KFP Pod: retrieve_data<br/>Image: ragas-provider-image"]
            Pod2["KFP Pod: run_ragas<br/>Image: ragas-provider-image<br/>S3 creds: env vars from Secret"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ConfigMap: trustyai-service-operator-config"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Object Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM"]
        Ollama["Ollama Server (dev only)<br/>11434/TCP HTTP<br/>No auth"]
    end

    %% External to Llama Stack
    Client -->|"HTTP/8321<br/>No encryption<br/>Auth: delegated"| LLS

    %% Inline flows (in-process)
    LLS -.->|"in-process"| InlineProvider
    InlineProvider -.->|"in-process"| LLMWrap
    InlineProvider -.->|"in-process"| EmbedWrap
    InlineProvider -.->|"in-process"| DatasetIO

    %% Remote flows
    LLS -.->|"in-process"| RemoteProvider
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth)"| KFP
    KFP -->|"schedules"| Pod1
    KFP -->|"schedules"| Pod2
    Pod1 -->|"HTTP/8321<br/>No encryption<br/>No auth"| LLS
    Pod2 -->|"HTTP/8321<br/>No encryption<br/>No auth"| LLS
    Pod2 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3fs)"| S3
    RemoteProvider -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inlinecomp fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef remotecomp fill:#ffe6cc,stroke:#d79b00,stroke-width:1px

    class Client external
    class LLS llamastack
    class InlineProvider,LLMWrap,EmbedWrap,DatasetIO inlinecomp
    class RemoteProvider remotecomp
    class KFP,Pod1,Pod2,K8sAPI cluster
    class S3,Ollama externalservice
