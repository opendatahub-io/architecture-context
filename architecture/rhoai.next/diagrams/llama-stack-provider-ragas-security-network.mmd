graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(Data Scientist / API Consumer)"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (No Service Mesh / No mTLS)"]
        direction TB

        subgraph NS_LlamaStack["Namespace: (deployment namespace)"]
            LlamaStack["Llama Stack Server<br/>+ llama-stack-provider-ragas<br/>Port: 8321/TCP<br/>Protocol: HTTP<br/>Encryption: None<br/>Auth: None (Llama Stack auth)<br/>Image: UBI9/Python 3.12"]
        end

        subgraph NS_Inference["Namespace: (inference namespace)"]
            Ollama["Ollama / vLLM<br/>Port: 11434/TCP (Ollama) or custom (vLLM)<br/>Protocol: HTTP<br/>Encryption: None (configurable for vLLM)<br/>Auth: None (optional API token for vLLM)"]
        end

        subgraph NS_KFP["Namespace: KUBEFLOW_NAMESPACE"]
            KFPPod["KFP Pipeline Pod<br/>(retrieve_data + run_ragas)<br/>Image: quay.io/trustyai/llama-stack-provider-ragas<br/>Secrets: AWS creds mounted as env vars"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Cluster)"]
        KFP["Kubeflow Pipelines API<br/>Port: 443/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: Bearer Token (OAuth)"]
        K8sAPI["Kubernetes API Server<br/>Port: 6443/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: Service Account Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>(AWS S3 / MinIO)<br/>Port: 443/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: AWS IAM credentials"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>No Encryption<br/>No Auth"| LlamaStack

    %% Llama Stack to Inference Backend
    LlamaStack -->|"HTTP/11434<br/>No Encryption<br/>No Auth"| Ollama

    %% Llama Stack (Remote Provider) to KFP
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KFP

    %% Llama Stack to Kubernetes API
    LlamaStack -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token / kubeconfig"| K8sAPI

    %% Llama Stack to S3 (result retrieval)
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3fs)"| S3

    %% KFP schedules pods
    KFP -->|"schedules"| KFPPod

    %% KFP Pod back to Llama Stack
    KFPPod -->|"HTTP/8321<br/>No Encryption<br/>No Auth"| LlamaStack

    %% KFP Pod to S3
    KFPPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (env vars)"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef clusterinternal fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#ff6666,stroke:#cc0000,stroke-width:3px,color:#fff

    class Client external
    class LlamaStack,Ollama,KFPPod clusterinternal
    class KFP,K8sAPI platform
    class S3 externalservice
