graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist"]
    end

    subgraph LlamaStackProcess["LLAMA STACK SERVER PROCESS (Port 8321)"]
        direction TB
        EvalAPI["Eval API<br/>/alpha/eval/*<br/>8321/TCP HTTP<br/>Auth: None (configurable)"]

        subgraph Provider["llama-stack-provider-ragas (Plugin)"]
            direction LR
            InlineProvider["RagasEvaluatorInline<br/>inline::trustyai_ragas<br/>(in-process execution)"]
            RemoteProvider["RagasEvaluatorRemote<br/>remote::trustyai_ragas<br/>(KFP pipeline execution)"]
        end

        InferenceAPI["Inference API<br/>(in-process)"]
        DatasetIOAPI["DatasetIO API<br/>(in-process)"]
    end

    subgraph KFPExecution["KFP PIPELINE POD (Remote Execution)"]
        direction TB
        RetrieveData["retrieve_data<br/>component"]
        RunRagas["run_ragas<br/>component<br/>(LlamaStackRemoteLLM<br/>LlamaStackRemoteEmbeddings)"]
        RetrieveData --> RunRagas
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        KFP["Kubeflow Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No TLS, No Auth<br/>(sample distro only)"]
    end

    subgraph Secrets["SECRETS (Manual Provisioning)"]
        direction LR
        S3Creds["S3 Credentials<br/>(AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY)"]
        KFPToken["kubeflow-pipelines-token<br/>(Bearer Token)"]
        InferSecret["llama-stack-inference-<br/>model-secret<br/>(vLLM URL, API token)"]
        AWSCreds["aws-credentials<br/>(AWS creds for pod)"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>No TLS<br/>No Auth"| EvalAPI

    %% Internal flows
    EvalAPI --> InlineProvider
    EvalAPI --> RemoteProvider
    InlineProvider -->|"in-process<br/>Python call"| InferenceAPI
    InlineProvider -->|"in-process<br/>Python call"| DatasetIOAPI

    %% Remote provider egress
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KFP
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RemoteProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% KFP pod flows (security concerns)
    KFP -->|schedules| RetrieveData
    RetrieveData -->|"HTTP/8321<br/>⚠ No TLS<br/>⚠ No Auth"| DatasetIOAPI
    RunRagas -->|"HTTP/8321<br/>⚠ No TLS<br/>⚠ No Auth"| InferenceAPI
    RunRagas -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Secret references
    S3Creds -.->|injected via<br/>use_secret_as_env| RunRagas
    KFPToken -.->|env var| RemoteProvider
    AWSCreds -.->|mounted| RetrieveData

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef server fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef provider fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef api fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef kfp fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#ff6b6b,stroke:#c0392b,stroke-width:2px,color:#fff

    class Client external
    class EvalAPI api
    class InlineProvider,RemoteProvider provider
    class InferenceAPI,DatasetIOAPI api
    class RetrieveData,RunRagas kfp
    class KFP,S3,K8sAPI,Ollama externalservice
    class S3Creds,KFPToken,InferSecret,AWSCreds secrets
