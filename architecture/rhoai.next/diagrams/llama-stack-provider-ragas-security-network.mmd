graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AppBoundary["LLAMA STACK SERVER (Application Boundary)"]
        direction TB
        LlamaStack["Llama Stack Server<br/>8321/TCP HTTP<br/>Auth: None (configurable)"]

        subgraph InlineZone["Inline Provider (in-process)"]
            InlineEval["RagasEvaluatorInline<br/>ragas.evaluate() in asyncio.to_thread<br/>All calls in-process (no network)"]
        end

        subgraph RemoteZone["Remote Provider"]
            RemoteEval["RagasEvaluatorRemote<br/>Constructs KFP pipeline<br/>Polls status, fetches results"]
        end
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (Internal Platform)"]
        direction TB
        KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]

        subgraph PipelinePods["Pipeline Execution"]
            Step1["KFP Pod: retrieve_data<br/>Base image from ConfigMap"]
            Step2["KFP Pod: run_ragas<br/>Mounts AWS Secret"]
        end

        KFPAPI --> Step1
        Step1 --> Step2
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No TLS, No Auth<br/>(sample distro only)"]
    end

    %% Client to Llama Stack
    Client -->|"HTTP/8321<br/>No TLS ⚠️<br/>No Auth (configurable)"| LlamaStack

    %% Llama Stack internal routing
    LlamaStack --> InlineEval
    LlamaStack --> RemoteEval

    %% Remote provider to KFP
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KFPAPI

    %% KFP pods callback to Llama Stack (security concern)
    Step1 -->|"HTTP/8321<br/>No TLS ⚠️<br/>No Auth ⚠️"| LlamaStack
    Step2 -->|"HTTP/8321<br/>No TLS ⚠️<br/>No Auth ⚠️"| LlamaStack

    %% KFP pods to S3
    Step2 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (Secret)"| S3

    %% Remote provider fetches results from S3
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3fs)"| S3

    %% ConfigMap resolution
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Ollama (sample only)
    LlamaStack -.->|"HTTP/11434<br/>No TLS<br/>No Auth"| Ollama

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef inline fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remote fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef kfp fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class LlamaStack appboundary
    class InlineEval inline
    class RemoteEval remote
    class KFPAPI,Step1,Step2 kfp
    class S3,K8sAPI,Ollama externalservice
