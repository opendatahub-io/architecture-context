graph TD
    subgraph SidecarSA["Service Account (per-component)"]
        SA["ServiceAccount<br/>(created by rhods-operator<br/>per component pod)"]
    end

    subgraph RBACBindings["Role Bindings (created by rhods-operator)"]
        CRB_TokenReview["ClusterRoleBinding<br/>(TokenReview access)"]
        CRB_SAR["ClusterRoleBinding<br/>(SubjectAccessReview access)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR_AuthN["ClusterRole<br/>(Authentication)"]
        CR_AuthZ["ClusterRole<br/>(Authorization)"]
    end

    subgraph APIResources["Kubernetes API Resources"]
        TokenReview["authentication.k8s.io<br/>TokenReview"]
        SAR["authorization.k8s.io<br/>SubjectAccessReview"]
    end

    %% Bindings
    SA -->|"bound via"| CRB_TokenReview
    SA -->|"bound via"| CRB_SAR
    CRB_TokenReview -->|"grants"| CR_AuthN
    CRB_SAR -->|"grants"| CR_AuthZ

    %% Permissions
    CR_AuthN -->|"create"| TokenReview
    CR_AuthZ -->|"create"| SAR

    subgraph HardcodedAuth["Hardcoded Authorization (kube-rbac-proxy)"]
        HardcodedRule["Hardcoded Authorizer"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["/metrics (GET)"]

        PromSA -->|"always allowed"| HardcodedRule
        HardcodedRule -->|"grants access to"| MetricsEndpoint
    end

    subgraph AuthMethods["Authentication Methods (auth mode)"]
        direction LR
        K8sToken["K8s ServiceAccount Token<br/>(via TokenReview API)"]
        OAuthToken["OAuth Bearer Token<br/>(via provider validation)"]
        JWTToken["JWT Bearer Token<br/>(via JWKS verification)"]
        BasicAuth["Basic Auth<br/>(htpasswd file)"]
        SessionCookie["Session Cookie<br/>(AES-CFB encrypted)"]
    end

    subgraph AuthzMethods["Authorization Methods (rbac mode)"]
        direction LR
        Hardcoded["Hardcoded<br/>(Prometheus SA)"]
        Static["Static Rules<br/>(YAML config)"]
        SARCheck["SubjectAccessReview<br/>(K8s API delegation)"]
    end

    subgraph OpenShiftAPIs["OpenShift-Specific API Access (auth mode)"]
        UserAPI["user.openshift.io/v1<br/>users/~<br/>Verbs: get"]
        OAuthTokenAPI["oauth.openshift.io/v1<br/>oauthaccesstokens<br/>Verbs: delete"]
    end

    SA -->|"auth mode uses"| AuthMethods
    SA -->|"rbac mode uses"| AuthzMethods

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR_AuthN fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthZ fill:#f5a623,stroke:#333,color:#fff
    style TokenReview fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style HardcodedRule fill:#ff6b6b,stroke:#333,color:#fff
    style PromSA fill:#4a90e2,stroke:#333,color:#fff
    style MetricsEndpoint fill:#7ed321,stroke:#333,color:#fff
    style UserAPI fill:#7ed321,stroke:#333,color:#fff
    style OAuthTokenAPI fill:#7ed321,stroke:#333,color:#fff
