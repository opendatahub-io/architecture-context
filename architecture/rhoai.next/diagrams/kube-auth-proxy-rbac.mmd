graph TD
    subgraph DeploymentModel["Deployment Model (RBAC configured by rhods-operator)"]
        Operator["rhods-operator<br/>(deploys sidecar, configures RBAC)"]
    end

    subgraph AuthModeRBAC["Auth Mode - Authentication Chain"]
        direction TB

        AuthSA["ServiceAccount<br/>(mounted in pod by operator)"]

        subgraph AuthChain["Multi-Layer Auth Chain (strict order)"]
            direction TB
            Layer1["1. K8s TokenReview<br/>(if --enable-k8s-token-validation)<br/>Validates K8s SA tokens<br/>via API server"]
            Layer2["2. OAuth Bearer<br/>Validates OAuth2 access tokens<br/>against OIDC provider"]
            Layer3["3. JWT Bearer<br/>(if --skip-jwt-bearer-tokens)<br/>Validates JWT tokens locally<br/>using OIDC JWKS"]
            Layer4["4. Basic Auth<br/>(if --htpasswd-file)<br/>Validates against htpasswd file"]
            Layer5["5. Stored Session<br/>Validates encrypted cookie<br/>or Redis session ticket"]

            Layer1 -->|"pass"| Layer2
            Layer2 -->|"pass"| Layer3
            Layer3 -->|"pass"| Layer4
            Layer4 -->|"pass"| Layer5
        end

        AuthSA -->|"used for<br/>TokenReview API calls"| Layer1
    end

    subgraph RBACModeAuthz["RBAC Mode - Authorization Chain"]
        direction TB

        RBACSA["ServiceAccount<br/>(mounted in pod by operator)"]

        subgraph AuthnLayer["Authentication (Delegating Authenticator)"]
            TokenReview["TokenReview<br/>(Bearer token → user identity)"]
            OIDCAuth["OIDC JWT Verification<br/>(if --oidc-issuer configured)"]
            X509Auth["x509 Client Certificate<br/>(if --client-ca-file configured)"]
        end

        subgraph AuthzLayer["Authorization (3-tier chain)"]
            direction TB
            Tier1["Tier 1: Hardcoded Metrics Authorizer<br/>Auto-allows:<br/>system:serviceaccount:<br/>openshift-monitoring:prometheus-k8s<br/>Path: /metrics"]
            Tier2["Tier 2: Static Authorizer<br/>Pre-configured rules from<br/>--config-file YAML"]
            Tier3["Tier 3: SubjectAccessReview<br/>Delegates to K8s API server<br/>Cache: 5min allow / 30s deny"]

            Tier1 -->|"not /metrics"| Tier2
            Tier2 -->|"no match"| Tier3
        end

        RBACSA -->|"used for<br/>TokenReview +<br/>SAR API calls"| AuthnLayer
        AuthnLayer --> AuthzLayer
    end

    subgraph K8sResources["Kubernetes API Resources Consumed"]
        TokenReviewAPI["authentication.k8s.io/v1<br/>TokenReview<br/>Verbs: create"]
        SARAPI["authorization.k8s.io/v1<br/>SubjectAccessReview<br/>Verbs: create"]
        OAuthTokenAPI["oauth.openshift.io/v1<br/>OAuthAccessToken<br/>Verbs: delete"]
    end

    %% Connections
    Operator -->|"creates SA +<br/>RoleBindings<br/>per component"| AuthSA
    Operator -->|"creates SA +<br/>RoleBindings<br/>per component"| RBACSA
    Layer1 -->|"HTTPS/443"| TokenReviewAPI
    Tier3 -->|"HTTPS/443"| SARAPI
    TokenReview -->|"HTTPS/443"| TokenReviewAPI

    subgraph PrometheusAccess["Auto-Allowed Metrics Access"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["/metrics endpoint<br/>8443/TCP HTTPS"]
        PromSA -->|"auto-allowed<br/>(hardcoded)"| MetricsEndpoint
    end

    %% Styling
    style Operator fill:#f5a623,stroke:#333,color:#fff
    style AuthSA fill:#4a90e2,stroke:#333,color:#fff
    style RBACSA fill:#4a90e2,stroke:#333,color:#fff
    style Layer1 fill:#85bbf0,stroke:#333
    style Layer2 fill:#85bbf0,stroke:#333
    style Layer3 fill:#85bbf0,stroke:#333
    style Layer4 fill:#85bbf0,stroke:#333
    style Layer5 fill:#85bbf0,stroke:#333
    style Tier1 fill:#7ed321,stroke:#333
    style Tier2 fill:#f5a623,stroke:#333
    style Tier3 fill:#e74c3c,stroke:#333,color:#fff
    style TokenReviewAPI fill:#dae8fc,stroke:#6c8ebf
    style SARAPI fill:#dae8fc,stroke:#6c8ebf
    style OAuthTokenAPI fill:#dae8fc,stroke:#6c8ebf
    style PromSA fill:#999,stroke:#333,color:#fff
    style MetricsEndpoint fill:#999,stroke:#333,color:#fff
