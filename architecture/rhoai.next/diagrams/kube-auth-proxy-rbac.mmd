graph TD
    subgraph Operator["rhods-operator (Provisions RBAC)"]
        OperatorController["Operator Controller<br/>Creates RBAC for sidecars"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        SA_Auth["SA: {component}-sa<br/>(auth mode sidecar)"]
        SA_RBAC["SA: {component}-sa<br/>(rbac mode sidecar)"]
    end

    subgraph RequiredPermissions["Required Cluster Permissions"]
        direction TB

        subgraph AuthnPerms["Authentication Permissions"]
            TokenReview["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        end

        subgraph AuthzPerms["Authorization Permissions"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
        end

        subgraph OAuthPerms["OpenShift OAuth Permissions (auth mode only)"]
            OAuthToken["oauth.openshift.io<br/>oauthaccesstokens<br/>Verbs: delete"]
        end
    end

    subgraph ProxyModes["Proxy Mode Usage"]
        direction TB
        AuthMode["kube-auth-proxy (auth mode)<br/>Uses: TokenReview + OAuthToken"]
        RBACMode["kube-rbac-proxy (rbac mode)<br/>Uses: TokenReview + SAR"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms Supported"]
        direction TB
        BearerToken["Bearer Token<br/>(K8s SA / OAuth2)"]
        ClientCert["X.509 Client Certificate<br/>(client-ca-file)"]
        OIDCJWT["OIDC JWT<br/>(oidc-issuer verification)"]
        SessionCookie["OAuth2 Session Cookie<br/>(AES-CFB encrypted)"]
        BasicAuth["Basic Auth<br/>(htpasswd file)"]
    end

    subgraph Secrets["Secrets Required"]
        direction TB
        CookieSecret["cookie-secret<br/>Type: Opaque<br/>Purpose: AES-CFB session encryption<br/>Rotate: Manual"]
        ClientSecret["client-secret<br/>Type: Opaque<br/>Purpose: OAuth2 client credentials<br/>Rotate: Manual"]
        TLSCert["tls-cert + tls-key<br/>Type: kubernetes.io/tls<br/>Purpose: kube-rbac-proxy HTTPS<br/>Rotate: cert-manager"]
    end

    %% Operator provisions RBAC
    OperatorController -->|"creates ClusterRole<br/>+ ClusterRoleBinding"| TokenReview
    OperatorController -->|"creates ClusterRole<br/>+ ClusterRoleBinding"| SAR
    OperatorController -->|"creates ClusterRole<br/>+ ClusterRoleBinding"| OAuthToken
    OperatorController -->|"provisions"| CookieSecret
    OperatorController -->|"provisions"| ClientSecret

    %% SA bindings
    SA_Auth -->|"bound to"| TokenReview
    SA_Auth -->|"bound to"| OAuthToken
    SA_RBAC -->|"bound to"| TokenReview
    SA_RBAC -->|"bound to"| SAR

    %% Mode to auth mechanisms
    AuthMode -->|"supports"| BearerToken
    AuthMode -->|"supports"| SessionCookie
    AuthMode -->|"supports"| BasicAuth
    AuthMode -->|"supports"| OIDCJWT
    RBACMode -->|"supports"| BearerToken
    RBACMode -->|"supports"| ClientCert
    RBACMode -->|"supports"| OIDCJWT

    %% Styling
    style OperatorController fill:#f5a623,stroke:#333,color:#fff
    style SA_Auth fill:#4a90e2,stroke:#333,color:#fff
    style SA_RBAC fill:#4a90e2,stroke:#333,color:#fff
    style TokenReview fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style OAuthToken fill:#7ed321,stroke:#333,color:#fff
    style AuthMode fill:#4a90e2,stroke:#333,color:#fff
    style RBACMode fill:#2c6cb0,stroke:#333,color:#fff
    style BearerToken fill:#e8e8e8,stroke:#333
    style ClientCert fill:#e8e8e8,stroke:#333
    style OIDCJWT fill:#e8e8e8,stroke:#333
    style SessionCookie fill:#e8e8e8,stroke:#333
    style BasicAuth fill:#e8e8e8,stroke:#333
    style CookieSecret fill:#ff6b6b,stroke:#333,color:#fff
    style ClientSecret fill:#ff6b6b,stroke:#333,color:#fff
    style TLSCert fill:#ff6b6b,stroke:#333,color:#fff
