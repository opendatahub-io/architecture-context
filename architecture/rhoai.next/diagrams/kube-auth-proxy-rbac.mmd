graph TD
    subgraph "Deployment Context"
        Operator["rhods-operator<br/>(Deploying Operator)<br/>Configures all RBAC"]
    end

    subgraph "Service Account"
        SA["kube-auth-proxy SA<br/>(configured per-deployment<br/>by rhods-operator)"]
    end

    subgraph "Required ClusterRole Permissions"
        direction TB
        TokenReviewRole["ClusterRole<br/>(TokenReview Access)"]
        OAuthTokenRole["ClusterRole<br/>(OAuthAccessToken Access)"]
        UserInfoRole["ClusterRole<br/>(User Info Access)"]
    end

    subgraph "API Resources - Kubernetes"
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
    end

    subgraph "API Resources - OpenShift OAuth"
        OAuthAccessTokens["oauth.openshift.io<br/>oauthaccesstokens"]
    end

    subgraph "API Resources - OpenShift User"
        Users["user.openshift.io<br/>users"]
    end

    subgraph "Authentication Mechanisms (Middleware Chain Order)"
        direction TB
        Auth1["1. K8s TokenReview<br/>SA token → TokenReview API<br/>(highest priority)"]
        Auth2["2. OAuth/JWT Bearer<br/>JWT via JWKS /<br/>sha256~ via OpenShift API"]
        Auth3["3. Basic Auth<br/>htpasswd file validation"]
        Auth4["4. Stored Session<br/>AES-encrypted cookie /<br/>Redis session lookup"]
        Auth1 --> Auth2 --> Auth3 --> Auth4
    end

    subgraph "Authorization Policies"
        direction TB
        EmailDomain["Email Domain Allowlist<br/>(--email-domain)"]
        AuthEmails["Authenticated Emails File<br/>(--authenticated-emails-file)"]
        GroupAuth["Group-Based Authorization<br/>(--allowed-group)"]
        TrustedIP["Trusted IP Bypass<br/>(--trusted-ip)"]
        ExtAuthzParams["ext_authz Per-Request Params<br/>(allowed_groups, allowed_emails,<br/>allowed_email_domains)"]
    end

    subgraph "Secrets"
        CookieSecret["Cookie Secret<br/>AES-128/192/256 key<br/>(16/24/32 bytes)"]
        OAuthCreds["OAuth Client Credentials<br/>client_id / client_secret"]
        TLSCert["TLS Certificate<br/>kubernetes.io/tls<br/>(cert-manager or operator)"]
        JWTKey["JWT Signing Key<br/>(optional, PEM format)"]
        RedisCreds["Redis Credentials<br/>(optional, username/password)"]
    end

    %% Operator configures everything
    Operator -->|"creates & binds"| SA
    Operator -->|"provisions"| CookieSecret
    Operator -->|"provisions"| OAuthCreds
    Operator -->|"provisions"| TLSCert

    %% RBAC bindings
    SA -->|"bound via ClusterRoleBinding"| TokenReviewRole
    SA -->|"bound via ClusterRoleBinding"| OAuthTokenRole
    SA -->|"bound via ClusterRoleBinding"| UserInfoRole

    %% Permissions
    TokenReviewRole -->|"create"| TokenReview
    OAuthTokenRole -->|"delete"| OAuthAccessTokens
    UserInfoRole -->|"get"| Users

    %% Styling
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style TokenReviewRole fill:#f5a623,stroke:#333
    style OAuthTokenRole fill:#f5a623,stroke:#333
    style UserInfoRole fill:#f5a623,stroke:#333
    style TokenReview fill:#7ed321,stroke:#333
    style OAuthAccessTokens fill:#7ed321,stroke:#333
    style Users fill:#7ed321,stroke:#333
    style Auth1 fill:#4a90e2,stroke:#333,color:#fff
    style Auth2 fill:#4a90e2,stroke:#333,color:#fff
    style Auth3 fill:#4a90e2,stroke:#333,color:#fff
    style Auth4 fill:#4a90e2,stroke:#333,color:#fff
    style EmailDomain fill:#e1d5e7,stroke:#9673a6
    style AuthEmails fill:#e1d5e7,stroke:#9673a6
    style GroupAuth fill:#e1d5e7,stroke:#9673a6
    style TrustedIP fill:#e1d5e7,stroke:#9673a6
    style ExtAuthzParams fill:#e1d5e7,stroke:#9673a6
    style CookieSecret fill:#f8cecc,stroke:#b85450
    style OAuthCreds fill:#f8cecc,stroke:#b85450
    style TLSCert fill:#f8cecc,stroke:#b85450
    style JWTKey fill:#f8cecc,stroke:#b85450
    style RedisCreds fill:#f8cecc,stroke:#b85450
