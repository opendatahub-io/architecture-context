graph TD
    subgraph Deployment["Deployment (managed by rhods-operator)"]
        SA["ServiceAccount<br/>(per-component, created by rhods-operator)"]
    end

    subgraph RequiredPermissions["Required RBAC Permissions"]
        direction TB

        subgraph AuthnPerms["Authentication Permissions"]
            TR["authentication.k8s.io<br/>tokenreviews"]
        end

        subgraph AuthzPerms["Authorization Permissions (rbac mode)"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        end
    end

    subgraph HardcodedAccess["Hardcoded Authorizer (kube-rbac-proxy)"]
        direction TB
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["/metrics<br/>Method: GET"]
        PromSA -->|"ALWAYS ALLOWED<br/>(no SAR check)"| MetricsEndpoint
    end

    subgraph AuthorizationFlow["Authorization Decision Flow (rbac mode)"]
        direction TB
        IncomingReq["Incoming Request<br/>with Bearer Token"]
        TokenReviewStep["Step 1: TokenReview<br/>(identify user)"]
        UnionAuth["Step 2: Union Authorizer<br/>(any-allow policy)"]

        HardcodedCheck["Hardcoded Authorizer<br/>(Prometheus → /metrics)"]
        StaticCheck["Static Authorizer<br/>(YAML config rules)"]
        SARCheck["SAR Authorizer<br/>(K8s API delegation)<br/>Cache: 5m pos / 30s neg"]

        IncomingReq --> TokenReviewStep
        TokenReviewStep --> UnionAuth
        UnionAuth --> HardcodedCheck
        UnionAuth --> StaticCheck
        UnionAuth --> SARCheck
    end

    subgraph Secrets["Secrets (provisioned by platform operator)"]
        direction TB
        CookieSecret["cookie-secret<br/>Type: Opaque<br/>AES key (16/24/32 bytes)<br/>Auto-Rotate: No"]
        ClientSecret["client-secret<br/>Type: Opaque<br/>OAuth2 client secret<br/>Auto-Rotate: No"]
        TLSCert["tls-cert<br/>Type: kubernetes.io/tls<br/>HTTPS listener cert<br/>Source: cert-manager / self-signed"]
        RedisPassword["redis-password (optional)<br/>Type: Opaque<br/>Redis auth credentials<br/>Auto-Rotate: No"]
    end

    SA -->|"create"| TR
    SA -->|"create"| SAR

    SA -.-|"mounts"| CookieSecret
    SA -.-|"mounts"| ClientSecret
    SA -.-|"mounts"| TLSCert
    SA -.-|"mounts"| RedisPassword

    style SA fill:#4a90e2,color:#fff
    style TR fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style PromSA fill:#f5a623,color:#fff
    style MetricsEndpoint fill:#f5a623,color:#fff
    style IncomingReq fill:#4a90e2,color:#fff
    style TokenReviewStep fill:#4a90e2,color:#fff
    style UnionAuth fill:#4a90e2,color:#fff
    style HardcodedCheck fill:#f5a623,color:#fff
    style StaticCheck fill:#d5e8d4,stroke:#82b366
    style SARCheck fill:#d5e8d4,stroke:#82b366
    style CookieSecret fill:#f8cecc,stroke:#b85450
    style ClientSecret fill:#f8cecc,stroke:#b85450
    style TLSCert fill:#f8cecc,stroke:#b85450
    style RedisPassword fill:#f8cecc,stroke:#b85450
