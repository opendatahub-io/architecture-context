graph TD
    subgraph Deployment["Deployment Context"]
        Operator["rhods-operator<br/>(deploying operator)"]
        Operator -->|"configures RBAC for"| SA
    end

    subgraph ServiceAccounts["Service Account"]
        SA["Service Account<br/>(configured by rhods-operator)<br/>Namespace: component namespace"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["ClusterRoleBinding or RoleBinding<br/>(configured by rhods-operator)"]
    end

    subgraph Roles["Cluster Role Permissions"]
        CR["ClusterRole<br/>(configured by rhods-operator)"]
    end

    subgraph APIResources["API Resources Accessed"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/><b>Verbs: create</b>"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms Enforced"]
        direction TB
        OIDC_Auth["OIDC Authentication<br/>JWT verification via JWKS<br/>Client ID/Secret"]
        OS_Auth["OpenShift OAuth<br/>Authorization code flow<br/>Client ID/Secret"]
        K8s_Auth["K8s SA Token<br/>TokenReview API validation"]
        Basic_Auth["Basic Auth<br/>htpasswd file"]
        Cookie_Auth["Session Cookie<br/>AES-GCM encrypted"]
    end

    subgraph AuthZPolicies["Authorization Policies"]
        direction TB
        AllowedGroups["allowed_groups<br/>Group membership check"]
        AllowedEmails["allowed_emails<br/>Email allowlist"]
        AllowedDomains["allowed_email_domains<br/>Domain allowlist"]
    end

    subgraph Secrets["Secrets Required"]
        direction TB
        CookieSecret["cookie-secret (Opaque)<br/>Session encryption key<br/>AES-GCM/CFB + HMAC"]
        ClientSecret["client-secret (Opaque)<br/>OAuth2 client secret<br/>OIDC/OpenShift provider"]
        TLSSecret["tls-cert/tls-key (kubernetes.io/tls)<br/>HTTPS listener cert+key"]
        RedisSecret["redis-password (Opaque)<br/>Redis auth (optional)"]
        HtpasswdSecret["htpasswd-file (Opaque)<br/>Basic auth file (optional)"]
        SAToken["SA Token (auto-mounted)<br/>kubernetes.io/service-account-token<br/>In-cluster K8s auth"]
    end

    subgraph InjectedHeaders["Identity Headers Injected to Upstream"]
        direction TB
        XForwardedUser["X-Forwarded-User"]
        XForwardedEmail["X-Forwarded-Email"]
        XForwardedGroups["X-Forwarded-Groups"]
        XForwardedPref["X-Forwarded-Preferred-Username"]
    end

    %% RBAC flow
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews

    %% Auth mechanisms feed into authZ
    OIDC_Auth --> AuthZPolicies
    OS_Auth --> AuthZPolicies
    K8s_Auth --> AuthZPolicies
    Basic_Auth --> AuthZPolicies
    Cookie_Auth --> AuthZPolicies

    %% AuthZ produces headers
    AuthZPolicies -->|"on success"| InjectedHeaders

    %% Secrets used by auth mechanisms
    CookieSecret -.->|"used by"| Cookie_Auth
    ClientSecret -.->|"used by"| OIDC_Auth
    ClientSecret -.->|"used by"| OS_Auth
    TLSSecret -.->|"used by"| SA
    SAToken -.->|"used by"| K8s_Auth
    HtpasswdSecret -.->|"used by"| Basic_Auth

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style CRB fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style Operator fill:#999,color:#fff

    style OIDC_Auth fill:#4a90e2,color:#fff
    style OS_Auth fill:#4a90e2,color:#fff
    style K8s_Auth fill:#4a90e2,color:#fff
    style Basic_Auth fill:#4a90e2,color:#fff
    style Cookie_Auth fill:#4a90e2,color:#fff

    style AllowedGroups fill:#e8f4fd,stroke:#4a90e2
    style AllowedEmails fill:#e8f4fd,stroke:#4a90e2
    style AllowedDomains fill:#e8f4fd,stroke:#4a90e2

    style CookieSecret fill:#fce4ec,stroke:#c62828
    style ClientSecret fill:#fce4ec,stroke:#c62828
    style TLSSecret fill:#fce4ec,stroke:#c62828
    style RedisSecret fill:#fce4ec,stroke:#c62828
    style HtpasswdSecret fill:#fce4ec,stroke:#c62828
    style SAToken fill:#fce4ec,stroke:#c62828

    style XForwardedUser fill:#d5e8d4,stroke:#82b366
    style XForwardedEmail fill:#d5e8d4,stroke:#82b366
    style XForwardedGroups fill:#d5e8d4,stroke:#82b366
    style XForwardedPref fill:#d5e8d4,stroke:#82b366
