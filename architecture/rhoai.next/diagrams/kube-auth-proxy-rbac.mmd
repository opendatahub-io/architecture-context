graph TD
    subgraph Operator["Provisioned by rhods-operator"]
        direction TB
        SA["ServiceAccount<br/>(per-component, managed<br/>by rhods-operator)"]
        CRB["ClusterRoleBinding<br/>(per-component)"]
        CR["ClusterRole<br/>(per-component)"]
    end

    subgraph RequiredPerms["Required API Permissions"]
        direction TB
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph HardcodedAuth["Hardcoded Authorization (kube-rbac-proxy)"]
        direction TB
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["/metrics endpoint<br/>GET method"]
    end

    subgraph AuthModes["Authentication Methods"]
        direction TB
        OIDCAuth["OIDC JWT<br/>Verification"]
        OAuthAuth["OpenShift OAuth<br/>Token Exchange"]
        BearerAuth["Bearer Token<br/>(K8s SA Token)"]
        CookieAuth["Session Cookie<br/>(AES-CFB encrypted)"]
        BasicAuth["Basic Auth<br/>(optional)"]
    end

    subgraph AuthzModes["Authorization Strategies (kube-rbac-proxy)"]
        direction TB
        UnionAuthz["Union Authorizer<br/>(any-allow policy)"]
        HardcodedAuthz["1. Hardcoded Authorizer<br/>(Prometheus scraping)"]
        StaticAuthz["2. Static Authorizer<br/>(YAML config rules)"]
        SARAuthz["3. SAR Authorizer<br/>(SubjectAccessReview)<br/>Cache: 5min+/30s-"]
    end

    %% RBAC flow
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReview
    CR -->|"create"| SAR

    %% Hardcoded rule
    PromSA -->|"always allowed"| MetricsEndpoint

    %% Auth methods feed into proxy
    OIDCAuth -->|"validates JWT"| SA
    OAuthAuth -->|"exchanges token"| SA
    BearerAuth -->|"TokenReview API"| TokenReview
    CookieAuth -->|"session lookup"| SA

    %% Authorization chain
    UnionAuthz --> HardcodedAuthz
    UnionAuthz --> StaticAuthz
    UnionAuthz --> SARAuthz
    SARAuthz -->|"delegates to<br/>K8s API"| SAR

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style CRB fill:#f5a623,color:#fff
    style TokenReview fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style PromSA fill:#e8e8e8,stroke:#333
    style MetricsEndpoint fill:#e8e8e8,stroke:#333
    style OIDCAuth fill:#dae8fc,stroke:#6c8ebf
    style OAuthAuth fill:#dae8fc,stroke:#6c8ebf
    style BearerAuth fill:#dae8fc,stroke:#6c8ebf
    style CookieAuth fill:#dae8fc,stroke:#6c8ebf
    style BasicAuth fill:#dae8fc,stroke:#6c8ebf
    style UnionAuthz fill:#fff2cc,stroke:#d6b656
    style HardcodedAuthz fill:#fff2cc,stroke:#d6b656
    style StaticAuthz fill:#fff2cc,stroke:#d6b656
    style SARAuthz fill:#fff2cc,stroke:#d6b656
