graph TD
    subgraph Deployment["Deployment by rhods-operator"]
        Operator["rhods-operator<br/>(provisions RBAC)"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        SA["Component Service Account<br/>(created by rhods-operator)"]
    end

    subgraph RequiredPermissions["Required RBAC Permissions<br/>(provisioned by operator, not in this repo)"]
        direction TB

        subgraph AuthN["Authentication Permissions"]
            TokenReview["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        end

        subgraph AuthZ["Authorization Permissions"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
        end
    end

    subgraph ProxyModes["Proxy Authentication Modes"]
        direction TB

        subgraph AuthModeAuth["Auth Mode (kube-auth-proxy)"]
            direction TB
            A1["1. K8s SA Token<br/>→ TokenReview API"]
            A2["2. JWT Bearer Token<br/>→ OIDC verification"]
            A3["3. Basic Auth<br/>→ htpasswd file"]
            A4["4. Session Cookie<br/>→ AES-CFB decrypt"]
            A1 --> A2 --> A3 --> A4
        end

        subgraph RBACModeAuth["RBAC Mode (kube-rbac-proxy)"]
            direction TB
            R1["1. Delegated TokenReview<br/>→ k8s.io/apiserver"]
            R2["2. OIDC JWT<br/>→ Direct verification"]
            R3["3. X.509 Client Cert<br/>→ CA validation"]
            R1 --> R2 --> R3
        end
    end

    subgraph AuthorizationPolicies["Authorization Enforcement"]
        direction TB
        EmailDomain["Email Domain Allowlist<br/>(auth mode)"]
        GroupRestrict["Group Restrictions<br/>(auth mode)"]
        ResourceAttrs["ResourceAttributes Mapping<br/>(rbac mode)<br/>HTTP → K8s resource attrs"]
        StaticRules["Static Authorization Rules<br/>(rbac mode, config file)"]
        MetricsAllow["OpenShift Monitoring Allow<br/>(rbac mode, hardcoded)"]
    end

    subgraph Endpoints["Protected Endpoints"]
        direction TB
        OAuthEndpoints["/oauth2/* endpoints<br/>Sign-in, callback, auth,<br/>userinfo, sign-out"]
        ProxyEndpoints["/* proxy endpoints<br/>All methods"]
        HealthEndpoints["/healthz, /ping, /ready<br/>Unauthenticated"]
    end

    %% Flows
    Operator -->|"creates"| SA
    Operator -->|"provisions via<br/>ClusterRole +<br/>ClusterRoleBinding"| RequiredPermissions
    SA -->|"uses permissions"| TokenReview
    SA -->|"uses permissions"| SAR

    A1 -->|"calls"| TokenReview
    R1 -->|"calls"| TokenReview
    R1 -->|"calls"| SAR

    AuthModeAuth -->|"enforces"| EmailDomain
    AuthModeAuth -->|"enforces"| GroupRestrict
    RBACModeAuth -->|"enforces"| ResourceAttrs
    RBACModeAuth -->|"enforces"| StaticRules
    RBACModeAuth -->|"enforces"| MetricsAllow

    AuthModeAuth -->|"protects"| OAuthEndpoints
    AuthModeAuth -->|"protects"| ProxyEndpoints
    RBACModeAuth -->|"protects"| ProxyEndpoints

    %% Styling
    style Operator fill:#e8e8e8,stroke:#333
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style TokenReview fill:#f5a623,stroke:#333
    style SAR fill:#f5a623,stroke:#333
    style A1 fill:#c8e6c9,stroke:#333
    style A2 fill:#c8e6c9,stroke:#333
    style A3 fill:#c8e6c9,stroke:#333
    style A4 fill:#c8e6c9,stroke:#333
    style R1 fill:#bbdefb,stroke:#333
    style R2 fill:#bbdefb,stroke:#333
    style R3 fill:#bbdefb,stroke:#333
    style EmailDomain fill:#fff3e0,stroke:#333
    style GroupRestrict fill:#fff3e0,stroke:#333
    style ResourceAttrs fill:#fff3e0,stroke:#333
    style StaticRules fill:#fff3e0,stroke:#333
    style MetricsAllow fill:#fff3e0,stroke:#333
    style OAuthEndpoints fill:#7ed321,stroke:#333,color:#fff
    style ProxyEndpoints fill:#7ed321,stroke:#333,color:#fff
    style HealthEndpoints fill:#7ed321,stroke:#333,color:#fff
