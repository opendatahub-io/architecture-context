graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>Data Scientists, API Consumers"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        direction TB
        GW["data-science-gateway<br/>Envoy-based Gateway<br/>443/TCP ext, TLS 1.2+"]
        KubeAuth["kube-auth-proxy<br/>Centralized OAuth2/OIDC + SAR<br/>Stateless replicas + Redis"]
        AuthorinoGW["Authorino<br/>API Key + TokenReview + OIDC JWT<br/>MaaS auth"]
    end

    subgraph NS_Operator["Namespace: redhat-ods-operator (OLM-managed)"]
        rhods_op["rhods-operator<br/>SA: rhods-operator<br/>Platform lifecycle controller"]
    end

    subgraph NS_Apps["Namespace: redhat-ods-applications (Platform Services)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            Dashboard_svc["RHOAI Dashboard<br/>SA: odh-dashboard<br/>8080/TCP"]
            KServe_ctrl["KServe Controller<br/>SA: kserve-controller-manager<br/>8080/TCP"]
            ModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>HTTPRoute + AuthPolicy mgmt"]
            KServe_LLM["KServe LLM Controller<br/>SA: kserve-llm-controller<br/>LLMInferenceService"]
        end

        subgraph SchedulingControllers["Scheduling & Training Controllers"]
            Kueue_ctrl["Kueue Controller<br/>SA: kueue-controller-manager<br/>8443/TCP metrics"]
            TrainingOp_ctrl["Training Operator<br/>SA: training-operator<br/>PyTorchJob controller"]
            Trainer_ctrl["Trainer Controller<br/>SA: trainer-controller<br/>TrainJob + TrainingRuntime"]
            CodeFlare_ctrl["CodeFlare Operator<br/>SA: codeflare-operator<br/>RayCluster lifecycle"]
            KubeRay_ctrl["KubeRay Operator<br/>SA: kuberay-operator<br/>Ray cluster mgmt"]
            Spark_ctrl["Spark Operator<br/>SA: spark-operator<br/>SparkApplication"]
        end

        subgraph PipelineControllers["Pipeline Controllers"]
            DSPO_ctrl["DSP Operator<br/>SA: data-science-pipelines-operator<br/>Pipeline lifecycle"]
        end

        subgraph RegistryControllers["Registry & Experiment Controllers"]
            ModelRegOp_ctrl["Model Registry Operator<br/>SA: model-registry-operator<br/>Registry lifecycle"]
            MLflowOp_ctrl["MLflow Operator<br/>SA: mlflow-operator<br/>Helm-as-template"]
            TrustyAIOp_ctrl["TrustyAI Operator<br/>SA: trustyai-service-operator<br/>LMEval + guardrails"]
            Feast_ctrl["Feast Operator<br/>SA: feast-operator<br/>Feature store"]
            LlamaStackOp_ctrl["Llama Stack Operator<br/>SA: llama-stack-operator<br/>API server lifecycle"]
        end

        subgraph InferenceGW["Inference Gateway"]
            GatewayAPIExt_svc["Gateway API Inference Ext<br/>SA: inference-gateway<br/>ext_proc scheduling"]
            MaaS_svc["Models as a Service<br/>SA: maas-controller<br/>Multi-tenant marketplace"]
            AIGateway_svc["AI Gateway Payload Proc<br/>SA: ai-gateway<br/>ext_proc guardrails"]
        end
    end

    subgraph NS_User["User Namespaces (per-project, RBAC isolated)"]
        direction TB
        InfSvc["InferenceServices<br/>vLLM, TGIS, MLServer,<br/>Caikit, OpenVINO pods"]
        llmd_pods["llm-d Pods<br/>Prefill + Decode pools<br/>EPP + routing sidecar"]
        Notebooks["Jupyter Notebooks<br/>Per-user workbenches"]
        TrainingJobs["Training Jobs<br/>PyTorchJob, TrainJob,<br/>RayCluster, SparkApp"]
        DSPAInstances["DSPA Instances<br/>API Server + Argo WF<br/>+ MariaDB + MLMD"]
        ModelRegInst["Model Registry Instances<br/>gRPC 9090 + REST 8080"]
        TrustyAIInst["TrustyAI Instances<br/>Explainability service"]
        FeastStore["Feast Feature Stores<br/>Online + offline stores"]
        MLflowInst["MLflow Instances<br/>Experiment tracking"]
    end

    subgraph NS_Istio["Namespace: istio-system"]
        Istiod["Istiod<br/>Control plane<br/>mTLS cert issuance"]
        IstioCNI["Istio CNI<br/>Pod network setup"]
    end

    subgraph NS_Knative["Namespace: knative-serving"]
        KnativeServing["Knative Serving<br/>Serverless scaling<br/>Activator + Autoscaler"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3-compatible Storage<br/>Model artifacts, pipeline data<br/>443/TCP HTTPS, AWS IAM/static creds"]
        ContainerReg["Container Registry<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS, Pull secrets"]
        K8sAPI["Kubernetes API Server<br/>CRD reconciliation<br/>443/TCP HTTPS, SA tokens"]
        ExternalLLM["External LLM Providers<br/>OpenAI, Azure, etc.<br/>443/TCP HTTPS, API keys"]
    end

    %% External to Ingress
    Clients -->|"HTTPS/443<br/>TLS 1.2+"| GW

    %% Gateway routing
    GW -->|"ext_authz<br/>EnvoyFilter"| KubeAuth
    GW -->|"AuthPolicy<br/>API keys"| AuthorinoGW
    GW -->|"HTTPRoute<br/>dashboard.*"| Dashboard_svc
    GW -->|"HTTPRoute<br/>model serving"| InfSvc
    GW -->|"HTTPRoute<br/>mlflow.*"| MLflowInst
    GW -->|"HTTPRoute<br/>model registry"| ModelRegInst
    GW -->|"ext_proc<br/>inference routing"| GatewayAPIExt_svc
    GW -->|"ext_proc<br/>guardrails"| AIGateway_svc

    %% Auth flows
    KubeAuth -->|"OAuth2/OIDC + SAR<br/>authenticated"| Dashboard_svc
    AuthorinoGW -->|"API key validated<br/>rate-limited"| MaaS_svc

    %% Platform operator
    rhods_op -->|"deploys components<br/>kustomize overlays"| NS_Apps
    rhods_op -->|"manages Gateway<br/>+ EnvoyFilters"| GW
    rhods_op -->|"HTTPS/443<br/>SA token"| K8sAPI

    %% Controller to user namespace
    KServe_ctrl -->|"creates Deployments<br/>Services, init containers"| InfSvc
    KServe_LLM -->|"creates LLM workloads<br/>InferencePool"| llmd_pods
    ModelCtrl -->|"creates HTTPRoute<br/>AuthPolicy, monitoring"| InfSvc
    Kueue_ctrl -->|"admission control<br/>quota enforcement"| TrainingJobs
    TrainingOp_ctrl -->|"creates worker pods<br/>headless Service"| TrainingJobs
    Trainer_ctrl -->|"creates workers<br/>TrainingRuntime"| TrainingJobs
    CodeFlare_ctrl -->|"lifecycle mgmt"| TrainingJobs
    KubeRay_ctrl -->|"Ray cluster<br/>head + workers"| TrainingJobs
    Spark_ctrl -->|"SparkApp<br/>driver + executors"| TrainingJobs
    DSPO_ctrl -->|"deploys DSP stack"| DSPAInstances
    ModelRegOp_ctrl -->|"deploys registry"| ModelRegInst
    MLflowOp_ctrl -->|"deploys MLflow"| MLflowInst
    TrustyAIOp_ctrl -->|"deploys TrustyAI"| TrustyAIInst
    Feast_ctrl -->|"deploys stores"| FeastStore
    LlamaStackOp_ctrl -->|"deploys API server"| NS_User

    %% Service mesh
    Istiod -->|"mTLS certs<br/>policy distribution"| InfSvc
    Istiod -->|"mTLS certs"| ModelRegInst
    KServe_ctrl -->|"VirtualService<br/>DestinationRule"| Istiod
    KServe_ctrl -->|"Knative Service<br/>serverless mode"| KnativeServing

    %% User namespace internal
    InfSvc -->|"gRPC/9090<br/>mTLS"| ModelRegInst
    DSPAInstances -->|"model deploy<br/>InferenceService CR"| KServe_ctrl
    DSPAInstances -->|"model metadata<br/>gRPC/9090"| ModelRegInst
    Notebooks -->|"pipeline submit<br/>KFP SDK"| DSPAInstances

    %% llm-d flows
    GatewayAPIExt_svc -->|"ext_proc scoring<br/>prefix cache + queue depth"| llmd_pods
    llmd_pods -->|"KV cache transfer<br/>NIXL/shared storage"| llmd_pods

    %% Guardrails
    AIGateway_svc -->|"input/output rails"| NS_User
    MaaS_svc -->|"model federation<br/>ExternalModel CR"| ExternalLLM

    %% Egress
    InfSvc -->|"HTTPS/443<br/>model download"| S3
    ModelRegInst -->|"HTTPS/443<br/>artifact refs"| S3
    DSPAInstances -->|"HTTPS/443<br/>artifact upload"| S3
    Notebooks -->|"HTTPS/443<br/>data access"| S3
    InfSvc -->|"HTTPS/443<br/>image pull"| ContainerReg
    Notebooks -->|"HTTPS/443<br/>image pull"| ContainerReg
    KServe_ctrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    Dashboard_svc -->|"HTTPS/443<br/>SA token"| K8sAPI
    Kueue_ctrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    AIGateway_svc -->|"HTTPS/443<br/>provider creds"| ExternalLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef user fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef mesh fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Clients external
    class GW,KubeAuth,AuthorinoGW ingress
    class Dashboard_svc,KServe_ctrl,ModelCtrl,KServe_LLM,Kueue_ctrl,TrainingOp_ctrl,Trainer_ctrl,CodeFlare_ctrl,KubeRay_ctrl,Spark_ctrl,DSPO_ctrl,ModelRegOp_ctrl,MLflowOp_ctrl,TrustyAIOp_ctrl,Feast_ctrl,LlamaStackOp_ctrl,GatewayAPIExt_svc,MaaS_svc,AIGateway_svc platform
    class InfSvc,llmd_pods,Notebooks,TrainingJobs,DSPAInstances,ModelRegInst,TrustyAIInst,FeastStore,MLflowInst user
    class Istiod,IstioCNI,KnativeServing mesh
    class S3,ContainerReg,K8sAPI,ExternalLLM egress
    class rhods_op operator
