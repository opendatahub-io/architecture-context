graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["Data Scientists<br/>ML Engineers<br/>API Clients"]
    end

    subgraph Ingress["INGRESS LAYER"]
        direction TB
        subgraph GatewayAPI["Gateway API (data-science-gateway)"]
            DashGW["ODH Dashboard<br/>443 → 8443 kube-rbac-proxy → 8080<br/>TLS service-ca, TokenReview+SAR"]
            KServeGW["KServe InferenceService<br/>443 → 8012<br/>TLS Gateway-terminated<br/>kube-rbac-proxy OR AuthPolicy"]
            LLMISGW["LLMInferenceService<br/>443 → model server<br/>TLS Gateway-terminated<br/>Kuadrant AuthPolicy"]
            NotebookGW["Kubeflow Notebooks<br/>443 → 8443 kube-rbac-proxy → 8888<br/>TLS service-ca"]
            ModelRegGW["Model Registry<br/>443 → 8443 kube-rbac-proxy → 8080<br/>TLS service-ca"]
            MLflowGW["MLflow<br/>443 → 5000<br/>K8s RBAC auth"]
            FeastGW["Feast UI<br/>443 → 8888<br/>OIDC + K8s token review"]
        end
        subgraph LegacyRoutes["OpenShift Routes (Legacy)"]
            RayDashGW["RayCluster Dashboard<br/>443 → 8443 OAuth proxy → 8265<br/>OpenShift OAuth + SAR"]
            MaaSGW["MaaS Endpoints<br/>443 → model server<br/>Authorino tokens"]
        end
    end

    subgraph OperatorNS["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator<br/>Webhook 9443, Metrics 8443"]
    end

    subgraph AppNS["Namespace: redhat-ods-applications"]
        direction TB
        Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>BFF 4000, UI 8080, Auth 8443"]
        KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager<br/>Webhook 9443, Metrics 8443"]
        LLMISCtrl["LLMInferenceService Controller<br/>SA: llmisvc-controller-manager<br/>Webhook 9443, Metrics 8443"]
        OdhModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>Metrics 8443"]
        DSPOCtrl["DSPO<br/>SA: dspo<br/>Webhook 9443, Metrics 8443"]
        NotebookCtrl["Kubeflow Notebook Controller<br/>SA: notebook-controller<br/>Webhook 9443, Metrics 8443"]
        KueueCtrl["Kueue Controller<br/>SA: kueue-controller-manager<br/>16V+5M webhooks, Metrics 8443"]
        CodeFlareCtrl["CodeFlare Operator<br/>SA: codeflare-operator<br/>Webhook 9443, Metrics 8443"]
        KubeRayCtrl["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics 8443"]
        TrainingCtrl["Training Operator<br/>SA: training-operator<br/>Webhook 9443, Metrics 8443"]
        TrustyAICtrl["TrustyAI Service Operator<br/>SA: trustyai-service-operator<br/>Webhook 9443, Metrics 8443"]
        ModelRegOpCtrl["Model Registry Operator<br/>SA: model-registry-operator<br/>Metrics 8443"]
        MLflowOpCtrl["MLflow Operator<br/>SA: mlflow-operator<br/>Metrics 8443"]
        FeastOpCtrl["Feast Operator<br/>SA: feast-operator<br/>Metrics 8443"]
        SparkCtrl["Spark Operator<br/>SA: spark-operator<br/>Webhook 9443, Metrics 8443"]
        ModelMeshCtrl["ModelMesh Serving Controller<br/>SA: modelmesh-controller<br/>Webhook 9443"]
    end

    subgraph UserNS["User Namespaces (workload-scoped)"]
        direction TB
        Notebooks["Notebooks (StatefulSets)<br/>JupyterLab 8888<br/>kube-rbac-proxy 8443"]
        ISPods["InferenceService Pods<br/>vLLM 8000, OVMS 8080<br/>kube-rbac-proxy 8443"]
        LLMISPods["LLMInferenceService Pods<br/>Prefill + Decode vLLM<br/>llm-d-routing-sidecar 9002"]
        DSPInstance["DSP Instance<br/>API Server 8888, MLMD 8080<br/>MariaDB/PostgreSQL"]
        RayCluster["RayCluster Pods<br/>Head 6379/8265/10001<br/>Workers, mTLS, OAuth 8443"]
        ModelRegInst["Model Registry Instance<br/>REST 8080, gRPC 9090<br/>MySQL/PostgreSQL"]
        MLflowInst["MLflow Instance<br/>Server 5000<br/>PostgreSQL + SeaweedFS"]
        FeastInst["FeatureStore Instance<br/>Online 6566, Offline 8815<br/>Registry 8766, UI 8888"]
        ModelMeshPods["ModelMesh Pods<br/>gRPC, rest-proxy 8008<br/>etcd 2379 TLS"]
        GuardrailsPods["Guardrails Orchestrator<br/>API 8033, Health 8034<br/>Detectors, vLLM, Caikit"]
        MaaSPods["MaaS Tenant Pods<br/>Authorino auth<br/>5 NetworkPolicies"]
    end

    subgraph InfraNS["Infrastructure Namespaces"]
        Istio["istio-system<br/>Istio Control Plane"]
        Knative["knative-serving<br/>Knative Serving"]
        Monitoring["redhat-ods-monitoring<br/>Platform Prometheus"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["Object Storage (S3/MinIO)<br/>443/TCP HTTPS<br/>AWS IAM or static creds"]
        Registry["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP, Pull secrets"]
        DB["Database Services<br/>MySQL 3306, PostgreSQL 5432<br/>Username/password"]
        NIM["NVIDIA NIM API<br/>api.ngc.nvidia.com<br/>NGC API key"]
    end

