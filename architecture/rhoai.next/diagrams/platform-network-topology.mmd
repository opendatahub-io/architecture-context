graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>(Data Scientists, Applications)"]
    end

    subgraph Ingress["INGRESS (Gateway API + OpenShift Routes)"]
        direction TB
        DSGateway["data-science-gateway<br/>(Envoy)<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
        KServeGW["KServe InferenceService<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Per domain template"]
        LLMISGW["KServe LLMInferenceService<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Per gateway listener"]
        IGRoute["InferenceGraph Route<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
        DSPRoute["DS Pipelines Route<br/>8443/TCP HTTPS<br/>TLS Reencrypt"]
        MRRoute["Model Registry Route<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
        TrustyRoute["TrustyAI Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
        FeastRoute["Feast UI Route<br/>443/TCP HTTPS<br/>TLS Edge"]
        CFRoute["Codeflare Ray Route<br/>443/TCP HTTPS<br/>TLS Reencrypt/Passthrough"]
    end

    subgraph GatewayAuth["GATEWAY AUTHENTICATION"]
        KubeAuthProxy["kube-auth-proxy<br/>OIDC/OAuth2<br/>8443/TCP Server TLS"]
    end

    subgraph NS_Operator["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator-controller-manager<br/>Ports: 8443 (webhook), 8080 (metrics), 8081 (health)"]
    end

    subgraph NS_Apps["Namespace: redhat-ods-applications"]
        direction TB

        Dashboard["odh-dashboard<br/>SA: odh-dashboard<br/>8443/TCP (kube-rbac-proxy)<br/>8080/TCP (app)"]

        KServeCtrl["kserve-controller<br/>SA: kserve-controller-manager<br/>8080/TCP (metrics), 9443/TCP (webhook)"]

        LLMISVCCtrl["llmisvc-controller<br/>SA: kserve-controller-manager<br/>8443/TCP (metrics), 9443/TCP (webhook)"]

        ODHModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>8080/TCP (metrics)"]

        KueueCtrl["kueue<br/>SA: kueue-controller-manager<br/>8080/TCP (metrics), 9443/TCP (webhook)"]

        KuberayCtrl["kuberay<br/>SA: kuberay-operator<br/>8080/TCP (metrics), 9443/TCP (webhook)"]

        TrainOp["training-operator<br/>SA: kubeflow-training-operator<br/>8080/TCP (metrics)"]

        TrainerCtrl["trainer<br/>SA: trainer-controller-manager<br/>28080/TCP (metrics)"]

        DSPO["data-science-pipelines-operator<br/>SA: dspo-controller-manager<br/>8080/TCP (metrics), 8443/TCP (kube-rbac-proxy)"]

        ModelRegOp["model-registry-operator<br/>SA: model-registry-operator<br/>8443/TCP (kube-rbac-proxy)"]

        TrustyAIOp["trustyai-service-operator<br/>SA: trustyai-operator<br/>8443/TCP (kube-rbac-proxy)"]

        MlflowOp["mlflow-operator<br/>SA: mlflow-operator"]

        CodeflarOp["codeflare-operator<br/>SA: codeflare-operator<br/>8443/TCP (metrics)"]

        MaaS["models-as-a-service<br/>SA: maas-controller<br/>8443/TCP HTTPS<br/>Kuadrant AuthPolicy"]

        LlamaOp["llama-stack-k8s-operator<br/>SA: llama-stack-operator"]
    end

    subgraph NS_Monitoring["Namespace: redhat-ods-monitoring"]
        Prometheus["Prometheus / MonitoringStack"]
        Thanos["ThanosQuerier"]
        Tempo["Tempo (Distributed Tracing)"]
        OTEL["OpenTelemetry Collector"]
    end

    subgraph NS_User["User Namespaces"]
        direction TB
        InfSvc["InferenceService Pods<br/>(vLLM, TGIS, OVMS, Caikit)"]
        LLMDStack["llm-d Pods<br/>(EPP, KV-Cache, Sidecar)"]
        NotebookPods["Notebook Pods<br/>(JupyterLab)"]
        DSPAPods["Pipeline Pods<br/>(API Server, Argo, ml-metadata)"]
        RayPods["RayCluster Pods<br/>(Head + Workers)"]
        TrainPods["Training Pods<br/>(PyTorchJob, TrainJob)"]
        MRPods["model-registry Pods"]
        MlflowPods["mlflow Pods"]
        TrustyPods["TrustyAI / Guardrails Pods"]
        FeastPods["FeatureStore Pods"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS, TLS 1.2+<br/>AWS IAM / Static Creds"]
        ContainerReg["Container Registry (quay.io)<br/>443/TCP HTTPS<br/>Pull Secrets"]
        LLMProviders["External LLM Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS, API Keys"]
        PyPI["PyPI / Conda / GitHub<br/>443/TCP HTTPS<br/>Package Installation"]
        CloudAPIs["Azure / CoreWeave APIs<br/>443/TCP HTTPS<br/>Cloud K8s Mgmt"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>Model Downloads"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443| DSGateway
    Clients -->|HTTPS/443| KServeGW
    Clients -->|HTTPS/443| LLMISGW
    Clients -->|HTTPS/443| DSPRoute
    Clients -->|HTTPS/443| MRRoute
    Clients -->|HTTPS/443| TrustyRoute
    Clients -->|HTTPS/443| FeastRoute
    Clients -->|HTTPS/443| CFRoute

    %% Gateway Auth
    DSGateway -->|OIDC auth| KubeAuthProxy
    KubeAuthProxy -->|identity headers| Dashboard
    KubeAuthProxy -->|identity headers| NotebookPods
    KubeAuthProxy -->|identity headers| MlflowPods

    %% Gateway to Services
    KServeGW -->|HTTPRoute<br/>kube-rbac-proxy| InfSvc
    LLMISGW -->|HTTPRoute<br/>ext-proc routing| LLMDStack
    LLMDStack -->|routed inference| InfSvc
    DSPRoute -->|kube-rbac-proxy| DSPAPods
    MRRoute -->|kube-rbac-proxy| MRPods
    TrustyRoute -->|kube-rbac-proxy| TrustyPods

    %% Operators to user workloads
    KServeCtrl -->|creates workloads| InfSvc
    LLMISVCCtrl -->|creates workloads| LLMDStack
    KueueCtrl -->|admission control| TrainPods
    KueueCtrl -->|admission control| RayPods
    KuberayCtrl -->|manages| RayPods
    TrainOp -->|manages| TrainPods
    TrainerCtrl -->|manages| TrainPods
    DSPO -->|deploys| DSPAPods
    ModelRegOp -->|deploys| MRPods
    TrustyAIOp -->|deploys| TrustyPods
    MlflowOp -->|deploys| MlflowPods
    CodeflarOp -->|secures, mTLS| RayPods

    %% Dashboard integrations
    Dashboard -->|REST proxy| MRPods
    Dashboard -->|REST proxy| DSPAPods
    Dashboard -->|K8s API| InfSvc

    %% Monitoring
    Prometheus -->|scrape :8080| KServeCtrl
    Prometheus -->|scrape :8080| KueueCtrl
    Prometheus -->|scrape :8080| KuberayCtrl
    Prometheus -->|scrape :8080| TrainOp
    Prometheus -->|scrape :8443| CodeflarOp
    Prometheus -->|scrape :8000| InfSvc
    OTEL -->|OTLP gRPC/4317| Tempo

    %% Egress
    InfSvc -->|model download<br/>HTTPS/443| S3
    InfSvc -->|model download<br/>HTTPS/443| HFHub
    InfSvc -->|image pull<br/>HTTPS/443| ContainerReg
    DSPAPods -->|artifacts<br/>HTTPS/443| S3
    NotebookPods -->|packages<br/>HTTPS/443| PyPI
    MaaS -->|remote inference<br/>HTTPS/443| LLMProviders
    RhodsOp -->|cloud mgmt<br/>HTTPS/443| CloudAPIs
    MlflowPods -->|artifacts<br/>HTTPS/443| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef userworkload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Clients external
    class DSGateway,KServeGW,LLMISGW,IGRoute,DSPRoute,MRRoute,TrustyRoute,FeastRoute,CFRoute ingress
    class KubeAuthProxy auth
    class RhodsOp,Dashboard,KServeCtrl,LLMISVCCtrl,ODHModelCtrl,KueueCtrl,KuberayCtrl,TrainOp,TrainerCtrl,DSPO,ModelRegOp,TrustyAIOp,MlflowOp,CodeflarOp,MaaS,LlamaOp operator
    class Prometheus,Thanos,Tempo,OTEL monitoring
    class InfSvc,LLMDStack,NotebookPods,DSPAPods,RayPods,TrainPods,MRPods,MlflowPods,TrustyPods,FeastPods userworkload
    class S3,ContainerReg,LLMProviders,PyPI,CloudAPIs,HFHub egress
