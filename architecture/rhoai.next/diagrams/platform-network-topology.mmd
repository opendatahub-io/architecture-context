graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>Data Scientists, Applications, CI/CD"]
    end

    subgraph Ingress["INGRESS (Istio Gateway API - DMZ)"]
        direction TB
        DSGateway["data-science-gateway<br/>Envoy Proxy<br/>443/TCP HTTPS, TLS termination"]
        EnvoyFilter["EnvoyFilter<br/>ext_authz + Lua filter chains<br/>Token forwarding"]
        KubeAuth["kube-auth-proxy<br/>OAuth/OIDC authentication<br/>OpenShift or external IdP"]
    end

    subgraph NS_Operator["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator<br/>209 controller watches"]
    end

    subgraph NS_Apps["Namespace: redhat-ods-applications"]
        direction TB

        subgraph ControlPlane["Control Plane Components"]
            KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager<br/>Ports: 8443 metrics, 9443 webhook"]
            ODHModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>Port: 8443 metrics"]
            ModelMeshCtrl["ModelMesh Controller<br/>SA: modelmesh-controller<br/>Port: 8443 metrics"]
            KueueCtrl["Kueue Controller<br/>SA: kueue-controller-manager<br/>Ports: 8443 metrics, 9443 webhook"]
            CodeFlareOp["CodeFlare Operator<br/>SA: codeflare-operator<br/>Port: 8443 metrics"]
            KubeRayOp["KubeRay Operator<br/>SA: kuberay-operator<br/>Port: 8443 metrics"]
            TrainingOp["Training Operator<br/>SA: training-operator<br/>Ports: 8443 metrics, 9443 webhook"]
            DSPOCtrl["DSPO Controller<br/>SA: data-science-pipelines-operator<br/>Port: 8443 metrics"]
            AIGWOp["AI Gateway Operator<br/>SA: ai-gateway-operator"]
            MaaSCtrl["MaaS Controller<br/>SA: maas-controller"]
            KagentiOp["Kagenti Operator<br/>SA: agents-operator"]
        end

        subgraph PlatformSvcs["Platform Services"]
            Dashboard["ODH Dashboard<br/>SA: odh-dashboard<br/>Port: 8080 HTTP"]
            ModelReg["Model Registry<br/>SA: model-registry<br/>Ports: 8080 REST, 9090 gRPC"]
            Authorino["Authorino<br/>SA: authorino<br/>API-level auth enforcement"]
        end
    end

    subgraph NS_KnativeServing["Namespace: knative-serving"]
        KnativeServing["Knative Serving<br/>Serverless autoscaling<br/>KServe serverless mode"]
    end

    subgraph NS_User["User Namespaces (per-project)"]
        direction TB

        subgraph InferencePods["Inference Workloads"]
            ISvcPod["InferenceService Pods<br/>vLLM / Caikit-TGIS / OVMS / MLServer<br/>Ports: 8080 HTTP, 8033 gRPC"]
            LLMDStack["llm-d Stack<br/>llm-d-router EPP + vLLM<br/>ext_proc routing, KV-cache"]
            ModelMeshPod["ModelMesh Pods<br/>5+ sidecars per pod<br/>REST proxy + runtime adapter"]
        end

        subgraph TrainingPods["Training Workloads"]
            RayCluster["RayCluster Pods<br/>Distributed Ray workers<br/>mTLS per-cluster CA"]
            PyTorchJob["PyTorchJob Pods<br/>DDP/DeepSpeed/FSDP workers<br/>Headless Service DNS"]
        end

        subgraph PipelinePods["Pipeline Workloads"]
            DSPAInstance["DSPA Instance<br/>API Server + Argo Controller<br/>Ports: 8888 API, 8887 proxy"]
            ArgoWorkers["Argo Workflow Pods<br/>Pipeline step containers<br/>argoexec sidecar"]
        end

        subgraph DevPods["Development Workloads"]
            NotebookPods["Notebook/Workbench Pods<br/>Jupyter, VS Code<br/>OAuth proxy sidecar"]
        end
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["Object Storage<br/>S3-compatible<br/>443/TCP HTTPS<br/>AWS IAM / static creds"]
        ContainerReg["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS<br/>Pull secrets"]
        ExtLLM["External LLM Providers<br/>OpenAI, Anthropic, Azure, Bedrock<br/>443/TCP HTTPS<br/>API keys / SigV4"]
        PostgreSQL["PostgreSQL<br/>Model Registry backend<br/>5432/TCP<br/>Username/password"]
        MariaDB["MariaDB/MySQL<br/>DSPA pipeline metadata<br/>3306/TCP<br/>Username/password"]
    end

    %% External to Ingress
    Clients -->|"HTTPS/443<br/>TLS 1.2+"| DSGateway
    DSGateway -->|"ext_authz"| EnvoyFilter
    EnvoyFilter -->|"auth check"| KubeAuth

    %% Ingress to Platform Services (via HTTPRoute)
    DSGateway -->|"HTTPRoute<br/>dashboard route"| Dashboard
    DSGateway -->|"HTTPRoute<br/>inference routes"| ISvcPod
    DSGateway -->|"HTTPRoute + ReferenceGrant<br/>cross-namespace"| ModelReg
    DSGateway -->|"HTTPRoute + ReferenceGrant<br/>Ray dashboard"| RayCluster
    DSGateway -->|"HTTPRoute<br/>MaaS endpoint"| MaaSCtrl
    DSGateway -->|"ext_proc<br/>llm-d routing"| LLMDStack

    %% AI Gateway external access
    DSGateway -->|"HTTPRoute<br/>AI Gateway"| AIGWOp

    %% Control plane to Kubernetes API
    RhodsOp -->|"HTTPS/443<br/>SA token"| K8sAPI
    KServeCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    ODHModelCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    KueueCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    KubeRayOp -->|"HTTPS/443<br/>SA token"| K8sAPI
    TrainingOp -->|"HTTPS/443<br/>SA token"| K8sAPI

    %% Cross-component communication
    ODHModelCtrl -->|"watches IS CRs"| KServeCtrl
    ODHModelCtrl -->|"gRPC/9090"| ModelReg
    ODHModelCtrl -->|"AuthPolicy CRDs"| Authorino
    Dashboard -->|"REST/8080"| ModelReg
    Dashboard -->|"HTTPS/443<br/>SA token"| K8sAPI
    KServeCtrl -->|"watches"| KnativeServing
    DSPOCtrl -->|"deploys"| DSPAInstance

    %% Inference pods
    ISvcPod -->|"model download<br/>HTTPS/443"| S3
    LLMDStack -->|"model download<br/>HTTPS/443"| S3
    ModelMeshPod -->|"model download<br/>HTTPS/443"| S3

    %% Training pods
    RayCluster -->|"data access<br/>HTTPS/443"| S3
    PyTorchJob -->|"data access<br/>HTTPS/443"| S3

    %% Pipeline pods
    DSPAInstance -->|"metadata<br/>3306/TCP"| MariaDB
    DSPAInstance -->|"artifacts<br/>HTTPS/443"| S3
    ArgoWorkers -->|"artifacts<br/>HTTPS/443"| S3

    %% MaaS to external providers
    AIGWOp -->|"API translation<br/>HTTPS/443<br/>API keys"| ExtLLM

    %% Container image pulls
    ISvcPod -->|"image pull<br/>HTTPS/443"| ContainerReg
    NotebookPods -->|"image pull<br/>HTTPS/443"| ContainerReg

    %% Model Registry backend
    ModelReg -->|"5432/TCP"| PostgreSQL

    %% Kubernetes API (hidden node for layout)
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA tokens"]

    %% Auth enforcement arrows
    Authorino -.->|"AuthPolicy<br/>enforcement"| ISvcPod
    Authorino -.->|"AuthPolicy<br/>enforcement"| MaaSCtrl

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platformsvc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Clients external
    class DSGateway,EnvoyFilter,KubeAuth ingress
    class KServeCtrl,ODHModelCtrl,ModelMeshCtrl,KueueCtrl,CodeFlareOp,KubeRayOp,TrainingOp,DSPOCtrl,AIGWOp,MaaSCtrl,KagentiOp controlplane
    class Dashboard,ModelReg,Authorino platformsvc
    class RhodsOp operator
    class ISvcPod,LLMDStack,ModelMeshPod,RayCluster,PyTorchJob,DSPAInstance,ArgoWorkers,NotebookPods userns
    class S3,ContainerReg,ExtLLM,PostgreSQL,MariaDB,K8sAPI egress
    class KnativeServing platformsvc
