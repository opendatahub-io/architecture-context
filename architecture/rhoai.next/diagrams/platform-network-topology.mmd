graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients[External Clients<br/>Data Scientists / ML Engineers]
        ExtLLM[External LLM Providers<br/>OpenAI, Anthropic, Azure,<br/>Bedrock, Vertex]
    end

    subgraph Ingress["INGRESS - Gateway API (DMZ)"]
        EnvoyGW["Envoy Proxy<br/>Gateway CR<br/>443/TCP HTTPS → backends<br/>TLS 1.2+"]
        KubeAuthProxy["kube-auth-proxy<br/>OIDC / OpenShift OAuth<br/>ext_authz delegate"]
        EnvoyFilter["EnvoyFilter<br/>ext_authz + Lua<br/>Cookie stripping + Token injection"]
        NginxRedirect["nginx Redirect<br/>Legacy hostname 301s"]
    end

    subgraph OperatorNS["Namespace: redhat-ods-operator"]
        RhodsOp["rhods-operator manager<br/>SA: rhods-operator<br/>Deploys all components"]
        CloudMgr["cloudmanager<br/>Helm-based dependency mgmt<br/>cert-manager, Istio, LWS"]
    end

    subgraph PlatformNS["Namespace: redhat-ods-applications"]
        direction TB

        subgraph Controllers["Operators / Controllers"]
            KServeCtrl["KServe Controllers<br/>SA: kserve-controller-manager<br/>controller + llmisvc + localmodel"]
            ODMCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>AuthPolicy, ServiceMonitor, KEDA"]
            DSPOCtrl["DSPO Controller<br/>SA: data-science-pipelines-operator<br/>Pipeline infrastructure"]
            ModelRegOp["Model Registry Operator<br/>SA: model-registry-operator"]
            TrustyAIOp["TrustyAI Operator<br/>SA: trustyai-service-operator"]
            FeastOp["Feast Operator<br/>SA: feast-operator"]
            MLflowOp["MLflow Operator<br/>SA: mlflow-operator"]
            OGXOp["OGX K8s Operator<br/>SA: ogx-operator"]
            MaaSCtrl["MaaS Controller<br/>SA: maas-controller"]
            KubeRayOp["KubeRay Operator<br/>SA: kuberay-operator"]
            KueueCtrl["Kueue Controller<br/>SA: kueue-controller-manager"]
            SparkOp["Spark Operator<br/>SA: spark-operator"]
            TrainerCtrl["Kubeflow Trainer<br/>SA: kubeflow-trainer"]
            WVACtrl["WVA Controller<br/>SA: wva-controller"]
        end

        subgraph PlatformSvcs["Platform Services"]
            DashboardUI["odh-dashboard<br/>SA: odh-dashboard<br/>Module Federation + 10 BFFs<br/>2-3 replicas"]
            NotebookCtrl["Kubeflow Notebook Controller<br/>SA: notebook-controller"]
            EvalHubSvc["EvalHub<br/>SA: evalhub"]
        end

        subgraph InfScheduling["Inference Scheduling"]
            LLMdEPP["llm-d EPP<br/>ext_proc gRPC<br/>Intelligent routing"]
            AIGWSvc["AI Gateway<br/>Payload Processing<br/>ext_proc API translation"]
            MaaSAPI["maas-api<br/>API key validation"]
        end
    end

    subgraph MonitoringNS["Namespace: redhat-ods-monitoring"]
        Prometheus["Prometheus<br/>Metric scraping"]
        Thanos["Thanos Querier<br/>Multi-tenant queries"]
        OTel["OpenTelemetry Collector<br/>Distributed tracing"]
        Perses["Perses<br/>Dashboards"]
        AlertMgr["AlertManager<br/>Alert routing"]
    end

    subgraph UserNS["User Data Science Project Namespaces"]
        NotebookPod["Notebook StatefulSets<br/>+ kube-rbac-proxy sidecar"]
        ISVCPod["InferenceService Deployments<br/>vLLM + llm-d sidecar"]
        DSPAPod["DSPA Pipeline Infrastructure<br/>API Server + Argo + MLMD"]
        RayCluster["RayClusters<br/>mTLS inter-pod"]
        FeatureStore["FeatureStore Deployments<br/>HPA + PDB"]
        MLflowInst["MLflow Instances<br/>Tracking + Registry"]
        OGXServer["OGX Servers<br/>LlamaStack + HPA + PDB"]
        ModelRegInst["Model Registry Instances<br/>REST + gRPC"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3/Object Storage<br/>Model artifacts, pipeline data<br/>443/TCP HTTPS<br/>AWS IAM / static creds"]
        ContainerReg["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS<br/>Pull secrets"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>ServiceAccount tokens"]
    end

    %% External to Ingress
    Clients -->|"HTTPS/443<br/>TLS 1.2+"| EnvoyGW
    Clients -->|"301 redirect"| NginxRedirect
    NginxRedirect -->|"redirect to"| EnvoyGW

    %% Ingress authentication flow
    EnvoyGW -->|"ext_authz"| EnvoyFilter
    EnvoyFilter -->|"OIDC/OAuth"| KubeAuthProxy
    KubeAuthProxy -->|"Bearer token<br/>injected"| EnvoyGW

    %% Ingress to Platform Services via HTTPRoutes
    EnvoyGW -->|"HTTPRoute<br/>dashboard"| DashboardUI
    EnvoyGW -->|"HTTPRoute<br/>notebooks"| NotebookPod
    EnvoyGW -->|"HTTPRoute<br/>model registry"| ModelRegInst
    EnvoyGW -->|"HTTPRoute<br/>mlflow"| MLflowInst
    EnvoyGW -->|"HTTPRoute<br/>inference"| ISVCPod

    %% Inference routing (ext_proc)
    EnvoyGW -->|"ext_proc<br/>gRPC"| LLMdEPP
    EnvoyGW -->|"ext_proc<br/>gRPC"| AIGWSvc
    LLMdEPP -->|"endpoint selection"| ISVCPod
    AIGWSvc -->|"API translation<br/>cred injection"| ExtLLM

    %% MaaS flow
    MaaSCtrl -->|"creates HTTPRoutes"| EnvoyGW
    MaaSAPI -->|"API key auth"| EnvoyGW

    %% Operator to platform namespace
    RhodsOp -->|"deploys controllers"| Controllers
    RhodsOp -->|"deploys services"| PlatformSvcs
    RhodsOp -->|"deploys gateway"| EnvoyGW
    CloudMgr -->|"Helm deploys<br/>cert-manager, Istio, LWS"| K8sAPI

    %% Controllers to user namespace
    KServeCtrl -->|"creates Deployments<br/>LeaderWorkerSet"| ISVCPod
    DSPOCtrl -->|"creates DSPA infra"| DSPAPod
    NotebookCtrl -->|"creates StatefulSet<br/>+ HTTPRoute"| NotebookPod
    FeastOp -->|"creates FeatureStore"| FeatureStore
    MLflowOp -->|"creates MLflow"| MLflowInst
    OGXOp -->|"creates OGXServer"| OGXServer
    KubeRayOp -->|"creates RayCluster"| RayCluster
    ModelRegOp -->|"creates Registry"| ModelRegInst
    ODMCtrl -->|"creates AuthPolicy<br/>ServiceMonitor"| ISVCPod

    %% Monitoring
    Prometheus -->|"scrapes metrics<br/>kube-rbac-proxy auth"| Controllers
    Prometheus -->|"scrapes metrics"| PlatformSvcs
    Prometheus -->|"scrapes metrics"| ISVCPod
    OTel -->|"collects traces<br/>OTLP gRPC"| PlatformSvcs

    %% Egress
    ISVCPod -->|"HTTPS/443<br/>model artifacts"| S3
    DSPAPod -->|"HTTPS/443<br/>pipeline artifacts"| S3
    ModelRegInst -->|"HTTPS/443<br/>artifact refs"| S3
    ISVCPod -->|"HTTPS/443<br/>pull images"| ContainerReg
    NotebookPod -->|"HTTPS/443<br/>pull images"| ContainerReg
    Controllers -->|"HTTPS/6443<br/>SA token auth"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Clients,ExtLLM external
    class EnvoyGW,KubeAuthProxy,EnvoyFilter,NginxRedirect ingress
    class RhodsOp,CloudMgr operator
    class KServeCtrl,ODMCtrl,DSPOCtrl,ModelRegOp,TrustyAIOp,FeastOp,MLflowOp,OGXOp,MaaSCtrl,KubeRayOp,KueueCtrl,SparkOp,TrainerCtrl,WVACtrl platform
    class DashboardUI,NotebookCtrl,EvalHubSvc,LLMdEPP,AIGWSvc,MaaSAPI platform
    class Prometheus,Thanos,OTel,Perses,AlertMgr monitoring
    class NotebookPod,ISVCPod,DSPAPod,RayCluster,FeatureStore,MLflowInst,OGXServer,ModelRegInst userns
    class S3,ContainerReg,K8sAPI egress
