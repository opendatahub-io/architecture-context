graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>(Data Scientists, API Consumers)"]
    end

    subgraph Ingress["INGRESS (Gateway API / Envoy)"]
        direction TB
        Dashboard_GW["ODH Dashboard<br/>HTTPRoute<br/>443/TCP HTTPS<br/>kube-auth-proxy OAuth2"]
        KServe_GW["KServe Inference<br/>HTTPRoute / Route<br/>443/TCP HTTPS<br/>Per-InferenceService host"]
        Notebook_GW["Notebook Access<br/>HTTPRoute<br/>443/TCP HTTPS<br/>kube-auth-proxy OAuth2"]
        RayDash_GW["Ray Dashboard<br/>HTTPRoute<br/>443/TCP HTTPS<br/>Per-RayCluster host"]
        MLflow_GW["MLflow UI/API<br/>HTTPRoute<br/>443/TCP HTTPS<br/>kubernetes-auth"]
        ModelReg_GW["Model Registry<br/>HTTPRoute / VirtualService<br/>443/TCP HTTPS<br/>Istio AuthorizationPolicy"]
        DSP_GW["DS Pipelines<br/>HTTPRoute<br/>443/TCP HTTPS<br/>Per-DSPA"]
        MaaS_GW["Models-as-a-Service<br/>HTTPRoute<br/>443/TCP HTTPS<br/>Kuadrant API key"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KubeAuthProxy["kube-auth-proxy<br/>4180,8443/TCP<br/>OAuth2/OIDC<br/>Envoy ext_authz"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP<br/>TokenReview + SAR<br/>Metrics sidecar"]
    end

    subgraph PlatformNS["NAMESPACE: redhat-ods-applications (Core Platform)"]
        direction TB

        subgraph OperatorCtrl["Operators & Controllers"]
            KServeCtrl["KServe Controller<br/>SA: kserve-controller-manager"]
            KubeflowCtrl["Kubeflow Controller<br/>SA: notebook-controller"]
            KubeRayCtrl["KubeRay Operator<br/>SA: kuberay-operator"]
            KueueCtrl["Kueue Controller<br/>SA: kueue-controller-manager"]
            TrainingOpCtrl["Training Operator<br/>SA: training-operator"]
            TrainerCtrl["Trainer Controller<br/>SA: trainer-controller-manager"]
            TrustyAIOpCtrl["TrustyAI Operator<br/>SA: trustyai-operator"]
            ModelRegOpCtrl["ModelRegistry Operator<br/>SA: model-registry-operator"]
            MLflowOpCtrl["MLflow Operator<br/>SA: mlflow-operator"]
            DSPOpCtrl["DSP Operator<br/>SA: dspa-operator"]
            ODHModelCtrl["odh-model-controller<br/>SA: odh-model-controller"]
            CodeFlareCtrl["CodeFlare Operator<br/>SA: codeflare-operator"]
            SparkOpCtrl["Spark Operator<br/>SA: spark-operator"]
            LlamaStackOpCtrl["Llama Stack Operator<br/>SA: llama-stack-operator"]
            WVACtrl["WVA Controller<br/>SA: wva-controller"]
            ModelMeshServCtrl["ModelMesh Serving<br/>SA: modelmesh-serving"]
            GatewayInfExtCtrl["Gateway Inf Extension<br/>SA: gw-inf-ext"]
            MaaSCtrl["MaaS Controller<br/>SA: maas-controller"]
        end

        subgraph PlatformSvc["Platform Services"]
            ODHDash["ODH Dashboard<br/>8080/TCP (UI)<br/>8043-8743/TCP (BFFs)"]
        end
    end

    subgraph OperatorNS["NAMESPACE: redhat-ods-operator"]
        RhodsOp["rhods-operator<br/>SA: rhods-operator<br/>8080/TCP"]
    end

    subgraph MonitorNS["NAMESPACE: redhat-ods-monitoring"]
        Prometheus["Prometheus (HA pair)"]
        Alertmanager["Alertmanager (HA pair)"]
    end

    subgraph IstioNS["NAMESPACE: istio-system"]
        IstioCP["Istio Control Plane"]
        EnvoyGW["Envoy Gateway Pods"]
    end

    subgraph KnativeNS["NAMESPACE: knative-serving"]
        KnativeCtrl["Knative Controllers"]
    end

    subgraph UserNS["USER NAMESPACES (Workloads)"]
        direction TB
        InfSvc["InferenceService Pods<br/>(vLLM, OVMS, MLServer, TGIS)"]
        NotebookPods["Notebook Pods<br/>(Jupyter, RStudio)"]
        TrainingPods["Training Pods<br/>(PyTorchJob, TrainJob)"]
        PipelinePods["Pipeline Workers<br/>(Argo Workflows)"]
        ModelRegInst["Model Registry Instances"]
        MLflowInst["MLflow Instances"]
        LlamaStackInst["Llama Stack Instances"]
        ModelMeshInst["ModelMesh Instances"]
        TrustyAIInst["TrustyAI Services"]
        GuardrailsPods["Guardrails Stack<br/>(Orchestrator, Detectors)"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>IAM / static creds"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>API token"]
        NGC["NGC API (nvcr.io)<br/>443/TCP HTTPS<br/>NIM key"]
        CloudAI["Cloud AI Providers<br/>(Bedrock, Vertex, Azure)<br/>443/TCP HTTPS"]
        VectorDB["Vector Databases<br/>(Milvus, Qdrant, pgvector)<br/>Various/TCP"]
        PackageRepos["Package Repos<br/>(PyPI, CRAN)<br/>443/TCP HTTPS"]
        OAuthServer["OpenShift OAuth<br/>443/TCP HTTPS"]
        PagerDuty["PagerDuty, DMS, SMTP<br/>443/TCP HTTPS"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443| Dashboard_GW
    Clients -->|HTTPS/443| KServe_GW
    Clients -->|HTTPS/443| Notebook_GW
    Clients -->|HTTPS/443| RayDash_GW
    Clients -->|HTTPS/443| MLflow_GW
    Clients -->|HTTPS/443| ModelReg_GW
    Clients -->|HTTPS/443| DSP_GW
    Clients -->|HTTPS/443| MaaS_GW

    %% Ingress to Auth
    Dashboard_GW -->|ext_authz| KubeAuthProxy
    Notebook_GW -->|ext_authz| KubeAuthProxy
    KubeAuthProxy -->|OIDC| OAuthServer

    %% Ingress to Services
    Dashboard_GW -->|HTTP/8080| ODHDash
    KServe_GW -->|HTTP/8012| InfSvc
    Notebook_GW -->|HTTP| NotebookPods
    RayDash_GW -->|HTTP| UserNS
    MLflow_GW -->|HTTP/5000| MLflowInst
    ModelReg_GW -->|HTTP/8080| ModelRegInst
    DSP_GW -->|HTTP| PipelinePods
    MaaS_GW -->|HTTP| InfSvc

    %% Operator management
    RhodsOp -->|manages all| PlatformNS

    %% Controller to workload
    KServeCtrl -->|reconciles| InfSvc
    KubeflowCtrl -->|reconciles| NotebookPods
    TrainingOpCtrl -->|reconciles| TrainingPods
    TrainerCtrl -->|reconciles| TrainingPods
    KubeRayCtrl -->|reconciles| UserNS
    DSPOpCtrl -->|reconciles| PipelinePods
    ModelRegOpCtrl -->|reconciles| ModelRegInst
    MLflowOpCtrl -->|reconciles| MLflowInst
    LlamaStackOpCtrl -->|reconciles| LlamaStackInst
    TrustyAIOpCtrl -->|reconciles| TrustyAIInst
    TrustyAIOpCtrl -->|reconciles| GuardrailsPods
    ModelMeshServCtrl -->|reconciles| ModelMeshInst
    MaaSCtrl -->|reconciles| InfSvc

    %% Dashboard BFF connections
    ODHDash -->|BFF gRPC/REST| ModelRegInst
    ODHDash -->|BFF REST| MLflowInst
    ODHDash -->|BFF REST| InfSvc

    %% Service mesh
    KServeCtrl -->|routing config| IstioCP
    KServeCtrl -->|autoscale| KnativeCtrl
    InfSvc -->|mTLS via mesh| IstioCP

    %% Monitoring
    Prometheus -->|scrapes /metrics<br/>via kube-rbac-proxy| KServeCtrl
    Prometheus -->|scrapes /metrics<br/>via kube-rbac-proxy| KubeflowCtrl
    Prometheus -->|scrapes /metrics<br/>via kube-rbac-proxy| KubeRayCtrl
    Prometheus -->|scrapes /metrics<br/>via kube-rbac-proxy| KueueCtrl
    Prometheus -->|scrapes /metrics| InfSvc

    %% Egress flows
    InfSvc -->|model download<br/>HTTPS/443| S3
    InfSvc -->|model download<br/>HTTPS/443| HFHub
    ODHModelCtrl -->|NIM validation<br/>HTTPS/443| NGC
    LlamaStackInst -->|AI APIs<br/>HTTPS/443| CloudAI
    LlamaStackInst -->|vector search| VectorDB
    NotebookPods -->|packages<br/>HTTPS/443| PackageRepos
    MLflowInst -->|AI Gateway<br/>HTTPS/443| CloudAI
    Alertmanager -->|alerts<br/>HTTPS/443| PagerDuty

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef user fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitor fill:#e6d0de,stroke:#996185,stroke-width:2px

    class Clients external
    class Dashboard_GW,KServe_GW,Notebook_GW,RayDash_GW,MLflow_GW,ModelReg_GW,DSP_GW,MaaS_GW ingress
    class KubeAuthProxy,KubeRBACProxy auth
    class ODHDash platform
    class RhodsOp,KServeCtrl,KubeflowCtrl,KubeRayCtrl,KueueCtrl,TrainingOpCtrl,TrainerCtrl,TrustyAIOpCtrl,ModelRegOpCtrl,MLflowOpCtrl,DSPOpCtrl,ODHModelCtrl,CodeFlareCtrl,SparkOpCtrl,LlamaStackOpCtrl,WVACtrl,ModelMeshServCtrl,GatewayInfExtCtrl,MaaSCtrl operator
    class InfSvc,NotebookPods,TrainingPods,PipelinePods,ModelRegInst,MLflowInst,LlamaStackInst,ModelMeshInst,TrustyAIInst,GuardrailsPods user
    class S3,HFHub,NGC,CloudAI,VectorDB,PackageRepos,OAuthServer,PagerDuty egress
    class Prometheus,Alertmanager monitor
