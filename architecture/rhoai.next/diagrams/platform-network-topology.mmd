graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>(Data Scientists, Apps, CI/CD)"]
    end

    subgraph Ingress["INGRESS (Gateway API — Centralized Envoy)"]
        direction TB
        DashGW["ODH Dashboard Gateway<br/>443/TCP → 8080/TCP<br/>HTTPS, TLS 1.3<br/>Auth: kube-auth-proxy OAuth2/OIDC"]
        KServeGW["KServe Model Gateway<br/>443/TCP → 8012/TCP<br/>HTTPS, TLS 1.3<br/>Auth: Kuadrant AuthPolicy"]
        MaaSGW["MaaS API Gateway<br/>443/TCP → 8080/TCP<br/>HTTPS, TLS 1.3<br/>Auth: Authorino + Limitador"]
        RayGW["KubeRay Dashboard<br/>443/TCP → 8265/TCP<br/>HTTPS, TLS 1.3<br/>Auth: kube-auth-proxy + oauth-proxy"]
        PipelineGW["Pipeline UI<br/>443/TCP → 8888/TCP<br/>HTTPS, TLS 1.3<br/>Auth: kube-auth-proxy"]
    end

    subgraph OperatorTier["OPERATOR TIER<br/>Namespace: redhat-ods-operator"]
        rhods["rhods-operator<br/>SA: rhods-operator-controller-manager<br/>Ports: 8443 metrics, 9443 webhook<br/>28 CRDs, 16+ sub-components"]
    end

    subgraph PlatformTier["PLATFORM TIER<br/>Namespace: redhat-ods-applications"]
        direction TB

        KubeAuth["kube-auth-proxy<br/>SA: kube-auth-proxy<br/>Port: 8080/TCP<br/>OAuth2/OIDC centralized auth"]

        Dashboard["odh-dashboard<br/>SA: odh-dashboard<br/>Port: 8080/TCP<br/>Sidecars: kube-rbac-proxy, BFF modules<br/>3-layer auth"]

        KServeCtrl["KServe Controllers (x4)<br/>SA: kserve-controller-manager<br/>Ports: 8443 metrics, 9443 webhook<br/>InferenceService, LLMInferenceService,<br/>LocalModelCache, LocalModelNode"]

        ODHModelCtrl["odh-model-controller<br/>SA: odh-model-controller<br/>Creates HTTPRoutes + AuthPolicies"]

        KueueCtrl["Kueue<br/>SA: kueue-controller-manager<br/>Ports: 8443 metrics, 9443 webhook<br/>Scheduler loop + cache snapshots"]

        ModelRegOp["Model Registry Operator<br/>SA: model-registry-operator<br/>Sidecar: kube-rbac-proxy"]

        DSPO["DSPO<br/>SA: data-science-pipelines-operator<br/>Deploys per-DSPA pipeline infra"]

        MaaSCtrl["MaaS Controllers<br/>SA: maas-controller-manager<br/>Aggregates AuthPolicy + RateLimitPolicy"]

        OtherCtrls["Additional Controllers:<br/>CodeFlare, KubeRay, Training Op,<br/>Notebook Ctrl, TrustyAI, MLflow,<br/>Feast, Spark"]
    end

    subgraph MonitoringTier["MONITORING TIER<br/>Namespace: redhat-ods-monitoring"]
        Prometheus["Prometheus<br/>Scrapes all controller metrics<br/>via kube-rbac-proxy on 8443/TCP"]
    end

    subgraph MeshTier["SERVICE MESH TIER"]
        direction TB
        subgraph IstioNS["Namespace: istio-system"]
            Istio["Istio Control Plane<br/>PeerAuth: STRICT mTLS<br/>AuthorizationPolicies<br/>EnvoyFilter ext_authz"]
        end
        subgraph KnativeNS["Namespace: knative-serving"]
            Knative["Knative Serving<br/>Autoscaling, scale-to-zero<br/>Revision-based traffic split"]
        end
    end

    subgraph WorkloadTier["WORKLOAD TIER — User Namespaces"]
        direction TB

        InferencePods["InferenceService Pods<br/>(vLLM, TGIS, MLServer, OVMS)<br/>Port: 8080/TCP inference<br/>LLM sidecars: routing, kv-cache,<br/>kube-rbac-proxy"]

        EPP["llm-d Inference Scheduler<br/>(EPP)<br/>ext-proc gRPC<br/>Scores: queue depth, KV util,<br/>prefix cache hits"]

        BBR["AI Gateway Payload Processing<br/>(BBR)<br/>Model resolution, API translation,<br/>credential injection, NeMo guard"]

        NotebookPods["Notebook Pods<br/>Port: 8888/TCP Jupyter<br/>SA: per-notebook"]

        PipelineInfra["Pipeline Infra (per-DSPA)<br/>API Server: 8888/TCP<br/>MariaDB: 3306/TCP<br/>MLMD: gRPC/8080<br/>Argo controller"]

        RayClusters["Ray Clusters<br/>Head: 6379, 8265/TCP<br/>Self-signed CA mTLS<br/>NetworkPolicies"]

        TrainingJobs["Training Jobs<br/>PyTorchJob, JAXJob<br/>Kueue-admitted"]

        ModelMeshPods["ModelMesh Runtimes<br/>Port: 8033/TCP gRPC<br/>etcd coordination<br/>Consistent hashing"]

        GuardrailsSvc["Guardrails Services<br/>Orchestrator: 8080 HTTP, 8085 gRPC<br/>Detectors: 8080/TCP<br/>ginepro DNS LB"]

        EvalPods["Evaluation Services<br/>lm-eval-harness, TrustyAI,<br/>MLflow (per-ns), Feast"]
    end

    subgraph Egress["EGRESS (External Services)"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS<br/>AWS IAM or static creds<br/>Models, artifacts, data"]
        Registry["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS<br/>Pull secrets"]
        OAuthProvider["OAuth/OIDC Provider<br/>443/TCP HTTPS<br/>OpenShift OAuth or external IdP"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>SA tokens, user tokens"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443| DashGW
    Clients -->|HTTPS/443| KServeGW
    Clients -->|HTTPS/443| MaaSGW
    Clients -->|HTTPS/443| RayGW
    Clients -->|HTTPS/443| PipelineGW

    %% Ingress to Platform
    DashGW -->|HTTP/8080<br/>service-ca TLS| Dashboard
    KServeGW -->|HTTP/8012<br/>Istio mTLS| InferencePods
    MaaSGW -->|HTTP/8080<br/>AuthPolicy| InferencePods
    RayGW -->|HTTP/8265<br/>oauth-proxy| RayClusters
    PipelineGW -->|HTTP/8888<br/>service-ca TLS| PipelineInfra

    %% Gateway auth
    DashGW -.->|ext_authz| KubeAuth
    RayGW -.->|ext_authz| KubeAuth
    PipelineGW -.->|ext_authz| KubeAuth
    KServeGW -.->|AuthPolicy| Istio
    MaaSGW -.->|Authorino + Limitador| Istio

    %% Operator deploys platform
    rhods -->|deploys controllers| PlatformTier

    %% Platform internal
    Dashboard -->|gRPC/9090| ModelRegOp
    Dashboard -->|HTTP| KServeCtrl
    Dashboard -->|HTTP| DSPO
    Dashboard -->|HTTP| MaaSCtrl
    Dashboard -->|HTTPS/443<br/>SA + user token| K8sAPI

    KServeCtrl -->|mTLS| Istio
    KServeCtrl -->|autoscaling| Knative
    KServeCtrl -->|HTTPS/443<br/>SA token| K8sAPI

    ODHModelCtrl -->|creates HTTPRoutes<br/>+ AuthPolicies| K8sAPI
    KueueCtrl -->|workload admission| K8sAPI
    DSPO -->|creates per-DSPA infra| PipelineInfra

    MaaSCtrl -->|backend status| KServeCtrl
    MaaSCtrl -->|AuthPolicy +<br/>RateLimitPolicy| K8sAPI

    %% Workload internal
    EPP -->|scores + routes<br/>ext-proc gRPC| InferencePods
    BBR -->|model resolve<br/>ext-proc| EPP
    PipelineInfra -->|gRPC/9090<br/>model lineage| ModelRegOp
    GuardrailsSvc -->|gRPC<br/>generation| InferencePods
    EvalPods -->|inference| InferencePods

    %% Monitoring
    Prometheus -.->|scrape 8443/TCP<br/>kube-rbac-proxy| KServeCtrl
    Prometheus -.->|scrape 8443/TCP| KueueCtrl
    Prometheus -.->|scrape 8443/TCP| rhods

    %% Egress
    InferencePods -->|HTTPS/443<br/>model download| S3
    InferencePods -->|HTTPS/443<br/>pull secrets| Registry
    NotebookPods -->|HTTPS/443<br/>training data| S3
    PipelineInfra -->|HTTPS/443<br/>artifacts| S3
    TrainingJobs -->|HTTPS/443<br/>data + checkpoints| S3
    KubeAuth -->|HTTPS/443<br/>token validation| OAuthProvider
    rhods -->|HTTPS/443<br/>CRD mgmt| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#1a1a2e,stroke:#e94560,stroke-width:3px,color:#fff
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef mesh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Clients external
    class DashGW,KServeGW,MaaSGW,RayGW,PipelineGW ingress
    class rhods operator
    class KubeAuth,Dashboard,KServeCtrl,ODHModelCtrl,KueueCtrl,ModelRegOp,DSPO,MaaSCtrl,OtherCtrls platform
    class Prometheus monitoring
    class Istio,Knative mesh
    class InferencePods,EPP,BBR,NotebookPods,PipelineInfra,RayClusters,TrainingJobs,ModelMeshPods,GuardrailsSvc,EvalPods workload
    class S3,Registry,OAuthProvider,K8sAPI egress
