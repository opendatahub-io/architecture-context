graph TD
    subgraph TGISWorkload["TGIS Workload Pod"]
        Pod["TGIS Pod<br/>(no K8s API access)"]
    end

    subgraph KServeManaged["RBAC Managed by KServe"]
        direction TB
        KServeSA["KServe ServiceAccount<br/>(manages TGIS lifecycle)"]
        KServeCRB["KServe ClusterRoleBinding"]
        KServeCR["KServe ClusterRole<br/>(kserve-manager-role)"]

        KServeSA -->|"bound via"| KServeCRB
        KServeCRB -->|"grants"| KServeCR
    end

    subgraph Resources["Kubernetes Resources"]
        direction TB
        IS["serving.kserve.io<br/>InferenceService"]
        Deploy["apps<br/>Deployment"]
        Svc["core<br/>Service"]
        Route["route.openshift.io<br/>Route"]
    end

    subgraph TLSAuth["Authentication / Authorization"]
        direction TB
        mTLSConfig["mTLS Configuration<br/>(Optional)"]
        TLSCert["TLS Keypair<br/>TLS_CERT_PATH<br/>TLS_KEY_PATH<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager"]
        ClientCA["Client CA Cert<br/>TLS_CLIENT_CA_CERT_PATH<br/>Type: Opaque<br/>Provisioned: Manual mount"]
    end

    subgraph Endpoints["Endpoint Auth Matrix"]
        direction TB
        GRPCEndpoint["gRPC GenerationService<br/>8033/TCP<br/>Auth: mTLS client certs (optional)<br/>Enforcement: Tonic gRPC server<br/>Policy: Client cert signed by CA"]
        HTTPEndpoint["HTTP /health, /metrics<br/>3000/TCP<br/>Auth: None<br/>Enforcement: None<br/>Policy: Unauthenticated"]
    end

    %% Relationships
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| IS
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Deploy
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Svc
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Route

    Pod -.-|"No RBAC required<br/>No K8s API interaction"| KServeManaged
    mTLSConfig --> TLSCert
    mTLSConfig --> ClientCA

    TLSCert -->|"used by"| GRPCEndpoint
    ClientCA -->|"verifies clients"| GRPCEndpoint

    %% Notes
    Note["Note: TGIS itself has NO RBAC resources.<br/>It runs as a workload pod and does not<br/>interact with the Kubernetes API.<br/>All RBAC is managed externally by KServe."]

    %% Styling
    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeCRB fill:#7ed321,stroke:#333,color:#fff
    style KServeCR fill:#f5a623,stroke:#333,color:#fff
    style IS fill:#dae8fc,stroke:#6c8ebf
    style Deploy fill:#dae8fc,stroke:#6c8ebf
    style Svc fill:#dae8fc,stroke:#6c8ebf
    style Route fill:#dae8fc,stroke:#6c8ebf
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style ClientCA fill:#fff2cc,stroke:#d6b656
    style mTLSConfig fill:#e1d5e7,stroke:#9673a6
    style GRPCEndpoint fill:#d5e8d4,stroke:#82b366
    style HTTPEndpoint fill:#d5e8d4,stroke:#82b366
    style Note fill:#f9f9f9,stroke:#ccc,stroke-dasharray: 5 5
