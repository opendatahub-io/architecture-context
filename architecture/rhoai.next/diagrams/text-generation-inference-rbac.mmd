graph TD
    subgraph TGISWorkload["TGIS Workload (No Direct RBAC)"]
        direction TB
        TGISPod["TGIS Pod<br/>(workload pod, not a controller)"]
        Note1["No Kubernetes API interaction<br/>No ServiceAccount permissions needed<br/>RBAC fully managed by KServe"]
    end

    subgraph KServeManaged["KServe-Managed RBAC"]
        direction TB
        KServeSA["KServe Controller<br/>ServiceAccount"]
        KServeRole["KServe ClusterRole<br/>kserve-manager-role"]
        KServeRB["KServe ClusterRoleBinding<br/>kserve-manager-rolebinding"]
    end

    subgraph ManagedResources["Resources KServe Manages for TGIS"]
        direction TB
        ISvc["serving.kserve.io<br/>InferenceService"]
        Deploy["apps<br/>Deployment"]
        Svc["core<br/>Service"]
        Route["route.openshift.io<br/>Route"]
        Secret["core<br/>Secret<br/>(TLS keypair)"]
    end

    subgraph TLSAuth["TGIS Authentication (Application-Level)"]
        direction TB
        TLSConfig["TLS Configuration"]
        ServerCert["Server TLS Cert<br/>TLS_CERT_PATH<br/>TLS_KEY_PATH<br/>Type: kubernetes.io/tls<br/>Provisioner: cert-manager / manual"]
        ClientCA["Client CA Cert<br/>TLS_CLIENT_CA_CERT_PATH<br/>Type: Opaque<br/>Provisioner: manual mount<br/>Purpose: mTLS client verification"]
    end

    %% Relationships
    KServeSA -->|bound via| KServeRB
    KServeRB -->|grants| KServeRole
    KServeRole -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ISvc
    KServeRole -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Deploy
    KServeRole -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Svc
    KServeRole -->|"get,list,watch,<br/>create,update"| Route
    KServeRole -->|"get,list,watch"| Secret

    KServeSA -->|"manages lifecycle of"| TGISPod
    TGISPod -.->|"no K8s API calls"| Note1

    TLSConfig --- ServerCert
    TLSConfig --- ClientCA
    TGISPod -->|"uses for TLS/mTLS"| TLSConfig

    %% Styling
    style TGISPod fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#fff3e0,stroke:#ff9800,color:#333

    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333,color:#fff
    style KServeRB fill:#f5a623,stroke:#333,color:#fff

    style ISvc fill:#c8e6c9,stroke:#388e3c,color:#333
    style Deploy fill:#c8e6c9,stroke:#388e3c,color:#333
    style Svc fill:#c8e6c9,stroke:#388e3c,color:#333
    style Route fill:#c8e6c9,stroke:#388e3c,color:#333
    style Secret fill:#c8e6c9,stroke:#388e3c,color:#333

    style TLSConfig fill:#e1d5e7,stroke:#9673a6,color:#333
    style ServerCert fill:#f8cecc,stroke:#b85450,color:#333
    style ClientCA fill:#f8cecc,stroke:#b85450,color:#333
