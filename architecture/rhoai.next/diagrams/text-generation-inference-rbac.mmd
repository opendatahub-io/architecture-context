graph TD
    subgraph "TGIS Security Model"
        direction TB

        subgraph "Container Security Context"
            Container["TGIS Container<br/>Image: text-gen-server"]
            User["User: tgis<br/>UID: 2000 | GID: 0"]
            SecCtx["Security Context:<br/>allowPrivilegeEscalation: false<br/>readOnlyRootFilesystem: true (optional)<br/>seccompProfile: RuntimeDefault"]
            Container --- User
            Container --- SecCtx
        end

        subgraph "TLS Configuration (Optional)"
            TLSCert["TLS cert/key<br/>(kubernetes.io/tls)<br/>Provisioned: Manual / cert-manager<br/>Auto-rotate: No"]
            ClientCA["TLS Client CA Cert<br/>(mTLS validation)<br/>TLS_CLIENT_CA_CERT_PATH"]
            HFToken["HuggingFace Auth Token<br/>(Opaque)<br/>Private model access<br/>Provisioned: Manual"]
        end

        subgraph "Authentication Endpoints"
            gRPCEP["fmaas.GenerationService<br/>gRPC :8033"]
            HealthEP["/health<br/>HTTP :3000"]
            MetricsEP["/metrics<br/>HTTP :3000"]
        end

        subgraph "Auth Mechanisms"
            mTLS["Optional mTLS<br/>tonic gRPC server<br/>Client cert validation"]
            NoAuth1["No Auth<br/>(health probes only)"]
            NoAuth2["No Auth<br/>(Prometheus scraping)"]
        end

        gRPCEP -->|"auth"| mTLS
        HealthEP -->|"auth"| NoAuth1
        MetricsEP -->|"auth"| NoAuth2
        mTLS -->|"uses"| TLSCert
        mTLS -->|"validates client via"| ClientCA
    end

    subgraph "Platform-Level RBAC (External to TGIS)"
        KServeRBAC["KServe RBAC<br/>Manages pod lifecycle<br/>and service accounts"]
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>Enforces auth/authz at ingress"]
        GatewayAPI["Gateway API HTTPRoute<br/>External access control"]
    end

    KServeRBAC -->|"manages"| Container
    KubeRBACProxy -->|"protects"| gRPCEP
    GatewayAPI -->|"routes to"| gRPCEP

    Note["NOTE: TGIS defines no RBAC resources<br/>(no ClusterRoles, Roles, or Bindings).<br/>All Kubernetes RBAC is handled at the<br/>KServe/platform level."]

    style Container fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style User fill:#5dade2,stroke:#333,stroke-width:1px
    style SecCtx fill:#5dade2,stroke:#333,stroke-width:1px
    style TLSCert fill:#f5a623,stroke:#333,stroke-width:2px
    style ClientCA fill:#f5a623,stroke:#333,stroke-width:2px
    style HFToken fill:#f5a623,stroke:#333,stroke-width:2px
    style gRPCEP fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style HealthEP fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style MetricsEP fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style mTLS fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    style NoAuth1 fill:#95a5a6,stroke:#333,stroke-width:1px
    style NoAuth2 fill:#95a5a6,stroke:#333,stroke-width:1px
    style KServeRBAC fill:#7ed321,stroke:#333,stroke-width:2px
    style KubeRBACProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style GatewayAPI fill:#7ed321,stroke:#333,stroke-width:2px
    style Note fill:#fff3cd,stroke:#856404,stroke-width:1px
