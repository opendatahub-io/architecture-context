graph TD
    subgraph TGISWorkload["TGIS Workload Pod"]
        Pod["TGIS Pod<br/>(no K8s API access)"]
    end

    subgraph KServeManaged["RBAC Managed by KServe"]
        direction TB
        SA["ServiceAccount<br/>(created by KServe<br/>per InferenceService)"]
        RB["RoleBinding<br/>(KServe-managed)"]
        Role["Role / ClusterRole<br/>(KServe-managed)"]
    end

    subgraph SecurityControls["Security Controls (Pod-Level)"]
        direction TB
        TLS["TLS Configuration<br/>TLS_CERT_PATH<br/>TLS_KEY_PATH<br/>rustls 0.22.4 / native-tls"]
        mTLS["mTLS Client Auth<br/>TLS_CLIENT_CA_CERT_PATH<br/>Client cert verification"]
        ReadOnly["Read-Only Root FS<br/>(optional patch)"]
    end

    subgraph Secrets["Secrets"]
        direction TB
        TLSSecret["TLS Keypair<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager<br/>or manual mount"]
        CASecret["Client CA Cert<br/>Type: Opaque<br/>Provisioned by: manual mount<br/>Auto-Rotate: No"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| Role
    SA -->|"assigned to"| Pod

    TLSSecret -->|"mounted as"| TLS
    CASecret -->|"mounted as"| mTLS

    Pod -->|"uses"| TLS
    Pod -->|"uses"| mTLS
    Pod -->|"enforces"| ReadOnly

    Note["Note: TGIS has NO direct RBAC.<br/>It runs as a workload pod,<br/>not a controller/operator.<br/>All K8s RBAC is managed by KServe."]

    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#7ed321,stroke:#333,color:#fff
    style RB fill:#7ed321,stroke:#333,color:#fff
    style Role fill:#7ed321,stroke:#333,color:#fff
    style TLS fill:#f5a623,stroke:#333,color:#fff
    style mTLS fill:#f5a623,stroke:#333,color:#fff
    style ReadOnly fill:#f5a623,stroke:#333,color:#fff
    style TLSSecret fill:#e8e8e8,stroke:#333
    style CASecret fill:#e8e8e8,stroke:#333
    style Note fill:#fff3cd,stroke:#856404,color:#856404
