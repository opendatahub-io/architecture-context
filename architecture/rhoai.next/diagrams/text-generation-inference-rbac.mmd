graph TD
    subgraph "TGIS Security Model"
        direction TB

        subgraph ContainerSecurity["Container Security Context"]
            User["Non-root User<br/>tgis (UID 2000, GID 0)"]
            NoPrivEsc["allowPrivilegeEscalation: false"]
            Seccomp["seccompProfile: RuntimeDefault"]
            ReadOnly["readOnlyRootFilesystem<br/>(optional kustomize patch)"]
        end

        subgraph TLSConfig["TLS Configuration (Optional)"]
            ServerTLS["Server TLS<br/>TLS_CERT_PATH<br/>TLS_KEY_PATH"]
            ClientTLS["Client mTLS Validation<br/>TLS_CLIENT_CA_CERT_PATH"]
        end

        subgraph Secrets["Secrets"]
            TLSSecret["TLS cert/key<br/>kubernetes.io/tls<br/>Manual / cert-manager<br/>No auto-rotation"]
            HFToken["HuggingFace Token<br/>Opaque<br/>Manual provisioning<br/>No auto-rotation"]
        end

        subgraph Endpoints["Endpoint Authentication"]
            gRPCEndpoint["fmaas.GenerationService<br/>8033/TCP gRPC<br/>Auth: Optional mTLS<br/>Enforcement: tonic gRPC server"]
            HealthEndpoint["/health<br/>3000/TCP HTTP<br/>Auth: None<br/>Unauthenticated"]
            MetricsEndpoint["/metrics<br/>3000/TCP HTTP<br/>Auth: None<br/>Unauthenticated"]
        end

        subgraph PlatformRBAC["Platform-Level RBAC (KServe)"]
            KServeRBAC["KServe manages RBAC<br/>for InferenceService resources"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(production RHOAI)<br/>Enforces auth at ingress"]
            GatewayAPI["Gateway API HTTPRoute<br/>(optional external access)"]
        end
    end

    %% Relationships
    ServerTLS -->|"configures"| gRPCEndpoint
    ClientTLS -->|"validates client certs"| gRPCEndpoint
    TLSSecret -->|"provides cert/key"| ServerTLS
    HFToken -->|"authenticates"| HFAccess["HuggingFace Hub Access"]

    User -->|"runs as"| gRPCEndpoint
    User -->|"runs as"| HealthEndpoint
    User -->|"runs as"| MetricsEndpoint

    KServeRBAC -->|"delegates auth to"| KubeRBACProxy
    KubeRBACProxy -->|"proxies to"| gRPCEndpoint

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style NoPrivEsc fill:#2ecc71,stroke:#333,color:#fff
    style Seccomp fill:#2ecc71,stroke:#333,color:#fff
    style ReadOnly fill:#2ecc71,stroke:#333,color:#fff
    style ServerTLS fill:#f5a623,stroke:#333,color:#fff
    style ClientTLS fill:#f5a623,stroke:#333,color:#fff
    style TLSSecret fill:#e74c3c,stroke:#333,color:#fff
    style HFToken fill:#e74c3c,stroke:#333,color:#fff
    style gRPCEndpoint fill:#9b59b6,stroke:#333,color:#fff
    style HealthEndpoint fill:#1abc9c,stroke:#333,color:#fff
    style MetricsEndpoint fill:#1abc9c,stroke:#333,color:#fff
    style KServeRBAC fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style HFAccess fill:#f5a623,stroke:#333
