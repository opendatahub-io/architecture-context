graph TB
    subgraph Pod["ModelMesh Serving Pod"]
        direction TB

        subgraph Puller["model-serving-puller"]
            PullerSvc["ModelRuntime gRPC Server<br/>8084/TCP"]
            PullmanLib["pullman Library<br/>(Storage Provider Framework)"]
            PullerSvc -->|"intercepts LoadModel"| PullmanLib
        end

        subgraph Adapters["Runtime Adapters (one per pod)"]
            direction LR
            TritonAdapter["triton-adapter<br/>8085/TCP gRPC"]
            MLServerAdapter["mlserver-adapter<br/>8085/TCP gRPC"]
            OVMSAdapter["ovms-adapter<br/>8085/TCP gRPC"]
            TorchServeAdapter["torchserve-adapter<br/>8085/TCP gRPC"]
        end

        subgraph Runtimes["Model Runtimes (one per pod)"]
            direction LR
            Triton["NVIDIA Triton<br/>8001/TCP gRPC"]
            MLServer["Seldon MLServer<br/>8001/TCP gRPC"]
            OVMS["OpenVINO Model Server<br/>8001/TCP HTTP"]
            TorchServe["TorchServe<br/>7071/TCP gRPC (mgmt)<br/>7070/TCP gRPC (infer)"]
        end

        subgraph Conversion["Format Conversion"]
            TFScript["tf_pb.py<br/>Keras H5 → TF SavedModel<br/>(Python/TensorFlow)"]
        end

        PullerSvc -->|"gRPC delegate<br/>8085/TCP"| TritonAdapter
        PullerSvc -->|"gRPC delegate<br/>8085/TCP"| MLServerAdapter
        PullerSvc -->|"gRPC delegate<br/>8085/TCP"| OVMSAdapter
        PullerSvc -->|"gRPC delegate<br/>8085/TCP"| TorchServeAdapter

        TritonAdapter -->|"gRPC<br/>8001/TCP"| Triton
        TritonAdapter -->|"exec subprocess"| TFScript
        MLServerAdapter -->|"gRPC<br/>8001/TCP"| MLServer
        OVMSAdapter -->|"HTTP REST<br/>8001/TCP"| OVMS
        TorchServeAdapter -->|"gRPC<br/>7071/TCP"| TorchServe
    end

    ModelMesh["ModelMesh Controller"] -->|"gRPC LoadModel/UnloadModel<br/>8084/TCP"| PullerSvc

    subgraph Storage["Remote Storage"]
        S3["S3 / IBM COS<br/>443/TCP HTTPS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
        HTTP["HTTP(S) Endpoints<br/>Configurable"]
        PVC["PVC Volumes<br/>Filesystem"]
    end

    PullmanLib -->|"S3 SDK<br/>TLS 1.2+"| S3
    PullmanLib -->|"GCS SDK<br/>TLS 1.2+"| GCS
    PullmanLib -->|"Azure SDK<br/>TLS 1.2+"| Azure
    PullmanLib -->|"HTTP GET<br/>Optional TLS"| HTTP
    PullmanLib -->|"Symlink"| PVC

    ModelsDir[("/models<br/>Local Model Storage")]
    PullmanLib -->|"write artifacts"| ModelsDir
    TritonAdapter -->|"read/adapt layout"| ModelsDir
    MLServerAdapter -->|"read/adapt layout"| ModelsDir
    OVMSAdapter -->|"read/adapt layout"| ModelsDir
    TorchServeAdapter -->|"read/symlink MAR"| ModelsDir

    style PullerSvc fill:#4a90e2,stroke:#333,color:#fff
    style PullmanLib fill:#4a90e2,stroke:#333,color:#fff
    style TritonAdapter fill:#7ed321,stroke:#333,color:#fff
    style MLServerAdapter fill:#7ed321,stroke:#333,color:#fff
    style OVMSAdapter fill:#7ed321,stroke:#333,color:#fff
    style TorchServeAdapter fill:#7ed321,stroke:#333,color:#fff
    style TFScript fill:#f5a623,stroke:#333,color:#fff
    style ModelMesh fill:#9013fe,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style Azure fill:#e8e8e8,stroke:#333
    style HTTP fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
    style Triton fill:#bd10e0,stroke:#333,color:#fff
    style MLServer fill:#bd10e0,stroke:#333,color:#fff
    style OVMS fill:#bd10e0,stroke:#333,color:#fff
    style TorchServe fill:#bd10e0,stroke:#333,color:#fff
    style ModelsDir fill:#f8e71c,stroke:#333
