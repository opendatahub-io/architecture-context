graph TB
    subgraph ModelServerPod["Model Server Pod"]
        direction TB

        subgraph PullerSidecar["model-serving-puller (8084/TCP gRPC)"]
            Puller[model-serving-puller<br/>Go Service]
            PullmanLib[pullman library<br/>Storage Provider Framework]
            Puller -->|uses| PullmanLib
        end

        subgraph AdapterSidecars["Runtime Adapters (8085/TCP gRPC)"]
            TritonAdapter[model-mesh-triton-adapter<br/>Go Service]
            OVMSAdapter[model-mesh-ovms-adapter<br/>Go Service]
            MLServerAdapter[model-mesh-mlserver-adapter<br/>Go Service]
            TorchServeAdapter[model-mesh-torchserve-adapter<br/>Go Service]
        end

        subgraph ModelRuntimes["Model Runtimes (co-located containers)"]
            Triton[NVIDIA Triton<br/>gRPC :8001]
            OVMS[OpenVINO Model Server<br/>HTTP :8001]
            MLServer[Seldon MLServer<br/>gRPC :8001]
            TorchServe[PyTorch TorchServe<br/>gRPC :7071/:7070]
        end

        TFScript[tf_pb.py<br/>Keras-to-TF Converter<br/>Python 3.11 / TensorFlow 2.19]

        Puller -->|"gRPC :8085<br/>LoadModel/UnloadModel"| AdapterSidecars
        TritonAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| Triton
        TritonAdapter -->|"invokes"| TFScript
        OVMSAdapter -->|"HTTP :8001<br/>/v1/config/reload"| OVMS
        MLServerAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| MLServer
        TorchServeAdapter -->|"gRPC :7071<br/>RegisterModel/Unregister"| TorchServe
    end

    ModelMesh[ModelMesh<br/>gRPC Client] -->|"gRPC :8084<br/>mmesh.ModelRuntime"| Puller
    ModelMesh -->|"gRPC :8085<br/>mmesh.ModelRuntime"| AdapterSidecars

    subgraph CloudStorage["Cloud Storage (Egress)"]
        S3["S3 / IBM COS<br/>HTTPS :443"]
        GCS["Google Cloud Storage<br/>HTTPS :443"]
        Azure["Azure Blob Storage<br/>HTTPS :443"]
        HTTP["HTTP/HTTPS Server<br/>:80/:443"]
    end

    PullmanLib -->|"HTTPS :443<br/>TLS 1.2+"| S3
    PullmanLib -->|"HTTPS :443<br/>TLS 1.2+"| GCS
    PullmanLib -->|"HTTPS :443<br/>TLS 1.2+"| Azure
    PullmanLib -->|"HTTP/HTTPS<br/>optional mTLS"| HTTP

    StorageSecret["storage-config Secret<br/>(mounted at /storage-config)"] -.->|"credentials"| PullmanLib

    MMController[ModelMesh Controller] -.->|"ConfigMap reference<br/>storageHelperImage"| ModelServerPod

    style Puller fill:#4a90e2,color:#fff
    style TritonAdapter fill:#4a90e2,color:#fff
    style OVMSAdapter fill:#4a90e2,color:#fff
    style MLServerAdapter fill:#4a90e2,color:#fff
    style TorchServeAdapter fill:#4a90e2,color:#fff
    style PullmanLib fill:#6baed6,color:#fff
    style TFScript fill:#9ecae1,color:#333
    style Triton fill:#e8e8e8,stroke:#333
    style OVMS fill:#e8e8e8,stroke:#333
    style MLServer fill:#e8e8e8,stroke:#333
    style TorchServe fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#7ed321,color:#fff
    style MMController fill:#7ed321,color:#fff
    style S3 fill:#f5a623,color:#fff
    style GCS fill:#f5a623,color:#fff
    style Azure fill:#f5a623,color:#fff
    style HTTP fill:#f5a623,color:#fff
