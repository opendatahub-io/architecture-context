graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        direction TB

        subgraph AdapterImage["modelmesh-runtime-adapter Container Image"]
            direction LR
            Puller["model-serving-puller<br/>gRPC :8084<br/>Go"]
            TritonAdapter["triton-adapter<br/>gRPC :8085<br/>Go"]
            OVMSAdapter["ovms-adapter<br/>gRPC :8085<br/>Go"]
            MLServerAdapter["mlserver-adapter<br/>gRPC :8085<br/>Go"]
            TorchServeAdapter["torchserve-adapter<br/>gRPC :8085<br/>Go"]

            subgraph PullmanLib["pullman Library"]
                S3Provider["S3 Provider"]
                GCSProvider["GCS Provider"]
                AzureProvider["Azure Provider"]
                HTTPProvider["HTTP Provider"]
                PVCProvider["PVC Provider"]
            end

            TFConvert["tf_pb.py<br/>Keras→TF Conversion<br/>Python 3.11"]
        end

        subgraph RuntimeContainer["Model Runtime Container (one of)"]
            Triton["NVIDIA Triton<br/>gRPC :8001"]
            OVMS["OpenVINO Model Server<br/>REST :8001"]
            MLServer["Seldon MLServer<br/>gRPC :8001"]
            TorchServe["TorchServe<br/>Mgmt gRPC :7071<br/>Infer gRPC :7070"]
        end
    end

    ModelMesh["ModelMesh Controller<br/>(external pod)"] -->|"gRPC :8084<br/>loadModel/unloadModel"| Puller
    ModelMesh -->|"gRPC :8085<br/>loadModel/unloadModel"| TritonAdapter
    ModelMesh -->|"gRPC :8085<br/>loadModel/unloadModel"| OVMSAdapter
    ModelMesh -->|"gRPC :8085<br/>loadModel/unloadModel"| MLServerAdapter
    ModelMesh -->|"gRPC :8085<br/>loadModel/unloadModel"| TorchServeAdapter

    Puller -->|"uses"| PullmanLib
    TritonAdapter -->|"uses (embedded puller)"| PullmanLib
    OVMSAdapter -->|"uses (embedded puller)"| PullmanLib
    MLServerAdapter -->|"uses (embedded puller)"| PullmanLib
    TorchServeAdapter -->|"uses (embedded puller)"| PullmanLib

    Puller -->|"gRPC :8085<br/>forward load/unload"| TritonAdapter
    Puller -->|"gRPC :8085<br/>forward load/unload"| OVMSAdapter
    Puller -->|"gRPC :8085<br/>forward load/unload"| MLServerAdapter
    Puller -->|"gRPC :8085<br/>forward load/unload"| TorchServeAdapter

    TritonAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| Triton
    TritonAdapter -->|"invokes"| TFConvert
    OVMSAdapter -->|"HTTP :8001<br/>/v1/config/reload"| OVMS
    MLServerAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| MLServer
    TorchServeAdapter -->|"gRPC :7071<br/>RegisterModel/Unregister"| TorchServe

    PullmanLib -->|"HTTPS :443<br/>TLS 1.2+"| CloudStorage["Cloud Storage<br/>(S3/GCS/Azure/HTTP)"]

    StorageSecret["/storage-config<br/>Mounted Secret"] -.->|"credentials"| PullmanLib

    style ModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style Puller fill:#5ba8f7,stroke:#333,color:#fff
    style TritonAdapter fill:#5ba8f7,stroke:#333,color:#fff
    style OVMSAdapter fill:#5ba8f7,stroke:#333,color:#fff
    style MLServerAdapter fill:#5ba8f7,stroke:#333,color:#fff
    style TorchServeAdapter fill:#5ba8f7,stroke:#333,color:#fff
    style TFConvert fill:#f5a623,stroke:#333,color:#fff
    style Triton fill:#76b900,stroke:#333,color:#fff
    style OVMS fill:#0068b5,stroke:#333,color:#fff
    style MLServer fill:#7ed321,stroke:#333,color:#fff
    style TorchServe fill:#ee4c2c,stroke:#333,color:#fff
    style CloudStorage fill:#f5a623,stroke:#333,color:#fff
    style StorageSecret fill:#e8e8e8,stroke:#999
    style S3Provider fill:#d5e8d4,stroke:#82b366
    style GCSProvider fill:#d5e8d4,stroke:#82b366
    style AzureProvider fill:#d5e8d4,stroke:#82b366
    style HTTPProvider fill:#d5e8d4,stroke:#82b366
    style PVCProvider fill:#d5e8d4,stroke:#82b366
