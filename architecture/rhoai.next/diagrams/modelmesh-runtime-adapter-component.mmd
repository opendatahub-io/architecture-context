graph TB
    subgraph Pod["ModelMesh Model Serving Pod"]
        direction TB

        subgraph PullerContainer["model-serving-puller (sidecar)"]
            Puller["model-serving-puller<br/>8084/TCP gRPC<br/>/opt/app/puller"]
            Pullman["pullman library<br/>Storage provider abstraction<br/>Client caching (1h TTL)"]
            Puller -->|uses| Pullman
        end

        subgraph AdapterContainer["Runtime Adapter (one per pod)"]
            TritonAdapter["triton-adapter<br/>8085/TCP gRPC"]
            MLServerAdapter["mlserver-adapter<br/>8085/TCP gRPC"]
            OVMSAdapter["ovms-adapter<br/>8085/TCP gRPC"]
            TorchServeAdapter["torchserve-adapter<br/>8085/TCP gRPC"]
        end

        subgraph RuntimeContainer["Inference Runtime (one per pod)"]
            Triton["NVIDIA Triton<br/>8001/TCP gRPC"]
            MLServer["SeldonIO MLServer<br/>8001/TCP gRPC"]
            OVMS["OpenVINO Model Server<br/>8001/TCP HTTP"]
            TorchServe["TorchServe<br/>7071/TCP gRPC mgmt<br/>7070/TCP gRPC inference"]
        end

        subgraph Conversion["Model Conversion"]
            TFScript["tf_pb.py<br/>Python 3.11<br/>Keras → TF SavedModel"]
        end

        Puller -->|"gRPC LoadModel/UnloadModel<br/>localhost:8085"| TritonAdapter
        Puller -->|"gRPC LoadModel/UnloadModel<br/>localhost:8085"| MLServerAdapter
        Puller -->|"gRPC LoadModel/UnloadModel<br/>localhost:8085"| OVMSAdapter
        Puller -->|"gRPC LoadModel/UnloadModel<br/>localhost:8085"| TorchServeAdapter

        TritonAdapter -->|"gRPC RepositoryModelLoad/Unload<br/>localhost:8001"| Triton
        MLServerAdapter -->|"gRPC RepositoryModelLoad/Unload<br/>localhost:8001"| MLServer
        OVMSAdapter -->|"HTTP POST /v1/config/reload<br/>localhost:8001"| OVMS
        TorchServeAdapter -->|"gRPC RegisterModel/UnregisterModel<br/>localhost:7071"| TorchServe

        TritonAdapter -.->|"subprocess exec"| TFScript
    end

    ModelMesh["ModelMesh Controller<br/>(modelmesh-serving)"] -->|"gRPC mmesh.ModelRuntime<br/>LoadModel / UnloadModel<br/>RuntimeStatus / PredictModelSize<br/>localhost:8084"| Puller

    Pullman -->|"HTTPS/443<br/>Access Key + Secret"| S3["S3 / IBM COS"]
    Pullman -->|"HTTPS/443<br/>Service Account JSON"| GCS["Google Cloud Storage"]
    Pullman -->|"HTTPS/443<br/>Service Principal"| Azure["Azure Blob Storage"]
    Pullman -->|"HTTP/HTTPS<br/>Optional certs/headers"| HTTPEndpoint["HTTP/HTTPS Endpoints"]
    Pullman -.->|"Filesystem symlink"| PVC["PVC Mounts"]

    StorageConfig["Kubernetes Secrets<br/>/storage-config"] -.->|"Volume mount"| Puller

    style Puller fill:#4a90e2,color:#fff
    style Pullman fill:#4a90e2,color:#fff
    style TritonAdapter fill:#7ed321,color:#fff
    style MLServerAdapter fill:#7ed321,color:#fff
    style OVMSAdapter fill:#7ed321,color:#fff
    style TorchServeAdapter fill:#7ed321,color:#fff
    style Triton fill:#f5a623,color:#fff
    style MLServer fill:#f5a623,color:#fff
    style OVMS fill:#f5a623,color:#fff
    style TorchServe fill:#f5a623,color:#fff
    style TFScript fill:#9b59b6,color:#fff
    style ModelMesh fill:#e74c3c,color:#fff
    style S3 fill:#999,color:#fff
    style GCS fill:#999,color:#fff
    style Azure fill:#999,color:#fff
    style HTTPEndpoint fill:#999,color:#fff
    style PVC fill:#999,color:#fff
    style StorageConfig fill:#e8e8e8
