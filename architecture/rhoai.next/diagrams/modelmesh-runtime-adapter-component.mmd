graph TB
    subgraph ModelServerPod["Model Server Pod"]
        direction TB

        subgraph PullerSidecar["model-serving-puller (8084/TCP gRPC)"]
            Puller[model-serving-puller<br/>Go Service]
            PullmanLib[pullman Library<br/>Storage Provider Framework]
            Puller -->|uses| PullmanLib
        end

        subgraph AdapterSidecar["Runtime Adapter (8085/TCP gRPC)"]
            TritonAdapter[model-mesh-triton-adapter<br/>Go Service]
            OVMSAdapter[model-mesh-ovms-adapter<br/>Go Service]
            MLServerAdapter[model-mesh-mlserver-adapter<br/>Go Service]
            TorchServeAdapter[model-mesh-torchserve-adapter<br/>Go Service]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            Triton[NVIDIA Triton<br/>8001/TCP gRPC]
            OVMS[OpenVINO Model Server<br/>8001/TCP HTTP]
            MLServer[Seldon MLServer<br/>8001/TCP gRPC]
            TorchServe[PyTorch TorchServe<br/>7071/TCP mgmt, 7070/TCP infer]
        end

        TFScript[tf_pb.py<br/>Keras-to-TF Converter<br/>Python/TensorFlow 2.19]
    end

    ModelMesh[ModelMesh<br/>gRPC Client] -->|"loadModel/unloadModel<br/>gRPC 8084/TCP"| Puller
    ModelMesh -->|"loadModel/unloadModel<br/>gRPC 8085/TCP"| AdapterSidecar

    Puller -->|"forward requests<br/>gRPC 8085/TCP"| AdapterSidecar

    TritonAdapter -->|"RepositoryModelLoad<br/>gRPC 8001/TCP"| Triton
    TritonAdapter -->|"Keras conversion"| TFScript
    OVMSAdapter -->|"config/reload<br/>HTTP 8001/TCP"| OVMS
    MLServerAdapter -->|"RepositoryModelLoad<br/>gRPC 8001/TCP"| MLServer
    TorchServeAdapter -->|"RegisterModel<br/>gRPC 7071/TCP"| TorchServe

    subgraph CloudStorage["Cloud Storage (External)"]
        S3[S3 / IBM COS<br/>443/TCP HTTPS]
        GCS[Google Cloud Storage<br/>443/TCP HTTPS]
        Azure[Azure Blob Storage<br/>443/TCP HTTPS]
        HTTP[HTTP/HTTPS Server<br/>80/443/TCP]
    end

    PullmanLib -->|"TLS 1.2+<br/>Cloud credentials"| S3
    PullmanLib -->|"TLS 1.2+<br/>SA credentials"| GCS
    PullmanLib -->|"TLS 1.2+<br/>SP credentials"| Azure
    PullmanLib -->|"TLS 1.2+<br/>Custom headers/mTLS"| HTTP

    PVC[PVC Filesystem<br/>Symlink Mount] -.->|"/pvc_mounts"| PullmanLib

    K8sSecret["storage-config Secret<br/>/storage-config mount"] -.->|"credentials"| PullerSidecar

    MMConfig["model-serving-config<br/>ConfigMap"] -.->|"storageHelperImage"| ModelServerPod

