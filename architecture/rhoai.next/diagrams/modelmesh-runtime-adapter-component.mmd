graph TB
    subgraph Pod["ModelMesh Serving Pod"]
        direction TB

        subgraph Puller["model-serving-puller"]
            PullerSvc["Puller gRPC Server<br/>8084/TCP<br/>mmesh.ModelRuntime"]
            Pullman["pullman Library<br/>Storage Provider Abstraction"]
            PullerSvc --> Pullman
        end

        subgraph Adapters["Runtime Adapters (one per pod)"]
            TritonAdapter["triton-adapter<br/>8085/TCP gRPC"]
            MLServerAdapter["mlserver-adapter<br/>8085/TCP gRPC"]
            OVMSAdapter["ovms-adapter<br/>8085/TCP gRPC"]
            TorchServeAdapter["torchserve-adapter<br/>8085/TCP gRPC"]
        end

        subgraph Runtimes["Inference Runtimes (one per pod)"]
            Triton["NVIDIA Triton<br/>8001/TCP gRPC"]
            MLServer["SeldonIO MLServer<br/>8001/TCP gRPC"]
            OVMS["OpenVINO Model Server<br/>8001/TCP HTTP"]
            TorchServe["TorchServe<br/>7071/TCP mgmt gRPC<br/>7070/TCP inference gRPC"]
        end

        subgraph Scripts["Conversion Scripts"]
            TfPb["tf_pb.py<br/>Keras → TensorFlow<br/>SavedModel Conversion"]
        end

        PullerSvc -->|"gRPC LoadModel<br/>8085/TCP"| TritonAdapter
        PullerSvc -->|"gRPC LoadModel<br/>8085/TCP"| MLServerAdapter
        PullerSvc -->|"gRPC LoadModel<br/>8085/TCP"| OVMSAdapter
        PullerSvc -->|"gRPC LoadModel<br/>8085/TCP"| TorchServeAdapter

        TritonAdapter -->|"gRPC RepositoryModelLoad<br/>8001/TCP"| Triton
        MLServerAdapter -->|"gRPC RepositoryModelLoad<br/>8001/TCP"| MLServer
        OVMSAdapter -->|"HTTP POST /v1/config/reload<br/>8001/TCP"| OVMS
        TorchServeAdapter -->|"gRPC RegisterModel<br/>7071/TCP"| TorchServe

        TritonAdapter -.->|"subprocess exec"| TfPb
    end

    ModelMesh["ModelMesh Controller<br/>(modelmesh-serving)"] -->|"gRPC LoadModel/UnloadModel<br/>8084/TCP"| PullerSvc

    StorageConfig["/storage-config<br/>K8s Secret Volume Mount"] -.->|"credentials"| Pullman

    subgraph CloudStorage["Cloud Storage (Egress)"]
        S3["AWS S3 / IBM COS<br/>443/TCP HTTPS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
        HTTP["HTTP/HTTPS Endpoints<br/>configurable"]
    end

    Pullman -->|"HTTPS/443<br/>TLS 1.2+"| S3
    Pullman -->|"HTTPS/443<br/>TLS 1.2+"| GCS
    Pullman -->|"HTTPS/443<br/>TLS 1.2+"| Azure
    Pullman -->|"HTTP/HTTPS"| HTTP

    PVC["/pvc_mounts<br/>PVC Volume"] -.->|"symlink"| Pullman

    style PullerSvc fill:#4a90e2,stroke:#333,color:#fff
    style Pullman fill:#4a90e2,stroke:#333,color:#fff
    style TritonAdapter fill:#7ed321,stroke:#333,color:#fff
    style MLServerAdapter fill:#7ed321,stroke:#333,color:#fff
    style OVMSAdapter fill:#7ed321,stroke:#333,color:#fff
    style TorchServeAdapter fill:#7ed321,stroke:#333,color:#fff
    style Triton fill:#f5a623,stroke:#333,color:#fff
    style MLServer fill:#f5a623,stroke:#333,color:#fff
    style OVMS fill:#f5a623,stroke:#333,color:#fff
    style TorchServe fill:#f5a623,stroke:#333,color:#fff
    style TfPb fill:#9b59b6,stroke:#333,color:#fff
    style ModelMesh fill:#e74c3c,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style Azure fill:#999,stroke:#333,color:#fff
    style HTTP fill:#999,stroke:#333,color:#fff
    style StorageConfig fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
