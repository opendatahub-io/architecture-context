graph TB
    subgraph Pod["ModelMesh Serving Pod"]
        direction TB

        subgraph Sidecar["modelmesh-runtime-adapter (Sidecar Container)"]
            direction TB

            subgraph PullerBlock["Model Serving Puller"]
                Puller["model-serving-puller<br/>gRPC :8084<br/>mmesh.ModelRuntime"]
                Pullman["pullman Library<br/>(pluggable storage providers)"]
                Puller -->|"uses"| Pullman
            end

            subgraph Adapters["Runtime Adapters (one active per pod)"]
                direction LR
                TritonAdapter["triton-adapter<br/>gRPC :8085"]
                MLServerAdapter["mlserver-adapter<br/>gRPC :8085"]
                OVMSAdapter["ovms-adapter<br/>gRPC :8085"]
                TorchServeAdapter["torchserve-adapter<br/>gRPC :8085"]
            end

            Puller -->|"gRPC :8085<br/>LoadModel/UnloadModel"| TritonAdapter
            Puller -->|"gRPC :8085"| MLServerAdapter
            Puller -->|"gRPC :8085"| OVMSAdapter
            Puller -->|"gRPC :8085"| TorchServeAdapter
        end

        subgraph Runtimes["Model Serving Runtime (one active per pod)"]
            direction LR
            Triton["NVIDIA Triton<br/>gRPC :8001"]
            MLServer["Seldon MLServer<br/>gRPC :8001"]
            OVMS["OpenVINO Model Server<br/>HTTP :8001"]
            TorchServe["TorchServe<br/>gRPC :7071 (mgmt)<br/>gRPC :7070 (inference)"]
        end

        TritonAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| Triton
        MLServerAdapter -->|"gRPC :8001<br/>RepositoryModelLoad/Unload"| MLServer
        OVMSAdapter -->|"HTTP :8001<br/>POST /v1/config/reload"| OVMS
        TorchServeAdapter -->|"gRPC :7071<br/>RegisterModel/UnregisterModel"| TorchServe
    end

    ModelMesh["ModelMesh Controller<br/>(modelmesh-serving)"] -->|"gRPC :8084<br/>LoadModel / UnloadModel<br/>RuntimeStatus / PredictModelSize"| Puller

    subgraph CloudStorage["Cloud Storage (External)"]
        S3["S3 / IBM COS / MinIO<br/>HTTPS :443"]
        GCS["Google Cloud Storage<br/>HTTPS :443"]
        Azure["Azure Blob Storage<br/>HTTPS :443"]
        HTTP["HTTP/HTTPS Endpoints<br/>configurable"]
    end

    Pullman -->|"HTTPS :443<br/>AWS IAM"| S3
    Pullman -->|"HTTPS :443<br/>GCP SA JWT"| GCS
    Pullman -->|"HTTPS :443<br/>Service Principal"| Azure
    Pullman -->|"HTTP/HTTPS<br/>Custom Headers/Certs"| HTTP

    K8sSecrets["Kubernetes Secrets<br/>/storage-config"]
    PVC["PVC Mounts<br/>/pvc_mounts"]

    K8sSecrets -.->|"volume mount"| Pullman
    PVC -.->|"symlink"| Puller

    %% Styling
    style Puller fill:#4a90e2,stroke:#333,color:#fff
    style Pullman fill:#4a90e2,stroke:#333,color:#fff
    style TritonAdapter fill:#5b9bd5,stroke:#333,color:#fff
    style MLServerAdapter fill:#5b9bd5,stroke:#333,color:#fff
    style OVMSAdapter fill:#5b9bd5,stroke:#333,color:#fff
    style TorchServeAdapter fill:#5b9bd5,stroke:#333,color:#fff
    style Triton fill:#7ed321,stroke:#333,color:#fff
    style MLServer fill:#7ed321,stroke:#333,color:#fff
    style OVMS fill:#7ed321,stroke:#333,color:#fff
    style TorchServe fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style Azure fill:#e8e8e8,stroke:#333
    style HTTP fill:#e8e8e8,stroke:#333
    style K8sSecrets fill:#fff2cc,stroke:#d6b656
    style PVC fill:#fff2cc,stroke:#d6b656
