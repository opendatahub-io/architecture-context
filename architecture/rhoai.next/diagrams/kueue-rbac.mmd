graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kueue-controller-manager<br/>(kueue-system / opendatahub)"]
    end

    subgraph ClusterBindings["Cluster Role Bindings"]
        CRB["kueue-manager-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph NamespaceBindings["Namespace Role Bindings"]
        LERB["kueue-leader-election-rolebinding<br/>(kueue-system / opendatahub)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["kueue-manager-role"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        LER["kueue-leader-election-role"]
    end

    subgraph KueueCRDs["Kueue CRDs (kueue.x-k8s.io)"]
        CQ["ClusterQueues<br/>+ status, finalizers"]
        LQ["LocalQueues<br/>+ status, finalizers"]
        WL["Workloads<br/>+ status, finalizers"]
        AC["AdmissionChecks<br/>+ status, finalizers"]
        RF["ResourceFlavors<br/>+ finalizers"]
        Cohort["Cohorts<br/>+ status"]
        MKConfig["MultiKueueConfigs"]
        MKCluster["MultiKueueClusters<br/>+ status"]
        PRC["ProvisioningRequestConfigs"]
        WPC["WorkloadPriorityClasses"]
        Topo["Topologies<br/>+ finalizers"]
    end

    subgraph JobFrameworks["Job Framework Resources"]
        BatchJobs["batch Jobs<br/>+ status, finalizers"]
        KubeflowJobs["kubeflow.org<br/>PyTorchJobs, TFJobs,<br/>XGBoostJobs, PaddleJobs,<br/>MPIJobs + status, finalizers"]
        RayResources["ray.io<br/>RayClusters, RayJobs<br/>+ status, finalizers"]
        JobSets["jobset.x-k8s.io<br/>JobSets + status, finalizers"]
        AppWrappers["workload.codeflare.dev<br/>AppWrappers + status, finalizers"]
        LWSets["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
    end

    subgraph CoreResources["Core K8s Resources"]
        Namespaces["Namespaces"]
        Events["Events"]
        LimitRanges["LimitRanges"]
        Pods["Pods + status, finalizers"]
        Nodes["Nodes"]
        PodTemplates["PodTemplates"]
        RuntimeClasses["RuntimeClasses<br/>(node.k8s.io)"]
        PriorityClasses["PriorityClasses<br/>(scheduling.k8s.io)"]
        Deployments["Deployments, ReplicaSets,<br/>StatefulSets (apps)"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        ProvReqs["ProvisioningRequests<br/>+ status<br/>(autoscaling.x-k8s.io)"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        Leases["Leases"]
        ConfigMaps["ConfigMaps"]
        LEEvents["Events"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via"| LERB
    CRB -->|"grants"| CR
    LERB -->|"grants"| LER

    %% ClusterRole → Kueue CRDs
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| CQ
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| LQ
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| WL
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| AC
    CR -->|"get,list,watch,<br/>update,delete"| RF
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Cohort
    CR -->|"get,list,watch"| MKConfig
    CR -->|"get,list,watch,<br/>update,patch"| MKCluster
    CR -->|"get,list,watch"| PRC
    CR -->|"get,list,watch"| WPC
    CR -->|"get,list,watch,<br/>update"| Topo

    %% ClusterRole → Job Frameworks
    CR -->|"get,list,watch,<br/>update,patch"| BatchJobs
    CR -->|"get,list,watch,<br/>update,patch"| KubeflowJobs
    CR -->|"get,list,watch,<br/>update,patch"| RayResources
    CR -->|"get,list,watch,<br/>update,patch"| JobSets
    CR -->|"get,list,watch,<br/>update,patch"| AppWrappers
    CR -->|"get,list,watch"| LWSets

    %% ClusterRole → Core Resources
    CR -->|"get,list,watch"| Namespaces
    CR -->|"create,watch,<br/>update,patch"| Events
    CR -->|"get,list,watch"| LimitRanges
    CR -->|"get,list,watch,update,<br/>patch,delete"| Pods
    CR -->|"get,list,watch"| Nodes
    CR -->|"get,list,watch,create,<br/>delete,update"| PodTemplates
    CR -->|"get,list,watch"| RuntimeClasses
    CR -->|"list,get,watch"| PriorityClasses
    CR -->|"get,list,watch"| Deployments

    %% ClusterRole → Autoscaling
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| ProvReqs

    %% Leader Election Role
    LER -->|"get,list,watch,create,<br/>update,patch,delete"| Leases
    LER -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    LER -->|"create,patch"| LEEvents

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style LER fill:#f5a623,stroke:#333,color:#fff
    style CRB fill:#e1d5e7,stroke:#9673a6
    style LERB fill:#e1d5e7,stroke:#9673a6

    style CQ fill:#7ed321,stroke:#333,color:#fff
    style LQ fill:#7ed321,stroke:#333,color:#fff
    style WL fill:#7ed321,stroke:#333,color:#fff
    style AC fill:#7ed321,stroke:#333,color:#fff
    style RF fill:#7ed321,stroke:#333,color:#fff
    style Cohort fill:#7ed321,stroke:#333,color:#fff
    style MKConfig fill:#7ed321,stroke:#333,color:#fff
    style MKCluster fill:#7ed321,stroke:#333,color:#fff
    style PRC fill:#7ed321,stroke:#333,color:#fff
    style WPC fill:#7ed321,stroke:#333,color:#fff
    style Topo fill:#7ed321,stroke:#333,color:#fff

    style BatchJobs fill:#dae8fc,stroke:#6c8ebf
    style KubeflowJobs fill:#dae8fc,stroke:#6c8ebf
    style RayResources fill:#dae8fc,stroke:#6c8ebf
    style JobSets fill:#dae8fc,stroke:#6c8ebf
    style AppWrappers fill:#dae8fc,stroke:#6c8ebf
    style LWSets fill:#dae8fc,stroke:#6c8ebf

    style Namespaces fill:#f5f5f5,stroke:#999
    style Events fill:#f5f5f5,stroke:#999
    style LimitRanges fill:#f5f5f5,stroke:#999
    style Pods fill:#f5f5f5,stroke:#999
    style Nodes fill:#f5f5f5,stroke:#999
    style PodTemplates fill:#f5f5f5,stroke:#999
    style RuntimeClasses fill:#f5f5f5,stroke:#999
    style PriorityClasses fill:#f5f5f5,stroke:#999
    style Deployments fill:#f5f5f5,stroke:#999

    style ProvReqs fill:#fff2cc,stroke:#d6b656
    style Leases fill:#f8cecc,stroke:#b85450
    style ConfigMaps fill:#f8cecc,stroke:#b85450
    style LEEvents fill:#f8cecc,stroke:#b85450
