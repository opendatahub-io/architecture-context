graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kueue-controller-manager<br/>Namespace: opendatahub"]
    end

    subgraph ClusterBindings["ClusterRole Bindings"]
        CRB["kueue-manager-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["kueue-leader-election-rolebinding<br/>Namespace: kueue-system"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["manager-role"]
        LER["leader-election-role"]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR
    SA -->|bound via| RB
    RB -->|grants| LER

    %% Kueue CRD Permissions
    subgraph KueueResources["kueue.x-k8s.io Resources"]
        KQ_Full["clusterqueues, localqueues,<br/>workloads, admissionchecks, cohorts<br/>✅ create, delete, get, list,<br/>patch, update, watch"]
        KQ_Read["multikueueclusters, multikueueconfigs,<br/>provisioningrequestconfigs,<br/>workloadpriorityclasses<br/>📖 get, list, watch"]
        KQ_Finalizers["*/finalizers<br/>(clusterqueues, localqueues, workloads,<br/>resourceflavors, topologies, admissionchecks)<br/>🔒 update"]
        KQ_Status["*/status<br/>(clusterqueues, localqueues, workloads,<br/>cohorts, multikueueclusters, admissionchecks)<br/>📝 get, patch, update"]
        KQ_RF["resourceflavors<br/>📝 delete, get, list, update, watch"]
        KQ_Topo["topologies<br/>📝 get, list, update, watch"]
    end

    %% Core K8s Resources
    subgraph CoreResources["Core Kubernetes Resources"]
        Pods["pods<br/>📝 delete, get, list, patch,<br/>update, watch"]
        PodFin["pods/finalizers<br/>🔒 get, update"]
        PodStatus["pods/status<br/>📝 get, patch"]
        Secrets["secrets<br/>📝 get, list, update, watch"]
        Events["events<br/>📝 create, patch, update, watch"]
        ReadOnly["limitranges, namespaces, nodes<br/>📖 get, list, watch"]
        PodTemplates["podtemplates<br/>📝 create, delete, get,<br/>list, update, watch"]
    end

    %% Batch Resources
    subgraph BatchResources["batch Resources"]
        Jobs["jobs<br/>📝 get, list, patch,<br/>update, watch"]
        JobsFin["jobs/finalizers, jobs/status<br/>📝 get, patch, update"]
    end

    %% Kubeflow Resources
    subgraph KubeflowResources["kubeflow.org Resources"]
        KFJobs["pytorchjobs, tfjobs,<br/>xgboostjobs, paddlejobs, mpijobs<br/>📝 get, list, patch, update, watch"]
        KFJobsFin["*/finalizers<br/>🔒 get, update"]
        KFJobsStatus["*/status<br/>📝 get, patch, update"]
    end

    %% Ray Resources
    subgraph RayResources["ray.io Resources"]
        RayWL["rayclusters, rayjobs<br/>📝 get, list, patch, update, watch"]
        RayFin["*/finalizers<br/>🔒 get, update"]
        RayStatus["*/status<br/>📝 get, patch, update"]
    end

    %% Other Integration Resources
    subgraph OtherResources["Other Integration Resources"]
        JobSets["jobset.x-k8s.io jobsets<br/>📝 get, list, patch, update, watch"]
        AppWrappers["workload.codeflare.dev appwrappers<br/>📝 get, list, patch, update, watch"]
        ProvReqs["autoscaling.x-k8s.io provisioningrequests<br/>✅ create, delete, get, list,<br/>patch, update, watch"]
        Webhooks["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>📝 get, list, update, watch"]
        AppsRead["apps deployments, replicasets,<br/>statefulsets<br/>📖 get, list, watch"]
        FlowControl["flowcontrol.apiserver.k8s.io<br/>flowschemas, prioritylevelconfigurations<br/>📖 list, watch"]
        PriorityClasses["scheduling.k8s.io priorityclasses<br/>📖 get, list, watch"]
        RuntimeClasses["node.k8s.io runtimeclasses<br/>📖 get, list, watch"]
        LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/>📖 get, list, watch"]
    end

    %% Connect ClusterRole to resources
    CR -->|"full CRUD"| KueueResources
    CR -->|"manage"| CoreResources
    CR -->|"manage"| BatchResources
    CR -->|"manage"| KubeflowResources
    CR -->|"manage"| RayResources
    CR -->|"manage"| OtherResources

    %% Styling
    style SA fill:#1565c0,color:#fff
    style CRB fill:#42a5f5,color:#fff
    style RB fill:#42a5f5,color:#fff
    style CR fill:#f5a623,color:#fff
    style LER fill:#f5a623,color:#fff

    style KueueResources fill:#e8f5e9,stroke:#2e7d32
    style CoreResources fill:#e3f2fd,stroke:#1565c0
    style BatchResources fill:#fff3e0,stroke:#ef6c00
    style KubeflowResources fill:#fce4ec,stroke:#c62828
    style RayResources fill:#f3e5f5,stroke:#7b1fa2
    style OtherResources fill:#f5f5f5,stroke:#616161
