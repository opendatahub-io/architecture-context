graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kueue-controller-manager<br/>(namespace: opendatahub)"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["kueue-manager-rolebinding<br/>(ClusterRoleBinding)"]
        RB["kueue-leader-election-rolebinding<br/>(RoleBinding, ns: opendatahub)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["kueue-manager-role<br/>(ClusterRole)"]
        LER["kueue-leader-election-role<br/>(Role, ns: opendatahub)"]
    end

    subgraph KueueResources["Kueue CRDs (kueue.x-k8s.io)"]
        KueueCRDs["ClusterQueues, LocalQueues,<br/>Workloads, AdmissionChecks,<br/>Cohorts, ResourceFlavors,<br/>Topologies, WorkloadPriorityClasses,<br/>MultiKueueClusters, MultiKueueConfigs,<br/>ProvisioningRequestConfigs"]
    end

    subgraph BatchResources["Batch & ML Frameworks"]
        Jobs["batch/v1 Jobs<br/>get, list, patch, update, watch"]
        JobSets["jobset.x-k8s.io JobSets<br/>get, list, patch, update, watch"]
        Kubeflow["kubeflow.org<br/>PyTorchJob, TFJob, MPIJob,<br/>XGBoostJob, PaddleJob<br/>get, list, patch, update, watch"]
        Ray["ray.io<br/>RayJobs, RayClusters<br/>get, list, patch, update, watch"]
        CodeFlare["workload.codeflare.dev<br/>AppWrappers<br/>get, list, patch, update, watch"]
        LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets<br/>get, list, watch"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        Pods["Pods<br/>delete, get, list, patch, update, watch"]
        PodsFinalizers["Pods/finalizers<br/>get, update"]
        PodsStatus["Pods/status<br/>get, patch"]
        PodTemplates["PodTemplates<br/>create, delete, get, list, update, watch"]
        Secrets["Secrets<br/>get, list, update, watch"]
        Events["Events<br/>create, patch, update, watch"]
        ReadOnly["Namespaces, Nodes, LimitRanges<br/>get, list, watch"]
    end

    subgraph InfraResources["Infrastructure Resources"]
        Webhooks["admissionregistration.k8s.io<br/>MutatingWebhookConfigs,<br/>ValidatingWebhookConfigs<br/>get, list, update, watch"]
        AppsReadOnly["apps/v1<br/>Deployments, ReplicaSets,<br/>StatefulSets<br/>get, list, watch"]
        Provisioning["autoscaling.x-k8s.io<br/>ProvisioningRequests<br/>create, delete, get, list,<br/>patch, update, watch"]
        FlowControl["flowcontrol.apiserver.k8s.io<br/>FlowSchemas,<br/>PriorityLevelConfigs<br/>list, watch, patch (status)"]
        Scheduling["scheduling.k8s.io<br/>PriorityClasses<br/>get, list, watch"]
        RuntimeClasses["node.k8s.io<br/>RuntimeClasses<br/>get, list, watch"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        Leases["coordination.k8s.io<br/>Leases<br/>create, get, update"]
        ConfigMaps["ConfigMaps<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB
    CRB -->|grants| CR
    RB -->|grants| LER

    %% ClusterRole permissions
    CR -->|"full CRUD +<br/>finalizers, status"| KueueCRDs
    CR -->|manages| BatchResources
    CR -->|manages| CoreResources
    CR -->|manages| InfraResources

    %% Leader election permissions
    LER -->|manages| LeaderElection

