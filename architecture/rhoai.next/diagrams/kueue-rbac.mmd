graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kueue-controller-manager<br/>Namespace: kueue-system / opendatahub"]
    end

    subgraph ClusterBindings["ClusterRole Bindings"]
        CRB["kueue-manager-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph NamespacedBindings["Role Bindings (Namespaced)"]
        LERB["kueue-leader-election-rolebinding<br/>Namespace: kueue-system / opendatahub"]
    end

    subgraph ClusterRoles["ClusterRole: kueue-manager-role"]
        direction TB

        subgraph KueueCRDs["kueue.x-k8s.io Resources"]
            CQ["ClusterQueues<br/>+ status, finalizers"]
            LQ["LocalQueues<br/>+ status, finalizers"]
            WL["Workloads<br/>+ status, finalizers"]
            AC["AdmissionChecks<br/>+ status, finalizers"]
            RF["ResourceFlavors<br/>+ finalizers"]
            Cohorts["Cohorts<br/>+ status"]
            MKCluster["MultiKueueClusters<br/>+ status"]
            MKConfig["MultiKueueConfigs"]
            PRC["ProvisioningRequestConfigs"]
            WPC["WorkloadPriorityClasses"]
            Topo["Topologies<br/>+ finalizers"]
        end

        subgraph CoreResources["Core API Resources"]
            NS["Namespaces"]
            Events["Events"]
            LR["LimitRanges"]
            PodsRes["Pods + status, finalizers"]
            Nodes["Nodes"]
            PodTemplates["PodTemplates"]
        end

        subgraph JobResources["Job Framework Resources"]
            BatchJobs["batch: Jobs<br/>+ status, finalizers"]
            AppsRes["apps: Deployments,<br/>ReplicaSets, StatefulSets"]
            JobSets["jobset.x-k8s.io: JobSets<br/>+ status, finalizers"]
            KubeflowJobs["kubeflow.org: PyTorchJobs,<br/>TFJobs, XGBoostJobs,<br/>PaddleJobs, MPIJobs<br/>+ status, finalizers"]
            RayRes["ray.io: RayClusters,<br/>RayJobs<br/>+ status, finalizers"]
            AppWrappers["workload.codeflare.dev:<br/>AppWrappers<br/>+ status, finalizers"]
            LWSRes["leaderworkerset.x-k8s.io:<br/>LeaderWorkerSets"]
        end

        subgraph AutoscalingRes["Autoscaling Resources"]
            ProvReqs["autoscaling.x-k8s.io:<br/>ProvisioningRequests<br/>+ status"]
        end

        subgraph OtherRes["Other Resources"]
            RuntimeClasses["node.k8s.io:<br/>RuntimeClasses"]
            PriorityClasses["scheduling.k8s.io:<br/>PriorityClasses"]
        end
    end

    subgraph NamespacedRoles["Role: kueue-leader-election-role"]
        LeaderElection["coordination.k8s.io: Leases<br/>Verbs: get, create, update"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via"| LERB
    CRB -->|"grants"| ClusterRoles
    LERB -->|"grants"| NamespacedRoles

    %% Verbs annotations
    CQ -.-|"get, list, watch,<br/>create, update, patch, delete"| CQ
    LQ -.-|"get, list, watch,<br/>create, update, patch, delete"| LQ
    WL -.-|"get, list, watch,<br/>create, update, patch, delete"| WL
    BatchJobs -.-|"get, list, watch,<br/>update, patch"| BatchJobs
    KubeflowJobs -.-|"get, list, watch,<br/>update, patch"| KubeflowJobs
    ProvReqs -.-|"get, list, watch,<br/>create, update, patch, delete"| ProvReqs

    %% Styles
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#e1d5e7,stroke:#9673a6
    style LERB fill:#e1d5e7,stroke:#9673a6
    style ClusterRoles fill:#fff2cc,stroke:#d6b656
    style NamespacedRoles fill:#fff2cc,stroke:#d6b656

    style CQ fill:#d5e8d4,stroke:#82b366
    style LQ fill:#d5e8d4,stroke:#82b366
    style WL fill:#d5e8d4,stroke:#82b366
    style AC fill:#d5e8d4,stroke:#82b366
    style RF fill:#d5e8d4,stroke:#82b366
    style Cohorts fill:#d5e8d4,stroke:#82b366
    style MKCluster fill:#d5e8d4,stroke:#82b366
    style MKConfig fill:#d5e8d4,stroke:#82b366
    style PRC fill:#d5e8d4,stroke:#82b366
    style WPC fill:#d5e8d4,stroke:#82b366
    style Topo fill:#d5e8d4,stroke:#82b366

    style NS fill:#dae8fc,stroke:#6c8ebf
    style Events fill:#dae8fc,stroke:#6c8ebf
    style LR fill:#dae8fc,stroke:#6c8ebf
    style PodsRes fill:#dae8fc,stroke:#6c8ebf
    style Nodes fill:#dae8fc,stroke:#6c8ebf
    style PodTemplates fill:#dae8fc,stroke:#6c8ebf

    style BatchJobs fill:#f8cecc,stroke:#b85450
    style AppsRes fill:#f8cecc,stroke:#b85450
    style JobSets fill:#f8cecc,stroke:#b85450
    style KubeflowJobs fill:#f8cecc,stroke:#b85450
    style RayRes fill:#f8cecc,stroke:#b85450
    style AppWrappers fill:#f8cecc,stroke:#b85450
    style LWSRes fill:#f8cecc,stroke:#b85450

    style ProvReqs fill:#ffe6cc,stroke:#d79b00
    style RuntimeClasses fill:#f5f5f5,stroke:#666
    style PriorityClasses fill:#f5f5f5,stroke:#666
    style LeaderElection fill:#fff2cc,stroke:#d6b656
