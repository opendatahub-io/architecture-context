graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["kueue-controller-manager<br/>Namespace: opendatahub"]
        SA_Metrics["kueue-controller-manager-<br/>metrics-reader<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["kueue-manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["kueue-metrics-reader-<br/>clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings (namespaced)"]
        RB_Leader["kueue-leader-election-<br/>rolebinding<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["kueue-manager-role"]
        CR_Metrics["kueue-metrics-reader"]
    end

    subgraph Roles["Roles (namespaced)"]
        R_Leader["kueue-leader-election-role<br/>Namespace: opendatahub"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        Pods["core/v1<br/>Pods, Pods/finalizers,<br/>Pods/status"]
        Events["core/v1<br/>Events"]
        Secrets["core/v1<br/>Secrets"]
        Nodes["core/v1<br/>Nodes, Namespaces,<br/>LimitRanges"]
        PodTemplates["core/v1<br/>PodTemplates"]
    end

    subgraph AppsResources["Apps Resources"]
        Deployments["apps/v1<br/>Deployments, ReplicaSets,<br/>StatefulSets"]
    end

    subgraph BatchResources["Batch Resources"]
        Jobs["batch/v1<br/>Jobs, Jobs/finalizers,<br/>Jobs/status"]
    end

    subgraph KueueResources["Kueue CRD Resources"]
        KueueCore["kueue.x-k8s.io<br/>ClusterQueues, LocalQueues,<br/>Workloads, AdmissionChecks,<br/>Cohorts"]
        KueueConfig["kueue.x-k8s.io<br/>ResourceFlavors, Topologies,<br/>WorkloadPriorityClasses"]
        KueueMulti["kueue.x-k8s.io<br/>MultiKueueClusters,<br/>MultiKueueConfigs,<br/>ProvisioningRequestConfigs"]
    end

    subgraph MLResources["ML Framework Resources"]
        KubeflowJobs["kubeflow.org<br/>PyTorchJobs, TFJobs,<br/>MPIJobs, PaddleJobs,<br/>XGBoostJobs<br/>+ /finalizers, /status"]
        RayResources["ray.io<br/>RayJobs, RayClusters<br/>+ /finalizers, /status"]
        AppWrappers["workload.codeflare.dev<br/>AppWrappers<br/>+ /finalizers, /status"]
        JobSets["jobset.x-k8s.io<br/>JobSets<br/>+ /finalizers, /status"]
        LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
    end

    subgraph OtherResources["Other Resources"]
        Webhooks["admissionregistration.k8s.io<br/>MutatingWebhookConfigurations,<br/>ValidatingWebhookConfigurations"]
        FlowControl["flowcontrol.apiserver.k8s.io<br/>FlowSchemas,<br/>PriorityLevelConfigurations"]
        ProvReqs["autoscaling.x-k8s.io<br/>ProvisioningRequests<br/>+ /status"]
        PriorityClass["scheduling.k8s.io<br/>PriorityClasses"]
        RuntimeClass["node.k8s.io<br/>RuntimeClasses"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        Leases["coordination.k8s.io<br/>Leases"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    SA_Metrics -->|bound via| CRB_Metrics

    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    RB_Leader -->|grants| R_Leader

    %% Manager role permissions
    CR_Manager -->|"get, list, watch,<br/>delete, patch, update"| Pods
    CR_Manager -->|"create, patch,<br/>update, watch"| Events
    CR_Manager -->|"get, list,<br/>update, watch"| Secrets
    CR_Manager -->|"get, list, watch"| Nodes
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| PodTemplates
    CR_Manager -->|"get, list, watch"| Deployments
    CR_Manager -->|"get, list, patch,<br/>update, watch"| Jobs
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| KueueCore
    CR_Manager -->|"delete, get, list,<br/>update, watch"| KueueConfig
    CR_Manager -->|"get, list, watch"| KueueMulti
    CR_Manager -->|"get, list, patch,<br/>update, watch"| KubeflowJobs
    CR_Manager -->|"get, list, patch,<br/>update, watch"| RayResources
    CR_Manager -->|"get, list, patch,<br/>update, watch"| AppWrappers
    CR_Manager -->|"get, list, patch,<br/>update, watch"| JobSets
    CR_Manager -->|"get, list, watch"| LWS
    CR_Manager -->|"get, list,<br/>update, watch"| Webhooks
    CR_Manager -->|"list, watch, patch"| FlowControl
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| ProvReqs
    CR_Manager -->|"get, list, watch"| PriorityClass
    CR_Manager -->|"get, list, watch"| RuntimeClass

    %% Leader election permissions
    R_Leader -->|"get, create,<br/>update"| Leases
    R_Leader -->|"get, list, watch,<br/>create, update"| ConfigMaps
    R_Leader -->|"create, patch"| Events

