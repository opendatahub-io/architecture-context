graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["kueue-controller-manager<br/>Namespace: opendatahub"]
        SA_Metrics["kueue-controller-manager-metrics-reader"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["kueue-manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["kueue-metrics-reader-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings (namespace: opendatahub)"]
        RB_Leader["kueue-leader-election-rolebinding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["kueue-manager-role"]
        CR_Metrics["kueue-metrics-reader"]
    end

    subgraph Roles["Roles (namespace: opendatahub)"]
        R_Leader["kueue-leader-election-role"]
    end

    subgraph KueueCRDs["Kueue CRDs (kueue.x-k8s.io)"]
        CQ["ClusterQueue<br/>create,delete,get,list,<br/>patch,update,watch"]
        LQ["LocalQueue<br/>create,delete,get,list,<br/>patch,update,watch"]
        WL["Workload<br/>create,delete,get,list,<br/>patch,update,watch"]
        RF["ResourceFlavor<br/>delete,get,list,update,watch"]
        AC["AdmissionCheck<br/>create,delete,get,list,<br/>patch,update,watch"]
        WPC["WorkloadPriorityClass<br/>get,list,watch"]
        MKC["MultiKueueCluster<br/>get,list,watch"]
        MKCfg["MultiKueueConfig<br/>get,list,watch"]
        Topo["Topology<br/>get,list,update,watch"]
        Cohort["Cohort<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph JobCRDs["Job Framework CRDs"]
        Jobs["batch/v1 Job<br/>get,list,patch,update,watch"]
        JobSets["jobset.x-k8s.io/JobSet<br/>get,list,patch,update,watch"]
        PyTorch["kubeflow.org/PyTorchJob<br/>get,list,patch,update,watch"]
        TFJob["kubeflow.org/TFJob<br/>get,list,patch,update,watch"]
        MPIJob["kubeflow.org/MPIJob<br/>get,list,patch,update,watch"]
        RayJob["ray.io/RayJob<br/>get,list,patch,update,watch"]
        RayCluster["ray.io/RayCluster<br/>get,list,patch,update,watch"]
        AppWrapper["workload.codeflare.dev/AppWrapper<br/>get,list,patch,update,watch"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        PodsRes["Pods<br/>delete,get,list,patch,<br/>update,watch"]
        Events["Events<br/>create,patch,update,watch"]
        Secrets["Secrets<br/>get,list,update,watch"]
        Nodes["Nodes<br/>get,list,watch"]
        NS["Namespaces<br/>get,list,watch"]
        Deploys["Deployments<br/>get,list,watch"]
        PR["ProvisioningRequests<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| RB_Leader
    SA_Metrics -->|"bound via"| CRB_Metrics

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_Leader -->|"grants"| R_Leader

    %% Permission grants
    CR_Manager -->|"manages"| KueueCRDs
    CR_Manager -->|"manages"| JobCRDs
    CR_Manager -->|"manages"| CoreResources

