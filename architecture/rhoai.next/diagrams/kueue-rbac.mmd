graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Main["kueue-controller-manager<br/>(ns: opendatahub)"]
        SA_Metrics["kueue-controller-manager<br/>-metrics-reader<br/>(ns: opendatahub)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["kueue-manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["kueue-metrics-reader<br/>-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["kueue-leader-election<br/>-rolebinding<br/>(ns: opendatahub)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["kueue-manager-role"]
        CR_Metrics["kueue-metrics-reader"]
    end

    subgraph Roles["Roles"]
        R_Leader["kueue-leader-election-role<br/>(ns: opendatahub)"]
    end

    subgraph CoreAPI["Core API Resources"]
        Events["events<br/>create, patch,<br/>update, watch"]
        Pods["pods<br/>delete, get, list,<br/>patch, update, watch"]
        PodsFinalizers["pods/finalizers<br/>get, update"]
        PodsStatus["pods/status<br/>get, patch"]
        PodTemplates["podtemplates<br/>create, delete, get,<br/>list, update, watch"]
        Secrets["secrets<br/>get, list,<br/>update, watch"]
        ReadOnly["limitranges,<br/>namespaces, nodes<br/>get, list, watch"]
    end

    subgraph KueueAPI["kueue.x-k8s.io Resources"]
        KueueCRDs["clusterqueues,<br/>localqueues,<br/>workloads,<br/>admissionchecks,<br/>cohorts<br/>full CRUD"]
        KueueFinalizers["All CRD /finalizers<br/>update"]
        KueueStatus["All CRD /status<br/>get, patch, update"]
        KueueReadOnly["multikueueclusters,<br/>multikueueconfigs,<br/>provisioningrequestconfigs,<br/>workloadpriorityclasses<br/>get, list, watch"]
        ResourceFlavors["resourceflavors<br/>delete, get, list,<br/>update, watch"]
        Topologies["topologies<br/>get, list,<br/>update, watch"]
    end

    subgraph JobAPIs["Job Framework Resources"]
        BatchJobs["batch/jobs<br/>get, list, patch,<br/>update, watch"]
        KubeflowJobs["kubeflow.org/*jobs<br/>get, list, patch,<br/>update, watch<br/>+ finalizers + status"]
        RayResources["ray.io/rayclusters,<br/>rayjobs<br/>get, list, patch,<br/>update, watch<br/>+ finalizers + status"]
        JobSets["jobset.x-k8s.io/<br/>jobsets<br/>get, list, patch,<br/>update, watch<br/>+ finalizers + status"]
        AppWrappers["workload.codeflare.dev/<br/>appwrappers<br/>get, list, patch,<br/>update, watch<br/>+ finalizers + status"]
    end

    subgraph OtherAPIs["Other API Resources"]
        AdmissionReg["admissionregistration<br/>webhook configs<br/>get, list, update, watch"]
        Apps["apps/deployments,<br/>replicasets,<br/>statefulsets<br/>get, list, watch"]
        Autoscaling["autoscaling.x-k8s.io/<br/>provisioningrequests<br/>full CRUD + status"]
        FlowControl["flowcontrol<br/>flowschemas,<br/>prioritylevelconfigs<br/>list, watch, patch"]
        Scheduling["scheduling.k8s.io/<br/>priorityclasses<br/>get, list, watch"]
        NodeAPI["node.k8s.io/<br/>runtimeclasses<br/>get, list, watch"]
        LWS["leaderworkerset<br/>get, list, watch"]
    end

    %% Bindings
    SA_Main -->|"bound via"| CRB_Manager
    SA_Main -->|"bound via"| RB_Leader
    SA_Metrics -->|"bound via"| CRB_Metrics

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_Leader -->|"grants"| R_Leader

    %% Manager role permissions
    CR_Manager -->|"permissions"| CoreAPI
    CR_Manager -->|"permissions"| KueueAPI
    CR_Manager -->|"permissions"| JobAPIs
    CR_Manager -->|"permissions"| OtherAPIs

