graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["kueue-controller-manager<br/>(opendatahub)"]
        SA_MetricsReader["kueue-controller-manager<br/>-metrics-reader<br/>(opendatahub)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["kueue-manager-rolebinding"]
        CRB_Metrics["kueue-metrics-reader<br/>-clusterrole-binding"]
    end

    subgraph RoleBindings["Role Bindings (opendatahub)"]
        RB_LeaderElection["kueue-leader-election<br/>-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["kueue-manager-role"]
        CR_Metrics["kueue-metrics-reader"]
    end

    subgraph Roles["Roles (opendatahub)"]
        R_LeaderElection["kueue-leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        Events["core<br/>events<br/>create,patch,update,watch"]
        LimitRanges["core<br/>limitranges, namespaces, nodes<br/>get,list,watch"]
        Pods["core<br/>pods<br/>delete,get,list,patch,update,watch"]
        PodsFinalizers["core<br/>pods/finalizers<br/>get,update"]
        Secrets["core<br/>secrets<br/>get,list,update,watch"]
        PodTemplates["core<br/>podtemplates<br/>create,delete,get,list,update,watch"]
    end

    subgraph KueueResources["Kueue API Resources (kueue.x-k8s.io)"]
        KueueCRDs["clusterqueues, localqueues,<br/>workloads, admissionchecks, cohorts<br/>create,delete,get,list,patch,update,watch"]
        KueueReadOnly["multikueueclusters, multikueueconfigs,<br/>provisioningrequestconfigs,<br/>workloadpriorityclasses<br/>get,list,watch"]
        KueueFlavors["resourceflavors, topologies<br/>delete,get,list,update,watch"]
    end

    subgraph WorkloadResources["Workload Framework Resources"]
        BatchJobs["batch<br/>jobs, jobs/finalizers, jobs/status<br/>get,list,patch,update,watch"]
        KubeflowJobs["kubeflow.org<br/>mpijobs, paddlejobs, pytorchjobs,<br/>tfjobs, xgboostjobs<br/>get,list,patch,update,watch"]
        RayResources["ray.io<br/>rayclusters, rayjobs<br/>get,list,patch,update,watch"]
        JobSets["jobset.x-k8s.io<br/>jobsets<br/>get,list,patch,update,watch"]
        AppWrappers["workload.codeflare.dev<br/>appwrappers<br/>get,list,patch,update,watch"]
        LWSets["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/>get,list,watch"]
    end

    subgraph AdminResources["Administrative Resources"]
        Webhooks["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>get,list,update,watch"]
        FlowControl["flowcontrol.apiserver.k8s.io<br/>flowschemas, prioritylevelconfigurations<br/>list,watch"]
        ProvReqs["autoscaling.x-k8s.io<br/>provisioningrequests<br/>create,delete,get,list,patch,update,watch"]
        AppsResources["apps<br/>deployments, replicasets, statefulsets<br/>get,list,watch"]
        PriorityClasses["scheduling.k8s.io<br/>priorityclasses<br/>get,list,watch"]
        RuntimeClasses["node.k8s.io<br/>runtimeclasses<br/>get,list,watch"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| RB_LeaderElection
    SA_MetricsReader -->|"bound via"| CRB_Metrics

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_LeaderElection -->|"grants"| R_LeaderElection

    %% Manager role permissions
    CR_Manager -->|"permits"| CoreResources
    CR_Manager -->|"permits"| KueueResources
    CR_Manager -->|"permits"| WorkloadResources
    CR_Manager -->|"permits"| AdminResources

