graph LR
    AIGWPP["AI Gateway<br/>Payload Processing<br/>(BBR ExtProc Host)"]

    %% External Dependencies (Required)
    AIGWPP -->|"BBR framework<br/>ExtProc runner<br/>plugin interfaces"| GAIE["gateway-api-inference-extension<br/>v1.5.0"]
    AIGWPP -->|"K8s client<br/>reconciler framework<br/>ExternalModel + Secret watches"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    AIGWPP -->|"Core API types<br/>(Secret, etc.)"| K8sAPI["Kubernetes API<br/>k8s.io/api v0.35.4"]
    AIGWPP -->|"EnvoyFilter attaches<br/>ExtProc to Gateway<br/>Envoy proxies traffic"| Istio["Istio / Envoy"]
    AIGWPP -->|"Gateway + HTTPRoute CRDs<br/>define inference gateway"| GatewayAPI["Gateway API"]

    %% Internal Platform Dependencies
    AIGWPP -->|"CRD Watch<br/>model→provider mapping"| ExternalModelCRD["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]
    AIGWPP -->|"Resource Watch<br/>API key caching<br/>(label-filtered)"| K8sSecrets["Kubernetes Secrets<br/>bbr-managed=true"]
    AIGWPP -->|"Envoy ExtProc attachment<br/>same namespace as Gateway"| AIGateway["AI Gateway<br/>(Istio Gateway +<br/>EnvoyFilter)"]
    AIGWPP -.->|"Optional HTTP REST<br/>/v1/guardrail/checks<br/>content moderation"| NeMo["NeMo Guardrails<br/>Service"]
    AIGWPP -.->|"CRD producer<br/>creates ExternalModel CRs"| MaaS["MaaS Controller"]

    %% Integration Points (components that depend on AIGWPP)
    UpstreamBBR["upstream<br/>body-based-routing chart"] -->|"Helm dependency<br/>Deployment, Service,<br/>SA, EnvoyFilter"| AIGWPP
    BodyFieldToHeader["body-field-to-header<br/>plugin (upstream)"] -->|"BBR plugin (in-process)<br/>model field →<br/>X-Gateway-Model-Name"| AIGWPP

    %% External LLM Providers (egress via Envoy)
    AIGWPP -->|"Inference requests<br/>translated + forwarded"| OpenAI["OpenAI API<br/>api.openai.com"]
    AIGWPP -->|"Inference requests<br/>translated + forwarded"| Anthropic["Anthropic API<br/>api.anthropic.com"]
    AIGWPP -->|"Inference requests<br/>translated + forwarded"| AzureOpenAI["Azure OpenAI API"]
    AIGWPP -->|"Inference requests<br/>translated + forwarded"| Bedrock["AWS Bedrock API<br/>bedrock.amazonaws.com"]
    AIGWPP -->|"Inference requests<br/>translated + forwarded"| VertexAI["Google Vertex AI API<br/>aiplatform.googleapis.com"]

    %% Styling
    style AIGWPP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style GAIE fill:#999,stroke:#333
    style ControllerRuntime fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style GatewayAPI fill:#999,stroke:#333

    %% Internal platform dependencies
    style ExternalModelCRD fill:#7ed321,stroke:#333
    style K8sSecrets fill:#7ed321,stroke:#333
    style AIGateway fill:#7ed321,stroke:#333
    style NeMo fill:#7ed321,stroke:#333
    style MaaS fill:#7ed321,stroke:#333

