    AIGateway -->|"inference<br/>HTTPS/443"| Vertex["Google Vertex AI<br/>{region}-aiplatform.googleapis.com"]

    %% K8s API
    AGPP -->|"API watch<br/>HTTPS/443"| K8sAPI["Kubernetes<br/>API Server"]

