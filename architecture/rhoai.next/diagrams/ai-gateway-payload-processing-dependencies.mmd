graph LR
    AGPP["AI Gateway<br/>Payload Processing"]

    %% External Dependencies (Required)
    AGPP -->|"BBR framework<br/>ExtProc runner"| InferenceGW["gateway-api-inference-extension<br/>v1.5.0"]
    AGPP -->|"K8s client<br/>reconciler framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    AGPP -->|"Core API types<br/>(Secret, etc.)"| K8sAPI["Kubernetes API<br/>v0.35.4"]
    AGPP -->|"EnvoyFilter<br/>ExtProc attachment"| Istio["Istio / Envoy"]
    AGPP -->|"Gateway + HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API"]

    %% Internal Platform Dependencies
    AGPP -->|"CRD Watch<br/>model→provider mapping"| ExternalModel["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]
    AGPP -->|"Resource Watch<br/>API key caching"| Secrets["Kubernetes Secrets<br/>(bbr-managed=true)"]
    AGPP -->|"ExtProc in data plane<br/>Envoy attachment"| AIGateway["AI Gateway<br/>(Istio Gateway + EnvoyFilter)"]
    AGPP -.->|"HTTP REST (optional)<br/>content moderation"| NeMo["NeMo Guardrails<br/>Service"]

    %% Components that depend on AGPP
    MaaS["MaaS Controller"] -->|"creates ExternalModel CRs"| ExternalModel

    %% Upstream Helm chart
    AGPP -->|"Helm dependency<br/>base resources"| BBRChart["body-based-routing chart<br/>(upstream K8s Inference GW)"]

    %% External LLM Providers (proxied via Envoy)
    AGPP -.->|"translated requests<br/>(via Envoy)"| OpenAI["OpenAI API"]
    AGPP -.->|"translated requests<br/>(via Envoy)"| Anthropic["Anthropic API"]
    AGPP -.->|"translated requests<br/>(via Envoy)"| Azure["Azure OpenAI API"]
    AGPP -.->|"translated requests<br/>(via Envoy)"| Bedrock["AWS Bedrock API"]
    AGPP -.->|"translated requests<br/>(via Envoy)"| Vertex["Google Vertex AI API"]

