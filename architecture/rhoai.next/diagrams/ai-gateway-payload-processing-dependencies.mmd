graph LR
    PayloadProc["AI Gateway<br/>Payload Processing"]

    %% External Dependencies (Required)
    PayloadProc -->|"ext_proc framework<br/>plugin registry"| LLMD["llm-d IPP<br/>v0.1.0-rc.1"]
    PayloadProc -->|"CRD reconciliation"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    PayloadProc -->|"HTTPRoute types"| GatewayAPI["Gateway API<br/>v1.5.1"]
    PayloadProc -->|"SigV4 signing<br/>(Bedrock auth)"| AWSSDK["aws-sdk-go-v2<br/>v1.42.0"]
    PayloadProc -->|"ext_proc filter<br/>mTLS, ServiceEntry<br/>DestinationRule"| Istio["Istio / Envoy"]

    %% Internal Platform Dependencies
    PayloadProc -->|"EnvoyFilter attachment<br/>HTTPRoute parent ref"| AIGateway["AI Gateway<br/>(Istio Gateway CR)"]
    PayloadProc -->|"credential caching<br/>apikey-injection"| K8sSecrets["Kubernetes Secrets<br/>(labeled bbr-managed)"]
    PayloadProc -->|"legacy watch<br/>migration controller"| LegacyCRDs["maas.opendatahub.io<br/>ExternalModel CRDs"]
    PayloadProc -.->|"content safety<br/>(optional)"| NeMo["NeMo Guardrails<br/>Service"]

    %% CRDs Managed
    PayloadProc -->|"watches + creates"| ExtModel["ExternalModel CR<br/>inference.opendatahub.io"]
    PayloadProc -->|"watches + creates"| ExtProvider["ExternalProvider CR<br/>inference.opendatahub.io"]

    %% Resources Created
    PayloadProc -->|"creates per model"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    PayloadProc -->|"creates per provider"| SvcEntry["Istio ServiceEntry<br/>(MESH_EXTERNAL)"]
    PayloadProc -->|"creates per provider"| DestRule["Istio DestinationRule<br/>(TLS SIMPLE)"]
    PayloadProc -->|"creates per provider"| ExtNameSvc["ExternalName Service"]

    %% External LLM Providers (egress targets)
    PayloadProc ===|"inference traffic<br/>(via Istio egress)"| ProviderGroup

    subgraph ProviderGroup["External LLM Providers"]
        OpenAI["OpenAI<br/>Bearer Token"]
        Anthropic["Anthropic<br/>x-api-key"]
        Azure["Azure OpenAI<br/>api-key header"]
        Bedrock["AWS Bedrock<br/>SigV4"]
        VertexAI["Google Vertex AI<br/>Bearer Token"]
    end

    %% Integration — other RHOAI components
    Kuadrant["Kuadrant WASMPlugin"] -.->|"EnvoyFilter ordering<br/>INSERT_AFTER"| PayloadProc

    %% Kubernetes API
    PayloadProc -->|"CRD watches<br/>resource CRUD"| K8sAPI["Kubernetes API<br/>Server"]

