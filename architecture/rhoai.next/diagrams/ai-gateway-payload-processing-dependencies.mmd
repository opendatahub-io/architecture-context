graph LR
    AGPP["AI Gateway<br/>Payload Processing"]

    %% External Dependencies (Required)
    AGPP -->|"BBR framework<br/>ext_proc host"| BBR["gateway-api-inference-extension<br/>BBR v1.5.0"]
    AGPP -->|"reconciler framework<br/>CRD + Secret watch"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    AGPP -->|"EnvoyFilter<br/>ext_proc attachment"| Istio["Istio<br/>(cluster)"]
    AGPP -->|"watches CRD<br/>model→provider mapping"| ExternalModelCRD["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]

    %% Optional External Dependencies
    AGPP -.->|"content safety<br/>guardrail checks"| NeMo["NeMo Guardrails<br/>(optional)"]

    %% Internal RHOAI Dependencies
    AGPP -->|"CRD dependency"| MaaS["models-as-a-service<br/>(MaaS)"]
    AGPP -->|"EnvoyFilter<br/>attachment target"| AIGateway["AI Gateway<br/>(Istio Gateway)"]
    AGPP -->|"API key storage<br/>bbr-managed label"| K8sSecrets["Kubernetes Secrets"]

    %% External Provider Integrations (via Gateway)
    AGPP -->|"path rewrite<br/>/v1/chat/completions"| OpenAI["OpenAI API"]
    AGPP -->|"full body transform<br/>Messages API"| Anthropic["Anthropic API"]
    AGPP -->|"path rewrite<br/>field stripping"| Azure["Azure OpenAI"]
    AGPP -->|"path rewrite<br/>pass-through"| Bedrock["AWS Bedrock"]
    AGPP -->|"path rewrite<br/>project/location/endpoint"| Vertex["Google Vertex AI"]

    %% Deployment Dependencies
    AGPP -->|"Helm chart<br/>dependency"| BBRChart["body-based-routing<br/>upstream Helm chart"]
    AGPP -->|"API server<br/>SA token auth"| K8sAPI["Kubernetes API"]

    %% Components that depend on AGPP
    MaaS -->|"provides<br/>ExternalModel CRDs"| AGPP

