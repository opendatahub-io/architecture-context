graph LR
    AGPP["AI Gateway<br/>Payload Processing<br/>(BBR ExtProc Host)"]

    %% External Dependencies (required frameworks)
    AGPP -->|"BBR framework<br/>ExtProc runner<br/>plugin interfaces"| GAIE["gateway-api-inference-extension<br/>v1.5.0"]
    AGPP -->|"K8s client<br/>reconciler framework"| CR["controller-runtime<br/>v0.23.3"]
    AGPP -->|"Core API types<br/>(Secret, etc.)"| K8sAPI_Dep["Kubernetes API<br/>k8s.io/api v0.35.4"]
    AGPP -->|"EnvoyFilter attachment<br/>ExtProc to Gateway"| Istio["Istio / Envoy"]
    AGPP -->|"Gateway + HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API"]

    %% Internal Platform Dependencies
    AGPP -->|"CRD Watch<br/>(model→provider mapping)"| ExternalModel["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]
    AGPP -->|"Resource Watch<br/>(API key caching)"| Secrets["Kubernetes Secrets<br/>(label: bbr-managed=true)"]
    AGPP -->|"Envoy ExtProc<br/>attachment"| AIGateway["AI Gateway<br/>(Istio Gateway +<br/>EnvoyFilter)"]
    AGPP -.->|"HTTP REST<br/>(optional guardrails)"| NeMo["NeMo Guardrails<br/>Service"]

    %% CRD producer
    MaaS["MaaS Controller"] -->|"creates ExternalModel CRs"| ExternalModel

    %% Upstream chart dependency
    AGPP -->|"Helm dependency<br/>(Deployment, Service,<br/>ServiceAccount, EnvoyFilter)"| BBRChart["upstream<br/>body-based-routing<br/>chart v1.5.0-rc.1"]

    %% Upstream plugin
    AGPP -->|"in-process plugin<br/>(model field → header)"| BodyFieldToHeader["body-field-to-header<br/>(upstream plugin)"]

    %% External LLM Providers (egress via Envoy)
    subgraph Providers["External LLM Providers (via Envoy)"]
        OpenAI["OpenAI<br/>api.openai.com"]
        Anthropic["Anthropic<br/>api.anthropic.com"]
        AzureOAI["Azure OpenAI"]
        Bedrock["AWS Bedrock<br/>bedrock.amazonaws.com"]
        VertexAI["Google Vertex AI<br/>aiplatform.googleapis.com"]
    end

    AGPP -->|"translated requests<br/>HTTPS/443"| Providers

