graph LR
    Notebooks["Notebooks<br/>Container Image Factory"]

    %% External Dependencies - Languages & Frameworks
    subgraph Frameworks["Languages & Frameworks"]
        Python["Python 3.12"]
        JupyterLab["JupyterLab 4.5"]
        CodeServerDep["code-server v4.106.3"]
        NodeJS["Node.js 22.21.1"]
    end

    Notebooks -->|runtime| Python
    Notebooks -->|IDE| JupyterLab
    Notebooks -->|IDE| CodeServerDep
    Notebooks -->|build/runtime| NodeJS

    %% External Dependencies - ML Frameworks
    subgraph MLFrameworks["ML Frameworks (from AIPCC Index)"]
        PyTorch["PyTorch"]
        TensorFlow["TensorFlow"]
        LLMCompressor["LLMCompressor"]
        TrustyAIDep["TrustyAI"]
    end

    Notebooks -->|deep learning| PyTorch
    Notebooks -->|ML training| TensorFlow
    Notebooks -->|model compression| LLMCompressor
    Notebooks -->|fairness/XAI| TrustyAIDep

    %% External Dependencies - Accelerators
    subgraph Accelerators["GPU Accelerators"]
        CUDA13["CUDA Toolkit 13.0.2"]
        CUDA12["CUDA Toolkit 12.9"]
        cuDNN["cuDNN 9.14.0"]
        NCCL["NCCL 2.28.3"]
        ROCmDep["ROCm 7.1.1"]
    end

    Notebooks -->|NVIDIA GPU| CUDA13
    Notebooks -->|NVIDIA GPU| CUDA12
    Notebooks -->|DNN accel| cuDNN
    Notebooks -->|multi-GPU| NCCL
    Notebooks -->|AMD GPU| ROCmDep

    %% External Dependencies - Infrastructure
    subgraph Infrastructure["Infrastructure"]
        nginx["nginx 1.24"]
        Java17["Java 17 JRE"]
        OpenMPI["OpenMPI"]
        GoToolset["UBI9 go-toolset 1.26.3"]
    end

    Notebooks -->|reverse proxy| nginx
    Notebooks -->|TrustyAI runtime| Java17
    Notebooks -->|distributed training| OpenMPI
    Notebooks -->|mongocli build| GoToolset

    %% External Dependencies - Extensions
    subgraph Extensions["Notebook Extensions"]
        Elyra["Elyra 4.3.1"]
        Kale["Kale"]
        Mongocli["mongocli"]
    end

    Notebooks -->|pipeline editor| Elyra
    Notebooks -->|nb-to-pipeline| Kale
    Notebooks -->|MongoDB CLI| Mongocli

    %% Internal ODH/RHOAI Platform Dependencies
    subgraph InternalPlatform["Internal RHOAI Platform"]
        NotebookCtrl["ODH Notebook Controller"]
        RhodsOp["rhods-operator"]
        DSPCtrl["Data Science Pipelines"]
        Dashboard["RHOAI Dashboard"]
        KubeRBAC["kube-rbac-proxy"]
        AIPCCBase["AIPCC Base Images"]
    end

    NotebookCtrl -->|launches pods from| Notebooks
    RhodsOp -->|applies manifests from| Notebooks
    DSPCtrl -->|runs steps with| Notebooks
    Dashboard -->|reads annotations from| Notebooks
    KubeRBAC -.->|injected as sidecar| Notebooks
    Notebooks -->|FROM base image| AIPCCBase

    %% Build System
    subgraph BuildSystem["Build System"]
        Konflux["Konflux / Tekton<br/>85 pipelines"]
        Cachi2["Cachi2 / Hermeto<br/>Hermetic prefetch"]
        AIPCCIndex["AIPCC PyPI Index<br/>packages.redhat.com"]
    end

    Konflux -->|builds| Notebooks
    Konflux -->|prefetch via| Cachi2
    Cachi2 -->|fetches wheels from| AIPCCIndex

    %% External Services (runtime)
    subgraph ExternalSvc["External Services (Runtime)"]
        K8sAPI["Kubernetes API"]
        S3["S3-Compatible Storage"]
        ContainerReg["Container Registry<br/>quay.io / registry.redhat.io"]
    end

    Notebooks -->|K8s operations| K8sAPI
    Notebooks -->|data access| S3
    Notebooks -->|image push/pull| ContainerReg

    %% Styling
    style Notebooks fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    classDef framework fill:#b8d4e3,stroke:#4a7a9b
    classDef mlfw fill:#c5e1a5,stroke:#7cb342
    classDef accel fill:#ffcc80,stroke:#ef6c00
    classDef infra fill:#e0e0e0,stroke:#757575
    classDef extension fill:#ce93d8,stroke:#8e24aa
    classDef internal fill:#7ed321,stroke:#5a9e18
    classDef build fill:#90caf9,stroke:#1565c0
    classDef external fill:#f5a623,stroke:#c7851a

    class Python,JupyterLab,CodeServerDep,NodeJS framework
    class PyTorch,TensorFlow,LLMCompressor,TrustyAIDep mlfw
    class CUDA13,CUDA12,cuDNN,NCCL,ROCmDep accel
    class nginx,Java17,OpenMPI,GoToolset infra
    class Elyra,Kale,Mongocli extension
    class NotebookCtrl,RhodsOp,DSPCtrl,Dashboard,KubeRBAC,AIPCCBase internal
    class Konflux,Cachi2,AIPCCIndex build
    class K8sAPI,S3,ContainerReg external
