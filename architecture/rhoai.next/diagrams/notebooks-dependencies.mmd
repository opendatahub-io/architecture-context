graph LR
    Notebooks["Notebooks<br/>(Workbench & Runtime Images)"]

    %% External Dependencies - Languages & Runtimes
    Notebooks -->|"runtime language<br/>all images"| Python["Python 3.12"]
    Notebooks -->|"notebook IDE<br/>workbenches"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"code-server runtime"| NodeJS["Node.js 22.21.1"]
    Notebooks -->|"R runtime<br/>rstudio images"| R["R 4.5.1"]

    %% External Dependencies - IDEs
    Notebooks -->|"VS Code backend"| CodeServer["code-server 4.106.3"]
    Notebooks -->|"R IDE server"| RStudioServer["RStudio Server<br/>2025.09.0-387"]
    Notebooks -->|"reverse proxy<br/>code-server, rstudio"| Nginx["nginx 1.24"]

    %% External Dependencies - Accelerators
    Notebooks -->|"NVIDIA GPU"| CUDA["NVIDIA CUDA 12.8"]
    Notebooks -->|"AMD GPU"| ROCm["AMD ROCm 6.3+"]

    %% External Dependencies - ML Frameworks
    Notebooks -->|"deep learning"| PyTorch["PyTorch"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow"]

    %% External Dependencies - Build
    Notebooks -->|"package installer"| UV["uv 0.10.8-0.11.7"]
    Notebooks -->|"FIPS binary"| Mongocli["mongocli<br/>(built from source)"]
    Notebooks -->|"pipeline authoring"| Elyra["Elyra 4.3.1"]

    %% Internal RHOAI Dependencies
    NotebookController["ODH Notebook Controller"] -->|"creates StatefulSets<br/>from ImageStream refs"| Notebooks
    Dashboard["ODH Dashboard"] -->|"reads ImageStream<br/>annotations for UI"| Notebooks
    Operator["rhods-operator /<br/>opendatahub-operator"] -->|"applies kustomize<br/>manifests"| Notebooks
    ElyraEngine["Elyra Pipeline Engine"] -->|"selects runtime images<br/>for pipeline nodes"| Notebooks

    %% Platform Dependencies
    Notebooks -->|"image tracking"| ImageStream["OpenShift ImageStream"]

    %% Build System
    Notebooks -->|"hermetic builds<br/>102 PipelineRuns"| Konflux["Konflux Build System"]
    Notebooks -->|"dependency prefetch"| Cachi2["Hermeto / cachi2"]

    %% External Services
    Notebooks -->|"image storage<br/>RHOAI production"| RegistryRH["registry.redhat.io"]
    Notebooks -->|"image storage<br/>ODH upstream"| RegistryQuay["quay.io"]

