graph LR
    Notebooks["Notebooks<br/>(Workbench & Runtime Images)"]

    %% External Dependencies - Base Images
    Notebooks -->|"base image<br/>(RHEL 9.6, Python 3.12)"| AIPCC_CPU["AIPCC CPU Base<br/>3.5.0"]
    Notebooks -->|"base image<br/>(CUDA 13.0 runtime)"| AIPCC_CUDA["AIPCC CUDA 13.0<br/>3.5.0"]
    Notebooks -->|"base image<br/>(CUDA 12.9 runtime)"| AIPCC_CUDA12["AIPCC CUDA 12.9<br/>3.5.0"]
    Notebooks -->|"base image<br/>(ROCm 7.1 runtime)"| AIPCC_ROCm["AIPCC ROCm 7.1<br/>3.5.0-ea.2"]

    %% External Dependencies - Frameworks
    Notebooks -->|"notebook IDE"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"deep learning"| PyTorch["PyTorch 2.11"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow"]
    Notebooks -->|"browser IDE"| CodeServer["code-server<br/>v4.106.3"]
    Notebooks -->|"pipeline editor"| Elyra["Elyra<br/>v4.3.1 / v5.0"]
    Notebooks -->|"KFP extension"| Kale["Kale"]

    %% External Dependencies - Build/Runtime
    Notebooks -->|"TrustyAI JRE"| Java17["Java 17<br/>(OpenJDK)"]
    Notebooks -->|"idle culling proxy"| Nginx["nginx 1.24"]
    Notebooks -->|"CGI gateway"| HTTPD["httpd (Apache)"]
    Notebooks -->|"Go compiler<br/>(build-time)"| GoToolset["ubi9/go-toolset<br/>1.26.3"]
    Notebooks -->|"MongoDB CLI"| MongoCLI["mongocli<br/>(Git submodule)"]

    %% Internal RHOAI Platform Dependencies
    Operator["rhods-operator"] -->|"deploys ImageStreams<br/>via kustomize"| Notebooks
    Dashboard["ODH Dashboard"] -->|"discovers images<br/>via annotations"| Notebooks
    NBController["odh-notebook-<br/>controller"] -->|"injects sidecar,<br/>CA bundle, secrets"| Notebooks
    DSPA["DSPA"] -->|"secret mount at<br/>/opt/app-root/runtimes/"| Notebooks
    Culler["Notebook Culler"] -->|"polls /api/kernels/<br/>for idle timeout"| Notebooks
    ISController["OpenShift<br/>ImageStream Controller"] -->|"imports images<br/>from Quay.io"| Notebooks

    %% Build Infrastructure
    Konflux["Konflux / Tekton"] -->|"builds images<br/>(hermetic)"| Notebooks
    NudgeBot["Renovate /<br/>nudge bot"] -->|"updates image<br/>digests in params.env"| Notebooks

    %% Embedded Libraries (optional integrations)
    Notebooks -.->|"distributed training"| CodeFlare["CodeFlare SDK"]
    Notebooks -.->|"training jobs"| KFTraining["Kubeflow<br/>Training SDK"]
    Notebooks -.->|"experiment tracking"| MLflow["MLflow"]
    Notebooks -.->|"feature store"| Feast["Feast"]

