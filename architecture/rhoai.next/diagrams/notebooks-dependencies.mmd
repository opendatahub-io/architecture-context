graph LR
    Notebooks["Notebooks<br/>(Workbench & Runtime Images)"]

    %% External Dependencies - Languages & Runtimes
    Notebooks -->|"runtime language<br/>(all images)"| Python["Python 3.12"]
    Notebooks -->|"IDE<br/>(workbenches)"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"runtime<br/>(code-server)"| NodeJS["Node.js 22.21.1"]
    Notebooks -->|"runtime<br/>(rstudio)"| R["R 4.5.1"]

    %% External Dependencies - Applications
    Notebooks -->|"IDE server<br/>(rstudio)"| RStudioServer["RStudio Server<br/>2025.09.0-387"]
    Notebooks -->|"IDE server<br/>(codeserver)"| CodeServer["code-server 4.106.3"]
    Notebooks -->|"reverse proxy<br/>(codeserver, rstudio)"| Nginx["nginx 1.24"]

    %% External Dependencies - GPU
    Notebooks -->|"GPU compute<br/>(CUDA variants)"| CUDA["NVIDIA CUDA<br/>Toolkit 12.8"]
    Notebooks -->|"GPU compute<br/>(ROCm variants)"| ROCm["AMD ROCm 6.3+"]

    %% External Dependencies - ML Frameworks
    Notebooks -->|"deep learning"| PyTorch["PyTorch"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow"]

    %% External Dependencies - Build Tools
    Notebooks -->|"package installer"| UV["uv 0.10.8-0.11.7"]
    Notebooks -->|"deployment installer"| Micropipenv["micropipenv 1.10.0"]
    Notebooks -->|"DB CLI (FIPS)"| Mongocli["mongocli<br/>(built from source)"]

    %% Optional
    Notebooks -.->|"pipeline authoring<br/>(optional)"| Elyra["Elyra 4.3.1"]

    %% Internal Platform Dependencies
    NotebookCtrl["ODH Notebook Controller"] -->|"creates StatefulSets<br/>from ImageStreams"| Notebooks
    Dashboard["ODH Dashboard"] -->|"reads annotations<br/>for image catalog"| Notebooks
    RhodsOp["rhods-operator"] -->|"applies kustomize<br/>manifests"| Notebooks
    OdhOp["opendatahub-operator"] -->|"applies kustomize<br/>manifests (ODH)"| Notebooks
    ElyraEngine["Elyra Pipeline Engine"] -->|"selects runtime<br/>images"| Notebooks

    %% External Services (runtime egress)
    Notebooks -->|"user pip install<br/>443/TCP HTTPS"| PyPI["PyPI"]
    Notebooks -->|"clone repos<br/>443/TCP HTTPS"| GitRepos["Git Repositories"]
    Notebooks -->|"data access<br/>443/TCP HTTPS"| S3["S3 Storage"]
    Notebooks -->|"DB connectivity<br/>27017/TCP"| MongoDB["MongoDB"]

    %% Build System
    KonfluxBuild["Konflux Build<br/>102 PipelineRuns"] -->|"hermetic builds"| Notebooks
    Notebooks -->|"pushes images<br/>443/TCP HTTPS"| Registry["Container Registry<br/>registry.redhat.io<br/>quay.io"]
    Notebooks -->|"image tracking"| ImageStream["OpenShift<br/>ImageStream"]

