graph LR
    Notebooks["Notebooks<br/>(Image Factory)"]

    %% External Dependencies - Languages & Runtimes
    Notebooks -->|"runtime language"| Python["Python 3.12"]
    Notebooks -->|"notebook IDE"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"code-server runtime"| NodeJS["Node.js 22.21.1"]
    Notebooks -->|"R language"| R["R 4.5.1"]
    Notebooks -->|"RStudio IDE"| RStudioServer["RStudio Server<br/>2025.09.0-387"]
    Notebooks -->|"VS Code in browser"| CodeServerDep["code-server 4.106.3"]

    %% External Dependencies - Infrastructure
    Notebooks -->|"reverse proxy"| Nginx["nginx 1.24"]
    Notebooks -->|"NVIDIA GPU"| CUDA["NVIDIA CUDA 12.8"]
    Notebooks -->|"AMD GPU"| ROCm["AMD ROCm 6.3+"]

    %% External Dependencies - ML Frameworks
    Notebooks -->|"deep learning"| PyTorch["PyTorch"]
    Notebooks -->|"deep learning"| TensorFlow["TensorFlow"]

    %% External Dependencies - Build Tools
    Notebooks -->|"package installer"| UV["uv 0.10.8-0.11.7"]
    Notebooks -->|"pip wrapper"| Micropipenv["micropipenv 1.10.0"]
    Notebooks -->|"DB CLI (FIPS)"| Mongocli["mongocli<br/>(built from source)"]
    Notebooks -.->|"pipeline integration"| Elyra["Elyra 4.3.1"]

    %% Internal Platform Dependencies
    NotebookCtrl["ODH Notebook Controller"] -->|"creates StatefulSets<br/>from ImageStreams"| Notebooks
    Dashboard["ODH Dashboard"] -->|"reads ImageStream<br/>annotations"| Notebooks
    Operator["rhods-operator"] -->|"applies kustomize<br/>manifests"| Notebooks
    ElyraEngine["Elyra Pipeline Engine"] -->|"selects runtime<br/>images"| Notebooks
    ImageStream["OpenShift ImageStream"] -->|"tracks image<br/>references"| Notebooks

    %% Build System
    Notebooks -->|"hermetic CI/CD<br/>102 PipelineRuns"| Konflux["Konflux Build System"]
    Konflux -->|"dependency prefetch"| Cachi2["cachi2/Hermeto"]

    %% Container Registries
    Notebooks -->|"RHOAI images"| RHIO["registry.redhat.io"]
    Notebooks -->|"ODH images"| Quay["quay.io"]

