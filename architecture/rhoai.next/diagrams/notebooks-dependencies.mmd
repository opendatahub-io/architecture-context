graph LR
    Notebooks["Notebooks<br/>(Workbench & Runtime Images)"]

    %% Core Runtime Dependencies
    Notebooks -->|"primary runtime"| Python["Python 3.12"]
    Notebooks -->|"notebook IDE"| JupyterLab["JupyterLab 4.5"]
    Notebooks -->|"browser IDE"| CodeServerDep["code-server 4.106.3"]
    Notebooks -->|"R IDE"| RStudioDep["RStudio Server 2025.09"]
    Notebooks -->|"R runtime"| RLang["R 4.5.1"]
    Notebooks -->|"Node.js runtime"| NodeJS["Node.js 22.x"]

    %% ML Framework Dependencies
    Notebooks -->|"deep learning (CUDA)"| PyTorchDep["PyTorch 2.10"]
    Notebooks -->|"deep learning (CUDA)"| TFDep["TensorFlow Latest"]
    Notebooks -->|"GPU compute"| CUDA["CUDA Toolkit 12.8-13.0"]
    Notebooks -->|"AMD GPU"| ROCm["ROCm 7.1"]

    %% Infrastructure Dependencies
    Notebooks -->|"reverse proxy"| NginxDep["nginx 1.24"]
    Notebooks -->|"CGI gateway"| HttpdDep["httpd 2.4"]
    Notebooks -->|"package manager"| UV["uv 0.10.9-0.11.7"]
    Notebooks -->|"pipeline editor"| Elyra["Elyra 4.3.1"]
    Notebooks -->|"MongoDB CLI"| MongoCLI["mongocli (Go)"]
    Notebooks -->|"OpenShift client"| OC["OpenShift CLI (oc)"]

    %% Internal ODH Platform Dependencies
    Notebooks -->|"ImageStream deploy<br/>Kustomize manifests"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    Notebooks -->|"workbench selection UI<br/>ImageStream annotations"| DashboardDep["ODH Dashboard"]
    Notebooks -->|"image resolution,<br/>sidecar injection,<br/>CA bundles"| NotebookCtrlDep["ODH Notebook Controller<br/>(kubeflow)"]
    Notebooks -->|"idle detection<br/>GET /api/kernels/"| CullerDep["Notebook Controller Culler"]
    Notebooks -->|"pipeline execution<br/>Secret + Elyra config"| DSPDep["Data Science Pipelines"]
    Notebooks -->|"runtime image metadata<br/>annotations"| ElyraDep["Elyra (ODH fork)"]

    %% Integration points (things that depend on Notebooks)
    DashboardDep -.->|"discovers images"| Notebooks
    NotebookCtrlDep -.->|"resolves + deploys"| Notebooks
    CullerDep -.->|"polls activity"| Notebooks
    DSPDep -.->|"launches runtimes"| Notebooks

    %% Build Dependencies
    Notebooks -->|"hermetic builds"| KonfluxDep["Konflux CI"]
    Notebooks -->|"image storage"| RegistryDep["registry.redhat.io /<br/>quay.io"]
    Notebooks -->|"dependency extraction"| BuildInputsDep["buildinputs<br/>(Go LLB tool)"]

    %% Styling
    style Notebooks fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - green
    style Python fill:#7ed321,stroke:#333
    style JupyterLab fill:#7ed321,stroke:#333
    style CodeServerDep fill:#7ed321,stroke:#333
    style RStudioDep fill:#7ed321,stroke:#333
    style RLang fill:#7ed321,stroke:#333
    style NodeJS fill:#7ed321,stroke:#333

    %% ML frameworks - orange
    style PyTorchDep fill:#f5a623,stroke:#333
    style TFDep fill:#f5a623,stroke:#333
    style CUDA fill:#f5a623,stroke:#333
    style ROCm fill:#f5a623,stroke:#333

    %% Infrastructure - gray
    style NginxDep fill:#e8e8e8,stroke:#333
    style HttpdDep fill:#e8e8e8,stroke:#333
    style UV fill:#e8e8e8,stroke:#333
    style Elyra fill:#e8e8e8,stroke:#333
    style MongoCLI fill:#e8e8e8,stroke:#333
    style OC fill:#e8e8e8,stroke:#333

    %% Internal ODH - blue
    style RhodsOp fill:#dae8fc,stroke:#6c8ebf
