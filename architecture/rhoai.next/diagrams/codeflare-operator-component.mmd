graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)<br/>Go controller-runtime"]
        RCWebhook["RayCluster Webhook<br/>Mutating + Validating<br/>Port 9443/TCP"]
        AWController["AppWrapper Controller<br/>(embedded, optional)"]
        AWWebhook["AppWrapper Webhook<br/>Mutating + Validating<br/>Port 9443/TCP"]

        Manager -->|"registers"| RCWebhook
        Manager -->|"optionally enables"| AWController
        AWController -->|"registers"| AWWebhook
    end

    %% CRDs Watched
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]
    DSCICR["DSCInitialization CR<br/>(opendatahub.io)"]

    %% Resources Created/Managed
    subgraph ManagedResources["Managed Resources (per RayCluster)"]
        OAuthProxy["OAuth Proxy Sidecar<br/>Port 8443"]
        mTLSCerts["mTLS Certificates<br/>CA + per-pod certs"]
        Routes["OpenShift Routes<br/>Dashboard (reencrypt)<br/>RayClient (passthrough)"]
        NetPolicies["NetworkPolicies<br/>Head + Worker isolation"]
        OAuthSecret["OAuth Config Secret<br/>Cookie secret"]
        CARBs["ClusterRoleBindings<br/>auth-delegator"]
        OAuthSA["ServiceAccount<br/>{cluster}-oauth-proxy"]
    end

    %% External Dependencies
    KubeRayOp["KubeRay Operator"]
    OSHOAuth["OpenShift OAuth Server"]
    Kueue["Kueue<br/>(optional)"]
    CertController["cert-controller<br/>(OPA)"]
    K8sAPI["Kubernetes API Server"]

    %% Flows
    RayClusterCR -->|"watched by"| Manager
    AppWrapperCR -->|"watched by"| AWController
    DSCICR -->|"watched by"| Manager

    Manager -->|"injects"| OAuthProxy
    Manager -->|"generates"| mTLSCerts
    Manager -->|"creates"| Routes
    Manager -->|"creates"| NetPolicies
    Manager -->|"creates"| OAuthSecret
    Manager -->|"creates"| CARBs
    Manager -->|"creates"| OAuthSA

    KubeRayOp -->|"creates"| RayClusterCR
    RCWebhook -->|"mutates/validates"| RayClusterCR
    AWWebhook -->|"mutates/validates"| AppWrapperCR
    AWController -->|"integrates with"| Kueue
    CertController -->|"manages webhook certs"| RCWebhook
    Manager -->|"CRUD operations"| K8sAPI
    OAuthProxy -->|"authenticates via"| OSHOAuth

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RCWebhook fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#6ba5e7,stroke:#333,color:#fff
    style AWWebhook fill:#6ba5e7,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style DSCICR fill:#f5a623,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333
    style mTLSCerts fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style NetPolicies fill:#7ed321,stroke:#333
    style OAuthSecret fill:#7ed321,stroke:#333
    style CARBs fill:#7ed321,stroke:#333
    style OAuthSA fill:#7ed321,stroke:#333
    style KubeRayOp fill:#e8e8e8,stroke:#333
    style OSHOAuth fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style CertController fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
