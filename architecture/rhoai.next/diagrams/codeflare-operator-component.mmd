graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)<br/>controller-runtime"]

        subgraph Controllers["Controllers"]
            RCController["RayCluster Controller<br/>Reconciles OAuth/mTLS/<br/>Routes/NetworkPolicies"]
            AWController["AppWrapper Controller<br/>(embedded, optional)<br/>Kueue-integrated scheduling"]
        end

        subgraph Webhooks["Webhooks (9443/TCP TLS)"]
            RCMutate["RayCluster<br/>Mutating Webhook<br/>Injects oauth-proxy,<br/>TLS init containers"]
            RCValidate["RayCluster<br/>Validating Webhook<br/>Enforces immutability"]
            AWMutate["AppWrapper<br/>Mutating Webhook<br/>Defaults AppWrapper CRs"]
            AWValidate["AppWrapper<br/>Validating Webhook<br/>SubjectAccessReview"]
        end

        CertController["cert-controller<br/>(embedded)<br/>Webhook cert rotation"]

        Manager --> RCController
        Manager --> AWController
        Manager --> CertController
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)<br/>Owned by KubeRay"]
    AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    %% Resources created per RayCluster
    subgraph PerClusterResources["Per-RayCluster Resources"]
        OAuthRoute["Route<br/>ray-dashboard-{cluster}<br/>TLS Reencrypt"]
        ClientRoute["Route<br/>rayclient-{cluster}<br/>TLS Passthrough"]
        OAuthService["Service<br/>{cluster}-oauth<br/>443→8443"]
        OAuthSA["ServiceAccount<br/>{cluster}-oauth-proxy"]
        CRB["ClusterRoleBinding<br/>system:auth-delegator"]
        CookieSecret["Secret<br/>{cluster}-oauth-config"]
        CASecret["Secret<br/>ca-secret-{cluster}<br/>RSA 2048-bit CA"]
        NetPolicies["NetworkPolicies<br/>Head + Worker isolation"]
    end

    %% Flows
    RayClusterCR -->|watched by| RCController
    RCController -->|creates| OAuthRoute
    RCController -->|creates| ClientRoute
    RCController -->|creates| OAuthService
    RCController -->|creates| OAuthSA
    RCController -->|creates| CRB
    RCController -->|creates| CookieSecret
    RCController -->|creates| CASecret
    RCController -->|creates| NetPolicies

    AppWrapperCR -->|watched by| AWController

    %% External dependencies
    KubeRayOp["KubeRay Operator<br/>Creates RayCluster CRs"]
    K8sAPI["Kubernetes API Server"]
    OAuthServer["OpenShift<br/>OAuth Server"]
    IngressController["OpenShift<br/>Ingress Controller"]
    Kueue["Kueue<br/>(optional)"]

    KubeRayOp -->|creates| RayClusterCR
    K8sAPI -->|webhook calls| RCMutate
    K8sAPI -->|webhook calls| RCValidate
    K8sAPI -->|webhook calls| AWMutate
    K8sAPI -->|webhook calls| AWValidate
    RCController -->|API calls| K8sAPI
    OAuthService -.->|delegates auth| OAuthServer
    OAuthRoute -.->|served by| IngressController
    ClientRoute -.->|served by| IngressController
    AWController -.->|integrates| Kueue

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style CertController fill:#4a90e2,stroke:#333,color:#fff
    style RCMutate fill:#9b59b6,stroke:#333,color:#fff
    style RCValidate fill:#9b59b6,stroke:#333,color:#fff
    style AWMutate fill:#9b59b6,stroke:#333,color:#fff
    style AWValidate fill:#9b59b6,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333,color:#fff
    style AppWrapperCR fill:#f5a623,stroke:#333,color:#fff
    style KubeRayOp fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style IngressController fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style OAuthRoute fill:#d5e8d4,stroke:#82b366
    style ClientRoute fill:#d5e8d4,stroke:#82b366
    style OAuthService fill:#d5e8d4,stroke:#82b366
    style OAuthSA fill:#d5e8d4,stroke:#82b366
    style CRB fill:#d5e8d4,stroke:#82b366
    style CookieSecret fill:#d5e8d4,stroke:#82b366
    style CASecret fill:#d5e8d4,stroke:#82b366
    style NetPolicies fill:#d5e8d4,stroke:#82b366
