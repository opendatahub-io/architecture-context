graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)<br/>Go Operator"]
        RCWebhook["RayCluster Webhook<br/>Mutating + Validating<br/>Port 9443/TCP"]
        AWController["AppWrapper Controller<br/>(embedded, optional)"]
        AWWebhook["AppWrapper Webhook<br/>Mutating + Validating<br/>Port 9443/TCP"]

        Manager -->|manages| RCWebhook
        Manager -->|embeds| AWController
        AWController -->|manages| AWWebhook
    end

    %% CRDs Watched
    RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    AppWrapperCR["AppWrapper CR<br/>workload.codeflare.dev/v1beta2"]
    DSCICR["DSCInitialization CR<br/>dscinitialization.opendatahub.io/v1"]

    %% Resources Created by Operator
    subgraph CreatedResources["Resources Created per RayCluster"]
        OAuthProxy["OAuth Proxy Sidecar<br/>(injected into head pod)"]
        mTLSCerts["mTLS Certificates<br/>(CA + per-pod certs)"]
        Routes["OpenShift Routes<br/>Dashboard + RayClient"]
        NetworkPolicies["NetworkPolicies<br/>(head + worker isolation)"]
        OAuthSA["ServiceAccount<br/>{cluster}-oauth-proxy"]
        CRB["ClusterRoleBinding<br/>auth-delegator"]
    end

    %% Flows
    RayClusterCR -->|watched by| Manager
    RayClusterCR -->|mutated by| RCWebhook
    AppWrapperCR -->|watched by| AWController
    AppWrapperCR -->|validated by| AWWebhook
    DSCICR -->|read by| Manager

    Manager -->|creates| OAuthProxy
    Manager -->|generates| mTLSCerts
    Manager -->|creates| Routes
    Manager -->|creates| NetworkPolicies
    Manager -->|creates| OAuthSA
    Manager -->|creates| CRB

    %% External Dependencies
    KubeRay["KubeRay Operator"]
    K8sAPI["Kubernetes API Server"]
    OAuthServer["OpenShift OAuth Server"]
    Kueue["Kueue<br/>(optional)"]

    KubeRay -->|creates| RayClusterCR
    Manager -->|CRUD| K8sAPI
    OAuthProxy -->|authenticates via| OAuthServer
    AWController -.->|integrates with| Kueue

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RCWebhook fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#6a9fd8,stroke:#333,color:#fff
    style AWWebhook fill:#6a9fd8,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style DSCICR fill:#f5a623,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333
    style mTLSCerts fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
    style OAuthSA fill:#7ed321,stroke:#333
    style CRB fill:#7ed321,stroke:#333
    style KubeRay fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
