graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)<br/>Go controller-runtime"]
        RCWebhook["RayCluster Webhook<br/>Mutating + Validating<br/>:9443/TCP HTTPS"]
        AWController["AppWrapper Controller<br/>(embedded, optional)<br/>Kueue integration"]
        AWWebhook["AppWrapper Webhook<br/>Mutating + Validating<br/>:9443/TCP HTTPS"]

        Manager -->|manages| RCWebhook
        Manager -->|embeds| AWController
        AWController -->|registers| AWWebhook
    end

    subgraph ManagedResources["Managed Resources (per RayCluster)"]
        OAuthProxy["OAuth Proxy Sidecar<br/>(injected into head pod)"]
        mTLSInit["mTLS Init Containers<br/>(injected into head+worker)"]
        Routes["OpenShift Routes<br/>Dashboard (reencrypt)<br/>RayClient (passthrough)"]
        NetPol["NetworkPolicies<br/>Head + Worker isolation"]
        CRB["ClusterRoleBindings<br/>auth-delegator"]
        OAuthSA["ServiceAccount<br/>+ OAuth redirect"]
        CACert["CA Secret<br/>RSA 2048-bit self-signed"]
    end

    User[Data Scientist] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|optionally creates| AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    RayClusterCR -->|admission| RCWebhook
    RCWebhook -->|injects| OAuthProxy
    RCWebhook -->|injects| mTLSInit

    Manager -->|reconciles| RayClusterCR
    Manager -->|creates| Routes
    Manager -->|creates| NetPol
    Manager -->|creates| CRB
    Manager -->|creates| OAuthSA
    Manager -->|creates| CACert

    AWController -->|reconciles| AppWrapperCR
    AppWrapperCR -->|wraps| RayClusterCR

    Manager -->|watches| KubeRayOp["KubeRay Operator"]
    Manager -->|reads| DSCInit["DSCInitialization CR<br/>(opendatahub-operator)"]
    Manager -->|reads| IngressConfig["OpenShift Ingress Config<br/>(cluster domain)"]

    OAuthProxy -->|authenticates via| OAuthServer["OpenShift OAuth Server"]
    Routes -->|served by| OSRouter["OpenShift Router"]

    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style RCWebhook fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style AWWebhook fill:#4a90e2,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333
    style mTLSInit fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style CRB fill:#7ed321,stroke:#333
    style OAuthSA fill:#7ed321,stroke:#333
    style CACert fill:#7ed321,stroke:#333
    style KubeRayOp fill:#e8e8e8,stroke:#333
    style DSCInit fill:#e8e8e8,stroke:#333
    style IngressConfig fill:#e8e8e8,stroke:#333
    style OAuthServer fill:#e8e8e8,stroke:#333
    style OSRouter fill:#e8e8e8,stroke:#333
