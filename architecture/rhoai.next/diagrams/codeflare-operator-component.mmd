graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        RCController["RayCluster Controller<br/><i>Watches RayCluster CRs</i>"]
        RCWebhook["RayCluster Webhook<br/><i>Mutating + Validating</i><br/><i>9443/TCP</i>"]
        AWController["AppWrapper Controller<br/><i>Embedded, optional</i>"]
        AWWebhook["AppWrapper Webhook<br/><i>Mutating + Validating</i><br/><i>9443/TCP</i>"]
        ConfigMgr["Config Manager<br/><i>codeflare-operator-config ConfigMap</i>"]

        ConfigMgr -->|enables/disables| AWController
        RCController -->|validates via| RCWebhook
        AWController -->|validates via| AWWebhook
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/><i>ray.io/v1</i>"]
    AppWrapperCR["AppWrapper CR<br/><i>workload.codeflare.dev/v1beta2</i>"]

    %% Created Resources
    subgraph CreatedResources["Resources Created per RayCluster"]
        OAuthRoute["Ray Dashboard Route<br/><i>TLS Reencrypt</i>"]
        ClientRoute["RayClient Route<br/><i>TLS Passthrough</i>"]
        OAuthService["OAuth Service<br/><i>443 → 8443</i>"]
        OAuthSA["OAuth ServiceAccount"]
        CASecret["CA Secret<br/><i>RSA 2048-bit</i>"]
        NetworkPolicy["NetworkPolicies"]
        OAuthConfig["OAuth Cookie Secret"]
        ProxyTLS["Proxy TLS Secret"]
    end

    %% Injected into Pods
    subgraph InjectedComponents["Injected into Ray Pods"]
        OAuthProxy["oauth-proxy sidecar<br/><i>Port 8443</i>"]
        mTLSInit["mTLS Init Containers<br/><i>Cert generation</i>"]
        TLSEnvVars["TLS Environment Vars"]
    end

    %% External Dependencies
    KubeRay["KubeRay Operator"]
    K8sAPI["Kubernetes API Server"]

    %% Flows
    KubeRay -->|creates| RayClusterCR
    RayClusterCR -->|watched by| RCController
    AppWrapperCR -->|watched by| AWController

    RCController -->|creates| OAuthRoute
    RCController -->|creates| ClientRoute
    RCController -->|creates| OAuthService
    RCController -->|creates| OAuthSA
    RCController -->|creates| CASecret
    RCController -->|creates| NetworkPolicy
    RCController -->|creates| OAuthConfig
    RCController -->|creates| ProxyTLS

    RCWebhook -->|injects| OAuthProxy
    RCWebhook -->|injects| mTLSInit
    RCWebhook -->|injects| TLSEnvVars

    RCController -->|CRUD operations| K8sAPI

    %% Styling
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style RCWebhook fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style AWWebhook fill:#4a90e2,stroke:#333,color:#fff
    style ConfigMgr fill:#4a90e2,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333,color:#fff
    style AppWrapperCR fill:#f5a623,stroke:#333,color:#fff
    style OAuthRoute fill:#7ed321,stroke:#333
    style ClientRoute fill:#7ed321,stroke:#333
    style OAuthService fill:#7ed321,stroke:#333
    style OAuthSA fill:#7ed321,stroke:#333
    style CASecret fill:#7ed321,stroke:#333
    style NetworkPolicy fill:#7ed321,stroke:#333
    style OAuthConfig fill:#7ed321,stroke:#333
    style ProxyTLS fill:#7ed321,stroke:#333
    style OAuthProxy fill:#9b59b6,stroke:#333,color:#fff
    style mTLSInit fill:#9b59b6,stroke:#333,color:#fff
    style TLSEnvVars fill:#9b59b6,stroke:#333,color:#fff
    style KubeRay fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
