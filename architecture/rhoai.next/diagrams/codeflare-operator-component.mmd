graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)<br/>controller-runtime"]

        subgraph Controllers["Controllers"]
            RCController["RayCluster Controller<br/>Reconciles OAuth/mTLS<br/>infrastructure"]
            AWController["AppWrapper Controller<br/>(embedded, optional)<br/>Kueue-integrated scheduling"]
        end

        subgraph Webhooks["Webhooks (9443/TCP TLS)"]
            RCMutate["RayCluster<br/>Mutating Webhook<br/>Injects oauth-proxy,<br/>TLS init containers"]
            RCValidate["RayCluster<br/>Validating Webhook<br/>Enforces immutability"]
            AWMutate["AppWrapper<br/>Mutating Webhook<br/>Defaults AppWrapper CRs"]
            AWValidate["AppWrapper<br/>Validating Webhook<br/>SubjectAccessReview"]
        end

        Manager --> RCController
        Manager --> AWController
        Manager --> RCMutate
        Manager --> RCValidate
        Manager --> AWMutate
        Manager --> AWValidate
    end

    %% CRDs Watched
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)<br/>Owned by KubeRay"]
    AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    RayClusterCR -->|watched by| RCController
    AppWrapperCR -->|managed by| AWController

    %% Resources Created per RayCluster
    subgraph PerCluster["Per-RayCluster Resources"]
        OAuthRoute["OpenShift Route<br/>ray-dashboard-{cluster}<br/>TLS Reencrypt"]
        ClientRoute["OpenShift Route<br/>rayclient-{cluster}<br/>TLS Passthrough"]
        OAuthService["Service<br/>{cluster}-oauth<br/>443 → 8443"]
        OAuthSA["ServiceAccount<br/>{cluster}-oauth-proxy"]
        CRB["ClusterRoleBinding<br/>system:auth-delegator"]
        CACert["CA Secret<br/>ca-secret-{cluster}<br/>RSA 2048-bit"]
        CookieSecret["Cookie Secret<br/>{cluster}-oauth-config"]
        NetPol["NetworkPolicies<br/>head + worker isolation"]
    end

    RCController -->|creates| OAuthRoute
    RCController -->|creates| ClientRoute
    RCController -->|creates| OAuthService
    RCController -->|creates| OAuthSA
    RCController -->|creates| CRB
    RCController -->|creates| CACert
    RCController -->|creates| CookieSecret
    RCController -->|creates| NetPol

    %% Injected by Webhook
    subgraph Injected["Injected into RayCluster Pods"]
        OAuthProxy["oauth-proxy sidecar<br/>port 8443"]
        TLSInit["create-cert init container<br/>generates per-pod TLS certs"]
    end

    RCMutate -->|injects| OAuthProxy
    RCMutate -->|injects| TLSInit

    %% External Dependencies
    KubeRay["KubeRay Operator<br/>Owns RayCluster CRD"]
    OSHiftOAuth["OpenShift OAuth Server"]
    OSHiftIngress["OpenShift Ingress<br/>Controller (HAProxy)"]
    K8sAPI["Kubernetes API Server"]
    CertController["cert-controller<br/>(embedded)<br/>Webhook cert rotation"]

    KubeRay -.->|creates| RayClusterCR
    OAuthProxy -->|delegates auth| OSHiftOAuth
    OAuthRoute -->|served by| OSHiftIngress
    ClientRoute -->|served by| OSHiftIngress
    Manager -->|CRUD resources| K8sAPI
    CertController -->|rotates certs| Webhooks

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style RCMutate fill:#9b59b6,stroke:#333,color:#fff
    style RCValidate fill:#9b59b6,stroke:#333,color:#fff
    style AWMutate fill:#9b59b6,stroke:#333,color:#fff
    style AWValidate fill:#9b59b6,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style OAuthRoute fill:#7ed321,stroke:#333
    style ClientRoute fill:#7ed321,stroke:#333
    style OAuthService fill:#7ed321,stroke:#333
    style OAuthSA fill:#7ed321,stroke:#333
    style CRB fill:#7ed321,stroke:#333
    style CACert fill:#e74c3c,stroke:#333,color:#fff
    style CookieSecret fill:#e74c3c,stroke:#333,color:#fff
    style NetPol fill:#7ed321,stroke:#333
    style OAuthProxy fill:#e67e22,stroke:#333,color:#fff
    style TLSInit fill:#e67e22,stroke:#333,color:#fff
    style KubeRay fill:#999,stroke:#333,color:#fff
    style OSHiftOAuth fill:#999,stroke:#333,color:#fff
    style OSHiftIngress fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CertController fill:#4a90e2,stroke:#333,color:#fff
