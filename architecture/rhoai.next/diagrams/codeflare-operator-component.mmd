graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        Manager["codeflare-operator<br/>(manager)"]

        subgraph Controllers["Controllers"]
            RCController["RayCluster Controller<br/>Reconciles RayCluster CRs"]
            AWController["AppWrapper Controller<br/>(embedded, optional)<br/>Quota-aware scheduling"]
        end

        subgraph Webhooks["Webhooks (port 9443)"]
            RCMutating["RayCluster Mutating Webhook<br/>Injects OAuth proxy + mTLS"]
            RCValidating["RayCluster Validating Webhook<br/>Enforces immutability"]
            AWMutating["AppWrapper Mutating Webhook<br/>(optional)"]
            AWValidating["AppWrapper Validating Webhook<br/>(optional)"]
        end

        Manager --> RCController
        Manager --> AWController
        Manager --> RCMutating
        Manager --> RCValidating
        Manager --> AWMutating
        Manager --> AWValidating
    end

    %% CRDs Watched
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]

    User["User / KubeRay Operator"] -->|creates| RayClusterCR
    User -->|creates| AppWrapperCR
    RayClusterCR -->|watched by| RCController
    AppWrapperCR -->|watched by| AWController

    %% Resources Created by RayCluster Controller
    subgraph CreatedResources["Resources Created per RayCluster"]
        OAuthRoute["OAuth Route<br/>(ray-dashboard)"]
        ClientRoute["Client Route<br/>(rayclient)"]
        OAuthService["OAuth Service<br/>(port 443→8443)"]
        OAuthProxy["OAuth Proxy Sidecar<br/>(injected into head pod)"]
        mTLSInit["mTLS Init Containers<br/>(cert generation)"]
        CASecret["CA Secret<br/>(RSA 2048-bit)"]
        OAuthSecret["OAuth Config Secret"]
        TLSSecret["Proxy TLS Secret"]
        NetPol["NetworkPolicies<br/>(head + worker)"]
        CRB["ClusterRoleBinding<br/>(auth-delegator)"]
        SA["ServiceAccount<br/>(oauth-proxy)"]
    end

    RCController -->|creates| OAuthRoute
    RCController -->|creates| ClientRoute
    RCController -->|creates| OAuthService
    RCController -->|creates| CASecret
    RCController -->|creates| OAuthSecret
    RCController -->|creates| TLSSecret
    RCController -->|creates| NetPol
    RCController -->|creates| CRB
    RCController -->|creates| SA
    RCMutating -->|injects| OAuthProxy
    RCMutating -->|injects| mTLSInit

    %% External Dependencies
    RCController -->|reads ingress domain| OSIngress["OpenShift Ingress Config"]
    OAuthProxy -->|delegates auth| OSOAuth["OpenShift OAuth Server"]
    AWController -->|integrates| Kueue["Kueue"]
    Manager -->|cert rotation| CertController["cert-controller"]
    RCController -->|reads| DSCI["DSCInitialization CR"]

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style RCMutating fill:#6baed6,stroke:#333
    style RCValidating fill:#6baed6,stroke:#333
    style AWMutating fill:#6baed6,stroke:#333
    style AWValidating fill:#6baed6,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style OAuthRoute fill:#7ed321,stroke:#333
    style ClientRoute fill:#7ed321,stroke:#333
    style OAuthService fill:#7ed321,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333
    style mTLSInit fill:#7ed321,stroke:#333
    style CASecret fill:#d0021b,stroke:#333,color:#fff
    style OAuthSecret fill:#d0021b,stroke:#333,color:#fff
    style TLSSecret fill:#d0021b,stroke:#333,color:#fff
    style NetPol fill:#7ed321,stroke:#333
    style CRB fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style OSIngress fill:#e8e8e8,stroke:#333
    style OSOAuth fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style CertController fill:#e8e8e8,stroke:#333
    style DSCI fill:#e8e8e8,stroke:#333
