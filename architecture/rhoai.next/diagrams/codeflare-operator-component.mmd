graph TB
    subgraph CodeFlareOperator["CodeFlare Operator"]
        direction TB
        subgraph Controllers["Controllers"]
            RCController["RayCluster Controller<br/><i>Reconciles RayCluster CRs</i>"]
            AWController["AppWrapper Controller<br/><i>Embedded from appwrapper library</i><br/><i>Kueue integration</i>"]
        end

        subgraph Webhooks["Admission Webhooks (port 9443)"]
            RCMutate["RayCluster Mutating Webhook<br/><i>Injects oauth-proxy sidecar,</i><br/><i>mTLS init containers</i>"]
            RCValidate["RayCluster Validating Webhook<br/><i>Validates immutability of</i><br/><i>injected resources</i>"]
            AWMutate["AppWrapper Mutating Webhook<br/><i>Defaults AppWrapper resources</i>"]
            AWValidate["AppWrapper Validating Webhook<br/><i>Validates create/update</i>"]
        end

        CertController["cert-controller<br/><i>Webhook TLS cert rotation</i><br/><i>(open-policy-agent/cert-controller)</i>"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/><i>ray.io/v1</i>"]
    AppWrapperCR["AppWrapper CR<br/><i>workload.codeflare.dev/v1beta2</i>"]

    %% Created Resources (per RayCluster)
    subgraph PerCluster["Per-RayCluster Resources"]
        OAuthSvc["OAuth Service<br/><i>443→8443</i>"]
        DashRoute["Dashboard Route<br/><i>Reencrypt TLS</i>"]
        ClientRoute["RayClient Route<br/><i>Passthrough TLS</i>"]
        OAuthSA["OAuth ServiceAccount<br/><i>+ ClusterRoleBinding</i>"]
        CASecret["CA Secret<br/><i>RSA 2048 self-signed</i>"]
        ProxyTLS["Proxy TLS Secret<br/><i>service-serving-cert</i>"]
        OAuthConfig["OAuth Cookie Secret"]
        NetPol["NetworkPolicies (x2)"]
    end

    %% External Dependencies
    KubeRay["KubeRay Operator"]
    DSCI["DSCInitialization CR<br/><i>(opendatahub-operator)</i>"]
    OSIngress["OpenShift Ingress Config"]
    OSOAuth["OpenShift OAuth"]
    Kueue["Kueue<br/><i>Workload queuing</i>"]
    K8sAPI["Kubernetes API Server"]

    %% Flows
    RayClusterCR -->|"watched by"| RCController
    AppWrapperCR -->|"watched by"| AWController
    RayClusterCR -->|"intercepts create/update"| RCMutate
    RayClusterCR -->|"intercepts create/update"| RCValidate
    AppWrapperCR -->|"intercepts create/update"| AWMutate
    AppWrapperCR -->|"intercepts create/update"| AWValidate

    RCController -->|"creates/manages"| OAuthSvc
    RCController -->|"creates"| DashRoute
    RCController -->|"creates"| ClientRoute
    RCController -->|"creates"| OAuthSA
    RCController -->|"generates"| CASecret
    RCController -->|"triggers"| ProxyTLS
    RCController -->|"creates"| OAuthConfig
    RCController -->|"creates"| NetPol

    KubeRay -->|"provisions Ray pods"| RayClusterCR
    RCController -->|"reads"| DSCI
    RCController -->|"reads domain"| OSIngress
    OAuthSA -->|"redirect ref"| OSOAuth
    AWController -->|"integrates"| Kueue
    CertController -->|"manages certs for"| Webhooks

    %% Styling
    style CodeFlareOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controllers fill:#bbdefb,stroke:#1565c0
    style Webhooks fill:#bbdefb,stroke:#1565c0
    style PerCluster fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style RCController fill:#4a90e2,stroke:#333,color:#fff
    style AWController fill:#4a90e2,stroke:#333,color:#fff
    style RCMutate fill:#7986cb,stroke:#333,color:#fff
    style RCValidate fill:#7986cb,stroke:#333,color:#fff
    style AWMutate fill:#7986cb,stroke:#333,color:#fff
    style AWValidate fill:#7986cb,stroke:#333,color:#fff
    style CertController fill:#4a90e2,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style KubeRay fill:#999,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333
    style OSIngress fill:#999,stroke:#333,color:#fff
    style OSOAuth fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
