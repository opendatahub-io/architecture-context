graph LR
    Notebooks["notebooks-downstream<br/>(Container Image Factory)"]

    %% External Dependencies
    subgraph ExtDeps["External Dependencies"]
        CUDA["NVIDIA CUDA Toolkit<br/>12.6.3"]
        cuDNN["NVIDIA cuDNN<br/>9.5.1.17"]
        NCCL["NVIDIA NCCL<br/>2.23.4"]
        ROCm["AMD ROCm<br/>6.2.4"]
        NVToolkit["NVIDIA Container Toolkit<br/>(on host)"]
        PyPI["PyPI<br/>(pypi.org)"]
        UBIRepos["Red Hat UBI<br/>Repositories"]
        RHELSub["RHEL Subscription<br/>(RStudio only)"]
        MSSQLRepo["MSSQL RPM<br/>Repository"]
        EPEL["EPEL 9<br/>(TF py3.12 only)"]
    end

    Notebooks -->|"GPU compute<br/>(GPU images only)"| CUDA
    Notebooks -->|"DNN acceleration<br/>(GPU images only)"| cuDNN
    Notebooks -->|"Multi-GPU comms<br/>(GPU images only)"| NCCL
    Notebooks -->|"AMD GPU compute<br/>(ROCm images only)"| ROCm
    Notebooks -.->|"device passthrough<br/>(host requirement)"| NVToolkit
    Notebooks -->|"Python packages<br/>(all images)"| PyPI
    Notebooks -->|"Base OS packages<br/>(all images)"| UBIRepos
    Notebooks -.->|"RHEL9 packages<br/>(RStudio RHEL9)"| RHELSub
    Notebooks -.->|"mssql-tools18<br/>(data science)"| MSSQLRepo
    Notebooks -.->|"hdf5-devel<br/>(TF py3.12)"| EPEL

    %% Internal RHOAI Dependencies
    subgraph IntDeps["Internal RHOAI Dependencies"]
        NotebookController["odh-notebook-controller<br/>(image consumer)"]
        Dashboard["RHOAI Dashboard<br/>(image catalog)"]
        RhodsOperator["rhods-operator<br/>(manifest consumer)"]
        Elyra["Elyra<br/>(runtime consumer)"]
        KFP["Kubeflow Pipelines SDK<br/>2.12 (bundled)"]
        Codeflare["Codeflare SDK<br/>0.30 (bundled)"]
        KFTraining["Kubeflow Training SDK<br/>1.9 (bundled)"]
    end

    NotebookController -->|"deploys as<br/>StatefulSets"| Notebooks
    Dashboard -->|"reads ImageStream<br/>annotations"| Notebooks
    RhodsOperator -->|"deploys ImageStream<br/>manifests"| Notebooks
    Elyra -->|"executes pipeline<br/>nodes"| Notebooks
    Notebooks -->|"includes SDK"| KFP
    Notebooks -->|"includes SDK"| Codeflare
    Notebooks -->|"includes SDK"| KFTraining

    %% Integration Points
    subgraph Integration["Integration Points"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>(sidecar injection)"]
        TektonKonflux["Tekton/Konflux<br/>(CI pipeline)"]
        QuayODH["quay.io/opendatahub<br/>(upstream registry)"]
        QuayMODH["quay.io/modh<br/>(downstream registry)"]
    end

    KubeRBACProxy -->|"auth sidecar<br/>injected by controller"| Notebooks
    TektonKonflux -->|"multi-arch builds"| Notebooks
    Notebooks -->|"publishes upstream"| QuayODH
    Notebooks -->|"publishes downstream"| QuayMODH

    %% Runtime egress targets
    subgraph RuntimeEgress["Runtime Egress Targets"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        MongoDB["MongoDB<br/>27017/TCP"]
        MySQL["MySQL<br/>3306/TCP"]
        Kafka["Kafka Brokers<br/>9092/TCP"]
    end

    Notebooks -.->|"user data access<br/>(at runtime)"| S3
    Notebooks -.->|"database connectivity<br/>(at runtime)"| PostgreSQL
    Notebooks -.->|"database connectivity<br/>(at runtime)"| MongoDB
    Notebooks -.->|"database connectivity<br/>(at runtime)"| MySQL
    Notebooks -.->|"event streaming<br/>(at runtime)"| Kafka

