graph LR
    Notebooks["Notebooks-Downstream<br/>(Workbench Images)"]

    %% External Dependencies - Base Images
    Notebooks -->|"base image<br/>(all images)"| UBI9_311["UBI9 Python 3.11<br/>registry.access.redhat.com"]
    Notebooks -->|"base image<br/>(3.12 variants)"| UBI9_312["UBI9 Python 3.12<br/>registry.access.redhat.com"]
    Notebooks -->|"base image<br/>(RStudio only)"| C9S["CentOS Stream 9<br/>Python 3.11<br/>quay.io/sclorg"]

    %% External Dependencies - GPU
    Notebooks -->|"GPU compute<br/>(CUDA variants)"| CUDA["NVIDIA CUDA 12.6.3<br/>+ cuDNN 9.5.1<br/>+ NCCL 2.23.4"]
    Notebooks -->|"GPU compute<br/>(ROCm variants)"| ROCm["AMD ROCm 6.2.4"]

    %% External Dependencies - IDE Components
    Notebooks -->|"VS Code IDE"| CodeServerPkg["code-server 4.98.0"]
    Notebooks -->|"R IDE"| RStudioPkg["RStudio Server<br/>2024.12.1-563"]
    Notebooks -->|"reverse proxy"| NGINX["NGINX 1.24"]

    %% External Dependencies - Tooling
    Notebooks -->|"embedded CLI"| OC["OpenShift CLI (oc)<br/>stable"]
    Notebooks -->|"Python deps"| Micropipenv["micropipenv<br/>latest"]
    Notebooks -->|"PDF export"| TexLive["TexLive + Pandoc"]

    %% Internal Platform Dependencies
    NotebookController["ODH Notebook<br/>Controller"] -->|"launches pods +<br/>injects sidecars"| Notebooks
    Dashboard["RHOAI Dashboard"] -->|"reads ImageStream<br/>annotations for UI"| Notebooks
    RhodsOp["rhods-operator"] -->|"deploys ImageStream<br/>manifests"| Notebooks
    Elyra["Elyra Pipeline<br/>Editor"] -->|"executes pipeline<br/>nodes via runtimes"| Notebooks
    KFP["Kubeflow Pipelines"] -->|"orchestrates<br/>runtime pods"| Notebooks

    %% CI/CD
    Konflux["Konflux / Tekton"] -->|"builds images<br/>.tekton/ PipelineRuns"| Notebooks

    %% Integration Points (bidirectional)
    Notebooks -.->|"publishes to"| Quay["quay.io/modh/<br/>Image Registry"]
    Notebooks -.->|"tracked via"| ImageStream["OpenShift<br/>ImageStreams"]

