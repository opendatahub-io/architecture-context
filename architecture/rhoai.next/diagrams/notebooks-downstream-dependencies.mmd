    Notebooks -.->|"DB CLI<br/>(datascience)"| MSSQLTools
    Notebooks -.->|"TrustyAI<br/>requirement"| Java17

    %% Internal ODH Platform Dependencies
    subgraph InternalODH["Internal Platform (ODH/RHOAI)"]
        NotebookController["odh-notebook-controller<br/>(image consumer)"]
        RHODSOp["rhods-operator<br/>(manifest consumer)"]
        RHOAIDash["RHOAI Dashboard<br/>(UI reference)"]
        KFP["Kubeflow Pipelines<br/>(runtime consumer)"]
        Elyra["Elyra<br/>(in-image library)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(injected sidecar)"]
    end

    NotebookController -->|"creates StatefulSet<br/>using image"| Notebooks
    RHODSOp -->|"deploys<br/>ImageStreams"| Notebooks
    RHOAIDash -->|"reads annotations<br/>for UI"| Notebooks
    KFP -->|"uses runtime<br/>images"| Notebooks
    Notebooks -->|"pre-installed<br/>extension"| Elyra
    KubeRBACProxy -->|"auth sidecar<br/>8443/TCP"| Notebooks

    %% CI/CD Integration
    subgraph CICD["CI/CD"]
        Konflux["Konflux / PaC"]
        Quay["quay.io/opendatahub"]
        QuayMODH["quay.io/modh"]
    end

    Konflux -->|"builds images<br/>via Tekton"| Notebooks
    Notebooks -->|"publishes to"| Quay
    Notebooks -->|"historical<br/>digests from"| QuayMODH

