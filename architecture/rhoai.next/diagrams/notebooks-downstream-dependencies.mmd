    Notebooks -->|"process mgmt"| supervisord["supervisord"]
    Notebooks -->|"Java runtime<br/>(TrustYAI)"| Java17["Java 17 JDK"]
    Notebooks -->|"R language"| R["R 4.4.3"]
    Notebooks -->|"R IDE"| RStudio["RStudio Server<br/>2024.12.1"]
