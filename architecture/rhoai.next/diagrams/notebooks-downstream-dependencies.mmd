graph LR
    Notebooks["Notebooks<br/>(Workbench Images)"]

    %% Base Images (External Dependencies)
    subgraph BaseImages["Base Container Images"]
        UBI9_311["UBI9 Python 3.11<br/>(latest)"]
        UBI9_312["UBI9 Python 3.12<br/>(latest)"]
        C9S["CentOS Stream 9<br/>Python 3.11"]
        RHEL9["RHEL9 Python 3.11<br/>(latest)"]
    end

    Notebooks -->|"base image<br/>(Jupyter, CodeServer, Runtime)"| UBI9_311
    Notebooks -->|"base image<br/>(Python 3.12 variants)"| UBI9_312
    Notebooks -->|"base image<br/>(RStudio C9S)"| C9S
    Notebooks -->|"base image<br/>(RStudio RHEL9)"| RHEL9

    %% GPU Acceleration Libraries
    subgraph GPULibs["GPU Acceleration"]
        CUDA["NVIDIA CUDA 12.6.3"]
        cuDNN["NVIDIA cuDNN 9.5.1.17"]
        NCCL["NVIDIA NCCL 2.23.4"]
        ROCm["AMD ROCm 6.2.4"]
    end

    Notebooks -->|"GPU accel<br/>(CUDA variants)"| CUDA
    CUDA ---|bundled| cuDNN
    CUDA ---|bundled| NCCL
    Notebooks -->|"GPU accel<br/>(ROCm variants)"| ROCm

    %% IDE / Server Software
    subgraph IDESoftware["IDE / Server Software"]
        JupyterLab["JupyterLab 4.2"]
        CodeServerSW["code-server 4.98.0"]
        RStudioSW["RStudio Server 2024.12.1"]
        R["R 4.4.3"]
        NGINX["NGINX 1.24"]
        Supervisor["supervisor"]
    end

    Notebooks -->|"notebook IDE"| JupyterLab
    Notebooks -->|"VS Code server"| CodeServerSW
    Notebooks -->|"R IDE"| RStudioSW
    RStudioSW ---|requires| R
    CodeServerSW ---|"reverse proxy"| NGINX
    RStudioSW ---|"reverse proxy"| NGINX
    CodeServerSW ---|"process mgmt"| Supervisor
    RStudioSW ---|"process mgmt"| Supervisor

    %% Build/Dev Tools
    subgraph BuildTools["Build & Document Tools"]
        micropipenv["micropipenv"]
        TexLive["TexLive (LaTeX)"]
        Pandoc["Pandoc 3.7.0.2"]
        OC_CLI["OpenShift CLI (oc)"]
        MongoCLI["MongoDB CLI 2.0.3<br/>(FIPS)"]
        MSSQLTools["MSSQL Tools 18"]
        Java17["Java 17 (OpenJDK)"]
    end

    Notebooks -->|"Python deps"| micropipenv
    Notebooks -->|"PDF export"| TexLive
    Notebooks -->|"PDF export"| Pandoc
    Notebooks -->|"cluster CLI"| OC_CLI
