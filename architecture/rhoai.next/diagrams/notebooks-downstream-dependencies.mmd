graph LR
    Notebooks["notebooks-downstream<br/>(~32 Container Images)"]

    %% Internal RHOAI Dependencies (consumers)
    Operator["rhods-operator<br/>opendatahub-operator"]
    NotebookCtrl["odh-notebook-controller"]
    Dashboard["RHOAI Dashboard"]
    ElyraCtrl["Elyra Pipeline Controller"]
    KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
    Tekton["Tekton / Konflux<br/>(35 PipelineRuns)"]

    %% GPU Dependencies
    CUDA["NVIDIA CUDA Toolkit<br/>12.6.3"]
    cuDNN["cuDNN 9.5.1.17"]
    NCCL["NCCL 2.23.4"]
    ROCm["AMD ROCm 6.2.4"]
    AMDGPU["AMDGPU Driver 6.2.4"]

    %% IDE Dependencies
    CodeServerDep["code-server 4.98.0"]
    RStudioDep["RStudio Server<br/>2024.12.1-563"]
    RLang["R 4.4.3"]
    NginxDep["nginx 1.24"]
    Supervisord["supervisord"]

    %% Build/System Tools
    Micropipenv["micropipenv"]
    TexLive["TeX Live"]
    Pandoc["pandoc"]
    OC["OpenShift CLI (oc)"]
    Skopeo["skopeo"]
    Java17["Java 17 (OpenJDK)"]
    MongoCLI["MongoDB CLI 2.0.3"]
    MSSQL["MSSQL Tools 18"]

    %% External Services
    Quay["quay.io/modh<br/>(Container Registry)"]
    PyPI["PyPI<br/>(Python Packages)"]
    K8sAPI["OpenShift API<br/>6443/TCP"]
    S3["Object Storage (S3)<br/>443/TCP"]

    %% Base Images
    UBI9["UBI9 Python 3.11/3.12<br/>registry.access.redhat.com"]
    C9S["CentOS Stream 9 Python<br/>quay.io/sclorg"]

    %% Internal platform consumes these images
    Operator -->|"deploys ImageStreams<br/>from manifests/"| Notebooks
    NotebookCtrl -->|"creates StatefulSet<br/>pods from images"| Notebooks
    Dashboard -->|"reads ImageStream<br/>annotations for UI"| Notebooks
    ElyraCtrl -->|"uses runtime images<br/>for pipeline steps"| Notebooks
    KubeRBACProxy -.->|"injected as sidecar<br/>by controller"| Notebooks
    Tekton -->|"builds images<br/>via .tekton/"| Notebooks

    %% Image base dependencies
    Notebooks -->|"base image"| UBI9
    Notebooks -->|"base image (RStudio)"| C9S

    %% GPU dependencies (optional)
    Notebooks -->|"GPU compute (NVIDIA)"| CUDA
    CUDA --> cuDNN
    CUDA --> NCCL
    Notebooks -->|"GPU compute (AMD)"| ROCm
    ROCm --> AMDGPU

    %% IDE dependencies
    Notebooks -->|"VS Code IDE"| CodeServerDep
    Notebooks -->|"R IDE"| RStudioDep
    RStudioDep --> RLang
    CodeServerDep --> NginxDep
    RStudioDep --> NginxDep
    NginxDep --> Supervisord

    %% Build tools
    Notebooks -->|"Python deps"| Micropipenv
    Notebooks -->|"PDF export"| TexLive
    Notebooks -->|"doc conversion"| Pandoc
    Notebooks -->|"cluster CLI"| OC
    Notebooks -->|"image inspect"| Skopeo
    Notebooks -->|"TrustyAI runtime"| Java17
    Notebooks -->|"DB tools"| MongoCLI
    Notebooks -->|"DB tools"| MSSQL

    %% External services
    Notebooks -->|"image storage"| Quay
    Notebooks -->|"Python packages"| PyPI
    Notebooks -.->|"runtime: oc CLI"| K8sAPI
    Notebooks -.->|"runtime: pipeline artifacts"| S3

