graph LR
    Notebooks["Notebooks Downstream<br/>(Workbench Images)"]

    %% Internal RHOAI Dependencies (consumers of this component)
    NotebookController["ODH Notebook Controller"] -->|"launches as StatefulSet"| Notebooks
    Dashboard["RHOAI Dashboard"] -->|"reads ImageStream<br/>annotations"| Notebooks
    RhodsOp["rhods-operator"] -->|"applies kustomize<br/>manifests"| Notebooks
    DSPipelines["Data Science Pipelines<br/>/ Elyra"] -->|"executes pipeline<br/>steps"| Notebooks
    KubeflowCtrl["Kubeflow Notebook<br/>Controller"] -->|"manages pod<br/>lifecycle"| Notebooks

    %% Base OS Dependencies
    Notebooks -->|"base image"| UBI9["Red Hat UBI 9"]
    Notebooks -->|"base image (RStudio C9S)"| C9S["CentOS Stream 9"]
    Notebooks -->|"base image (RStudio RHEL9)"| RHEL9["RHEL 9"]

    %% GPU Dependencies
    Notebooks -->|"GPU compute<br/>(CUDA images)"| CUDA["NVIDIA CUDA 12.6.3<br/>+ cuDNN 9.5.1<br/>+ NCCL 2.23.4"]
    Notebooks -->|"GPU compute<br/>(ROCm images)"| ROCm["AMD ROCm 6.2.4"]

    %% Runtime Dependencies
    Notebooks -->|"Python deps"| Micropipenv["micropipenv"]
    Notebooks -->|"cluster CLI"| OC["OpenShift CLI (oc) 4.x"]
    Notebooks -->|"reverse proxy"| NGINX["NGINX 1.24"]
    Notebooks -->|"process mgmt"| Supervisord["supervisord"]

    %% IDE / Server Dependencies
    Notebooks -->|"VS Code IDE"| CodeServerDep["code-server v4.98.0"]
    Notebooks -->|"R IDE"| RStudioDep["RStudio Server 2024.12.1"]
    Notebooks -->|"R language"| RLang["R 4.4.3"]
    Notebooks -->|"Java runtime"| Java17["Java 17 JDK<br/>(TrustYAI only)"]

    %% Database Tools
    Notebooks -->|"MongoDB shell"| MongoSH["MongoDB CLI (mongosh)"]
    Notebooks -->|"SQL Server tools"| MSSQL["MSSQL Tools 18"]

    %% Build Infrastructure
    Notebooks -->|"CI/CD"| Konflux["Konflux / Tekton"]
    Notebooks -->|"image registry"| Quay["quay.io/modh"]

    %% Integration Points (other components that integrate)
    KubeflowTraining["Kubeflow Training<br/>Operator"] -.->|"SDK bundled<br/>in images"| Notebooks
    OSBuild["OpenShift Build<br/>(BuildConfig)"] -.->|"builds RStudio<br/>RHEL9 images"| Notebooks
    NVIDIARuntime["NVIDIA Container<br/>Runtime"] -.->|"GPU passthrough<br/>via env vars"| Notebooks
    AMDRuntime["AMD ROCm<br/>Runtime"] -.->|"GPU passthrough<br/>via device plugin"| Notebooks

