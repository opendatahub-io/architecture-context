graph LR
    Notebooks["Notebooks-Downstream<br/>(Workbench Images)"]

    %% External Dependencies - Base OS
    Notebooks -->|"base OS layer"| UBI9["Red Hat UBI 9<br/>latest"]
    Notebooks -.->|"RStudio C9S only"| C9S["CentOS Stream 9<br/>latest"]
    Notebooks -.->|"RStudio RHEL9 only"| RHEL9["RHEL 9<br/>latest"]

    %% External Dependencies - GPU
    Notebooks -->|"GPU compute (CUDA images)"| CUDA["NVIDIA CUDA Toolkit<br/>12.6.3"]
    Notebooks -->|"deep learning primitives"| cuDNN["NVIDIA cuDNN<br/>9.5.1.17"]
    Notebooks -->|"multi-GPU comms"| NCCL["NVIDIA NCCL<br/>2.23.4"]
    Notebooks -->|"GPU compute (ROCm images)"| ROCm["AMD ROCm<br/>6.2.4"]

    %% External Dependencies - Tooling
    Notebooks -->|"cluster CLI"| OC["OpenShift CLI (oc)<br/>4.x"]
    Notebooks -->|"Python deps installer"| micropipenv["micropipenv<br/>latest"]
    Notebooks -.->|"reverse proxy<br/>(code-server/RStudio)"| NGINX["NGINX<br/>1.24"]
    Notebooks -.->|"process mgmt<br/>(code-server/RStudio)"| supervisord["supervisord<br/>latest"]
    Notebooks -.->|"TrustYAI only"| Java17["Java 17 JDK"]
    Notebooks -.->|"RStudio only"| R["R<br/>4.4.3"]
    Notebooks -.->|"RStudio only"| RStudioSvr["RStudio Server<br/>2024.12.1"]
    Notebooks -.->|"code-server only"| CodeSvr["code-server<br/>v4.98.0"]
    Notebooks -.->|"datascience images"| MongoDB["MongoDB CLI<br/>(mongosh)"]
    Notebooks -.->|"datascience images"| MSSQL["MSSQL Tools<br/>18"]

    %% Internal ODH Dependencies
    NotebookCtrl["ODH Notebook<br/>Controller"] -->|"launches as StatefulSet"| Notebooks
    Dashboard["RHOAI Dashboard"] -->|"reads ImageStream<br/>annotations"| Notebooks
    Operator["rhods-operator"] -->|"applies kustomize<br/>manifests"| Notebooks
    DSPipelines["Data Science Pipelines<br/>/ Elyra"] -->|"uses runtime images"| Notebooks
    KubeflowCtrl["Kubeflow Notebook<br/>Controller"] -->|"manages pod lifecycle"| Notebooks

    %% Integration Points (consumers of notebooks)
    KubeflowTraining["Kubeflow Training<br/>Operator"] -.->|"SDK bundled<br/>in images"| Notebooks
    Konflux["Konflux / Tekton"] -->|"builds multi-arch<br/>images"| Notebooks
    NVIDIARuntime["NVIDIA Container<br/>Runtime"] -.->|"GPU passthrough<br/>(CUDA images)"| Notebooks
    AMDRuntime["AMD ROCm<br/>Runtime"] -.->|"GPU passthrough<br/>(ROCm images)"| Notebooks
    BuildConfig["OpenShift Build<br/>(BuildConfig)"] -->|"builds RStudio<br/>RHEL9 images"| Notebooks

