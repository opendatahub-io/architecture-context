graph TB
    subgraph Platform["PLATFORM ORCHESTRATOR"]
        PlatformOp["rhods-operator /<br/>opendatahub-operator"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (e.g., redhat-ods-applications)"]
        direction TB
        Operator["trainer-operator<br/>SA: controller-manager<br/>FIPS: CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime"]

        subgraph Ports["Exposed Ports"]
            MetricsPort["Metrics<br/>8080/TCP HTTP<br/>No encryption<br/>NetworkPolicy: metrics=enabled"]
            HealthPort["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz<br/>kubelet only"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    subgraph ManagedCluster["MANAGED RESOURCES (deployed by operator)"]
        direction TB
        KFTrainer["Kubeflow Trainer v2<br/>Controller + CRDs +<br/>Webhooks + RBAC"]
        CTR["ClusterTrainingRuntimes<br/>15 variants<br/>(torch-distributed +<br/>training-hub)"]
        ImgStreams["Training Hub<br/>ImageStreams<br/>(OpenShift only)"]
    end

    subgraph Dependencies["RUNTIME DEPENDENCIES"]
        JobSetOp["JobSet Operator<br/>(OLM)"]
        JobSetCRD["JobSet CRD<br/>jobsets.jobset.x-k8s.io"]
    end

    %% Platform creates CR
    PlatformOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Create Trainer CR"| APIServer

    %% API Server watches to operator
    APIServer -->|"Watch stream<br/>TLS 1.2+<br/>SA token<br/>Trainer CR events"| Operator

    %% Operator CRUD to API Server
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD: CRDs, Deployments,<br/>Services, RBAC, Secrets,<br/>Webhooks, ImageStreams"| APIServer

    %% Operator deploys resources via API Server
    Operator -->|"SSA Apply<br/>HTTPS/443"| KFTrainer
    Operator -->|"SSA Apply<br/>HTTPS/443"| CTR
    Operator -->|"SSA Apply<br/>HTTPS/443"| ImgStreams

    %% Dependency checks
    Operator -.->|"HTTPS/443<br/>Existence check"| JobSetOp
    Operator -.->|"HTTPS/443<br/>CRD check"| JobSetCRD

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>NetworkPolicy gated"| MetricsPort

    %% Styling - Trust zones
    classDef platform fill:#e6d5f7,stroke:#7c3aed,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ports fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef managed fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef dependency fill:#f5f5f5,stroke:#999,stroke-width:1px

    class PlatformOp platform
    class APIServer controlplane
    class Operator operator
    class MetricsPort,HealthPort ports
    class KFTrainer,CTR,ImgStreams managed
    class Prometheus monitoring
    class JobSetOp,JobSetCRD dependency
