graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AppBoundary["CAIKIT RUNTIME (Application Boundary)"]
        direction TB

        Runtime["Caikit Runtime Server<br/>gRPC :8085 / HTTP :8080<br/>Configurable TLS"]

        subgraph Library["caikit-nlp Library (In-Process)"]
            direction TB

            subgraph LocalModules["Local Inference Modules"]
                TextGen["TextGeneration<br/>(HuggingFace Local)"]
                EmbedMod["EmbeddingModule<br/>(sentence-transformers)"]
                CrossEnc["CrossEncoderModule<br/>(CrossEncoder)"]
                SeqClass["SequenceClassification"]
                SpanClass["FilteredSpanClassification"]
                PeftLocal["PeftPromptTuning<br/>(Local Training)"]
            end

            subgraph RemoteModules["Remote Backend Modules"]
                TextGenTGIS["TextGenerationTGIS<br/>(TGIS Backend)"]
                PeftTGIS["PeftPromptTuningTGIS<br/>(TGIS Backend)"]
            end
        end
    end

    subgraph EgressZone["EGRESS (Outbound Connections)"]
        TGIS["TGIS Server<br/>gRPC :8033-8034/TCP<br/>Configurable: Plaintext / TLS / mTLS<br/>Auth: Client certs (optional)"]
        HFHub["HuggingFace Hub<br/>HTTPS :443/TCP<br/>TLS 1.2+<br/>Auth: API token (optional)<br/>DEFAULT: DISABLED"]
    end

    %% Flows
    Client -->|"gRPC :8085 or HTTP :8080<br/>Configurable TLS"| Runtime
    Runtime -->|"In-process<br/>Python call"| Library

    TextGenTGIS -->|"gRPC :8033<br/>TLS/mTLS (configurable)<br/>ca_cert_file + client certs"| TGIS
    PeftTGIS -->|"gRPC :8033<br/>TLS/mTLS (configurable)<br/>ca_cert_file + client certs"| TGIS

    PeftLocal -.->|"HTTPS :443<br/>TLS 1.2+<br/>HF_TOKEN (optional)<br/>allow_downloads=true required"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef localmod fill:#d5e8d4,stroke:#82b366
    classDef remotemod fill:#ffe6cc,stroke:#d79b00
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450

    class Client external
    class Runtime runtime
    class TextGen,EmbedMod,CrossEnc,SeqClass,SpanClass,PeftLocal localmod
    class TextGenTGIS,PeftTGIS remotemod
    class TGIS egress
    class HFHub warning
