graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Platform["PLATFORM ORCHESTRATION"]
        KServe["KServe / ModelMesh<br/>Deploys container"]
        RBAC["kube-rbac-proxy sidecar<br/>(RHOAI 3.x)<br/>AuthN enforcement"]
    end

    subgraph RuntimeBoundary["RUNTIME BOUNDARY (odh-caikit-nlp-rhel9 Container)"]
        direction TB

        subgraph Server["Caikit Runtime Server"]
            gRPC["gRPC Server<br/>8085/TCP<br/>Configurable TLS"]
            HTTP["REST Gateway<br/>8080/TCP<br/>Configurable TLS"]
        end

        subgraph Modules["caikit-nlp Modules (in-process)"]
            TextGen["TextGeneration<br/>(Local HF)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            Peft["PeftPromptTuning<br/>(Training)"]
            PeftTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
            Embed["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEnc["CrossEncoderModule"]
            SeqClass["SequenceClassification"]
            SpanClass["FilteredSpanClassification"]
        end
    end

    subgraph EgressTargets["EGRESS TARGETS"]
        TGIS["TGIS Backend<br/>Configurable Port/TCP<br/>gRPC<br/>Optional mTLS"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token (optional)<br/>DISABLED by default"]
        PyTorchDist["PyTorch Distributed Peers<br/>29550/TCP<br/>PLAINTEXT<br/>No Auth"]
    end

    %% External access flow
    Client -->|"gRPC :8085 / HTTP :8080<br/>Configurable TLS<br/>Auth: platform-level"| RBAC
    RBAC -->|"authenticated request"| Server
    KServe -->|"deploys + manages"| RuntimeBoundary

    %% Internal routing
    gRPC -->|in-process| Modules
    HTTP -->|in-process| Modules

    %% Egress flows
    TextGenTGIS -->|"gRPC (configurable port)<br/>Optional TLS/mTLS<br/>ca_cert + client_cert"| TGIS
    PeftTGIS -->|"gRPC (configurable port)<br/>Optional TLS/mTLS<br/>Prompt cache upload"| TGIS
    TextGen -->|"HTTPS :443<br/>TLS 1.2+<br/>Optional API token<br/>allow_downloads=true required"| HFHub
    Peft -->|"TCP :29550<br/>PLAINTEXT<br/>No auth<br/>torchrun elastic launch"| PyTorchDist

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef server fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef module fill:#fff2cc,stroke:#d6b656
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#ff6666,stroke:#cc0000,stroke-width:2px,color:#fff

    class Client external
    class KServe,RBAC platform
    class gRPC,HTTP server
    class TextGen,TextGenTGIS,Peft,PeftTGIS,Embed,CrossEnc,SeqClass,SpanClass module
    class TGIS,HFHub egress
    class PyTorchDist warning
