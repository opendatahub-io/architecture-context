graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist<br/>Application"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Managed)"]
        Ingress["KServe InferenceService /<br/>Gateway API / kube-rbac-proxy<br/>TLS Termination<br/>AuthN/AuthZ: Platform-level"]
    end

    subgraph InternalCluster["INTERNAL CLUSTER (Trusted)"]
        direction TB

        subgraph RuntimePod["caikit Runtime Container<br/>User: caikit (UID 1001)<br/>Image: ubi9/ubi-minimal"]
            HTTPSvc["HTTP Server<br/>ClusterIP 8080/TCP<br/>Plaintext<br/>No Auth (delegated)"]
            GRPCSvc["gRPC Server<br/>ClusterIP 8085/TCP<br/>Plaintext<br/>No Auth (delegated)"]

            subgraph CaikitNLP["caikit-nlp Library (in-process)"]
                LocalModules["Local Modules<br/>TextGeneration<br/>PeftPromptTuning<br/>EmbeddingModule<br/>CrossEncoderModule<br/>SequenceClassification"]
                RemoteModules["TGIS Modules<br/>TextGenerationTGIS<br/>PeftPromptTuningTGIS<br/>TGISAutoFinder"]
            end
        end

        subgraph MultiGPU["MULTI-GPU TRAINING"]
            OtherRank["Other Runtime Pod<br/>(peer rank)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        TGIS["TGIS Server<br/>gRPC (default 8033/TCP)<br/>TLS optional<br/>mTLS optional"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth (optional)"]
    end

    %% Client to Platform
    Client -->|"HTTP/8080 or gRPC/8085<br/>Auth: Platform-managed"| Ingress

    %% Platform to Runtime
    Ingress -->|"HTTP/8080<br/>Plaintext (in-cluster)<br/>Auth validated at ingress"| HTTPSvc
    Ingress -->|"gRPC/8085<br/>Plaintext (in-cluster)<br/>Auth validated at ingress"| GRPCSvc

    %% Internal module routing
    HTTPSvc --> LocalModules
    HTTPSvc --> RemoteModules
    GRPCSvc --> LocalModules
    GRPCSvc --> RemoteModules

    %% Egress: TGIS
    RemoteModules -->|"gRPC/8033 (configurable)<br/>TLS optional<br/>mTLS: ca_cert, client_cert, client_key"| TGIS

    %% Egress: HuggingFace
    LocalModules -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (optional)<br/>Only when allow_downloads=true"| HFHub

    %% Multi-GPU training
    RuntimePod -->|"TCP/29550 (configurable)<br/>Plaintext<br/>PyTorch Distributed (torchrun)"| OtherRank

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef module fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class Ingress ingress
    class HTTPSvc,GRPCSvc,RuntimePod internal
    class LocalModules,RemoteModules module
    class TGIS,HFHub externalservice
    class OtherRank internal
