graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph ServingLayer["CAIKIT RUNTIME (Serving Layer)"]
        RuntimeHTTP["Caikit Runtime HTTP<br/>8080/TCP REST API<br/>TLS: runtime-configured"]
        RuntimeGRPC["Caikit Runtime gRPC<br/>8085/TCP<br/>TLS: runtime-configured"]
    end

    subgraph Library["CAIKIT-NLP LIBRARY (In-Process)"]
        direction TB

        subgraph LocalModules["Local Inference (no network egress)"]
            EmbMod["EmbeddingModule<br/>sentence-transformers<br/>thread-safe tokenization"]
            CrossEnc["CrossEncoderModule<br/>cross-encoder<br/>thread-safe tokenization"]
            TextGenLocal["TextGeneration<br/>HuggingFace CausalLM/Seq2Seq"]
            SeqClass["SequenceClassification<br/>AutoModelForSequenceClassification"]
        end

        subgraph RemoteModules["Remote Inference (gRPC egress)"]
            TextGenTGIS["TextGenerationTGIS<br/>gRPC client"]
            PeftTGIS["PeftPromptTuningTGIS<br/>gRPC client"]
        end

        subgraph Training["Training (multi-GPU)"]
            PeftLocal["PeftPromptTuning<br/>PEFT + Accelerate<br/>fp16/bf16 mixed precision"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        TGIS["TGIS Server<br/>8033/TCP gRPC<br/>TLS optional<br/>mTLS configurable"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)<br/>DEFAULT: DISABLED"]
        TorchDist["Torch Distributed<br/>29550/TCP TCP<br/>No encryption<br/>No auth"]
        LocalStorage["Local Model Storage<br/>Filesystem<br/>Path validation:<br/>TWO_DOTS_REGEX"]
    end

    %% Client to Runtime
    Client -->|"HTTP/8080<br/>TLS: runtime-configured<br/>Auth: runtime-configured"| RuntimeHTTP
    Client -->|"gRPC/8085<br/>TLS: runtime-configured<br/>Auth: runtime-configured"| RuntimeGRPC

    %% Runtime to Library (in-process)
    RuntimeHTTP -->|"In-process<br/>Python function call"| LocalModules
    RuntimeGRPC -->|"In-process<br/>Python function call"| RemoteModules
    RuntimeGRPC -->|"In-process<br/>Python function call"| Training

    %% Library to External Services
    TextGenTGIS -->|"gRPC/8033<br/>TLS optional<br/>ca_cert + client_cert<br/>configurable mTLS"| TGIS
    PeftTGIS -->|"gRPC/8033<br/>TLS optional<br/>mTLS configurable"| TGIS
    PeftLocal -->|"TCP/29550<br/>No encryption<br/>No auth"| TorchDist
    LocalModules -->|"Filesystem<br/>read-only models"| LocalStorage

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef serving fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef library fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef localmod fill:#4a90e2,color:#fff,stroke:#333
    classDef remotemod fill:#e86c00,color:#fff,stroke:#333
    classDef trainingmod fill:#9b59b6,color:#fff,stroke:#333
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef danger fill:#f8d7da,stroke:#f5c6cb,stroke-width:2px

    class Client external
    class RuntimeHTTP,RuntimeGRPC serving
    class EmbMod,CrossEnc,TextGenLocal,SeqClass localmod
    class TextGenTGIS,PeftTGIS remotemod
    class PeftLocal trainingmod
    class TGIS,LocalStorage extsvc
    class HFHub danger
    class TorchDist extsvc
