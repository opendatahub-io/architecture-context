graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>Data Scientist"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Managed)"]
        Ingress["kube-rbac-proxy /<br/>KServe InferenceService /<br/>Gateway API<br/>TLS termination + AuthN"]
    end

    subgraph RuntimePod["CAIKIT RUNTIME POD (In-Cluster)"]
        direction TB

        subgraph Servers["Network Servers"]
            HTTPServer["HTTP Server<br/>8080/TCP<br/>Plaintext (in-cluster)<br/>Auth: delegated"]
            GRPCServer["gRPC Server<br/>8085/TCP<br/>Plaintext (in-cluster)<br/>Auth: delegated"]
        end

        subgraph Modules["caikit-nlp Modules (In-Process)"]
            direction LR
            TextGenLocal["TextGeneration<br/>(Local)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote)"]
            EmbMod["EmbeddingModule"]
            PeftPT["PeftPromptTuning"]
            PeftTGIS["PeftPromptTuningTGIS"]
            CrossEnc["CrossEncoderModule"]
        end

        ContainerInfo["Container: ubi9/ubi-minimal<br/>User: caikit (UID 1001)<br/>Non-root"]
    end

    subgraph InternalSvc["INTERNAL SERVICES"]
        TGIS["TGIS Server<br/>gRPC (default 8033/TCP)<br/>TLS (configurable)<br/>mTLS (optional)"]
        TorchDist["PyTorch Distributed<br/>29550/TCP<br/>TCP plaintext<br/>Multi-GPU coordination"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth (optional)"]
    end

    %% External to Platform
    Client -->|"HTTPS (platform-managed)<br/>Platform AuthN/AuthZ"| Ingress

    %% Platform to Runtime
    Ingress -->|"HTTP/8080 or gRPC/8085<br/>Plaintext (in-cluster)<br/>Identity verified"| HTTPServer
    Ingress -->|"HTTP/8080 or gRPC/8085<br/>Plaintext (in-cluster)<br/>Identity verified"| GRPCServer

    %% Servers to Modules
    HTTPServer --- Modules
    GRPCServer --- Modules

    %% Module to TGIS
    TextGenTGIS -->|"gRPC (default 8033/TCP)<br/>TLS (ca_cert_file)<br/>mTLS (client_cert + key)"| TGIS
    PeftTGIS -->|"gRPC (default 8033/TCP)<br/>TLS (ca_cert_file)<br/>mTLS (client_cert + key)"| TGIS

    %% Module to HuggingFace
    TextGenLocal -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (optional)<br/>Only if allow_downloads=true"| HFHub
    EmbMod -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (optional)<br/>Only if allow_downloads=true"| HFHub

    %% Torch distributed
    PeftPT -.->|"TCP/29550<br/>Plaintext<br/>elastic_launch"| TorchDist

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef container fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class Ingress ingress
    class HTTPServer,GRPCServer,TextGenLocal,TextGenTGIS,EmbMod,PeftPT,PeftTGIS,CrossEnc runtime
    class ContainerInfo container
    class TGIS,TorchDist internal
    class HFHub externalservice
