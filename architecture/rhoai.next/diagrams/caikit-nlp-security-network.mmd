graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph PlatformLayer["PLATFORM LAYER (RHOAI)"]
        RBACProxy["kube-rbac-proxy Sidecar<br/>Auth Enforcement<br/>Token Validation / RBAC"]
    end

    subgraph CaikitRuntime["CAIKIT RUNTIME (Inference Container)"]
        direction TB

        gRPCServer["Caikit gRPC Server<br/>8085/TCP<br/>Configurable TLS<br/>RUNTIME_TLS_SERVER_KEY/CERT"]
        HTTPGateway["Caikit HTTP REST Gateway<br/>8080/TCP<br/>Configurable TLS<br/>/api/v1/task/*"]

        subgraph CaikitNLPLib["caikit-nlp Library (in-process)"]
            direction LR
            TextGenMods["TextGeneration<br/>TextGenerationTGIS<br/>PeftPromptTuning<br/>PeftPromptTuningTGIS"]
            EmbedMods["EmbeddingModule<br/>CrossEncoderModule"]
            ClassMods["SequenceClassification<br/>FilteredSpanClassification<br/>RegexSentenceSplitter"]
        end

        TGISClient["TGISGenerationClient<br/>(gRPC client)"]
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        TGIS["TGIS Backend<br/>Configurable Port/TCP<br/>gRPC<br/>Optional TLS/mTLS"]
        HFHub["HuggingFace Hub<br/>443/TCP<br/>HTTPS / TLS 1.2+<br/>API Token (optional)<br/>DEFAULT: DISABLED"]
        PyTorchDist["PyTorch Distributed Peers<br/>29550/TCP<br/>TCP PLAINTEXT<br/>No Auth"]
    end

    %% Flows
    Client -->|"gRPC/8085 or HTTP/8080<br/>Configurable TLS<br/>No in-lib auth"| RBACProxy
    RBACProxy -->|"Authenticated request<br/>gRPC/8085"| gRPCServer
    RBACProxy -->|"Authenticated request<br/>HTTP/8080"| HTTPGateway

    gRPCServer --> CaikitNLPLib
    HTTPGateway --> CaikitNLPLib

    TextGenMods --> TGISClient
    TGISClient -->|"gRPC / Configurable Port<br/>Optional TLS/mTLS<br/>ca_cert + client_cert"| TGIS

    CaikitNLPLib -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Token (opt)<br/>DISABLED by default"| HFHub

    TextGenMods -.->|"TCP/29550<br/>PLAINTEXT<br/>No Auth<br/>Distributed training only"| PyTorchDist

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef library fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class RBACProxy platform
    class gRPCServer,HTTPGateway runtime
    class TextGenMods,EmbedMods,ClassMods library
    class TGISClient runtime
    class TGIS,HFHub egress
    class PyTorchDist warning
