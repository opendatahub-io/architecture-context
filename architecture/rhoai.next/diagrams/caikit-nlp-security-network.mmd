graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe / Gateway Layer)"]
        Gateway["KServe InferenceService Gateway<br/>TLS Termination<br/>AuthN: kube-rbac-proxy / Gateway API"]
    end

    subgraph Application["APPLICATION (caikit Runtime Container)"]
        direction TB

        subgraph RuntimePod["Pod: InferenceService<br/>Namespace: {user-namespace}<br/>User: UID 1001 (caikit, non-root)"]
            HTTPServer["caikit HTTP Server<br/>8080/TCP ClusterIP<br/>Encryption: Runtime-configured<br/>Auth: Runtime-configured"]
            gRPCServer["caikit gRPC Server<br/>8085/TCP ClusterIP<br/>Encryption: Runtime-configured<br/>Auth: Runtime-configured"]

            subgraph CaikitNLP["caikit-nlp Library (in-process)<br/>RUNTIME_LIBRARY=caikit_nlp"]
                TextGen["TextGeneration<br/>(Local HF Models)"]
                TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
                Embed["EmbeddingModule<br/>(SentenceTransformer)"]
                Peft["PeftPromptTuning<br/>(Local Training)"]
                PeftTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
                SeqClass["SequenceClassification"]
                SpanClass["FilteredSpanClassification"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        TGIS["TGIS Server<br/>configurable/TCP<br/>gRPC<br/>TLS optional"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph LocalStorage["LOCAL STORAGE"]
        ModelMount["/caikit/ Volume Mount<br/>Model artifacts<br/>Prompt vectors (encoder.pt, decoder.pt)"]
    end

    %% External → Ingress
    Client -->|"HTTPS<br/>TLS (platform-managed)<br/>Bearer Token"| Gateway

    %% Ingress → Application
    Gateway -->|"HTTP/8080<br/>Runtime-configured"| HTTPServer
    Gateway -->|"gRPC/8085<br/>Runtime-configured"| gRPCServer

    %% Runtime → Modules
    HTTPServer -->|in-process| CaikitNLP
    gRPCServer -->|in-process| CaikitNLP

    %% Egress: Modules → External
    TextGenTGIS -->|"gRPC<br/>TLS optional<br/>mTLS optional<br/>ca_cert_file / client_cert"| TGIS
    PeftTGIS -->|"gRPC<br/>TLS optional<br/>mTLS optional"| TGIS
    Embed -.->|"HTTPS/443<br/>TLS 1.2+<br/>API token (optional)<br/>allow_downloads=false"| HFHub

    %% Local storage
    TextGen -->|"File I/O"| ModelMount
    Peft -->|"File I/O<br/>Save prompt vectors"| ModelMount
    Embed -->|"File I/O<br/>Load model"| ModelMount

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class HTTPServer,gRPCServer,TextGen,TextGenTGIS,Embed,Peft,PeftTGIS,SeqClass,SpanClass application
    class TGIS,HFHub externalservice
    class ModelMount storage
