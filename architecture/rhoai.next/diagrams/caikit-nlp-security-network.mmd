graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Trust Boundary)"]
        Ingress["KServe InferenceService /<br/>Gateway API / kube-rbac-proxy<br/>TLS Termination<br/>AuthN/AuthZ: Platform-managed"]
    end

    subgraph InCluster["IN-CLUSTER (Caikit Runtime Pod)"]
        direction TB

        subgraph RuntimePod["Namespace: {user-namespace}"]
            Runtime["Caikit Runtime<br/>User: caikit (UID 1001)<br/>Image: ubi9/ubi-minimal"]

            subgraph Endpoints["Exposed Endpoints"]
                HTTP["HTTP API<br/>8080/TCP ClusterIP<br/>Plaintext"]
                GRPC["gRPC API<br/>8085/TCP ClusterIP<br/>Plaintext"]
            end

            subgraph Modules["caikit-nlp Modules (in-process)"]
                LocalMods["TextGeneration<br/>EmbeddingModule<br/>CrossEncoderModule<br/>PeftPromptTuning<br/>SequenceClassification"]
                RemoteMods["TextGenerationTGIS<br/>PeftPromptTuningTGIS<br/>TGISAutoFinder"]
            end

            Runtime --- HTTP
            Runtime --- GRPC
            Runtime --- Modules
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        TGIS["TGIS Server<br/>gRPC (default 8033/TCP)<br/>TLS (configurable)<br/>mTLS (optional)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth (optional)"]
    end

    subgraph Training["MULTI-GPU TRAINING (optional)"]
        Torchrun["PyTorch Distributed<br/>torchrun elastic_launch<br/>29550/TCP<br/>Plaintext / No auth"]
    end

    %% Flows
    Client -->|"HTTPS<br/>TLS (platform)<br/>Bearer / OAuth"| Ingress
    Ingress -->|"HTTP :8080 or gRPC :8085<br/>Plaintext (in-cluster)<br/>Auth: delegated"| Runtime
    RemoteMods -->|"gRPC (default :8033)<br/>TLS (optional, ca_cert_file)<br/>mTLS (optional, client_cert + key)"| TGIS
    Runtime -->|"HTTPS :443<br/>TLS 1.2+<br/>Token (optional)"| HFHub
    LocalMods -.->|"TCP :29550<br/>Plaintext<br/>No auth"| Torchrun

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef incluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef training fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Ingress ingress
    class Runtime,HTTP,GRPC,LocalMods,RemoteMods incluster
    class TGIS internalservice
    class HFHub externalservice
    class Torchrun training
