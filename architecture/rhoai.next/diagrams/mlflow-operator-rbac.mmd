graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["mlflow-operator-<br/>controller-manager<br/>(operator SA)"]
        SA_MLflow["mlflow-sa<br/>(MLflow server SA)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding, Helm)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_NS["namespace-rolebinding<br/>(RoleBinding)"]
        RB_Leader["leader-election-<br/>rolebinding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_MLflow["mlflow<br/>(ClusterRole, Helm)"]
        CR_View["mlflow-view<br/>(aggregate ClusterRole)"]
        CR_Edit["mlflow-edit<br/>(aggregate ClusterRole)"]
        CR_Integration["mlflow-integration<br/>(ClusterRole)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Manager["manager-role<br/>(Role)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph OperatorCRResources["Operator ClusterRole Resources"]
        MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        Secrets_CR["core<br/>secrets<br/>(mlflow-artifact-connection)"]
        Namespaces_CR["core<br/>namespaces"]
        MLflowConfigs_CR["mlflow.kubeflow.org<br/>mlflowconfigs"]
        ConsoleLinks["console.openshift.io<br/>consolelinks"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        RBAC_Resources["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings"]
    end

    subgraph OperatorNSResources["Operator Namespace Role Resources"]
        CoreResources["core<br/>configmaps, secrets,<br/>serviceaccounts, services,<br/>persistentvolumeclaims"]
        Deployments["apps<br/>deployments"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        ConfigMaps_LE["core<br/>configmaps"]
        Leases["coordination.k8s.io<br/>leases"]
        Events["core<br/>events"]
    end

    subgraph MLflowServerResources["MLflow Server Resources"]
        Namespaces_ML["core<br/>namespaces"]
        Secrets_ML["core<br/>secrets<br/>(mlflow-artifact-connection)"]
        MLflowConfigs_ML["mlflow.kubeflow.org<br/>mlflowconfigs"]
    end

    subgraph AggregateResources["Aggregate Role Resources (User-facing)"]
        ViewResources["mlflow.opendatahub.io: mlflows<br/>mlflow.kubeflow.org: mlflowconfigs,<br/>datasets, experiments,<br/>registeredmodels, etc."]
        EditResources["All view resources +<br/>create, update, delete<br/>+ gatewaysecrets/use,<br/>gatewayendpoints/use"]
        IntegrationResources["mlflow.kubeflow.org:<br/>datasets, experiments,<br/>registeredmodels,<br/>gatewayendpoints"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    SA_Operator -->|"bound via"| RB_NS
    SA_Operator -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    RB_NS -->|"grants"| R_Manager
    RB_Leader -->|"grants"| R_Leader

    %% MLflow SA bindings
    SA_MLflow -->|"bound via"| CRB_MLflow
    CRB_MLflow -->|"grants"| CR_MLflow

    %% Operator ClusterRole → resources
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| MLflows
    CR_Manager -->|"get,list,watch"| Secrets_CR
    CR_Manager -->|"get,list,watch"| Namespaces_CR
    CR_Manager -->|"get,list,watch"| MLflowConfigs_CR
    CR_Manager -->|"full CRUD"| ConsoleLinks
    CR_Manager -->|"full CRUD"| HTTPRoutes
    CR_Manager -->|"full CRUD"| RBAC_Resources

    %% Operator namespace Role → resources
    R_Manager -->|"full CRUD"| CoreResources
    R_Manager -->|"full CRUD"| Deployments
    R_Manager -->|"full CRUD"| NetworkPolicies
    R_Manager -->|"full CRUD"| ServiceMonitors

    %% Leader election
    R_Leader -->|"full CRUD"| ConfigMaps_LE
    R_Leader -->|"full CRUD"| Leases
    R_Leader -->|"create,patch"| Events

    %% MLflow server → resources
    CR_MLflow -->|"get,list,watch"| Namespaces_ML
    CR_MLflow -->|"get,list,watch"| Secrets_ML
    CR_MLflow -->|"get,list,watch"| MLflowConfigs_ML

    %% Aggregate roles → resources
    CR_View -->|"get,list,watch"| ViewResources
    CR_Edit -->|"full CRUD"| EditResources
    CR_Integration -->|"get,list,<br/>create,update"| IntegrationResources

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_MLflow fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_MLflow fill:#f5a623,color:#fff
    style CR_View fill:#e8a0f5,color:#333
    style CR_Edit fill:#e8a0f5,color:#333
    style CR_Integration fill:#e8a0f5,color:#333
    style R_Manager fill:#f5c623,color:#333
    style R_Leader fill:#f5c623,color:#333
    style CRB_Manager fill:#b8d4e8,color:#333
    style CRB_MLflow fill:#b8d4e8,color:#333
    style RB_NS fill:#b8d4e8,color:#333
    style RB_Leader fill:#b8d4e8,color:#333
    style MLflows fill:#7ed321,color:#fff
    style Secrets_CR fill:#7ed321,color:#fff
    style Namespaces_CR fill:#7ed321,color:#fff
    style MLflowConfigs_CR fill:#7ed321,color:#fff
    style ConsoleLinks fill:#7ed321,color:#fff
    style HTTPRoutes fill:#7ed321,color:#fff
    style RBAC_Resources fill:#7ed321,color:#fff
    style CoreResources fill:#a8e86c,color:#333
    style Deployments fill:#a8e86c,color:#333
    style NetworkPolicies fill:#a8e86c,color:#333
    style ServiceMonitors fill:#a8e86c,color:#333
    style ConfigMaps_LE fill:#c8e8a0,color:#333
    style Leases fill:#c8e8a0,color:#333
    style Events fill:#c8e8a0,color:#333
    style Namespaces_ML fill:#8ed3a1,color:#333
    style Secrets_ML fill:#8ed3a1,color:#333
    style MLflowConfigs_ML fill:#8ed3a1,color:#333
    style ViewResources fill:#d8b0f5,color:#333
    style EditResources fill:#d8b0f5,color:#333
    style IntegrationResources fill:#d8b0f5,color:#333
