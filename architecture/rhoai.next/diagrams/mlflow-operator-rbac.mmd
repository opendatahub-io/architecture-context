graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op["mlflow-operator-<br/>controller-manager"]
        SA_MLflow["mlflow-sa<br/>(target namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_NS["namespace-rolebinding<br/>(RoleBinding, target ns)"]
        CRB_Leader["leader-election-rolebinding<br/>(RoleBinding, target ns)"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding, Helm)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_NSRole["manager-role<br/>(Role, namespace-scoped)"]
        CR_Leader["leader-election-role<br/>(Role)"]
        CR_MLflow["mlflow<br/>(ClusterRole, Helm)"]
    end

    subgraph AggregateRoles["Aggregate Cluster Roles"]
        CR_View["mlflow-view<br/>(aggregate)"]
        CR_Edit["mlflow-edit<br/>(aggregate)"]
        CR_Integration["mlflow-integration"]
    end

    subgraph APIResources_Cluster["Cluster-Scoped API Resources"]
        MLflows["mlflow.opendatahub.io<br/>mlflows<br/>mlflows/status<br/>mlflows/finalizers"]
        MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
        ConsoleLinks["console.openshift.io<br/>consolelinks"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        RBACRes["rbac.authorization.k8s.io<br/>clusterroles<br/>clusterrolebindings"]
        Namespaces["core<br/>namespaces"]
        Secrets_Global["core<br/>secrets<br/>(mlflow-artifact-connection)"]
    end

    subgraph APIResources_NS["Namespace-Scoped API Resources"]
        CoreRes["core<br/>configmaps, secrets,<br/>serviceaccounts, services, pvcs"]
        AppsRes["apps<br/>deployments"]
        NetRes["networking.k8s.io<br/>networkpolicies"]
        MonRes["monitoring.coreos.com<br/>servicemonitors"]
        LeaderRes["core: configmaps, events<br/>coordination.k8s.io: leases"]
    end

    subgraph PseudoResources["Pseudo-Resources (K8s Auth)"]
        Experiments["mlflow.kubeflow.org<br/>experiments"]
        Datasets["mlflow.kubeflow.org<br/>datasets"]
        RegisteredModels["mlflow.kubeflow.org<br/>registeredmodels"]
        GatewaySecrets["mlflow.kubeflow.org<br/>gatewaysecrets"]
        GatewayEndpoints["mlflow.kubeflow.org<br/>gatewayendpoints"]
        GatewayModelDefs["mlflow.kubeflow.org<br/>gatewaymodeldefinitions"]
    end

    %% Operator SA bindings
    SA_Op -->|"bound via"| CRB_Manager
    SA_Op -->|"bound via"| CRB_NS
    SA_Op -->|"bound via"| CRB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_NS -->|"grants"| CR_NSRole
    CRB_Leader -->|"grants"| CR_Leader

    %% MLflow SA bindings
    SA_MLflow -->|"bound via"| CRB_MLflow
    CRB_MLflow -->|"grants"| CR_MLflow

    %% ClusterRole permissions
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| MLflows
    CR_Manager -->|"get,list,watch"| MLflowConfigs
    CR_Manager -->|"get,list,watch"| Namespaces
    CR_Manager -->|"get,list,watch"| Secrets_Global
    CR_Manager -->|"full CRUD"| ConsoleLinks
    CR_Manager -->|"full CRUD"| HTTPRoutes
    CR_Manager -->|"full CRUD"| RBACRes

    %% Namespace Role permissions
    CR_NSRole -->|"full CRUD"| CoreRes
    CR_NSRole -->|"full CRUD"| AppsRes
    CR_NSRole -->|"full CRUD"| NetRes
    CR_NSRole -->|"full CRUD"| MonRes

    %% Leader election
    CR_Leader -->|"full CRUD"| LeaderRes

    %% MLflow server permissions
    CR_MLflow -->|"get,list,watch"| Namespaces
    CR_MLflow -->|"get,list,watch"| Secrets_Global
    CR_MLflow -->|"get,list,watch"| MLflowConfigs

    %% Aggregate roles (for user access)
    CR_View -->|"get,list,watch"| MLflows
    CR_View -->|"get,list"| Experiments
    CR_View -->|"get,list"| Datasets
    CR_View -->|"get,list"| RegisteredModels

    CR_Edit -->|"full CRUD"| MLflows
    CR_Edit -->|"full CRUD"| Experiments
    CR_Edit -->|"full CRUD"| Datasets
    CR_Edit -->|"full CRUD"| RegisteredModels
    CR_Edit -->|"full CRUD"| GatewaySecrets
    CR_Edit -->|"full CRUD"| GatewayEndpoints
    CR_Edit -->|"full CRUD"| GatewayModelDefs

    CR_Integration -->|"get,list,<br/>create,update"| Experiments
    CR_Integration -->|"get,list,<br/>create,update"| Datasets
    CR_Integration -->|"get,list,<br/>create,update"| RegisteredModels
    CR_Integration -->|"get,list +<br/>use (create)"| GatewayEndpoints

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,color:#fff
    style SA_MLflow fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_NSRole fill:#f5a623,stroke:#333,color:#fff
    style CR_Leader fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#e8d44d,stroke:#333,color:#333
    style CR_Edit fill:#e8d44d,stroke:#333,color:#333
    style CR_Integration fill:#e8d44d,stroke:#333,color:#333
    style MLflows fill:#7ed321,stroke:#333,color:#fff
    style MLflowConfigs fill:#7ed321,stroke:#333,color:#fff
    style ConsoleLinks fill:#7ed321,stroke:#333,color:#fff
    style HTTPRoutes fill:#7ed321,stroke:#333,color:#fff
    style RBACRes fill:#7ed321,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style Secrets_Global fill:#7ed321,stroke:#333,color:#fff
    style CoreRes fill:#7ed321,stroke:#333,color:#fff
    style AppsRes fill:#7ed321,stroke:#333,color:#fff
    style NetRes fill:#7ed321,stroke:#333,color:#fff
    style MonRes fill:#7ed321,stroke:#333,color:#fff
    style LeaderRes fill:#7ed321,stroke:#333,color:#fff
    style Experiments fill:#d4a6e8,stroke:#333,color:#333
    style Datasets fill:#d4a6e8,stroke:#333,color:#333
    style RegisteredModels fill:#d4a6e8,stroke:#333,color:#333
    style GatewaySecrets fill:#d4a6e8,stroke:#333,color:#333
    style GatewayEndpoints fill:#d4a6e8,stroke:#333,color:#333
    style GatewayModelDefs fill:#d4a6e8,stroke:#333,color:#333
