    style CR_MetricsAuth fill:#e8c14a,color:#333
    style CR_MetricsReader fill:#e8c14a,color:#333
    style R_Manager fill:#f5a623,color:#fff
    style R_LeaderElection fill:#f5a623,color:#fff
    style OR_MLflows fill:#7ed321,color:#fff
    style OR_Namespaces fill:#7ed321,color:#fff
    style OR_Secrets fill:#7ed321,color:#fff
    style OR_MLflowConfigs fill:#7ed321,color:#fff
    style OR_ConsoleLinks fill:#7ed321,color:#fff
