graph TD
    subgraph "Operator Service Account"
        SA_Op["mlflow-operator-controller-manager<br/>ServiceAccount"]
    end

    subgraph "MLflow Workload Service Account"
        SA_MLflow["mlflow-sa<br/>ServiceAccount"]
    end

    subgraph "User-Facing Aggregate Roles"
        ViewRole["mlflow-view<br/>(aggregate ClusterRole)"]
        EditRole["mlflow-edit<br/>(aggregate ClusterRole)"]
        IntegrationRole["mlflow-integration<br/>(ClusterRole)"]
    end

    subgraph "Operator ClusterRole Bindings"
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph "Operator Role Bindings (namespace-scoped)"
        RB_Manager["manager-rolebinding<br/>(RoleBinding)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding)"]
    end

    subgraph "MLflow Workload Bindings"
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding)<br/>Helm-rendered"]
    end

    subgraph "Operator ClusterRole Permissions"
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Metrics["metrics-auth-role<br/>(ClusterRole)"]
        CR_Reader["metrics-reader<br/>(ClusterRole)"]
    end

    subgraph "Operator Role Permissions (namespace-scoped)"
        R_Manager["manager-role<br/>(Role)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph "MLflow Workload Role"
        CR_MLflow["mlflow<br/>(ClusterRole)<br/>Helm-rendered"]
    end

    subgraph "Cluster-scoped API Resources"
        MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        ConsoleLinks["console.openshift.io<br/>consolelinks"]
        ClusterRBAC["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings"]
        Namespaces["core<br/>namespaces"]
        ArtifactSecret["core<br/>secrets<br/>(mlflow-artifact-connection)"]
        MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        MetricsEndpoint["/metrics<br/>(non-resource URL)"]
    end

    subgraph "Namespace-scoped API Resources"
        CoreResources["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services"]
        Deployments["apps<br/>deployments"]
        NetPolicies["networking.k8s.io<br/>networkpolicies"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
        LeaderResources["core, coordination.k8s.io<br/>configmaps, leases, events"]
    end

    subgraph "User-Facing API Resources"
        UserMLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        UserKubeflow["mlflow.kubeflow.org<br/>mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewayendpoints,<br/>gatewaymodeldefinitions,<br/>gatewaysecrets"]
    end

    %% Operator bindings
    SA_Op -->|bound via| CRB_Manager
    SA_Op -->|bound via| CRB_Metrics
    SA_Op -->|bound via| RB_Manager
    SA_Op -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_Metrics
    RB_Manager -->|grants| R_Manager
    RB_Leader -->|grants| R_Leader

    %% Operator cluster permissions
    CR_Manager -->|"full CRUD"| MLflows
    CR_Manager -->|"full CRUD"| HTTPRoutes
    CR_Manager -->|"full CRUD"| ConsoleLinks
    CR_Manager -->|"full CRUD"| ClusterRBAC
    CR_Manager -->|"get, list, watch"| Namespaces
    CR_Manager -->|"get, list, watch"| ArtifactSecret
    CR_Manager -->|"get, list, watch"| MLflowConfigs

    %% Operator namespace permissions
    R_Manager -->|"full CRUD"| CoreResources
    R_Manager -->|"full CRUD"| Deployments
    R_Manager -->|"full CRUD"| NetPolicies
    R_Manager -->|"full CRUD"| ServiceMonitors

    %% Metrics auth
    CR_Metrics -->|"create"| TokenReviews
    CR_Metrics -->|"create"| SAR
    CR_Reader -->|"get"| MetricsEndpoint

    %% Leader election
    R_Leader -->|"full CRUD"| LeaderResources

    %% MLflow workload bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow
    CR_MLflow -->|"get, list, watch"| Namespaces
    CR_MLflow -->|"get, list, watch"| ArtifactSecret
    CR_MLflow -->|"get, list, watch"| MLflowConfigs

    %% User-facing roles
    ViewRole -->|"get, list, watch"| UserMLflows
    ViewRole -->|"get, list"| UserKubeflow
    EditRole -->|"full CRUD"| UserMLflows
    EditRole -->|"full CRUD"| UserKubeflow
    IntegrationRole -->|"get, list, create, update"| UserKubeflow

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,color:#fff
    style SA_MLflow fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Metrics fill:#f5a623,stroke:#333,color:#fff
    style CR_Reader fill:#f5a623,stroke:#333,color:#fff
    style R_Manager fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style ViewRole fill:#9b59b6,stroke:#333,color:#fff
    style EditRole fill:#9b59b6,stroke:#333,color:#fff
    style IntegrationRole fill:#9b59b6,stroke:#333,color:#fff
    style MLflows fill:#7ed321,stroke:#333,color:#fff
    style HTTPRoutes fill:#7ed321,stroke:#333,color:#fff
    style ConsoleLinks fill:#7ed321,stroke:#333,color:#fff
    style ClusterRBAC fill:#7ed321,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style ArtifactSecret fill:#7ed321,stroke:#333,color:#fff
    style MLflowConfigs fill:#7ed321,stroke:#333,color:#fff
    style CoreResources fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style NetPolicies fill:#7ed321,stroke:#333,color:#fff
    style ServiceMonitors fill:#7ed321,stroke:#333,color:#fff
    style LeaderResources fill:#7ed321,stroke:#333,color:#fff
    style TokenReviews fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style MetricsEndpoint fill:#7ed321,stroke:#333,color:#fff
    style UserMLflows fill:#7ed321,stroke:#333,color:#fff
    style UserKubeflow fill:#7ed321,stroke:#333,color:#fff
