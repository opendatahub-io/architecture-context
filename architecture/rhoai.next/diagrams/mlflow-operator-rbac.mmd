graph TD
    subgraph "Service Accounts"
        SA_Operator["mlflow-operator-<br/>controller-manager"]
        SA_MLflow["mlflow-sa<br/>(Helm-rendered)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding, Helm)"]
    end

    subgraph "Role Bindings (Namespace)"
        RB_NS["namespace-rolebinding"]
        RB_Leader["leader-election-rolebinding"]
    end

    subgraph "ClusterRoles"
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_MLflow["mlflow<br/>(ClusterRole, Helm)"]
        CR_View["mlflow-view<br/>(aggregate)"]
        CR_Edit["mlflow-edit<br/>(aggregate)"]
        CR_Integration["mlflow-integration"]
    end

    subgraph "Namespace Roles"
        R_NS["manager-role<br/>(Role)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph "Operator ClusterRole Resources"
        OR1["mlflow.opendatahub.io<br/>mlflows<br/>get,list,watch,create,<br/>update,patch,delete"]
        OR2["mlflow.opendatahub.io<br/>mlflows/status<br/>get,update,patch"]
        OR3["mlflow.opendatahub.io<br/>mlflows/finalizers<br/>update"]
        OR4["core / secrets<br/>(mlflow-artifact-connection)<br/>get,list,watch"]
        OR5["core / namespaces<br/>get,list,watch"]
        OR6["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
        OR7["console.openshift.io<br/>consolelinks<br/>full CRUD"]
        OR8["gateway.networking.k8s.io<br/>httproutes<br/>full CRUD"]
        OR9["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings<br/>full CRUD"]
    end

    subgraph "Namespace Role Resources"
        NR1["core / configmaps,secrets,<br/>serviceaccounts,services,pvcs<br/>full CRUD"]
        NR2["apps / deployments<br/>full CRUD"]
        NR3["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
        NR4["monitoring.coreos.com<br/>servicemonitors<br/>full CRUD"]
    end

    subgraph "Leader Election Resources"
        LR1["core / configmaps<br/>full CRUD"]
        LR2["coordination.k8s.io / leases<br/>full CRUD"]
        LR3["core / events<br/>create,patch"]
    end

    subgraph "MLflow Server Resources"
        MR1["core / namespaces<br/>get,list,watch"]
        MR2["core / secrets<br/>(mlflow-artifact-connection)<br/>get,list,watch"]
        MR3["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
    end

    subgraph "Aggregate - View Resources"
        VR1["mlflow.opendatahub.io<br/>mlflows, mlflows/status<br/>get,list,watch"]
        VR2["mlflow.kubeflow.org<br/>mlflowconfigs,datasets,<br/>experiments,registeredmodels<br/>get,list"]
    end

    subgraph "Aggregate - Edit Resources"
        ER1["mlflow.opendatahub.io<br/>mlflows<br/>full CRUD + deletecollection"]
        ER2["mlflow.kubeflow.org<br/>mlflowconfigs,datasets,<br/>experiments,registeredmodels,<br/>gatewaysecrets,gatewayendpoints<br/>full CRUD"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    SA_Operator -->|"bound via"| RB_NS
    RB_NS -->|"grants"| R_NS
    SA_Operator -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| R_Leader

    %% MLflow SA bindings
    SA_MLflow -->|"bound via"| CRB_MLflow
    CRB_MLflow -->|"grants"| CR_MLflow

    %% ClusterRole to resources
    CR_Manager -->|"permits"| OR1
    CR_Manager -->|"permits"| OR2
    CR_Manager -->|"permits"| OR3
    CR_Manager -->|"permits"| OR4
    CR_Manager -->|"permits"| OR5
    CR_Manager -->|"permits"| OR6
    CR_Manager -->|"permits"| OR7
    CR_Manager -->|"permits"| OR8
    CR_Manager -->|"permits"| OR9

    %% Namespace role to resources
    R_NS -->|"permits"| NR1
    R_NS -->|"permits"| NR2
    R_NS -->|"permits"| NR3
    R_NS -->|"permits"| NR4

    %% Leader election
    R_Leader -->|"permits"| LR1
    R_Leader -->|"permits"| LR2
    R_Leader -->|"permits"| LR3

    %% MLflow server role
    CR_MLflow -->|"permits"| MR1
    CR_MLflow -->|"permits"| MR2
    CR_MLflow -->|"permits"| MR3

    %% Aggregate roles
    CR_View -->|"aggregates"| VR1
    CR_View -->|"aggregates"| VR2
    CR_Edit -->|"aggregates"| ER1
    CR_Edit -->|"aggregates"| ER2

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_MLflow fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#f5a623,stroke:#333,color:#fff
    style CR_Edit fill:#f5a623,stroke:#333,color:#fff
    style CR_Integration fill:#f5a623,stroke:#333,color:#fff
    style R_NS fill:#e8a623,stroke:#333,color:#fff
    style R_Leader fill:#e8a623,stroke:#333,color:#fff
    style CRB_Manager fill:#b8e986,stroke:#333
    style CRB_MLflow fill:#b8e986,stroke:#333
    style RB_NS fill:#b8e986,stroke:#333
    style RB_Leader fill:#b8e986,stroke:#333
