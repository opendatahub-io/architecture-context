graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator)"]
        SA_MLflow["mlflow-sa<br/>(MLflow server)"]
        SA_GC["mlflow-gc-sa<br/>(garbage collection)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-wide)"]
        CRB_NS["namespace-rolebinding<br/>(target namespace)"]
        CRB_MLflow["mlflow<br/>(cluster-wide)"]
        CRB_GC["mlflow-gc<br/>(cluster-wide)"]
        CRB_Leader["leader-election-rolebinding<br/>(target namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_NS["manager-role<br/>(namespace Role)"]
        CR_MLflow["mlflow<br/>(shared ClusterRole)"]
        CR_GC["mlflow-gc<br/>(ClusterRole)"]
        CR_Leader["leader-election-role"]
    end

    subgraph AggregateRoles["User-Facing Aggregate Roles"]
        CR_View["mlflow-view<br/>(read-only)"]
        CR_Edit["mlflow-edit<br/>(full CRUD)"]
        CR_Integration["mlflow-integration<br/>(minimal service role)"]
    end

    subgraph OperatorResources["Operator ClusterRole Resources"]
        R_MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers<br/>→ full CRUD"]
        R_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>→ full CRUD"]
        R_ConsoleLinks["console.openshift.io<br/>consolelinks<br/>→ full CRUD"]
        R_MLflowConfigs_RO["mlflow.kubeflow.org<br/>mlflowconfigs<br/>→ get, list, watch"]
        R_Namespaces["core: namespaces<br/>→ get, list, watch"]
        R_Secrets_Named["core: secrets<br/>(mlflow-artifact-connection)<br/>→ get, list, watch"]
        R_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>→ create; CRUD (named)"]
    end

    subgraph NSResources["Namespace Role Resources"]
        R_Core["core: configmaps, pvcs,<br/>secrets, serviceaccounts,<br/>services → full CRUD"]
        R_Pods["core: pods<br/>→ get, list, watch"]
        R_Deployments["apps: deployments<br/>→ full CRUD"]
        R_Jobs["batch: jobs, cronjobs<br/>→ full CRUD"]
        R_NetPol["networking.k8s.io:<br/>networkpolicies → full CRUD"]
        R_ServiceMon["monitoring.coreos.com:<br/>servicemonitors → full CRUD"]
    end

    subgraph ServerResources["MLflow Server ClusterRole Resources"]
        R_NS_Server["core: namespaces<br/>→ get, list, watch"]
        R_Secrets_Server["core: secrets<br/>(mlflow-artifact-connection)<br/>→ get, list, watch"]
        R_Configs_Server["mlflow.kubeflow.org:<br/>mlflowconfigs<br/>→ get, list, watch"]
    end

    subgraph GCResources["GC ClusterRole Resources"]
        R_Experiments["mlflow.kubeflow.org:<br/>experiments<br/>→ get, list, update"]
    end

    subgraph AggregateResources["Aggregate Role Resources"]
        R_ViewRes["mlflow.opendatahub.io +<br/>mlflow.kubeflow.org<br/>→ get, list, watch"]
        R_EditRes["mlflow.opendatahub.io +<br/>mlflow.kubeflow.org<br/>→ full CRUD"]
        R_IntegRes["mlflow.kubeflow.org:<br/>datasets, experiments,<br/>registeredmodels,<br/>gatewayendpoints<br/>→ get, list, create, update"]
    end

    %% Bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_NS
    SA_CM -->|bound via| CRB_Leader
    SA_MLflow -->|bound via| CRB_MLflow
    SA_GC -->|bound via| CRB_GC

    CRB_Manager -->|grants| CR_Manager
    CRB_NS -->|grants| CR_NS
    CRB_Leader -->|grants| CR_Leader
    CRB_MLflow -->|grants| CR_MLflow
    CRB_GC -->|grants| CR_GC

    %% Role → Resources
    CR_Manager --> R_MLflows
    CR_Manager --> R_HTTPRoutes
    CR_Manager --> R_ConsoleLinks
    CR_Manager --> R_MLflowConfigs_RO
    CR_Manager --> R_Namespaces
    CR_Manager --> R_Secrets_Named
    CR_Manager --> R_RBAC

    CR_NS --> R_Core
    CR_NS --> R_Pods
    CR_NS --> R_Deployments
    CR_NS --> R_Jobs
    CR_NS --> R_NetPol
    CR_NS --> R_ServiceMon

    CR_MLflow --> R_NS_Server
    CR_MLflow --> R_Secrets_Server
    CR_MLflow --> R_Configs_Server

    CR_GC --> R_Experiments

    CR_View --> R_ViewRes
    CR_Edit --> R_EditRes
    CR_Integration --> R_IntegRes

