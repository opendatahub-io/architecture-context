    style Res_Namespaces fill:#7ed321,color:#fff
    style Res_Secrets_Cluster fill:#7ed321,color:#fff
    style Res_ConsoleLinks fill:#7ed321,color:#fff
    style Res_HTTPRoutes fill:#7ed321,color:#fff
    style Res_MLflowConfigs_Watch fill:#7ed321,color:#fff
    style Res_RBAC fill:#7ed321,color:#fff
    style Res_CoreNS fill:#7ed321,color:#fff
    style Res_Pods fill:#7ed321,color:#fff
