graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_MLflow["mlflow-sa<br/>(target namespace)"]
        SA_GC["mlflow-gc-sa<br/>(target namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding, chart)"]
        CRB_GC["mlflow-gc<br/>(ClusterRoleBinding, chart)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Manager["manager-rolebinding<br/>(RoleBinding, target ns)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_MLflow["mlflow<br/>(shared server ClusterRole)"]
        CR_GC["mlflow-gc<br/>(GC ClusterRole)"]
    end

    subgraph NamespaceRoles["Roles (namespace-scoped)"]
        R_Manager["manager-role<br/>(Role, target ns)"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles (for users)"]
        CR_View["mlflow-view<br/>(aggregate: view)"]
        CR_Edit["mlflow-edit<br/>(aggregate: edit)"]
        CR_Integration["mlflow-integration<br/>(cross-component)"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| RB_Manager
    SA_MLflow -->|"bound via"| CRB_MLflow
    SA_GC -->|"bound via"| CRB_GC

    CRB_Manager -->|"grants"| CR_Manager
    CRB_MLflow -->|"grants"| CR_MLflow
    CRB_GC -->|"grants"| CR_GC
    RB_Manager -->|"grants"| R_Manager

    %% Operator ClusterRole Resources
    subgraph ManagerClusterResources["manager-role ClusterRole Resources"]
        Res_MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers<br/>full CRUD"]
        Res_Namespaces["core<br/>namespaces<br/>get, list, watch"]
        Res_Secrets_Cluster["core<br/>secrets [mlflow-artifact-connection]<br/>get, list, watch"]
        Res_ConsoleLinks["console.openshift.io<br/>consolelinks<br/>full CRUD"]
        Res_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>full CRUD"]
        Res_MLflowConfigs_Watch["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get, list, watch"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>create (open), CRUD (mlflow, mlflow-gc)"]
    end

    CR_Manager -->|"permits"| Res_MLflows
    CR_Manager -->|"permits"| Res_Namespaces
    CR_Manager -->|"permits"| Res_Secrets_Cluster
    CR_Manager -->|"permits"| Res_ConsoleLinks
    CR_Manager -->|"permits"| Res_HTTPRoutes
    CR_Manager -->|"permits"| Res_MLflowConfigs_Watch
    CR_Manager -->|"permits"| Res_RBAC

    %% Operator namespace Role Resources
    subgraph ManagerNSResources["manager-role Role Resources (namespace-scoped)"]
        Res_CoreNS["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>full CRUD"]
        Res_Pods["core<br/>pods<br/>get, list, watch"]
        Res_Deployments["apps<br/>deployments<br/>full CRUD"]
        Res_Jobs["batch<br/>jobs, cronjobs<br/>full CRUD"]
        Res_NetPol["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
        Res_SvcMon["monitoring.coreos.com<br/>servicemonitors<br/>full CRUD"]
    end

    R_Manager -->|"permits"| Res_CoreNS
    R_Manager -->|"permits"| Res_Pods
    R_Manager -->|"permits"| Res_Deployments
    R_Manager -->|"permits"| Res_Jobs
    R_Manager -->|"permits"| Res_NetPol
    R_Manager -->|"permits"| Res_SvcMon

    %% MLflow Server Resources
    subgraph MLflowServerResources["mlflow ClusterRole Resources"]
        Res_NS_Server["core<br/>namespaces<br/>get, list, watch"]
        Res_Secrets_Server["core<br/>secrets [mlflow-artifact-connection]<br/>get, list, watch"]
        Res_Configs_Server["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get, list, watch"]
    end

    CR_MLflow -->|"permits"| Res_NS_Server
    CR_MLflow -->|"permits"| Res_Secrets_Server
    CR_MLflow -->|"permits"| Res_Configs_Server

    %% GC Resources
    subgraph GCResources["mlflow-gc ClusterRole Resources"]
        Res_Experiments["mlflow.kubeflow.org<br/>experiments<br/>get, list, update"]
    end

    CR_GC -->|"permits"| Res_Experiments

    %% Aggregate Role Resources
    subgraph ViewResources["mlflow-view Resources"]
        Res_View["mlflow.opendatahub.io: mlflows (read)<br/>mlflow.kubeflow.org: mlflowconfigs,<br/>datasets, experiments,<br/>registeredmodels (read)"]
    end

    subgraph EditResources["mlflow-edit Resources"]
        Res_Edit["mlflow.opendatahub.io: mlflows (CRUD)<br/>mlflow.kubeflow.org: mlflowconfigs,<br/>datasets, experiments,<br/>registeredmodels, gatewaysecrets,<br/>gatewayendpoints (CRUD + use)"]
    end

    subgraph IntegrationResources["mlflow-integration Resources"]
        Res_Integ["mlflow.kubeflow.org:<br/>datasets, experiments,<br/>registeredmodels (get,list,create,update)<br/>gatewayendpoints (get,list)<br/>gatewayendpoints/use (create)"]
    end

    CR_View -->|"permits"| Res_View
    CR_Edit -->|"permits"| Res_Edit
    CR_Integration -->|"permits"| Res_Integ

