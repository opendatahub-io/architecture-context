graph TD
    subgraph OperatorSA["Operator Service Account"]
        SA_CM["controller-manager<br/>(redhat-ods-applications)"]
    end

    subgraph MLflowSA["MLflow Server Service Account"]
        SA_MLflow["mlflow-sa<br/>(redhat-ods-applications)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_MLflow["mlflow-rolebinding<br/>(cluster-scoped, Helm-rendered)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_NSManager["manager-rolebinding<br/>(redhat-ods-applications)"]
        RB_Leader["leader-election-rolebinding<br/>(redhat-ods-applications)"]
    end

    subgraph OperatorClusterRole["ClusterRole: manager-role"]
        CR_MLflows["mlflow.opendatahub.io<br/>mlflows<br/>get,list,watch,create,<br/>update,patch,delete"]
        CR_MLflowsStatus["mlflow.opendatahub.io<br/>mlflows/status<br/>get,patch,update"]
        CR_MLflowsFin["mlflow.opendatahub.io<br/>mlflows/finalizers<br/>update"]
        CR_NS["core<br/>namespaces<br/>get,list,watch"]
        CR_Secrets["core<br/>secrets [mlflow-artifact-connection]<br/>get,list,watch"]
        CR_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
        CR_ConsoleLinks["console.openshift.io<br/>consolelinks<br/>get,list,watch,create,<br/>update,patch,delete"]
        CR_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>get,list,watch,create,<br/>update,patch,delete"]
        CR_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>full CRUD"]
    end

    subgraph OperatorNSRole["Role: manager-role (namespace-scoped)"]
        NR_Core["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>full CRUD"]
        NR_Apps["apps<br/>deployments<br/>full CRUD"]
        NR_NetPol["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
        NR_Monitoring["monitoring.coreos.com<br/>servicemonitors<br/>full CRUD"]
    end

    subgraph MLflowClusterRole["ClusterRole: mlflow (Helm-rendered)"]
        MCR_NS["core<br/>namespaces<br/>get,list,watch"]
        MCR_Secrets["core<br/>secrets [mlflow-artifact-connection]<br/>get,list,watch"]
        MCR_Configs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles"]
        AGG_View["mlflow-view<br/>(aggregates to: view)<br/>mlflows, mlflowconfigs,<br/>datasets, experiments,<br/>registeredmodels<br/>get,list,watch"]
        AGG_Edit["mlflow-edit<br/>(aggregates to: edit, admin)<br/>mlflows, mlflowconfigs,<br/>datasets, experiments,<br/>registeredmodels,<br/>gatewaysecrets, etc.<br/>full CRUD"]
        AGG_Integration["mlflow-integration<br/>(for platform components)<br/>datasets, experiments,<br/>registeredmodels,<br/>gatewayendpoints<br/>get,list,create,update"]
    end

    subgraph MetricsRoles["Metrics Roles"]
        MR_Auth["metrics-auth-role<br/>tokenreviews, subjectaccessreviews<br/>create"]
        MR_Reader["metrics-reader<br/>/metrics (nonResourceURL)<br/>get"]
    end

    subgraph LeaderElection["Leader Election Role"]
        LE_Role["leader-election-role<br/>configmaps, leases, events<br/>full CRUD"]
    end

    %% Operator bindings
    SA_CM -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_MLflows
    CRB_Manager -->|grants| CR_MLflowsStatus
    CRB_Manager -->|grants| CR_MLflowsFin
    CRB_Manager -->|grants| CR_NS
    CRB_Manager -->|grants| CR_Secrets
    CRB_Manager -->|grants| CR_MLflowConfigs
    CRB_Manager -->|grants| CR_ConsoleLinks
    CRB_Manager -->|grants| CR_HTTPRoutes
    CRB_Manager -->|grants| CR_RBAC

    SA_CM -->|bound via| RB_NSManager
    RB_NSManager -->|grants| NR_Core
    RB_NSManager -->|grants| NR_Apps
    RB_NSManager -->|grants| NR_NetPol
    RB_NSManager -->|grants| NR_Monitoring

    SA_CM -->|bound via| RB_Leader
    RB_Leader -->|grants| LE_Role

    %% MLflow server bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| MCR_NS
    CRB_MLflow -->|grants| MCR_Secrets
    CRB_MLflow -->|grants| MCR_Configs

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_MLflow fill:#4a90e2,color:#fff
    style CRB_Manager fill:#9b59b6,color:#fff
    style CRB_MLflow fill:#9b59b6,color:#fff
    style RB_NSManager fill:#9b59b6,color:#fff
    style RB_Leader fill:#9b59b6,color:#fff
    style AGG_View fill:#27ae60,color:#fff
    style AGG_Edit fill:#e67e22,color:#fff
    style AGG_Integration fill:#2980b9,color:#fff
    style MR_Auth fill:#95a5a6,color:#fff
    style MR_Reader fill:#95a5a6,color:#fff
    style LE_Role fill:#95a5a6,color:#fff
