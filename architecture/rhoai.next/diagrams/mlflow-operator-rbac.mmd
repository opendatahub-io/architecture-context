graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(Operator SA)"]
        SA_MLflow["mlflow-sa<br/>(MLflow Server SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_MLflow["mlflow-rolebinding<br/>(Helm-rendered, cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (redhat-ods-applications)"]
        RB_Manager["manager-rolebinding<br/>(namespace-scoped)"]
        RB_LeaderElection["leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_MLflow["mlflow<br/>(Helm-rendered)"]
        CR_View["mlflow-view<br/>(aggregate → admin/edit/view)"]
        CR_Edit["mlflow-edit<br/>(aggregate → admin/edit)"]
        CR_Integration["mlflow-integration"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
    end

    subgraph Roles["Roles (redhat-ods-applications)"]
        R_Manager["manager-role<br/>(namespace Role)"]
        R_LeaderElection["leader-election-role"]
    end

    subgraph OperatorResources["Operator ClusterRole Resources"]
        OR_MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers"]
        OR_Namespaces["core<br/>namespaces"]
        OR_Secrets["core<br/>secrets (mlflow-artifact-connection)"]
        OR_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
        OR_ConsoleLinks["console.openshift.io<br/>consolelinks"]
        OR_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        OR_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings"]
    end

    subgraph NamespaceResources["Namespace Role Resources"]
        NR_Core["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services"]
        NR_Apps["apps<br/>deployments"]
        NR_NetPol["networking.k8s.io<br/>networkpolicies"]
        NR_Monitor["monitoring.coreos.com<br/>servicemonitors"]
    end

    subgraph MLflowServerResources["MLflow Server ClusterRole Resources"]
        MR_Namespaces["core<br/>namespaces"]
        MR_Secrets["core<br/>secrets (mlflow-artifact-connection)"]
        MR_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
    end

    subgraph AggregateResources["Aggregate Role Resources (pseudo-resources)"]
        AR_View["mlflow.opendatahub.io<br/>mlflows, mlflows/status<br/>mlflow.kubeflow.org<br/>mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewayendpoints,<br/>gatewaymodeldefinitions"]
        AR_Edit["mlflow.opendatahub.io<br/>mlflows, mlflows/finalizers<br/>mlflow.kubeflow.org<br/>mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewaysecrets, gatewayendpoints,<br/>gatewaymodeldefinitions + /use"]
    end

    %% Operator SA bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Manager
    SA_Controller -->|bound via| RB_LeaderElection

    CRB_Manager -->|grants| CR_Manager
    RB_Manager -->|grants| R_Manager
    RB_LeaderElection -->|grants| R_LeaderElection

    %% MLflow Server SA bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow

    %% ClusterRole → Resources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| OR_MLflows
    CR_Manager -->|"get,list,watch"| OR_Namespaces
    CR_Manager -->|"get,list,watch"| OR_Secrets
    CR_Manager -->|"get,list,watch"| OR_MLflowConfigs
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| OR_ConsoleLinks
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| OR_HTTPRoutes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| OR_RBAC

    %% Namespace Role → Resources
    R_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| NR_Core
    R_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| NR_Apps
    R_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| NR_NetPol
    R_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| NR_Monitor

    %% MLflow Server → Resources
    CR_MLflow -->|"get,list,watch"| MR_Namespaces
    CR_MLflow -->|"get,list,watch"| MR_Secrets
    CR_MLflow -->|"get,list,watch"| MR_MLflowConfigs

    %% Aggregate → Resources
    CR_View -->|"get,list,watch"| AR_View
    CR_Edit -->|"get,list,watch,create,<br/>update,delete,<br/>deletecollection,patch"| AR_Edit

    style SA_Controller fill:#4a90e2,color:#fff
    style SA_MLflow fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_MLflow fill:#f5a623,color:#fff
    style CR_View fill:#e8c14a,color:#333
    style CR_Edit fill:#e8c14a,color:#333
