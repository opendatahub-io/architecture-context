graph TB
    subgraph Operator["OGX K8s Operator"]
        direction TB
        Controller["OGXServer Reconciler<br/>(controller-runtime)"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS"]
        KustomizeEngine["Kustomize Engine<br/>(embedded manifest renderer)"]
        LegacyAdoption["Legacy Adoption System<br/>(v1alpha1 → v1beta1 migration)"]
        StatusUpdater["Status Updater<br/>(provider info, version, health)"]

        Controller -->|renders manifests via| KustomizeEngine
        Controller -->|validates CRs via| Webhook
        Controller -->|migrates resources via| LegacyAdoption
        Controller -->|updates CR status via| StatusUpdater
    end

    subgraph CRDs["Custom Resources"]
        OGXServerCR["OGXServer CR<br/>(ogx.io/v1beta1)"]
        LegacyCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)<br/><i>legacy</i>"]
    end

    subgraph ManagedResources["Managed Resources (per OGXServer)"]
        Deploy["Deployment<br/>(OGX server pods)"]
        Svc["Service<br/>(ClusterIP, port 8321)"]
        NP["NetworkPolicy"]
        PVC["PersistentVolumeClaim"]
        HPA["HorizontalPodAutoscaler"]
        PDB["PodDisruptionBudget"]
        Ing["Ingress<br/>(optional external access)"]
        CM["ConfigMap<br/>(config.yaml)"]
        SA["ServiceAccount"]
        RB["RoleBinding<br/>(SCC anyuid)"]
    end

    subgraph Providers["AI Provider Configuration"]
        Inference["Inference Providers<br/>(vLLM, OpenAI, Azure,<br/>Bedrock, VertexAI, Watsonx)"]
        VectorIO["Vector I/O Providers<br/>(PGVector, Milvus, Qdrant)"]
        ToolRuntime["Tool Runtime Providers<br/>(BraveSearch, Tavily, MCP)"]
        Files["Files Provider<br/>(S3)"]
    end

    User["User / Data Scientist"] -->|creates/updates| OGXServerCR
    OGXServerCR -->|watched by| Controller
    LegacyCR -.->|adopted by| LegacyAdoption

    Controller -->|creates/manages| Deploy
    Controller -->|creates/manages| Svc
    Controller -->|creates/manages| NP
    Controller -->|creates/manages| PVC
    Controller -->|creates/manages| HPA
    Controller -->|creates/manages| PDB
    Controller -->|creates/manages| Ing
    Controller -->|creates/manages| CM
    Controller -->|creates/manages| SA
    Controller -->|creates/manages| RB

    OGXServerCR -.->|configures| Providers

    StatusUpdater -->|queries /v1/providers, /v1/version| Deploy

    KubeAPI["Kubernetes API Server"] -->|watch events| Controller
    Controller -->|CRUD operations| KubeAPI

    Prometheus["Prometheus"] -->|scrapes /metrics<br/>8443/TCP HTTPS| Operator

    CertProvider["cert-manager /<br/>OpenShift service-ca"] -->|provisions TLS cert| Webhook

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style KustomizeEngine fill:#4a90e2,stroke:#333,color:#fff
    style LegacyAdoption fill:#4a90e2,stroke:#333,color:#fff
    style StatusUpdater fill:#4a90e2,stroke:#333,color:#fff
    style OGXServerCR fill:#f5a623,stroke:#333,color:#fff
    style LegacyCR fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Deploy fill:#7ed321,stroke:#333
    style Svc fill:#7ed321,stroke:#333
    style NP fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style Ing fill:#7ed321,stroke:#333
    style CM fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style RB fill:#7ed321,stroke:#333
    style Inference fill:#e8d5f5,stroke:#333
    style VectorIO fill:#e8d5f5,stroke:#333
    style ToolRuntime fill:#e8d5f5,stroke:#333
    style Files fill:#e8d5f5,stroke:#333
    style KubeAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style CertProvider fill:#e8e8e8,stroke:#333
