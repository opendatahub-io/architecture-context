graph TB
    subgraph Operator["llama-stack-k8s-operator"]
        direction TB
        Controller["Reconciler<br/>(LlamaStackDistribution Controller)"]
        Kustomizer["Kustomize Pipeline<br/>(Manifest Rendering)"]
        PluginPipeline["Plugin Pipeline<br/>(NamePrefix → Namespace → FieldMutator → NetworkPolicy)"]
        DirectClient["DirectClient<br/>(Non-cached ConfigMap reads)"]
        CABundleMgr["CA Bundle Manager<br/>(PEM/X.509 validation, aggregation)"]
        FeatureFlags["Feature Flags<br/>(enableNetworkPolicy, etc.)"]
        UpgradeCleanup["Upgrade Cleanup<br/>(Legacy ClusterRoleBinding removal)"]

        Controller -->|renders manifests| Kustomizer
        Kustomizer -->|applies transformations| PluginPipeline
        Controller -->|reads ConfigMaps| DirectClient
        Controller -->|aggregates certs| CABundleMgr
        Controller -->|checks flags| FeatureFlags
        Controller -->|on startup| UpgradeCleanup
    end

    User[Platform Admin] -->|creates/updates| LSD_CR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LSD_CR -->|watched by| Controller

    subgraph ManagedResources["Managed Per-Instance Resources"]
        direction TB
        Deploy["Deployment<br/>(Llama Stack server)"]
        Svc["Service<br/>(8321/TCP)"]
        SA["ServiceAccount"]
        PVC["PersistentVolumeClaim"]
        NP["NetworkPolicy"]
        PDB["PodDisruptionBudget"]
        HPA["HorizontalPodAutoscaler"]
        RB["RoleBinding<br/>(anyuid SCC)"]
        CABundle["CA Bundle ConfigMap"]
        Ingress["Ingress<br/>(optional, exposeRoute=true)"]
    end

    Controller -->|creates/manages| Deploy
    Controller -->|creates/manages| Svc
    Controller -->|creates/manages| SA
    Controller -->|creates/manages| PVC
    Controller -->|creates/manages| NP
    Controller -->|creates/manages| PDB
    Controller -->|creates/manages| HPA
    Controller -->|creates/manages| RB
    CABundleMgr -->|creates/manages| CABundle
    Controller -->|creates/manages| Ingress

    Controller -->|probes /v1/health,<br/>/v1/providers, /v1/version| LlamaServer["Llama Stack Server Pod<br/>(8321/TCP HTTP)"]
    Deploy -.->|runs| LlamaServer

    Controller -->|CRUD resources| K8sAPI["Kubernetes API Server<br/>(443/TCP HTTPS)"]
    DirectClient -->|reads| ODHTrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    DirectClient -->|reads| UserConfig["User ConfigMaps<br/>(userConfig, caBundle)"]
    DirectClient -->|reads| OperatorConfig["llama-stack-operator-config<br/>ConfigMap"]

    Prometheus["Prometheus"] -->|scrapes /metrics| MetricsSvc["Metrics Service<br/>(8443/TCP HTTPS)"]

    style Controller fill:#4a90e2,color:#fff
    style Kustomizer fill:#4a90e2,color:#fff
    style PluginPipeline fill:#4a90e2,color:#fff
    style DirectClient fill:#4a90e2,color:#fff
    style CABundleMgr fill:#4a90e2,color:#fff
    style FeatureFlags fill:#4a90e2,color:#fff
    style UpgradeCleanup fill:#4a90e2,color:#fff
    style LSD_CR fill:#f5a623,color:#fff
    style Deploy fill:#7ed321,color:#fff
    style Svc fill:#7ed321,color:#fff
    style SA fill:#7ed321,color:#fff
    style PVC fill:#7ed321,color:#fff
    style NP fill:#7ed321,color:#fff
    style PDB fill:#7ed321,color:#fff
    style HPA fill:#7ed321,color:#fff
    style RB fill:#7ed321,color:#fff
    style CABundle fill:#7ed321,color:#fff
    style Ingress fill:#7ed321,color:#fff
    style LlamaServer fill:#50c878,color:#fff
    style K8sAPI fill:#e8e8e8
    style ODHTrustedCA fill:#e8e8e8
    style UserConfig fill:#e8e8e8
    style OperatorConfig fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style MetricsSvc fill:#e8e8e8
