graph TB
    subgraph "Llama Stack K8s Operator"
        Controller["Operator Controller<br/>(controller-runtime)"]
        Kustomizer["Kustomize Pipeline<br/>(in-process rendering)"]
        CABundle["CA Bundle Manager<br/>(PEM parsing + X.509 validation)"]
        FeatureFlags["Feature Flags<br/>(ConfigMap-backed)"]
        StatusProbe["Status Prober<br/>(/v1/health, /v1/providers, /v1/version)"]
        MetricsProxy["kube-rbac-proxy<br/>8443/TCP HTTPS"]
    end

    User[Data Scientist / Admin] -->|"creates/updates"| LLSDCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LLSDCR -->|"watched by"| Controller

    Controller -->|"renders manifests via"| Kustomizer
    Controller -->|"manages CA certs via"| CABundle
    Controller -->|"checks flags via"| FeatureFlags
    Controller -->|"probes server via"| StatusProbe

    Kustomizer -->|"creates"| Deployment["Deployment<br/>(Llama Stack server)"]
    Kustomizer -->|"creates"| Service["Service<br/>(ClusterIP 8321/TCP)"]
    Kustomizer -->|"creates"| SA["ServiceAccount"]
    Kustomizer -->|"creates"| PVC["PersistentVolumeClaim<br/>(optional)"]
    Kustomizer -->|"creates"| NP["NetworkPolicy<br/>(when enabled)"]
    Kustomizer -->|"creates"| PDB["PodDisruptionBudget"]
    Kustomizer -->|"creates"| HPA["HorizontalPodAutoscaler<br/>(optional)"]
    Kustomizer -->|"creates"| RB["RoleBinding<br/>(anyuid SCC)"]
    Kustomizer -->|"creates"| Ingress["Ingress<br/>(optional, exposeRoute=true)"]

    CABundle -->|"reads"| ODHCACfg["odh-trusted-ca-bundle<br/>ConfigMap"]
    CABundle -->|"reads"| UserCACfg["User CA Bundle<br/>ConfigMaps"]
    CABundle -->|"creates"| ManagedCA["Managed CA Bundle<br/>ConfigMap"]

    StatusProbe -->|"queries"| LlamaStackPod["Llama Stack Pod<br/>8321/TCP HTTP"]

    Controller -->|"CRUD via"| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Kustomizer fill:#4a90e2,stroke:#333,color:#fff
    style CABundle fill:#4a90e2,stroke:#333,color:#fff
    style FeatureFlags fill:#4a90e2,stroke:#333,color:#fff
    style StatusProbe fill:#4a90e2,stroke:#333,color:#fff
    style MetricsProxy fill:#4a90e2,stroke:#333,color:#fff
    style LLSDCR fill:#f5a623,stroke:#333
    style Deployment fill:#7ed321,stroke:#333
    style Service fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style NP fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style RB fill:#7ed321,stroke:#333
    style Ingress fill:#7ed321,stroke:#333
    style ManagedCA fill:#7ed321,stroke:#333
    style ODHCACfg fill:#e8e8e8,stroke:#333
    style UserCACfg fill:#e8e8e8,stroke:#333
    style LlamaStackPod fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
