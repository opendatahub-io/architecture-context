graph TB
    subgraph Operator["llama-stack-k8s-operator"]
        Controller["LlamaStackDistribution<br/>Controller<br/>(Go, controller-runtime)"]
        Kustomizer["Kustomize Pipeline<br/>(manifest rendering)"]
        Plugins["Plugin Pipeline<br/>(name prefix, namespace,<br/>field mutation, netpol transform)"]
        CAManager["CA Bundle Manager<br/>(PEM/X.509 validation,<br/>aggregation)"]
        DirectClient["Direct Client<br/>(uncached ConfigMap reads)"]

        Controller -->|renders manifests| Kustomizer
        Kustomizer -->|applies transforms| Plugins
        Controller -->|validates certs| CAManager
        Controller -->|reads ConfigMaps| DirectClient
    end

    User["Data Scientist / Admin"] -->|creates/updates| LSD_CR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LSD_CR -->|watched by| Controller

    subgraph ManagedResources["Managed Per-Instance Resources"]
        Deployment["Deployment<br/>(Llama Stack server)"]
        Service["Service<br/>(ClusterIP 8321/TCP)"]
        SA["ServiceAccount"]
        PVC["PersistentVolumeClaim"]
        NP["NetworkPolicy"]
        PDB["PodDisruptionBudget"]
        HPA["HorizontalPodAutoscaler"]
        RB["RoleBinding<br/>(anyuid SCC)"]
        CABundle["CA Bundle ConfigMap"]
        Ingress["Ingress<br/>(optional, 80/TCP)"]
    end

    Controller -->|creates/manages| Deployment
    Controller -->|creates/manages| Service
    Controller -->|creates/manages| SA
    Controller -->|creates/manages| PVC
    Controller -->|creates/manages| NP
    Controller -->|creates/manages| PDB
    Controller -->|creates/manages| HPA
    Controller -->|creates/manages| RB
    CAManager -->|creates/manages| CABundle
    Controller -->|creates/manages| Ingress

    Controller -->|probes /v1/health,<br/>/v1/providers,<br/>/v1/version| LlamaServer["Llama Stack Server Pod<br/>(8321/TCP)"]
    Controller -->|CRUD resources| K8sAPI["Kubernetes API<br/>(443/TCP HTTPS)"]

    ODHTrustCA["odh-trusted-ca-bundle<br/>ConfigMap"] -->|auto-detected| DirectClient
    UserCA["User CA Bundle<br/>ConfigMap"] -->|referenced via spec| DirectClient
    UserConfig["User Config<br/>ConfigMap"] -->|referenced via spec| DirectClient
    OperatorConfig["llama-stack-operator-config<br/>ConfigMap"] -->|feature flags,<br/>image overrides| DirectClient

    style Controller fill:#4a90e2,color:#fff
    style Kustomizer fill:#4a90e2,color:#fff
