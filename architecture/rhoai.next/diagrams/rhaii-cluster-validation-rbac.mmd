graph TD
    subgraph "Service Accounts"
        SA["rhaii-validator<br/>Namespace: rhaii-validation"]
    end

    subgraph "ClusterRole Bindings"
        CRB["rhaii-validator<br/>(cluster-scoped)"]
        CRB_SCC["rhaii-validator-scc<br/>(cluster-scoped, OCP only)"]
    end

    subgraph "ClusterRoles"
        CR["rhaii-validator"]
        SCC["system:openshift:scc:privileged"]
    end

    subgraph "API Resources"
        direction TB

        subgraph "Core API (\"\")"
            Nodes["nodes"]
            Pods["pods"]
            PodsLog["pods/log"]
        end

        subgraph "Batch API"
            Jobs["jobs"]
        end

        subgraph "API Extensions"
            CRDs["customresourcedefinitions<br/>(apiextensions.k8s.io)"]
        end
    end

    subgraph "OpenShift SCC (OCP only)"
        Privileged["privileged SCC<br/>hostPID, host volumes,<br/>privileged containers"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via (OCP)"| CRB_SCC
    CRB -->|"grants"| CR
    CRB_SCC -->|"grants"| SCC

    %% Permissions
    CR -->|"get, list"| Nodes
    CR -->|"get, list, patch"| Pods
    CR -->|"get"| PodsLog
    CR -->|"create, get, list, delete"| Jobs
    CR -->|"get, list"| CRDs

    %% SCC
    SCC -->|"enables"| Privileged

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#6c8ebf,stroke:#333,color:#fff
    style CRB_SCC fill:#6c8ebf,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style SCC fill:#f5a623,stroke:#333,color:#fff
    style Nodes fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsLog fill:#7ed321,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333,color:#fff
    style CRDs fill:#7ed321,stroke:#333,color:#fff
    style Privileged fill:#f8cecc,stroke:#b85450
