graph TD
    subgraph "Service Accounts"
        SA["rhaii-validator<br/>Namespace: rhaii-validation"]
    end

    subgraph "ClusterRole Bindings"
        CRB["rhaii-validator<br/>(cluster-wide)"]
        CRB_SCC["rhaii-validator-scc<br/>(cluster-wide, OCP only,<br/>dynamically created)"]
    end

    subgraph "ClusterRoles"
        CR["rhaii-validator"]
        CR_SCC["system:openshift:scc:privileged<br/>(OCP only)"]
    end

    subgraph "API Resources - Core ('')"
        Nodes["core<br/>nodes"]
        Pods["core<br/>pods"]
        PodsLog["core<br/>pods/log"]
    end

    subgraph "API Resources - Batch"
        Jobs["batch<br/>jobs"]
    end

    subgraph "API Resources - API Extensions"
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph "Security Context Constraints (OCP)"
        SCC["privileged SCC<br/>Allows: privileged containers,<br/>hostPID, hostPath mounts"]
    end

    %% Binding flows
    SA -->|"bound via"| CRB
    SA -->|"bound via (OCP)"| CRB_SCC

    CRB -->|"grants"| CR
    CRB_SCC -->|"grants"| CR_SCC

    %% Permission flows
    CR -->|"get, list"| Nodes
    CR -->|"get, list, patch"| Pods
    CR -->|"get"| PodsLog
    CR -->|"create, get, list, delete"| Jobs
    CR -->|"get, list"| CRDs

    %% SCC flow
    CR_SCC -->|"allows"| SCC

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#7b68ee,stroke:#333,color:#fff
    style CRB_SCC fill:#7b68ee,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style CR_SCC fill:#f5a623,stroke:#333
    style Nodes fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsLog fill:#7ed321,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style CRDs fill:#7ed321,stroke:#333
    style SCC fill:#f8cecc,stroke:#b85450
