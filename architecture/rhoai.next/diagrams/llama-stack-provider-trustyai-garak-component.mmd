graph TB
    subgraph Provider["TrustyAI Garak Llama Stack Provider"]
        direction TB

        subgraph Core["core/ - Shared Pipeline Logic"]
            ConfigRes["config_resolution.py<br/>Deep-merge config + API key resolution"]
            CmdBuilder["command_builder.py<br/>garak CLI argument builder"]
            GarakRunner["garak_runner.py<br/>Process management + timeout"]
            PipelineSteps["pipeline_steps.py<br/>validate → taxonomy → SDG → prompts → scan → parse"]
        end

        subgraph Inline["inline/ - Llama Stack Inline Provider"]
            InlineEval["GarakInlineEvalAdapter<br/>Runs garak as subprocess<br/>Semaphore concurrency control"]
        end

        subgraph Remote["remote/ - Llama Stack Remote Provider"]
            RemoteEval["GarakRemoteEvalAdapter<br/>Submits scans to KFP<br/>Polls pipeline status"]
        end

        subgraph EvalHub["evalhub/ - Eval-Hub Adapter"]
            GarakAdapter["GarakAdapter<br/>FrameworkAdapter impl<br/>simple + kfp modes"]
            KfpAdapter["kfp_adapter.py<br/>KFP pipeline submission"]
            S3Utils["s3_utils.py<br/>S3 artifact transfer"]
        end

        subgraph Shared["Shared Modules"]
            Config["config.py<br/>GarakCommandConfig + benchmark profiles"]
            BaseEval["base_eval.py<br/>Base adapter with deep-merge"]
            ShieldScan["shield_scan.py<br/>Llama Stack safety API client"]
            SDG["sdg.py<br/>Synthetic data generation"]
            Intents["intents.py<br/>Intents benchmark pipeline"]
            Compat["compat.py<br/>Llama Stack API compatibility"]
        end
    end

    %% Internal relationships
    InlineEval -->|extends| BaseEval
    RemoteEval -->|extends| BaseEval
    InlineEval -->|uses| GarakRunner
    InlineEval -->|uses| CmdBuilder
    RemoteEval -->|uses| ConfigRes
    GarakAdapter -->|uses| GarakRunner
    GarakAdapter -->|uses| CmdBuilder
    GarakAdapter -->|uses| S3Utils
    GarakAdapter -->|kfp mode| KfpAdapter
    BaseEval -->|uses| Config
    BaseEval -->|uses| Compat
    PipelineSteps -->|uses| SDG
    PipelineSteps -->|uses| ShieldScan
    PipelineSteps -->|uses| Intents

    %% External interactions
    User[User / Client] -->|benchmarks.register<br/>eval.run_eval| LSD
    LSD["Llama Stack Server<br/>8321/TCP"] -->|loads plugin| InlineEval
    LSD -->|loads plugin| RemoteEval

    EvalHubSvc["Eval-Hub Service"] -->|K8s Job + ConfigMap| GarakAdapter

    InlineEval -->|subprocess| Garak["garak<br/>Red-teaming engine"]
    GarakAdapter -->|subprocess| Garak
    Garak -->|probes| TargetLLM["Target LLM<br/>(vLLM)<br/>443/TCP HTTPS"]

    RemoteEval -->|submit pipeline| KFP["KFP / DSPA<br/>443/TCP HTTPS"]
    KfpAdapter -->|submit pipeline| KFP

    GarakAdapter -->|push artifacts| OCI["OCI Registry<br/>443/TCP HTTPS"]
    GarakAdapter -->|log metrics| MLflow["MLflow<br/>443/TCP HTTPS"]

    %% Styling
    style Provider fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#f0f7e8,stroke:#82b366,stroke-width:1px
    style Inline fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Remote fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style EvalHub fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    style Shared fill:#f5f0ff,stroke:#9673a6,stroke-width:1px

    style LSD fill:#4a90e2,color:#fff
    style EvalHubSvc fill:#4a90e2,color:#fff
    style TargetLLM fill:#f5a623,color:#fff
    style KFP fill:#999,color:#fff
    style OCI fill:#999,color:#fff
    style MLflow fill:#999,color:#fff
    style Garak fill:#e74c3c,color:#fff
    style User fill:#e8e8e8,stroke:#333
