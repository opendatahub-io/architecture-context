graph TB
    subgraph LlamaStackProvider["Llama Stack Provider Integration"]
        direction TB
        InlineProvider["Llama Stack Inline Provider<br/><i>Runs Garak as local subprocess</i>"]
        RemoteProvider["Llama Stack Remote Provider<br/><i>Submits Garak as KFP pipelines</i>"]
        BaseEval["BaseEval Protocol<br/><i>Llama Stack Eval interface</i>"]
        BaseEval --> InlineProvider
        BaseEval --> RemoteProvider
    end

    subgraph EvalHubIntegration["Eval-Hub Integration"]
        direction TB
        EvalHubSimple["Eval-Hub Adapter (Simple)<br/><i>Direct Garak in K8s job pods</i>"]
        EvalHubKFP["Eval-Hub KFP Adapter<br/><i>Submits Garak as KFP pipelines</i>"]
    end

    subgraph CoreModule["Core Module (Shared Logic)"]
        direction TB
        PipelineSteps["Core Pipeline Steps<br/><i>validate → taxonomy → SDG →<br/>prompts → scan → parse</i>"]
        GarakRunner["Garak Runner<br/><i>Subprocess mgmt with process<br/>group isolation & timeout</i>"]
        ConfigResolution["Config Resolution<br/><i>Profiles → benchmark config →<br/>user overrides merging</i>"]
        ResultParser["Result Parser<br/><i>JSONL/AVID parsing, TBSA scoring,<br/>Vega charts, HTML reports</i>"]
        ShieldOrch["Shield Orchestrator<br/><i>Input/output guardrail scanning</i>"]
    end

    subgraph KFPPipelines["KFP Pipeline Components"]
        direction TB
        KFPLlamaStack["KFP Components (Llama Stack)<br/><i>6 @dsl.component steps<br/>Files API artifact transfer</i>"]
        KFPEvalHub["KFP Components (Eval-Hub)<br/><i>6 @dsl.component steps<br/>S3 artifact transfer</i>"]
    end

    %% Core dependencies
    InlineProvider --> GarakRunner
    InlineProvider --> PipelineSteps
    InlineProvider --> ShieldOrch
    InlineProvider --> ConfigResolution
    RemoteProvider --> KFPLlamaStack
    RemoteProvider --> ConfigResolution
    EvalHubSimple --> GarakRunner
    EvalHubSimple --> PipelineSteps
    EvalHubSimple --> ConfigResolution
    EvalHubKFP --> KFPEvalHub
    EvalHubKFP --> ConfigResolution
    KFPLlamaStack --> PipelineSteps
    KFPEvalHub --> PipelineSteps
    PipelineSteps --> GarakRunner
    PipelineSteps --> ResultParser

    %% External interactions
    LlamaStackServer["Llama Stack Server<br/><i>8321/TCP HTTP</i>"]
    KFPServer["KFP API Server<br/><i>443/TCP HTTPS</i>"]
    vLLM["vLLM Model Serving<br/><i>HTTP/HTTPS</i>"]
    S3["S3 / MinIO<br/><i>443/TCP HTTPS</i>"]
    PostgreSQL["PostgreSQL<br/><i>5432/TCP</i>"]

    InlineProvider -.->|"Files/Safety/Inference API"| LlamaStackServer
    RemoteProvider -.->|"Pipeline submission"| KFPServer
    KFPLlamaStack -.->|"Files API artifacts"| LlamaStackServer
    KFPEvalHub -.->|"S3 artifacts"| S3
    GarakRunner -.->|"Inference requests"| vLLM
    LlamaStackServer -.->|"Persistence"| PostgreSQL

    %% Styling
    style InlineProvider fill:#4a90e2,color:#fff
    style RemoteProvider fill:#4a90e2,color:#fff
    style BaseEval fill:#4a90e2,color:#fff
    style EvalHubSimple fill:#9b59b6,color:#fff
    style EvalHubKFP fill:#9b59b6,color:#fff
    style PipelineSteps fill:#2ecc71,color:#fff
    style GarakRunner fill:#2ecc71,color:#fff
    style ConfigResolution fill:#2ecc71,color:#fff
    style ResultParser fill:#2ecc71,color:#fff
    style ShieldOrch fill:#2ecc71,color:#fff
    style KFPLlamaStack fill:#e67e22,color:#fff
    style KFPEvalHub fill:#e67e22,color:#fff
    style LlamaStackServer fill:#e8e8e8,stroke:#333
    style KFPServer fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
