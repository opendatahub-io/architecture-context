graph TB
    subgraph "Garak Adapter Component"
        direction TB

        subgraph "evalhub package"
            Adapter["GarakAdapter<br/>(FrameworkAdapter)"]
            KFPAdapter["KFP Adapter"]
            KFPPipeline["KFP Pipeline Definition<br/>(6-step DAG)"]
            S3Utils["S3 Utilities"]
        end

        subgraph "core package"
            ConfigRes["Config Resolution"]
            CmdBuilder["Command Builder"]
            GarakRunner["Garak Runner<br/>(subprocess mgmt)"]
            PipelineSteps["Pipeline Steps<br/>(validate, resolve_taxonomy,<br/>sdg_generate, prepare_prompts,<br/>garak_scan, write_outputs)"]
        end

        subgraph "support modules"
            ResultUtils["Result Utils<br/>(JSONL/AVID parsing,<br/>ASR/TBSA metrics)"]
            Intents["Intents Module<br/>(taxonomy, CAS topology,<br/>intent stubs)"]
            SDG["SDG Module<br/>(synthetic adversarial<br/>prompt generation)"]
        end

        Adapter -->|"simple mode"| ConfigRes
        Adapter -->|"KFP mode"| KFPAdapter
        KFPAdapter --> KFPPipeline
        KFPPipeline --> PipelineSteps
        ConfigRes --> CmdBuilder
        CmdBuilder --> GarakRunner
        PipelineSteps --> S3Utils
        Adapter --> ResultUtils
        Adapter --> Intents
        Adapter --> SDG
    end

    %% External orchestration
    EvalHub["eval-hub Service"] -->|"creates K8s Job<br/>with JobSpec ConfigMap"| Adapter
    Adapter -->|"status callbacks<br/>localhost HTTP"| EvalHubSidecar["eval-hub Sidecar"]

    %% External services
    GarakRunner -->|"HTTPS/443<br/>Bearer Token"| TargetModel["Target Model<br/>(OpenAI-compatible)"]
    GarakRunner -->|"HTTPS/443<br/>Bearer Token"| JudgeModel["Judge Model"]
    GarakRunner -->|"HTTPS/443<br/>Bearer Token"| AttackerModel["Attacker Model"]
    SDG -->|"HTTPS/443<br/>Bearer Token"| SDGModel["SDG Model"]
    S3Utils -->|"HTTPS/443<br/>AWS IAM"| S3["S3 Storage"]
    KFPPipeline -->|"HTTPS/443<br/>SA Token"| KFPAPI["KFP API Server"]
    Adapter -->|"HTTPS/443"| OCI["OCI Registry"]
    Adapter -->|"HTTPS/443"| MLflow["MLflow"]

    %% Styling
    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style KFPAdapter fill:#4a90e2,stroke:#333,color:#fff
    style KFPPipeline fill:#4a90e2,stroke:#333,color:#fff
    style S3Utils fill:#4a90e2,stroke:#333,color:#fff
    style ConfigRes fill:#6baed6,stroke:#333,color:#fff
    style CmdBuilder fill:#6baed6,stroke:#333,color:#fff
    style GarakRunner fill:#6baed6,stroke:#333,color:#fff
    style PipelineSteps fill:#6baed6,stroke:#333,color:#fff
    style ResultUtils fill:#9ecae1,stroke:#333
    style Intents fill:#9ecae1,stroke:#333
    style SDG fill:#9ecae1,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style EvalHubSidecar fill:#7ed321,stroke:#333,color:#fff
    style TargetModel fill:#f5a623,stroke:#333
    style JudgeModel fill:#f5a623,stroke:#333
    style AttackerModel fill:#f5a623,stroke:#333
    style SDGModel fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style KFPAPI fill:#7ed321,stroke:#333,color:#fff
    style OCI fill:#f5a623,stroke:#333
    style MLflow fill:#f5a623,stroke:#333
