    style Provider fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CoreLib fill:#bbdefb,stroke:#1565c0
    style CoreModule fill:#c8e6c9,stroke:#2e7d32
    style InlineModule fill:#fff3e0,stroke:#e65100
    style RemoteModule fill:#fff3e0,stroke:#e65100
    style EvalHubModule fill:#f3e5f5,stroke:#6a1b9a
    style ContainerImage fill:#fce4ec,stroke:#c62828
    style DSPImage fill:#fce4ec,stroke:#c62828
    style LlamaStack fill:#4a90e2,color:#fff
    style TargetLLM fill:#f5a623,color:#fff
    style KFP fill:#4a90e2,color:#fff
    style S3 fill:#999,color:#fff
    style OCI fill:#999,color:#fff
    style MLflow fill:#999,color:#fff
    style Garak fill:#e53935,color:#fff
    style EvalHubSvc fill:#7ed321,color:#fff
