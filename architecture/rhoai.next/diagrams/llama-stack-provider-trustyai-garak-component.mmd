graph TB
    subgraph LlamaStackProvider["Llama Stack Provider (trustyai-garak)"]
        direction TB

        subgraph InlineMode["Inline Provider"]
            InlineProvider["GarakInlineEvalAdapter<br/>Runs garak locally in-process<br/>asyncio semaphore concurrency"]
        end

        subgraph RemoteMode["Remote Provider"]
            RemoteProvider["GarakRemoteEvalAdapter<br/>Submits KFP pipelines<br/>Polls for completion"]
        end

        subgraph EvalHubAdapters["Eval-Hub Adapters"]
            GarakAdapter["GarakAdapter<br/>FrameworkAdapter<br/>Simple or KFP execution"]
            KFPAdapter["GarakKFPAdapter<br/>Forces KFP mode"]
            KFPAdapter -->|extends| GarakAdapter
        end

        subgraph CoreModules["Core Modules"]
            PipelineSteps["Pipeline Steps<br/>Shared business logic"]
            CommandBuilder["Command Builder<br/>Garak CLI config"]
            ConfigResolution["Config Resolution<br/>Deep-merge profiles"]
            GarakRunner["Garak Runner<br/>Subprocess execution"]
            ResultUtils["Result Utilities<br/>JSONL/AVID parsing<br/>TBSA scoring"]
        end

        subgraph SpecializedModules["Specialized Modules"]
            ShieldScan["Shield Scan Orchestrator<br/>Input/output shield wrapping"]
            IntentsModule["Intents Module<br/>Policy taxonomy<br/>Intent stub generation"]
            SDGModule["SDG Module<br/>Synthetic adversarial<br/>prompt generation"]
            GarakCommandConfig["Garak Command Config<br/>Pydantic models"]
        end

        InlineProvider -->|uses| CoreModules
        RemoteProvider -->|uses| CoreModules
        GarakAdapter -->|uses| CoreModules
        InlineProvider -->|uses| ShieldScan
        InlineProvider -->|uses| IntentsModule
        GarakAdapter -->|uses| IntentsModule
        IntentsModule -->|uses| SDGModule
        CoreModules -->|uses| GarakCommandConfig
    end

    subgraph KFPPipelines["KFP Pipelines"]
        LLSPipeline["Llama Stack Pipeline<br/>4 steps: validate → scan →<br/>parse → upload"]
        EvalHubPipeline["Eval-Hub Pipeline<br/>6 steps: validate → taxonomy →<br/>SDG → prompts → scan → write"]
    end

    RemoteProvider -->|submits| LLSPipeline
    GarakAdapter -->|submits| EvalHubPipeline

    %% External Systems
    User[User / Client] -->|creates benchmark| InlineProvider
    User -->|creates benchmark| RemoteProvider
    EvalHub[Eval-Hub Service] -->|creates job| GarakAdapter

    LlamaStackServer["Llama Stack Server<br/>8321/TCP"] -->|loads provider| InlineProvider
    LlamaStackServer -->|loads provider| RemoteProvider

    TargetModel["Target Model<br/>(vLLM)<br/>OpenAI-compatible"]
    InlineProvider -->|scans| TargetModel
    LLSPipeline -->|scans| TargetModel
    EvalHubPipeline -->|scans| TargetModel

    %% Styling
    style LlamaStackProvider fill:#e8f4f8,stroke:#4a90e2,stroke-width:2px
    style InlineMode fill:#d5e8d4,stroke:#82b366
    style RemoteMode fill:#dae8fc,stroke:#6c8ebf
    style EvalHubAdapters fill:#fff2cc,stroke:#d6b656
    style CoreModules fill:#f8cecc,stroke:#b85450
    style SpecializedModules fill:#e1d5e7,stroke:#9673a6
    style KFPPipelines fill:#ffe6cc,stroke:#d79b00
    style LlamaStackServer fill:#4a90e2,color:#fff
    style TargetModel fill:#f5a623
    style EvalHub fill:#7ed321
    style User fill:#e8e8e8,stroke:#999
