graph TB
    subgraph Provider["TrustyAI Garak Provider Package"]
        direction TB

        subgraph Core["core/ - Shared Pipeline Logic"]
            ConfigRes["config_resolution.py<br/>Deep-merge config"]
            CmdBuilder["command_builder.py<br/>Garak CLI builder"]
            GarakRunner["garak_runner.py<br/>Process management"]
            PipeSteps["pipeline_steps.py<br/>validate → taxonomy →<br/>SDG → prompts → scan → parse"]
        end

        subgraph Inline["inline/ - Inline Provider"]
            InlineEval["GarakInlineEvalAdapter<br/>In-process garak execution<br/>Semaphore concurrency control"]
        end

        subgraph Remote["remote/ - Remote Provider"]
            RemoteEval["GarakRemoteEvalAdapter<br/>KFP pipeline submission"]
        end

        subgraph EvalHub["evalhub/ - Eval-Hub Adapter"]
            GarakAdapter["GarakAdapter<br/>FrameworkAdapter impl"]
            KFPAdapter["kfp_adapter.py<br/>KFP pipeline definition"]
            S3Utils["s3_utils.py<br/>S3 artifact transfer"]
        end

        subgraph Shared["Shared Modules"]
            BaseEval["base_eval.py<br/>Common eval logic"]
            Config["config.py<br/>Benchmark profiles<br/>OWASP, AVID, CWE, Intents"]
            ShieldScan["shield_scan.py<br/>Guardrail testing"]
            SDG["sdg.py<br/>Synthetic data generation"]
            Intents["intents.py<br/>Intents benchmark pipeline"]
            Compat["compat.py<br/>Llama Stack API compat"]
        end
    end

    subgraph ContainerImage["Container Image"]
        DSPImage["odh-trustyai-garak-lls-provider-dsp<br/>quay.io/rhoai/odh-trustyai-garak-<br/>lls-provider-dsp-rhel9<br/>Python 3.12 + Rust (build-time)"]
    end

    %% Internal relationships
    InlineEval -->|extends| BaseEval
    RemoteEval -->|extends| BaseEval
    BaseEval -->|uses| Config
    BaseEval -->|uses| ConfigRes
    InlineEval -->|spawns| GarakRunner
    GarakRunner -->|builds CLI| CmdBuilder
    RemoteEval -->|submits| KFPAdapter
    GarakAdapter -->|uses| PipeSteps
    GarakAdapter -->|uses| S3Utils
    GarakAdapter -->|mode: simple| GarakRunner
    GarakAdapter -->|mode: kfp| KFPAdapter
    InlineEval -->|intents| Intents
    Intents -->|generates| SDG
    ShieldScan -->|called by| BaseEval

    %% External interactions
    User[User / Client] -->|benchmarks.register<br/>eval.run_eval| LSD
    LSD["Llama Stack Server<br/>8321/TCP"] -->|loads plugin| InlineEval
    LSD -->|loads plugin| RemoteEval
    EvalHubSvc["Eval-Hub Service"] -->|K8s Job| GarakAdapter
    DSPImage -.->|base image for| KFPPod["KFP Pipeline Pods"]
    DSPImage -.->|base image for| EvalPod["Eval-Hub Job Pods"]

    %% Styling
    style Provider fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#fff3e0,stroke:#f5a623,stroke-width:1px
    style Inline fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style Remote fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style EvalHub fill:#fce4ec,stroke:#e91e63,stroke-width:1px
    style Shared fill:#f3e5f5,stroke:#9c27b0,stroke-width:1px
    style ContainerImage fill:#e0e0e0,stroke:#616161,stroke-width:1px
    style LSD fill:#4a90e2,color:#fff
    style EvalHubSvc fill:#e91e63,color:#fff
    style User fill:#f5f5f5,stroke:#333
