graph TB
    subgraph EvalHub["eval-hub Service"]
        JobSpec["JobSpec<br/>(ConfigMap mount)"]
    end

    subgraph GarakProvider["Garak Provider (Batch Job Pod)"]
        direction TB

        subgraph Adapters["Adapters (evalhub/)"]
            GarakAdapter["GarakAdapter<br/>FrameworkAdapter"]
            GarakKFPAdapter["GarakKFPAdapter<br/>KFP subclass"]
            GarakKFPAdapter -->|extends| GarakAdapter
        end

        subgraph Core["Core Library (core/)"]
            ConfigResolution["config_resolution<br/>Layered merge"]
            CommandBuilder["command_builder<br/>CLI args"]
            GarakRunner["garak_runner<br/>Subprocess mgmt"]
            PipelineSteps["pipeline_steps<br/>KFP step logic"]
        end

        subgraph Support["Support Modules"]
            Config["config<br/>Pydantic models<br/>Scan profiles"]
            ResultUtils["result_utils<br/>JSONL/AVID parser<br/>HTML reports"]
            SDG["sdg<br/>Synthetic Data<br/>Generation"]
            Intents["intents<br/>Taxonomy loader<br/>Stub generator"]
        end

        GarakAdapter -->|resolves config| ConfigResolution
        GarakAdapter -->|builds commands| CommandBuilder
        GarakAdapter -->|runs scans| GarakRunner
        GarakAdapter -->|parses results| ResultUtils
        GarakAdapter -->|generates prompts| SDG
        GarakAdapter -->|loads taxonomies| Intents
        GarakKFPAdapter -->|submits pipeline| PipelineSteps
        ConfigResolution -->|reads profiles| Config
    end

    subgraph KFPPipeline["KFP Pipeline (6 steps)"]
        direction LR
        Validate["validate"]
        ResolveTaxonomy["resolve_taxonomy"]
        SDGGenerate["sdg_generate"]
        PreparePrompts["prepare_prompts"]
        GarakScan["garak_scan"]
        WriteOutputs["write_kfp_outputs"]
        Validate --> ResolveTaxonomy --> SDGGenerate --> PreparePrompts --> GarakScan --> WriteOutputs
    end

    %% External connections
    JobSpec -->|mounts config| GarakAdapter
    GarakKFPAdapter -->|submits| KFPPipeline

    GarakRunner -->|executes| GarakSubprocess["Garak CLI<br/>Subprocess"]
    GarakSubprocess -->|scans| TargetLLM["Target LLM<br/>(OpenAI-compatible)"]

    GarakAdapter -->|reports results| EvalHubCallback["eval-hub Sidecar<br/>(callback)"]
    GarakAdapter -->|persists| OCIRegistry["OCI Registry"]
    GarakAdapter -->|tracks| MLflow["MLflow"]
    GarakAdapter -->|transfers artifacts| S3["S3 Storage"]

    %% Styling
    style GarakAdapter fill:#4a90e2,color:#fff
    style GarakKFPAdapter fill:#4a90e2,color:#fff
    style ConfigResolution fill:#5ba3e6,color:#fff
    style CommandBuilder fill:#5ba3e6,color:#fff
    style GarakRunner fill:#5ba3e6,color:#fff
    style PipelineSteps fill:#5ba3e6,color:#fff
    style Config fill:#7ed321,color:#fff
    style ResultUtils fill:#7ed321,color:#fff
    style SDG fill:#7ed321,color:#fff
    style Intents fill:#7ed321,color:#fff
    style GarakSubprocess fill:#f5a623,color:#fff
    style TargetLLM fill:#e8e8e8
    style S3 fill:#e8e8e8
    style MLflow fill:#e8e8e8
    style OCIRegistry fill:#e8e8e8
    style EvalHubCallback fill:#e8e8e8
    style JobSpec fill:#f5a623,color:#fff
