graph TB
    subgraph Provider["TrustyAI Garak Llama Stack Provider"]
        direction TB

        subgraph CoreLib["Core Library (llama_stack_provider_trustyai_garak)"]
            Config["config.py<br/>GarakCommandConfig<br/>Benchmark Profiles"]
            BaseEval["base_eval.py<br/>Shared Eval Logic<br/>Deep-Merge Config"]
            Compat["compat.py<br/>LS API Compatibility"]
            ShieldScan["shield_scan.py<br/>Guardrail Testing"]
            Intents["intents.py<br/>Intents Benchmark<br/>6-Step Pipeline"]
            SDG["sdg.py<br/>Synthetic Data Generation"]
        end

        subgraph CoreModule["core/ (Framework-Agnostic)"]
            ConfigRes["config_resolution.py<br/>Config Resolution"]
            CmdBuilder["command_builder.py<br/>Garak CLI Builder"]
            GarakRunner["garak_runner.py<br/>Process Management<br/>setsid + SIGTERM/SIGKILL"]
            PipeSteps["pipeline_steps.py<br/>validate → taxonomy →<br/>SDG → prompts → scan → parse"]
        end

        subgraph InlineModule["inline/ Provider"]
            InlineEval["garak_eval.py<br/>GarakInlineEvalAdapter<br/>In-process garak execution<br/>Semaphore concurrency"]
        end

        subgraph RemoteModule["remote/ Provider"]
            RemoteEval["garak_remote_eval.py<br/>GarakRemoteEvalAdapter<br/>KFP pipeline submission"]
        end

        subgraph EvalHubModule["evalhub/ Adapter"]
            GarakAdapter["garak_adapter.py<br/>GarakAdapter<br/>FrameworkAdapter impl"]
            KFPAdapter["kfp_adapter.py<br/>KFP Mode"]
            S3Utils["s3_utils.py<br/>S3 artifact transfer"]
            KFPPipeline["kfp_pipeline.py<br/>Pipeline definition"]
        end
    end

    subgraph ContainerImage["Container Image"]
        DSPImage["odh-trustyai-garak-lls-provider-dsp<br/>quay.io/rhoai/odh-trustyai-garak-<br/>lls-provider-dsp-rhel9<br/>Python 3.12 + Rust (build)<br/>UBI9 Base"]
    end

    %% Internal relationships
    InlineEval --> BaseEval
    RemoteEval --> BaseEval
    BaseEval --> Config
    BaseEval --> Compat
    BaseEval --> ShieldScan
    InlineEval --> GarakRunner
    InlineEval --> CmdBuilder
    RemoteEval --> CmdBuilder
    GarakAdapter --> PipeSteps
    GarakAdapter --> ConfigRes
    GarakAdapter --> S3Utils
    GarakAdapter --> KFPAdapter
    KFPAdapter --> KFPPipeline
    PipeSteps --> GarakRunner
    PipeSteps --> SDG
    Intents --> PipeSteps
    ShieldScan --> Compat

    %% External dependencies
    User[User / API Client] -->|"benchmarks.register<br/>eval.run_eval"| LlamaStack
    LlamaStack["Llama Stack Server<br/>8321/TCP"] -->|plugin load| InlineEval
    LlamaStack -->|plugin load| RemoteEval
    EvalHubSvc["Eval-Hub Service"] -->|"K8s Job + ConfigMap<br/>/meta/job.json"| GarakAdapter

    InlineEval -->|subprocess| Garak["garak 0.14.1+rhaiv.7<br/>NVIDIA Red-Teaming"]
    GarakAdapter -->|subprocess| Garak
    RemoteEval -->|"KFP SDK<br/>443/TCP HTTPS"| KFP["Data Science Pipelines<br/>(DSPA)"]
    KFPAdapter -->|"KFP SDK"| KFP

    Garak -->|"OpenAI API<br/>443/TCP HTTPS"| TargetLLM["Target LLM<br/>(vLLM)"]
    InlineEval -->|in-process| FilesAPI["Llama Stack<br/>Files API"]
    GarakAdapter -->|"443/TCP HTTPS"| S3["S3 Object Storage"]
    GarakAdapter -->|"443/TCP HTTPS"| OCI["OCI Registry"]
    GarakAdapter -->|"443/TCP HTTPS"| MLflow["MLflow"]

    ContainerImage -.->|"base image for"| KFP
    ContainerImage -.->|"base image for"| EvalHubSvc

