graph TB
    subgraph LlamaStackProvider["Llama Stack Provider Surface"]
        direction TB
        InlineProvider["Llama Stack Inline Provider<br/><i>Python Library</i>"]
        RemoteProvider["Llama Stack Remote Provider<br/><i>Python Library</i>"]
        BaseEval["BaseEval Protocol<br/><i>Llama Stack Eval interface</i>"]
        BaseEval --> InlineProvider
        BaseEval --> RemoteProvider
    end

    subgraph EvalHubSurface["Eval-Hub Adapter Surface"]
        direction TB
        EvalHubSimple["Eval-Hub Adapter (Simple)<br/><i>Direct Garak execution</i>"]
        EvalHubKFP["Eval-Hub KFP Adapter<br/><i>KFP pipeline submission</i>"]
    end

    subgraph CoreModule["Core Module (Shared)"]
        direction TB
        PipelineSteps["Core Pipeline Steps<br/><i>validate → taxonomy → SDG →<br/>prompts → scan → parse</i>"]
        GarakRunner["Garak Runner<br/><i>Subprocess mgmt, process groups,<br/>SIGTERM/SIGKILL, log streaming</i>"]
        ConfigResolution["Config Resolution<br/><i>Profiles → benchmark config →<br/>user overrides (deep merge)</i>"]
        ResultParser["Result Parser<br/><i>JSONL/AVID parsing, TBSA scoring,<br/>Vega charts, Jinja2 HTML</i>"]
        ShieldOrchestrator["Shield Orchestrator<br/><i>Input/output guardrail scanning</i>"]
    end

    subgraph KFPPipelines["KFP Pipeline Components"]
        direction TB
        KFPLlamaStack["KFP Components (Llama Stack)<br/><i>6 @dsl.component steps<br/>Files API artifact transfer</i>"]
        KFPEvalHub["KFP Components (Eval-Hub)<br/><i>6 @dsl.component steps<br/>S3 artifact transfer</i>"]
    end

    %% Internal connections
    InlineProvider --> PipelineSteps
    InlineProvider --> GarakRunner
    InlineProvider --> ShieldOrchestrator
    RemoteProvider --> KFPLlamaStack
    RemoteProvider --> ConfigResolution
    EvalHubSimple --> PipelineSteps
    EvalHubSimple --> GarakRunner
    EvalHubKFP --> KFPEvalHub
    KFPLlamaStack --> PipelineSteps
    KFPEvalHub --> PipelineSteps
    PipelineSteps --> GarakRunner
    PipelineSteps --> ResultParser
    PipelineSteps --> ConfigResolution

    %% External services
    LlamaStackServer["Llama Stack Server<br/>8321/TCP HTTP"]
    KFPServer["KFP API Server<br/>443/TCP HTTPS"]
    vLLM["vLLM Model Serving<br/>HTTP/HTTPS"]
    S3["S3 / MinIO<br/>443/TCP HTTPS"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    SDGEndpoint["SDG Model Endpoint<br/>HTTP/HTTPS"]

    %% External connections
    InlineProvider -->|"Files/Safety/Shields API"| LlamaStackServer
    RemoteProvider -->|"Pipeline submission"| KFPServer
    KFPLlamaStack -->|"Artifact transfer"| LlamaStackServer
    KFPEvalHub -->|"Artifact transfer"| S3
    GarakRunner -->|"Inference requests"| vLLM
    ShieldOrchestrator -->|"Guardrail scanning"| LlamaStackServer
    LlamaStackServer -->|"Persistence"| PostgreSQL
    PipelineSteps -->|"Synthetic data gen"| SDGEndpoint

    %% Styling
    style LlamaStackProvider fill:#4a90e2,stroke:#333,color:#fff
    style EvalHubSurface fill:#9b59b6,stroke:#333,color:#fff
    style CoreModule fill:#27ae60,stroke:#333,color:#fff
    style KFPPipelines fill:#e67e22,stroke:#333,color:#fff
    style LlamaStackServer fill:#e8e8e8,stroke:#333
    style KFPServer fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style SDGEndpoint fill:#e8e8e8,stroke:#333
