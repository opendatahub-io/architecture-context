graph TB
    subgraph DeployerContainer["odh-deployer Container (UBI8-minimal)"]
        DeployScript["deploy.sh<br/>Bash Script<br/>Main Orchestrator"]
        OC["oc CLI<br/>OpenShift Client"]
        DeployScript -->|executes| OC
    end

    subgraph KfDefManifests["KfDef Manifests"]
        KfDashboard["rhods-dashboard.yaml"]
        KfNBC["rhods-nbc.yaml"]
        KfModelMesh["rhods-model-mesh.yaml"]
        KfDSPO["rhods-dspo.yaml"]
        KfMonitoring["rhods-monitoring.yaml"]
        KfNotebooks["rhods-notebooks.yaml"]
        KfAnaconda["rhods-anaconda.yaml"]
    end

    subgraph MonitoringStack["Prometheus Monitoring Stack"]
        Prometheus["Prometheus<br/>9090/TCP"]
        Alertmanager["Alertmanager<br/>9093/TCP"]
        BlackboxExporter["Blackbox Exporter<br/>9114/TCP"]
        OAuthProxyProm["OAuth Proxy<br/>9091/TCP HTTPS"]
        OAuthProxyAM["OAuth Proxy<br/>10443/TCP HTTPS"]
        Prometheus --> Alertmanager
        Prometheus --> BlackboxExporter
        OAuthProxyProm -->|proxies| Prometheus
        OAuthProxyAM -->|proxies| Alertmanager
    end

    subgraph DashboardConfig["Dashboard Configuration"]
        CRDs["CRDs<br/>OdhApplication<br/>OdhDocument<br/>OdhQuickStart<br/>OdhDashboardConfig"]
        ISVTiles["ISV Application Tiles<br/>Jupyter, Anaconda,<br/>OpenVINO, Pachyderm,<br/>Watson, AIKit"]
        ServingRuntimes["ServingRuntime Templates<br/>OVMS CPU + GPU"]
    end

    subgraph NetworkPolicies["Network Policies"]
        AppNP["applications NP"]
        MonNP["monitoring NP"]
        OpNP["operator NP"]
    end

    %% Deployment flows
    DeployScript -->|"creates KfDef CRs"| KfDefManifests
    DeployScript -->|"deploys"| MonitoringStack
    DeployScript -->|"applies CRDs & config"| DashboardConfig
    DeployScript -->|"applies"| NetworkPolicies

    %% External targets
    K8sAPI["OpenShift API Server<br/>443/TCP HTTPS"]
    OC -->|"oc apply"| K8sAPI

    ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    KfDefManifests -->|"watched by"| ODHOperator
    ODHOperator -->|"installs components from<br/>odh-manifests tarball"| Components["Platform Components<br/>Dashboard, Notebooks,<br/>ModelMesh, DSPO"]

    %% Namespaces
    NSApps["NS: redhat-ods-applications"]
    NSMon["NS: redhat-ods-monitoring"]
    NSNotebooks["NS: rhods-notebooks"]
    DeployScript -->|"creates & labels"| NSApps
    DeployScript -->|"creates & labels"| NSMon
    DeployScript -->|"creates & labels"| NSNotebooks

    %% Styling
    style DeployScript fill:#4a90e2,stroke:#333,color:#fff
    style OC fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style BlackboxExporter fill:#e6522c,stroke:#333,color:#fff
    style OAuthProxyProm fill:#f5a623,stroke:#333
    style OAuthProxyAM fill:#f5a623,stroke:#333
    style CRDs fill:#7ed321,stroke:#333
    style ISVTiles fill:#7ed321,stroke:#333
    style ServingRuntimes fill:#7ed321,stroke:#333
    style ODHOperator fill:#9b59b6,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Components fill:#9b59b6,stroke:#333,color:#fff
    style NSApps fill:#d5e8d4,stroke:#82b366
    style NSMon fill:#d5e8d4,stroke:#82b366
    style NSNotebooks fill:#d5e8d4,stroke:#82b366
