graph TB
    subgraph "odh-deployer (Init Container)"
        DeploySH["deploy.sh<br/>Main Entrypoint"]
        KfDefs["kfdefs/<br/>KfDef Manifests"]
        Monitoring["monitoring/<br/>Prometheus Stack"]
        Dashboard["odh-dashboard/<br/>Dashboard Config"]
        Network["network/<br/>NetworkPolicy"]
        PodSec["pod-security-rbac/<br/>SCC Bindings"]
        ConsoleLink["consolelink/<br/>ConsoleLink CR"]
        Partners["partners/<br/>Anaconda CE"]

        DeploySH -->|creates| KfDefs
        DeploySH -->|deploys| Monitoring
        DeploySH -->|applies CRDs & config| Dashboard
        DeploySH -->|applies| Network
        DeploySH -->|applies| PodSec
        DeploySH -->|creates| ConsoleLink
        DeploySH -->|creates secret| Partners
    end

    %% CRDs Applied
    subgraph "CRDs Applied"
        OdhApp["OdhApplication CR<br/>dashboard.opendatahub.io/v1"]
        OdhDoc["OdhDocument CR<br/>dashboard.opendatahub.io/v1"]
        OdhQS["OdhQuickStart CR<br/>console.openshift.io/v1"]
        OdhDC["OdhDashboardConfig CR<br/>opendatahub.io/v1alpha"]
    end

    Dashboard -->|applies| OdhApp
    Dashboard -->|applies| OdhDoc
    Dashboard -->|applies| OdhQS
    Dashboard -->|applies| OdhDC

    %% KfDef CRs Created
    subgraph "KfDef CRs (trigger operator)"
        KfDashboard["rhods-dashboard"]
        KfNBC["rhods-nbc"]
        KfModelMesh["rhods-model-mesh"]
        KfDSPO["rhods-data-science-pipelines-operator"]
        KfNotebooks["rhods-notebooks"]
        KfMonitoring["rhods-monitoring"]
        KfMMMonitoring["rhods-modelmesh-monitoring"]
        KfAnaconda["rhods-anaconda"]
    end

    KfDefs -->|creates| KfDashboard
    KfDefs -->|creates| KfNBC
    KfDefs -->|creates| KfModelMesh
    KfDefs -->|creates| KfDSPO
    KfDefs -->|creates| KfNotebooks
    KfDefs -->|creates| KfMonitoring
    KfDefs -->|creates| KfMMMonitoring
    KfDefs -->|creates| KfAnaconda

    %% Monitoring Stack Created
    subgraph "Monitoring Stack (redhat-ods-monitoring)"
        Prometheus["Prometheus<br/>9090/9091 TCP"]
        Alertmanager["Alertmanager<br/>9093/10443 TCP"]
        Blackbox["Blackbox Exporter<br/>9114/9115 TCP"]
    end

    Monitoring -->|deploys| Prometheus
    Monitoring -->|deploys| Alertmanager
    Monitoring -->|deploys| Blackbox

    %% External Dependencies
    RhodsOperator["rhods-operator<br/>(watches KfDefs)"]
    OdhManifests["odh-manifests<br/>(tarball)"]
    K8sAPI["OpenShift API Server"]
    ClusterProm["prometheus-k8s<br/>(openshift-monitoring)"]

    KfDashboard & KfNBC & KfModelMesh & KfDSPO & KfNotebooks & KfMonitoring & KfMMMonitoring & KfAnaconda -->|watched by| RhodsOperator
    RhodsOperator -->|extracts| OdhManifests
    DeploySH -->|oc apply via| K8sAPI
    Prometheus -->|federates from| ClusterProm

    %% Styling
    style DeploySH fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style KfDefs fill:#4a90e2,stroke:#333,color:#fff
    style Monitoring fill:#4a90e2,stroke:#333,color:#fff
    style Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style Network fill:#4a90e2,stroke:#333,color:#fff
    style PodSec fill:#4a90e2,stroke:#333,color:#fff
    style ConsoleLink fill:#4a90e2,stroke:#333,color:#fff
    style Partners fill:#4a90e2,stroke:#333,color:#fff

    style OdhApp fill:#f5a623,stroke:#333
    style OdhDoc fill:#f5a623,stroke:#333
    style OdhQS fill:#f5a623,stroke:#333
    style OdhDC fill:#f5a623,stroke:#333

    style RhodsOperator fill:#7ed321,stroke:#333
    style OdhManifests fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ClusterProm fill:#e8e8e8,stroke:#333

    style Prometheus fill:#d4526e,stroke:#333,color:#fff
    style Alertmanager fill:#d4526e,stroke:#333,color:#fff
    style Blackbox fill:#d4526e,stroke:#333,color:#fff
