graph TB
    subgraph DeployerContainer["odh-deployer Container (UBI8-minimal)"]
        DeployScript["deploy.sh<br/>Main Deployment Orchestrator"]
        OC_CLI["oc CLI<br/>OpenShift Client"]
        DeployScript -->|"executes"| OC_CLI
    end

    subgraph KfDefManifests["KfDef Manifests"]
        KfDashboard["rhods-dashboard.yaml"]
        KfNBC["rhods-nbc.yaml"]
        KfModelMesh["rhods-model-mesh.yaml"]
        KfDSPO["rhods-data-science-pipelines-operator.yaml"]
        KfMonitoring["rhods-monitoring.yaml"]
        KfNotebooks["rhods-notebooks.yaml"]
        KfAnaconda["rhods-anaconda.yaml"]
    end

    subgraph MonitoringStack["Prometheus Monitoring Stack"]
        Prometheus["Prometheus<br/>9090/TCP"]
        Alertmanager["Alertmanager<br/>9093/TCP"]
        BlackboxExporter["Blackbox Exporter<br/>9114/TCP"]
        OAuthProxyProm["OAuth Proxy<br/>9091/TCP HTTPS"]
        OAuthProxyAM["OAuth Proxy<br/>10443/TCP HTTPS"]
        Prometheus -->|"evaluates alerts"| Alertmanager
        Prometheus -->|"probes via"| BlackboxExporter
        OAuthProxyProm -->|"fronts"| Prometheus
        OAuthProxyAM -->|"fronts"| Alertmanager
    end

    subgraph DashboardConfig["Dashboard Configuration"]
        CRDs["CRDs<br/>(OdhApplication, OdhDocument,<br/>OdhQuickStart)"]
        ISVTiles["ISV Application Tiles<br/>(Jupyter, Anaconda, OpenVINO,<br/>Watson, AIKit)"]
        DashConfig["OdhDashboardConfig CR<br/>Feature flags, admin groups"]
        ServingRuntimes["ServingRuntime Templates<br/>(OVMS CPU + GPU)"]
    end

    subgraph NetworkPolicies["Network Policies"]
        AppNP["applications_network_policy"]
        MonNP["monitoring_network_policy"]
        OpNP["operator_network_policy"]
    end

    %% deploy.sh creates everything
    DeployScript -->|"creates namespaces<br/>(redhat-ods-applications,<br/>redhat-ods-monitoring,<br/>rhods-notebooks)"| Namespaces["Namespaces"]
    DeployScript -->|"applies"| KfDefManifests
    DeployScript -->|"deploys"| MonitoringStack
    DeployScript -->|"installs"| DashboardConfig
    DeployScript -->|"applies"| NetworkPolicies
    DeployScript -->|"creates"| ConsoleLink["ConsoleLink CR<br/>(App Launcher)"]

    %% KfDefs trigger the operator
    KfDefManifests -->|"watched by"| ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    ODHOperator -->|"installs from<br/>odh-manifests tarball"| Components["Platform Components"]

    %% External integrations (managed only)
    Alertmanager -.->|"443/TCP HTTPS<br/>Service Key"| PagerDuty["PagerDuty<br/>(managed only)"]
    Alertmanager -.->|"443/TCP HTTPS<br/>URL Token"| DMS["Dead Man's Snitch<br/>(managed only)"]
    Alertmanager -.->|"SMTP STARTTLS"| SMTPServer["SMTP Server<br/>(managed only)"]

    %% Prometheus scrapes
    Prometheus -->|"federates 9091/TCP"| ClusterProm["OpenShift Cluster<br/>Prometheus"]
    Prometheus -->|"scrapes 8080/TCP"| Components

    %% Styling
    style DeployScript fill:#4a90e2,stroke:#333,color:#fff
    style OC_CLI fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style BlackboxExporter fill:#e6522c,stroke:#333,color:#fff
    style OAuthProxyProm fill:#c0392b,stroke:#333,color:#fff
    style OAuthProxyAM fill:#c0392b,stroke:#333,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style PagerDuty fill:#999,stroke:#333,color:#fff
    style DMS fill:#999,stroke:#333,color:#fff
    style SMTPServer fill:#999,stroke:#333,color:#fff
    style ClusterProm fill:#999,stroke:#333,color:#fff
    style CRDs fill:#f5a623,stroke:#333,color:#fff
    style DashConfig fill:#f5a623,stroke:#333,color:#fff
    style ISVTiles fill:#f5a623,stroke:#333,color:#fff
    style ServingRuntimes fill:#f5a623,stroke:#333,color:#fff
    style ConsoleLink fill:#f5a623,stroke:#333,color:#fff
