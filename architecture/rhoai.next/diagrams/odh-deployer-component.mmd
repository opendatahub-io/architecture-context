graph TB
    subgraph DeployerPod["odh-deployer Container (UBI8-minimal + oc CLI)"]
        DeploySH["deploy.sh<br/>Bash Script<br/>Main Orchestrator"]
        KfDefManifests["KfDef Manifests<br/>Component Definitions"]
        MonitoringConfigs["Monitoring Configs<br/>Prometheus + Alertmanager YAML"]
        NetworkPolicies["Network Policies<br/>Namespace Isolation"]
        DashboardISVs["Dashboard ISVs<br/>Kustomize Overlays"]
        ModelServingTemplates["ServingRuntime Templates<br/>OVMS CPU/GPU"]
    end

    subgraph NamespacesCreated["Namespaces Created"]
        NSApps["redhat-ods-applications"]
        NSMon["redhat-ods-monitoring"]
        NSNotebooks["rhods-notebooks"]
    end

    subgraph CRDsApplied["CRDs Applied"]
        OdhApp["OdhApplication<br/>dashboard.opendatahub.io/v1alpha1"]
        OdhDoc["OdhDocument<br/>dashboard.opendatahub.io/v1alpha1"]
        OdhQS["OdhQuickStart<br/>console.openshift.io/v1"]
        OdhDC["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
    end

    subgraph MonitoringStack["Monitoring Stack (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>9090/TCP metrics<br/>9091/TCP OAuth proxy"]
        Alertmanager["Alertmanager<br/>9093/TCP<br/>10443/TCP OAuth proxy"]
        BlackboxExporter["Blackbox Exporter<br/>9114/TCP TLS"]
        OAuthProxy1["OAuth Proxy<br/>(Prometheus)"]
        OAuthProxy2["OAuth Proxy<br/>(Alertmanager)"]
    end

    subgraph ComponentsDeployed["Components Deployed via KfDef"]
        Dashboard["RHODS Dashboard"]
        NotebookCtrl["ODH Notebook Controller"]
        ModelMesh["ModelMesh Serving"]
        DSPO["Data Science Pipelines Operator"]
        AnacondaCE["Anaconda CE"]
    end

    %% Deploy.sh orchestrates everything
    DeploySH -->|"creates"| NSApps
    DeploySH -->|"creates"| NSMon
    DeploySH -->|"creates"| NSNotebooks
    DeploySH -->|"oc apply"| KfDefManifests
    DeploySH -->|"oc apply"| MonitoringConfigs
    DeploySH -->|"oc apply"| NetworkPolicies
    DeploySH -->|"oc apply"| DashboardISVs
    DeploySH -->|"oc apply"| ModelServingTemplates

    %% KfDef triggers operator
    KfDefManifests -->|"triggers"| ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    ODHOperator -->|"installs"| Dashboard
    ODHOperator -->|"installs"| NotebookCtrl
    ODHOperator -->|"installs"| ModelMesh
    ODHOperator -->|"installs"| DSPO
    ODHOperator -->|"installs"| AnacondaCE

    %% CRDs applied to dashboard
    DashboardISVs -->|"creates"| OdhApp
    DashboardISVs -->|"creates"| OdhDoc
    DashboardISVs -->|"creates"| OdhQS
    DashboardISVs -->|"creates"| OdhDC

    %% Monitoring stack
    MonitoringConfigs -->|"deploys"| Prometheus
    MonitoringConfigs -->|"deploys"| Alertmanager
    MonitoringConfigs -->|"deploys"| BlackboxExporter
    Prometheus --- OAuthProxy1
    Alertmanager --- OAuthProxy2

    %% Environment detection
    EnvDetect{{"Environment Detection<br/>addon-managed-odh-catalog<br/>CatalogSource?"}}
    DeploySH -->|"checks"| EnvDetect
    EnvDetect -->|"Managed (OSD)"| ManagedPath["PagerDuty + DMS + SMTP<br/>dedicated-admins RBAC<br/>NVIDIA/RHOAM/Starburst Galaxy ISVs"]
    EnvDetect -->|"Self-Managed"| SelfManagedPath["rhods-admins group<br/>Starburst Enterprise ISVs<br/>Simplified monitoring"]

    %% Styling
    style DeploySH fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ODHOperator fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style BlackboxExporter fill:#e6522c,stroke:#333,color:#fff
    style OAuthProxy1 fill:#f5a623,stroke:#333
    style OAuthProxy2 fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style NotebookCtrl fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style AnacondaCE fill:#7ed321,stroke:#333
    style OdhApp fill:#f5a623,stroke:#333
    style OdhDoc fill:#f5a623,stroke:#333
    style OdhQS fill:#f5a623,stroke:#333
    style OdhDC fill:#f5a623,stroke:#333
    style NSApps fill:#d5e8d4,stroke:#82b366
    style NSMon fill:#d5e8d4,stroke:#82b366
    style NSNotebooks fill:#d5e8d4,stroke:#82b366
    style ManagedPath fill:#ffe6cc,stroke:#d79b00
    style SelfManagedPath fill:#dae8fc,stroke:#6c8ebf
    style EnvDetect fill:#fff2cc,stroke:#d6b656
