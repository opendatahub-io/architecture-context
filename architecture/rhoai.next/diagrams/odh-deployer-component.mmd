graph TB
    subgraph DeployerContainer["odh-deployer (Init Container)"]
        DeploySH["deploy.sh<br/>Main Entrypoint"]
        DeploySH -->|applies| KfDefManifests["kfdefs/<br/>8 KfDef CRs"]
        DeploySH -->|applies| MonitoringManifests["monitoring/<br/>Prometheus Stack"]
        DeploySH -->|applies| DashboardConfig["odh-dashboard/<br/>CRDs + Config"]
        DeploySH -->|applies| NetworkPolicies["network/<br/>NetworkPolicies"]
        DeploySH -->|applies| PodSecRBAC["pod-security-rbac/<br/>SCC Bindings"]
        DeploySH -->|applies| ConsoleLink["consolelink/<br/>ConsoleLink CR"]
        DeploySH -->|applies| Partners["partners/<br/>Anaconda CE"]
    end

    subgraph KfDefCRs["KfDef Custom Resources"]
        KfDashboard["rhods-dashboard<br/>KfDef"]
        KfNBC["rhods-nbc<br/>KfDef"]
        KfModelMesh["rhods-model-mesh<br/>KfDef"]
        KfDSPO["rhods-dspo<br/>KfDef"]
        KfNotebooks["rhods-notebooks<br/>KfDef"]
        KfMonitoring["rhods-monitoring<br/>KfDef"]
        KfMMMonitoring["rhods-modelmesh-monitoring<br/>KfDef"]
        KfAnaconda["rhods-anaconda<br/>KfDef"]
    end

    subgraph MonitoringStack["Monitoring Stack (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>+ oauth-proxy"]
        Alertmanager["Alertmanager<br/>+ oauth-proxy"]
        Blackbox["Blackbox Exporter<br/>+ oauth-proxy"]
        Prometheus -->|alerts to| Alertmanager
        Prometheus -->|probes via| Blackbox
    end

    subgraph CRDs["Dashboard CRDs (Applied)"]
        OdhApp["OdhApplication"]
        OdhDoc["OdhDocument"]
        OdhQS["OdhQuickStart"]
        OdhDC["OdhDashboardConfig"]
    end

    subgraph Namespaces["Created Namespaces"]
        NSApps["redhat-ods-applications"]
        NSMon["redhat-ods-monitoring"]
        NSNotebooks["rhods-notebooks"]
    end

    %% Relationships
    KfDefManifests --> KfDashboard
    KfDefManifests --> KfNBC
    KfDefManifests --> KfModelMesh
    KfDefManifests --> KfDSPO
    KfDefManifests --> KfNotebooks
    KfDefManifests --> KfMonitoring
    KfDefManifests --> KfMMMonitoring
    KfDefManifests --> KfAnaconda

    DashboardConfig --> CRDs

    MonitoringManifests --> MonitoringStack

    DeploySH -->|creates| Namespaces

    %% External dependencies
    KfDefCRs -->|watched by| Operator["rhods-operator"]
    Operator -->|deploys from| Manifests["odh-manifests<br/>(tarball)"]
    DeploySH -->|uses| OC["oc CLI"]
    DeploySH -->|runs on| K8sAPI["OpenShift API Server"]

    %% Managed service extras
    Alertmanager -.->|critical alerts| PagerDuty["PagerDuty"]
    Alertmanager -.->|heartbeat| DMS["Dead Man's Snitch"]
    Alertmanager -.->|user emails| SMTP["SMTP Server"]

    %% Styling
    style DeploySH fill:#4a90e2,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style Blackbox fill:#e6522c,stroke:#333,color:#fff
    style OC fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Manifests fill:#999,stroke:#333
    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style OdhApp fill:#b8e986,stroke:#333
    style OdhDoc fill:#b8e986,stroke:#333
    style OdhQS fill:#b8e986,stroke:#333
    style OdhDC fill:#b8e986,stroke:#333
