graph TB
    subgraph DeployerContainer["odh-deployer Container (Init Container)"]
        DeployScript["deploy.sh<br/>Main Orchestrator<br/>(Bash)"]
        OcCLI["oc CLI<br/>OpenShift Client"]
        OpenSSL["openssl<br/>Secret Generation"]
        DeployScript -->|"executes"| OcCLI
        DeployScript -->|"generates secrets"| OpenSSL
    end

    subgraph KfDefManifests["KfDef Custom Resources"]
        KfDashboard["rhods-dashboard<br/>KfDef"]
        KfNBC["rhods-nbc<br/>KfDef"]
        KfModelMesh["rhods-model-mesh<br/>KfDef"]
        KfDSPO["rhods-dspo<br/>KfDef"]
        KfNotebooks["rhods-notebooks<br/>KfDef"]
        KfMonitoring["rhods-monitoring<br/>KfDef"]
        KfAnaconda["rhods-anaconda<br/>KfDef"]
        KfOSDConfigs["rhods-osd-configs<br/>KfDef"]
    end

    subgraph MonitoringStack["Prometheus Monitoring Stack"]
        Prometheus["Prometheus<br/>9091/TCP HTTPS"]
        Alertmanager["Alertmanager<br/>443/TCP HTTPS"]
        BlackboxExporter["Blackbox Exporter<br/>9114/TCP HTTPS"]
        OAuthProxy1["OAuth Proxy<br/>(Prometheus)"]
        OAuthProxy2["OAuth Proxy<br/>(Alertmanager)"]
        OAuthProxy3["OAuth Proxy<br/>(Blackbox)"]
        Prometheus --- OAuthProxy1
        Alertmanager --- OAuthProxy2
        BlackboxExporter --- OAuthProxy3
    end

    subgraph DashboardResources["Dashboard Resources"]
        CRDs["CRDs<br/>OdhApplication<br/>OdhDocument<br/>OdhQuickStart<br/>OdhDashboardConfig"]
        ISVTiles["ISV Application Tiles<br/>(Jupyter, Anaconda,<br/>OpenVINO, Watson)"]
        ConsoleLink["ConsoleLink CR"]
    end

    subgraph NetworkPolicies["Network Policies"]
        AppNP["applications<br/>network policy"]
        MonNP["monitoring<br/>network policy"]
        OpNP["operator<br/>network policy"]
    end

    %% Deploy script creates all resources
    DeployScript -->|"oc apply"| KfDashboard
    DeployScript -->|"oc apply"| KfNBC
    DeployScript -->|"oc apply"| KfModelMesh
    DeployScript -->|"oc apply"| KfDSPO
    DeployScript -->|"oc apply"| KfNotebooks
    DeployScript -->|"oc apply"| KfMonitoring
    DeployScript -->|"oc apply"| KfAnaconda
    DeployScript -->|"oc apply"| KfOSDConfigs
    DeployScript -->|"deploys"| Prometheus
    DeployScript -->|"deploys"| Alertmanager
    DeployScript -->|"deploys"| BlackboxExporter
    DeployScript -->|"installs"| CRDs
    DeployScript -->|"applies"| ISVTiles
    DeployScript -->|"creates"| ConsoleLink
    DeployScript -->|"applies"| AppNP
    DeployScript -->|"applies"| MonNP
    DeployScript -->|"applies"| OpNP

    %% External systems
    RHODSOperator["rhods-operator<br/>(KfDef Controller)"]
    K8sAPI["OpenShift<br/>API Server"]
    OSConsole["OpenShift<br/>Console"]

    KfDashboard -->|"reconciled by"| RHODSOperator
    KfNBC -->|"reconciled by"| RHODSOperator
    KfModelMesh -->|"reconciled by"| RHODSOperator
    KfDSPO -->|"reconciled by"| RHODSOperator
    KfNotebooks -->|"reconciled by"| RHODSOperator
    KfMonitoring -->|"reconciled by"| RHODSOperator
    KfAnaconda -->|"reconciled by"| RHODSOperator
    OcCLI -->|"443/TCP HTTPS"| K8sAPI
    ConsoleLink -->|"adds launcher link"| OSConsole

    %% Styling
    style DeployScript fill:#4a90e2,stroke:#333,color:#fff
    style OcCLI fill:#4a90e2,stroke:#333,color:#fff
    style OpenSSL fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#e8744f,stroke:#333,color:#fff
    style Alertmanager fill:#e8744f,stroke:#333,color:#fff
    style BlackboxExporter fill:#e8744f,stroke:#333,color:#fff
    style CRDs fill:#f5a623,stroke:#333
    style ISVTiles fill:#f5a623,stroke:#333
    style ConsoleLink fill:#f5a623,stroke:#333
    style RHODSOperator fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OSConsole fill:#999,stroke:#333,color:#fff
    style AppNP fill:#b8d4e3,stroke:#333
    style MonNP fill:#b8d4e3,stroke:#333
    style OpNP fill:#b8d4e3,stroke:#333
