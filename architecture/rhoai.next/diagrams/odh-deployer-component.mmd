graph TB
    subgraph "odh-deployer Container (UBI8-minimal)"
        direction TB
        DeploySH["deploy.sh<br/>(Main Entry Point)"]

        subgraph "KfDef Manifests"
            KfDashboard[rhods-dashboard.yaml]
            KfNBC[rhods-nbc.yaml]
            KfModelMesh[rhods-model-mesh.yaml]
            KfDSPO[rhods-data-science-pipelines-operator.yaml]
            KfNotebooks[rhods-notebooks.yaml]
            KfMonitoring[rhods-monitoring.yaml]
            KfAnaconda[rhods-anaconda.yaml]
        end

        subgraph "Monitoring Stack"
            PromManifest[prometheus.yaml]
            AlertMgrManifest[alertmanager-svc.yaml]
            BlackboxManifest[blackbox-exporter-*.yaml]
            PromConfigs[prometheus-configs.yaml<br/>SLO Burn Rate Alerts]
        end

        subgraph "Dashboard Config"
            DashCRDs[Dashboard CRDs<br/>OdhApplication, OdhDocument,<br/>OdhQuickStart, OdhDashboardConfig]
            ISVTiles[ISV Application Tiles<br/>Jupyter, Anaconda, OpenVINO,<br/>Pachyderm, Watson]
            ServingRT[Serving Runtime Templates<br/>OVMS CPU + GPU]
        end

        subgraph "Network & RBAC"
            NetPolicies[NetworkPolicies<br/>applications, monitoring, operator]
            SCCBindings[SCC RoleBindings<br/>anyuid grants]
        end
    end

    %% Environment Detection
    CatalogCheck{addon-managed-odh-catalog<br/>CatalogSource present?}
    DeploySH -->|checks| CatalogCheck
    CatalogCheck -->|Yes| ManagedPath["Managed Service Path<br/>(OSD/Addon)"]
    CatalogCheck -->|No| SelfManagedPath["Self-Managed Path<br/>(On-Prem)"]

    %% Deploy.sh creates namespaces
    DeploySH -->|creates| NS_Apps["Namespace:<br/>redhat-ods-applications"]
    DeploySH -->|creates| NS_Mon["Namespace:<br/>redhat-ods-monitoring"]
    DeploySH -->|creates| NS_NB["Namespace:<br/>rhods-notebooks"]

    %% Deploy.sh applies manifests
    DeploySH -->|applies| KfDashboard
    DeploySH -->|applies| KfNBC
    DeploySH -->|applies| KfModelMesh
    DeploySH -->|applies| KfDSPO
    DeploySH -->|applies| KfNotebooks
    DeploySH -->|applies| PromManifest
    DeploySH -->|applies| DashCRDs
    DeploySH -->|applies| NetPolicies

    %% KfDef CRs trigger operator
    KfDashboard -->|triggers| ODHOperator["opendatahub operator<br/>(KfDef Controller)"]
    KfNBC -->|triggers| ODHOperator
    KfModelMesh -->|triggers| ODHOperator
    KfDSPO -->|triggers| ODHOperator
    KfNotebooks -->|triggers| ODHOperator
    KfMonitoring -->|triggers| ODHOperator
    KfAnaconda -->|triggers| ODHOperator

    %% Operator deploys components
    ODHOperator -->|deploys| Dashboard[rhods-dashboard]
    ODHOperator -->|deploys| NBC[odh-notebook-controller]
    ODHOperator -->|deploys| ModelMesh[modelmesh-controller]
    ODHOperator -->|deploys| ModelCtrl[odh-model-controller]
    ODHOperator -->|deploys| DSPO[data-science-pipelines-operator]

    %% External integration
    DeploySH -->|interacts via oc CLI| K8sAPI["OpenShift API Server<br/>443/TCP HTTPS"]

    %% Styling
    style DeploySH fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style CatalogCheck fill:#f5a623,stroke:#333
    style ManagedPath fill:#e8744f,stroke:#333,color:#fff
    style SelfManagedPath fill:#9b59b6,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333
    style NS_Apps fill:#d5e8d4,stroke:#82b366
    style NS_Mon fill:#d5e8d4,stroke:#82b366
    style NS_NB fill:#d5e8d4,stroke:#82b366
    style Dashboard fill:#7ed321,stroke:#333
    style NBC fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style ModelCtrl fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
