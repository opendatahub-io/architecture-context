graph TB
    subgraph DeployerContainer["odh-deployer Container (Init Container)"]
        DeploySH["deploy.sh<br/>Main Deployment Script<br/>(Bash)"]
        Manifests["Manifest Files<br/>(KfDef YAML, CRDs,<br/>Kustomize Overlays)"]
        OC["oc CLI<br/>(OpenShift Client)"]

        DeploySH -->|reads| Manifests
        DeploySH -->|executes| OC
    end

    subgraph KfDefCRs["KfDef Custom Resources"]
        KfDashboard["rhods-dashboard<br/>KfDef"]
        KfNBC["rhods-nbc<br/>KfDef"]
        KfModelMesh["rhods-model-mesh<br/>KfDef"]
        KfDSPO["rhods-data-science-<br/>pipelines-operator KfDef"]
        KfMonitoring["rhods-monitoring<br/>KfDef"]
        KfAnaconda["rhods-anaconda<br/>KfDef"]
    end

    subgraph DashboardCRDs["Dashboard CRDs"]
        OdhApp["OdhApplication CRs<br/>(ISV Tiles)"]
        OdhDoc["OdhDocument CRs<br/>(Documentation)"]
        OdhQS["OdhQuickStart CRs<br/>(Guided Workflows)"]
        OdhConfig["OdhDashboardConfig CR<br/>(Feature Flags)"]
    end

    subgraph MonitoringStack["Monitoring Stack"]
        Prometheus["Prometheus<br/>9091/TCP HTTPS"]
        Alertmanager["Alertmanager<br/>443/TCP HTTPS"]
        Blackbox["Blackbox Exporter<br/>9114/TCP HTTPS"]

        Prometheus -->|alerts| Alertmanager
        Prometheus -->|probes via| Blackbox
    end

    subgraph SecurityResources["Security & Network"]
        NetPol["NetworkPolicies<br/>(applications, monitoring,<br/>operator namespaces)"]
        PodSec["Pod Security RBAC<br/>(anyuid SCC bindings)"]
    end

    %% Deploy script creates resources
    DeploySH -->|creates| KfDashboard
    DeploySH -->|creates| KfNBC
    DeploySH -->|creates| KfModelMesh
    DeploySH -->|creates| KfDSPO
    DeploySH -->|creates| KfMonitoring
    DeploySH -->|creates| KfAnaconda
    DeploySH -->|applies| OdhApp
    DeploySH -->|applies| OdhDoc
    DeploySH -->|applies| OdhQS
    DeploySH -->|applies| OdhConfig
    DeploySH -->|deploys| Prometheus
    DeploySH -->|deploys| Alertmanager
    DeploySH -->|deploys| Blackbox
    DeploySH -->|applies| NetPol
    DeploySH -->|applies| PodSec

    %% Operator reconciles KfDefs
    Operator["rhods-operator<br/>(opendatahub operator)"]
    KfDashboard -->|reconciled by| Operator
    KfNBC -->|reconciled by| Operator
    KfModelMesh -->|reconciled by| Operator
    KfDSPO -->|reconciled by| Operator
    KfMonitoring -->|reconciled by| Operator
    KfAnaconda -->|reconciled by| Operator

    %% External alerting (managed service)
    Alertmanager -->|critical alerts| PagerDuty["PagerDuty API"]
    Alertmanager -->|notifications| SMTP["SMTP Server"]
    Alertmanager -->|heartbeat| DMS["Dead Man's Snitch"]

    %% Styling
    style DeploySH fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Manifests fill:#4a90e2,stroke:#333,color:#fff
    style OC fill:#4a90e2,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style Blackbox fill:#e6522c,stroke:#333,color:#fff
    style KfDashboard fill:#f5a623,stroke:#333
    style KfNBC fill:#f5a623,stroke:#333
    style KfModelMesh fill:#f5a623,stroke:#333
    style KfDSPO fill:#f5a623,stroke:#333
    style KfMonitoring fill:#f5a623,stroke:#333
    style KfAnaconda fill:#f5a623,stroke:#333
    style OdhApp fill:#9b59b6,stroke:#333,color:#fff
    style OdhDoc fill:#9b59b6,stroke:#333,color:#fff
    style OdhQS fill:#9b59b6,stroke:#333,color:#fff
    style OdhConfig fill:#9b59b6,stroke:#333,color:#fff
    style NetPol fill:#3498db,stroke:#333,color:#fff
    style PodSec fill:#3498db,stroke:#333,color:#fff
    style PagerDuty fill:#999,stroke:#333
    style SMTP fill:#999,stroke:#333
    style DMS fill:#999,stroke:#333
