graph TB
    subgraph LLMd["llm-d Integration Stack"]
        direction TB

        subgraph ContainerImages["Container Images"]
            CUDA["llm-d-cuda<br/>NVIDIA GPU Image<br/>(vLLM + NIXL + UCX + NVSHMEM<br/>+ DeepEP + DeepGEMM + FlashInfer<br/>+ LMCache + OTEL)"]
            CPU["llm-d-cpu<br/>CPU-Only Image<br/>(vLLM + NIXL + UCX)"]
            HPU["llm-d-hpu<br/>Intel Gaudi Image<br/>(vLLM-Gaudi + NIXL)"]
            ROCm["llm-d-rocm<br/>AMD ROCm Image<br/>(vLLM + RIXL + UCX)"]
            RDMATools["llm-d-rdma-tools<br/>Diagnostic Image<br/>(iperf3, perftest, NCCL tests)"]
        end

        subgraph DeploymentRecipes["Deployment Recipes (Kustomize)"]
            SingleHost["Single-Host<br/>Decode Deployment"]
            PDBase["P/D Disaggregation<br/>Prefill + Decode"]
            WideEP["Wide Expert-Parallelism<br/>(LeaderWorkerSet)"]
        end

        subgraph GatewayRecipes["Gateway Recipes"]
            IstioGW["Istio Gateway"]
            KGatewayGW["agentgateway"]
            GKEGW["GKE Gateway"]
        end

        subgraph SchedulerConfig["Scheduler Configuration"]
            HelmValues["Helm Values<br/>(EPP plugin chains,<br/>scoring profiles)"]
        end
    end

    subgraph RuntimeComponents["Runtime Components (External)"]
        vLLM["vLLM Model Server<br/>8000/TCP HTTP<br/>(OpenAI-compatible API)"]
        EPP["llm-d-inference-scheduler<br/>(EPP)<br/>9002/TCP gRPC"]
        RoutingSidecar["llm-d-routing-sidecar<br/>8000/TCP HTTP<br/>(P/D coordination)"]
    end

    subgraph K8sAPIs["Kubernetes CRDs (Consumed)"]
        GatewayCR["Gateway<br/>gateway.networking.k8s.io"]
        HTTPRoute["HTTPRoute<br/>gateway.networking.k8s.io"]
        InfPool["InferencePool<br/>inference.networking.x-k8s.io"]
        InfObj["InferenceObjective<br/>inference.networking.x-k8s.io"]
        LWS["LeaderWorkerSet<br/>leaderworkerset.x-k8s.io"]
    end

    Client["External Client"] -->|HTTP/80| GatewayCR
    GatewayCR -->|routes via| HTTPRoute
    HTTPRoute -->|selects| InfPool
    InfPool -->|configures| EPP
    EPP -->|scores & routes| vLLM
    InfObj -->|flow control| EPP

    CUDA -->|builds| vLLM
    CPU -->|builds| vLLM
    HPU -->|builds| vLLM
    ROCm -->|builds| vLLM

    PDBase -->|deploys| RoutingSidecar
    WideEP -->|deploys via| LWS
    HelmValues -->|configures| EPP

    IstioGW -->|implements| GatewayCR
    KGatewayGW -->|implements| GatewayCR
    GKEGW -->|implements| GatewayCR

    %% Styling
    style CUDA fill:#76b900,stroke:#333,color:#000
    style CPU fill:#4a90e2,stroke:#333,color:#fff
    style HPU fill:#0071c5,stroke:#333,color:#fff
    style ROCm fill:#ed1c24,stroke:#333,color:#fff
    style RDMATools fill:#999,stroke:#333,color:#fff
    style vLLM fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style EPP fill:#f5a623,stroke:#333,color:#000
    style RoutingSidecar fill:#f5a623,stroke:#333,color:#000
    style GatewayCR fill:#9b59b6,stroke:#333,color:#fff
    style HTTPRoute fill:#9b59b6,stroke:#333,color:#fff
    style InfPool fill:#9b59b6,stroke:#333,color:#fff
    style InfObj fill:#9b59b6,stroke:#333,color:#fff
    style LWS fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333,color:#000
