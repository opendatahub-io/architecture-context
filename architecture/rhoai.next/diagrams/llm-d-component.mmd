graph TB
    subgraph "llm-d Integration Stack"
        direction TB

        subgraph "Container Images"
            CUDA["llm-d-cuda<br/>NVIDIA GPU Image<br/>(vLLM + NIXL + UCX + NVSHMEM<br/>+ DeepEP + DeepGEMM + FlashInfer<br/>+ LMCache + OTEL)"]
            CPU["llm-d-cpu<br/>CPU-Only Image<br/>(vLLM + NIXL + UCX)"]
            HPU["llm-d-hpu<br/>Intel Gaudi Image<br/>(vLLM-Gaudi + NIXL)"]
            ROCm["llm-d-rocm<br/>AMD ROCm Image<br/>(vLLM + RIXL + UCX)"]
            RDMATools["llm-d-rdma-tools<br/>Diagnostic Image<br/>(iperf3, perftest, NCCL tests)"]
        end

        subgraph "Deployment Recipes"
            BaseRecipes["Kustomize Bases<br/>(single-host, P/D, wide-EP)"]
            GatewayRecipes["Gateway Recipes<br/>(Istio, kgateway, agentgateway, GKE)"]
            SchedulerValues["Scheduler Helm Values<br/>(EPP plugin chains, scoring profiles)"]
        end

        subgraph "Well-Lit Path Guides"
            OptBaseline["Optimized Baseline"]
            PDDisagg["P/D Disaggregation"]
            WideEP["Wide Expert-Parallelism"]
            TieredCache["Tiered KV Cache"]
            PredLatency["Predicted Latency Scheduling"]
            FlowCtrl["Flow Control"]
            WkldAutoscale["Workload Autoscaling"]
        end
    end

    %% CRDs consumed
    GatewayCR["Gateway CR<br/>(gateway.networking.k8s.io/v1)"]
    HTTPRouteCR["HTTPRoute CR<br/>(gateway.networking.k8s.io/v1)"]
    InferencePoolCR["InferencePool CR<br/>(inference.networking.x-k8s.io)"]
    InferenceObjCR["InferenceObjective CR<br/>(inference.networking.x-k8s.io)"]
    LWSCR["LeaderWorkerSet CR<br/>(leaderworkerset.x-k8s.io/v1)"]

    %% Runtime components (external)
    EPP["llm-d-inference-scheduler<br/>(EPP v0.8.0)"]
    RoutingSidecar["llm-d-routing-sidecar<br/>(v0.7.1)"]
    WVA["Workload Variant Autoscaler<br/>(ig-wva)"]

    %% Connections
    BaseRecipes -->|"deploys"| CUDA
    BaseRecipes -->|"deploys"| CPU
    BaseRecipes -->|"deploys"| HPU
    BaseRecipes -->|"deploys"| ROCm
    GatewayRecipes -->|"configures"| GatewayCR
    GatewayRecipes -->|"configures"| HTTPRouteCR
    SchedulerValues -->|"configures"| EPP
    BaseRecipes -->|"references"| InferencePoolCR
    PDDisagg -->|"uses"| RoutingSidecar
    WideEP -->|"uses"| LWSCR
    FlowCtrl -->|"uses"| InferenceObjCR
    WkldAutoscale -->|"uses"| WVA

    %% Guide to recipe connections
    OptBaseline -->|"combines"| BaseRecipes
    PDDisagg -->|"combines"| BaseRecipes
    WideEP -->|"combines"| BaseRecipes
    TieredCache -->|"combines"| BaseRecipes
    PredLatency -->|"combines"| BaseRecipes
    FlowCtrl -->|"combines"| BaseRecipes
    WkldAutoscale -->|"combines"| BaseRecipes

    %% Styling
    style CUDA fill:#4a90e2,stroke:#333,color:#fff
    style CPU fill:#4a90e2,stroke:#333,color:#fff
    style HPU fill:#4a90e2,stroke:#333,color:#fff
    style ROCm fill:#4a90e2,stroke:#333,color:#fff
    style RDMATools fill:#7f8c8d,stroke:#333,color:#fff
    style BaseRecipes fill:#f5a623,stroke:#333,color:#000
    style GatewayRecipes fill:#f5a623,stroke:#333,color:#000
    style SchedulerValues fill:#f5a623,stroke:#333,color:#000
    style EPP fill:#7ed321,stroke:#333,color:#000
    style RoutingSidecar fill:#7ed321,stroke:#333,color:#000
    style WVA fill:#7ed321,stroke:#333,color:#000
    style GatewayCR fill:#e8e8e8,stroke:#666
    style HTTPRouteCR fill:#e8e8e8,stroke:#666
    style InferencePoolCR fill:#e8e8e8,stroke:#666
    style InferenceObjCR fill:#e8e8e8,stroke:#666
    style LWSCR fill:#e8e8e8,stroke:#666
