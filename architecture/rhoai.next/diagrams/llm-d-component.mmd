graph TB
    subgraph "llm-d Integration Stack"
        direction TB

        subgraph "Container Images"
            CUDA["llm-d-cuda<br/>NVIDIA GPU Image<br/>(vLLM + NIXL + UCX + NVSHMEM<br/>+ DeepEP + DeepGEMM<br/>+ FlashInfer + LMCache + OTEL)"]
            CPU["llm-d-cpu<br/>CPU-Only Image<br/>(vLLM + NIXL + UCX)"]
            HPU["llm-d-hpu<br/>Intel Gaudi Image<br/>(vLLM-Gaudi + NIXL)"]
            ROCm["llm-d-rocm<br/>AMD ROCm Image<br/>(vLLM + RIXL + UCX)"]
            RDMATools["llm-d-rdma-tools<br/>Diagnostic Image<br/>(iperf3, perftest, NCCL tests)"]
        end

        subgraph "Deployment Recipes (Kustomize)"
            SingleHost["Single-Host<br/>Decode Deployment"]
            PD["Prefill/Decode<br/>Disaggregation"]
            WideEP["Wide Expert-Parallelism<br/>(LeaderWorkerSet)"]
        end

        subgraph "Gateway Recipes"
            IstioGW["Istio Gateway"]
            KGatewayGW["agentgateway"]
            GKEGW["GKE Gateway"]
        end

        subgraph "Scheduler Configuration"
            SchedulerValues["EPP Helm Values<br/>(Scoring, Filtering,<br/>Scheduling Profiles)"]
        end
    end

    %% External Runtime Components
    Client[External Client] -->|HTTP/80| Gateway["Gateway API<br/>(Gateway CR + HTTPRoute)"]
    Gateway -->|gRPC/9002<br/>ext_proc| EPP["llm-d-inference-scheduler<br/>(EPP)"]
    EPP -->|HTTP/8000| vLLM["vLLM Model Server<br/>(inside llm-d image)"]

    %% CRDs consumed
    InferencePool["InferencePool CR"] -.->|selects pods| EPP
    InferenceObjective["InferenceObjective CR"] -.->|flow control| EPP
    LWS["LeaderWorkerSet CR"] -.->|multi-node groups| WideEP

    %% Internal data paths
    vLLM -->|NIXL/5600<br/>RDMA/TCP| vLLM2["vLLM Peer Instance<br/>(KV Cache Transfer)"]
    RoutingSidecar["llm-d-routing-sidecar<br/>(init container)"] -->|HTTP/8200| vLLM

    %% Observability
    vLLM -->|metrics/8000| Prometheus["Prometheus"]
    vLLM -->|OTLP/4317| OTELCollector["OTEL Collector"]

    %% Model download
    vLLM -->|HTTPS/443| HFHub["HuggingFace Hub"]

    %% Styling
    style CUDA fill:#76b900,stroke:#333,color:#000
    style CPU fill:#4a90e2,stroke:#333,color:#000
    style HPU fill:#0071c5,stroke:#333,color:#fff
    style ROCm fill:#ed1c24,stroke:#333,color:#fff
    style RDMATools fill:#999,stroke:#333,color:#000
    style SingleHost fill:#d5e8d4,stroke:#82b366
    style PD fill:#d5e8d4,stroke:#82b366
    style WideEP fill:#d5e8d4,stroke:#82b366
    style IstioGW fill:#466bb0,stroke:#333,color:#fff
    style KGatewayGW fill:#466bb0,stroke:#333,color:#fff
    style GKEGW fill:#466bb0,stroke:#333,color:#fff
    style SchedulerValues fill:#fff2cc,stroke:#d6b656
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style EPP fill:#f5a623,stroke:#333,color:#000
    style vLLM fill:#76b900,stroke:#333,color:#000
    style vLLM2 fill:#76b900,stroke:#333,color:#000
    style RoutingSidecar fill:#f5a623,stroke:#333,color:#000
    style InferencePool fill:#e1d5e7,stroke:#9673a6
    style InferenceObjective fill:#e1d5e7,stroke:#9673a6
    style LWS fill:#e1d5e7,stroke:#9673a6
    style Prometheus fill:#e8e8e8,stroke:#999
    style OTELCollector fill:#e8e8e8,stroke:#999
    style HFHub fill:#e8e8e8,stroke:#999
    style Client fill:#f9f9f9,stroke:#999
