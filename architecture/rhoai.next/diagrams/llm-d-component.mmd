graph TB
    subgraph "llm-d Inference Stack"
        direction TB

        subgraph ProxyLayer["Layer 1: Proxy Layer"]
            Gateway["Gateway<br/>(Envoy / Istio / AgentGateway)<br/>Port: 80/443 TCP"]
            HTTPRoute["HTTPRoute<br/>(gateway.networking.k8s.io/v1)"]
            Gateway -->|routes via| HTTPRoute
        end

        subgraph EPPLayer["Layer 2: Endpoint Picker (EPP)"]
            EPP["llm-d-inference-scheduler<br/>(EPP)<br/>Port: 9002/TCP gRPC"]
            LatencyPredictor["Latency Predictor<br/>(XGBoost sidecar)"]
            KVIndexer["KV-Cache Indexer<br/>(ZMQ events)"]
            EPP --- LatencyPredictor
            EPP --- KVIndexer
        end

        subgraph PoolLayer["Layer 3: InferencePool"]
            InferencePool["InferencePool CR<br/>(inference.networking.k8s.io/v1)"]
            InferenceObjective["InferenceObjective CR<br/>(v1alpha2)"]
            InferencePool --- InferenceObjective
        end

        subgraph ModelServers["Layer 4: Model Servers"]
            direction LR
            subgraph DecodeGroup["Decode Pods"]
                DecodePod["Decode Pod<br/>vLLM :8000/TCP<br/>Routing Sidecar :8200/TCP"]
            end
            subgraph PrefillGroup["Prefill Pods (P/D mode)"]
                PrefillPod["Prefill Pod<br/>vLLM :8000/TCP<br/>NIXL :5600/TCP RDMA"]
            end
            DecodePod <-->|"RDMA KV Transfer<br/>5600/TCP (NIXL)"| PrefillPod
        end
    end

    subgraph ContainerImages["Container Images"]
        direction LR
        CUDAImg["llm-d-cuda<br/>NVIDIA GPU<br/>CUDA 13.0"]
        CPUImg["llm-d-cpu<br/>CPU x86/ARM"]
        ROCmImg["llm-d-rocm<br/>AMD ROCm"]
        HPUImg["llm-d-hpu<br/>Intel Gaudi"]
        RDMATools["llm-d-rdma-tools<br/>Diagnostics"]
    end

    Client["External Client"] -->|"HTTP/HTTPS<br/>80/443 TCP"| Gateway
    Gateway -->|"ext-proc gRPC<br/>9002/TCP"| EPP
    HTTPRoute -->|"backend ref"| InferencePool
    InferencePool -->|"pod selector"| DecodePod
    InferencePool -->|"pod selector"| PrefillPod
    EPP -->|"selects endpoint"| DecodePod
    KVIndexer -.->|"ZMQ events"| DecodePod
    KVIndexer -.->|"ZMQ events"| PrefillPod

    ContainerImages -.->|"deployed as"| ModelServers

    %% External services
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    OTelCollector["OpenTelemetry Collector<br/>4317/TCP gRPC"]
    Prometheus["Prometheus<br/>(PodMonitor scrape)"]

    DecodePod -->|"model download<br/>HF_TOKEN"| HFHub
    PrefillPod -->|"model download<br/>HF_TOKEN"| HFHub
    DecodePod -.->|"OTLP traces<br/>4317/TCP"| OTelCollector
    Prometheus -.->|"scrape /metrics<br/>8000/TCP"| DecodePod
    Prometheus -.->|"scrape /metrics<br/>8000/TCP"| PrefillPod

    %% Styling
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style InferenceObjective fill:#f5a623,stroke:#333,color:#fff
    style DecodePod fill:#7ed321,stroke:#333,color:#fff
    style PrefillPod fill:#7ed321,stroke:#333,color:#fff
    style LatencyPredictor fill:#9b59b6,stroke:#333,color:#fff
    style KVIndexer fill:#9b59b6,stroke:#333,color:#fff
    style CUDAImg fill:#76b900,stroke:#333,color:#fff
    style CPUImg fill:#3498db,stroke:#333,color:#fff
    style ROCmImg fill:#ed1c24,stroke:#333,color:#fff
    style HPUImg fill:#0071c5,stroke:#333,color:#fff
    style RDMATools fill:#95a5a6,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style HFHub fill:#ffd700,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style HTTPRoute fill:#f5a623,stroke:#333,color:#fff
