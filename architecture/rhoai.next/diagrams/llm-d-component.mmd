graph TB
    subgraph External["External Clients"]
        Client["Client Application<br/>(OpenAI-compatible API)"]
    end

    subgraph ProxyLayer["1. Proxy Layer"]
        Gateway["Gateway<br/>(Envoy / Gateway API)<br/>Port: 80/HTTP"]
        AG["agentgateway<br/>(Preferred)"]
        Istio["Istio<br/>(IngressGateway)"]
        GKEGw["GKE Gateway<br/>(Cloud-managed LB)"]
        AG -.- Gateway
        Istio -.- Gateway
        GKEGw -.- Gateway
    end

    subgraph EPPLayer["2. Endpoint Picker (EPP)"]
        direction TB
        ExtProc["Ext-Proc Server<br/>(gRPC bidirectional streaming)"]
        ReqHandler["Request Handler<br/>(OpenAI API Parser)"]
        FlowCtrl["Flow Control<br/>Priority Bands: Premium / Standard / Best-Effort<br/>Fairness: Round-Robin / Strict"]
        Scheduler["Scheduler Pipeline<br/>Filter → Score → Pick"]
        ExtProc --> ReqHandler
        ReqHandler --> FlowCtrl
        FlowCtrl --> Scheduler
    end

    subgraph SchedulerDetail["Scheduler Plugins"]
        direction LR
        Filters["Filters:<br/>prefix-cache-affinity<br/>slo-headroom-tier<br/>prefill/decode<br/>label-selector"]
        Scorers["Scorers:<br/>kv-cache-utilization<br/>queue-depth<br/>prefix-scorer<br/>lora-affinity<br/>latency-scorer<br/>session-affinity"]
        Pickers["Pickers:<br/>max-score<br/>random<br/>weighted-random"]
        Filters --> Scorers
        Scorers --> Pickers
    end

    subgraph PoolLayer["3. InferencePool (CRD)"]
        Pool["InferencePool<br/>(gateway.networking.k8s.io)<br/>Endpoint Discovery<br/>+ Gateway Integration"]
    end

    subgraph ModelLayer["4. Model Servers"]
        direction LR
        vLLM["vLLM<br/>(Primary Engine)<br/>Port: 8000/TCP"]
        SGLang["SGLang<br/>(Alternative Engine)<br/>Port: 8000/TCP"]
    end

    subgraph Accelerators["Accelerator Hardware"]
        direction LR
        NVIDIA["NVIDIA<br/>A100/H100/H200/B200"]
        AMD["AMD<br/>MI250X+"]
        IntelXPU["Intel XPU<br/>Max 1550+"]
        IntelHPU["Intel HPU<br/>Gaudi 1/2/3"]
        TPU["Google TPU<br/>v5e/v6e/v7"]
        CPU["CPU<br/>x86_64 Xeon"]
    end

    subgraph DataSources["EPP Data Sources"]
        Prometheus["Prometheus Metrics<br/>(Queue depth, KV cache %)"]
        K8sAPI["Kubernetes API<br/>(Pod lifecycle events)"]
        ZMQ["ZMQ Events<br/>(KV cache block events)<br/>Port: 5556"]
    end

    %% Main request flow
    Client -->|"OpenAI API<br/>HTTP/80"| Gateway
    Gateway -->|"ext-proc gRPC"| ExtProc
    Scheduler --> Pool
    Scheduler -.-> SchedulerDetail
    Pool -->|"label-based<br/>discovery"| vLLM
    Pool -->|"label-based<br/>discovery"| SGLang
    Gateway -->|"forwards request<br/>to selected endpoint"| vLLM
    Gateway -->|"forwards request<br/>to selected endpoint"| SGLang

    vLLM --> NVIDIA
    vLLM --> AMD
    vLLM --> IntelXPU
    vLLM --> IntelHPU
    vLLM --> TPU
    vLLM --> CPU
    SGLang --> NVIDIA

    %% Data source connections
    Prometheus -.->|"polling"| ExtProc
    K8sAPI -.->|"watch events"| ExtProc
    ZMQ -.->|"cache events"| ExtProc

    %% Styling
    style Client fill:#f9f9f9,stroke:#333,stroke-width:2px
    style Gateway fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ExtProc fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style ReqHandler fill:#e67e22,stroke:#333,stroke-width:1px,color:#fff
    style FlowCtrl fill:#e67e22,stroke:#333,stroke-width:1px,color:#fff
    style Scheduler fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style Pool fill:#f5a623,stroke:#333,stroke-width:2px
    style vLLM fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style SGLang fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style NVIDIA fill:#76b900,stroke:#333,stroke-width:1px
    style AMD fill:#ed1c24,stroke:#333,stroke-width:1px,color:#fff
    style IntelXPU fill:#0071c5,stroke:#333,stroke-width:1px,color:#fff
    style IntelHPU fill:#0071c5,stroke:#333,stroke-width:1px,color:#fff
    style TPU fill:#4285f4,stroke:#333,stroke-width:1px,color:#fff
    style CPU fill:#999,stroke:#333,stroke-width:1px
    style Prometheus fill:#e6522c,stroke:#333,stroke-width:1px,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff
    style ZMQ fill:#df0000,stroke:#333,stroke-width:1px,color:#fff
