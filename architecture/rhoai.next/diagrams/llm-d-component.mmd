graph TB
    subgraph "llm-d Inference Stack"
        direction TB

        subgraph BuildSystem["Container Image Build System"]
            DockerCuda["Dockerfile.cuda<br/>NVIDIA CUDA vLLM<br/>UCX, UCCL, NVSHMEM, NIXL,<br/>DeepEP, FlashInfer, LMCache"]
            DockerCPU["Dockerfile.cpu<br/>CPU-only vLLM<br/>NIXL, UCX"]
            DockerROCm["Dockerfile.rocm<br/>AMD ROCm vLLM<br/>RIXL, UCX, UCCL"]
            DockerXPU["Dockerfile.xpu<br/>Intel XPU vLLM"]
            DockerRDMA["Dockerfile.rdma-tools<br/>RDMA Diagnostics"]
        end

        subgraph RuntimeComponents["Runtime Components"]
            ModelServer["vLLM Model Server<br/>Port 8000/TCP<br/>OpenAI-compatible API"]
            EPP["llm-d-router EPP<br/>Endpoint Picker<br/>ext-proc (gRPC)"]
            Proxy["Envoy Proxy<br/>Sidecar or Gateway"]
        end

        subgraph KVCacheInfra["KV-Cache Infrastructure"]
            MooncakeMaster["Mooncake Master Store<br/>50051/TCP gRPC<br/>8080/TCP metadata<br/>9003/TCP metrics"]
            MooncakeClient["Mooncake Client<br/>DaemonSet<br/>50052/TCP gRPC + RDMA"]
            NIXL["NIXL KV Transfer<br/>5600/TCP gRPC<br/>P/D Disaggregation"]
        end

        subgraph DeploymentGuides["Kustomize Deployment Guides"]
            OptBaseline["Optimized Baseline"]
            PDDisagg["P/D Disaggregation"]
            PrefixCache["Prefix Cache Routing"]
            TieredCache["Tiered Prefix Cache"]
            WideEP["Wide Expert Parallelism"]
        end
    end

    subgraph External["External Dependencies"]
        Gateway["Kubernetes Gateway<br/>(Istio / agentgateway / Envoy AI)"]
        GatewayAPI["Gateway API CRDs<br/>InferencePool, HTTPRoute"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC"]
    end

    %% Build outputs
    DockerCuda -->|produces| ModelServer
    DockerCPU -->|produces| ModelServer
    DockerROCm -->|produces| ModelServer
    DockerXPU -->|produces| ModelServer

    %% Runtime flows
    Gateway -->|routes to| Proxy
    Proxy -->|ext-proc| EPP
    EPP -->|selects pod| ModelServer
    EPP -->|scrapes metrics| ModelServer

    %% KV-cache flows
    ModelServer -->|offload KV| MooncakeClient
    MooncakeClient -->|metadata| MooncakeMaster
    MooncakeClient -->|RDMA transfer| MooncakeClient
    ModelServer -->|KV transfer| NIXL

    %% External
    ModelServer -->|downloads models| HFHub
    Prometheus -->|scrapes| ModelServer
    Prometheus -->|scrapes| MooncakeMaster
    ModelServer -->|traces| OTEL
    GatewayAPI -->|configures| Gateway

    %% Deployment guides reference
    OptBaseline -.->|deploys| ModelServer
    PDDisagg -.->|deploys| ModelServer
    PDDisagg -.->|uses| NIXL
    TieredCache -.->|uses| MooncakeMaster

    %% Styling
    style DockerCuda fill:#76b900,stroke:#333,color:#000
    style DockerCPU fill:#0071c5,stroke:#333,color:#fff
    style DockerROCm fill:#ed1c24,stroke:#333,color:#fff
    style DockerXPU fill:#0071c5,stroke:#333,color:#fff
    style DockerRDMA fill:#999,stroke:#333,color:#000
    style ModelServer fill:#4a90e2,stroke:#333,color:#fff
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style MooncakeMaster fill:#9b59b6,stroke:#333,color:#fff
    style MooncakeClient fill:#9b59b6,stroke:#333,color:#fff
    style NIXL fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333,color:#000
    style GatewayAPI fill:#e8e8e8,stroke:#333,color:#000
    style HFHub fill:#f5a623,stroke:#333,color:#000
    style Prometheus fill:#e8e8e8,stroke:#333,color:#000
    style OTEL fill:#e8e8e8,stroke:#333,color:#000
    style OptBaseline fill:#d5e8d4,stroke:#82b366,color:#000
    style PDDisagg fill:#d5e8d4,stroke:#82b366,color:#000
    style PrefixCache fill:#d5e8d4,stroke:#82b366,color:#000
    style TieredCache fill:#d5e8d4,stroke:#82b366,color:#000
    style WideEP fill:#d5e8d4,stroke:#82b366,color:#000
