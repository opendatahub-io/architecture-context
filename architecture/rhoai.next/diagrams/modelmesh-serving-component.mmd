graph TB
    subgraph ModelMeshServing["ModelMesh Serving Operator"]
        direction TB
        Controller["modelmesh-controller<br/>(Go Operator)"]
        Webhook["ServingRuntime Webhook<br/>9443/TCP HTTPS"]

        subgraph Reconcilers["Reconcilers"]
            ServiceReconciler["ServiceReconciler<br/>Manages K8s Service &<br/>ServiceMonitor per namespace"]
            RuntimeReconciler["ServingRuntimeReconciler<br/>Constructs multi-container<br/>runtime Deployments"]
            PredictorReconciler["PredictorReconciler<br/>Bridges CRDs ↔ ModelMesh<br/>gRPC API"]
        end

        Controller --> ServiceReconciler
        Controller --> RuntimeReconciler
        Controller --> PredictorReconciler
    end

    subgraph RuntimePod["Runtime Pod (per ServingRuntime)"]
        direction TB
        MM["mm (ModelMesh)<br/>Java · gRPC 8033<br/>Inference & Routing"]
        RestProxy["rest-proxy<br/>Go · HTTP 8008<br/>REST-to-gRPC adapter"]
        Puller["puller<br/>Go · gRPC 8086<br/>Model artifact fetcher"]
        OAuthProxy["oauth-proxy<br/>HTTPS 8443<br/>OpenShift OAuth"]
        RuntimeContainer["ML Runtime Container<br/>(OVMS/Triton/MLServer/TorchServe)"]
    end

    %% CRDs
    User["User / Pipeline"] -->|creates| ServingRuntimeCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| PredictorCR["Predictor CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    User -->|creates| ClusterServingRuntimeCR["ClusterServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]

    %% CRD → Reconciler flows
    ServingRuntimeCR -->|watched by| RuntimeReconciler
    ClusterServingRuntimeCR -->|watched by| RuntimeReconciler
    PredictorCR -->|watched by| PredictorReconciler
    InferenceServiceCR -->|watched by| PredictorReconciler

    %% Reconciler outputs
    RuntimeReconciler -->|creates| RuntimePod
    PredictorReconciler -->|gRPC SetVModel| MM
    ServiceReconciler -->|creates| Service["K8s Service<br/>(headless ClusterIP)"]

    %% Webhook validation
    ServingRuntimeCR -.->|validated by| Webhook
    ClusterServingRuntimeCR -.->|validated by| Webhook

    %% Internal pod communication
    RestProxy -->|gRPC| MM
    OAuthProxy -->|HTTP proxy| RestProxy
    MM -->|gRPC 8086| Puller
    MM -->|Unix socket| RuntimeContainer

    %% External dependencies
    MM -->|gRPC 2379| etcd["etcd Cluster<br/>Model Registry &<br/>Placement State"]
    Puller -->|HTTPS 443| Storage["Storage Backends<br/>(S3/GCS/Azure/PVC/HTTP)"]
    Controller -->|HTTPS 443| K8sAPI["Kubernetes API"]
    Controller -->|watches| ConfigMap["model-serving-config<br/>(ConfigMap)"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style ServiceReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style RuntimeReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style PredictorReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style MM fill:#e87d3e,stroke:#333,color:#fff
    style RestProxy fill:#e87d3e,stroke:#333,color:#fff
    style Puller fill:#e87d3e,stroke:#333,color:#fff
    style OAuthProxy fill:#e87d3e,stroke:#333,color:#fff
    style RuntimeContainer fill:#9b59b6,stroke:#333,color:#fff
    style ServingRuntimeCR fill:#f5a623,stroke:#333,color:#fff
    style PredictorCR fill:#f5a623,stroke:#333,color:#fff
    style InferenceServiceCR fill:#f5a623,stroke:#333,color:#fff
    style ClusterServingRuntimeCR fill:#f5a623,stroke:#333,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style Storage fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#7ed321,stroke:#333,color:#fff
