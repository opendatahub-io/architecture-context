graph TB
    subgraph ControlPlane["ModelMesh Serving Controller"]
        Controller["modelmesh-controller<br/>(Go Operator)"]
        Webhook["ServingRuntime Webhook<br/>(Validating, :9443)"]
        EventStream["ModelMesh Event Stream<br/>(etcd Watcher)"]
        GRPCResolver["gRPC Resolver<br/>(kube:// Service Discovery)"]
    end

    subgraph CRDs["Custom Resource Definitions"]
        SR["ServingRuntime<br/>(serving.kserve.io/v1alpha1)"]
        CSR["ClusterServingRuntime<br/>(serving.kserve.io/v1alpha1)"]
        Predictor["Predictor<br/>(serving.kserve.io/v1alpha1)"]
        InferenceService["InferenceService<br/>(serving.kserve.io/v1beta1)"]
    end

    subgraph DataPlane["ModelMesh Data Plane (per ServingRuntime)"]
        MM["ModelMesh Container<br/>(:8033 gRPC, :8089 health)"]
        Puller["Puller Sidecar<br/>(:8086 gRPC)"]
        RESTProxy["REST Proxy Sidecar<br/>(:8008 HTTP)"]
        OAuthProxy["OAuth Proxy Sidecar<br/>(:8443 HTTPS)"]
        BuiltInAdapter["BuiltIn Adapter<br/>(:8085 gRPC)"]
        Runtime["Runtime Container<br/>(Triton/MLServer/OVMS/TorchServe)"]
    end

    User["Data Scientist / Client"] -->|creates| SR
    User -->|creates| CSR
    User -->|creates| Predictor
    User -->|creates| InferenceService

    SR -->|watched by| Controller
    CSR -->|watched by| Controller
    Predictor -->|watched by| Controller
    InferenceService -->|bridged to Predictor| Controller

    Controller -->|validates via| Webhook
    Controller -->|creates/manages| DataPlane
    Controller -->|registerModel/setVModel| MM
    EventStream -->|watches model state| etcd["etcd<br/>(:2379)"]
    EventStream -->|triggers reconcile| Controller
    GRPCResolver -->|discovers endpoints| K8sEndpoints["K8s Endpoints"]

    MM -->|inference| Runtime
    Puller -->|loads model| Runtime
    RESTProxy -->|translates REST→gRPC| MM
    OAuthProxy -->|authenticates| RESTProxy
    Puller -->|downloads models| Storage["S3 / GCS / Azure / PVC"]

    Controller -->|CRUD| K8sAPI["Kubernetes API<br/>(:443)"]

    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style EventStream fill:#4a90e2,color:#fff
    style GRPCResolver fill:#4a90e2,color:#fff
    style MM fill:#50c878,color:#fff
    style Puller fill:#50c878,color:#fff
    style RESTProxy fill:#50c878,color:#fff
    style OAuthProxy fill:#50c878,color:#fff
    style BuiltInAdapter fill:#50c878,color:#fff
    style Runtime fill:#50c878,color:#fff
    style SR fill:#f5a623
    style CSR fill:#f5a623
    style Predictor fill:#f5a623
    style InferenceService fill:#f5a623
