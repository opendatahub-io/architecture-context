graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>(Go Operator / controller-runtime)<br/>Port: 8080 metrics, 8081 probes"]
        Webhook["ServingRuntime Webhook<br/>(Validating Webhook)<br/>Port: 9443/TCP TLS"]
        EventStream["ModelMesh Event Stream<br/>(etcd Watcher)"]
        GRPCResolver["gRPC Resolver<br/>(kube:// scheme)<br/>K8s Service Discovery"]

        Controller -->|"validates via"| Webhook
        Controller -->|"receives events"| EventStream
        Controller -->|"discovers endpoints"| GRPCResolver
    end

    subgraph "CRDs Watched"
        SR["ServingRuntime<br/>(serving.kserve.io/v1alpha1)<br/>Namespaced"]
        CSR["ClusterServingRuntime<br/>(serving.kserve.io/v1alpha1)<br/>Cluster-scoped"]
        Predictor["Predictor<br/>(serving.kserve.io/v1alpha1)<br/>Namespaced"]
        IS["InferenceService<br/>(serving.kserve.io/v1beta1)<br/>Namespaced"]
    end

    subgraph "Generated Pod (per ServingRuntime)"
        MM["ModelMesh Container<br/>Port: 8033 gRPC, 8089 probes"]
        Runtime["Runtime Container<br/>(Triton/MLServer/OVMS/TorchServe)"]
        Puller["Puller Sidecar<br/>(modelmesh-runtime-adapter)<br/>Port: 8086 gRPC"]
        RESTProxy["REST Proxy Sidecar<br/>Port: 8008 HTTP"]
        OAuthProxy["oauth-proxy Sidecar<br/>Port: 8443 HTTPS"]
        BuiltInAdapter["Built-in Adapter<br/>Port: 8085 gRPC"]

        OAuthProxy -->|"8008/HTTP"| RESTProxy
        RESTProxy -->|"8033/gRPC"| MM
        MM -->|"gRPC/UDS"| Runtime
        Puller -->|"8085/gRPC"| BuiltInAdapter
        BuiltInAdapter -->|"manages models"| Runtime
    end

    User["Data Scientist / Client"] -->|"creates"| Predictor
    User -->|"creates"| IS
    User -->|"creates"| SR

    SR -->|"watched by"| Controller
    CSR -->|"watched by"| Controller
    Predictor -->|"watched by"| Controller
    IS -->|"bridged to Predictor"| Controller

    Controller -->|"creates/manages<br/>Deployment + Service"| MM

    EventStream -->|"watches 2379/gRPC"| etcd["etcd<br/>v3.5.x"]
    MM -->|"model state<br/>2379/gRPC"| etcd
    Controller -->|"443/HTTPS"| K8sAPI["Kubernetes API"]
    Puller -->|"443/HTTPS"| Storage["S3 / GCS / Azure / PVC"]

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style EventStream fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style GRPCResolver fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
