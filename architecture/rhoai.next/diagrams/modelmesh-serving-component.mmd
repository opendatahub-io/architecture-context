graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>Go Operator (controller-runtime)"]
        Webhook["ServingRuntime Webhook<br/>9443/TCP HTTPS"]

        subgraph "Controllers"
            SRReconciler["ServingRuntime<br/>Reconciler"]
            PredictorReconciler["Predictor<br/>Reconciler"]
            ServiceReconciler["Service<br/>Reconciler"]
        end

        Controller --> SRReconciler
        Controller --> PredictorReconciler
        Controller --> ServiceReconciler
    end

    subgraph "Runtime Pod (Managed Deployment)"
        direction TB
        ModelMeshSidecar["ModelMesh Sidecar<br/>(Java) 8033/TCP gRPC"]
        Puller["modelmesh-runtime-adapter<br/>(puller) 8086/TCP gRPC"]
        RESTProxy["REST Proxy<br/>HTTP-to-gRPC bridge"]
        OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS (RHOAI)"]
        RuntimeContainer["Model Runtime<br/>(Triton/OVMS/MLServer/TorchServe)"]

        OAuthProxy -->|"8008/TCP"| RESTProxy
        RESTProxy -->|"gRPC"| ModelMeshSidecar
        ModelMeshSidecar -->|"unix socket/port"| RuntimeContainer
        ModelMeshSidecar -->|"8086/TCP gRPC"| Puller
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| PredictorCR["Predictor CR<br/>serving.kserve.io/v1alpha1"]
    User -->|creates| ServingRuntimeCR["ServingRuntime CR<br/>serving.kserve.io/v1alpha1"]
    User -->|creates| InferenceServiceCR["InferenceService CR<br/>serving.kserve.io/v1beta1<br/>(mode: ModelMesh)"]

    PredictorCR -->|watched by| PredictorReconciler
    ServingRuntimeCR -->|validated by| Webhook
    ServingRuntimeCR -->|watched by| SRReconciler
    InferenceServiceCR -->|converted to Predictor| PredictorReconciler

    %% Controller actions
    SRReconciler -->|"creates/manages"| RuntimePod["Runtime Pod Deployment"]
    PredictorReconciler -->|"SetVModel gRPC"| ModelMeshSidecar
    ServiceReconciler -->|"creates"| InferenceService["modelmesh-serving Service<br/>ClusterIP"]

    %% External dependencies
    ModelMeshSidecar -->|"2379/TCP gRPC"| etcd["etcd<br/>Distributed State Store"]
    Puller -->|"443/TCP HTTPS"| Storage["Model Storage<br/>(S3/GCS/Azure/PVC)"]
    Controller -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Metrics
    Controller -->|"8080/TCP"| Metrics["Prometheus Metrics"]
    RuntimePod -->|"2112/TCP"| RuntimeMetrics["Runtime Metrics"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SRReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style PredictorReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style ServiceReconciler fill:#5ba3f5,stroke:#333,color:#fff
    style ModelMeshSidecar fill:#7ed321,stroke:#333,color:#fff
    style Puller fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#9b59b6,stroke:#333,color:#fff
    style RuntimeContainer fill:#e67e22,stroke:#333,color:#fff
    style PredictorCR fill:#f5a623,stroke:#333
    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style etcd fill:#999,stroke:#333,color:#fff
    style Storage fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
