graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>(Go Operator / controller-runtime)"]
        Webhook["ServingRuntime Webhook<br/>(9443/TCP HTTPS)"]
        Controller -->|validates via| Webhook
    end

    subgraph "Runtime Pod (multi-container)"
        direction TB
        ModelMesh["ModelMesh Sidecar<br/>(Java, gRPC 8033/TCP)"]
        Puller["modelmesh-runtime-adapter<br/>(puller, gRPC 8086/TCP)"]
        RESTProxy["REST Proxy<br/>(HTTP-to-gRPC bridge)"]
        OAuthProxy["oauth-proxy<br/>(8443/TCP HTTPS, RHOAI)"]
        Runtime["Model Runtime<br/>(Triton / OVMS / MLServer / TorchServe)"]
        ModelMesh -->|inference| Runtime
        ModelMesh -->|download model| Puller
        OAuthProxy -->|forward| RESTProxy
        RESTProxy -->|gRPC| ModelMesh
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| PredictorCR["Predictor CR<br/>(serving.kserve.io/v1alpha1)"]
    User -->|creates| ISVC["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    User -->|creates| SRTCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    Admin["Platform Admin"] -->|creates| CSRT["ClusterServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]

    %% Controller watches
    PredictorCR -->|watched by| Controller
    ISVC -->|"watched by<br/>(mode: ModelMesh)"| Controller
    SRTCR -->|watched by| Controller
    CSRT -->|watched by| Controller

    %% Controller creates
    Controller -->|"creates/manages"| RuntimePod["Runtime Deployment"]
    RuntimePod --- ModelMesh
    Controller -->|"creates"| HPA["HorizontalPodAutoscaler"]
    Controller -->|"creates"| SVC["Service<br/>(modelmesh-serving)"]
    Controller -->|"gRPC: SetVModel<br/>GetVModelStatus"| ModelMesh

    %% External dependencies
    ModelMesh -->|"model state<br/>(2379/TCP gRPC)"| etcd["etcd<br/>(v3.5.x)"]
    Puller -->|"download artifacts<br/>(443/TCP HTTPS)"| Storage["Model Storage<br/>(S3 / GCS / Azure / PVC)"]
    Controller -->|"CRD CRUD<br/>(443/TCP HTTPS)"| K8sAPI["Kubernetes API"]

    %% Inference flow
    Client["Inference Client"] -->|"HTTPS/8443<br/>(OAuth)"| OAuthProxy
    Client -->|"gRPC/8033<br/>(mTLS optional)"| ModelMesh

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ModelMesh fill:#7b68ee,stroke:#333,stroke-width:2px,color:#fff
    style Puller fill:#7b68ee,stroke:#333,stroke-width:2px,color:#fff
    style RESTProxy fill:#7b68ee,stroke:#333,stroke-width:2px,color:#fff
    style OAuthProxy fill:#7b68ee,stroke:#333,stroke-width:2px,color:#fff
    style Runtime fill:#7b68ee,stroke:#333,stroke-width:2px,color:#fff
    style PredictorCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ISVC fill:#f5a623,stroke:#333,stroke-width:2px
    style SRTCR fill:#f5a623,stroke:#333,stroke-width:2px
    style CSRT fill:#f5a623,stroke:#333,stroke-width:2px
    style etcd fill:#e8e8e8,stroke:#333,stroke-width:2px
    style Storage fill:#e8e8e8,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333,stroke-width:2px
    style User fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Admin fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
