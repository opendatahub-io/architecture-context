    style OAuthProxy fill:#50c878,stroke:#333,stroke-width:2px
    style BuiltInAdapter fill:#50c878,stroke:#333,stroke-width:2px
    style SR fill:#f5a623,stroke:#333,stroke-width:2px
    style CSR fill:#f5a623,stroke:#333,stroke-width:2px
