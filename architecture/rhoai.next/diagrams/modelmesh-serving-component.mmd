graph TB
    subgraph "ModelMesh Serving Controller"
        Controller["modelmesh-controller<br/>(Go Operator / controller-runtime)"]

        subgraph "Controllers"
            SRCtrl["ServingRuntime Controller<br/>Manages runtime Deployments"]
            PredCtrl["Predictor Controller<br/>Manages model lifecycle via gRPC"]
            SvcCtrl["Service Controller<br/>Manages K8s Services & ServiceMonitors"]
        end

        Controller --> SRCtrl
        Controller --> PredCtrl
        Controller --> SvcCtrl

        Webhook["Webhook Server<br/>:9443/TCP HTTPS"]
    end

    subgraph "Runtime Pod (per ServingRuntime)"
        direction TB
        MM["ModelMesh (mm)<br/>gRPC inference routing<br/>:8033/TCP"]
        RESTProxy["REST Proxy<br/>HTTP-to-gRPC translation<br/>:8008/TCP"]
        Puller["Puller / Storage Helper<br/>Model artifact download<br/>:8086/TCP gRPC"]
        OAuthProxy["oauth-proxy<br/>OpenShift OAuth<br/>:8443/TCP HTTPS"]
        RuntimeContainer["Runtime Container<br/>(model server)"]

        OAuthProxy -->|":8008 HTTP"| RESTProxy
        RESTProxy -->|":8033 gRPC"| MM
        MM -->|"UDS/localhost"| RuntimeContainer
        Puller -.->|"model artifacts"| RuntimeContainer
    end

    %% CRDs
    User["User / Pipeline"] -->|creates| PredictorCR["Predictor CR<br/>serving.kserve.io/v1alpha1"]
    User -->|creates| ISVC["InferenceService CR<br/>serving.kserve.io/v1beta1"]
    Admin["Admin"] -->|creates| SRCR["ServingRuntime CR<br/>serving.kserve.io/v1alpha1"]
    Admin -->|creates| CSRCR["ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1"]

    PredictorCR -->|"watched by"| PredCtrl
    ISVC -->|"converted to Predictor"| PredCtrl
    SRCR -->|"watched by"| SRCtrl
    CSRCR -->|"watched by"| SRCtrl

    %% Controller outputs
    SRCtrl -->|"creates/manages"| RuntimePodDeploy["Runtime Deployment"]
    SRCtrl -->|"creates/manages"| HPA["HorizontalPodAutoscaler"]
    SvcCtrl -->|"creates"| SvcResource["Kubernetes Service<br/>(headless)"]
    SvcCtrl -->|"creates"| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    PredCtrl -->|"gRPC: registerModel,<br/>setVModel, ensureLoaded"| MM

    RuntimePodDeploy -.-> MM
    RuntimePodDeploy -.-> RESTProxy
    RuntimePodDeploy -.-> Puller
    RuntimePodDeploy -.-> OAuthProxy
    RuntimePodDeploy -.-> RuntimeContainer

    %% External dependencies
    PredCtrl -->|"gRPC :2379"| etcd["etcd<br/>Model registry & coordination"]
    SRCtrl -->|"gRPC :2379"| etcd
    Puller -->|"HTTPS :443"| S3["Object Storage<br/>(S3 / MinIO)"]
    Controller -->|"HTTPS :443"| K8sAPI["Kubernetes API Server"]
    Webhook -->|"validates"| SRCR
    Webhook -->|"validates"| CSRCR

    %% Config
    ConfigMap["ConfigMap<br/>model-serving-config"] -.->|"watched"| Controller
    StorageSecret["Secret<br/>storage-config"] -.->|"watched"| Puller
    EtcdSecret["Secret<br/>model-serving-etcd"] -.->|"credentials"| etcd

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style SRCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style PredCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style SvcCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style MM fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style Puller fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff
    style RuntimeContainer fill:#7ed321,stroke:#333,color:#fff
    style PredictorCR fill:#f5a623,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#fff
    style SRCR fill:#f5a623,stroke:#333,color:#fff
    style CSRCR fill:#f5a623,stroke:#333,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#333
    style StorageSecret fill:#e8e8e8,stroke:#333
    style EtcdSecret fill:#e8e8e8,stroke:#333
