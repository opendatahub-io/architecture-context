graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route / HTTPRoute<br/>443/TCP<br/>TLS 1.2+ (edge/reencrypt)<br/>OAuth Redirect"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB

        subgraph SidecarContainer["Sidecar: kube-rbac-proxy"]
            KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OAuth Token Validation<br/>Namespace RBAC Check"]
        end

        subgraph MainContainer["Main Container (one of)"]
            direction TB
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>plaintext, no auth"]
            CodeServerStack["code-server Stack<br/>nginx: 80/TCP<br/>code-server: 8787/TCP<br/>httpd CGI: 8080/TCP"]
            RStudioStack["RStudio Stack<br/>nginx: 80/TCP<br/>RStudio: 8787/TCP<br/>httpd CGI: 8080/TCP"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Operator Namespace)"]
        Culler["Notebook Controller Culler<br/>Polls /api/kernels/<br/>SA: Bearer Token"]
        NotebookCtrl["ODH Notebook Controller<br/>Mutating Webhook<br/>Injects kube-rbac-proxy"]
        Operator["rhods-operator<br/>Deploys ImageStreams"]
        Dashboard["ODH Dashboard<br/>Reads ImageStream Annotations"]
    end

    subgraph BuildInfra["BUILD INFRASTRUCTURE"]
        Konflux["Konflux CI<br/>Hermetic Build<br/>cachi2 prefetch<br/>Hash-verified deps"]
        BuildConfig["OpenShift BuildConfig<br/>(RStudio only)<br/>Requires RHEL subscription"]
    end

    subgraph ExternalEgress["EGRESS (User-initiated)"]
        PyPI["PyPI / RHAI Console<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        CRAN["CRAN<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>User/Pass"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS optional<br/>User/Pass"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>User/Pass"]
        DSP["Data Science Pipelines<br/>8888/TCP HTTP<br/>Bearer Token<br/>(in-cluster)"]
    end

    subgraph ContainerRegistry["CONTAINER REGISTRY"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
    end

    %% External access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Route
    Route -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP/8888<br/>plaintext (localhost)<br/>no auth"| JupyterLab
    KubeRBAC -->|"HTTP/80<br/>plaintext (localhost)<br/>no auth"| CodeServerStack
    KubeRBAC -->|"HTTP/80<br/>plaintext (localhost)<br/>no auth"| RStudioStack

    %% Idle culling
    Culler -->|"HTTPS/8443<br/>TLS<br/>SA Bearer Token"| KubeRBAC

    %% Platform management
    NotebookCtrl -->|"Creates Pod<br/>Injects sidecar<br/>Mounts CA bundles"| WorkbenchPod
    Operator -->|"Deploys ImageStreams<br/>Kubernetes API<br/>TLS 1.2+"| WorkbenchPod
    Dashboard -->|"HTTPS/6443<br/>Bearer Token<br/>Reads annotations"| WorkbenchPod

    %% Build & registry
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>SA auth"| Registry
    BuildConfig -->|"Build API<br/>TLS 1.2+"| Registry
    Registry -->|"Image Pull<br/>sha256 digest"| WorkbenchPod

    %% Egress from workbench
    MainContainer -->|"HTTPS/443"| PyPI
    MainContainer -->|"HTTPS/443"| CRAN
    MainContainer -->|"TCP/5432"| PostgreSQL
    MainContainer -->|"TCP/3306"| MySQL
    MainContainer -->|"TCP/27017"| MongoDB
    MainContainer -->|"HTTP/8888<br/>Bearer Token"| DSP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef sidecar fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef build fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef registry fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Route ingress
    class KubeRBAC sidecar
    class JupyterLab,CodeServerStack,RStudioStack pod
    class Culler,NotebookCtrl,Operator,Dashboard platform
    class Konflux,BuildConfig build
    class PyPI,CRAN,PostgreSQL,MySQL,MongoDB,DSP egress
    class Registry registry
