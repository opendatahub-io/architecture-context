graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>User Browser"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP<br/>TLS 1.2+ SIMPLE<br/>HTTPRoute (Gateway API)"]
    end

    subgraph AuthBoundary["AUTH BOUNDARY (Sidecar)"]
        KRBP["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth/OIDC Token Validation"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (localhost only)"]
        direction TB

        subgraph JupyterStack["Jupyter Workbench"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>No auth (behind sidecar)"]
            Elyra["Elyra Extension<br/>Pipeline Editor"]
        end

        subgraph CodeServerStack["Code-Server Workbench"]
            NginxProxy["nginx Reverse Proxy<br/>80/TCP HTTP<br/>JSON access logging"]
            CodeServerProc["code-server<br/>8787/TCP HTTP<br/>--auth none"]
            HttpdCGI["httpd CGI Gateway<br/>8080/TCP HTTP<br/>access.cgi idle culling"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Internal)"]
        DSPA["Data Science Pipelines (DSPA)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        NotebookController["Notebook Controller Culler<br/>Polls /api/kernels/<br/>via 8443/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token Auth"]
    end

    %% Inbound flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>OAuth Token"| KRBP

    %% Sidecar to workbench
    KRBP -->|"HTTP/8888<br/>plaintext (localhost)<br/>No auth"| Jupyter
    KRBP -->|"HTTP/80<br/>plaintext (localhost)<br/>No auth"| NginxProxy

    %% Code-Server internal
    NginxProxy -->|"HTTP/8787<br/>localhost"| CodeServerProc
    HttpdCGI -->|"HTTP/8888<br/>healthz poll"| CodeServerProc

    %% Idle culling
    NotebookController -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Token"| KRBP

    %% Egress
    Elyra -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| DSPA
    Jupyter -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    WorkbenchPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>Token"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authboundary fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBP authboundary
    class Jupyter,Elyra,NginxProxy,CodeServerProc,HttpdCGI workbench
    class DSPA,K8sAPI,NotebookController platform
    class Registry externalservice
