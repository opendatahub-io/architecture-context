graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Gateway)"]
        Gateway["HTTPRoute → OpenShift Gateway<br/>443/TCP<br/>TLS 1.3<br/>OAuth session"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (user namespace)"]
        direction TB

        subgraph JupyterPod["Jupyter Workbench"]
            KRBP_J["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OAuth + RBAC"]
            JLab["JupyterLab Server<br/>8888/TCP HTTP<br/>No auth (trusted after proxy)"]
            KRBP_J -->|"HTTP/8888<br/>plaintext loopback"| JLab
        end

        subgraph CodeServerPod["Code-Server Workbench (alternative)"]
            KRBP_CS["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OAuth + RBAC"]
            CodeServer["code-server v4.106.3<br/>8787/TCP HTTP<br/>--auth none"]
            NginxProxy["nginx<br/>80/TCP HTTP<br/>idle culling logs"]
            HTTPDCGI["httpd CGI<br/>8080/TCP HTTP<br/>/api/kernels/ emulation"]
            KRBP_CS -->|"HTTP/8787<br/>plaintext loopback"| CodeServer
            HTTPDCGI -->|"polls /codeserver/healthz<br/>8787/TCP"| CodeServer
        end

        Culler["Notebook Controller<br/>Culler"]
    end

    subgraph EgressTargets["EGRESS TARGETS"]
        K8sAPI["OpenShift API Server<br/>443/TCP HTTPS TLS<br/>ServiceAccount token"]
        DSPA["DSPA API<br/>443/TCP HTTPS TLS<br/>SA token"]
        Registry["Container Registries<br/>443/TCP HTTPS TLS<br/>Registry credentials"]
        PyPI["External PyPI<br/>443/TCP HTTPS TLS<br/>No auth"]
    end

    subgraph BuildInfra["BUILD INFRASTRUCTURE (Konflux)"]
        Konflux["Konflux / Tekton<br/>(hermetic build)"]
        Hermeto["Hermeto/Cachi2<br/>(dependency prefetch)"]
        QuayIO["Quay.io Registry<br/>quay.io/modh/<br/>443/TCP HTTPS TLS"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth"| Gateway

    %% Ingress to Pods
    Gateway -->|"HTTPS/8443<br/>TLS<br/>OAuth token"| KRBP_J
    Gateway -->|"HTTPS/8443<br/>TLS<br/>OAuth token"| KRBP_CS

    %% Culler polling
    Culler -->|"HTTP GET /api/kernels/<br/>8888/TCP<br/>No auth (internal)"| JLab
    Culler -->|"HTTP GET /api/kernels/<br/>80/TCP<br/>No auth (internal)"| NginxProxy

    %% Egress from workbench
    JLab -->|"HTTPS/443<br/>SA token"| K8sAPI
    JLab -->|"HTTPS/443<br/>SA token"| DSPA
    JLab -->|"HTTPS/443<br/>Registry creds"| Registry
    JLab -->|"HTTPS/443<br/>No auth"| PyPI

    %% Build infra
    Hermeto -->|"prefetch deps<br/>(rpm, pip, go, npm)"| Konflux
    Konflux -->|"push image<br/>HTTPS/443 TLS<br/>Registry push creds"| QuayIO

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef proxy fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#e8e8e8,stroke:#666,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBP_J,KRBP_CS proxy
    class JLab,CodeServer,NginxProxy,HTTPDCGI,Culler pod
    class K8sAPI,DSPA,Registry,PyPI egress
    class Konflux,Hermeto,QuayIO build
