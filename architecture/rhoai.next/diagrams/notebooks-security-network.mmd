graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS Edge Termination<br/>Created by Notebook Controller"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Trust Boundary)"]
        direction TB

        KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP (TLS)<br/>OAuth token validation<br/>Injected by Notebook Controller"]

        subgraph JupyterStack["Jupyter Workbench"]
            JupyterLab["JupyterLab Server<br/>8888/TCP HTTP<br/>--auth=none<br/>Native /api/kernels/"]
        end

        subgraph CodeServerStack["Code-Server Workbench"]
            CSNginx["nginx proxy<br/>80/TCP HTTP"]
            CSServer["code-server<br/>8787/TCP HTTP<br/>--auth=none"]
            CSHttpd["httpd CGI<br/>8080/TCP HTTP<br/>/api/kernels/ emulation"]
        end

        subgraph RStudioStack["RStudio Workbench"]
            RSNginx["nginx proxy<br/>80/TCP HTTP"]
            RSServer["RStudio Server<br/>8787/TCP HTTP"]
            RSHttpd["httpd CGI<br/>8080/TCP HTTP<br/>/api/kernels/ emulation"]
        end
    end

    subgraph InCluster["IN-CLUSTER SERVICES"]
        DSP["Data Science Pipelines API<br/>8888/TCP HTTP<br/>Bearer Token"]
        Culler["Notebook Controller Culler<br/>Polls /api/kernels/"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        PyPI["PyPI / Red Hat AI Console<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        CRAN["CRAN<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/Password"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS optional<br/>Username/Password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Username/Password"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Route

    %% Ingress to Pod
    Route -->|"HTTPS/8443<br/>TLS<br/>OAuth token"| KubeRBAC

    %% kube-rbac-proxy to workbenches
    KubeRBAC -->|"HTTP/8888<br/>plaintext<br/>localhost"| JupyterLab
    KubeRBAC -->|"HTTP/80<br/>plaintext<br/>localhost"| CSNginx
    KubeRBAC -->|"HTTP/80<br/>plaintext<br/>localhost"| RSNginx

    %% Code-Server internal
    CSNginx -->|"HTTP/8787<br/>localhost"| CSServer
    CSNginx -->|"HTTP/8080<br/>localhost"| CSHttpd
    CSHttpd -->|"HTTP/8787<br/>/codeserver/healthz"| CSServer

    %% RStudio internal
    RSNginx -->|"HTTP/8787<br/>localhost"| RSServer
    RSNginx -->|"HTTP/8080<br/>localhost"| RSHttpd
    RSHttpd -->|"File read<br/>nginx access log"| RSNginx

    %% Culler flow
    Culler -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC

    %% Egress from workbenches
    JupyterLab -->|"HTTP/8888<br/>Bearer Token<br/>in-cluster"| DSP
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    JupyterLab -->|"TCP/5432<br/>Username/Password"| PostgreSQL
    JupyterLab -->|"TCP/3306<br/>Username/Password"| MySQL
    JupyterLab -->|"TCP/27017<br/>Username/Password"| MongoDB
    RSServer -->|"HTTPS/443<br/>TLS 1.2+"| CRAN

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef trustboundary fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class KubeRBAC authproxy
    class JupyterLab,CSNginx,CSServer,CSHttpd,RSNginx,RSServer,RSHttpd trustboundary
    class DSP,Culler,K8sAPI internalservice
    class PyPI,CRAN,PostgreSQL,MySQL,MongoDB,Registry externalservice
