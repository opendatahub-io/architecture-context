graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE<br/>HTTPRoute (Gateway API)"]
    end

    subgraph NotebookPod["NOTEBOOK POD (StatefulSet)"]
        direction TB
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>OAuth/OIDC validation<br/>Injected by Notebook Controller"]

        subgraph WorkbenchVariants["Workbench Container (one of)"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>Jupyter / PyTorch / TF / TrustyAI"]
            CodeServerStack["code-server Stack<br/>nginx (8888) → code-server (8080)<br/>httpd CGI (8080)"]
            RStudioStack["RStudio Stack<br/>nginx (8888) → RStudio (8787)"]
        end
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB
        APIServer["OpenShift API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount token auth"]

        subgraph PlatformComponents["Platform Components"]
            NbController["ODH Notebook Controller<br/>Creates StatefulSets +<br/>kube-rbac-proxy sidecars"]
            DashboardUI["ODH Dashboard<br/>Reads ImageStream annotations"]
            PlatformOp["rhods-operator<br/>Applies kustomize manifests"]
            Elyra["Elyra Pipeline Engine<br/>Selects runtime images"]
        end

        ImageStreams["OpenShift ImageStreams<br/>Image reference tracking<br/>3 version tags (N, N-1, N-2)"]
    end

    subgraph EgressTargets["EGRESS (User-Initiated)"]
        PyPI["PyPI / Package Registries<br/>443/TCP HTTPS TLS 1.2+"]
        GitRepos["Git Repositories<br/>443/TCP HTTPS TLS 1.2+<br/>User-configured auth"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / S3 credentials"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Credentials"]
        ODBC["ODBC Data Sources<br/>varies/TCP<br/>Credentials"]
    end

    subgraph BuildPipeline["BUILD PIPELINE"]
        Konflux["Konflux Build System<br/>102 Tekton PipelineRuns<br/>Hermetic (zero network)"]
        ContainerReg["Container Registry<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC cookie"| Gateway

    %% Ingress → Pod
    Gateway -->|"HTTPS/8443<br/>TLS (in-cluster)<br/>Bearer token"| KubeRBAC

    %% kube-rbac-proxy → Workbench
    KubeRBAC -->|"HTTP/8888<br/>localhost (no TLS)<br/>Pre-authenticated"| JupyterLab
    KubeRBAC -->|"HTTP/8888<br/>localhost (no TLS)<br/>Pre-authenticated"| CodeServerStack
    KubeRBAC -->|"HTTP/8888<br/>localhost (no TLS)<br/>Pre-authenticated"| RStudioStack

    %% Platform components → API Server
    NbController -->|"HTTPS/6443<br/>SA token"| APIServer
    DashboardUI -->|"HTTPS/6443<br/>SA token"| APIServer
    PlatformOp -->|"HTTPS/6443<br/>SA token"| APIServer
    Elyra -->|"HTTPS/6443<br/>SA token"| APIServer

    %% API Server ↔ ImageStreams
    PlatformOp -->|creates| ImageStreams
    DashboardUI -->|reads| ImageStreams
    NbController -->|reads| ImageStreams

    %% Egress from notebook
    JupyterLab -->|"HTTPS/443<br/>pip install"| PyPI
    JupyterLab -->|"HTTPS/443<br/>git clone"| GitRepos
    JupyterLab -->|"HTTPS/443<br/>AWS IAM"| S3
    JupyterLab -->|"TCP/27017<br/>mongocli"| MongoDB
    JupyterLab -->|"TCP/varies<br/>unixODBC"| ODBC

    %% Build pipeline
    Konflux -->|"HTTPS/443<br/>SA auth<br/>Push images"| ContainerReg
    ContainerReg -.->|"HTTPS/443<br/>Pull secret<br/>Image pull"| NotebookPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#f5f5f5,stroke:#666,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC security
    class JupyterLab,CodeServerStack,RStudioStack pod
    class APIServer,NbController,DashboardUI,PlatformOp,Elyra,ImageStreams cluster
    class PyPI,GitRepos,S3,MongoDB,ODBC egress
    class Konflux,ContainerReg build
