graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway / Envoy<br/>HTTPRoute (Gateway API)<br/>443/TCP → internal<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph AuthBoundary["AUTH BOUNDARY"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP → 8888/TCP<br/>Injected by Notebook Controller<br/>OAuth/OIDC enforcement"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB

        subgraph JupyterOption["Option A: Jupyter"]
            Jupyter["JupyterLab Server<br/>8888/TCP HTTP<br/>Endpoints: /notebook/.../api, /lab"]
        end

        subgraph CodeServerOption["Option B: code-server"]
            NginxCS["nginx proxy<br/>8888/TCP"]
            CS["code-server<br/>8080/TCP"]
            HTTPDCGI["httpd CGI<br/>8080/TCP<br/>/api/kernels/access.cgi"]
            NginxCS --> CS
        end

        subgraph RStudioOption["Option C: RStudio"]
            NginxRS["nginx proxy<br/>8888/TCP"]
            RS["RStudio Server<br/>8787/TCP"]
            NginxRS --> RS
        end
    end

    subgraph EgressTargets["EGRESS (User-Initiated)"]
        PyPI["PyPI / Package Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>User-configured Auth"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / S3 Creds"]
        MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Credentials"]
        ODBC["ODBC Data Sources<br/>varies/TCP<br/>Credentials"]
    end

    subgraph ControlPlane["PLATFORM CONTROL PLANE"]
        K8sAPI["OpenShift API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount tokens"]
        ContainerReg["Container Registry<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS<br/>Pull Secrets"]
        Operator["rhods-operator<br/>Applies kustomize manifests"]
        DashboardCtrl["ODH Dashboard<br/>Reads ImageStream annotations"]
        NotebookCtrl["ODH Notebook Controller<br/>Creates StatefulSets + sidecars"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC cookie"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS (in-cluster)<br/>Bearer token"| KubeRBAC

    %% Auth → Workbench
    KubeRBAC -->|"HTTP/8888<br/>None (pod network)<br/>Pre-authenticated"| Jupyter
    KubeRBAC -->|"HTTP/8888<br/>None (pod network)<br/>Pre-authenticated"| NginxCS
    KubeRBAC -->|"HTTP/8888<br/>None (pod network)<br/>Pre-authenticated"| NginxRS

    %% Workbench → Egress
    Jupyter -->|"HTTPS/443"| PyPI
    Jupyter -->|"HTTPS/443"| Git
    Jupyter -->|"HTTPS/443<br/>AWS IAM"| S3
    Jupyter -->|"TCP/27017"| MongoDB
    Jupyter -->|"TCP/varies"| ODBC

    %% Control Plane
    Operator -->|"HTTPS/6443<br/>SA token"| K8sAPI
    DashboardCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    NotebookCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/443<br/>Pull secret"| ContainerReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC auth
    class Jupyter,NginxCS,CS,HTTPDCGI,NginxRS,RS workbench
    class PyPI,Git,S3,MongoDB,ODBC egress
    class K8sAPI,ContainerReg,Operator,DashboardCtrl,NotebookCtrl controlplane
