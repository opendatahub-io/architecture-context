graph LR
    KFTO["Training Operator<br/>(KFTO)"]

    %% External Dependencies (Required)
    KFTO -->|"controller framework<br/>v0.19.1"| CR["controller-runtime"]
    KFTO -->|"target platform<br/>1.31+"| K8s["Kubernetes"]
    KFTO -->|"webhook cert rotation<br/>v0.12.0"| OPACert["OPA cert-controller"]

    %% External Dependencies (Optional)
    KFTO -.->|"gang scheduling<br/>v1.9.0 (optional)"| Volcano["Volcano Scheduler"]
    KFTO -.->|"gang scheduling<br/>v0.28.9 (optional)"| SchedPlugins["scheduler-plugins"]

    %% Internal RHOAI Dependencies
    KFTO -.->|"job queuing<br/>managedBy field"| Kueue["Kueue / MultiKueue"]
    KFTO -->|"metrics scraping<br/>PodMonitor"| OSMonitoring["OpenShift Monitoring"]

    %% K8s API interactions
    KFTO -->|"CRUD: Pods, Services,<br/>ConfigMaps, CRDs"| K8sAPI["Kubernetes API Server"]
    KFTO -->|"CRUD: HPA, RBAC,<br/>NetworkPolicies"| K8sAPI

    %% Webhook interaction
    K8sAPI -->|"webhook callbacks<br/>9443/TCP"| KFTO

    %% CRDs managed
    subgraph CRDs["CRDs (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        MPIJob["MPIJob"]
        XGBoostJob["XGBoostJob"]
        PaddleJob["PaddleJob"]
        JAXJob["JAXJob"]
    end

    KFTO -->|"watches &<br/>reconciles"| CRDs

    %% Created resources
    subgraph CreatedResources["Resources Created per Job"]
        Pods["Worker Pods"]
        Services["Headless Services"]
        NetPol["NetworkPolicy<br/>(PyTorch only)"]
        HPA["HPA<br/>(PyTorch elastic)"]
        MPI_Resources["ConfigMap + RBAC<br/>(MPI only)"]
    end

    KFTO -->|"creates & manages"| CreatedResources

    %% Styles
    style KFTO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style OPACert fill:#999,stroke:#333,color:#fff
    style Volcano fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style SchedPlugins fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style Kueue fill:#7ed321,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style OSMonitoring fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style CRDs fill:#fff2cc,stroke:#d6b656
    style PyTorchJob fill:#fff2cc,stroke:#d6b656
    style TFJob fill:#fff2cc,stroke:#d6b656
    style MPIJob fill:#fff2cc,stroke:#d6b656
    style XGBoostJob fill:#fff2cc,stroke:#d6b656
    style PaddleJob fill:#fff2cc,stroke:#d6b656
    style JAXJob fill:#fff2cc,stroke:#d6b656
    style CreatedResources fill:#e8f4fd,stroke:#4a90e2
    style Pods fill:#e8f4fd,stroke:#4a90e2
    style Services fill:#e8f4fd,stroke:#4a90e2
    style NetPol fill:#e8f4fd,stroke:#4a90e2
    style HPA fill:#e8f4fd,stroke:#4a90e2
    style MPI_Resources fill:#e8f4fd,stroke:#4a90e2
