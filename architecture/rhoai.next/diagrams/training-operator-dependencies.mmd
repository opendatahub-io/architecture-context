graph LR
    TrainingOp["Training Operator<br/>(KFTO)"]

    %% External Dependencies (Required)
    TrainingOp -->|"controller framework<br/>(required)"| K8s["Kubernetes 1.31+"]
    TrainingOp -->|"operator framework<br/>(required)"| CR["controller-runtime v0.19.1"]
    TrainingOp -->|"webhook cert rotation<br/>(required)"| CertCtrl["OPA cert-controller v0.12.0"]

    %% External Dependencies (Optional)
    TrainingOp -.->|"gang scheduling<br/>(optional)"| Volcano["Volcano Scheduler v1.9.0"]
    TrainingOp -.->|"gang scheduling<br/>(optional)"| SchPlugins["scheduler-plugins v0.28.9"]

    %% Internal Platform Dependencies
    TrainingOp -.->|"managedBy field<br/>(jobs skipped)"| Kueue["Kueue<br/>(MultiKueue)"]

    %% Integration Points - Outbound
    TrainingOp -->|"CRUD: Pods, Services,<br/>ConfigMaps, CRDs, HPA,<br/>RBAC, NetworkPolicies<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    TrainingOp -->|"CRD Watch<br/>(informer)<br/>HTTPS/443"| K8sAPI

    %% Integration Points - Inbound
    K8sAPI -->|"webhook validation<br/>HTTPS/9443<br/>fail-closed"| TrainingOp
    Monitoring["OpenShift Monitoring"] -->|"PodMonitor scrape<br/>HTTP/8080"| TrainingOp

    %% CRDs managed
    TrainingOp -->|manages| PyTorchJob["PyTorchJob<br/>kubeflow.org/v1"]
    TrainingOp -->|manages| TFJob["TFJob<br/>kubeflow.org/v1"]
    TrainingOp -->|manages| MPIJob["MPIJob<br/>kubeflow.org/v1"]
    TrainingOp -->|manages| XGBoostJob["XGBoostJob<br/>kubeflow.org/v1"]
    TrainingOp -->|manages| PaddleJob["PaddleJob<br/>kubeflow.org/v1"]
    TrainingOp -->|manages| JAXJob["JAXJob<br/>kubeflow.org/v1"]

