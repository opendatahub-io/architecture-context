graph LR
    TrainingOp["Training Operator<br/>(Kubeflow Training Operator)"]

    %% Required External Dependencies
    TrainingOp -->|"CRD reconciliation<br/>Pod/Service CRUD<br/>443/TCP HTTPS"| K8s["Kubernetes v1.31+"]
    TrainingOp -->|"operator framework<br/>reconciliation loops"| ControllerRuntime["controller-runtime<br/>v0.19.1"]
    TrainingOp -->|"webhook cert<br/>generation & rotation"| CertController["cert-controller<br/>v0.12.0"]

    %% Optional External Dependencies
    TrainingOp -.->|"gang scheduling<br/>PodGroup CRD<br/>443/TCP HTTPS"| Volcano["Volcano v1.9.0<br/>(optional)"]
    TrainingOp -.->|"alt gang scheduling<br/>PodGroup CRD<br/>443/TCP HTTPS"| SchedulerPlugins["scheduler-plugins<br/>v0.28.9 (optional)"]
    TrainingOp -.->|"metrics scrape<br/>8080/TCP HTTP"| Prometheus["Prometheus<br/>(optional)"]

    %% Internal Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>Kustomize manifests"| TrainingOp
    PromOp["Prometheus Operator"] -.->|"PodMonitor CR<br/>metrics scrape"| TrainingOp

    %% Integration Points (peers that interact with training-operator)
    TrainingOp -.->|"elastic training<br/>HPA integration<br/>443/TCP HTTPS"| K8sHPA["Kubernetes HPA"]
    Kueue["Kueue"] -.->|"webhooks intercept<br/>training CRDs<br/>RunPolicy.ManagedBy"| TrainingOp

    %% CRDs managed
    TrainingOp -->|"manages"| CRDs["CRDs:<br/>PyTorchJob, TFJob,<br/>MPIJob, JAXJob,<br/>XGBoostJob, PaddleJob"]

    %% Styling
    style TrainingOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff
    style Volcano fill:#bbb,stroke:#333,color:#000
    style SchedulerPlugins fill:#bbb,stroke:#333,color:#000
    style Prometheus fill:#bbb,stroke:#333,color:#000
    style RHODSOp fill:#7ed321,stroke:#333,color:#000
    style PromOp fill:#7ed321,stroke:#333,color:#000
    style K8sHPA fill:#bbb,stroke:#333,color:#000
    style Kueue fill:#7ed321,stroke:#333,color:#000
    style CRDs fill:#f5a623,stroke:#333,color:#000
