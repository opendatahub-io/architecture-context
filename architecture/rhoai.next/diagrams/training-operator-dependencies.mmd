graph LR
    TrainingOperator["Training Operator<br/>(Kubeflow Training Operator)<br/>v1.9.0"]

    %% External Dependencies (Required)
    TrainingOperator -->|"CRD reconciliation<br/>Pod/Service CRUD<br/>HTTPS/443"| K8s["Kubernetes v1.31+"]
    TrainingOperator -->|"operator framework<br/>reconciliation loops"| ControllerRuntime["controller-runtime<br/>v0.19.1"]
    TrainingOperator -->|"webhook cert<br/>generation + rotation"| CertController["cert-controller<br/>v0.12.0"]

    %% External Dependencies (Optional)
    TrainingOperator -.->|"gang scheduling<br/>PodGroup CRD<br/>HTTPS/443"| Volcano["Volcano v1.9.0<br/>(optional)"]
    TrainingOperator -.->|"alternative gang scheduling<br/>PodGroup CRD<br/>HTTPS/443"| SchedPlugins["scheduler-plugins<br/>v0.28.9 (optional)"]
    TrainingOperator -.->|"metrics scrape<br/>HTTP/8080"| Prometheus["Prometheus<br/>(optional)"]

    %% Internal Platform Dependencies
    RHODSOperator["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>Kustomize manifests"| TrainingOperator
    PromOperator["Prometheus Operator"] -->|"PodMonitor CR<br/>scrape config"| TrainingOperator

    %% Integration Points
    TrainingOperator -.->|"elastic training<br/>HPA CRUD<br/>HTTPS/443"| K8sHPA["Kubernetes HPA"]
    TrainingOperator -.->|"ManagedBy field<br/>job queueing"| Kueue["Kueue<br/>(optional)"]

    %% CRDs managed
    subgraph ManagedCRDs["Managed CRDs (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        MPIJob["MPIJob"]
        JAXJob["JAXJob"]
        XGBoostJob["XGBoostJob"]
        PaddleJob["PaddleJob"]
    end

    TrainingOperator -->|"reconciles"| ManagedCRDs

    %% Styling
    style TrainingOperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style ControllerRuntime fill:#326ce5,stroke:#333,color:#fff
    style CertController fill:#326ce5,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333,color:#fff
    style SchedPlugins fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style RHODSOperator fill:#7ed321,stroke:#333
    style PromOperator fill:#7ed321,stroke:#333
    style K8sHPA fill:#f5a623,stroke:#333
    style Kueue fill:#999,stroke:#333,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
