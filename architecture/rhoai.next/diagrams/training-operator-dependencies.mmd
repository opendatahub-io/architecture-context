graph LR
    TO["Training Operator<br/>(Kubeflow Training Operator)"]

    %% External Dependencies (Required)
    TO -->|"runtime platform<br/>client-go v0.31.3"| K8s["Kubernetes v1.31+"]
    TO -->|"controller framework<br/>webhook, leader election"| CR["controller-runtime v0.19.1"]
    TO -->|"webhook cert rotation"| CertCtrl["cert-controller<br/>(OPA) v0.12.0"]

    %% External Dependencies (Optional)
    TO -.->|"gang scheduling<br/>PodGroup CRD<br/>(--gang-scheduler-name=volcano)"| Volcano["Volcano v1.9.0"]
    TO -.->|"gang scheduling<br/>PodGroup CRD<br/>(--gang-scheduler-name=...)"| SchedPlugins["scheduler-plugins v0.28.9"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize<br/>manifests/rhoai"| TO
    Prometheus["Prometheus"] -->|"metrics scrape<br/>PodMonitor 8080/TCP HTTP"| TO

    %% Peer Integration (Kueue)
    Kueue["Kueue"] -->|"mutating + validating<br/>webhooks on all<br/>training job CRDs"| TO
    TO -.->|"MultiKueue delegation<br/>managedBy field"| Kueue

    %% Kubernetes API Resources
    TO -->|"CRD watch<br/>Pod/Service CRUD<br/>RBAC management"| K8sAPI["Kubernetes API Server"]
    TO -->|"webhook config<br/>updates"| AdmissionReg["admissionregistration<br/>API"]

    %% Created CRDs
    subgraph CRDs["Custom Resource Definitions (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        XGBoostJob["XGBoostJob"]
        MPIJob["MPIJob"]
        PaddleJob["PaddleJob"]
        JAXJob["JAXJob"]
    end

    TO -->|"reconciles"| CRDs

