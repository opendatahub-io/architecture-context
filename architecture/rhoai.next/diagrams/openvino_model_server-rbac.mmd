graph TD
    subgraph Note["OVMS RBAC / Authentication Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRoles["No ClusterRoles / Roles defined<br/>OVMS is a standalone inference server<br/>and does not interact with the Kubernetes API.<br/>RBAC for InferenceService is managed<br/>by the KServe platform operator."]
        end

        subgraph PlatformAuth["Platform-Level Authentication (External)"]
            direction LR
            RHOAI3x["RHOAI 3.x<br/>kube-rbac-proxy sidecar<br/>(OIDC / ServiceAccount)"]
            RHOAI2x["RHOAI 2.x<br/>oauth-proxy sidecar<br/>(OpenShift OAuth)"]
            NginxMTLS["nginx mTLS sidecar<br/>(X.509 client certificates)<br/>extras/nginx-mtls-auth/"]
        end

        subgraph BuiltInAuth["Built-in API Authentication"]
            direction TB
            APIKeyConfig["API Key Configuration<br/>--api_key_file=path or<br/>API_KEY=value (env var)"]
            APIKeyValidation["HttpRestApiHandler<br/>Validates Authorization: Bearer header<br/>against configured API key"]
            APIKeyConfig -->|"configures"| APIKeyValidation
        end

        subgraph EndpointAuth["Endpoint Authentication Matrix"]
            direction TB
            AuthEndpoints["Authenticated Endpoints (when API key configured):<br/>/v1/chat/completions, /v1/completions,<br/>/v1/embeddings, /v1/rerank,<br/>/v1/images/generations, /v1/audio/*,<br/>/v1/models/*, /v2/models/*/infer,<br/>/v3/models/*"]
            UnauthEndpoints["Unauthenticated Endpoints (always):<br/>/v2/health/ready (readiness probe)<br/>/v2/health/live (liveness probe)<br/>/v2 (server metadata)<br/>/metrics (Prometheus)"]
            GRPCEndpoints["gRPC Endpoints (no built-in auth):<br/>PredictionService (predict, classify, regress)<br/>ModelService (get_model_status, reload_config)<br/>GRPCInferenceService (ModelInfer, ModelStreamInfer)"]
        end

        subgraph SecurityControls["In-Process Security Controls"]
            PathTraversal["Path Traversal Prevention<br/>isPathEscaped() blocks ../ in model paths<br/>Prevents unauthorized file access"]
            CORSControl["CORS Configuration<br/>Configurable allowed origins<br/>Drogon HTTP server level"]
        end

        subgraph Secrets["Secrets Used by OVMS"]
            AWSCreds["AWS Credentials (env vars)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_SESSION_TOKEN<br/>No auto-rotation"]
            GCSCreds["GCS Credentials<br/>Application Default Credentials<br/>No auto-rotation"]
            AzureCreds["Azure Credentials<br/>Connection string / SAS token<br/>No auto-rotation"]
            HFToken["HuggingFace Token<br/>HF_TOKEN (env var)<br/>No auto-rotation"]
            APIKey["API Key<br/>File or env var<br/>No auto-rotation"]
        end
    end

    %% Connections
    RHOAI3x -->|"protects"| AuthEndpoints
    RHOAI2x -->|"protects"| AuthEndpoints
    NginxMTLS -->|"protects"| AuthEndpoints
    APIKeyValidation -->|"validates"| AuthEndpoints

    %% Styling
    style NoRoles fill:#f0f0f0,stroke:#999,color:#666
    style RHOAI3x fill:#d5e8d4,stroke:#82b366
    style RHOAI2x fill:#d5e8d4,stroke:#82b366
    style NginxMTLS fill:#ffe6cc,stroke:#d79b00
    style APIKeyConfig fill:#dae8fc,stroke:#6c8ebf
    style APIKeyValidation fill:#dae8fc,stroke:#6c8ebf
    style AuthEndpoints fill:#d5e8d4,stroke:#82b366
    style UnauthEndpoints fill:#fff2cc,stroke:#d6b656
    style GRPCEndpoints fill:#f8cecc,stroke:#b85450
    style PathTraversal fill:#e1d5e7,stroke:#9673a6
    style CORSControl fill:#e1d5e7,stroke:#9673a6
    style AWSCreds fill:#fff2cc,stroke:#d6b656
    style GCSCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style HFToken fill:#fff2cc,stroke:#d6b656
    style APIKey fill:#fff2cc,stroke:#d6b656
