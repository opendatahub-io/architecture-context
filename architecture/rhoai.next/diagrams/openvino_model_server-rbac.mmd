graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["OVMS does not define its own RBAC resources.<br/>RBAC is managed by the deploying operator<br/>(KServe, RHOAI Operator)."]
    end

    subgraph PlatformRBAC["Platform-Level RBAC (Managed by KServe/RHOAI)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            OVMS_SA["OVMS Pod ServiceAccount<br/>(created by KServe)"]
        end

        subgraph AuthEnforcement["Authentication & Authorization Enforcement"]
            KubeRBAC["kube-rbac-proxy Sidecar<br/>Enforces K8s RBAC<br/>via SubjectAccessReview"]
            APIKey["OVMS API Key Auth<br/>(--api_key_file / API_KEY)<br/>Optional Bearer Token"]
        end
    end

    subgraph Endpoints["Endpoint Auth Requirements"]
        direction TB

        subgraph AuthRequired["Auth: API Key (Optional)"]
            REST_TFS["REST: /v1/models/* (TFS)"]
            REST_KServe["REST: /v2/models/* (KServe v2)"]
            REST_OpenAI["REST: /v3/*/chat/completions (OpenAI)"]
            REST_Metrics["REST: /metrics"]
            REST_Config["REST: /v1/config, /v1/config/reload"]
        end

        subgraph NoAuth["Auth: None (Bypassed)"]
            Health_Live["REST: /v2/health/live"]
            Health_Ready["REST: /v2/health/ready"]
        end

        subgraph NoBuiltinAuth["Auth: None (No Built-in gRPC Auth)"]
            gRPC_TFS["gRPC: PredictionService"]
            gRPC_Model["gRPC: ModelService"]
            gRPC_KServe["gRPC: GRPCInferenceService"]
        end
    end

    subgraph Secrets["Secrets (User/Operator Provisioned)"]
        direction TB
        AWSCreds["AWS Credentials<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_SESSION_TOKEN<br/>Type: Environment"]
        GCSCreds["GCS Credentials<br/>GOOGLE_APPLICATION_CREDENTIALS<br/>Type: JSON Key File"]
        AzureCreds["Azure Credentials<br/>AZURE_STORAGE_CONNECTION_STRING<br/>Type: Environment"]
        HFToken["Hugging Face Token<br/>HF_TOKEN<br/>Type: Environment"]
        APIKeySecret["API Key<br/>--api_key_file / API_KEY<br/>Type: File or Environment"]
    end

    %% Relationships
    OVMS_SA -->|"pod identity"| KubeRBAC
    KubeRBAC -->|"enforces access to"| AuthRequired
    APIKey -.->|"optional bearer check"| AuthRequired

    AWSCreds -->|"S3 model access"| OVMS_SA
    GCSCreds -->|"GCS model access"| OVMS_SA
    AzureCreds -->|"Azure model access"| OVMS_SA
    HFToken -->|"HF Hub access"| OVMS_SA
    APIKeySecret -->|"API auth"| APIKey

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,stroke-width:2px
    style OVMS_SA fill:#4a90e2,color:#fff
    style KubeRBAC fill:#f5a623,color:#fff
    style APIKey fill:#f5a623,color:#fff

    style REST_TFS fill:#d5e8d4,stroke:#82b366
    style REST_KServe fill:#d5e8d4,stroke:#82b366
    style REST_OpenAI fill:#d5e8d4,stroke:#82b366
    style REST_Metrics fill:#d5e8d4,stroke:#82b366
    style REST_Config fill:#d5e8d4,stroke:#82b366

    style Health_Live fill:#e8e8e8,stroke:#999
    style Health_Ready fill:#e8e8e8,stroke:#999

    style gRPC_TFS fill:#f8cecc,stroke:#b85450
    style gRPC_Model fill:#f8cecc,stroke:#b85450
    style gRPC_KServe fill:#f8cecc,stroke:#b85450

    style AWSCreds fill:#fff2cc,stroke:#d6b656
    style GCSCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style HFToken fill:#fff2cc,stroke:#d6b656
    style APIKeySecret fill:#fff2cc,stroke:#d6b656
