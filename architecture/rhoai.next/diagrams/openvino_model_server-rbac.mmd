graph TD
    subgraph PodSecurity["Pod Security Context"]
        OVMSUser["OVMS Process<br/>UID: 5000 / GID: 5000<br/>User: ovms<br/>Non-root"]
    end

    subgraph NoK8sRBAC["No Kubernetes RBAC Defined"]
        direction TB
        Note1["OVMS does not define its own<br/>ClusterRoles, Roles, or RoleBindings"]
        Note2["No Kubernetes API access<br/>from the OVMS container"]
    end

    subgraph PlatformAuth["Platform-Level Authentication (kube-rbac-proxy)"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>Injected by RHOAI Operator"]

        subgraph TokenReview["Authentication"]
            TR["TokenReview API<br/>Validates K8s Bearer Token"]
        end

        subgraph SubjectAccess["Authorization"]
            SAR["SubjectAccessReview API<br/>Checks RBAC permissions"]
        end

        KubeRBAC -->|"validates token"| TR
        KubeRBAC -->|"checks permissions"| SAR
    end

    subgraph AppAuth["Application-Level Auth (v3 API only)"]
        APIKeyCheck["isAuthorized() Handler<br/>Checks Bearer token<br/>in Authorization header"]

        subgraph V3Endpoints["Protected Endpoints"]
            Chat["/v3/chat/completions"]
            Completions["/v3/completions"]
            EmbeddingsEP["/v3/embeddings"]
            Rerank["/v3/rerank"]
            Tokenize["/v3/tokenize"]
            TTS["/v3/text-to-speech"]
            ImageGen["/v3/image-generation"]
            Models["/v3/models"]
        end

        APIKeyCheck -->|"optional guard"| Chat
        APIKeyCheck -->|"optional guard"| Completions
        APIKeyCheck -->|"optional guard"| EmbeddingsEP
        APIKeyCheck -->|"optional guard"| Rerank
        APIKeyCheck -->|"optional guard"| Tokenize
        APIKeyCheck -->|"optional guard"| TTS
        APIKeyCheck -->|"optional guard"| ImageGen
        APIKeyCheck -->|"optional guard"| Models
    end

    subgraph OpenEndpoints["Open Endpoints (No App-Level Auth)"]
        V1["/v1/models/* (TFS v1)<br/>No auth"]
        V2["/v2/* (KServe v2)<br/>No auth"]
        Metrics["/metrics (Prometheus)<br/>No auth"]
        GRPC["gRPC Services<br/>InsecureServerCredentials<br/>No auth"]
    end

    subgraph SecretAccess["Secrets Consumed"]
        HFToken["HF_TOKEN<br/>env var<br/>HuggingFace auth"]
        AWSCreds["AWS Credentials<br/>env vars / IAM role<br/>S3 access"]
        GCSCreds["GCS Credentials<br/>service account JSON<br/>GCS access"]
        AzureCreds["Azure Connection String<br/>env var<br/>Azure Blob access"]
    end

    Client["External Client"] -->|"HTTPS/8443<br/>K8s Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP (localhost)<br/>Authenticated"| OVMSUser
    OVMSUser --> APIKeyCheck
    OVMSUser --> OpenEndpoints
    OVMSUser -->|"reads at startup"| SecretAccess

    style PodSecurity fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
