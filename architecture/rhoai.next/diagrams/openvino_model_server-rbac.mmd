graph TD
    subgraph PodSecurity["Pod Security Context"]
        OVMSProcess["OVMS Process<br/>UID: 5000 / GID: 5000<br/>User: ovms<br/>Non-root"]
    end

    subgraph NoK8sRBAC["Kubernetes RBAC (None Defined)"]
        direction TB
        NoRoles["No ClusterRoles"]
        NoBindings["No RoleBindings"]
        NoSA["No custom ServiceAccount"]
        Note1["OVMS does not define its own<br/>RBAC resources. Pod has no<br/>Kubernetes API access."]
    end

    subgraph PlatformAuth["Platform-Level Auth (RHOAI)"]
        direction TB

        subgraph KRBACProxy["kube-rbac-proxy Sidecar"]
            TokenReview["TokenReview<br/>Validates K8s Bearer Token"]
            SAReview["SubjectAccessReview<br/>RBAC-based authorization"]
        end

        subgraph IstioAuth["Istio Service Mesh (Optional)"]
            PeerAuth["PeerAuthentication<br/>mTLS STRICT"]
            AuthzPolicy["AuthorizationPolicy<br/>Service identity-based access"]
        end
    end

    subgraph AppLevelAuth["Application-Level Auth (OVMS)"]
        direction TB

        subgraph V3Auth["OpenAI v3 API Auth"]
            APIKeyCheck["isAuthorized()<br/>HTTP handler check"]
            BearerToken["API Key<br/>Bearer token in header"]
        end

        subgraph OpenEndpoints["Open Endpoints (No Auth)"]
            V1Open["/v1/* TFS v1<br/>No authentication"]
            V2Open["/v2/* KServe v2<br/>No authentication"]
            GRPCOpen["gRPC services<br/>InsecureServerCredentials"]
            MetricsOpen["/metrics<br/>No authentication"]
        end
    end

    subgraph SecretAccess["Secrets Accessed by OVMS"]
        direction TB
        HFToken["HF_TOKEN<br/>Environment variable<br/>HuggingFace Hub auth<br/>User-provisioned"]
        AWSCreds["AWS Credentials<br/>Env vars or IAM role (IRSA)<br/>S3 model storage"]
        GCSCreds["GCS Credentials<br/>Service account JSON<br/>GCS model storage"]
        AzureCreds["Azure Connection String<br/>Environment variable<br/>Azure Blob storage"]
    end

    %% Connections
    OVMSProcess -->|"no API access"| NoK8sRBAC
    TokenReview -->|"authenticates requests<br/>before reaching OVMS"| OVMSProcess
    SAReview -->|"authorizes access"| OVMSProcess
    PeerAuth -.->|"encrypts traffic"| OVMSProcess
    BearerToken -->|"validated by"| APIKeyCheck
    OVMSProcess -->|"reads at startup"| HFToken
    OVMSProcess -->|"reads for model loading"| AWSCreds
    OVMSProcess -->|"reads for model loading"| GCSCreds
    OVMSProcess -->|"reads for model loading"| AzureCreds

    %% Styling
    style OVMSProcess fill:#4a90e2,stroke:#333,color:#fff
    style NoRoles fill:#f8cecc,stroke:#b85450
    style NoBindings fill:#f8cecc,stroke:#b85450
    style NoSA fill:#f8cecc,stroke:#b85450
    style Note1 fill:#f8cecc,stroke:#b85450
    style TokenReview fill:#ffe6cc,stroke:#d79b00
    style SAReview fill:#ffe6cc,stroke:#d79b00
    style PeerAuth fill:#ffe6cc,stroke:#d79b00
    style AuthzPolicy fill:#ffe6cc,stroke:#d79b00
    style APIKeyCheck fill:#d5e8d4,stroke:#82b366
    style BearerToken fill:#d5e8d4,stroke:#82b366
    style V1Open fill:#f9f9f9,stroke:#999
    style V2Open fill:#f9f9f9,stroke:#999
    style GRPCOpen fill:#f9f9f9,stroke:#999
    style MetricsOpen fill:#f9f9f9,stroke:#999
    style HFToken fill:#fff2cc,stroke:#d6b656
    style AWSCreds fill:#fff2cc,stroke:#d6b656
    style GCSCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
