graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["OVMS is a standalone inference server<br/>and does NOT define Kubernetes RBAC roles.<br/><br/>RBAC for KServe InferenceService is managed<br/>by the platform operator."]
    end

    subgraph AuthN["Authentication Mechanisms"]
        direction TB

        subgraph RESTAuth["REST API Authentication"]
            APIKeyFile["--api_key_file flag<br/>or API_KEY env var"]
            BearerToken["Authorization: Bearer &lt;key&gt;<br/>validated by HttpRestApiHandler"]
            APIKeyFile -->|"configures"| BearerToken
        end

        subgraph GRPCAuth["gRPC Authentication"]
            NoBuiltIn["No built-in auth"]
            ExternalProxy["External proxy required:<br/>- kube-rbac-proxy (RHOAI 3.x)<br/>- oauth-proxy (RHOAI 2.x)<br/>- nginx mTLS sidecar<br/>- Istio service mesh"]
            NoBuiltIn -->|"delegated to"| ExternalProxy
        end

        subgraph UnauthEndpoints["Unauthenticated Endpoints"]
            HealthReady["/v2/health/ready"]
            HealthLive["/v2/health/live"]
            Metrics["/metrics<br/>(--metrics_enable flag)"]
        end
    end

    subgraph SecurityControls["Security Controls"]
        direction TB
        PathTraversal["Path Traversal Prevention<br/>isPathEscaped() blocks ../ sequences"]
        MaxMsgSize["Max Message Size: 1GB<br/>(gRPC and REST)"]
        CORS["CORS Configuration<br/>(Drogon HTTP server)"]
    end

    subgraph Secrets["Secrets Management"]
        direction TB
        AWSCreds["AWS Credentials<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_SESSION_TOKEN<br/>(env vars, no auto-rotate)"]
        GCSCreds["GCS Credentials<br/>Application Default Credentials<br/>(no auto-rotate)"]
        AzureCreds["Azure Credentials<br/>Connection String / SAS Token<br/>(no auto-rotate)"]
        HFToken["HuggingFace Token<br/>HF_TOKEN env var<br/>(optional, no auto-rotate)"]
        APIKey["API Key<br/>--api_key_file or API_KEY env<br/>(no auto-rotate)"]
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style RESTAuth fill:#d5e8d4,stroke:#82b366
    style GRPCAuth fill:#ffe6cc,stroke:#d79b00
    style UnauthEndpoints fill:#f8d7da,stroke:#dc3545
    style SecurityControls fill:#d1ecf1,stroke:#0c5460
    style Secrets fill:#e1d5e7,stroke:#9673a6

    style APIKeyFile fill:#d5e8d4,stroke:#82b366
    style BearerToken fill:#d5e8d4,stroke:#82b366
    style NoBuiltIn fill:#ffe6cc,stroke:#d79b00
    style ExternalProxy fill:#ffe6cc,stroke:#d79b00
    style HealthReady fill:#f8d7da,stroke:#dc3545
    style HealthLive fill:#f8d7da,stroke:#dc3545
    style Metrics fill:#f8d7da,stroke:#dc3545
    style PathTraversal fill:#d1ecf1,stroke:#0c5460
    style MaxMsgSize fill:#d1ecf1,stroke:#0c5460
    style CORS fill:#d1ecf1,stroke:#0c5460
    style AWSCreds fill:#e1d5e7,stroke:#9673a6
    style GCSCreds fill:#e1d5e7,stroke:#9673a6
    style AzureCreds fill:#e1d5e7,stroke:#9673a6
    style HFToken fill:#e1d5e7,stroke:#9673a6
    style APIKey fill:#e1d5e7,stroke:#9673a6
