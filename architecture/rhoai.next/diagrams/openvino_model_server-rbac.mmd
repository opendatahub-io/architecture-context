graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["🔵 Platform Security"]
        L2["🟠 Auth Mechanism"]
        L3["🟢 Protected Endpoint"]
        L4["⚪ No Built-in Auth"]
    end

    subgraph PlatformRBAC["Platform RBAC (kube-rbac-proxy Sidecar)"]
        direction TB
        KRBAC["kube-rbac-proxy<br/>(Injected by rhods-operator)"]

        subgraph AuthNLayer["Authentication (AuthN)"]
            TokenReview["Kubernetes TokenReview<br/>Validates bearer tokens<br/>against K8s API server"]
        end

        subgraph AuthZLayer["Authorization (AuthZ)"]
            SubjectAccessReview["Kubernetes SubjectAccessReview<br/>Checks RBAC permissions<br/>for authenticated identity"]
        end

        KRBAC --> TokenReview
        KRBAC --> SubjectAccessReview
    end

    subgraph OVMSBuiltIn["OVMS Built-in Auth (Optional)"]
        direction TB
        APIKeyFile["--api_key_file / API_KEY env<br/>Bearer Token validation"]
        APIKeyFile -->|"validates"| BearerCheck["Token Match Check<br/>http_rest_api_handler.cpp"]
        BearerCheck -->|"401 Unauthorized<br/>if invalid"| Reject["Reject Request"]
        BearerCheck -->|"pass"| Allow["Allow Request"]
    end

    subgraph Endpoints["OVMS Endpoints"]
        direction TB

        subgraph ProtectedBySidecar["Protected by kube-rbac-proxy (External AuthN/AuthZ)"]
            V1["REST: /v1/models/{model}:predict<br/>(TFS predict)"]
            V2Infer["REST: /v2/models/{model}/infer<br/>(KServe v2 inference)"]
            V2Meta["REST: /v2/models/{model}<br/>(Model metadata)"]
            GRPCPredict["gRPC: PredictionService.Predict<br/>(TFS gRPC)"]
            GRPCInfer["gRPC: GRPCInferenceService.ModelInfer<br/>(KServe v2 gRPC)"]
            GRPCStream["gRPC: GRPCInferenceService.ModelStreamInfer<br/>(KServe v2 streaming)"]
        end

        subgraph ProtectedByAPIKey["Protected by Built-in Bearer Token (/v3/*)"]
            V3Chat["/v3/chat/completions<br/>(OpenAI-compat chat)"]
            V3Completions["/v3/completions<br/>(OpenAI-compat completions)"]
            V3Embeddings["/v3/embeddings<br/>(OpenAI-compat embeddings)"]
            V3Rerank["/v3/rerank<br/>(Cohere-compat reranking)"]
            V3S2T["/v3/speech_to_text<br/>(Audio transcription)"]
            V3T2S["/v3/text_to_speech<br/>(Audio synthesis)"]
            V3ImageGen["/v3/image_generation<br/>(Stable Diffusion)"]
            V3Models["/v3/models<br/>(List models)"]
        end

        subgraph Unprotected["No Built-in Auth (Network Policy / Probes)"]
            HealthLive["/v2/health/live<br/>(Liveness probe)"]
            HealthReady["/v2/health/ready<br/>(Readiness probe)"]
            Metrics["/metrics<br/>(Prometheus scrape)"]
            ConfigReload["/v1/config/reload<br/>(Config hot-reload)"]
        end
    end

    %% kube-rbac-proxy protects all external traffic
    KRBAC -->|"TLS termination +<br/>K8s RBAC enforcement"| ProtectedBySidecar
    KRBAC -->|"TLS termination +<br/>K8s RBAC enforcement"| ProtectedByAPIKey

    %% Built-in API key auth
    APIKeyFile -->|"Optional Bearer Token<br/>validation (if configured)"| ProtectedByAPIKey

    %% Unprotected endpoints
    Kubelet["Kubernetes Kubelet"] -->|"HTTP GET<br/>(plaintext)"| HealthLive
    Kubelet -->|"HTTP GET<br/>(plaintext)"| HealthReady
    PromServer["Prometheus Server"] -->|"HTTP GET<br/>(plaintext)"| Metrics

    subgraph Secrets["Secrets Used for Auth"]
        HFToken["HF_TOKEN (env)<br/>HuggingFace Hub auth"]
        APIKey["API_KEY / --api_key_file<br/>REST Bearer Token"]
        AWSCreds["AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>S3 model storage"]
        GCPCreds["GOOGLE_APPLICATION_CREDENTIALS<br/>GCS model storage"]
        AzureCreds["Azure connection string<br/>SAS token / Managed identity"]
    end

    %% Styling
    style KRBAC fill:#4a90e2,stroke:#333,color:#fff
    style TokenReview fill:#4a90e2,stroke:#333,color:#fff
    style SubjectAccessReview fill:#4a90e2,stroke:#333,color:#fff
    style APIKeyFile fill:#f5a623,stroke:#333
    style BearerCheck fill:#f5a623,stroke:#333
    style V1 fill:#7ed321,stroke:#333
    style V2Infer fill:#7ed321,stroke:#333
    style V2Meta fill:#7ed321,stroke:#333
    style GRPCPredict fill:#7ed321,stroke:#333
    style GRPCInfer fill:#7ed321,stroke:#333
    style GRPCStream fill:#7ed321,stroke:#333
    style V3Chat fill:#7ed321,stroke:#333
    style V3Completions fill:#7ed321,stroke:#333
    style V3Embeddings fill:#7ed321,stroke:#333
    style V3Rerank fill:#7ed321,stroke:#333
    style V3S2T fill:#7ed321,stroke:#333
    style V3T2S fill:#7ed321,stroke:#333
    style V3ImageGen fill:#7ed321,stroke:#333
    style V3Models fill:#7ed321,stroke:#333
    style HealthLive fill:#e8e8e8,stroke:#999
    style HealthReady fill:#e8e8e8,stroke:#999
    style Metrics fill:#e8e8e8,stroke:#999
    style ConfigReload fill:#e8e8e8,stroke:#999
    style HFToken fill:#fff2cc,stroke:#d6b656
    style APIKey fill:#fff2cc,stroke:#d6b656
    style AWSCreds fill:#fff2cc,stroke:#d6b656
    style GCPCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style Reject fill:#e06666,stroke:#333,color:#fff
    style Allow fill:#7ed321,stroke:#333
