graph TB
    subgraph "caikit-tgis-backend Library"
        direction TB
        TGISBackend["TGISBackend<br/>(BackendBase plugin)<br/>backend_type='TGIS'"]
        TGISConnection["TGISConnection<br/>gRPC connection manager<br/>TLS/mTLS config"]
        LoadBalancer["GRPCLoadBalancerProxy<br/>DNS-based endpoint discovery<br/>Automatic channel reconnection"]
        ManagedSubprocess["ManagedTGISSubprocess<br/>Local TGIS lifecycle<br/>Health monitoring + auto-recovery"]
        ProtoStubs["generation_pb2 / generation_pb2_grpc<br/>fmaas.GenerationService stubs<br/>Generate, GenerateStream, Tokenize, ModelInfo"]

        TGISBackend -->|"creates per-model"| TGISConnection
        TGISBackend -->|"manages (local mode)"| ManagedSubprocess
        TGISConnection -->|"creates gRPC client via"| LoadBalancer
        TGISConnection -->|"uses stubs from"| ProtoStubs
        LoadBalancer -->|"wraps"| ProtoStubs
    end

    subgraph "Caikit Core Framework"
        CaikitRegistry["Backend Registry<br/>register_backend_type()"]
        CaikitRuntime["Caikit Runtime<br/>(consuming application)"]
    end

    subgraph "Remote Mode"
        RemoteTGIS["Remote TGIS Server<br/>50055/TCP gRPC<br/>TLS/mTLS/plaintext"]
        DNS["DNS Resolver<br/>53/UDP<br/>Endpoint discovery"]
    end

    subgraph "Local Mode"
        LocalTGIS["Local TGIS Subprocess<br/>50055/TCP gRPC (localhost)<br/>3000/TCP HTTP health"]
    end

    subgraph "Filesystem"
        PromptDir["Shared Prompt Directory<br/>Prompt vector artifacts<br/>for prefix tuning"]
    end

    %% Registration
    TGISBackend -.->|"registers at import"| CaikitRegistry
    CaikitRuntime -->|"discovers & configures"| TGISBackend

    %% Remote mode flows
    LoadBalancer -->|"gRPC inference<br/>TLS/mTLS"| RemoteTGIS
    LoadBalancer -->|"polls for endpoints"| DNS

    %% Local mode flows
    ManagedSubprocess -->|"launches & monitors"| LocalTGIS
    ManagedSubprocess -->|"HTTP health check<br/>3000/TCP"| LocalTGIS

    %% Prompt artifacts
    TGISConnection -->|"copies artifacts to"| PromptDir

    %% Styling
    style TGISBackend fill:#4a90e2,stroke:#333,color:#fff
    style TGISConnection fill:#4a90e2,stroke:#333,color:#fff
    style LoadBalancer fill:#4a90e2,stroke:#333,color:#fff
    style ManagedSubprocess fill:#4a90e2,stroke:#333,color:#fff
    style ProtoStubs fill:#6baed6,stroke:#333,color:#fff
    style CaikitRegistry fill:#7ed321,stroke:#333,color:#fff
    style CaikitRuntime fill:#7ed321,stroke:#333,color:#fff
    style RemoteTGIS fill:#f5a623,stroke:#333,color:#fff
    style LocalTGIS fill:#f5a623,stroke:#333,color:#fff
    style DNS fill:#e8e8e8,stroke:#333
    style PromptDir fill:#e8e8e8,stroke:#333
