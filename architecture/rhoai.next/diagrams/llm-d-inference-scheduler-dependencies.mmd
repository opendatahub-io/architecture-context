graph LR
    LLMDScheduler["llm-d-inference-scheduler<br/>(EPP + PD Sidecar)"]

    %% External Dependencies (Required)
    LLMDScheduler -->|"ext-proc gRPC<br/>9002/TCP TLS"| Envoy["Envoy Gateway<br/>(via Gateway impl)"]
    LLMDScheduler -->|"CRD watches<br/>443/TCP HTTPS"| K8s["Kubernetes 1.31+"]
    LLMDScheduler -->|"HTTPRoute, Gateway<br/>CRDs"| GatewayAPI["Gateway API v1.5.1"]
    LLMDScheduler -->|"InferencePool CRD<br/>ext-proc framework"| GIE["Gateway API<br/>Inference Extension v1.5.0"]
    LLMDScheduler -->|"controller framework<br/>leader election"| ControllerRT["controller-runtime<br/>v0.23.3"]
    LLMDScheduler -->|"ext-proc protobuf"| EnvoyCP["envoy-go-control-plane<br/>v1.37.0"]
    LLMDScheduler -->|"ZMQ SUB 5557/TCP<br/>KV-cache block index"| KVCacheLib["llm-d-kv-cache<br/>v0.7.1"]
    LLMDScheduler -->|"metrics instrumentation"| PromClient["Prometheus client<br/>v1.23.2"]

    %% External Dependencies (Optional)
    LLMDScheduler -.->|"traces gRPC 4317/TCP"| OTEL["OpenTelemetry<br/>v1.43.0"]
    LLMDScheduler -.->|"mTLS, DestinationRules<br/>(dev environments)"| Istio["Istio<br/>(optional)"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"HTTP metrics scraping<br/>+ Pod watch"| vLLM["vLLM / Model Servers"]
    LLMDScheduler -->|"Unix Domain Socket<br/>/tmp/tokenizer"| UDSTokenizer["UDS Tokenizer<br/>(sidecar)"]

    %% Integration Points (consumed by)
    Prometheus["Prometheus /<br/>ServiceMonitor"] -->|"scrape /metrics<br/>9090/TCP HTTP"| LLMDScheduler
    Envoy -->|"routed inference<br/>requests 80/TCP"| LLMDScheduler

    %% PD Sidecar specific
    LLMDScheduler -->|"prefill requests<br/>HTTP/HTTPS TLS"| RemotePrefiller["Remote Prefiller<br/>Pods"]
    LLMDScheduler -->|"encoder requests<br/>HTTP/HTTPS TLS"| RemoteEncoder["Remote Encoder<br/>Pods"]
    LLMDScheduler -->|"decode requests<br/>8001/TCP HTTP"| LocalDecoder["Local vLLM<br/>Decoder"]

