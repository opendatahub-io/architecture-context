graph LR
    LLMDScheduler["llm-d Inference Scheduler<br/>(EPP + P/D Sidecar)"]

    %% External Dependencies (Required)
    LLMDScheduler -->|"ext_proc gRPC<br/>routing callbacks"| EnvoyGateway["Envoy Gateway<br/>(Istio or kGateway)"]
    LLMDScheduler -->|"core GIE framework<br/>v1.5.0"| GIE["Gateway API<br/>Inference Extension"]
    LLMDScheduler -->|"HTTPRoute, Gateway<br/>v1.5.1"| GatewayAPI["Gateway API CRDs"]
    LLMDScheduler -->|"controller framework<br/>v0.23.3"| ControllerRuntime["controller-runtime"]
    LLMDScheduler -->|"ext_proc types<br/>v1.37.0"| EnvoyControlPlane["envoy go-control-plane"]
    LLMDScheduler -->|"KV cache indexing<br/>v0.7.1"| KVCacheLib["llm-d-kv-cache"]
    LLMDScheduler -->|"API types<br/>v1.12.0"| OpenAIGo["openai-go"]
    LLMDScheduler -->|"metrics exposition<br/>v1.23.2"| PromClient["prometheus client_golang"]
    LLMDScheduler -->|"distributed tracing<br/>v1.43.0"| OTel["OpenTelemetry SDK"]
    LLMDScheduler -->|"expression eval<br/>v0.26.0"| CEL["CEL-Go"]
    LLMDScheduler -->|"K8s client<br/>v0.35.4"| ClientGo["k8s client-go"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"gRPC ext_proc<br/>9002/TCP"| Envoy2["Envoy Gateway"]
    LLMDScheduler -->|"CRD watch<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    LLMDScheduler -->|"metrics scraping<br/>HTTP(S)"| vLLM["vLLM Model Servers"]
    LLMDScheduler -->|"KV cache events<br/>ZMQ 5556/TCP"| vLLM
    LLMDScheduler -->|"tokenization<br/>gRPC over UDS"| UDSTokenizer["UDS Tokenizer"]

    %% CRDs Watched
    LLMDScheduler -->|"watches"| InferencePool["InferencePool CRD<br/>(GIE)"]
    LLMDScheduler -->|"watches"| InferenceObjective["InferenceObjective CRD<br/>(GIE)"]
    LLMDScheduler -->|"watches"| InferenceModelRewrite["InferenceModelRewrite CRD<br/>(GIE)"]
    LLMDScheduler -->|"watches"| PodResources["Pod Resources<br/>(core)"]

    %% Integration Points (other components using this)
    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|"scrape /metrics<br/>9090/TCP HTTP"| LLMDScheduler
    OTelCollector["OpenTelemetry Collector"] -.->|"OTLP traces<br/>4317/TCP gRPC"| LLMDScheduler
    GatewayHTTPRoute["HTTPRoute"] -->|"backendRef →<br/>InferencePool"| LLMDScheduler

    %% Sidecar-specific dependencies
    LLMDScheduler -->|"prefill requests<br/>HTTP(S)"| PrefillerPods["Prefiller Pods"]
    LLMDScheduler -->|"decode requests<br/>8001/TCP"| DecoderPods["Decoder Pods"]
    LLMDScheduler -->|"encode requests<br/>HTTP(S) (E/P/D)"| EncoderPods["Encoder Pods"]

