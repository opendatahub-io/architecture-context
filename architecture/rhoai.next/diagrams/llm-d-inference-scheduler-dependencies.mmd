    style Kubernetes fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff

    %% External optional
    style Prometheus fill:#bbb,stroke:#333,color:#fff
    style OTEL fill:#bbb,stroke:#333,color:#fff

