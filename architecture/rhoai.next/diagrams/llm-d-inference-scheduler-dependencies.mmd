graph LR
    LLMDScheduler["llm-d Inference<br/>Scheduler"]

    %% External Dependencies (Required)
    LLMDScheduler -->|"ext-proc callbacks<br/>gRPC/9002"| Envoy["Envoy Proxy<br/>v1.37+"]
    LLMDScheduler -->|"CRD watches<br/>HTTPS/443"| K8s["Kubernetes<br/>v1.31+"]
    LLMDScheduler -->|"Gateway + HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API<br/>v1.5.1"]
    LLMDScheduler -->|"InferencePool, InferenceModel<br/>ext-proc framework"| GIE["Gateway API<br/>Inference Extension<br/>v1.5.0"]
    LLMDScheduler -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]

    %% External Dependencies (Optional)
    LLMDScheduler -.->|"metrics scraping<br/>HTTP/9090"| Prometheus["Prometheus"]
    LLMDScheduler -.->|"trace export<br/>gRPC/4317"| OTel["OpenTelemetry<br/>Collector"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"metrics scrape HTTP/3000<br/>inference routing HTTP/8000"| vLLM["vLLM Model<br/>Servers"]
    LLMDScheduler -->|"KV cache block index<br/>Go library"| KVCache["llm-d-kv-cache"]
    LLMDScheduler -->|"prompt tokenization<br/>gRPC over UDS"| UDSTokenizer["UDS Tokenizer<br/>Sidecar"]
    LLMDScheduler -->|"KV cache events<br/>ZMQ SUB/5557"| ZMQPublisher["ZMQ KV-Events<br/>Publisher"]

    %% Integration Points (Inbound)
    Envoy -->|"ext-proc bidirectional<br/>stream gRPC/9002"| LLMDScheduler
    Prometheus -->|"scrapes /metrics<br/>HTTP/9090"| LLMDScheduler

    %% PD Sidecar specific dependencies
    subgraph "PD Sidecar Dependencies"
        Prefiller["Prefiller<br/>Instances"]
        Encoder["Encoder<br/>Instances"]
        LocalDecoder["Local Decoder<br/>(vLLM)"]
    end
    LLMDScheduler -->|"prefill requests<br/>HTTP/HTTPS Dynamic"| Prefiller
    LLMDScheduler -->|"encode requests<br/>HTTP/HTTPS Dynamic"| Encoder
    LLMDScheduler -->|"decode requests<br/>HTTP/8001 localhost"| LocalDecoder

    %% Styling
    style LLMDScheduler fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Envoy fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style GIE fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#bbb,stroke:#333,color:#333
    style OTel fill:#bbb,stroke:#333,color:#333
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style KVCache fill:#7ed321,stroke:#333,color:#fff
    style UDSTokenizer fill:#7ed321,stroke:#333,color:#fff
    style ZMQPublisher fill:#7ed321,stroke:#333,color:#fff
    style Prefiller fill:#f5a623,stroke:#333,color:#fff
    style Encoder fill:#f5a623,stroke:#333,color:#fff
    style LocalDecoder fill:#f5a623,stroke:#333,color:#fff
