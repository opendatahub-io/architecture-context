graph LR
    Router["llm-d Router<br/>(Inference Scheduler)"]

    %% External Dependencies (Required)
    Router -->|"ext_proc v3<br/>gRPC/9002"| Envoy["Envoy Proxy<br/>(ext_proc compatible)"]
    Router -->|"CRD watches<br/>HTTPS/443"| K8s["Kubernetes 1.31+<br/>(k8s.io/api v0.35.6)"]
    Router -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    Router -->|"InferencePool CRD"| GIE["gateway-api-inference-ext<br/>v1.5.0"]
    Router -->|"HTTPRoute, Gateway"| GatewayAPI["Gateway API<br/>v1.5.1"]
    Router -->|"metrics exposition"| PromClient["Prometheus<br/>client_golang v1.23.2"]
    Router -->|"model serving<br/>HTTP/HTTPS"| vLLM["vLLM<br/>(compatible version)"]

    %% External Dependencies (Optional)
    Router -.->|"distributed traces<br/>gRPC/4317"| OTel["OpenTelemetry<br/>v1.44.0"]
    Router -.->|"KV-cache events<br/>ZMQ/5557"| KVCache["llm-d-kv-cache<br/>v0.9.0-rc.1"]
    Router -.->|"ZMQ SUB socket"| ZMQ["ZeroMQ (zmq4)<br/>v0.17.0"]

    %% Internal Platform Dependencies
    Router -->|"CRD watch<br/>pool config"| InferencePool["InferencePool<br/>(GIE CRD)"]
    Router -->|"CRD watch<br/>priority config"| InferenceObj["InferenceObjective<br/>(llm-d CRD)"]
    Router -->|"CRD watch<br/>model rewrite"| InferenceRewrite["InferenceModelRewrite<br/>(llm-d CRD)"]
    Router -->|"pod watch<br/>endpoint tracking"| ModelPods["Model Server Pods<br/>(vLLM / SGLang)"]
    Router -->|"metrics polling<br/>HTTP/HTTPS"| ModelMetrics["Model Server Metrics<br/>(KV cache, queue, running)"]

    %% Sidecar-specific dependencies
    Router -.->|"KV transfer<br/>NIXL v2 / shared / SGLang"| PrefillerPods["Prefiller Pods"]
    Router -.->|"encode requests<br/>fan-out"| EncoderPods["Encoder Pods"]
    Router -.->|"Mooncake bootstrap<br/>HTTP/8998"| MooncakeBS["Mooncake Bootstrap"]

    %% Deployment dependencies
    Router -.->|"service mesh<br/>gateway integration"| Istio["Istio"]
    Router -.->|"TLS certificates"| CertManager["cert-manager 1.13+"]

    %% Integration points (other components → Router)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| Router
    Gateway["Gateway API<br/>HTTPRoute"] -->|"references<br/>InferencePool"| Router

    %% Styling
    style Router fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Envoy fill:#7f8c8d,stroke:#333,color:#fff
    style K8s fill:#7f8c8d,stroke:#333,color:#fff
    style CtrlRuntime fill:#7f8c8d,stroke:#333,color:#fff
    style GIE fill:#7f8c8d,stroke:#333,color:#fff
    style GatewayAPI fill:#7f8c8d,stroke:#333,color:#fff
    style PromClient fill:#7f8c8d,stroke:#333,color:#fff
    style vLLM fill:#7f8c8d,stroke:#333,color:#fff

    %% Optional external
    style OTel fill:#bdc3c7,stroke:#333
    style KVCache fill:#bdc3c7,stroke:#333
    style ZMQ fill:#bdc3c7,stroke:#333
    style Istio fill:#bdc3c7,stroke:#333
    style CertManager fill:#bdc3c7,stroke:#333
    style MooncakeBS fill:#bdc3c7,stroke:#333

    %% Internal platform
    style InferencePool fill:#27ae60,stroke:#333,color:#fff
    style InferenceObj fill:#27ae60,stroke:#333,color:#fff
    style InferenceRewrite fill:#27ae60,stroke:#333,color:#fff
    style ModelPods fill:#27ae60,stroke:#333,color:#fff
    style ModelMetrics fill:#27ae60,stroke:#333,color:#fff
    style PrefillerPods fill:#27ae60,stroke:#333,color:#fff
    style EncoderPods fill:#27ae60,stroke:#333,color:#fff

    %% Integration inbound
    style Prometheus fill:#1abc9c,stroke:#333,color:#fff
    style Gateway fill:#1abc9c,stroke:#333,color:#fff
