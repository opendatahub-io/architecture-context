graph LR
    LLMDScheduler["llm-d Inference<br/>Scheduler"]

    %% External Dependencies (Required)
    LLMDScheduler -->|"ext-proc framework<br/>gRPC/9002"| EnvoyProxy["Envoy Proxy<br/>v1.37+"]
    LLMDScheduler -->|"CRDs + ext-proc<br/>interfaces"| GIE["Gateway API<br/>Inference Extension<br/>(GIE) v1.5.0"]
    LLMDScheduler -->|"Gateway +<br/>HTTPRoute CRDs"| GatewayAPI["Gateway API<br/>v1.5.1"]
    LLMDScheduler -->|"CRD watches<br/>RBAC, pod discovery<br/>HTTPS/443"| Kubernetes["Kubernetes<br/>v1.31+"]
    LLMDScheduler -->|"controller<br/>framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]

    %% External Dependencies (Optional)
    LLMDScheduler -.->|"metrics scraping<br/>HTTP/9090"| Prometheus["Prometheus"]
    LLMDScheduler -.->|"OTLP traces<br/>gRPC/4317"| OTEL["OpenTelemetry<br/>Collector"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"metrics scraping<br/>HTTP/3000 +<br/>inference routing<br/>HTTP/8000"| vLLM["vLLM<br/>Model Servers"]
    LLMDScheduler -->|"KV cache block<br/>index library"| KVCache["llm-d-kv-cache<br/>(Go library)"]
    LLMDScheduler -->|"prompt tokenization<br/>gRPC over UDS"| UDSTokenizer["UDS Tokenizer<br/>(sidecar)"]
    LLMDScheduler -->|"KV cache events<br/>ZMQ SUB/5557"| ZMQPublisher["ZMQ KV-Events<br/>Publisher"]

    %% Integration Points (consumers of this component)
    EnvoyProxy -->|"ext-proc callback<br/>per request"| LLMDScheduler
    Prometheus -.->|"scrapes /metrics<br/>ServiceMonitor"| LLMDScheduler

    %% Styling
    style LLMDScheduler fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

