graph LR
    LLMDScheduler["llm-d Inference<br/>Scheduler"]

    %% Core External Dependencies
    LLMDScheduler -->|"core framework<br/>ext_proc, controllers"| GIE["Gateway API<br/>Inference Extension<br/>v1.5.0"]
    LLMDScheduler -->|"HTTPRoute, Gateway<br/>types"| GatewayAPI["Gateway API<br/>v1.5.1"]
    LLMDScheduler -->|"controller framework<br/>manager, reconcilers"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    LLMDScheduler -->|"ext_proc protocol<br/>gRPC service defs"| EnvoyCP["Envoy<br/>go-control-plane<br/>v1.37.0"]
    LLMDScheduler -->|"KV cache indexing<br/>prefix matching"| KVCacheLib["llm-d-kv-cache<br/>v0.7.1"]

    %% Utility Dependencies
    LLMDScheduler -->|"API types<br/>request/response parsing"| OpenAI["openai-go<br/>v1.12.0"]
    LLMDScheduler -->|"metrics collection<br/>exposition"| PromClient["prometheus<br/>client_golang<br/>v1.23.2"]
    LLMDScheduler -->|"distributed tracing"| OTel["OpenTelemetry<br/>v1.43.0"]
    LLMDScheduler -->|"CEL expressions<br/>plugin config"| CEL["cel-go<br/>v0.26.0"]
    LLMDScheduler -->|"K8s API client"| ClientGo["k8s client-go<br/>v0.35.4"]

    %% Internal Platform Dependencies
    LLMDScheduler -->|"gRPC ext_proc<br/>routing callbacks<br/>9002/TCP"| EnvoyGW["Envoy Gateway<br/>(Istio or kGateway)"]
    LLMDScheduler -->|"CRD Watch<br/>pod selector, target ports"| InferencePool["InferencePool CRD<br/>(GIE)"]
    LLMDScheduler -->|"CRD Watch<br/>priority, SLOs"| InferenceObj["InferenceObjective CRD<br/>(GIE)"]
    LLMDScheduler -->|"CRD Watch<br/>model aliasing, routing"| ModelRewrite["InferenceModelRewrite CRD<br/>(GIE)"]
    LLMDScheduler -->|"HTTP metrics scraping<br/>ZMQ KV events"| vLLM["vLLM<br/>Model Servers"]
    LLMDScheduler -->|"backendRef routing"| HTTPRoute["Gateway API<br/>HTTPRoute"]

    %% Monitoring integration
    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|"scrape /metrics<br/>9090/TCP, 15s"| LLMDScheduler
    LLMDScheduler -.->|"gRPC OTLP<br/>4317/TCP"| OTelCollector["OpenTelemetry<br/>Collector"]

