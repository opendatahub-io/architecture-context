graph TD
    subgraph UserAuth["User Authentication"]
        User["Data Scientist<br/>(Notebook User)"]
        Token["Bearer Token<br/>(TokenAuthentication)"]
        KubeConfig["KubeConfig File<br/>(KubeConfigFileAuthentication)"]
    end

    User -->|"authenticates via"| Token
    User -->|"or authenticates via"| KubeConfig

    subgraph K8sRBAC["Kubernetes RBAC (User-provided, not SDK-installed)"]
        UserRole["Required Role/ClusterRole<br/>(user-provided)"]
    end

    Token -->|"presents to K8s API"| UserRole
    KubeConfig -->|"presents to K8s API"| UserRole

    subgraph RayResources["ray.io API Group"]
        RayClusters["rayclusters<br/>get, list, create, delete"]
    end

    subgraph CFResources["workload.codeflare.dev API Group"]
        AppWrappers["appwrappers<br/>get, list, create, delete"]
    end

    subgraph KueueResources["kueue.x-k8s.io API Group"]
        LocalQueues["localqueues<br/>get, list"]
    end

    subgraph OCPResources["route.openshift.io API Group"]
        Routes["routes<br/>get, list"]
    end

    subgraph CoreResources["Core API Group"]
        Secrets["secrets<br/>get, list"]
    end

    subgraph NetResources["networking.k8s.io API Group"]
        Ingresses["ingresses<br/>get, list"]
    end

    %% Role to resources
    UserRole -->|"get, list, create, delete"| RayClusters
    UserRole -->|"get, list, create, delete"| AppWrappers
    UserRole -->|"get, list"| LocalQueues
    UserRole -->|"get, list"| Routes
    UserRole -->|"get, list"| Secrets
    UserRole -->|"get, list"| Ingresses

    %% Additional auth mechanisms
    subgraph AdditionalAuth["Additional Authentication (Non-RBAC)"]
        RayDashAuth["Ray Dashboard Auth<br/>Bearer Token via OpenShift OAuth<br/>Endpoint: 8265/TCP"]
        RayClientAuth["Ray Client Auth<br/>mTLS Client Certificate (optional)<br/>Endpoint: 10001/TCP<br/>Cert: RSA-2048, SHA-256"]
    end

    User -.->|"job submission"| RayDashAuth
    User -.->|"interactive use"| RayClientAuth

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style Token fill:#5b9bd5,stroke:#333,color:#fff
    style KubeConfig fill:#5b9bd5,stroke:#333,color:#fff
    style UserRole fill:#f5a623,stroke:#333
    style RayClusters fill:#7ed321,stroke:#333
    style AppWrappers fill:#7ed321,stroke:#333
    style LocalQueues fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333
    style RayDashAuth fill:#e1d5e7,stroke:#9673a6
    style RayClientAuth fill:#e1d5e7,stroke:#9673a6
