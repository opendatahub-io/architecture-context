graph TD
    subgraph AuthMethods["Authentication Methods"]
        BearerToken["Bearer Token<br/>(TokenAuthentication)"]
        Kubeconfig["kubeconfig File<br/>(KubeConfigFileAuthentication)"]
        InCluster["In-Cluster SA Token<br/>(auto-detected)"]
    end

    subgraph UserSA["User / Service Account"]
        SA["Authenticated Identity<br/>(user or SA)"]
    end

    BearerToken -->|authenticates as| SA
    Kubeconfig -->|authenticates as| SA
    InCluster -->|authenticates as| SA

    subgraph RequiredPermissions["Required RBAC Permissions (Minimum)"]
        direction TB

        subgraph RayIO["API Group: ray.io"]
            RayClusters["rayclusters<br/>get, list, create, delete"]
        end

        subgraph WorkloadCF["API Group: workload.codeflare.dev"]
            AppWrappers["appwrappers<br/>get, list, create, delete"]
        end

        subgraph KueueIO["API Group: kueue.x-k8s.io"]
            LocalQueues["localqueues<br/>get, list"]
        end

        subgraph RouteOCP["API Group: route.openshift.io"]
            Routes["routes<br/>get, list"]
        end

        subgraph CoreAPI["API Group: core (v1)"]
            Secrets["secrets<br/>get, list"]
            Namespaces["namespaces<br/>get"]
        end

        subgraph NetworkingAPI["API Group: networking.k8s.io"]
            Ingresses["ingresses<br/>get, list"]
        end
    end

    SA -->|"requires"| RayClusters
    SA -->|"requires"| AppWrappers
    SA -->|"requires"| LocalQueues
    SA -->|"requires"| Routes
    SA -->|"requires"| Secrets
    SA -->|"requires"| Namespaces
    SA -->|"requires"| Ingresses

    subgraph SecretsManaged["Secrets Managed by SDK"]
        CASecret["{cluster}-ca-secret-*<br/>Type: Opaque<br/>Keys: ca.key, ca.crt<br/>Purpose: Ray TLS mTLS<br/>Validity: 30 days<br/>Auto-Rotate: No"]
    end

    SA -->|"get, create"| CASecret

    subgraph DashboardAuth["Ray Dashboard Authentication"]
        OCPDashAuth["OpenShift Dashboard<br/>Auth: Bearer Token (OAuth)<br/>Enforcement: Route + oauth-proxy"]
        K8sDashAuth["Vanilla K8s Dashboard<br/>Auth: None<br/>Enforcement: Ingress"]
    end

    SA -.->|"token forwarded"| OCPDashAuth
    SA -.->|"no auth needed"| K8sDashAuth

    %% Note about RBAC model
    Note["Note: SDK does NOT create<br/>ClusterRoles or RoleBindings.<br/>It operates with existing<br/>user/SA permissions."]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style BearerToken fill:#e3f2fd,stroke:#1565c0
    style Kubeconfig fill:#e3f2fd,stroke:#1565c0
    style InCluster fill:#e3f2fd,stroke:#1565c0

    style RayClusters fill:#c8e6c9,stroke:#2e7d32
    style AppWrappers fill:#c8e6c9,stroke:#2e7d32
    style LocalQueues fill:#c8e6c9,stroke:#2e7d32
    style Routes fill:#c8e6c9,stroke:#2e7d32
    style Secrets fill:#c8e6c9,stroke:#2e7d32
    style Namespaces fill:#c8e6c9,stroke:#2e7d32
    style Ingresses fill:#c8e6c9,stroke:#2e7d32

    style CASecret fill:#ffcdd2,stroke:#c62828

    style OCPDashAuth fill:#ffe0b2,stroke:#d79b00
    style K8sDashAuth fill:#ffe0b2,stroke:#d79b00

    style Note fill:#fff9c4,stroke:#f9a825,stroke-dasharray: 5 5
