graph TD
    subgraph UserAuth["User Authentication"]
        User["Data Scientist / ML Engineer"]
        SA["Service Account<br/>(notebook-sa or user context)"]
        Token["Bearer Token<br/>(OAuth / kubeconfig)"]
    end

    subgraph AuthFlow["Authentication Flow"]
        User -->|"authenticates as"| SA
        SA -->|"presents"| Token
        Token -->|"validated by"| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    end

    subgraph RequiredPerms["Required RBAC Permissions (user-required)"]
        direction TB
        Note["Note: SDK does NOT define RBAC resources.<br/>User/SA must have these permissions pre-configured."]
    end

    subgraph RayPerms["ray.io API Group"]
        RayClusters["rayclusters<br/>get, list, create, delete"]
    end

    subgraph CFPerms["workload.codeflare.dev API Group"]
        AppWrappers["appwrappers<br/>get, list, create, delete"]
    end

    subgraph KueuePerms["kueue.x-k8s.io API Group"]
        LocalQueues["localqueues<br/>get, list"]
    end

    subgraph RoutePerms["route.openshift.io API Group"]
        Routes["routes<br/>get, list"]
    end

    subgraph CorePerms["Core API Group"]
        Secrets["secrets<br/>get, list"]
    end

    subgraph NetPerms["networking.k8s.io API Group"]
        Ingresses["ingresses<br/>get, list"]
    end

    K8sAPI -->|"authorizes"| RayClusters
    K8sAPI -->|"authorizes"| AppWrappers
    K8sAPI -->|"authorizes"| LocalQueues
    K8sAPI -->|"authorizes"| Routes
    K8sAPI -->|"authorizes"| Secrets
    K8sAPI -->|"authorizes"| Ingresses

    subgraph TLSAuth["Ray Client Authentication (Tier 3)"]
        CASecret["{cluster}-ca-secret-*<br/>Opaque: ca.crt, ca.key<br/>Provisioned by: KubeRay/RHOAI"]
        LocalCert["Local TLS files<br/>tls-{cluster}-{ns}/<br/>Generated by: SDK"]
        RayClient["Ray Head Node<br/>10001/TCP gRPC<br/>mTLS"]
    end

    Secrets -->|"reads"| CASecret
    CASecret -->|"SDK generates"| LocalCert
    LocalCert -->|"mTLS client cert"| RayClient

    subgraph DashAuth["Ray Dashboard Authentication (Tier 2)"]
        DashRoute["OpenShift Route<br/>443/TCP HTTPS"]
        RayDash["Ray Dashboard<br/>8265/TCP"]
    end

    Routes -->|"discovers"| DashRoute
    Token -->|"forwarded as"| DashRoute
    DashRoute -->|"proxies to"| RayDash

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Token fill:#f5a623,stroke:#333,color:#333
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style Note fill:#fff2cc,stroke:#d6b656
    style RayClusters fill:#7ed321,stroke:#333
    style AppWrappers fill:#7ed321,stroke:#333
    style LocalQueues fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333
    style CASecret fill:#f5a623,stroke:#333
    style LocalCert fill:#f5a623,stroke:#333
    style RayClient fill:#e8e8e8,stroke:#333
    style DashRoute fill:#ffe6cc,stroke:#d79b00
    style RayDash fill:#e8e8e8,stroke:#333
