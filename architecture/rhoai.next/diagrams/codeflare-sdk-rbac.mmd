graph TD
    subgraph "Authentication Methods"
        TokenAuth["TokenAuthentication<br/>(Bearer Token)"]
        KubeConfigAuth["KubeConfigFileAuthentication<br/>(kubeconfig file)"]
        InClusterAuth["In-Cluster ServiceAccount<br/>(auto-detected via<br/>KUBERNETES_PORT env)"]
    end

    subgraph "User Identity"
        UserCreds["Authenticated User<br/>(no SDK-managed SA)"]
    end

    TokenAuth -->|provides credentials| UserCreds
    KubeConfigAuth -->|provides credentials| UserCreds
    InClusterAuth -->|provides credentials| UserCreds

    subgraph "Required RBAC Permissions (user-provided)"
        Role1["Role/ClusterRole<br/>(user-provisioned)"]
    end

    UserCreds -->|must be bound to| Role1

    subgraph "ray.io API Group"
        RayClusters["ray.io<br/>rayclusters<br/>create, delete, list, get"]
    end

    subgraph "workload.codeflare.dev API Group"
        AppWrappers["workload.codeflare.dev<br/>appwrappers<br/>create, delete, list, get"]
    end

    subgraph "kueue.x-k8s.io API Group"
        LocalQueues["kueue.x-k8s.io<br/>localqueues<br/>list, get"]
    end

    subgraph "route.openshift.io API Group"
        RoutesRes["route.openshift.io<br/>routes<br/>list, get"]
    end

    subgraph "Core API Group"
        Secrets["core ('')<br/>secrets<br/>list, get, read"]
        Nodes["core ('')<br/>nodes<br/>list (KinD detection)"]
    end

    subgraph "networking.k8s.io API Group"
        Ingresses["networking.k8s.io<br/>ingresses<br/>list, get"]
    end

    Role1 -->|"create, delete,<br/>list, get"| RayClusters
    Role1 -->|"create, delete,<br/>list, get"| AppWrappers
    Role1 -->|"list, get"| LocalQueues
    Role1 -->|"list, get"| RoutesRes
    Role1 -->|"list, get, read"| Secrets
    Role1 -->|"list"| Nodes
    Role1 -->|"list, get"| Ingresses

    subgraph "Additional Auth Endpoints"
        RayDashAuth["Ray Dashboard (OpenShift)<br/>Auth: Bearer Token<br/>(from K8s API client)<br/>Enforcement: OAuth proxy"]
        RayDashNoAuth["Ray Dashboard (non-OpenShift)<br/>Auth: None<br/>Enforcement: None (open)"]
        RaymTLS["Ray Client (mTLS)<br/>Auth: Client TLS cert<br/>(RSA 2048, SHA-256)<br/>Enforcement: Ray TLS config"]
    end

    UserCreds -.->|"forwards Bearer Token"| RayDashAuth
    UserCreds -.->|"generates client cert"| RaymTLS

    %% Styling
    style TokenAuth fill:#4a90e2,color:#fff
    style KubeConfigAuth fill:#4a90e2,color:#fff
    style InClusterAuth fill:#4a90e2,color:#fff
    style UserCreds fill:#2ecc71,color:#fff
    style Role1 fill:#f5a623,color:#fff
    style RayClusters fill:#d5e8d4,stroke:#82b366
    style AppWrappers fill:#d5e8d4,stroke:#82b366
    style LocalQueues fill:#d5e8d4,stroke:#82b366
    style RoutesRes fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style Nodes fill:#d5e8d4,stroke:#82b366
    style Ingresses fill:#d5e8d4,stroke:#82b366
    style RayDashAuth fill:#ffe6cc,stroke:#d79b00
    style RayDashNoAuth fill:#ffe6cc,stroke:#d79b00
    style RaymTLS fill:#ffe6cc,stroke:#d79b00
