graph TD
    subgraph SA["Service Account / User Identity"]
        User["SDK User / Service Account<br/>(running CodeFlare SDK)"]
    end

    subgraph AuthMethods["Authentication Methods"]
        Bearer["Bearer Token"]
        OIDC["OIDC"]
        mTLSAuth["mTLS (client cert)"]
        Kubeconfig["kubeconfig"]
        InCluster["In-Cluster SA"]
    end

    subgraph RequiredPerms["Required RBAC Permissions"]
        direction TB

        subgraph RayIO["API Group: ray.io"]
            RayClusters["rayclusters<br/>get, list, create, delete, patch"]
            RayJobs["rayjobs<br/>get, list, create, delete, patch"]
        end

        subgraph CoreAPI["API Group: (core)"]
            Secrets["secrets<br/>get, list, create, update"]
            Namespaces["namespaces<br/>get"]
        end

        subgraph KueueAPI["API Group: kueue.x-k8s.io"]
            LocalQueues["localqueues<br/>get, list"]
            Workloads["workloads<br/>list"]
            WPClass["workloadpriorityclasses<br/>get"]
        end

        subgraph RouteAPI["API Group: route.openshift.io"]
            Routes["routes<br/>list"]
        end

        subgraph GatewayAPIGroup["API Group: gateway.networking.k8s.io"]
            HTTPRoutes["httproutes<br/>list, get"]
            Gateways["gateways<br/>get"]
        end

        subgraph NetworkAPI["API Group: networking.k8s.io"]
            Ingresses["ingresses<br/>list"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>AuthZ: RBAC"]
        RayDash["Ray Dashboard<br/>8265/TCP HTTP(S)<br/>AuthZ: mTLS verification"]
        RayJobSub["Ray Job Submission<br/>8265/TCP HTTP(S)<br/>AuthZ: mTLS verification"]
    end

    %% Auth method connections
    User -->|"kube-authkit<br/>auto-detect"| Bearer
    User -->|"kube-authkit<br/>auto-detect"| OIDC
    User -->|"kube-authkit<br/>auto-detect"| mTLSAuth
    User -->|"kube-authkit<br/>auto-detect"| Kubeconfig
    User -->|"kube-authkit<br/>auto-detect"| InCluster

    %% Auth to API
    Bearer -->|"authenticates"| K8sAPI
    OIDC -->|"authenticates"| K8sAPI
    mTLSAuth -->|"authenticates"| K8sAPI
    Kubeconfig -->|"authenticates"| K8sAPI
    InCluster -->|"authenticates"| K8sAPI

    %% API authorizes resources
    K8sAPI -->|"RBAC authorizes"| RayClusters
    K8sAPI -->|"RBAC authorizes"| RayJobs
    K8sAPI -->|"RBAC authorizes"| Secrets
    K8sAPI -->|"RBAC authorizes"| Namespaces
    K8sAPI -->|"RBAC authorizes"| LocalQueues
    K8sAPI -->|"RBAC authorizes"| Workloads
    K8sAPI -->|"RBAC authorizes"| WPClass
    K8sAPI -->|"RBAC authorizes"| Routes
    K8sAPI -->|"RBAC authorizes"| HTTPRoutes
    K8sAPI -->|"RBAC authorizes"| Gateways
    K8sAPI -->|"RBAC authorizes"| Ingresses

    %% mTLS to Ray endpoints
    User -->|"TLS client certificate<br/>(RSA 3072-bit)"| RayDash
    User -->|"TLS client certificate<br/>(RSA 3072-bit)"| RayJobSub

    %% Styling
    style User fill:#4a90e2,color:#fff,stroke:#333,stroke-width:3px

    style Bearer fill:#e1bee7,stroke:#7b1fa2
    style OIDC fill:#e1bee7,stroke:#7b1fa2
    style mTLSAuth fill:#e1bee7,stroke:#7b1fa2
    style Kubeconfig fill:#e1bee7,stroke:#7b1fa2
    style InCluster fill:#e1bee7,stroke:#7b1fa2

    style RayClusters fill:#7ed321,color:#fff
    style RayJobs fill:#7ed321,color:#fff
    style Secrets fill:#f5a623,color:#333
    style Namespaces fill:#f5a623,color:#333
    style LocalQueues fill:#81d4fa,color:#333
    style Workloads fill:#81d4fa,color:#333
    style WPClass fill:#81d4fa,color:#333
    style Routes fill:#ffab91,color:#333
    style HTTPRoutes fill:#ffab91,color:#333
    style Gateways fill:#ffab91,color:#333
    style Ingresses fill:#ffab91,color:#333

    style K8sAPI fill:#ef5350,color:#fff
    style RayDash fill:#ef5350,color:#fff
    style RayJobSub fill:#ef5350,color:#fff
