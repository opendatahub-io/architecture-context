graph TD
    subgraph UserIdentity["User Identity"]
        User["Data Scientist / ML Engineer"]
        SA["Notebook Service Account<br/>(user-configured)"]
    end

    subgraph AuthMethods["Authentication Methods"]
        Token["TokenAuthentication<br/>(Bearer Token)"]
        KubeConfig["KubeConfigFileAuthentication<br/>(kubeconfig file)"]
    end

    subgraph RoleBindings["Role Bindings (User-Provided)"]
        RB["RoleBinding<br/>(user namespace)"]
    end

    subgraph Roles["Required RBAC Roles (User-Provided)"]
        Role["Role / ClusterRole<br/>(must be granted to user/SA)"]
    end

    subgraph APIResources["Required API Resource Permissions"]
        subgraph ReadWrite["Read + Write (CRUD)"]
            RayClusters["ray.io<br/>rayclusters<br/><i>get, list, create, delete</i>"]
            AppWrappers["workload.codeflare.dev<br/>appwrappers<br/><i>get, list, create, delete</i>"]
        end
        subgraph ReadOnly["Read Only"]
            LocalQueues["kueue.x-k8s.io<br/>localqueues<br/><i>get, list</i>"]
            Routes["route.openshift.io<br/>routes<br/><i>get, list</i>"]
            Secrets["core (v1)<br/>secrets<br/><i>get, list</i>"]
            Ingresses["networking.k8s.io<br/>ingresses<br/><i>get, list</i>"]
        end
    end

    subgraph ExternalAuth["External Authentication"]
        K8sAuth["Kubernetes API Server<br/>AuthN: Bearer Token / X.509<br/>AuthZ: RBAC"]
        RayAuth["Ray Dashboard (OpenShift)<br/>Auth: Bearer Token<br/>via OAuth Proxy"]
        RayTLS["Ray Client (10001/TCP)<br/>Auth: mTLS<br/>Client cert generated by SDK"]
    end

    %% User to Auth
    User -->|"logs in via"| Token
    User -->|"provides"| KubeConfig
    SA -->|"used by notebook pod"| Token

    %% Auth to Binding
    Token -->|"identity bound via"| RB
    KubeConfig -->|"identity bound via"| RB

    %% Binding to Role
    RB -->|"grants"| Role

    %% Role to Resources
    Role -->|"get, list,<br/>create, delete"| RayClusters
    Role -->|"get, list,<br/>create, delete"| AppWrappers
    Role -->|"get, list"| LocalQueues
    Role -->|"get, list"| Routes
    Role -->|"get, list"| Secrets
    Role -->|"get, list"| Ingresses

    %% External Auth flows
    Token -->|"authenticates to"| K8sAuth
    Token -->|"forwarded to"| RayAuth
    SDK_CertGen["SDK generate_tls_cert()"] -->|"generates client cert"| RayTLS

    %% Styling
    style User fill:#08427b,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Token fill:#4a90e2,stroke:#333,color:#fff
    style KubeConfig fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#f5a623,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style RayClusters fill:#7ed321,stroke:#333,color:#fff
    style AppWrappers fill:#7ed321,stroke:#333,color:#fff
    style LocalQueues fill:#a8d88e,stroke:#333
    style Routes fill:#a8d88e,stroke:#333
    style Secrets fill:#a8d88e,stroke:#333
    style Ingresses fill:#a8d88e,stroke:#333
    style K8sAuth fill:#e8e8e8,stroke:#333
    style RayAuth fill:#e8e8e8,stroke:#333
    style RayTLS fill:#e8e8e8,stroke:#333
    style SDK_CertGen fill:#4a90e2,stroke:#333,color:#fff
