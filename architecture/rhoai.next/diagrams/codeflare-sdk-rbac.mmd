graph TD
    subgraph UserAuth["User Authentication"]
        User["Data Scientist<br/>(Authenticated User)"]
        SA["ServiceAccount<br/>(Workbench SA or User Token)"]
    end

    subgraph RequiredPerms["Required RBAC Permissions"]
        direction TB

        subgraph RayPerms["ray.io API Group"]
            RayClusters["rayclusters<br/>get, list, create, delete"]
        end

        subgraph CFPerms["workload.codeflare.dev API Group"]
            AppWrappers["appwrappers<br/>get, list, create, delete"]
        end

        subgraph KueuePerms["kueue.x-k8s.io API Group"]
            LocalQueues["localqueues<br/>get, list"]
        end

        subgraph OSPerms["route.openshift.io API Group"]
            Routes["routes<br/>get, list"]
        end

        subgraph CorePerms["Core API Group"]
            Secrets["secrets<br/>get, list"]
        end

        subgraph NetworkPerms["networking.k8s.io API Group"]
            Ingresses["ingresses<br/>get, list"]
        end
    end

    subgraph Operations["SDK Operations Requiring RBAC"]
        CreateCluster["Create/Delete<br/>Ray Cluster"]
        WrapAW["Create/Delete<br/>AppWrapper"]
        DiscoverQueue["Discover<br/>LocalQueue"]
        FindRoute["Find Dashboard<br/>Route/Ingress"]
        ReadCerts["Read CA<br/>Certificates"]
    end

    User -->|"authenticates as"| SA
    SA -->|"must have"| RayClusters
    SA -->|"must have"| AppWrappers
    SA -->|"must have"| LocalQueues
    SA -->|"must have"| Routes
    SA -->|"must have"| Secrets
    SA -->|"must have"| Ingresses

    RayClusters -->|"enables"| CreateCluster
    AppWrappers -->|"enables"| WrapAW
    LocalQueues -->|"enables"| DiscoverQueue
    Routes -->|"enables"| FindRoute
    Ingresses -->|"enables"| FindRoute
    Secrets -->|"enables"| ReadCerts

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff

    style RayClusters fill:#f5a623,stroke:#333,color:#333
    style AppWrappers fill:#f5a623,stroke:#333,color:#333
    style LocalQueues fill:#f5a623,stroke:#333,color:#333
    style Routes fill:#f5a623,stroke:#333,color:#333
    style Secrets fill:#f5a623,stroke:#333,color:#333
    style Ingresses fill:#f5a623,stroke:#333,color:#333

    style CreateCluster fill:#7ed321,stroke:#333,color:#333
    style WrapAW fill:#7ed321,stroke:#333,color:#333
    style DiscoverQueue fill:#7ed321,stroke:#333,color:#333
    style FindRoute fill:#7ed321,stroke:#333,color:#333
    style ReadCerts fill:#7ed321,stroke:#333,color:#333
