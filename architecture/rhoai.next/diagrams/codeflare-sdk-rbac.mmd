graph TD
    subgraph UserAuth["User Authentication"]
        User["Data Scientist / ML Engineer"]
        Token["Bearer Token<br/>(OpenShift OAuth)"]
        KubeConfig["KubeConfig<br/>(file-based auth)"]
    end

    User -->|"authenticates via"| Token
    User -->|"authenticates via"| KubeConfig

    subgraph SDKAuth["SDK Authentication Layer"]
        AuthModule["common.kubernetes_cluster.auth<br/>TokenAuthentication / KubeConfigFileAuthentication"]
    end

    Token -->|"injected into"| AuthModule
    KubeConfig -->|"loaded by"| AuthModule

    subgraph RequiredPerms["Required RBAC Permissions (User-Provided)"]
        direction TB

        subgraph RayPerms["ray.io API Group"]
            RayClusters["rayclusters<br/>get, list, create, delete"]
        end

        subgraph CFPerms["workload.codeflare.dev API Group"]
            AppWrappers["appwrappers<br/>get, list, create, delete"]
        end

        subgraph KueuePerms["kueue.x-k8s.io API Group"]
            LocalQueues["localqueues<br/>get, list"]
        end

        subgraph RoutePerms["route.openshift.io API Group"]
            Routes["routes<br/>get, list"]
        end

        subgraph CorePerms["core API Group"]
            Secrets["secrets<br/>get, list"]
        end

        subgraph NetPerms["networking.k8s.io API Group"]
            Ingresses["ingresses<br/>get, list"]
        end
    end

    AuthModule -->|"requires"| RayClusters
    AuthModule -->|"requires"| AppWrappers
    AuthModule -->|"requires"| LocalQueues
    AuthModule -->|"requires"| Routes
    AuthModule -->|"requires"| Secrets
    AuthModule -->|"requires"| Ingresses

    subgraph RayAuth["Ray Cluster Authentication"]
        DashAuth["Ray Dashboard Auth<br/>Bearer Token (OpenShift Route)<br/>Cluster auth"]
        ClientAuth["Ray Client Auth<br/>mTLS client certificate (optional)<br/>CA-signed by cluster CA"]
    end

    AuthModule -->|"token forwarded"| DashAuth
    AuthModule -.->|"cert generated by<br/>generate_cert module"| ClientAuth

    subgraph SecretsUsed["Secrets Consumed"]
        CASec["{cluster-name}-ca-secret-*<br/>Type: Opaque<br/>Keys: ca.crt, ca.key<br/>Provisioned by: KubeRay operator<br/>No auto-rotation"]
    end

    Secrets -->|"reads"| CASec
    CASec -->|"used to sign"| ClientAuth

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style Token fill:#5ba3f5,stroke:#333,color:#fff
    style KubeConfig fill:#5ba3f5,stroke:#333,color:#fff
    style AuthModule fill:#4a90e2,stroke:#333,color:#fff

    style RayClusters fill:#f5a623,stroke:#333
    style AppWrappers fill:#f5a623,stroke:#333
    style LocalQueues fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333

    style DashAuth fill:#d5e8d4,stroke:#333
    style ClientAuth fill:#d5e8d4,stroke:#333
    style CASec fill:#fff2cc,stroke:#d6b656
