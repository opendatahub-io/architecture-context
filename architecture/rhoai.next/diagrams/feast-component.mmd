graph TB
    subgraph "Feast Component"
        direction TB

        subgraph ControlPlane["Control Plane"]
            Operator["feast-operator<br/>(Go / controller-runtime)<br/>Port: 8081/TCP health, 8443/TCP metrics"]
        end

        subgraph DataPlane["Data Plane"]
            FeatureServer["feature-server<br/>(Python / FastAPI / Uvicorn / Gunicorn)<br/>Port: 6566/TCP REST"]
            GoServer["Go feature server<br/>(Go / gRPC+HTTP)<br/>Port: 50051/TCP gRPC"]
            Registry["Registry Service<br/>Port: 6001/TCP gRPC, 8001/TCP REST"]
        end

        subgraph Frontend["Frontend"]
            UI["feast-ui<br/>(React / Elastic UI)<br/>Port: 3000/TCP"]
        end
    end

    %% CRDs
    FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|watched by| Operator

    %% Operator creates resources
    Operator -->|creates/manages| FeatureServer
    Operator -->|creates/manages| GoServer
    Operator -->|creates/manages| Registry
    Operator -->|creates/manages| UI
    Operator -->|creates| Deployments["Deployments"]
    Operator -->|creates| Services["Services"]
    Operator -->|creates| CronJobs["CronJobs<br/>(materialization)"]
    Operator -->|creates| Routes["OpenShift Routes"]
    Operator -->|creates| RBACResources["RBAC Resources"]
    Operator -->|creates| HPAs["HorizontalPodAutoscalers"]

    %% Feature Server internals
    FeatureServer -->|reads features| OnlineStore["Online Store<br/>(Redis, PostgreSQL, DynamoDB, etc.)"]
    FeatureServer -->|reads data| OfflineStore["Offline Store<br/>(BigQuery, Snowflake, DuckDB, etc.)"]
    FeatureServer -->|reads metadata| RegistryBackend["Registry Backend<br/>(SQL, S3, GCS, Remote)"]

    %% Inter-component communication
    Operator -->|fetches permissions<br/>JWT auth| Registry
    FeatureServer -.->|registry sync| Registry

    %% External users
    User["ML Model / Client"] -->|REST/gRPC<br/>Bearer Token| FeatureServer
    User -->|gRPC| GoServer
    DataScientist["Data Scientist"] -->|browses| UI

    %% Platform dependencies
    Operator -->|depends on| K8sAPI["Kubernetes API"]
    Operator -->|depends on| OpenShiftAPI["OpenShift API"]
    Operator -->|watches| NotebookCRD["Kubeflow Notebook CRD"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServer fill:#4a90e2,stroke:#333,color:#fff
    style GoServer fill:#4a90e2,stroke:#333,color:#fff
    style Registry fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#4a90e2,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#fff
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style RegistryBackend fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OpenShiftAPI fill:#e8e8e8,stroke:#333
    style NotebookCRD fill:#7ed321,stroke:#333,color:#fff
    style User fill:#f9f9f9,stroke:#999
    style DataScientist fill:#f9f9f9,stroke:#999
    style Deployments fill:#ddd,stroke:#999
    style Services fill:#ddd,stroke:#999
    style CronJobs fill:#ddd,stroke:#999
    style Routes fill:#ddd,stroke:#999
    style RBACResources fill:#ddd,stroke:#999
    style HPAs fill:#ddd,stroke:#999
