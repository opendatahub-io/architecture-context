graph TB
    subgraph FeastOperator["Feast Operator (Go)"]
        Controller["feast-operator<br/>controller-manager<br/>Go / controller-runtime"]
        HealthProbe["Health Probes<br/>:8081/TCP"]
        MetricsEndpoint["Metrics Endpoint<br/>:8443/TCP HTTPS"]
        NotebookReconciler["NotebookConfigMap<br/>Reconciler"]
        Controller --> HealthProbe
        Controller --> MetricsEndpoint
        Controller --> NotebookReconciler
    end

    subgraph FeatureServerInstance["Feature Server Instance (Python)"]
        FeatureServer["feature-server<br/>FastAPI / Gunicorn<br/>:6566 HTTP / :6567 HTTPS"]
        RegistryGRPC["Registry gRPC Server<br/>:6570 / :6571 TLS"]
        RegistryREST["Registry REST Server<br/>:6572 / :6573 TLS"]
        SecurityMgr["SecurityManager<br/>OIDC / K8s RBAC"]
        FeatureServer --> SecurityMgr
        FeatureServer --> RegistryGRPC
        FeatureServer --> RegistryREST
    end

    User["Data Scientist / ML App"] -->|creates| FeatureStoreCR["FeatureStore CR<br/>feast.dev/v1"]
    FeatureStoreCR -->|watched by| Controller

    Controller -->|creates| OnlineSvc["feast-{name}-online<br/>Service"]
    Controller -->|creates| OfflineSvc["feast-{name}-offline<br/>Service"]
    Controller -->|creates| RegistrySvc["feast-{name}-registry<br/>Service"]
    Controller -->|creates| UISvc["feast-{name}-ui<br/>Service"]
    Controller -->|creates| Deployment["Feature Server<br/>Deployment"]
    Controller -->|creates| CronJobRes["Materialization<br/>CronJob"]
    Controller -->|creates| RBACRes["RBAC Resources<br/>Roles / Bindings"]
    Controller -->|creates| TLSSecrets["TLS Secrets<br/>(service-serving certs)"]

    NotebookReconciler -->|watches| NotebookCR["Notebook CR<br/>kubeflow.org"]
    NotebookReconciler -->|creates| FeastConfigCM["feast-config<br/>ConfigMap"]

    Deployment --> FeatureServer

    FeatureServer -->|reads/writes| OnlineStore["Online Store<br/>Redis / PostgreSQL"]
    FeatureServer -->|reads| OfflineStore["Offline Store<br/>BigQuery / DuckDB"]

    Controller -->|reconciles via| K8sAPI["Kubernetes API<br/>:6443/TCP"]

    style Controller fill:#4a90e2,color:#fff
    style FeatureServer fill:#4a90e2,color:#fff
    style RegistryGRPC fill:#4a90e2,color:#fff
    style RegistryREST fill:#4a90e2,color:#fff
    style SecurityMgr fill:#4a90e2,color:#fff
    style NotebookReconciler fill:#4a90e2,color:#fff
    style FeatureStoreCR fill:#f5a623,color:#fff
    style NotebookCR fill:#f5a623,color:#fff
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#7ed321,color:#fff
