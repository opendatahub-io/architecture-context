graph TB
    subgraph "Feast Platform"
        subgraph "Control Plane"
            Operator["feast-operator<br/>(Go, controller-runtime)<br/>Port: 8081/TCP health, 8443/TCP metrics"]
        end

        subgraph "Data Plane"
            FeatureServer["feature-server<br/>(Python, FastAPI/Uvicorn/Gunicorn)<br/>Port: 6566/TCP REST"]
            GoServer["Go feature server<br/>(Go, gRPC/HTTP)<br/>Port: 50051/TCP gRPC"]
            Registry["Registry Service<br/>Port: 6001/TCP gRPC, 8001/TCP REST"]
        end

        subgraph "Frontend"
            UI["feast-ui<br/>(React/TypeScript, Elastic UI)<br/>Port: 3000/TCP"]
        end
    end

    %% CRDs
    User[Data Scientist / ML Engineer] -->|creates| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|watched by| Operator

    %% Operator reconciliation
    Operator -->|creates/manages| FeatureServer
    Operator -->|creates/manages| GoServer
    Operator -->|creates/manages| Registry
    Operator -->|creates/manages| UI
    Operator -->|creates| CronJob["Materialization CronJob"]
    Operator -->|creates| HPA["HorizontalPodAutoscaler"]
    Operator -->|creates| Routes["OpenShift Routes"]
    Operator -->|creates| RBACResources["RBAC Resources<br/>(Roles, Bindings)"]

    %% Operator fetches permissions
    Operator -->|fetches permissions<br/>8001/TCP JWT| Registry

    %% Feature Server interactions
    MLModel[ML Model / Client] -->|/get-online-features<br/>6566/TCP Bearer Token| FeatureServer
    MLModel -->|gRPC<br/>50051/TCP| GoServer
    FeatureServer -->|reads/writes| OnlineStore["Online Store<br/>(Redis, PostgreSQL, DynamoDB, etc.)"]
    FeatureServer -->|reads| OfflineStore["Offline Store<br/>(BigQuery, Snowflake, DuckDB, etc.)"]
    FeatureServer -->|reads/writes| RegistryBackend["Registry Backend<br/>(SQL, S3, GCS, Remote)"]

    %% CronJob materialization
    CronJob -->|exec into| FeatureServer

    %% Notebook integration
    Operator -->|injects ConfigMap| Notebooks["Kubeflow Notebooks"]

    %% UI
    UI -->|reads| Registry

    %% External dependencies
    Operator -->|watches/creates| K8sAPI["Kubernetes API<br/>6443/TCP"]
    Operator -->|Routes, certs| OpenShiftAPI["OpenShift API<br/>6443/TCP"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServer fill:#4a90e2,stroke:#333,color:#fff
    style GoServer fill:#4a90e2,stroke:#333,color:#fff
    style Registry fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#4a90e2,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#fff
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style RegistryBackend fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OpenShiftAPI fill:#e8e8e8,stroke:#333
    style CronJob fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style RBACResources fill:#7ed321,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style User fill:#f9f9f9,stroke:#999
    style MLModel fill:#f9f9f9,stroke:#999
