graph TB
    subgraph FeastOperator["feast-operator (Go, controller-runtime)"]
        Controller["FeatureStore Controller<br/>Reconciles FeatureStore CRDs"]
        NotebookCtrl["Notebook ConfigMap Controller<br/>Watches kubeflow.org/v1 Notebooks"]
        AccessMgr["Access Manager<br/>Auto-access RBAC sync"]
        TLSMgr["TLS Manager<br/>Service-serving certs"]
    end

    subgraph FeatureServer["feature-server (Python + embedded Go)"]
        OnlineServer["Online Store Server<br/>FastAPI/uvicorn<br/>6566/TCP REST + gRPC"]
        OfflineServer["Offline Store Server<br/>Arrow Flight<br/>8815/TCP"]
        RegistryServer["Registry Server<br/>gRPC + REST<br/>6570/TCP gRPC, 6572/TCP REST"]
        GoServer["Go Feature Server<br/>Embedded high-perf<br/>HTTP + gRPC"]
        UIServer["Feast UI<br/>8888/TCP"]
    end

    %% CRDs
    User["Data Scientist / ML Engineer"] -->|creates| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|watched by| Controller

    %% Operator creates services
    Controller -->|deploys| OnlineServer
    Controller -->|deploys| OfflineServer
    Controller -->|deploys| RegistryServer
    Controller -->|deploys| UIServer
    Controller -->|creates| CronJob["Materialization CronJob"]
    Controller -->|creates| HPA["HPA / PDB"]
    Controller -->|manages| TLSMgr

    %% Access Manager flow
    AccessMgr -->|queries| RegistryServer
    AccessMgr -->|creates| RBAC["K8s RBAC Resources"]

    %% Notebook integration
    NotebookCtrl -->|watches| NotebookCRD["Notebook CRD<br/>(kubeflow.org/v1)"]
    NotebookCtrl -->|creates| ConfigMap["feast ConfigMap<br/>feature_store.yaml"]

    %% Online server uses Go server
    OnlineServer -->|delegates| GoServer

    %% External dependencies
    OnlineServer -->|reads/writes| Redis["Redis<br/>6379/TCP"]
    OnlineServer -->|reads/writes| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    OfflineServer -->|queries| BigQuery["BigQuery<br/>443/TCP"]
    RegistryServer -->|stores| S3["S3 / GCS<br/>443/TCP"]

    %% Platform integration
    Controller -->|API calls| K8sAPI["Kubernetes API<br/>6443/TCP"]
    PlatformOp["rhods-operator"] -->|deploys via kustomize| FeastOperator

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style NotebookCtrl fill:#4a90e2,color:#fff
    style AccessMgr fill:#4a90e2,color:#fff
    style TLSMgr fill:#4a90e2,color:#fff
    style OnlineServer fill:#50c878,color:#fff
    style OfflineServer fill:#50c878,color:#fff
    style RegistryServer fill:#50c878,color:#fff
    style GoServer fill:#50c878,color:#fff
    style UIServer fill:#50c878,color:#fff
    style FeatureStoreCR fill:#f5a623,color:#fff
    style NotebookCRD fill:#f5a623,color:#fff
    style Redis fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style BigQuery fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PlatformOp fill:#7ed321,color:#fff
    style CronJob fill:#d4a5f9,color:#333
    style HPA fill:#d4a5f9,color:#333
