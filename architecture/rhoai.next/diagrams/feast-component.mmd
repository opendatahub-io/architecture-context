graph TB
    subgraph FeastOperator["Feast Operator (Go)"]
        Controller["feast-operator<br/>Controller Manager<br/>Go 1.22.9"]
        FeatureStoreReconciler["FeatureStore<br/>Reconciler"]
        NotebookReconciler["Notebook ConfigMap<br/>Reconciler"]
        AutoAccessRBAC["Auto-Access<br/>RBAC Controller"]
        Controller --> FeatureStoreReconciler
        Controller --> NotebookReconciler
        Controller --> AutoAccessRBAC
    end

    subgraph FeatureServerStack["Feature Server (Python, per-instance)"]
        FeatureServer["feature-server<br/>FastAPI/Gunicorn<br/>Python 3.12"]
        SecurityMgr["SecurityManager<br/>OIDC / K8s RBAC"]
        RegistryGRPC["Registry gRPC Server<br/>6570/6571 TCP"]
        RegistryREST["Registry REST Server<br/>6572/6573 TCP"]
        FeatureServer --> SecurityMgr
        FeatureServer --> RegistryGRPC
        FeatureServer --> RegistryREST
    end

    User["Data Scientist /<br/>ML Application"] -->|"POST /get-online-features<br/>6567/TCP HTTPS"| FeatureServer

    FeatureStoreCR["FeatureStore CR<br/>feast.dev/v1"]
    User -->|"kubectl apply"| FeatureStoreCR
    FeatureStoreCR -->|"watched by"| FeatureStoreReconciler

    FeatureStoreReconciler -->|"creates"| Deployment["Deployment<br/>(feature-server pod)"]
    FeatureStoreReconciler -->|"creates"| Services["Services<br/>(online/offline/registry/ui)"]
    FeatureStoreReconciler -->|"creates"| CronJob["CronJob<br/>(materialization)"]
    FeatureStoreReconciler -->|"creates"| RBAC["Roles &<br/>RoleBindings"]
    FeatureStoreReconciler -->|"creates"| TLS["TLS Secrets<br/>(service-serving certs)"]

    NotebookCR["Notebook CR<br/>kubeflow.org"]
    NotebookReconciler -->|"watches"| NotebookCR
    NotebookReconciler -->|"creates"| ConfigMap["feast-config<br/>ConfigMap"]

    AutoAccessRBAC -->|"fetches policies"| RegistryREST
    AutoAccessRBAC -->|"creates"| ClusterRoleBindings["ClusterRoleBindings<br/>(dynamic)"]

    FeatureServer -->|"read/write"| OnlineStore["Online Store<br/>(Redis/PostgreSQL)"]
    FeatureServer -->|"read"| OfflineStore["Offline Store<br/>(BigQuery/DuckDB)"]

    Controller -->|"reconciliation"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style FeatureStoreReconciler fill:#4a90e2,stroke:#333,color:#fff
    style NotebookReconciler fill:#4a90e2,stroke:#333,color:#fff
    style AutoAccessRBAC fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServer fill:#7b68ee,stroke:#333,color:#fff
    style SecurityMgr fill:#7b68ee,stroke:#333,color:#fff
    style RegistryGRPC fill:#7b68ee,stroke:#333,color:#fff
    style RegistryREST fill:#7b68ee,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333
    style NotebookCR fill:#f5a623,stroke:#333
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#7ed321,stroke:#333
    style CronJob fill:#7ed321,stroke:#333
    style RBAC fill:#7ed321,stroke:#333
    style TLS fill:#7ed321,stroke:#333
    style Deployment fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ClusterRoleBindings fill:#7ed321,stroke:#333
