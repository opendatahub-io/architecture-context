graph TB
    subgraph FeastOperator["feast-operator (Go Operator)"]
        direction TB
        Controller["FeatureStoreReconciler<br/>controller-runtime"]
        NotebookCtrl["NotebookConfigMapReconciler<br/>Watches kubeflow.org/v1 Notebooks"]
        AuthzMgr["AuthZ Manager<br/>RBAC / OIDC / None"]
        TLSMgr["TLS Manager<br/>OpenShift Service CA / Custom"]
        Controller --> AuthzMgr
        Controller --> TLSMgr
    end

    subgraph FeatureServerPython["feature-server Python (FastAPI/Gunicorn)"]
        direction TB
        OnlineServer["Online Store Server<br/>:6566/TCP"]
        RegistryGRPC["Registry gRPC Server<br/>:6570/TCP"]
        RegistryREST["Registry REST Server<br/>:6572/TCP"]
        OfflineServer["Offline Store Server<br/>:8815/TCP"]
        UIHost["UI Host<br/>:8888/TCP"]
        OnlineServer -.-> RegistryGRPC
    end

    subgraph FeatureServerGo["feature-server Go"]
        direction TB
        GoOnline["Online Feature Server<br/>:8080/TCP HTTP/gRPC"]
        GoMetrics["Metrics<br/>:9090/TCP"]
    end

    subgraph FeastUI["feast-ui (React/TypeScript)"]
        WebUI["Feature Store Web UI<br/>Entities, Feature Views,<br/>Data Sources, Services"]
    end

    %% CRDs
    FeatureStoreCR["FeatureStore CR<br/>feast.dev/v1<br/>(Namespaced)"]:::crd

    %% User interactions
    User["Data Scientist / ML Engineer"]:::user
    Admin["Platform Admin"]:::user

    %% Flows
    Admin -->|"kubectl apply"| FeatureStoreCR
    FeatureStoreCR -->|"watched by"| Controller
    Controller -->|"deploys"| FeatureServerPython
    Controller -->|"deploys (optional)"| FeatureServerGo
    Controller -->|"creates Services,<br/>ConfigMaps, RBAC"| K8sResources["K8s Resources"]:::k8s

    NotebookCtrl -->|"auto-creates<br/>ConfigMap"| NotebookCM["Feast Client ConfigMap"]:::k8s
    NotebookCtrl -->|"watches"| NotebookCR["Notebook CR<br/>kubeflow.org/v1"]:::crd

    User -->|"HTTP POST<br/>/get-online-features"| OnlineServer
    User -->|"browses"| WebUI
    WebUI -->|"REST API<br/>:6572/TCP"| RegistryREST

    %% External dependencies
    Controller -->|"HTTPS/443"| K8sAPI["Kubernetes API"]:::external
    Controller -->|"creates"| Routes["OpenShift Route"]:::k8s
    Controller -->|"creates"| ServiceMonitor["ServiceMonitor"]:::k8s

    OnlineServer -->|"TCP"| Redis["Redis<br/>:6379"]:::external
    OnlineServer -->|"TCP"| PostgreSQL["PostgreSQL<br/>:5432"]:::external
    RegistryGRPC -->|"TCP"| PostgreSQL
    OfflineServer -->|"HTTPS"| Snowflake["Snowflake"]:::external
    OfflineServer -->|"HTTPS"| BigQuery["BigQuery"]:::external

    %% Styles
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef python fill:#3776ab,stroke:#333,stroke-width:2px,color:#fff
    classDef goserver fill:#00add8,stroke:#333,stroke-width:2px,color:#fff
    classDef ui fill:#61dafb,stroke:#333,stroke-width:2px,color:#000
    classDef crd fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef external fill:#999,stroke:#333,stroke-width:1px,color:#fff
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff
    classDef user fill:#e8e8e8,stroke:#333,stroke-width:1px

    class Controller,NotebookCtrl,AuthzMgr,TLSMgr operator
    class OnlineServer,RegistryGRPC,RegistryREST,OfflineServer,UIHost python
    class GoOnline,GoMetrics goserver
    class WebUI ui
