graph TB
    subgraph FeastOperator["Feast Operator (Go)"]
        Controller["feast-operator<br/>controller-runtime<br/>Port: 8443 metrics, 8081 health"]
        FeatureStoreReconciler["FeatureStore Reconciler"]
        NotebookConfigMapCtrl["Notebook ConfigMap Controller"]
        AutoAccessRBAC["Auto-Access RBAC Loop"]
        Controller --> FeatureStoreReconciler
        Controller --> NotebookConfigMapCtrl
        Controller --> AutoAccessRBAC
    end

    subgraph FeatureStorePod["FeatureStore Deployment (Multi-Container Pod)"]
        direction TB
        OfflineServer["Offline Store Container<br/>gRPC: 8815/8816<br/>Python/Feast SDK"]
        OnlineServer["Online Store Container<br/>gRPC: 6566/6567<br/>HTTP metrics: 8000<br/>Python/Feast SDK"]
        RegistryServer["Registry Container<br/>gRPC: 6570/6571<br/>REST: 6572/6573<br/>Python/FastAPI"]
        UIContainer["UI Container<br/>HTTP: 8888/8443<br/>React/TypeScript"]
    end

    %% CRDs
    FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]

    %% Users
    User["Data Scientist / ML Engineer"]
    MLApp["ML Application"]

    %% External systems
    K8sAPI["Kubernetes API<br/>443/TCP"]
    OpenShiftAPI["OpenShift API<br/>443/TCP"]

    %% User interactions
    User -->|"kubectl create"| FeatureStoreCR
    User -->|"browse features"| UIContainer
    MLApp -->|"GetOnlineFeatures<br/>gRPC"| OnlineServer
    MLApp -->|"get historical features<br/>gRPC"| OfflineServer

    %% Operator reconciliation
    FeatureStoreCR -->|"watched by"| FeatureStoreReconciler
    FeatureStoreReconciler -->|"creates/manages"| FeatureStorePod
    FeatureStoreReconciler -->|"creates Services,<br/>RBAC, PVCs, CronJobs,<br/>Routes, HPA"| K8sAPI

    %% Notebook integration
    NotebookConfigMapCtrl -->|"watches Notebooks<br/>(kubeflow.org)"| K8sAPI
    NotebookConfigMapCtrl -->|"creates ConfigMaps<br/>with feature_store.yaml"| K8sAPI

    %% Auto-access RBAC
    AutoAccessRBAC -->|"fetches permissions<br/>HMAC-SHA256 JWT"| RegistryServer
    AutoAccessRBAC -->|"creates RBAC<br/>resources"| K8sAPI

    %% Backend stores
    BackendStores["Backend Stores<br/>(Redis, PostgreSQL,<br/>Snowflake, DuckDB)"]
    OnlineServer -->|"read/write features"| BackendStores
    OfflineServer -->|"read features"| BackendStores
    RegistryServer -->|"metadata storage"| BackendStores

    %% OpenShift integration
    FeatureStoreReconciler -->|"Routes, TLS certs"| OpenShiftAPI

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style FeatureStoreReconciler fill:#4a90e2,color:#fff
    style NotebookConfigMapCtrl fill:#4a90e2,color:#fff
    style AutoAccessRBAC fill:#4a90e2,color:#fff
    style OfflineServer fill:#50b5a9,color:#fff
    style OnlineServer fill:#50b5a9,color:#fff
    style RegistryServer fill:#50b5a9,color:#fff
    style UIContainer fill:#50b5a9,color:#fff
    style FeatureStoreCR fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8
    style OpenShiftAPI fill:#e8e8e8
    style BackendStores fill:#e8e8e8
    style User fill:#d4edda,stroke:#28a745
    style MLApp fill:#d4edda,stroke:#28a745
