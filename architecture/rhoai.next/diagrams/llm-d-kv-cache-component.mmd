graph TB
    subgraph EPP["llm-d Inference Scheduler (EPP)"]
        direction TB
        subgraph IndexerLib["KV-Cache Indexer Library (Go)"]
            Indexer["Indexer<br/>(pkg/kvcache)"]
            TokenProcessor["TokenProcessor<br/>FNV-64a hashing"]
            Scorer["KVBlockScorer<br/>prefix matching"]
            Indexer -->|computes block keys| TokenProcessor
            Indexer -->|scores candidates| Scorer
        end

        subgraph IndexBackends["Pluggable Index Backends"]
            InMemory["InMemory LRU"]
            CostAware["CostAwareMemory<br/>(Ristretto)"]
            RedisBackend["Redis / Valkey<br/>(optional)"]
        end

        Indexer -->|lookup/add/evict| InMemory
        Indexer -.->|alternative| CostAware
        Indexer -.->|alternative| RedisBackend

        subgraph EventsPool["KV-Events Pool (pkg/kvevents)"]
            Pool["Sharded Worker Pool<br/>4 workers default"]
            SubMgr["SubscriberManager"]
            ZMQSub["ZMQ Subscriber"]
            Pool -->|manages| SubMgr
            SubMgr -->|creates| ZMQSub
        end

        subgraph TokenPool["Tokenization Pool (pkg/tokenization)"]
            TokenClient["UDS Tokenizer Client<br/>gRPC over UDS"]
        end

        Pool -->|updates index| Indexer
        Indexer -->|tokenizes prompts| TokenClient
    end

    subgraph TokenizerSidecar["UDS Tokenizer Sidecar (Python)"]
        GRPCServer["gRPC Server<br/>TokenizationService"]
        Renderer["vLLM OpenAIServingRender<br/>CPU mode"]
        HealthCheck["Health Probe<br/>:8082/TCP"]
        GRPCServer -->|renders prompts| Renderer
    end

    subgraph FSBackend["llmd_fs_backend (Python/C++/CUDA)"]
        OffloadHandler["StorageOffloadingHandlers"]
        CUDAOps["CUDA/GDS Memory Ops<br/>(csrc/)"]
        OffloadHandler -->|GPU transfers| CUDAOps
    end

    subgraph PVCEvictor["PVC Evictor (Python)"]
        Crawlers["N Crawler Processes"]
        Activator["Activator<br/>threshold monitor"]
        Deleter["Deleter<br/>batch deletion"]
        Crawlers -->|file queue| Activator
        Activator -->|triggers| Deleter
    end

    %% External connections
    vLLMPods["vLLM / SGLang Pods"]
    SharedStorage["Shared Storage<br/>(NFS/PVC)"]
    HFHub["HuggingFace Hub"]

    vLLMPods -->|"ZMQ PUB 5557/TCP<br/>KV-Events [msgpack]"| ZMQSub
    TokenClient -->|gRPC via UDS socket| GRPCServer
    GRPCServer -.->|downloads tokenizers| HFHub
    vLLMPods -->|OffloadingConnector API| OffloadHandler
    OffloadHandler -->|POSIX I/O| SharedStorage
    CUDAOps -->|read/write blocks| SharedStorage
    PVCEvictor -->|evicts old blocks| SharedStorage

    %% Styling
    style Indexer fill:#4a90e2,stroke:#333,color:#fff
    style Pool fill:#4a90e2,stroke:#333,color:#fff
    style TokenClient fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#9b59b6,stroke:#333,color:#fff
    style Renderer fill:#9b59b6,stroke:#333,color:#fff
    style OffloadHandler fill:#e67e22,stroke:#333,color:#fff
    style CUDAOps fill:#e67e22,stroke:#333,color:#fff
    style Crawlers fill:#27ae60,stroke:#333,color:#fff
    style Activator fill:#27ae60,stroke:#333,color:#fff
    style Deleter fill:#27ae60,stroke:#333,color:#fff
    style vLLMPods fill:#e8e8e8,stroke:#333
    style SharedStorage fill:#f5a623,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style InMemory fill:#3498db,stroke:#333,color:#fff
    style CostAware fill:#3498db,stroke:#333,color:#fff
    style RedisBackend fill:#3498db,stroke:#333,color:#fff
