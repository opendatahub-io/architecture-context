graph TB
    subgraph "llm-d-kv-cache"
        subgraph "Go Library (pkg/kvcache)"
            Indexer["KV-Cache Indexer<br/>(pkg/kvcache)"]
            TokenProcessor["TokenProcessor<br/>FNV-64a hashing"]
            Scorer["KVBlock Scorer<br/>Cache-hit scoring"]
            Indexer -->|computes hashes| TokenProcessor
            Indexer -->|scores pods| Scorer
        end

        subgraph "Index Backends (pkg/kvcache/kvblock)"
            InMemoryLRU["InMemory LRU"]
            CostAwareMemory["CostAware Memory<br/>(Ristretto)"]
            RedisBackend["Redis / Valkey<br/>Backend"]
            IndexInterface["kvblock.Index<br/>Interface"]
            IndexInterface -.->|impl| InMemoryLRU
            IndexInterface -.->|impl| CostAwareMemory
            IndexInterface -.->|impl| RedisBackend
        end

        subgraph "Event Ingestion (pkg/kvevents)"
            Pool["kvevents.Pool<br/>Sharded Worker Pool"]
            ZMQSub["ZMQ Subscriber<br/>5557/TCP"]
            SubManager["Subscriber Manager<br/>(Pod Discovery)"]
            VLLMAdapter["vLLM Adapter<br/>msgpack decode"]
            SGLangAdapter["SGLang Adapter<br/>msgpack decode"]
            ZMQSub -->|raw messages| Pool
            SubManager -->|manages| ZMQSub
            Pool -->|dispatches| VLLMAdapter
            Pool -->|dispatches| SGLangAdapter
        end

        subgraph "Tokenization (pkg/tokenization)"
            TokenPool["Tokenization Pool"]
            UdsClient["UDS Tokenizer Client<br/>gRPC over UDS"]
            TokenPool -->|delegates| UdsClient
        end

        subgraph "UDS Tokenizer Service (Python Sidecar)"
            GRPCServer["gRPC Server<br/>UDS: /tmp/tokenizer/tokenizer-uds.socket<br/>Health: 8082/TCP"]
            Renderer["vLLM OpenAIServingRender<br/>(CPU mode)"]
            GRPCServer -->|renders| Renderer
        end

        subgraph "Storage Connectors"
            FSBackend["llmd_fs_backend<br/>Python/C++/CUDA<br/>vLLM OffloadingConnector"]
            PVCEvictor["PVC Evictor<br/>N crawlers + activator + deleter"]
        end

        Indexer -->|updates| IndexInterface
        Pool -->|Add/Evict| IndexInterface
        UdsClient -->|gRPC| GRPCServer
    end

    %% External actors
    EPP["llm-d EPP<br/>(Host Scheduler)"]
    EPP -->|embeds & calls ScoreTokens| Indexer
    EPP -->|tokenize prompts| TokenPool

    VLLMPods["vLLM / SGLang Pods"]
    VLLMPods -->|ZMQ PUB 5557/TCP<br/>KV-Events| ZMQSub
    VLLMPods -->|OffloadingConnector API| FSBackend

    K8sAPI["Kubernetes API"]
    SubManager -->|Pod watch| K8sAPI

    SharedStorage["Shared Storage<br/>(NFS / PVC)"]
    FSBackend -->|POSIX I/O| SharedStorage
    PVCEvictor -->|manages disk| SharedStorage

    Redis["Redis / Valkey<br/>6379/TCP"]
    RedisBackend -->|block index| Redis

    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    Renderer -->|download tokenizers| HFHub

    %% Styling
    style Indexer fill:#4a90e2,stroke:#333,color:#fff
    style Pool fill:#4a90e2,stroke:#333,color:#fff
    style TokenPool fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#9b59b6,stroke:#333,color:#fff
    style Renderer fill:#9b59b6,stroke:#333,color:#fff
    style FSBackend fill:#e67e22,stroke:#333,color:#fff
    style PVCEvictor fill:#e67e22,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style VLLMPods fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style SharedStorage fill:#f5a623,stroke:#333,color:#fff
