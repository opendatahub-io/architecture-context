graph TB
    subgraph KVCache["llm-d-kv-cache Component"]
        direction TB

        subgraph GoCore["Go Core Library"]
            Indexer["KV-Cache Indexer<br/><i>pkg/kvcache/</i><br/>Pod scoring & cache-aware routing"]
            EventsPool["KV Events Pool<br/><i>pkg/kvevents/</i><br/>Sharded ZMQ event ingestion"]
            BlockIndex["KV Block Index<br/><i>pkg/kvcache/kvblock/</i><br/>LRU / Ristretto / Redis backend"]
            TokenSystem["Tokenization System<br/><i>pkg/tokenization/</i><br/>Multi-strategy fallback chain"]
            Preprocessing["Chat Completions Preprocessor<br/><i>pkg/preprocessing/</i><br/>CGo Python bridge"]
            Telemetry["OpenTelemetry Tracing<br/><i>pkg/telemetry/</i><br/>OTLP gRPC exporter"]
            Metrics["Prometheus Metrics<br/><i>pkg/kvcache/metrics/</i><br/>Index & tokenization metrics"]
        end

        subgraph PythonServices["Python Services"]
            UDSTokenizer["UDS Tokenizer Service<br/><i>services/uds_tokenizer/</i><br/>gRPC over Unix Domain Socket<br/>Port: 8082/TCP health"]
            FSBackend["Filesystem Backend<br/><i>kv_connectors/llmd_fs_backend/</i><br/>vLLM plugin + C++ CUDA ext"]
            PVCEvictor["PVC Evictor<br/><i>kv_connectors/pvc_evictor/</i><br/>N+2 process eviction"]
        end
    end

    %% Internal flows
    Indexer -->|"queries"| BlockIndex
    Indexer -->|"tokenizes via"| TokenSystem
    TokenSystem -->|"gRPC UDS"| UDSTokenizer
    TokenSystem -->|"CGo FFI"| Preprocessing
    EventsPool -->|"updates"| BlockIndex
    Indexer -->|"traces"| Telemetry
    Indexer -->|"exposes"| Metrics

    %% External interactions
    vLLMPods["vLLM Inference Pods"]
    Scheduler["llm-d-inference-scheduler"]
    K8sAPI["Kubernetes API Server"]
    Redis["Redis / Valkey<br/>(optional)"]
    SharedStorage["Shared Storage<br/>NFS / PVC"]
    HFHub["HuggingFace Hub"]
    OTLPCollector["OTLP Collector"]
    PromScraper["Prometheus"]

    vLLMPods -->|"ZMQ PUB 5557/TCP<br/>KV-cache events"| EventsPool
    Scheduler -->|"Go library embedding<br/>GetPodScores()"| Indexer
    K8sAPI -->|"Pod watch<br/>controller-runtime"| EventsPool
    BlockIndex -->|"RESP 6379/TCP"| Redis
    FSBackend -->|"POSIX I/O + GDS"| SharedStorage
    PVCEvictor -->|"scandir + rm"| SharedStorage
    UDSTokenizer -->|"HTTPS 443/TCP"| HFHub
    Telemetry -->|"gRPC 4317/TCP"| OTLPCollector
    Metrics -->|"HTTP 8080/TCP"| PromScraper

