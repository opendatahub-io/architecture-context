graph TB
    subgraph KVCacheComponent["llm-d-kv-cache Component"]
        direction TB

        subgraph GoLibraries["Go Libraries (embedded in host process)"]
            Indexer["KV-Cache Indexer<br/><i>pkg/kvcache</i><br/>Core indexer — tracks block<br/>residency, scores pods"]
            EventPool["KV-Event Processing<br/><i>pkg/kvevents</i><br/>Sharded ZMQ subscriber pool"]
            TokenProcessor["Token Processor<br/><i>pkg/kvcache/kvblock</i><br/>Chained FNV-64a hashing"]
            BlockIndex["Block Index<br/><i>pkg/kvcache/kvblock</i><br/>In-memory LRU / Ristretto / Redis"]
            Scorer["Block Scorer<br/><i>pkg/kvcache/kvblock_scorer</i><br/>Longest-prefix-match scoring"]
        end

        subgraph Sidecars["Sidecar Services"]
            UDSTokenizer["UDS Tokenizer<br/><i>services/uds_tokenizer</i><br/>Python gRPC Sidecar<br/>Port: 8082/TCP (health)"]
        end

        subgraph Plugins["vLLM Plugins"]
            FSBackend["llmd-fs-backend<br/><i>kv_connectors/llmd_fs_backend</i><br/>POSIX / GDS / NIXL storage"]
            PVCEvictor["PVC Evictor<br/><i>kv_connectors/pvc_evictor</i><br/>Hysteresis-based disk mgmt"]
        end
    end

    %% Internal flows
    EventPool -->|"ingests events"| TokenProcessor
    TokenProcessor -->|"updates"| BlockIndex
    Indexer -->|"queries"| BlockIndex
    Indexer -->|"tokenizes via"| TokenProcessor
    TokenProcessor -->|"scores via"| Scorer
    Indexer -->|"gRPC over UDS"| UDSTokenizer

    %% External sources
    vLLMPods["vLLM Pods"] -->|"ZMQ PUB 5557/TCP<br/>KVEvents (msgpack)"| EventPool
    SGLangPods["SGLang Pods<br/>(experimental)"] -.->|"ZMQ PUB 5557/TCP"| EventPool

    %% Host process
    EPP["llm-d EPP<br/>(Inference Scheduler)"] -->|"Go API call<br/>(library embedding)"| Indexer

    %% Plugin integration
    vLLMPods -->|"in-process plugin"| FSBackend
    FSBackend -->|"POSIX I/O / S3 API"| SharedStorage["Shared Storage<br/>(PVC / S3)"]
    PVCEvictor -->|"file eviction"| SharedStorage

    %% External services
    UDSTokenizer -->|"HTTPS 443/TCP<br/>Bearer Token"| HFHub["HuggingFace Hub"]
    BlockIndex -.->|"Redis 6379/TCP<br/>(optional)"| Redis["Redis / Valkey"]
    Indexer -->|"HTTPS 443/TCP<br/>ServiceAccount Token"| K8sAPI["Kubernetes API"]

    %% Styling
    style Indexer fill:#4a90e2,stroke:#333,color:#fff
    style EventPool fill:#4a90e2,stroke:#333,color:#fff
    style TokenProcessor fill:#4a90e2,stroke:#333,color:#fff
    style BlockIndex fill:#4a90e2,stroke:#333,color:#fff
    style Scorer fill:#4a90e2,stroke:#333,color:#fff
    style UDSTokenizer fill:#7ed321,stroke:#333,color:#fff
    style FSBackend fill:#9b59b6,stroke:#333,color:#fff
    style PVCEvictor fill:#9b59b6,stroke:#333,color:#fff
    style vLLMPods fill:#f5a623,stroke:#333,color:#fff
    style SGLangPods fill:#f5a623,stroke:#333,color:#fff
    style EPP fill:#e74c3c,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333
    style HFHub fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style SharedStorage fill:#999,stroke:#333
