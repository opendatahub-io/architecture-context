graph TB
    subgraph LLMDKVCache["llm-d-kv-cache Component"]
        direction TB

        subgraph CoreLibrary["Core Go Library (embedded in EPP)"]
            Indexer["KV-Cache Indexer<br/>(pkg/kvcache)"]
            TokenProcessor["Token Processor<br/>FNV-64a hashing"]
            Scorer["KVBlock Scorer<br/>Cache-hit scoring"]
            BlockIndex["Block Index<br/>(InMemory / Ristretto / Redis)"]

            Indexer -->|computes hashes| TokenProcessor
            Indexer -->|looks up blocks| BlockIndex
            Indexer -->|scores pods| Scorer
        end

        subgraph EventIngestion["Event Ingestion Layer"]
            Pool["KV-Events Pool<br/>(pkg/kvevents)<br/>4 sharded workers"]
            ZMQSub["ZMQ Subscriber<br/>5557/TCP"]
            VLLMAdapter["vLLM Adapter<br/>msgpack decode"]
            SGLangAdapter["SGLang Adapter<br/>msgpack decode"]

            ZMQSub -->|raw messages| Pool
            Pool -->|vLLM events| VLLMAdapter
            Pool -->|SGLang events| SGLangAdapter
            VLLMAdapter -->|Add/Evict| BlockIndex
            SGLangAdapter -->|Add/Evict| BlockIndex
        end

        subgraph TokenizerSidecar["UDS Tokenizer Sidecar (Python)"]
            GRPCServer["gRPC Server<br/>UDS socket"]
            VLLMRender["vLLM OpenAIServingRender<br/>CPU mode"]
            HealthCheck["Health Probe<br/>8082/TCP"]

            GRPCServer -->|renders| VLLMRender
        end

        subgraph StorageConnector["Storage Connector"]
            FSBackend["llmd_fs_backend<br/>Python/C++/CUDA"]
            PVCEvictor["PVC Evictor<br/>N crawlers + activator + deleter"]
        end

        TokenPool["Tokenization Pool<br/>(pkg/tokenization)"]
        TokenPool -->|UDS gRPC| GRPCServer
        Indexer -->|get tokens| TokenPool
    end

    %% External inputs
    EPP["llm-d Inference Scheduler<br/>(EPP - Host Process)"]
    EPP -->|embeds library<br/>ScoreTokens()| Indexer

    VLLMPods["vLLM Inference Pods"]
    SGLangPods["SGLang Inference Pods"]
    VLLMPods -->|KV-Events<br/>ZMQ PUB 5557/TCP| ZMQSub
    SGLangPods -->|KV-Events<br/>ZMQ PUB 5557/TCP| ZMQSub

    %% External dependencies
    Redis["Redis / Valkey<br/>6379/TCP<br/>(optional)"]
    BlockIndex -.->|optional backend| Redis

    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    GRPCServer -->|download tokenizers| HFHub

    SharedStorage["Shared Storage<br/>NFS / PVC"]
    FSBackend -->|POSIX I/O<br/>KV-cache blocks| SharedStorage
    PVCEvictor -->|evicts old blocks| SharedStorage

    K8sAPI["Kubernetes API<br/>443/TCP"]
    Pool -.->|pod discovery<br/>(optional)| K8sAPI

