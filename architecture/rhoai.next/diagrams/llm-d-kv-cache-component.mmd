graph TB
    subgraph KVCache["llm-d-kv-cache"]
        direction TB

        subgraph GoCore["Go Core Library (pkg/kvcache)"]
            Indexer["kvcache.Indexer<br/>Orchestrates scoring"]
            TokenProcessor["kvblock.TokenProcessor<br/>FNV-64a over CBOR"]
            Scorer["kvblock.Scorer<br/>Cache-hit scoring"]
            Indexer -->|computes block keys| TokenProcessor
            Indexer -->|scores pods| Scorer
        end

        subgraph IndexBackends["Block Index Backends"]
            InMemory["InMemory LRU"]
            CostAware["CostAwareMemory<br/>(Ristretto)"]
            RedisBackend["Redis / Valkey<br/>(External)"]
        end

        subgraph EventPipeline["Event Ingestion Pipeline"]
            ZMQSub["zmqSubscriber<br/>ZMQ SUB client"]
            Pool["kvevents.Pool<br/>Sharded worker pool"]
            VLLMAdapter["vLLM EngineAdapter"]
            SGLangAdapter["SGLang EngineAdapter"]
            ZMQSub -->|raw events| Pool
            Pool -->|vLLM events| VLLMAdapter
            Pool -->|SGLang events| SGLangAdapter
        end

        subgraph UDSTokenizer["uds_tokenizer (Python Sidecar)"]
            GRPCServer["gRPC Server<br/>UDS socket"]
            TokenizerSvc["TokenizationService"]
            Renderer["Chat Template Renderer"]
            GRPCServer --> TokenizerSvc
            GRPCServer --> Renderer
        end

        subgraph FSBackend["llmd_fs_backend (vLLM Plugin)"]
            OffloadMgr["OffloadingManager"]
            FileMapper["FileMapper<br/>Block-to-file mapping"]
            EventPub["ZMQ Event Publisher"]
            OffloadMgr --> FileMapper
            OffloadMgr --> EventPub
        end

        subgraph PVCEvictor["pvc_evictor (Utility)"]
            Crawlers["N Crawler Processes"]
            Activator["Activator Process"]
            Deleter["Deleter Process"]
            FolderCleaner["Folder Cleaner"]
            Crawlers -->|cold files| Activator
            Activator -->|batch| Deleter
            Activator -.->|cleanup| FolderCleaner
        end

        Indexer -->|lookup| IndexBackends
        Pool -->|Add/Evict/Clear| IndexBackends
    end

    %% External actors
    EPP["llm-d EPP<br/>(Host Process)"]
    vLLMPods["vLLM / SGLang<br/>Inference Pods"]
    HFHub["HuggingFace Hub"]
    K8sAPI["Kubernetes API"]
    SharedStorage["Shared Storage<br/>(PVC / S3)"]
    GPU["GPU Memory"]

    %% External interactions
    EPP -->|embeds library| Indexer
    EPP -->|gRPC over UDS| GRPCServer
    vLLMPods -->|ZMQ PUB 5557/TCP| ZMQSub
    GRPCServer -.->|first request| HFHub
    K8sAPI -.->|pod watch| Pool
    GPU -->|CUDA memcpy| OffloadMgr
    OffloadMgr -->|file I/O| SharedStorage
    PVCEvictor -->|evicts files| SharedStorage

