graph TB
    subgraph "llm-d-kv-cache System"
        direction TB

        subgraph GoCore["Go Core Library"]
            direction TB
            Indexer["KV-Cache Indexer<br/>(pkg/kvcache/)<br/>Pod scoring & routing"]
            EventsPool["KV Events Pool<br/>(pkg/kvevents/)<br/>Sharded ZMQ ingestion"]
            BlockIndex["KV Block Index<br/>(pkg/kvcache/kvblock/)<br/>LRU / Ristretto / Redis"]
            TokenPool["Tokenization Pool<br/>(pkg/tokenization/)<br/>Multi-strategy fallback"]
            TokenProcessor["Token Processor<br/>Block key computation<br/>FNV-64a hash chain"]
            Scorer["KV Block Scorer<br/>Cache-hit scoring"]
            Preprocessor["Chat Completions<br/>Preprocessor<br/>(CGo Python bridge)"]
            Telemetry["OpenTelemetry<br/>Tracing<br/>(pkg/telemetry/)"]
            Metrics["Prometheus Metrics<br/>(pkg/kvcache/metrics/)"]
        end

        subgraph Sidecar["UDS Tokenizer Sidecar (Python)"]
            TokenizerSvc["UDS Tokenizer Service<br/>services/uds_tokenizer/<br/>gRPC over Unix Domain Socket<br/>Port: 8082/TCP (health)"]
        end

        subgraph FSBackend["Filesystem Backend (Python/C++)"]
            OffloadMgr["SharedStorageOffloading<br/>Manager<br/>kv_connectors/llmd_fs_backend/"]
            FileMapper["FileMapper<br/>Hash-based directory hierarchy"]
            CppEngine["C++ storage_offload<br/>Async I/O + NVIDIA GDS"]
        end

        subgraph Evictor["PVC Evictor (Python)"]
            Activator["Activator<br/>Disk usage monitor<br/>statvfs() polling"]
            Crawlers["N Crawler Processes<br/>Hex-based load balancing"]
            Deleter["Deleter<br/>Batch rm via xargs"]
        end
    end

    %% Internal connections
    Indexer -->|"queries"| BlockIndex
    Indexer -->|"tokenizes"| TokenPool
    Indexer -->|"computes block keys"| TokenProcessor
    Indexer -->|"scores pods"| Scorer
    EventsPool -->|"updates index"| BlockIndex
    TokenPool -->|"gRPC over UDS"| TokenizerSvc
    TokenPool -->|"CGo bridge"| Preprocessor
    OffloadMgr -->|"maps files"| FileMapper
    OffloadMgr -->|"async I/O"| CppEngine
    Activator -->|"triggers"| Crawlers
    Crawlers -->|"queues files"| Deleter

    %% External connections
    vLLMPods["vLLM Inference Pods"]
    Scheduler["llm-d-inference-scheduler"]
    K8sAPI["Kubernetes API"]
    Redis["Redis / Valkey<br/>(optional)"]
    SharedStorage["Shared Storage<br/>(NFS/PVC)"]
    HFHub["HuggingFace Hub"]
    OTLPCollector["OTLP Collector"]
    PromScraper["Prometheus"]

    vLLMPods -->|"ZMQ PUB 5557/TCP<br/>KV-cache events"| EventsPool
    Scheduler -->|"embeds library<br/>in-process"| Indexer
    K8sAPI -->|"Pod watch<br/>controller-runtime"| EventsPool
    BlockIndex -.->|"RESP 6379/TCP<br/>(optional)"| Redis
    CppEngine -->|"POSIX / GDS"| SharedStorage
    Evictor -->|"POSIX filesystem"| SharedStorage
    TokenizerSvc -->|"HTTPS 443/TCP"| HFHub
    Telemetry -->|"gRPC 4317/TCP"| OTLPCollector
    Metrics -->|"HTTP 8080/TCP"| PromScraper

