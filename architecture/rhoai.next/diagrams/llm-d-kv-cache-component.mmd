graph TB
    subgraph KVCacheLib["KV-Cache Indexer Library (Go)"]
        direction TB
        Indexer["Indexer<br/>ScoreTokens() API"]
        TokenProcessor["TokenProcessor<br/>FNV-64a hashing"]
        Scorer["Scorer<br/>Pod ranking"]

        subgraph IndexBackends["Index Backends"]
            InMemory["In-Memory LRU<br/>(default)"]
            Ristretto["Cost-Aware Ristretto"]
            RedisBackend["Redis/Valkey<br/>(optional)"]
        end

        subgraph EventPipeline["Event Processing Pipeline"]
            ZMQSub["ZMQ Subscriber<br/>(per-pod)"]
            Pool["Sharded Worker Pool<br/>FNV-1a routing"]
            EngineAdapter["Engine Adapter"]
            VLLMAdapter["vLLM Adapter"]
            SGLangAdapter["SGLang Adapter"]
        end

        subgraph Instrumentation["Observability"]
            InstrumentedIndex["InstrumentedIndex<br/>Prometheus metrics"]
            TracedIndex["TracedIndex<br/>OpenTelemetry traces"]
        end

        Indexer --> TokenProcessor
        Indexer --> Scorer
        Indexer --> InstrumentedIndex
        InstrumentedIndex --> TracedIndex
        TracedIndex --> InMemory
        TracedIndex --> Ristretto
        TracedIndex --> RedisBackend

        ZMQSub --> Pool
        Pool --> EngineAdapter
        EngineAdapter --> VLLMAdapter
        EngineAdapter --> SGLangAdapter
        Pool --> InstrumentedIndex
    end

    subgraph UDSTokenizer["UDS Tokenizer (Python Sidecar)"]
        GRPCServer["gRPC Server<br/>UDS Socket"]
        Tokenizer["Tokenizer Engine<br/>HuggingFace transformers"]
        HealthCheck["Health Endpoint<br/>8082/TCP"]
    end

    subgraph FSBackend["llmd-fs-backend (vLLM Plugin)"]
        OffloadManager["Offload Manager"]
        CUDATransfer["CUDA Transfer<br/>cudaMemcpyBatchAsync"]
        EventPublisher["ZMQ Event Publisher"]
    end

    subgraph PVCEvictor["PVC Evictor (Python Utility)"]
        Crawlers["N Crawler Processes"]
        Activator["Activator"]
        Deleter["Deleter"]
        FolderCleaner["Folder Cleaner"]
    end

    %% External interactions
    EPP["llm-d-router (EPP)"] -->|embeds library| Indexer
    EPP -->|gRPC over UDS| GRPCServer
    VLLMPod["vLLM Pod"] -->|ZMQ PUB 5557/TCP| ZMQSub
    SGLangPod["SGLang Pod"] -->|ZMQ PUB 5557/TCP| ZMQSub
    VLLMPod -->|loads plugin| OffloadManager
    OffloadManager --> CUDATransfer
    CUDATransfer -->|POSIX I/O| SharedStorage["Shared Storage<br/>NFS/PVC"]
    EventPublisher -->|ZMQ PUSH| ZMQSub
    Crawlers -->|scan| SharedStorage
    Activator -->|triggers| Deleter
    Deleter -->|removes files| SharedStorage
    K8sAPI["Kubernetes API<br/>443/TCP"] -.->|Pod watch| Pool
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"] -.->|model download| Tokenizer

