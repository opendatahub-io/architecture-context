graph TB
    subgraph "pipelines-components"
        subgraph "Init Container"
            GenManaged["generate_managed_pipelines.py<br/>Compiles pipeline.py → YAML"]
            InitManaged["init_managed_pipelines.py<br/>Copies YAMLs to shared volume"]
            GenManaged -->|compiled YAMLs| InitManaged
        end

        subgraph "KFP Component Library (kfp-components)"
            subgraph "Data Processing"
                DatasetDownload["dataset_download<br/>HF/S3/HTTP sources"]
                AutoMLDataLoader["automl_data_loader<br/>Tabular & time-series"]
                AutoRAGDocDiscovery["documents_discovery<br/>S3 document listing"]
                AutoRAGTextExtract["text_extraction<br/>PDF/DOCX/PPTX via Docling"]
                AutoRAGIndexing["documents_indexing<br/>ChromaDB + Llama Stack"]
                SDGComponent["sdg<br/>Synthetic Data Generation"]
            end

            subgraph "Training"
                LoRA["lora<br/>LoRA fine-tuning via Unsloth"]
                OSFT["osft<br/>OSFT via mini-trainer"]
                SFT["sft<br/>SFT via InstructLab"]
                AutoGluonTrain["autogluon_models_training<br/>Tabular AutoML"]
                RAGOptimize["rag_templates_optimization<br/>RAG config tuning"]
            end

            subgraph "Evaluation"
                LMEval["lm_eval<br/>LLM benchmarks via EleutherAI"]
                AutoGluonLeaderboard["autogluon_leaderboard<br/>Model comparison"]
                RAGLeaderboard["rag_leaderboard<br/>RAG evaluation"]
            end

            subgraph "Deployment"
                ModelRegistry["kubeflow_model_registry<br/>Model registration"]
                BuildResponses["build_responses_request_bodies<br/>AutoRAG deployment"]
            end
        end

        subgraph "Runtime Images"
            AutoMLImage["odh-automl<br/>AutoGluon + pandas + scikit-learn<br/>base-image-cpu-rhel9"]
            AutoRAGImage["odh-autorag<br/>ai4rag + Docling + Llama Stack<br/>base-image-cpu-rhel9"]
        end
    end

    %% Init container → KFP API Server
    InitManaged -->|"/config/managed-pipelines<br/>shared volume"| KFPAPI["KFP API Server"]

    %% Runtime image references
    AutoMLDataLoader -.->|runs on| AutoMLImage
    AutoGluonTrain -.->|runs on| AutoMLImage
    AutoGluonLeaderboard -.->|runs on| AutoMLImage
    AutoRAGDocDiscovery -.->|runs on| AutoRAGImage
    AutoRAGTextExtract -.->|runs on| AutoRAGImage
    AutoRAGIndexing -.->|runs on| AutoRAGImage
    RAGOptimize -.->|runs on| AutoRAGImage
    RAGLeaderboard -.->|runs on| AutoRAGImage

    %% External dependencies
    DatasetDownload -->|HTTPS/443| HFHub["HuggingFace Hub"]
    DatasetDownload -->|HTTPS/443| S3["AWS S3"]
    LoRA -->|HTTPS/443| K8sAPI["Kubernetes API<br/>TrainingJob CR"]
    OSFT -->|HTTPS/443| K8sAPI
    SFT -->|HTTPS/443| K8sAPI
    RAGOptimize -->|HTTP/HTTPS| LlamaStack["Llama Stack API"]
    ModelRegistry -->|HTTP/8080| ModelReg["Kubeflow Model Registry"]
    SDGComponent -->|HTTPS| LLMAPI["LLM API Endpoint"]
    LMEval -.->|local| vLLM["vLLM Inference"]

    %% Styling
    style GenManaged fill:#4a90e2,color:#fff
    style InitManaged fill:#4a90e2,color:#fff
    style KFPAPI fill:#7ed321,stroke:#333
    style AutoMLImage fill:#f5a623,color:#fff
    style AutoRAGImage fill:#f5a623,color:#fff
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style LlamaStack fill:#e8e8e8,stroke:#333
    style ModelReg fill:#7ed321,stroke:#333
    style LLMAPI fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
