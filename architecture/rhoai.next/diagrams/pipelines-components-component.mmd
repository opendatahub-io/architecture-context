graph TB
    subgraph PipelinesComponents["Pipelines Components"]
        direction TB

        subgraph InitContainer["odh-pipelines-components (Init Container)"]
            GenScript["generate_managed_pipelines.py<br/>Compiles pipeline.py → YAML"]
            InitScript["init_managed_pipelines.py<br/>Copies YAMLs to shared volume"]
            GenScript --> InitScript
        end

        subgraph KFPLibrary["kfp-components (Python Library)"]
            direction TB
            subgraph DataProc["Data Processing"]
                DatasetDownload["dataset_download"]
                SDG["sdg (Synthetic Data Gen)"]
                YodaProcessor["yoda_data_processor"]
            end

            subgraph Training["Training"]
                LoRA["LoRA Fine-Tuning<br/>(Unsloth)"]
                OSFT["OSFT Fine-Tuning<br/>(mini-trainer)"]
                SFT["SFT Fine-Tuning<br/>(InstructLab)"]
                AutoMLTrain["AutoGluon Training<br/>(Tabular/TimeSeries)"]
                AutoRAGOpt["RAG Optimization<br/>(ai4rag)"]
            end

            subgraph Evaluation["Evaluation"]
                LMEval["lm_eval<br/>(EleutherAI benchmarks)"]
                Leaderboard["Leaderboard Evaluation"]
            end

            subgraph Deploy["Deployment"]
                ModelReg["kubeflow_model_registry<br/>registration"]
                BuildResponses["build_responses<br/>request_bodies"]
            end
        end

        subgraph RuntimeImages["Runtime Images"]
            AutoMLImage["odh-automl<br/>AutoGluon + pandas + sklearn<br/>base-image-cpu-rhel9"]
            AutoRAGImage["odh-autorag<br/>ai4rag + Docling + Llama Stack<br/>base-image-cpu-rhel9"]
        end
    end

    %% Init Container Flow
    InitScript -->|"stages YAMLs to<br/>/config/managed-pipelines"| SharedVolume["Shared Volume<br/>/config/managed-pipelines"]
    SharedVolume -->|"reads managed pipelines"| KFPServer["KFP API Server"]

    %% Runtime image usage
    AutoMLTrain -.->|"runs on"| AutoMLImage
    AutoRAGOpt -.->|"runs on"| AutoRAGImage

    %% Fine-tuning → Trainer API
    LoRA -->|"submits TrainingJob CR"| TrainerAPI["Kubeflow Trainer<br/>ClusterTrainingRuntime"]
    OSFT -->|"submits TrainingJob CR"| TrainerAPI
    SFT -->|"submits TrainingJob CR"| TrainerAPI

    %% External Dependencies
    DatasetDownload -->|"downloads"| HFHub["HuggingFace Hub"]
    DatasetDownload -->|"downloads"| S3["AWS S3"]
    AutoRAGOpt -->|"vector store + inference"| LlamaStack["Llama Stack API"]
    ModelReg -->|"registers model"| ModelRegistry["Kubeflow Model Registry"]
    LMEval -->|"inference"| vLLM["vLLM Engine"]
    SDG -->|"LLM calls"| LLMAPI["LLM API Endpoint"]

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style KFPLibrary fill:#e8f4fd,stroke:#4a90e2
    style RuntimeImages fill:#fff3e0,stroke:#f5a623
    style KFPServer fill:#7ed321,stroke:#333
    style TrainerAPI fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#999
    style S3 fill:#e8e8e8,stroke:#999
    style LlamaStack fill:#e8e8e8,stroke:#999
    style vLLM fill:#e8e8e8,stroke:#999
    style LLMAPI fill:#e8e8e8,stroke:#999
    style SharedVolume fill:#f5a623,stroke:#333,color:#fff
