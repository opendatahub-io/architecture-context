graph TB
    subgraph "pipelines-components"
        direction TB

        subgraph InitContainer["odh-pipelines-components (Init Container)"]
            GenScript["generate_managed_pipelines.py<br/>Compiles pipeline.py → YAML"]
            InitScript["init_managed_pipelines.py<br/>Copies YAMLs to shared volume"]
            GenScript -->|compiled YAMLs| InitScript
        end

        subgraph Library["kfp-components (Python Library)"]
            direction LR
            DataProc["Data Processing<br/>dataset_download<br/>automl_data_loader<br/>autorag_discovery<br/>text_extraction<br/>sdg"]
            Training["Training<br/>LoRA (Unsloth)<br/>OSFT (mini-trainer)<br/>SFT (InstructLab)<br/>AutoGluon<br/>RAG optimization"]
            Evaluation["Evaluation<br/>lm-eval harness<br/>vLLM inference<br/>AutoGluon leaderboard<br/>RAG leaderboard"]
            Deployment["Deployment<br/>Model Registry<br/>AutoRAG responses"]
        end

        subgraph RuntimeImages["Runtime Images"]
            AutoML["odh-automl<br/>AutoGluon + pandas<br/>scikit-learn"]
            AutoRAG["odh-autorag<br/>ai4rag + Docling<br/>Llama Stack client<br/>ChromaDB"]
        end
    end

    subgraph KFPPlatform["KFP Platform"]
        KFPServer["KFP API Server"]
        ArgoWF["Argo Workflows<br/>(Pipeline Execution)"]
    end

    InitScript -->|"/config/managed-pipelines<br/>(shared volume)"| KFPServer
    KFPServer -->|orchestrates| ArgoWF
    ArgoWF -->|runs steps using| DataProc
    ArgoWF -->|runs steps using| Training
    ArgoWF -->|runs steps using| Evaluation
    ArgoWF -->|runs steps using| Deployment
    ArgoWF -->|uses image| AutoML
    ArgoWF -->|uses image| AutoRAG

    subgraph ExternalServices["External Services"]
        S3["AWS S3<br/>443/TCP HTTPS"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS"]
        LlamaStack["Llama Stack API<br/>HTTP/HTTPS"]
        LLMAPI["LLM API Endpoints<br/>HTTPS"]
    end

    subgraph InternalServices["Internal Platform Services"]
        ModelReg["Kubeflow Model Registry<br/>8080/TCP HTTP"]
        Trainer["Kubeflow Trainer<br/>443/TCP HTTPS"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
        PVC["PVC Workspace<br/>Shared Filesystem"]
    end

    DataProc -->|datasets| S3
    DataProc -->|models/datasets| HF
    DataProc -->|SDG flows| LLMAPI
    Training -->|TrainingJob CRs| Trainer
    Training -->|RAG indexing| LlamaStack
    Training -->|checkpoints| PVC
    Evaluation -->|model loading| PVC
    Deployment -->|register models| ModelReg
    Trainer -->|submit jobs| K8sAPI

    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style Library fill:#7ed321,stroke:#333,color:#fff
    style RuntimeImages fill:#f5a623,stroke:#333,color:#fff
    style KFPPlatform fill:#b8e6ff,stroke:#333
    style ExternalServices fill:#f9f9f9,stroke:#999
    style InternalServices fill:#e8f5e9,stroke:#333
