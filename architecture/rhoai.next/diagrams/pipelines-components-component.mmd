graph TB
    subgraph "Pipelines Components"
        direction TB

        subgraph "Pipeline Library (kfp-components Python Package)"
            direction LR

            subgraph "Data Processing Components"
                DatasetDL["Dataset Download<br/>(HF/S3/HTTPS/PVC/OCI)"]
                TabularLoader["Tabular Data Loader"]
                TSLoader["Timeseries Data Loader"]
                DocsDiscovery["Documents Discovery"]
                TextExtraction["Text Extraction<br/>(Docling)"]
                DocsIndexing["Documents Indexing"]
                TestDataLoader["Test Data Loader"]
                SDG["Synthetic Data<br/>Generation"]
                YodaProc["Yoda Data Processor"]
            end

            subgraph "Training Components"
                AGTabular["AutoGluon Tabular<br/>Training"]
                AGTimeseries["AutoGluon Timeseries<br/>Selection & Refit"]
                RAGOptimize["RAG Templates<br/>Optimization (ai4rag)"]
                SearchSpace["Search Space<br/>Preparation"]
                LoRA["LoRA Fine-Tuning<br/>(unsloth)"]
                OSFT["OSFT Fine-Tuning<br/>(mini-trainer)"]
                SFT["SFT Fine-Tuning<br/>(instructlab)"]
            end

            subgraph "Evaluation Components"
                LMEval["lm-eval Harness"]
                AGLeaderboard["AutoGluon<br/>Leaderboard"]
                AGTSLeaderboard["Timeseries<br/>Leaderboard"]
                RAGLeaderboard["RAG<br/>Leaderboard"]
            end

            subgraph "Deployment Components"
                ModelReg["Kubeflow Model<br/>Registry Registration"]
                ResponsesAPI["Responses API<br/>Request Builder"]
            end
        end

        subgraph "Pre-Composed Pipelines"
            AutoMLTabPipeline["AutoML Tabular<br/>Training Pipeline"]
            AutoMLTSPipeline["AutoML Timeseries<br/>Training Pipeline"]
            AutoRAGPipeline["AutoRAG Optimization<br/>Pipeline"]
            LoRAPipeline["LoRA Fine-Tuning<br/>Pipeline"]
            OSFTPipeline["OSFT Fine-Tuning<br/>Pipeline"]
            SFTPipeline["SFT Fine-Tuning<br/>Pipeline"]
            SDGPipeline["SDG Pipeline"]
            DocsIndexPipeline["Documents Indexing<br/>Pipeline"]
        end

        subgraph "Container Images"
            InitContainer["Init Container<br/>(pipelines-components)<br/>Compiles & stages managed pipelines"]
            AutoMLImage["AutoML Runtime<br/>(odh-automl)<br/>AutoGluon + PyTorch"]
            AutoRAGImage["AutoRAG Runtime<br/>(odh-autorag)<br/>Docling + LangChain + ChromaDB"]
        end

        subgraph "CI/CD Tooling"
            CompileCheck["compile_check.py"]
            ValidateBase["validate_base_images.py"]
            ValidateMeta["validate_metadata.py"]
            GenManaged["generate_managed_pipelines.py"]
            OverrideImg["override_base_images.py"]
        end
    end

    %% Pipeline composition relationships
    AutoMLTabPipeline -->|uses| TabularLoader
    AutoMLTabPipeline -->|uses| AGTabular
    AutoMLTabPipeline -->|uses| AGLeaderboard

    AutoMLTSPipeline -->|uses| TSLoader
    AutoMLTSPipeline -->|uses| AGTimeseries
    AutoMLTSPipeline -->|uses| AGTSLeaderboard

    AutoRAGPipeline -->|uses| TestDataLoader
    AutoRAGPipeline -->|uses| DocsDiscovery
    AutoRAGPipeline -->|uses| TextExtraction
    AutoRAGPipeline -->|uses| RAGOptimize
    AutoRAGPipeline -->|uses| RAGLeaderboard

    LoRAPipeline -->|uses| DatasetDL
    LoRAPipeline -->|uses| LoRA
    LoRAPipeline -->|uses| LMEval
    LoRAPipeline -->|uses| ModelReg

    OSFTPipeline -->|uses| DatasetDL
    OSFTPipeline -->|uses| OSFT
    OSFTPipeline -->|uses| LMEval
    OSFTPipeline -->|uses| ModelReg

    SFTPipeline -->|uses| DatasetDL
    SFTPipeline -->|uses| SFT
    SFTPipeline -->|uses| LMEval
    SFTPipeline -->|uses| ModelReg

    %% Init container relationship
    GenManaged -->|compiles| InitContainer
    InitContainer -->|copies YAMLs to| KFPServer["KFP API Server"]

    %% External dependencies
    AutoMLImage -->|runs| AGTabular
    AutoMLImage -->|runs| AGTimeseries
    AutoRAGImage -->|runs| TextExtraction
    AutoRAGImage -->|runs| RAGOptimize
    AutoRAGImage -->|runs| DocsIndexing

    %% External services
    DatasetDL -->|downloads from| HFHub["Hugging Face Hub"]
    DatasetDL -->|downloads from| S3["S3 Storage"]
    ModelReg -->|registers in| ModelRegistry["Model Registry"]
    RAGOptimize -->|calls| LlamaStack["Llama Stack API"]

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,stroke-width:2px
    style AutoMLImage fill:#4a90e2,stroke:#333,stroke-width:2px
    style AutoRAGImage fill:#4a90e2,stroke:#333,stroke-width:2px
    style KFPServer fill:#e8e8e8,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style LlamaStack fill:#f5a623,stroke:#333
