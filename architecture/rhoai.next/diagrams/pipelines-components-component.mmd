graph TB
    subgraph PipelinesComponents["Pipelines Components"]
        direction TB

        subgraph InitContainer["Init Container"]
            Generator["Managed Pipelines<br/>Generator<br/>(generate_managed_pipelines.py)"]
            InitScript["Init Script<br/>(init_managed_pipelines.py)"]
            Generator -->|"compiles @dsl.pipeline<br/>to YAML at build time"| InitScript
        end

        subgraph ComponentLibrary["KFP Component Library (kfp-components wheel)"]
            direction LR

            subgraph DataProc["Data Processing"]
                DatasetDownload["dataset_download"]
                DownloadModel["download_model"]
                SDG["sdg"]
                ParseChunk["parse_and_chunk"]
                IngestMilvus["ingest_to_milvus"]
                TabularLoader["tabular_data_loader"]
                TSLoader["timeseries_data_loader"]
                DocsDiscovery["documents_discovery"]
                TextExtraction["text_extraction"]
                DocsIndexing["documents_indexing"]
            end

            subgraph Training["Training"]
                SFT["sft (fine-tuning)"]
                AutoGluonTabular["autogluon_tabular"]
                AutoGluonTS["autogluon_timeseries"]
                RAGOptimize["rag_templates_optimization"]
                Leaderboard["leaderboard_evaluation"]
            end

            subgraph Evaluation["Evaluation"]
                LMEval["lm_eval"]
                EvalHub["evalhub_kserve"]
            end

            subgraph Deployment["Deployment"]
                ModelDeploy["model_deployment"]
                EmbeddingDeploy["deploy_embedding_model"]
                ModelRegistryComp["kubeflow_model_registry"]
            end
        end

        subgraph ValidationCI["Validation & CI"]
            CompileCheck["compile_check"]
            ValidateComponents["validate_components"]
            ValidateBaseImages["validate_base_images"]
        end
    end

    subgraph RuntimeImages["Runtime Container Images"]
        AutoMLImage["odh-automl<br/>(AutoGluon + kfp-components)<br/>AIPCC CPU base"]
        AutoRAGImage["odh-autorag<br/>(AI4RAG + Docling + OGX)<br/>AIPCC CPU base"]
        PipelinesImage["odh-pipelines-components<br/>(Init Container)<br/>UBI9 Python 3.12"]
    end

    %% Init container flow
    InitScript -->|"copies compiled YAMLs<br/>to shared volume"| SharedVol["Shared Volume<br/>/config/managed-pipelines/"]
    SharedVol -->|"consumed by"| KFPAPI["KFP API Server"]
    KFPAPI -->|"managed by"| DSPO["DSPO"]

    %% Runtime image relationships
    AutoGluonTabular -.->|"runs in"| AutoMLImage
    AutoGluonTS -.->|"runs in"| AutoMLImage
    TabularLoader -.->|"runs in"| AutoMLImage
    TSLoader -.->|"runs in"| AutoMLImage
    DocsDiscovery -.->|"runs in"| AutoRAGImage
    TextExtraction -.->|"runs in"| AutoRAGImage
    DocsIndexing -.->|"runs in"| AutoRAGImage
    RAGOptimize -.->|"runs in"| AutoRAGImage
    Generator -.->|"packaged in"| PipelinesImage

    %% External integrations
    ModelDeploy -->|"creates CRDs"| KServe["KServe<br/>(InferenceService)"]
    EmbeddingDeploy -->|"creates CRDs"| KServe
    ParseChunk -->|"submits"| RayOp["Ray Operator<br/>(RayJob)"]
    ModelRegistryComp -->|"registers models"| ModelReg["Model Registry"]
    IngestMilvus -->|"inserts vectors"| Milvus["Milvus"]

    %% External data sources
    DatasetDownload -->|"downloads"| HFHub["HuggingFace Hub"]
    DatasetDownload -->|"reads/writes"| S3["S3 Storage"]
    SFT -->|"training via"| KFTrainer["Kubeflow Trainer"]

    %% Styling
    style PipelinesComponents fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style InitContainer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ComponentLibrary fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RuntimeImages fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style ValidationCI fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style AutoMLImage fill:#f8cecc,stroke:#b85450
    style AutoRAGImage fill:#f8cecc,stroke:#b85450
    style PipelinesImage fill:#f8cecc,stroke:#b85450
    style DSPO fill:#7ed321,stroke:#333
    style KFPAPI fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style RayOp fill:#7ed321,stroke:#333
    style ModelReg fill:#7ed321,stroke:#333
    style Milvus fill:#7ed321,stroke:#333
    style HFHub fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style KFTrainer fill:#7ed321,stroke:#333
    style SharedVol fill:#dae8fc,stroke:#6c8ebf
