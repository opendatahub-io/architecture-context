graph TB
    subgraph "Pipelines Components"
        direction TB

        subgraph "Init Container"
            InitContainer["odh-pipelines-components<br/>(Init Container)<br/>Python 3.12 / UBI9"]
            InitEntrypoint["init_managed_pipelines<br/>(Entrypoint Script)"]
            GenScript["generate_managed_pipelines<br/>(Build Script)"]
            InitContainer --> InitEntrypoint
            GenScript -->|"compiles at build time"| InitContainer
        end

        subgraph "Runtime Images"
            AutoML["odh-automl<br/>(Runtime Image)<br/>AutoGluon + PyTorch<br/>AIPCC CPU Base"]
            AutoRAG["odh-autorag<br/>(Runtime Image)<br/>Docling + ai4rag + OGX<br/>AIPCC CPU Base"]
        end

        subgraph "KFP Component Library"
            direction LR
            DataProc["Data Processing<br/>Components"]
            Training["Training<br/>Components"]
            Evaluation["Evaluation<br/>Components"]
            Deployment["Deployment<br/>Components"]
        end

        subgraph "Data Processing Components"
            DatasetDownload["dataset_download"]
            DownloadModel["download_model"]
            ParseChunk["parse_and_chunk"]
            IngestMilvus["ingest_to_milvus"]
            SDG["sdg (Synthetic Data)"]
            DocsDiscovery["documents_discovery"]
            TextExtraction["text_extraction"]
        end

        subgraph "Training Components"
            LoRA["LoRA Fine-Tuning"]
            OSFT["OSFT Fine-Tuning"]
            SFT["SFT Fine-Tuning"]
            AutoGluonTrain["AutoGluon Training"]
            AutoGluonTS["AutoGluon Timeseries"]
            RAGOptimize["RAG Optimization"]
        end

        subgraph "Evaluation Components"
            LMEval["lm-eval Evaluator"]
            EvalHub["Eval Hub Evaluator"]
            Leaderboard["Leaderboard Evaluation"]
        end

        subgraph "Deployment Components"
            ModelDeploy["model_deployment"]
            EmbeddingDeploy["deploy_embedding_model"]
            ModelReg["kubeflow_model_registry"]
        end
    end

    %% Init container flow
    InitEntrypoint -->|"copies YAMLs to"| SharedVol["Shared Volume<br/>/config/managed-pipelines"]
    SharedVol -->|"read by"| KFPServer["KFP API Server"]

    %% Runtime image usage
    AutoML -.->|"base_image for"| AutoGluonTrain
    AutoML -.->|"base_image for"| AutoGluonTS
    AutoRAG -.->|"base_image for"| DocsDiscovery
    AutoRAG -.->|"base_image for"| TextExtraction
    AutoRAG -.->|"base_image for"| RAGOptimize

    %% Component categories
    DataProc --> DatasetDownload
    DataProc --> DownloadModel
    DataProc --> ParseChunk
    DataProc --> IngestMilvus
    DataProc --> SDG
    DataProc --> DocsDiscovery
    DataProc --> TextExtraction
    Training --> LoRA
    Training --> OSFT
    Training --> SFT
    Training --> AutoGluonTrain
    Training --> AutoGluonTS
    Training --> RAGOptimize
    Evaluation --> LMEval
    Evaluation --> EvalHub
    Evaluation --> Leaderboard
    Deployment --> ModelDeploy
    Deployment --> EmbeddingDeploy
    Deployment --> ModelReg

    %% External dependencies
    ModelDeploy -->|"creates CRDs"| KServe["KServe<br/>(ServingRuntime /<br/>InferenceService)"]
    EmbeddingDeploy -->|"creates CRDs"| KServe
    EvalHub -->|"ephemeral CRDs"| KServe
    ModelReg -->|"REST API"| ModelRegistry["Model Registry<br/>8080/TCP"]
    ParseChunk -->|"creates CRD"| KubeRay["KubeRay<br/>(RayJob)"]
    LoRA -->|"uses CRD"| TrainingOp["Training Operator<br/>(ClusterTrainingRuntime)"]

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style AutoML fill:#4a90e2,stroke:#333,color:#fff
    style AutoRAG fill:#4a90e2,stroke:#333,color:#fff
    style KFPServer fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333
    style TrainingOp fill:#7ed321,stroke:#333
    style SharedVol fill:#f5a623,stroke:#333
    style DataProc fill:#e8e8e8,stroke:#333
    style Training fill:#e8e8e8,stroke:#333
    style Evaluation fill:#e8e8e8,stroke:#333
    style Deployment fill:#e8e8e8,stroke:#333
