graph TB
    subgraph PipelinesComponents["Pipelines Components"]
        direction TB

        subgraph Library["KFP Component Library"]
            DataProc["Data Processing<br/>Components"]
            Training["Training<br/>Components"]
            Evaluation["Evaluation<br/>Components"]
            Deployment["Deployment<br/>Components"]
        end

        subgraph Pipelines["Pre-composed Pipelines"]
            AutoMLPipeline["AutoML Pipelines<br/>(Tabular, Timeseries)"]
            AutoRAGPipeline["AutoRAG Pipeline<br/>(Document Optimization)"]
            FineTunePipeline["Fine-Tuning Pipelines<br/>(LoRA, OSFT, SFT)"]
        end

        subgraph InitContainer["Managed Pipeline Init Container"]
            Compiler["Pipeline Compiler<br/>(generate_managed_pipelines.py)"]
            Stager["Pipeline Stager<br/>(init_managed_pipelines.py)"]
            Compiler -->|"compiles at build time"| Stager
        end

        subgraph RuntimeImages["Runtime Images"]
            AutoMLImage["odh-automl<br/>AutoGluon + PyTorch"]
            AutoRAGImage["odh-autorag<br/>Docling + LangChain + ChromaDB"]
        end
    end

    %% Pipeline composition
    DataProc -->|"used by"| AutoMLPipeline
    DataProc -->|"used by"| AutoRAGPipeline
    DataProc -->|"used by"| FineTunePipeline
    Training -->|"used by"| AutoMLPipeline
    Training -->|"used by"| AutoRAGPipeline
    Training -->|"used by"| FineTunePipeline
    Evaluation -->|"used by"| FineTunePipeline
    Deployment -->|"used by"| FineTunePipeline

    %% Runtime image usage
    AutoMLPipeline -->|"runs on"| AutoMLImage
    AutoRAGPipeline -->|"runs on"| AutoRAGImage

    %% Init container flow
    Pipelines -->|"managed pipelines"| Compiler
    Stager -->|"copies YAMLs to<br/>/config/managed-pipelines/"| KFPServer["KFP API Server"]

    %% External dependencies
    FineTunePipeline -->|"downloads models"| HFHub["Hugging Face Hub"]
    FineTunePipeline -->|"registers models"| ModelRegistry["Kubeflow Model Registry"]
    AutoRAGPipeline -->|"embeddings & inference"| LlamaStack["Llama Stack API"]
    AutoMLPipeline -->|"dataset I/O"| S3["S3-Compatible Storage"]
    FineTunePipeline -->|"dataset I/O"| S3
    AutoRAGPipeline -->|"document storage"| S3

    %% Platform integration
    KFPServer -->|"execution runtime"| DSPA["Data Science Pipelines<br/>Application (DSPA)"]

    %% Styling
    style PipelinesComponents fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Library fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Pipelines fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style InitContainer fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style RuntimeImages fill:#f8cecc,stroke:#b85450,stroke-width:1px

    style DataProc fill:#d5e8d4,stroke:#82b366
    style Training fill:#d5e8d4,stroke:#82b366
    style Evaluation fill:#d5e8d4,stroke:#82b366
    style Deployment fill:#d5e8d4,stroke:#82b366

    style AutoMLPipeline fill:#dae8fc,stroke:#6c8ebf
    style AutoRAGPipeline fill:#dae8fc,stroke:#6c8ebf
    style FineTunePipeline fill:#dae8fc,stroke:#6c8ebf

    style Compiler fill:#fff2cc,stroke:#d6b656
    style Stager fill:#fff2cc,stroke:#d6b656
    style AutoMLImage fill:#f8cecc,stroke:#b85450
    style AutoRAGImage fill:#f8cecc,stroke:#b85450

    style KFPServer fill:#e1d5e7,stroke:#9673a6
    style DSPA fill:#e1d5e7,stroke:#9673a6
    style HFHub fill:#f5f5f5,stroke:#666
    style ModelRegistry fill:#e1d5e7,stroke:#9673a6
    style LlamaStack fill:#f5f5f5,stroke:#666
    style S3 fill:#f5f5f5,stroke:#666
