graph LR
    TrainerOp["trainer-operator<br/>(Module Operator)"]

    %% Internal Platform Dependencies (Go modules / runtime)
    TrainerOp -->|"Go module<br/>PlatformObject, GC,<br/>kustomize, conditions"| ODHPlatUtils["odh-platform-utilities<br/>v0.1.0"]
    TrainerOp -->|"Build-time manifest<br/>fetch (get_trainer_manifests.sh)"| UpstreamTrainer["opendatahub-io/trainer<br/>(or red-hat-data-services/trainer)"]
    TrainerOp -->|"Creates Trainer CR<br/>triggers reconciliation"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]

    %% Runtime Dependencies
    TrainerOp -->|"Required: CRD check<br/>+ OLM install check"| JobSetOp["JobSet Operator<br/>(OLM)"]
    TrainerOp -->|"Required: CRD must<br/>be Established"| JobSetCRD["JobSet CRD<br/>(jobsets.jobset.x-k8s.io)"]

    %% Go Module Dependencies
    TrainerOp -->|"Go module<br/>API types"| KFTrainerAPI["Kubeflow Trainer v2<br/>v2.2.0"]
    TrainerOp -->|"Go module<br/>controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    TrainerOp -->|"Go module<br/>manifest rendering"| ManifestKit["k8s-manifest-kit<br/>v0.2.1"]
    TrainerOp -->|"Go module<br/>K8s API types + client"| K8sGoMod["k8s.io/api + client-go<br/>v0.35.2"]
    TrainerOp -->|"Go module (indirect)<br/>JobSet API types"| JobSetAPI["sigs.k8s.io/jobset<br/>v0.11.1"]
    TrainerOp -->|"Go module (indirect)<br/>PodGroup API types"| VolcanoAPI["volcano.sh/apis<br/>v1.13.1"]
    TrainerOp -->|"Go module (indirect)<br/>chart rendering"| HelmAPI["helm.sh/helm/v4<br/>v4.1.1"]

    %% Infrastructure Dependencies
    TrainerOp -->|"CRUD on all<br/>managed resources"| K8sAPI["Kubernetes API<br/>Server"]

    %% Integration Points (other components that interact)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080"| TrainerOp
    RhodsOp -->|"creates/deletes<br/>Trainer CR"| TrainerOp

    %% Deployed downstream
    TrainerOp -.->|"deploys via SSA"| KFController["Kubeflow Trainer v2<br/>Controller (deployed)"]
    TrainerOp -.->|"deploys via SSA"| CTRuntimes["ClusterTrainingRuntimes<br/>(15 variants)"]
    TrainerOp -.->|"deploys via SSA<br/>(OpenShift only)"| ImgStreams["Training Hub<br/>ImageStreams"]

