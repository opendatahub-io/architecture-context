graph TB
    subgraph MCPServer["RHOAI MCP Server"]
        direction TB

        subgraph Core["Core Layer"]
            FastMCP["FastMCP Server<br/>(stdio/SSE/HTTP)"]
            PluginMgr["Plugin Manager<br/>(pluggy)"]
            K8sClient["K8sClient<br/>(kubeconfig/token/in-cluster)"]
            ResponseBuilder["Response Builder<br/>(verbosity control)"]
            PortFwdMgr["Port Forward Manager<br/>(async oc port-forward)"]
            Cache["TTL Cache"]
        end

        subgraph Domains["Domain Modules (10 Plugins)"]
            direction LR
            Projects["Projects<br/>5 tools"]
            Notebooks["Notebooks<br/>8 tools"]
            Inference["Inference<br/>12 tools"]
            Pipelines["Pipelines<br/>3 tools"]
            Connections["Connections<br/>4 tools"]
            Storage["Storage<br/>3 tools"]
            Training["Training<br/>21 tools"]
            ModelReg["Model Registry<br/>10 tools"]
            Quickstarts["Quickstarts<br/>3 tools"]
            Prompts["Prompts<br/>18 prompts"]
        end

        subgraph Composites["Composite Modules (4 Plugins)"]
            direction LR
            ClusterComp["Cluster<br/>9 tools"]
            TrainingComp["Training Workflow<br/>orchestration"]
            MetaComp["Meta / Tool Discovery<br/>2 tools"]
            NeuralNav["Neural Navigator<br/>2 tools"]
        end
    end

    %% External clients
    Agent["AI Agent<br/>(Claude Desktop/Code)"]
    Agent -->|"MCP JSON-RPC<br/>stdio or 8000/TCP"| FastMCP

    %% Core relationships
    FastMCP -->|registers| PluginMgr
    PluginMgr -->|loads| Domains
    PluginMgr -->|loads| Composites
    Domains -->|uses| K8sClient
    Domains -->|uses| ResponseBuilder
    Composites -->|orchestrates| Domains
    ModelReg -->|uses| PortFwdMgr

    %% External dependencies
    K8sClient -->|"HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    ModelReg -->|"HTTP/8080 or HTTPS/8443"| ModelRegSvc["Model Registry API"]
    ModelReg -->|"HTTP/8080 or HTTPS/8443"| ModelCatalog["Model Catalog API"]
    NeuralNav -->|"HTTP/8000"| NeuralNavBE["Neural Navigator Backend"]
    Quickstarts -->|"HTTPS/443"| GitHub["GitHub"]

    %% CRDs consumed
    K8sClient -.->|watches| DSC["DataScienceCluster CR"]
    K8sClient -.->|CRUD| NotebookCR["Notebook CR"]
    K8sClient -.->|CRUD| InferSvcCR["InferenceService CR"]
    K8sClient -.->|CRUD| TrainJobCR["TrainJob CR"]
    K8sClient -.->|CRUD| DSPACR["DSPA CR"]

    %% Styling
    style MCPServer fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Core fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Domains fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Composites fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style FastMCP fill:#4a90e2,color:#fff
    style PluginMgr fill:#4a90e2,color:#fff
    style K8sClient fill:#4a90e2,color:#fff
    style Agent fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333
    style ModelRegSvc fill:#999,stroke:#333
    style ModelCatalog fill:#999,stroke:#333
    style NeuralNavBE fill:#999,stroke:#333
    style GitHub fill:#999,stroke:#333
    style DSC fill:#f5a623,stroke:#333
    style NotebookCR fill:#f5a623,stroke:#333
    style InferSvcCR fill:#f5a623,stroke:#333
    style TrainJobCR fill:#f5a623,stroke:#333
    style DSPACR fill:#f5a623,stroke:#333
