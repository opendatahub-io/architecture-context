graph TB
    subgraph MCPServer["RHOAI MCP Server"]
        direction TB

        subgraph Core["Core Services"]
            FastMCP["FastMCP Server<br/>(SSE / streamable-http / stdio)"]
            PluginMgr["Plugin Manager<br/>(pluggy framework)"]
            K8sClient["K8s Dynamic Client<br/>(kubernetes-python SDK)"]
            AuthSystem["Auth System<br/>(OIDC / TokenReview)"]
        end

        subgraph DomainPlugins["Domain Plugins"]
            Projects["Projects Plugin<br/>(namespaces, labels)"]
            Notebooks["Notebooks Plugin<br/>(workbench lifecycle)"]
            Inference["Inference Plugin<br/>(model serving)"]
            Connections["Connections Plugin<br/>(data connections)"]
            Storage["Storage Plugin<br/>(PVCs, storage classes)"]
            Pipelines["Pipelines Plugin<br/>(DSPA management)"]
            Training["Training Plugin<br/>(TrainJob lifecycle)"]
            ModelReg["Model Registry Plugin<br/>(models, versions)"]
            Quickstarts["Quickstarts Plugin<br/>(deploy templates)"]
            Prompts["Prompts Plugin<br/>(guided workflows)"]
        end

        subgraph CompositePlugins["Composite Plugins"]
            ClusterSummary["Cluster Summary<br/>(aggregated health)"]
            TrainingOrch["Training Orchestration<br/>(unified workflow)"]
            MetaTools["Meta / Tool Discovery<br/>(suggest_tools)"]
            Planner["Planner<br/>(model recommendations)"]
        end

        FastMCP -->|"routes requests"| PluginMgr
        PluginMgr -->|"loads"| DomainPlugins
        PluginMgr -->|"loads"| CompositePlugins
        AuthSystem -->|"validates tokens"| FastMCP
        AuthSystem -->|"RBAC filtering"| PluginMgr
        DomainPlugins -->|"uses"| K8sClient
        CompositePlugins -->|"aggregates"| DomainPlugins
    end

    AIAgent["AI Agent<br/>(Claude Desktop / Code / Lightspeed)"]
    AIAgent -->|"MCP Protocol<br/>8000/TCP"| FastMCP

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    K8sClient -->|"CRUD operations<br/>TLS 1.2+"| K8sAPI

    ModelRegSvc["Model Registry Service<br/>8080/8443 TCP"]
    ModelReg -->|"REST API<br/>httpx"| ModelRegSvc

    PlannerSvc["Planner Backend<br/>8000/TCP HTTP"]
    Planner -->|"REST API"| PlannerSvc

    CatalogSvc["Model Catalog<br/>8080/8443 TCP"]
    ModelReg -->|"REST API"| CatalogSvc

    GitHub["GitHub<br/>(rh-ai-quickstart)"]
    Quickstarts -->|"git clone<br/>443/TCP HTTPS"| GitHub

    OIDCProvider["OIDC Identity Provider"]
    AuthSystem -->|"JWKS fetch<br/>443/TCP HTTPS"| OIDCProvider

    %% CRDs watched
    NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1)"]
    DSPACR["DSPA CR<br/>(opendatahub.io/v1alpha1)"]
    DSCCR["DataScienceCluster CR"]

    Notebooks -->|"watches/creates"| NotebookCR
    Inference -->|"watches/creates"| InferenceServiceCR
    Training -->|"watches/creates"| TrainJobCR
    Pipelines -->|"watches/creates"| DSPACR
    ClusterSummary -->|"reads"| DSCCR

    %% Styling
    style MCPServer fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style DomainPlugins fill:#f0fdf4,stroke:#22c55e,stroke-width:1px
    style CompositePlugins fill:#fef3c7,stroke:#f59e0b,stroke-width:1px

    style FastMCP fill:#4a90e2,color:#fff
    style PluginMgr fill:#4a90e2,color:#fff
    style K8sClient fill:#4a90e2,color:#fff
    style AuthSystem fill:#4a90e2,color:#fff

    style AIAgent fill:#f5f5f5,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#666
    style ModelRegSvc fill:#7ed321,stroke:#333
    style PlannerSvc fill:#7ed321,stroke:#333
    style CatalogSvc fill:#7ed321,stroke:#333
    style GitHub fill:#f5a623,stroke:#333
    style OIDCProvider fill:#f5a623,stroke:#333

    style NotebookCR fill:#fef3c7,stroke:#d97706
    style InferenceServiceCR fill:#fef3c7,stroke:#d97706
    style TrainJobCR fill:#fef3c7,stroke:#d97706
    style DSPACR fill:#fef3c7,stroke:#d97706
    style DSCCR fill:#fef3c7,stroke:#d97706
