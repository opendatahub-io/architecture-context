graph TB
    %% RHOAI MCP Server - Component Structure Diagram
    %% Generated from: architecture/rhoai.next/rhoai-mcp.md

    Agent["AI Agent<br/>(Claude Desktop / Lightspeed / Custom LLM)"]

    subgraph MCPServer["RHOAI MCP Server (FastMCP)"]
        direction TB

        subgraph Transport["Transport Layer"]
            STDIO["stdio<br/>Transport"]
            SSE["SSE<br/>/sse (8000/TCP)"]
            StreamHTTP["Streamable HTTP<br/>/mcp (8000/TCP)"]
            Health["/health<br/>Liveness Probe"]
        end

        subgraph Core["Core Services"]
            PluginMgr["Plugin Manager<br/>(pluggy)"]
            K8sClient["K8s Client<br/>(kubernetes)"]
            ResponseBuilder["Response Builder<br/>(verbosity: minimal/standard/full)"]
            PortFwdMgr["Port Forward Manager<br/>(oc port-forward)"]
            Cache["Cache Manager"]
            Config["Config<br/>(pydantic-settings)"]
        end

        subgraph DomainPlugins["Domain Plugins (10)"]
            Projects["projects<br/>Namespaces & Labels"]
            Notebooks["notebooks<br/>Workbench Lifecycle"]
            Inference["inference<br/>Model Serving"]
            Pipelines["pipelines<br/>DSPA Management"]
            Connections["connections<br/>S3 Secrets"]
            Storage["storage<br/>PVC Management"]
            Training["training<br/>Distributed Training"]
            ModelReg["model_registry<br/>Registry Integration"]
            Quickstarts["quickstarts<br/>Guided Workflows"]
            Prompts["prompts<br/>Workflow Prompts"]
        end

        subgraph CompositePlugins["Composite Plugins (4)"]
            Cluster["cluster<br/>Cluster Exploration"]
            TrainingComp["training_composites<br/>Training Orchestration"]
            Meta["meta<br/>Tool Discovery"]
            NeuralNav["neuralnav<br/>Model Recommendation"]
        end
    end

    %% Agent connections
    Agent -->|"MCP Protocol<br/>(stdio / SSE / HTTP)"| Transport

    %% Transport to Plugin Manager
    STDIO --> PluginMgr
    SSE --> PluginMgr
    StreamHTTP --> PluginMgr

    %% Plugin Manager dispatches to plugins
    PluginMgr --> DomainPlugins
    PluginMgr --> CompositePlugins

    %% Plugins use core services
    DomainPlugins --> K8sClient
    DomainPlugins --> ResponseBuilder
    CompositePlugins --> K8sClient
    CompositePlugins --> ResponseBuilder
    NeuralNav --> PortFwdMgr
    ModelReg --> PortFwdMgr

    %% CRDs watched/managed
    subgraph CRDs["Kubernetes CRDs (watched/managed)"]
        NotebookCR["Notebook<br/>kubeflow.org/v1"]
        InferenceServiceCR["InferenceService<br/>serving.kserve.io/v1beta1"]
        ServingRuntimeCR["ServingRuntime<br/>serving.kserve.io/v1alpha1"]
        DSPACR["DSPA<br/>opendatahub.io/v1alpha1"]
        TrainJobCR["TrainJob<br/>kubeflow.org/v1alpha1"]
        DSCCR["DataScienceCluster<br/>opendatahub.io/v1"]
        ModelRegCR["ModelRegistry<br/>opendatahub.io/v1alpha1"]
        AccelCR["AcceleratorProfile<br/>dashboard.opendatahub.io/v1"]
    end

    K8sClient -->|"HTTPS/6443<br/>Bearer Token"| CRDs

    %% External services
    subgraph ExternalSvc["External Services"]
        K8sAPI["Kubernetes<br/>API Server"]
        ModelRegSvc["Model Registry<br/>Service (8080)"]
        NeuralNavSvc["Neural Navigator<br/>Backend (8000)"]
        S3Svc["S3 Storage<br/>(443)"]
    end

    K8sClient -->|"HTTPS/6443"| K8sAPI
    ModelReg -->|"HTTP/8080<br/>port-forward"| ModelRegSvc
    NeuralNav -->|"HTTP/8000<br/>in-cluster"| NeuralNavSvc
    Connections -.->|"HTTPS/443<br/>validation"| S3Svc

    %% Styling
    style MCPServer fill:#e8f4fd,stroke:#2196f3,stroke-width:2px
    style Transport fill:#bbdefb,stroke:#1976d2
    style Core fill:#c8e6c9,stroke:#388e3c
    style DomainPlugins fill:#fff3e0,stroke:#f57c00
    style CompositePlugins fill:#f3e5f5,stroke:#7b1fa2
    style CRDs fill:#fff9c4,stroke:#f9a825
    style ExternalSvc fill:#ffebee,stroke:#c62828

    style Agent fill:#4a90e2,stroke:#333,color:#fff
    style PluginMgr fill:#4caf50,stroke:#333,color:#fff
    style K8sClient fill:#4caf50,stroke:#333,color:#fff
    style Config fill:#4caf50,stroke:#333,color:#fff
