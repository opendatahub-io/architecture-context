graph LR
    OGX["OGX Distribution<br/>AI Gateway<br/>8321/TCP"]

    %% Internal ODH/RHOAI Dependencies
    OGXUpstream["opendatahub-io/ogx<br/>(ogx + ogx-api packages)"]
    AIPCCBase["AIPCC Base Image<br/>cpu:3.5.0-ea.2<br/>RHEL 9.6 + Python 3.12"]
    Konflux["Konflux Central<br/>Tekton Pipelines"]

    OGX ---|"pip install<br/>(git)"| OGXUpstream
    AIPCCBase -.->|"container base<br/>FROM"| OGX
    Konflux -.->|"multi-arch build<br/>amd64, arm64, ppc64le"| OGX

    %% Primary Inference Provider
    vLLM_Inf["vLLM Inference<br/>8000/TCP HTTP/S"]
    vLLM_Emb["vLLM Embedding<br/>8001/TCP HTTP/S"]
    OGX -->|"chat completions<br/>Bearer Token"| vLLM_Inf
    OGX -->|"embeddings<br/>Bearer Token"| vLLM_Emb

    %% Cloud Inference Providers
    Bedrock["AWS Bedrock<br/>443/TCP HTTPS"]
    WatsonX["IBM WatsonX<br/>443/TCP HTTPS"]
    Azure["Azure OpenAI<br/>443/TCP HTTPS"]
    Vertex["Google Vertex AI<br/>443/TCP HTTPS"]
    OpenAI["OpenAI<br/>443/TCP HTTPS"]
    Gemini["Google Gemini<br/>443/TCP HTTPS"]
    Anthropic["Anthropic<br/>443/TCP HTTPS"]

    OGX -.->|"ENABLE_BEDROCK"| Bedrock
    OGX -.->|"WATSONX_API_KEY"| WatsonX
    OGX -.->|"AZURE_API_KEY"| Azure
    OGX -.->|"VERTEX_AI_PROJECT"| Vertex
    OGX -.->|"OPENAI_API_KEY"| OpenAI
    OGX -.->|"ENABLE_GEMINI"| Gemini
    OGX -.->|"ANTHROPIC_API_KEY"| Anthropic

    %% State Store (Required)
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    OGX -->|"state persistence<br/>User/Pass"| PostgreSQL

    %% Vector Databases (Optional)
    Milvus["Milvus<br/>gRPC/HTTPS"]
    PGVector["pgvector<br/>5432/TCP"]
    Qdrant["Qdrant<br/>6333-6334/TCP"]

    OGX -.->|"vector ops<br/>Token + mTLS"| Milvus
    OGX -.->|"vector ops<br/>User/Pass"| PGVector
    OGX -.->|"vector ops<br/>API Key"| Qdrant

    %% Tool Runtimes (Optional)
    BraveSearch["Brave Search<br/>443/TCP HTTPS"]
    TavilySearch["Tavily Search<br/>443/TCP HTTPS"]
    MCPServers["MCP Servers<br/>Configurable"]
    DoclingServe["Docling Serve<br/>Configurable"]

    OGX -.->|"web search<br/>API Key"| BraveSearch
    OGX -.->|"web search<br/>API Key"| TavilySearch
    OGX -.->|"tool execution"| MCPServers
    OGX -.->|"document processing<br/>API Key"| DoclingServe

    %% Storage (Optional)
    S3["AWS S3<br/>443/TCP HTTPS"]
    OGX -.->|"file storage<br/>IAM Creds"| S3

    %% Auth (Optional)
    OIDC["OAuth2/OIDC Issuer<br/>443/TCP HTTPS"]
    OGX -.->|"JWKS retrieval<br/>AUTH_ISSUER"| OIDC

    %% Observability (Optional)
    OTel["OpenTelemetry Collector<br/>OTLP gRPC/HTTP"]
    OGX -.->|"traces + metrics<br/>OTEL_SERVICE_NAME"| OTel

    %% Build-time only
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    OGX -.->|"model download<br/>(build-time only)"| HFHub

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal dependencies
    style OGXUpstream fill:#7ed321,stroke:#333
    style AIPCCBase fill:#cc0000,stroke:#333,color:#fff
    style Konflux fill:#7ed321,stroke:#333

    %% Required dependencies
    style vLLM_Inf fill:#4a90e2,stroke:#333,color:#fff
    style vLLM_Emb fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,stroke-width:3px

    %% Cloud providers (optional)
    style Bedrock fill:#999,stroke:#333
    style WatsonX fill:#999,stroke:#333
    style Azure fill:#999,stroke:#333
    style Vertex fill:#999,stroke:#333
    style OpenAI fill:#999,stroke:#333
    style Gemini fill:#999,stroke:#333
    style Anthropic fill:#999,stroke:#333

    %% Vector DBs (optional)
    style Milvus fill:#d4a574,stroke:#333
    style PGVector fill:#d4a574,stroke:#333
    style Qdrant fill:#d4a574,stroke:#333

    %% Tool runtimes (optional)
    style BraveSearch fill:#9b59b6,stroke:#333,color:#fff
    style TavilySearch fill:#9b59b6,stroke:#333,color:#fff
    style MCPServers fill:#9b59b6,stroke:#333,color:#fff
    style DoclingServe fill:#9b59b6,stroke:#333,color:#fff

    %% Storage & infrastructure
    style S3 fill:#f5a623,stroke:#333
    style OIDC fill:#e8e8e8,stroke:#333
    style OTel fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
