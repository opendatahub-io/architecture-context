    style Tempo fill:#50c8e8,stroke:#333,color:#fff

    style NFD fill:#e8a850,stroke:#333,color:#fff
    style GPUOp fill:#e8a850,stroke:#333,color:#fff

    style KEDA fill:#c8c8c8,stroke:#333
    style MariaDB fill:#c8c8c8,stroke:#333

