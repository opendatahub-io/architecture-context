graph LR
    ODHGitops["odh-gitops<br/>GitOps / Helm / Kustomize"]

    %% ===== Internal Platform Dependencies =====
    subgraph InternalPlatform["Internal Platform (Installed by odh-gitops)"]
        direction TB
        RhodsOp["rhods-operator /<br/>opendatahub-operator"]
        CertMgr["cert-manager"]
        Kueue["Kueue"]
        LWS["Leader Worker Set"]
        JobSet["JobSet"]
        Kuadrant["Kuadrant / RHCL /<br/>Authorino"]
        IstioSail["Istio / Sail Operator"]
        GatewayAPI["Gateway API CRDs"]
    end

    subgraph Observability["Observability Stack"]
        direction TB
        COO["Cluster Observability<br/>Operator"]
        OTel["OpenTelemetry"]
        Tempo["Tempo"]
    end

    subgraph GPUStack["GPU / Hardware Stack"]
        direction TB
        NFD["NFD (Node Feature<br/>Discovery)"]
        GPUOp["NVIDIA GPU Operator<br/>(driver v580.65.06)"]
    end

    subgraph OptionalDeps["Optional Dependencies"]
        direction TB
        KEDA["Custom Metrics<br/>Autoscaler (KEDA)"]
        MariaDB["MariaDB Operator<br/>(community, Manual approval)"]
    end

    %% ===== External Dependencies =====
    subgraph ExternalPlatform["External Platform"]
        direction TB
        OpenShift["OpenShift 4.19.9+"]
        K8s["Kubernetes 1.28+"]
        OLM["OLM"]
    end

    subgraph ExternalTools["External Tools"]
        direction TB
        Helm["Helm v3"]
        Kustomize["Kustomize v5+"]
        Kubectl["kubectl / oc"]
        ArgoCD["ArgoCD / Flux<br/>(optional)"]
        Podman["Podman<br/>(optional)"]
    end

    subgraph ExternalServices["External Services"]
        direction TB
        RegistryRH["registry.redhat.io"]
        Quay["quay.io"]
        CloudAPIs["Cloud Provider APIs<br/>(Azure / CoreWeave / AWS)"]
    end

    %% ===== Relationships =====

    %% Internal platform
    ODHGitops -->|"OLM Sub / Helm deploy"| RhodsOp
    ODHGitops -->|"OLM Sub / Helm sub-chart"| CertMgr
    ODHGitops -->|"OLM Sub + CR"| Kueue
    ODHGitops -->|"OLM Sub / Helm sub-chart"| LWS
    ODHGitops -->|"OLM Sub + CR"| JobSet
    ODHGitops -->|"OLM Sub + CRs"| Kuadrant
    ODHGitops -->|"OLM Sub / Helm sub-chart"| IstioSail
    ODHGitops -->|"Helm sub-chart (CRDs)"| GatewayAPI

    %% Observability
    ODHGitops -->|"OLM Sub"| COO
    ODHGitops -->|"OLM Sub"| OTel
    ODHGitops -->|"OLM Sub"| Tempo
    OTel -.->|"depends on"| COO
    Tempo -.->|"depends on"| COO

    %% GPU
    ODHGitops -->|"OLM Sub + CR"| NFD
    ODHGitops -->|"OLM Sub + ClusterPolicy"| GPUOp
    GPUOp -.->|"depends on"| NFD

    %% Optional
    ODHGitops -->|"OLM Sub"| KEDA
    ODHGitops -.->|"OLM Sub (optional)"| MariaDB

    %% External platform
    ODHGitops -->|"deploys on"| OpenShift
    ODHGitops -->|"deploys on (xKS)"| K8s
    ODHGitops -->|"manages via"| OLM

    %% External tools
    ODHGitops -->|"rendered by"| Helm
    ODHGitops -->|"composed by"| Kustomize
    ODHGitops -->|"applied via"| Kubectl
    ODHGitops -.->|"delivered by"| ArgoCD

    %% External services
    ODHGitops -->|"pulls images"| RegistryRH
    ODHGitops -->|"pulls images"| Quay
    ODHGitops -->|"cloud mgmt (xKS)"| CloudAPIs

    %% Transitive dependencies
    Kueue -.->|"requires"| CertMgr
    Kuadrant -.->|"TLS via"| CertMgr
    IstioSail -.->|"uses"| GatewayAPI

