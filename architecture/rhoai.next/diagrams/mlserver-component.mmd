graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph CoreServer["Core Server"]
            RESTServer["REST Server<br/>(FastAPI/Uvicorn)<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>(grpcio)<br/>Port 8081/TCP"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>Port 8082/TCP"]
            KafkaServer["Kafka Server<br/>(aiokafka, optional)<br/>Port 9092"]
        end

        subgraph DataLayer["Data Plane & Orchestration"]
            DataPlane["DataPlane Handler"]
            AdaptiveBatcher["Adaptive Batcher<br/>(time-window/size-limit)"]
            ResponseCache["Response Cache<br/>(local, optional)"]
            ModelRegistry["Model Registry"]
        end

        subgraph Runtimes["Runtime Plugins"]
            SKLearn["mlserver-sklearn<br/>(Scikit-learn)"]
            XGBoost["mlserver-xgboost<br/>(XGBoost)"]
            LightGBM["mlserver-lightgbm<br/>(LightGBM)"]
            ONNX["mlserver-onnx<br/>(ONNX Runtime)"]
        end

        subgraph ParallelInference["Parallel Inference"]
            Dispatcher["Dispatcher"]
            WorkerPool["Inference Pool<br/>(multiprocessing workers)"]
        end

        subgraph Security["Security Layer"]
            TrustedRuntimes["Trusted Runtimes<br/>Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
            CORSValidation["CORS Validation<br/>(production mode)"]
        end
    end

    %% External connections
    Client["Client<br/>(via KServe Ingress)"] -->|"POST /v2/models/.../infer"| RESTServer
    Client -->|"gRPC ModelInfer"| GRPCServer

    %% Internal flow
    RESTServer --> DataPlane
    GRPCServer --> DataPlane
    KafkaServer --> DataPlane

    DataPlane --> AdaptiveBatcher
    DataPlane --> ResponseCache
    DataPlane --> ModelRegistry

    ModelRegistry -->|validates| TrustedRuntimes
    ModelRegistry -->|loads| SKLearn
    ModelRegistry -->|loads| XGBoost
    ModelRegistry -->|loads| LightGBM
    ModelRegistry -->|loads| ONNX

    DataPlane -->|parallel mode| Dispatcher
    Dispatcher -->|"multiprocessing.Queue"| WorkerPool
    WorkerPool -->|"predict()"| SKLearn
    WorkerPool -->|"predict()"| XGBoost
    WorkerPool -->|"predict()"| LightGBM
    WorkerPool -->|"predict()"| ONNX

    %% External dependencies
    ModelStorage["/mnt/models<br/>(PVC/S3 Volume)"] -->|model artifacts| ModelRegistry
    KServeAgent["KServe Model Agent"] -->|"load/unload models"| RESTServer
    Prometheus["Prometheus"] -->|"scrapes /metrics"| MetricsServer
    KafkaBrokers["Kafka Brokers<br/>9092/TCP"] <-->|"consume/produce"| KafkaServer
    OTELCollector["OpenTelemetry<br/>Collector"] -.->|"OTLP traces"| RESTServer
    OTELCollector -.->|"OTLP traces"| GRPCServer

    %% Styling
    style RESTServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style KafkaServer fill:#4a90e2,stroke:#333,color:#fff
