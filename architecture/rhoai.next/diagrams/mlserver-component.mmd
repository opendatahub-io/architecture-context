graph TB
    subgraph MLServerPod["MLServer Pod (KServe InferenceService)"]
        direction TB

        subgraph Sidecar["Auth Sidecar"]
            KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS termination + AuthZ"]
        end

        subgraph MLServerCore["MLServer Core"]
            direction TB
            RESTServer["REST Server<br/>(FastAPI/Uvicorn)<br/>8080/TCP HTTP"]
            GRPCServer["gRPC Server<br/>(grpc.aio)<br/>8081/TCP gRPC"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>8082/TCP HTTP"]

            DataPlane["DataPlaneHandlers<br/>(shared business logic)"]
            ModelRegistry["MultiModelRegistry<br/>(model lifecycle)"]

            RESTServer --> DataPlane
            GRPCServer --> DataPlane
            DataPlane --> ModelRegistry
        end

        subgraph Runtimes["Pluggable Runtime Backends (RHOAI)"]
            direction LR
            SKLearn["mlserver-sklearn<br/>(scikit-learn)"]
            XGBoost["mlserver-xgboost<br/>(XGBoost)"]
            LightGBM["mlserver-lightgbm<br/>(LightGBM)"]
            ONNX["mlserver-onnx<br/>(ONNX Runtime)"]
        end

        subgraph Middleware["Cross-Cutting Concerns"]
            direction LR
            Batching["Adaptive<br/>Batching"]
            Cache["Response<br/>Cache"]
            Codecs["Codec System<br/>(numpy/pandas/string)"]
            Tracing["OpenTelemetry<br/>Tracing"]
        end

        subgraph ParallelInference["Parallel Inference (optional)"]
            Dispatcher["Dispatcher<br/>(round-robin)"]
            Worker1["Worker Process 1"]
            Worker2["Worker Process N"]
            Dispatcher --> Worker1
            Dispatcher --> Worker2
        end

        KubeRBACProxy -->|"HTTP 8080"| RESTServer
        KubeRBACProxy -->|"gRPC 8081"| GRPCServer

        ModelRegistry --> SKLearn
        ModelRegistry --> XGBoost
        ModelRegistry --> LightGBM
        ModelRegistry --> ONNX

        DataPlane --> Batching
        DataPlane --> Cache
        DataPlane --> Codecs

        ModelRegistry -.->|"multiprocessing.Queue"| Dispatcher
    end

    Client["External Client"] -->|"HTTPS 8443<br/>Bearer Token"| KubeRBACProxy

    TrustedRuntimes["/etc/mlserver/trusted-runtimes.json<br/>(Runtime Allowlist)"] -.->|"validates"| ModelRegistry
    ModelStorage["/mnt/models<br/>(PVC / Storage Initializer)"] -.->|"model artifacts"| ModelRegistry

    Prometheus["Prometheus"] -->|"HTTP 8082"| MetricsServer
    OTelCollector["OpenTelemetry Collector"] <-.->|"gRPC 4317"| Tracing

    style KubeRBACProxy fill:#e8a838,stroke:#333,stroke-width:2px
    style RESTServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style GRPCServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style MetricsServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style DataPlane fill:#5b6abf,stroke:#333,stroke-width:2px
    style ModelRegistry fill:#5b6abf,stroke:#333,stroke-width:2px
    style SKLearn fill:#7ed321,stroke:#333
    style XGBoost fill:#7ed321,stroke:#333
    style LightGBM fill:#7ed321,stroke:#333
    style ONNX fill:#7ed321,stroke:#333
    style Batching fill:#b8d4e3,stroke:#333
    style Cache fill:#b8d4e3,stroke:#333
    style Codecs fill:#b8d4e3,stroke:#333
    style Tracing fill:#b8d4e3,stroke:#333
    style Dispatcher fill:#d4a5d0,stroke:#333
    style Worker1 fill:#d4a5d0,stroke:#333
    style Worker2 fill:#d4a5d0,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style TrustedRuntimes fill:#f5a623,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
