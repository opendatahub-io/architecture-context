graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Server"]
            Server["MLServer<br/>(server.py)"]
            DataPlane["DataPlane Handler<br/>(handlers/dataplane.py)"]
            Registry["Model Registry<br/>(registry.py)"]
            Settings["Settings Manager<br/>(settings.py)<br/>Pydantic v2"]
        end

        subgraph Protocols["Protocol Servers"]
            REST["REST Server<br/>FastAPI/Uvicorn<br/>Port 8080/TCP"]
            GRPC["gRPC Server<br/>grpcio<br/>Port 8081/TCP"]
            Metrics["Metrics Server<br/>Prometheus<br/>Port 8082/TCP"]
            KafkaSrv["Kafka Server<br/>aiokafka<br/>Port 9092 (optional)"]
        end

        subgraph Runtimes["ML Runtime Plugins"]
            SKLearn["mlserver-sklearn<br/>Scikit-learn"]
            XGBoost["mlserver-xgboost<br/>XGBoost"]
            LightGBM["mlserver-lightgbm<br/>LightGBM"]
            ONNX["mlserver-onnx<br/>ONNX Runtime"]
        end

        subgraph Features["Cross-Cutting Features"]
            Batching["Adaptive Batcher<br/>(batching/adaptive.py)"]
            Cache["Response Cache<br/>(cache/local)"]
            Parallel["Parallel Workers<br/>(parallel/pool.py)<br/>multiprocessing"]
            Tracing["OpenTelemetry<br/>(tracing.py)"]
            CloudEvt["CloudEvents<br/>(cloudevents.py)"]
            TrustedRT["Trusted Runtimes<br/>Allowlist Security"]
        end
    end

    %% Internal connections
    Server --> REST
    Server --> GRPC
    Server --> Metrics
    Server --> KafkaSrv

    REST --> DataPlane
    GRPC --> DataPlane
    KafkaSrv --> DataPlane

    DataPlane --> Registry
    DataPlane --> Batching
    DataPlane --> Cache
    DataPlane --> Parallel

    Registry --> SKLearn
    Registry --> XGBoost
    Registry --> LightGBM
    Registry --> ONNX

    Settings --> TrustedRT

    %% External interactions
    Client["Client<br/>(via KServe Ingress)"] -->|"REST v2 API"| REST
    Client -->|"gRPC v2 API"| GRPC

    KServeAgent["KServe Model Agent"] -->|"Load/Unload<br/>REST 8080"| REST

    ModelStorage["/mnt/models<br/>PVC / S3 Volume"] -.->|"Model Artifacts"| Registry

    Prometheus["Prometheus"] -->|"Scrape /metrics<br/>8082/TCP"| Metrics
    OTelCollector["OpenTelemetry<br/>Collector"] -.->|"OTLP gRPC"| Tracing
    KafkaBroker["Kafka Brokers<br/>9092/TCP"] <-->|"Async Inference"| KafkaSrv

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#4a90e2,stroke:#333,color:#fff
    style Registry fill:#4a90e2,stroke:#333,color:#fff
    style Settings fill:#4a90e2,stroke:#333,color:#fff

    style REST fill:#50b5e9,stroke:#333,color:#fff
    style GRPC fill:#50b5e9,stroke:#333,color:#fff
    style Metrics fill:#50b5e9,stroke:#333,color:#fff
    style KafkaSrv fill:#50b5e9,stroke:#333,color:#fff

    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff

    style Batching fill:#f5a623,stroke:#333,color:#fff
    style Cache fill:#f5a623,stroke:#333,color:#fff
    style Parallel fill:#f5a623,stroke:#333,color:#fff
    style Tracing fill:#f5a623,stroke:#333,color:#fff
    style CloudEvt fill:#f5a623,stroke:#333,color:#fff
    style TrustedRT fill:#d0021b,stroke:#333,color:#fff

    style Client fill:#e8e8e8,stroke:#333
    style KServeAgent fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
