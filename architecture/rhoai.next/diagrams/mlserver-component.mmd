graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Servers["Protocol Adapters"]
            REST["REST Server<br/>FastAPI/Uvicorn<br/>Port 8080/TCP"]
            GRPC["gRPC Server<br/>grpc.aio<br/>Port 8081/TCP"]
            Kafka["Kafka Server<br/>aiokafka<br/>Port 9092/TCP"]
            Metrics["Metrics Server<br/>FastAPI/Uvicorn<br/>Port 8082/TCP"]
        end

        subgraph Core["Core Engine"]
            DataPlane["DataPlane Handler<br/>Unified request router"]
            Registry["MultiModelRegistry<br/>Model lifecycle manager"]
            Repo["Model Repository<br/>Filesystem scanner"]
            Cache["Response Cache<br/>OrderedDict FIFO"]
            Batcher["Adaptive Batcher<br/>Time + size batching"]
            Workers["Parallel Workers<br/>Multiprocess pool"]
            Codecs["Codec System<br/>Type converter"]
        end

        subgraph Runtimes["Runtime Plugins (MLModel)"]
            SKLearn["sklearn Runtime<br/>.joblib, .pickle, .pkl"]
            XGBoost["xgboost Runtime<br/>.bst, .json, .ubj"]
            LightGBM["lightgbm Runtime<br/>.bst"]
            ONNX["onnx Runtime<br/>.onnx via onnxruntime"]
        end

        subgraph Security["Security"]
            TrustedRT["Trusted Runtimes<br/>Allowlist at<br/>/etc/mlserver/trusted-runtimes.json"]
        end
    end

    %% Protocol adapters → DataPlane
    REST -->|"v2 inference API"| DataPlane
    GRPC -->|"v2 inference API"| DataPlane
    Kafka -->|"async inference"| DataPlane

    %% Core flow
    DataPlane -->|"route to model"| Registry
    DataPlane -->|"check cache"| Cache
    Registry -->|"discover models"| Repo
    Registry -->|"validate runtime"| TrustedRT
    DataPlane -->|"batch requests"| Batcher
    Batcher -->|"dispatch"| Workers

    %% Workers → Runtimes
    Workers -->|"predict()"| SKLearn
    Workers -->|"predict()"| XGBoost
    Workers -->|"predict()"| LightGBM
    Workers -->|"predict()"| ONNX

    %% Codecs
    Codecs -.->|"decode inputs"| DataPlane
    Codecs -.->|"encode outputs"| DataPlane

    %% External
    Client["External Client"] -->|"HTTP :8080"| REST
    Client -->|"gRPC :8081"| GRPC
    KafkaBroker["Kafka Broker"] <-->|"9092/TCP"| Kafka
    Prom["Prometheus"] -->|"scrape :8082"| Metrics
    ModelFiles["/mnt/models<br/>Model Artifacts"] -->|"file read"| Repo

    %% Platform
    KServe["KServe Controller"] -->|"manages pod lifecycle"| MLServer
    StorageInit["Storage Initializer<br/>Init Container"] -->|"populates /mnt/models"| ModelFiles
    AuthProxy["kube-rbac-proxy<br/>Sidecar"] -->|"auth → forward"| REST
    AuthProxy -->|"auth → forward"| GRPC

    %% Styling
    style REST fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style Kafka fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#2c5f8a,stroke:#333,color:#fff
    style Registry fill:#2c5f8a,stroke:#333,color:#fff
    style Repo fill:#2c5f8a,stroke:#333,color:#fff
    style Cache fill:#2c5f8a,stroke:#333,color:#fff
    style Batcher fill:#2c5f8a,stroke:#333,color:#fff
    style Workers fill:#2c5f8a,stroke:#333,color:#fff
    style Codecs fill:#2c5f8a,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff
    style TrustedRT fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#f5a623,stroke:#333
    style StorageInit fill:#f5a623,stroke:#333
    style AuthProxy fill:#f5a623,stroke:#333
