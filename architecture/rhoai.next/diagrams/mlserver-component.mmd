    style KafkaServer fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#5b9bd5,stroke:#333,color:#fff
    style RuntimeSec fill:#e74c3c,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333
    style XGBoost fill:#7ed321,stroke:#333
    style LightGBM fill:#7ed321,stroke:#333
