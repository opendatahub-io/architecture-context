graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Services"]
            RESTServer["REST Server<br/>FastAPI/Uvicorn<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>grpcio<br/>Port 8081/TCP"]
            MetricsServer["Metrics Server<br/>FastAPI/Uvicorn<br/>Port 8082/TCP"]
            KafkaServer["Kafka Server<br/>aiokafka<br/>(optional)"]
        end

        subgraph Handler["Request Processing"]
            DataPlane["DataPlane Handler"]
            Middleware["Inference Middleware<br/>(CloudEvents)"]
            Batcher["Adaptive Batcher<br/>(size/time triggers)"]
            Cache["Response Cache<br/>(in-memory FIFO)"]
            CodecSystem["Codec System<br/>(NumPy, Pandas, Base64,<br/>String, JSON, DateTime)"]
        end

        subgraph Runtimes["Pluggable Runtimes"]
            SKLearn["SKLearn Runtime"]
            XGBoost["XGBoost Runtime"]
            LightGBM["LightGBM Runtime"]
            ONNX["ONNX Runtime"]
            HuggingFace["HuggingFace Runtime"]
            MLflow["MLflow Runtime"]
            CatBoost["CatBoost Runtime"]
            AlibiDetect["Alibi Detect Runtime"]
            AlibiExplain["Alibi Explain Runtime"]
            MLlib["Spark MLlib Runtime"]
        end

        subgraph Infra["Infrastructure"]
            ModelRepo["Model Repository<br/>(filesystem-based)"]
            ParallelPool["Parallel Inference Pool<br/>(multiprocessing)"]
            RuntimeSec["Runtime Security<br/>(trusted-runtimes.json)"]
        end
    end

    Client["Client<br/>(External)"] -->|"REST HTTP<br/>8080/TCP"| RESTServer
    Client -->|"gRPC<br/>8081/TCP"| GRPCServer

    RESTServer --> DataPlane
    GRPCServer --> DataPlane
    KafkaServer --> DataPlane

    DataPlane --> Middleware
    Middleware --> Batcher
    Middleware --> Cache
    DataPlane --> CodecSystem

    Batcher --> SKLearn & XGBoost & LightGBM & ONNX
    Batcher --> HuggingFace & MLflow & CatBoost
    Batcher --> AlibiDetect & AlibiExplain & MLlib

    ModelRepo -->|"loads models"| Runtimes
    RuntimeSec -->|"validates"| Runtimes
    ParallelPool -->|"distributes"| Runtimes

    KServe["KServe<br/>(InferenceService CRD)"] -->|"deploys"| MLServer
    ModelStorage["Model Storage<br/>(PVC / S3)"] -->|"/mnt/models"| ModelRepo
    Prometheus["Prometheus"] -->|"scrapes<br/>8082/TCP"| MetricsServer

    style RESTServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
