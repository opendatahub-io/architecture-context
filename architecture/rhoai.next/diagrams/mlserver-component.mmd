graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Server"]
            RESTServer["REST Server<br/>(FastAPI/Uvicorn)<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>(grpcio)<br/>Port 8081/TCP"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>Port 8082/TCP"]
        end

        subgraph Logic["Business Logic"]
            DataPlane["DataPlane Handler<br/>(Central Orchestrator)"]
            AdaptiveBatcher["Adaptive Batcher<br/>(Time-window/Size-limit)"]
            ResponseCache["Response Cache<br/>(Local Cache)"]
            CloudEvents["CloudEvents<br/>Middleware"]
        end

        subgraph Runtimes["Runtime Plugins"]
            SKLearn["mlserver-sklearn<br/>(scikit-learn)"]
            XGBoost["mlserver-xgboost<br/>(XGBoost)"]
            LightGBM["mlserver-lightgbm<br/>(LightGBM)"]
            ONNX["mlserver-onnx<br/>(onnxruntime)"]
        end

        subgraph Parallel["Parallel Inference"]
            Dispatcher["Dispatcher"]
            WorkerPool["Worker Process Pool<br/>(multiprocessing)"]
        end

        subgraph Security["Security Layer"]
            TrustedRuntimes["Trusted Runtimes<br/>Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
        end

        RESTServer --> DataPlane
        GRPCServer --> DataPlane
        DataPlane --> AdaptiveBatcher
        DataPlane --> ResponseCache
        DataPlane --> CloudEvents
        DataPlane --> Dispatcher
        Dispatcher --> WorkerPool
        WorkerPool --> SKLearn
        WorkerPool --> XGBoost
        WorkerPool --> LightGBM
        WorkerPool --> ONNX
        DataPlane --> SKLearn
        DataPlane --> XGBoost
        DataPlane --> LightGBM
        DataPlane --> ONNX
        TrustedRuntimes -.->|validates| SKLearn
        TrustedRuntimes -.->|validates| XGBoost
        TrustedRuntimes -.->|validates| LightGBM
        TrustedRuntimes -.->|validates| ONNX
    end

    subgraph External["External Systems"]
        KafkaServer["Kafka Server<br/>(Optional Async)"]
    end

    KafkaServer --> DataPlane

    Client["Client<br/>(via KServe Ingress)"] -->|"REST V2 Protocol"| RESTServer
    Client -->|"gRPC V2 Protocol"| GRPCServer
    KafkaBroker["Kafka Brokers<br/>9092/TCP"] <-->|"Async Inference"| KafkaServer
    Prometheus["Prometheus"] -->|"Scrapes /metrics"| MetricsServer
    ModelStorage["Model Storage<br/>/mnt/models"] -.->|"Model Artifacts"| Runtimes
    OTelCollector["OpenTelemetry<br/>Collector"] <-.->|"OTLP Traces"| Core

    style RESTServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#e8744f,stroke:#333,color:#fff
    style AdaptiveBatcher fill:#e8744f,stroke:#333,color:#fff
    style ResponseCache fill:#e8744f,stroke:#333,color:#fff
    style CloudEvents fill:#e8744f,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff
    style Dispatcher fill:#9b59b6,stroke:#333,color:#fff
    style WorkerPool fill:#9b59b6,stroke:#333,color:#fff
    style TrustedRuntimes fill:#e74c3c,stroke:#333,color:#fff
    style KafkaServer fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style KafkaBroker fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
    style ModelStorage fill:#f9f9f9,stroke:#999
    style OTelCollector fill:#f9f9f9,stroke:#999
