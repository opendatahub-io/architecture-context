    style XGBoost fill:#7ed321,stroke:#333
    style LightGBM fill:#7ed321,stroke:#333
    style ONNX fill:#7ed321,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style HuggingFace fill:#7ed321,stroke:#333
    style AlibiExplain fill:#7ed321,stroke:#333
    style AlibiDetect fill:#7ed321,stroke:#333
    style CatBoost fill:#7ed321,stroke:#333
    style MLlib fill:#7ed321,stroke:#333
    style TrustedRuntimes fill:#f5a623,stroke:#333
    style CORSMiddleware fill:#f5a623,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
