graph TB
    subgraph MLServer["MLServer (V2 Dataplane API)"]
        direction TB

        subgraph Core["Core Server"]
            RESTServer["REST Server<br/>FastAPI/Uvicorn<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>grpcio<br/>Port 8081/TCP"]
            MetricsServer["Metrics Server<br/>Uvicorn/FastAPI<br/>Port 8082/TCP"]
            KafkaServer["Kafka Server<br/>aiokafka<br/>(Optional)"]
        end

        subgraph Handler["Request Processing"]
            DataPlane["DataPlane Handler"]
            Middleware["InferenceMiddleware<br/>(CloudEvents)"]
            Batcher["Adaptive Batcher<br/>(size/time limits)"]
            Cache["Response Cache<br/>(In-memory FIFO)"]
            CodecSystem["Codec System<br/>(NumPy, Pandas, Base64,<br/>String, JSON, DateTime)"]
        end

        subgraph ParallelInference["Parallel Inference"]
            Dispatcher["Dispatcher<br/>(Round-Robin)"]
            WorkerPool["Worker Process Pool<br/>(multiprocessing.Queue)"]
        end

        subgraph Runtimes["Pluggable Runtimes"]
            SKLearn["SKLearn<br/>(joblib)"]
            XGBoost["XGBoost<br/>(xgb/json/ubj)"]
            LightGBM["LightGBM<br/>(bst)"]
            ONNX["ONNX Runtime<br/>(providers)"]
            HuggingFace["HuggingFace<br/>(Transformers)"]
            MLflow["MLflow<br/>(PyFunc)"]
            CatBoost["CatBoost<br/>(cbm/bin)"]
            AlibiDetect["Alibi Detect<br/>(drift/outlier)"]
            AlibiExplain["Alibi Explain<br/>(Anchor/SHAP)"]
            MLlib["Spark MLlib"]
        end

        subgraph Security["Runtime Security"]
            TrustedRuntimes["Trusted Runtimes<br/>Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
        end

        ModelRepo["Model Repository<br/>(Filesystem-based)"]
    end

    %% Internal flows
    RESTServer -->|"V2 REST API"| DataPlane
    GRPCServer -->|"V2 gRPC API"| DataPlane
    KafkaServer -->|"Event-driven"| DataPlane
    DataPlane --> Middleware
    Middleware --> Batcher
    Middleware --> Cache
    DataPlane -->|"direct"| CodecSystem
    DataPlane -->|"parallel mode"| Dispatcher
    Dispatcher --> WorkerPool
    WorkerPool -->|"MLModel.predict()"| SKLearn
    WorkerPool -->|"MLModel.predict()"| XGBoost

    %% Security check
    TrustedRuntimes -.->|"validates"| Runtimes

    %% Model loading
    ModelRepo -->|"discovers & loads"| Runtimes

    %% External actors
    Client["Client<br/>(REST/gRPC)"] -->|"HTTP :8080"| RESTServer
    Client -->|"gRPC :8081"| GRPCServer
    Prometheus["Prometheus"] -->|"scrape :8082"| MetricsServer

    KServe["KServe<br/>InferenceService"] -->|"deploys as<br/>serving runtime"| MLServer
    ModelStorage["Model Storage<br/>(PVC/S3)"] -->|"/mnt/models"| ModelRepo

    %% Styling
    style MLServer fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style Handler fill:#fef3c7,stroke:#f59e0b,stroke-width:1px
    style Runtimes fill:#d1fae5,stroke:#10b981,stroke-width:1px
    style Security fill:#fee2e2,stroke:#ef4444,stroke-width:1px
    style ParallelInference fill:#ede9fe,stroke:#8b5cf6,stroke-width:1px
    style RESTServer fill:#4a90e2,color:#fff
    style GRPCServer fill:#4a90e2,color:#fff
    style MetricsServer fill:#4a90e2,color:#fff
    style KafkaServer fill:#4a90e2,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style KServe fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style TrustedRuntimes fill:#ef4444,color:#fff
