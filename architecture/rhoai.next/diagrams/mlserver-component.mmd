graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Server"]
            RESTServer["REST Server<br/>(FastAPI/Uvicorn)<br/>8080/TCP"]
            GRPCServer["gRPC Server<br/>(grpc.aio)<br/>8081/TCP"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>8082/TCP"]
            DataPlane["DataPlane<br/>Request Router"]
            ModelRegistry["ModelRegistry<br/>Model Lifecycle Manager"]
            BatchingAdaptive["Adaptive Batcher<br/>Request Aggregation"]
            ParallelPool["Parallel Worker Pool<br/>Multiprocessing"]
        end

        subgraph Runtimes["Pluggable ML Runtimes (MLModel base class)"]
            SKLearn["mlserver-sklearn<br/>.joblib/.pickle/.pkl"]
            XGBoost["mlserver-xgboost<br/>.bst/.json/.ubj"]
            LightGBM["mlserver-lightgbm<br/>.bst"]
            ONNX["mlserver-onnx<br/>.onnx (onnxruntime)"]
            MLflow["mlserver-mlflow<br/>MLflow artifacts"]
            HuggingFace["mlserver-huggingface<br/>Transformers"]
            AlibiExplain["mlserver-alibi-explain<br/>SHAP/ALE"]
            AlibiDetect["mlserver-alibi-detect<br/>Drift/Outlier"]
            CatBoost["mlserver-catboost<br/>.cbm/.bin"]
            MLlib["mlserver-mllib<br/>PySpark MLlib"]
        end

        subgraph Security["Security Layer"]
            TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
            CORSMiddleware["CORS Middleware<br/>Production Mode Validation"]
        end
    end

    Client["Client<br/>(KServe Router /<br/>ModelMesh / Direct)"]
    ModelStorage["Model Storage<br/>(PVC @ /mnt/models)"]

    Client -->|"REST V2 Protocol"| RESTServer
    Client -->|"gRPC V2 Protocol"| GRPCServer
    RESTServer --> DataPlane
    GRPCServer --> DataPlane
    DataPlane --> BatchingAdaptive
    BatchingAdaptive --> ModelRegistry
    ModelRegistry -->|"load/predict"| SKLearn
    ModelRegistry -->|"load/predict"| XGBoost
    ModelRegistry -->|"load/predict"| LightGBM
    ModelRegistry -->|"load/predict"| ONNX
    ModelRegistry -->|"load/predict"| MLflow
    ModelRegistry -->|"load/predict"| HuggingFace
    ModelRegistry -->|"load/predict"| AlibiExplain
    ModelRegistry -->|"load/predict"| AlibiDetect
    ModelRegistry -->|"load/predict"| CatBoost
    ModelRegistry -->|"load/predict"| MLlib
    DataPlane -.->|"parallel dispatch"| ParallelPool
    TrustedRuntimes -.->|"validates runtime<br/>import paths"| ModelRegistry
    CORSMiddleware -.->|"origin validation"| RESTServer

    SKLearn -->|"load artifacts"| ModelStorage
    XGBoost -->|"load artifacts"| ModelStorage
    LightGBM -->|"load artifacts"| ModelStorage
    ONNX -->|"load artifacts"| ModelStorage

    Prometheus["Prometheus"] -->|"scrape /metrics"| MetricsServer

    style RESTServer fill:#4a90e2,stroke:#333
    style GRPCServer fill:#4a90e2,stroke:#333
    style MetricsServer fill:#4a90e2,stroke:#333
    style DataPlane fill:#4a90e2,stroke:#333
    style ModelRegistry fill:#4a90e2,stroke:#333
    style BatchingAdaptive fill:#4a90e2,stroke:#333
    style ParallelPool fill:#4a90e2,stroke:#333
