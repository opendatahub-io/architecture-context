graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>(operator namespace)"]
        SA_Autoscaler["{cluster}-autoscaler-sa<br/>(user namespace)"]
    end

    subgraph ClusterRoleBindings["Role Bindings"]
        CRB_Operator["kuberay-operator<br/>(ClusterRoleBinding)"]
        RB_Autoscaler["{cluster}-autoscaler-rolebinding<br/>(RoleBinding, namespaced)"]
    end

    subgraph ClusterRole["ClusterRole: kuberay-operator"]
        direction TB

        subgraph RayIO["ray.io"]
            RayClusters["rayclusters<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayJobs["rayjobs<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayServices["rayservices<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph CoreAPI["core ('')"]
            Pods["pods, pods/status<br/>get,list,watch,create,update,<br/>patch,delete,deletecollection"]
            Services["services, services/status,<br/>services/proxy<br/>get,list,watch,create,<br/>update,patch,delete"]
            Endpoints["endpoints<br/>get,list,watch"]
            Events["events<br/>get,list,watch,create,<br/>update,patch,delete"]
            SAs["serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
            ConfigMaps["configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
            Secrets["secrets<br/>get,list,watch,delete"]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            Roles["roles, rolebindings<br/>get,list,watch,create,<br/>delete,update"]
            ClusterRoles["clusterroles,<br/>clusterrolebindings<br/>get,list,watch"]
        end

        subgraph BatchAPI["batch"]
            Jobs["jobs<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph NetworkingAPI["networking.k8s.io"]
            Ingresses["ingresses, ingressclasses<br/>get,list,watch,create,<br/>update,delete,patch"]
            NetworkPolicies["networkpolicies<br/>get,list,watch,create,<br/>update,delete,patch"]
        end

        subgraph AppsAPI["apps"]
            Deployments["deployments<br/>get,list,watch,<br/>update,patch"]
        end

        subgraph OpenShiftAPIs["OpenShift APIs"]
            Routes["route.openshift.io<br/>routes<br/>full CRUD"]
            Authentications["config.openshift.io<br/>authentications, oauths<br/>get,list,watch"]
            KubeAPIServers["operator.openshift.io<br/>kubeapiservers<br/>get,list,watch"]
        end

        subgraph AuthAPIs["Auth APIs"]
            TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        end

        subgraph CertManagerAPI["cert-manager.io"]
            Issuers["issuers<br/>full CRUD"]
            Certificates["certificates,<br/>certificates/status<br/>full CRUD"]
        end

        subgraph GatewayAPIs["gateway.networking.k8s.io"]
            HTTPRoutes["httproutes<br/>full CRUD"]
            Gateways["gateways<br/>get,list,watch"]
            ReferenceGrants["referencegrants<br/>full CRUD"]
        end

        subgraph CoordinationAPI["coordination.k8s.io"]
            Leases["leases<br/>get,list,create,update"]
        end
    end

    %% Bindings
    SA_Operator -->|bound via| CRB_Operator
    CRB_Operator -->|grants| ClusterRole
    SA_Autoscaler -->|bound via| RB_Autoscaler
    RB_Autoscaler -->|grants| AutoscalerRole["{cluster}-autoscaler-role<br/>(namespaced Role)"]

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Autoscaler fill:#4a90e2,color:#fff
    style CRB_Operator fill:#f5a623,color:#fff
    style RB_Autoscaler fill:#f5a623,color:#fff
    style AutoscalerRole fill:#f5a623,color:#fff

    style RayClusters fill:#7ed321
    style RayJobs fill:#7ed321
    style RayServices fill:#7ed321
    style Pods fill:#7ed321
    style Services fill:#7ed321
    style Endpoints fill:#7ed321
    style Events fill:#7ed321
    style SAs fill:#7ed321
    style ConfigMaps fill:#7ed321
    style Secrets fill:#7ed321
    style Roles fill:#7ed321
    style ClusterRoles fill:#7ed321
    style Jobs fill:#7ed321
    style Ingresses fill:#7ed321
    style NetworkPolicies fill:#7ed321
    style Deployments fill:#7ed321
    style Routes fill:#7ed321
    style Authentications fill:#7ed321
    style KubeAPIServers fill:#7ed321
    style TokenReviews fill:#e74c3c,color:#fff
    style SAR fill:#e74c3c,color:#fff
    style Issuers fill:#7ed321
    style Certificates fill:#7ed321
    style HTTPRoutes fill:#7ed321
    style Gateways fill:#7ed321
    style ReferenceGrants fill:#7ed321
    style Leases fill:#7ed321
