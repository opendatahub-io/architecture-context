graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>(operator namespace)"]
        ClusterSA["{cluster} SA<br/>(per RayCluster, user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB1["kuberay-operator"]
        CRB2["kuberay-operator-gateway-api"]
        CRB3["kuberay-operator-configmap"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB1["kuberay-operator-leader-election<br/>(operator namespace)"]
        RB2["{cluster} autoscaler<br/>(cluster namespace)"]
    end

    %% ClusterRoles
    subgraph CR_Main["ClusterRole: kuberay-operator"]
        direction LR
        subgraph CoreAPI["Core API ('')"]
            Pods["pods<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
            Services["services<br/>get,list,watch,create,<br/>update,patch,delete"]
            Secrets["secrets<br/>get,list,watch,delete"]
            ConfigMaps["configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
            SvcAccts["serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
            Events["events<br/>get,list,watch,create,<br/>update,patch,delete"]
            Endpoints["endpoints<br/>get,list,watch"]
            PodsProxy["pods/proxy<br/>get,patch,update"]
            SvcProxy["services/proxy<br/>get,create,patch,update"]
        end

        subgraph RayAPI["ray.io API"]
            RayClusters["rayclusters<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayJobs["rayjobs<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayServices["rayservices<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayStatuses["*/status<br/>get,patch,update"]
            RayFinalizers["*/finalizers<br/>update"]
        end

        subgraph OtherAPI["Other APIs"]
            Deployments["apps/deployments<br/>get,list,watch,<br/>patch,update"]
            Jobs["batch/jobs<br/>get,list,watch,create,<br/>update,patch,delete"]
            Ingresses["networking/ingresses<br/>networking/networkpolicies<br/>get,list,watch,create,<br/>update,patch,delete"]
            Routes["route.openshift.io/routes<br/>get,list,watch,create,<br/>update,patch,delete"]
            CertMgr["cert-manager.io/<br/>certificates,issuers<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph AuthAPI["Auth & OpenShift APIs"]
            TokenReview["authentication.k8s.io/<br/>tokenreviews<br/>create"]
            SAR["authorization.k8s.io/<br/>subjectaccessreviews<br/>create"]
            OSAuth["config.openshift.io/<br/>authentications,oauths<br/>get,list,watch"]
            OSKubeAPI["operator.openshift.io/<br/>kubeapiservers<br/>get,list,watch"]
            RBAC["rbac.authorization.k8s.io/<br/>roles: get,list,watch,<br/>create,delete,update<br/>rolebindings: get,list,<br/>watch,create,delete"]
            Leases["coordination.k8s.io/<br/>leases<br/>get,list,create,update"]
        end
    end

    subgraph CR_Gateway["ClusterRole: kuberay-operator-gateway-api"]
        Gateways["gateway.networking.k8s.io/<br/>gateways<br/>get,list,watch"]
        HTTPRoutes["gateway.networking.k8s.io/<br/>httproutes<br/>get,list,watch,create,<br/>update,patch,delete"]
        RefGrants["gateway.networking.k8s.io/<br/>referencegrants<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph CR_ConfigMap["ClusterRole: kuberay-operator-configmap"]
        CMPerms["configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1

    CRB1 -->|grants| CR_Main
    CRB2 -->|grants| CR_Gateway
    CRB3 -->|grants| CR_ConfigMap

    ClusterSA -->|bound via| RB2
    RB2 -->|grants autoscaler perms| RayClusters

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style ClusterSA fill:#4a90e2,color:#fff
    style CRB1 fill:#ff9800,color:#fff
    style CRB2 fill:#ff9800,color:#fff
    style CRB3 fill:#ff9800,color:#fff
    style RB1 fill:#ff9800,color:#fff
    style RB2 fill:#ff9800,color:#fff
    style CR_Main fill:#fff3e0,stroke:#e65100
    style CR_Gateway fill:#e8f5e9,stroke:#2e7d32
    style CR_ConfigMap fill:#e3f2fd,stroke:#1565c0
    style RayClusters fill:#7ed321
    style RayJobs fill:#7ed321
    style RayServices fill:#7ed321
    style Pods fill:#ef9a9a
    style Secrets fill:#ef9a9a
    style TokenReview fill:#ce93d8
    style SAR fill:#ce93d8
