    CR_Main -->|"create"| TokenReviews
    CR_Main -->|"create"| SAR
    CR_Main -->|"full CRUD"| Routes
    CR_Main -->|"read-only"| AuthConfig
    CR_Main -->|"read-only"| KubeAPIServer
    CR_Main -->|"read + update"| Deployments
    CR_Main -->|"full CRUD"| BatchJobs
    CR_Main -->|"create, get,<br/>list, update"| Leases

    %% Gateway ClusterRole → Resources
    CR_Gateway -->|"read-only"| Gateways
    CR_Gateway -->|"full CRUD"| HTTPRoutes
    CR_Gateway -->|"full CRUD"| RefGrants

    %% ConfigMap ClusterRole → Resources
    CR_ConfigMap -->|"full CRUD"| ConfigMaps

    %% Leader Election Role → Resources
    R_Leader -->|"create, get,<br/>list, update"| Leases

    %% Autoscaler Role → Resources
    R_Autoscaler -->|"get, list, watch"| Pods
    R_Autoscaler -->|"get, patch"| RayClusters

