graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>(operator namespace)"]
        SA_Autoscaler["{cluster}-autoscaler-sa<br/>(per-cluster, user namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB1["kuberay-operator"]
        CRB2["kuberay-operator-gateway-api"]
        CRB3["kuberay-operator-configmap"]
    end

    subgraph RoleBindings["Role Bindings (namespaced)"]
        RB1["kuberay-operator-leader-election<br/>(operator namespace)"]
        RB2["{cluster}-autoscaler<br/>(cluster namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["kuberay-operator"]
        CR_Gateway["kuberay-operator-gateway-api"]
        CR_ConfigMap["kuberay-operator-configmap"]
    end

    subgraph Roles["Roles (namespaced)"]
        R_Leader["kuberay-operator-leader-election"]
        R_Autoscaler["{cluster}<br/>(autoscaler role)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core: pods<br/>create,delete,deletecollection,<br/>get,list,patch,update,watch"]
        Services["core: services<br/>create,delete,get,list,<br/>patch,update,watch"]
        ConfigMaps["core: configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Secrets["core: secrets<br/>delete,get,list,watch"]
        Events["core: events<br/>create,delete,get,list,<br/>patch,update,watch"]
        SA["core: serviceaccounts<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["core: endpoints<br/>get,list,watch"]
    end

    subgraph RayResources["Ray API Resources (ray.io)"]
        RayClusters["ray.io: rayclusters<br/>+ finalizers + status<br/>full CRUD + watch"]
        RayJobs["ray.io: rayjobs<br/>+ finalizers + status<br/>full CRUD + watch"]
        RayServices["ray.io: rayservices<br/>+ finalizers + status<br/>full CRUD + watch"]
    end

    subgraph NetworkResources["Network Resources"]
        Ingresses["networking.k8s.io: ingresses<br/>full CRUD + watch"]
        NetworkPolicies["networking.k8s.io: networkpolicies<br/>full CRUD + watch"]
        Routes["route.openshift.io: routes<br/>full CRUD + watch"]
    end

    subgraph GatewayResources["Gateway API Resources"]
        Gateways["gateway.networking.k8s.io: gateways<br/>get,list,watch"]
        HTTPRoutes["gateway.networking.k8s.io: httproutes<br/>full CRUD + watch"]
        RefGrants["gateway.networking.k8s.io: referencegrants<br/>full CRUD + watch"]
    end

    subgraph SecurityResources["Security & Auth Resources"]
        CertManagerCerts["cert-manager.io: certificates<br/>+ status<br/>full CRUD + watch"]
        CertManagerIssuers["cert-manager.io: issuers<br/>full CRUD + watch"]
        RBACRoles["rbac: roles<br/>create,delete,get,list,update,watch"]
        RBACBindings["rbac: rolebindings<br/>create,delete,get,list,watch"]
        TokenReviews["authentication.k8s.io: tokenreviews<br/>create"]
        SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        OAuthConfig["config.openshift.io:<br/>authentications, oauths<br/>get,list,watch"]
        KubeAPIServer["operator.openshift.io:<br/>kubeapiservers<br/>get,list,watch"]
    end

    subgraph AutoscalerResources["Autoscaler Resources (per-cluster)"]
        AutoPods["core: pods<br/>get,list,watch"]
        AutoRC["ray.io: rayclusters<br/>get,patch"]
    end

    %% SA → CRB → CR chains
    SA_Operator -->|bound via| CRB1
    SA_Operator -->|bound via| CRB2
    SA_Operator -->|bound via| CRB3
    SA_Operator -->|bound via| RB1

    CRB1 -->|grants| CR_Main
    CRB2 -->|grants| CR_Gateway
    CRB3 -->|grants| CR_ConfigMap

    RB1 -->|grants| R_Leader

    %% Autoscaler chain
    SA_Autoscaler -->|bound via| RB2
    RB2 -->|grants| R_Autoscaler

    %% CR → Resources
    CR_Main --> CoreResources
    CR_Main --> RayResources
    CR_Main --> NetworkResources
    CR_Main --> SecurityResources
    CR_Main --> OpenShiftResources

    CR_Gateway --> GatewayResources
    CR_ConfigMap --> ConfigMaps

    R_Autoscaler --> AutoscalerResources

