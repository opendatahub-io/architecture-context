    %% SA → CRB → CR
    SA_Operator -->|bound via| CRB_Main
    SA_Operator -->|bound via| CRB_Gateway
    SA_Operator -->|bound via| CRB_ConfigMap
    SA_Operator -->|bound via| RB_Leader

    CRB_Main -->|grants| CR_Main
    CRB_Gateway -->|grants| CR_Gateway
    CRB_ConfigMap -->|grants| CR_ConfigMap
    RB_Leader -->|grants| R_Leader

    %% Autoscaler SA
    SA_Autoscaler -->|bound via| RB_Autoscaler
    RB_Autoscaler -->|grants| R_Autoscaler

    %% CR → Resources
    CR_Main -->|manages| CoreResources
    CR_Main -->|manages| RayResources
    CR_Main -->|manages| NetworkResources
    CR_Main -->|manages| CertResources
    CR_Main -->|manages| OpenShiftResources
    CR_Main -->|manages| AuthzResources
    CR_Main -->|manages| RBACResources

    CR_Gateway -->|manages| Gateways
    CR_Gateway -->|manages| HTTPRoutes
    CR_Gateway -->|manages| RefGrants

    CR_ConfigMap -->|manages| ConfigMaps

    R_Autoscaler -->|read-only| AutoscalerResources

