graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>(operator namespace)"]
        SA_Autoscaler["{cluster}-autoscaler-sa<br/>(user namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Operator["kuberay-operator<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Autoscaler["{cluster}-autoscaler-rolebinding<br/>(RayCluster namespace)"]
    end

    subgraph ClusterRole["ClusterRole: kuberay-operator"]
        direction TB

        subgraph RayIO["ray.io"]
            RayClusters["rayclusters<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayJobs["rayjobs<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
            RayServices["rayservices<br/>+ status + finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph CoreAPI["Core API ('')"]
            Pods["pods, pods/status<br/>get,list,watch,create,update,<br/>patch,delete,deletecollection"]
            Services["services, services/status,<br/>services/proxy<br/>get,list,watch,create,<br/>update,patch,delete"]
            Secrets["secrets<br/>get,list,watch,delete"]
            Events["events<br/>get,list,watch,create,<br/>update,patch,delete"]
            SvcAccounts["serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
            ConfigMaps["configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
            Endpoints["endpoints<br/>get,list,watch"]
        end

        subgraph NetworkAPI["networking.k8s.io"]
            Ingresses["ingresses, ingressclasses<br/>get,list,watch,create,<br/>update,delete,patch"]
            NetworkPolicies["networkpolicies<br/>get,list,watch,create,<br/>update,delete,patch"]
        end

        subgraph GatewayAPIGrp["gateway.networking.k8s.io"]
            HTTPRoutes["httproutes<br/>get,list,watch,create,<br/>update,patch,delete"]
            Gateways["gateways<br/>get,list,watch"]
            RefGrants["referencegrants<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph CertMgrAPI["cert-manager.io"]
            Issuers["issuers<br/>get,list,watch,create,<br/>update,patch,delete"]
            Certificates["certificates,<br/>certificates/status<br/>get,list,watch,create,<br/>update,patch,delete"]
        end

        subgraph AuthAPI["Auth APIs"]
            TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            Roles["roles, rolebindings<br/>get,list,watch,create,<br/>delete,update"]
            ClusterRoles["clusterroles,<br/>clusterrolebindings<br/>get,list,watch"]
        end

        subgraph OtherAPI["Other APIs"]
            BatchJobs["batch: jobs<br/>get,list,watch,create,<br/>update,patch,delete"]
            Deployments["apps: deployments<br/>get,list,watch,<br/>update,patch"]
            Routes["route.openshift.io: routes<br/>get,list,watch,create,<br/>update,patch,delete"]
            Leases["coordination.k8s.io: leases<br/>get,list,create,update"]
            OCPAuth["config.openshift.io:<br/>authentications, oauths<br/>get,list,watch"]
            KAS["operator.openshift.io:<br/>kubeapiservers<br/>get,list,watch"]
        end
    end

    subgraph AutoscalerRole["Role: {cluster}-autoscaler-role"]
        AutoscalerPerms["ray.io: rayclusters<br/>get,update,patch"]
    end

    %% Bindings
    SA_Operator -->|"bound via"| CRB_Operator
    CRB_Operator -->|"grants"| ClusterRole

    SA_Autoscaler -->|"bound via"| RB_Autoscaler
    RB_Autoscaler -->|"grants"| AutoscalerRole

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Autoscaler fill:#4a90e2,color:#fff
    style CRB_Operator fill:#9b59b6,color:#fff
    style RB_Autoscaler fill:#9b59b6,color:#fff
    style RayClusters fill:#7ed321,color:#fff
    style RayJobs fill:#7ed321,color:#fff
    style RayServices fill:#7ed321,color:#fff
    style Secrets fill:#e74c3c,color:#fff
    style TokenReviews fill:#e74c3c,color:#fff
    style SAR fill:#e74c3c,color:#fff
