graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB1["kuberay-operator<br/>(ClusterRoleBinding)"]
        CRB2["kuberay-operator-configmap<br/>(ClusterRoleBinding)"]
        CRB3["kuberay-operator-gateway-api<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB1["kuberay-operator-leader-election<br/>(RoleBinding, operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR1["kuberay-operator"]
        CR2["kuberay-operator-configmap"]
        CR3["kuberay-operator-gateway-api"]
        CR4["kuberay-edit-role<br/>(aggregate)"]
        CR5["kuberay-view-role<br/>(aggregate)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R1["kuberay-operator-leader-election"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/status"]
        Services["core<br/>services, services/proxy"]
        SvcAccounts["core<br/>serviceaccounts"]
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        Events["core<br/>events"]
        Endpoints["core<br/>endpoints"]
    end

    subgraph RayResources["Ray API Resources (ray.io)"]
        RayClusters["ray.io<br/>rayclusters<br/>+ status, finalizers"]
        RayJobs["ray.io<br/>rayjobs<br/>+ status, finalizers"]
        RayServices["ray.io<br/>rayservices<br/>+ status, finalizers"]
    end

    subgraph NetworkResources["Network API Resources"]
        Ingresses["networking.k8s.io<br/>ingresses, ingressclasses"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
        Routes["route.openshift.io<br/>routes"]
        Gateways["gateway.networking.k8s.io<br/>gateways"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes, referencegrants"]
    end

    subgraph SecurityResources["Security API Resources"]
        CertIssuer["cert-manager.io<br/>issuers, certificates<br/>+ certificates/status"]
        RBACRoles["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        RBACCluster["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings"]
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph OpenShiftResources["OpenShift API Resources"]
        OCPAuth["config.openshift.io<br/>authentications, oauths<br/>+ status"]
        KubeAPIServer["operator.openshift.io<br/>kubeapiservers + status"]
    end

    subgraph OtherResources["Other Resources"]
        Deployments["apps<br/>deployments"]
        Jobs["batch<br/>jobs"]
        Leases["coordination.k8s.io<br/>leases"]
    end

    %% SA to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    RB1 -->|grants| R1

    %% Main ClusterRole permissions
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"| Pods
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| Services
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| SvcAccounts
    CR1 -->|"get,list,watch,<br/>delete"| Secrets
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| RayClusters
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| RayJobs
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| RayServices
    CR1 -->|"get,list,watch,create,<br/>update,delete,patch"| Ingresses
    CR1 -->|"get,list,watch,create,<br/>update,delete,patch"| NetworkPolicies
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| Routes
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| CertIssuer
    CR1 -->|"get,list,watch,create,<br/>delete,update,patch"| RBACRoles
    CR1 -->|"create"| TokenReview
    CR1 -->|"create"| SAR
    CR1 -->|"get,list,watch"| OCPAuth
    CR1 -->|"get,list,watch"| KubeAPIServer
    CR1 -->|"get,list,watch,<br/>patch,update"| Deployments
    CR1 -->|"get,list,watch,create,<br/>update,patch,delete"| Jobs

    %% Supplementary roles
    CR2 -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    CR3 -->|"get,list,watch"| Gateways
    CR3 -->|"get,list,watch,create,<br/>update,patch,delete"| HTTPRoutes

    %% Leader election
    R1 -->|"get,list,watch,create,<br/>update,patch,delete"| Events
    R1 -->|"get,list,create,update"| Leases

    %% Aggregate roles
    CR4 -->|"create,delete,get,list,<br/>patch,update,watch"| RayClusters
    CR5 -->|"get,list,watch"| RayClusters

