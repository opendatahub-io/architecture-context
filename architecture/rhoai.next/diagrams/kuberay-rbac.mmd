graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>(operator namespace)"]
        SA_Autoscaler["{cluster-name}<br/>(per-cluster, user namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Main["kuberay-operator"]
        CRB_Gateway["kuberay-operator-gateway-api"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["kuberay-operator-leader-election<br/>(operator namespace)"]
        RB_Autoscaler["{cluster-name}<br/>(user namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["kuberay-operator"]
        CR_Gateway["kuberay-operator-gateway-api"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["kuberay-operator-leader-election"]
        R_Autoscaler["{cluster-name}<br/>(autoscaler role)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods<br/>create,delete,deletecollection,<br/>get,list,patch,update,watch"]
        Services["core<br/>services<br/>create,delete,get,list,<br/>patch,update,watch"]
        Secrets["core<br/>secrets<br/>delete,get,list,watch"]
        ConfigMaps["core<br/>configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Events["core<br/>events<br/>create,delete,get,list,<br/>patch,update,watch"]
        SvcAccounts["core<br/>serviceaccounts<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["core<br/>endpoints<br/>get,list,watch"]
        PodsProxy["core<br/>pods/proxy, services/proxy<br/>create,get,patch,update"]
    end

    subgraph RayResources["Ray API Resources"]
        RayClusters["ray.io<br/>rayclusters<br/>create,delete,get,list,<br/>patch,update,watch"]
        RayJobs["ray.io<br/>rayjobs<br/>create,delete,get,list,<br/>patch,update,watch"]
        RayServices["ray.io<br/>rayservices<br/>create,delete,get,list,<br/>patch,update,watch"]
        RayFinalizers["ray.io<br/>*/finalizers<br/>update"]
        RayStatus["ray.io<br/>*/status<br/>get,patch,update"]
    end

    subgraph NetworkResources["Network API Resources"]
        Ingresses["networking.k8s.io / extensions<br/>ingresses<br/>create,delete,get,list,<br/>patch,update,watch"]
        IngressClasses["networking.k8s.io<br/>ingressclasses<br/>get,list,watch"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph GatewayResources["Gateway API Resources"]
        Gateways["gateway.networking.k8s.io<br/>gateways<br/>get,list,watch"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>create,delete,get,list,<br/>patch,update,watch"]
        RefGrants["gateway.networking.k8s.io<br/>referencegrants<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph CertResources["cert-manager Resources"]
        Certificates["cert-manager.io<br/>certificates<br/>create,delete,get,list,<br/>patch,update,watch"]
        Issuers["cert-manager.io<br/>issuers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        Routes["route.openshift.io<br/>routes<br/>create,delete,get,list,<br/>patch,update,watch"]
        AuthConfig["config.openshift.io<br/>authentications, oauths<br/>get,list,watch"]
        KubeAPIServers["operator.openshift.io<br/>kubeapiservers<br/>get,list,watch"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph RBACResources["RBAC Resources"]
        CRoles["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>get,list,watch"]
        RolesRes["rbac.authorization.k8s.io<br/>roles<br/>create,delete,get,list,update,watch"]
        RoleBindingsRes["rbac.authorization.k8s.io<br/>rolebindings<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        LEConfigMaps["core<br/>configmaps, events<br/>get,list,watch,create,<br/>update,patch,delete"]
        LELeases["coordination.k8s.io<br/>leases<br/>create,get,list,update"]
    end

    subgraph AutoscalerResources["Autoscaler Resources"]
        ASPods["core<br/>pods<br/>get,list,watch"]
        ASRayClusters["ray.io<br/>rayclusters<br/>get,patch"]
    end

    %% Operator SA bindings
    SA_Operator -->|bound via| CRB_Main
    SA_Operator -->|bound via| CRB_Gateway
    SA_Operator -->|bound via| RB_Leader

    CRB_Main -->|grants| CR_Main
    CRB_Gateway -->|grants| CR_Gateway
    RB_Leader -->|grants| R_Leader

    %% Autoscaler SA bindings
    SA_Autoscaler -->|bound via| RB_Autoscaler
    RB_Autoscaler -->|grants| R_Autoscaler

    %% Main ClusterRole permissions
    CR_Main -->|access| Pods
    CR_Main -->|access| Services
    CR_Main -->|access| Secrets
    CR_Main -->|access| ConfigMaps
    CR_Main -->|access| Events
    CR_Main -->|access| SvcAccounts
    CR_Main -->|access| Endpoints
    CR_Main -->|access| PodsProxy
    CR_Main -->|access| RayClusters
    CR_Main -->|access| RayJobs
    CR_Main -->|access| RayServices
    CR_Main -->|access| RayFinalizers
    CR_Main -->|access| RayStatus
    CR_Main -->|access| Ingresses
    CR_Main -->|access| IngressClasses
    CR_Main -->|access| NetworkPolicies
    CR_Main -->|access| Certificates
    CR_Main -->|access| Issuers
    CR_Main -->|access| Routes
    CR_Main -->|access| AuthConfig
    CR_Main -->|access| KubeAPIServers
    CR_Main -->|access| TokenReviews
    CR_Main -->|access| SAR
    CR_Main -->|access| CRoles
    CR_Main -->|access| RolesRes
    CR_Main -->|access| RoleBindingsRes

    %% Gateway API ClusterRole permissions
    CR_Gateway -->|access| Gateways
    CR_Gateway -->|access| HTTPRoutes
    CR_Gateway -->|access| RefGrants

    %% Leader election permissions
    R_Leader -->|access| LEConfigMaps
    R_Leader -->|access| LELeases

    %% Autoscaler permissions
    R_Autoscaler -->|access| ASPods
    R_Autoscaler -->|access| ASRayClusters

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Autoscaler fill:#4a90e2,color:#fff
    style CR_Main fill:#f5a623,color:#fff
    style CR_Gateway fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style R_Autoscaler fill:#f5a623,color:#fff
    style CRB_Main fill:#e8e8e8
    style CRB_Gateway fill:#e8e8e8
    style RB_Leader fill:#e8e8e8
    style RB_Autoscaler fill:#e8e8e8
    style RayClusters fill:#7ed321,color:#fff
    style RayJobs fill:#7ed321,color:#fff
    style RayServices fill:#7ed321,color:#fff
    style RayFinalizers fill:#7ed321,color:#fff
    style RayStatus fill:#7ed321,color:#fff
