graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["kuberay-operator<br/>(operator namespace)"]
        SA_Autoscaler["{cluster}-autoscaler-sa<br/>(per-cluster namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Main["kuberay-operator<br/>(cluster-scoped)"]
        CRB_Gateway["kuberay-operator-gateway-api<br/>(cluster-scoped)"]
        CRB_ConfigMap["kuberay-operator-configmap<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["kuberay-operator-leader-election<br/>(operator namespace)"]
        RB_Autoscaler["{cluster}-autoscaler<br/>(cluster namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["kuberay-operator"]
        CR_Gateway["kuberay-operator-gateway-api"]
        CR_ConfigMap["kuberay-operator-configmap"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["kuberay-operator-leader-election"]
        R_Autoscaler["{cluster}<br/>(per-cluster)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/status, pods/proxy"]
        Services["core<br/>services, services/status, services/proxy"]
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        Events["core<br/>events"]
        Endpoints["core<br/>endpoints"]
        ServiceAccts["core<br/>serviceaccounts"]
    end

    subgraph RayResources["ray.io Resources"]
        RayClusters["ray.io<br/>rayclusters, /status, /finalizers"]
        RayJobs["ray.io<br/>rayjobs, /status, /finalizers"]
        RayServices["ray.io<br/>rayservices, /status, /finalizers"]
    end

    subgraph NetworkResources["Networking Resources"]
        Ingresses["networking.k8s.io<br/>ingresses"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
        Gateways["gateway.networking.k8s.io<br/>gateways (read-only)"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        RefGrants["gateway.networking.k8s.io<br/>referencegrants"]
    end

    subgraph SecurityResources["Security &amp; Auth Resources"]
        RBACRoles["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        ClusterRBACRead["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings (read)"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews (create)"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews (create)"]
    end

    subgraph CertManagerResources["cert-manager Resources"]
        Certificates["cert-manager.io<br/>certificates, /status"]
        Issuers["cert-manager.io<br/>issuers"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        Routes["route.openshift.io<br/>routes"]
        AuthConfig["config.openshift.io<br/>authentications, oauths (read)"]
        KubeAPIServer["operator.openshift.io<br/>kubeapiservers (read)"]
    end

    subgraph OtherResources["Other Resources"]
        Deployments["apps<br/>deployments"]
        BatchJobs["batch<br/>jobs"]
        Leases["coordination.k8s.io<br/>leases"]
    end

    %% SA → Bindings
    SA_Operator -->|"bound via"| CRB_Main
    SA_Operator -->|"bound via"| CRB_Gateway
    SA_Operator -->|"bound via"| CRB_ConfigMap
    SA_Operator -->|"bound via"| RB_Leader
    SA_Autoscaler -->|"bound via"| RB_Autoscaler

    %% Bindings → Roles
    CRB_Main -->|"grants"| CR_Main
    CRB_Gateway -->|"grants"| CR_Gateway
    CRB_ConfigMap -->|"grants"| CR_ConfigMap
    RB_Leader -->|"grants"| R_Leader
    RB_Autoscaler -->|"grants"| R_Autoscaler

    %% Main ClusterRole → Resources
    CR_Main -->|"full CRUD +<br/>deletecollection"| Pods
    CR_Main -->|"full CRUD"| Services
    CR_Main -->|"read + delete"| Secrets
    CR_Main -->|"full CRUD"| Events
    CR_Main -->|"read-only"| Endpoints
    CR_Main -->|"full CRUD"| ServiceAccts
    CR_Main -->|"full CRUD"| RayClusters
    CR_Main -->|"full CRUD"| RayJobs
