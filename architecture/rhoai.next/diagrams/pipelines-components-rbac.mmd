graph TD
    subgraph "Pipeline Task Pods"
        InitPod["Init Container<br/>(pipelines-components)"]
        AutoMLPod["AutoML Task Pods<br/>(odh-automl)"]
        AutoRAGPod["AutoRAG Task Pods<br/>(odh-autorag)"]
        FTPod["Fine-Tuning Task Pods"]
    end

    subgraph "Service Account (Inherited from DSPA)"
        SA["DSPA Pipeline Runner SA<br/>(configured by DSPA operator)"]
    end

    subgraph "Inherited Permissions (via DSPA)"
        SecretRead["core / Secrets<br/>get, list"]
        PVCManage["core / PersistentVolumeClaims<br/>get, list, create, delete"]
        PodManage["core / Pods<br/>get, list, watch"]
        KFPAccess["KFP API Access<br/>pipeline execution, artifact storage"]
    end

    subgraph "Secrets Accessed at Runtime"
        S3Secret["s3-secret<br/>train_data_secret<br/>input_data_secret<br/>(Opaque)<br/>AWS S3 credentials"]
        HFToken["hf-token<br/>(Opaque)<br/>HF API token"]
        LLMCreds["llm-credentials<br/>llama_stack_secret<br/>(Opaque)<br/>API key + endpoint"]
        K8sCreds["kubernetes-credentials<br/>(Opaque)<br/>K8s API URL + token"]
        OCIPull["oci-pull-secret-model-download<br/>(Opaque)<br/>OCI registry credentials"]
        S3Conn["s3-connection<br/>(Opaque)<br/>DSPA S3 connection"]
    end

    subgraph "External Service Authentication"
        S3Auth["S3 Storage<br/>Auth: AWS IAM<br/>(AccessKeyId/SecretAccessKey)"]
        HFAuth["Hugging Face Hub<br/>Auth: Bearer Token<br/>(HF_TOKEN)"]
        LlamaAuth["Llama Stack API<br/>Auth: API Key"]
        RegAuth["Model Registry<br/>Auth: Bearer Token<br/>(K8s SA Token)"]
        OCIAuth["OCI Registry<br/>Auth: Registry Credentials"]
    end

    %% All pods use inherited SA
    InitPod -->|"uses"| SA
    AutoMLPod -->|"uses"| SA
    AutoRAGPod -->|"uses"| SA
    FTPod -->|"uses"| SA

    %% SA grants inherited permissions
    SA -->|"inherits from DSPA"| SecretRead
    SA -->|"inherits from DSPA"| PVCManage
    SA -->|"inherits from DSPA"| PodManage
    SA -->|"inherits from DSPA"| KFPAccess

    %% Secrets accessed by pods
    SecretRead -->|"reads"| S3Secret
    SecretRead -->|"reads"| HFToken
    SecretRead -->|"reads"| LLMCreds
    SecretRead -->|"reads"| K8sCreds
    SecretRead -->|"reads"| OCIPull
    SecretRead -->|"reads"| S3Conn

    %% Secrets used for auth
    S3Secret -->|"provides creds for"| S3Auth
    HFToken -->|"provides token for"| HFAuth
    LLMCreds -->|"provides key for"| LlamaAuth
    K8sCreds -->|"provides token for"| RegAuth
    OCIPull -->|"provides creds for"| OCIAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style InitPod fill:#6baed6,stroke:#333
    style AutoMLPod fill:#6baed6,stroke:#333
    style AutoRAGPod fill:#6baed6,stroke:#333
    style FTPod fill:#6baed6,stroke:#333

    style SecretRead fill:#f5a623,stroke:#333
    style PVCManage fill:#f5a623,stroke:#333
    style PodManage fill:#f5a623,stroke:#333
    style KFPAccess fill:#f5a623,stroke:#333

    style S3Secret fill:#e8e8e8,stroke:#333
    style HFToken fill:#e8e8e8,stroke:#333
    style LLMCreds fill:#e8e8e8,stroke:#333
    style K8sCreds fill:#e8e8e8,stroke:#333
    style OCIPull fill:#e8e8e8,stroke:#333
    style S3Conn fill:#e8e8e8,stroke:#333

    style S3Auth fill:#7ed321,stroke:#333
    style HFAuth fill:#7ed321,stroke:#333
    style LlamaAuth fill:#7ed321,stroke:#333
    style RegAuth fill:#7ed321,stroke:#333
    style OCIAuth fill:#7ed321,stroke:#333
