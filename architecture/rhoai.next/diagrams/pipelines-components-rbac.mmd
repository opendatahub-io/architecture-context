graph TD
    subgraph "Service Accounts"
        PipelineRunner["pipeline-runner<br/>(KFP-managed SA)<br/>Namespace: {user-namespace}"]
        KFPServerSA["KFP API Server SA<br/>(hosts init container)"]
    end

    subgraph "RBAC Configuration"
        direction TB
        Note1["No ClusterRoles/Roles defined<br/>directly by pipelines-components"]
        Note2["RBAC inherited from<br/>platform operator (rhods-operator)"]
    end

    subgraph "Pipeline Runner Permissions (Pre-configured)"
        PipelinePerm["Pipeline Execution<br/>create/get/list/watch pods<br/>create/get workflows"]
    end

    subgraph "Required Permissions for Fine-Tuning"
        TrainerPerm["TrainingJob Management<br/>create/watch/get/list TrainingJobs<br/>(kubeflow.org API group)"]
        PodPerm["Pod Log Streaming<br/>get/list pods, get pods/log<br/>(core API group)"]
        NSPerm["Namespace Resolution<br/>get namespaces<br/>(core API group)"]
    end

    subgraph "Secrets Access (User-Provisioned)"
        S3Secret["S3 Credentials<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_DEFAULT_REGION"]
        LlamaSecret["Llama Stack Credentials<br/>LLAMA_STACK_CLIENT_BASE_URL<br/>LLAMA_STACK_CLIENT_API_KEY"]
        HFSecret["HuggingFace Token<br/>HF_TOKEN"]
        K8sSecret["Kubernetes Credentials<br/>KUBERNETES_SERVER_URL<br/>KUBERNETES_AUTH_TOKEN"]
        OCISecret["OCI Pull Secret<br/>Container registry credentials"]
        LLMSecret["LLM Credentials<br/>LLM_API_KEY"]
    end

    subgraph "ConfigMaps"
        SDGFlow["sdg-llm-test-flow<br/>SDG flow YAML<br/>Mount: /etc/sdg"]
        SDGPrompt["sdg-llm-test-prompt<br/>SDG prompt templates<br/>Mount: /etc/sdg/prompts"]
    end

    %% Relationships
    PipelineRunner -->|"runs as"| PipelinePerm
    PipelineRunner -->|"requires for fine-tuning"| TrainerPerm
    PipelineRunner -->|"requires for fine-tuning"| PodPerm
    PipelineRunner -->|"requires for fine-tuning"| NSPerm

    KFPServerSA -->|"init container runs under"| KFPServerSA

    PipelineRunner -->|"env injection via<br/>RHOAI Connections"| S3Secret
    PipelineRunner -->|"env injection"| LlamaSecret
    PipelineRunner -->|"env injection"| HFSecret
    PipelineRunner -->|"env injection"| K8sSecret
    PipelineRunner -->|"env injection"| OCISecret
    PipelineRunner -->|"env injection"| LLMSecret
    PipelineRunner -->|"volume mount"| SDGFlow
    PipelineRunner -->|"volume mount"| SDGPrompt

