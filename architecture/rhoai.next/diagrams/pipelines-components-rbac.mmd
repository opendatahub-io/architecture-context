graph TD
    subgraph "Service Account"
        SA["Pipeline ServiceAccount<br/>(configured by RHOAI<br/>Pipelines Operator)"]
    end

    subgraph "Role Bindings"
        RB["RoleBinding<br/>(operator-managed)"]
    end

    subgraph "Required Permissions"
        direction TB
        R1["KServe Permissions"]
        R2["Core Resource Permissions"]
        R3["PVC Permissions"]
        R4["Ray Permissions"]
        R5["Training Permissions"]
        R6["HardwareProfile Permissions"]
    end

    subgraph "API Resources - serving.kserve.io"
        ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
        InferenceService["serving.kserve.io<br/>InferenceService"]
    end

    subgraph "API Resources - core"
        Pods["core<br/>Pods"]
        Secrets["core<br/>Secrets"]
        ConfigMaps["core<br/>ConfigMaps"]
        Services["core<br/>Services"]
        PVCs["core<br/>PersistentVolumeClaims"]
    end

    subgraph "API Resources - ray.io"
        RayJobs["ray.io<br/>RayJobs"]
        RayClusters["ray.io<br/>RayClusters"]
    end

    subgraph "API Resources - kubeflow.org"
        CTR["kubeflow.org<br/>ClusterTrainingRuntimes"]
    end

    subgraph "API Resources - infrastructure.opendatahub.io"
        HP["infrastructure.opendatahub.io<br/>HardwareProfiles"]
    end

    SA -->|"bound via"| RB

    RB -->|"grants"| R1
    RB -->|"grants"| R2
    RB -->|"grants"| R3
    RB -->|"grants"| R4
    RB -->|"grants"| R5
    RB -->|"grants"| R6

    R1 -->|"get, list, create,<br/>patch, delete"| ServingRuntime
    R1 -->|"get, list, create,<br/>patch, delete"| InferenceService

    R2 -->|"get, list"| Pods
    R2 -->|"get, list"| Secrets
    R2 -->|"get, list"| ConfigMaps
    R2 -->|"get, list"| Services

    R3 -->|"get, list, create"| PVCs

    R4 -->|"get, list,<br/>create, delete"| RayJobs
    R4 -->|"get, list,<br/>create, delete"| RayClusters

    R5 -->|"get, list"| CTR

    R6 -->|"get, list"| HP

    %% Secrets used by components
    subgraph "Secrets Consumed by Pipeline Components"
        S3Secret["s3-secret<br/>(AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT)"]
        HFToken["hf-token<br/>(HuggingFace API token)"]
        K8sCreds["kubernetes-credentials<br/>(remote cluster access)"]
        OCIPull["oci-pull-secret-model-download<br/>(private registry pull)"]
        OGXSecret["ogx_secret_name<br/>(OGX_CLIENT_API_KEY,<br/>OGX_CLIENT_BASE_URL)"]
        LLMCreds["llm-credentials<br/>(LLM_API_KEY)"]
        MinioSecret["minio-secret<br/>(MinIO S3 access)"]
    end

    SA -.->|"mounts/reads"| S3Secret
    SA -.->|"mounts/reads"| HFToken
    SA -.->|"mounts/reads"| K8sCreds
    SA -.->|"mounts/reads"| OCIPull
    SA -.->|"mounts/reads"| OGXSecret
    SA -.->|"mounts/reads"| LLMCreds
    SA -.->|"mounts/reads"| MinioSecret

