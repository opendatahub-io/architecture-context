graph TD
    subgraph "Service Accounts"
        PipelineRunner["pipeline-runner<br/>(KFP default SA)"]
        UserSA["User-configured SA<br/>(for Trainer components)"]
    end

    subgraph "RBAC Source"
        PlatformOp["rhods-operator /<br/>opendatahub-operator<br/>(pre-configures RBAC)"]
    end

    subgraph "Credential Injection (User-Provisioned Secrets)"
        direction TB
        S3Creds["train_data_secret_name<br/>input_data_secret_name<br/>test_data_secret_name<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT"]
        LlamaCreds["llama_stack_secret_name<br/>(Opaque)<br/>LLAMA_STACK_CLIENT_BASE_URL<br/>LLAMA_STACK_CLIENT_API_KEY"]
        HFCreds["hf-token<br/>(Opaque)<br/>HF_TOKEN"]
        S3FT["s3-secret<br/>(Opaque)<br/>AWS S3 credentials"]
        K8sCreds["kubernetes-credentials<br/>(Opaque)<br/>KUBERNETES_SERVER_URL<br/>KUBERNETES_AUTH_TOKEN"]
        OCICreds["oci-pull-secret-model-download<br/>(Opaque)<br/>OCI registry credentials"]
        LLMCreds["llm-credentials<br/>(Opaque)<br/>LLM_API_KEY"]
        SDGFlow["sdg-llm-test-flow<br/>(ConfigMap)<br/>SDG flow YAML at /etc/sdg"]
        SDGPrompt["sdg-llm-test-prompt<br/>(ConfigMap)<br/>Prompt templates at /etc/sdg/prompts"]
    end

    subgraph "API Access Patterns"
        S3API["AWS S3 API<br/>443/TCP HTTPS<br/>IAM Auth"]
        HFAPI["HuggingFace Hub<br/>443/TCP HTTPS<br/>Bearer Token"]
        LlamaAPI["Llama Stack API<br/>HTTP/HTTPS<br/>API Key"]
        LLMAPI["LLM API<br/>HTTPS<br/>API Key"]
        MRAccess["Model Registry<br/>8080/TCP HTTP<br/>⚠️ No Auth"]
        K8sAccess["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token / Bearer"]
    end

    %% RBAC provisioning
    PlatformOp -->|"pre-configures"| PipelineRunner
    PipelineRunner -->|"runs pipeline steps"| K8sAccess

    %% User SA for training
    UserSA -->|"creates/watches<br/>TrainingJob CRs"| K8sAccess

    %% Secrets → API access
    S3Creds -->|"injected as env vars"| S3API
    S3FT -->|"injected as env vars"| S3API
    LlamaCreds -->|"injected as env vars"| LlamaAPI
    HFCreds -->|"injected as env vars"| HFAPI
    K8sCreds -->|"injected as env vars"| K8sAccess
    LLMCreds -->|"injected as env vars"| LLMAPI

    %% No auth path
    PipelineRunner -.->|"direct access<br/>⚠️ no auth required"| MRAccess

    %% Styling
    style PipelineRunner fill:#4a90e2,stroke:#333,color:#fff
    style UserSA fill:#4a90e2,stroke:#333,color:#fff
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff

    style S3Creds fill:#f5a623,stroke:#333
    style LlamaCreds fill:#f5a623,stroke:#333
    style HFCreds fill:#f5a623,stroke:#333
    style S3FT fill:#f5a623,stroke:#333
    style K8sCreds fill:#f5a623,stroke:#333
    style OCICreds fill:#f5a623,stroke:#333
    style LLMCreds fill:#f5a623,stroke:#333
    style SDGFlow fill:#fff3e0,stroke:#f5a623
    style SDGPrompt fill:#fff3e0,stroke:#f5a623

    style S3API fill:#e8e8e8,stroke:#999
    style HFAPI fill:#e8e8e8,stroke:#999
    style LlamaAPI fill:#e8e8e8,stroke:#999
    style LLMAPI fill:#e8e8e8,stroke:#999
    style MRAccess fill:#ffe6cc,stroke:#d79b00
    style K8sAccess fill:#e8e8e8,stroke:#999
