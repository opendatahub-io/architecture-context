graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["No RBAC manifests in this repository.<br/>Pipeline components run under the KFP<br/>pipeline runner ServiceAccount with<br/>permissions granted by the KFP installation."]
    end

    subgraph RuntimeRBAC["Runtime RBAC (Inherited from KFP)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            PipelineRunner["pipeline-runner<br/>(KFP pipeline runner SA)<br/>Namespace: {user-namespace}"]
            KFPAPIServerSA["kfp-api-server SA<br/>(runs init container)<br/>Namespace: {dspa-namespace}"]
        end

        subgraph Permissions["Inherited Permissions (from DSPA)"]
            PipelinePerm["Pipeline Execution<br/>- Create/manage pods<br/>- Mount PVCs<br/>- Read Secrets/ConfigMaps"]
            ArtifactPerm["Artifact Management<br/>- KFP artifact store access<br/>- Pipeline metadata access"]
        end
    end

    subgraph SecretAccess["Kubernetes Secrets Access"]
        direction TB

        S3Secret["s3-secret (Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_DEFAULT_REGION<br/>Provisioned: User / RHOAI Connections"]
        HFSecret["hf-token (Opaque)<br/>HF_TOKEN<br/>Provisioned: User"]
        OGXSecret["ogx-secret (Opaque)<br/>OGX_CLIENT_API_KEY<br/>OGX_CLIENT_BASE_URL<br/>Provisioned: RHOAI Connections"]
        LLMSecret["llm-credentials (Opaque)<br/>api_key (LLM_API_KEY)<br/>Provisioned: User"]
        WandBSecret["wandb-secret (Opaque)<br/>WANDB_API_KEY<br/>Provisioned: User (optional)"]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        S3Auth["S3 Storage<br/>Methods: GET, PUT, LIST<br/>Auth: AWS Signature V4<br/>Enforcement: S3 endpoint<br/>Policy: IAM policy"]
        HFAuth["HuggingFace Hub<br/>Methods: GET<br/>Auth: Bearer Token<br/>Enforcement: HF API<br/>Policy: Token-gated"]
        OGXAuth["OGX API<br/>Methods: POST<br/>Auth: Bearer Token<br/>Enforcement: OGX API server<br/>Policy: API key validation"]
        LLMAuth["LLM API<br/>Methods: POST<br/>Auth: Bearer Token<br/>Enforcement: LLM provider<br/>Policy: API key validation"]
        MRAuth["Model Registry<br/>Methods: POST<br/>Auth: ServiceAccount Token<br/>Enforcement: MR server<br/>Policy: Namespace-scoped"]
    end

    %% Relationships
    PipelineRunner -->|"uses"| PipelinePerm
    PipelineRunner -->|"uses"| ArtifactPerm
    KFPAPIServerSA -->|"runs"| InitInfo["odh-pipelines-components<br/>init container"]

    PipelineRunner -->|"mounts as env/vol"| S3Secret
    PipelineRunner -->|"mounts as env/vol"| HFSecret
    PipelineRunner -->|"mounts as env/vol"| OGXSecret
    PipelineRunner -->|"mounts as env/vol"| LLMSecret
    PipelineRunner -->|"mounts as env/vol (optional)"| WandBSecret

    S3Secret -->|"provides credentials"| S3Auth
    HFSecret -->|"provides token"| HFAuth
    OGXSecret -->|"provides API key"| OGXAuth
    LLMSecret -->|"provides API key"| LLMAuth
    PipelineRunner -->|"auto-mounted token"| MRAuth

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Info fill:#fff3cd,stroke:#856404
    style PipelineRunner fill:#4a90e2,stroke:#333,color:#fff
    style KFPAPIServerSA fill:#4a90e2,stroke:#333,color:#fff
    style InitInfo fill:#e6f3ff,stroke:#4a90e2
    style S3Secret fill:#f5a623,stroke:#333
    style HFSecret fill:#f5a623,stroke:#333
    style OGXSecret fill:#f5a623,stroke:#333
    style LLMSecret fill:#f5a623,stroke:#333
    style WandBSecret fill:#f5a623,stroke:#333
    style S3Auth fill:#7ed321,stroke:#333
    style HFAuth fill:#7ed321,stroke:#333
    style OGXAuth fill:#7ed321,stroke:#333
    style LLMAuth fill:#7ed321,stroke:#333
    style MRAuth fill:#7ed321,stroke:#333
