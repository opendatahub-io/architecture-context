graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["🟦 Service Account"]
        L2["🟧 Inherited Permissions"]
        L3["🟩 API Resources"]
        L4["🟥 Secrets"]
    end

    subgraph ServiceAccounts["Service Accounts (Inherited from KFP)"]
        KFPSA["KFP Pipeline Execution SA<br/>(managed by DSPO)<br/>Namespace: {pipeline-namespace}"]
    end

    subgraph Note["⚠ No RBAC Manifests Defined"]
        direction TB
        NoteText["pipelines-components does not define<br/>its own RBAC resources.<br/>All permissions are inherited from the<br/>KFP execution ServiceAccount<br/>managed by DSPO."]
    end

    subgraph InheritedPermissions["Inherited Permissions (Required by Components)"]
        direction TB

        subgraph KServePerm["KServe CRD Access"]
            KServeRes["serving.kserve.io<br/>InferenceService<br/>ServingRuntime"]
        end

        subgraph RayPerm["Ray Operator CRD Access"]
            RayRes["ray.io<br/>RayJob"]
        end

        subgraph HWPerm["HardwareProfile CRD Access"]
            HWRes["hardwareprofile.opendatahub.io<br/>HardwareProfile"]
        end

        subgraph CorePerm["Core API Access"]
            CoreRes["core<br/>Secrets<br/>Namespaces<br/>ConfigMaps"]
        end

        subgraph TrainerPerm["Kubeflow Trainer CRD Access"]
            TrainerRes["kubeflow.org<br/>ClusterTrainingRuntime"]
        end
    end

    subgraph Secrets["Secrets Consumed (User-Provisioned)"]
        S3Secret["s3-secret (Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_DEFAULT_REGION"]
        HFSecret["hf-token (Opaque)<br/>HuggingFace Hub token"]
        K8sSecret["kubernetes-credentials (Opaque)<br/>K8s API URL + auth token"]
        OCISecret["oci-pull-secret-model-download (Opaque)<br/>OCI image pull credentials"]
        MinIOSecret["minio-secret (Opaque)<br/>MinIO access_key + secret_key"]
        OGXSecret["ogx-secret (Opaque)<br/>OGX API key + base URL"]
        LLMSecret["llm-credentials (Opaque)<br/>LLM API key for SDG"]
    end

    %% SA to permissions
    KFPSA -->|"get, create, delete, patch"| KServeRes
    KFPSA -->|"get, create, delete"| RayRes
    KFPSA -->|"get, list"| HWRes
    KFPSA -->|"get, list"| CoreRes
    KFPSA -->|"create, get, delete"| TrainerRes

    %% SA to secrets
    KFPSA -->|"mounts via<br/>kfp-kubernetes<br/>use_secret_as_env()"| S3Secret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| HFSecret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| K8sSecret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| OCISecret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| MinIOSecret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| OGXSecret
    KFPSA -->|"mounts via<br/>use_secret_as_env()"| LLMSecret

    %% Styling
    style KFPSA fill:#4a90e2,stroke:#333,color:#fff
    style NoteText fill:#fff3cd,stroke:#ffc107,color:#333
    style KServeRes fill:#7ed321,stroke:#333
    style RayRes fill:#7ed321,stroke:#333
    style HWRes fill:#7ed321,stroke:#333
    style CoreRes fill:#7ed321,stroke:#333
    style TrainerRes fill:#7ed321,stroke:#333
    style S3Secret fill:#f8cecc,stroke:#b85450
    style HFSecret fill:#f8cecc,stroke:#b85450
    style K8sSecret fill:#f8cecc,stroke:#b85450
    style OCISecret fill:#f8cecc,stroke:#b85450
    style MinIOSecret fill:#f8cecc,stroke:#b85450
    style OGXSecret fill:#f8cecc,stroke:#b85450
    style LLMSecret fill:#f8cecc,stroke:#b85450
