graph TD
    subgraph "Pipeline Runtime Identity"
        SA["DSPA Pipeline Runner<br/>ServiceAccount<br/>(configured by DSPA operator)"]
    end

    subgraph "RBAC Source"
        DSPA_RBAC["DSPA Operator<br/>Provisions RBAC for<br/>pipeline execution"]
    end

    subgraph "Inherited Permissions"
        direction TB
        SecretRead["Secrets<br/>get (read-only)"]
        PVCMgmt["PersistentVolumeClaims<br/>create, get, list"]
        PodExec["Pods<br/>create, get, watch"]
        ArtifactStore["KFP Artifact Store<br/>read, write"]
    end

    subgraph "Secrets Accessed by Pipeline Tasks"
        direction TB
        S3Secret["s3-secret /<br/>train_data_secret /<br/>input_data_secret<br/>(Opaque)<br/>AWS S3 credentials"]
        HFToken["hf-token<br/>(Opaque)<br/>Hugging Face API token"]
        LLMCreds["llm-credentials /<br/>llama_stack_secret<br/>(Opaque)<br/>LLM API key + endpoint"]
        K8sCreds["kubernetes-credentials<br/>(Opaque)<br/>K8s API token for<br/>Model Registry"]
        OCISecret["oci-pull-secret-<br/>model-download<br/>(Opaque)<br/>OCI registry credentials"]
        S3Conn["s3-connection<br/>(Opaque)<br/>DSPA S3 connection<br/>(DSPA Operator provisioned)"]
    end

    subgraph "Base Image Governance (CI)"
        direction TB
        Allowlist["base_image_allowlist.yaml"]
        Validator["validate_base_images.py"]
        AllowedRegs["Allowed Registries:<br/>registry.redhat.io<br/>ghcr.io/kubeflow<br/>quay.io/opendatahub<br/>quay.io/rhoai"]
    end

    %% RBAC flow
    DSPA_RBAC -->|"provisions"| SA
    SA -->|"grants access to"| SecretRead
    SA -->|"grants access to"| PVCMgmt
    SA -->|"grants access to"| PodExec
    SA -->|"grants access to"| ArtifactStore

    %% Secret access
    SecretRead -->|"reads"| S3Secret
    SecretRead -->|"reads"| HFToken
    SecretRead -->|"reads"| LLMCreds
    SecretRead -->|"reads"| K8sCreds
    SecretRead -->|"reads"| OCISecret
    SecretRead -->|"reads"| S3Conn

    %% CI governance
    Allowlist -->|"enforced by"| Validator
    Validator -->|"validates against"| AllowedRegs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style DSPA_RBAC fill:#e1d5e7,stroke:#9673a6

    style SecretRead fill:#f5a623,stroke:#333
    style PVCMgmt fill:#f5a623,stroke:#333
    style PodExec fill:#f5a623,stroke:#333
    style ArtifactStore fill:#f5a623,stroke:#333

    style S3Secret fill:#f8cecc,stroke:#b85450
    style HFToken fill:#f8cecc,stroke:#b85450
    style LLMCreds fill:#f8cecc,stroke:#b85450
    style K8sCreds fill:#f8cecc,stroke:#b85450
    style OCISecret fill:#f8cecc,stroke:#b85450
    style S3Conn fill:#f8cecc,stroke:#b85450

    style Allowlist fill:#d5e8d4,stroke:#82b366
    style Validator fill:#d5e8d4,stroke:#82b366
    style AllowedRegs fill:#d5e8d4,stroke:#82b366
