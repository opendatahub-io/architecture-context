graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["ModelMesh does not define its own<br/>RBAC resources (ClusterRoles,<br/>RoleBindings, ServiceAccounts).<br/><br/>RBAC is managed entirely by the<br/>modelmesh-serving controller."]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        subgraph gRPCAuth["gRPC API (:8033)"]
            gRPCEndpoint["ModelMeshApi Endpoint<br/>:8033/TCP"]
            gRPCMech["mTLS (optional)<br/>MM_TLS_CLIENT_AUTH=REQUIRE/OPTIONAL"]
            gRPCEnforce["Enforcement: Netty SSL handler<br/>Trust: MM_TLS_TRUST_CERT_PATH"]
            gRPCEndpoint --> gRPCMech --> gRPCEnforce
        end

        subgraph LitelinksAuth["Litelinks Inter-Instance (:8080)"]
            LLEndpoint["Litelinks Endpoint<br/>:8080/TCP"]
            LLMech["mTLS (optional)<br/>MM_INTRACLUSTER_CLIENTAUTH"]
            LLEnforce["Enforcement: Litelinks SSL handler<br/>Shared cluster certificates"]
            LLEndpoint --> LLMech --> LLEnforce
        end

        subgraph PrometheusAuth["Prometheus Metrics (:2112)"]
            PromEndpoint["Prometheus Endpoint<br/>:2112/TCP"]
            PromMech["No authentication"]
            PromEnforce["Enforcement: NetworkPolicy only<br/>TLS self-signed (transport only)"]
            PromEndpoint --> PromMech --> PromEnforce
        end

        subgraph HealthAuth["Health Probes (:8089)"]
            HealthEndpoint["Health Probe Endpoint<br/>:8089/TCP"]
            HealthMech["No authentication"]
            HealthEnforce["Enforcement: NetworkPolicy only<br/>No encryption"]
            HealthEndpoint --> HealthMech --> HealthEnforce
        end
    end

    subgraph Secrets["Secrets"]
        direction LR
        TLSSecret["model-mesh-tls-secret<br/>Type: kubernetes.io/tls<br/>Purpose: TLS cert + key<br/>Provisioned by: Manual/cert-manager<br/>Auto-Rotate: No"]
        EtcdSecret["model-mesh-icd-etcd<br/>Type: Opaque<br/>Purpose: etcd connection config<br/>Provisioned by: Manual/operator<br/>Auto-Rotate: No"]
    end

    subgraph NetworkPolicy["NetworkPolicy"]
        NP["config/base/networkpolicy.yaml<br/>Restricts ingress/egress<br/>to necessary ports and services"]
    end

    %% Relationships
    gRPCEnforce -->|"uses"| TLSSecret
    LLEnforce -->|"uses"| TLSSecret

    style Info fill:#fff3cd,stroke:#ffc107,color:#333
    style gRPCEndpoint fill:#4a90e2,color:#fff
    style LLEndpoint fill:#4a90e2,color:#fff
    style PromEndpoint fill:#4a90e2,color:#fff
    style HealthEndpoint fill:#4a90e2,color:#fff
    style gRPCMech fill:#d4edda,stroke:#28a745,color:#333
    style LLMech fill:#d4edda,stroke:#28a745,color:#333
    style PromMech fill:#f8d7da,stroke:#dc3545,color:#333
    style HealthMech fill:#f8d7da,stroke:#dc3545,color:#333
    style TLSSecret fill:#f5a623,color:#fff
    style EtcdSecret fill:#f5a623,color:#fff
    style NP fill:#7ed321,color:#fff
