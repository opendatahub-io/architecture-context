graph TD
    subgraph "ModelMesh RBAC Model"
        direction TB

        Note["NOTE: ModelMesh does NOT define its own RBAC resources.<br/>It runs as a sidecar with no direct Kubernetes API access.<br/>All RBAC is managed by the modelmesh-serving controller."]
    end

    subgraph "Managed by modelmesh-serving Controller"
        direction TB

        SA["ServiceAccount<br/>(inherited from pod,<br/>set by controller)"]

        subgraph "Pod Security Context"
            PodSec["Pod runs with controller-defined<br/>security context and service account"]
        end
    end

    subgraph "Authentication & Authorization (Application-Level)"
        direction TB

        subgraph "External gRPC (8033/TCP)"
            ExtAuth["mTLS Client Certificates<br/>MM_TLS_CLIENT_AUTH: NONE | REQUIRE | OPTIONAL<br/>Enforcement: Netty SSL context in ModelMeshApi<br/>Secret: model-mesh-tls-secret"]
        end

        subgraph "Internal to Runtime (8085/TCP or UDS)"
            IntAuth["No Auth<br/>Trusted sidecar communication<br/>localhost / Unix Domain Socket"]
        end

        subgraph "Litelinks Inter-Pod (8080/TCP)"
            LLAuth["mTLS (optional)<br/>Certificate-based when TLS enabled<br/>Via litelinks SSL config"]
        end

        subgraph "Prometheus Metrics (2112/TCP)"
            PromAuth["No Auth<br/>HTTPS with self-signed TLS cert<br/>BouncyCastle-generated"]
        end
    end

    subgraph "Secrets Access"
        direction TB

        TLSSecret["model-mesh-tls-secret<br/>Type: kubernetes.io/tls<br/>Purpose: TLS cert/key for gRPC + Litelinks<br/>Provisioned by: controller / manual<br/>Auto-Rotate: No"]

        EtcdSecret["model-mesh-icd-etcd<br/>Type: Opaque (JSON)<br/>Purpose: etcd connection config<br/>(endpoints, credentials, TLS)<br/>Provisioned by: Platform operator<br/>Auto-Rotate: No"]
    end

    SA -->|"mounts"| TLSSecret
    SA -->|"mounts"| EtcdSecret

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style PodSec fill:#e8e8e8,stroke:#333
    style ExtAuth fill:#d4edda,stroke:#28a745,stroke-width:2px
    style IntAuth fill:#f8d7da,stroke:#dc3545,stroke-width:2px
    style LLAuth fill:#d4edda,stroke:#28a745,stroke-width:2px
    style PromAuth fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style TLSSecret fill:#f5a623,stroke:#333,color:#fff
    style EtcdSecret fill:#f5a623,stroke:#333,color:#fff
