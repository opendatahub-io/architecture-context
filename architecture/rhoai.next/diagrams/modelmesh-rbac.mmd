graph TD
    subgraph Note["ModelMesh RBAC"]
        direction TB
        Info["ModelMesh does not define its own<br/>RBAC resources (ClusterRoles,<br/>Roles, or RoleBindings)"]
        Delegation["RBAC is managed by the<br/>modelmesh-serving controller"]
    end

    subgraph Secrets["Secrets Used"]
        direction TB
        TLSSecret["model-mesh-tls-secret<br/>Type: kubernetes.io/tls<br/>Purpose: TLS cert & key for<br/>gRPC server & internal comm<br/>Provisioned: Manual / cert-manager<br/>Auto-Rotate: No"]
        EtcdSecret["model-mesh-icd-etcd<br/>Type: Opaque<br/>Purpose: etcd connection config<br/>(host, port, TLS certs)<br/>Provisioned: Manual / platform operator<br/>Auto-Rotate: No"]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB
        ExternalGRPC["gRPC API :8033<br/>Auth: mTLS (optional)<br/>MM_TLS_CLIENT_AUTH=REQUIRE/OPTIONAL<br/>Cert validation via MM_TLS_TRUST_CERT_PATH"]
        InternalThrift["Litelinks :8080<br/>Auth: mTLS (optional)<br/>MM_INTRACLUSTER_CLIENTAUTH<br/>Shared cluster certificates"]
        MetricsEndpoint["Prometheus :2112<br/>Auth: None<br/>Protected by NetworkPolicy"]
        HealthEndpoint["Health Probes :8089<br/>Auth: None<br/>Protected by NetworkPolicy"]
    end

    subgraph NetworkPolicy["Network Policy"]
        direction TB
        NP["config/base/networkpolicy.yaml<br/>Restricts access to pod ports<br/>Controls Prometheus scrape access<br/>Controls health probe access"]
    end

    Info --> Delegation
    Delegation -->|"see modelmesh-serving<br/>for RBAC details"| ExternalGRPC

