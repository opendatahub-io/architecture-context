graph TD
    subgraph "ModelMesh RBAC & Secrets"
        direction TB

        Note["NOTE: ModelMesh is a sidecar service<br/>that does NOT interact with the<br/>Kubernetes API directly.<br/><br/>RBAC is managed by the<br/>modelmesh-serving controller."]

        subgraph "Secrets Used by ModelMesh"
            TLSSecret["model-mesh-tls-secret<br/>(kubernetes.io/tls)<br/>───────────────────<br/>TLS cert + private key<br/>for gRPC + inter-instance<br/>───────────────────<br/>Provisioned: controller / manual<br/>Auto-Rotate: No"]

            EtcdSecret["model-mesh-icd-etcd<br/>(Opaque)<br/>───────────────────<br/>etcd connection config<br/>(JSON connection string)<br/>───────────────────<br/>Provisioned: controller / manual<br/>Auto-Rotate: No"]

            TrustCerts["Trust Certs<br/>(Opaque)<br/>───────────────────<br/>CA certificates for<br/>mTLS client auth<br/>───────────────────<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        end

        subgraph "Authentication Endpoints"
            GRPC_Ext["gRPC External :8033<br/>───────────────────<br/>Auth: Optional mTLS<br/>Mode: NONE / REQUIRE / OPTIONAL<br/>Enforcement: Netty/gRPC TLS handler"]

            GRPC_Inter["gRPC Inter-Instance :8033<br/>───────────────────<br/>Auth: TLS (shared certs)<br/>Mode: Mutual auth<br/>Enforcement: litelinks/Netty"]

            GRPC_RT["gRPC Runtime :8085/UDS<br/>───────────────────<br/>Auth: None<br/>Mode: Pod-internal only<br/>Enforcement: N/A (localhost)"]

            Metrics["Metrics :2112<br/>───────────────────<br/>Auth: None<br/>Mode: Self-signed TLS<br/>Enforcement: N/A"]

            Health["Health Probes :8089<br/>───────────────────<br/>Auth: None<br/>Mode: Plaintext HTTP<br/>Enforcement: N/A"]
        end

        TLSSecret -->|"provides certs"| GRPC_Ext
        TLSSecret -->|"provides certs"| GRPC_Inter
        EtcdSecret -->|"connection config"| EtcdConn["etcd Connection"]
        TrustCerts -->|"CA chain"| GRPC_Ext
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style TLSSecret fill:#f8d7da,stroke:#721c24,color:#721c24
    style EtcdSecret fill:#f8d7da,stroke:#721c24,color:#721c24
    style TrustCerts fill:#f8d7da,stroke:#721c24,color:#721c24
    style GRPC_Ext fill:#d4edda,stroke:#155724,color:#155724
    style GRPC_Inter fill:#d4edda,stroke:#155724,color:#155724
    style GRPC_RT fill:#d4edda,stroke:#155724,color:#155724
    style Metrics fill:#d4edda,stroke:#155724,color:#155724
    style Health fill:#d4edda,stroke:#155724,color:#155724
    style EtcdConn fill:#cce5ff,stroke:#004085,color:#004085
