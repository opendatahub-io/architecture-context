graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["No Kubernetes RBAC"]
        L2["ModelMesh is a sidecar service"]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph ExternalGrpc["gRPC External API (8033/TCP)"]
            ExtAuth["Auth: Optional mTLS<br/>ClientAuth: NONE / REQUIRE / OPTIONAL<br/>Enforcement: Netty/gRPC TLS handler<br/>Config: MM_TLS_CLIENT_AUTH env var"]
        end

        subgraph InterInstance["gRPC Inter-Instance (8033/TCP)"]
            InterAuth["Auth: TLS with shared certs<br/>Enforcement: litelinks/Netty<br/>Policy: Mutual auth between pods<br/>Uses same certs as external API"]
        end

        subgraph RuntimeGrpc["gRPC Runtime (8085/TCP or UDS)"]
            RtAuth["Auth: None<br/>Enforcement: N/A<br/>Policy: Pod-internal only<br/>Localhost or Unix Domain Socket"]
        end

        subgraph MetricsHttp["Metrics Endpoint (2112/TCP)"]
            MetAuth["Auth: None<br/>Encryption: Self-signed TLS<br/>Generated by: BouncyCastle<br/>Note: NOT FIPS-validated"]
        end

        subgraph HealthHttp["Health Probes (8089/TCP)"]
            HlthAuth["Auth: None<br/>Encryption: Plaintext HTTP<br/>Endpoints: /ready, /live"]
        end
    end

    subgraph Secrets["Secrets"]
        direction TB
        TLSSecret["model-mesh-tls-secret<br/>Type: kubernetes.io/tls<br/>Purpose: TLS cert+key for gRPC<br/>and inter-instance comms<br/>Provisioned: controller / manual<br/>Auto-Rotate: No"]
        EtcdSecret["model-mesh-icd-etcd<br/>Type: Opaque<br/>Purpose: etcd connection config<br/>(JSON connection string)<br/>Provisioned: controller / manual<br/>Auto-Rotate: No"]
        TrustCerts["(trust certs)<br/>Type: Opaque<br/>Purpose: CA certificates for<br/>mTLS client auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    ExternalGrpc -->|"uses"| TLSSecret
    InterInstance -->|"uses"| TLSSecret
    ExternalGrpc -->|"validates clients"| TrustCerts

    Note["Note: ModelMesh does NOT interact<br/>with the Kubernetes API.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined.<br/>All K8s RBAC is managed by the<br/>modelmesh-serving controller."]

    style ExtAuth fill:#4a90e2,stroke:#333,color:#fff
    style InterAuth fill:#4a90e2,stroke:#333,color:#fff
    style RtAuth fill:#7ed321,stroke:#333,color:#fff
    style MetAuth fill:#f5a623,stroke:#333,color:#fff
    style HlthAuth fill:#f5a623,stroke:#333,color:#fff
    style TLSSecret fill:#e8e8e8,stroke:#333
    style EtcdSecret fill:#e8e8e8,stroke:#333
    style TrustCerts fill:#e8e8e8,stroke:#333
    style Note fill:#fff2cc,stroke:#d6b656
    style L1 fill:#fff,stroke:#999
    style L2 fill:#fff,stroke:#999
