graph TD
    subgraph Legend["RBAC Context"]
        direction TB
        Note["ModelMesh runs as a sidecar container<br/>and does NOT directly interact with<br/>the Kubernetes API.<br/><br/>RBAC roles and bindings are managed by<br/>the modelmesh-serving controller,<br/>not by ModelMesh itself."]
    end

    subgraph PodIdentity["Pod Identity (Inherited)"]
        SA["ServiceAccount<br/>(Defined by modelmesh-serving<br/>in ServingRuntime pod spec)"]
    end

    subgraph DownwardAPI["Kubernetes Downward API (Read-Only)"]
        PodName["WKUBE_POD_NAME<br/>(Pod name)"]
        PodIP["WKUBE_POD_IPADDR<br/>(Pod IP)"]
        HostIP["MM_LOCATION<br/>(Host IP)"]
    end

    subgraph Secrets["Mounted Secrets"]
        TLSSecret["model-mesh-tls-secret<br/>(kubernetes.io/tls)<br/>TLS cert + private key<br/>Manual or cert-manager"]
        EtcdSecret["model-mesh-icd-etcd<br/>(Opaque)<br/>etcd connection JSON<br/>(endpoint, credentials, TLS)"]
    end

    subgraph ManagedBy["RBAC Managed By"]
        Controller["modelmesh-serving Controller<br/>(Separate Repository)<br/>Manages all RBAC for<br/>ServingRuntime pods"]
    end

    SA -->|"env vars via"| DownwardAPI
    SA -->|"volume mounts"| Secrets
    Controller -->|"creates and binds<br/>RBAC resources for"| SA

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style TLSSecret fill:#e74c3c,stroke:#333,color:#fff
    style EtcdSecret fill:#e74c3c,stroke:#333,color:#fff
    style Controller fill:#7ed321,stroke:#333,color:#fff
    style PodName fill:#e8e8e8,stroke:#333
    style PodIP fill:#e8e8e8,stroke:#333
    style HostIP fill:#e8e8e8,stroke:#333
