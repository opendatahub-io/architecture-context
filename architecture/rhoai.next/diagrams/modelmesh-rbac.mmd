graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Note: ModelMesh is a service, not a Kubernetes operator.<br/>It does NOT interact with the Kubernetes API.<br/>No RBAC manifests are defined in this repository.<br/>RBAC for the parent controller (modelmesh-serving) is in a separate repo."]
    end

    subgraph TLSAuth["TLS / mTLS Authentication"]
        direction TB

        subgraph ExternalGRPC["External gRPC API (8033/TCP)"]
            TLSSecret["Secret: model-mesh-tls-secret<br/>(kubernetes.io/tls)<br/>PKCS8 key + certificate"]
            ClientAuth["Client Auth Mode<br/>(MM_TLS_CLIENT_AUTH)"]
            TrustCert["Trust Certificate<br/>(MM_TLS_TRUST_CERT_PATH)"]

            ClientAuth -->|NONE| NoAuth["No client cert required"]
            ClientAuth -->|REQUIRE| RequireAuth["Client cert required<br/>Validated against trust cert"]
            ClientAuth -->|OPTIONAL| OptionalAuth["Client cert validated<br/>if presented"]
        end

        subgraph IntraCluster["Inter-Pod Litelinks (8080/TCP)"]
            SameKey["Uses same TLS keypair<br/>as external gRPC"]
            IntraAuth["Intra-Cluster Auth<br/>(MM_INTRACLUSTER_CLIENTAUTH)"]
            JKSTrust["JKS Truststore<br/>(watson.ssl.truststore)"]

            IntraAuth -->|configurable| JKSTrust
        end

        subgraph etcdAuth["etcd Connection (2379/TCP)"]
            etcdSecret["Secret: model-mesh-icd-etcd<br/>(Opaque)<br/>host, port, credentials"]
            etcdTLS["TLS: configurable"]
            etcdClientCert["Auth: Client certificate<br/>(configurable)"]
        end
    end

    subgraph UnauthEndpoints["Unauthenticated Endpoints"]
        Metrics["Prometheus Metrics<br/>2112/TCP HTTP(S)<br/>Auth: None<br/>NetworkPolicy: allows all"]
        HealthReady["/ready - Readiness Probe<br/>8089/TCP HTTP<br/>Auth: None"]
        HealthLive["/live - Liveness Probe<br/>8089/TCP HTTP<br/>Auth: None"]
        PreStop["/prestop - Graceful Shutdown<br/>configurable/TCP HTTP<br/>Auth: None"]
    end

    subgraph LocalhostOnly["Localhost-Only (Pod Boundary)"]
        RuntimeGRPC["ModelRuntime gRPC<br/>8085/TCP or UDS<br/>plaintext, no auth<br/>Secured by pod boundary"]
    end

    style Legend fill:#fff3cd,stroke:#856404,stroke-width:2px
    style TLSSecret fill:#4a90e2,stroke:#333,color:#fff
    style etcdSecret fill:#4a90e2,stroke:#333,color:#fff
    style RequireAuth fill:#28a745,stroke:#333,color:#fff
    style OptionalAuth fill:#ffc107,stroke:#333
    style NoAuth fill:#dc3545,stroke:#333,color:#fff
    style Metrics fill:#e8e8e8,stroke:#333
    style HealthReady fill:#e8e8e8,stroke:#333
    style HealthLive fill:#e8e8e8,stroke:#333
    style PreStop fill:#e8e8e8,stroke:#333
    style RuntimeGRPC fill:#f5a623,stroke:#333,color:#fff
