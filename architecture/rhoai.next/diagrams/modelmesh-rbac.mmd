graph TD
    subgraph "ModelMesh RBAC Overview"
        direction TB
        Note["ModelMesh is a sidecar service<br/>that does NOT interact with<br/>the Kubernetes API directly"]
    end

    subgraph "Secrets (Managed by modelmesh-serving controller)"
        direction TB
        TLSSecret["model-mesh-tls-secret<br/>(kubernetes.io/tls)<br/>─────────────────────<br/>TLS cert + private key<br/>for gRPC + inter-instance<br/>─────────────────────<br/>Provisioned by: controller/manual<br/>Auto-Rotate: No"]
        etcdSecret["model-mesh-icd-etcd<br/>(Opaque)<br/>─────────────────────<br/>etcd connection config<br/>(JSON connection string)<br/>─────────────────────<br/>Provisioned by: controller/manual<br/>Auto-Rotate: No"]
        TrustCerts["Trust CA Certs<br/>(Opaque)<br/>─────────────────────<br/>CA certificates for<br/>mTLS client auth<br/>─────────────────────<br/>Provisioned by: manual<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication Endpoints"
        direction TB
        ExtGRPC["gRPC External :8033<br/>Auth: Optional mTLS<br/>ClientAuth: NONE/REQUIRE/OPTIONAL<br/>Configured via MM_TLS_CLIENT_AUTH"]
        InterGRPC["gRPC Inter-Instance :8033<br/>Auth: TLS shared certs<br/>Mutual auth between pods"]
        IntGRPC["gRPC Runtime :8085/UDS<br/>Auth: None<br/>(pod-internal only)"]
        MetricsEP["Metrics :2112<br/>Auth: None<br/>Self-signed TLS"]
        HealthEP["Health :8089<br/>Auth: None<br/>Plaintext HTTP"]
    end

    TLSSecret -->|"provides certs"| ExtGRPC
    TLSSecret -->|"provides certs"| InterGRPC
    etcdSecret -->|"provides connection"| etcdConn["etcd Connection<br/>:2379/TCP gRPC<br/>Optional TLS client certs"]
    TrustCerts -->|"provides CA chain"| ExtGRPC

    subgraph "Delegated RBAC"
        direction TB
        ControllerRBAC["modelmesh-serving Controller<br/>─────────────────────<br/>Manages all Kubernetes RBAC<br/>for the ModelMesh deployment<br/>─────────────────────<br/>• Creates ServiceAccounts<br/>• Manages pod specs<br/>• Handles CRDs (InferenceService,<br/>  ServingRuntime)"]
    end

    ControllerRBAC -->|"deploys & configures"| Note

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style TLSSecret fill:#f5a623,stroke:#333,color:#fff
    style etcdSecret fill:#f5a623,stroke:#333,color:#fff
    style TrustCerts fill:#f5a623,stroke:#333,color:#fff
    style ExtGRPC fill:#4a90e2,stroke:#333,color:#fff
    style InterGRPC fill:#4a90e2,stroke:#333,color:#fff
    style IntGRPC fill:#7ed321,stroke:#333,color:#fff
    style MetricsEP fill:#7ed321,stroke:#333,color:#fff
    style HealthEP fill:#7ed321,stroke:#333,color:#fff
    style ControllerRBAC fill:#999,stroke:#333,color:#fff
    style etcdConn fill:#e8e8e8,stroke:#333
