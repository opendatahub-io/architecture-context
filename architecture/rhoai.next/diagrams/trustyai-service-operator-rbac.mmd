graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Instance["per-instance SA<br/>(workload namespaces)"]
        SA_NonAdmin["non-admin users"]
        SA_EvalHubJobs["evalhub job runners"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_AuthDelegator["auth-delegator CRB<br/>(per TAS/GORCH/NEMO/EvalHub)"]
        CRB_NonAdmin["non-admin-lmeval-binding"]
        CRB_EvalHubJobs["evalhub-jobs-writer-binding"]
    end

    subgraph ManagerRoles["ClusterRoles - Manager"]
        CR_TAS["manager-role (TAS)"]
        CR_LMES["manager-role (LMES)"]
        CR_JOB_MGR["manager-role (JOB_MGR)"]
        CR_GORCH["manager-role (GORCH)"]
        CR_NEMO["manager-role (NEMO)"]
        CR_EVALHUB["manager-role (EVALHUB)"]
    end

    subgraph UtilityRoles["ClusterRoles - Utility"]
        CR_Proxy["proxy-role"]
        CR_Leader["leader-election-role<br/>(namespaced)"]
        CR_NonAdmin["non-admin-lmeval-role"]
        CR_EvalHubWriter["evalhub-jobs-writer"]
        CR_EvalHubConfig["evalhub-job-config"]
    end

    subgraph TASResources["TAS Resources"]
        TrustyAIServices["trustyai.opendatahub.io<br/>TrustyAIService<br/>+ status + finalizers"]
        TAS_Deployments["apps<br/>Deployments<br/>+ status + finalizers"]
        TAS_Core["core<br/>Services, Pods, ConfigMaps<br/>PVCs, Secrets, SAs, Events"]
        TAS_KServe["serving.kserve.io<br/>InferenceServices<br/>+ finalizers"]
        TAS_Istio["networking.istio.io<br/>DestinationRules<br/>VirtualServices"]
        TAS_Routes["route.openshift.io<br/>Routes"]
        TAS_Monitors["monitoring.coreos.com<br/>ServiceMonitors"]
        TAS_RBAC["rbac.authorization.k8s.io<br/>ClusterRoleBindings"]
    end

    subgraph LMESResources["LMES Resources"]
        LMEvalJobs["trustyai.opendatahub.io<br/>LMEvalJob<br/>+ status + finalizers"]
        LMES_Pods["core<br/>Pods, Pods/exec"]
        LMES_Config["core<br/>ConfigMaps, Secrets"]
        LMES_PVCs["core<br/>PersistentVolumeClaims"]
    end

    subgraph KueueResources["Kueue Resources"]
        Workloads["kueue.x-k8s.io<br/>Workloads<br/>+ status + finalizers"]
        ResourceFlavors["kueue.x-k8s.io<br/>ResourceFlavors"]
        WorkloadPriorities["kueue.x-k8s.io<br/>WorkloadPriorityClasses"]
    end

    subgraph GORCHResources["GORCH Resources"]
        GuardrailsOrchestrators["trustyai.opendatahub.io<br/>GuardrailsOrchestrator<br/>+ status + finalizers"]
        GORCH_KServe["serving.kserve.io<br/>InferenceServices<br/>ServingRuntimes"]
    end

    subgraph NEMOResources["NEMO Resources"]
        NemoGuardrails["trustyai.opendatahub.io<br/>NemoGuardrails<br/>+ status + finalizers"]
    end

    subgraph EvalHubResources["EvalHub Resources"]
        EvalHubs["trustyai.opendatahub.io<br/>EvalHub<br/>+ status + finalizers"]
        EH_Namespaces["core<br/>Namespaces"]
        EH_Jobs["batch<br/>Jobs"]
    end

    subgraph ProxyResources["Proxy Resources"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
    end

    subgraph LeaderResources["Leader Election"]
        Leases["coordination.k8s.io<br/>Leases"]
    end

    %% SA → CRB → CR → Resources
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Proxy
    SA_Instance -->|bound via| CRB_AuthDelegator
    SA_NonAdmin -->|bound via| CRB_NonAdmin
    SA_EvalHubJobs -->|bound via| CRB_EvalHubJobs

    CRB_Manager -->|grants| CR_TAS
    CRB_Manager -->|grants| CR_LMES
    CRB_Manager -->|grants| CR_JOB_MGR
    CRB_Manager -->|grants| CR_GORCH
    CRB_Manager -->|grants| CR_NEMO
    CRB_Manager -->|grants| CR_EVALHUB
    CRB_Proxy -->|grants| CR_Proxy
    CRB_AuthDelegator -->|grants| CR_Leader
    CRB_NonAdmin -->|grants| CR_NonAdmin
    CRB_EvalHubJobs -->|grants| CR_EvalHubWriter

    %% TAS permissions
    CR_TAS -->|"get,list,watch,create<br/>update,patch,delete"| TrustyAIServices
    CR_TAS -->|"list,watch,get,create<br/>update,patch,delete"| TAS_Deployments
    CR_TAS -->|"get,list,watch,create<br/>update,patch,delete"| TAS_Core
    CR_TAS -->|"list,watch,get<br/>update,patch,delete"| TAS_KServe
    CR_TAS -->|"create,list,watch<br/>get,update,patch,delete"| TAS_Istio
    CR_TAS -->|"list,watch,get<br/>create,update,patch,delete"| TAS_Routes
    CR_TAS -->|"list,watch,create"| TAS_Monitors
    CR_TAS -->|"get,list,watch<br/>create,update,delete"| TAS_RBAC

    %% LMES permissions
    CR_LMES -->|"get,list,watch,create<br/>update,patch,delete"| LMEvalJobs
    CR_LMES -->|"get,list,watch<br/>create,delete"| LMES_Pods
    CR_LMES -->|"get,watch,list"| LMES_Config
    CR_LMES -->|"list,get,watch,create<br/>update,patch,delete"| LMES_PVCs

    %% JOB_MGR permissions
    CR_JOB_MGR -->|"get,list,watch,create<br/>update,patch,delete"| Workloads
    CR_JOB_MGR -->|"get,list,watch"| ResourceFlavors
    CR_JOB_MGR -->|"get,list,watch"| WorkloadPriorities

    %% GORCH permissions
    CR_GORCH -->|"get,list,watch,create<br/>update,patch,delete"| GuardrailsOrchestrators
    CR_GORCH -->|"list,watch,get"| GORCH_KServe

    %% NEMO permissions
    CR_NEMO -->|"get,list,watch,create<br/>update,patch,delete"| NemoGuardrails

    %% EVALHUB permissions
    CR_EVALHUB -->|"get,list,watch,create<br/>update,patch,delete"| EvalHubs
    CR_EVALHUB -->|"get,list,watch"| EH_Namespaces
    CR_EVALHUB -->|"get,list,watch,delete"| EH_Jobs

    %% Proxy permissions
    CR_Proxy -->|"create"| SAR

    %% Leader election
    CR_Leader -->|"get,create,update"| Leases

    %% Non-admin
    CR_NonAdmin -->|"get,list,watch,create<br/>update,patch,delete"| LMEvalJobs

    %% EvalHub jobs writer
    CR_EvalHubWriter -->|"get,list,watch,create<br/>update,patch"| LMES_Config
    CR_EvalHubWriter -->|"get,list,watch,create<br/>update,patch,delete"| EH_Jobs

