    CR_LMES -->|"CRUD"| LMES_R1
    CR_LMES -->|"CRUD"| LMES_R2

    CR_GORCH -->|"CRUD"| GORCH_R1
    CR_GORCH -->|"get,list,watch"| GORCH_R2
    CR_GORCH -->|"CRUD"| GORCH_R3

    CR_NEMO -->|"CRUD"| NEMO_R1
    CR_NEMO -->|"CRUD"| NEMO_R2
    CR_NEMO -->|"CRUD"| NEMO_R3

    CR_EVALHUB -->|"CRUD"| EVALHUB_R1
    CR_EVALHUB -->|"get,list,watch,<br/>patch,delete"| EVALHUB_R2
    CR_EVALHUB -->|"get,list,watch"| EVALHUB_R3
    CR_EVALHUB -->|"CRUD"| EVALHUB_R4

    CR_PROXY -->|"create"| PROXY_R1
    CR_PROXY -->|"create"| PROXY_R2

    CR_LMEVAL_USER -->|"CRUD"| LMES_R1

