graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Auth["system:authenticated<br/>(Group - all users)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_TAS["tas-manager-rolebinding<br/>cluster-scoped"]
        CRB_LMES["lmes-manager-rolebinding<br/>cluster-scoped"]
        CRB_GORCH["gorch-manager-rolebinding<br/>cluster-scoped"]
        CRB_NEMO["nemo-guardrails-manager-rolebinding<br/>cluster-scoped"]
        CRB_EH["evalhub-manager-rolebinding<br/>cluster-scoped"]
        CRB_PROXY["proxy-rolebinding<br/>cluster-scoped"]
        CRB_AUTH["manager-auth-delegator<br/>cluster-scoped"]
        CRB_LMEVAL_USER["default-lmeval-user-rolebinding<br/>cluster-scoped"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_TAS["tas-manager-role"]
        CR_LMES["lmes-manager-role"]
        CR_GORCH["gorch-manager-role"]
        CR_NEMO["nemo-guardrails-manager-role"]
        CR_EH["evalhub-manager-role"]
        CR_PROXY["proxy-role"]
        CR_AUTH["system:auth-delegator"]
        CR_LMEVAL_USER["lmeval-user-role"]
    end

    %% SA → CRB → CR
    SA_CM -->|bound via| CRB_TAS
    SA_CM -->|bound via| CRB_LMES
