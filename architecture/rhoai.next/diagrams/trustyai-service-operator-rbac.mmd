        TAS_KServe["serving.kserve.io<br/>inferenceservices[/*]"]
        TAS_Istio["networking.istio.io<br/>destinationrules, virtualservices"]
        TAS_Monitor["monitoring.coreos.com<br/>servicemonitors"]
        TAS_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        TAS_CRD_Watch["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph LMES_Resources["LMES Resources"]
        LMES_CRD["trustyai.opendatahub.io<br/>lmevaljobs[/*]"]
        LMES_Core["core<br/>pods, pods/exec, configmaps,<br/>secrets, pvcs"]
    end

    subgraph GORCH_Resources["GORCH Resources"]
        GORCH_CRD["trustyai.opendatahub.io<br/>guardrailsorchestrators[/*]"]
        GORCH_KServe["serving.kserve.io<br/>servingruntimes, inferenceservices"]
        GORCH_Apps["apps<br/>deployments[/*]"]
    end

    subgraph NEMO_Resources["NemoGuardrails Resources"]
        NEMO_CRD["trustyai.opendatahub.io<br/>nemoguardrails[/*]"]
