        TAS_R8["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        TAS_R9["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph LMES_Resources["LMES Controller Resources"]
        LMES_R1["trustyai.opendatahub.io<br/>lmevaljobs/*"]
        LMES_R2["core<br/>pods, pods/exec,<br/>configmaps, secrets, pvcs"]
    end

    subgraph GORCH_Resources["GORCH Controller Resources"]
        GORCH_R1["trustyai.opendatahub.io<br/>guardrailsorchestrators/*"]
        GORCH_R2["serving.kserve.io<br/>servingruntimes,<br/>inferenceservices"]
        GORCH_R3["apps<br/>deployments/*"]
    end

    subgraph NEMO_Resources["NeMo Controller Resources"]
        NEMO_R1["trustyai.opendatahub.io<br/>nemoguardrails/*"]
        NEMO_R2["core<br/>configmaps, services,<br/>secrets, serviceaccounts"]
        NEMO_R3["route.openshift.io<br/>routes"]
