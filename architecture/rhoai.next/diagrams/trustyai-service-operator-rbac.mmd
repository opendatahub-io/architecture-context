    CR_GORCH -->|"full CRUD"| GORCH_CRD
    CR_GORCH -->|"get,list,watch"| GORCH_KServe
    CR_GORCH -->|"full CRUD"| GORCH_Apps

    CR_NEMO -->|"full CRUD"| NEMO_CRD
    CR_NEMO -->|"full CRUD"| NEMO_Core
    CR_NEMO -->|"full CRUD"| NEMO_Route

    CR_EH -->|"full CRUD"| EH_CRD
    CR_EH -->|"get,list,watch,<br/>patch,delete"| EH_Batch
    CR_EH -->|"get,list,watch"| EH_NS
    CR_EH -->|"full CRUD"| EH_RBAC

    CR_PROXY -->|"create"| Proxy_TokenReview
    CR_PROXY -->|"create"| Proxy_SAR

    CR_LMEVAL_USER -->|"full CRUD"| User_LMEval

