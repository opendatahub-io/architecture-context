    subgraph EH_Resources["EvalHub Resources"]
        EH_CRD["trustyai.opendatahub.io<br/>evalhubs[/*], status-events"]
        EH_Batch["batch<br/>jobs"]
        EH_NS["core<br/>namespaces"]
        EH_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings, roles,<br/>rolebindings"]
    end

    subgraph Proxy_Resources["Proxy Resources"]
        Proxy_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        Proxy_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph User_Resources["User-Facing Resources"]
        User_LMEval["trustyai.opendatahub.io<br/>lmevaljobs"]
    end

    %% CR → Resources
    CR_TAS -->|"full CRUD"| TAS_CRD
