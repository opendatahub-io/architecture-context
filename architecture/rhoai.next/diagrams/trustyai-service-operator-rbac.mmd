        UR_EVALHUB_PROV["evalhub-providers-<br/>access"]
        UR_EVALHUB_JOBS["evalhub-jobs-<br/>writer"]
    end

    %% SA → CRB → CR
    SA_CM -->|bound via| CRB_TAS
    SA_CM -->|bound via| CRB_LMES
