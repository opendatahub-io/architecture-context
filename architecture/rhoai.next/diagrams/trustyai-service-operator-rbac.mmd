    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style SA_NonAdmin fill:#4a90e2,stroke:#333,color:#fff
    style SA_EvalHubJobs fill:#4a90e2,stroke:#333,color:#fff

    style CR_TAS fill:#f5a623,stroke:#333,color:#333
    style CR_LMES fill:#f5a623,stroke:#333,color:#333
    style CR_JOB_MGR fill:#f5a623,stroke:#333,color:#333
    style CR_GORCH fill:#f5a623,stroke:#333,color:#333
    style CR_NEMO fill:#f5a623,stroke:#333,color:#333
    style CR_EVALHUB fill:#f5a623,stroke:#333,color:#333
    style CR_Proxy fill:#f5a623,stroke:#333,color:#333
    style CR_Leader fill:#f5a623,stroke:#333,color:#333
    style CR_NonAdmin fill:#f5a623,stroke:#333,color:#333
    style CR_EvalHubWriter fill:#f5a623,stroke:#333,color:#333
    style CR_EvalHubConfig fill:#f5a623,stroke:#333,color:#333

    style TrustyAIServices fill:#7ed321,stroke:#333,color:#333
    style LMEvalJobs fill:#7ed321,stroke:#333,color:#333
    style GuardrailsOrchestrators fill:#7ed321,stroke:#333,color:#333
    style NemoGuardrails fill:#7ed321,stroke:#333,color:#333
