graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-service-operator-<br/>controller-manager<br/>(operator namespace)"]
        ProxySA["{tas-name}-proxy<br/>(user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        TASBinding["tas-manager-<br/>rolebinding"]
        LMESBinding["lmes-manager-<br/>rolebinding"]
        GORCHBinding["gorch-manager-<br/>rolebinding"]
        EvalHubBinding["evalhub-manager-<br/>rolebinding"]
        NemoBinding["nemo-guardrails-<br/>manager-rolebinding"]
        JobMgrBinding["job-mgr-manager-<br/>rolebinding"]
        ProxyBinding["{tas-name}-{ns}-<br/>proxy-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        TASRole["tas-manager-role"]
        LMESRole["lmes-manager-role"]
        GORCHRole["gorch-manager-role"]
        EvalHubRole["evalhub-manager-role"]
        NemoRole["nemo-guardrails-<br/>manager-role"]
        JobMgrRole["job-mgr-manager-role"]
        ProxyRole["trustyai-service-<br/>operator-proxy-role"]
    end

    subgraph TASResources["TAS Resources"]
        TASCRDS["trustyai.opendatahub.io<br/>trustyaiservices/*"]
        TASApps["apps<br/>deployments/*"]
        TASCore["core<br/>services, pods, configmaps,<br/>pvcs, secrets, serviceaccounts,<br/>events, pvs"]
        TASMonitor["monitoring.coreos.com<br/>servicemonitors"]
        TASRoutes["route.openshift.io<br/>routes"]
        TASKServe["serving.kserve.io<br/>inferenceservices/*"]
        TASRBAC["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        TASIstio["networking.istio.io<br/>destinationrules, virtualservices"]
    end

    subgraph LMESResources["LMES Resources"]
        LMESCRDS["trustyai.opendatahub.io<br/>lmevaljobs/*"]
        LMESPods["core<br/>pods, pods/exec"]
        LMESConfig["core<br/>configmaps, secrets,<br/>pvs, pvcs"]
    end

    subgraph GORCHResources["GORCH Resources"]
        GORCHCRDS["trustyai.opendatahub.io<br/>guardrailsorchestrators/*"]
        GORCHKServe["serving.kserve.io<br/>servingruntimes, inferenceservices"]
        GORCHCore["core + apps + route<br/>deployments, services, pods,<br/>configmaps, secrets, routes"]
    end

    subgraph EvalHubResources["EvalHub Resources"]
        EHCRDS["trustyai.opendatahub.io<br/>evalhubs, evalhubs/proxy,<br/>status-events"]
        EHCore["core + apps + route<br/>deployments, services, configmaps,<br/>serviceaccounts, namespaces"]
        EHRBAC["rbac.authorization.k8s.io<br/>clusterrolebindings, roles,<br/>rolebindings"]
    end

    subgraph JobMgrResources["JobMgr Resources"]
        JMKueue["kueue.x-k8s.io<br/>workloads/*, resourceflavors,<br/>workloadpriorityclasses"]
        JMScheduling["scheduling.k8s.io<br/>priorityclasses"]
        JMEvents["core<br/>events"]
    end

    %% SA → Bindings
    SA -->|bound via| TASBinding
    SA -->|bound via| LMESBinding
    SA -->|bound via| GORCHBinding
    SA -->|bound via| EvalHubBinding
    SA -->|bound via| NemoBinding
    SA -->|bound via| JobMgrBinding
    ProxySA -->|bound via| ProxyBinding

    %% Bindings → Roles
    TASBinding -->|grants| TASRole
    LMESBinding -->|grants| LMESRole
    GORCHBinding -->|grants| GORCHRole
    EvalHubBinding -->|grants| EvalHubRole
    NemoBinding -->|grants| NemoRole
    JobMgrBinding -->|grants| JobMgrRole
    ProxyBinding -->|grants| ProxyRole

    %% Roles → Resources
    TASRole -->|"CRUD + watch"| TASCRDS
    TASRole -->|"CRUD + watch"| TASApps
    TASRole -->|"CRUD + watch"| TASCore
    TASRole -->|"list, watch, create"| TASMonitor
    TASRole -->|"CRUD + watch"| TASRoutes
    TASRole -->|"list, watch, get,<br/>update, patch, delete"| TASKServe
    TASRole -->|"CRUD + watch"| TASRBAC
    TASRole -->|"CRUD + watch"| TASIstio

    LMESRole -->|"CRUD + watch"| LMESCRDS
    LMESRole -->|"get, list, watch,<br/>create, delete"| LMESPods
    LMESRole -->|"get, watch, list"| LMESConfig

    GORCHRole -->|"CRUD + watch"| GORCHCRDS
    GORCHRole -->|"get, list, watch"| GORCHKServe
    GORCHRole -->|"CRUD + watch"| GORCHCore

    EvalHubRole -->|"CRUD + watch"| EHCRDS
    EvalHubRole -->|"CRUD + watch"| EHCore
    EvalHubRole -->|"CRUD + watch"| EHRBAC

    JobMgrRole -->|"CRUD + watch"| JMKueue
    JobMgrRole -->|"list, get, watch"| JMScheduling
    JobMgrRole -->|"create, watch,<br/>update, patch"| JMEvents

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style ProxySA fill:#4a90e2,stroke:#333,color:#fff
    style TASRole fill:#f5a623,stroke:#333
    style LMESRole fill:#f5a623,stroke:#333
    style GORCHRole fill:#f5a623,stroke:#333
    style EvalHubRole fill:#f5a623,stroke:#333
    style NemoRole fill:#f5a623,stroke:#333
    style JobMgrRole fill:#f5a623,stroke:#333
    style ProxyRole fill:#f5a623,stroke:#333
    style TASCRDS fill:#7ed321,stroke:#333
    style TASApps fill:#7ed321,stroke:#333
    style TASCore fill:#7ed321,stroke:#333
    style TASMonitor fill:#7ed321,stroke:#333
    style TASRoutes fill:#7ed321,stroke:#333
    style TASKServe fill:#7ed321,stroke:#333
    style TASRBAC fill:#7ed321,stroke:#333
    style TASIstio fill:#7ed321,stroke:#333
    style LMESCRDS fill:#7ed321,stroke:#333
    style LMESPods fill:#7ed321,stroke:#333
    style LMESConfig fill:#7ed321,stroke:#333
    style GORCHCRDS fill:#7ed321,stroke:#333
    style GORCHKServe fill:#7ed321,stroke:#333
    style GORCHCore fill:#7ed321,stroke:#333
    style EHCRDS fill:#7ed321,stroke:#333
    style EHCore fill:#7ed321,stroke:#333
    style EHRBAC fill:#7ed321,stroke:#333
    style JMKueue fill:#7ed321,stroke:#333
    style JMScheduling fill:#7ed321,stroke:#333
    style JMEvents fill:#7ed321,stroke:#333
