graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Auth["system:authenticated<br/>(Group)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_TAS["tas-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LMES["lmes-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_GORCH["gorch-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_NEMO["nemo-guardrails-manager-<br/>rolebinding (cluster-scoped)"]
        CRB_EVALHUB["evalhub-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_PROXY["proxy-rolebinding<br/>(cluster-scoped)"]
        CRB_LEADER["leader-election-rolebinding<br/>(namespace-scoped)"]
        CRB_LMEVAL_USER["default-lmeval-user-<br/>rolebinding (cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_TAS["tas-manager-role"]
        CR_LMES["lmes-manager-role"]
        CR_GORCH["gorch-manager-role"]
        CR_NEMO["nemo-guardrails-<br/>manager-role"]
