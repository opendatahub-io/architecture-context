graph TD
    subgraph ServiceAccount["Service Account"]
        SA["trustyai-service-operator-<br/>controller-manager"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        TASBinding["tas-manager-<br/>rolebinding"]
        LMESBinding["lmes-manager-<br/>rolebinding"]
        GORCHBinding["gorch-manager-<br/>rolebinding"]
        EvalHubBinding["evalhub-manager-<br/>rolebinding"]
        NemoBinding["nemo-guardrails-manager-<br/>rolebinding"]
        JobMgrBinding["job-mgr-manager-<br/>rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        TASRole["tas-manager-role"]
        LMESRole["lmes-manager-role"]
        GORCHRole["gorch-manager-role"]
        EvalHubRole["evalhub-manager-role"]
        NemoRole["nemo-guardrails-<br/>manager-role"]
        JobMgrRole["job-mgr-manager-role"]
    end

    SA -->|bound via| TASBinding
    SA -->|bound via| LMESBinding
    SA -->|bound via| GORCHBinding
    SA -->|bound via| EvalHubBinding
    SA -->|bound via| NemoBinding
    SA -->|bound via| JobMgrBinding

    TASBinding -->|grants| TASRole
    LMESBinding -->|grants| LMESRole
    GORCHBinding -->|grants| GORCHRole
    EvalHubBinding -->|grants| EvalHubRole
    NemoBinding -->|grants| NemoRole
    JobMgrBinding -->|grants| JobMgrRole

    subgraph TASResources["TAS Resources"]
        TAS_CRD["trustyai.opendatahub.io<br/>TrustyAIService */*<br/>CRUD"]
        TAS_Apps["apps<br/>Deployments */*<br/>CRUD"]
        TAS_Core["core<br/>Services, Pods, ConfigMaps,<br/>Secrets, PVCs, SAs, Events<br/>CRUD"]
        TAS_Monitoring["monitoring.coreos.com<br/>ServiceMonitors<br/>list, watch, create"]
        TAS_Routes["route.openshift.io<br/>Routes<br/>CRUD"]
        TAS_KServe["serving.kserve.io<br/>InferenceServices */*<br/>list, watch, get, update, patch, delete"]
        TAS_RBAC["rbac.authorization.k8s.io<br/>ClusterRoleBindings<br/>CRUD"]
        TAS_Istio["networking.istio.io<br/>DestinationRules, VirtualServices<br/>CRUD"]
        TAS_CRDDef["apiextensions.k8s.io<br/>CRDs<br/>list, watch, get"]
    end

    subgraph LMESResources["LMES Resources"]
        LMES_CRD["trustyai.opendatahub.io<br/>LMEvalJobs */*<br/>CRUD"]
        LMES_Pods["core<br/>Pods, Pods/exec<br/>get, list, watch, create, delete"]
        LMES_Config["core<br/>ConfigMaps, Secrets<br/>get, watch, list"]
        LMES_PV["core<br/>PVs, PVCs<br/>list, get, watch, CRUD"]
    end

    subgraph GORCHResources["GORCH Resources"]
        GORCH_CRD["trustyai.opendatahub.io<br/>GuardrailsOrchestrators */*<br/>CRUD"]
        GORCH_KServe["serving.kserve.io<br/>ServingRuntimes, InferenceServices<br/>get, list, watch"]
        GORCH_Apps["apps<br/>Deployments */*<br/>CRUD"]
        GORCH_Core["core<br/>Services, Pods, ConfigMaps,<br/>Secrets, SAs, Events<br/>CRUD"]
        GORCH_Routes["route.openshift.io<br/>Routes<br/>CRUD"]
    end

    subgraph EvalHubResources["EvalHub Resources"]
        EH_CRD["trustyai.opendatahub.io<br/>EvalHubs, proxy, status */*<br/>CRUD"]
        EH_Apps["apps<br/>Deployments */*<br/>CRUD"]
        EH_Core["core<br/>Services, ConfigMaps, SAs,<br/>Namespaces, Events<br/>CRUD"]
        EH_RBAC["rbac.authorization.k8s.io<br/>ClusterRoleBindings, Roles,<br/>RoleBindings<br/>CRUD"]
        EH_Routes["route.openshift.io<br/>Routes<br/>CRUD"]
    end

    subgraph NemoResources["NemoGuardrails Resources"]
        NEMO_CRD["trustyai.opendatahub.io<br/>NemoGuardrails */*<br/>CRUD"]
        NEMO_Core["core<br/>ConfigMaps, Services,<br/>Secrets, SAs<br/>CRUD"]
        NEMO_Routes["route.openshift.io<br/>Routes<br/>CRUD"]
        NEMO_Apps["apps<br/>Deployments */*<br/>CRUD"]
        NEMO_RBAC["rbac.authorization.k8s.io<br/>ClusterRoleBindings<br/>CRUD"]
    end

    subgraph JobMgrResources["JobMgr Resources"]
        JM_Sched["scheduling.k8s.io<br/>PriorityClasses<br/>list, get, watch"]
        JM_Kueue["kueue.x-k8s.io<br/>Workloads */*,<br/>ResourceFlavors,<br/>WorkloadPriorityClasses<br/>CRUD"]
        JM_Events["core<br/>Events<br/>create, watch, update, patch"]
    end

    TASRole -->|manages| TAS_CRD
    TASRole -->|manages| TAS_Apps
    TASRole -->|manages| TAS_Core
    TASRole -->|manages| TAS_Monitoring
    TASRole -->|manages| TAS_Routes
    TASRole -->|manages| TAS_KServe
    TASRole -->|manages| TAS_RBAC
    TASRole -->|manages| TAS_Istio
    TASRole -->|reads| TAS_CRDDef

    LMESRole -->|manages| LMES_CRD
    LMESRole -->|manages| LMES_Pods
    LMESRole -->|reads| LMES_Config
    LMESRole -->|manages| LMES_PV

    GORCHRole -->|manages| GORCH_CRD
    GORCHRole -->|reads| GORCH_KServe
    GORCHRole -->|manages| GORCH_Apps
    GORCHRole -->|manages| GORCH_Core
    GORCHRole -->|manages| GORCH_Routes

    EvalHubRole -->|manages| EH_CRD
    EvalHubRole -->|manages| EH_Apps
    EvalHubRole -->|manages| EH_Core
    EvalHubRole -->|manages| EH_RBAC
    EvalHubRole -->|manages| EH_Routes

    NemoRole -->|manages| NEMO_CRD
    NemoRole -->|manages| NEMO_Core
    NemoRole -->|manages| NEMO_Routes
    NemoRole -->|manages| NEMO_Apps
    NemoRole -->|manages| NEMO_RBAC

    JobMgrRole -->|reads| JM_Sched
    JobMgrRole -->|manages| JM_Kueue
    JobMgrRole -->|manages| JM_Events

    %% Additional RBAC for managed services
    subgraph ProxyRBAC["Proxy RBAC (per TAS instance)"]
        ProxySA["{tas-name}-proxy<br/>ServiceAccount"]
        ProxyBinding["{tas-name}-{ns}-proxy-<br/>rolebinding"]
        ProxyRole["trustyai-service-operator-<br/>proxy-role"]
        ProxySA -->|bound via| ProxyBinding
        ProxyBinding -->|grants| ProxyRole
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style TASRole fill:#f5a623,stroke:#333,color:#333
    style LMESRole fill:#f5a623,stroke:#333,color:#333
    style GORCHRole fill:#f5a623,stroke:#333,color:#333
    style EvalHubRole fill:#f5a623,stroke:#333,color:#333
    style NemoRole fill:#f5a623,stroke:#333,color:#333
    style JobMgrRole fill:#f5a623,stroke:#333,color:#333

    style TAS_CRD fill:#7ed321,stroke:#333,color:#333
    style LMES_CRD fill:#7ed321,stroke:#333,color:#333
    style GORCH_CRD fill:#7ed321,stroke:#333,color:#333
    style EH_CRD fill:#7ed321,stroke:#333,color:#333
    style NEMO_CRD fill:#7ed321,stroke:#333,color:#333

    style ProxySA fill:#9b59b6,stroke:#333,color:#fff
    style ProxyRole fill:#e74c3c,stroke:#333,color:#fff
