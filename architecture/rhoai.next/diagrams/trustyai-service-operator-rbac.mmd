graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["trustyai-service-operator-<br/>controller-manager"]
        SA_TASProxy["&lt;tas-instance&gt;-proxy"]
        SA_EVService["&lt;evalhub-instance&gt;-service"]
        SA_AuthUsers["system:authenticated<br/>(all authenticated users)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_TAS["manager-rolebinding (TAS)"]
        CRB_LMES["manager-rolebinding (LMES)"]
        CRB_EvalHub["manager-rolebinding (EvalHub)"]
        CRB_GORCH["manager-rolebinding (GORCH)"]
        CRB_Nemo["manager-rolebinding (Nemo)"]
        CRB_JobMgr["manager-rolebinding (Job Mgr)"]
        CRB_Proxy["proxy-role-binding"]
        CRB_TASProxy["&lt;tas&gt;-proxy-rolebinding"]
        CRB_EVAuth["&lt;evalhub&gt;-auth-reviewer-crb"]
        CRB_LMEVAL["default-lmeval-user-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_TAS["manager-role (TAS)"]
        CR_LMES["manager-role (LMES)"]
        CR_EvalHub["manager-role (EvalHub)"]
        CR_GORCH["manager-role (GORCH)"]
        CR_Nemo["manager-role (NemoGuardrails)"]
        CR_JobMgr["manager-role (Job Mgr)"]
        CR_Proxy["proxy-role"]
        CR_NonAdmin["non-admin-lmeval-role"]
    end

    subgraph TAS_Resources["TAS API Resources"]
        TAS_CRD["trustyai.opendatahub.io<br/>TrustyAIService<br/>+ status + finalizers"]
        TAS_Apps["apps<br/>Deployments<br/>+ status + finalizers"]
        TAS_Core["core<br/>Pods, ConfigMaps, Secrets,<br/>ServiceAccounts, Services,<br/>Events, PVs, PVCs"]
        TAS_KServe["serving.kserve.io<br/>InferenceServices<br/>+ finalizers"]
        TAS_Istio["networking.istio.io<br/>DestinationRules,<br/>VirtualServices"]
        TAS_Route["route.openshift.io<br/>Routes"]
        TAS_Monitor["monitoring.coreos.com<br/>ServiceMonitors"]
        TAS_CRDApi["apiextensions.k8s.io<br/>CRDs"]
    end

    subgraph LMES_Resources["LMES API Resources"]
        LMES_CRD["trustyai.opendatahub.io<br/>LMEvalJobs<br/>+ status + finalizers"]
        LMES_Core["core<br/>Pods, Pods/exec,<br/>ConfigMaps, Secrets,<br/>PVs, PVCs"]
    end

    subgraph EvalHub_Resources["EvalHub API Resources"]
        EV_CRD["trustyai.opendatahub.io<br/>EvalHubs, EvalHubs/proxy,<br/>+ status + finalizers,<br/>status-events"]
        EV_HW["infrastructure.opendatahub.io<br/>HardwareProfiles"]
        EV_Kueue["kueue.x-k8s.io<br/>Workloads"]
        EV_Batch["batch<br/>Jobs"]
    end

    subgraph GORCH_Resources["GORCH API Resources"]
        GORCH_CRD["trustyai.opendatahub.io<br/>GuardrailsOrchestrators<br/>+ status + finalizers"]
        GORCH_KServe["serving.kserve.io<br/>ServingRuntimes,<br/>InferenceServices"]
    end

    subgraph Nemo_Resources["NemoGuardrails API Resources"]
        NEMO_CRD["trustyai.opendatahub.io<br/>NemoGuardrails<br/>+ status + finalizers"]
        NEMO_Istio["networking.istio.io<br/>EnvoyFilters"]
        NEMO_MCP["mcp.kuadrant.io<br/>MCPGatewayExtensions"]
        NEMO_GW["gateway.networking.k8s.io<br/>Gateways"]
    end

    subgraph JobMgr_Resources["Job Manager API Resources"]
        JM_Workloads["kueue.x-k8s.io<br/>Workloads<br/>+ status + finalizers"]
        JM_Flavors["kueue.x-k8s.io<br/>ResourceFlavors"]
        JM_Priority["kueue.x-k8s.io<br/>WorkloadPriorityClasses"]
    end

    subgraph Proxy_Resources["Proxy API Resources"]
        Proxy_Token["authentication.k8s.io<br/>TokenReviews"]
        Proxy_SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
    end

    subgraph NonAdmin_Resources["Non-Admin API Resources"]
        NA_LMEval["trustyai.opendatahub.io<br/>LMEvalJobs"]
    end

    %% SA → CRB connections
    SA_Operator -->|bound via| CRB_TAS
    SA_Operator -->|bound via| CRB_LMES
    SA_Operator -->|bound via| CRB_EvalHub
    SA_Operator -->|bound via| CRB_GORCH
    SA_Operator -->|bound via| CRB_Nemo
    SA_Operator -->|bound via| CRB_JobMgr
    SA_Operator -->|bound via| CRB_Proxy
    SA_TASProxy -->|bound via| CRB_TASProxy
    SA_EVService -->|bound via| CRB_EVAuth
    SA_AuthUsers -->|bound via| CRB_LMEVAL

    %% CRB → CR connections
    CRB_TAS -->|grants| CR_TAS
    CRB_LMES -->|grants| CR_LMES
    CRB_EvalHub -->|grants| CR_EvalHub
    CRB_GORCH -->|grants| CR_GORCH
    CRB_Nemo -->|grants| CR_Nemo
    CRB_JobMgr -->|grants| CR_JobMgr
    CRB_Proxy -->|grants| CR_Proxy
    CRB_TASProxy -->|grants| CR_Proxy
    CRB_EVAuth -->|grants| CR_Proxy
    CRB_LMEVAL -->|grants| CR_NonAdmin

    %% CR → Resources
    CR_TAS -->|"CRUD + watch"| TAS_CRD
    CR_TAS -->|"CRUD + watch"| TAS_Apps
    CR_TAS -->|"CRUD + watch"| TAS_Core
    CR_TAS -->|"get,list,watch,update,patch,delete"| TAS_KServe
    CR_TAS -->|"CRUD + watch"| TAS_Istio
    CR_TAS -->|"CRUD + watch"| TAS_Route
    CR_TAS -->|"list,watch,create"| TAS_Monitor
    CR_TAS -->|"list,watch,get"| TAS_CRDApi

    CR_LMES -->|"CRUD + watch"| LMES_CRD
    CR_LMES -->|"CRUD + watch"| LMES_Core

    CR_EvalHub -->|"CRUD + watch"| EV_CRD
    CR_EvalHub -->|"get,list"| EV_HW
    CR_EvalHub -->|"get,list,watch,patch"| EV_Kueue
    CR_EvalHub -->|"get,list,watch,patch,delete"| EV_Batch

    CR_GORCH -->|"CRUD + watch"| GORCH_CRD
    CR_GORCH -->|"get,list,watch"| GORCH_KServe

    CR_Nemo -->|"CRUD + watch"| NEMO_CRD
    CR_Nemo -->|"CRUD + watch"| NEMO_Istio
    CR_Nemo -->|"get,list,watch"| NEMO_MCP
    CR_Nemo -->|"get,list,watch"| NEMO_GW

    CR_JobMgr -->|"CRUD + watch"| JM_Workloads
    CR_JobMgr -->|"CRUD + watch"| JM_Flavors
    CR_JobMgr -->|"CRUD + watch"| JM_Priority

    CR_Proxy -->|"create"| Proxy_Token
    CR_Proxy -->|"create"| Proxy_SAR

    CR_NonAdmin -->|"CRUD + watch"| NA_LMEval

