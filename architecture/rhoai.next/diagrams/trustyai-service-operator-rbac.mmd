    style LMES_CRD fill:#7ed321,stroke:#333
    style LMES_Core fill:#7ed321,stroke:#333
    style GORCH_CRD fill:#7ed321,stroke:#333
    style GORCH_KServe fill:#7ed321,stroke:#333
    style GORCH_Apps fill:#7ed321,stroke:#333
    style NEMO_CRD fill:#7ed321,stroke:#333
    style NEMO_Core fill:#7ed321,stroke:#333
    style NEMO_Route fill:#7ed321,stroke:#333
    style EH_CRD fill:#7ed321,stroke:#333
    style EH_Batch fill:#7ed321,stroke:#333
    style EH_NS fill:#7ed321,stroke:#333
    style EH_RBAC fill:#7ed321,stroke:#333
