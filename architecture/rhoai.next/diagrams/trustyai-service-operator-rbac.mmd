graph TD
    subgraph ServiceAccounts["Service Accounts"]
        OpSA["trustyai-service-operator<br/>-controller-manager"]
        TASProxySA["{tas.Name}-proxy"]
        EHServiceSA["{evalhub.Name}-service"]
        GORCHServiceSA["{gorch.Name}-serviceaccount"]
        NemoServiceSA["{nemo.Name}-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        ManagerCRB["manager-rolebinding"]
        ProxyCRB["{tas}-proxy-rolebinding"]
        EHAuthCRB["{evalhub}-auth-reviewer-crb"]
        GORCHDelegCRB["{gorch}-auth-delegator"]
        NemoDelegCRB["{nemo}-auth-delegator"]
    end

    subgraph PrimaryClusterRole["ClusterRole: trustyai-service-operator-manager-role"]
        direction TB

        subgraph TASPerms["TAS Permissions"]
            TAS_CRD["trustyai.opendatahub.io<br/>trustyaiservices (+status,finalizers)<br/>CRUD"]
            TAS_Apps["apps: deployments (+status,finalizers)<br/>CRUD"]
            TAS_Core["core: pods, configmaps, pvcs,<br/>secrets, serviceaccounts, events<br/>CRUD"]
            TAS_KServe["serving.kserve.io<br/>inferenceservices (+finalizers)<br/>get,list,watch,update,patch,delete"]
            TAS_Route["route.openshift.io: routes<br/>CRUD"]
            TAS_Istio["networking.istio.io<br/>destinationrules, virtualservices<br/>CRUD"]
            TAS_Monitor["monitoring.coreos.com<br/>servicemonitors<br/>list,watch,create"]
            TAS_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>CRUD"]
            TAS_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>list,watch,get"]
        end

        subgraph LMESPerms["LMES Permissions"]
            LMES_CRD["trustyai.opendatahub.io<br/>lmevaljobs (+status,finalizers)<br/>CRUD"]
            LMES_Core["core: pods, pods/exec, configmaps,<br/>secrets, pvcs<br/>CRUD"]
        end

        subgraph EHPerms["EvalHub Permissions"]
            EH_CRD["trustyai.opendatahub.io<br/>evalhubs (+proxy,status,finalizers)<br/>status-events<br/>CRUD"]
            EH_HW["infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get,list"]
            EH_Kueue["kueue.x-k8s.io<br/>workloads<br/>get,list,watch,patch"]
        end

        subgraph GORCHPerms["GORCH Permissions"]
            GORCH_CRD["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>(+status,finalizers)<br/>CRUD"]
            GORCH_KServe["serving.kserve.io<br/>servingruntimes, inferenceservices<br/>get,list,watch"]
        end

        subgraph NemoPerms["NeMo Permissions"]
            NEMO_CRD["trustyai.opendatahub.io<br/>nemoguardrails (+status,finalizers)<br/>CRUD"]
            NEMO_Istio["networking.istio.io<br/>envoyfilters<br/>CRUD"]
            NEMO_MCP["mcp.kuadrant.io<br/>mcpgatewayextensions<br/>get,list,watch"]
            NEMO_GW["gateway.networking.k8s.io<br/>gateways<br/>get,list,watch"]
        end

        subgraph JobMgrPerms["Job Manager Permissions"]
            JM_Kueue["kueue.x-k8s.io<br/>workloads (+status,finalizers),<br/>resourceflavors,<br/>workloadpriorityclasses<br/>CRUD"]
            JM_Sched["scheduling.k8s.io<br/>priorityclasses<br/>list,get,watch"]
        end
    end

    subgraph AdditionalClusterRoles["Additional ClusterRoles"]
        AuthReviewerCR["evalhub-auth-reviewer-role<br/>authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews<br/>Verbs: create"]

        ProxyCR["proxy-role<br/>core: tokenreviews,<br/>subjectaccessreviews<br/>Verbs: create"]

        EHJobsWriterCR["evalhub-jobs-writer<br/>batch: jobs<br/>Verbs: create, delete"]

        EHJobConfigCR["evalhub-job-config<br/>core: configmaps<br/>Verbs: create, get, list"]

        EHHWReaderCR["evalhub-hw-profiles-reader<br/>infrastructure.opendatahub.io:<br/>hardwareprofiles<br/>Verbs: get, list"]

        EHProvidersCR["evalhub-providers-access<br/>trustyai.opendatahub.io:<br/>providers (virtual)<br/>Verbs: get, list, create"]

        EHCollectionsCR["evalhub-collections-access<br/>trustyai.opendatahub.io:<br/>collections (virtual)<br/>Verbs: get, list, create"]

        EHMLflowCR["evalhub-mlflow-access<br/>mlflow.kubeflow.org:<br/>experiments<br/>Verbs: CRUD"]

        NonAdminLMEvalCR["non-admin-lmeval-role<br/>trustyai.opendatahub.io:<br/>lmevaljobs<br/>Verbs: CRUD"]
    end

    %% Bindings
    OpSA -->|bound via| ManagerCRB
    ManagerCRB -->|grants| PrimaryClusterRole

    TASProxySA -->|bound via| ProxyCRB
    ProxyCRB -->|grants| ProxyCR

    EHServiceSA -->|bound via| EHAuthCRB
    EHAuthCRB -->|grants| AuthReviewerCR

    GORCHServiceSA -->|bound via| GORCHDelegCRB
    GORCHDelegCRB -->|grants| SystemAuthDelegator["system:auth-delegator<br/>(built-in)"]

    NemoServiceSA -->|bound via| NemoDelegCRB
    NemoDelegCRB -->|grants| SystemAuthDelegator

    %% EvalHub service additional bindings
    EHServiceSA -.->|namespace-scoped| EHJobsWriterCR
    EHServiceSA -.->|namespace-scoped| EHJobConfigCR
    EHServiceSA -.->|namespace-scoped| EHHWReaderCR

    %% Styling
    style OpSA fill:#4a90e2,stroke:#333,color:#fff
    style TASProxySA fill:#4a90e2,stroke:#333,color:#fff
    style EHServiceSA fill:#4a90e2,stroke:#333,color:#fff
    style GORCHServiceSA fill:#4a90e2,stroke:#333,color:#fff
    style NemoServiceSA fill:#4a90e2,stroke:#333,color:#fff

    style PrimaryClusterRole fill:#f5a623,stroke:#333
    style TASPerms fill:#fff3cd,stroke:#f5a623
    style LMESPerms fill:#fff3cd,stroke:#f5a623
    style EHPerms fill:#fff3cd,stroke:#f5a623
    style GORCHPerms fill:#fff3cd,stroke:#f5a623
    style NemoPerms fill:#fff3cd,stroke:#f5a623
    style JobMgrPerms fill:#fff3cd,stroke:#f5a623

    style AuthReviewerCR fill:#e8e8e8,stroke:#333
    style ProxyCR fill:#e8e8e8,stroke:#333
    style EHJobsWriterCR fill:#e8e8e8,stroke:#333
    style EHJobConfigCR fill:#e8e8e8,stroke:#333
    style EHHWReaderCR fill:#e8e8e8,stroke:#333
    style EHProvidersCR fill:#e8e8e8,stroke:#333
    style EHCollectionsCR fill:#e8e8e8,stroke:#333
    style EHMLflowCR fill:#e8e8e8,stroke:#333
    style NonAdminLMEvalCR fill:#7ed321,stroke:#333
    style SystemAuthDelegator fill:#e8e8e8,stroke:#333
