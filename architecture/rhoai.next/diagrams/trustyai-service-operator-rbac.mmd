    CRB_TAS -->|grants| CR_TAS
    CRB_LMES -->|grants| CR_LMES
    CRB_GORCH -->|grants| CR_GORCH
    CRB_NEMO -->|grants| CR_NEMO
    CRB_EH -->|grants| CR_EH
    CRB_PROXY -->|grants| CR_PROXY
    CRB_AUTH -->|grants| CR_AUTH
    CRB_LMEVAL_USER -->|grants| CR_LMEVAL_USER

    subgraph TAS_Resources["TAS Resources"]
        TAS_CRD["trustyai.opendatahub.io<br/>trustyaiservices[/*]"]
        TAS_Apps["apps<br/>deployments[/*]"]
