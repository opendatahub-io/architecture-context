graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["controller-manager<br/>(operator namespace)"]
        AuthGroup["system:authenticated<br/>(Group - all users)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        TASBinding["tas-manager-rolebinding"]
        LMESBinding["lmes-manager-rolebinding"]
        GORCHBinding["gorch-manager-rolebinding"]
        NEMOBinding["nemo-guardrails-manager-rolebinding"]
        EHBinding["evalhub-manager-rolebinding"]
        ProxyBinding["proxy-rolebinding"]
        AuthDelegator["manager-auth-delegator"]
        LMEvalUserBinding["default-lmeval-user-rolebinding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        TASRole["tas-manager-role"]
        LMESRole["lmes-manager-role"]
        GORCHRole["gorch-manager-role"]
        NEMORole["nemo-guardrails-manager-role"]
        EHRole["evalhub-manager-role"]
        ProxyRole["proxy-role"]
        LMEvalUserRole["lmeval-user-role"]
    end

    subgraph TASResources["TAS Resources"]
        TAS_CRD["trustyai.opendatahub.io<br/>trustyaiservices/*"]
        TAS_Apps["apps<br/>deployments/*"]
        TAS_Core["core<br/>services, pods, configmaps,<br/>secrets, serviceaccounts,<br/>pvcs, events"]
        TAS_Route["route.openshift.io<br/>routes"]
        TAS_KServe["serving.kserve.io<br/>inferenceservices/*"]
        TAS_Istio["networking.istio.io<br/>destinationrules,<br/>virtualservices"]
        TAS_Mon["monitoring.coreos.com<br/>servicemonitors"]
        TAS_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings"]
    end

    subgraph LMESResources["LMES Resources"]
        LMES_CRD["trustyai.opendatahub.io<br/>lmevaljobs/*"]
        LMES_Core["core<br/>pods, pods/exec,<br/>configmaps, secrets, pvcs"]
    end

    subgraph GORCHResources["GORCH Resources"]
        GORCH_CRD["trustyai.opendatahub.io<br/>guardrailsorchestrators/*"]
        GORCH_KServe["serving.kserve.io<br/>servingruntimes,<br/>inferenceservices"]
        GORCH_Apps["apps<br/>deployments/*"]
    end

    subgraph NEMOResources["NeMo Resources"]
        NEMO_CRD["trustyai.opendatahub.io<br/>nemoguardrails/*"]
        NEMO_Core["core<br/>configmaps, services,<br/>secrets, serviceaccounts"]
        NEMO_Route["route.openshift.io<br/>routes"]
    end

    subgraph EHResources["EvalHub Resources"]
        EH_CRD["trustyai.opendatahub.io<br/>evalhubs/*, status-events"]
        EH_Batch["batch<br/>jobs"]
        EH_NS["core<br/>namespaces"]
        EH_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>roles, rolebindings"]
    end

    subgraph ProxyResources["Proxy Resources"]
        Proxy_Auth["authentication.k8s.io<br/>tokenreviews"]
        Proxy_Authz["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph UserResources["User-Accessible Resources"]
        User_LMES["trustyai.opendatahub.io<br/>lmevaljobs"]
    end

    %% SA to Bindings
    SA -->|bound via| TASBinding
    SA -->|bound via| LMESBinding
    SA -->|bound via| GORCHBinding
    SA -->|bound via| NEMOBinding
    SA -->|bound via| EHBinding
    SA -->|bound via| ProxyBinding
    SA -->|bound via| AuthDelegator
    AuthGroup -->|bound via| LMEvalUserBinding

    %% Bindings to Roles
    TASBinding -->|grants| TASRole
    LMESBinding -->|grants| LMESRole
    GORCHBinding -->|grants| GORCHRole
    NEMOBinding -->|grants| NEMORole
    EHBinding -->|grants| EHRole
    ProxyBinding -->|grants| ProxyRole
    LMEvalUserBinding -->|grants| LMEvalUserRole

    %% Roles to Resources
    TASRole -->|"CRUD"| TAS_CRD
    TASRole -->|"CRUD"| TAS_Apps
    TASRole -->|"CRUD"| TAS_Core
    TASRole -->|"CRUD"| TAS_Route
    TASRole -->|"CRUD"| TAS_KServe
    TASRole -->|"CRUD"| TAS_Istio
    TASRole -->|"list,watch,create"| TAS_Mon
    TASRole -->|"CRUD"| TAS_RBAC

    LMESRole -->|"CRUD"| LMES_CRD
    LMESRole -->|"CRUD"| LMES_Core

    GORCHRole -->|"CRUD"| GORCH_CRD
    GORCHRole -->|"get,list,watch"| GORCH_KServe
    GORCHRole -->|"CRUD"| GORCH_Apps

    NEMORole -->|"CRUD"| NEMO_CRD
    NEMORole -->|"CRUD"| NEMO_Core
    NEMORole -->|"CRUD"| NEMO_Route

    EHRole -->|"CRUD"| EH_CRD
    EHRole -->|"get,list,watch,patch,delete"| EH_Batch
    EHRole -->|"get,list,watch"| EH_NS
    EHRole -->|"CRUD"| EH_RBAC

    ProxyRole -->|"create"| Proxy_Auth
    ProxyRole -->|"create"| Proxy_Authz

    LMEvalUserRole -->|"CRUD+watch"| User_LMES

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style AuthGroup fill:#e8e8e8,stroke:#333

    style TASRole fill:#f5a623,stroke:#333
    style LMESRole fill:#f5a623,stroke:#333
    style GORCHRole fill:#f5a623,stroke:#333
    style NEMORole fill:#f5a623,stroke:#333
    style EHRole fill:#f5a623,stroke:#333
    style ProxyRole fill:#f5a623,stroke:#333
    style LMEvalUserRole fill:#f5a623,stroke:#333

