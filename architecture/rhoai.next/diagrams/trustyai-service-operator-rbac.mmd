        CR_PROXY["proxy-role"]
        CR_LEADER["leader-election-role"]
        CR_LMEVAL_USER["lmeval-user-role"]
    end

    subgraph TAS_Resources["TAS Controller Resources"]
        TAS_R1["trustyai.opendatahub.io<br/>trustyaiservices/*"]
        TAS_R2["apps<br/>deployments/*"]
        TAS_R3["core<br/>services, pods, configmaps,<br/>pvcs, secrets, sa, events"]
