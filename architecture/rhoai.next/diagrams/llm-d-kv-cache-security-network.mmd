graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Route - Edge TLS)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination<br/>No Auth"]
    end

    subgraph Cluster["CLUSTER INTERNAL (No Encryption)"]
        direction TB

        subgraph Pod["KV-Cache Manager Pod<br/>NS: hc4ai-operator<br/>SA: operator-controller-manager"]
            direction LR
            Manager["KV-Cache Manager<br/>8080/TCP HTTP (scoring+metrics)<br/>50051/TCP gRPC (IndexerService)<br/>No Auth, No Encryption"]
            Tokenizer["UDS Tokenizer Sidecar<br/>8082/TCP HTTP (health)<br/>UDS: /tmp/tokenizer/*.socket<br/>No Auth, No Encryption"]
            Manager ---|"gRPC over UDS<br/>shared emptyDir"| Tokenizer
        end

        subgraph InternalServices["Cluster Services"]
            vLLM["vLLM Pods<br/>ZMQ PUB 5557/TCP<br/>No Encryption, No Auth"]
            K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS, SA Token Auth"]
            Redis["Redis / Valkey (optional)<br/>6379/TCP RESP<br/>No Encryption, No Auth"]
            OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No Encryption, No Auth"]
            Prom["Prometheus<br/>Scrapes 8080/TCP<br/>No Auth"]
        end

        subgraph Storage["FILESYSTEM (Shared PVC)"]
            SharedPVC["Shared Storage NFS/PVC<br/>POSIX Filesystem<br/>POSIX Permissions<br/>No Encryption"]
            Evictor["PVC Evictor Pod<br/>No Network Interfaces<br/>N+2 Process Model<br/>85%/70% Thresholds"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        ModelScope["ModelScope API (optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| Route
    Route -->|"HTTP/8080<br/>Plaintext<br/>Post-TLS"| Manager

    %% Cluster internal flows
    vLLM -->|"ZMQ SUB/5557<br/>Plaintext<br/>No Auth"| Manager
    Manager -->|"Pod Watch/443<br/>TLS<br/>SA Token"| K8sAPI
    Manager -->|"RESP/6379<br/>Plaintext<br/>No Auth"| Redis
    Manager -->|"gRPC/4317<br/>Plaintext<br/>No Auth"| OTLP
    Prom -->|"HTTP/8080<br/>Plaintext<br/>No Auth"| Manager

    %% Storage flows
    Manager -->|"POSIX I/O + GDS<br/>No Encryption<br/>POSIX Perms"| SharedPVC
    Evictor -->|"scandir + rm<br/>POSIX Perms"| SharedPVC

    %% External service flows
    Tokenizer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| HF
    Tokenizer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| ModelScope

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class Manager,Tokenizer pod
    class vLLM,K8sAPI,Redis,OTLP,Prom cluster
    class SharedPVC,Evictor storage
    class HF,ModelScope externalservice
