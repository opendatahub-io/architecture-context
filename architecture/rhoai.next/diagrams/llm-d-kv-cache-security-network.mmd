graph TB
    subgraph External["EXTERNAL SERVICES (Untrusted)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        ModelScope["ModelScope<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Cluster["CLUSTER INTERNAL (No Service Mesh)"]
        direction TB

        subgraph EPPPod["Pod: llm-d-router (EPP)<br/>SA: operator-controller-manager"]
            direction TB

            subgraph IndexerLib["KV-Cache Indexer Library (embedded)"]
                ZMQSub["ZMQ Subscriber<br/>Connects to 5557/TCP<br/>ZMQ SUB<br/>⚠️ No encryption"]
                IndexerCore["Indexer Core<br/>ScoreTokens() API<br/>In-process"]
            end

            subgraph TokenizerSidecar["Sidecar: UDS Tokenizer"]
                GRPCServer["gRPC Server<br/>UDS: /tmp/tokenizer/<br/>tokenizer-uds.socket<br/>No encryption<br/>Socket mode 0700"]
                HealthProbe["Health Probe<br/>8082/TCP HTTP<br/>No encryption<br/>No auth"]
            end
        end

        subgraph VLLMFleet["vLLM/SGLang Pod Fleet"]
            direction TB
            VLLMEngine["vLLM/SGLang Engine<br/>5557/TCP ZMQ PUB<br/>⚠️ No encryption<br/>⚠️ No auth"]
            FSBackendPlugin["llmd-fs-backend Plugin<br/>(loaded in-process)<br/>CUDA transfers"]
        end

        subgraph StorageZone["Storage"]
            SharedStorage["Shared Storage<br/>NFS/PVC<br/>POSIX filesystem<br/>File permissions"]
        end

        subgraph EvictorPod["Pod: PVC Evictor"]
            EvictorProc["Evictor Processes<br/>N crawlers + activator + deleter<br/>No network services"]
        end

        subgraph OptionalServices["Optional Services"]
            Redis["Redis / Valkey<br/>6379/TCP<br/>Redis protocol<br/>TLS optional (rediss://)<br/>Password auth"]
            OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>TLS optional<br/>No auth"]
            Prometheus["Prometheus<br/>HTTP scrape<br/>No encryption"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    %% Flows - EPP Pod
    GRPCServer -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| HFHub
    GRPCServer -.->|HTTPS/443<br/>TLS 1.2+| ModelScope

    %% ZMQ Event Flow
    VLLMEngine -->|ZMQ PUB/5557<br/>⚠️ Plaintext<br/>⚠️ No auth| ZMQSub

    %% Storage Flows
    FSBackendPlugin -->|POSIX I/O<br/>File permissions| SharedStorage
    EvictorProc -->|POSIX I/O<br/>File permissions| SharedStorage

    %% Optional Flows
    IndexerCore -.->|Redis/6379<br/>TLS optional<br/>Password| Redis
    IndexerCore -.->|gRPC/4317<br/>TLS optional| OTLP
    IndexerCore -.->|HTTP scrape| Prometheus
    ZMQSub -.->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class HFHub,ModelScope external
    class GRPCServer,HealthProbe,IndexerCore internal
    class ZMQSub,VLLMEngine warning
    class SharedStorage storage
    class Redis,OTLP,Prometheus optional
    class K8sAPI internal
    class EvictorProc internal
    class FSBackendPlugin internal
