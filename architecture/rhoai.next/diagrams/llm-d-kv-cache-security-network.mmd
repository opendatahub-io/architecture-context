graph TB
    subgraph External["EXTERNAL SERVICES (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
        ModelScope["ModelScope<br/>modelscope.cn<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(optional)"]
        RedisExt["Redis / Valkey<br/>6379/TCP<br/>Optional TLS (rediss://)<br/>No Auth<br/>(optional)"]
    end

    subgraph KubeControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Namespace Scope)"]
        direction TB

        subgraph EPPPod["EPP Scheduler Pod"]
            direction TB
            EPP["llm-d Inference Scheduler<br/>(EPP Host Process)"]

            subgraph EmbeddedLib["Embedded Go Library (no network hop)"]
                Indexer["KV-Cache Indexer<br/>pkg/kvcache"]
                EventPool["KV-Events Pool<br/>pkg/kvevents<br/>ZMQ SUB 5557/TCP"]
                TokenPool["Tokenization Pool<br/>pkg/tokenization"]
            end

            UDSTok["UDS Tokenizer Sidecar<br/>Python gRPC<br/>UDS: /tmp/tokenizer/*.socket<br/>Health: 8082/TCP HTTP<br/>Perms: 0o700"]

            EPP -->|in-process<br/>Go API| Indexer
            TokenPool -->|gRPC over UDS<br/>No Encryption<br/>Filesystem ACL| UDSTok
        end

        subgraph InferencePods["vLLM / SGLang Inference Pods"]
            direction TB
            VLLMEngine["vLLM/SGLang Engine<br/>ZMQ PUB 5557/TCP<br/>msgpack, No Encryption<br/>No Auth"]
            FSBackend["llmd_fs_backend<br/>OffloadingConnector<br/>C++/CUDA"]
            PVCEvictor["PVC Evictor Sidecar<br/>Disk space management<br/>85% trigger / 70% target"]
        end

        SharedStorage["Shared Storage<br/>NFS / PVC<br/>POSIX I/O<br/>Mount: /kv-cache"]
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No Encryption<br/>No Auth"]
        Prometheus["Prometheus<br/>HTTP metrics scrape<br/>kvcache namespace"]
    end

    %% Network Flows
    VLLMEngine -->|"ZMQ msgpack/5557<br/>⚠️ No Encryption<br/>⚠️ No Auth"| EventPool
    UDSTok -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub
    UDSTok -.->|"HTTPS/443<br/>TLS 1.2+<br/>(optional)"| ModelScope
    Indexer -.->|"Redis/6379<br/>Optional TLS<br/>(optional)"| RedisExt
    EventPool -.->|"HTTPS/443<br/>Bearer Token<br/>(optional pod watch)"| K8sAPI
    FSBackend -->|"POSIX I/O<br/>No Encryption"| SharedStorage
    PVCEvictor -->|"POSIX I/O<br/>Filesystem perms"| SharedStorage
    Indexer -.->|"gRPC/4317<br/>(optional)"| OTLP
    Indexer -.->|"HTTP metrics<br/>(optional)"| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e8e8ff,stroke:#666,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#f0f0f0,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class HFHub,ModelScope,RedisExt external
    class K8sAPI controlplane
    class EPP,Indexer,EventPool,TokenPool,UDSTok internal
    class VLLMEngine,FSBackend,PVCEvictor warning
    class SharedStorage warning
    class OTLP,Prometheus observability
