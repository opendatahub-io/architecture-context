graph TB
    subgraph External["EXTERNAL SERVICES (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF Token (optional)"]
        ModelScope["ModelScope (optional)<br/>modelscope.cn<br/>443/TCP HTTPS TLS 1.2+"]
        OTLPCollector["OTLP Collector (optional)<br/>4317/TCP gRPC<br/>No encryption"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Bearer"]
        Redis["Redis / Valkey (optional)<br/>6379/TCP<br/>Optional TLS (rediss://)"]
        Prometheus["Prometheus (optional)<br/>HTTP scrape<br/>No encryption"]
    end

    subgraph InferenceNS["INFERENCE NAMESPACE (Pod-to-Pod)"]
        direction TB

        subgraph InferencePods["vLLM / SGLang Inference Pods"]
            vLLMEngine["vLLM/SGLang Engine<br/>ZMQ PUB :5557/TCP"]
        end

        subgraph EPPPod["EPP Pod (Inference Scheduler)"]
            ZMQSub["ZMQ Subscriber<br/>SUB :5557/TCP<br/>⚠️ No encryption"]
            IndexerLib["KV-Cache Indexer<br/>(embedded Go library)"]
            TokenClient["Tokenization Client<br/>gRPC over UDS"]
            TokenizerSidecar["UDS Tokenizer Sidecar<br/>Image: odh-llm-d-kv-cache-rhel9<br/>Health: :8082/TCP HTTP<br/>gRPC: UDS socket (0o700)"]

            ZMQSub -->|in-process<br/>Go channels| IndexerLib
            IndexerLib -->|in-process| TokenClient
            TokenClient -->|UDS socket<br/>/tmp/tokenizer/tokenizer-uds.socket<br/>gRPC, no encryption<br/>FS permissions 0o700| TokenizerSidecar
        end

        subgraph vLLMPod["vLLM Pod (with sidecars)"]
            FSBackend["llmd_fs_backend<br/>(OffloadingConnector plugin)<br/>C++/CUDA"]
            PVCEvictor["PVC Evictor<br/>N crawlers + activator + deleter<br/>Threshold: 85% → 70%"]
            SharedPVC["Shared Storage PVC<br/>/tmp/shared-kv"]

            FSBackend -->|POSIX I/O<br/>No encryption| SharedPVC
            PVCEvictor -->|evicts old blocks<br/>POSIX I/O| SharedPVC
        end

        subgraph HelmServices["KV-Cache Manager (Helm)"]
            KVHTTP["HTTP Service<br/>:8080/TCP ClusterIP"]
            KVZMQ["ZMQ Service<br/>:5557/TCP ClusterIP"]
        end
    end

    %% Network flows
    vLLMEngine -->|ZMQ PUB/SUB 5557/TCP<br/>msgpack, ⚠️ NO encryption<br/>⚠️ NO authentication| ZMQSub
    TokenizerSidecar -->|HTTPS 443/TCP<br/>TLS 1.2+, HF Token| HFHub
    TokenizerSidecar -.->|HTTPS 443/TCP<br/>TLS 1.2+| ModelScope
    IndexerLib -.->|Redis 6379/TCP<br/>Optional TLS| Redis
    IndexerLib -.->|HTTPS 443/TCP<br/>Bearer token| K8sAPI
    IndexerLib -.->|gRPC 4317/TCP| OTLPCollector
    IndexerLib -.->|HTTP metrics| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef epp fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class HFHub,ModelScope,OTLPCollector external
    class K8sAPI,Redis,Prometheus cluster
    class vLLMEngine inference
    class ZMQSub warning
    class IndexerLib,TokenClient,TokenizerSidecar epp
    class FSBackend,PVCEvictor,SharedPVC storage
    class KVHTTP,KVZMQ inference
