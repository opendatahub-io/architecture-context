graph TB
    subgraph Cluster["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph KVCachePod["KV-Cache Manager Pod"]
            direction TB
            KVManager["KV-Cache Manager<br/>(Go)<br/>5557/TCP ZMQ SUB<br/>8080/TCP HTTP"]
            UDSTokenizer["UDS Tokenizer Sidecar<br/>(Python)<br/>8082/TCP HTTP health<br/>UDS gRPC: /tmp/tokenizer/*.socket"]
            UDSVolume["Shared emptyDir<br/>/tmp/tokenizer<br/>Permissions: 0o700"]

            KVManager -->|"gRPC over UDS<br/>No encryption<br/>Filesystem auth"| UDSVolume
            UDSVolume -->|"gRPC over UDS<br/>No encryption<br/>Filesystem auth"| UDSTokenizer
        end

        subgraph vLLMPods["vLLM / SGLang Pods"]
            direction TB
            vLLM["vLLM Pod<br/>8000/TCP HTTP<br/>5557/TCP ZMQ PUB"]
            FSBackend["llmd-fs-backend<br/>(in-process plugin)<br/>POSIX / GDS / NIXL"]
            PVCEvictor["PVC Evictor<br/>(sidecar/DaemonSet)"]
        end

        subgraph OptionalServices["Optional Services"]
            Redis["Redis / Valkey<br/>6379/TCP Redis protocol<br/>No encryption (default)<br/>Optional URL auth"]
        end

        subgraph ControlPlane["Kubernetes Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        end

        subgraph Observability["Observability (Optional)"]
            OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No encryption<br/>No auth"]
        end
    end

    subgraph External["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        S3["S3-Compatible Store<br/>(Optional - NIXL)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS-style credentials"]
    end

    %% Internal flows
    vLLM -->|"ZMQ PUB/SUB 5557/TCP<br/>No encryption<br/>No auth<br/>Payload: msgpack"| KVManager
    KVManager -.->|"Redis 6379/TCP<br/>No encryption (default)<br/>Optional auth"| Redis
    KVManager -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>SA bearer token"| K8sAPI
    KVManager -.->|"gRPC 4317/TCP<br/>No encryption"| OTLP
    FSBackend -->|"POSIX I/O<br/>No network"| PVCEvictor

    %% External flows
    UDSTokenizer -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    FSBackend -.->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>AWS credentials"| S3

    %% Embedding
    EPP["llm-d EPP<br/>(Inference Scheduler)"] -->|"Go API (in-process)<br/>Library embedding<br/>No network"| KVManager

    %% Styling
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef host fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class KVManager,UDSTokenizer,UDSVolume pod
    class vLLM,FSBackend,PVCEvictor pod
    class Redis optional
    class K8sAPI controlplane
    class OTLP observability
    class HFHub,S3 external
    class EPP host
