graph LR
    ai4rag["ai4rag<br/><i>RAG Optimization Engine</i><br/>(Python Library)"]

    %% External Python Dependencies (Required)
    ai4rag -->|"document handling<br/>text splitting"| LangChain["langchain ~1.1.3<br/>+ langchain-chroma ~1.1.0<br/>+ langchain-text-splitters ~1.1.0"]
    ai4rag -->|"OGX API client<br/>(embeddings, vector stores, LLM)"| OgxClient["ogx-client ~1.0.0"]
    ai4rag -->|"DataFrame manipulation<br/>results processing"| Pandas["pandas 2.2.*"]
    ai4rag -->|"data validation<br/>payload schemas"| Pydantic["pydantic 2.11.*"]
    ai4rag -->|"GAM optimizer<br/>(Bayesian-style HPO)"| PyGAM["pygam ~0.12.0"]
    ai4rag -->|"label encoding<br/>(categorical params)"| Sklearn["scikit-learn 1.8.*"]
    ai4rag -->|"RAG evaluation metrics<br/>(correctness, faithfulness)"| Unitxt["unitxt ~1.26.1"]

    %% Internal Platform Dependencies
    ai4rag -->|"HTTPS / API Key<br/>embeddings, vector stores,<br/>chat completions"| OGX["OGX Server"]
    ai4rag -.->|"KFPEventHandler<br/>(in-process Python API)"| KFP["Kubeflow Pipelines"]

    %% Integration Points (consumers)
    KFPStep["KFP Pipeline Step<br/>(consuming service)"] -->|"imports & invokes"| ai4rag
    Notebook["Jupyter Notebook<br/>(local development)"] -->|"imports & invokes"| ai4rag

    %% Transitive: ogx-client depends on httpx for HTTP
    OgxClient -->|"HTTP transport"| httpx["httpx"]

    %% Styling
    style ai4rag fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Python libraries
    style LangChain fill:#999,stroke:#333,color:#fff
    style OgxClient fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style PyGAM fill:#999,stroke:#333,color:#fff
    style Sklearn fill:#999,stroke:#333,color:#fff
    style Unitxt fill:#999,stroke:#333,color:#fff
    style httpx fill:#bbb,stroke:#333

    %% Internal RHOAI platform
    style OGX fill:#7ed321,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff

    %% Consumers
    style KFPStep fill:#f5a623,stroke:#333,color:#fff
    style Notebook fill:#f5a623,stroke:#333,color:#fff
