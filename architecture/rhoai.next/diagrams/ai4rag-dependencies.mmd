graph LR
    ai4rag["ai4rag<br/>RAG Optimization Library<br/>v0.5.5"]

    %% Core Dependencies (Required)
    ai4rag -->|"document abstraction,<br/>text splitting"| langchain["langchain ~1.1.3"]
    ai4rag -->|"ChromaDB wrapper"| langchainchroma["langchain-chroma ~1.1.0"]
    ai4rag -->|"recursive/char/token<br/>text splitting"| langchainsplitters["langchain-text-splitters ~1.1.0"]
    ai4rag -->|"models, embeddings,<br/>vector stores"| llamastackclient["llama-stack-client ~0.7.1"]
    ai4rag -->|"alternative backend<br/>chat + embeddings"| openai["openai 2.23.*"]
    ai4rag -->|"benchmark data,<br/>results handling"| pandas["pandas 2.2.*"]
    ai4rag -->|"parameter validation,<br/>constraints"| pydantic["pydantic 2.11.*"]
    ai4rag -->|"GAM surrogate model<br/>for HPO"| pygam["pygam ~0.12.0"]
    ai4rag -->|"categorical encoding<br/>for GAM"| sklearn["scikit-learn 1.8.*"]
    ai4rag -->|"RAG evaluation<br/>metrics"| unitxt["unitxt ~1.26.1"]

    %% Optional Dependencies
    ai4rag -.->|"document conversion<br/>(dev only)"| docling["docling (latest)"]
    ai4rag -.->|"HTTP timeout config<br/>for LS embeddings"| httpx["httpx (latest)"]

    %% External Services (Runtime)
    ai4rag ==>|"REST API<br/>HTTP/HTTPS<br/>API Key"| LlamaStack["Llama Stack Server<br/>(Runtime Service)"]
    ai4rag ==>|"REST API<br/>HTTPS/TLS<br/>API Key"| OpenAIAPI["OpenAI-Compatible API<br/>(Runtime Service)"]

    %% Integration Points
    KFP["Kubeflow Pipelines"] -.->|"consumes metadata<br/>via KFPEventHandler"| ai4rag

    %% Styling
    style ai4rag fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

