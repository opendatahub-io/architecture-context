graph LR
    ai4rag["ai4rag<br/>RAG Optimization Engine<br/>(Python Library)"]

    %% Internal RHOAI Dependencies
    ai4rag -->|"REST API<br/>HTTPS/TLS<br/>API Key"| OGX["OGX Server<br/>(chat, embeddings,<br/>vector stores)"]

    %% Core External Dependencies (Required)
    ai4rag -->|"document splitting"| LangChain["langchain ~1.1.3<br/>+ langchain-text-splitters"]
    ai4rag -->|"in-memory vector store"| LangChainChroma["langchain-chroma ~1.1.0<br/>(ChromaDB)"]
    ai4rag -->|"OGX client"| OGXClient["ogx-client ~1.0.0<br/>(REST client)"]
    ai4rag -->|"HPO (GAM)"| PyGAM["pygam ~0.12.0"]
    ai4rag -->|"RAG metrics"| Unitxt["unitxt ~1.26.1"]
    ai4rag -->|"data validation"| Pydantic["pydantic 2.11.*"]
    ai4rag -->|"data management"| Pandas["pandas 2.2.*"]
    ai4rag -->|"label encoding"| Sklearn["scikit-learn 1.8.*"]

    %% Integration Points (Consumers)
    KFP["Kubeflow Pipelines<br/>(KFPEventHandler)"] -.->|"consumes as<br/>pipeline component"| ai4rag

    %% Transitive dependencies
    OGXClient -->|"HTTP transport"| httpx["httpx<br/>(TLS via system trust store)"]

    %% Styling
    style ai4rag fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OGX fill:#7ed321,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff
    style LangChain fill:#999,stroke:#333,color:#fff
    style LangChainChroma fill:#999,stroke:#333,color:#fff
    style OGXClient fill:#999,stroke:#333,color:#fff
    style PyGAM fill:#999,stroke:#333,color:#fff
    style Unitxt fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style Sklearn fill:#999,stroke:#333,color:#fff
    style httpx fill:#ccc,stroke:#333
