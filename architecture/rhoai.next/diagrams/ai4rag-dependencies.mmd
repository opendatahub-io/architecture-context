    style llamastackclient fill:#7ed321,stroke:#333
    style openai fill:#7ed321,stroke:#333
    style pandas fill:#7ed321,stroke:#333
    style pydantic fill:#7ed321,stroke:#333
    style pygam fill:#7ed321,stroke:#333
    style sklearn fill:#7ed321,stroke:#333
    style unitxt fill:#7ed321,stroke:#333

