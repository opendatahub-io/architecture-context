graph LR
    ai4rag["ai4rag<br/><i>RAG Optimization Engine</i>"]

    %% External Dependencies (Python packages)
    ai4rag -->|"RAG framework<br/>document abstraction"| LangChain["langchain ~1.1.3"]
    ai4rag -->|"in-memory vector store<br/>(MPS phase)"| LangChainChroma["langchain-chroma ~1.1.0"]
    ai4rag -->|"document chunking<br/>RecursiveCharacterTextSplitter"| LangChainSplitters["langchain-text-splitters ~1.1.0"]
    ai4rag -->|"REST API client<br/>(embeddings, chat, vectors)"| OGXClient["ogx-client ~1.0.0"]
    ai4rag -->|"benchmark data<br/>results processing"| Pandas["pandas 2.2.*"]
    ai4rag -->|"data validation<br/>model parameters"| Pydantic["pydantic 2.11.*"]
    ai4rag -->|"GAM surrogate model<br/>for HPO"| PyGAM["pygam ~0.12.0"]
    ai4rag -->|"categorical encoding<br/>LabelEncoder"| Scikit["scikit-learn 1.8.*"]
    ai4rag -->|"RAG evaluation metrics<br/>(faithfulness, correctness)"| Unitxt["unitxt ~1.26.1"]

    %% Internal Platform Dependencies
    ai4rag -->|"model inference<br/>embeddings, vectors"| OGXServer["OGX Server<br/><i>Internal Platform</i>"]

