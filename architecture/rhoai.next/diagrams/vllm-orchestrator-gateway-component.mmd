graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)<br/>Port 8090/TCP"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>/{route-name}/v1/chat/completions"]
        DetectorInjector["Detector Injector<br/>Injects detector specs into request"]
        ProxyClient["Proxy Client<br/>(reqwest + native-tls)"]
        StreamProcessor["SSE Stream Processor<br/>(futures + axum SSE)"]
        FallbackHandler["Fallback Handler<br/>Replaces content on detection"]
        TLSConfig["mTLS Configuration<br/>(openssl PKCS#12)"]

        ConfigLoader -->|"loads routes &<br/>detector pipelines"| RouteHandler
        RouteHandler -->|"POST request"| DetectorInjector
        DetectorInjector -->|"augmented payload"| ProxyClient
        ProxyClient -->|"non-streaming response"| FallbackHandler
        ProxyClient -->|"SSE stream"| StreamProcessor
        StreamProcessor -->|"detection in chunk"| FallbackHandler
        TLSConfig -->|"client identity"| ProxyClient
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP<br/>Authorization header"| RouteHandler

    ProxyClient -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP or HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"indirect"| Detectors["Detector Services<br/>(e.g., regex-detector)"]
    Orchestrator -->|"indirect"| vLLM["vLLM Model Server<br/>(e.g., Qwen2.5)"]

    ConfigMap["ConfigMap<br/>config.yaml"] -->|"volume mount"| ConfigLoader
    TLSSecrets["TLS Secrets<br/>/etc/tls/private/<br/>/etc/tls/ca/"] -->|"volume mount"| TLSConfig

    FallbackHandler -->|"response<br/>(original or fallback)"| Client

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style DetectorInjector fill:#4a90e2,stroke:#333,color:#fff
    style ProxyClient fill:#4a90e2,stroke:#333,color:#fff
    style StreamProcessor fill:#4a90e2,stroke:#333,color:#fff
    style FallbackHandler fill:#4a90e2,stroke:#333,color:#fff
    style TLSConfig fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style Detectors fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#f5a623,stroke:#333
    style TLSSecrets fill:#f5a623,stroke:#333
