graph TB
    subgraph "vllm-orchestrator-gateway (Rust/axum)"
        direction TB
        Router["axum Router<br/>Route Registration"]
        ProxyHandler["Proxy Handler<br/>Detector Injection"]
        StreamProcessor["SSE Stream Processor<br/>Chunk-by-chunk filtering"]
        FallbackChecker["Fallback Checker<br/>Detection replacement"]
        ConfigLoader["Config Loader<br/>YAML parsing"]
        TLSBuilder["TLS Client Builder<br/>mTLS identity (PKCS#12)"]

        ConfigLoader -->|"loads routes &<br/>detector definitions"| Router
        Router -->|"routes to"| ProxyHandler
        ProxyHandler -->|"streaming path"| StreamProcessor
        ProxyHandler -->|"non-streaming path"| FallbackChecker
        StreamProcessor -->|"per-chunk"| FallbackChecker
        ConfigLoader -->|"TLS config"| TLSBuilder
        TLSBuilder -->|"HTTP client"| ProxyHandler
    end

    Client["API Client"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| Router

    ProxyHandler -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS (optional mTLS)"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"invokes"| Detectors["Content Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -->|"routes to"| vLLM["vLLM Model Server"]

    ConfigFile["YAML Config File<br/>/app/config/config.yaml"] -->|"mounted"| ConfigLoader
    TLSSecrets["TLS Secrets<br/>/etc/tls/private/<br/>/etc/tls/ca/"] -->|"volume mount"| TLSBuilder

    style Router fill:#4a90e2,color:#fff
    style ProxyHandler fill:#4a90e2,color:#fff
    style StreamProcessor fill:#4a90e2,color:#fff
    style FallbackChecker fill:#4a90e2,color:#fff
    style ConfigLoader fill:#4a90e2,color:#fff
    style TLSBuilder fill:#4a90e2,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Orchestrator fill:#7ed321,color:#fff
    style Detectors fill:#7ed321,color:#fff
    style vLLM fill:#7ed321,color:#fff
    style ConfigFile fill:#f5a623,color:#fff
    style TLSSecrets fill:#f5a623,color:#fff
