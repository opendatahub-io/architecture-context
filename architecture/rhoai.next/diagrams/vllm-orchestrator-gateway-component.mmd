graph TB
    subgraph "vllm-orchestrator-gateway (Rust/axum)"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>HTTP Server :8090"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>/{route_name}/v1/chat/completions"]
        StreamHandler["SSE Stream Handler<br/>(futures::StreamExt)"]
        DetectorInjector["Detector Injector<br/>Injects detector config into payload"]
        DetectionChecker["Detection Checker<br/>Inspects response for detections"]
        FallbackHandler["Fallback Handler<br/>Substitutes fallback_message"]
        TLSClient["TLS Client Builder<br/>(openssl + native-tls)"]
        OrchestratorClient["Orchestrator HTTP Client<br/>(reqwest)"]

        ConfigLoader -->|"loads config.yaml<br/>at startup"| RouteHandler
        RouteHandler -->|"non-streaming"| DetectorInjector
        RouteHandler -->|"streaming"| StreamHandler
        StreamHandler --> DetectorInjector
        DetectorInjector --> OrchestratorClient
        OrchestratorClient -->|"response"| DetectionChecker
        DetectionChecker -->|"detections found"| FallbackHandler
        TLSClient -->|"configures mTLS"| OrchestratorClient
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| Gateway
    Gateway --> RouteHandler

    OrchestratorClient -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"invokes"| Detectors["Guardrails Detectors<br/>(e.g., regex-language)"]
    Orchestrator -->|"inference"| vLLM["vLLM / Model Server"]

    subgraph "TLS Certificates (Optional)"
        TLSCert["/etc/tls/private/tls.crt"]
        TLSKey["/etc/tls/private/tls.key"]
        CACert["/etc/tls/ca/service-ca.crt"]
    end

    TLSCert --> TLSClient
    TLSKey --> TLSClient
    CACert --> TLSClient

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style StreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style DetectorInjector fill:#4a90e2,stroke:#333,color:#fff
    style DetectionChecker fill:#4a90e2,stroke:#333,color:#fff
    style FallbackHandler fill:#4a90e2,stroke:#333,color:#fff
    style TLSClient fill:#4a90e2,stroke:#333,color:#fff
    style OrchestratorClient fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f5f5f5,stroke:#999
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style TLSKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
