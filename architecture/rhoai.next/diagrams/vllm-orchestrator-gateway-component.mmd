graph TB
    subgraph "vLLM Orchestrator Gateway"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>/{route_name}/v1/chat/completions"]
        DetectorInjector["Detector Injector<br/>(per-route detector maps)"]
        StreamHandler["SSE Stream Handler<br/>(futures::Stream)"]
        NonStreamHandler["Non-Stream Handler<br/>(reqwest)"]
        FallbackHandler["Fallback Message Handler"]
        TLSConfig["TLS/mTLS Config<br/>(openssl + native-tls)"]

        ConfigLoader -->|"loads YAML config"| Gateway
        Gateway -->|"routes requests"| RouteHandler
        RouteHandler -->|"injects detectors"| DetectorInjector
        DetectorInjector -->|"stream=false"| NonStreamHandler
        DetectorInjector -->|"stream=true"| StreamHandler
        NonStreamHandler -->|"checks detections"| FallbackHandler
        StreamHandler -->|"checks detections"| FallbackHandler
        Gateway -->|"configures client"| TLSConfig
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| RouteHandler

    subgraph "Backend Services"
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP HTTP/HTTPS"]
        Detectors["Guardrails Detectors<br/>(e.g., regex-detector)"]
        LLM["vLLM / LLM Inference Server"]
    end

    NonStreamHandler -->|"POST /api/v2/chat/completions-detection<br/>HTTP/HTTPS + optional mTLS"| Orchestrator
    StreamHandler -->|"POST /api/v2/chat/completions-detection<br/>HTTP/HTTPS + optional mTLS (SSE)"| Orchestrator
    Orchestrator -->|"invokes"| Detectors
    Orchestrator -->|"generates via"| LLM

    subgraph "Configuration Sources"
        ConfigFile["config.yaml<br/>(GATEWAY_CONFIG env var)"]
        TLSCerts["TLS Certificates<br/>/etc/tls/private/{tls.crt,tls.key}"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt"]
    end

    ConfigFile -->|"read at startup"| ConfigLoader
    TLSCerts -->|"mTLS identity"| TLSConfig
    CACert -->|"custom CA trust"| TLSConfig

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style DetectorInjector fill:#4a90e2,stroke:#333,color:#fff
    style StreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style NonStreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style FallbackHandler fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style TLSConfig fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#e8e8e8,stroke:#333
    style LLM fill:#e8e8e8,stroke:#333
    style ConfigFile fill:#d5e8d4,stroke:#82b366
    style TLSCerts fill:#d5e8d4,stroke:#82b366
    style CACert fill:#d5e8d4,stroke:#82b366
