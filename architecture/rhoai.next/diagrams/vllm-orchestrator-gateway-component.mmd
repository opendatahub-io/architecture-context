graph TB
    subgraph External["External Clients"]
        Client[API Client]
    end

    subgraph Gateway["vLLM Orchestrator Gateway (Rust/axum)"]
        direction TB
        Router[axum Router<br/>Dynamic Route Registration]
        ConfigLoader[Config Loader<br/>YAML Parser]
        DetectorInjector[Detector Injector<br/>Payload Augmentation]
        StreamHandler[SSE Stream Handler<br/>Chunk Processing]
        FallbackHandler[Fallback Handler<br/>Detection Response Replacement]
        TLSClient[mTLS Client Builder<br/>OpenSSL + native-tls]

        ConfigLoader -->|defines routes| Router
        ConfigLoader -->|defines detectors| DetectorInjector
        Router -->|non-streaming| DetectorInjector
        Router -->|streaming| StreamHandler
        StreamHandler -->|per-chunk| FallbackHandler
        DetectorInjector -->|augmented payload| TLSClient
        StreamHandler -->|augmented payload| TLSClient
    end

    subgraph TrustyAI["TrustyAI Guardrails Stack"]
        Orchestrator[FMS Guardrails Orchestrator<br/>/api/v2/chat/completions-detection]
        Detectors[Content Detectors<br/>regex-detector, etc.]
        vLLM[vLLM Model Server<br/>LLM Inference]

        Orchestrator -->|invokes| Detectors
        Orchestrator -->|routes to| vLLM
    end

    subgraph Config["Configuration"]
        ConfigFile[config.yaml<br/>Routes + Detectors + Orchestrator]
        TLSCerts[TLS Secrets<br/>/etc/tls/private/]
        CACert[CA Certificate<br/>/etc/tls/ca/]
    end

    Client -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| Router
    TLSClient -->|"HTTP/HTTPS<br/>default 8085/TCP<br/>Optional mTLS"| Orchestrator
    Orchestrator -->|"Response (JSON or SSE)"| FallbackHandler
    FallbackHandler -->|"Response<br/>(with fallback if detections)"| Client

    ConfigFile -.->|mounted| ConfigLoader
    TLSCerts -.->|mounted| TLSClient
    CACert -.->|mounted| TLSClient

    style Router fill:#4a90e2,color:#fff
    style ConfigLoader fill:#4a90e2,color:#fff
    style DetectorInjector fill:#4a90e2,color:#fff
    style StreamHandler fill:#4a90e2,color:#fff
    style FallbackHandler fill:#4a90e2,color:#fff
    style TLSClient fill:#4a90e2,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Orchestrator fill:#7ed321,color:#fff
    style Detectors fill:#7ed321,color:#fff
    style vLLM fill:#7ed321,color:#fff
    style ConfigFile fill:#f5a623,color:#fff
    style TLSCerts fill:#f5a623,color:#fff
    style CACert fill:#f5a623,color:#fff
