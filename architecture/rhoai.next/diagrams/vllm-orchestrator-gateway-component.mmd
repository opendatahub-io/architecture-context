graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["Gateway Service<br/>(Rust/axum)<br/>0.0.0.0:8090"]
        Router["Route Dispatcher"]
        DetectorInjector["Detector Config Injector"]
        FallbackHandler["Fallback Message Handler"]
        StreamProcessor["SSE Stream Processor"]
        ConfigLoader["YAML Config Loader"]
        TLSBuilder["mTLS Client Builder<br/>(OpenSSL + native-tls)"]

        ConfigLoader -->|"loads routes,<br/>detectors, orchestrator"| Router
        Gateway -->|"dispatches by<br/>route name"| Router
        Router -->|"injects detector<br/>params into payload"| DetectorInjector
        DetectorInjector -->|"non-streaming"| FallbackHandler
        DetectorInjector -->|"streaming (SSE)"| StreamProcessor
        StreamProcessor -->|"per-chunk<br/>fallback check"| FallbackHandler
        TLSBuilder -->|"PKCS#12 identity"| DetectorInjector
    end

    Client["API Client"] -->|"POST /{route_name}/v1/chat/completions<br/>8090/TCP HTTP"| Gateway

    ConfigFile["YAML Config File<br/>/app/config/config.yaml"] -.->|"mounted volume"| ConfigLoader

    TLSCerts["TLS Secrets<br/>/etc/tls/private/<br/>/etc/tls/ca/"] -.->|"volume mount"| TLSBuilder

    DetectorInjector -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP(S) + optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"detection results"| FallbackHandler
    Orchestrator -->|"SSE stream"| StreamProcessor

    FallbackHandler -->|"JSON / SSE response<br/>(with fallback if detections)"| Client

    Orchestrator -->|"routes to"| Detectors["Content Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -->|"routes to"| vLLM["vLLM Model Server"]

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style Router fill:#4a90e2,stroke:#333,color:#fff
    style DetectorInjector fill:#4a90e2,stroke:#333,color:#fff
    style FallbackHandler fill:#4a90e2,stroke:#333,color:#fff
    style StreamProcessor fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style TLSBuilder fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style ConfigFile fill:#f5a623,stroke:#333,color:#fff
    style TLSCerts fill:#f5a623,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
