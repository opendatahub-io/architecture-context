graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["Gateway Service<br/>(axum HTTP Server)<br/>Port 8090/TCP"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteEngine["Dynamic Route Engine"]
        TLSBuilder["TLS Client Builder<br/>(openssl + native-tls)"]
        StreamHandler["SSE Stream Handler<br/>(futures)"]
        DetectionFilter["Detection Filter<br/>(fallback message injection)"]

        ConfigLoader -->|"loads YAML config"| RouteEngine
        RouteEngine -->|"creates per-route<br/>POST endpoints"| Gateway
        Gateway -->|"streaming requests"| StreamHandler
        Gateway -->|"non-streaming requests"| DetectionFilter
        StreamHandler -->|"per-chunk detection"| DetectionFilter
        TLSBuilder -->|"configures mTLS client"| Gateway
    end

    Client["Client<br/>(External)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP"| Gateway

    subgraph "Route Examples (from config)"
        Route_PII["/pii/v1/chat/completions<br/>regex-language detector"]
        Route_Pass["/passthrough/v1/chat/completions<br/>no detectors"]
    end

    RouteEngine -.->|"generates"| Route_PII
    RouteEngine -.->|"generates"| Route_Pass

    Gateway -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS<br/>Conditional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    Orchestrator -->|"calls"| vLLM["vLLM Inference<br/>Server"]
    Orchestrator -->|"calls"| Detectors["Content Detectors<br/>(e.g., regex detector)"]

    subgraph "TLS Materials (Kubernetes Mounts)"
        ClientCert["/etc/tls/private/tls.crt"]
        ClientKey["/etc/tls/private/tls.key"]
        CACert["/etc/tls/ca/service-ca.crt"]
    end

    TLSBuilder -.->|"reads if present"| ClientCert
    TLSBuilder -.->|"reads if present"| ClientKey
    TLSBuilder -.->|"reads if present"| CACert

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style RouteEngine fill:#4a90e2,stroke:#333,color:#fff
    style TLSBuilder fill:#4a90e2,stroke:#333,color:#fff
    style StreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style DetectionFilter fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style Detectors fill:#7ed321,stroke:#333
    style Route_PII fill:#f5a623,stroke:#333
    style Route_Pass fill:#f5a623,stroke:#333
    style ClientCert fill:#fff2cc,stroke:#d6b656
    style ClientKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
