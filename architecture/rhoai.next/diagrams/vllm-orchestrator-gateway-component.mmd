graph TB
    subgraph "vllm-orchestrator-gateway"
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)<br/>Port: 8090/TCP"]
        ConfigLoader["Config Loader<br/>(serde_yml)"]
        RouteHandler["Route Handler<br/>POST /{route_name}/v1/chat/completions"]
        StreamHandler["SSE Stream Handler<br/>(futures::StreamExt)"]
        DetectionChecker["Detection Checker<br/>(fallback_message substitution)"]
        TLSBuilder["TLS Client Builder<br/>(openssl + native-tls)"]

        ConfigLoader -->|"loads YAML<br/>config/config.yaml"| Gateway
        Gateway -->|"registers routes"| RouteHandler
        RouteHandler -->|"streaming=true"| StreamHandler
        RouteHandler -->|"streaming=false"| DetectionChecker
        StreamHandler -->|"checks detections<br/>per SSE chunk"| DetectionChecker
        Gateway -->|"builds mTLS client<br/>if certs present"| TLSBuilder
    end

    Client["Client<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP<br/>Authorization header"| RouteHandler

    RouteHandler -->|"POST /api/v2/chat/completions-detection<br/>HTTP or HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator<br/>8085/TCP"]

    Orchestrator -->|"delegates inference"| vLLM["vLLM / Model Server<br/>(indirect)"]
    Orchestrator -->|"runs detectors"| Detectors["Guardrails Detectors<br/>(e.g., regex-language)<br/>(indirect)"]

    TLSBuilder -.->|"reads certs"| TLSCerts["/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key<br/>/etc/tls/ca/service-ca.crt"]

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style RouteHandler fill:#4a90e2,stroke:#333,color:#fff
    style StreamHandler fill:#4a90e2,stroke:#333,color:#fff
    style DetectionChecker fill:#4a90e2,stroke:#333,color:#fff
    style TLSBuilder fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
    style TLSCerts fill:#fff2cc,stroke:#d6b656
