graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["payload-processing-{release}<br/>Namespace: Gateway namespace"]
    end

    subgraph Bindings["ClusterRoleBinding / RoleBinding"]
        CRB["{release}-externalmodels-reader<br/>Scope: Cluster-wide (multiNamespace=true)<br/>or namespace-scoped (multiNamespace=false)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["{release}-externalmodels-reader"]
    end

    subgraph APIResources["API Resources & Permissions"]
        subgraph CoreAPI["API Group: core ('')"]
            Secrets["secrets<br/>Verbs: get, list, watch"]
        end

        subgraph MaaSAPI["API Group: maas.opendatahub.io"]
            ExternalModels["externalmodels<br/>Verbs: get, list, watch"]
        end
    end

    subgraph WatchedResources["Resources Watched at Runtime"]
        LabeledSecrets["Secrets with label:<br/>inference.networking.k8s.io/<br/>bbr-managed=true<br/><br/>Data field: api-key<br/>Type: Opaque<br/>Provisioned by: User / MaaS controller"]
        ExternalModelCRs["ExternalModel CRs<br/>maas.opendatahub.io/v1alpha1<br/><br/>Maps model name →<br/>provider + credentials<br/>spec.externalProviderRefs (MaxItems=1)"]
    end

    subgraph Consumers["In-Memory Consumers"]
        SecretStore["secretStore<br/>(apikey-injection plugin)<br/>Caches API keys<br/>RWMutex sync"]
        ModelInfoStore["modelInfoStore<br/>(model-provider-resolver plugin)<br/>Caches model→provider mappings<br/>RWMutex sync"]
    end

    %% RBAC chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    %% Runtime data flow
    Secrets -.->|"reconciled into"| LabeledSecrets
    ExternalModels -.->|"reconciled into"| ExternalModelCRs
    LabeledSecrets -->|"cached in"| SecretStore
    ExternalModelCRs -->|"cached in"| ModelInfoStore

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#64b5f6,stroke:#333
    style CR fill:#f5a623,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style ExternalModels fill:#7ed321,stroke:#333
    style LabeledSecrets fill:#fff59d,stroke:#f9a825
    style ExternalModelCRs fill:#fff59d,stroke:#f9a825
    style SecretStore fill:#ce93d8,stroke:#7b1fa2
    style ModelInfoStore fill:#ce93d8,stroke:#7b1fa2
