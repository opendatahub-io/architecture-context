graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["payload-processing-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["ClusterRoleBinding<br/>{release}-externalmodels-reader<br/>(when multiNamespace=true)"]
        RB["RoleBinding<br/>{release}-externalmodels-reader<br/>(when multiNamespace=false)<br/>Namespace: {release-namespace}"]
    end

    subgraph Roles["Cluster Role"]
        CR["ClusterRole<br/>{release}-externalmodels-reader"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            Secrets["secrets"]
        end

        subgraph MaaSAPI["API Group: maas.opendatahub.io"]
            ExternalModels["externalmodels"]
        end
    end

    subgraph Verbs["Granted Verbs"]
        V1["get"]
        V2["list"]
        V3["watch"]
    end

    %% Bindings
    SA -->|"bound via<br/>(cluster-scoped)"| CRB
    SA -->|"bound via<br/>(namespace-scoped)"| RB
    CRB -->|grants| CR
    RB -->|grants| CR

    %% Permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    %% Purpose annotations
    Secrets -.-|"API keys for<br/>cloud providers<br/>(bbr-managed=true label)"| SecretNote["Used by apikey-injection<br/>plugin reconciler"]
    ExternalModels -.-|"Model → provider<br/>mapping definitions"| ModelNote["Used by model-provider-<br/>resolver reconciler"]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style RB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style ExternalModels fill:#7ed321,stroke:#333,color:#fff
    style V1 fill:#d5e8d4,stroke:#82b366
    style V2 fill:#d5e8d4,stroke:#82b366
    style V3 fill:#d5e8d4,stroke:#82b366
    style SecretNote fill:#fff2cc,stroke:#d6b656
    style ModelNote fill:#fff2cc,stroke:#d6b656
