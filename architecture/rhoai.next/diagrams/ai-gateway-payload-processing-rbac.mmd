graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["payload-processing-{release}<br/>(ServiceAccount)<br/>Namespace: Gateway namespace"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["ClusterRoleBinding<br/>{release}-externalmodels-reader<br/>(cluster-wide)"]
        RB["RoleBinding (alternative)<br/>{release}-externalmodels-reader<br/>(namespace-scoped,<br/>if multiNamespace=false)"]
    end

    subgraph Roles["Cluster Roles"]
        CR["ClusterRole<br/>{release}-externalmodels-reader"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph CoreAPI["API Group: core ('')"]
            Secrets["secrets"]
        end

        subgraph MaaSAPI["API Group: maas.opendatahub.io"]
            ExternalModels["externalmodels"]
        end
    end

    subgraph Verbs["Permitted Verbs"]
        VerbSet["get, list, watch<br/>(read-only)"]
    end

    subgraph CRDs["Custom Resource Definitions"]
        ExternalModelCRD["ExternalModel<br/>inference.opendatahub.io/v1alpha1<br/>Namespaced"]
        ExternalProviderCRD["ExternalProvider<br/>inference.opendatahub.io/v1alpha1<br/>Namespaced"]
    end

    subgraph SecretAccess["Secret Access Pattern"]
        LabelFilter["Label Filter:<br/>inference.networking.k8s.io/<br/>bbr-managed=true"]
        SecretData["Secret Data Field:<br/>api-key"]
    end

    %% Binding flow
    SA -->|"bound via"| CRB
    SA -.->|"alternative binding<br/>(namespace-scoped)"| RB
    CRB -->|"grants"| CR
    RB -.->|"grants"| CR

    %% Permission flow
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    %% CRD relationship
    ExternalModels -.->|"defined by"| ExternalModelCRD
    ExternalModelCRD -.->|"references"| ExternalProviderCRD

    %% Secret access pattern
    Secrets -.->|"filtered by"| LabelFilter
    Secrets -.->|"reads"| SecretData

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style RB fill:#dae8fc,stroke:#6c8ebf,stroke-dasharray: 5 5
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333
    style ExternalModels fill:#7ed321,stroke:#333
    style VerbSet fill:#d5e8d4,stroke:#82b366
    style ExternalModelCRD fill:#ffe6cc,stroke:#d79b00
    style ExternalProviderCRD fill:#ffe6cc,stroke:#d79b00
    style LabelFilter fill:#e1d5e7,stroke:#9673a6
    style SecretData fill:#e1d5e7,stroke:#9673a6
