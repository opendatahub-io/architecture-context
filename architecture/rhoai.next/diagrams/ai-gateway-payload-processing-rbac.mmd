graph TD
    subgraph ServiceAccount["Service Account"]
        SA["{name}-{release}"]
    end

    subgraph ClusterRoleBinding["ClusterRole Binding"]
        CRB["{release}-externalmodels-reader<br/>(cluster-wide or release namespace)"]
    end

    subgraph ClusterRole["ClusterRole: {release}-externalmodels-reader"]
        CR["ClusterRole"]
    end

    subgraph CoreAPI["API Group: core ('')"]
        Secrets["secrets"]
        Services["services"]
    end

    subgraph MaasAPI["API Group: maas.opendatahub.io"]
        MaasEM["externalmodels<br/>(legacy)"]
    end

    subgraph InferenceAPI["API Group: inference.opendatahub.io"]
        InfEM["externalmodels"]
        InfEP["externalproviders"]
        InfEMStatus["externalmodels/status"]
        InfEPStatus["externalproviders/status"]
        InfEMFinalizers["externalmodels/finalizers"]
        InfEPFinalizers["externalproviders/finalizers"]
    end

    subgraph GatewayAPIGroup["API Group: gateway.networking.k8s.io"]
        HTTPRoutes["httproutes"]
    end

    subgraph IstioAPI["API Group: networking.istio.io"]
        ServiceEntries["serviceentries"]
        DestRules["destinationrules"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Core API permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch,<br/>create, update, delete"| Services

    %% Legacy API permissions
    CR -->|"get, list, watch"| MaasEM

    %% Inference API permissions
    CR -->|"get, list, watch,<br/>create, update"| InfEM
    CR -->|"get, list, watch,<br/>create, update"| InfEP
    CR -->|"get, update, patch"| InfEMStatus
    CR -->|"get, update, patch"| InfEPStatus
    CR -->|"update"| InfEMFinalizers
    CR -->|"update"| InfEPFinalizers

    %% Gateway API permissions
    CR -->|"get, list, watch,<br/>create, update, delete"| HTTPRoutes

    %% Istio API permissions
    CR -->|"get, list, watch,<br/>create, update, delete"| ServiceEntries
    CR -->|"get, list, watch,<br/>create, update, delete"| DestRules

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,color:#fff
    classDef binding fill:#9b59b6,stroke:#333,color:#fff
    classDef role fill:#f5a623,stroke:#333,color:#fff
    classDef resource fill:#7ed321,stroke:#333,color:#fff
    classDef readonly fill:#95a5a6,stroke:#333,color:#fff

    class SA sa
    class CRB binding
    class CR role
    class Services,InfEM,InfEP,InfEMStatus,InfEPStatus,InfEMFinalizers,InfEPFinalizers,HTTPRoutes,ServiceEntries,DestRules resource
    class Secrets,MaasEM readonly
