graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["payload-processing-{release}"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["{release}-externalmodels-reader<br/>(ClusterRoleBinding or RoleBinding)<br/>Scope: cluster-wide or namespace"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["{release}-externalmodels-reader"]
    end

    subgraph CoreResources["API Group: core ('')"]
        Secrets["secrets"]
    end

    subgraph MaaSResources["API Group: maas.opendatahub.io"]
        ExternalModels["externalmodels"]
    end

    subgraph ProviderSecrets["Watched Secrets (Runtime)"]
        direction LR
        LabelFilter["Label filter:<br/>inference.networking.k8s.io/<br/>bbr-managed=true"]
        SecretData["Data field: api-key<br/>Type: Opaque<br/>Provisioned by: User or MaaS controller"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    %% Runtime behavior
    SA -.->|"watches at runtime"| LabelFilter
    LabelFilter -.->|"caches into secretStore"| SecretData

    %% Notes
    Note["Note: When bbr.multiNamespace=false,<br/>Role/RoleBinding used instead of<br/>ClusterRole/ClusterRoleBinding<br/>(namespace-scoped)"]

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#64b5f6,color:#fff
    style CR fill:#f5a623,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style ExternalModels fill:#7ed321,color:#fff
    style LabelFilter fill:#fff9c4,stroke:#f9a825
    style SecretData fill:#fff9c4,stroke:#f9a825
    style Note fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5
