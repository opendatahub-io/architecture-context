graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["payload-processing-{release}"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB1["{release}-externalmodels-reader<br/>binding"]
        CRB2["controller RBAC binding<br/>(kubebuilder-generated)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR1["{release}-externalmodels-reader"]
        CR2["controller RBAC role<br/>(kubebuilder markers)"]
    end

    subgraph APIResources_Core["API Group: core ('')"]
        Secrets["secrets"]
        Services["services"]
    end

    subgraph APIResources_MaaS["API Group: maas.opendatahub.io"]
        MaaSExternalModels["externalmodels"]
    end

    subgraph APIResources_Inference["API Group: inference.opendatahub.io"]
        InfExternalModels["externalmodels"]
        InfExternalModelsStatus["externalmodels/status"]
        InfExternalModelsFinalizers["externalmodels/finalizers"]
        InfExternalProviders["externalproviders"]
        InfExternalProvidersStatus["externalproviders/status"]
        InfExternalProvidersFinalizers["externalproviders/finalizers"]
    end

    subgraph APIResources_Istio["API Group: networking.istio.io"]
        ServiceEntries["serviceentries"]
        DestinationRules["destinationrules"]
    end

    subgraph APIResources_GW["API Group: gateway.networking.k8s.io"]
        HTTPRoutes["httproutes"]
    end

    %% Bindings
    SA -->|"bound via"| CRB1
    SA -->|"bound via"| CRB2
    CRB1 -->|"grants"| CR1
    CRB2 -->|"grants"| CR2

    %% Reader Role Permissions
    CR1 -->|"get, list, watch"| Secrets
    CR1 -->|"get, list, watch"| MaaSExternalModels

    %% Controller Role Permissions - inference.opendatahub.io
    CR2 -->|"get, list, watch"| InfExternalModels
    CR2 -->|"get, update, patch"| InfExternalModelsStatus
    CR2 -->|"update"| InfExternalModelsFinalizers
    CR2 -->|"get, list, watch"| InfExternalProviders
    CR2 -->|"get, update, patch"| InfExternalProvidersStatus
    CR2 -->|"update"| InfExternalProvidersFinalizers

    %% Controller Role Permissions - core
    CR2 -->|"get, list, watch"| Secrets
    CR2 -->|"get, list, watch,<br/>create, update, delete"| Services

    %% Controller Role Permissions - networking.istio.io
    CR2 -->|"get, list, watch,<br/>create, update, delete"| ServiceEntries
    CR2 -->|"get, list, watch,<br/>create, update, delete"| DestinationRules

    %% Controller Role Permissions - gateway.networking.k8s.io
    CR2 -->|"get, list, watch,<br/>create, update, delete"| HTTPRoutes

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB1 fill:#dae8fc,stroke:#6c8ebf
    style CRB2 fill:#dae8fc,stroke:#6c8ebf
    style CR1 fill:#f5a623,color:#fff
    style CR2 fill:#f5a623,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style MaaSExternalModels fill:#7ed321,color:#fff
    style InfExternalModels fill:#7ed321,color:#fff
    style InfExternalModelsStatus fill:#7ed321,color:#fff
    style InfExternalModelsFinalizers fill:#7ed321,color:#fff
    style InfExternalProviders fill:#7ed321,color:#fff
    style InfExternalProvidersStatus fill:#7ed321,color:#fff
    style InfExternalProvidersFinalizers fill:#7ed321,color:#fff
    style ServiceEntries fill:#7ed321,color:#fff
    style DestinationRules fill:#7ed321,color:#fff
    style HTTPRoutes fill:#7ed321,color:#fff
