graph TD
    subgraph ServiceAccount["Service Account"]
        SA["payload-processing-{release}<br/>Namespace: gateway namespace"]
    end

    subgraph Binding["ClusterRoleBinding"]
        CRB["{release}-externalmodels-reader<br/>(ClusterRoleBinding when multiNamespace=true)<br/>(RoleBinding when multiNamespace=false)"]
    end

    subgraph ClusterRole["ClusterRole"]
        CR["{release}-externalmodels-reader"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    subgraph CoreAPI["API Group: core ('')"]
        Secrets["secrets"]
        Services["services"]
    end

    subgraph MaasAPI["API Group: maas.opendatahub.io"]
        MaasExternalModels["externalmodels<br/>(legacy)"]
    end

    subgraph InferenceAPI["API Group: inference.opendatahub.io"]
        InfExternalProviders["externalproviders"]
        InfExternalModels["externalmodels"]
        InfEPStatus["externalproviders/status"]
        InfEMStatus["externalmodels/status"]
        InfEPFinalizers["externalproviders/finalizers"]
        InfEMFinalizers["externalmodels/finalizers"]
    end

    subgraph GatewayAPIGroup["API Group: gateway.networking.k8s.io"]
        HTTPRoutes["httproutes"]
    end

    subgraph IstioAPI["API Group: networking.istio.io"]
        ServiceEntries["serviceentries"]
        DestinationRules["destinationrules"]
    end

    %% Core permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch,<br/>create, update, delete"| Services

    %% Legacy maas permissions
    CR -->|"get, list, watch"| MaasExternalModels

    %% Inference API permissions
    CR -->|"get, list, watch,<br/>create, update"| InfExternalProviders
    CR -->|"get, list, watch,<br/>create, update"| InfExternalModels
    CR -->|"get, update, patch"| InfEPStatus
    CR -->|"get, update, patch"| InfEMStatus
    CR -->|"update"| InfEPFinalizers
    CR -->|"update"| InfEMFinalizers

    %% Gateway API permissions
    CR -->|"get, list, watch,<br/>create, update, delete"| HTTPRoutes

    %% Istio permissions
    CR -->|"get, list, watch,<br/>create, update, delete"| ServiceEntries
    CR -->|"get, list, watch,<br/>create, update, delete"| DestinationRules

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style MaasExternalModels fill:#e8e8e8,stroke:#999
    style InfExternalProviders fill:#7ed321,stroke:#333
    style InfExternalModels fill:#7ed321,stroke:#333
    style InfEPStatus fill:#a8d98a,stroke:#333
    style InfEMStatus fill:#a8d98a,stroke:#333
    style InfEPFinalizers fill:#a8d98a,stroke:#333
    style InfEMFinalizers fill:#a8d98a,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style ServiceEntries fill:#7ed321,stroke:#333
    style DestinationRules fill:#7ed321,stroke:#333
