graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["payload-processing-{release}"]
    end

    subgraph Bindings["ClusterRole Binding (multiNamespace=true)"]
        CRB["{release}-externalmodels-reader<br/>ClusterRoleBinding"]
    end

    subgraph AltBindings["Role Binding (multiNamespace=false)"]
        RB["{release}-externalmodels-reader<br/>RoleBinding<br/>(namespace-scoped)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["{release}-externalmodels-reader"]
    end

    subgraph CoreResources["API Group: core ('')"]
        Secrets["secrets"]
    end

    subgraph MaaSResources["API Group: maas.opendatahub.io"]
        ExternalModels["externalmodels"]
    end

    subgraph Verbs["Permitted Verbs"]
        ReadOnly["get, list, watch"]
    end

    SA -->|"bound via"| CRB
    SA -.->|"alt: bound via"| RB
    CRB -->|"grants"| CR
    RB -.->|"grants"| CR
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    subgraph WatchedResources["Watched Resources (Runtime)"]
        direction LR
        ExternalModelCRD["ExternalModel CRDs<br/>maas.opendatahub.io/v1alpha1<br/>(all namespaces when cluster-scoped)"]
        LabeledSecrets["Secrets<br/>label: inference.networking.k8s.io/<br/>bbr-managed=true<br/>(all namespaces when cluster-scoped)"]
    end

    CR -->|"enables watch on"| ExternalModelCRD
    CR -->|"enables watch on"| LabeledSecrets

    subgraph SecurityNotes["Security Notes"]
        direction LR
        Note1["ext_proc 9004/TCP: No Auth<br/>(network isolation only)"]
        Note2["API keys: in-memory only<br/>(refreshed via reconciler)"]
        Note3["FIPS: GOEXPERIMENT=strictfipsruntime"]
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#e8f0fe,stroke:#4a90e2
    style RB fill:#e8f0fe,stroke:#4a90e2,stroke-dasharray:5 5
    style CR fill:#f5a623,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style ExternalModels fill:#7ed321,stroke:#333
    style ExternalModelCRD fill:#d5e8d4,stroke:#82b366
    style LabeledSecrets fill:#d5e8d4,stroke:#82b366
    style Note1 fill:#f8d7da,stroke:#f5c6cb
    style Note2 fill:#f8d7da,stroke:#f5c6cb
    style Note3 fill:#d4edda,stroke:#c3e6cb
