graph TB
    subgraph OGXOperator["OGX K8s Operator"]
        direction TB
        Controller["OGX Operator Manager<br/>Go controller-runtime<br/>Ports: 8080, 8081, 9443"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS<br/>service-serving-cert"]
        ConfigGen["Config Generator<br/>Kustomize Pipeline"]
        LegacyAdopt["Legacy Adoption<br/>LlamaStackDistribution → OGXServer"]
        Controller -->|validates via| Webhook
        Controller -->|generates config| ConfigGen
        Controller -->|migrates| LegacyAdopt
    end

    subgraph OGXModule["OGX Module Operator (scaffold)"]
        ModuleCtrl["Module Controller<br/>Port: 8081<br/>(reconciler not yet implemented)"]
    end

    %% CRDs
    User[Data Scientist / Admin] -->|creates| OGXServerCR["OGXServer CR<br/>ogx.io/v1beta1<br/>(Namespaced)"]
    PlatformOp["ODH/RHOAI Platform Operator"] -->|creates| OGXCR["OGX CR<br/>components.platform.opendatahub.io/v1alpha1<br/>(Cluster-scoped)"]
    LegacyCR["LlamaStackDistribution CR<br/>llamastack.io/v1alpha1<br/>(legacy, read-only)"]

    %% Watches
    OGXServerCR -->|watched by| Controller
    LegacyCR -.->|adopted by| LegacyAdopt
    OGXCR -->|watched by| ModuleCtrl

    %% Created Resources
    Controller -->|creates| Deployment["Deployment<br/>(OGX Server)"]
    Controller -->|creates| Service["Service<br/>(ClusterIP)"]
    Controller -->|creates| PVC["PersistentVolumeClaim"]
    Controller -->|creates| NetPol["NetworkPolicy"]
    Controller -->|creates| HPA["HorizontalPodAutoscaler"]
    Controller -->|creates| PDB["PodDisruptionBudget"]
    Controller -->|creates| Ingress["Ingress<br/>(optional, external access)"]
    Controller -->|creates| SA["ServiceAccount<br/>+ RoleBinding (anyuid SCC)"]
    Controller -->|creates| ConfigMap["ConfigMap<br/>(generated config.yaml,<br/>content-hash named, immutable)"]

    %% Monitoring
    Controller -.->|creates if CRDs exist| ServiceMonitor["ServiceMonitor"]
    Controller -.->|creates if CRDs exist| PrometheusRule["PrometheusRule"]

    %% Dependencies
    Controller -->|depends on| CertProvider["cert-manager /<br/>service-serving-cert-signer"]
    Controller -->|depends on| K8sAPI["Kubernetes API Server"]
    Controller -->|fetches OCI labels| OCIRegistry["OCI Image Registry"]
    ModuleCtrl -->|deploys manifests| OGXOperator

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style ConfigGen fill:#4a90e2,stroke:#333,color:#fff
    style LegacyAdopt fill:#4a90e2,stroke:#333,color:#fff
    style ModuleCtrl fill:#6baed6,stroke:#333,color:#fff
    style OGXServerCR fill:#f5a623,stroke:#333,color:#fff
    style OGXCR fill:#f5a623,stroke:#333,color:#fff
    style LegacyCR fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Deployment fill:#7ed321,stroke:#333
    style Service fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style Ingress fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style ConfigMap fill:#7ed321,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333,stroke-dasharray: 5 5
    style PrometheusRule fill:#7ed321,stroke:#333,stroke-dasharray: 5 5
    style CertProvider fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
    style PlatformOp fill:#fff,stroke:#333
