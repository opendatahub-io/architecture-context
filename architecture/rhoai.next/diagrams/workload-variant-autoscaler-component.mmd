graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB

        subgraph Controllers["Controllers"]
            VAReconciler["VA Reconciler<br/>Reconciles VariantAutoscaling CRs"]
            CMReconciler["ConfigMap Reconciler<br/>Watches config overrides"]
            IPReconciler["InferencePool Reconciler<br/>Watches InferencePool CRs"]
        end

        subgraph Engines["Optimization Engines"]
            SatEngine["Saturation Engine<br/>30s polling interval<br/>V1/V2/Queueing analyzers"]
            SFZEngine["Scale-From-Zero Engine<br/>100ms polling interval<br/>EPP pod scraping"]
            QMEngine["Queueing Model Engine<br/>M/M/1 theory analyzer"]
        end

        subgraph Core["Core Components"]
            Collector["Collector<br/>vLLM metrics from Prometheus"]
            Actuator["Actuator<br/>Emits wva_desired_replicas<br/>wva_desired_ratio metrics"]
            Datastore["Datastore<br/>In-memory cache<br/>InferencePool data + EPP sources"]
            DecisionCache["Decision Cache<br/>In-memory scaling decisions"]
        end

        SatEngine -->|"writes decisions"| DecisionCache
        SFZEngine -->|"writes decisions"| DecisionCache
        QMEngine -->|"writes decisions"| DecisionCache
        DecisionCache -->|"triggers via Go channel"| VAReconciler
        SatEngine -->|"reads metrics"| Collector
        CMReconciler -->|"config updates"| SatEngine
        CMReconciler -->|"config updates"| SFZEngine
        IPReconciler -->|"pool metadata"| Datastore
        SFZEngine -->|"reads EPP sources"| Datastore
        VAReconciler -->|"emits scaling metrics"| Actuator
    end

    %% External CRDs
    User["Data Scientist / Platform Admin"] -->|"creates"| VACR["VariantAutoscaling CR<br/>llmd.ai/v1alpha1"]
    VACR -->|"watched by"| VAReconciler

    %% External Dependencies
    Collector -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus / Thanos Querier"]
    Prometheus -->|"scrapes"| vLLM["vLLM Inference Servers"]
    SFZEngine -->|"scrapes metrics<br/>HTTPS"| EPP["EPP Pods<br/>Endpoint Picker"]
    IPReconciler -->|"watches"| InferencePoolCR["InferencePool CR<br/>Gateway API"]

    %% Outputs
    Actuator -->|"exposes /metrics<br/>8443/TCP HTTPS"| PrometheusOut["Prometheus Scraper"]
    PrometheusOut -->|"wva_desired_ratio"| HPA["HPA / KEDA"]
    HPA -->|"scales"| Deployments["Deployments / LWS"]
    SFZEngine -->|"direct scale 0→1<br/>443/TCP HTTPS"| Deployments

    %% K8s API
    VAReconciler -->|"status patch<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    CMReconciler -->|"watches ConfigMaps"| K8sAPI

    %% Styling
    style VAReconciler fill:#4a90e2,color:#fff
    style CMReconciler fill:#4a90e2,color:#fff
    style IPReconciler fill:#4a90e2,color:#fff
    style SatEngine fill:#e67e22,color:#fff
    style SFZEngine fill:#e67e22,color:#fff
    style QMEngine fill:#e67e22,color:#fff
    style Collector fill:#27ae60,color:#fff
    style Actuator fill:#27ae60,color:#fff
    style Datastore fill:#27ae60,color:#fff
    style DecisionCache fill:#27ae60,color:#fff
    style VACR fill:#f5a623,color:#000
    style InferencePoolCR fill:#f5a623,color:#000
    style Prometheus fill:#999,color:#fff
    style vLLM fill:#999,color:#fff
    style EPP fill:#999,color:#fff
    style HPA fill:#999,color:#fff
    style K8sAPI fill:#999,color:#fff
    style Deployments fill:#8e44ad,color:#fff
