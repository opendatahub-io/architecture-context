graph TB
    subgraph WVA["Workload Variant Autoscaler (WVA)"]
        direction TB

        subgraph Controllers["Controllers"]
            VAReconciler["VariantAutoscaling<br/>Reconciler"]
            CMReconciler["ConfigMap<br/>Reconciler"]
            IPReconciler["InferencePool<br/>Reconciler"]
        end

        subgraph Engines["Scaling Engines"]
            SatEngine["Saturation Engine<br/>(V1/V2/Queueing Model)"]
            SFZEngine["Scale-from-Zero<br/>Engine"]
        end

        subgraph Core["Core Components"]
            DecisionCache["Decision Cache<br/>(in-memory)"]
            Datastore["Datastore<br/>(InferencePool cache)"]
            Config["Config Object<br/>(in-memory)"]
            GPUDiscovery["GPU Discovery"]
        end

        subgraph Actuators["Actuators"]
            Actuator["Actuator<br/>(Prometheus metrics emitter)"]
            DirectActuator["DirectActuator<br/>(Scale subresource)"]
        end

        MetricsCollector["Metrics Collector<br/>(Prometheus queries)"]
    end

    %% Internal flows
    SatEngine -->|"queries metrics"| MetricsCollector
    SatEngine -->|"writes decisions"| DecisionCache
    SFZEngine -->|"writes decisions"| DecisionCache
    DecisionCache -->|"channel trigger"| VAReconciler
    VAReconciler -->|"reads decisions"| DecisionCache
    VAReconciler -->|"emits metrics"| Actuator
    SFZEngine -->|"direct scale"| DirectActuator
    CMReconciler -->|"updates config"| Config
    Config -->|"read by"| SatEngine
    IPReconciler -->|"caches pools"| Datastore
    Datastore -->|"read by"| SFZEngine
    GPUDiscovery -->|"GPU inventory"| SatEngine

    %% External resources
    User[Data Scientist / Admin] -->|"creates"| VACR["VariantAutoscaling CR"]
    VACR -->|"watched by"| VAReconciler

    %% External dependencies
    MetricsCollector -->|"PromQL queries"| Prometheus["Prometheus /<br/>Thanos Querier"]
    SFZEngine -->|"scrapes metrics"| EPP["EPP Pods<br/>(Gateway API Inference Ext.)"]
    VAReconciler -->|"patches status"| K8sAPI["Kubernetes API"]
    DirectActuator -->|"scale subresource"| K8sAPI
    Actuator -->|"exposes /metrics"| HPAKEDA["HPA / KEDA"]
    HPAKEDA -->|"scales"| ScaleTargets["Deployments /<br/>LeaderWorkerSets"]
    GPUDiscovery -->|"reads node labels"| Nodes["Cluster Nodes<br/>(GPU labels)"]

    %% Styling
    style VAReconciler fill:#4a90e2,color:#fff
    style CMReconciler fill:#4a90e2,color:#fff
    style IPReconciler fill:#4a90e2,color:#fff
    style SatEngine fill:#7b68ee,color:#fff
    style SFZEngine fill:#7b68ee,color:#fff
    style Actuator fill:#50c878,color:#fff
    style DirectActuator fill:#50c878,color:#fff
    style MetricsCollector fill:#50c878,color:#fff
    style DecisionCache fill:#f5a623,color:#fff
    style Datastore fill:#f5a623,color:#fff
    style Config fill:#f5a623,color:#fff
    style GPUDiscovery fill:#50c878,color:#fff
    style VACR fill:#ff6b6b,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#999
    style EPP fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style HPAKEDA fill:#e8e8e8,stroke:#999
    style ScaleTargets fill:#e8e8e8,stroke:#999
    style Nodes fill:#e8e8e8,stroke:#999
