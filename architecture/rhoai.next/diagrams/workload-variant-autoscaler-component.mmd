graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB
        Controller["controller-manager<br/>(Go Operator / controller-runtime)"]
        SatEngine["Saturation Engine<br/>(30s polling loop)"]
        SFZEngine["Scale-From-Zero Engine<br/>(100ms polling loop)"]
        DecisionCache["Decision Cache<br/>(in-memory)"]
        Datastore["Datastore<br/>(in-memory)"]

        SatEngine -->|"writes decisions"| DecisionCache
        SFZEngine -->|"writes decisions"| DecisionCache
        DecisionCache -->|"DecisionTrigger channel"| Controller
        Controller -->|"tracks namespaces"| Datastore
        SFZEngine -->|"reads InferencePool state"| Datastore

        subgraph Analyzers["Analyzer Pipeline"]
            V1["V1 Analyzer<br/>(percentage-based saturation)"]
            V2["V2 Analyzer<br/>(token-based capacity)"]
            QM["Queueing Model Analyzer<br/>(Kalman filter / M/M/c)"]
        end
        SatEngine --> V1
        SatEngine --> V2
        SatEngine --> QM

        subgraph Pipeline["Optimization Pipeline"]
            Limiter["DefaultLimiter<br/>(GPU-aware)"]
            Greedy["GreedyBySaturation<br/>Algorithm"]
            Limiter --> Greedy
        end
        V1 --> Limiter
        V2 --> Limiter
        QM --> Limiter
    end

    %% External Resources
    User["Platform Admin"] -->|"creates"| VACR["VariantAutoscaling CR<br/>(llmd.ai/v1alpha1)"]
    VACR -->|"watched by"| Controller
    Controller -->|"patches status"| VACR

    %% Scale Targets
    Controller -->|"emits metrics"| MetricsEndpoint["/metrics<br/>8443/TCP HTTPS"]
    MetricsEndpoint -->|"scraped by"| Prometheus["Prometheus"]
    MetricsEndpoint -->|"consumed by"| HPA["HPA"]
    MetricsEndpoint -->|"consumed by"| KEDA["KEDA"]
    HPA -->|"scales"| Deployment["Deployment"]
    KEDA -->|"scales"| Deployment
    SFZEngine -->|"direct /scale"| Deployment

    %% Data Sources
    Prometheus -->|"PromQL queries<br/>9091/TCP HTTPS"| SatEngine
    InferencePool["InferencePool CR"] -->|"watched by"| Controller
    EPP["EPP Pods"] -->|"HTTP metrics scraping"| SFZEngine
    ConfigMaps["ConfigMaps<br/>(saturation, scale-to-zero,<br/>queueing model)"] -->|"watched by"| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style SatEngine fill:#4a90e2,stroke:#333,color:#fff
    style SFZEngine fill:#4a90e2,stroke:#333,color:#fff
    style DecisionCache fill:#4a90e2,stroke:#333,color:#fff
    style Datastore fill:#4a90e2,stroke:#333,color:#fff
    style V1 fill:#6ba5e7,stroke:#333,color:#fff
    style V2 fill:#6ba5e7,stroke:#333,color:#fff
    style QM fill:#6ba5e7,stroke:#333,color:#fff
    style Limiter fill:#6ba5e7,stroke:#333,color:#fff
    style Greedy fill:#6ba5e7,stroke:#333,color:#fff
    style VACR fill:#f5a623,stroke:#333
    style InferencePool fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style HPA fill:#e8e8e8,stroke:#333
    style KEDA fill:#e8e8e8,stroke:#333
    style EPP fill:#7ed321,stroke:#333
    style Deployment fill:#e8e8e8,stroke:#333
    style MetricsEndpoint fill:#d4edda,stroke:#333
