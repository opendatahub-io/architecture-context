graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB

        subgraph Controllers["Controllers"]
            VAReconciler["VariantAutoscaling<br/>Reconciler"]
            CMReconciler["ConfigMap<br/>Reconciler"]
            IPReconciler["InferencePool<br/>Reconciler"]
        end

        subgraph Engines["Scaling Engines"]
            SatEngine["Saturation Engine<br/>(V1/V2/Queueing Model)"]
            SFZEngine["Scale-from-Zero<br/>Engine"]
        end

        subgraph Core["Core Components"]
            DecisionCache["Decision Cache<br/>(in-memory)"]
            Datastore["Datastore<br/>(InferencePool cache)"]
            ConfigObj["Config Object<br/>(in-memory)"]
            GPUDiscovery["GPU Discovery"]
            MetricsCollector["Metrics Collector"]
        end

        subgraph Actuators["Actuators"]
            Actuator["Actuator<br/>(Prometheus metrics emitter)"]
            DirectActuator["DirectActuator<br/>(Scale subresource)"]
        end
    end

    %% Internal flows
    SatEngine -->|"stores decisions"| DecisionCache
    SFZEngine -->|"stores decisions"| DecisionCache
    DecisionCache -->|"channel trigger"| VAReconciler
    CMReconciler -->|"updates config"| ConfigObj
    ConfigObj -->|"read by"| SatEngine
    IPReconciler -->|"caches pool data"| Datastore
    Datastore -->|"read by"| SFZEngine
    MetricsCollector -->|"feeds metrics"| SatEngine
    GPUDiscovery -->|"GPU inventory"| SatEngine
    SatEngine -->|"scaling targets"| Actuator
    SFZEngine -->|"direct scale"| DirectActuator

    %% CRD
    User["User / Platform"] -->|"creates"| VACR["VariantAutoscaling CR<br/>(llmd.ai/v1alpha1)"]
    VACR -->|"watched by"| VAReconciler

    %% External interactions
    MetricsCollector -->|"PromQL queries"| Prometheus["Prometheus /<br/>Thanos Querier"]
    SFZEngine -->|"scrape metrics"| EPP["EPP Pods<br/>(Gateway API Inference Extension)"]
    Actuator -->|"emits metrics"| MetricsEndpoint["/metrics<br/>8443/TCP HTTPS"]
    MetricsEndpoint -->|"scraped by"| HPAKEDA["HPA / KEDA"]
    HPAKEDA -->|"scales"| ScaleTarget["Deployment /<br/>LeaderWorkerSet"]
    DirectActuator -->|"scales directly"| ScaleTarget
    VAReconciler -->|"patches status"| K8sAPI["Kubernetes API<br/>443/TCP"]

    %% Styling
    style WVA fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Engines fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Core fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style Actuators fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style VAReconciler fill:#4a90e2,color:#fff
    style CMReconciler fill:#4a90e2,color:#fff
    style IPReconciler fill:#4a90e2,color:#fff
    style SatEngine fill:#f5a623,color:#fff
    style SFZEngine fill:#f5a623,color:#fff
    style Actuator fill:#9673a6,color:#fff
    style DirectActuator fill:#9673a6,color:#fff
    style VACR fill:#f5a623
    style Prometheus fill:#e8e8e8,stroke:#999
    style EPP fill:#e8e8e8,stroke:#999
    style HPAKEDA fill:#e8e8e8,stroke:#999
    style ScaleTarget fill:#7ed321
    style K8sAPI fill:#e8e8e8,stroke:#999
