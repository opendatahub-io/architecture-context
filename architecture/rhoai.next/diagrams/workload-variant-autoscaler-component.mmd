    style GreedyOpt fill:#ffb74d,stroke:#333
    style Limiter fill:#ffb74d,stroke:#333
    style Enforcer fill:#ffb74d,stroke:#333
    style VACR fill:#f5a623,stroke:#333
    style HPACR fill:#f5a623,stroke:#333
    style SOCR fill:#f5a623,stroke:#333
    style IPPool fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
