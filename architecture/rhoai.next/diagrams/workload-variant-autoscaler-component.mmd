graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB
        Controller["controller-manager<br/>(Go Operator)"]

        subgraph Engines["Scaling Engines"]
            direction LR
            SatV1["Saturation Engine V1<br/>Percentage-based<br/>KV Cache + Queue Depth"]
            SatV2["Saturation Engine V2<br/>Token-based Capacity<br/>k₁ memory + k₂ compute"]
            SFZ["Scale-from-Zero Engine<br/>0→1 Replica Scaling"]
        end

        subgraph Analyzers["Analyzer Plugins"]
            direction LR
            Throughput["Throughput Analyzer<br/>ITL Model + Two-tier OLS"]
            Queueing["Queueing Model Analyzer<br/>M/M/c + Kalman Filter"]
        end

        subgraph Coordinator["Coordinator (Experimental)"]
            direction LR
            CoordLoop["Leader-Elected Loop"]
            GPURebalance["GPU Rebalance Plugin<br/>Proportional Quota Allocation"]
            CoordLoop --> GPURebalance
        end

        Controller -->|runs| SatV1
        Controller -->|runs| SatV2
        Controller -->|runs| SFZ
        SatV1 -->|uses| Throughput
        SatV1 -->|uses| Queueing
        SatV2 -->|uses| Throughput
        Controller -->|starts| CoordLoop
    end

    %% CRDs
    VACR["VariantAutoscaling CR<br/>(DEPRECATED)"]
    HPA["HPA<br/>(llm-d.ai/managed=true)"]
    ScaledObj["KEDA ScaledObject<br/>(llm-d.ai/managed=true)"]
    InfPool["InferencePool CR"]

    VACR -->|watched by| Controller
    HPA -->|watched by| Controller
    ScaledObj -->|watched by| Controller
    InfPool -->|watched by| Controller

    %% Config
    ManagerCM["ConfigMap<br/>manager-config"]
    SatCM["ConfigMap<br/>saturation-scaling-config"]
    ManagerCM -->|mounted into| Controller
    SatCM -->|watched by| Controller

    %% Outputs
    Controller -->|emits| Metrics["/metrics :8443<br/>wva_desired_replicas"]
    Metrics -->|scraped by| Prometheus["Prometheus"]
    Prometheus -->|external metric| HPA
    Prometheus -->|external metric| ScaledObj

    %% Scale targets
    HPA -->|scales| Deploy["Deployment"]
    ScaledObj -->|scales| Deploy
    SFZ -->|patches scale 0→1| Deploy
    SFZ -->|patches scale 0→1| LWS["LeaderWorkerSet"]

    %% Prometheus as input
    Prometheus -->|vLLM metrics| Controller
    EPP["EPP / Inference Scheduler"] -->|queue metrics via Prometheus| SFZ
    EPP -->|queue depth via Prometheus| GPURebalance

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style SatV1 fill:#5b9bd5,stroke:#333,color:#fff
    style SatV2 fill:#5b9bd5,stroke:#333,color:#fff
    style SFZ fill:#5b9bd5,stroke:#333,color:#fff
    style Throughput fill:#70ad47,stroke:#333,color:#fff
    style Queueing fill:#70ad47,stroke:#333,color:#fff
    style CoordLoop fill:#ed7d31,stroke:#333,color:#fff
    style GPURebalance fill:#ed7d31,stroke:#333,color:#fff
    style VACR fill:#f5a623,stroke:#333
    style HPA fill:#f5a623,stroke:#333
    style ScaledObj fill:#f5a623,stroke:#333
    style InfPool fill:#f5a623,stroke:#333
    style Metrics fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Deploy fill:#e8e8e8,stroke:#333
    style LWS fill:#e8e8e8,stroke:#333
    style EPP fill:#e8e8e8,stroke:#333
