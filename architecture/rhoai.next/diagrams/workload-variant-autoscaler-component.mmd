graph TB
    subgraph WVA["Workload Variant Autoscaler (WVA)"]
        direction TB
        Controller["controller-manager<br/>(Go Operator / controller-runtime)"]

        subgraph Reconcilers["Reconcilers"]
            VAReconciler["VariantAutoscaling<br/>Reconciler"]
            HPAReconciler["HPA Reconciler<br/>(llm-d.ai/managed=true)"]
            SOReconciler["ScaledObject<br/>Reconciler"]
            CMReconciler["ConfigMap<br/>Reconciler"]
            IPReconciler["InferencePool<br/>Reconciler"]
        end

        subgraph Engines["Scaling Engines"]
            SatEngine["Saturation Engine"]
            SFZEngine["Scale-from-Zero Engine"]
            Coordinator["Coordinator<br/>(experimental)"]
        end

        subgraph Analyzers["Analyzers"]
            V1["V1 Saturation<br/>(% KV cache)"]
            V2["V2 Token-based<br/>(absolute tokens)"]
            QM["Queueing Model<br/>(M/M/c theory)"]
            Throughput["Throughput<br/>Analyzer"]
        end

        subgraph Pipeline["Pipeline"]
            CostOpt["Cost-Aware<br/>Optimizer"]
            GreedyOpt["Greedy Score<br/>Optimizer"]
            Limiter["Default Limiter<br/>(GPU capacity)"]
            Enforcer["Enforcer<br/>(min/max bounds)"]
        end

        subgraph Config["Configuration"]
            ManagerCfg["wva-manager-config"]
            SatCfg["wva-saturation-scaling-config"]
            STZCfg["wva-model-scale-to-zero-config"]
            QMCfg["wva-qm-analyzer-config"]
        end

        subgraph Datastore["Datastore"]
            DS["In-Memory Datastore<br/>(variants, namespaces,<br/>replica metrics)"]
            DecisionCache["Decision Cache<br/>(scale-from-zero)"]
        end

        Controller --> Reconcilers
        Controller --> Engines
        SatEngine --> Analyzers
        SatEngine --> Pipeline
        SFZEngine --> DecisionCache
        CMReconciler --> Config
        Config --> DS
        Reconcilers --> DS
        Engines --> DS
    end

    %% External Resources
    VACR["VariantAutoscaling CR<br/>(llmd.ai/v1alpha1)<br/>DEPRECATED"]
    HPACR["HPA<br/>(autoscaling/v2)<br/>llm-d.ai/managed=true"]
    SOCR["ScaledObject<br/>(keda.sh/v1alpha1)<br/>llm-d.ai/managed=true"]
    IPPool["InferencePool CR<br/>(inference.networking.k8s.io)"]
    ConfigMaps["ConfigMaps<br/>(namespace-aware)"]

    VACR -->|watched by| VAReconciler
    HPACR -->|watched by| HPAReconciler
    SOCR -->|watched by| SOReconciler
    IPPool -->|watched by| IPReconciler
    ConfigMaps -->|watched by| CMReconciler

    %% External Systems
    Prometheus["Prometheus /<br/>Thanos Querier"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    vLLM["vLLM Model Servers"]
    EPP["EPP<br/>(Endpoint Picker Proxy)"]
    HPA["HPA Controller"]
    KEDA["KEDA"]

    vLLM -->|exposes metrics| Prometheus
    SatEngine -->|queries metrics<br/>9090-9091/TCP HTTPS| Prometheus
    SatEngine -->|emits wva_desired_replicas<br/>8443/TCP HTTPS| MetricsEndpoint["/metrics endpoint<br/>8443/TCP HTTPS"]
    SFZEngine -->|scrapes queue_size<br/>HTTPS| EPP
    SFZEngine -->|scales directly<br/>6443/TCP| K8sAPI
    HPA -->|reads external metric| Prometheus
    KEDA -->|reads external metric| Prometheus
    HPA -->|scales| K8sAPI
    KEDA -->|scales| K8sAPI

    %% Styling
    style WVA fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style SatEngine fill:#4a90e2,stroke:#333,color:#fff
    style SFZEngine fill:#4a90e2,stroke:#333,color:#fff
    style Coordinator fill:#90caf9,stroke:#333
