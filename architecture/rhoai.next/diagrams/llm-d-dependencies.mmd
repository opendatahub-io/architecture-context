graph LR
    LLMD["llm-d<br/>Distributed Inference Stack"]

    %% Core Runtime Dependencies
    LLMD -->|"model serving<br/>v0.19.1 (pinned SHA)"| vLLM["vLLM"]
    LLMD -->|"alt model serving"| SGLang["SGLang"]
    LLMD -->|"proxy / routing"| Envoy["Envoy Proxy<br/>(ext-proc protocol)"]
    LLMD -->|"scheduling<br/>v0.7.0"| EPPSched["llm-d-inference-scheduler"]
    LLMD -->|"routing sidecar<br/>v0.7.1"| RoutingSidecar["llm-d-routing-sidecar"]

    %% Gateway Implementations
    LLMD -->|"preferred gateway"| AgentGW["agentgateway"]
    LLMD -.->|"alternative"| Istio["Istio"]
    LLMD -.->|"alternative (GKE)"| GKEGW["GKE Gateway"]
    LLMD -.->|"deprecated"| KGateway["kgateway"]

    %% Kubernetes Dependencies
    LLMD -->|"CRD: InferencePool<br/>v1.4.0"| GatewayAPIIE["Gateway API<br/>Inference Extension"]
    LLMD -->|"multi-node EP"| LWS["LeaderWorkerSet<br/>(CRD)"]
    LLMD -->|"cluster API"| K8sAPI["Kubernetes API<br/>v1.29+"]

    %% GPU / Accelerator Libraries
    LLMD -->|"KV transfer<br/>v0.10.0"| NIXL["NIXL"]
    LLMD -->|"GPU memory reg<br/>v2.5.2"| GDRCOPY["gdrcopy"]
    LLMD -->|"comms framework<br/>v1.20.0"| UCX["UCX"]
    LLMD -->|"GPU shared mem<br/>v3.5.19"| NVSHMEM["NVSHMEM"]
    LLMD -->|"expert parallel<br/>v0.5.1"| DeepEP["DeepEP (fork)"]
    LLMD -->|"inference kernels<br/>v0.6.1"| FlashInfer["FlashInfer"]
    LLMD -->|"GEMM ops"| DeepGEMM["DeepGEMM"]

    %% Caching
    LLMD -->|"tiered cache<br/>v0.3.14"| LMCache["LMCache"]

    %% ML Framework
    LLMD -->|"runtime<br/>2.9.1"| PyTorch["PyTorch"]
    LLMD -->|"runtime<br/>12.9.1"| CUDA["CUDA"]

    %% Helm Charts
    LLMD -->|"infra chart<br/>v1.4.0"| LLMDInfra["llm-d-infra<br/>(Helm)"]
    LLMD -->|"model chart<br/>v0.4.7"| LLMDModel["llm-d-modelservice<br/>(Helm)"]

    %% Monitoring / Observability
    LLMD -.->|"metrics"| Prometheus["Prometheus"]
    LLMD -.->|"dashboards"| Grafana["Grafana"]
    LLMD -.->|"tracing (OTLP)"| Jaeger["Jaeger"]
    LLMD -.->|"instrumentation"| OTel["OpenTelemetry"]

    %% Autoscaling
    LLMD -.->|"HPA metrics"| PromAdapter["Prometheus Adapter"]
    LLMD -.->|"workload autoscaling"| WVA["Workload Variant<br/>Autoscaler (WVA)"]

    %% Async Processing
    LLMD -.->|"async queue (optional)"| PubSub["GCP Pub/Sub"]
    LLMD -.->|"async queue (optional)"| Redis["Redis Sorted Set"]

    %% Infrastructure Providers
    GKE["Google GKE"] -.-> LLMD
    AKS["Azure AKS"] -.-> LLMD
    OCP["OpenShift"] -.-> LLMD
    DOKS["DigitalOcean DOKS"] -.-> LLMD
    Minikube["minikube"] -.-> LLMD

