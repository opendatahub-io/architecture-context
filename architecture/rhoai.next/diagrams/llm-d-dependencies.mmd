graph LR
    LLMD["llm-d<br/>Inference Stack"]

    %% Core Runtime Dependencies
    LLMD -->|"builds from source"| vLLM["vLLM v0.23.0"]
    LLMD -->|"inference routing"| Router["llm-d-router v0.9.0<br/>(Helm chart)"]
    LLMD -->|"benchmarking"| Benchmark["llm-d-benchmark<br/>(CLI tool)"]

    %% Kubernetes/Gateway Dependencies
    LLMD -->|"ingress CRDs"| GatewayAPI["Kubernetes Gateway API v1<br/>Gateway, HTTPRoute"]
    LLMD -->|"endpoint discovery"| GAIE["Gateway API Inference<br/>Extension v1.5.0<br/>InferencePool CRD"]

    %% Gateway Implementations (alternatives)
    subgraph GatewayImpl["Gateway Implementations (choose one)"]
        Istio["Istio<br/>(ext-proc, mTLS opt.)"]
        AgentGW["agentgateway<br/>(lightweight)"]
        EnvoyAI["Envoy AI Gateway<br/>(AI-optimized)"]
        GKE["GKE Gateway<br/>(cloud-managed)"]
    end
    GatewayAPI -->|"implemented by"| GatewayImpl

    %% Accelerator Libraries (CUDA)
    subgraph AccelLibs["Accelerator Libraries (CUDA build)"]
        CUDA["NVIDIA CUDA 13.0.2"]
        UCX["UCX v1.20.0"]
        UCCL["UCCL v0.1.1"]
        NVSHMEM["NVSHMEM v3.4.5-0"]
        NIXL["NIXL v1.2.0"]
        DeepEP["DeepEP"]
        FlashInfer["FlashInfer v0.6.12"]
        LMCache["LMCache v0.4.6"]
        Torch["PyTorch 2.11.0"]
    end
    LLMD -->|"GPU runtime"| AccelLibs

    %% KV-Cache Offloading
    LLMD -->|"KV offloading"| Mooncake["Mooncake v0.8.0<br/>(master-store + client)"]

    %% Multi-node Coordination
    LLMD -->|"multi-node EP"| LWS["LeaderWorkerSet<br/>(CRD)"]

    %% Observability
    LLMD -->|"metrics"| Prometheus["Prometheus"]
    LLMD -->|"dashboards"| Grafana["Grafana"]
    LLMD -->|"tracing"| OTEL["OpenTelemetry<br/>Collector"]
    OTEL -->|"visualization"| Jaeger["Jaeger"]

    %% External Services
    LLMD -->|"model downloads<br/>HTTPS/443<br/>HF_TOKEN"| HFHub["HuggingFace Hub"]

    %% Autoscaling
    LLMD -.->|"SLO-aware scaling"| WVA["Workload Variant<br/>Autoscaler"]

    %% Integration Points (other components depending on llm-d)

