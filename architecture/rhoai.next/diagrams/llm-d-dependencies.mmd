graph LR
    LLMD["llm-d<br/>Distributed Inference<br/>Serving Stack"]

    %% Core Runtime Dependencies
    LLMD -->|"model serving<br/>(primary engine)"| vLLM["vLLM<br/>(pinned commit SHA)"]
    LLMD -->|"model serving<br/>(alternative)"| SGLang["SGLang"]
    LLMD -->|"proxy / routing"| Envoy["Envoy Proxy<br/>(ext-proc protocol)"]
    LLMD -->|"L7 networking"| GatewayAPI["Kubernetes<br/>Gateway API"]

    %% Gateway Implementations
    GatewayAPI -->|"preferred impl"| AgentGW["agentgateway"]
    GatewayAPI -->|"tested impl"| Istio["Istio"]
    GatewayAPI -->|"cloud impl"| GKEGW["GKE Gateway"]
    GatewayAPI -.->|"deprecated"| KGateway["kgateway"]

    %% Scheduling
    LLMD -->|"scheduling brain"| Scheduler["llm-d-inference-scheduler<br/>v0.7.0"]
