graph LR
    LLMD["llm-d<br/>Integration Stack"]

    %% Core Runtime Dependencies
    LLMD -->|"model serving engine"| vLLM["vLLM v0.19.1<br/>(commit-pinned)"]
    LLMD -->|"KV cache transfer"| NIXL["NIXL v1.0.0"]
    LLMD -->|"RDMA/IB transport"| UCX["UCX v1.20.0"]
    LLMD -->|"GPU-to-GPU memory"| NVSHMEM["NVSHMEM v3.5.19-1<br/>(CUDA only)"]

    %% Compute Acceleration Libraries
    LLMD -->|"expert parallelism"| DeepEP["DeepEP<br/>(CUDA only)"]
    LLMD -->|"GEMM kernels"| DeepGEMM["DeepGEMM v2.1.1<br/>(CUDA only)"]
    LLMD -->|"flash attention"| FlashInfer["FlashInfer v0.6.6<br/>(CUDA only)"]
    LLMD -->|"KV cache offload"| LMCache["LMCache v0.4.1<br/>(CUDA only)"]

    %% Infrastructure Dependencies
    LLMD -->|"ingress routing"| GatewayAPI["K8s Gateway API v1"]
    LLMD -->|"inference CRDs"| InferenceGW["K8s Inference Gateway<br/>Extension v1alpha2"]
    LLMD -->|"deep learning framework"| PyTorch["PyTorch 2.10.0"]

    %% Internal llm-d Ecosystem
    LLMD -->|"request routing (EPP)"| EPP["llm-d-inference-scheduler<br/>v0.8.0"]
    LLMD -->|"P/D coordination"| Sidecar["llm-d-routing-sidecar<br/>v0.7.1"]
    LLMD -->|"KV filesystem backend"| KVCache["llm-d-kv-cache"]
    LLMD -->|"workload autoscaling"| WVA["ig-wva<br/>(Workload Variant Autoscaler)"]

    %% Gateway Providers (one required)
    LLMD -->|"gateway provider"| Istio["Istio"]
    LLMD -->|"gateway provider"| AGW["agentgateway<br/>(kgateway)"]
    LLMD -->|"gateway provider"| GKE["GKE Gateway"]

    %% Optional Dependencies
    LLMD -->|"multi-node groups"| LWS["LeaderWorkerSet<br/>Controller<br/>(wide-EP only)"]

    %% Observability
    LLMD -.->|"metrics"| Prometheus["Prometheus"]
    LLMD -.->|"traces"| OTEL["OpenTelemetry SDK<br/>>=1.39.1"]
    LLMD -.->|"dashboards"| Grafana["Grafana"]
    LLMD -.->|"trace UI"| Jaeger["Jaeger"]

    %% External Services
    LLMD -->|"model download"| HF["HuggingFace Hub"]

    %% Downstream consumers
    RHOAI["RHOAI"] -->|"builds downstream images from"| LLMD

