graph LR
    LLMD["llm-d<br/>Integration Stack"]

    %% Core Runtime Dependencies (Required)
    LLMD -->|"model serving engine<br/>(embedded in images)"| vLLM["vLLM v0.19.1<br/>(commit-pinned)"]
    LLMD -->|"KV cache transfer<br/>5600/TCP RDMA"| NIXL["NIXL v1.0.0"]
    LLMD -->|"RDMA/IB transport"| UCX["UCX v1.20.0"]
    LLMD -->|"intelligent routing<br/>gRPC/9002"| EPP["llm-d-inference-scheduler<br/>(EPP) v0.8.0"]
    LLMD -->|"Gateway API impl<br/>(one required)"| GatewayProvider["Gateway Provider<br/>(Istio / agentgateway / GKE)"]

    %% Kubernetes API Dependencies
    LLMD -->|"ingress + routing"| GatewayAPI["K8s Gateway API v1<br/>(Gateway, HTTPRoute)"]
    LLMD -->|"pool + objectives"| InferenceGW["K8s Inference Gateway Ext<br/>(InferencePool,<br/>InferenceObjective)"]

    %% CUDA-Specific Dependencies
    LLMD -.->|"GPU-to-GPU memory<br/>(CUDA only)"| NVSHMEM["NVSHMEM v3.5.19-1"]
    LLMD -.->|"MoE expert parallelism<br/>(CUDA only)"| DeepEP["DeepEP<br/>(commit-pinned)"]
    LLMD -.->|"GEMM kernels<br/>(CUDA only)"| DeepGEMM["DeepGEMM v2.1.1"]
    LLMD -.->|"flash attention<br/>(CUDA only)"| FlashInfer["FlashInfer v0.6.6"]
    LLMD -.->|"KV cache offload<br/>(CUDA only)"| LMCache["LMCache v0.4.1"]
    LLMD -.->|"distributed store<br/>(CUDA only)"| InfiniStore["InfiniStore 0.2.33"]
    LLMD -.->|"GPU-Direct RDMA<br/>(CUDA only)"| GDRCopy["GDRCopy v2.5.2"]

    %% Internal Platform Dependencies
    LLMD -->|"P/D decode sidecar<br/>HTTP/8000"| RoutingSidecar["llm-d-routing-sidecar<br/>v0.7.1"]
    LLMD -.->|"KV cache filesystem"| KVCache["llm-d-kv-cache<br/>(connector library)"]
    LLMD -.->|"SLO-aware autoscaling"| WVA["ig-wva<br/>(Workload Variant Autoscaler)"]

    %% Conditional Dependencies
    LLMD -.->|"multi-node groups<br/>(wide-EP only)"| LWS["LeaderWorkerSet<br/>Controller"]

    %% Observability (Optional)
    LLMD -.->|"metrics/8000"| Prometheus["Prometheus"]
    LLMD -.->|"dashboards"| Grafana["Grafana"]
    LLMD -.->|"traces/4317 OTLP"| OTEL["OTEL Collector"]
    LLMD -.->|"trace viz"| Jaeger["Jaeger"]

    %% External Services
    LLMD -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LLMD -->|"deep learning framework"| PyTorch["PyTorch 2.10.0"]

