graph LR
    LLMd["llm-d<br/>Integration Stack"]

    %% Core Runtime Dependencies (Required)
    LLMd -->|"model serving<br/>v0.19.1"| vLLM["vLLM<br/>(commit-pinned)"]
    LLMd -->|"KV cache transfer<br/>v1.0.0"| NIXL["NIXL"]
    LLMd -->|"RDMA transport<br/>v1.20.0"| UCX["UCX"]
    LLMd -->|"ingress & routing"| GatewayAPI["K8s Gateway API<br/>v1"]
    LLMd -->|"intelligent routing<br/>v0.8.0"| EPP["llm-d-inference-<br/>scheduler (EPP)"]
    LLMd -->|"InferencePool,<br/>InferenceObjective"| InfGW["K8s Inference<br/>Gateway Extension<br/>v1alpha1/v1alpha2"]

    %% Gateway Providers (one required)
    LLMd -.->|"gateway provider"| Istio["Istio"]
    LLMd -.->|"gateway provider"| AGW["agentgateway<br/>(kgateway)"]
    LLMd -.->|"gateway provider"| GKE["GKE Gateway"]

    %% CUDA-only Dependencies
    LLMd -->|"GPU-to-GPU memory"| NVSHMEM["NVSHMEM<br/>v3.5.19-1"]
    LLMd -->|"MoE expert parallelism"| DeepEP["DeepEP"]
    LLMd -->|"GEMM kernels<br/>v2.1.1"| DeepGEMM["DeepGEMM"]
    LLMd -->|"flash attention<br/>v0.6.6"| FlashInfer["FlashInfer"]
    LLMd -->|"KV cache offload<br/>v0.4.1"| LMCache["LMCache"]
    LLMd -->|"distributed store<br/>v0.2.33"| InfiniStore["InfiniStore"]
    LLMd -->|"GPU-Direct RDMA<br/>v2.5.2"| GDRCopy["GDRCopy"]

    %% Framework
    LLMd -->|"deep learning<br/>v2.10.0"| PyTorch["PyTorch"]

    %% Internal Platform Dependencies
    LLMd -->|"P/D coordination<br/>v0.7.1"| RoutingSidecar["llm-d-routing-<br/>sidecar"]
    LLMd -->|"KV cache FS backend"| KVCache["llm-d-kv-cache"]
    LLMd -->|"autoscaling"| WVA["Workload Variant<br/>Autoscaler (WVA)"]

    %% Conditional Dependencies
    LLMd -.->|"wide-EP only"| LWS["LeaderWorkerSet<br/>Controller"]

    %% Observability (Optional)
    LLMd -.->|"tracing"| OTEL["OpenTelemetry<br/>SDK ≥1.39.1"]
    LLMd -.->|"metrics"| Prometheus["Prometheus"]
    LLMd -.->|"dashboards"| Grafana["Grafana"]
    LLMd -.->|"trace viz"| Jaeger["Jaeger"]

    %% External Services
    LLMd -->|"model download<br/>HTTPS/443"| HF["HuggingFace Hub"]

