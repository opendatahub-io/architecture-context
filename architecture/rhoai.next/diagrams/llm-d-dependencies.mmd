    vLLM -->|"expert parallelism"| DeepEP["DeepEP<br/>v0.5.1 (fork)"]
    vLLM -->|"GPU runtime"| CUDA["CUDA<br/>12.9.1"]
    vLLM -->|"runtime"| Python["Python<br/>3.12"]

    %% Kubernetes
    LLMD -->|"CRD: InferencePool"| GAIE["Gateway API<br/>Inference Extension"]
    LLMD -->|"multi-node coordination"| LWS["LeaderWorkerSet<br/>(CRD)"]
    LLMD -->|"cluster orchestration"| K8s["Kubernetes<br/>v1.29+"]

    %% Helm Charts
    LLMD -->|"infrastructure chart"| HelmInfra["llm-d-infra<br/>v1.4.0"]
