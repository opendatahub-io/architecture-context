graph LR
    LLMD["llm-d<br/>Inference Serving Stack"]

    %% Core Runtime Dependencies
    subgraph CoreRuntime["Core Runtime"]
        vLLM["vLLM<br/>(Neural Magic fork)<br/>v0.19.1"]
        PyTorch["PyTorch<br/>2.10.0"]
        CUDA["CUDA Toolkit<br/>13.0.2"]
    end

    LLMD -->|"inference engine"| vLLM
    LLMD -->|"deep learning framework"| PyTorch
    LLMD -->|"GPU compute (NVIDIA)"| CUDA

    %% Communication Libraries
    subgraph CommLibs["Communication Libraries"]
        NIXL["NIXL<br/>v1.0.0"]
        UCX["UCX<br/>v1.20.0"]
        NVSHMEM["NVSHMEM<br/>v3.4.5-0"]
        GDRCopy["GDRCopy<br/>v2.5.2"]
    end

    LLMD -->|"KV cache transfer"| NIXL
    LLMD -->|"RDMA transport"| UCX
    LLMD -->|"GPU collectives"| NVSHMEM
    LLMD -->|"GPU-Direct RDMA"| GDRCopy

    %% Optimized Kernels
    subgraph Kernels["Optimized Kernels"]
        DeepEP["DeepEP<br/>38d21b7"]
        DeepGEMM["DeepGEMM<br/>477618c"]
        FlashInfer["FlashInfer<br/>v0.6.6"]
    end

    LLMD -->|"MoE expert parallel"| DeepEP
    LLMD -->|"GEMM kernels"| DeepGEMM
    LLMD -->|"attention kernels"| FlashInfer

    %% KV Cache Management
    subgraph KVCache["KV Cache Management"]
        LMCache["LMCache<br/>v0.4.4-cu13"]
        InfiniStore["InfiniStore<br/>0.2.33"]
        KVConnector["llm-d-kv-cache<br/>connector 0.19"]
    end

    LLMD -->|"tiered KV offloading"| LMCache
    LMCache -->|"distributed backend"| InfiniStore
    LLMD -.->|"storage offloading"| KVConnector

    %% Internal Platform Dependencies (sibling repos)
    subgraph InternalPlatform["Internal llm-d Ecosystem"]
        EPP["llm-d-inference-scheduler<br/>(EPP)"]
        GAIE["Gateway API<br/>Inference Extension"]
        WVA["Workload Variant<br/>Autoscaler (WVA)"]
        LatPred["Latency Predictor<br/>(XGBoost)"]
        KVIndexer["KV-Cache Indexer<br/>(ZMQ)"]
    end

    LLMD -->|"ext-proc gRPC :9002"| EPP
    LLMD -->|"InferencePool CRD"| GAIE
    WVA -->|"HPA/KEDA scaling"| LLMD
    EPP --- LatPred
    EPP --- KVIndexer

    %% Infrastructure Dependencies
    subgraph Infrastructure["Kubernetes Infrastructure"]
        GatewayAPI["Kubernetes<br/>Gateway API"]
        Envoy["Envoy / Istio /<br/>AgentGateway"]
        LWS["LeaderWorkerSet<br/>(LWS)"]
    end

    LLMD -->|"Gateway/HTTPRoute CRDs"| GatewayAPI
    LLMD -->|"L7 proxy + ext-proc"| Envoy
    LLMD -.->|"multi-node inference"| LWS

    %% Monitoring
    subgraph Monitoring["Monitoring Stack"]
        Prometheus["Prometheus"]
        OTel["OpenTelemetry<br/>SDK >=1.39.1"]
        Grafana["Grafana"]
    end

    Prometheus -->|"PodMonitor :8000"| LLMD
    LLMD -->|"OTLP traces :4317"| OTel
    Grafana -->|"dashboards"| Prometheus

    %% External Services
    subgraph ExternalSvc["External Services"]
        HFHub["HuggingFace Hub"]
    end

    LLMD -->|"model downloads<br/>HTTPS :443"| HFHub

    %% Accelerator Variants
    subgraph AccelVariants["Accelerator Variants"]
        RIXL["RIXL (ROCm NIXL)<br/>39be1de"]
        VLLMGaudi["vLLM-Gaudi<br/>v0.16.0"]
        HabanaPT["Habana PyTorch<br/>2.9.0"]
        EFA["AWS EFA Installer<br/>1.46.0"]
    end

    LLMD -.->|"AMD ROCm RDMA"| RIXL
    LLMD -.->|"Intel Gaudi plugin"| VLLMGaudi
    VLLMGaudi -->|"runtime"| HabanaPT
    LLMD -.->|"AWS networking"| EFA

