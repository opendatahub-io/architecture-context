graph TB
    subgraph LlamaStack["Llama Stack Server"]
        direction TB
        FastAPI["FastAPI/uvicorn<br/>Port 8321/TCP"]

        subgraph Middleware["ASGI Middleware Chain"]
            direction LR
            ClientVersion["ClientVersion<br/>Middleware"]
            AuthMW["Authentication<br/>Middleware"]
            QuotaMW["Quota<br/>Middleware"]
            TracingMW["Tracing<br/>Middleware"]
            ClientVersion --> AuthMW --> QuotaMW --> TracingMW
        end

        subgraph Routers["API Routers (Dynamic)"]
            InferenceRouter["Inference Router"]
            AgentsRouter["Agents Router"]
            SafetyRouter["Safety Router"]
            VectorIORouter["Vector IO Router"]
            EvalRouter["Eval Router"]
            TelemetryRouter["Telemetry Router"]
            ToolRouter["Tool Runtime Router"]
        end

        subgraph ProviderSystem["Provider Plugin System"]
            direction TB
            Resolver["Provider Resolver"]
            InlineProviders["Inline Providers<br/>(in-process)"]
            RemoteProviders["Remote Providers<br/>(HTTP adapters)"]
            Resolver --> InlineProviders
            Resolver --> RemoteProviders
        end

        subgraph AccessControl["Access Control (ABAC)"]
            CedarRules["Cedar-like<br/>Policy Rules"]
        end

        FastAPI --> Middleware
        TracingMW --> Routers
        Routers --> ProviderSystem
        AuthMW --> AccessControl
    end

    subgraph DistTemplates["Distribution Templates"]
        RemoteVLLM["remote-vllm"]
        Starter["starter"]
        OllamaTemplate["ollama"]
    end

    subgraph Clients["Clients"]
        ExtClient["External Client"]
        CLI["llama CLI"]
        StreamlitUI["Streamlit UI"]
        NextUI["Next.js UI"]
    end

    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Server<br/>8000/TCP"]
        Ollama["Ollama<br/>11434/TCP"]
        OpenAIAPI["OpenAI API<br/>443/TCP"]
        AnthropicAPI["Anthropic API<br/>443/TCP"]
        Bedrock["AWS Bedrock<br/>443/TCP"]
    end

    subgraph Storage["Storage Backends"]
        PgVector["PostgreSQL + pgvector<br/>5432/TCP"]
        ChromaDB["Chroma<br/>8000/TCP"]
        QdrantDB["Qdrant<br/>6333/TCP"]
        Redis["Redis<br/>6379/TCP"]
    end

    subgraph AuthProviders["Auth Providers"]
        OAuth2["OAuth2/OIDC<br/>(JWKS/Introspection)"]
        CustomAuth["Custom Auth<br/>Endpoint"]
    end

    %% Client connections
    ExtClient -->|"REST API<br/>8321/TCP<br/>Bearer Token"| FastAPI
    CLI -->|"REST API"| FastAPI
    StreamlitUI -->|"REST API"| FastAPI
    NextUI -->|"REST API"| FastAPI

    %% Distribution templates configure providers
    DistTemplates -.->|"configures"| Resolver

    %% Provider connections to backends
    RemoteProviders -->|"OpenAI-compatible API<br/>8000/TCP"| vLLM
    RemoteProviders -->|"REST API<br/>11434/TCP"| Ollama
    RemoteProviders -->|"REST API<br/>443/TCP HTTPS"| OpenAIAPI
    RemoteProviders -->|"REST API<br/>443/TCP HTTPS"| AnthropicAPI
    RemoteProviders -->|"REST API<br/>443/TCP HTTPS"| Bedrock

    %% Storage connections
    RemoteProviders -->|"PostgreSQL<br/>5432/TCP"| PgVector
    RemoteProviders -->|"HTTP<br/>8000/TCP"| ChromaDB
    RemoteProviders -->|"HTTP/gRPC<br/>6333/TCP"| QdrantDB
    RemoteProviders -->|"Redis Protocol<br/>6379/TCP"| Redis

    %% Auth connections
    AuthMW -->|"HTTPS<br/>443/TCP"| OAuth2
    AuthMW -->|"HTTPS"| CustomAuth

    %% Styling
    style FastAPI fill:#4a90e2,stroke:#333,color:#fff
    style AuthMW fill:#e74c3c,stroke:#333,color:#fff
    style QuotaMW fill:#e74c3c,stroke:#333,color:#fff
    style TracingMW fill:#3498db,stroke:#333,color:#fff
    style ClientVersion fill:#3498db,stroke:#333,color:#fff
    style Resolver fill:#9b59b6,stroke:#333,color:#fff
    style InlineProviders fill:#27ae60,stroke:#333,color:#fff
    style RemoteProviders fill:#f39c12,stroke:#333,color:#fff
    style CedarRules fill:#e74c3c,stroke:#333,color:#fff
    style vLLM fill:#95a5a6,stroke:#333,color:#fff
    style Ollama fill:#95a5a6,stroke:#333,color:#fff
    style OpenAIAPI fill:#95a5a6,stroke:#333,color:#fff
    style AnthropicAPI fill:#95a5a6,stroke:#333,color:#fff
    style Bedrock fill:#95a5a6,stroke:#333,color:#fff
    style PgVector fill:#e8e8e8,stroke:#333
    style ChromaDB fill:#e8e8e8,stroke:#333
    style QdrantDB fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style OAuth2 fill:#f5a623,stroke:#333,color:#fff
    style CustomAuth fill:#f5a623,stroke:#333,color:#fff
