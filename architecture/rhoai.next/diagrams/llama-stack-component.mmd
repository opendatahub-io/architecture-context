graph TB
    subgraph LlamaStack["Llama Stack Server (FastAPI/Uvicorn — 8321/TCP)"]
        direction TB

        subgraph Middleware["Request Pipeline"]
            AuthMiddleware["Authentication Middleware<br/>OAuth2 JWT / JWKS / Introspection"]
            QuotaMiddleware["Quota Middleware<br/>Per-client rate limiting"]
            AuthMiddleware --> QuotaMiddleware
        end

        subgraph Core["Core Routing"]
            ProviderRouter["Provider Router<br/>Routes by model/resource ID"]
            AccessControl["Access Control Engine<br/>Cedar-inspired ABAC policies"]
            QuotaMiddleware --> AccessControl
            AccessControl --> ProviderRouter
        end

        subgraph APIs["API Surfaces"]
            InferenceAPI["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*<br/>/v1/openai/v1/responses/*"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorIOAPI["Vector I/O API<br/>/v1/vector-io/*<br/>/v1/vector-dbs/*"]
            EvalAPI["Eval API<br/>/v1/eval/*<br/>/v1/scoring/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
            ToolsAPI["Tools API<br/>/v1/tools/*<br/>/v1/tool-runtime/*"]
            FilesAPI["Files & Datasets API<br/>/v1/openai/v1/files/*<br/>/v1/datasets/*"]
        end

        ProviderRouter --> InferenceAPI
        ProviderRouter --> AgentsAPI
        ProviderRouter --> SafetyAPI
        ProviderRouter --> VectorIOAPI
        ProviderRouter --> EvalAPI
        ProviderRouter --> TelemetryAPI
        ProviderRouter --> ToolsAPI
        ProviderRouter --> FilesAPI
    end

    Client["Client Application"] -->|"POST /v1/inference/chat-completion<br/>8321/TCP HTTP/HTTPS<br/>Bearer JWT"| AuthMiddleware

    CLI["CLI (llama)<br/>build, run, download"] -.->|"manages"| LlamaStack

    subgraph InlineProviders["Inline Providers (in-process)"]
        MetaRef["meta-reference<br/>(PyTorch inference)"]
        FAISS["FAISS<br/>(vector store)"]
        SQLiteStore["SQLite<br/>(metadata/quota)"]
    end

    subgraph RemoteProviders["Remote Providers (HTTP adapters)"]
        vLLM["vLLM<br/>8000/TCP"]
        OllamaP["Ollama<br/>11434/TCP"]
        TGIP["TGI<br/>443/TCP"]
        OpenAIP["OpenAI API<br/>443/TCP"]
        BedrockP["AWS Bedrock<br/>443/TCP"]
    end

    subgraph VectorDBs["Vector Databases"]
        PGVector["PostgreSQL pgvector<br/>5432/TCP"]
        ChromaDB["ChromaDB<br/>8000/TCP"]
        Qdrant["Qdrant<br/>6333/TCP"]
        Milvus["Milvus<br/>19530/TCP"]
    end

    subgraph ExternalTools["External Tools"]
        BraveSearch["Brave Search<br/>443/TCP"]
        TavilySearch["Tavily Search<br/>443/TCP"]
        WolframAlpha["Wolfram Alpha<br/>443/TCP"]
    end

    InferenceAPI --> MetaRef
    InferenceAPI --> vLLM
    InferenceAPI --> OllamaP
    InferenceAPI --> TGIP
    InferenceAPI --> OpenAIP
    InferenceAPI --> BedrockP

    VectorIOAPI --> FAISS
    VectorIOAPI --> PGVector
    VectorIOAPI --> ChromaDB
    VectorIOAPI --> Qdrant
    VectorIOAPI --> Milvus

    ToolsAPI --> BraveSearch
    ToolsAPI --> TavilySearch
    ToolsAPI --> WolframAlpha

    AuthMiddleware -->|"JWKS fetch"| IdP["OAuth2 IdP<br/>443/TCP HTTPS"]
    QuotaMiddleware --> SQLiteStore
    TelemetryAPI --> OTLP["OTLP Collector<br/>4318/TCP"]

    DistTemplates["Distribution Templates<br/>(YAML configs)"] -.->|"configures providers"| ProviderRouter

