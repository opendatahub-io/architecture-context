graph TB
    subgraph LlamaStack["Llama Stack Server (FastAPI/uvicorn)"]
        direction TB

        subgraph Middleware["ASGI Middleware Chain"]
            ClientVersion["ClientVersionMiddleware"]
            AuthMW["AuthenticationMiddleware<br/>JWT/JWKS + Introspection"]
            QuotaMW["QuotaMiddleware<br/>Rate Limiting"]
            TracingMW["TracingMiddleware<br/>x-trace-id header"]
            ClientVersion --> AuthMW --> QuotaMW --> TracingMW
        end

        subgraph APIs["API Surfaces (Dynamic Routes)"]
            InferenceAPI["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorIOAPI["Vector IO API<br/>/v1/vector-io/*"]
            EvalAPI["Eval & Scoring API<br/>/v1/eval/*<br/>/v1/scoring/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
            ToolsAPI["Tool Runtime API<br/>/v1/tool-runtime/*"]
            RegistryAPIs["Registry APIs<br/>/v1/models, /v1/shields<br/>/v1/datasets, /v1/vector-dbs"]
        end

        subgraph ProviderSystem["Provider Plugin System"]
            Resolver["Provider Resolver<br/>Dynamic Import & DI"]
            InlineProviders["Inline Providers<br/>(in-process)"]
            RemoteProviders["Remote Providers<br/>(HTTP adapters)"]
            Resolver --> InlineProviders
            Resolver --> RemoteProviders
        end

        subgraph AccessControl["Access Control System"]
            ABAC["ABAC Engine<br/>Cedar-like Policy Rules"]
        end

        TracingMW --> APIs
        APIs --> ProviderSystem
        APIs --> AccessControl
    end

    subgraph CLI["CLI Tool"]
        LlamaCLI["llama CLI<br/>Build/Run/Manage distributions"]
    end

    subgraph OptionalUI["Optional UIs"]
        StreamlitUI["Streamlit UI<br/>Playground & Eval"]
        NextUI["Next.js UI<br/>Log Viewer"]
    end

    subgraph DistTemplates["Distribution Templates"]
        RemoteVLLM["remote-vllm"]
        Starter["starter"]
        OllamaTemplate["ollama"]
    end

    %% External connections
    Client[Client / Application] -->|"REST API<br/>8321/TCP"| LlamaStack
    LlamaCLI -->|manages| LlamaStack
    StreamlitUI -->|"REST API"| LlamaStack
    NextUI -->|"REST API"| LlamaStack
    DistTemplates -.->|configures| Resolver

    %% Provider backends
    InlineProviders -->|"in-process"| vLLMLocal["vLLM (local)"]
    InlineProviders -->|"in-process"| FAISS["FAISS Vector"]
    InlineProviders -->|"in-process"| SentenceTransformers["sentence-transformers"]
    InlineProviders -->|"in-process"| SQLiteVec["SQLite-vec"]

    RemoteProviders -->|"HTTP/8000"| vLLMRemote["vLLM Server"]
    RemoteProviders -->|"HTTP/5432"| PgVector["PostgreSQL + pgvector"]
    RemoteProviders -->|"HTTPS/443"| OpenAI["OpenAI API"]
    RemoteProviders -->|"HTTPS/443"| Anthropic["Anthropic API"]
    RemoteProviders -->|"HTTP"| ChromaDB["ChromaDB"]
    RemoteProviders -->|"HTTP/gRPC"| Qdrant["Qdrant"]

    AuthMW -->|"HTTPS/443"| OAuth2["OAuth2/OIDC<br/>JWKS + Introspection"]

    %% Styling
    style LlamaStack fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Middleware fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style APIs fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    style ProviderSystem fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    style AccessControl fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style Client fill:#e3f2fd,stroke:#1976d2,stroke-width:2px

    style vLLMRemote fill:#e0e0e0,stroke:#616161
    style PgVector fill:#e0e0e0,stroke:#616161
    style OpenAI fill:#e0e0e0,stroke:#616161
    style Anthropic fill:#e0e0e0,stroke:#616161
    style ChromaDB fill:#e0e0e0,stroke:#616161
    style Qdrant fill:#e0e0e0,stroke:#616161
    style OAuth2 fill:#e0e0e0,stroke:#616161

    style vLLMLocal fill:#f5f5f5,stroke:#9e9e9e
    style FAISS fill:#f5f5f5,stroke:#9e9e9e
    style SentenceTransformers fill:#f5f5f5,stroke:#9e9e9e
    style SQLiteVec fill:#f5f5f5,stroke:#9e9e9e
