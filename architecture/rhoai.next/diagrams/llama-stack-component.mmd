graph TB
    subgraph LlamaStack["Llama Stack Server (Port 8321)"]
        direction TB
        FastAPI["FastAPI / Uvicorn<br/>ASGI Server"]

        subgraph Middleware["Middleware Stack"]
            AuthMW["Authentication<br/>Middleware<br/>(OAuth2 JWT / Custom)"]
            ACMW["Access Control<br/>Middleware<br/>(Cedar ABAC)"]
            QuotaMW["Quota Middleware<br/>(Rate Limiting)"]
            TraceMW["Tracing Middleware<br/>(W3C TraceContext)"]
        end

        subgraph APIRouters["API Routers"]
            InfRouter["Inference Router"]
            AgentRouter["Agent Router"]
            SafetyRouter["Safety Router"]
            VectorRouter["Vector IO Router"]
            EvalRouter["Eval Router"]
            ToolRouter["Tool Runtime Router"]
            TrainRouter["Post-Training Router"]
            TelRouter["Telemetry Router"]
        end

        subgraph ProviderRegistry["Provider Registry"]
            InlineProviders["Inline Providers<br/>(in-process)"]
            RemoteProviders["Remote Providers<br/>(adapters)"]
        end

        DistSystem["Distribution System<br/>(YAML Config Loader)"]
        ACEngine["Access Control Engine<br/>(Cedar-inspired Policies)"]
    end

    subgraph CLI["CLI (llama)"]
        CLIBuild["llama stack build"]
        CLIRun["llama stack run"]
        CLIConfig["llama stack configure"]
    end

    subgraph UI["Llama Stack UI"]
        NextJS["Next.js Frontend<br/>(Chat Playground + Log Viewer)"]
    end

    %% Flow
    Client[Client / Application] -->|"REST API<br/>8321/TCP"| FastAPI
    FastAPI --> AuthMW
    AuthMW --> ACMW
    ACMW --> QuotaMW
    QuotaMW --> TraceMW
    TraceMW --> APIRouters

    APIRouters --> ProviderRegistry
    ProviderRegistry --> InlineProviders
    ProviderRegistry --> RemoteProviders

    DistSystem -->|"configures"| ProviderRegistry
    ACEngine -->|"evaluates policies"| ACMW

    CLIRun -->|"launches"| FastAPI
    NextJS -->|"REST API<br/>8321/TCP"| FastAPI

    %% External connections
    RemoteProviders -->|"HTTP/HTTPS"| vLLM["vLLM<br/>8000/TCP"]
    RemoteProviders -->|"HTTP"| Ollama["Ollama<br/>11434/TCP"]
    RemoteProviders -->|"HTTPS/443"| CloudAPIs["Cloud LLM APIs<br/>(OpenAI, Anthropic,<br/>Bedrock, etc.)"]
    RemoteProviders -->|"TCP/5432"| PgVector["PostgreSQL<br/>pgvector"]
    RemoteProviders -->|"HTTP/HTTPS"| VectorDBs["Vector DBs<br/>(Chroma, Qdrant,<br/>Milvus, Weaviate)"]

    AuthMW -->|"HTTPS/443"| OIDC["OIDC Provider<br/>(JWKS / Introspection)"]

    TraceMW -->|"OTLP HTTP"| OTel["OpenTelemetry<br/>Collector"]

    InlineProviders -->|"File I/O"| SQLite["SQLite<br/>(Registry, Agents, Traces)"]

