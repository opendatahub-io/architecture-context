graph TB
    subgraph LlamaStack["Llama Stack Server (FastAPI/Uvicorn · 8321/TCP)"]
        direction TB

        subgraph Middleware["Request Middleware Pipeline"]
            AuthMiddleware["Authentication Middleware<br/>OAuth2 JWT (JWKS) / Token Introspection<br/>Custom Auth Provider"]
            QuotaMiddleware["Quota Middleware<br/>Per-client rate limiting<br/>100/day anon · 1000/day auth"]
            AccessControl["Access Control Engine<br/>Cedar-inspired ABAC<br/>Permit/Forbid per resource"]
            AuthMiddleware --> QuotaMiddleware
            QuotaMiddleware --> AccessControl
        end

        subgraph Core["Core Routing"]
            ProviderRouter["Provider Router<br/>Routes by model/resource ID<br/>to correct provider"]
        end

        subgraph APIs["API Surfaces"]
            InferenceAPI["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*<br/>/v1/openai/v1/responses"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorIOAPI["Vector I/O API<br/>/v1/vector-io/*<br/>/v1/vector-dbs/*"]
            EvalAPI["Eval & Scoring API<br/>/v1/eval/*<br/>/v1/scoring/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
            ToolsAPI["Tools API<br/>/v1/tools/*<br/>/v1/tool-runtime/*"]
            FilesAPI["Files & Datasets API<br/>/v1/openai/v1/files/*<br/>/v1/datasets/*"]
        end

        AccessControl --> ProviderRouter
        ProviderRouter --> InferenceAPI
        ProviderRouter --> AgentsAPI
        ProviderRouter --> SafetyAPI
        ProviderRouter --> VectorIOAPI
        ProviderRouter --> EvalAPI
        ProviderRouter --> TelemetryAPI
        ProviderRouter --> ToolsAPI
        ProviderRouter --> FilesAPI
    end

    subgraph CLI["CLI"]
        LlamaCLI["llama CLI<br/>build · run · model download<br/>template management"]
    end

    subgraph DistConfig["Distribution Configuration"]
        Templates["Distribution Templates<br/>(YAML: run.yaml + build.yaml)<br/>remote-vllm · ollama · bedrock · etc."]
    end

    Client["Client / API Consumer"] -->|"POST /v1/inference/chat-completion<br/>Bearer Token (JWT)"| LlamaStack
    LlamaCLI -->|"starts server with<br/>--config run.yaml"| LlamaStack
    Templates -->|"configures providers"| LlamaStack

    subgraph InferenceBackends["Inference Backends (Remote Providers)"]
        vLLM["vLLM<br/>8000/TCP"]
        Ollama["Ollama<br/>11434/TCP"]
        TGI["TGI<br/>443/TCP"]
        CloudAPIs["Cloud APIs<br/>(OpenAI · Anthropic · Bedrock<br/>Gemini · NVIDIA · Together)"]
    end

    subgraph VectorStores["Vector Stores"]
        pgvector["PostgreSQL pgvector<br/>5432/TCP"]
        ChromaDB["ChromaDB<br/>8000/TCP"]
        Qdrant["Qdrant<br/>6333/TCP"]
        Milvus["Milvus<br/>19530/TCP"]
    end

    subgraph ExternalServices["External Services"]
        OAuth2IdP["OAuth2 IdP<br/>JWKS / Introspection<br/>443/TCP"]
        OTLP["OTLP Collector<br/>4318/TCP"]
        SearchAPIs["Search APIs<br/>(Brave · Tavily · Bing)<br/>443/TCP"]
        SQLite["SQLite<br/>(metadata · quotas · inference store)"]
    end

    InferenceAPI -->|"HTTP/HTTPS"| InferenceBackends
    AgentsAPI -->|"HTTP/HTTPS"| InferenceBackends
    AgentsAPI -->|"HTTPS"| SearchAPIs
    VectorIOAPI -->|"TCP/HTTP"| VectorStores
    AuthMiddleware -->|"HTTPS/443"| OAuth2IdP
    TelemetryAPI -->|"HTTP/4318"| OTLP
    QuotaMiddleware -->|"File I/O"| SQLite

