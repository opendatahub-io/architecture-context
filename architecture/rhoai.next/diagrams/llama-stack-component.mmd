graph TB
    subgraph LlamaStack["Llama Stack Server"]
        direction TB
        Server["FastAPI/Uvicorn Server<br/>Port 8321/TCP"]
        AuthMiddleware["Authentication Middleware<br/>(OAuth2 JWT / Custom)"]
        QuotaMiddleware["Quota Middleware<br/>(Rate Limiting)"]
        AccessControl["Access Control Engine<br/>(Cedar-inspired ABAC)"]
        DistSystem["Distribution System<br/>(Provider Composition)"]

        subgraph APIRouters["API Routers"]
            InferenceRouter["Inference Router"]
            AgentRouter["Agent Router"]
            SafetyRouter["Safety Router"]
            VectorIORouter["Vector I/O Router"]
            EvalRouter["Eval Router"]
            ToolRouter["Tool Runtime Router"]
            TelemetryRouter["Telemetry Router"]
            DatasetRouter["Dataset Router"]
            ScoringRouter["Scoring Router"]
            PostTrainingRouter["Post-Training Router"]
        end

        subgraph ProviderRegistry["Provider Registry"]
            InlineProviders["Inline Providers<br/>(in-process)"]
            RemoteProviders["Remote Providers<br/>(API adapters)"]
        end
    end

    subgraph UI["Llama Stack UI"]
        NextJS["Next.js Frontend<br/>(Log Viewer & Playground)"]
    end

    subgraph CLI["CLI"]
        LlamaCLI["llama CLI<br/>(Build/Configure/Run)"]
    end

    Client["API Client<br/>(SDK / curl)"] -->|"REST API<br/>8321/TCP"| Server
    Server --> AuthMiddleware
    AuthMiddleware --> QuotaMiddleware
    QuotaMiddleware --> AccessControl
    AccessControl --> APIRouters
    APIRouters --> DistSystem
    DistSystem --> ProviderRegistry

    NextJS -->|"REST API<br/>8321/TCP"| Server
    LlamaCLI -->|"Manages"| DistSystem

    %% External provider connections
    RemoteProviders -->|"HTTP/HTTPS"| vLLM["vLLM<br/>8000/TCP"]
    RemoteProviders -->|"HTTP"| Ollama["Ollama<br/>11434/TCP"]
    RemoteProviders -->|"HTTPS/443"| CloudAPIs["Cloud APIs<br/>(OpenAI, Anthropic,<br/>Bedrock, etc.)"]
    RemoteProviders -->|"SQL/5432"| pgvector["PostgreSQL/pgvector"]
    RemoteProviders -->|"HTTP/HTTPS"| VectorDBs["Vector DBs<br/>(ChromaDB, Qdrant,<br/>Milvus, Weaviate)"]

    InlineProviders -->|"File I/O"| SQLite["SQLite<br/>(Default Persistence)"]

    AuthMiddleware -->|"HTTPS/443"| OIDC["OIDC Provider<br/>(JWKS / Introspection)"]

