    style AgentsAPI fill:#7ed321,stroke:#333
    style SafetyAPI fill:#7ed321,stroke:#333
    style VectorAPI fill:#7ed321,stroke:#333
    style EvalAPI fill:#7ed321,stroke:#333
    style ToolsAPI fill:#7ed321,stroke:#333
    style PostTrainAPI fill:#7ed321,stroke:#333
    style TelemetryAPI fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
