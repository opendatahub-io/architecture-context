graph TB
    subgraph LlamaStack["Llama Stack Server (FastAPI/uvicorn :8321)"]
        direction TB

        subgraph Middleware["ASGI Middleware Chain"]
            ClientVersion["ClientVersionMiddleware"]
            AuthMW["AuthenticationMiddleware<br/>JWT/JWKS + Introspection"]
            QuotaMW["QuotaMiddleware<br/>Rate Limiting"]
            TracingMW["TracingMiddleware<br/>x-trace-id header"]
            ClientVersion --> AuthMW --> QuotaMW --> TracingMW
        end

        subgraph AccessControl["Access Control"]
            ABAC["ABAC Engine<br/>Cedar-like Policy Rules"]
        end

        subgraph APIRouter["Dynamic Route System"]
            InferenceAPI["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorIOAPI["Vector IO API<br/>/v1/vector-io/*"]
            EvalAPI["Eval API<br/>/v1/eval/*"]
            ScoringAPI["Scoring API<br/>/v1/scoring/*"]
            PostTrainingAPI["Post-Training API<br/>/v1/post-training/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
            ToolRuntimeAPI["Tool Runtime API<br/>/v1/tool-runtime/*"]
            RegistryAPIs["Registry APIs<br/>/v1/models, /v1/shields,<br/>/v1/datasets, /v1/vector-dbs"]
        end

        subgraph Providers["Provider Plugin System"]
            direction LR
            InlineProviders["Inline Providers<br/>(in-process)"]
            RemoteProviders["Remote Providers<br/>(HTTP adapters)"]
        end

        TracingMW --> ABAC
        ABAC --> APIRouter
        APIRouter --> Providers
    end

    subgraph DistTemplates["Distribution Templates"]
        RemoteVLLM["remote-vllm"]
        Starter["starter"]
        OllamaTemplate["ollama"]
        Custom["custom configs"]
    end

    subgraph CLI["CLI (llama)"]
        Build["llama stack build"]
        Run["llama stack run"]
        Configure["llama stack configure"]
    end

    subgraph OptionalUI["Optional UIs"]
        StreamlitUI["Streamlit UI<br/>(Python)"]
        NextUI["Next.js UI<br/>(TypeScript)"]
    end

    Client["Client / Application"]
    Client -->|"REST API :8321<br/>HTTP/HTTPS"| Middleware

    DistTemplates -.->|configures| Providers
    CLI -.->|manages| LlamaStack
    OptionalUI -.->|"REST API :8321"| LlamaStack

    %% Provider backends
    InlineProviders -->|"in-process"| VLLMLocal["vLLM (local)"]
    InlineProviders -->|"in-process"| FAISS["FAISS"]
    InlineProviders -->|"in-process"| SentenceTransformers["sentence-transformers"]
    InlineProviders -->|"in-process"| SQLiteVec["sqlite-vec"]

    RemoteProviders -->|"HTTP :8000"| VLLMRemote["vLLM (remote)"]
    RemoteProviders -->|"HTTPS :443"| CloudAPIs["Cloud APIs<br/>(OpenAI, Anthropic,<br/>Bedrock, Gemini)"]
    RemoteProviders -->|"TCP :5432"| PGVector["PostgreSQL + pgvector"]
    RemoteProviders -->|"TCP :6379"| Redis["Redis"]

    %% Styling
    style LlamaStack fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Middleware fill:#fff3e0,stroke:#ef6c00,stroke-width:1px
    style AccessControl fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style APIRouter fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style Providers fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px
    style Client fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    style DistTemplates fill:#e0f2f1,stroke:#00695c,stroke-width:1px
    style CLI fill:#e0f2f1,stroke:#00695c,stroke-width:1px
    style OptionalUI fill:#e0f2f1,stroke:#00695c,stroke-width:1px
    style VLLMRemote fill:#e8e8e8,stroke:#333
    style CloudAPIs fill:#e8e8e8,stroke:#333
    style PGVector fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style VLLMLocal fill:#e8e8e8,stroke:#333
    style FAISS fill:#e8e8e8,stroke:#333
    style SentenceTransformers fill:#e8e8e8,stroke:#333
    style SQLiteVec fill:#e8e8e8,stroke:#333
