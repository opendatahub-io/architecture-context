graph TB
    subgraph LlamaStack["Llama Stack Server (8321/TCP)"]
        direction TB
        FastAPI["FastAPI / Uvicorn<br/>ASGI HTTP Server"]

        subgraph Middleware["Middleware Stack"]
            AuthMiddleware["AuthenticationMiddleware<br/>OAuth2 JWT / Custom"]
            QuotaMiddleware["QuotaMiddleware<br/>Rate Limiting"]
            TracingMiddleware["TracingMiddleware<br/>OpenTelemetry W3C"]
            ACMiddleware["AccessControlMiddleware<br/>Cedar-inspired ABAC"]
        end

        subgraph APIs["API Layer (Protocol-Oriented)"]
            InferenceAPI["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorAPI["Vector IO API<br/>/v1/vector-io/*"]
            EvalAPI["Eval API<br/>/v1/eval/*"]
            ToolsAPI["Tools API<br/>/v1/toolgroups/*<br/>/v1/tool-runtime/*"]
            PostTrainAPI["Post-Training API<br/>/v1/post-training/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
        end

        subgraph Routing["Router Layer"]
            InferenceRouter["InferenceRouter"]
            SafetyRouter["SafetyRouter"]
            AgentProvider["Agent Provider"]
            VectorRouter["VectorIORouter"]
        end

        subgraph Core["Core Components"]
            DistSystem["Distribution System<br/>YAML Config Composer"]
            ProviderRegistry["Provider Registry<br/>Inline + Remote"]
            AccessControl["Access Control Engine<br/>Cedar-inspired Policies"]
        end

        FastAPI --> AuthMiddleware
        AuthMiddleware --> QuotaMiddleware
        QuotaMiddleware --> ACMiddleware
        ACMiddleware --> TracingMiddleware

        TracingMiddleware --> APIs

        InferenceAPI --> InferenceRouter
        AgentsAPI --> AgentProvider
        SafetyAPI --> SafetyRouter
        VectorAPI --> VectorRouter

        DistSystem --> ProviderRegistry
    end

    subgraph UI["Llama Stack UI"]
        NextJS["Next.js Frontend<br/>Log Viewer & Playground"]
    end

    subgraph CLI["CLI"]
        LlamaCLI["llama CLI<br/>Build, Configure, Run"]
    end

    %% External clients
    Client["Client Application"]
    Client -->|"REST API<br/>8321/TCP<br/>Bearer Token"| FastAPI
    NextJS -->|"REST API<br/>8321/TCP"| FastAPI
    LlamaCLI -->|"Manages"| DistSystem

    %% Provider backends
    subgraph InferenceProviders["Inference Providers"]
        vLLM["vLLM<br/>8000/TCP"]
        Ollama["Ollama<br/>11434/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
        Anthropic["Anthropic API<br/>443/TCP"]
        Bedrock["AWS Bedrock<br/>443/TCP"]
        NIM["NVIDIA NIM<br/>443/TCP"]
    end

    subgraph VectorProviders["Vector DB Providers"]
        pgvector["PostgreSQL/pgvector<br/>5432/TCP"]
        ChromaDB["ChromaDB"]
        Qdrant["Qdrant"]
        Milvus["Milvus"]
        Weaviate["Weaviate"]
    end

    subgraph ToolProviders["Tool Providers"]
        BraveSearch["Brave Search<br/>443/TCP"]
        Tavily["Tavily Search<br/>443/TCP"]
        WolframAlpha["Wolfram Alpha<br/>443/TCP"]
        MCPServers["MCP Servers"]
    end

    subgraph Storage["Storage Backends"]
        SQLite["SQLite<br/>Default Persistence"]
        Redis["Redis<br/>6379/TCP"]
        MongoDB["MongoDB<br/>27017/TCP"]
    end

    InferenceRouter -->|"HTTP/HTTPS"| vLLM
    InferenceRouter -->|"HTTP"| Ollama
    InferenceRouter -->|"HTTPS"| OpenAI
    InferenceRouter -->|"HTTPS"| Anthropic
    InferenceRouter -->|"HTTPS"| Bedrock
    InferenceRouter -->|"HTTPS"| NIM

    VectorRouter --> pgvector
    VectorRouter --> ChromaDB

    AgentProvider --> ToolProviders

    %% Auth egress
    AuthMiddleware -->|"JWKS / Introspection<br/>443/TCP HTTPS"| OIDC["OIDC Provider<br/>(Keycloak)"]

    %% Telemetry
    TelemetryAPI -->|"OTLP HTTP"| OTelCollector["OpenTelemetry<br/>Collector"]

