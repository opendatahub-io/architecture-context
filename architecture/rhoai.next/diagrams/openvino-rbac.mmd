graph TD
    subgraph Notice["OpenVINO RBAC"]
        direction TB
        Info["OpenVINO is a native C++ library<br/>NOT a Kubernetes workload"]
        NoRBAC["No RBAC definitions<br/>No ServiceAccounts<br/>No ClusterRoles<br/>No RoleBindings<br/>No Secrets"]
    end

    subgraph OVMSContext["RBAC Context (handled by OVMS)"]
        direction TB
        Note1["RBAC for inference serving is<br/>managed by OpenVINO Model Server (OVMS)<br/>which links against OpenVINO"]
        Note2["Platform-level RBAC is managed by<br/>RHOAI Operator"]
    end

    subgraph SupplyChain["Supply Chain Security"]
        direction TB
        SC1["14 git submodules<br/>pinned by commit SHA"]
        SC2["conan.lock<br/>pinned C++ dependency versions"]
        SC3["vcpkg.json + builtin-baseline<br/>reproducible C++ builds"]
        SC4["package-lock.json<br/>pinned JS dependencies"]
    end

    subgraph SecuritySurface["Security Attack Surface"]
        direction TB
        AS1["Model Deserialization<br/>protobuf 3.21.12, flatbuffers, pugixml<br/>parsing untrusted model files"]
        AS2["Dynamic Plugin Loading<br/>.so files loaded at runtime<br/>paths must be controlled"]
        AS3["JIT Code Generation<br/>xbyak generates executable code<br/>requires W^X memory pages"]
    end

    Info --> NoRBAC
    NoRBAC --> Note1
    Note1 --> Note2

    style Info fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#e8e8e8,stroke:#333
    style Note1 fill:#7ed321,stroke:#333,color:#fff
    style Note2 fill:#7ed321,stroke:#333,color:#fff
    style SC1 fill:#fff2cc,stroke:#d6b656
    style SC2 fill:#fff2cc,stroke:#d6b656
    style SC3 fill:#fff2cc,stroke:#d6b656
    style SC4 fill:#fff2cc,stroke:#d6b656
    style AS1 fill:#f8cecc,stroke:#b85450
    style AS2 fill:#f8cecc,stroke:#b85450
    style AS3 fill:#f8cecc,stroke:#b85450
