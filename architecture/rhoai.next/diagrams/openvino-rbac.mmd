graph TD
    subgraph Notice["NOT APPLICABLE"]
        direction TB
        Info["OpenVINO is a native C++ library,<br/>NOT a Kubernetes workload.<br/><br/>It has no ServiceAccounts,<br/>no Roles, no ClusterRoles,<br/>and no RoleBindings.<br/><br/>RBAC and access control<br/>are handled by the consuming<br/>application (OVMS) and the<br/>RHOAI platform operator."]
    end

    subgraph OVMSContext["OVMS (consuming application) owns RBAC"]
        direction TB
        OVMSSA["OVMS ServiceAccount<br/>(defined by OVMS/KServe)"]
        OVMSRole["OVMS ClusterRole<br/>(defined by OVMS operator)"]
        OVMSBinding["OVMS RoleBinding<br/>(managed by platform)"]

        OVMSSA -->|"bound via"| OVMSBinding
        OVMSBinding -->|"grants"| OVMSRole
    end

    subgraph OpenVINOScope["OpenVINO Library Scope"]
        direction TB
        LibRuntime["libopenvino.so<br/>No Kubernetes API access<br/>No RBAC requirements<br/>Pure compute library"]
        Plugins["Device Plugins (.so)<br/>No Kubernetes API access<br/>Hardware driver calls only"]
        Frontends["Model Frontends<br/>File I/O only<br/>No API server access"]
    end

    OVMSRole -->|"permissions apply to<br/>OVMS pod which contains"| LibRuntime

    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style OVMSSA fill:#e8e8e8,stroke:#333
    style OVMSRole fill:#e8e8e8,stroke:#333
    style OVMSBinding fill:#e8e8e8,stroke:#333
    style LibRuntime fill:#d5e8d4,stroke:#82b366
    style Plugins fill:#d5e8d4,stroke:#82b366
    style Frontends fill:#d5e8d4,stroke:#82b366
