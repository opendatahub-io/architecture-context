graph TB
    subgraph Platform["opendatahub-operator (Platform)"]
        PlatformOp[Platform Operator<br/>Deploys module operators]
    end

    subgraph AIGatewayModule["AI Gateway Operator (Module Operator)"]
        direction TB
        InitContainer["Init Container<br/>(copy-manifests)<br/>Copies vendored manifests<br/>to emptyDir volume"]
        Manager["ai-gateway-operator<br/>Manager<br/>(controller-runtime)"]
        ConfigMount["ConfigMap Mount<br/>/etc/controller/config<br/>platform-type, platform-version"]
        ManifestsVol["EmptyDir Volume<br/>/opt/manifests<br/>Vendored kustomize manifests"]

        InitContainer -->|"copies manifests"| ManifestsVol
        Manager -->|"reads config"| ConfigMount
        Manager -->|"reads manifests"| ManifestsVol
    end

    subgraph SubComponents["Sub-Components (Deployed by Module Operator)"]
        direction TB
        BatchGWOp["batch-gateway-operator<br/>(llm-d-batch-gateway-operator)"]

        subgraph BatchOperands["Batch Gateway Operands"]
            APIServer["llm-d-batch-gateway<br/>API Server"]
            Processor["llm-d-batch-gateway<br/>Processor"]
            GC["llm-d-batch-gateway<br/>GC (Garbage Collector)"]
        end

        BatchGWOp -->|"creates"| APIServer
        BatchGWOp -->|"creates"| Processor
        BatchGWOp -->|"creates"| GC
    end

    %% CRDs
    AIGatewayCR["AIGateway CR<br/>(components.platform.opendatahub.io/v1alpha1)<br/>Cluster-scoped singleton<br/>default-aigateway"]
    LLMBatchGWCR["LLMBatchGateway CR<br/>(batch.llm-d.ai/v1alpha1)<br/>Namespaced"]

    %% Flows
    PlatformOp -->|"deploys via<br/>module handler"| Manager
    PlatformOp -->|"creates"| AIGatewayCR
    AIGatewayCR -->|"watched by"| Manager
    Manager -->|"applies kustomize<br/>manifests when<br/>batchGateway=Managed"| BatchGWOp
    LLMBatchGWCR -->|"watched by"| BatchGWOp

    %% External dependencies
    Manager -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    BatchGWOp -->|"443/TCP HTTPS"| K8sAPI

    %% Metrics
    MetricsSvc["ai-gateway-metrics-service<br/>ClusterIP 8443/TCP HTTPS"]
    Manager -->|"serves"| MetricsSvc
    Prometheus["Prometheus"] -->|"scrapes"| MetricsSvc

    %% Styling
    style PlatformOp fill:#7ed321,stroke:#333,stroke-width:2px
    style Manager fill:#4a90e2,stroke:#333,stroke-width:2px
    style InitContainer fill:#4a90e2,stroke:#333,stroke-width:1px
    style BatchGWOp fill:#4a90e2,stroke:#333,stroke-width:2px
    style APIServer fill:#50c8e8,stroke:#333
    style Processor fill:#50c8e8,stroke:#333
    style GC fill:#50c8e8,stroke:#333
    style AIGatewayCR fill:#f5a623,stroke:#333,stroke-width:2px
    style LLMBatchGWCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#333
    style MetricsSvc fill:#d5e8d4,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ConfigMount fill:#fff2cc,stroke:#d6b656
    style ManifestsVol fill:#fff2cc,stroke:#d6b656
