graph TD
    subgraph AuthArchitecture["Authentication & Authorization Architecture"]
        direction TB

        subgraph ExternalAuth["External Authentication (Platform-Managed)"]
            PlatformIngress["Platform Ingress<br/>(kube-rbac-proxy / OAuth proxy)"]
            PlatformIngress -->|"validates"| ExternalClients["External Clients"]
        end

        subgraph AppLevel["Application Level (Llama Stack)"]
            NoAppAuth["No Application-Level Auth<br/>/v1/* endpoints are unauthenticated<br/>Auth is delegated to platform ingress"]
        end

        PlatformIngress -->|"forwards authenticated<br/>requests"| NoAppAuth
    end

    subgraph SecretsManagement["Secrets Management (Environment Variables)"]
        direction TB

        subgraph InferenceSecrets["Inference Backend Credentials"]
            VLLM_API_TOKEN["VLLM_API_TOKEN<br/>vLLM inference auth<br/>Bearer Token"]
            VLLM_EMBEDDING_API_TOKEN["VLLM_EMBEDDING_API_TOKEN<br/>vLLM embedding auth<br/>Bearer Token"]
            AWS_BEARER_TOKEN["AWS_BEARER_TOKEN_BEDROCK<br/>AWS Bedrock auth<br/>Short-lived (12h)"]
            WATSONX_API_KEY["WATSONX_API_KEY<br/>IBM WatsonX auth"]
            AZURE_API_KEY["AZURE_API_KEY<br/>Azure OpenAI auth"]
            OPENAI_API_KEY["OPENAI_API_KEY<br/>OpenAI auth"]
        end

        subgraph StorageSecrets["Storage Credentials"]
            POSTGRES_PASSWORD["POSTGRES_PASSWORD<br/>PostgreSQL auth<br/>Provisioned by platform operator"]
            PGVECTOR_PASSWORD["PGVECTOR_PASSWORD<br/>pgvector auth"]
            MILVUS_TOKEN["MILVUS_TOKEN<br/>Remote Milvus auth"]
            QDRANT_API_KEY["QDRANT_API_KEY<br/>Qdrant auth"]
            AWS_ACCESS_KEY["AWS_ACCESS_KEY_ID<br/>+ AWS_SECRET_ACCESS_KEY<br/>S3 storage auth"]
        end

        subgraph ServiceSecrets["Service Credentials"]
            BRAVE_SEARCH_KEY["BRAVE_SEARCH_API_KEY<br/>Brave Search auth"]
            TAVILY_SEARCH_KEY["TAVILY_SEARCH_API_KEY<br/>Tavily Search auth"]
            KFP_TOKEN["KUBEFLOW_PIPELINES_TOKEN<br/>Kubeflow auth<br/>Bearer Token"]
        end

        subgraph BuildSecrets["Build-Time Secrets (Konflux only)"]
            BOT_PAT["BOT_PAT<br/>GitLab PAT<br/>Private wheel downloads"]
        end
    end

    subgraph RBACStatus["RBAC Status"]
        NoRBAC["No RBAC Roles Defined<br/>This component runs as a container<br/>without direct Kubernetes API access"]
        LMEvalNote["Note: TrustyAI LMEval provider<br/>may use K8s API when<br/>TRUSTYAI_LMEVAL_USE_K8S=true<br/>RBAC managed by platform operator"]
    end

    subgraph SecurityNotes["Security Notes"]
        Note1["No auto-rotation for any secret"]
        Note2["PostgreSQL: plaintext in-cluster"]
        Note3["Cloud backends: TLS 1.2+ enforced"]
        Note4["Provider activation via env vars<br/>(conditional, not always active)"]
    end

    %% Styling
    style NoAppAuth fill:#fff3cd,stroke:#856404,stroke-width:2px
    style PlatformIngress fill:#d4edda,stroke:#155724,stroke-width:2px
    style NoRBAC fill:#f8d7da,stroke:#721c24,stroke-width:2px
    style LMEvalNote fill:#fff3cd,stroke:#856404,stroke-width:1px

