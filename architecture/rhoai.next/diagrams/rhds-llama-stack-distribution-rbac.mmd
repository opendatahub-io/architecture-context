graph TD
    subgraph NoRBAC["RBAC — Not Applicable"]
        direction TB
        Note["This component is a container image,<br/>not a Kubernetes operator.<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined in this repository."]
    end

    subgraph PlatformManaged["Platform-Managed RBAC"]
        direction TB
        Operator["rhods-operator /<br/>opendatahub-operator"]
        SA["Pod ServiceAccount<br/>(platform-assigned)"]
        Operator -->|"creates & manages"| SA
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

        subgraph InboundAuth["Inbound Auth (to Llama Stack)"]
            direction TB
            AppAuth["Application-Level Auth: NONE"]
            PlatformAuth["Platform Ingress Layer<br/>kube-rbac-proxy / Gateway API<br/>Enforces AuthN/AuthZ"]
            PlatformAuth -->|"forwards<br/>authenticated<br/>requests"| AppAuth
        end

        subgraph OutboundAuth["Outbound Auth (from Llama Stack)"]
            direction TB
            VLLMAuth["vLLM<br/>Bearer Token<br/>(VLLM_API_TOKEN)"]
            CloudAuth["Cloud Providers<br/>API Keys / Bearer Tokens<br/>(AWS, Azure, GCP, IBM, OpenAI)"]
            DBAuth["PostgreSQL / pgvector<br/>Username/Password<br/>(POSTGRES_PASSWORD)"]
            VectorAuth["Vector DBs<br/>Token / API Key<br/>(MILVUS_TOKEN, QDRANT_API_KEY)"]
            ToolAuth["Tool Services<br/>API Keys<br/>(BRAVE, TAVILY)"]
            K8sAuth["Kubernetes API<br/>ServiceAccount Token<br/>(for LMEval K8s mode)"]
            KFPAuth["Kubeflow Pipelines<br/>Bearer Token<br/>(KUBEFLOW_PIPELINES_TOKEN)"]
        end
    end

    subgraph Secrets["Secrets Inventory (13+ Environment Variables)"]
        direction LR
        S1["VLLM_API_TOKEN"]
        S2["AWS_BEARER_TOKEN_BEDROCK<br/>(12h TTL auto-rotate)"]
        S3A["AZURE_API_KEY"]
        S4["WATSONX_API_KEY"]
        S5["OPENAI_API_KEY"]
        S6["POSTGRES_PASSWORD"]
        S7["MILVUS_TOKEN"]
        S8["PGVECTOR_PASSWORD"]
        S9["QDRANT_API_KEY"]
        S10["BRAVE_SEARCH_API_KEY"]
        S11["TAVILY_SEARCH_API_KEY"]
        S12["AWS_ACCESS_KEY_ID /<br/>AWS_SECRET_ACCESS_KEY"]
        S13["KUBEFLOW_PIPELINES_TOKEN"]
        S14["FMS_SSL_CERT_PATH<br/>(TLS cert file)"]
    end

    style NoRBAC fill:#f9f9f9,stroke:#999,stroke-width:2px,stroke-dasharray: 5 5
    style Note fill:#fff,stroke:none
    style PlatformManaged fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style AppAuth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style PlatformAuth fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style VLLMAuth fill:#fff2cc,stroke:#d6b656
    style CloudAuth fill:#fff2cc,stroke:#d6b656
    style DBAuth fill:#fff2cc,stroke:#d6b656
    style VectorAuth fill:#fff2cc,stroke:#d6b656
    style ToolAuth fill:#fff2cc,stroke:#d6b656
    style K8sAuth fill:#fff2cc,stroke:#d6b656
    style KFPAuth fill:#fff2cc,stroke:#d6b656
