graph TD
    subgraph DeploymentNote["Llama Stack Distribution - RBAC Model"]
        direction TB
        Note["⚠️ No RBAC resources defined in this repository.<br/>This is a container image, not an operator.<br/>RBAC is managed by the deploying platform."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (RHOAI Operator)"]
        direction TB

        subgraph AuthFlow["Authentication Flow"]
            User["User / Client"]
            KubeRBAC["kube-rbac-proxy Sidecar<br/>(injected by RHOAI operator)"]
            K8sAPI["Kubernetes API Server<br/>SubjectAccessReview"]
        end

        User -->|"1. HTTPS request<br/>OAuth/OIDC token"| KubeRBAC
        KubeRBAC -->|"2. Validate token<br/>SubjectAccessReview"| K8sAPI
        K8sAPI -->|"3. Allow/Deny"| KubeRBAC
        KubeRBAC -->|"4. Forward if authorized<br/>HTTP/8321"| LlamaStack
    end

    subgraph ApplicationAuth["Application-Level Auth"]
        LlamaStack["Llama Stack Server<br/>Port 8321/TCP<br/>⚠️ No built-in auth"]

        subgraph Endpoints["All Endpoints (No Auth)"]
            Health["/v1/health"]
            Models["/v1/models"]
            Chat["/v1/chat/completions"]
            Completions["/v1/completions"]
            Embeddings["/v1/embeddings"]
            Inference["/v1/inference/*"]
            Agents["/v1/agents/*"]
            Safety["/v1/safety/*"]
            VectorIO["/v1/vector-io/*"]
            Eval["/v1/eval/*"]
            Scoring["/v1/scoring/*"]
            DatasetIO["/v1/datasetio/*"]
            Files["/v1/files/*"]
            Batches["/v1/batches/*"]
            ToolRuntime["/v1/tool-runtime/*"]
        end

        LlamaStack --> Endpoints
    end

    subgraph BuildSecrets["Build-Time Secrets"]
        BOT_PAT["rhel-ai-private-index-auth<br/>Type: Build-time secret<br/>Purpose: GitLab PAT for wheel releases<br/>Provisioned: Manual / Konflux<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret<br/>Type: Build-time secret<br/>Purpose: Git auth for Tekton<br/>Provisioned: Pipelines-as-Code<br/>Auto-Rotate: No"]
    end

    subgraph RuntimeSecrets["Runtime Secrets (Environment Variables)"]
        VLLM_TOKEN["VLLM_API_TOKEN<br/>vLLM inference auth"]
        AWS_TOKEN["AWS_BEARER_TOKEN_BEDROCK<br/>AWS Bedrock auth"]
        AZURE_KEY["AZURE_API_KEY<br/>Azure OpenAI auth"]
        WATSONX_KEY["WATSONX_API_KEY<br/>IBM watsonx auth"]
        OPENAI_KEY["OPENAI_API_KEY<br/>OpenAI API auth"]
        MILVUS_TK["MILVUS_TOKEN<br/>Milvus vector DB auth"]
        QDRANT_KEY["QDRANT_API_KEY<br/>Qdrant vector DB auth"]
        KF_TOKEN["KUBEFLOW_PIPELINES_TOKEN<br/>Kubeflow Pipelines auth"]
        BRAVE_KEY["BRAVE_SEARCH_API_KEY<br/>Brave Search auth"]
        TAVILY_KEY["TAVILY_SEARCH_API_KEY<br/>Tavily Search auth"]
        PG_CREDS["PostgreSQL credentials<br/>Database username/password"]
    end

    LlamaStack -.->|"uses at runtime"| RuntimeSecrets

