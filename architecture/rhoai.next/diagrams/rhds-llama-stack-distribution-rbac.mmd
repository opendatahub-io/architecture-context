        direction TB
        Note["This component is a container image,<br/>not a Kubernetes operator or controller.<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined by this component."]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

