            ToolCreds["Tool & Eval:<br/>BRAVE_SEARCH_API_KEY<br/>TAVILY_SEARCH_API_KEY<br/>KUBEFLOW_PIPELINES_TOKEN"]
        end
    end

    subgraph BuildSecrets["Build-Time Secrets"]
