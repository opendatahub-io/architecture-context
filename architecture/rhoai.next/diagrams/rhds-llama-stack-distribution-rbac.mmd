graph TD
    subgraph "Container Image - No RBAC Defined"
        Note["This component is a container image,<br/>not a Kubernetes operator.<br/>No RBAC resources are defined<br/>in this repository."]
    end

    subgraph "Platform-Managed RBAC"
        direction TB
        PlatformOp["Platform Operator<br/>(rhods-operator / opendatahub-operator)"]
        SA["Pod ServiceAccount<br/>(managed by platform)"]
        PlatformOp -->|"creates & manages"| SA
    end

    subgraph "Runtime K8s Access (Conditional)"
        direction TB
        LMEvalMode["TRUSTYAI_LMEVAL_USE_K8S=true"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
        LMEvalJob["LMEval Job<br/>(batch/v1)"]

        LMEvalMode -->|"enables"| K8sAccess["K8s API Access"]
        K8sAccess -->|"Auth: SA Token<br/>TLS 1.2+"| K8sAPI
        K8sAPI -->|"creates"| LMEvalJob
    end

    subgraph "Outbound Authentication (Environment Variables)"
        direction TB

        subgraph "Bearer Tokens"
            VLLM_TOKEN["VLLM_API_TOKEN<br/>→ vLLM Server"]
            AWS_TOKEN["AWS_BEARER_TOKEN_BEDROCK<br/>→ AWS Bedrock<br/>Auto-rotate: 12h"]
            KFP_TOKEN["KUBEFLOW_PIPELINES_TOKEN<br/>→ Kubeflow Pipelines"]
        end

        subgraph "API Keys"
            AZURE_KEY["AZURE_API_KEY<br/>→ Azure OpenAI"]
            WATSON_KEY["WATSONX_API_KEY<br/>→ IBM WatsonX"]
            OPENAI_KEY["OPENAI_API_KEY<br/>→ OpenAI"]
            QDRANT_KEY["QDRANT_API_KEY<br/>→ Qdrant"]
            BRAVE_KEY["BRAVE_SEARCH_API_KEY<br/>→ Brave Search"]
            TAVILY_KEY["TAVILY_SEARCH_API_KEY<br/>→ Tavily Search"]
        end

        subgraph "Database Credentials"
            PG_PASS["POSTGRES_PASSWORD<br/>→ PostgreSQL"]
            PGV_PASS["PGVECTOR_PASSWORD<br/>→ pgvector"]
            MILVUS_TOK["MILVUS_TOKEN<br/>→ Milvus"]
        end

        subgraph "IAM & Certificates"
            AWS_IAM["AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>→ S3 Storage"]
            FMS_CERT["FMS_SSL_CERT_PATH<br/>→ TrustyAI FMS"]
            MILVUS_CERTS["MILVUS_CA_PEM_PATH<br/>MILVUS_CLIENT_PEM_PATH<br/>→ Milvus mTLS"]
            GOOGLE_ADC["Google ADC<br/>→ Vertex AI"]
        end
    end

    subgraph "Inbound Authentication"
        NoAuth["⚠️ NO APPLICATION-LEVEL AUTH<br/>All /v1/* endpoints unauthenticated<br/>Relies on platform ingress:<br/>• kube-rbac-proxy<br/>• Gateway API<br/>• External auth proxy"]
    end

    SA -.->|"token used for<br/>K8s API access"| K8sAccess

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style NoAuth fill:#f8d7da,stroke:#721c24,stroke-width:2px
    style PlatformOp fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style LMEvalJob fill:#e8e8e8,stroke:#333
    style LMEvalMode fill:#fff3cd,stroke:#856404

    style VLLM_TOKEN fill:#d4edda,stroke:#155724
    style AWS_TOKEN fill:#d4edda,stroke:#155724
    style KFP_TOKEN fill:#d4edda,stroke:#155724
    style AZURE_KEY fill:#cce5ff,stroke:#004085
    style WATSON_KEY fill:#cce5ff,stroke:#004085
    style OPENAI_KEY fill:#cce5ff,stroke:#004085
    style QDRANT_KEY fill:#cce5ff,stroke:#004085
    style BRAVE_KEY fill:#cce5ff,stroke:#004085
    style TAVILY_KEY fill:#cce5ff,stroke:#004085
    style PG_PASS fill:#e2d5f1,stroke:#4a235a
    style PGV_PASS fill:#e2d5f1,stroke:#4a235a
    style MILVUS_TOK fill:#e2d5f1,stroke:#4a235a
    style AWS_IAM fill:#fdebd0,stroke:#7e5109
    style FMS_CERT fill:#fdebd0,stroke:#7e5109
