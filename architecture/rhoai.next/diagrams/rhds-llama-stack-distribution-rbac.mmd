graph TD
    subgraph Note["RBAC Architecture Note"]
        direction TB
        Info["ℹ️ No RBAC resources defined in this repository.<br/>This is a container image, not a Kubernetes operator.<br/>RBAC for the pod's ServiceAccount is managed by<br/>the platform operator (rhods-operator / opendatahub-operator)."]
    end

    subgraph AuthArchitecture["Authentication Architecture"]
        direction TB

        subgraph InboundAuth["Inbound (Server) Authentication"]
            AppLayer["Application Layer<br/>Auth: NONE<br/>All /v1/* endpoints unauthenticated"]
            IngressLayer["Ingress Layer<br/>Auth: Platform-enforced<br/>(kube-rbac-proxy / Gateway API / ext auth proxy)"]
            IngressLayer -->|"forwards authenticated<br/>requests"| AppLayer
        end

        subgraph OutboundAuth["Outbound (Client) Authentication"]
            direction TB
            BearerTokens["Bearer Token Auth"]
            APIKeys["API Key Auth"]
            PasswordAuth["Password Auth"]
            IAMAuth["IAM/ADC Auth"]
            CertAuth["Certificate Auth"]
        end
    end

    subgraph SecretsMatrix["Secrets & Credentials Matrix"]
        direction TB

        subgraph InferenceSecrets["Inference Backend Secrets"]
            S1["VLLM_API_TOKEN<br/>Type: Bearer Token<br/>Provisioned: Manual/Platform<br/>Rotation: None"]
            S2["AWS_BEARER_TOKEN_BEDROCK<br/>Type: Bearer Token<br/>Provisioned: AWS IAM<br/>Rotation: 12h TTL ✅"]
            S3a["AZURE_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
            S4["WATSONX_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
            S5["OPENAI_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
        end

        subgraph StorageSecrets["Storage Secrets"]
            S6["POSTGRES_PASSWORD<br/>Type: Password<br/>Provisioned: Manual/Platform<br/>Rotation: None"]
            S7["AWS_ACCESS_KEY_ID /<br/>AWS_SECRET_ACCESS_KEY<br/>Type: IAM Credentials<br/>Provisioned: Manual/IAM<br/>Rotation: None"]
        end

        subgraph VectorDBSecrets["Vector DB Secrets"]
            S8["MILVUS_TOKEN<br/>Type: Token<br/>Provisioned: Manual<br/>Rotation: None"]
            S9["PGVECTOR_PASSWORD<br/>Type: Password<br/>Provisioned: Manual<br/>Rotation: None"]
            S10["QDRANT_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
        end

        subgraph ToolSecrets["Tool & Pipeline Secrets"]
            S11["BRAVE_SEARCH_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
            S12["TAVILY_SEARCH_API_KEY<br/>Type: API Key<br/>Provisioned: Manual<br/>Rotation: None"]
