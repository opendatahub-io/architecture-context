graph TD
    subgraph LlamaStackPod["Llama Stack Server Pod"]
        direction TB
        LSContainer["Llama Stack Container<br/>No direct K8s API access<br/>No RBAC roles defined"]
    end

    subgraph PlatformManaged["Platform-Managed Auth (rhods-operator)"]
        direction TB
        IngressAuth["Platform Ingress Auth<br/>kube-rbac-proxy / OAuth Proxy"]
        PlatformRBAC["Platform RBAC<br/>Managed by rhods-operator"]
        IngressAuth -->|"enforces"| PlatformRBAC
    end

    subgraph ConditionalK8sAccess["Conditional K8s API Access<br/>(TrustyAI LMEval only)"]
        direction TB
        LMEvalCondition{"TRUSTYAI_LMEVAL_USE_K8S<br/>= true ?"}
        LMEvalSA["Service Account<br/>(platform-provisioned)"]
        K8sAPI["Kubernetes API<br/>mTLS (service account)"]
        LMEvalJobs["LMEval Jobs<br/>create, get, list, watch"]

        LMEvalCondition -->|"Yes"| LMEvalSA
        LMEvalSA -->|"authenticates via"| K8sAPI
        K8sAPI -->|"batch/v1 Jobs"| LMEvalJobs
    end

    subgraph SecretManagement["Secret Management (Environment Variables)"]
        direction TB

        subgraph InferenceCreds["Inference Credentials"]
            VLLMToken["VLLM_API_TOKEN<br/>Bearer Token<br/>Provisioned by: platform/user"]
            VLLMEmbedToken["VLLM_EMBEDDING_API_TOKEN<br/>Bearer Token<br/>Provisioned by: platform/user"]
        end

        subgraph CloudCreds["Cloud Provider Credentials"]
            AWSBedrock["AWS_BEARER_TOKEN_BEDROCK<br/>Bearer Token (12h TTL)<br/>Provisioned by: user"]
            WatsonXKey["WATSONX_API_KEY<br/>API Key<br/>Provisioned by: user"]
            AzureKey["AZURE_API_KEY<br/>API Key<br/>Provisioned by: user"]
            OpenAIKey["OPENAI_API_KEY<br/>API Key<br/>Provisioned by: user"]
        end

        subgraph StorageCreds["Storage Credentials"]
            PGPassword["POSTGRES_PASSWORD<br/>Password<br/>Provisioned by: platform operator"]
            AWSAccessKey["AWS_ACCESS_KEY_ID<br/>IAM Credential<br/>Provisioned by: user"]
            AWSSecretKey["AWS_SECRET_ACCESS_KEY<br/>IAM Credential<br/>Provisioned by: user"]
        end

        subgraph VectorDBCreds["Vector DB Credentials"]
            MilvusToken["MILVUS_TOKEN<br/>Token<br/>Provisioned by: user"]
            PGVectorPW["PGVECTOR_PASSWORD<br/>Password<br/>Provisioned by: user"]
            QdrantKey["QDRANT_API_KEY<br/>API Key<br/>Provisioned by: user"]
        end

        subgraph ToolCreds["Tool & Service Credentials"]
            BraveKey["BRAVE_SEARCH_API_KEY<br/>API Key<br/>Provisioned by: user"]
            TavilyKey["TAVILY_SEARCH_API_KEY<br/>API Key<br/>Provisioned by: user"]
            KFPToken["KUBEFLOW_PIPELINES_TOKEN<br/>Bearer Token<br/>Provisioned by: user"]
        end

        subgraph BuildCreds["Build-Only Credentials"]
            BotPAT["rhel-ai-private-index-auth/BOT_PAT<br/>BuildSecret (GitLab PAT)<br/>Konflux build only"]
        end
    end

    LSContainer -.->|"no RBAC"| PlatformManaged
    LSContainer -.->|"conditional"| LMEvalCondition
    LSContainer -->|"reads env vars"| SecretManagement

    PlatformManaged -->|"protects"| LSContainer

    style LSContainer fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style IngressAuth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style PlatformRBAC fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style LMEvalCondition fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style LMEvalSA fill:#d5e8d4,stroke:#82b366
    style K8sAPI fill:#d5e8d4,stroke:#82b366
    style LMEvalJobs fill:#d5e8d4,stroke:#82b366
    style VLLMToken fill:#f8cecc,stroke:#b85450
    style VLLMEmbedToken fill:#f8cecc,stroke:#b85450
    style AWSBedrock fill:#f8cecc,stroke:#b85450
    style WatsonXKey fill:#f8cecc,stroke:#b85450
    style AzureKey fill:#f8cecc,stroke:#b85450
    style OpenAIKey fill:#f8cecc,stroke:#b85450
    style PGPassword fill:#f8cecc,stroke:#b85450
    style AWSAccessKey fill:#f8cecc,stroke:#b85450
    style AWSSecretKey fill:#f8cecc,stroke:#b85450
    style MilvusToken fill:#f8cecc,stroke:#b85450
    style PGVectorPW fill:#f8cecc,stroke:#b85450
    style QdrantKey fill:#f8cecc,stroke:#b85450
    style BraveKey fill:#f8cecc,stroke:#b85450
