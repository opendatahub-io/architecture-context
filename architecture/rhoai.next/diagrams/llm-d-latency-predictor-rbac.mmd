graph TD
    subgraph Legend["RBAC Status: Not Configured"]
        direction TB
        Note["No RBAC resources defined.<br/>Both servers run with default<br/>ServiceAccount permissions."]
    end

    subgraph TrainingServerRBAC["Training Server"]
        TrainSA["ServiceAccount: default<br/>(namespace default SA)"]
        TrainPod["Training Server Pod<br/>Port: 8000/TCP"]
    end

    subgraph PredictionServerRBAC["Prediction Server"]
        PredSA["ServiceAccount: default<br/>(namespace default SA)"]
        PredPod["Prediction Server Pods<br/>Port: 8001/TCP (10 replicas)"]
    end

    subgraph SecurityGaps["Security Gaps"]
        direction TB
        Gap1["No ClusterRoles or Roles defined"]
        Gap2["No RoleBindings configured"]
        Gap3["No NetworkPolicies restricting access"]
        Gap4["No AuthorizationPolicies (no service mesh)"]
        Gap5["All endpoints unauthenticated"]
        Gap6["Default SA may have excessive permissions"]
    end

    TrainSA -->|"runs as"| TrainPod
    PredSA -->|"runs as"| PredPod

    subgraph Recommendations["Production Recommendations"]
        direction TB
        Rec1["Create dedicated ServiceAccounts"]
        Rec2["Add NetworkPolicies to restrict pod-to-pod traffic"]
        Rec3["Deploy with Istio service mesh for mTLS"]
        Rec4["Add AuthorizationPolicies for endpoint access"]
        Rec5["Consider kube-rbac-proxy sidecar per RHOAI pattern"]
    end

