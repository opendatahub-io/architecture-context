graph TB
    subgraph UserEnv["USER ENVIRONMENT (Workstation / Notebook / Job Pod)"]
        direction TB
        User["Data Scientist<br/>Python Script"]

        subgraph Library["training-hub Library (in-process)"]
            direction TB

            subgraph AlgoLayer["Algorithm Layer"]
                SFT["SFT"]
                OSFT["OSFT"]
                LoRA["LoRA+SFT"]
                LoRAGRPO["LoRA+GRPO"]
                GRPO["GRPO"]
            end

            subgraph BackendLayer["Backend Layer (subprocess isolation)"]
                ILab["instructlab-training"]
                Mini["mini-trainer"]
                Unsloth["Unsloth"]
                ART["OpenPipe ART<br/>(subprocess)"]
                VeRL["verl<br/>(subprocess)"]
            end

            subgraph RuntimeProcs["Ephemeral Subprocesses"]
                Torchrun["torchrun<br/>TCP (NCCL)<br/>configurable port<br/>No encryption"]
                VLLM["vLLM Inference<br/>TCP/HTTP<br/>configurable port<br/>No encryption<br/>localhost only"]
            end
        end
    end

    subgraph GPUCluster["GPU INTERCONNECT (Hardware)"]
        GPUs["GPU 0 .. GPU N<br/>NCCL (NVLink/PCIe/IB)<br/>No encryption (hardware)"]
    end

    subgraph External["EXTERNAL SERVICES (Outbound Only)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
        WandB["Weights & Biases<br/>api.wandb.ai<br/>HTTPS/443<br/>TLS 1.2+<br/>WANDB_API_KEY"]
        MLflow["MLflow Server<br/>HTTP(S)/configurable<br/>Optional TLS"]
    end

    %% Flows
    User -->|"Python API<br/>in-process"| AlgoLayer

    SFT --> ILab
    OSFT --> Mini
    LoRA --> Unsloth
    LoRAGRPO --> ART
    LoRAGRPO --> VeRL
    GRPO --> VeRL

    ILab --> Torchrun
    Mini --> Torchrun
    ART --> VLLM
    VeRL --> VLLM

    Torchrun -->|"NCCL/TCP<br/>No encryption<br/>Local"| GPUs
    VeRL -->|"FSDP<br/>No encryption<br/>Local"| GPUs

    Library -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (opt)"| HF
    Library -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WandB
    Library -.->|"HTTP(S)<br/>Optional TLS"| MLflow

    %% Styling
    classDef userenv fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    classDef library fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef algo fill:#dae8fc,stroke:#6c8ebf
    classDef backend fill:#e1d5e7,stroke:#9673a6
    classDef proc fill:#ffe6cc,stroke:#d79b00

    class User userenv
    class SFT,OSFT,LoRA,LoRAGRPO,GRPO algo
    class ILab,Mini,Unsloth,ART,VeRL backend
    class Torchrun,VLLM proc
    class GPUs gpu
    class HF,WandB,MLflow external
