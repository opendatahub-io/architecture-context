graph TB
    subgraph UserEnv["USER ENVIRONMENT (Trusted)"]
        direction TB
        User["User Code<br/>(Jupyter Notebook / CLI Script)"]
        SDK["training-hub SDK<br/>(Python Library - In-Process)"]
    end

    subgraph LocalExec["LOCAL EXECUTION (Same Host / Pod)"]
        direction TB

        subgraph Subprocesses["Subprocess Isolation"]
            Torchrun["torchrun<br/>Subprocess<br/>Distributed Training"]
            vLLMProc["vLLM Server<br/>Subprocess<br/>Dynamic Port/HTTP<br/>No Auth"]
        end

        subgraph Frameworks["Training Frameworks (In-Process)"]
            ILab["instructlab-training"]
            MiniTrainer["mini-trainer"]
            Unsloth["Unsloth + TRL"]
            ART["OpenPipe ART"]
        end

        Disk["Local Filesystem<br/>Checkpoints, Metrics,<br/>Model Cache"]
    end

    subgraph DistributedNet["DISTRIBUTED TRAINING NETWORK (Multi-Node)"]
        Workers["GPU Worker Nodes<br/>NCCL / Gloo<br/>torch.distributed"]
        VeRLDist["verl Distributed<br/>Ray / torchrun"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Internet)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        WandB["Weights & Biases<br/>api.wandb.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: WANDB_API_KEY<br/>(Optional)"]
        MLflow["MLflow Tracking<br/>User-configured URI<br/>HTTP/HTTPS<br/>Auth: Configurable<br/>(Optional)"]
    end

    %% Flows
    User -->|Python API<br/>In-Process| SDK
    SDK -->|subprocess<br/>torchrun CLI| Torchrun
    SDK -->|subprocess<br/>HTTP (localhost)| vLLMProc
    SDK -->|Python import| Frameworks

    Torchrun -->|Python import| ILab
    Torchrun -->|Python import| MiniTrainer
    vLLMProc -.->|HTTP<br/>Dynamic Port<br/>No Encryption<br/>localhost only| ART

    Frameworks -->|File I/O| Disk
    Torchrun -->|File I/O| Disk
    SDK -->|File I/O| Disk

    Torchrun -->|NCCL/Gloo<br/>master_addr:master_port<br/>No Encryption| Workers
    SDK -->|subprocess<br/>verl CLI| VeRLDist
    VeRLDist -->|NCCL<br/>torch.distributed| Workers

    SDK -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer: HF_TOKEN| HFHub
    Frameworks -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer: HF_TOKEN| HFHub
    Frameworks -.->|HTTPS/443<br/>TLS 1.2+<br/>API Key| WandB
    Frameworks -.->|HTTP/HTTPS<br/>Configurable| MLflow

    %% Styling
    classDef userenv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef localexec fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef distributed fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional stroke-dasharray: 5 5

    class User,SDK userenv
    class Torchrun,vLLMProc,ILab,MiniTrainer,Unsloth,ART,Disk localexec
    class Workers,VeRLDist distributed
    class HFHub,WandB,MLflow external
