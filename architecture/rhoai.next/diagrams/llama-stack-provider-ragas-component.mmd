graph TB
    subgraph "Llama Stack Server (Port 8321)"
        subgraph "llama-stack-provider-ragas"
            direction TB
            subgraph "Inline Provider"
                InlineEval["RagasEvaluatorInline<br/>inline::trustyai_ragas"]
                InlineLLM["LlamaStackInlineLLM<br/>(BaseRagasLLM adapter)"]
                InlineEmbed["LlamaStackInlineEmbeddings<br/>(BaseRagasEmbeddings adapter)"]
                InlineEval -->|calls| InlineLLM
                InlineEval -->|calls| InlineEmbed
            end

            subgraph "Remote Provider"
                RemoteEval["RagasEvaluatorRemote<br/>remote::trustyai_ragas"]
                RemoteLLM["LlamaStackRemoteLLM<br/>(HTTP-based adapter)"]
                RemoteEmbed["LlamaStackRemoteEmbeddings<br/>(HTTP-based adapter)"]
                KFPPipeline["KFP Pipeline Builder<br/>(retrieve_data → run_ragas)"]
                RemoteEval -->|constructs| KFPPipeline
            end

            Compat["Compatibility Layer<br/>(llama_stack ↔ llama_stack_api)"]
        end

        InferenceAPI["Llama Stack Inference API"]
        DatasetIOAPI["Llama Stack DatasetIO API"]
        EvalAPI["Llama Stack Eval API<br/>/alpha/eval/*"]
    end

    Client["Client / User"] -->|"POST /alpha/eval/run_eval<br/>8321/TCP HTTP"| EvalAPI
    EvalAPI -->|routes to| InlineEval
    EvalAPI -->|routes to| RemoteEval

    InlineLLM -->|in-process call| InferenceAPI
    InlineEmbed -->|in-process call| InferenceAPI
    InlineEval -->|in-process call| DatasetIOAPI

    KFPPipeline -->|"submit pipeline<br/>443/TCP HTTPS"| KFP["Kubeflow Pipelines"]

    subgraph "KFP Pod (Remote Execution)"
        KFPRetrieve["retrieve_data<br/>component"]
        KFPRagas["run_ragas<br/>component"]
        KFPRetrieve --> KFPRagas
        RemoteLLM2["LlamaStackRemoteLLM"]
        RemoteEmbed2["LlamaStackRemoteEmbeddings"]
        KFPRagas --- RemoteLLM2
        KFPRagas --- RemoteEmbed2
    end

    KFP -->|runs| KFPRetrieve
    KFPRetrieve -->|"HTTP 8321/TCP"| DatasetIOAPI
    RemoteLLM2 -->|"HTTP 8321/TCP"| InferenceAPI
    RemoteEmbed2 -->|"HTTP 8321/TCP"| InferenceAPI
    KFPRagas -->|"HTTPS 443/TCP<br/>AWS IAM"| S3["S3 Storage"]

    RemoteEval -->|"poll status / read results<br/>HTTPS 443/TCP"| S3

    ConfigMap["trustyai-service-operator-config<br/>ConfigMap"] -.->|base image resolution| KFPPipeline

    style InlineEval fill:#4a90e2,color:#fff
    style RemoteEval fill:#4a90e2,color:#fff
    style InlineLLM fill:#6baed6
    style InlineEmbed fill:#6baed6
    style RemoteLLM fill:#6baed6
    style RemoteEmbed fill:#6baed6
    style KFPPipeline fill:#6baed6
    style Compat fill:#9ecae1
    style EvalAPI fill:#f5a623,color:#fff
    style InferenceAPI fill:#f5a623,color:#fff
    style DatasetIOAPI fill:#f5a623,color:#fff
    style KFP fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#e8e8e8,stroke:#333
    style Client fill:#7ed321,color:#fff
    style KFPRetrieve fill:#d5e8d4,stroke:#82b366
    style KFPRagas fill:#d5e8d4,stroke:#82b366
    style RemoteLLM2 fill:#d5e8d4,stroke:#82b366
    style RemoteEmbed2 fill:#d5e8d4,stroke:#82b366
