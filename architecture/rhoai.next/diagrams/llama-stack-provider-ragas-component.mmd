graph TB
    subgraph "Llama Stack Provider Ragas"
        direction TB

        subgraph "Inline Mode"
            InlineProvider["Ragas Inline Provider<br/><i>inline::trustyai_ragas</i>"]
            LLMWrapper["LlamaStackInlineLLM<br/><i>BaseRagasLLM adapter</i>"]
            EmbedWrapper["LlamaStackInlineEmbeddings<br/><i>BaseRagasEmbeddings adapter</i>"]
            InlineProvider -->|"uses"| LLMWrapper
            InlineProvider -->|"uses"| EmbedWrapper
        end

        subgraph "Remote Mode"
            RemoteProvider["Ragas Remote Provider<br/><i>remote::trustyai_ragas</i>"]
            KFPPipeline["KFP Pipeline Builder<br/><i>pipeline.py</i>"]
            RetrieveComp["retrieve_data_from_llama_stack<br/><i>KFP Component</i>"]
            RagasComp["run_ragas_evaluation<br/><i>KFP Component</i>"]
            RemoteProvider -->|"constructs"| KFPPipeline
            KFPPipeline -->|"step 1"| RetrieveComp
            KFPPipeline -->|"step 2"| RagasComp
        end

        subgraph "Shared"
            CompatLayer["Compatibility Layer<br/><i>compat.py</i>"]
            Config["Provider Config<br/><i>config.py / Pydantic</i>"]
        end

        InlineProvider -->|"imports via"| CompatLayer
        RemoteProvider -->|"imports via"| CompatLayer
        RemoteProvider -->|"reads"| Config
    end

    %% External interactions
    Client[Client] -->|"POST /alpha/eval/run-eval<br/>8321/TCP HTTP"| LlamaStackServer["Llama Stack Server<br/>8321/TCP"]
    LlamaStackServer -->|"delegates to"| InlineProvider
    LlamaStackServer -->|"delegates to"| RemoteProvider

    LLMWrapper -->|"in-process"| InferenceAPI["Llama Stack<br/>Inference API"]
    EmbedWrapper -->|"in-process"| InferenceAPI

    RemoteProvider -->|"submits pipeline<br/>443/TCP HTTPS"| KFP["Kubeflow Pipelines<br/>(DSP)"]
    RetrieveComp -->|"fetches data<br/>8321/TCP HTTP"| LlamaStackServer
    RagasComp -->|"writes results<br/>443/TCP HTTPS"| S3["S3 Object Storage"]

    Config -->|"reads ConfigMap<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    style InlineProvider fill:#4a90e2,color:#fff
    style RemoteProvider fill:#4a90e2,color:#fff
    style LLMWrapper fill:#5b9bd5,color:#fff
    style EmbedWrapper fill:#5b9bd5,color:#fff
    style KFPPipeline fill:#5b9bd5,color:#fff
    style RetrieveComp fill:#5b9bd5,color:#fff
    style RagasComp fill:#5b9bd5,color:#fff
    style CompatLayer fill:#9b59b6,color:#fff
    style Config fill:#9b59b6,color:#fff
    style LlamaStackServer fill:#2ecc71,color:#fff
    style KFP fill:#e8e8e8,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferenceAPI fill:#2ecc71,color:#fff
    style Client fill:#f9f9f9,stroke:#999
