graph TB
    subgraph "llama-stack-provider-ragas"
        subgraph "Inline Mode"
            InlineProvider["Inline Provider<br/>(RagasInlineEvalImpl)"]
            InlineLLM["LlamaStackInlineLLM<br/>(BaseRagasLLM adapter)"]
            InlineEmbed["LlamaStackInlineEmbeddings<br/>(BaseRagasEmbeddings adapter)"]
            InlineProvider -->|uses| InlineLLM
            InlineProvider -->|uses| InlineEmbed
        end

        subgraph "Remote Mode"
            RemoteProvider["Remote Provider<br/>(RagasRemoteEvalImpl)"]
            KFPPipeline["KFP Pipeline Definition<br/>(two-step pipeline)"]
            RemoteLLM["LlamaStackRemoteLLM<br/>(llama-stack-client adapter)"]
            RemoteEmbed["LlamaStackRemoteEmbeddings<br/>(llama-stack-client adapter)"]
            Components["KFP Components<br/>(components.py)"]
            RemoteProvider -->|submits| KFPPipeline
            KFPPipeline -->|defines| Components
            Components -.->|runs in KFP pods| RemoteLLM
            Components -.->|runs in KFP pods| RemoteEmbed
        end

        subgraph "Shared"
            ProviderSpec["Provider Spec<br/>(get_provider_spec)"]
            Compat["Compatibility Layer<br/>(compat.py)"]
            Config["Config<br/>(RagasEvalConfig / RagasRemoteEvalConfig)"]
        end

        InlineProvider -->|uses| Compat
        RemoteProvider -->|uses| Compat
        ProviderSpec -->|registers| InlineProvider
        ProviderSpec -->|registers| RemoteProvider
    end

    Client[Client] -->|POST /alpha/eval/run_eval| LlamaStackServer
    LlamaStackServer["Llama Stack Server<br/>:8321/TCP"] -->|routes eval API| ProviderSpec

    InlineLLM -->|in-process| InferenceAPI["Llama Stack Inference API<br/>(openai_completion)"]
    InlineEmbed -->|in-process| EmbeddingAPI["Llama Stack Inference API<br/>(openai_embeddings)"]
    InlineProvider -->|in-process| DatasetIOAPI["Llama Stack DatasetIO API"]

    RemoteProvider -->|HTTPS/443<br/>Bearer Token| KFPAPI["Kubeflow Pipelines API"]
    Components -.->|HTTP/8321| LlamaStackServer
    Components -.->|HTTPS/443<br/>AWS IAM| S3["S3 Storage"]

    RemoteProvider -->|HTTPS/6443| K8sAPI["Kubernetes API<br/>(ConfigMap read)"]

    style InlineProvider fill:#4a90e2,color:#fff
    style RemoteProvider fill:#4a90e2,color:#fff
    style InlineLLM fill:#7ed321,color:#fff
    style InlineEmbed fill:#7ed321,color:#fff
    style RemoteLLM fill:#7ed321,color:#fff
    style RemoteEmbed fill:#7ed321,color:#fff
