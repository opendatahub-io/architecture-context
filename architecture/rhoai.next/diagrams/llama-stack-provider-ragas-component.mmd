graph TB
    subgraph "Llama Stack Provider Ragas"
        direction TB

        subgraph InlineProvider["Inline Eval Provider"]
            RagasInline[RagasEvaluatorInline]
            InlineLLM[LlamaStackInlineLLM<br/>Adapter]
            InlineEmbed[LlamaStackInlineEmbeddings<br/>Adapter]
            RagasInline -->|adapts| InlineLLM
            RagasInline -->|adapts| InlineEmbed
        end

        subgraph RemoteProvider["Remote Eval Provider"]
            RagasRemote[RagasEvaluatorRemote]
            RemoteLLM[LlamaStackRemoteLLM<br/>Adapter]
            RemoteEmbed[LlamaStackRemoteEmbeddings<br/>Adapter]
            KFPPipeline[KFP Pipeline Builder]
            RagasRemote -->|constructs| KFPPipeline
            KFPPipeline -.->|uses in pods| RemoteLLM
            KFPPipeline -.->|uses in pods| RemoteEmbed
        end

        Compat[Compatibility Layer<br/>compat.py]
        ProviderSpec[Provider Spec<br/>inline::trustyai_ragas<br/>remote::trustyai_ragas]
    end

    Client[Client] -->|POST /alpha/eval/run_eval<br/>8321/TCP| LlamaStack

    subgraph LlamaStack["Llama Stack Server"]
        EvalAPI[Eval API]
        InferenceAPI[Inference API]
        DatasetIOAPI[DatasetIO API]
        BenchmarksAPI[Benchmarks API]
    end

    EvalAPI -->|routes to| ProviderSpec
    ProviderSpec -->|inline mode| RagasInline
    ProviderSpec -->|remote mode| RagasRemote

    InlineLLM -->|in-process call| InferenceAPI
    InlineEmbed -->|in-process call| InferenceAPI
    RagasInline -->|reads datasets| DatasetIOAPI

    RagasRemote -->|submits pipeline| KFP[Kubeflow Pipelines<br/>443/TCP HTTPS]
    KFPPipeline -->|retrieve data step| DatasetIOAPI
    KFPPipeline -->|write results| S3[S3 Storage<br/>443/TCP HTTPS]
    RemoteLLM -->|HTTP 8321/TCP| LlamaStack
    RemoteEmbed -->|HTTP 8321/TCP| LlamaStack

    style RagasInline fill:#4a90e2,stroke:#333
    style RagasRemote fill:#4a90e2,stroke:#333
    style InlineLLM fill:#50c878,stroke:#333
    style InlineEmbed fill:#50c878,stroke:#333
    style RemoteLLM fill:#50c878,stroke:#333
    style RemoteEmbed fill:#50c878,stroke:#333
    style KFPPipeline fill:#f5a623,stroke:#333
    style Compat fill:#b8b8b8,stroke:#333
    style ProviderSpec fill:#b8b8b8,stroke:#333
    style EvalAPI fill:#ddd,stroke:#333
    style InferenceAPI fill:#ddd,stroke:#333
    style DatasetIOAPI fill:#ddd,stroke:#333
    style BenchmarksAPI fill:#ddd,stroke:#333
    style KFP fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
