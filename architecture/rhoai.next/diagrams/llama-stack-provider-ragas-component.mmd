graph TB
    subgraph "Llama Stack Provider Ragas"
        direction TB
        subgraph InlineMode["Inline Provider"]
            InlineEval["RagasEvaluatorInline<br/>ragas_inline_eval.py"]
            InlineLLM["LlamaStackInlineLLM<br/>wrappers_inline.py"]
            InlineEmbed["LlamaStackInlineEmbeddings<br/>wrappers_inline.py"]
            InlineEval -->|uses| InlineLLM
            InlineEval -->|uses| InlineEmbed
        end

        subgraph RemoteMode["Remote Provider (KFP)"]
            RemoteEval["RagasEvaluatorRemote<br/>ragas_remote_eval.py"]
            Pipeline["KFP Pipeline Builder<br/>kubeflow/pipeline.py"]
            Components["KFP Components<br/>kubeflow/components.py"]
            RemoteLLM["LlamaStackRemoteLLM<br/>wrappers_remote.py"]
            RemoteEmbed["LlamaStackRemoteEmbeddings<br/>wrappers_remote.py"]
            RemoteEval -->|builds| Pipeline
            Pipeline -->|defines| Components
            Components -->|uses| RemoteLLM
            Components -->|uses| RemoteEmbed
        end

        Config["RagasProviderConfig<br/>config.py"]
        Compat["Compatibility Layer<br/>compat.py"]
        InlineEval -->|configured by| Config
        RemoteEval -->|configured by| Config
        InlineEval -->|imports via| Compat
        RemoteEval -->|imports via| Compat
    end

    Client["Client / User"] -->|POST /alpha/eval/run-eval| LlamaStack

    subgraph LlamaStack["Llama Stack Server :8321"]
        EvalAPI["Eval API"]
        InferenceAPI["Inference API"]
        DatasetAPI["DatasetIO API"]
        BenchmarksAPI["Benchmarks API"]
        FilesAPI["Files API"]
    end

    EvalAPI -->|loads plugin| InlineEval
    EvalAPI -->|loads plugin| RemoteEval
    InlineLLM -->|in-process call| InferenceAPI
    InlineEmbed -->|in-process call| InferenceAPI

    InferenceAPI -->|REST API| Ollama["Ollama<br/>:11434/TCP"]
    InferenceAPI -->|REST API| vLLM["vLLM<br/>:8443/TCP"]

    RemoteEval -->|submits pipeline| KFP["Kubeflow Pipelines<br/>:443/TCP HTTPS"]
    RemoteEval -->|reads results| S3["S3 Storage<br/>:443/TCP HTTPS"]
    RemoteEval -->|reads ConfigMap| K8sAPI["Kubernetes API<br/>:443/TCP"]

    KFP -->|callback| LlamaStack

    style InlineEval fill:#4a90e2,color:#fff
    style RemoteEval fill:#4a90e2,color:#fff
    style Config fill:#9b59b6,color:#fff
    style EvalAPI fill:#f5a623,color:#fff
    style InferenceAPI fill:#f5a623,color:#fff
    style DatasetAPI fill:#f5a623,color:#fff
    style BenchmarksAPI fill:#f5a623,color:#fff
    style FilesAPI fill:#f5a623,color:#fff
    style Ollama fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style KFP fill:#7ed321,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
