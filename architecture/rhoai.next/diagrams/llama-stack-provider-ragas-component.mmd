graph TB
    subgraph "Llama Stack Provider Ragas"
        direction TB

        subgraph InlineMode["Inline Mode (in-process)"]
            InlineProvider["Ragas Inline Provider<br/><i>inline::trustyai_ragas</i>"]
            LLMWrapper["LlamaStackInlineLLM<br/><i>BaseRagasLLM adapter</i>"]
            EmbWrapper["LlamaStackInlineEmbeddings<br/><i>BaseRagasEmbeddings adapter</i>"]
            InlineProvider --> LLMWrapper
            InlineProvider --> EmbWrapper
        end

        subgraph RemoteMode["Remote Mode (KFP)"]
            RemoteProvider["Ragas Remote Provider<br/><i>remote::trustyai_ragas</i>"]
            subgraph KFPPipeline["KFP Pipeline Components"]
                RetrieveData["retrieve_data_from_llama_stack<br/><i>Step 1: Data Fetch</i>"]
                RunRagas["run_ragas_evaluation<br/><i>Step 2: Metrics Compute</i>"]
                RetrieveData --> RunRagas
            end
            RemoteProvider -->|constructs & submits| KFPPipeline
        end

        CompatLayer["Compatibility Layer<br/><i>compat.py</i><br/>llama_stack / llama_stack_api bridge"]
        InlineProvider --> CompatLayer
        RemoteProvider --> CompatLayer
    end

    Client[Client] -->|POST /alpha/eval/run-eval| LlamaStackServer
    Client -->|GET /alpha/eval/job-status| LlamaStackServer
    Client -->|GET /alpha/eval/job-result| LlamaStackServer

    LlamaStackServer["Llama Stack Server<br/>8321/TCP HTTP"] -->|Eval API dispatch| InlineProvider
    LlamaStackServer -->|Eval API dispatch| RemoteProvider

    LLMWrapper -->|in-process| InferenceAPI["Llama Stack Inference API<br/><i>LLM completions + embeddings</i>"]
    EmbWrapper -->|in-process| InferenceAPI
    InlineProvider -->|in-process| DatasetIO["Llama Stack DatasetIO API"]

    RemoteProvider -->|HTTPS/443<br/>Bearer Token| KFP["Kubeflow Pipelines API"]
    RetrieveData -->|HTTP/8321| LlamaStackServer
    RunRagas -->|HTTP/8321| LlamaStackServer
    RunRagas -->|HTTPS/443<br/>AWS IAM| S3["S3 Object Storage"]
    RemoteProvider -->|HTTPS/443<br/>AWS IAM| S3

    RemoteProvider -->|HTTPS/6443<br/>kubeconfig| K8sAPI["Kubernetes API<br/><i>ConfigMap read</i>"]

    style InlineProvider fill:#4a90e2,color:#fff
    style RemoteProvider fill:#4a90e2,color:#fff
    style LLMWrapper fill:#6db3f2,color:#fff
    style EmbWrapper fill:#6db3f2,color:#fff
    style RetrieveData fill:#9b59b6,color:#fff
    style RunRagas fill:#9b59b6,color:#fff
    style CompatLayer fill:#95a5a6,color:#fff
    style LlamaStackServer fill:#f5a623,color:#000
    style InferenceAPI fill:#f5a623,color:#000
    style DatasetIO fill:#f5a623,color:#000
    style KFP fill:#e8e8e8,color:#000
    style S3 fill:#e8e8e8,color:#000
    style K8sAPI fill:#e8e8e8,color:#000
    style Client fill:#2ecc71,color:#fff
