graph TB
    subgraph "llama-stack-provider-ragas"
        direction TB

        subgraph InlineMode["Inline Mode (in-process)"]
            InlineProvider["Ragas Inline Provider<br/><i>inline::trustyai_ragas</i>"]
            InlineLLM["LlamaStackInlineLLM<br/><i>BaseRagasLLM wrapper</i>"]
            InlineEmbed["LlamaStackInlineEmbeddings<br/><i>BaseRagasEmbeddings wrapper</i>"]
            InlineProvider -->|"asyncio.to_thread()"| RagasEval["Ragas evaluate()<br/><i>max_workers=1</i>"]
            RagasEval --> InlineLLM
            RagasEval --> InlineEmbed
        end

        subgraph RemoteMode["Remote Mode (KFP)"]
            RemoteProvider["Ragas Remote Provider<br/><i>remote::trustyai_ragas</i>"]
            KFPPipeline["KFP Pipeline Builder<br/><i>pipeline.py</i>"]
            RetrieveComp["retrieve_data<br/><i>KFP Component</i>"]
            RunRagasComp["run_ragas<br/><i>KFP Component</i>"]
            RemoteProvider -->|"constructs"| KFPPipeline
            KFPPipeline --> RetrieveComp
            KFPPipeline --> RunRagasComp
        end

        Compat["Compatibility Layer<br/><i>compat.py</i><br/>llama_stack / llama_stack_api"]
        InlineProvider --> Compat
        RemoteProvider --> Compat
    end

    Client[Client] -->|"POST /alpha/eval/run-eval<br/>8321/TCP HTTP"| LlamaStack["Llama Stack Server<br/><i>Host Process</i>"]
    LlamaStack -->|"routes to provider"| InlineProvider
    LlamaStack -->|"routes to provider"| RemoteProvider

    InlineLLM -->|"in-process"| InferenceAPI["Llama Stack<br/>Inference API"]
    InlineEmbed -->|"in-process"| InferenceAPI
    InlineProvider -->|"in-process"| DatasetIO["Llama Stack<br/>DatasetIO API"]

    RemoteProvider -->|"HTTPS/443<br/>Bearer Token"| KFP["Kubeflow Pipelines<br/>API"]
    RemoteProvider -->|"HTTPS/443<br/>AWS IAM"| S3["S3 Object Storage"]
    RetrieveComp -->|"HTTP/8321"| LlamaStack
    RunRagasComp -->|"HTTPS/443"| S3

    RemoteProvider -->|"HTTPS/6443"| K8sAPI["Kubernetes API<br/><i>ConfigMap read</i>"]

    style InlineProvider fill:#4a90e2,color:#fff
    style RemoteProvider fill:#4a90e2,color:#fff
    style InlineLLM fill:#5ba3d9,color:#fff
    style InlineEmbed fill:#5ba3d9,color:#fff
    style RagasEval fill:#7ed321,color:#fff
    style KFPPipeline fill:#5ba3d9,color:#fff
    style RetrieveComp fill:#5ba3d9,color:#fff
    style RunRagasComp fill:#5ba3d9,color:#fff
    style Compat fill:#f5a623,color:#fff
    style LlamaStack fill:#e8e8e8,stroke:#333
    style KFP fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style InferenceAPI fill:#e8e8e8,stroke:#333
    style DatasetIO fill:#e8e8e8,stroke:#333
