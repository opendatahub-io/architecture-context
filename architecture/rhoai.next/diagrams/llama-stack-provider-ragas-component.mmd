    style Components fill:#f5a623,color:#fff
    style LlamaStackServer fill:#e8e8e8,stroke:#333
    style KFPAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
