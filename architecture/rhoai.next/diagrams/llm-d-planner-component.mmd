    style SpecGenerator fill:#6ab0f3,stroke:#333,color:#fff
    style RecommendEngine fill:#6ab0f3,stroke:#333,color:#fff
    style ConfigGenerator fill:#6ab0f3,stroke:#333,color:#fff
    style ClusterManager fill:#6ab0f3,stroke:#333,color:#fff
    style CapacityPlanner fill:#6ab0f3,stroke:#333,color:#fff
    style GPURecommender fill:#6ab0f3,stroke:#333,color:#fff
    style ModelCatalogSync fill:#6ab0f3,stroke:#333,color:#fff
    style InferenceService fill:#f5a623,stroke:#333,color:#fff
