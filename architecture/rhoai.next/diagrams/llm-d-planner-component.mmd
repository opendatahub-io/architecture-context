graph TB
    subgraph External["External Users"]
        User["User (Browser)"]
        CLIUser["User (CLI)"]
    end

    subgraph Routes["OpenShift Routes (TLS Edge)"]
        UIRoute["planner Route<br/>443/TCP HTTPS"]
        BackendRoute["planner-backend Route<br/>443/TCP HTTPS"]
    end

    subgraph Planner["llm-d Planner Platform"]
        direction TB

        subgraph Frontend["Streamlit UI (port 8501)"]
            StreamlitApp["Streamlit App<br/>Multi-tab Workflow"]
            APIClient["API Client"]
            StreamlitApp --> APIClient
        end

        subgraph Backend["Backend API (FastAPI, port 8000)"]
            direction TB
            FastAPI["FastAPI Router<br/>29 REST endpoints"]

            subgraph Modules["Internal Modules"]
                IntentEngine["Intent Extraction<br/>Engine"]
                SpecGen["Specification<br/>Generator"]
                RecEngine["Recommendation<br/>Engine"]
                Scorer["Multi-Criteria Scorer<br/>(accuracy, price,<br/>latency, complexity)"]
                ConfigGen["Configuration<br/>Generator (Jinja2)"]
                CapPlanner["Capacity Planner<br/>(GPU memory est.)"]
                GPURec["GPU Recommender<br/>(roofline est.)"]
                KBase["Knowledge Base<br/>(PostgreSQL + JSON)"]
                ClusterMgr["Cluster Manager<br/>(kubectl)"]
            end

            FastAPI --> IntentEngine
            FastAPI --> SpecGen
            FastAPI --> RecEngine
            RecEngine --> Scorer
            FastAPI --> ConfigGen
            FastAPI --> CapPlanner
            FastAPI --> GPURec
            FastAPI --> KBase
            FastAPI --> ClusterMgr
        end

        subgraph Simulator["vLLM Simulator (port 8080)"]
            SimService["OpenAI-compatible API<br/>(dev/test only)"]
        end

        subgraph DBInit["db-init Job"]
            InitJob["Schema Init +<br/>Benchmark Loading"]
        end
    end

    subgraph Infrastructure["Infrastructure Services"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        Ollama["Ollama LLM<br/>11434/TCP<br/>(qwen2.5:7b)"]
    end

    subgraph ExternalSvc["External Services"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
        ModelCatalog["RHOAI Model Catalog<br/>8443/TCP HTTPS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        KServe["KServe<br/>InferenceService CRDs"]
    end

    %% User flows
    User -->|HTTPS/443| UIRoute
    User -->|HTTPS/443| BackendRoute
    CLIUser -->|HTTP/8000| FastAPI
    UIRoute -->|HTTP/8501| StreamlitApp
    BackendRoute -->|HTTP/8000| FastAPI
    APIClient -->|HTTP/8000| FastAPI

    %% Backend to infrastructure
    IntentEngine -->|HTTP/11434| Ollama
    KBase -->|PostgreSQL/5432| PostgreSQL
    InitJob -->|PostgreSQL/5432| PostgreSQL

    %% Backend to external
    CapPlanner -->|HTTPS/443| HFHub
    KBase -->|HTTPS/8443| ModelCatalog
    ClusterMgr -->|HTTPS/6443| K8sAPI
    ConfigGen -.->|generates CRDs for| KServe

    %% Styling
    style User fill:#f9f9f9,stroke:#333
    style CLIUser fill:#f9f9f9,stroke:#333
    style UIRoute fill:#ffe6cc,stroke:#d79b00
    style BackendRoute fill:#ffe6cc,stroke:#d79b00
    style StreamlitApp fill:#dae8fc,stroke:#6c8ebf
    style APIClient fill:#dae8fc,stroke:#6c8ebf
    style FastAPI fill:#4a90e2,stroke:#333,color:#fff
    style IntentEngine fill:#d5e8d4,stroke:#82b366
    style SpecGen fill:#d5e8d4,stroke:#82b366
    style RecEngine fill:#d5e8d4,stroke:#82b366
    style Scorer fill:#d5e8d4,stroke:#82b366
    style ConfigGen fill:#d5e8d4,stroke:#82b366
    style CapPlanner fill:#d5e8d4,stroke:#82b366
    style GPURec fill:#d5e8d4,stroke:#82b366
    style KBase fill:#d5e8d4,stroke:#82b366
    style ClusterMgr fill:#d5e8d4,stroke:#82b366
    style SimService fill:#e1d5e7,stroke:#9673a6
    style InitJob fill:#e1d5e7,stroke:#9673a6
    style PostgreSQL fill:#fff2cc,stroke:#d6b656
    style Ollama fill:#fff2cc,stroke:#d6b656
    style HFHub fill:#f8cecc,stroke:#b85450
    style ModelCatalog fill:#f8cecc,stroke:#b85450
    style K8sAPI fill:#f8cecc,stroke:#b85450
    style KServe fill:#f8cecc,stroke:#b85450
