graph TB
    subgraph External["External Users"]
        User["User (Browser)"]
    end

    subgraph OpenShiftRouter["OpenShift Router (Edge TLS)"]
        RoutePlanner["Route: planner<br/>443/TCP HTTPS"]
        RouteBackend["Route: planner-backend<br/>443/TCP HTTPS"]
    end

    subgraph PlannerNamespace["Namespace: planner"]
        subgraph UIService["UI Service"]
            UI["Streamlit UI<br/>8501/TCP HTTP<br/>python:3.14-slim"]
        end

        subgraph BackendService["Backend Service"]
            Backend["FastAPI Backend<br/>8000/TCP HTTP<br/>python:3.14-slim"]
            IntentExtractor["Intent Extractor<br/>(LLM-powered)"]
            SpecGenerator["Specification Generator<br/>(Template-driven)"]
            RecommendEngine["Recommendation Engine<br/>(Multi-criteria scoring)"]
            ConfigGenerator["Config Generator<br/>(Jinja2 templates)"]
            ClusterManager["Cluster Manager<br/>(kubectl subprocess)"]
            CapacityPlanner["Capacity Planner<br/>(GPU memory estimation)"]
            GPURecommender["GPU Recommender<br/>(Roofline modeling)"]
            ModelCatalogSync["Model Catalog Sync<br/>(Daemon thread)"]

            Backend --> IntentExtractor
            Backend --> SpecGenerator
            Backend --> RecommendEngine
            Backend --> ConfigGenerator
            Backend --> ClusterManager
            Backend --> CapacityPlanner
            Backend --> GPURecommender
            Backend --> ModelCatalogSync
        end

        subgraph DataLayer["Data Layer"]
            Postgres["PostgreSQL<br/>5432/TCP<br/>Benchmark DB"]
        end

        subgraph LLMService["LLM Service (Optional)"]
            Ollama["Ollama<br/>11434/TCP HTTP<br/>(when LLM_PROVIDER=ollama)"]
        end

        DBInit["db-init Job<br/>(Schema + Data Load)"]
    end

    %% User flows
    User -->|HTTPS/443| RoutePlanner
    User -->|HTTPS/443| RouteBackend
    RoutePlanner -->|HTTP/8501| UI
    RouteBackend -->|HTTP/8000| Backend

    %% Internal flows
    UI -->|HTTP/8000<br/>All API calls| Backend
    IntentExtractor -->|HTTP/11434<br/>LLM chat| Ollama
    RecommendEngine -->|TCP/5432<br/>Benchmark queries| Postgres
    ModelCatalogSync -->|TCP/5432<br/>Benchmark insert| Postgres
    DBInit -->|TCP/5432<br/>Schema init| Postgres

    %% External dependencies
    IntentExtractor -->|HTTPS/443<br/>Vertex AI / OpenAI| ExternalLLM["External LLM APIs<br/>(Vertex AI, OpenAI)"]
    CapacityPlanner -->|HTTPS/443<br/>Model metadata| HuggingFace["HuggingFace Hub API"]
    GPURecommender -.->|In-process| BentoML["BentoML llm-optimizer<br/>(Roofline model)"]
    ClusterManager -->|HTTPS/6443<br/>SA token| K8sAPI["Kubernetes API"]
    ModelCatalogSync -->|HTTPS/8443<br/>SA token| ModelCatalog["Model Catalog API<br/>(rhoai-model-registries)"]

    %% CRD creation
    ClusterManager -->|creates| InferenceService["KServe InferenceService CR"]

    %% Styling
    style Backend fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#4a90e2,stroke:#333,color:#fff
    style Ollama fill:#4a90e2,stroke:#333,color:#fff
    style Postgres fill:#4a90e2,stroke:#333,color:#fff
    style DBInit fill:#4a90e2,stroke:#333,color:#fff
