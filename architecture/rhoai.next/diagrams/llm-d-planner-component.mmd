graph TB
    subgraph External["External Access"]
        User[User / Browser]
    end

    subgraph OpenShiftRouter["OpenShift Router (TLS Edge)"]
        RouteUI["Route: planner<br/>443/TCP HTTPS"]
        RouteBackend["Route: planner-backend<br/>443/TCP HTTPS"]
    end

    subgraph PlannerNamespace["Namespace: planner"]
        subgraph Frontend["Streamlit UI"]
            StreamlitApp["Streamlit App<br/>8501/TCP HTTP"]
        end

        subgraph BackendService["Backend API (FastAPI)"]
            APIServer["FastAPI Server<br/>8000/TCP HTTP"]

            subgraph Orchestration["Orchestration Layer"]
                Workflow["RecommendationWorkflow"]
            end

            subgraph Engines["Processing Engines"]
                IntentExtractor["Intent Extraction<br/>Engine"]
                SpecEngine["Specification<br/>Engine"]
                RecommendEngine["Recommendation<br/>Engine"]
                ConfigGen["Configuration<br/>Generator (Jinja2)"]
                CapPlanner["Capacity<br/>Planner"]
                GPURec["GPU<br/>Recommender"]
            end

            subgraph ClusterMgmt["Cluster Management"]
                ClusterMgr["Cluster Manager<br/>(kubectl subprocess)"]
                GPUDetector["GPU Detector<br/>(K8s Python client)"]
            end

            subgraph KnowledgeBase["Knowledge Base"]
                BenchmarkDB["Benchmark<br/>Manager"]
                Loader["Data Loader"]
                ModelCatClient["Model Catalog<br/>Client"]
                ModelCatSync["Model Catalog<br/>Sync (background)"]
                SLOTemplates["SLO Templates"]
            end
        end

        subgraph DataLayer["Data Layer"]
            PostgreSQL["PostgreSQL<br/>5432/TCP"]
            Ollama["Ollama LLM<br/>11434/TCP"]
        end
    end

    subgraph ExternalServices["External Services"]
        HFHub["HuggingFace Hub API<br/>443/TCP HTTPS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        ModelCatalog["RHOAI Model Catalog<br/>8443/TCP HTTPS"]
        BentoML["BentoML llm-optimizer<br/>(in-process)"]
    end

    subgraph DeployTargets["Deploy Targets (Generated)"]
        KServe["KServe InferenceService"]
        ServiceMonitor["Prometheus ServiceMonitor"]
        HPA["HPA Autoscaler"]
    end

    %% User flows
    User -->|HTTPS/443| RouteUI
    User -->|HTTPS/443| RouteBackend
    RouteUI -->|HTTP/8501| StreamlitApp
    RouteBackend -->|HTTP/8000| APIServer

    %% Frontend to Backend
    StreamlitApp -->|HTTP/8000| APIServer

    %% API to Orchestration
    APIServer --> Workflow

    %% Orchestration to Engines
    Workflow --> IntentExtractor
    Workflow --> SpecEngine
    Workflow --> RecommendEngine
    Workflow --> ConfigGen
    Workflow --> CapPlanner
    Workflow --> GPURec

    %% Engine dependencies
    IntentExtractor -->|HTTP/11434| Ollama
    RecommendEngine --> BenchmarkDB
    RecommendEngine --> GPURec
    CapPlanner -->|HTTPS/443| HFHub
    GPURec --> BentoML
    ConfigGen -.->|generates| KServe
    ConfigGen -.->|generates| ServiceMonitor
    ConfigGen -.->|generates| HPA

    %% Cluster management
    ClusterMgr -->|HTTPS/6443<br/>SA Token| K8sAPI
    GPUDetector -->|HTTPS/6443<br/>SA Token| K8sAPI

    %% Knowledge base
    BenchmarkDB -->|5432/TCP<br/>Password| PostgreSQL
    ModelCatClient -->|HTTPS/8443<br/>Bearer Token| ModelCatalog
    ModelCatSync -->|HTTPS/8443| ModelCatalog
    ModelCatSync -->|5432/TCP| PostgreSQL
    Loader --> PostgreSQL

    %% Styles
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style StreamlitApp fill:#4a90e2,stroke:#333,color:#fff
    style Workflow fill:#5b9bd5,stroke:#333,color:#fff
    style IntentExtractor fill:#7fb3de,stroke:#333
    style SpecEngine fill:#7fb3de,stroke:#333
    style RecommendEngine fill:#7fb3de,stroke:#333
    style ConfigGen fill:#7fb3de,stroke:#333
    style CapPlanner fill:#7fb3de,stroke:#333
    style GPURec fill:#7fb3de,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#333,stroke:#666,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style ServiceMonitor fill:#e8e8e8,stroke:#333
    style HPA fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#333
    style BentoML fill:#f5a623,stroke:#333
