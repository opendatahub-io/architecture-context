    %% ─── Service Accounts ───
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager"]
        SA_LLM["llmisvc-controller-manager"]
        SA_LocalModel["kserve-localmodel-<br/>controller-manager"]
        SA_NodeAgent["kserve-localmodelnode-<br/>agent"]
        SA_IGAuth["{ig}-auth-verifier<br/><i>(per InferenceGraph)</i>"]
        SA_EPPAuth["{llmisvc}-epp-sa<br/><i>(per LLMInferenceService)</i>"]
    end

    %% ─── ClusterRoleBindings ───
    subgraph Bindings["ClusterRoleBindings"]
        CRB_KServe["kserve-manager-<br/>rolebinding"]
        CRB_LLM["llmisvc-manager-<br/>rolebinding"]
