graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager"]
        SA_LLMISVC["llmisvc-controller-manager"]
        SA_LocalModel["kserve-localmodel-controller"]
        SA_LocalModelNode["kserve-localmodelnode-agent"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LLMISVC["kserve-llmisvc-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LocalModel["kserve-localmodel-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LocalModelNode["kserve-localmodelnode-agent-rolebinding<br/>(cluster-scoped)"]
        CRB_Leader["kserve-leader-election-rolebinding<br/>(namespace: kserve)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMISVC["kserve-llmisvc-manager-role"]
        CR_LocalModel["kserve-localmodel-manager-role"]
        CR_LocalModelNode["kserve-localmodelnode-agent-role"]
    end

    subgraph KServeResources["kserve-manager-role Resources"]
        direction LR
        KR_ISVC["serving.kserve.io<br/>InferenceService<br/>ServingRuntime<br/>ClusterServingRuntime<br/>TrainedModel<br/>InferenceGraph<br/>LocalModelCache(s)<br/><i>full CRUD</i>"]
        KR_Apps["apps<br/>Deployments<br/><i>full CRUD</i>"]
        KR_Core["core<br/>Services, Events,<br/>ConfigMaps, Secrets,<br/>ServiceAccounts,<br/>Namespaces, Pods<br/><i>various</i>"]
        KR_Knative["serving.knative.dev<br/>Services<br/><i>full CRUD</i>"]
        KR_Istio["networking.istio.io<br/>VirtualServices<br/><i>full CRUD</i>"]
        KR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes<br/><i>full CRUD</i>"]
        KR_Autoscaling["autoscaling<br/>HPAs<br/><i>full CRUD</i>"]
        KR_KEDA["keda.sh<br/>ScaledObjects<br/><i>full CRUD</i>"]
        KR_OTel["opentelemetry.io<br/>OTelCollectors<br/><i>full CRUD</i>"]
        KR_Ingress["networking.k8s.io<br/>Ingresses<br/><i>full CRUD</i>"]
        KR_Admission["admissionregistration.k8s.io<br/>Mutating/Validating<br/>WebhookConfigurations<br/><i>full CRUD</i>"]
        KR_Route["route.openshift.io<br/>Routes<br/><i>full CRUD</i>"]
    end

    subgraph LLMISVCResources["kserve-llmisvc-manager-role Resources"]
        direction LR
        LR_LLMISVC["serving.kserve.io<br/>LLMInferenceService<br/>LLMInferenceServiceConfig<br/><i>full CRUD</i>"]
        LR_Apps["apps<br/>Deployments<br/><i>full CRUD</i>"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets<br/><i>full CRUD</i>"]
        LR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes, Gateways,<br/>GatewayClasses<br/><i>full CRUD</i>"]
        LR_Inference["inference.networking.x-k8s.io<br/>InferencePools,<br/>InferenceObjectives,<br/>InferenceModels<br/><i>full CRUD</i>"]
        LR_WVA["llmd.ai<br/>VariantAutoscalings<br/><i>full CRUD</i>"]
        LR_Monitoring["monitoring.coreos.com<br/>PodMonitors,<br/>ServiceMonitors<br/><i>full CRUD</i>"]
        LR_Istio["networking.istio.io<br/>(distro only)<br/>DestinationRules<br/><i>CRUD (no patch)</i>"]
        LR_SCC["security.openshift.io<br/>(distro only)<br/>SCC: use<br/><i>openshift-ai-<br/>llminferenceservice-scc</i>"]
    end

    subgraph LocalModelResources["kserve-localmodel-manager-role Resources"]
        direction LR
        LMR_KServe["serving.kserve.io<br/>LocalModelCache(s)<br/>LocalModelNodeGroup<br/>LocalModelNode<br/><i>full CRUD</i>"]
        LMR_Core["core<br/>PVs, PVCs, Nodes,<br/>ConfigMaps<br/><i>get, list, watch,<br/>create, update, patch</i>"]
    end

    subgraph LocalModelNodeResources["kserve-localmodelnode-agent-role Resources"]
        direction LR
        LMNR_KServe["serving.kserve.io<br/>LocalModelNodeGroups<br/>ClusterStorageContainers<br/>LocalModelNodes<br/><i>full CRUD</i>"]
        LMNR_Batch["batch<br/>Jobs<br/><i>full CRUD</i>"]
        LMNR_Core["core<br/>Secrets, SAs,<br/>Nodes, ConfigMaps<br/><i>get, list, watch</i>"]
    end

    %% SA → Binding → Role chains
    SA_KServe -->|bound via| CRB_KServe
    SA_KServe -->|bound via| CRB_Leader
    CRB_KServe -->|grants| CR_KServe
    CR_KServe -->|permissions| KR_ISVC
    CR_KServe -->|permissions| KR_Apps
    CR_KServe -->|permissions| KR_Core
    CR_KServe -->|permissions| KR_Knative
    CR_KServe -->|permissions| KR_Istio
    CR_KServe -->|permissions| KR_Gateway
    CR_KServe -->|permissions| KR_Autoscaling
    CR_KServe -->|permissions| KR_KEDA
    CR_KServe -->|permissions| KR_OTel
    CR_KServe -->|permissions| KR_Ingress
    CR_KServe -->|permissions| KR_Admission
    CR_KServe -->|permissions| KR_Route

    SA_LLMISVC -->|bound via| CRB_LLMISVC
    CRB_LLMISVC -->|grants| CR_LLMISVC
    CR_LLMISVC -->|permissions| LR_LLMISVC
    CR_LLMISVC -->|permissions| LR_Apps
    CR_LLMISVC -->|permissions| LR_LWS
    CR_LLMISVC -->|permissions| LR_Gateway
    CR_LLMISVC -->|permissions| LR_Inference
    CR_LLMISVC -->|permissions| LR_WVA
    CR_LLMISVC -->|permissions| LR_Monitoring
    CR_LLMISVC -->|permissions| LR_Istio
    CR_LLMISVC -->|permissions| LR_SCC

    SA_LocalModel -->|bound via| CRB_LocalModel
    CRB_LocalModel -->|grants| CR_LocalModel
    CR_LocalModel -->|permissions| LMR_KServe
    CR_LocalModel -->|permissions| LMR_Core

    SA_LocalModelNode -->|bound via| CRB_LocalModelNode
    CRB_LocalModelNode -->|grants| CR_LocalModelNode
    CR_LocalModelNode -->|permissions| LMNR_KServe
    CR_LocalModelNode -->|permissions| LMNR_Batch
    CR_LocalModelNode -->|permissions| LMNR_Core

