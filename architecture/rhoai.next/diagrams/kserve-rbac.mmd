graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kserve-controller-manager<br/><i>Namespace: opendatahub</i>"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["kserve-manager-rolebinding<br/><i>cluster-scoped</i>"]
    end

    subgraph ClusterRole["ClusterRole: kserve-manager-role"]
        CR["kserve-manager-role"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    subgraph CoreAPI["Core API Resources"]
        ConfigMaps["core/configmaps<br/><b>create, get, update</b>"]
        Events["core/events<br/><b>create, delete, get, list,<br/>patch, update, watch</b>"]
        Services["core/services<br/><b>create, delete, get, list,<br/>patch, update, watch</b>"]
        Namespaces["core/namespaces<br/><b>get, list, watch</b>"]
        Pods["core/pods<br/><b>get, list, watch</b>"]
        Secrets["core/secrets<br/><b>get</b>"]
        ServiceAccts["core/serviceaccounts<br/><b>create, delete, get, patch</b>"]
    end

    subgraph Admission["Admission Control"]
        MWC["admissionregistration/<br/>mutatingwebhookconfigurations<br/><b>full CRUD + watch</b>"]
        VWC["admissionregistration/<br/>validatingwebhookconfigurations<br/><b>full CRUD + watch</b>"]
    end

    subgraph Workload["Workload Resources"]
        Deployments["apps/deployments<br/><b>full CRUD + watch</b>"]
        HPAs["autoscaling/<br/>horizontalpodautoscalers<br/><b>full CRUD + watch</b>"]
    end

    subgraph Networking["Networking Resources"]
        HTTPRoutes["gateway.networking.k8s.io/<br/>httproutes<br/><b>full CRUD + watch</b>"]
        VirtualServices["networking.istio.io/<br/>virtualservices<br/><b>full CRUD + watch</b>"]
        Ingresses["networking.k8s.io/<br/>ingresses<br/><b>full CRUD + watch</b>"]
        Routes["route.openshift.io/<br/>routes<br/><b>full CRUD + watch</b>"]
    end

    subgraph Scaling["Scaling & Observability"]
        ScaledObjects["keda.sh/<br/>scaledobjects<br/><b>full CRUD + watch</b>"]
        OTelCollectors["opentelemetry.io/<br/>opentelemetrycollectors<br/><b>full CRUD + watch</b>"]
    end

    subgraph KnativeRes["Knative Resources"]
        KnativeSvcs["serving.knative.dev/<br/>services<br/><b>full CRUD + watch</b>"]
    end

    subgraph KServeCRDs["KServe CRDs (serving.kserve.io)"]
        ISVC["inferenceservices<br/><b>full CRUD + watch</b>"]
        IG["inferencegraphs<br/><b>full CRUD + watch</b>"]
        TM["trainedmodels<br/><b>full CRUD + watch</b>"]
        SR["servingruntimes<br/><b>full CRUD + watch</b>"]
        CSR["clusterservingruntimes<br/><b>full CRUD + watch</b>"]
        CSC["clusterstoragecontainers<br/><b>full CRUD + watch</b>"]
        LMC["localmodelcaches<br/><b>get, list, watch</b>"]
        LMNC["localmodelnamespacecaches<br/><b>get, list, watch</b>"]
    end

    CR -->|"core API"| ConfigMaps
    CR -->|"core API"| Events
    CR -->|"core API"| Services
    CR -->|"core API (read-only)"| Namespaces
    CR -->|"core API (read-only)"| Pods
    CR -->|"core API (read-only)"| Secrets
    CR -->|"core API"| ServiceAccts

    CR -->|"admission"| MWC
    CR -->|"admission"| VWC

    CR -->|"workload"| Deployments
    CR -->|"workload"| HPAs

    CR -->|"networking"| HTTPRoutes
    CR -->|"networking"| VirtualServices
    CR -->|"networking"| Ingresses
    CR -->|"networking"| Routes

    CR -->|"scaling"| ScaledObjects
    CR -->|"observability"| OTelCollectors

    CR -->|"knative"| KnativeSvcs

    CR -->|"kserve (full)"| ISVC
    CR -->|"kserve (full)"| IG
    CR -->|"kserve (full)"| TM
    CR -->|"kserve (full)"| SR
    CR -->|"kserve (full)"| CSR
    CR -->|"kserve (full)"| CSC
    CR -->|"kserve (read-only)"| LMC
    CR -->|"kserve (read-only)"| LMNC

