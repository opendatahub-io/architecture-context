    class CR_KServe,CR_LLMISVC,CR_LocalModel,CR_LMAgent,CR_Proxy,CR_AuthDelegator cr
    class KR_ISVC,KR_SR,KR_CSC,KR_Deploy,KR_Core,KR_Ingress,KR_Knative,KR_Istio,KR_HPA,KR_HTTPRoute,KR_KEDA,KR_OTel resource
    class KR_LMC,KR_OCPRoute readonly
    class LR_LLMISVC,LR_GW,LR_InfPool,LR_LWS,LR_VarAuto,LR_Monitor,LR_DestRule resource
    class LR_SCC,LR_Auth readonly
    class LMR_Cache resource
    class LMR_PV readonly
    class AR_LMN,AR_Jobs resource
