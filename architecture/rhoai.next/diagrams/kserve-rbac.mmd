graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager"]
        SA_LLM["llmisvc-controller-manager"]
        SA_LM["kserve-localmodel-controller-manager"]
        SA_LMAgent["localmodelnode-agent"]
        SA_EPP["{llmSvc-name}-epp-sa"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding"]
        CRB_LLM["llmisvc-manager-rolebinding"]
        CRB_LM["localmodel-manager-rolebinding"]
        CRB_Proxy["kserve-proxy-rolebinding"]
        CRB_EPP["{llmSvc}-epp-auth-rb"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KServe["kserve-manager-role"]
        CR_LLM["llmisvc-manager-role"]
        CR_LM["localmodel-manager-role"]
        CR_LMAgent["localmodelnode-agent-role"]
        CR_Proxy["kserve-proxy-role"]
        CR_AuthDelegator["system:auth-delegator"]
    end

    %% SA → CRB → CR bindings
    SA_KServe -->|bound via| CRB_KServe
    SA_KServe -->|bound via| CRB_Proxy
    SA_LLM -->|bound via| CRB_LLM
    SA_LM -->|bound via| CRB_LM
    SA_EPP -->|bound via| CRB_EPP

    CRB_KServe -->|grants| CR_KServe
    CRB_LLM -->|grants| CR_LLM
    CRB_LM -->|grants| CR_LM
    CRB_Proxy -->|grants| CR_Proxy
    CRB_EPP -->|grants| CR_AuthDelegator

    %% kserve-manager-role resources
    subgraph KServeResources["kserve-manager-role Resources"]
        KR_ISVC["serving.kserve.io<br/>inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status"]
        KR_SR["serving.kserve.io<br/>servingruntimes<br/>clusterservingruntimes<br/>clusterstoragecontainers"]
        KR_LMC["serving.kserve.io<br/>localmodelcaches<br/>localmodelnamespacecaches"]
        KR_Deploys["apps<br/>deployments"]
        KR_Core["core ('')<br/>services, configmaps, secrets<br/>namespaces, events, pods, sa"]
        KR_Ingress["networking.k8s.io<br/>ingresses"]
        KR_Knative["serving.knative.dev<br/>services"]
        KR_Istio["networking.istio.io<br/>virtualservices"]
        KR_HPA["autoscaling<br/>horizontalpodautoscalers"]
        KR_GW["gateway.networking.k8s.io<br/>httproutes"]
        KR_KEDA["keda.sh<br/>scaledobjects"]
        KR_OTel["opentelemetry.io<br/>opentelemetrycollectors"]
        KR_Route["route.openshift.io<br/>routes"]
    end

    CR_KServe -->|"full CRUD"| KR_ISVC
    CR_KServe -->|"full CRUD"| KR_SR
    CR_KServe -->|"get,list,watch"| KR_LMC
    CR_KServe -->|"full CRUD"| KR_Deploys
    CR_KServe -->|"full CRUD"| KR_Core
    CR_KServe -->|"full CRUD"| KR_Ingress
    CR_KServe -->|"full CRUD"| KR_Knative
    CR_KServe -->|"full CRUD"| KR_Istio
    CR_KServe -->|"full CRUD"| KR_HPA
    CR_KServe -->|"full CRUD"| KR_GW
    CR_KServe -->|"full CRUD"| KR_KEDA
    CR_KServe -->|"full CRUD"| KR_OTel
    CR_KServe -->|"get,list,watch"| KR_Route

    %% llmisvc-manager-role resources
    subgraph LLMResources["llmisvc-manager-role Resources"]
        LR_LLMSVC["serving.kserve.io<br/>llminferenceservices<br/>llminferenceserviceconfigs"]
        LR_GW["gateway.networking.k8s.io<br/>httproutes, gateways<br/>gatewayclasses"]
        LR_InfPool["inference.networking.x-k8s.io<br/>inferencepools, inferenceobjectives<br/>inferencemodels, inferencemodelrewrites"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets"]
        LR_WVA["llmd.ai<br/>variantautoscalings"]
        LR_Mon["monitoring.coreos.com<br/>podmonitors, servicemonitors"]
        LR_Istio["networking.istio.io<br/>destinationrules"]
        LR_SCC["security.openshift.io<br/>SCC (use)"]
        LR_Auth["authentication.k8s.io<br/>tokenreviews<br/>subjectaccessreviews"]
    end

    CR_LLM -->|"full CRUD"| LR_LLMSVC
    CR_LLM -->|"full CRUD"| LR_GW
    CR_LLM -->|"full CRUD"| LR_InfPool
    CR_LLM -->|"full CRUD"| LR_LWS
    CR_LLM -->|"full CRUD"| LR_WVA
    CR_LLM -->|"full CRUD"| LR_Mon
    CR_LLM -->|"get,list,watch,create,update,delete"| LR_Istio
    CR_LLM -->|"use"| LR_SCC
    CR_LLM -->|"create"| LR_Auth

    %% localmodel-manager-role resources
    subgraph LMResources["localmodel-manager-role Resources"]
        LMR_CRDs["serving.kserve.io<br/>localmodelcaches<br/>localmodelnamespacecaches<br/>localmodelnodes<br/>localmodelnodegroups"]
        LMR_PV["core ('')<br/>persistentvolumes<br/>persistentvolumeclaims<br/>nodes"]
    end

    CR_LM -->|"full CRUD"| LMR_CRDs
    CR_LM -->|"get,list,watch,create,update,patch"| LMR_PV

    %% localmodelnode-agent-role resources
    subgraph LMAgentResources["localmodelnode-agent-role Resources"]
        LMA_CRDs["serving.kserve.io<br/>localmodelnodes<br/>clusterstoragecontainers<br/>localmodelnodegroups"]
        LMA_Jobs["batch<br/>jobs, jobs/status"]
    end

    SA_LMAgent -->|"via DaemonSet"| CR_LMAgent
    CR_LMAgent -->|"full CRUD"| LMA_CRDs
    CR_LMAgent -->|"full CRUD"| LMA_Jobs

