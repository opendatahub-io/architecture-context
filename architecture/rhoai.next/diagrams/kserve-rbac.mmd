    style SA_KServe fill:#4a90e2,stroke:#333,color:#fff
    style SA_LLMISVC fill:#4a90e2,stroke:#333,color:#fff
    style SA_LocalModel fill:#4a90e2,stroke:#333,color:#fff
    style SA_LocalModelNode fill:#4a90e2,stroke:#333,color:#fff

