        KR_Ingress["networking.k8s.io<br/>Ingresses<br/>★ full CRUD"]
        KR_Knative["serving.knative.dev<br/>Services<br/>★ full CRUD"]
        KR_Istio["networking.istio.io<br/>VirtualServices<br/>★ full CRUD"]
        KR_HPA["autoscaling<br/>HPA<br/>★ full CRUD"]
