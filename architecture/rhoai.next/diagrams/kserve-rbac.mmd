graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager<br/>(kserve namespace)"]
        SA_LLMISVC["llmisvc-controller-manager<br/>(kserve namespace)"]
        SA_EPP["&#123;llmisvc&#125;-epp-sa<br/>(dynamic, per LLMInferenceService)"]
        SA_Metrics["kserve-metrics-reader-sa<br/>(dynamic, per namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LLMISVC["llmisvc-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_EPP["&#123;llmisvc&#125;-epp-auth-rb<br/>(cluster-scoped)"]
        CRB_Metrics["kserve-metrics-reader-role-binding-&#123;ns&#125;<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (kserve namespace)"]
        RB_KServeLease["kserve-leader-election-rolebinding"]
        RB_LLMISVCLease["llmisvc-leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMISVC["llmisvc-manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_MetricsReader["kserve-metrics-reader-cluster-role"]
    end

    subgraph Roles["Roles (kserve namespace)"]
        R_KServeLease["kserve-leader-election-role"]
        R_LLMISVCLease["llmisvc-leader-election-role"]
    end

    %% Bindings
    SA_KServe -->|bound via| CRB_KServe
    SA_LLMISVC -->|bound via| CRB_LLMISVC
    SA_EPP -->|bound via| CRB_EPP
    SA_Metrics -->|bound via| CRB_Metrics

    SA_KServe -->|bound via| RB_KServeLease
    SA_LLMISVC -->|bound via| RB_LLMISVCLease

    CRB_KServe -->|grants| CR_KServe
    CRB_LLMISVC -->|grants| CR_LLMISVC
    CRB_EPP -->|grants| CR_AuthDelegator
    CRB_Metrics -->|grants| CR_MetricsReader

    RB_KServeLease -->|grants| R_KServeLease
    RB_LLMISVCLease -->|grants| R_LLMISVCLease

    %% kserve-manager-role permissions
    subgraph KServeResources["kserve-manager-role Permissions"]
        KR_ISVC["serving.kserve.io<br/>inferenceservices<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        KR_SR["serving.kserve.io<br/>servingruntimes<br/>clusterservingruntimes<br/><i>full CRUD</i>"]
        KR_LMC["serving.kserve.io<br/>localmodelcaches<br/>localmodelnamespacecaches<br/><i>get,list,watch</i>"]
        KR_Deploy["apps<br/>deployments<br/><i>full CRUD</i>"]
        KR_Core["core<br/>services, configmaps,<br/>secrets, events, pods,<br/>namespaces, serviceaccounts<br/><i>full CRUD (varies)</i>"]
        KR_Knative["serving.knative.dev<br/>services<br/><i>full CRUD</i>"]
        KR_Istio["networking.istio.io<br/>virtualservices<br/><i>full CRUD</i>"]
        KR_GW["gateway.networking.k8s.io<br/>httproutes<br/><i>full CRUD</i>"]
        KR_HPA["autoscaling<br/>horizontalpodautoscalers<br/><i>full CRUD</i>"]
        KR_KEDA["keda.sh<br/>scaledobjects<br/><i>full CRUD</i>"]
        KR_OTEL["opentelemetry.io<br/>opentelemetrycollectors<br/><i>full CRUD</i>"]
        KR_Route["route.openshift.io<br/>routes<br/><i>get,list,watch</i>"]
        KR_Ingress["networking.k8s.io<br/>ingresses<br/><i>full CRUD</i>"]
        KR_Webhook["admissionregistration.k8s.io<br/>webhookconfigurations<br/><i>full CRUD</i>"]
    end

    CR_KServe -->|"full CRUD"| KR_ISVC
    CR_KServe -->|"full CRUD"| KR_SR
    CR_KServe -->|"read only"| KR_LMC
    CR_KServe -->|"full CRUD"| KR_Deploy
    CR_KServe -->|"varies"| KR_Core
    CR_KServe -->|"full CRUD"| KR_Knative
    CR_KServe -->|"full CRUD"| KR_Istio
    CR_KServe -->|"full CRUD"| KR_GW
    CR_KServe -->|"full CRUD"| KR_HPA
    CR_KServe -->|"full CRUD"| KR_KEDA
    CR_KServe -->|"full CRUD"| KR_OTEL
    CR_KServe -->|"read only"| KR_Route
    CR_KServe -->|"full CRUD"| KR_Ingress
    CR_KServe -->|"full CRUD"| KR_Webhook

    %% llmisvc-manager-role permissions
    subgraph LLMISVCResources["llmisvc-manager-role Permissions"]
        LR_LLMISVC["serving.kserve.io<br/>llminferenceservices<br/>llminferenceserviceconfigs<br/><i>full CRUD</i>"]
        LR_GW["gateway.networking.k8s.io<br/>httproutes, gateways,<br/>gatewayclasses<br/><i>full CRUD</i>"]
        LR_InfPool["inference.networking.x-k8s.io<br/>inferencepools, objectives,<br/>models, rewrites, imports<br/><i>full CRUD</i>"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/><i>full CRUD</i>"]
        LR_WVA["llmd.ai<br/>variantautoscalings<br/><i>full CRUD</i>"]
        LR_Mon["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/><i>full CRUD</i>"]
        LR_IstioOCP["networking.istio.io<br/>destinationrules<br/><i>full CRUD (OCP only)</i>"]
        LR_SCC["security.openshift.io<br/>securitycontextconstraints<br/><i>use (OCP only)</i>"]
        LR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings<br/><i>full CRUD</i>"]
        LR_Lease["coordination.k8s.io<br/>leases<br/><i>full CRUD</i>"]
    end

    CR_LLMISVC -->|"full CRUD"| LR_LLMISVC
    CR_LLMISVC -->|"full CRUD"| LR_GW
    CR_LLMISVC -->|"full CRUD"| LR_InfPool
    CR_LLMISVC -->|"full CRUD"| LR_LWS
    CR_LLMISVC -->|"full CRUD"| LR_WVA
    CR_LLMISVC -->|"full CRUD"| LR_Mon
    CR_LLMISVC -->|"full CRUD (OCP)"| LR_IstioOCP
    CR_LLMISVC -->|"use (OCP)"| LR_SCC
    CR_LLMISVC -->|"full CRUD"| LR_RBAC
    CR_LLMISVC -->|"full CRUD"| LR_Lease

