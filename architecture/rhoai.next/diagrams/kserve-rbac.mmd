graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager"]
        SA_LLMISVC["llmisvc-controller-manager"]
        SA_LocalModel["kserve-localmodel-controller"]
        SA_LocalModelNode["kserve-localmodelnode-agent"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/>(cluster)"]
        CRB_LLMISVC["kserve-llmisvc-manager-rolebinding<br/>(cluster)"]
        CRB_LocalModel["kserve-localmodel-manager-rolebinding<br/>(cluster)"]
        CRB_LocalModelNode["kserve-localmodelnode-agent-rolebinding<br/>(cluster)"]
        RB_LeaderElection["kserve-leader-election-rolebinding<br/>(kserve namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMISVC["kserve-llmisvc-manager-role"]
        CR_LocalModel["kserve-localmodel-manager-role"]
        CR_LocalModelNode["kserve-localmodelnode-agent-role"]
        CR_LeaderElection["kserve-leader-election-role"]
    end

    %% SA → CRB → CR bindings
    SA_KServe -->|"bound via"| CRB_KServe
    CRB_KServe -->|"grants"| CR_KServe
    SA_KServe -->|"bound via"| RB_LeaderElection
    RB_LeaderElection -->|"grants"| CR_LeaderElection

    SA_LLMISVC -->|"bound via"| CRB_LLMISVC
    CRB_LLMISVC -->|"grants"| CR_LLMISVC

    SA_LocalModel -->|"bound via"| CRB_LocalModel
    CRB_LocalModel -->|"grants"| CR_LocalModel

    SA_LocalModelNode -->|"bound via"| CRB_LocalModelNode
    CRB_LocalModelNode -->|"grants"| CR_LocalModelNode

    %% kserve-manager-role resources
    subgraph KServeResources["kserve-manager-role → API Resources"]
        KR_ISVC["serving.kserve.io<br/>InferenceService<br/>ServingRuntime<br/>ClusterServingRuntime<br/>TrainedModel<br/>InferenceGraph<br/>LocalModelCache<br/>LocalModelNamespaceCache"]
        KR_Apps["apps<br/>Deployments"]
        KR_Core["core<br/>Services, Events,<br/>ConfigMaps, Secrets,<br/>ServiceAccounts,<br/>Namespaces, Pods"]
        KR_Knative["serving.knative.dev<br/>Services"]
        KR_Istio["networking.istio.io<br/>VirtualServices"]
        KR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes"]
        KR_Autoscaling["autoscaling<br/>HorizontalPodAutoscalers"]
        KR_KEDA["keda.sh<br/>ScaledObjects"]
        KR_OTel["opentelemetry.io<br/>OpenTelemetryCollectors"]
        KR_Ingress["networking.k8s.io<br/>Ingresses"]
        KR_Admission["admissionregistration.k8s.io<br/>Mutating/ValidatingWebhook<br/>Configurations"]
        KR_Route["route.openshift.io<br/>Routes"]
    end

    CR_KServe -->|"CRUD"| KR_ISVC
    CR_KServe -->|"CRUD"| KR_Apps
    CR_KServe -->|"various"| KR_Core
    CR_KServe -->|"CRUD"| KR_Knative
    CR_KServe -->|"CRUD"| KR_Istio
    CR_KServe -->|"CRUD"| KR_Gateway
    CR_KServe -->|"CRUD"| KR_Autoscaling
    CR_KServe -->|"CRUD"| KR_KEDA
    CR_KServe -->|"CRUD"| KR_OTel
    CR_KServe -->|"CRUD"| KR_Ingress
    CR_KServe -->|"CRUD"| KR_Admission
    CR_KServe -->|"CRUD"| KR_Route

    %% llmisvc-manager-role resources
    subgraph LLMISVCResources["kserve-llmisvc-manager-role → API Resources"]
        LR_LLMISVC["serving.kserve.io<br/>LLMInferenceService<br/>LLMInferenceServiceConfig"]
        LR_Apps["apps<br/>Deployments"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
        LR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes, Gateways,<br/>GatewayClasses"]
        LR_InfPool["inference.networking.x-k8s.io<br/>InferencePools,<br/>InferenceObjectives,<br/>InferenceModels"]
        LR_WVA["llmd.ai<br/>VariantAutoscalings"]
        LR_Monitor["monitoring.coreos.com<br/>PodMonitors,<br/>ServiceMonitors"]
        LR_Istio["networking.istio.io (distro)<br/>DestinationRules"]
        LR_SCC["security.openshift.io (distro)<br/>SecurityContextConstraints<br/>(use: openshift-ai-llminferenceservice-scc)"]
    end

    CR_LLMISVC -->|"CRUD"| LR_LLMISVC
    CR_LLMISVC -->|"CRUD"| LR_Apps
    CR_LLMISVC -->|"CRUD"| LR_LWS
    CR_LLMISVC -->|"CRUD"| LR_Gateway
    CR_LLMISVC -->|"CRUD"| LR_InfPool
    CR_LLMISVC -->|"CRUD"| LR_WVA
    CR_LLMISVC -->|"CRUD"| LR_Monitor
    CR_LLMISVC -->|"CRUD"| LR_Istio
    CR_LLMISVC -->|"use"| LR_SCC

    %% localmodel-manager-role resources
    subgraph LocalModelResources["kserve-localmodel-manager-role → API Resources"]
        LMR_KServe["serving.kserve.io<br/>LocalModelCache<br/>LocalModelNamespaceCache<br/>LocalModelNodeGroup<br/>LocalModelNode"]
        LMR_Core["core<br/>PersistentVolumes<br/>PersistentVolumeClaims<br/>Nodes, ConfigMaps"]
    end

    CR_LocalModel -->|"CRUD"| LMR_KServe
    CR_LocalModel -->|"get,list,watch,<br/>create,update,patch"| LMR_Core

    %% localmodelnode-agent-role resources
    subgraph LocalModelNodeResources["kserve-localmodelnode-agent-role → API Resources"]
        LMNR_KServe["serving.kserve.io<br/>LocalModelNodeGroups<br/>ClusterStorageContainers<br/>LocalModelNodes"]
        LMNR_Batch["batch<br/>Jobs"]
        LMNR_Core["core<br/>Secrets, ServiceAccounts,<br/>Nodes, ConfigMaps<br/>(read-only)"]
    end

    CR_LocalModelNode -->|"CRUD"| LMNR_KServe
    CR_LocalModelNode -->|"CRUD"| LMNR_Batch
    CR_LocalModelNode -->|"get,list,watch"| LMNR_Core

