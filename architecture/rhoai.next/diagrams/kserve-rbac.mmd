graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager<br/>(opendatahub namespace)"]
        SA_LLMISVC["llmisvc-controller-manager<br/>(opendatahub namespace)"]
        SA_LocalModel["kserve-localmodel-controller<br/>(opendatahub namespace)"]
        SA_LocalModelNode["kserve-localmodelnode-agent<br/>(opendatahub namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LLMISVC["kserve-llmisvc-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LocalModel["kserve-localmodel-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LocalModelNode["kserve-localmodelnode-agent-rolebinding<br/>(cluster-scoped)"]
        RB_Leader["kserve-leader-election-rolebinding<br/>(namespace-scoped)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMISVC["kserve-llmisvc-manager-role"]
        CR_LocalModel["kserve-localmodel-manager-role"]
        CR_LocalModelNode["kserve-localmodelnode-agent-role"]
        CR_Leader["kserve-leader-election-role"]
    end

    %% SA to CRB
    SA_KServe -->|bound via| CRB_KServe
    SA_KServe -->|bound via| RB_Leader
    SA_LLMISVC -->|bound via| CRB_LLMISVC
    SA_LocalModel -->|bound via| CRB_LocalModel
    SA_LocalModelNode -->|bound via| CRB_LocalModelNode

    %% CRB to CR
    CRB_KServe -->|grants| CR_KServe
    CRB_LLMISVC -->|grants| CR_LLMISVC
    CRB_LocalModel -->|grants| CR_LocalModel
    CRB_LocalModelNode -->|grants| CR_LocalModelNode
    RB_Leader -->|grants| CR_Leader

    %% kserve-manager-role resources
    subgraph KServeResources["kserve-manager-role Resources"]
        KR_ISVC["serving.kserve.io<br/>InferenceService<br/>ServingRuntime<br/>ClusterServingRuntime<br/>TrainedModel<br/>InferenceGraph<br/>LocalModelCache<br/>LocalModelNamespaceCache"]
        KR_Apps["apps<br/>Deployments"]
        KR_Core["core<br/>Services, Events,<br/>ConfigMaps, Secrets,<br/>ServiceAccounts,<br/>Namespaces, Pods"]
        KR_Knative["serving.knative.dev<br/>Services"]
        KR_Istio["networking.istio.io<br/>VirtualServices"]
        KR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes"]
        KR_Autoscaling["autoscaling<br/>HorizontalPodAutoscalers"]
        KR_KEDA["keda.sh<br/>ScaledObjects"]
        KR_OTel["opentelemetry.io<br/>OpenTelemetryCollectors"]
        KR_Ingress["networking.k8s.io<br/>Ingresses"]
        KR_Admission["admissionregistration.k8s.io<br/>MutatingWebhookConfigs<br/>ValidatingWebhookConfigs"]
        KR_Routes["route.openshift.io<br/>Routes"]
    end

    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_ISVC
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Apps
    CR_KServe -->|"various"| KR_Core
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Knative
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Istio
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Gateway
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Autoscaling
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_KEDA
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_OTel
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Ingress
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Admission
    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_Routes

    %% llmisvc-manager-role resources
    subgraph LLMISVCResources["kserve-llmisvc-manager-role Resources"]
        LR_LLMISVC["serving.kserve.io<br/>LLMInferenceService<br/>LLMInferenceServiceConfig"]
        LR_Apps["apps<br/>Deployments"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
        LR_Gateway["gateway.networking.k8s.io<br/>HTTPRoutes, Gateways,<br/>GatewayClasses"]
        LR_Inference["inference.networking.x-k8s.io<br/>InferencePools,<br/>InferenceObjectives,<br/>InferenceModels"]
        LR_WVA["llmd.ai<br/>VariantAutoscalings"]
        LR_Monitoring["monitoring.coreos.com<br/>PodMonitors,<br/>ServiceMonitors"]
        LR_IstioDistro["networking.istio.io (distro)<br/>DestinationRules"]
        LR_SCCDistro["security.openshift.io (distro)<br/>SecurityContextConstraints<br/>use: openshift-ai-<br/>llminferenceservice-scc"]
    end

    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_LLMISVC
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_Apps
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_LWS
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_Gateway
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_Inference
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_WVA
    CR_LLMISVC -->|"get,list,watch<br/>create,update<br/>patch,delete"| LR_Monitoring
    CR_LLMISVC -->|"get,list,watch<br/>create,update,delete"| LR_IstioDistro
    CR_LLMISVC -->|"use"| LR_SCCDistro

    %% localmodel-manager-role resources
    subgraph LocalModelResources["kserve-localmodel-manager-role Resources"]
        LMR_CRDs["serving.kserve.io<br/>LocalModelCache<br/>LocalModelNamespaceCache<br/>LocalModelNodeGroup<br/>LocalModelNode"]
        LMR_Core["core<br/>PersistentVolumes,<br/>PersistentVolumeClaims,<br/>Nodes, ConfigMaps"]
    end

    CR_LocalModel -->|"get,list,watch<br/>create,update<br/>patch,delete"| LMR_CRDs
    CR_LocalModel -->|"get,list,watch<br/>create,update,patch"| LMR_Core

    %% localmodelnode-agent-role resources
    subgraph LocalModelNodeResources["kserve-localmodelnode-agent-role Resources"]
        LMNR_CRDs["serving.kserve.io<br/>LocalModelNodeGroup<br/>ClusterStorageContainer<br/>LocalModelNode"]
        LMNR_Batch["batch<br/>Jobs"]
        LMNR_Core["core<br/>Secrets, ServiceAccounts,<br/>Nodes, ConfigMaps<br/>(read-only)"]
    end

    CR_LocalModelNode -->|"get,list,watch<br/>create,update<br/>patch,delete"| LMNR_CRDs
    CR_LocalModelNode -->|"get,list,watch<br/>create,update<br/>patch,delete"| LMNR_Batch
    CR_LocalModelNode -->|"get,list,watch"| LMNR_Core

