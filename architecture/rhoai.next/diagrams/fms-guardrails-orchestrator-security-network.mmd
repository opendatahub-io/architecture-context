graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["AI Application Client"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE"]
        direction TB
        subgraph GuardrailsServer["Guardrails API Server"]
            APIPort["Port 8033/TCP<br/>HTTP/HTTPS<br/>TLS 1.2+ (rustls/ring)<br/>mTLS optional (WebPKI)<br/>Auth: Passthrough headers"]
        end
        subgraph HealthSvr["Health Server"]
            HealthPort["Port 8034/TCP<br/>HTTP plaintext<br/>No TLS, No Auth"]
        end
    end

    subgraph DetectorZone["DETECTOR SERVICES"]
        DetectorSvc["Detector Services<br/>(HAP, PII, etc.)<br/>Port 8080/TCP REST<br/>Health: 8081/TCP<br/>TLS (configurable)"]
    end

    subgraph ChunkerZone["CHUNKER SERVICES"]
        ChunkerSvc["Chunker Services<br/>(caikit-based)<br/>Port 8085/TCP gRPC<br/>TLS (configurable)"]
    end

    subgraph GenerationZone["GENERATION BACKENDS"]
        TGISSvc["TGIS<br/>Port 8033/TCP gRPC<br/>TLS (optional)"]
        NLPSvc["caikit-nlp<br/>Port 8085/TCP gRPC<br/>TLS (optional)"]
        OpenAISvc["OpenAI-compatible<br/>(vLLM, etc.)<br/>Port 8080/TCP REST<br/>TLS (optional)"]
    end

    subgraph ObservabilityZone["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>4318/TCP HTTP"]
    end

    %% External to Orchestrator
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ (optional)<br/>Passthrough headers<br/>X-Forwarded-Access-Token"| APIPort
    Client -.->|"HTTP 8034/TCP<br/>Plaintext<br/>No Auth"| HealthPort

    %% Orchestrator to Detectors
    APIPort -->|"HTTP/HTTPS 8080/TCP<br/>TLS (per-detector config)<br/>Bearer token (optional)<br/>x-model-name header"| DetectorSvc

    %% Orchestrator to Chunkers
    APIPort -->|"gRPC 8085/TCP<br/>TLS (per-chunker config)<br/>mm-model-id header"| ChunkerSvc

    %% Orchestrator to Generation backends
    APIPort -->|"gRPC 8033/TCP<br/>TLS (optional)<br/>No auth"| TGISSvc
    APIPort -->|"gRPC 8085/TCP<br/>TLS (optional)<br/>mm-model-id header"| NLPSvc
    APIPort -->|"HTTP/HTTPS 8080/TCP<br/>TLS (optional)<br/>Bearer token (api_token)"| OpenAISvc

    %% Orchestrator to Observability
    APIPort -.->|"OTLP 4317/4318<br/>gRPC or HTTP<br/>No encryption"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef detector fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef chunker fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef generation fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class APIPort,HealthPort orchestrator
    class DetectorSvc detector
    class ChunkerSvc chunker
    class TGISSvc,NLPSvc,OpenAISvc generation
    class OTel observability
