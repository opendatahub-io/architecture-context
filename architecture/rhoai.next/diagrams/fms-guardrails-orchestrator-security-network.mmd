graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / API Consumer"]
    end

    subgraph GuardrailsService["GUARDRAILS SERVICE (ClusterIP — Internal)"]
        direction TB
        subgraph APIServer["Guardrails Server :8033"]
            Orchestrator["fms-guardrails-orchestr8<br/>Rust (axum + tokio)<br/>TLS: Optional rustls (ring)<br/>mTLS: Optional WebPkiClientVerifier<br/>Auth: Header passthrough only"]
        end
        subgraph HealthSvr["Health Server :8034"]
            Health["Health / Readiness<br/>No TLS, No Auth<br/>Open for K8s probes"]
        end
    end

    subgraph GenerationServices["UPSTREAM GENERATION SERVICES (Internal)"]
        direction TB
        TGIS["TGIS<br/>8033/TCP gRPC<br/>Optional TLS<br/>No Auth<br/>ginepro LB"]
        CaikitNLP["Caikit NLP<br/>8085/TCP gRPC<br/>Optional TLS<br/>No Auth<br/>ginepro LB<br/>Retry: exp backoff 502-506"]
        OpenAIvLLM["OpenAI / vLLM<br/>8080/TCP HTTP(S)<br/>Optional TLS<br/>Optional Bearer (api_token)"]
    end

    subgraph ChunkerServices["UPSTREAM CHUNKER SERVICES (Internal)"]
        Chunkers["Caikit Chunkers<br/>8085/TCP gRPC<br/>Optional TLS<br/>No Auth<br/>ginepro LB<br/>Unary + Bidi streaming"]
    end

    subgraph DetectorServices["UPSTREAM DETECTOR SERVICES (Internal)"]
        Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>API: 8080/TCP HTTP(S)<br/>Health: 8081/TCP<br/>Optional TLS<br/>Optional Bearer (api_token)"]
    end

    subgraph Observability["OBSERVABILITY (Internal)"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Plaintext<br/>No Auth"]
    end

    K8sProbes["Kubernetes Probes"] -->|"GET /health, /info<br/>8034/TCP<br/>No TLS, No Auth"| Health

    %% Inbound flow
    Client -->|"HTTP(S)/8033<br/>Optional TLS 1.2+ (rustls/ring)<br/>Optional mTLS<br/>Header passthrough<br/>(X-Forwarded-Access-Token → Bearer)"| Orchestrator

    %% Outbound flows
    Orchestrator -->|"gRPC/8033<br/>Optional TLS<br/>No Auth"| TGIS
    Orchestrator -->|"gRPC/8085<br/>Optional TLS<br/>No Auth"| CaikitNLP
    Orchestrator -->|"HTTP(S)/8080<br/>Optional TLS<br/>Optional Bearer"| OpenAIvLLM
    Orchestrator -->|"gRPC/8085<br/>Optional TLS<br/>No Auth"| Chunkers
    Orchestrator -->|"HTTP(S)/8080<br/>Optional TLS<br/>Optional Bearer"| Detectors
    Orchestrator -.->|"gRPC or HTTP<br/>4317 or 4318<br/>Plaintext"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef guardrails fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef generation fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef chunker fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef detector fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef probe fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Orchestrator,Health guardrails
    class TGIS,CaikitNLP,OpenAIvLLM generation
    class Chunkers chunker
    class Detectors detector
    class OTLP observability
    class K8sProbes probe
