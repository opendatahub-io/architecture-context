graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Consumer / Client"]
    end

    subgraph OrchestratorZone["FMS GUARDRAILS ORCHESTRATOR SERVICE"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["API Server<br/>8033/TCP HTTP/HTTPS<br/>TLS optional (rustls)<br/>mTLS optional (client CA)<br/>Auth: Passthrough headers"]
            HealthServer["Health Server<br/>8034/TCP HTTP/HTTPS<br/>TLS shared with API<br/>Auth: None"]
        end
    end

    subgraph Downstream["DOWNSTREAM SERVICES (Internal Platform)"]
        direction TB

        subgraph gRPCServices["gRPC Services"]
            TGIS["TGIS Server<br/>8033/TCP gRPC<br/>mTLS optional<br/>Bearer optional<br/>fmaas.GenerationService"]
            CaikitNLP["Caikit NLP Server<br/>8085/TCP gRPC<br/>mTLS optional<br/>Bearer optional<br/>NlpService"]
            Chunker["Chunker Service(s)<br/>8085/TCP gRPC<br/>mTLS optional<br/>Bearer optional<br/>ChunkersService"]
        end

        subgraph HTTPServices["HTTP Services"]
            Detector["Detector Service(s)<br/>8080/TCP HTTP/HTTPS<br/>TLS optional<br/>Bearer optional<br/>/api/v1/text/*"]
            OpenAI["OpenAI API (vLLM)<br/>8080/TCP HTTP/HTTPS<br/>TLS optional<br/>Bearer optional<br/>/v1/chat/completions"]
        end
    end

    subgraph Telemetry["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC | 4318/TCP HTTP<br/>Encryption: None<br/>Auth: None"]
    end

    %% External flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS optional (rustls)<br/>Passthrough headers<br/>X-Forwarded-Access-Token → Bearer"| APIServer

    %% Health probes
    Client -.->|"HTTP/HTTPS 8034/TCP<br/>No auth"| HealthServer

    %% Egress to gRPC services
    APIServer -->|"gRPC 8033/TCP<br/>mTLS optional<br/>Bearer optional<br/>DNS load balancing (ginepro)"| TGIS
    APIServer -->|"gRPC 8085/TCP<br/>mTLS optional<br/>Bearer optional"| CaikitNLP
    APIServer -->|"gRPC 8085/TCP<br/>mTLS optional<br/>Bearer optional<br/>Bidi-streaming supported"| Chunker

    %% Egress to HTTP services
    APIServer -->|"HTTP/HTTPS 8080/TCP<br/>TLS optional<br/>Bearer optional<br/>Passthrough headers"| Detector
    APIServer -->|"HTTP/HTTPS 8080/TCP<br/>TLS optional<br/>Bearer optional<br/>SSE streaming"| OpenAI

    %% Telemetry
    APIServer -.->|"gRPC 4317/TCP | HTTP 4318/TCP<br/>OTLP export<br/>W3C traceparent propagation"| OTLP

    %% Health probes to downstream
    HealthServer -.->|"Health probes"| TGIS
    HealthServer -.->|"Health probes"| CaikitNLP
    HealthServer -.->|"Health probes"| Chunker
    HealthServer -.->|"Health probes<br/>GET /health 8081/TCP"| Detector
    HealthServer -.->|"Health probes<br/>GET /health"| OpenAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef grpcservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef httpservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef telemetry fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class APIServer,HealthServer orchestrator
    class TGIS,CaikitNLP,Chunker grpcservice
    class Detector,OpenAI httpservice
    class OTLP telemetry
