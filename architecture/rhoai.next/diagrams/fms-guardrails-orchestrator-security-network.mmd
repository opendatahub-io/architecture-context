graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph ServiceBoundary["GUARDRAILS ORCHESTRATOR (Service Boundary)"]
        direction TB

        subgraph APIServer["Guardrails Server"]
            GuardrailsAPI["fms-guardrails-orchestr8<br/>8033/TCP HTTP/HTTPS<br/>rustls + ring (TLS 1.2+)<br/>Optional mTLS (WebPkiClientVerifier)<br/>Header passthrough (no auth enforcement)"]
        end

        subgraph HealthSvr["Health Server"]
            HealthAPI["Health / Info<br/>8034/TCP HTTP<br/>No TLS, No Auth"]
        end
    end

    subgraph UpstreamGRPC["UPSTREAM SERVICES (gRPC)"]
        direction TB
        TGIS["TGIS Generation Server<br/>8033/TCP gRPC<br/>Optional TLS<br/>No Auth<br/>ginepro load balancing"]
        CaikitNLP["Caikit NLP Server<br/>8085/TCP gRPC<br/>Optional TLS<br/>No Auth<br/>Retry: exp backoff 502-506"]
        CaikitChunker["Caikit Chunker Server<br/>8085/TCP gRPC<br/>Optional TLS<br/>No Auth"]
    end

    subgraph UpstreamHTTP["UPSTREAM SERVICES (HTTP/REST)"]
        direction TB
        Detectors["Detector Services (HAP, PII)<br/>API: 8080/TCP HTTP/HTTPS<br/>Health: 8081/TCP<br/>Optional TLS<br/>Optional Bearer token"]
        OpenAISvc["OpenAI / vLLM Server<br/>8080/TCP HTTP/HTTPS<br/>Optional TLS<br/>Optional Bearer token"]
    end

    subgraph Telemetry["TELEMETRY"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Plaintext<br/>No Auth"]
    end

    subgraph K8s["KUBERNETES"]
        Probes["Kubernetes Probes"]
    end

    %% External flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>Optional TLS 1.2+ (rustls/ring)<br/>Optional mTLS<br/>Header passthrough"| GuardrailsAPI

    %% Health flows
    Probes -->|"HTTP 8034/TCP<br/>No TLS, No Auth"| HealthAPI

    %% gRPC egress
    GuardrailsAPI -->|"gRPC 8033/TCP<br/>Optional TLS<br/>No Auth"| TGIS
    GuardrailsAPI -->|"gRPC 8085/TCP<br/>Optional TLS<br/>No Auth"| CaikitNLP
    GuardrailsAPI -->|"gRPC 8085/TCP<br/>Optional TLS<br/>No Auth"| CaikitChunker

    %% HTTP egress
    GuardrailsAPI -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Optional Bearer"| Detectors
    GuardrailsAPI -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Optional Bearer"| OpenAISvc

    %% Telemetry
    GuardrailsAPI -.->|"gRPC/HTTP 4317-4318/TCP<br/>Plaintext"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef boundary fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    classDef grpc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef http fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef telemetry fill:#e8e8e8,stroke:#999,stroke-width:1px
    classDef k8s fill:#f9f9f9,stroke:#999,stroke-width:1px

    class Client external
    class GuardrailsAPI,HealthAPI boundary
    class TGIS,CaikitNLP,CaikitChunker grpc
    class Detectors,OpenAISvc http
    class OTLP telemetry
    class Probes k8s
