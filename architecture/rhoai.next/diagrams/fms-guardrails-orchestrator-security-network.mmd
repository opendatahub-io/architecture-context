graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Auth Proxy"]
    end

    subgraph GuardrailsService["GUARDRAILS ORCHESTRATOR SERVICE"]
        direction TB

        subgraph APIServer["Guardrails Server"]
            API["fms-guardrails-orchestr8<br/>Port: 8033/TCP<br/>HTTP or HTTPS<br/>TLS: rustls + ring (TLS 1.2+)<br/>mTLS: Optional (WebPkiClientVerifier)"]
        end

        subgraph HealthSrv["Health Server"]
            Health["Health Endpoint<br/>Port: 8034/TCP<br/>HTTP (No TLS)<br/>Auth: None"]
        end
    end

    subgraph gRPCUpstreams["gRPC UPSTREAMS (Optional TLS)"]
        direction TB
        TGIS["TGIS<br/>Port: 8033/TCP<br/>gRPC<br/>Optional TLS<br/>Auth: None"]
        CaikitNLP["Caikit NLP<br/>Port: 8085/TCP<br/>gRPC<br/>Optional TLS<br/>Auth: None"]
        Chunkers["Caikit Chunkers<br/>Port: 8085/TCP<br/>gRPC<br/>Optional TLS<br/>Auth: None"]
    end

    subgraph HTTPUpstreams["HTTP UPSTREAMS (Optional TLS)"]
        direction TB
        Detectors["Detector Services<br/>HAP, PII, etc.<br/>Port: 8080/TCP API, 8081/TCP Health<br/>HTTP/HTTPS<br/>Auth: Optional Bearer"]
        OpenAIBackend["OpenAI / vLLM<br/>Port: 8080/TCP<br/>HTTP/HTTPS<br/>Auth: Optional Bearer"]
    end

    subgraph Telemetry["TELEMETRY"]
        OTLP["OTLP Collector<br/>Port: 4317/TCP gRPC<br/>Port: 4318/TCP HTTP<br/>Plaintext<br/>Auth: None"]
    end

    K8sProbe["Kubernetes<br/>Liveness/Readiness<br/>Probes"]

    %% External to Orchestrator
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ (rustls/ring)<br/>Optional mTLS<br/>Header passthrough<br/>(X-Forwarded-Access-Token → Bearer)"| API

    %% Health probes
    K8sProbe -->|"HTTP 8034/TCP<br/>No encryption<br/>No auth"| Health

    %% gRPC connections (ginepro LB)
    API -->|"gRPC 8033/TCP<br/>Optional TLS<br/>ginepro DNS LB"| TGIS
    API -->|"gRPC 8085/TCP<br/>Optional TLS<br/>ginepro DNS LB<br/>Retry: exp backoff 502-506"| CaikitNLP
    API -->|"gRPC 8085/TCP<br/>Optional TLS<br/>ginepro DNS LB"| Chunkers

    %% HTTP connections (reqwest)
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Optional Bearer (api_token)"| Detectors
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Optional Bearer (api_token)"| OpenAIBackend

    %% Telemetry
    API -.->|"gRPC/HTTP 4317|4318/TCP<br/>Plaintext<br/>Traces + Metrics"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef health fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef grpc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef http fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef telemetry fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef probe fill:#f5f5f5,stroke:#666,stroke-width:1px

    class Client external
    class API service
    class Health health
    class TGIS,CaikitNLP,Chunkers grpc
    class Detectors,OpenAIBackend http
    class OTLP telemetry
    class K8sProbe probe
