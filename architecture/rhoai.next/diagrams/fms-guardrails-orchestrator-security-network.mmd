graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / API Consumer"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE"]
        direction TB

        subgraph MainServer["Guardrails API Server"]
            API["axum Router<br/>Port: 8033/TCP<br/>HTTP/HTTPS<br/>TLS 1.2+ / mTLS (rustls + ring)<br/>Auth: Header passthrough"]
        end

        subgraph HealthSrv["Health Server"]
            HealthAPI["Health Endpoints<br/>Port: 8034/TCP<br/>HTTP (plaintext, NO TLS)<br/>Auth: None<br/>/health, /info"]
        end
    end

    subgraph Downstream["DOWNSTREAM SERVICES (Internal)"]
        direction TB

        subgraph GenServers["Generation Backends"]
            TGIS["TGIS<br/>8033/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>Generate, GenerateStream,<br/>Tokenize, ModelInfo"]
            CaikitNLP["caikit-nlp<br/>8085/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>TextGenerationTask,<br/>TokenizationTask"]
        end

        subgraph DetectorSvcs["Safety Services"]
            Detectors["Detector Services<br/>8080/TCP HTTP/HTTPS<br/>Optional TLS/mTLS (hyper-rustls)<br/>/api/v1/text/contents,<br/>/chat, /context/doc, /generation"]
            Chunkers["caikit Chunkers<br/>8085/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>ChunkerTokenizationTask"]
        end

        OpenAISrv["OpenAI-compatible Server (vLLM)<br/>8080/TCP HTTP/HTTPS<br/>Optional TLS (rustls)<br/>Bearer token (api_token)<br/>/v1/chat/completions,<br/>/v1/completions, /tokenize"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>4317/TCP (gRPC) or 4318/TCP (HTTP)<br/>No encryption<br/>No auth"]
    end

    subgraph K8s["KUBERNETES PLATFORM"]
        Probes["Kubernetes Probes<br/>(liveness/readiness)"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ / mTLS (rustls+ring)<br/>Header passthrough<br/>X-Forwarded-Access-Token rewrite"| API
    Probes -->|"HTTP 8034/TCP<br/>Plaintext (no TLS)<br/>No auth"| HealthAPI

    API -->|"gRPC/HTTP2 8033/TCP<br/>Optional TLS/mTLS<br/>Header passthrough"| TGIS
    API -->|"gRPC/HTTP2 8085/TCP<br/>Optional TLS/mTLS<br/>Header passthrough"| CaikitNLP
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS/mTLS<br/>detector-id header"| Detectors
    API -->|"gRPC/HTTP2 8085/TCP<br/>Optional TLS/mTLS"| Chunkers
    API -->|"HTTP/HTTPS 8080/TCP<br/>Optional TLS<br/>Bearer token"| OpenAISrv
    API -->|"gRPC 4317 or HTTP 4318<br/>No encryption"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#4a90e2,stroke:#2c6fbb,stroke-width:2px,color:#fff
    classDef health fill:#7ed321,stroke:#5ca118,stroke-width:2px,color:#fff
    classDef downstream fill:#f5a623,stroke:#d4891a,stroke-width:2px,color:#fff
    classDef observability fill:#bd10e0,stroke:#9a0db8,stroke-width:2px,color:#fff
    classDef k8s fill:#50e3c2,stroke:#3bc4a5,stroke-width:2px

    class Client external
    class API orchestrator
    class HealthAPI health
    class TGIS,CaikitNLP,Detectors,Chunkers,OpenAISrv downstream
    class OTLP observability
    class Probes k8s
