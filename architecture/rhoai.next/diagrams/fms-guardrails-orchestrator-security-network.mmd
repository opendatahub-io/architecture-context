graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / API Consumer"]
    end

    subgraph Orchestrator["ORCHESTRATOR SERVICE"]
        direction TB
        subgraph APIServer["API Server"]
            API["fms-guardrails-orchestr8<br/>Port: 8033/TCP<br/>Protocol: HTTP<br/>TLS: rustls (optional)<br/>Auth: Passthrough headers"]
        end

        subgraph HealthServer["Health Server (Isolated)"]
            HealthSrv["Health/Readiness<br/>Port: 8034/TCP<br/>Protocol: HTTP<br/>TLS: optional (shared config)<br/>Auth: None"]
        end
    end

    subgraph DownstreamGRPC["DOWNSTREAM gRPC SERVICES (Internal)"]
        direction TB
        TGIS["TGIS Server<br/>Port: 8033/TCP<br/>Protocol: gRPC<br/>Encryption: mTLS optional<br/>Auth: Bearer optional"]
        CaikitNLP["Caikit NLP Server<br/>Port: 8085/TCP<br/>Protocol: gRPC<br/>Encryption: mTLS optional<br/>Auth: Bearer optional"]
        Chunker["Chunker Service(s)<br/>Port: 8085/TCP<br/>Protocol: gRPC (bidi-stream)<br/>Encryption: mTLS optional<br/>Auth: Bearer optional"]
    end

    subgraph DownstreamHTTP["DOWNSTREAM HTTP SERVICES (Internal)"]
        direction TB
        Detectors["Detector Service(s)<br/>Port: 8080/TCP (API), 8081/TCP (health)<br/>Protocol: HTTP/HTTPS<br/>Encryption: TLS optional<br/>Auth: Bearer + passthrough headers"]
        OpenAI["OpenAI-compatible API (vLLM)<br/>Port: 8080/TCP<br/>Protocol: HTTP/HTTPS (SSE)<br/>Encryption: TLS optional<br/>Auth: Bearer optional"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTEL["OpenTelemetry Collector<br/>Port: 4317/TCP (gRPC) or 4318/TCP (HTTP)<br/>Encryption: None (configurable)<br/>Auth: None"]
    end

    %% Client to Orchestrator
    Client -->|"HTTP/8033<br/>TLS optional (rustls)<br/>Passthrough headers<br/>X-Forwarded-Access-Token rewrite"| API

    %% Health checks
    Client -.->|"HTTP/8034<br/>TLS optional<br/>No auth"| HealthSrv

    %% Orchestrator to gRPC downstream
    API -->|"gRPC/8033<br/>mTLS optional<br/>Bearer optional<br/>Named TLS profile"| TGIS
    API -->|"gRPC/8085<br/>mTLS optional<br/>Bearer optional<br/>Named TLS profile"| CaikitNLP
    API -->|"gRPC/8085 (bidi-stream)<br/>mTLS optional<br/>Bearer optional<br/>Named TLS profile"| Chunker

    %% Orchestrator to HTTP downstream
    API -->|"HTTP/8080<br/>TLS optional<br/>Bearer + passthrough headers<br/>Named TLS profile"| Detectors
    API -->|"HTTP/8080 (SSE streaming)<br/>TLS optional<br/>Bearer optional<br/>Named TLS profile"| OpenAI

    %% Health probes from readiness
    HealthSrv -.->|"Health probes"| TGIS
    HealthSrv -.->|"Health probes"| CaikitNLP
    HealthSrv -.->|"Health probes"| Chunker
    HealthSrv -.->|"Health probes<br/>GET /health :8081"| Detectors
    HealthSrv -.->|"Health probes<br/>GET /health"| OpenAI

    %% Observability
    API -->|"OTLP gRPC/4317 or HTTP/4318<br/>No encryption<br/>W3C traceparent propagated"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef grpcservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef httpservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class API,HealthSrv orchestrator
    class TGIS,CaikitNLP,Chunker grpcservice
    class Detectors,OpenAI httpservice
    class OTEL observability
