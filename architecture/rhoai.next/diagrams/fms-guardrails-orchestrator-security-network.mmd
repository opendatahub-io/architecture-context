graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE (Dual-Server)"]
        direction TB
        subgraph MainAPI["Guardrails API Server"]
            API["Port: 8033/TCP<br/>HTTP/HTTPS<br/>TLS 1.2+ (optional, rustls+ring)<br/>mTLS (optional, WebPkiClientVerifier)<br/>Auth: Header passthrough"]
        end
        subgraph HealthAPI["Health Server"]
            Health["Port: 8034/TCP<br/>HTTP (plaintext)<br/>No auth"]
        end
    end

    subgraph gRPCBackends["BACKEND SERVICES - gRPC"]
        direction TB
        TGIS["TGIS Generation Server<br/>8033/TCP gRPC/HTTP2<br/>TLS (optional)<br/>No auth<br/>Retry: exp backoff 502/503/504"]
        CaikitNLP["Caikit NLP Service<br/>8085/TCP gRPC/HTTP2<br/>TLS (optional)<br/>No auth"]
        CaikitChunker["Caikit Chunkers Service<br/>8085/TCP gRPC/HTTP2<br/>TLS (optional)<br/>No auth"]
    end

    subgraph HTTPBackends["BACKEND SERVICES - HTTP"]
        direction TB
        Detectors["Detector Services<br/>8080/TCP (API) + 8081/TCP (health)<br/>HTTP/HTTPS<br/>TLS (optional)<br/>Bearer token (optional, env var)"]
        OpenAISvr["OpenAI-compatible Server<br/>(e.g., vLLM)<br/>8080/TCP HTTP/HTTPS<br/>TLS (optional)<br/>Bearer token (optional, env var)"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>4317/TCP (gRPC) or 4318/TCP (HTTP)<br/>No encryption<br/>No auth"]
    end

    %% Inbound flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>TLS 1.2+ (optional)<br/>Header passthrough<br/>(X-Forwarded-Access-Token)"| API
    Client -->|"HTTP 8034/TCP<br/>Plaintext<br/>No auth"| Health

    %% Outbound gRPC flows
    API -->|"gRPC/HTTP2 8033/TCP<br/>TLS (optional)<br/>No auth"| TGIS
    API -->|"gRPC/HTTP2 8085/TCP<br/>TLS (optional)<br/>No auth"| CaikitNLP
    API -->|"gRPC/HTTP2 8085/TCP<br/>TLS (optional)<br/>No auth"| CaikitChunker

    %% Outbound HTTP flows
    API -->|"HTTP/HTTPS 8080/TCP<br/>TLS (optional)<br/>Bearer (optional)"| Detectors
    API -->|"HTTP/HTTPS 8080/TCP<br/>TLS (optional)<br/>Bearer (optional)"| OpenAISvr

    %% Health check flows
    Health -.->|"gRPC health check"| TGIS
    Health -.->|"gRPC health check"| CaikitNLP
    Health -.->|"gRPC health check"| CaikitChunker
    Health -.->|"HTTP /health 8081/TCP"| Detectors

    %% Telemetry flows
    API -.->|"OTLP 4317 or 4318/TCP<br/>Traces + Metrics"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#4a90e2,stroke:#2c5aa0,stroke-width:2px,color:#fff
    classDef healthzone fill:#7ed321,stroke:#5a9e18,stroke-width:2px,color:#fff
    classDef grpcbackend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef httpbackend fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e8e8e8,stroke:#999,stroke-width:1px

    class Client external
    class API orchestrator
    class Health healthzone
    class TGIS,CaikitNLP,CaikitChunker grpcbackend
    class Detectors,OpenAISvr httpbackend
    class OTLP observability
