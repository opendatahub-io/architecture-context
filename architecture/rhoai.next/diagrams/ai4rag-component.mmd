graph TB
    subgraph "ai4rag Library"
        direction TB

        subgraph "Orchestration"
            Experiment["AI4RAGExperiment<br/><i>Top-level orchestrator</i>"]
            MPS["ModelsPreSelector<br/><i>Model pair evaluation</i>"]
            SearchSpace["AI4RAGSearchSpace<br/><i>Constrained parameter space</i>"]
        end

        subgraph "Optimizers"
            GAM["GAMOptimizer<br/><i>GAM-based guided search</i>"]
            Random["RandomOptimizer<br/><i>Random baseline search</i>"]
        end

        subgraph "RAG Pipeline"
            SimpleRAG["SimpleRAG<br/><i>RAG template</i>"]
            Chunker["LangChainChunker<br/><i>RecursiveCharacterTextSplitter</i>"]
            Retriever["Retriever<br/><i>Vector similarity search</i>"]
        end

        subgraph "Provider Adapters"
            OGXFoundation["OGXFoundationModel<br/><i>LLM chat completions</i>"]
            OGXEmbedding["OGXEmbeddingModel<br/><i>Text embeddings</i>"]
            OGXVector["OGXVectorStore<br/><i>Vector store CRUD</i>"]
            ChromaVector["ChromaVectorStore<br/><i>In-memory (local/MPS)</i>"]
        end

        subgraph "Evaluation"
            UnitxtEval["UnitxtEvaluator<br/><i>Faithfulness, correctness metrics</i>"]
        end

        subgraph "Event Handlers"
            LocalHandler["LocalEventHandler<br/><i>JSON file output</i>"]
            KFPHandler["KFPEventHandler<br/><i>Kubeflow Pipelines callback</i>"]
        end
    end

    %% Orchestration flows
    User["User / KFP Component"] -->|"search()"| Experiment
    Experiment -->|"pre-select models"| MPS
    Experiment -->|"build search space"| SearchSpace
    Experiment -->|"optimize"| GAM
    Experiment -->|"optimize (alt)"| Random

    %% Optimizer to evaluation
    GAM -->|"run_single_evaluation()"| SimpleRAG
    Random -->|"run_single_evaluation()"| SimpleRAG

    %% RAG pipeline internals
    SimpleRAG -->|"chunk documents"| Chunker
    SimpleRAG -->|"retrieve context"| Retriever
    SimpleRAG -->|"generate answers"| OGXFoundation
    SimpleRAG -->|"embed queries"| OGXEmbedding
    Retriever -->|"similarity search"| OGXVector
    SimpleRAG -->|"evaluate"| UnitxtEval

    %% MPS uses Chroma
    MPS -->|"in-memory store"| ChromaVector
    MPS -->|"embed"| OGXEmbedding
    MPS -->|"generate"| OGXFoundation

    %% Event handler outputs
    Experiment -->|"report results"| LocalHandler
    Experiment -->|"report results"| KFPHandler

    %% External dependency
    OGXFoundation -->|"HTTPS/TLS 1.2+"| OGXServer["OGX Server<br/><i>External</i>"]
    OGXEmbedding -->|"HTTPS/TLS 1.2+"| OGXServer
    OGXVector -->|"HTTPS/TLS 1.2+"| OGXServer

    %% Styling
    style Experiment fill:#4a90e2,stroke:#333,color:#fff
    style MPS fill:#4a90e2,stroke:#333,color:#fff
    style SearchSpace fill:#4a90e2,stroke:#333,color:#fff
    style GAM fill:#9b59b6,stroke:#333,color:#fff
    style Random fill:#9b59b6,stroke:#333,color:#fff
    style SimpleRAG fill:#27ae60,stroke:#333,color:#fff
    style Chunker fill:#27ae60,stroke:#333,color:#fff
    style Retriever fill:#27ae60,stroke:#333,color:#fff
    style UnitxtEval fill:#e67e22,stroke:#333,color:#fff
    style OGXFoundation fill:#3498db,stroke:#333,color:#fff
    style OGXEmbedding fill:#3498db,stroke:#333,color:#fff
    style OGXVector fill:#3498db,stroke:#333,color:#fff
    style ChromaVector fill:#1abc9c,stroke:#333,color:#fff
    style LocalHandler fill:#95a5a6,stroke:#333,color:#fff
    style KFPHandler fill:#95a5a6,stroke:#333,color:#fff
    style OGXServer fill:#e74c3c,stroke:#333,color:#fff
    style User fill:#f5a623,stroke:#333,color:#fff
