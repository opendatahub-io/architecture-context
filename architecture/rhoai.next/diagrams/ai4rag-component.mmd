graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Core["Core Layer"]
            Experiment["AI4RAGExperiment<br/><i>Orchestrates optimization loop</i>"]
            MPS["ModelsPreSelector<br/><i>Pre-selects top-N models</i>"]
            Results["ExperimentResults<br/><i>Aggregates pattern results</i>"]
        end

        subgraph HPO["Hyperparameter Optimization"]
            GAMOpt["GAMOptimizer<br/><i>Bayesian-style GAM optimization</i>"]
            RandomOpt["RandomOptimizer<br/><i>Random baseline fallback</i>"]
            BaseOpt["BaseOptimizer<br/><i>Abstract optimizer interface</i>"]
            GAMOpt -.->|extends| BaseOpt
            RandomOpt -.->|extends| BaseOpt
        end

        subgraph RAG["RAG Pipeline"]
            Template["SimpleRAGTemplate<br/><i>End-to-end RAG pattern</i>"]
            Chunker["LangChainChunker<br/><i>Recursive text splitting</i>"]
            Retriever["Retriever<br/><i>Similarity search</i>"]
            EmbModel["EmbeddingModel<br/><i>Text embeddings (OGX)</i>"]
            FMModel["FoundationModel<br/><i>Text generation (OGX)</i>"]
            VectorStore["VectorStore<br/><i>OGX / ChromaDB</i>"]
        end

        subgraph Evaluation["Evaluation"]
            Evaluator["UnitxtEvaluator<br/><i>Answer correctness, faithfulness</i>"]
        end

        subgraph SearchSpace["Search Space"]
            SS["AI4RAGSearchSpace<br/><i>Constraint-based param pruning</i>"]
            Params["Parameters<br/><i>Categorical + numeric ranges</i>"]
            SS --> Params
        end

        subgraph EventHandlers["Event Handlers"]
            KFPHandler["KFPEventHandler<br/><i>Kubeflow Pipelines integration</i>"]
            LocalHandler["LocalEventHandler<br/><i>Local JSON output</i>"]
        end
    end

    %% Internal flows
    Experiment -->|uses| GAMOpt
    Experiment -->|uses| SS
    Experiment -->|instantiates| Template
    Experiment -->|calls| Evaluator
    Experiment -->|emits events| KFPHandler
    Experiment -->|emits events| LocalHandler
    MPS -->|pre-filters models| Experiment
    Template -->|uses| Chunker
    Template -->|uses| Retriever
    Template -->|uses| EmbModel
    Template -->|uses| FMModel
    Retriever -->|queries| VectorStore

    %% External dependencies
    OGX["OGX Server<br/><i>Embeddings, Vector Stores,<br/>Chat Completions</i>"]
    ChromaDB["ChromaDB<br/><i>In-memory vector store</i>"]
    KFP["Kubeflow Pipelines<br/><i>Pipeline orchestration</i>"]

    EmbModel -->|HTTPS / API Key| OGX
    FMModel -->|HTTPS / API Key| OGX
    VectorStore -->|HTTPS / API Key| OGX
    VectorStore -->|In-process| ChromaDB
    KFPHandler -->|Python API| KFP

    %% Styling
    style ai4rag fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#d5e8d4,stroke:#82b366
    style HPO fill:#fff2cc,stroke:#d6b656
    style RAG fill:#dae8fc,stroke:#6c8ebf
    style Evaluation fill:#f8cecc,stroke:#b85450
    style SearchSpace fill:#e1d5e7,stroke:#9673a6
    style EventHandlers fill:#ffe6cc,stroke:#d79b00

    style OGX fill:#999,stroke:#333,stroke-width:2px
    style ChromaDB fill:#999,stroke:#333
    style KFP fill:#7ed321,stroke:#333
