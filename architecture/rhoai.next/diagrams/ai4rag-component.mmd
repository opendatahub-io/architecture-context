graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Orchestration["Experiment Orchestration Layer"]
            Experiment["AI4RAGExperiment<br/>Orchestrates full optimization"]
            MPS["ModelsPreSelector<br/>Pre-selects top models"]
            Results["ExperimentResults<br/>Stores & ranks results"]
            BenchmarkData["BenchmarkData<br/>Manages Q&A pairs"]
        end

        subgraph HPO["Hyperparameter Optimization Layer"]
            GAM["GAMOptimizer<br/>GAM-based search"]
            RandomOpt["RandomOptimizer<br/>Random search baseline"]
        end

        subgraph RAGPipeline["RAG Pipeline Layer"]
            SimpleRAG["SimpleRAGTemplate<br/>Prompt + retrieve + generate"]
            Retriever["Retriever<br/>Similarity/hybrid search"]
            Chunker["LangChainChunker<br/>RecursiveCharacterTextSplitter"]
        end

        subgraph Providers["Provider Abstraction Layer"]
            OGXFoundation["OGXFoundationModel<br/>Chat completions"]
            OGXEmbedding["OGXEmbeddingModel<br/>Text embeddings"]
            OGXVectorStore["OGXVectorStore<br/>Remote vector CRUD"]
            ChromaVS["ChromaVectorStore<br/>In-memory local"]
        end

        subgraph Evaluation["Evaluation Layer"]
            UnitxtEval["UnitxtEvaluator<br/>Faithfulness, correctness"]
        end

        subgraph SearchSpace["Search Space"]
            SSConfig["AI4RAGSearchSpace<br/>Parameters + constraints"]
            SSPrepare["prepare_search_space_with_ogx<br/>Auto-discover models"]
        end
    end

    %% Internal flows
    Experiment -->|runs| MPS
    Experiment -->|uses| GAM
    Experiment -->|uses| RandomOpt
    GAM -->|calls| Experiment
    MPS -->|evaluates with| UnitxtEval
    MPS -->|uses| ChromaVS
    Experiment -->|configures| SimpleRAG
    SimpleRAG -->|uses| Retriever
    SimpleRAG -->|uses| Chunker
    Retriever -->|queries| OGXVectorStore
    SimpleRAG -->|generates via| OGXFoundation
    Experiment -->|evaluates with| UnitxtEval
    Experiment -->|stores in| Results
    SSPrepare -->|builds| SSConfig
    Experiment -->|iterates over| SSConfig

    %% External interactions
    OGXFoundation -->|REST API| OGXServer["OGX Server<br/>HTTPS + API Key"]
    OGXEmbedding -->|REST API| OGXServer
    OGXVectorStore -->|REST API| OGXServer
    SSPrepare -->|models.list| OGXServer

    %% Event handling
    Experiment -->|emits events| EventHandler["EventHandler<br/>Local / KFP"]
    EventHandler -.->|streams to| KFP["Kubeflow Pipelines"]

    %% Styling
    style ai4rag fill:#f0f4ff,stroke:#4a90e2,stroke-width:2px
    style Orchestration fill:#e8f0fe,stroke:#4a90e2
    style HPO fill:#e8f0fe,stroke:#4a90e2
    style RAGPipeline fill:#e8f0fe,stroke:#4a90e2
    style Providers fill:#e8f0fe,stroke:#4a90e2
    style Evaluation fill:#e8f0fe,stroke:#4a90e2
    style SearchSpace fill:#e8f0fe,stroke:#4a90e2
    style OGXServer fill:#f5a623,stroke:#333,stroke-width:2px
    style KFP fill:#7ed321,stroke:#333
    style Experiment fill:#4a90e2,color:#fff
    style GAM fill:#4a90e2,color:#fff
    style MPS fill:#4a90e2,color:#fff
    style SimpleRAG fill:#4a90e2,color:#fff
