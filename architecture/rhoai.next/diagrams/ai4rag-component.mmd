graph TB
    subgraph UserCode["User Code (Notebook / Pipeline)"]
        User[Data Scientist / ML Engineer]
    end

    subgraph AI4RAG["ai4rag Library"]
        direction TB

        subgraph Experiment["ai4rag.core.experiment"]
            ExpOrch[AI4RAGExperiment<br/>Experiment Orchestration]
            MPS[ModelsPreSelector<br/>Models Pre-Selection]
            BenchData[BenchmarkData<br/>Dataset Management]
            Results[Results Manager]
        end

        subgraph HPO["ai4rag.core.hpo"]
            GAMOpt[GAMOptimizer<br/>Surrogate-based HPO]
            RandomOpt[RandomOptimizer<br/>Random Search Baseline]
        end

        subgraph RAG["ai4rag.rag"]
            direction TB

            subgraph Templates["Templates"]
                SimpleRAG[SimpleRAG<br/>index-retrieve-generate]
            end

            subgraph Chunking["Chunking"]
                LCChunker[LangChainChunker<br/>Recursive/Character/Token]
            end

            subgraph Embedding["Embedding Models"]
                LSEmbed[LSEmbeddingModel<br/>Llama Stack]
                OAIEmbed[OpenAIEmbeddingModel<br/>OpenAI-compatible]
            end

            subgraph FoundationModels["Foundation Models"]
                LSFM[LSFoundationModel<br/>Llama Stack]
                OAIFM[OpenAIFoundationModel<br/>OpenAI-compatible]
            end

            subgraph VectorStores["Vector Stores"]
                ChromaVS[ChromaVectorStore<br/>In-memory]
                LSVS[LSVectorStore<br/>Llama Stack]
            end

            Retriever[Retriever<br/>Vector / Hybrid Search]
        end

        subgraph SearchSpace["ai4rag.search_space"]
            Params[Parameter Definitions<br/>Boolean/Integer/Real/Categorical]
            Constraints[Constraint Rules<br/>Search Space Pruning]
            LSDiscovery[Llama Stack Auto-Discovery<br/>Models & Vector Stores]
        end

        subgraph Evaluator["ai4rag.evaluator"]
            UnitxtEval[UnitxtEvaluator<br/>Answer Correctness, Faithfulness,<br/>Context Correctness]
        end

        subgraph EventHandlers["ai4rag.utils.event_handler"]
            LocalEH[LocalEventHandler<br/>JSON to Filesystem]
            KFPEH[KFPEventHandler<br/>Pipeline Metadata]
        end
    end

    %% User interactions
    User -->|"import & configure"| ExpOrch
    User -->|"define search space"| Params

    %% Experiment orchestration flows
    ExpOrch -->|"optional pre-selection"| MPS
    ExpOrch -->|"request next params"| GAMOpt
    ExpOrch -->|"alternative optimizer"| RandomOpt
    ExpOrch -->|"execute pipeline"| SimpleRAG
    ExpOrch -->|"evaluate results"| UnitxtEval
    ExpOrch -->|"emit events"| LocalEH
    ExpOrch -->|"emit events"| KFPEH
    ExpOrch -->|"manage datasets"| BenchData
    ExpOrch -->|"collect results"| Results

    %% RAG pipeline flows
    SimpleRAG -->|"chunk documents"| LCChunker
    SimpleRAG -->|"embed text"| LSEmbed
    SimpleRAG -->|"embed text"| OAIEmbed
    SimpleRAG -->|"store vectors"| ChromaVS
    SimpleRAG -->|"store vectors"| LSVS
    SimpleRAG -->|"query similar"| Retriever
    SimpleRAG -->|"generate answer"| LSFM
    SimpleRAG -->|"generate answer"| OAIFM

    %% Search space
    ExpOrch -->|"apply constraints"| Constraints
    MPS -->|"discover models"| LSDiscovery

    %% Styling
    style ExpOrch fill:#4a90e2,color:#fff
    style MPS fill:#4a90e2,color:#fff
    style GAMOpt fill:#9b59b6,color:#fff
    style RandomOpt fill:#9b59b6,color:#fff
    style SimpleRAG fill:#2ecc71,color:#fff
    style UnitxtEval fill:#e67e22,color:#fff
    style LocalEH fill:#95a5a6,color:#fff
    style KFPEH fill:#95a5a6,color:#fff
    style User fill:#34495e,color:#fff
    style LSEmbed fill:#3498db,color:#fff
    style OAIEmbed fill:#3498db,color:#fff
    style LSFM fill:#3498db,color:#fff
    style OAIFM fill:#3498db,color:#fff
    style ChromaVS fill:#1abc9c,color:#fff
    style LSVS fill:#1abc9c,color:#fff
    style Retriever fill:#1abc9c,color:#fff
    style LCChunker fill:#2ecc71,color:#fff
    style Params fill:#f39c12,color:#fff
    style Constraints fill:#f39c12,color:#fff
    style LSDiscovery fill:#f39c12,color:#fff
