graph TB
    subgraph "ai4rag Library"
        subgraph "Core"
            Experiment["ai4rag.core.experiment<br/>Experiment Orchestration"]
            HPO["ai4rag.core.hpo<br/>HPO Algorithms"]
            GAM["GAM Optimizer<br/>(surrogate model)"]
            Random["Random Search<br/>(baseline)"]
            MPS["Models Pre-Selection<br/>(MPS Phase)"]
            HPO --> GAM
            HPO --> Random
            Experiment --> HPO
            Experiment --> MPS
        end

        subgraph "RAG Pipeline"
            Template["RAG Template<br/>(Template Method)"]
            Chunker["LangChain Chunker<br/>(recursive/char/token)"]
            EmbeddingModel["Embedding Model<br/>(LS / OpenAI)"]
            Retriever["Retriever<br/>(vector/hybrid search)"]
            VectorStore["Vector Store<br/>(LS / Chroma)"]
            FoundationModel["Foundation Model<br/>(LS / OpenAI)"]
            Template --> Chunker
            Template --> EmbeddingModel
            Template --> Retriever
            Template --> VectorStore
            Template --> FoundationModel
        end

        subgraph "Evaluation"
            Evaluator["Unitxt Evaluator<br/>(correctness, faithfulness,<br/>context metrics)"]
        end

        subgraph "Search Space"
            SearchSpace["Search Space Manager<br/>(Parameter definitions,<br/>Constraint rules)"]
            LSDiscovery["Llama Stack<br/>Auto-Discovery"]
            SearchSpace --> LSDiscovery
        end

        subgraph "Utilities"
            EventHandler["Event Handlers<br/>(Local / KFP)"]
            Validators["Validators<br/>(descriptor-based)"]
        end

        Experiment --> Template
        Experiment --> Evaluator
        Experiment --> SearchSpace
        Experiment --> EventHandler
    end

    User["Data Scientist / ML Engineer"] -->|"imports & calls<br/>experiment.search()"| Experiment

    %% External connections
    LSDiscovery -->|"models.list()"| LlamaStack["Llama Stack Server"]
    EmbeddingModel -->|"embeddings API"| LlamaStack
    VectorStore -->|"vector_io API"| LlamaStack
    FoundationModel -->|"chat completions"| LlamaStack
    EmbeddingModel -->|"embeddings API"| OpenAI["OpenAI-compatible API"]
    FoundationModel -->|"chat completions"| OpenAI
    VectorStore -->|"in-process"| ChromaDB["ChromaDB<br/>(in-memory)"]
    EventHandler -->|"pipeline metadata"| KFP["Kubeflow Pipelines"]

