graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Core["core"]
            Experiment["ai4rag.core.experiment<br/>Experiment Orchestration"]
            MPS["Models Pre-Selection<br/>(MPS)"]
            BenchmarkData["BenchmarkData<br/>Dataset Management"]
            Results["Results<br/>Aggregation"]
        end

        subgraph HPO["core.hpo"]
            GAMOpt["GAM Optimizer<br/>(Surrogate Model)"]
            RandomOpt["Random Search<br/>(Baseline)"]
            BaseOpt["BaseOptimizer<br/>(ABC)"]
            GAMOpt -.->|extends| BaseOpt
            RandomOpt -.->|extends| BaseOpt
        end

        subgraph RAG["rag"]
            direction TB
            subgraph Templates["Templates"]
                BaseTemplate["BaseRAGTemplate<br/>(ABC)"]
                SimpleRAG["SimpleRAG<br/>(index → retrieve → generate)"]
                SimpleRAG -.->|extends| BaseTemplate
            end

            subgraph Chunking["Chunking"]
                LCChunker["LangChainChunker<br/>(recursive, character, token)"]
            end

            subgraph Embedding["Embedding"]
                LSEmbed["LlamaStack<br/>EmbeddingModel"]
                OAIEmbed["OpenAI<br/>EmbeddingModel"]
            end

            subgraph VectorStore["Vector Stores"]
                ChromaVS["ChromaDB<br/>(in-memory)"]
                LSVS["LlamaStack<br/>VectorStore"]
            end

            subgraph Foundation["Foundation Models"]
                LSModel["LlamaStack<br/>FoundationModel"]
                OAIModel["OpenAI<br/>FoundationModel"]
            end

            Retriever["Retriever<br/>(vector + hybrid)"]
        end

        subgraph SearchSpace["search_space"]
            SearchSpaceDef["SearchSpace<br/>Definition"]
            Parameters["Parameters<br/>(Bool, Int, Real, Cat)"]
            Constraints["Constraint Rules"]
            LSAutoDiscover["LlamaStack<br/>Auto-Discovery"]
        end

        subgraph Evaluator["evaluator"]
            UnitxtEval["UnitxtEvaluator<br/>(correctness, faithfulness,<br/>context correctness)"]
        end

        subgraph Utils["utils"]
            EventHandlers["Event Handlers"]
            LocalEH["LocalEventHandler<br/>(JSON/filesystem)"]
            KFPEH["KFPEventHandler<br/>(pipeline metadata)"]
            LocalEH -.->|extends| EventHandlers
            KFPEH -.->|extends| EventHandlers
        end
    end

    %% Core orchestration flows
    Experiment -->|uses| HPO
    Experiment -->|configures| RAG
    Experiment -->|defines| SearchSpace
    Experiment -->|runs| Evaluator
    Experiment -->|emits events| Utils
    MPS -->|narrows| SearchSpace

    %% External interactions
    LSEmbed -->|HTTP/HTTPS| LlamaStackAPI["Llama Stack Server"]
    LSVS -->|HTTP/HTTPS| LlamaStackAPI
    LSModel -->|HTTP/HTTPS| LlamaStackAPI
    LSAutoDiscover -->|HTTP/HTTPS| LlamaStackAPI
    OAIEmbed -->|HTTPS| OpenAIAPI["OpenAI-Compatible API"]
    OAIModel -->|HTTPS| OpenAIAPI

    User["Data Scientist / ML Engineer"] -->|import & configure| Experiment

    %% Styling
    style ai4rag fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Core fill:#d5e8d4,stroke:#82b366
    style HPO fill:#fff2cc,stroke:#d6b656
    style RAG fill:#dae8fc,stroke:#6c8ebf
    style SearchSpace fill:#f8cecc,stroke:#b85450
    style Evaluator fill:#e1d5e7,stroke:#9673a6
    style Utils fill:#ffe6cc,stroke:#d79b00
    style LlamaStackAPI fill:#f5f5f5,stroke:#666,stroke-width:2px
    style OpenAIAPI fill:#f5f5f5,stroke:#666,stroke-width:2px
    style User fill:#fff,stroke:#333,stroke-width:2px
