graph TB
    subgraph ai4rag["ai4rag Library (Python Package)"]
        direction TB

        subgraph Orchestration["Orchestration Layer"]
            Experiment["AI4RAGExperiment<br/>Top-level orchestrator"]
            MPS["ModelsPreSelector<br/>Model pair pre-selection"]
        end

        subgraph Optimization["Optimization Engine"]
            GAMOpt["GAMOptimizer<br/>GAM-based HPO (pygam)"]
            RandomOpt["RandomOptimizer<br/>Random search baseline"]
            SearchSpace["AI4RAGSearchSpace<br/>Constraint-aware search space"]
        end

        subgraph RAGPipeline["RAG Pipeline"]
            SimpleRAG["SimpleRAG<br/>Default RAG template"]
            Chunker["LangChainChunker<br/>RecursiveCharacterTextSplitter"]
            Retriever["Retriever<br/>Vector similarity search"]
        end

        subgraph Evaluation["Evaluation Layer"]
            Evaluator["UnitxtEvaluator<br/>answer_correctness, faithfulness,<br/>context_correctness"]
        end

        subgraph EventHandlers["Event Handlers"]
            LocalEH["LocalEventHandler<br/>JSON artifacts to disk"]
            KFPEH["KFPEventHandler<br/>Kubeflow Pipelines integration"]
        end

        subgraph Models["Model Backends"]
            direction LR
            LSFoundation["LlamaStack<br/>Foundation Model"]
            LSEmbedding["LlamaStack<br/>Embedding Model"]
            OAIFoundation["OpenAI<br/>Foundation Model"]
            OAIEmbedding["OpenAI<br/>Embedding Model"]
        end

        subgraph VectorStores["Vector Store Backends"]
            direction LR
            LSVectorStore["LlamaStack VectorStore<br/>(Milvus, Qdrant)"]
            ChromaVS["ChromaDB VectorStore<br/>(In-memory)"]
        end
    end

    %% Internal flows
    Experiment -->|"Phase 1: pre-select"| MPS
    Experiment -->|"Phase 2: optimize"| GAMOpt
    Experiment -->|"Phase 2: optimize"| RandomOpt
    GAMOpt -->|"selects nodes from"| SearchSpace
    RandomOpt -->|"samples from"| SearchSpace

    MPS -->|"evaluates with"| Evaluator
    MPS -->|"uses"| ChromaVS

    GAMOpt -->|"runs"| SimpleRAG
    SimpleRAG -->|"chunks docs"| Chunker
    SimpleRAG -->|"retrieves context"| Retriever
    SimpleRAG -->|"generates answer"| LSFoundation
    SimpleRAG -->|"generates answer"| OAIFoundation

    Retriever -->|"queries"| LSVectorStore
    Retriever -->|"queries"| ChromaVS

    Chunker -->|"embeds chunks"| LSEmbedding
    Chunker -->|"embeds chunks"| OAIEmbedding

    GAMOpt -->|"evaluates"| Evaluator
    GAMOpt -->|"emits events"| LocalEH
    GAMOpt -->|"emits events"| KFPEH

    %% External systems
    LlamaStack["Llama Stack Server<br/>(External)"]
    OpenAIAPI["OpenAI-compatible API<br/>(External)"]
    KFP["Kubeflow Pipelines<br/>(Platform)"]

    LSFoundation -->|"HTTP/HTTPS"| LlamaStack
    LSEmbedding -->|"HTTP/HTTPS"| LlamaStack
    LSVectorStore -->|"HTTP/HTTPS"| LlamaStack
    OAIFoundation -->|"HTTP/HTTPS"| OpenAIAPI
    OAIEmbedding -->|"HTTP/HTTPS"| OpenAIAPI
    KFPEH -->|"Python SDK"| KFP

    %% Styling
    style ai4rag fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Experiment fill:#4a90e2,color:#fff
    style MPS fill:#4a90e2,color:#fff
    style GAMOpt fill:#7b68ee,color:#fff
    style RandomOpt fill:#7b68ee,color:#fff
    style SearchSpace fill:#7b68ee,color:#fff
    style SimpleRAG fill:#2ecc71,color:#fff
    style Chunker fill:#2ecc71,color:#fff
    style Retriever fill:#2ecc71,color:#fff
    style Evaluator fill:#e67e22,color:#fff
    style LocalEH fill:#95a5a6,color:#fff
    style KFPEH fill:#95a5a6,color:#fff
    style LSFoundation fill:#3498db,color:#fff
    style LSEmbedding fill:#3498db,color:#fff
    style OAIFoundation fill:#9b59b6,color:#fff
    style OAIEmbedding fill:#9b59b6,color:#fff
    style LSVectorStore fill:#3498db,color:#fff
    style ChromaVS fill:#e74c3c,color:#fff
    style LlamaStack fill:#bdc3c7,stroke:#333
    style OpenAIAPI fill:#bdc3c7,stroke:#333
    style KFP fill:#7ed321,stroke:#333
