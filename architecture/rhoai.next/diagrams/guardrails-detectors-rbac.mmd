graph TD
    subgraph DetectorPods["Guardrails Detector Pods"]
        BI_Pod["odh-built-in-detector<br/>(no specific SA defined)"]
        HF_Pod["odh-guardrails-detector-<br/>huggingface-runtime<br/>(no specific SA defined)"]
        Judge_Pod["guardrails-detector-<br/>llm-judge<br/>(no specific SA defined)"]
    end

    subgraph ManagedByPlatform["RBAC Managed by Platform"]
        direction TB
        KServeRBAC["KServe Controller<br/>manages InferenceService<br/>and ServingRuntime RBAC"]
        RhodsOperator["rhods-operator<br/>manages platform-level<br/>RBAC policies"]
    end

    subgraph ExampleBindings["Example Role Bindings"]
        UserBinding["RoleBinding: user-one-view"]
        ViewRole["ClusterRole: view"]
        UserSA["ServiceAccount: user-one"]

        UserSA -->|"bound via"| UserBinding
        UserBinding -->|"grants"| ViewRole
    end

    subgraph AuthEnforcement["Authentication & Authorization"]
        direction TB
        IstioSidecar["Istio Sidecar Proxy<br/>mTLS enforcement"]
        KServeAuth["KServe Auth Proxy<br/>Bearer token validation"]
        Annotation1["sidecar.istio.io/inject: 'true'"]
        Annotation2["security.opendatahub.io/enable-auth: 'true'"]
        Annotation3["serving.knative.openshift.io/enablePassthrough: 'true'"]

        IstioSidecar -.->|"configured by"| Annotation1
        KServeAuth -.->|"configured by"| Annotation2
        KServeAuth -.->|"configured by"| Annotation3
    end

    subgraph Endpoints["Endpoint Authorization"]
        AuthEndpoints["/api/v1/text/contents (POST)<br/>/api/v1/text/generation (POST)<br/>→ Bearer Token required"]
        UnauthEndpoints["/health (GET)<br/>/metrics (GET)<br/>/registry (GET)<br/>→ No auth required"]
    end

    KServeRBAC -.->|"manages RBAC for"| DetectorPods
    RhodsOperator -.->|"manages RBAC for"| DetectorPods
    IstioSidecar -->|"protects"| AuthEndpoints
    KServeAuth -->|"validates"| AuthEndpoints

    style BI_Pod fill:#4a90e2,stroke:#333,color:#fff
    style HF_Pod fill:#4a90e2,stroke:#333,color:#fff
    style Judge_Pod fill:#4a90e2,stroke:#333,color:#fff
    style KServeRBAC fill:#999,stroke:#333,color:#fff
    style RhodsOperator fill:#999,stroke:#333,color:#fff
    style IstioSidecar fill:#f5a623,stroke:#333,color:#fff
    style KServeAuth fill:#f5a623,stroke:#333,color:#fff
    style AuthEndpoints fill:#d5e8d4,stroke:#82b366
    style UnauthEndpoints fill:#fff2cc,stroke:#d6b656
    style ViewRole fill:#7ed321,stroke:#333,color:#fff
