graph TD
    subgraph "Guardrails Detectors - Security Model"
        direction TB

        subgraph "Authentication (Platform-Delegated)"
            IstioSidecar["Istio Sidecar<br/>(injected per annotation:<br/>sidecar.istio.io/inject: true)"]
            mTLS["mTLS Enforcement<br/>(PeerAuthentication - platform level)"]
            KServeAuth["KServe Auth<br/>(annotation: security.opendatahub.io/<br/>enable-auth: true)"]
        end

        subgraph "Service Accounts & Bindings"
            SA_Example["ServiceAccount: user-one<br/>(example only)"]
            RB_Example["RoleBinding: user-one-view<br/>(example only)"]
            CR_View["ClusterRole: view<br/>(platform default)"]
        end

        subgraph "Secrets"
            S3Secret["Secret: aws-connection-minio-<br/>data-connection-guardrails-guardian<br/>Type: Opaque<br/>Keys: ACCESS_KEY, SECRET_KEY,<br/>ENDPOINT, BUCKET, REGION<br/>Auto-rotate: No"]
        end

        subgraph "Detector Endpoints (No App-Level Auth)"
            EP_BuiltIn["/api/v1/text/contents<br/>Port: 8080/TCP<br/>Auth: None (app level)<br/>Enforcement: Istio mTLS"]
            EP_HF["/api/v1/text/contents<br/>Port: 8000/TCP<br/>Auth: None (app level)<br/>Enforcement: Istio mTLS + KServe auth"]
            EP_Judge["/api/v1/text/contents<br/>/api/v1/text/generation<br/>Port: 8000/TCP<br/>Auth: None (app level)<br/>Enforcement: Istio mTLS + KServe auth"]
        end

        subgraph "KServe Platform RBAC (External)"
            KServe_RBAC["KServe manages:<br/>- ServingRuntime resources<br/>- InferenceService resources<br/>- Pod scheduling<br/>- Storage initializer<br/>(Detectors inherit platform RBAC)"]
        end
    end

    %% Relationships
    IstioSidecar -->|enforces| mTLS
    mTLS -->|protects| EP_BuiltIn
    mTLS -->|protects| EP_HF
    mTLS -->|protects| EP_Judge
    KServeAuth -->|enables auth on| EP_HF
    KServeAuth -->|enables auth on| EP_Judge

    SA_Example -->|bound via| RB_Example
    RB_Example -->|grants| CR_View

    S3Secret -->|used by| EP_HF

    KServe_RBAC -.->|"manages deployment of"| EP_HF
    KServe_RBAC -.->|"manages deployment of"| EP_Judge

    %% Styling
    style IstioSidecar fill:#4a90e2,color:#fff
    style mTLS fill:#4a90e2,color:#fff
    style KServeAuth fill:#4a90e2,color:#fff
    style SA_Example fill:#e8e8e8,color:#333
    style RB_Example fill:#e8e8e8,color:#333
    style CR_View fill:#e8e8e8,color:#333
    style S3Secret fill:#e74c3c,color:#fff
    style EP_BuiltIn fill:#50c878,color:#fff
    style EP_HF fill:#9b59b6,color:#fff
    style EP_Judge fill:#e67e22,color:#fff
    style KServe_RBAC fill:#f5a623,color:#fff

    %% Note
    linkStyle default stroke:#666
