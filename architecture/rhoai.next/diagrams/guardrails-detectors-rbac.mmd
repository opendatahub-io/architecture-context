graph TD
    subgraph "Guardrails Detectors - Security Model"
        subgraph "Application-Level Auth"
            Note1["No application-level authentication<br/>All endpoints are open at the app layer"]
        end

        subgraph "Platform-Managed Security"
            KServeAuth["KServe Auth<br/>(InferenceService auth)"]
            IstioSidecar["Istio Sidecar<br/>(mTLS STRICT)"]
            PlatformAuth["Platform Auth<br/>(security.opendatahub.io/enable-auth)"]
        end

        subgraph "Endpoint Protection Matrix"
            EP1["/api/v1/text/contents<br/>POST"]
            EP2["/api/v1/text/generation<br/>POST"]
            EP3["/health<br/>GET"]
            EP4["/metrics<br/>GET"]
            EP5["/registry<br/>GET"]
        end

        subgraph "Service Accounts (Platform-Managed)"
            SA_BuiltIn["Built-in Detector SA<br/>(managed by Orchestrator deployment)"]
            SA_HF["HF Detector SA<br/>(managed by KServe InferenceService)"]
            SA_Judge["Judge Detector SA<br/>(managed by KServe InferenceService)"]
        end

        subgraph "Secrets"
            S3Secret["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>AWS_S3_BUCKET<br/>Auto-Rotate: No"]
        end

        subgraph "Custom Detector Sandbox"
            Sandbox["Static Code Analysis Gate"]
            ForbiddenImports["Forbidden imports:<br/>os, subprocess, sys, shutil"]
            ForbiddenCalls["Forbidden calls:<br/>eval, exec, open, compile, input"]
            Allowed["Exceptions:<br/>os.environ, os.getenv"]

            Sandbox --> ForbiddenImports
            Sandbox --> ForbiddenCalls
            Sandbox --> Allowed
        end
    end

    %% Protection flows
    KServeAuth -->|protects| EP1
    KServeAuth -->|protects| EP2
    IstioSidecar -->|mTLS| EP1
    IstioSidecar -->|mTLS| EP2
    IstioSidecar -->|mTLS| EP3
    IstioSidecar -->|mTLS| EP4
    IstioSidecar -->|mTLS| EP5
    PlatformAuth -->|enforces| KServeAuth

    %% SA to secrets
    SA_HF -->|mounts| S3Secret

    %% No K8s API access
    SA_BuiltIn -.-|"No K8s API access<br/>(app containers only)"| Note1
    SA_HF -.-|"No K8s API access<br/>(app containers only)"| Note1
    SA_Judge -.-|"No K8s API access<br/>(app containers only)"| Note1

    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style KServeAuth fill:#4a90e2,color:#fff
    style IstioSidecar fill:#4a90e2,color:#fff
    style PlatformAuth fill:#4a90e2,color:#fff
    style EP1 fill:#d5e8d4,stroke:#82b366
    style EP2 fill:#d5e8d4,stroke:#82b366
    style EP3 fill:#f0f0f0,stroke:#999
    style EP4 fill:#f0f0f0,stroke:#999
    style EP5 fill:#f0f0f0,stroke:#999
    style S3Secret fill:#f8cecc,stroke:#b85450
    style Sandbox fill:#fd79a8,color:#fff
    style ForbiddenImports fill:#ffcccc,stroke:#b85450
    style ForbiddenCalls fill:#ffcccc,stroke:#b85450
    style Allowed fill:#d5e8d4,stroke:#82b366
    style SA_BuiltIn fill:#dae8fc,stroke:#6c8ebf
    style SA_HF fill:#dae8fc,stroke:#6c8ebf
    style SA_Judge fill:#dae8fc,stroke:#6c8ebf
