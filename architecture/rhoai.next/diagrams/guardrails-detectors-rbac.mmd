graph TD
    subgraph PlatformManaged["Platform-Managed RBAC (KServe / RHOAI Operator)"]
        direction TB
        Note1["No ClusterRoles defined by guardrails-detectors.<br/>KServe and the platform operator manage RBAC<br/>for InferenceService deployment."]
    end

    subgraph ExampleBinding["Example Role Binding (from deploy manifests)"]
        direction TB
        SA["Service Account<br/>user-one"]
        RB["RoleBinding<br/>user-one-view"]
        CR["ClusterRole<br/>view"]

        SA -->|"bound via"| RB
        RB -->|"grants"| CR
    end

    subgraph Resources["Accessible Resources (via 'view' ClusterRole)"]
        direction TB
        Pods["core<br/>Pods"]
        Services["core<br/>Services"]
        ConfigMaps["core<br/>ConfigMaps"]
        Deployments["apps<br/>Deployments"]
        ISVC["serving.kserve.io<br/>InferenceService"]
    end

    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, watch"| ConfigMaps
    CR -->|"get, list, watch"| Deployments
    CR -->|"get, list, watch"| ISVC

    subgraph Secrets["Secrets Access"]
        direction TB
        S3Secret["aws-connection-minio-data-<br/>connection-guardrails-guardian<br/>(Opaque / S3 connection)<br/>Fields: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>endpoint, bucket, region"]
        SecretNote["Provisioned By: Manual / ODH Dashboard<br/>Auto-Rotate: No<br/>Purpose: S3 credentials for MinIO"]
    end

    subgraph AuthDelegation["Authentication Delegation"]
        direction TB
        KServeAuth["KServe + Istio Sidecar<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
        BuiltInAuth["Built-in Detector<br/>Network Isolation Only<br/>(No Auth Enforcement)"]
    end

    style PlatformManaged fill:#f0f0f0,stroke:#999,stroke-width:2px
    style ExampleBinding fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Resources fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Secrets fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthDelegation fill:#f8cecc,stroke:#b85450,stroke-width:2px

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#b8d4f0,stroke:#333
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style ISVC fill:#7ed321,stroke:#333,color:#fff
    style S3Secret fill:#fff,stroke:#d6b656
    style KServeAuth fill:#fff,stroke:#b85450
    style BuiltInAuth fill:#fff,stroke:#b85450
