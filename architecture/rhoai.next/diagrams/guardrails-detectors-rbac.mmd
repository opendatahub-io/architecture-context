graph TD
    subgraph "Guardrails Detectors RBAC Model"
        direction TB

        subgraph "Application-Level Security"
            Note1["No RBAC roles defined by component<br/>Detectors run as application workloads"]
        end

        subgraph "Platform-Level Security (Delegated)"
            direction TB

            subgraph "KServe Auth"
                KServeAnnotation["KServe InferenceService Annotation<br/>security.opendatahub.io/enable-auth: true"]
            end

            subgraph "Istio Service Mesh"
                IstioSidecar["Istio Sidecar Injection<br/>sidecar.istio.io/inject: true"]
                PeerAuth["PeerAuthentication<br/>(Platform-level mTLS)"]
                IstioSidecar --> PeerAuth
            end

            subgraph "Example RBAC (Demo Only)"
                SA_Example["ServiceAccount<br/>user-one"]
                RB_Example["RoleBinding<br/>user-one-view"]
                CR_View["ClusterRole<br/>view"]

                SA_Example -->|"bound via"| RB_Example
                RB_Example -->|"grants"| CR_View
            end
        end

        subgraph "Secret Access"
            direction TB

            Secret_S3["Secret: aws-connection-minio-<br/>data-connection-guardrails-guardian<br/>Type: Opaque"]

            subgraph "Secret Keys"
                Key_Access["ACCESS_KEY"]
                Key_Secret["SECRET_KEY"]
                Key_Endpoint["ENDPOINT"]
                Key_Bucket["BUCKET"]
                Key_Region["REGION"]
            end

            Secret_S3 --> Key_Access
            Secret_S3 --> Key_Secret
            Secret_S3 --> Key_Endpoint
            Secret_S3 --> Key_Bucket
            Secret_S3 --> Key_Region
        end

        subgraph "Authentication Enforcement"
            direction TB
            EP_Contents["/api/v1/text/contents<br/>POST"]
            EP_Generation["/api/v1/text/generation<br/>POST"]
            EP_All["All endpoints"]

            Enforcement_Istio["Enforcement: Istio Sidecar<br/>(when deployed via KServe)"]
            Enforcement_mTLS["Enforcement: mTLS<br/>PeerAuthentication (platform)"]

            EP_Contents --> Enforcement_Istio
            EP_Generation --> Enforcement_Istio
            EP_All --> Enforcement_mTLS
        end

        subgraph "Custom Detector Security (Built-in)"
            direction TB
            StaticAnalysis["AST Static Code Analysis<br/>(before loading user Python)"]
            Forbidden_Imports["Forbidden Imports:<br/>os, subprocess, sys, shutil"]
            Forbidden_Calls["Forbidden Calls:<br/>eval, exec, open, compile, input"]
            Allowed["Exceptions Allowed:<br/>os.environ, os.getenv"]

            StaticAnalysis --> Forbidden_Imports
            StaticAnalysis --> Forbidden_Calls
            StaticAnalysis --> Allowed
        end
    end

    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style KServeAnnotation fill:#d5e8d4,stroke:#82b366
    style IstioSidecar fill:#d5e8d4,stroke:#82b366
    style PeerAuth fill:#d5e8d4,stroke:#82b366
    style SA_Example fill:#e8e8e8,stroke:#999
    style RB_Example fill:#e8e8e8,stroke:#999
    style CR_View fill:#f5a623,stroke:#333
    style Secret_S3 fill:#ffcccc,stroke:#cc0000
    style StaticAnalysis fill:#dae8fc,stroke:#6c8ebf
    style Forbidden_Imports fill:#ffcccc,stroke:#cc0000
    style Forbidden_Calls fill:#ffcccc,stroke:#cc0000
    style Allowed fill:#d5e8d4,stroke:#82b366
