graph TD
    subgraph "Guardrails Detectors RBAC"
        direction TB

        Note["Note: No ClusterRoles defined.<br/>This component runs as application-level pods<br/>and does not interact with the Kubernetes API."]

        subgraph "Example Role Binding"
            SA["ServiceAccount<br/>user-one"]
            RB["RoleBinding<br/>user-one-view"]
            CR["ClusterRole<br/>view"]
        end

        SA -->|"bound via"| RB
        RB -->|"grants"| CR

        subgraph "KServe-Managed Auth"
            KServeAuth["security.opendatahub.io/enable-auth<br/>(annotation on InferenceService)"]
            IstioSidecar["Istio Sidecar<br/>sidecar.istio.io/inject=true"]
        end

        subgraph "Application Endpoints"
            ContentAPI["POST /api/v1/text/contents<br/>Auth: Platform-managed<br/>(KServe + Istio)"]
            GenerationAPI["POST /api/v1/text/generation<br/>Auth: Platform-managed<br/>(detector_id header required)"]
            HealthAPI["GET /health<br/>Auth: None (Open)"]
            MetricsAPI["GET /metrics<br/>Auth: None (Open)"]
        end

        KServeAuth -->|"enforces auth on"| ContentAPI
        KServeAuth -->|"enforces auth on"| GenerationAPI
        IstioSidecar -->|"mTLS enforcement"| ContentAPI
        IstioSidecar -->|"mTLS enforcement"| GenerationAPI

        subgraph "Secrets"
            S3Secret["Secret: aws-connection-minio-data-connection-guardrails-guardian<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_BUCKET, AWS_S3_ENDPOINT<br/>Provisioned: Manual | Auto-Rotate: No"]
        end

        subgraph "Custom Detector Sandboxing"
            Sandbox["AST-based Static Code Analysis"]
            BlockedImports["Blocked Imports:<br/>os, subprocess, sys, shutil"]
            BlockedFunctions["Blocked Functions:<br/>eval, exec, open, compile, input"]
            AllowedExceptions["Allowed Exceptions:<br/>os.getenv, os.environ"]
        end

        Sandbox --> BlockedImports
        Sandbox --> BlockedFunctions
        Sandbox --> AllowedExceptions
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,color:#fff
    style RB fill:#f5a623,color:#fff
    style CR fill:#f5a623,color:#fff
    style KServeAuth fill:#7ed321,color:#fff
    style IstioSidecar fill:#7ed321,color:#fff
    style ContentAPI fill:#d5e8d4,stroke:#82b366
    style GenerationAPI fill:#d5e8d4,stroke:#82b366
    style HealthAPI fill:#e8e8e8,stroke:#666
    style MetricsAPI fill:#e8e8e8,stroke:#666
    style S3Secret fill:#f8cecc,stroke:#b85450
    style Sandbox fill:#dae8fc,stroke:#6c8ebf
    style BlockedImports fill:#f8cecc,stroke:#b85450
    style BlockedFunctions fill:#f8cecc,stroke:#b85450
    style AllowedExceptions fill:#d5e8d4,stroke:#82b366
