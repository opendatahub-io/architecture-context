graph TD
    subgraph DetectorWorkloads["Detector Workloads (No Custom RBAC)"]
        BuiltIn["Built-in Detector Pod<br/>(standalone deployment)"]
        HF["HuggingFace Detector Pod<br/>(KServe InferenceService)"]
        Judge["LLM Judge Detector Pod<br/>(KServe InferenceService)"]
    end

    subgraph PlatformRBAC["Platform-Level RBAC"]
        KServeRBAC["KServe RBAC<br/>(manages InferenceService lifecycle)"]
        IstioRBAC["Istio RBAC<br/>(mTLS PeerAuthentication)"]
    end

    subgraph ExampleRBAC["Example RBAC (model_container.yaml)"]
        SA["ServiceAccount: user-one"]
        RB["RoleBinding: user-one-view"]
        CR["ClusterRole: view"]
    end

    subgraph AuthAnnotations["KServe Auth Annotations"]
        AuthEnabled["security.opendatahub.io/<br/>enable-auth: 'true'"]
        SidecarInject["sidecar.istio.io/<br/>inject: 'true'"]
        Passthrough["serving.knative.openshift.io/<br/>enablePassthrough: 'true'"]
    end

    %% Platform RBAC manages detectors
    KServeRBAC -->|manages lifecycle| HF
    KServeRBAC -->|manages lifecycle| Judge
    IstioRBAC -->|enforces mTLS| BuiltIn
    IstioRBAC -->|enforces mTLS| HF
    IstioRBAC -->|enforces mTLS| Judge

    %% Example RBAC
    SA -->|bound via| RB
    RB -->|grants| CR

    %% Auth annotations apply to KServe ISVCs
    AuthEnabled -.->|applied to| HF
    AuthEnabled -.->|applied to| Judge
    SidecarInject -.->|applied to| HF
    SidecarInject -.->|applied to| Judge
    Passthrough -.->|applied to| HF
    Passthrough -.->|applied to| Judge

    %% Note
    Note["Note: Detectors have NO custom RBAC.<br/>All access control is handled at<br/>platform level via KServe + Istio."]

    style BuiltIn fill:#4a90e2,stroke:#333,color:#fff
    style HF fill:#4a90e2,stroke:#333,color:#fff
    style Judge fill:#4a90e2,stroke:#333,color:#fff
    style KServeRBAC fill:#f5a623,stroke:#333
    style IstioRBAC fill:#f5a623,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style CR fill:#f5a623,stroke:#333
    style RB fill:#e8e8e8,stroke:#333
    style AuthEnabled fill:#ffe6cc,stroke:#333
    style SidecarInject fill:#ffe6cc,stroke:#333
    style Passthrough fill:#ffe6cc,stroke:#333
    style Note fill:#fff,stroke:#999,stroke-dasharray: 5 5
