graph TD
    subgraph "Guardrails Detectors RBAC Model"
        direction TB

        subgraph SAs["Service Accounts"]
            SA_UserOne["user-one<br/>(example SA)"]
            SA_KServe["KServe Controller<br/>(platform-managed)"]
        end

        subgraph Bindings["Role Bindings"]
            RB_View["user-one-view<br/>(RoleBinding)<br/>Namespace: deploy namespace"]
            RB_KServe["KServe RBAC<br/>(platform-managed)<br/>Manages InferenceService lifecycle"]
        end

        subgraph Roles["Roles"]
            CR_View["view<br/>(ClusterRole)<br/>Built-in K8s role"]
            CR_KServe["KServe ClusterRoles<br/>(platform-managed)"]
        end

        subgraph Resources["Protected Resources"]
            IS["serving.kserve.io<br/>InferenceService"]
            SR["serving.kserve.io<br/>ServingRuntime"]
            Pods["core<br/>Pods"]
            Svcs["core<br/>Services"]
            Secrets["core<br/>Secrets<br/>(S3 credentials)"]
        end

        %% User service account path
        SA_UserOne -->|"bound via"| RB_View
        RB_View -->|"grants"| CR_View
        CR_View -->|"get, list, watch"| IS
        CR_View -->|"get, list, watch"| Pods
        CR_View -->|"get, list, watch"| Svcs

        %% KServe controller path
        SA_KServe -->|"bound via"| RB_KServe
        RB_KServe -->|"grants"| CR_KServe
        CR_KServe -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| IS
        CR_KServe -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| SR
        CR_KServe -->|"get, list, watch,<br/>create, update"| Pods
        CR_KServe -->|"get, list, watch"| Secrets
    end

    subgraph AuthNote["Authentication & Authorization"]
        direction LR
        Note1["Detector endpoints have<br/>NO application-level auth"]
        Note2["Security enforced by:<br/>KServe + Istio sidecar<br/>Annotation: security.opendatahub.io/<br/>enable-auth: 'true'"]
        Note3["Built-in detector relies on<br/>cluster network isolation only"]
    end

    style SA_UserOne fill:#4a90e2,stroke:#333,color:#fff
    style SA_KServe fill:#4a90e2,stroke:#333,color:#fff
    style RB_View fill:#b8d4f0,stroke:#333
    style RB_KServe fill:#b8d4f0,stroke:#333
    style CR_View fill:#f5a623,stroke:#333,color:#fff
    style CR_KServe fill:#f5a623,stroke:#333,color:#fff
    style IS fill:#7ed321,stroke:#333,color:#fff
    style SR fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Svcs fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#e74c3c,stroke:#333,color:#fff
    style Note1 fill:#fff3cd,stroke:#856404
    style Note2 fill:#fff3cd,stroke:#856404
    style Note3 fill:#fff3cd,stroke:#856404
