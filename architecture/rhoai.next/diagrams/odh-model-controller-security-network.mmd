graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        InferenceClient["External Inference Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        OSRoute["OpenShift Route<br/>{isvc}<br/>443/TCP HTTPS<br/>TLS reencrypt/edge"]
        GatewayEF["Gateway EnvoyFilter (Istio)<br/>50051/TCP gRPC/HTTP2<br/>mTLS MUTUAL"]
        GatewayAP["Gateway AuthPolicy (Kuadrant)<br/>Anonymous or UserDefined"]
        HTTPRouteAP["{httpRoute} AuthPolicy (Kuadrant)<br/>Per-LLMInferenceService auth"]
        Authorino["Authorino<br/>Auth enforcement"]
        GatewayEF -->|mTLS<br/>Service account CA| Authorino
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_Controller["Namespace: opendatahub"]
            Controller["odh-model-controller<br/>SA: odh-model-controller<br/>Image: quay.io/.../odh-model-controller:odh-stable"]
            WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS (cert-manager TLS)<br/>Auth: K8s API server mTLS"]
            MetricsSvc["Metrics Service<br/>8080/TCP<br/>HTTP (no TLS)<br/>Auth: Optional"]
            HealthProbe["Health Probes<br/>8081/TCP<br/>HTTP (no TLS)"]

            APIServer["model-serving-api<br/>SA: model-serving-api<br/>Image: quay.io/.../odh-model-serving-api:odh-stable"]
            APISvc["API Service<br/>443/TCP → 8443/TCP<br/>HTTPS TLS 1.2+ FIPS<br/>ECDHE+AES-GCM, P-256/P-384<br/>Auth: Bearer Token"]
            APIMetricsSvc["API Metrics Service<br/>8080/TCP<br/>HTTPS TLS 1.2+ FIPS"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            ISVCMetrics["{isvc}-metrics<br/>ClusterIP dynamic/TCP<br/>HTTP (no TLS)<br/>Prometheus scrape"]
        end

        Dashboard["RHOAI Dashboard"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount / Bearer Token"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API key bearer"]
        NVCR["NVIDIA NVCR<br/>nvcr.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: OAuth token"]
        OTLP["OTLP Collector<br/>configurable/TCP gRPC<br/>TLS optional<br/>Auth: None"]
    end

    %% External → Ingress flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI
    InferenceClient -->|HTTPS/443<br/>TLS reencrypt/edge<br/>Optional auth| OSRoute

    %% Ingress auth flow
    GatewayAP -.->|auth check| Authorino
    HTTPRouteAP -.->|auth check| Authorino

    %% Dashboard → API
    Dashboard -->|HTTPS/443→8443<br/>TLS 1.2+ FIPS<br/>User bearer token| APISvc

    %% Controller → Kubernetes API
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token| K8sAPI
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>SA + User bearer| K8sAPI

    %% Controller → NVIDIA
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>API key bearer| NGC
    Controller -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth token| NVCR

    %% API Server → OTLP
    APIServer -.->|gRPC<br/>TLS optional<br/>Optional| OTLP

    %% Kubernetes API → Webhook
    K8sAPI -->|HTTPS/443→9443<br/>TLS (cert-manager)<br/>K8s API mTLS| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User,InferenceClient external
    class OSRoute,GatewayEF,GatewayAP,HTTPRouteAP,Authorino ingress
    class Controller,WebhookSvc,MetricsSvc,HealthProbe,APIServer,APISvc,APIMetricsSvc,ISVCMetrics,Dashboard internal
    class K8sAPI,NGC,NVCR,OTLP externalservice
