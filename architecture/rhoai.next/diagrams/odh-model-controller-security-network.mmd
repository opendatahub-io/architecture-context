graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com<br/>authn.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        Route["OpenShift Route (dynamic)<br/>443/TCP → backend<br/>TLS Edge/Reencrypt<br/>Auth: Optional AuthPolicy"]
    end

    subgraph AuthZone["AUTHORIZATION ZONE"]
        Authorino["Authorino<br/>50051/TCP gRPC/HTTP2<br/>mTLS<br/>TokenReview + SAR"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph ControllerNS["Namespace: opendatahub"]
            OMC["odh-model-controller<br/>SA: odh-model-controller<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (health)<br/>9443/TCP HTTPS (webhooks)"]

            MSA["model-serving-api<br/>SA: model-serving-api<br/>8443/TCP HTTPS (API)<br/>8080/TCP HTTPS (metrics)<br/>TLS 1.2+ FIPS ciphers"]
        end

        subgraph Services["ClusterIP Services"]
            SvcAPI["model-serving-api<br/>443→8443, 8080→8080"]
            SvcWebhook["webhook-service<br/>443→9443"]
            SvcMetrics["metrics-service<br/>8080→8080"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / User Token"]

        Dashboard["RHOAI Dashboard<br/>Bearer Token"]

        subgraph OptionalSvc["Optional Services"]
            OTLP["OTLP Collector<br/>gRPC / TLS"]
            ModelReg["Model Registry<br/>HTTPS / TLS 1.2+<br/>Bearer Token"]
        end
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Edge/Reencrypt<br/>Optional AuthPolicy"| Route
    Route -->|"gRPC/50051<br/>mTLS<br/>Service Identity"| Authorino

    %% Controller egress
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key / Bearer Token"| NGC
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    OMC -->|"gRPC mTLS<br/>configures auth chain"| Authorino

    %% API server flows
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+ FIPS<br/>Bearer Token"| SvcAPI
    SvcAPI --> MSA
    MSA -->|"HTTPS/443<br/>TLS 1.2+<br/>User Token (forwarded)"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/443<br/>TLS serving-cert"| SvcWebhook
    SvcWebhook --> OMC

    %% Optional flows
    MSA -.->|"gRPC/TLS"| OTLP
    OMC -.->|"HTTPS/TLS 1.2+<br/>Bearer Token"| ModelReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authzone fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef apiserver fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray:5

    class Client,NGC external
    class Route ingress
    class Authorino authzone
    class OMC,MSA,Dashboard internal
    class SvcAPI,SvcWebhook,SvcMetrics service
    class K8sAPI apiserver
    class OTLP,ModelReg optional
