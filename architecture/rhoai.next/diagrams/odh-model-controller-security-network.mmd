graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(Data Scientist)"]
        DashCLI["Dashboard / CLI"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        Route["OpenShift Route<br/>(per InferenceService)<br/>443/TCP<br/>TLS passthrough/reencrypt<br/>Auth: Kuadrant AuthPolicy"]
    end

    subgraph ClusterInternal["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_Apps["Namespace: {applications-namespace}"]
            direction TB

            subgraph MSADeploy["model-serving-api"]
                MSA["model-serving-api<br/>SA: model-serving-api<br/>Image: odh-model-serving-api"]
                MSA_SVC1["Service: model-serving-api<br/>443/TCP → 8443<br/>HTTPS TLS 1.2+ FIPS<br/>Auth: Bearer Token"]
                MSA_SVC2["Service: model-serving-api<br/>8080/TCP<br/>HTTPS TLS 1.2+<br/>Metrics (no auth)"]
            end

            subgraph OMCDeploy["odh-model-controller"]
                OMC["odh-model-controller<br/>SA: odh-model-controller<br/>Image: odh-model-controller"]
                OMC_Metrics["Service: metrics<br/>8080/TCP HTTP<br/>Metrics (no auth)"]
                OMC_Webhook["Service: webhook<br/>443/TCP → 9443<br/>HTTPS TLS<br/>Auth: TLS client cert"]
                OMC_Health["Health: 8081/TCP<br/>HTTP (no auth)"]
            end
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA token / Bearer"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        NGC["api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer (NGC API key)<br/>⚠ No explicit FIPS ciphers"]
        NVCR["nvcr.io<br/>443/TCP HTTPS OCI<br/>TLS 1.2+<br/>Auth: Bearer (registry token)"]
        ModelReg["Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+ (skip configurable)<br/>Auth: Bearer Token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS passthrough/reencrypt<br/>AuthPolicy"| Route
    DashCLI -->|"HTTPS/443→8443<br/>TLS 1.2+ FIPS ciphers<br/>Bearer Token"| MSA_SVC1

    %% Internal flows
    MSA -->|"HTTPS/6443<br/>TLS 1.2+<br/>User Bearer (SSAR)"| K8sAPI
    MSA -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (list GW)"| K8sAPI
    OMC -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token<br/>(Watch/CRUD CRDs)"| K8sAPI

    %% Egress flows
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC API key"| NGC
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry token"| NVCR
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| ModelReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterint fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client,DashCLI external
    class Route ingress
    class MSA,OMC,MSA_SVC1,MSA_SVC2,OMC_Metrics,OMC_Webhook,OMC_Health clusterint
    class K8sAPI k8sapi
    class NGC,NVCR,ModelReg externalservice
