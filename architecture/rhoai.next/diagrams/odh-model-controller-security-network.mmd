graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        Dashboard["RHOAI Dashboard"]
        Client["External Client<br/>(inference consumer)"]
    end

    subgraph Ingress["INGRESS (External Model Access)"]
        Route["Per-ISVC OpenShift Route<br/>443/TCP<br/>TLS Edge/Reencrypt<br/>Optional AuthPolicy"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            OMC["odh-model-controller<br/>SA: odh-model-controller<br/>Ports: 8080(metrics), 8081(health),<br/>9443(webhooks HTTPS)"]
            MSA["model-serving-api<br/>SA: model-serving-api<br/>Port: 8443(HTTPS FIPS),<br/>9090(metrics HTTPS)"]
        end

        subgraph Services["ClusterIP Services"]
            SvcMSA["model-serving-api<br/>443→8443 HTTPS<br/>Bearer Token"]
            SvcMetrics["metrics-service<br/>8443 HTTPS<br/>authn/authz"]
            SvcWebhook["webhook-service<br/>443→9443 HTTPS<br/>cert injection"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / User Token"]
    end

    subgraph ExternalEgress["EXTERNAL SERVICES (Egress)"]
        NGC["api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key (Bearer)"]
        NVCR["nvcr.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key (Basic)"]
        AuthnNV["authn.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token Exchange"]
        ModelReg["Model Registry API<br/>Configurable Port<br/>HTTPS/HTTP<br/>Bearer Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS Edge/Reencrypt<br/>Optional Auth"| Route

    %% External to Cluster
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+ (FIPS)<br/>Bearer Token"| SvcMSA

    %% Service routing
    SvcMSA -.->|"8443"| MSA
    SvcMetrics -.->|"8443"| OMC
    SvcWebhook -.->|"9443"| OMC

    %% Internal flows
    K8sAPI -->|"HTTPS/9443<br/>TLS cert injection<br/>Admission"| OMC
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    MSA -->|"HTTPS/443<br/>TLS 1.2+<br/>User Token (SSAR)"| K8sAPI
    MSA -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (list)"| K8sAPI

    %% Egress
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC API Key"| NGC
    OMC -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC Basic Auth"| NVCR
    OMC -->|"HTTPS/443<br/>TLS 1.2+"| AuthnNV
    OMC -->|"HTTPS<br/>TLS 1.2+ (optional)<br/>Bearer Token"| ModelReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e0e0e0,stroke:#424242,stroke-width:2px

    class User,Dashboard,Client external
    class Route ingress
    class OMC,MSA clusterinternal
    class SvcMSA,SvcMetrics,SvcWebhook service
    class K8sAPI k8s
    class NGC,NVCR,AuthnNV,ModelReg externalservice
