graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        Client["Inference Client"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / SA Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph ControllerPod["odh-model-controller"]
            Controller["Controller Manager<br/>SA: odh-model-controller<br/>FIPS: strictfipsruntime"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (cert injection)"]
            MetricsCtrl["Metrics<br/>8080/TCP HTTP/HTTPS<br/>authn/authz filter"]
            HealthCtrl["Health Probes<br/>8081/TCP HTTP"]
        end

        subgraph APIPod["model-serving-api"]
            APIServer["API Server<br/>8443/TCP HTTPS<br/>TLS 1.2+ FIPS ciphers<br/>ECDHE+AES-GCM<br/>P-256, P-384"]
            MetricsAPI["Metrics<br/>9090/TCP HTTPS<br/>TLS 1.2+"]
        end
    end

    subgraph Services["SERVICES (ClusterIP)"]
        SvcAPI["model-serving-api<br/>443 → 8443/TCP"]
        SvcWebhook["webhook-service<br/>443 → 9443/TCP"]
        SvcMetrics["metrics-service<br/>8443 → 8443/TCP"]
        SvcAPIMetrics["api-metrics<br/>9090 → 9090/TCP"]
    end

    subgraph UserNS["USER NAMESPACE (per InferenceService)"]
        ISVCRoute["OpenShift Route<br/>{isvc}.{ns}.{domain}<br/>443/TCP HTTPS<br/>TLS Edge/Reencrypt"]
    end

    subgraph PlatformDeps["PLATFORM DEPENDENCIES (Internal)"]
        Dashboard["RHOAI Dashboard"]
        Prometheus["Prometheus<br/>(scrapes ServiceMonitors)"]
        KServe["KServe Controller"]
        Kuadrant["Kuadrant / Authorino"]
    end

    subgraph NVIDIAEgress["NVIDIA SERVICES (External Egress)"]
        NGC["api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key (Bearer)"]
        NVCR["nvcr.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>NGC API Key (Basic)"]
        AuthN["authn.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph OptionalEgress["OPTIONAL EGRESS"]
        ModelReg["Model Registry<br/>Configurable port<br/>HTTP/HTTPS<br/>Bearer Token"]
    end

    %% External → K8s
    User -->|"HTTPS/443<br/>Bearer Token"| K8sAPI
    Client -->|"HTTPS/443<br/>TLS Edge/Reencrypt"| ISVCRoute

    %% K8s → Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS cert injection<br/>Mutate+Validate"| WebhookSrv

    %% Controller → K8s
    Controller -->|"HTTPS/443<br/>SA Token<br/>CRUD: Routes, Secrets,<br/>ServiceMonitors, AuthPolicies,<br/>EnvoyFilters, Templates"| K8sAPI

    %% API Server flows
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+ FIPS<br/>Bearer Token"| SvcAPI
    SvcAPI --> APIServer
    APIServer -->|"HTTPS/443<br/>User Bearer + SA Token<br/>SSAR + List Gateways"| K8sAPI

    %% Services routing
    SvcWebhook --> WebhookSrv
    SvcMetrics --> MetricsCtrl

    %% Monitoring
    Prometheus -->|"scrapes"| SvcMetrics
    Prometheus -->|"scrapes"| SvcAPIMetrics
    SvcAPIMetrics --> MetricsAPI

    %% NIM Egress
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC Key (Bearer)"| NGC
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC Key (Basic)"| NVCR
    Controller -->|"HTTPS/443<br/>TLS 1.2+"| AuthN

    %% Optional Egress
    Controller -->|"HTTP/HTTPS<br/>Bearer Token<br/>Optional TLS"| ModelReg

    %% Platform interactions (CRD watches)
    KServe -.->|"CRD events"| Controller
    Kuadrant -.->|"Auth enforcement"| ISVCRoute

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326ce5,stroke:#fff,stroke-width:2px,color:#fff
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e8e8e8,stroke:#666,stroke-width:1px

    class User,Client external
    class K8sAPI k8s
    class Controller,WebhookSrv,MetricsCtrl,HealthCtrl,APIServer,MetricsAPI operator
    class SvcAPI,SvcWebhook,SvcMetrics,SvcAPIMetrics service
    class ISVCRoute ingress
    class NGC,NVCR,AuthN,ModelReg egress
    class Dashboard,Prometheus,KServe,Kuadrant platform
