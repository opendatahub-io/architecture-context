graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        Dashboard["RHOAI Dashboard"]
        Client["External Client<br/>(Inference)"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        ISVCRoute["Per-ISVC OpenShift Route<br/>443/TCP<br/>TLS Edge/Reencrypt<br/>Auth: None or Kuadrant AuthPolicy"]
    end

    subgraph Internal["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_Operator["Namespace: {operator-namespace}"]
            direction TB

            subgraph OMC_Deploy["odh-model-controller Deployment"]
                OMC_Metrics["Metrics :8080/TCP<br/>HTTP (optional TLS)<br/>authn/authz filter"]
                OMC_Health["Health :8081/TCP<br/>HTTP<br/>No auth"]
                OMC_Webhook["Webhooks :9443/TCP<br/>HTTPS (cert injection)<br/>Auth: K8s API server"]
            end

            subgraph MSA_Deploy["model-serving-api Deployment"]
                MSA_API["/api/v1/gateways :8443/TCP<br/>HTTPS TLS 1.2+ FIPS<br/>ECDHE+AES-GCM (P-256, P-384)<br/>Auth: Bearer Token + SSAR"]
                MSA_Metrics["Metrics :9090/TCP<br/>HTTPS TLS 1.2+<br/>No auth"]
            end
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
    end

    subgraph ExternalEgress["EXTERNAL SERVICES (Egress)"]
        NGC["api.ngc.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: NGC API Key (Bearer)"]
        NVCR["nvcr.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: NGC API Key (Basic)"]
        AuthN["authn.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: None"]
        ModelReg["Model Registry<br/>Configurable port HTTP/HTTPS<br/>Auth: Bearer Token"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS Edge/Reencrypt"| ISVCRoute

    %% External → Internal
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+ FIPS<br/>Bearer Token (user)"| MSA_API

    %% Internal → K8s API
    OMC_Deploy -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI
    MSA_Deploy -->|"HTTPS/443<br/>TLS 1.2+<br/>User Bearer + SA token"| K8sAPI

    %% K8s API → Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert injection)<br/>Admission webhooks"| OMC_Webhook

    %% Internal → External Egress
    OMC_Deploy -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC API Key (Bearer)"| NGC
    OMC_Deploy -->|"HTTPS/443<br/>TLS 1.2+<br/>NGC API Key (Basic)"| NVCR
    OMC_Deploy -->|"HTTPS/443<br/>TLS 1.2+"| AuthN
    OMC_Deploy -->|"HTTP(S)<br/>Optional TLS<br/>Bearer Token"| ModelReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User,Dashboard,Client external
    class ISVCRoute ingress
    class OMC_Metrics,OMC_Health,OMC_Webhook,MSA_API,MSA_Metrics internal
    class K8sAPI k8sapi
    class NGC,NVCR,AuthN,ModelReg externalservice
