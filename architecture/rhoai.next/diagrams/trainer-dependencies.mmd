graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% External Dependencies (Required)
    Trainer -->|"workload orchestration<br/>CRD: JobSet"| JobSet["JobSet<br/>v0.10.1"]
    Trainer -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"cert auto-rotation"| CertController["cert-controller<br/>(OPA) v0.14.0"]
    Trainer -->|"API server<br/>HTTPS/443"| K8s["Kubernetes<br/>1.34+"]

    %% External Dependencies (Optional)
    Trainer -.->|"gang-scheduling<br/>CRD: PodGroup"| SchedulerPlugins["Scheduler Plugins<br/>(Coscheduling)<br/>v0.34.1-devel"]
    Trainer -.->|"gang-scheduling<br/>CRD: PodGroup"| Volcano["Volcano<br/>v1.13.1"]
    Trainer -.->|"multi-cluster<br/>managedBy delegation"| Kueue["Kueue<br/>(MultiKueue)"]

    %% Internal RHOAI Dependencies
    RhodsOperator["rhods-operator<br/>(Platform Operator)"] -->|"deploys via<br/>kustomize"| Trainer
    Trainer -->|"image resolution"| ImageStreams["OpenShift<br/>ImageStreams"]

    %% Integration Points (consumers)
    Prometheus["Prometheus /<br/>Monitoring Stack"] -->|"scrapes metrics<br/>HTTPS/8443"| Trainer

    %% Dynamic runtime integrations
    Trainer -->|"progression polling<br/>HTTP/28080"| TrainingPods["Training Pods<br/>(RHAI)"]
    Trainer -->|"SSH key mgmt<br/>SSH/2222"| MPIPods["MPI Worker<br/>Pods"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style JobSet fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff

    %% Optional external
    style SchedulerPlugins fill:#bbb,stroke:#333,color:#fff
    style Volcano fill:#bbb,stroke:#333,color:#fff
    style Kueue fill:#bbb,stroke:#333,color:#fff

    %% Internal RHOAI
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% Runtime targets
    style TrainingPods fill:#f5a623,stroke:#333
    style MPIPods fill:#f5a623,stroke:#333
