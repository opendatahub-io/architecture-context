graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% External Dependencies (Required)
    Trainer -->|"workload orchestration<br/>(required)"| JobSet["JobSet Controller<br/>v0.10.1"]
    Trainer -->|"operator framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"webhook cert rotation<br/>(required)"| CertController["cert-controller<br/>(OPA) v0.14.0"]
    Trainer -->|"core platform<br/>(required)"| K8s["Kubernetes<br/>1.34+"]

    %% External Dependencies (Optional)
    Trainer -.->|"gang-scheduling<br/>(optional)"| SchedulerPlugins["scheduler-plugins<br/>v0.34.1-devel"]
    Trainer -.->|"gang-scheduling<br/>(optional)"| Volcano["Volcano<br/>v1.13.1"]
    Trainer -.->|"multi-cluster<br/>(optional)"| Kueue["Kueue<br/>(MultiKueue)"]

    %% Internal Platform Dependencies
    RHODSOperator["rhods-operator"] -->|"deploys via kustomize"| Trainer
    Trainer -->|"CRD watch"| JobSetCtrl["JobSet Controller<br/>(reconciles JobSets)"]

    %% Integration Points - Inbound
    Prometheus["Prometheus /<br/>Monitoring Stack"] -->|"scrapes metrics<br/>HTTPS/8443"| Trainer

    %% Integration Points - Outbound
    Trainer -->|"metrics polling<br/>HTTP/28080"| TrainingPods["Training Pods<br/>(RHAI progression)"]
    Trainer -->|"SSH key provisioning"| MPIPods["MPI Pods<br/>(SSH/2222)"]
    Trainer -->|"image resolution"| ImageStreams["OpenShift<br/>ImageStreams"]

    %% CRDs Created/Managed
    Trainer -->|"creates"| JobSetCRD["JobSet CRDs<br/>(jobset.x-k8s.io)"]
    Trainer -->|"creates (RHAI)"| NetworkPolicies["NetworkPolicies<br/>(networking.k8s.io)"]
    Trainer -.->|"creates"| PodGroups["PodGroup CRDs<br/>(scheduling.x-k8s.io /<br/>scheduling.volcano.sh)"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required External
    style JobSet fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff

    %% Optional External
    style SchedulerPlugins fill:#bbb,stroke:#333,color:#333
    style Volcano fill:#bbb,stroke:#333,color:#333
    style Kueue fill:#bbb,stroke:#333,color:#333

    %% Internal Platform
    style RHODSOperator fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff

    %% Runtime Resources
    style TrainingPods fill:#f5a623,stroke:#333,color:#fff
    style MPIPods fill:#f5a623,stroke:#333,color:#fff
    style JobSetCRD fill:#f5a623,stroke:#333,color:#fff
    style NetworkPolicies fill:#f5a623,stroke:#333,color:#fff
    style PodGroups fill:#f5a623,stroke:#333,color:#fff
    style JobSetCtrl fill:#999,stroke:#333,color:#fff
