graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% Required External Dependencies
    Trainer -->|"resource CRUD<br/>HTTPS/443"| K8s["Kubernetes 1.34+"]
    Trainer -->|"workload orchestration<br/>CRD API"| JobSet["JobSet v0.10.1"]
    Trainer -->|"operator framework<br/>library"| ControllerRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"webhook cert rotation<br/>library"| CertController["cert-controller<br/>(OPA) v0.14.0"]

    %% Optional External Dependencies
    Trainer -.->|"gang-scheduling<br/>CRD API"| SchedulerPlugins["scheduler-plugins<br/>v0.34.1-devel<br/>(Coscheduling)"]
    Trainer -.->|"gang-scheduling<br/>CRD API"| Volcano["Volcano<br/>v1.13.1"]

    %% Internal Platform Dependencies
    RhodsOperator["rhods-operator<br/>(platform operator)"] -->|"kustomize deployment"| Trainer
    Trainer -->|"creates JobSet CRs"| JobSetController["JobSet Controller"]
    JobSetController -->|"manages Jobs/Pods"| K8s

    %% Integration Points - Inbound
    Prometheus["Prometheus /<br/>Monitoring Stack"] -->|"HTTPS/8443<br/>PodMonitor scrape"| Trainer
    Kueue["Kueue<br/>(MultiKueue)"] -.->|"managedBy delegation<br/>CRD API"| Trainer

    %% Integration Points - Outbound
    Trainer -->|"HTTP/28080<br/>metrics polling<br/>(RHAI)"| TrainingPods["Training Pods"]
    Trainer -->|"SSH/2222<br/>MPI setup"| TrainingPods
    Trainer -->|"image resolution"| ImageStreams["OpenShift<br/>ImageStreams"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8s fill:#999,stroke:#333,color:#fff
    style JobSet fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff

    %% Optional external
    style SchedulerPlugins fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Volcano fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff

    %% Internal RHOAI
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style JobSetController fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff

    %% Workload
    style TrainingPods fill:#f5a623,stroke:#333
