graph LR
    Trainer["Kubeflow Trainer V2<br/><i>trainer-controller-manager</i>"]

    %% External Dependencies (Required)
    Trainer -->|"workload orchestration<br/>(Required)"| JobSetAPI["JobSet API<br/>jobset.x-k8s.io v1alpha2"]
    Trainer -->|"operator framework<br/>(Required)"| ControllerRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"webhook certs<br/>(Required)"| CertController["cert-controller<br/>v0.14.0"]
    Trainer -->|"target platform<br/>(Required)"| Kubernetes["Kubernetes<br/>1.34+"]

    %% External Dependencies (Optional)
    Trainer -.->|"gang-scheduling<br/>(Optional)"| SchedulerPlugins["scheduler-plugins<br/>scheduling.x-k8s.io v0.34.1"]
    Trainer -.->|"gang-scheduling<br/>(Optional)"| Volcano["Volcano<br/>scheduling.volcano.sh v1.13.1"]

    %% Internal Platform Dependencies
    rhods["rhods-operator"] -->|"deploys via<br/>kustomize"| Trainer
    Trainer -->|"creates JobSet CRs"| JobSetCtrl["JobSet Controller"]
    Trainer -->|"creates PodGroups"| Kueue["Kueue /<br/>scheduler-plugins"]
    Trainer -->|"references images"| TrainingImages["Training Hub Images<br/>CUDA / ROCm / CPU"]

    %% Integration Points (components that interact with Trainer)
    Dashboard["ODH Dashboard"] -.->|"user creates<br/>TrainJobs"| Trainer
    Prometheus["PodMonitor /<br/>Prometheus"] -.->|"scrapes metrics<br/>8443/TCP"| Trainer

    %% Kubernetes Resources
    Trainer -->|"API watches<br/>& creates"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style JobSetAPI fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff
    style Kubernetes fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style SchedulerPlugins fill:#bbb,stroke:#333,color:#333
    style Volcano fill:#bbb,stroke:#333,color:#333

    %% Internal platform deps
    style rhods fill:#7ed321,stroke:#333,color:#fff
    style JobSetCtrl fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style TrainingImages fill:#7ed321,stroke:#333,color:#fff

    %% Integration points
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style K8sAPI fill:#f5a623,stroke:#333
