graph LR
    Trainer["Kubeflow Trainer Operator<br/>(trainer-controller-manager)"]

    %% Required External Dependencies
    Trainer -->|"CRD reconciliation<br/>HTTPS/443"| K8s["Kubernetes 1.34+"]
    Trainer -->|"training orchestration<br/>CRD create/watch"| JobSet["JobSet Controller<br/>v0.10.1<br/>(Required)"]
    Trainer -->|"controller framework"| CR["controller-runtime<br/>v0.22.3<br/>(Required)"]
    Trainer -->|"webhook cert mgmt<br/>auto-rotation"| CertCtrl["cert-controller<br/>v0.14.0<br/>(Required)"]

    %% Optional External Dependencies
    Trainer -.->|"CoScheduling<br/>gang scheduling"| SchedPlugins["Scheduler Plugins<br/>v0.34.1<br/>(Optional)"]
    Trainer -.->|"Volcano<br/>gang scheduling"| Volcano["Volcano<br/>v1.13.1<br/>(Optional)"]
    Trainer -.->|"head-worker topology<br/>(data cache only)"| LWS["LeaderWorkerSet<br/>(Optional)"]

    %% Data Cache Dependencies (Rust)
    subgraph DataCacheDeps["Data Cache Dependencies (Rust, Optional)"]
        Arrow["Apache Arrow<br/>(Arrow Flight gRPC)"]
        Iceberg["Apache Iceberg<br/>(Table metadata)"]
    end
    Trainer -.->|"data cache feature"| DataCacheDeps

    %% Internal Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlay"| Trainer
    Trainer -->|"references images"| TrainingImages["Training Images<br/>(th06-* variants)<br/>CPU/CUDA/ROCm"]
    Trainer -->|"creates"| ImageStreams["ImageStreams<br/>(training-hub-universal-*)<br/>3 streams"]

    %% Integration Points (bidirectional)
    Dashboard["RHOAI Dashboard"] -.->|"UI management"| Trainer
    Kueue["Kueue<br/>(multikueue)"] -.->|"workload mgmt<br/>managedBy field"| Trainer
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrapes metrics<br/>HTTPS/8443"| Trainer

    %% Kubernetes sub-APIs watched
    Trainer -->|"watches"| RuntimeClass["RuntimeClass API<br/>(GPU runtime availability)"]
    Trainer -->|"watches"| LimitRange["LimitRange API<br/>(resource constraints)"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external (dark gray)
    style K8s fill:#666,stroke:#333,color:#fff
    style JobSet fill:#666,stroke:#333,color:#fff
    style CR fill:#666,stroke:#333,color:#fff
    style CertCtrl fill:#666,stroke:#333,color:#fff

    %% Optional external (light gray)
    style SchedPlugins fill:#999,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff

    %% Data cache deps
    style Arrow fill:#00b894,stroke:#333,color:#fff
    style Iceberg fill:#00b894,stroke:#333,color:#fff

    %% Internal ODH (green)
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style TrainingImages fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style Prometheus fill:#f5a623,stroke:#333,color:#333
    style RuntimeClass fill:#f5a623,stroke:#333,color:#333
    style LimitRange fill:#f5a623,stroke:#333,color:#333
