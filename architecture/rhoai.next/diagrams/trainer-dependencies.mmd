graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% External Dependencies (Required)
    Trainer -->|"CRD watches<br/>resource CRUD<br/>443/TCP HTTPS"| K8s["Kubernetes 1.34+"]
    Trainer -->|"creates JobSets<br/>for distributed training"| JobSet["JobSet API<br/>v1alpha2"]
    Trainer -->|"controller framework<br/>reconciliation loops"| ControllerRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"webhook cert<br/>rotation"| CertController["cert-controller<br/>(OPA) v0.14.0"]

    %% Internal Platform Dependencies (Optional)
    Trainer -->|"gang scheduling<br/>PodGroup CRD"| Volcano["Volcano Scheduler"]
    Trainer -->|"gang scheduling<br/>PodGroup CRD"| CoScheduling["Scheduler Plugins<br/>(CoScheduling)"]
    Trainer -->|"workbench images<br/>ImageStreams"| OSRegistry["OpenShift<br/>Image Registry"]

    %% Integration Points (Inbound)
    Prometheus["Prometheus<br/>(PodMonitor)"] -->|"metrics scrape<br/>8443/TCP HTTPS"| Trainer
    Kueue["Kueue<br/>(MultiKueue)"] -->|"workload scheduling<br/>managedBy field"| Trainer

    %% Integration Points (CRD-based)
    Trainer -.->|"watches<br/>RuntimeClass"| RuntimeClassAPI["Kubernetes<br/>RuntimeClass API"]
    Trainer -.->|"watches<br/>LimitRange"| LimitRangeAPI["Kubernetes<br/>LimitRange API"]

    %% Training workload connections
    Trainer -->|"polls metrics<br/>28080/TCP HTTP"| TrainingPods["Training Pods<br/>(rank-0)"]
    TrainingPods -.->|"peer discovery<br/>DNS 53/UDP"| HeadlessSvc["Headless Service<br/>(JobSet DNS)"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8s fill:#999,stroke:#333,color:#fff
    style JobSet fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style Volcano fill:#7ed321,stroke:#333,color:#fff
    style CoScheduling fill:#7ed321,stroke:#333,color:#fff
    style OSRegistry fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff

    %% K8s APIs
    style RuntimeClassAPI fill:#ccc,stroke:#333
    style LimitRangeAPI fill:#ccc,stroke:#333

    %% Workload
    style TrainingPods fill:#f5a623,stroke:#333,color:#fff
    style HeadlessSvc fill:#f5a623,stroke:#333,color:#fff
