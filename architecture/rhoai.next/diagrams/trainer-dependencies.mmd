graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% External Dependencies (Required)
    Trainer -->|"CRD watches<br/>resource CRUD"| K8s["Kubernetes 1.34+"]
    Trainer -->|"creates JobSets<br/>for distributed training"| JobSet["JobSet API<br/>v1alpha2"]
    Trainer -->|"controller framework<br/>reconciliation loops"| CtrlRuntime["controller-runtime<br/>v0.22.3"]
    Trainer -->|"webhook cert<br/>rotation"| CertCtrl["cert-controller<br/>(OPA) v0.14.0"]

    %% Internal Platform Dependencies (Optional)
    Trainer -->|"gang scheduling<br/>PodGroups"| Volcano["Volcano Scheduler"]
    Trainer -.->|"gang scheduling<br/>PodGroups"| CoSched["Scheduler Plugins<br/>(CoScheduling)"]
    Trainer -.->|"Training Hub<br/>ImageStreams"| OSRegistry["OpenShift<br/>Image Registry"]

    %% Integration Points - Components using Trainer
    Kueue["Kueue<br/>(MultiKueue)"] -.->|"managedBy field<br/>scheduling"| Trainer
    Prometheus["Prometheus"] -->|"PodMonitor<br/>8443/TCP HTTPS"| Trainer

    %% Integration Points - Kubernetes APIs watched
    Trainer -->|"watches for<br/>re-queuing"| RuntimeClass["RuntimeClass API"]
    Trainer -->|"watches for<br/>resource eval"| LimitRange["LimitRange API"]

    %% Training Infrastructure
    Trainer -->|"creates for<br/>pod isolation"| NetPol["NetworkPolicy<br/>(RHOAI)"]
    Trainer -->|"headless svc<br/>peer discovery"| K8sDNS["Kubernetes DNS"]
    Trainer -->|"polls metrics<br/>28080/TCP HTTP"| TrainingPods["Training Pods<br/>(rank-0)"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8s fill:#999,stroke:#333,color:#fff
    style JobSet fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style CertCtrl fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style Volcano fill:#7ed321,stroke:#333
    style CoSched fill:#7ed321,stroke:#333
    style OSRegistry fill:#7ed321,stroke:#333

    %% Integration targets
    style Kueue fill:#7ed321,stroke:#333
    style Prometheus fill:#e1d5e7,stroke:#9673a6

    %% Kubernetes APIs
    style RuntimeClass fill:#dae8fc,stroke:#6c8ebf
    style LimitRange fill:#dae8fc,stroke:#6c8ebf

    %% Infrastructure
    style NetPol fill:#ffe6cc,stroke:#d79b00
    style K8sDNS fill:#dae8fc,stroke:#6c8ebf
    style TrainingPods fill:#f5a623,stroke:#333
