graph TB
    subgraph "odh-gitops Repository"
        direction TB

        subgraph KustomizeLayer["Kustomize Layer (OLM/OpenShift)"]
            KComponents["Kustomize Components<br/>12 Operator Installers<br/>(Namespace + OperatorGroup + Subscription)"]
            KConfigs["Kustomize Configurations<br/>Post-install CRs<br/>(Kueue, JobSet, LWS, Kuadrant, Authorino)"]
            KComponents -->|"phase 2"| KConfigs
        end

        subgraph HelmOCP["Helm on OpenShift (rhai-on-openshift-chart v3.4.0)"]
            OCPChart["rhai-on-openshift-chart"]
            Profiles["Profile System<br/>default | rhaii"]
            TriState["Tri-State Dependencies<br/>auto / true / false"]
            DSC["DataScienceCluster CR<br/>13 Components"]
            DSCI["DSCInitialization CR"]
            OCPChart --> Profiles
            OCPChart --> TriState
            OCPChart -->|creates| DSC
            OCPChart -->|creates| DSCI
        end

        subgraph HelmXKS["Helm on XKS (rhai-on-xks-chart v3.5.0-ea.2)"]
            XKSChart["rhai-on-xks-chart"]
            RHAIOp["RHAI Operator Deployment<br/>9443/TCP webhook<br/>8080/TCP metrics<br/>8081/TCP health"]
            CloudMgrs["Cloud Managers<br/>(Azure | CoreWeave | AWS)"]
            PostInstall["Post-Install Hooks<br/>(CRs + Gateway)"]
            XKSChart --> RHAIOp
            XKSChart --> CloudMgrs
            XKSChart --> PostInstall
        end

        subgraph DepCharts["Helm Dependency Charts"]
            CertMgrChart["cert-manager-operator<br/>v1.1.0"]
            GatewayAPIChart["gateway-api<br/>v1.4.0 (6 CRDs)"]
            LWSChart["lws-operator<br/>v1.0.0"]
            SailChart["sail-operator<br/>v1.0.0 (Istio v1.27-v1.28)"]
        end

        subgraph Contracts["CRD Contract Schemas"]
            Schemas["40+ JSON Schemas<br/>(KServe, Platform, Gateway API,<br/>Istio, cert-manager, cloud providers)"]
        end

        subgraph CICD["CI/CD"]
            Tekton["Tekton Pipelines<br/>Ephemeral AWS HyperShift<br/>OCP 4.19+"]
            Scripts["11 Automation Scripts<br/>(install, verify, TLS, cleanup)"]
        end
    end

    %% External targets
    Admin["Administrator<br/>(kubectl / helm / ArgoCD)"]
    OLM["OLM<br/>(Operator Lifecycle Manager)"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    Registry["Container Registries<br/>(registry.redhat.io / quay.io)"]

    %% Relationships
    Admin -->|"kubectl apply -k"| KComponents
    Admin -->|"helm install"| OCPChart
    Admin -->|"helm install"| XKSChart

    OCPChart -->|"OLM Subscriptions"| OLM
    KComponents -->|"OLM Subscriptions"| OLM
    XKSChart -->|"direct deploy (no OLM)"| K8sAPI

    HelmXKS -->|"sub-charts"| DepCharts
    HelmOCP -.->|"optional sub-charts"| DepCharts

    OLM -->|"pulls images"| Registry
    RHAIOp -->|"pulls images"| Registry

    %% Styling
    style KComponents fill:#4a90e2,stroke:#333,color:#fff
    style KConfigs fill:#4a90e2,stroke:#333,color:#fff
    style OCPChart fill:#7ed321,stroke:#333,color:#fff
    style XKSChart fill:#f5a623,stroke:#333,color:#fff
    style CertMgrChart fill:#b8e6ff,stroke:#333
    style GatewayAPIChart fill:#b8e6ff,stroke:#333
    style LWSChart fill:#b8e6ff,stroke:#333
    style SailChart fill:#b8e6ff,stroke:#333
    style Schemas fill:#e8e8e8,stroke:#333
    style Tekton fill:#d5a6e6,stroke:#333
    style Scripts fill:#d5a6e6,stroke:#333
    style Admin fill:#f9f9f9,stroke:#999
    style OLM fill:#f9f9f9,stroke:#999
    style K8sAPI fill:#f9f9f9,stroke:#999
    style Registry fill:#f9f9f9,stroke:#999
