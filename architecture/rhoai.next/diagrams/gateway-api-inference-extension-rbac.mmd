graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{epp-name}<br/>Namespace: {release-namespace}"]
        SA_BBR["{bbr-name}-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["{epp-name}-sa<br/>RoleBinding<br/>Namespace: {release-namespace}"]
        RB_BBR["{bbr-name}-{release}<br/>RoleBinding<br/>Namespace: {release-namespace}"]
        CRB_EPP["{epp-cluster-rbac}<br/>ClusterRoleBinding<br/>(conditional: monitoring enabled)"]
        CRB_BBR["bbr-configmap-reader<br/>ClusterRoleBinding<br/>(conditional: multiNamespace)"]
    end

    subgraph Roles["Roles"]
        R_EPP["{epp-name}-sa<br/>Role<br/>Namespace: {release-namespace}"]
        R_BBR["{bbr-name}-{release}-configmap-reader<br/>Role<br/>Namespace: {release-namespace}"]
        CR_EPP["{epp-cluster-rbac}<br/>ClusterRole<br/>(conditional: monitoring)"]
        CR_BBR["bbr-configmap-reader<br/>ClusterRole<br/>(conditional: multiNamespace)"]
    end

    subgraph EPP_Resources["EPP API Resources"]
        Pods["core<br/>pods<br/>get, watch, list"]
    end

    subgraph EPP_Cluster_Resources["EPP Cluster Resources (monitoring)"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        MetricsNonResource["/metrics<br/>(non-resource URL)<br/>get"]
    end

    subgraph BBR_Resources["BBR API Resources"]
        ConfigMaps_NS["core<br/>configmaps<br/>get, list, watch<br/>(namespace-scoped)"]
    end

    subgraph BBR_Cluster_Resources["BBR Cluster Resources (multiNamespace)"]
        ConfigMaps_Cluster["core<br/>configmaps<br/>get, list, watch<br/>(cluster-wide)"]
    end

    %% EPP bindings
    SA_EPP -->|bound via| RB_EPP
    RB_EPP -->|grants| R_EPP
    R_EPP -->|"get, watch, list"| Pods

    SA_EPP -->|bound via| CRB_EPP
    CRB_EPP -->|grants| CR_EPP
    CR_EPP -->|create| TokenReviews
    CR_EPP -->|create| SubjectAccessReviews
    CR_EPP -->|get| MetricsNonResource

    %% BBR bindings
    SA_BBR -->|bound via| RB_BBR
    RB_BBR -->|grants| R_BBR
    R_BBR -->|"get, list, watch"| ConfigMaps_NS

    SA_BBR -->|bound via| CRB_BBR
    CRB_BBR -->|grants| CR_BBR
    CR_BBR -->|"get, list, watch"| ConfigMaps_Cluster

    %% Secrets
    subgraph Secrets["Secrets"]
        MetricsSecret["inference-gateway-sa-metrics-reader-secret<br/>Type: kubernetes.io/service-account-token<br/>Purpose: Prometheus metrics auth<br/>Auto-Rotate: Yes"]
        TLSCerts["TLS Certs (self-signed at runtime)<br/>Type: tls<br/>Key: 4096-bit RSA, 10-year validity<br/>Auto-Rotate: No"]
    end

    SA_EPP -.->|token| MetricsSecret
    SA_EPP -.->|uses| TLSCerts
    SA_BBR -.->|uses| TLSCerts

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff
    style R_EPP fill:#f5a623,stroke:#333
    style R_BBR fill:#f5a623,stroke:#333
    style CR_EPP fill:#e67e22,stroke:#333,color:#fff
    style CR_BBR fill:#e67e22,stroke:#333,color:#fff
    style RB_EPP fill:#ddd,stroke:#333
    style RB_BBR fill:#ddd,stroke:#333
    style CRB_EPP fill:#ccc,stroke:#333
    style CRB_BBR fill:#ccc,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SubjectAccessReviews fill:#7ed321,stroke:#333
    style MetricsNonResource fill:#7ed321,stroke:#333
    style ConfigMaps_NS fill:#7ed321,stroke:#333
    style ConfigMaps_Cluster fill:#7ed321,stroke:#333
    style MetricsSecret fill:#e74c3c,stroke:#333,color:#fff
    style TLSCerts fill:#e74c3c,stroke:#333,color:#fff
