graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{release}<br/>(EPP ServiceAccount)"]
        SA_BBR["{bbr-name}-{release}<br/>(BBR ServiceAccount)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (Conditional)"]
        CRB_EPP["{release}-inference-extension<br/>ClusterRoleBinding"]
        CRB_BBR["bbr-configmap-reader<br/>ClusterRoleBinding"]
    end

    subgraph ClusterRoles["ClusterRoles (Conditional)"]
        CR_EPP["{release}-inference-extension<br/>ClusterRole"]
        CR_BBR["bbr-configmap-reader<br/>ClusterRole"]
    end

    subgraph RoleBindings["Namespace-scoped RoleBindings"]
        RB_NonSA["{release}-non-sa<br/>RoleBinding"]
        RB_SA["{release}-sa<br/>RoleBinding"]
        RB_Leader["{release}-leader-election<br/>RoleBinding"]
        RB_BBR_CM["{bbr-name}-{release}-configmap-reader<br/>RoleBinding"]
    end

    subgraph Roles["Namespace-scoped Roles"]
        R_NonSA["CRD Read Role"]
        R_SA["Pod Read Role"]
        R_Leader["Leader Election Role"]
        R_BBR_CM["ConfigMap Read Role"]
    end

    subgraph ClusterResources["Cluster-scoped API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        MetricsNonRes["/metrics<br/>(non-resource URL)"]
    end

    subgraph NamespacedResources["Namespaced API Resources"]
        InferencePool["inference.networking.k8s.io<br/>InferencePool"]
        InferenceObjective["inference.networking.x-k8s.io<br/>InferenceObjective"]
        InferenceModelRewrite["inference.networking.x-k8s.io<br/>InferenceModelRewrite"]
        Pods["core<br/>Pods"]
        Leases["coordination.k8s.io<br/>Leases"]
        Events["core<br/>Events"]
        ConfigMaps["core<br/>ConfigMaps"]
    end

    %% EPP ClusterRole path
    SA_EPP -->|bound via| CRB_EPP
    CRB_EPP -->|grants| CR_EPP
    CR_EPP -->|create| TokenReviews
    CR_EPP -->|create| SAR
    CR_EPP -->|get| MetricsNonRes

    %% BBR ClusterRole path
    SA_BBR -->|bound via| CRB_BBR
    CRB_BBR -->|grants| CR_BBR
    CR_BBR -->|"get, list, watch"| ConfigMaps

    %% EPP namespace-scoped paths
    SA_EPP -->|bound via| RB_NonSA
    RB_NonSA -->|grants| R_NonSA
    R_NonSA -->|"get, list, watch"| InferencePool
    R_NonSA -->|"get, list, watch"| InferenceObjective
    R_NonSA -->|"get, list, watch"| InferenceModelRewrite

    SA_EPP -->|bound via| RB_SA
    RB_SA -->|grants| R_SA
    R_SA -->|"get, list, watch"| Pods

    SA_EPP -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader
    R_Leader -->|"get, create,<br/>update, patch, delete"| Leases
    R_Leader -->|"create, patch"| Events

    %% BBR namespace-scoped path
    SA_BBR -->|bound via| RB_BBR_CM
    RB_BBR_CM -->|grants| R_BBR_CM
    R_BBR_CM -->|"get, list, watch"| ConfigMaps

    %% Styling
    style SA_EPP fill:#4a90e2,color:#fff
    style SA_BBR fill:#4a90e2,color:#fff
    style CR_EPP fill:#f5a623,color:#000
    style CR_BBR fill:#f5a623,color:#000
    style R_NonSA fill:#f5a623,color:#000
    style R_SA fill:#f5a623,color:#000
    style R_Leader fill:#f5a623,color:#000
    style R_BBR_CM fill:#f5a623,color:#000
    style InferencePool fill:#7ed321,color:#000
    style InferenceObjective fill:#7ed321,color:#000
    style InferenceModelRewrite fill:#7ed321,color:#000
    style Pods fill:#7ed321,color:#000
    style Leases fill:#7ed321,color:#000
    style Events fill:#7ed321,color:#000
    style ConfigMaps fill:#7ed321,color:#000
    style TokenReviews fill:#7ed321,color:#000
    style SAR fill:#7ed321,color:#000
    style MetricsNonRes fill:#7ed321,color:#000
