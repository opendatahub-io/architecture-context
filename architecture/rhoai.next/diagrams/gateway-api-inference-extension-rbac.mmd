graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{epp-name}<br/>Namespace: {release-namespace}"]
        SA_BBR["{bbr-name}-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["{epp-name}-sa<br/>RoleBinding"]
        RB_BBR["{bbr-name}-{release}<br/>RoleBinding"]
        CRB_EPP["{epp-cluster-rbac}<br/>ClusterRoleBinding<br/>(conditional: monitoring)"]
        CRB_BBR["bbr-configmap-reader<br/>ClusterRoleBinding<br/>(conditional: multiNamespace)"]
    end

    subgraph Roles["Namespace Roles"]
        R_EPP["{epp-name}-sa<br/>Role"]
        R_BBR["{bbr-name}-{release}-<br/>configmap-reader<br/>Role"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_EPP["{epp-cluster-rbac}<br/>ClusterRole<br/>(monitoring)"]
        CR_BBR["bbr-configmap-reader<br/>ClusterRole<br/>(multiNamespace)"]
    end

    subgraph EPP_Resources["EPP API Resources"]
        Pods["core<br/>pods"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccess["authorization.k8s.io<br/>subjectaccessreviews"]
        MetricsNR["/metrics<br/>(non-resource URL)"]
    end

    subgraph BBR_Resources["BBR API Resources"]
        ConfigMaps["core<br/>configmaps"]
        ConfigMapsCluster["core<br/>configmaps<br/>(cluster-wide)"]
    end

    %% EPP bindings
    SA_EPP -->|bound via| RB_EPP
    RB_EPP -->|grants| R_EPP
    R_EPP -->|"get, watch, list"| Pods

    SA_EPP -->|bound via| CRB_EPP
    CRB_EPP -->|grants| CR_EPP
    CR_EPP -->|"create"| TokenReviews
    CR_EPP -->|"create"| SubjectAccess
    CR_EPP -->|"get"| MetricsNR

    %% BBR bindings
    SA_BBR -->|bound via| RB_BBR
    RB_BBR -->|grants| R_BBR
    R_BBR -->|"get, list, watch"| ConfigMaps

    SA_BBR -->|bound via| CRB_BBR
    CRB_BBR -->|grants| CR_BBR
    CR_BBR -->|"get, list, watch"| ConfigMapsCluster

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff
    style RB_EPP fill:#6ab0de,stroke:#333,color:#fff
    style RB_BBR fill:#6ab0de,stroke:#333,color:#fff
    style CRB_EPP fill:#6ab0de,stroke:#333,color:#fff
    style CRB_BBR fill:#6ab0de,stroke:#333,color:#fff
    style R_EPP fill:#f5a623,stroke:#333
    style R_BBR fill:#f5a623,stroke:#333
    style CR_EPP fill:#e67e22,stroke:#333,color:#fff
    style CR_BBR fill:#e67e22,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SubjectAccess fill:#7ed321,stroke:#333
    style MetricsNR fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style ConfigMapsCluster fill:#7ed321,stroke:#333
