graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{epp-name}<br/>Namespace: {release-namespace}"]
        SA_BBR["{bbr-name}-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["{epp-name}-sa<br/>RoleBinding<br/>Namespace: {release-namespace}"]
        RB_BBR["{bbr-name}-{release}<br/>RoleBinding<br/>Namespace: {release-namespace}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (conditional: monitoring)"]
        CRB_EPP["{epp-cluster-rbac}<br/>ClusterRoleBinding"]
    end

    subgraph ClusterRoleBindings_BBR["ClusterRole Bindings (conditional: multiNamespace)"]
        CRB_BBR["bbr-configmap-reader<br/>ClusterRoleBinding"]
    end

    subgraph Roles["Namespace Roles"]
        Role_EPP["{epp-name}-sa<br/>Role<br/>Namespace: {release-namespace}"]
        Role_BBR["{bbr-name}-{release}-configmap-reader<br/>Role<br/>Namespace: {release-namespace}"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_EPP["{epp-cluster-rbac}<br/>ClusterRole<br/>(conditional: monitoring)"]
        CR_BBR["bbr-configmap-reader<br/>ClusterRole<br/>(conditional: multiNamespace)"]
    end

    subgraph EPP_Resources["EPP API Resources"]
        Pods["core/v1<br/>Pods"]
    end

    subgraph EPP_ClusterResources["EPP Cluster API Resources (monitoring)"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>SubjectAccessReviews"]
        MetricsEndpoint["/metrics<br/>(non-resource URL)"]
    end

    subgraph BBR_Resources["BBR API Resources"]
        ConfigMaps["core/v1<br/>ConfigMaps"]
    end

    %% EPP bindings
    SA_EPP -->|"bound via"| RB_EPP
    RB_EPP -->|"grants"| Role_EPP
    Role_EPP -->|"get, watch, list"| Pods

    %% EPP cluster bindings (conditional)
    SA_EPP -->|"bound via"| CRB_EPP
    CRB_EPP -->|"grants"| CR_EPP
    CR_EPP -->|"create"| TokenReviews
    CR_EPP -->|"create"| SubjectAccessReviews
    CR_EPP -->|"get"| MetricsEndpoint

    %% BBR bindings
    SA_BBR -->|"bound via"| RB_BBR
    RB_BBR -->|"grants"| Role_BBR
    Role_BBR -->|"get, list, watch"| ConfigMaps

    %% BBR cluster bindings (conditional)
    SA_BBR -->|"bound via"| CRB_BBR
    CRB_BBR -->|"grants"| CR_BBR
    CR_BBR -->|"get, list, watch"| ConfigMaps

    subgraph Secrets["Secrets"]
        MetricsSecret["inference-gateway-sa-metrics-reader-secret<br/>Type: kubernetes.io/service-account-token<br/>Purpose: Prometheus metrics auth<br/>Auto-Rotate: Yes"]
        TLSCerts["TLS Certificates<br/>Type: tls (self-signed)<br/>4096-bit RSA, 10-year validity<br/>Auto-Rotate: No"]
    end

    SA_EPP -.->|"token"| MetricsSecret
    SA_EPP -.->|"mounts"| TLSCerts
    SA_BBR -.->|"mounts"| TLSCerts

    %% Styling
    style SA_EPP fill:#4a90e2,color:#fff
    style SA_BBR fill:#4a90e2,color:#fff
    style Role_EPP fill:#f5a623,color:#fff
    style Role_BBR fill:#f5a623,color:#fff
    style CR_EPP fill:#e67e22,color:#fff
    style CR_BBR fill:#e67e22,color:#fff
    style Pods fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SubjectAccessReviews fill:#7ed321,color:#fff
    style MetricsEndpoint fill:#7ed321,color:#fff
    style MetricsSecret fill:#e74c3c,color:#fff
    style TLSCerts fill:#e74c3c,color:#fff
