graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{release}-inference-extension<br/>Namespace: {release-ns}"]
        SA_BBR["body-based-router-{release}<br/>Namespace: {release-ns}"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_EPP["{release}-epp-cluster-rbac<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace: {release-ns})"]
        RB_Pods["{release}-sa<br/>(RoleBinding)"]
        RB_Leader["{release}-leader-election-binding<br/>(RoleBinding)"]
        RB_BBR["bbr-{release}-configmap-reader<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_EPP["{release}-epp-cluster-rbac<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (Namespace: {release-ns})"]
        R_Pods["{release}-sa<br/>(Role)"]
        R_Leader["{release}-leader-election<br/>(Role)"]
        R_BBR["bbr-{release}-configmap-reader<br/>(Role)"]
    end

    subgraph ClusterResources["Cluster-Scoped API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
        MetricsNonResource["(non-resource)<br/>/metrics<br/>Verbs: get"]
    end

    subgraph NamespacedResources["Namespaced API Resources"]
        Pods["core<br/>pods<br/>Verbs: get, list, watch"]
        Leases["coordination.k8s.io<br/>leases<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        Events["core<br/>events<br/>Verbs: create, patch"]
        ConfigMaps["core<br/>configmaps<br/>Verbs: get, list, watch"]
    end

    %% EPP ServiceAccount bindings
    SA_EPP -->|bound via| CRB_EPP
    CRB_EPP -->|grants| CR_EPP
    CR_EPP -->|access| TokenReviews
    CR_EPP -->|access| SubjectAccessReviews
    CR_EPP -->|access| MetricsNonResource

    SA_EPP -->|bound via| RB_Pods
    RB_Pods -->|grants| R_Pods
    R_Pods -->|access| Pods

    SA_EPP -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader
    R_Leader -->|access| Leases
    R_Leader -->|access| Events

    %% BBR ServiceAccount bindings
    SA_BBR -->|bound via| RB_BBR
    RB_BBR -->|grants| R_BBR
    R_BBR -->|access| ConfigMaps

    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff
    style CR_EPP fill:#f5a623,stroke:#333
    style R_Pods fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_BBR fill:#f5a623,stroke:#333
    style CRB_EPP fill:#e8e8e8,stroke:#333
    style RB_Pods fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style RB_BBR fill:#e8e8e8,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SubjectAccessReviews fill:#7ed321,stroke:#333
    style MetricsNonResource fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
