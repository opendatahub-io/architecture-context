graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["ServiceAccount<br/>{release}-epp"]
        SA_BBR["ServiceAccount<br/>bbr-{release}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["RoleBinding<br/>{release}-epp"]
        RB_BBR["RoleBinding<br/>bbr-{release}"]
    end

    subgraph Roles["Roles"]
        Role_EPP["Role<br/>{release}-epp"]
        Role_BBR["Role / ClusterRole<br/>bbr-configmap-reader"]
    end

    subgraph InferenceResources["Inference API Resources"]
        InferencePool["inference.networking.k8s.io<br/>InferencePool"]
        InferenceObjective["inference.networking.x-k8s.io<br/>InferenceObjective"]
        InferenceModelRewrite["inference.networking.x-k8s.io<br/>InferenceModelRewrite"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>Pods"]
        ConfigMaps_EPP["core<br/>ConfigMaps (EPP)"]
        Events["core<br/>Events"]
        ConfigMaps_BBR["core<br/>ConfigMaps (BBR)"]
    end

    subgraph CoordinationResources["Coordination API Resources"]
        Leases["coordination.k8s.io<br/>Leases"]
    end

    %% EPP bindings
    SA_EPP -->|"bound via"| RB_EPP
    RB_EPP -->|"grants"| Role_EPP

    %% EPP permissions
    Role_EPP -->|"get, list, watch"| InferencePool
    Role_EPP -->|"get, list, watch"| InferenceObjective
    Role_EPP -->|"get, list, watch"| InferenceModelRewrite
    Role_EPP -->|"get, list, watch"| Pods
    Role_EPP -->|"get, list, watch"| ConfigMaps_EPP
    Role_EPP -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Leases
    Role_EPP -->|"create, patch"| Events

    %% BBR bindings
    SA_BBR -->|"bound via"| RB_BBR
    RB_BBR -->|"grants"| Role_BBR

    %% BBR permissions
    Role_BBR -->|"get, list, watch"| ConfigMaps_BBR

    %% Styling
    style SA_EPP fill:#4a90e2,color:#fff
    style SA_BBR fill:#4a90e2,color:#fff
    style RB_EPP fill:#5dade2,color:#fff
    style RB_BBR fill:#5dade2,color:#fff
    style Role_EPP fill:#f5a623,color:#fff
    style Role_BBR fill:#f5a623,color:#fff
    style InferencePool fill:#7ed321
    style InferenceObjective fill:#7ed321
    style InferenceModelRewrite fill:#7ed321
    style Pods fill:#82e0aa
    style ConfigMaps_EPP fill:#82e0aa
    style Events fill:#82e0aa
    style ConfigMaps_BBR fill:#82e0aa
    style Leases fill:#f9e79f
