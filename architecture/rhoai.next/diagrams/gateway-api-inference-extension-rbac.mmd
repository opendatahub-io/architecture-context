graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["{release-name}<br/>Namespace: {namespace}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (conditional)"]
        CRB_Metrics["{release-name}-metrics-reader<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_SA["{release-name}-sa<br/>(RoleBinding)"]
        RB_LE["{release-name}-leader-election-binding<br/>(RoleBinding, conditional)"]
    end

    subgraph ClusterRoles["ClusterRoles (conditional)"]
        CR_Metrics["{release-name}-metrics-reader<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_SA["{release-name}-sa<br/>(Role)"]
        R_LE["{release-name}-leader-election<br/>(Role, conditional)"]
    end

    subgraph ClusterRoleResources["ClusterRole Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        MetricsNR["/metrics<br/>(non-resource URL)"]
    end

    subgraph RoleResources["Namespace-Scoped Resources"]
        Pods["core<br/>Pods"]
        ConfigMaps["core<br/>ConfigMaps"]
        Leases["coordination.k8s.io<br/>Leases"]
        Events["core<br/>Events"]
    end

    subgraph CRDResources["CRD Resources (via controller-runtime scheme)"]
        InferencePool["inference.networking.k8s.io<br/>InferencePool"]
        InferenceObjective["inference.networking.x-k8s.io<br/>InferenceObjective"]
        InferenceModelRewrite["inference.networking.x-k8s.io<br/>InferenceModelRewrite"]
        InferencePoolImport["inference.networking.x-k8s.io<br/>InferencePoolImport"]
    end

    %% ServiceAccount → Bindings
    SA -->|"bound via"| CRB_Metrics
    SA -->|"bound via"| RB_SA
    SA -->|"bound via"| RB_LE

    %% Bindings → Roles
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_SA -->|"grants"| R_SA
    RB_LE -->|"grants"| R_LE

    %% ClusterRole → Resources
    CR_Metrics -->|"create"| TokenReviews
    CR_Metrics -->|"create"| SAR
    CR_Metrics -->|"get"| MetricsNR

    %% Role → Resources
    R_SA -->|"get, watch, list"| Pods
    R_SA -->|"get, watch, list"| ConfigMaps
    R_LE -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Leases
    R_LE -->|"create, patch"| Events

    %% CRD access (scheme-based, implicit full CRUD)
    SA -.->|"scheme registration<br/>(full CRUD)"| InferencePool
    SA -.->|"scheme registration<br/>(full CRUD)"| InferenceObjective
    SA -.->|"scheme registration<br/>(full CRUD)"| InferenceModelRewrite
    SA -.->|"scheme registration<br/>(full CRUD)"| InferencePoolImport

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR_Metrics fill:#f5a623,stroke:#333
    style R_SA fill:#f5a623,stroke:#333
    style R_LE fill:#f5a623,stroke:#333
    style CRB_Metrics fill:#e8c8a0,stroke:#333
    style RB_SA fill:#e8c8a0,stroke:#333
    style RB_LE fill:#e8c8a0,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style MetricsNR fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style InferencePool fill:#9b59b6,stroke:#333,color:#fff
    style InferenceObjective fill:#9b59b6,stroke:#333,color:#fff
    style InferenceModelRewrite fill:#9b59b6,stroke:#333,color:#fff
    style InferencePoolImport fill:#9b59b6,stroke:#333,color:#fff
