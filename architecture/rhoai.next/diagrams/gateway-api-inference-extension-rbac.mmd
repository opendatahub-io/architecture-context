graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["{release}-inference-extension"]
        SA_BBR["body-based-router-{release}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_EPP["{release}-epp-cluster-rbac<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Pods["{release}-sa<br/>(RoleBinding)"]
        RB_Leader["{release}-leader-election-binding<br/>(RoleBinding)"]
        RB_BBR["bbr-{release}-configmap-reader<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_EPP["{release}-epp-cluster-rbac"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Pods["{release}-sa"]
        R_Leader["{release}-leader-election"]
        R_BBR["bbr-{release}-configmap-reader"]
    end

    subgraph API_Resources["API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
        MetricsURL["/metrics<br/>(non-resource URL)<br/><i>get</i>"]
        Pods["core<br/>pods<br/><i>get, list, watch</i>"]
        Leases["coordination.k8s.io<br/>leases<br/><i>get, create, update, delete</i>"]
        Events["core<br/>events<br/><i>create, patch</i>"]
        ConfigMaps["core<br/>configmaps<br/><i>get, list, watch</i>"]
    end

    %% EPP Service Account bindings
    SA_EPP -->|bound via| CRB_EPP
    SA_EPP -->|bound via| RB_Pods
    SA_EPP -->|bound via| RB_Leader

    CRB_EPP -->|grants| CR_EPP
    RB_Pods -->|grants| R_Pods
    RB_Leader -->|grants| R_Leader

    %% ClusterRole permissions
    CR_EPP -->|"create"| TokenReviews
    CR_EPP -->|"create"| SAR
    CR_EPP -->|"get"| MetricsURL

    %% Role permissions
    R_Pods -->|"get, list, watch"| Pods
    R_Leader -->|"get, create,<br/>update, delete"| Leases
    R_Leader -->|"create, patch"| Events

    %% BBR Service Account bindings
    SA_BBR -->|bound via| RB_BBR
    RB_BBR -->|grants| R_BBR
    R_BBR -->|"get, list, watch"| ConfigMaps

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff
    style CR_EPP fill:#f5a623,stroke:#333
    style R_Pods fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_BBR fill:#f5a623,stroke:#333
    style CRB_EPP fill:#e8e8e8,stroke:#333
    style RB_Pods fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style RB_BBR fill:#e8e8e8,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style MetricsURL fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
