graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["llamastack-garak-distribution-sa<br/><i>Namespace: tai-garak-lls</i>"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB1["lsd-garak-dspa-api-access<br/><i>Namespace: tai-garak-lls</i>"]
        RB2["lsd-garak-pipeline-management<br/><i>Namespace: tai-garak-lls</i>"]
    end

    subgraph Roles["Roles"]
        R1["lsd-garak-dspa-api-access<br/><i>Custom Role</i>"]
        R2["ds-pipeline-dspa<br/><i>Predefined by DSP Operator</i>"]
    end

    subgraph APIResources["API Resources"]
        direction TB
        DSPA["datasciencepipelinesapplications.<br/>opendatahub.io<br/><b>datasciencepipelinesapplications/api</b>"]
        PipelineRes["Pipeline Resources<br/><i>(managed by ds-pipeline-dspa role)</i>"]
    end

    subgraph Secrets["Secrets Accessed"]
        direction TB
        InferenceSecret["llama-stack-inference-model-secret<br/><i>Opaque</i><br/>Key: VLLM_API_TOKEN"]
        PostgresSecret["postgres-secret<br/><i>Opaque</i><br/>Keys: POSTGRES_DB, POSTGRES_USER,<br/>POSTGRES_PASSWORD"]
        ModelAuth["model-auth<br/><i>Opaque</i><br/>Mounted: /mnt/model-auth<br/>Per-role API keys:<br/>TARGET, SDG, JUDGE,<br/>ATTACKER, EVALUATOR"]
        DataConnSecret["Data Connection Secret<br/><i>Opaque</i><br/>Keys: access_key, secret_key,<br/>region, bucket, endpoint"]
    end

    subgraph ConfigMaps["ConfigMaps Read"]
        direction TB
        GarakConfig["llamastack-garak-config<br/>Keys: POSTGRES_HOST, POSTGRES_PORT,<br/>VLLM_URL, INFERENCE_MODEL,<br/>KUBEFLOW_PIPELINES_ENDPOINT,<br/>KUBEFLOW_NAMESPACE,<br/>KUBEFLOW_GARAK_BASE_IMAGE,<br/>KUBEFLOW_LLAMA_STACK_URL"]
        TrustyAIConfig["trustyai-service-operator-config<br/><i>Read from candidate namespaces</i><br/>Key: Garak container image override"]
    end

    %% RBAC Flow
    SA -->|"bound via"| RB1
    SA -->|"bound via"| RB2
    RB1 -->|"grants"| R1
    RB2 -->|"grants"| R2
    R1 -->|"get, create"| DSPA
    R2 -->|"pipeline management verbs"| PipelineRes

    %% Secret Access
    SA -.->|"envFrom"| InferenceSecret
    SA -.->|"envFrom"| PostgresSecret
    SA -.->|"volume mount"| ModelAuth
    SA -.->|"envFrom"| DataConnSecret

    %% ConfigMap Access
    SA -.->|"env valueFrom"| GarakConfig
    SA -.->|"K8s API read"| TrustyAIConfig

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style R1 fill:#f5a623,stroke:#333
    style R2 fill:#f5a623,stroke:#333
    style RB1 fill:#e8e8e8,stroke:#333
    style RB2 fill:#e8e8e8,stroke:#333
    style DSPA fill:#7ed321,stroke:#333
    style PipelineRes fill:#7ed321,stroke:#333
    style InferenceSecret fill:#e74c3c,stroke:#333,color:#fff
    style PostgresSecret fill:#e74c3c,stroke:#333,color:#fff
    style ModelAuth fill:#e74c3c,stroke:#333,color:#fff
    style DataConnSecret fill:#e74c3c,stroke:#333,color:#fff
    style GarakConfig fill:#9b59b6,stroke:#333,color:#fff
    style TrustyAIConfig fill:#9b59b6,stroke:#333,color:#fff
