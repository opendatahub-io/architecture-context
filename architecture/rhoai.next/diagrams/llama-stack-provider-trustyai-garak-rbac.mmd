graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["llamastack-garak-distribution-sa<br/>Namespace: tai-garak-lls"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB1["lsd-garak-dspa-api-access<br/>Namespace: tai-garak-lls"]
        RB2["lsd-garak-pipeline-management<br/>Namespace: tai-garak-lls"]
    end

    subgraph Roles["Roles"]
        R1["lsd-garak-dspa-api-access<br/>(Custom Role)"]
        R2["ds-pipeline-dspa<br/>(Pre-existing DSP Role)"]
    end

    subgraph APIResources["API Resources"]
        DSPA["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications/api"]
        DSPPipeline["DSP Pipeline Resources<br/>(via ds-pipeline-dspa role)"]
    end

    subgraph Secrets["Kubernetes Secrets"]
        PostgresSecret["postgres-secret<br/>Type: Opaque<br/>PostgreSQL credentials<br/>Manual, No rotation"]
        InferenceSecret["llama-stack-inference-<br/>model-secret<br/>Type: Opaque<br/>vLLM API token<br/>Manual, No rotation"]
        ModelAuth["model-auth<br/>Type: Opaque<br/>Multi-key:<br/>api-key, SDG_API_KEY,<br/>JUDGE_API_KEY,<br/>ATTACKER_API_KEY,<br/>EVALUATOR_API_KEY<br/>Manual, No rotation"]
        S3Secret["S3 Data Connection<br/>Type: Opaque<br/>ACCESS_KEY_ID,<br/>SECRET_ACCESS_KEY,<br/>ENDPOINT, BUCKET, REGION<br/>RHOAI Data Connection"]
    end

    subgraph SecretUsage["Secret Injection Methods"]
        EnvInjection["kubernetes.use_secret_as_env<br/>(KFP pipeline pods)"]
        VolumeMount["Volume Mount<br/>/mnt/model-auth<br/>(optional=true)"]
        KeyResolution["API Key Resolution Chain:<br/>1. Role-specific env var<br/>2. Role-specific file<br/>3. Generic env var<br/>4. Generic file<br/>5. DUMMY fallback"]
    end

    %% RBAC flows
    SA -->|"bound via"| RB1
    SA -->|"bound via"| RB2
    RB1 -->|"grants"| R1
    RB2 -->|"grants"| R2
    R1 -->|"get, create"| DSPA
    R2 -->|"pipeline management"| DSPPipeline

    %% Secret injection flows
    ModelAuth -->|"injected as"| EnvInjection
    ModelAuth -->|"mounted at"| VolumeMount
    VolumeMount -->|"resolved by"| KeyResolution
    InferenceSecret -->|"injected as"| EnvInjection
    S3Secret -->|"injected as"| EnvInjection

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB1 fill:#dae8fc,stroke:#6c8ebf
    style RB2 fill:#dae8fc,stroke:#6c8ebf
    style R1 fill:#f5a623,stroke:#333,color:#fff
    style R2 fill:#f5a623,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style DSPPipeline fill:#7ed321,stroke:#333,color:#fff
    style PostgresSecret fill:#f8cecc,stroke:#b85450
    style InferenceSecret fill:#f8cecc,stroke:#b85450
    style ModelAuth fill:#f8cecc,stroke:#b85450
    style S3Secret fill:#f8cecc,stroke:#b85450
    style EnvInjection fill:#e1d5e7,stroke:#9673a6
    style VolumeMount fill:#e1d5e7,stroke:#9673a6
    style KeyResolution fill:#e1d5e7,stroke:#9673a6
