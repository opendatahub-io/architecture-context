graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_LSD["{lsd-name}-sa<br/>Llama Stack Distribution SA"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_DSPA["lsd-garak-dspa-api-access<br/>RoleBinding"]
        RB_Pipeline["lsd-garak-pipeline-management<br/>RoleBinding"]
    end

    subgraph Roles["Roles"]
        Role_DSPA["lsd-garak-dspa-api-access<br/>Role"]
        Role_Pipeline["ds-pipeline-{dspa-name}<br/>Role (pre-existing)"]
        Role_Secret["secret-reader<br/>Role (documented in code)"]
    end

    subgraph APIResources_DSPA["API Resources: DSPA"]
        DSPA_API["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications/api"]
    end

    subgraph APIResources_Pipeline["API Resources: Pipeline Management"]
        Pipeline_Resources["datasciencepipelinesapplications<br/>.opendatahub.io<br/>+ core resources<br/>(pipeline CRUD)"]
    end

    subgraph APIResources_Secrets["API Resources: Secrets"]
        Secrets["core (v1)<br/>secrets"]
    end

    subgraph SecretsMounted["Secrets (Volume Mounts)"]
        ModelAuth["model-auth<br/>/mnt/model-auth<br/>Keys: api-key, SDG_API_KEY,<br/>JUDGE_API_KEY, ATTACKER_API_KEY,<br/>EVALUATOR_API_KEY"]
        InferenceSecret["llama-stack-inference-<br/>model-secret<br/>vLLM API token"]
        DataConnection["Data Connection Secret<br/>AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT,<br/>AWS_S3_BUCKET"]
        KFCreds["kubeflow-credentials<br/>(optional)<br/>KFP API token"]
    end

    subgraph ConfigMaps["ConfigMaps"]
        TrustyAICM["trustyai-service-operator-config<br/>Key: garak-provider-image"]
        EvalHubCM["Eval-Hub JobSpec ConfigMap<br/>Mount: /meta/job.json"]
    end

    %% SA to RoleBindings
    SA_LSD -->|"bound via"| RB_DSPA
    SA_LSD -->|"bound via"| RB_Pipeline

    %% RoleBindings to Roles
    RB_DSPA -->|"grants"| Role_DSPA
    RB_Pipeline -->|"grants"| Role_Pipeline

    %% Roles to API Resources
    Role_DSPA -->|"get, create"| DSPA_API
    Role_Pipeline -->|"pipeline CRUD"| Pipeline_Resources
    Role_Secret -->|"get"| Secrets

    %% Secret mounts
    SA_LSD -.->|"mounts"| ModelAuth
    SA_LSD -.->|"mounts"| InferenceSecret
    SA_LSD -.->|"mounts"| DataConnection
    SA_LSD -.->|"mounts (optional)"| KFCreds

    %% ConfigMap reads
    SA_LSD -.->|"reads"| TrustyAICM
    SA_LSD -.->|"reads"| EvalHubCM

    %% Styling
    style SA_LSD fill:#4a90e2,color:#fff
    style RB_DSPA fill:#90caf9,stroke:#1565c0
    style RB_Pipeline fill:#90caf9,stroke:#1565c0
    style Role_DSPA fill:#f5a623,color:#fff
    style Role_Pipeline fill:#f5a623,color:#fff
    style Role_Secret fill:#f5a623,color:#fff
    style DSPA_API fill:#7ed321,color:#fff
    style Pipeline_Resources fill:#7ed321,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style ModelAuth fill:#ef5350,color:#fff
    style InferenceSecret fill:#ef5350,color:#fff
    style DataConnection fill:#ef5350,color:#fff
    style KFCreds fill:#ef5350,color:#fff
    style TrustyAICM fill:#ab47bc,color:#fff
    style EvalHubCM fill:#ab47bc,color:#fff
