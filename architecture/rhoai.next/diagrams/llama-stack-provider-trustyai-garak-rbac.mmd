graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_LSD["{lsd-name}-sa<br/>Llama Stack Distribution SA"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_DSPA["lsd-garak-dspa-api-access<br/>(RoleBinding)"]
        RB_Pipeline["lsd-garak-pipeline-management<br/>(RoleBinding)"]
    end

    subgraph Roles["Roles"]
        Role_DSPA["lsd-garak-dspa-api-access<br/>(Role)"]
        Role_Pipeline["ds-pipeline-{dspa-name}<br/>(Role, pre-existing)"]
        Role_Secret["secret-reader<br/>(Role, documented in code)"]
    end

    subgraph Resources_DSPA["DSPA API Resources"]
        DSPA_API["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications/api"]
    end

    subgraph Resources_Pipeline["Pipeline Resources"]
        PipelineRuns["Pipeline management<br/>(runs, experiments, pipelines)"]
    end

    subgraph Resources_Secrets["Secret Resources"]
        Secrets["core (v1)<br/>secrets"]
    end

    subgraph MountedSecrets["Secrets (Volume Mounts)"]
        ModelAuth["model-auth<br/>Mount: /mnt/model-auth<br/>Keys: api-key, SDG_API_KEY,<br/>JUDGE_API_KEY, ATTACKER_API_KEY,<br/>EVALUATOR_API_KEY"]
        InferenceSecret["llama-stack-inference-<br/>model-secret<br/>vLLM API token"]
        DataConnection["Data Connection Secret<br/>AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT,<br/>AWS_S3_BUCKET"]
        KFPCreds["kubeflow-credentials<br/>(optional)<br/>KFP API token"]
    end

    %% SA to RoleBindings
    SA_LSD -->|bound via| RB_DSPA
    SA_LSD -->|bound via| RB_Pipeline

    %% RoleBindings to Roles
    RB_DSPA -->|grants| Role_DSPA
    RB_Pipeline -->|grants| Role_Pipeline

    %% Roles to Resources
    Role_DSPA -->|"get, create"| DSPA_API
    Role_Pipeline -->|"pipeline management"| PipelineRuns
    Role_Secret -->|"get"| Secrets

    %% Secret access
    SA_LSD -.->|"volume mount"| ModelAuth
    SA_LSD -.->|"env / volume"| InferenceSecret
    SA_LSD -.->|"env / volume"| DataConnection
    SA_LSD -.->|"env / volume"| KFPCreds

    %% Redaction note
    Redaction["🔒 Secret Redaction<br/>redact_api_keys() before upload<br/>Placeholders: DUMMY, __FROM_ENV__, ***<br/>Secrets never persist in S3/OCI/Files API"]

    %% Styling
    style SA_LSD fill:#4a90e2,color:#fff
    style RB_DSPA fill:#9b59b6,color:#fff
    style RB_Pipeline fill:#9b59b6,color:#fff
    style Role_DSPA fill:#f5a623,color:#fff
    style Role_Pipeline fill:#f5a623,color:#fff
    style Role_Secret fill:#f5a623,color:#fff
    style DSPA_API fill:#7ed321,color:#fff
    style PipelineRuns fill:#7ed321,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style ModelAuth fill:#e74c3c,color:#fff
    style InferenceSecret fill:#e74c3c,color:#fff
    style DataConnection fill:#e74c3c,color:#fff
    style KFPCreds fill:#e74c3c,color:#fff
    style Redaction fill:#f9f9f9,stroke:#999,stroke-dasharray:5
