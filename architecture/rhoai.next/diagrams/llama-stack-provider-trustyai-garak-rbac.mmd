graph TD
    subgraph "Job Pod Identity"
        SA["Job Service Account<br/>(configured by eval-hub)"]
    end

    subgraph "Runtime RBAC Requirements"
        direction TB

        subgraph "Documented (not provisioned by this repo)"
            SecretReader["Role: secret-reader<br/>(target namespace)"]
        end
    end

    subgraph "API Resources Accessed"
        direction TB

        subgraph "Kubernetes Core API"
            Secrets["core/v1<br/>Secrets"]
            ConfigMaps["core/v1<br/>ConfigMaps"]
        end

        subgraph "External APIs (non-K8s RBAC)"
            S3API["S3 API<br/>Auth: AWS IAM<br/>(Data Connection secret)"]
            KFPAPI["KFP API<br/>Auth: SA Token<br/>(/var/run/secrets/.../token)"]
            ModelAPI["Model Endpoints<br/>Auth: Bearer Token<br/>(/mnt/model-auth)"]
            OCIAPI["OCI Registry<br/>Auth: Registry creds"]
            MLflowAPI["MLflow API<br/>Auth: Bearer Token"]
        end
    end

    subgraph "Secrets Consumed"
        direction TB
        ModelAuth["model-auth (Opaque)<br/>Mount: /mnt/model-auth<br/>Keys: API keys per role<br/>Optional: True"]
        DataConn["Data Connection (Opaque)<br/>Injection: env vars<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT,<br/>AWS_S3_BUCKET,<br/>AWS_DEFAULT_REGION"]
    end

    subgraph "Key Resolution Order"
        direction TB
        Resolution["1. Role-specific env var<br/>2. Generic fallback env var<br/>3. Volume-mounted secret file<br/>4. 'DUMMY' default"]
    end

    %% Bindings
    SA -->|"needs"| SecretReader
    SecretReader -->|"get"| Secrets

    SA -->|"reads (ConfigMap mount)"| ConfigMaps

    SA -->|"credentials from"| ModelAuth
    SA -->|"credentials from"| DataConn

    ModelAuth -->|"provides auth for"| ModelAPI
    DataConn -->|"provides auth for"| S3API
    SA -->|"SA token for"| KFPAPI

    ModelAuth -.->|"key resolution"| Resolution

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style SecretReader fill:#f5a623,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style ModelAuth fill:#e74c3c,stroke:#333,color:#fff
    style DataConn fill:#e74c3c,stroke:#333,color:#fff
    style S3API fill:#f5a623,stroke:#333
    style KFPAPI fill:#f5a623,stroke:#333
    style ModelAPI fill:#f5a623,stroke:#333
    style OCIAPI fill:#f5a623,stroke:#333
    style MLflowAPI fill:#f5a623,stroke:#333
    style Resolution fill:#dae8fc,stroke:#6c8ebf
