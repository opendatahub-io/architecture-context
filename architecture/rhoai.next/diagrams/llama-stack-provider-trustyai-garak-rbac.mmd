graph TD
    subgraph "Service Accounts"
        SA["eval-hub Job ServiceAccount<br/>(provisioned by eval-hub)"]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB["RoleBinding<br/>(provisioned externally)"]
    end

    subgraph "Roles (Namespace-scoped)"
        SecretReader["Role: secret-reader<br/>(documented requirement)"]
    end

    subgraph "API Resources Accessed"
        direction TB
        Secrets["core / v1<br/>Secrets"]
        ConfigMaps["core / v1<br/>ConfigMaps<br/>(trustyai-service-operator-config)"]
    end

    subgraph "Secrets Consumed"
        direction TB
        ModelAuth["Secret: model-auth<br/>Keys: api-key, SDG_API_KEY,<br/>JUDGE_API_KEY, ATTACKER_API_KEY,<br/>EVALUATOR_API_KEY"]
        DataConn["Secret: Data Connection (S3)<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT,<br/>AWS_S3_BUCKET,<br/>AWS_DEFAULT_REGION"]
    end

    subgraph "Volume Mounts"
        direction TB
        MntModelAuth["/mnt/model-auth<br/>(Secret volume mount)"]
        VarRunSecrets["/var/run/secrets/model/<br/>(Secret volume mount)"]
        SAToken["/var/run/secrets/kubernetes.io/<br/>serviceaccount/token<br/>(SA token auto-mount)"]
    end

    subgraph "API Key Resolution Cascade"
        direction TB
        Step1["1. Role-specific env var<br/>(e.g., JUDGE_API_KEY)"]
        Step2["2. Role-specific file<br/>(/mnt/model-auth/JUDGE_API_KEY)"]
        Step3["3. Generic env var<br/>(api-key)"]
        Step4["4. Generic file<br/>(/mnt/model-auth/api-key)"]
        Step5["5. Legacy file<br/>(/var/run/secrets/model/api-key)"]
        Step6["6. Fallback: DUMMY"]
        Step1 --> Step2 --> Step3 --> Step4 --> Step5 --> Step6
    end

    %% Bindings
    SA -->|"bound via"| RB
    RB -->|"grants"| SecretReader
    SecretReader -->|"get"| Secrets

    %% Secret consumption
    Secrets -->|"contains"| ModelAuth
    Secrets -->|"contains"| DataConn

    %% Mount paths
    ModelAuth -->|"mounted at"| MntModelAuth
    ModelAuth -->|"mounted at"| VarRunSecrets
    DataConn -->|"injected via"| SA

    %% SA token
    SA -->|"auto-mounted"| SAToken

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style SecretReader fill:#f5a623,color:#fff
    style RB fill:#e8e8e8
    style Secrets fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style ModelAuth fill:#f8cecc,stroke:#b85450
    style DataConn fill:#f8cecc,stroke:#b85450
    style MntModelAuth fill:#dae8fc,stroke:#6c8ebf
    style VarRunSecrets fill:#dae8fc,stroke:#6c8ebf
    style SAToken fill:#dae8fc,stroke:#6c8ebf
    style Step1 fill:#fff2cc,stroke:#d6b656
    style Step2 fill:#fff2cc,stroke:#d6b656
    style Step3 fill:#fff2cc,stroke:#d6b656
    style Step4 fill:#fff2cc,stroke:#d6b656
    style Step5 fill:#fff2cc,stroke:#d6b656
    style Step6 fill:#fff2cc,stroke:#d6b656
