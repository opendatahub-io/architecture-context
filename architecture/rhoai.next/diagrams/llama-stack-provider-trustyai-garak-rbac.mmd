graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_LSD["{lsd-name}-sa<br/>Llama Stack Distribution SA"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_DSPA["lsd-garak-dspa-api-access<br/>Namespace: (configurable)"]
        RB_Pipeline["lsd-garak-pipeline-management<br/>Namespace: (configurable)"]
    end

    subgraph Roles["Roles"]
        Role_DSPA["lsd-garak-dspa-api-access<br/>(Role)"]
        Role_Pipeline["ds-pipeline-{dspa-name}<br/>(Role, provided by DSPA)"]
        Role_SecretReader["secret-reader<br/>(Role, documented in code)"]
    end

    subgraph APIResources_DSPA["DSPA API Resources"]
        DSPA_API["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications/api"]
    end

    subgraph APIResources_Secrets["Secret Resources"]
        Secrets_API["core ('')<br/>secrets"]
    end

    subgraph KFPResources["KFP Pipeline Resources"]
        KFP_Runs["KFP pipeline runs<br/>(managed by DSPA Role)"]
    end

    subgraph SecretsMounted["Secrets (Volume Mounts)"]
        direction TB
        InferenceSecret["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Key: api-key<br/>Provisioned: Manual"]
        ModelAuth["model-auth<br/>Type: Opaque<br/>Keys: api-key, SDG_API_KEY,<br/>JUDGE_API_KEY, ATTACKER_API_KEY,<br/>EVALUATOR_API_KEY<br/>Mount: /mnt/model-auth<br/>Provisioned: Manual"]
        DataConnection["Data Connection Secret<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT, AWS_S3_BUCKET<br/>Provisioned: OpenShift AI"]
        KFCreds["kubeflow-credentials (optional)<br/>Type: Opaque<br/>Key: KFP API token<br/>Provisioned: Manual"]
    end

    %% Bindings
    SA_LSD -->|bound via| RB_DSPA
    SA_LSD -->|bound via| RB_Pipeline

    RB_DSPA -->|grants| Role_DSPA
    RB_Pipeline -->|grants| Role_Pipeline

    %% Role -> Resources
    Role_DSPA -->|"get, create"| DSPA_API
    Role_Pipeline -->|"manage"| KFP_Runs
    Role_SecretReader -->|"get"| Secrets_API

    %% Secret resolution flow
    SA_LSD -.->|"volume mount<br/>/mnt/model-auth"| ModelAuth
    SA_LSD -.->|"env injection"| InferenceSecret
    SA_LSD -.->|"env injection"| DataConnection
    SA_LSD -.->|"env injection"| KFCreds

    subgraph APIKeyResolution["API Key Resolution (resolve_api_key)"]
        direction LR
        Step1["1. /mnt/model-auth/{ROLE}_API_KEY"]
        Step2["2. /mnt/model-auth/api-key (fallback)"]
        Step3["3. Environment variable (fallback)"]
        Step1 --> Step2 --> Step3
    end

    ModelAuth -.->|"read by"| APIKeyResolution

    subgraph SecurityMeasures["Security Measures"]
        Redaction["redact_api_keys()<br/>Strips secrets before<br/>upload to S3/OCI/Files API"]
        Placeholders["Placeholder replacement<br/>DUMMY, __FROM_ENV__, ***<br/>→ real keys at pod startup"]
    end

    %% Styling
    style SA_LSD fill:#4a90e2,stroke:#333,color:#fff
    style Role_DSPA fill:#f5a623,stroke:#333,color:#fff
    style Role_Pipeline fill:#f5a623,stroke:#333,color:#fff
    style Role_SecretReader fill:#f5a623,stroke:#333,color:#fff
    style DSPA_API fill:#7ed321,stroke:#333,color:#fff
    style Secrets_API fill:#7ed321,stroke:#333,color:#fff
    style KFP_Runs fill:#7ed321,stroke:#333,color:#fff
    style RB_DSPA fill:#e0e0e0,stroke:#333
    style RB_Pipeline fill:#e0e0e0,stroke:#333
    style InferenceSecret fill:#fce4ec,stroke:#c62828
    style ModelAuth fill:#fce4ec,stroke:#c62828
    style DataConnection fill:#fce4ec,stroke:#c62828
    style KFCreds fill:#fce4ec,stroke:#c62828
    style Redaction fill:#c8e6c9,stroke:#2e7d32
    style Placeholders fill:#c8e6c9,stroke:#2e7d32
