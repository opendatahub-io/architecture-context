graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>Data Scientist / API Consumer"]
    end

    subgraph AppServer["APPLICATION SERVER (Llama Stack)"]
        direction TB

        subgraph Pipeline["Request Security Pipeline"]
            AuthMW["Authentication Middleware<br/>JWT via JWKS / Introspection / Custom"]
            QuotaMW["Quota Middleware<br/>100/day anon, 1000/day auth"]
            ABAC["Access Control Engine<br/>Cedar ABAC<br/>permit/forbid × principal × resource"]
            Router["Provider Router<br/>Routes by model/resource ID"]
            AuthMW --> QuotaMW --> ABAC --> Router
        end

        TLSConfig["TLS Config<br/>Optional TLS 1.2+ / mTLS<br/>tls_certfile + tls_keyfile + tls_cafile"]
    end

    subgraph AuthEgress["AUTHENTICATION EGRESS"]
        JWKS["JWKS URI (OAuth2 IdP)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth (public keys)"]
        Introspection["Token Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HTTP Basic Auth"]
        CustomAuth["Custom Auth Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph InferenceEgress["INFERENCE PROVIDER EGRESS"]
        direction TB
        vLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>API Key Bearer"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>⚠ plaintext<br/>No Auth"]
        TGI["TGI (HuggingFace)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key Bearer"]
        CloudAPIs["OpenAI / Anthropic / Gemini /<br/>Bedrock / NVIDIA / Together /<br/>Fireworks / Groq / SambaNova /<br/>Cerebras / Databricks / WatsonX<br/>443/TCP HTTPS TLS 1.2+<br/>API Key or AWS IAM"]
    end

    subgraph VectorEgress["VECTOR DATABASE EGRESS"]
        PGVector["PostgreSQL pgvector<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password"]
        ChromaDB["ChromaDB<br/>8000/TCP HTTP<br/>Configurable<br/>API Key or None"]
        Qdrant["Qdrant<br/>6333/TCP HTTP/gRPC<br/>Configurable<br/>API Key or None"]
        Milvus["Milvus<br/>19530/TCP gRPC<br/>Configurable<br/>Token or None"]
        Weaviate["Weaviate<br/>8080/TCP HTTP/HTTPS<br/>Configurable<br/>API Key or None"]
    end

    subgraph ToolEgress["TOOL & SEARCH EGRESS"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        TavilySearch["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        WolframAlpha["Wolfram Alpha<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    subgraph TelemetryEgress["TELEMETRY & MODEL EGRESS"]
        OTLP["OTLP Collector<br/>4318/TCP HTTP<br/>Configurable<br/>No Auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key Bearer"]
    end

    subgraph LocalStores["LOCAL DATA STORES (In-Process)"]
        SQLite["SQLite<br/>File I/O<br/>Metadata / Quota / History"]
        FAISS["FAISS<br/>In-memory<br/>Default vector store"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS 8321/TCP<br/>TLS 1.2+ (optional mTLS)<br/>Bearer JWT"| AuthMW

    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| JWKS
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>Basic Auth"| Introspection
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| CustomAuth

    Router -->|"HTTP/8000<br/>API Key"| vLLM
    Router -->|"HTTP/11434<br/>⚠ plaintext"| Ollama
    Router -->|"HTTPS/443<br/>TLS 1.2+"| TGI
    Router -->|"HTTPS/443<br/>TLS 1.2+"| CloudAPIs

    Router -->|"TCP/5432<br/>TLS optional"| PGVector
    Router -->|"HTTP/8000"| ChromaDB
    Router -->|"HTTP+gRPC/6333"| Qdrant
    Router -->|"gRPC/19530"| Milvus
    Router -->|"HTTP/8080"| Weaviate

    Router -->|"HTTPS/443<br/>TLS 1.2+"| BraveSearch
    Router -->|"HTTPS/443<br/>TLS 1.2+"| TavilySearch
    Router -->|"HTTPS/443<br/>TLS 1.2+"| WolframAlpha

    Router -->|"HTTP/4318"| OTLP
    Router -->|"HTTPS/443<br/>TLS 1.2+"| HFHub

    QuotaMW --> SQLite
    Router --> FAISS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appserver fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    classDef security fill:#f5a623,stroke:#d79b00,stroke-width:2px
    classDef authegress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inference fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef vectordb fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tools fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef telemetry fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef local fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class AuthMW,QuotaMW,ABAC security
    class Router appserver
    class JWKS,Introspection,CustomAuth authegress
    class vLLM,Ollama,TGI,CloudAPIs inference
    class PGVector,ChromaDB,Qdrant,Milvus,Weaviate vectordb
    class BraveSearch,TavilySearch,WolframAlpha tools
    class OTLP,HFHub telemetry
    class SQLite,FAISS local
