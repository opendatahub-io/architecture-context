graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client / SDK"]
        UI["Llama Stack UI<br/>(Next.js)"]
    end

    subgraph AppBoundary["APPLICATION BOUNDARY (Llama Stack Server)"]
        direction TB

        subgraph Middleware["Middleware Stack (ASGI)"]
            AuthMW["Authentication Middleware<br/>OAuth2 JWT / Custom<br/>Claims: sub, groups, team, project"]
            QuotaMW["Quota Middleware<br/>Auth: 1000 req/day<br/>Anon: 100 req/day"]
            ABAC["Access Control (Cedar ABAC)<br/>permit/forbid rules<br/>Default: deny"]
        end

        subgraph ServerCore["Server Core - Port 8321/TCP"]
            APIRouters["API Routers<br/>/v1/inference, /v1/agents,<br/>/v1/safety, /v1/vector-io,<br/>/v1/eval, /v1/tool-runtime,<br/>/v1/openai/v1/*"]
            Distribution["Distribution System<br/>(Provider Routing)"]
        end

        subgraph Providers["Provider Layer"]
            InlineP["Inline Providers<br/>(in-process, no isolation)"]
            RemoteP["Remote Providers<br/>(outbound connections)"]
        end
    end

    subgraph AuthServices["AUTHENTICATION SERVICES"]
        OIDC["OIDC / Keycloak<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        TokenIntro["Token Introspection<br/>443/TCP HTTPS<br/>Client Credentials"]
        CustomAuth["Custom Auth Endpoint<br/>Configurable HTTPS"]
    end

    subgraph InferenceBackends["INFERENCE PROVIDERS"]
        vLLM["vLLM (Primary RHOAI)<br/>8000/TCP HTTP/HTTPS<br/>Configurable TLS<br/>Bearer Token"]
        Ollama["Ollama<br/>11434/TCP HTTP<br/>No Encryption<br/>No Auth"]
        CloudAPIs["Cloud APIs<br/>(OpenAI, Anthropic, Bedrock,<br/>NIM, Fireworks, Together,<br/>Groq, SambaNova, Gemini)<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token / AWS IAM"]
    end

    subgraph DataStores["DATA STORES"]
        pgvector["PostgreSQL/pgvector<br/>5432/TCP<br/>Configurable TLS<br/>User/Pass"]
        VectorDBs["ChromaDB / Qdrant /<br/>Milvus / Weaviate<br/>Configurable ports<br/>Configurable encryption"]
        Redis["Redis<br/>6379/TCP<br/>Configurable TLS<br/>Password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Configurable TLS<br/>User/Pass"]
        SQLite["SQLite<br/>File I/O<br/>(Default Persistence)"]
    end

    subgraph ToolServices["TOOL & SEARCH SERVICES"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF)"]
        SearchAPIs["Brave / Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Wolfram["Wolfram Alpha<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        MCP["MCP Servers<br/>Configurable HTTP/SSE<br/>Configurable"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>Configurable HTTP (OTLP)<br/>Configurable encryption"]
    end

    %% Inbound flows
    Client -->|"HTTP/HTTPS 8321<br/>Configurable TLS 1.2+<br/>Bearer Token (JWT)"| AuthMW
    UI -->|"HTTP/HTTPS 8321<br/>Configurable TLS 1.2+<br/>Bearer Token"| AuthMW
    AuthMW --> QuotaMW
    QuotaMW --> ABAC
    ABAC --> APIRouters
    APIRouters --> Distribution
    Distribution --> Providers

    %% Auth egress
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS fetch"| OIDC
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>Client creds"| TokenIntro
    AuthMW -->|"HTTPS<br/>Configurable<br/>Token delegation"| CustomAuth

    %% Inference egress
    RemoteP -->|"HTTP/HTTPS 8000<br/>Configurable TLS<br/>Bearer Token"| vLLM
    RemoteP -->|"HTTP/11434<br/>No encryption"| Ollama
    RemoteP -->|"HTTPS/443<br/>TLS 1.2+<br/>API keys/IAM"| CloudAPIs

    %% Data store egress
    RemoteP -->|"PostgreSQL/5432<br/>Configurable TLS<br/>User/Pass"| pgvector
    RemoteP -->|"Various protocols<br/>Configurable"| VectorDBs
    RemoteP -->|"Redis/6379<br/>Configurable TLS"| Redis
    RemoteP -->|"MongoDB/27017<br/>Configurable TLS"| MongoDB
    InlineP -->|"File I/O"| SQLite

    %% Tool egress
    RemoteP -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace
    RemoteP -->|"HTTPS/443<br/>TLS 1.2+"| SearchAPIs
    RemoteP -->|"HTTPS/443<br/>TLS 1.2+"| Wolfram
    RemoteP -->|"HTTP/HTTPS<br/>Configurable"| MCP

    %% Observability
    ServerCore -->|"HTTP OTLP<br/>Configurable"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#dbeafe,stroke:#2563eb,stroke-width:2px
    classDef middleware fill:#fecaca,stroke:#dc2626,stroke-width:2px
    classDef server fill:#bfdbfe,stroke:#3b82f6,stroke-width:2px
    classDef provider fill:#bbf7d0,stroke:#16a34a,stroke-width:2px
    classDef authservice fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef inference fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    classDef datastore fill:#fde68a,stroke:#d97706,stroke-width:2px
    classDef tool fill:#ddd6fe,stroke:#7c3aed,stroke-width:2px
    classDef observability fill:#ccfbf1,stroke:#0d9488,stroke-width:2px

    class Client,UI external
    class AuthMW,QuotaMW,ABAC middleware
    class APIRouters,Distribution server
    class InlineP,RemoteP provider
    class OIDC,TokenIntro,CustomAuth authservice
    class vLLM,Ollama,CloudAPIs inference
    class pgvector,VectorDBs,Redis,MongoDB,SQLite datastore
    class HuggingFace,SearchAPIs,Wolfram,MCP tool
    class OTel observability
