graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Application"]
    end

    subgraph ServerZone["LLAMA STACK SERVER (Port 8321)"]
        direction TB

        subgraph MiddlewareZone["Middleware Stack"]
            AuthMW["Authentication MW<br/>OAuth2 JWT / Custom<br/>JWKS + RFC 7662"]
            ACMW["Access Control MW<br/>Cedar ABAC<br/>permit/forbid rules"]
            QuotaMW["Quota MW<br/>1000/day auth, 100/day anon"]
            TraceMW["Tracing MW<br/>W3C TraceContext"]
        end

        subgraph APIZone["API Layer"]
            APIs["Inference | Agents | Safety<br/>Vector IO | Eval | Tools<br/>Post-Training | Telemetry"]
        end

        subgraph ProviderZone["Provider Layer (no isolation)"]
            Inline["Inline Providers<br/>(in-process)"]
            Remote["Remote Providers<br/>(HTTP adapters)"]
        end
    end

    subgraph InferenceBackends["LLM INFERENCE BACKENDS"]
        vLLM["vLLM<br/>8000/TCP HTTP/HTTPS<br/>Configurable TLS<br/>Bearer Token"]
        Ollama["Ollama<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
    end

    subgraph CloudProviders["CLOUD LLM PROVIDERS (443/TCP HTTPS TLS 1.2+)"]
        OpenAI["OpenAI API<br/>Bearer Token"]
        Anthropic["Anthropic API<br/>Bearer Token"]
        Bedrock["AWS Bedrock<br/>IAM Credentials"]
        NIM["NVIDIA NIM<br/>Bearer Token"]
        OtherLLM["Fireworks | Together<br/>Groq | SambaNova | Gemini"]
    end

    subgraph VectorDBs["VECTOR DATABASES"]
        PgVector["PostgreSQL/pgvector<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password"]
        Chroma["ChromaDB<br/>HTTP/HTTPS<br/>No auth"]
        Qdrant["Qdrant<br/>HTTP/gRPC<br/>API key"]
        Milvus["Milvus<br/>gRPC<br/>Token"]
    end

    subgraph DataStores["DATA STORES"]
        SQLite["SQLite<br/>File I/O (local)<br/>No network"]
        Redis["Redis<br/>6379/TCP<br/>Configurable TLS<br/>Password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Configurable TLS<br/>Username/Password"]
    end

    subgraph AuthServices["AUTH & IDENTITY"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS public keys"]
        Introspect["Token Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client Credentials"]
        CustomAuth["Custom Auth Endpoint<br/>HTTPS<br/>Configurable"]
    end

    subgraph AgentTools["AGENT TOOLS (443/TCP HTTPS TLS 1.2+)"]
        BraveSearch["Brave Search<br/>API key"]
        Tavily["Tavily Search<br/>API key"]
        Wolfram["Wolfram Alpha<br/>API key"]
        HFHub["HuggingFace Hub<br/>HF Token"]
        MCP["MCP Servers<br/>HTTP/HTTPS"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>OTLP HTTP<br/>Configurable"]
    end

    %% Ingress flow
    Client -->|"HTTP/HTTPS 8321/TCP<br/>TLS 1.2+ (configurable)<br/>Bearer Token (JWT/Custom)"| AuthMW
    AuthMW --> ACMW
    ACMW --> QuotaMW
    QuotaMW --> TraceMW
    TraceMW --> APIs
    APIs --> Inline
    APIs --> Remote

    %% Auth egress
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| OIDC
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>Client Creds"| Introspect
    AuthMW -->|"HTTPS<br/>Configurable"| CustomAuth

    %% Inference egress
    Remote -->|"HTTP/HTTPS<br/>8000/TCP<br/>Bearer Token"| vLLM
    Remote -->|"HTTP<br/>11434/TCP"| Ollama
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>API keys"| OpenAI
    Remote -->|"HTTPS/443<br/>TLS 1.2+"| Anthropic
    Remote -->|"HTTPS/443<br/>AWS IAM"| Bedrock
    Remote -->|"HTTPS/443"| NIM
    Remote -->|"HTTPS/443"| OtherLLM

    %% Vector DB egress
    Remote -->|"TCP/5432<br/>Configurable TLS"| PgVector
    Remote -->|"HTTP/HTTPS"| Chroma
    Remote -->|"HTTP/gRPC"| Qdrant
    Remote -->|"gRPC"| Milvus

    %% Data store
    Inline -->|"File I/O"| SQLite
    Remote -->|"TCP/6379<br/>Configurable TLS"| Redis
    Remote -->|"TCP/27017<br/>Configurable TLS"| MongoDB

    %% Tools egress
    Remote -->|"HTTPS/443"| BraveSearch
    Remote -->|"HTTPS/443"| Tavily
    Remote -->|"HTTPS/443"| Wolfram
    Remote -->|"HTTPS/443"| HFHub
    Remote -->|"HTTP/HTTPS"| MCP

    %% Telemetry
    TraceMW -->|"OTLP HTTP"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef server fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef middleware fill:#fde68a,stroke:#d97706,stroke-width:2px
    classDef inference fill:#d1d5db,stroke:#6b7280,stroke-width:2px
    classDef cloud fill:#e5e7eb,stroke:#9ca3af,stroke-width:2px
    classDef vectordb fill:#d1fae5,stroke:#10b981,stroke-width:2px
    classDef datastore fill:#e0e7ff,stroke:#6366f1,stroke-width:2px
    classDef auth fill:#fce7f3,stroke:#ec4899,stroke-width:2px
    classDef tools fill:#fff7ed,stroke:#f97316,stroke-width:2px
    classDef observability fill:#ede9fe,stroke:#8b5cf6,stroke-width:2px

    class Client external
    class AuthMW,ACMW,QuotaMW,TraceMW middleware
    class APIs,Inline,Remote server
    class vLLM,Ollama inference
    class OpenAI,Anthropic,Bedrock,NIM,OtherLLM cloud
    class PgVector,Chroma,Qdrant,Milvus vectordb
    class SQLite,Redis,MongoDB datastore
    class OIDC,Introspect,CustomAuth auth
    class BraveSearch,Tavily,Wolfram,HFHub,MCP tools
    class OTel observability
