graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / API Consumer"]
    end

    subgraph AppBoundary["APPLICATION BOUNDARY — Llama Stack Server"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            AuthMW["Authentication Middleware<br/>OAuth2 JWT (JWKS) · Token Introspection · Custom Auth"]
        end

        subgraph RateLimit["Rate Limiting"]
            QuotaMW["Quota Middleware<br/>100/day anon · 1000/day auth<br/>SQLite-backed tracking"]
        end

        subgraph AccessCtrl["Authorization Layer"]
            ABAC["ABAC Engine (Cedar-inspired)<br/>Actions: CREATE · READ · UPDATE · DELETE<br/>Resources: type::identifier"]
        end

        subgraph ProvRouter["Request Routing"]
            Router["Provider Router<br/>Routes by model/resource ID"]
        end

        AuthMW --> QuotaMW
        QuotaMW --> ABAC
        ABAC --> Router
    end

    subgraph AuthEgress["EGRESS — Identity (443/TCP · HTTPS · TLS 1.2+)"]
        JWKS["OAuth2 IdP (JWKS)<br/>Public key fetch<br/>No auth"]
        Introspect["Token Introspection<br/>RFC 7662<br/>HTTP Basic Auth"]
        CustomAuth["Custom Auth Endpoint<br/>Token delegation<br/>No auth"]
    end

    subgraph InferenceEgress["EGRESS — Inference Backends"]
        vLLM["vLLM<br/>8000/TCP · HTTP/HTTPS<br/>API Key (Bearer)"]
        Ollama["Ollama<br/>11434/TCP · HTTP<br/>plaintext · No auth"]
        TGI["TGI<br/>443/TCP · HTTPS<br/>TLS 1.2+ · API Key"]
        CloudInference["Cloud APIs (443/TCP · HTTPS · TLS 1.2+)<br/>OpenAI · Anthropic · Gemini<br/>Bedrock (AWS IAM) · NVIDIA<br/>Together · Fireworks · Groq<br/>SambaNova · Cerebras · Databricks<br/>RunPod · WatsonX"]
    end

    subgraph VectorEgress["EGRESS — Vector Stores"]
        pgvector["PostgreSQL pgvector<br/>5432/TCP · SQL/TCP<br/>Configurable TLS · User/Pass"]
        ChromaDB["ChromaDB<br/>8000/TCP · HTTP<br/>Configurable · API Key/None"]
        Qdrant["Qdrant<br/>6333/TCP · HTTP/gRPC<br/>Configurable · API Key/None"]
        Milvus["Milvus<br/>19530/TCP · gRPC<br/>Configurable · Token/None"]
        Weaviate["Weaviate<br/>8080/TCP · HTTP/HTTPS<br/>Configurable · API Key/None"]
    end

    subgraph ToolEgress["EGRESS — Tools & Search (443/TCP · HTTPS · TLS 1.2+)"]
        Brave["Brave Search<br/>API Key (Bearer)"]
        Tavily["Tavily Search<br/>API Key (Bearer)"]
        Bing["Bing Search<br/>API Key (Bearer)"]
        Wolfram["Wolfram Alpha<br/>API Key"]
    end

    subgraph ObsEgress["EGRESS — Observability & Storage"]
        OTLP["OTLP Collector<br/>4318/TCP · HTTP<br/>Configurable · No auth"]
        HFHub["HuggingFace Hub<br/>443/TCP · HTTPS<br/>TLS 1.2+ · API Key"]
        SQLite["SQLite (local)<br/>File I/O<br/>Metadata · Quotas · History"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS · 8321/TCP<br/>TLS 1.2+ (configurable)<br/>Bearer Token (JWT)"| AuthMW

    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| JWKS
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>HTTP Basic"| Introspect
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| CustomAuth

    QuotaMW -->|"File I/O"| SQLite

    Router -->|"HTTP/HTTPS<br/>8000/TCP<br/>API Key"| vLLM
    Router -->|"HTTP<br/>11434/TCP<br/>plaintext"| Ollama
    Router -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| TGI
    Router -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key / IAM"| CloudInference

    Router -->|"TCP/5432<br/>User/Pass"| pgvector
    Router -->|"HTTP/8000"| ChromaDB
    Router -->|"HTTP/6333"| Qdrant
    Router -->|"gRPC/19530"| Milvus
    Router -->|"HTTP/8080"| Weaviate

    Router -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Brave
    Router -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Tavily
    Router -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Bing
    Router -->|"HTTPS/443<br/>TLS 1.2+"| Wolfram

    Router -->|"HTTP/4318"| OTLP
    Router -->|"HTTPS/443<br/>API Key"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef auth fill:#fecaca,stroke:#dc2626,stroke-width:2px
    classDef ratelimit fill:#fed7aa,stroke:#ea580c,stroke-width:2px
    classDef abac fill:#fde68a,stroke:#ca8a04,stroke-width:2px
    classDef router fill:#bfdbfe,stroke:#2563eb,stroke-width:2px
    classDef inference fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    classDef vectorstore fill:#d1fae5,stroke:#059669,stroke-width:2px
    classDef toolapi fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef observability fill:#ede9fe,stroke:#7c3aed,stroke-width:2px

    class Client external
    class AuthMW auth
    class QuotaMW ratelimit
    class ABAC abac
    class Router router
    class JWKS,Introspect,CustomAuth auth
    class vLLM,Ollama,TGI,CloudInference inference
    class pgvector,ChromaDB,Qdrant,Milvus,Weaviate vectorstore
    class Brave,Tavily,Bing,Wolfram toolapi
    class OTLP,HFHub,SQLite observability
