graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Application"]
    end

    subgraph Ingress["INGRESS (Llama Stack Server)"]
        direction TB
        Server["Llama Stack Server<br/>Port: 8321/TCP<br/>HTTP/HTTPS (Optional TLS 1.2+)<br/>Auth: Bearer Token (JWT/Introspection)"]

        subgraph MiddlewareChain["Middleware Chain"]
            Auth["AuthenticationMiddleware<br/>JWT/JWKS + RFC 7662 Introspection"]
            Quota["QuotaMiddleware<br/>100/day anon, 1000/day auth"]
            ABACEngine["ABAC Engine<br/>Cedar-like policy rules"]
        end
    end

    subgraph InferenceBackends["INFERENCE BACKENDS"]
        vLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>Optional TLS<br/>Bearer Token"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+ SigV4<br/>AWS IAM"]
        Gemini["Google Gemini<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        NIM["NVIDIA NIM<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
    end

    subgraph DataStores["DATA STORES"]
        PgVector["PostgreSQL + pgvector<br/>5432/TCP PostgreSQL<br/>Optional TLS<br/>Password auth"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Optional password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Optional TLS<br/>Optional credentials"]
        Chroma["ChromaDB<br/>8000/TCP HTTP<br/>No encryption<br/>No auth"]
        QdrantDB["Qdrant<br/>6333/TCP HTTP/gRPC<br/>Optional TLS<br/>Optional API key"]
        MilvusDB["Milvus<br/>19530/TCP gRPC<br/>Optional TLS<br/>Optional credentials"]
        Weaviate["Weaviate<br/>8080/TCP HTTP<br/>Optional TLS<br/>Optional API key"]
    end

    subgraph AuthServices["AUTHENTICATION & IDENTITY"]
        JWKS["JWKS Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth (public keys)"]
        Introspection["OAuth2 Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Client credentials"]
        CustomAuth["Custom Auth Endpoint<br/>configurable HTTPS<br/>TLS 1.2+"]
    end

    subgraph ToolServices["TOOLS & EXTERNAL SERVICES"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF token"]
        MCP["MCP Servers<br/>configurable HTTP/HTTPS<br/>Optional TLS"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>configurable HTTP OTLP<br/>Optional TLS<br/>No auth"]
    end

    %% Client to Server
    Client -->|"HTTP/HTTPS 8321/TCP<br/>Optional TLS 1.2+<br/>Bearer Token (JWT)"| Server

    %% Auth flows
    Auth -->|"HTTPS/443<br/>TLS 1.2+"| JWKS
    Auth -->|"HTTPS/443<br/>TLS 1.2+ custom CA<br/>Client credentials"| Introspection
    Auth -->|"HTTPS<br/>TLS 1.2+"| CustomAuth

    %% Inference egress
    Server -->|"HTTP/HTTPS 8000/TCP<br/>Optional TLS<br/>Bearer Token"| vLLM
    Server -->|"HTTP 11434/TCP<br/>No encryption"| Ollama
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Anthropic
    Server -->|"HTTPS/443<br/>SigV4<br/>AWS IAM"| Bedrock
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Gemini
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| NIM

    %% Data store egress
    Server -->|"PostgreSQL/5432<br/>Optional TLS<br/>Password"| PgVector
    Server -->|"Redis/6379<br/>Optional TLS<br/>Optional password"| Redis
    Server -->|"MongoDB/27017<br/>Optional TLS"| MongoDB
    Server -->|"HTTP/8000<br/>No encryption"| Chroma
    Server -->|"HTTP-gRPC/6333<br/>Optional TLS"| QdrantDB
    Server -->|"gRPC/19530<br/>Optional TLS"| MilvusDB
    Server -->|"HTTP/8080<br/>Optional TLS"| Weaviate

    %% Tool egress
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Tavily
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Brave
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>HF token"| HFHub
    Server -->|"HTTP/HTTPS<br/>Optional TLS"| MCP

    %% Observability
    Server -->|"HTTP OTLP<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef inference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datastore fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tools fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Server,Auth,Quota,ABACEngine ingress
    class vLLM,Ollama,OpenAI,Anthropic,Bedrock,Gemini,NIM inference
    class PgVector,Redis,MongoDB,Chroma,QdrantDB,MilvusDB,Weaviate datastore
    class JWKS,Introspection,CustomAuth auth
    class Tavily,Brave,HFHub,MCP tools
    class OTel observability
