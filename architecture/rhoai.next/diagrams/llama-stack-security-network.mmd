graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Application"]
    end

    subgraph AppLayer["APPLICATION LAYER (Llama Stack Server :8321)"]
        direction TB

        subgraph MiddlewareZone["Middleware Chain"]
            AuthMW["AuthenticationMiddleware<br/>JWT/JWKS | Introspection | Custom<br/>Rate: 100/day anon, 1000/day auth"]
            ABAC_Engine["ABAC Engine<br/>Cedar-like Policy Rules<br/>permit/forbid with when/unless"]
        end

        subgraph ProviderZone["Provider Plugin System"]
            InlineP["Inline Providers<br/>(in-process)<br/>vLLM local, FAISS,<br/>sentence-transformers, sqlite-vec"]
            RemoteP["Remote Providers<br/>(HTTP adapters)"]
        end

        AuthMW --> ABAC_Engine
        ABAC_Engine --> InlineP
        ABAC_Engine --> RemoteP
    end

    subgraph AuthProviders["AUTHENTICATION PROVIDERS"]
        JWKS["OAuth2 JWKS Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth (public keys)"]
        Introspection["OAuth2 Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Client credentials"]
        CustomAuth["Custom Auth Endpoint<br/>configurable/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS"]
        VLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>Optional TLS<br/>Bearer Token (optional)"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
        CloudAPIs["Cloud Inference APIs<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API keys / IAM"]
    end

    subgraph DataStores["DATA STORES"]
        PG["PostgreSQL + pgvector<br/>5432/TCP<br/>Optional TLS<br/>Password auth"]
        Redis_Store["Redis<br/>6379/TCP<br/>Optional TLS<br/>Optional password"]
        MongoDB_Store["MongoDB<br/>27017/TCP<br/>Optional TLS<br/>Optional credentials"]
        VectorDBs["Vector DBs<br/>Chroma :8000 | Qdrant :6333<br/>Milvus :19530 | Weaviate :8080<br/>Optional TLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF)"]
        SearchAPIs["Search APIs<br/>Tavily | Brave | Wolfram<br/>443/TCP HTTPS<br/>TLS 1.2+, API key"]
        OTel["OpenTelemetry Collector<br/>configurable/TCP<br/>HTTP (OTLP)<br/>Optional TLS"]
        MCP["MCP Servers<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
    end

    %% Client to Server
    Client -->|"HTTP/HTTPS :8321<br/>Optional TLS 1.2+<br/>mTLS supported<br/>Bearer Token (JWT)"| AuthMW

    %% Auth provider egress
    AuthMW -->|"HTTPS :443<br/>TLS 1.2+<br/>Public keys"| JWKS
    AuthMW -->|"HTTPS :443<br/>TLS 1.2+ (custom CA)<br/>Client creds"| Introspection
    AuthMW -->|"HTTPS<br/>TLS 1.2+<br/>Token in body"| CustomAuth

    %% Inference egress
    RemoteP -->|"HTTP/HTTPS :8000<br/>Optional TLS<br/>Bearer Token"| VLLM
    RemoteP -->|"HTTP :11434<br/>No encryption"| Ollama
    RemoteP -->|"HTTPS :443<br/>TLS 1.2+<br/>API keys/IAM"| CloudAPIs

    %% Data store egress
    RemoteP -->|"PostgreSQL :5432<br/>Optional TLS<br/>Password"| PG
    RemoteP -->|"Redis :6379<br/>Optional TLS<br/>Password"| Redis_Store
    RemoteP -->|"MongoDB :27017<br/>Optional TLS<br/>Credentials"| MongoDB_Store
    RemoteP -->|"Various ports<br/>Optional TLS"| VectorDBs

    %% External service egress
    RemoteP -->|"HTTPS :443<br/>TLS 1.2+<br/>HF Token"| HFHub
    RemoteP -->|"HTTPS :443<br/>TLS 1.2+<br/>API keys"| SearchAPIs
    RemoteP -->|"HTTP (OTLP)<br/>Optional TLS"| OTel
    RemoteP -->|"HTTP/HTTPS<br/>Optional TLS"| MCP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appLayer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef middleware fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    classDef authProvider fill:#fce4ec,stroke:#c62828,stroke-width:1px
    classDef inferenceBackend fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    classDef dataStore fill:#fff8e1,stroke:#f9a825,stroke-width:1px
    classDef externalSvc fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px

    class Client external
    class AuthMW,ABAC_Engine middleware
    class InlineP,RemoteP appLayer
    class JWKS,Introspection,CustomAuth authProvider
    class VLLM,Ollama,CloudAPIs inferenceBackend
    class PG,Redis_Store,MongoDB_Store,VectorDBs dataStore
    class HFHub,SearchAPIs,OTel,MCP externalSvc
