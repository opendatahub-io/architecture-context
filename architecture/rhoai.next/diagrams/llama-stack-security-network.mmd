graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>llama CLI / Streamlit UI / Next.js UI"]
    end

    subgraph AppLayer["APPLICATION LAYER (Llama Stack Server)"]
        direction TB

        subgraph MiddlewareChain["Middleware Chain"]
            direction LR
            ClientVer["ClientVersion<br/>MW"]
            AuthMW["Authentication<br/>MW<br/>JWT/Introspection/Custom"]
            QuotaMW["Quota MW<br/>100/day anon<br/>1000/day auth"]
            TraceMW["Tracing MW<br/>x-trace-id"]
        end

        subgraph ABAC["ABAC Access Control"]
            CedarRules["Cedar-like Rules<br/>permit/forbid<br/>when/unless conditions"]
        end

        Server["FastAPI/uvicorn<br/>Port 8321/TCP<br/>Optional TLS 1.2+<br/>Optional mTLS"]

        subgraph PublicEndpoints["Public (No Auth)"]
            Health["/v1/health"]
            Version["/v1/version"]
            Docs["/docs, /openapi.json"]
        end
    end

    subgraph AuthZone["AUTH PROVIDERS"]
        JWKS["OAuth2 JWKS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public keys"]
        Introspect["OAuth2 Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Client credentials"]
        CustomAuth["Custom Auth Endpoint<br/>HTTPS<br/>TLS 1.2+<br/>Token in body"]
    end

    subgraph InferenceZone["INFERENCE BACKENDS"]
        vLLM["vLLM Server<br/>8000/TCP HTTP/HTTPS<br/>Optional TLS<br/>Bearer Token (optional)"]
        Ollama["Ollama<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
        CloudAPIs["Cloud APIs<br/>(OpenAI/Anthropic/Bedrock/Gemini)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key / AWS IAM"]
    end

    subgraph StorageZone["STORAGE BACKENDS"]
        PostgreSQL["PostgreSQL + pgvector<br/>5432/TCP<br/>Optional TLS<br/>Password auth"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Optional password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Optional TLS<br/>Optional credentials"]
        VectorDBs["Vector DBs<br/>Chroma: 8000/TCP<br/>Qdrant: 6333/TCP<br/>Milvus: 19530/TCP<br/>Weaviate: 8080/TCP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        SearchAPIs["Search APIs<br/>(Tavily/Brave)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        OTelCollector["OpenTelemetry Collector<br/>configurable port<br/>HTTP OTLP<br/>Optional TLS"]
        MCPServers["MCP Servers<br/>configurable<br/>HTTP/HTTPS<br/>Varies"]
    end

    %% Client to Server
    Client -->|"HTTP/HTTPS 8321/TCP<br/>TLS 1.2+ (optional)<br/>Bearer Token (JWT)"| Server

    %% Auth connections
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+"| JWKS
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+ (custom CA)<br/>Client creds"| Introspect
    AuthMW -->|"HTTPS<br/>TLS 1.2+"| CustomAuth

    %% Inference egress
    Server -->|"HTTP/HTTPS 8000/TCP<br/>Optional TLS<br/>Bearer Token"| vLLM
    Server -->|"HTTP 11434/TCP<br/>No TLS"| Ollama
    Server -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>API Key/IAM"| CloudAPIs

    %% Storage egress
    Server -->|"PostgreSQL 5432/TCP<br/>Optional TLS<br/>Password"| PostgreSQL
    Server -->|"Redis 6379/TCP<br/>Optional TLS<br/>Password"| Redis
    Server -->|"MongoDB 27017/TCP<br/>Optional TLS"| MongoDB
    Server -->|"HTTP/gRPC<br/>Optional TLS"| VectorDBs

    %% External services
    Server -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>HF Token"| HuggingFace
    Server -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>API Key"| SearchAPIs
    Server -->|"HTTP OTLP<br/>Optional TLS"| OTelCollector
    Server -->|"HTTP/HTTPS<br/>Optional TLS"| MCPServers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appLayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef auth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extService fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef middleware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef server fill:#4a90e2,stroke:#333,color:#fff,stroke-width:3px

    class Client external
    class Server server
    class AuthMW,QuotaMW,TraceMW,ClientVer middleware
    class CedarRules middleware
    class JWKS,Introspect,CustomAuth auth
    class vLLM,Ollama,CloudAPIs inference
    class PostgreSQL,Redis,MongoDB,VectorDBs storage
    class HuggingFace,SearchAPIs,OTelCollector,MCPServers extService
