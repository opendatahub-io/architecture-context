graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
        UI["Llama Stack UI<br/>(Next.js)"]
    end

    subgraph AppBoundary["LLAMA STACK SERVER (Application Boundary)"]
        direction TB

        subgraph Server["FastAPI / Uvicorn - 8321/TCP"]
            direction TB

            subgraph MiddlewareStack["Middleware Stack"]
                AuthMW["AuthenticationMiddleware<br/>OAuth2 JWT / Custom<br/>Bypass: /health, /version, /docs"]
                QuotaMW["QuotaMiddleware<br/>Auth: 1000 req/day<br/>Anon: 100 req/day"]
                ABACMW["AccessControlMiddleware<br/>Cedar Policies<br/>Default: DENY"]
                TraceMW["TracingMiddleware<br/>W3C Trace Context"]
            end

            subgraph Routers["API Routers"]
                InfRouter["InferenceRouter"]
                SafeRouter["SafetyRouter"]
                AgentProv["Agent Provider"]
                VecRouter["VectorIORouter"]
            end
        end

        SQLite["SQLite<br/>File I/O<br/>Default Persistence"]
    end

    subgraph AuthProviders["AUTH PROVIDERS"]
        OIDC["OIDC / Keycloak<br/>JWKS Endpoint<br/>443/TCP HTTPS TLS 1.2+"]
        TokenIntro["Token Introspection<br/>RFC 7662<br/>443/TCP HTTPS TLS 1.2+<br/>Client Credentials"]
        CustomAuth["Custom Auth Endpoint<br/>Configurable<br/>HTTPS"]
    end

    subgraph InferenceProviders["INFERENCE PROVIDERS"]
        vLLM["vLLM<br/>8000/TCP HTTP/HTTPS<br/>Configurable TLS<br/>Bearer Token"]
        Ollama["Ollama<br/>11434/TCP HTTP<br/>No Encryption<br/>No Auth"]
        CloudProviders["OpenAI / Anthropic /<br/>Fireworks / Together /<br/>Groq / SambaNova / Gemini<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (API Key)"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM Credentials"]
        NIM["NVIDIA NIM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph VectorDBs["VECTOR DATABASE PROVIDERS"]
        pgvector["PostgreSQL/pgvector<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password"]
        ChromaDB["ChromaDB<br/>Configurable Port<br/>HTTP/HTTPS<br/>No Auth"]
        Qdrant["Qdrant<br/>HTTP/gRPC<br/>Configurable<br/>API Key"]
        Milvus["Milvus<br/>gRPC<br/>Configurable<br/>Token"]
        Weaviate["Weaviate<br/>HTTP/HTTPS<br/>Configurable<br/>API Key"]
    end

    subgraph KVStores["KV STORE BACKENDS"]
        Redis["Redis<br/>6379/TCP<br/>Configurable TLS<br/>Password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Configurable TLS<br/>Username/Password"]
    end

    subgraph ToolServices["TOOL PROVIDERS"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Wolfram["Wolfram Alpha<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        MCP["MCP Servers<br/>Configurable<br/>REST/SSE"]
    end

    subgraph Telemetry["TELEMETRY & DATA"]
        OTel["OpenTelemetry Collector<br/>Configurable Port<br/>OTLP HTTP"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token"]
    end

    %% Ingress flows
    Client -->|"HTTP/HTTPS 8321/TCP<br/>Configurable TLS 1.2+<br/>Bearer Token (JWT)"| Server
    UI -->|"HTTP/HTTPS 8321/TCP"| Server

    %% Auth egress
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>None"| OIDC
    AuthMW -->|"HTTPS/443<br/>TLS 1.2+<br/>Client Creds"| TokenIntro
    AuthMW -->|"HTTPS<br/>Configurable"| CustomAuth

    %% Inference egress
    InfRouter -->|"HTTP/HTTPS 8000<br/>Configurable TLS<br/>Bearer Token"| vLLM
    InfRouter -->|"HTTP 11434<br/>No Encryption"| Ollama
    InfRouter -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| CloudProviders
    InfRouter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| Bedrock
    InfRouter -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| NIM

    %% Vector DB egress
    VecRouter -->|"PostgreSQL 5432<br/>Configurable TLS<br/>User/Pass"| pgvector
    VecRouter -->|"HTTP/HTTPS<br/>Configurable"| ChromaDB
    VecRouter -->|"HTTP/gRPC<br/>API Key"| Qdrant

    %% KV store egress
    Server -->|"Redis 6379<br/>Configurable TLS<br/>Password"| Redis
    Server -->|"MongoDB 27017<br/>Configurable TLS<br/>User/Pass"| MongoDB

    %% Tool egress
    AgentProv -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| BraveSearch
    AgentProv -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Tavily
    AgentProv -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Wolfram
    AgentProv -->|"REST/SSE<br/>Configurable"| MCP

    %% Telemetry egress
    TraceMW -->|"OTLP HTTP<br/>Configurable"| OTel
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef middleware fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef router fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infprovider fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef vectordb fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kvstore fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef toolsvc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef telemetry fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client,UI external
    class AuthMW,QuotaMW,ABACMW,TraceMW middleware
    class InfRouter,SafeRouter,AgentProv,VecRouter router
    class OIDC,TokenIntro,CustomAuth authprovider
    class vLLM,Ollama,CloudProviders,Bedrock,NIM infprovider
    class pgvector,ChromaDB,Qdrant,Milvus,Weaviate vectordb
    class Redis,MongoDB kvstore
    class BraveSearch,Tavily,Wolfram,MCP toolsvc
    class OTel,HFHub telemetry
    class SQLite kvstore
