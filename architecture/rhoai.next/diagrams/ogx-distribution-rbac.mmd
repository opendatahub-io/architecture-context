graph TD
    subgraph ContainerImage["Container Image (No K8s RBAC)"]
        direction TB
        Note["OGX Distribution is a container image,<br/>not a Kubernetes operator.<br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined in this repository."]
    end

    subgraph ApplicationAuth["Application-Level Access Control"]
        direction TB
        AuthMiddleware["OAuth2 Token Provider<br/>(oauth2_token)"]
        AccessPolicy["OGX Access Policy Engine"]
    end

    subgraph AuthConfig["Authentication Configuration"]
        direction TB
        AuthIssuer["AUTH_ISSUER<br/>(OIDC Issuer URL)"]
        AuthJWKS["AUTH_JWKS_URI<br/>(JWKS Endpoint)"]
        AuthAudience["AUTH_AUDIENCE<br/>(default: ogx)"]
        AuthVerifyTLS["AUTH_VERIFY_TLS<br/>(default: true)"]
    end

    subgraph ResourcePolicies["Resource Access Policies"]
        direction TB

        subgraph SystemResources["System Resources (unowned)"]
            SysRead["READ: All authenticated users"]
        end

        subgraph UserResources["User Resources (owned)"]
            UserCreate["CREATE: Any authenticated user"]
            UserRead["READ: Owner only"]
            UserUpdate["UPDATE: Owner only"]
            UserDelete["DELETE: Owner only"]
        end

        subgraph HealthEndpoint["Health Endpoint"]
            HealthOpen["GET /v1/health: Open (no auth)"]
        end
    end

    subgraph Secrets["Secrets (Environment Variables)"]
        direction TB

        subgraph InferenceSecrets["Inference Provider Secrets"]
            VLLM_Token["VLLM_API_TOKEN<br/>VLLM_EMBEDDING_API_TOKEN"]
            AWS_Creds["AWS_BEDROCK_BEARER_TOKEN<br/>AWS_ROLE_ARN<br/>AWS_WEB_IDENTITY_TOKEN_FILE"]
            CloudKeys["WATSONX_API_KEY<br/>AZURE_API_KEY<br/>OPENAI_API_KEY<br/>GEMINI_API_KEY<br/>ANTHROPIC_API_KEY"]
        end

        subgraph StorageSecrets["Storage Secrets"]
            PG_Creds["POSTGRES_USER<br/>POSTGRES_PASSWORD"]
            VecDB_Creds["MILVUS_TOKEN<br/>PGVECTOR_PASSWORD<br/>QDRANT_API_KEY"]
            S3_Creds["AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY"]
        end

        subgraph ToolSecrets["Tool Runtime Secrets"]
            SearchKeys["BRAVE_SEARCH_API_KEY<br/>TAVILY_SEARCH_API_KEY"]
        end

        subgraph MilvusTLS["Milvus mTLS Certificates"]
            MilvusCerts["MILVUS_CA_PEM_PATH<br/>MILVUS_CLIENT_PEM_PATH<br/>MILVUS_CLIENT_KEY_PATH"]
        end
    end

    %% Flows
    AuthConfig -->|"configures"| AuthMiddleware
    AuthMiddleware -->|"validates JWT"| AccessPolicy
    AccessPolicy -->|"enforces"| ResourcePolicies

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style AuthMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style AccessPolicy fill:#4a90e2,stroke:#333,color:#fff
    style SysRead fill:#d5e8d4,stroke:#82b366
    style UserCreate fill:#d5e8d4,stroke:#82b366
    style UserRead fill:#d5e8d4,stroke:#82b366
    style UserUpdate fill:#ffe6cc,stroke:#d79b00
    style UserDelete fill:#f8cecc,stroke:#b85450
    style HealthOpen fill:#d5e8d4,stroke:#82b366
    style VLLM_Token fill:#f5f5f5,stroke:#999
    style AWS_Creds fill:#f5f5f5,stroke:#999
    style CloudKeys fill:#f5f5f5,stroke:#999
    style PG_Creds fill:#f5f5f5,stroke:#999
    style VecDB_Creds fill:#f5f5f5,stroke:#999
    style S3_Creds fill:#f5f5f5,stroke:#999
    style SearchKeys fill:#f5f5f5,stroke:#999
    style MilvusCerts fill:#f5f5f5,stroke:#999
    style AuthIssuer fill:#dae8fc,stroke:#6c8ebf
    style AuthJWKS fill:#dae8fc,stroke:#6c8ebf
    style AuthAudience fill:#dae8fc,stroke:#6c8ebf
    style AuthVerifyTLS fill:#dae8fc,stroke:#6c8ebf
