graph TB
    subgraph Pod["Kubernetes Pod"]
        subgraph Sidecar["llm-d-routing-sidecar"]
            Proxy["HTTP Reverse Proxy<br/>:8000/TCP HTTPS"]
            NIXLv2["NIXL v2 Connector<br/>(current)"]
            NIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            LMCache["LMCache Connector<br/>(deprecated)"]
            AllowlistValidator["AllowlistValidator<br/>SSRF Protection"]
            TLSMgr["TLS Manager<br/>TLS 1.2+ / Self-signed RSA-4096"]
            LRUCache["LRU Cache<br/>Prefiller proxy handlers<br/>capacity: 16"]
        end

        Decoder["vLLM Decoder<br/>(co-located)<br/>:8001/TCP"]
    end

    Client["Client / Gateway"] -->|"POST /v1/chat/completions<br/>HTTPS :8000<br/>+ x-prefiller-host-port header"| Proxy
    Proxy -->|"validate prefill target"| AllowlistValidator
    AllowlistValidator -->|"watch"| InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    AllowlistValidator -->|"watch pods"| K8sAPI["Kubernetes API<br/>:443/TCP"]

    Proxy -->|"prefill request<br/>(max_tokens=1)"| NIXLv2
    NIXLv2 -->|"via LRU cached handler"| LRUCache
    LRUCache -->|"HTTP/HTTPS"| RemotePrefiller["Remote Prefiller Pod"]

    RemotePrefiller -->|"KV transfer params"| NIXLv2
    NIXLv2 -->|"decode request<br/>+ kv_transfer_params"| Decoder

    Proxy -->|"TLS config"| TLSMgr
    Proxy -->|"passthrough<br/>(no prefill header)"| Decoder

    Decoder -->|"response<br/>(streamed through sidecar)"| Client

    style Proxy fill:#4a90e2,color:#fff
    style AllowlistValidator fill:#4a90e2,color:#fff
    style NIXLv2 fill:#4a90e2,color:#fff
    style NIXLv1 fill:#999,color:#fff
    style LMCache fill:#999,color:#fff
    style TLSMgr fill:#4a90e2,color:#fff
    style LRUCache fill:#4a90e2,color:#fff
    style Decoder fill:#7ed321,color:#fff
    style RemotePrefiller fill:#7ed321,color:#fff
    style InferencePoolCR fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8
    style Client fill:#e8e8e8
