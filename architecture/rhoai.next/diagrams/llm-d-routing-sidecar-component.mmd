graph TB
    subgraph Sidecar["llm-d-routing-sidecar (Go HTTP Reverse Proxy)"]
        direction TB
        Proxy["Reverse Proxy Server<br/>Port: 8000/TCP<br/>TLS 1.2+"]
        ChatHandler["/v1/chat/completions Handler"]
        CompHandler["/v1/completions Handler"]
        HealthHandler["/health Handler"]
        CatchAll["/* Catch-All Handler"]

        subgraph Connectors["P/D Protocol Connectors"]
            NIXLv2["NIXL v2 Connector<br/>(current)"]
            NIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            LMCache["LMCache Connector<br/>(deprecated)"]
        end

        subgraph Security["Security"]
            AllowlistValidator["AllowlistValidator<br/>SSRF Protection"]
            TLSConfig["TLS Config<br/>ECDHE + AES-GCM/ChaCha20"]
        end

        LRUCache["LRU Cache<br/>Prefiller Proxy Handlers<br/>(capacity: 16)"]

        Proxy --> ChatHandler
        Proxy --> CompHandler
        Proxy --> HealthHandler
        Proxy --> CatchAll

        ChatHandler -->|SSRF check| AllowlistValidator
        CompHandler -->|SSRF check| AllowlistValidator
        ChatHandler -->|protocol dispatch| NIXLv2
        ChatHandler -->|protocol dispatch| NIXLv1
        ChatHandler -->|protocol dispatch| LMCache
        CompHandler -->|protocol dispatch| NIXLv2

        NIXLv2 -->|cache handler| LRUCache
        NIXLv1 -->|cache handler| LRUCache
        LMCache -->|cache handler| LRUCache
    end

    Client[External Client] -->|"HTTPS/8000<br/>TLS 1.2+"| Proxy

    subgraph K8sResources["Kubernetes Resources (Watched)"]
        InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        Pods["Pods<br/>matching InferencePool selector"]
    end

    AllowlistValidator -->|"watch via K8s API<br/>HTTPS/443"| InferencePoolCR
    AllowlistValidator -->|"watch via K8s API<br/>HTTPS/443"| Pods

    subgraph LocalDecoder["Co-located vLLM Instance"]
        Decoder["vLLM Decoder<br/>Port: 8001/TCP"]
    end

    RemotePrefiller["Remote vLLM Prefiller(s)<br/>Dynamic port from header"]

    NIXLv2 -->|"Step 1: prefill request<br/>HTTP(S)"| RemotePrefiller
    RemotePrefiller -->|"KV cache transfer params"| NIXLv2
    NIXLv2 -->|"Step 2: enriched decode<br/>HTTP(S)/8001"| Decoder

    CatchAll -->|"passthrough<br/>HTTP(S)/8001"| Decoder

    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style ChatHandler fill:#4a90e2,stroke:#333,color:#fff
    style CompHandler fill:#4a90e2,stroke:#333,color:#fff
    style HealthHandler fill:#4a90e2,stroke:#333,color:#fff
    style CatchAll fill:#4a90e2,stroke:#333,color:#fff
    style NIXLv2 fill:#50c878,stroke:#333,color:#fff
    style NIXLv1 fill:#999,stroke:#333,color:#fff
    style LMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#e8594f,stroke:#333,color:#fff
    style TLSConfig fill:#e8594f,stroke:#333,color:#fff
    style LRUCache fill:#f5a623,stroke:#333
    style InferencePoolCR fill:#f5a623,stroke:#333
    style Pods fill:#f5a623,stroke:#333
    style Decoder fill:#7ed321,stroke:#333
    style RemotePrefiller fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
