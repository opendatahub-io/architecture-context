graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Pod["Kubernetes Pod"]
        subgraph Sidecar["llm-d-routing-sidecar"]
            direction TB
            Proxy["HTTP Reverse Proxy<br/>Port 8000/TCP<br/>TLS 1.2+"]
            ChatHandler["Chat Completions Handler<br/>/v1/chat/completions"]
            CompletionsHandler["Completions Handler<br/>/v1/completions"]
            HealthHandler["Health Check<br/>/health"]
            Passthrough["Catch-all Passthrough<br/>/*"]

            subgraph Connectors["Connector Protocols"]
                NIXLv2["NIXLv2 Connector<br/>(current/recommended)"]
                NIXLv1["NIXLv1 Connector<br/>(deprecated)"]
                LMCache["LMCache Connector<br/>(deprecated)"]
            end

            subgraph Security["Security Subsystem"]
                AllowlistValidator["AllowlistValidator<br/>(SSRF Protection)"]
                TLSConfig["TLS Configuration<br/>FIPS-compatible ciphers"]
            end

            LRUCache["LRU Cache<br/>(capacity 16)<br/>Prefiller proxy handlers"]

            Proxy --> ChatHandler
            Proxy --> CompletionsHandler
            Proxy --> HealthHandler
            Proxy --> Passthrough

            ChatHandler -->|validates target| AllowlistValidator
            CompletionsHandler -->|validates target| AllowlistValidator
            ChatHandler -->|selects protocol| NIXLv2
            ChatHandler -->|selects protocol| NIXLv1
            ChatHandler -->|selects protocol| LMCache
            NIXLv2 -->|reuses handlers| LRUCache
            NIXLv1 -->|reuses handlers| LRUCache
            LMCache -->|reuses handlers| LRUCache
        end

        Decoder["vLLM Decoder<br/>Port 8001/TCP<br/>(local)"]
    end

    subgraph RemotePods["Remote Prefiller Pods"]
        Prefiller["vLLM Prefiller<br/>(remote GPU worker)"]
    end

    subgraph K8sControl["Kubernetes Control Plane"]
        APIServer["Kubernetes API Server<br/>443/TCP"]
        InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        PodAPI["Pod API<br/>(watch/list)"]
    end

    Client -->|"POST /v1/chat/completions<br/>+ x-prefiller-host-port header"| Proxy
    NIXLv2 -->|"prefill request"| Prefiller
    NIXLv1 -->|"prefill request"| Prefiller
    LMCache -->|"prefill request<br/>(max_tokens=1)"| Prefiller
    Prefiller -->|"kv_transfer_params"| Sidecar
    Passthrough -->|"forward request"| Decoder
    NIXLv2 -->|"modified request<br/>+ KV transfer params"| Decoder
    NIXLv1 -->|"modified request<br/>+ KV transfer params"| Decoder
    LMCache -->|"original request"| Decoder

    AllowlistValidator -->|"watch InferencePool + Pods"| APIServer
    APIServer --- InferencePoolCR
    APIServer --- PodAPI

    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style ChatHandler fill:#4a90e2,stroke:#333,color:#fff
    style CompletionsHandler fill:#4a90e2,stroke:#333,color:#fff
    style HealthHandler fill:#4a90e2,stroke:#333,color:#fff
    style Passthrough fill:#4a90e2,stroke:#333,color:#fff
    style NIXLv2 fill:#7ed321,stroke:#333,color:#fff
    style NIXLv1 fill:#999,stroke:#333,color:#fff
    style LMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#f5a623,stroke:#333,color:#fff
    style TLSConfig fill:#f5a623,stroke:#333,color:#fff
    style LRUCache fill:#9b59b6,stroke:#333,color:#fff
    style Decoder fill:#e74c3c,stroke:#333,color:#fff
    style Prefiller fill:#e74c3c,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style APIServer fill:#e8e8e8,stroke:#333
    style PodAPI fill:#e8e8e8,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
