graph TB
    subgraph External["External Traffic"]
        Client["Client<br/>(EPP / Gateway)"]
    end

    subgraph SidecarPod["Pod: vLLM Decoder + Routing Sidecar"]
        subgraph Sidecar["llm-d-routing-sidecar (Go HTTP Reverse Proxy)"]
            TLSServer["TLS Server<br/>8000/TCP<br/>TLS 1.2+"]
            ChatHandler["/v1/chat/completions<br/>Handler"]
            CompHandler["/v1/completions<br/>Handler"]
            HealthHandler["/health<br/>Handler"]
            CatchAll["/* Catch-All<br/>Passthrough"]
            ConnectorNIXLv2["NIXL v2 Connector<br/>(recommended)"]
            ConnectorNIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            ConnectorLMCache["LMCache Connector<br/>(deprecated)"]
            PrefillerLRU["Prefiller Proxy<br/>LRU Cache (cap: 16)"]
            DecoderProxy["Decoder Reverse<br/>Proxy (localhost)"]

            subgraph SSRFProtection["SSRF Protection (Optional)"]
                AllowlistValidator["AllowlistValidator<br/>(K8s Informer)"]
                AllowlistCache["In-Memory<br/>IP Allowlist"]
            end
        end

        DecoderVLLM["vLLM Decoder<br/>8001/TCP"]
    end

    subgraph RemotePods["Remote Prefiller Pods"]
        PrefillerVLLM["vLLM Prefiller<br/>(varies port)"]
    end

    subgraph K8sAPI["Kubernetes API"]
        InferencePoolCR["InferencePool CR<br/>(inference.networking.x-k8s.io/v1alpha2)"]
        PodResources["Pod Resources"]
    end

    %% External traffic flow
    Client -->|"HTTPS/8000<br/>TLS 1.2+"| TLSServer
    TLSServer --> ChatHandler
    TLSServer --> CompHandler
    TLSServer --> HealthHandler
    TLSServer --> CatchAll

    %% Handler routing
    ChatHandler -->|"x-prefiller-host-port<br/>header present"| ConnectorNIXLv2
    CompHandler -->|"x-prefiller-host-port<br/>header present"| ConnectorNIXLv2
    ChatHandler -->|"no prefill header"| DecoderProxy
    CompHandler -->|"no prefill header"| DecoderProxy
    CatchAll --> DecoderProxy

    %% Connector flow
    ConnectorNIXLv2 -->|"validate target"| AllowlistValidator
    ConnectorNIXLv2 -->|"get/create proxy"| PrefillerLRU
    PrefillerLRU -->|"HTTP(S)"| PrefillerVLLM
    ConnectorNIXLv2 -->|"forward with<br/>kv_transfer_params"| DecoderProxy

    %% Local decoder
    DecoderProxy -->|"HTTP(S)/8001"| DecoderVLLM

    %% SSRF allowlist
    AllowlistValidator -->|"watch"| InferencePoolCR
    AllowlistValidator -->|"watch matching pods"| PodResources
    AllowlistValidator -->|"update"| AllowlistCache

    %% Styles
    style TLSServer fill:#4a90e2,color:#fff
    style ChatHandler fill:#4a90e2,color:#fff
    style CompHandler fill:#4a90e2,color:#fff
    style HealthHandler fill:#4a90e2,color:#fff
    style CatchAll fill:#4a90e2,color:#fff
    style ConnectorNIXLv2 fill:#7ed321,color:#fff
    style ConnectorNIXLv1 fill:#999,color:#fff
    style ConnectorLMCache fill:#999,color:#fff
    style PrefillerLRU fill:#f5a623,color:#fff
    style DecoderProxy fill:#f5a623,color:#fff
    style AllowlistValidator fill:#e74c3c,color:#fff
    style AllowlistCache fill:#e74c3c,color:#fff
    style DecoderVLLM fill:#9b59b6,color:#fff
    style PrefillerVLLM fill:#9b59b6,color:#fff
    style InferencePoolCR fill:#f5a623,color:#fff
    style Client fill:#e8e8e8,color:#333
