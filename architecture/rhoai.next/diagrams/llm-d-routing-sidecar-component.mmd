graph TB
    subgraph External["External Clients"]
        Client["Client<br/>(EPP / Gateway)"]
    end

    subgraph SidecarPod["Pod: vLLM Decoder + Sidecar"]
        subgraph Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]
            TLSServer["TLS Server<br/>8000/TCP HTTPS<br/>TLS 1.2+"]
            ChatHandler["/v1/chat/completions<br/>Handler"]
            CompletionsHandler["/v1/completions<br/>Handler"]
            HealthHandler["/health<br/>Handler"]
            CatchAll["/* Catch-All<br/>Passthrough Proxy"]
            ConnectorNIXLv2["NIXL v2 Connector<br/>(recommended)"]
            ConnectorNIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            ConnectorLMCache["LMCache Connector<br/>(deprecated)"]
            AllowlistValidator["AllowlistValidator<br/>(SSRF Protection)"]
            LRUCache["LRU Cache<br/>(Prefiller Proxy Pool<br/>capacity: 16)"]
            DecoderProxy["Decoder Reverse Proxy<br/>(localhost)"]
        end

        DecoderVLLM["vLLM Decoder<br/>8001/TCP"]
    end

    subgraph RemotePods["Remote Prefiller Pods"]
        PrefillerVLLM["vLLM Prefiller<br/>(remote pod)"]
    end

    subgraph K8sAPI["Kubernetes API"]
        InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        PodResources["Pod Resources"]
    end

    %% Client flow
    Client -->|"HTTPS/8000<br/>x-prefiller-host-port header"| TLSServer
    TLSServer --> ChatHandler
    TLSServer --> CompletionsHandler
    TLSServer --> HealthHandler
    TLSServer --> CatchAll

    %% Request processing
    ChatHandler -->|"validates target"| AllowlistValidator
    CompletionsHandler -->|"validates target"| AllowlistValidator
    ChatHandler -->|"P/D routing"| ConnectorNIXLv2
    CompletionsHandler -->|"P/D routing"| ConnectorNIXLv2

    %% Connector to prefiller
    ConnectorNIXLv2 -->|"get/create proxy"| LRUCache
    LRUCache -->|"HTTP(S) prefill request<br/>max_tokens=1, do_remote_decode=true"| PrefillerVLLM

    %% Connector to decoder
    ConnectorNIXLv2 -->|"forward with KV metadata"| DecoderProxy
    CatchAll -->|"passthrough"| DecoderProxy
    DecoderProxy -->|"HTTP(S)/8001"| DecoderVLLM

    %% SSRF allowlist
    AllowlistValidator -->|"Watch stream<br/>HTTPS/443"| InferencePoolCR
    AllowlistValidator -->|"Watch stream<br/>HTTPS/443"| PodResources

    %% Styles
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style TLSServer fill:#3a7bc8,stroke:#333,color:#fff
    style ChatHandler fill:#3a7bc8,stroke:#333,color:#fff
    style CompletionsHandler fill:#3a7bc8,stroke:#333,color:#fff
    style HealthHandler fill:#3a7bc8,stroke:#333,color:#fff
    style CatchAll fill:#3a7bc8,stroke:#333,color:#fff
    style ConnectorNIXLv2 fill:#5ba0d9,stroke:#333,color:#fff
    style ConnectorNIXLv1 fill:#999,stroke:#333,color:#fff
    style ConnectorLMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#e8a838,stroke:#333,color:#fff
    style LRUCache fill:#5ba0d9,stroke:#333,color:#fff
    style DecoderProxy fill:#5ba0d9,stroke:#333,color:#fff
    style DecoderVLLM fill:#7ed321,stroke:#333,color:#fff
    style PrefillerVLLM fill:#7ed321,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333,color:#fff
    style PodResources fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
