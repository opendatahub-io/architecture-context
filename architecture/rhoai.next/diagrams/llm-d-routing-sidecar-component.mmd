graph TB
    subgraph SidecarPod["vLLM Decoder Pod"]
        subgraph Sidecar["llm-d-routing-sidecar (Go Reverse Proxy)"]
            direction TB
            ProxyServer["Proxy Server<br/>:8000/TCP<br/>HTTP/HTTPS"]
            ChatHandler["Chat Completions Handler<br/>/v1/chat/completions"]
            CompHandler["Completions Handler<br/>/v1/completions"]
            PassThrough["Pass-through Handler<br/>/* (all other paths)"]
            HealthCheck["Health Check<br/>/health"]

            subgraph Connectors["P/D Connector Protocols"]
                direction LR
                NIXLv2["NIXL v2<br/>(current/default)"]
                NIXLv1["NIXL v1<br/>(deprecated)"]
                LMCache["LMCache<br/>(deprecated)"]
            end

            AllowlistValidator["AllowlistValidator<br/>(K8s Informer)<br/>SSRF Protection"]
            TLSManager["TLS Manager<br/>Self-signed / External Certs"]
            LRUCache["LRU Cache<br/>(capacity: 16)<br/>Prefiller Proxy Handlers"]

            ProxyServer --> ChatHandler
            ProxyServer --> CompHandler
            ProxyServer --> PassThrough
            ProxyServer --> HealthCheck
            ChatHandler --> Connectors
            CompHandler --> Connectors
            ChatHandler -.->|validates prefiller host| AllowlistValidator
            CompHandler -.->|validates prefiller host| AllowlistValidator
            TLSManager -->|configures TLS| ProxyServer
            Connectors -->|caches handlers| LRUCache
        end

        Decoder["vLLM Decoder<br/>localhost:8001/TCP"]
    end

    Client["Client<br/>(via Gateway/EPP)"] -->|"POST /v1/chat/completions<br/>x-prefiller-host-port header"| ProxyServer
    Connectors -->|"prefill request<br/>HTTP/HTTPS"| RemotePrefiller["Remote vLLM Prefiller<br/>{host}:{port}"]
    Connectors -->|"decode request<br/>HTTP/HTTPS"| Decoder
    PassThrough -->|"proxy all traffic"| Decoder

    AllowlistValidator -->|"watches CRs"| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    AllowlistValidator -->|"watches pods"| K8sAPI

    InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"] -.->|"label selector"| AllowlistValidator

    style ProxyServer fill:#4a90e2,stroke:#333,color:#fff
    style ChatHandler fill:#4a90e2,stroke:#333,color:#fff
    style CompHandler fill:#4a90e2,stroke:#333,color:#fff
    style PassThrough fill:#4a90e2,stroke:#333,color:#fff
    style HealthCheck fill:#4a90e2,stroke:#333,color:#fff
    style NIXLv2 fill:#7ed321,stroke:#333,color:#fff
    style NIXLv1 fill:#999,stroke:#333,color:#fff
    style LMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#f5a623,stroke:#333,color:#fff
    style TLSManager fill:#f5a623,stroke:#333,color:#fff
    style LRUCache fill:#f5a623,stroke:#333,color:#fff
    style Decoder fill:#d0e8ff,stroke:#333
    style RemotePrefiller fill:#d0e8ff,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePool fill:#ffe6cc,stroke:#d79b00
    style Client fill:#f9f9f9,stroke:#999
