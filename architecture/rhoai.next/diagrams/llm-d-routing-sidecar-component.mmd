graph TB
    subgraph Pod["Kubernetes Pod"]
        subgraph Sidecar["llm-d-routing-sidecar"]
            Proxy["HTTP Reverse Proxy<br/>Go net/http<br/>Port 8000/TCP"]
            ConnNIXLv2["NIXL v2 Connector<br/>(current protocol)"]
            ConnNIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            ConnLMCache["LMCache Connector<br/>(deprecated)"]
            AllowlistValidator["AllowlistValidator<br/>K8s Dynamic Watch Client"]
            TLSMgr["TLS Manager<br/>Self-signed or mounted certs<br/>TLS 1.2+ / RSA-4096"]
            LRUCache["LRU Cache<br/>Prefiller proxy handlers<br/>Capacity: 16"]

            Proxy --> ConnNIXLv2
            Proxy --> ConnNIXLv1
            Proxy --> ConnLMCache
            Proxy -->|SSRF check| AllowlistValidator
            Proxy --> TLSMgr
            Proxy --> LRUCache
        end

        Decoder["vLLM Decoder<br/>(co-located)<br/>Port 8001/TCP"]
    end

    Client["Client / Gateway"] -->|"POST /v1/chat/completions<br/>HTTPS 8000/TCP<br/>x-prefiller-host-port header"| Proxy
    Proxy -->|"Decode request<br/>HTTP(S) localhost:8001"| Decoder

    RemotePrefiller["Remote vLLM Prefiller<br/>(separate pod)"]
    Proxy -->|"Prefill request<br/>HTTP(S) variable port<br/>max_tokens=1"| RemotePrefiller
    RemotePrefiller -->|"KV transfer params<br/>(engine IDs, block IDs)"| Proxy

    InferencePoolCR["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    AllowlistValidator -->|"Watch pods & pool"| InferencePoolCR

    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    AllowlistValidator -->|"Dynamic client watch<br/>ServiceAccount token"| K8sAPI

    style Proxy fill:#4a90e2,color:#fff
    style AllowlistValidator fill:#4a90e2,color:#fff
    style ConnNIXLv2 fill:#50c878,color:#fff
    style ConnNIXLv1 fill:#999,color:#fff
    style ConnLMCache fill:#999,color:#fff
    style TLSMgr fill:#4a90e2,color:#fff
    style LRUCache fill:#4a90e2,color:#fff
    style Decoder fill:#f5a623,color:#fff
    style RemotePrefiller fill:#f5a623,color:#fff
    style InferencePoolCR fill:#e8e8e8
    style K8sAPI fill:#e8e8e8
    style Client fill:#d5e8d4
