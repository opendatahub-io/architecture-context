graph TB
    subgraph External["EXTERNAL CLIENTS (Untrusted)"]
        Browser["Browser / Client"]
        EnvoyClient["Envoy ext_authz<br/>(Service Mesh)"]
        K8sClient["K8s Client<br/>(SA Token)"]
        MLflow["MLflow Python SDK<br/>User-Agent: mlflow-python-client/*"]
    end

    subgraph KAP["KUBE-AUTH-PROXY (Sidecar)<br/>UBI 9 Minimal | FIPS: strictfipsruntime"]
        direction TB

        subgraph Listeners["Listeners"]
            HTTPListener["HTTP Listener<br/>4180/TCP<br/>No encryption"]
            HTTPSListener["HTTPS Listener<br/>443/TCP<br/>TLS 1.2-1.3<br/>NextProtos: http/1.1"]
            MetricsListener["Metrics Server<br/>configurable port<br/>HTTP/HTTPS"]
        end

        subgraph AuthChain["Authentication Chain"]
            K8sTokenAuth["K8s SA Token<br/>→ TokenReview API"]
            JWTAuth["JWT/OAuth Bearer<br/>→ JWKS verification"]
            BasicAuth["Basic Auth<br/>→ htpasswd file"]
            SessionAuth["Session Cookie<br/>→ AES-GCM decrypt"]
        end

        subgraph AuthZ["Authorization"]
            GroupCheck["allowed_groups"]
            EmailCheck["allowed_emails"]
            DomainCheck["allowed_email_domains"]
        end
    end

    subgraph UpstreamZone["UPSTREAM (Pod-local)"]
        Upstream["Upstream Application<br/>configurable port<br/>HTTP/HTTPS/Unix<br/>Trusts identity headers"]
    end

    subgraph IdentityProviders["IDENTITY PROVIDERS (External)"]
        OIDCIdP["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client ID/Secret + PKCE"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Client ID/Secret"]
    end

    subgraph K8sAPIs["KUBERNETES APIs"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (SA CA)<br/>POST /api/v1/tokenreviews"]
        OSAPI["OpenShift API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (SA CA)<br/>GET users/~ | DELETE oauthaccesstokens"]
    end

    subgraph OptionalServices["OPTIONAL SERVICES"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password/ACL<br/>Standalone/Sentinel/Cluster"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics endpoint"]
    end

    %% Inbound flows
    Browser -->|"4180 or 443/TCP<br/>HTTP or HTTPS TLS 1.2+<br/>Cookie / Bearer JWT"| Listeners
    EnvoyClient -->|"4180/TCP HTTP<br/>/oauth2/auth<br/>Forwarded cookies/Bearer<br/>→ 202 or 401/403"| Listeners
    K8sClient -->|"4180/TCP HTTP<br/>Authorization: Bearer SA-token"| Listeners
    MLflow -->|"4180/TCP HTTP<br/>Bearer / None<br/>Custom JSON error response"| Listeners

    %% Internal flow
    Listeners --> AuthChain
    AuthChain --> AuthZ

    %% Upstream
    AuthZ -->|"X-Forwarded-User<br/>X-Forwarded-Email<br/>X-Forwarded-Groups<br/>X-Forwarded-Preferred-Username"| Upstream

    %% Egress - Identity Providers
    AuthChain -->|"HTTPS/443<br/>TLS 1.2+<br/>Client ID/Secret + PKCE<br/>discovery, authorize, token, userinfo, end_session"| OIDCIdP
    AuthChain -->|"HTTPS/443<br/>TLS 1.2+ (custom CA)<br/>Client ID/Secret<br/>discovery, authorize, token"| OSAuth

    %% Egress - K8s APIs
    K8sTokenAuth -->|"HTTPS/443<br/>TLS 1.2+ (SA CA)<br/>SA Token<br/>TokenReview"| K8sAPI
    AuthChain -->|"HTTPS/443<br/>TLS 1.2+ (SA CA)<br/>Bearer Token<br/>user info, token cleanup"| OSAPI

    %% Egress - Optional
    SessionAuth -->|"6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Password/ACL"| Redis

    %% Monitoring
    Prometheus -->|"HTTP/HTTPS<br/>configurable port<br/>No auth"| MetricsListener

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    classDef upstream fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef idp fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f5f5f5,stroke:#aaa,stroke-width:1px,stroke-dasharray: 5 5
    classDef monitoring fill:#e6e6fa,stroke:#9370db,stroke-width:1px

    class Browser,EnvoyClient,K8sClient,MLflow external
    class HTTPListener,HTTPSListener,MetricsListener,K8sTokenAuth,JWTAuth,BasicAuth,SessionAuth,GroupCheck,EmailCheck,DomainCheck proxy
    class Upstream upstream
    class OIDCIdP,OSAuth idp
    class K8sAPI,OSAPI k8s
    class Redis optional
    class Prometheus monitoring
