graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser User"]
        APIClient["API Client"]
    end

    subgraph Ingress["INGRESS (Platform-managed)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → sidecar port<br/>TLS 1.2+ SIMPLE<br/>Created by rhods-operator"]
    end

    subgraph Pod["POD (Sidecar Architecture)"]
        direction TB

        subgraph ProxyContainer["kube-auth-proxy Container"]
            direction LR

            subgraph AuthMode["AUTH MODE"]
                AuthProxy["kube-auth-proxy<br/>4180/HTTP, 4443/HTTPS<br/>TLS 1.2+<br/>Auth: OAuth2 session /<br/>Bearer / K8s token / Basic<br/>CSRF: PKCE + Nonce"]
            end

            subgraph RBACModeBox["RBAC MODE (default)"]
                RBACProxy["kube-rbac-proxy<br/>8443/HTTPS<br/>TLS 1.2+<br/>Auth: Bearer / x509 cert<br/>Authz: SAR (cached)<br/>HTTP/2 disabled"]
            end
        end

        UpstreamApp["Upstream Application<br/>(same pod)<br/>Configurable port<br/>HTTP/HTTPS/Unix/h2c"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        Prometheus["OpenShift Prometheus<br/>Scrapes /metrics<br/>Hardcoded allow:<br/>openshift-monitoring:prometheus-k8s"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["OIDC / OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials"]
        Redis["Redis (optional)<br/>6379/TCP<br/>TLS optional<br/>Password auth optional<br/>Standalone / Sentinel / Cluster"]
    end

    %% External → Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 session"| Route
    APIClient -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Route

    %% Ingress → Pod
    Route -->|"HTTPS/4443<br/>TLS 1.2+<br/>Re-encrypt"| AuthProxy
    Route -->|"HTTPS/8443<br/>TLS 1.2+<br/>Re-encrypt"| RBACProxy

    %% Pod internal (sidecar → upstream)
    AuthProxy -->|"HTTP/HTTPS/Unix<br/>Configurable<br/>GAP-Auth headers"| UpstreamApp
    RBACProxy -->|"HTTP/HTTPS/h2c<br/>Configurable<br/>Auth headers (optional)"| UpstreamApp

    %% Proxy → Cluster Services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview"| K8sAPI
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview + SAR"| K8sAPI
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Auto-allowed SA"| RBACProxy

    %% Proxy → External Services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>client_id + secret"| OIDC
    AuthProxy -->|"TCP/6379<br/>TLS optional<br/>Password optional"| Redis

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser,APIClient external
    class Route ingress
    class AuthProxy,RBACProxy,UpstreamApp pod
    class K8sAPI,Prometheus cluster
    class OIDC,Redis externalservice
