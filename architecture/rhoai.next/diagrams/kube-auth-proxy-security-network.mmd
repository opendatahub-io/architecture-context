graph TB
    subgraph External["EXTERNAL CLIENTS (Untrusted)"]
        Browser["Browser Client"]
        APIClient["API Client<br/>(JWT / sha256~ token)"]
        MLflow["MLflow Python SDK<br/>(mlflow-python-client/* UA)"]
        K8sSA["K8s Service Account<br/>Client"]
    end

    subgraph Gateway["GATEWAY LAYER (RHOAI 3.x)"]
        Envoy["Envoy Gateway<br/>ext_authz subrequest<br/>Returns 202/401/403"]
    end

    subgraph ProxyService["PROXY SERVICE (Sidecar Container)"]
        direction TB
        Proxy["kube-auth-proxy<br/>Ports: 4180/TCP (HTTP), 443/TCP (HTTPS)<br/>FIPS: GOEXPERIMENT=strictfipsruntime<br/>TLS: 1.2+ (configurable to 1.3)<br/>Base: UBI9 ubi-minimal"]
        MetricsSrv["Metrics Server<br/>Configurable port<br/>/metrics endpoint"]
    end

    subgraph UpstreamZone["UPSTREAM (Protected Backend)"]
        Upstream["Upstream Application<br/>Configurable port<br/>HTTP/HTTPS/Unix socket"]
    end

    subgraph IdentityProviders["IDENTITY PROVIDERS (Egress)"]
        OIDC["OIDC Provider<br/>(e.g., Keycloak)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OShiftOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>Retryable discovery"]
    end

    subgraph K8sAPIs["KUBERNETES / OPENSHIFT APIs (Egress)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS (in-cluster CA)<br/>TokenReview endpoint"]
        OShiftAPI["OpenShift API<br/>kubernetes.default.svc<br/>443/TCP HTTPS<br/>TLS (cluster CA)<br/>User info + token deletion"]
    end

    subgraph SessionStore["SESSION STORE (Optional Egress)"]
        Redis["Redis<br/>6379/TCP TCP/TLS<br/>Optional TLS + custom CA<br/>Auth: Username/Password<br/>Modes: Standalone/Sentinel/Cluster"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    %% Ingress flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Session cookie"| Proxy
    APIClient -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Proxy
    MLflow -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Proxy
    K8sSA -->|"HTTPS/443<br/>TLS 1.2+<br/>K8s SA token"| Proxy
    Envoy -->|"HTTP(S)/4180 or 443<br/>ext_authz /oauth2/auth<br/>Forwarded credentials"| Proxy

    %% Upstream flow
    Proxy -->|"HTTP/HTTPS/Unix<br/>Configurable port<br/>HMAC-SHA256 (optional)<br/>X-Forwarded-* headers"| Upstream

    %% IdP egress
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials"| OIDC
    Proxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials / SA token"| OShiftOAuth

    %% K8s API egress
    Proxy -->|"HTTPS/443<br/>TLS (in-cluster CA)<br/>SA token<br/>POST tokenreviews"| K8sAPI
    Proxy -->|"HTTPS/443<br/>TLS (cluster CA)<br/>User's Bearer token<br/>GET users/~ DELETE oauthaccesstokens"| OShiftAPI

    %% Session store
    Proxy -->|"TCP/TLS 6379<br/>Optional TLS<br/>Username/Password"| Redis

    %% Observability
    Prometheus -->|"HTTP(S)<br/>Configurable port<br/>No auth"| MetricsSrv

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef proxy fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef upstream fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef idp fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8sapi fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sessionstore fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef observability fill:#e6e6e6,stroke:#666,stroke-width:1px

    class Browser,APIClient,MLflow,K8sSA external
    class Envoy gateway
    class Proxy,MetricsSrv proxy
    class Upstream upstream
    class OIDC,OShiftOAuth idp
    class K8sAPI,OShiftAPI k8sapi
    class Redis sessionstore
    class Prometheus observability
