graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API / Route)"]
        EnvoyGW["Envoy Gateway / OpenShift Route<br/>443/TCP<br/>TLS 1.3 Termination<br/>Managed by rhods-operator"]
    end

    subgraph Pod["POD (Sidecar Pattern)"]
        direction TB

        subgraph AuthModeZone["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP | 443/TCP HTTPS<br/>OIDC / OpenShift OAuth / JWT / K8s SA Token<br/>FIPS: strictfipsruntime"]
        end

        subgraph RBACModeZone["RBAC Mode (PROXY_MODE=rbac)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ (configurable ciphers)<br/>Bearer + TokenReview + SAR<br/>FIPS: strictfipsruntime"]
        end

        UpstreamApp["Upstream Application<br/>(same pod, localhost)<br/>configurable port"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (in-cluster CA)<br/>ServiceAccount token"]

        Redis["Redis (optional)<br/>6379/TCP<br/>Optional TLS<br/>Password/ACL<br/>AES-GCM encrypted sessions"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client credentials"]

        OShiftOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client credentials"]
    end

    %% Flows - External to Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.3<br/>Cookie / Bearer / None"| EnvoyGW

    %% Flows - Ingress to Pod
    EnvoyGW -->|"HTTP/4180 (ext_authz)<br/>No encryption (pod-local)<br/>Forwarded headers"| AuthProxy
    EnvoyGW -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer token"| RBACProxy

    %% Flows - Sidecar to Upstream
    AuthProxy -->|"HTTP/HTTPS/h2c<br/>Optional TLS<br/>X-Forwarded-User/Email/Groups"| UpstreamApp
    RBACProxy -->|"HTTP/HTTPS/h2c<br/>Optional TLS<br/>x-remote-user/groups"| UpstreamApp

    %% Flows - to Cluster Internal
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview"| K8sAPI
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview + SAR"| K8sAPI
    AuthProxy -->|"Redis/6379<br/>Optional TLS<br/>Password/ACL"| Redis

    %% Flows - to External
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OIDC
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OShiftOAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterinternal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class EnvoyGW ingress
    class AuthProxy,RBACProxy,UpstreamApp pod
    class K8sAPI,Redis clusterinternal
    class OIDC,OShiftOAuth externalservice
