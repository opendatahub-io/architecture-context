graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser /<br/>External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Envoy["Envoy Proxy<br/>443/TCP → internal<br/>TLS 1.3 Termination<br/>ext_authz delegation"]
    end

    subgraph SidecarPod["SIDECAR PROXY (Pod-local)"]
        direction TB

        subgraph AuthModeBox["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP (pod-local)<br/>443/TCP HTTPS (optional)<br/>FIPS: strictfipsruntime<br/>SA: managed by rhods-operator"]
        end

        subgraph RBACModeBox["RBAC Mode (PROXY_MODE=rbac)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ (configurable)<br/>FIPS: strictfipsruntime<br/>SA: managed by rhods-operator"]
        end

        UpstreamApp["Upstream Application<br/>configurable port<br/>HTTP/HTTPS/h2c"]
    end

    subgraph IdentityProviders["IDENTITY PROVIDERS (External)"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client creds"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client creds"]
    end

    subgraph K8sCluster["KUBERNETES API (In-cluster)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (in-cluster CA)<br/>ServiceAccount token"]
    end

    subgraph SessionStore["SESSION STORAGE (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Redis protocol / TLS<br/>Password/ACL auth"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.3<br/>No auth (pre-login)"| Envoy

    %% Ingress → Sidecar (ext_authz)
    Envoy -->|"HTTP/4180<br/>No encryption (pod-local)<br/>ext_authz subrequest"| AuthProxy

    %% Auth Mode flows
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds + code"| OIDC
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OSAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+ (in-cluster CA)<br/>SA token (TokenReview)"| K8sAPI
    AuthProxy -->|"Redis/6379<br/>Optional TLS<br/>Password/ACL"| Redis
    AuthProxy -->|"HTTP/HTTPS<br/>Optional TLS<br/>Proxied headers"| UpstreamApp

    %% RBAC Mode flows
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+ (in-cluster CA)<br/>SA token (TokenReview + SAR)"| K8sAPI
    RBACProxy -->|"HTTP/HTTPS/h2c<br/>Optional TLS<br/>x-remote-user headers"| UpstreamApp

    %% Direct client to RBAC proxy
    User -.->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer token"| RBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef idp fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef upstream fill:#dcedc8,stroke:#689f38,stroke-width:2px

    class User external
    class Envoy ingress
    class AuthProxy,RBACProxy sidecar
    class OIDC,OSAuth idp
    class K8sAPI k8s
    class Redis storage
    class UpstreamApp upstream
