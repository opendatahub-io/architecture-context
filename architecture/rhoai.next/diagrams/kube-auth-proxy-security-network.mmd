graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser User"]
        SAClient["Service Account Client"]
    end

    subgraph PodNetwork["POD NETWORK (Sidecar Proxy)"]
        direction TB

        subgraph Container["Container: quay.io/rhoai/odh-kube-auth-proxy<br/>FIPS: strictfipsruntime"]
            direction LR

            subgraph AuthModeBox["Auth Mode"]
                AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP<br/>AuthN: K8s SA TokenReview,<br/>JWT Bearer, OAuth2 cookie,<br/>Basic Auth (htpasswd)<br/>Session: AES-CFB cookie"]
            end

            subgraph RBACModeBox["RBAC Mode (default)"]
                RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: TokenReview,<br/>OIDC JWT, X.509 cert<br/>AuthZ: SubjectAccessReview"]
            end
        end

        Upstream["Upstream Application<br/>Proxied requests<br/>Headers: GAP-Auth /<br/>x-remote-user / x-remote-groups"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Trusted - In-Cluster)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (in-cluster CA)<br/>SA token auth"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (service CA)<br/>OAuth2 client credentials"]
        OSUser["OpenShift User API<br/>443/TCP HTTPS<br/>TLS 1.2+ (service CA)<br/>Bearer token"]
        Redis["Redis (Optional)<br/>6379/TCP<br/>TLS optional<br/>Password auth optional"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["OIDC Provider<br/>(Keycloak, DEX)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 client credentials"]
    end

    %% External to proxy flows
    Browser -->|"HTTP/4180<br/>No encryption<br/>(TLS at ingress)<br/>OAuth2 flow"| AuthProxy
    SAClient -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer token"| RBACProxy
    SAClient -->|"HTTP/4180<br/>Bearer SA token"| AuthProxy

    %% Proxy to upstream
    AuthProxy -->|"HTTP/HTTPS<br/>configurable<br/>GAP-Auth header"| Upstream
    RBACProxy -->|"HTTP/HTTPS<br/>configurable<br/>x-remote-user"| Upstream

    %% Proxy to cluster services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview"| K8sAPI
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview +<br/>SubjectAccessReview"| K8sAPI
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OSAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| OSUser
    AuthProxy -->|"TCP/6379<br/>TLS optional<br/>Password optional"| Redis

    %% Proxy to external services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds<br/>OIDC discovery +<br/>token exchange"| OIDC

    %% Operator relationship
    Operator["rhods-operator"] -.->|"Deploys sidecar<br/>+ provisions RBAC"| Container

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef upstream fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff

    class Browser,SAClient external
    class AuthProxy,RBACProxy proxy
    class Upstream upstream
    class K8sAPI,OSAuth,OSUser,Redis cluster
    class OIDC extservice
    class Operator operator
