graph LR
    RestProxy["rest-proxy<br/>(gRPC-Gateway<br/>Reverse Proxy)"]

    %% Internal Platform Dependencies
    RestProxy -->|"sidecar in pod<br/>configured via ConfigMap"| ModelMesh["ModelMesh Serving"]
    RestProxy -->|"gRPC/8033<br/>localhost"| GRPCSrv["gRPC Inference Server<br/>(co-located)"]
    RestProxy -.->|"image config"| ConfigMap["model-serving-config<br/>ConfigMap"]

    %% External Go Dependencies
    RestProxy -->|"REST-to-gRPC<br/>translation"| GRPCGateway["grpc-gateway/v2<br/>v2.15.0"]
    RestProxy -->|"gRPC client"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    RestProxy -->|"protobuf<br/>serialization"| Protobuf["google.golang.org/protobuf<br/>v1.35.1"]
    RestProxy -->|"structured<br/>logging (zap)"| ControllerRuntime["controller-runtime<br/>v0.14.1"]

    %% Platform Infrastructure
    CertManager["cert-manager"] -.->|"TLS certs"| RestProxy
    PlatformIngress["Platform Ingress<br/>(routes traffic)"] -->|"HTTP/HTTPS<br/>8008/TCP"| RestProxy

    %% Styling
    style RestProxy fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style GRPCSrv fill:#7ed321,stroke:#333,color:#fff
    style ConfigMap fill:#7ed321,stroke:#333,color:#fff
    style GRPCGateway fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertManager fill:#f5a623,stroke:#333,color:#fff
    style PlatformIngress fill:#f5a623,stroke:#333,color:#fff
