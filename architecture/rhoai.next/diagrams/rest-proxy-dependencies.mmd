graph LR
    RestProxy["rest-proxy<br/>gRPC-to-REST Reverse Proxy"]

    %% External Library Dependencies
    subgraph ExternalLibs["External Libraries"]
        GRPCGateway["grpc-gateway/v2<br/>v2.15.0"]
        GRPC["google.golang.org/grpc<br/>v1.56.3"]
        Protobuf["google.golang.org/protobuf<br/>v1.35.1"]
        ControllerRuntime["controller-runtime<br/>v0.14.1<br/>(zap logger only)"]
    end

    RestProxy -->|"REST-to-gRPC<br/>translation"| GRPCGateway
    RestProxy -->|"gRPC client<br/>connections"| GRPC
    RestProxy -->|"protobuf<br/>serialization"| Protobuf
    RestProxy -->|"zap logger<br/>initialization"| ControllerRuntime

    %% Internal RHOAI Dependencies
    subgraph InternalDeps["Internal RHOAI Platform"]
        ModelMesh["ModelMesh Serving<br/>(gRPC backend)"]
        ModelMeshOperator["ModelMesh Operator<br/>(sidecar injection)"]
        ModelServingConfig["model-serving-config<br/>ConfigMap"]
    end

    RestProxy -->|"gRPC/8033<br/>localhost"| ModelMesh
    ModelMeshOperator -->|"deploys as<br/>sidecar"| RestProxy
    ModelServingConfig -->|"restProxy.image<br/>configuration"| RestProxy

    %% Protocol / Standard Dependencies
    subgraph Standards["Protocol Standards"]
        KServeV2REST["KServe V2<br/>REST Predict Protocol"]
        KServeV2gRPC["KServe V2<br/>gRPC Predict Protocol"]
        Proto["grpc_predict_v2.proto<br/>Protocol Definition"]
    end

    RestProxy -->|"implements"| KServeV2REST
    RestProxy -->|"translates to"| KServeV2gRPC
    Proto -.->|"generates gateway<br/>+ client code"| RestProxy

    %% Build Dependencies
    subgraph BuildDeps["Build Infrastructure"]
        Konflux["Konflux CI<br/>(FIPS build)"]
        UBI9["UBI9 Minimal<br/>Base Image"]
    end

    Konflux -.->|"CGO_ENABLED=1<br/>strictfipsruntime"| RestProxy
    UBI9 -.->|"runtime base<br/>+ OpenSSL"| RestProxy

    style RestProxy fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style GRPCGateway fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style ModelMeshOperator fill:#7ed321,stroke:#333,color:#fff
    style ModelServingConfig fill:#7ed321,stroke:#333,color:#fff
    style KServeV2REST fill:#f5a623,stroke:#333,color:#fff
    style KServeV2gRPC fill:#f5a623,stroke:#333,color:#fff
    style Proto fill:#f5a623,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333,color:#333
    style UBI9 fill:#e8e8e8,stroke:#333,color:#333
