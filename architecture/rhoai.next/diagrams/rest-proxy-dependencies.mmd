graph LR
    RestProxy["rest-proxy<br/>(Sidecar Proxy)"]

    %% Internal Platform Dependencies
    RestProxy -->|"gRPC inference<br/>8033/TCP localhost"| ModelMesh["ModelMesh Serving<br/>(Main Container)"]
    RestProxy -.->|"image config via<br/>model-serving-config ConfigMap"| ModelMeshConfig["ModelMesh Config<br/>(restProxy.image)"]

    %% External Library Dependencies
    RestProxy -->|"HTTP↔gRPC translation"| GRPCGateway["grpc-gateway/v2<br/>v2.15.0"]
    RestProxy -->|"gRPC client"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    RestProxy -->|"protobuf serialization"| Protobuf["google.golang.org/protobuf<br/>v1.35.1"]
    RestProxy -.->|"zap logging only"| ControllerRuntime["controller-runtime<br/>v0.14.1"]

    %% Protocol Definition
    RestProxy -->|"API definition"| Proto["grpc_predict_v2.proto<br/>(KServe V2 Protocol)"]

    %% Integration Points
    subgraph Integrators["Components that use rest-proxy"]
        direction TB
        MMServing["ModelMesh Serving<br/>(deploys as sidecar)"]
    end

    MMServing -->|"deploys"| RestProxy

    %% Styling
    style RestProxy fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style ModelMeshConfig fill:#7ed321,stroke:#333,color:#fff
    style GRPCGateway fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style Proto fill:#f5a623,stroke:#333,color:#fff
    style MMServing fill:#7ed321,stroke:#333,color:#fff

    linkStyle 5 stroke:#999,stroke-dasharray: 5 5
