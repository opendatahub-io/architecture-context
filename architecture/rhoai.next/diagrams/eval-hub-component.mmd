graph TB
    subgraph EvalHub["Eval Hub Service"]
        direction TB
        API["eval-hub<br/>Go REST API<br/>8080/TCP"]
        AuthMiddleware["Auth Middleware<br/>TokenReview + SAR"]
        ConfigLoader["Config Loader<br/>Hot-Reload (fsnotify)"]
        K8sRuntime["Kubernetes Runtime<br/>Job Builder"]

        API --> AuthMiddleware
        API --> ConfigLoader
        API --> K8sRuntime
    end

    subgraph EvalJobPod["Evaluation Job Pod"]
        direction TB
        InitContainer["eval-runtime-init<br/>Go CLI<br/>S3 Data Download"]
        Sidecar["eval-runtime-sidecar<br/>Go HTTP Proxy<br/>8080/TCP (localhost)"]
        Adapter["Eval Adapter Container<br/>(lm-eval / lighteval /<br/>garak / guideLLM)"]

        InitContainer -.->|"shared volume"| Adapter
        Adapter -->|"HTTP localhost:8080<br/>plaintext"| Sidecar
    end

    subgraph MCPServer["MCP Server (Optional)"]
        MCP["evalhub-mcp<br/>Go MCP Server<br/>3001/TCP"]
    end

    %% External actors
    Client["Client<br/>(Dashboard / CLI)"]
    AIAgent["AI Agent<br/>(MCP Client)"]

    %% External services
    K8sAPI["Kubernetes API<br/>443/TCP"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflow["MLflow Tracking<br/>Server"]
    S3["S3 Storage"]
    OCI["OCI Registry<br/>(Quay)"]
    OTEL["OTEL Collector<br/>4317/4318"]
    Prometheus["Prometheus"]

    %% Client flows
    Client -->|"HTTPS 8080<br/>Bearer Token"| API
    AIAgent -->|"HTTP/stdio<br/>3001/TCP"| MCP

    %% API to external
    API -->|"HTTPS 443"| K8sAPI
    API -->|"SQL 5432"| PostgreSQL
    API -->|"HTTPS"| MLflow
    API -->|"OTLP"| OTEL
    K8sRuntime -->|"creates Jobs"| K8sAPI

    %% MCP to API
    MCP -->|"HTTPS 8080"| API

    %% Sidecar egress
    Sidecar -->|"HTTPS 8080<br/>SA token"| API
    Sidecar -->|"HTTPS<br/>Projected SA token"| MLflow
    Sidecar -->|"HTTPS 443<br/>Docker config"| OCI

    %% Init container
    InitContainer -->|"HTTPS 443<br/>AWS creds"| S3

    %% Prometheus scrape
    Prometheus -.->|"scrape /metrics<br/>8080/TCP"| API

    %% ConfigMap
    ConfigMap["ConfigMap<br/>(Provider/Collection YAML)"]
    ConfigMap -.->|"volume mount<br/>hot-reload"| ConfigLoader

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style AuthMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style ConfigLoader fill:#4a90e2,stroke:#333,color:#fff
    style K8sRuntime fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#50a0d2,stroke:#333,color:#fff
    style InitContainer fill:#50a0d2,stroke:#333,color:#fff
    style Adapter fill:#e8e8e8,stroke:#333
    style MCP fill:#6ba0d2,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333
    style AIAgent fill:#f5a623,stroke:#333
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333
    style S3 fill:#999,stroke:#333,color:#fff
    style OCI fill:#999,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#fff2cc,stroke:#d6b656
