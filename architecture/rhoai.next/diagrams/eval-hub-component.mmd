graph TB
    subgraph EvalHubSystem["EvalHub System"]
        direction TB

        subgraph APIPod["eval-hub Pod"]
            RBAC1["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS 1.2+ / Bearer Token"]
            API["eval-hub API<br/>Go REST Service<br/>8080/TCP (API)<br/>8081/TCP (metrics)"]
            RBAC1 -->|"X-Tenant + X-User<br/>headers injected"| API
        end

        subgraph MCPPod["evalhub-mcp Pod"]
            RBAC2["kube-rbac-proxy<br/>8443/TCP → 3001/TCP<br/>TLS 1.2+ / Bearer Token"]
            MCP["evalhub-mcp<br/>MCP Server<br/>3001/TCP"]
            RBAC2 -->|"X-Tenant + X-User<br/>headers injected"| MCP
        end

        subgraph EvalJobPod["Evaluation Job Pod"]
            Init["eval-runtime-init<br/>Init Container"]
            Adapter["Benchmark Adapter<br/>(lm-eval-harness, RAGAS,<br/>Garak, GuideLLM, LightEval)"]
            Sidecar["eval-runtime-sidecar<br/>Credential Proxy<br/>8080/TCP"]
            Init -->|"downloads test data<br/>before start"| Adapter
            Adapter -->|"HTTP/8080<br/>ref tokens"| Sidecar
        end
    end

    %% External Users
    User["User / Client"] -->|"HTTPS/8443<br/>Bearer Token"| RBAC1
    AIAssistant["AI Assistant<br/>(Cursor, VS Code,<br/>Claude Code)"] -->|"HTTPS/8443<br/>Bearer Token"| RBAC2

    %% MCP to API
    MCP -->|"HTTP/8080 or HTTPS/8443<br/>Bearer token"| API

    %% API creates Jobs
    API -->|"creates batch/v1 Jobs"| EvalJobPod

    %% CRD
    EvalHubCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]
    TrustyAIOp["TrustyAI Service<br/>Operator"] -->|"watches"| EvalHubCR
    TrustyAIOp -->|"creates/manages"| APIPod
    TrustyAIOp -->|"creates/manages"| MCPPod

    %% Sidecar connections
    Sidecar -->|"HTTPS<br/>SA token"| API
    Sidecar -->|"HTTPS<br/>credential injection"| ModelEndpoint["Model Endpoint"]
    Sidecar -->|"HTTPS<br/>Bearer token"| MLflow["MLflow"]
    Sidecar -->|"HTTPS/443<br/>OAuth2"| OCIRegistry["OCI Registry"]

    %% Init container
    Init -->|"HTTPS/443<br/>AWS IAM"| S3["S3 Storage"]

    %% API dependencies
    API -->|"TCP/5432"| PostgreSQL["PostgreSQL"]
    API -->|"HTTPS/443<br/>SA token"| K8sAPI["Kubernetes API"]
    API -->|"gRPC/4317"| OTEL["OpenTelemetry<br/>Collector"]
    API -->|"HTTPS<br/>Bearer token"| MLflow

    %% Prometheus
    Prometheus["Prometheus"] -->|"scrape<br/>HTTP/8081"| API

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style MCP fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#4a90e2,stroke:#333,color:#fff
    style Init fill:#4a90e2,stroke:#333,color:#fff
    style RBAC1 fill:#f5a623,stroke:#333,color:#fff
    style RBAC2 fill:#f5a623,stroke:#333,color:#fff
    style EvalHubCR fill:#f5a623,stroke:#333
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style Adapter fill:#9b59b6,stroke:#333,color:#fff
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style ModelEndpoint fill:#e8e8e8,stroke:#333
    style OTEL fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
