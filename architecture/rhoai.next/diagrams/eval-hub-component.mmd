graph TB
    subgraph EvalHubService["EvalHub Service (eval-hub)"]
        direction TB
        API["eval-hub API Server<br/>Go · 8080/TCP HTTP<br/>8081/TCP Metrics"]
        Handlers["REST Handlers<br/>/api/v1/evaluations/*"]
        Storage["Storage Layer<br/>SQLite (dev) / PostgreSQL (prod)"]
        ConfigWatcher["Config Watcher<br/>fsnotify · live reload"]
        K8sRuntime["K8s Runtime<br/>Job/ConfigMap/Secret CRUD"]
        LocalRuntime["Local Runtime<br/>CLI / dev mode"]
        MLflowClient["MLflow Client<br/>Experiment & run tracking"]

        API --> Handlers
        Handlers --> Storage
        Handlers --> K8sRuntime
        Handlers --> LocalRuntime
        Handlers --> MLflowClient
        ConfigWatcher -->|live reload| Handlers
    end

    subgraph AuthProxy["Auth Proxy"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph JobPod["Evaluation Job Pod"]
        direction TB
        InitContainer["eval-runtime-init<br/>Go Init Container<br/>S3 test data download"]
        Sidecar["eval-runtime-sidecar<br/>Go Native Sidecar (KEP-753)<br/>8080/TCP"]
        Adapter["Adapter Container<br/>lm-eval-harness / RAGAS /<br/>Garak / GuideLLM / etc."]

        InitContainer -.->|completes before| Sidecar
        Sidecar -->|ready before| Adapter
        Adapter -->|all traffic via| Sidecar
    end

    subgraph MCPServer["MCP Server (evalhub-mcp)"]
        MCP["evalhub-mcp<br/>Go · 3001/TCP HTTP<br/>or stdio transport"]
    end

    %% External actors
    Client["Client<br/>(Dashboard / CLI / User)"]
    AIAgent["AI Agent<br/>(Claude / Cursor / Copilot)"]

    %% CRDs
    EvalHubCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]
    HardwareProfileCR["HardwareProfile CR<br/>infrastructure.opendatahub.io/v1"]

    %% External services
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    MLflow["MLflow Tracking Server"]
    S3["S3-compatible Storage"]
    OCIRegistry["OCI Registry"]
    ModelEndpoint["Model Inference<br/>Endpoint"]

    %% Operator
    TrustyAIOp["TrustyAI Service Operator"]

    %% Flows
    TrustyAIOp -->|manages via CR| EvalHubCR
    EvalHubCR -->|deploys| EvalHubService
    TrustyAIOp -->|injects| KubeRBACProxy

    Client -->|HTTPS/8443| KubeRBACProxy
    KubeRBACProxy -->|HTTP/8080<br/>X-Tenant + X-User| API

    K8sRuntime -->|creates| JobPod
    K8sRuntime -->|CRUD| K8sAPI
    K8sRuntime -->|reads| HardwareProfileCR
    MLflowClient -->|REST| MLflow

    Sidecar -->|status events| KubeRBACProxy
    Sidecar -->|tracking| MLflow
    Sidecar -->|artifacts| OCIRegistry
    Sidecar -->|inference| ModelEndpoint
    InitContainer -->|download| S3

    AIAgent -->|MCP protocol| MCP
    MCP -->|HTTP client| API

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style MCP fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e8744f,stroke:#333,color:#fff
    style EvalHubCR fill:#f5a623,stroke:#333,color:#fff
    style HardwareProfileCR fill:#f5a623,stroke:#333,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style MLflow fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style OCIRegistry fill:#999,stroke:#333,color:#fff
    style ModelEndpoint fill:#999,stroke:#333,color:#fff
    style Adapter fill:#9b59b6,stroke:#333,color:#fff
