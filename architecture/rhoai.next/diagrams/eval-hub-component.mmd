graph TB
    subgraph EvalHub["Eval Hub Platform"]
        direction TB

        subgraph CoreService["eval-hub (Go REST API)"]
            Server["HTTP Server<br/>8080/TCP"]
            AuthN["AuthN Middleware<br/>K8s TokenReview"]
            AuthZ["AuthZ Middleware<br/>K8s SAR"]
            Handlers["API Handlers<br/>/api/v1/evaluations/*"]
            StorageLayer["Storage Layer<br/>SQLite / PostgreSQL"]
            RuntimeLayer["Runtime Layer<br/>K8s / Local"]
            ConfigWatcher["Config Watcher<br/>fsnotify + debounce"]
            Metrics["Prometheus Metrics<br/>/metrics"]
            OTEL["OTEL Exporter<br/>Traces + Metrics"]

            Server --> AuthN
            AuthN --> AuthZ
            AuthZ --> Handlers
            Handlers --> StorageLayer
            Handlers --> RuntimeLayer
            ConfigWatcher -->|hot-reload| Handlers
            Server --> Metrics
            Server --> OTEL
        end

        subgraph JobPod["Evaluation Job Pod (per benchmark)"]
            direction LR
            InitContainer["eval-runtime-init<br/>S3 Data Downloader"]
            Sidecar["eval-runtime-sidecar<br/>HTTP Reverse Proxy<br/>8080/TCP localhost"]
            Adapter["Evaluation Adapter<br/>Lighteval / lm-eval / Garak / etc."]

            InitContainer -->|downloads data| Adapter
            Adapter -->|localhost:8080| Sidecar
        end

        subgraph MCPServer["evalhub-mcp (Optional)"]
            MCP["MCP Server<br/>stdio / HTTP 3001/TCP"]
            MCPClient["EvalHub REST Client<br/>pkg/evalhubclient"]
            MCP --> MCPClient
        end
    end

    %% External actors
    Client["Client<br/>(Dashboard / API / CLI)"]
    AIAgent["AI Agent<br/>(MCP Consumer)"]

    %% External dependencies
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    MLflow["MLflow Tracking Server<br/>HTTPS"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    S3["S3 Object Storage<br/>443/TCP HTTPS"]
    OCIRegistry["OCI Registry<br/>443/TCP HTTPS"]
    OTELCollector["OTEL Collector<br/>4317/TCP gRPC"]

    %% Client flows
    Client -->|"HTTPS 8080<br/>Bearer Token"| Server
    AIAgent -->|"stdio / HTTP 3001"| MCP
    MCPClient -->|"HTTPS 8080<br/>Bearer Token"| Server

    %% Core service egress
    AuthN -->|TokenReview| K8sAPI
    AuthZ -->|SubjectAccessReview| K8sAPI
    RuntimeLayer -->|"Create Job/ConfigMap"| K8sAPI
    StorageLayer -->|"5432/TCP"| PostgreSQL
    Handlers -->|"Experiment tracking"| MLflow
    OTEL -->|"OTLP gRPC"| OTELCollector

    %% Job pod egress
    InitContainer -->|"Download test data"| S3
    Sidecar -->|"Status updates"| Server
    Sidecar -->|"Run tracking"| MLflow
    Sidecar -->|"Artifact push"| OCIRegistry

