graph TB
    subgraph EvalHub["Eval Hub Service"]
        direction TB

        subgraph APILayer["HTTP Handler Layer"]
            Server["eval-hub API Server<br/>Go REST API<br/>8080/TCP"]
            AuthN["AuthN Middleware<br/>K8s TokenReview<br/>2-min cache"]
            AuthZ["AuthZ Middleware<br/>K8s SubjectAccessReview<br/>5-min allow / 30s deny cache"]
            Server --> AuthN --> AuthZ
        end

        subgraph StorageLayer["Storage Abstraction"]
            StorageIF["Storage Interface<br/>WithTenant / WithOwner"]
            PostgreSQL["PostgreSQL Driver<br/>pgx"]
            SQLite["SQLite Driver<br/>modernc.org/sqlite"]
            StorageIF --> PostgreSQL
            StorageIF --> SQLite
        end

        subgraph RuntimeLayer["Runtime Abstraction"]
            RuntimeIF["Runtime Interface"]
            K8sRuntime["Kubernetes Runtime<br/>Batch Jobs + ConfigMaps"]
            LocalRuntime["Local Runtime<br/>Shell Subprocess"]
            RuntimeIF --> K8sRuntime
            RuntimeIF --> LocalRuntime
        end

        subgraph Observability["Observability"]
            Prometheus["Prometheus Metrics<br/>/metrics endpoint"]
            OTEL["OpenTelemetry<br/>OTLP gRPC/HTTP"]
        end

        AuthZ --> StorageIF
        AuthZ --> RuntimeIF
    end

    subgraph JobPod["Evaluation Job Pod (KEP-753)"]
        direction LR
        InitContainer["eval-runtime-init<br/>S3 Data Downloader"]
        Sidecar["eval-runtime-sidecar<br/>HTTP Reverse Proxy<br/>8080/TCP localhost"]
        Adapter["Evaluation Adapter<br/>(Lighteval / lm-eval / Garak / etc.)"]
        InitContainer -.->|"completes before"| Adapter
        Adapter -->|"localhost:8080"| Sidecar
    end

    subgraph MCPServer["evalhub-mcp"]
        MCP["MCP Server<br/>stdio / HTTP:3001"]
    end

    Client["Client<br/>(Dashboard / API / CLI)"] -->|"HTTPS 8080<br/>Bearer Token"| Server
    K8sRuntime -->|"creates"| JobPod
    Sidecar -->|"HTTPS 8080<br/>SA Token"| Server
    MCP -->|"REST API<br/>Bearer Token"| Server

    Sidecar -->|"HTTPS<br/>Projected SA Token"| MLflow["MLflow Tracking Server"]
    Sidecar -->|"HTTPS 443<br/>Bearer Token"| OCIRegistry["OCI Registry"]
    InitContainer -->|"HTTPS 443<br/>AWS IAM"| S3["S3 Object Storage"]

    K8sRuntime -->|"HTTPS 443<br/>SA Token"| K8sAPI["Kubernetes API Server"]
    AuthN -->|"TokenReview<br/>HTTPS 443"| K8sAPI
    AuthZ -->|"SAR<br/>HTTPS 443"| K8sAPI

    style Server fill:#4a90e2,color:#fff
    style AuthN fill:#4a90e2,color:#fff
    style AuthZ fill:#4a90e2,color:#fff
    style StorageIF fill:#4a90e2,color:#fff
    style RuntimeIF fill:#4a90e2,color:#fff
    style Sidecar fill:#4a90e2,color:#fff
    style InitContainer fill:#4a90e2,color:#fff
    style MCP fill:#4a90e2,color:#fff
    style Prometheus fill:#50c878,color:#fff
    style OTEL fill:#50c878,color:#fff
    style PostgreSQL fill:#336791,color:#fff
    style SQLite fill:#003b57,color:#fff
    style K8sRuntime fill:#326ce5,color:#fff
    style LocalRuntime fill:#326ce5,color:#fff
    style Client fill:#f5a623,color:#fff
    style MLflow fill:#0194e2,color:#fff
    style OCIRegistry fill:#999,color:#fff
    style S3 fill:#e47911,color:#fff
