graph TB
    subgraph EvalHub["Eval Hub Service"]
        direction TB
        API["eval-hub API Server<br/>Go REST API<br/>8080/TCP"]
        AuthN["AuthN Middleware<br/>K8s TokenReview"]
        AuthZ["AuthZ Middleware<br/>K8s SubjectAccessReview"]
        Storage["Storage Layer<br/>SQLite / PostgreSQL"]
        RuntimeK8s["K8s Runtime<br/>Batch Job Creator"]
        RuntimeLocal["Local Runtime<br/>Shell Subprocess"]
        ConfigWatcher["Config Watcher<br/>fsnotify + debounce"]
        Metrics["Prometheus Metrics<br/>/metrics"]
        OTEL["OpenTelemetry<br/>Tracing + Metrics"]

        API -->|validates| AuthN
        AuthN -->|authorizes| AuthZ
        AuthZ -->|queries| Storage
        AuthZ -->|dispatches| RuntimeK8s
        AuthZ -->|dispatches| RuntimeLocal
        API --> Metrics
        API --> OTEL
        ConfigWatcher -->|reloads providers/collections| API
    end

    subgraph JobPod["Evaluation Job Pod"]
        direction TB
        InitContainer["eval-runtime-init<br/>S3 Data Downloader"]
        Sidecar["eval-runtime-sidecar<br/>HTTP Reverse Proxy<br/>8080/TCP (localhost)"]
        Adapter["Evaluation Adapter<br/>(Lighteval / lm-eval / Garak / etc.)"]

        InitContainer -.->|completes before| Adapter
        Adapter -->|localhost:8080| Sidecar
    end

    subgraph MCP["MCP Server"]
        MCPServer["evalhub-mcp<br/>stdio / HTTP 3001/TCP"]
    end

    Client["Client<br/>(Dashboard / API User)"] -->|"HTTPS 8080/TCP<br/>Bearer Token"| API
    MCPServer -->|"REST API<br/>Bearer Token"| API

    RuntimeK8s -->|"creates Job + ConfigMap"| K8sAPI["Kubernetes API<br/>443/TCP"]
    API -->|"TokenReview + SAR"| K8sAPI

    Sidecar -->|"HTTPS<br/>SA Token"| API
    Sidecar -->|"HTTPS<br/>Projected SA Token"| MLflow["MLflow Tracking Server"]
    Sidecar -->|"HTTPS<br/>Bearer Token"| OCIRegistry["OCI Registry"]
    InitContainer -->|"HTTPS<br/>AWS IAM"| S3["S3 Object Storage"]
    Storage -->|"TCP 5432"| PostgreSQL["PostgreSQL"]

    ConfigWatcher -.->|watches| ConfigMaps["Provider/Collection<br/>ConfigMaps"]

    style API fill:#4a90e2,stroke:#333,color:#fff
    style AuthN fill:#4a90e2,stroke:#333,color:#fff
    style AuthZ fill:#4a90e2,stroke:#333,color:#fff
    style Storage fill:#4a90e2,stroke:#333,color:#fff
    style RuntimeK8s fill:#4a90e2,stroke:#333,color:#fff
    style RuntimeLocal fill:#4a90e2,stroke:#333,color:#fff
    style ConfigWatcher fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style OTEL fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#50c878,stroke:#333,color:#fff
    style InitContainer fill:#50c878,stroke:#333,color:#fff
    style Adapter fill:#50c878,stroke:#333,color:#fff
    style MCPServer fill:#9b59b6,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Client fill:#f5a623,stroke:#333,color:#fff
