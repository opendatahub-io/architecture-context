graph TB
    subgraph EvalHub["Eval-Hub Service"]
        direction TB
        API["eval-hub API Server<br/>Go REST API<br/>8080/TCP"]
        AuthN["Authentication<br/>K8s TokenReview"]
        AuthZ["Authorization<br/>K8s SubjectAccessReview"]
        Storage["Storage Layer<br/>PostgreSQL / SQLite"]
        ConfigWatcher["Config Watcher<br/>inotify hot-reload"]
        JobBuilder["Job Builder<br/>K8s batch/v1 Jobs"]
        MLflowClient["MLflow Client<br/>Experiment Tracking"]

        API --> AuthN
        AuthN --> AuthZ
        AuthZ --> Storage
        API --> JobBuilder
        API --> MLflowClient
        API --> ConfigWatcher
    end

    subgraph EvalJobPod["Evaluation Job Pod"]
        direction TB
        InitContainer["eval-runtime-init<br/>Go Init Container<br/>S3 Data Download"]
        Sidecar["eval-runtime-sidecar<br/>Go Sidecar Proxy<br/>8080/TCP localhost"]
        Adapter["Adapter Container<br/>LM Eval / Garak /<br/>Lighteval / GuideLLM"]

        InitContainer -.->|"completes before"| Adapter
        Adapter -->|"HTTP localhost:8080"| Sidecar
    end

    Client["Client<br/>Dashboard / CLI"] -->|"HTTPS 8080/TCP<br/>Bearer Token"| API

    JobBuilder -->|"creates"| EvalJobPod
    Sidecar -->|"HTTPS 8443/TCP<br/>SA Token callback"| API
    Sidecar -->|"HTTPS<br/>Projected SA Token"| MLflow["MLflow Tracking Server"]
    Sidecar -->|"HTTPS 443/TCP<br/>Registry Token"| OCIRegistry["OCI Registry"]
    InitContainer -->|"HTTPS 443/TCP<br/>AWS IAM"| S3["S3-compatible Storage"]

    API -->|"HTTPS 443/TCP<br/>SA Token"| K8sAPI["Kubernetes API Server"]
    MLflowClient -->|"HTTPS<br/>Bearer Token"| MLflow
    Storage -->|"pgx 5432/TCP<br/>Username/Password"| PostgreSQL["PostgreSQL Database"]
    ConfigWatcher -->|"reads"| ConfigMaps["ConfigMap Mounts<br/>providers/ collections/"]

    style API fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style AuthN fill:#4a90e2,stroke:#333,color:#fff
    style AuthZ fill:#4a90e2,stroke:#333,color:#fff
    style Storage fill:#4a90e2,stroke:#333,color:#fff
    style ConfigWatcher fill:#4a90e2,stroke:#333,color:#fff
    style JobBuilder fill:#4a90e2,stroke:#333,color:#fff
    style MLflowClient fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#50c878,stroke:#333,color:#fff
    style Sidecar fill:#50c878,stroke:#333,color:#fff
    style Adapter fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style ConfigMaps fill:#e8e8e8,stroke:#333
