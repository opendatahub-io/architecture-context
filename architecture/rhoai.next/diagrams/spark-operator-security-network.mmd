graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>Bearer / client cert / SA token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB

        Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>9443/TCP HTTPS (self-signed TLS)<br/>8080/TCP metrics (HTTP)<br/>8081/TCP probes (HTTP)<br/>HTTP/2 disabled (CVE-2023-44487)"]

        Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>8080/TCP metrics (HTTP)<br/>8081/TCP probes (HTTP)"]

        SparkSubmit["spark-submit<br/>(local process exec)"]

        WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443<br/>HTTPS"]
    end

    subgraph UserNS["USER NAMESPACE (NetworkPolicy protected)"]
        direction TB

        Driver["Spark Driver Pod<br/>SA: spark-operator-spark<br/>Mutated by webhook (25+ ops)"]

        Executors["Spark Executor Pods<br/>Mutated by webhook"]

        ConnectServer["Spark Connect Server<br/>15002/TCP gRPC<br/>7078/TCP RPC<br/>7079/TCP BlockMgr<br/>4040/TCP WebUI"]

        UISvc["{app}-ui-svc<br/>ClusterIP 4040/TCP<br/>HTTP, no auth"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scraping"]
    end

    subgraph BatchSchedulers["BATCH SCHEDULERS (Optional)"]
        Volcano["Volcano<br/>(PodGroup CRDs)"]
        KubeSched["kube-scheduler plugins<br/>(PodGroup CRDs)"]
        Yunikorn["Yunikorn<br/>(annotation-based)"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer token"| K8sAPI

    %% API Server → Webhook (admission)
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert"| WebhookSvc
    WebhookSvc --> Webhook

    %% Controller → API Server
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (Bearer)"| K8sAPI

    %% Controller → spark-submit
    Controller -->|"Process exec<br/>No network"| SparkSubmit
    SparkSubmit -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Driver ↔ Executors
    Driver -->|"HTTP/7078 driver-rpc<br/>HTTP/7079 block-mgr<br/>No encryption<br/>No auth"| Executors

    %% Driver → API Server
    Driver -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Connect server
    ConnectServer -->|"HTTP/7078, 7079<br/>No encryption"| Executors

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Webhook

    %% Batch schedulers (via K8s API)
    Controller -.->|"PodGroup CRDs<br/>via K8s API"| Volcano
    Controller -.->|"PodGroup CRDs<br/>via K8s API"| KubeSched
    Controller -.->|"Pod annotations<br/>No network"| Yunikorn

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef scheduler fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Webhook,Controller,SparkSubmit,WebhookSvc operator
    class Driver,Executors,ConnectServer,UISvc userns
    class Prometheus monitoring
    class Volcano,KubeSched,Yunikorn scheduler
