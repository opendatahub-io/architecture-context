graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / X.509"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications)"]
        direction TB

        Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]

        Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>Webhook: 9443/TCP HTTPS TLS<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]

        WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443 → 9443<br/>TLS (self-signed/cert-manager)"]

        CertProvider["Certificate Provider<br/>RSA 2048-bit<br/>10yr validity / 180d rotation"]
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB

        DriverPod["Spark Driver Pod<br/>SA: spark-operator-spark<br/>Label: launched-by-spark-operator"]

        ExecutorPods["Spark Executor Pods<br/>SA: spark-operator-spark<br/>Webhook-mutated"]

        ConnectSvc["SparkConnect Service<br/>7078/TCP Spark RPC<br/>7079/TCP Spark RPC<br/>4040/TCP Spark UI<br/>15002/TCP Connect"]

        UISvc["{app}-ui-svc<br/>ClusterIP<br/>HTTP No TLS"]
    end

    subgraph OptionalIngress["OPTIONAL INGRESS"]
        Ingress["{app}-ui-ingress<br/>networking.k8s.io/v1<br/>80/443 TCP<br/>TLS: Optional"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP<br/>via PodMonitor"]
        JMXExporter["JMX Exporter Sidecar<br/>8090/TCP HTTP"]
    end

    subgraph Schedulers["OPTIONAL BATCH SCHEDULERS"]
        VolcanoSched["Volcano<br/>PodGroup CRD<br/>443/TCP HTTPS"]
        YunikornSched["Yunikorn<br/>Pod Annotations"]
        KubeSchedPG["kube-scheduler PodGroups<br/>scheduling.x-k8s.io<br/>443/TCP HTTPS"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% API Server to Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server client cert"| WebhookSvc
    WebhookSvc --> Webhook

    %% Controller to API Server
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller to spark-submit (local)
    Controller -->|"local exec<br/>spark-submit"| DriverPod

    %% Controller creates resources
    Controller -.->|"creates"| UISvc
    Controller -.->|"creates"| Ingress

    %% Certificate management
    CertProvider -.->|"provisions TLS"| Webhook

    %% Driver ↔ Executors
    DriverPod -->|"Spark RPC<br/>No TLS"| ExecutorPods

    %% SparkConnect
    User -->|"15002/TCP<br/>Spark Connect<br/>No TLS No Auth"| ConnectSvc
    ConnectSvc -->|"7078-7079/TCP<br/>Spark RPC<br/>No TLS"| ExecutorPods

    %% Monitoring
    Prometheus -.->|"HTTP/8080<br/>No Auth"| Controller
    Prometheus -.->|"HTTP/8080<br/>No Auth"| Webhook
    JMXExporter -.->|"HTTP/8090"| DriverPod

    %% Scheduler integrations
    Controller -.->|"HTTPS/443<br/>SA token"| VolcanoSched
    Controller -.->|"annotations"| YunikornSched
    Controller -.->|"HTTPS/443<br/>SA token"| KubeSchedPG

    %% Ingress to UI
    Ingress -->|"HTTP"| UISvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduler fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI k8scontrol
    class Controller,Webhook,WebhookSvc,CertProvider operator
    class DriverPod,ExecutorPods,ConnectSvc,UISvc workload
    class Prometheus,JMXExporter monitoring
    class VolcanoSched,YunikornSched,KubeSchedPG scheduler
    class Ingress ingress
