graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / CI System"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>Bearer / SA tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph WebhookDeploy["Webhook Deployment"]
            WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443/TCP<br/>HTTPS TLS<br/>SA: spark-operator-webhook"]
        end

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>Metrics: 8080/TCP HTTP"]
        end
    end

    subgraph WorkloadNS["SPARK WORKLOAD NAMESPACE (mTLS: N/A)"]
        direction TB

        subgraph DriverGroup["Spark Driver"]
            Driver["Driver Pod<br/>SA: spark-operator-spark<br/>Mutated by webhook"]
        end

        subgraph ExecutorGroup["Spark Executors"]
            Executors["Executor Pods<br/>SA: spark-operator-spark<br/>Mutated by webhook"]
        end

        subgraph SparkServices["Dynamic Services"]
            UISvc["Spark UI Service<br/>4040/TCP HTTP<br/>No encryption"]
            ConnSvc["SparkConnect Service<br/>7078, 7079, 4040, 15002/TCP<br/>No encryption"]
        end
    end

    subgraph OptionalIngress["OPTIONAL INGRESS"]
        IngressRes["Ingress Resource<br/>80/443 TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP<br/>No auth<br/>PodMonitor"]
        JMXExporter["JMX Exporter Sidecar<br/>8090/TCP HTTP<br/>Spark JMX metrics"]
    end

    subgraph OptionalIntegrations["OPTIONAL INTEGRATIONS"]
        CertMgr["cert-manager<br/>Certificate + Issuer CRDs<br/>Auto-rotation"]
        Volcano["Volcano Scheduler<br/>PodGroup CRD<br/>Gang scheduling"]
        KubeSchedPlugins["kube-scheduler-plugins<br/>PodGroup CRD<br/>Min members"]
        YunikornSched["Yunikorn<br/>Annotations only<br/>Task groups"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS<br/>Bearer token"| K8sAPI

    %% API server to webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed/cert-mgr)<br/>API server mTLS<br/>failurePolicy: Fail"| WebhookSvc

    %% Controller to API
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Controller creates workloads
    Controller -->|"spark-submit<br/>Process exec"| Driver

    %% Driver to API and executors
    Driver -->|"HTTPS/443<br/>TLS<br/>SA: spark-operator-spark"| K8sAPI
    Driver -->|"TCP/7078, 7079<br/>Plaintext<br/>No auth"| Executors

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption"| Controller
    Prometheus -->|"HTTP/8080<br/>No encryption"| WebhookSvc
    JMXExporter -.->|"HTTP/8090"| Driver
    JMXExporter -.->|"HTTP/8090"| Executors

    %% Optional integrations
    Controller -.->|"CRD CRUD via K8s API"| Volcano
    Controller -.->|"CRD CRUD via K8s API"| KubeSchedPlugins
    Controller -.->|"Annotations"| YunikornSched
    WebhookSvc -.->|"TLS certs"| CertMgr

    %% Ingress
    IngressRes -.->|"HTTP/4040"| UISvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workloadns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class WebhookSvc,Controller operatorns
    class Driver,Executors,UISvc,ConnSvc workloadns
    class Prometheus,JMXExporter monitoring
    class CertMgr,Volcano,KubeSchedPlugins,YunikornSched optional
    class IngressRes ingress
