graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OpenShiftAPI["OpenShift APIServer CR<br/>config.openshift.io/v1<br/>TLS profile config"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>Svc: spark-operator-webhook-svc<br/>ClusterIP 443→9443"]
            WebhookEndpoints["Webhook Endpoints:<br/>POST /mutate--v1-pod<br/>POST /mutate-*-sparkapplication<br/>POST /validate-*-sparkapplication<br/>POST /mutate-*-scheduledsparkapplication<br/>POST /validate-*-scheduledsparkapplication<br/>failurePolicy: Fail"]
        end

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>spark-submit (local exec)"]
        end

        Metrics1["Metrics: 8080/TCP HTTP"]
        Health1["Health: 8081/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB

        subgraph SparkPods["Spark Pods (sparkoperator.k8s.io/launched-by-spark-operator)"]
            Driver["Spark Driver Pod<br/>SA: spark-operator-spark<br/>7078/TCP (driver-rpc)<br/>7079/TCP (block-mgr)<br/>4040/TCP (UI)"]
            Executors["Spark Executor Pods<br/>7078/TCP (driver-rpc)<br/>7079/TCP (block-mgr)"]
        end

        SparkConnectPod["SparkConnect Server<br/>15002/TCP gRPC<br/>7078, 7079, 4040/TCP"]

        UIService["Spark UI Service<br/>ClusterIP 4040/TCP<br/>HTTP, No Auth"]

        ConnectService["SparkConnect Service<br/>ClusterIP 15002/TCP gRPC<br/>No Encryption, No Auth"]

        OptIngress["Ingress (optional)<br/>80/443 HTTP/HTTPS<br/>TLS: SIMPLE (optional)"]
    end

    subgraph WorkbenchNS["WORKBENCH NAMESPACES<br/>(opendatahub.io/dashboard: true)"]
        Workbench["ODH/RHOAI Workbench Pods"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scraping"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User credentials"| K8sAPI

    %% Control Plane → Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+ (self-signed)<br/>API Server cert"| Webhook

    %% Webhook → Control Plane
    Webhook -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Webhook -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (read)"| OpenShiftAPI

    %% Controller → Control Plane
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller → creates pods (via K8s API)
    Controller -.->|"creates via API"| Driver
    Controller -.->|"creates via API"| SparkConnectPod

    %% Spark internal communication
    Driver -->|"TCP/7078, 7079<br/>Plaintext<br/>No Auth"| Executors

    %% SparkConnect
    SparkConnectPod -->|"TCP/7078, 7079<br/>Plaintext"| Executors

    %% Workbench → SparkConnect
    Workbench -->|"gRPC/15002<br/>No Encryption<br/>No Auth<br/>(NetworkPolicy restricted)"| ConnectService

    %% User → Spark UI
    User -->|"HTTP/4040<br/>No Encryption<br/>No Auth<br/>(NetworkPolicy restricted)"| UIService

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No Encryption<br/>No Auth"| Metrics1

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workbench fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI,OpenShiftAPI controlplane
    class Webhook,Controller,Metrics1,Health1,WebhookEndpoints operator
    class Driver,Executors,SparkConnectPod,UIService,ConnectService,OptIngress workload
    class Workbench workbench
    class Prometheus monitoring
