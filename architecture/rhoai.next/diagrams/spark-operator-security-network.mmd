graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / CI System"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>AuthN: Bearer / certs / SA tokens<br/>AuthZ: RBAC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: redhat-ods-applications"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443/TCP<br/>TLS (self-signed or cert-manager)"]
            Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>Webhooks: 9443/TCP HTTPS<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
            WebhookSvc --> Webhook
        end
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB

        DriverPod["Spark Driver Pod<br/>SA: spark-operator-spark<br/>Label: launched-by-spark-operator=true"]
        ExecutorPods["Spark Executor Pods<br/>Label: launched-by-spark-operator=true<br/>Ports: 7078, 7079/TCP"]
        UISvc["{app}-ui-svc<br/>ClusterIP 4040/TCP HTTP<br/>No auth"]
        ConnectSvc["{conn}-server<br/>ClusterIP 7078,7079,4040,15002/TCP<br/>No auth"]
        DynIngress["{app}-ing (optional)<br/>Ingress 80/443 TCP<br/>External exposure"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor<br/>Scrapes /metrics"]
    end

    subgraph OptionalSchedulers["OPTIONAL BATCH SCHEDULERS"]
        Volcano["Volcano<br/>PodGroup CRD<br/>443/TCP HTTPS"]
        Yunikorn["Yunikorn<br/>Pod annotations<br/>No CRD"]
        KubeSched["kube-scheduler-plugins<br/>PodGroup CRD<br/>443/TCP HTTPS"]
    end

    %% External to API
    User -->|"HTTPS/443<br/>TLS<br/>Bearer token"| K8sAPI

    %% API to Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server mTLS<br/>failurePolicy=Fail"| WebhookSvc

    %% Controller to API
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Webhook to API (quota checks)
    Webhook -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Controller creates workloads
    Controller -->|"Creates pods<br/>via spark-submit"| DriverPod
    Controller -->|"Creates services<br/>& ingress"| UISvc

    %% Driver to Executors
    DriverPod -->|"TCP/7078 driver-rpc<br/>TCP/7079 blockmanager<br/>No encryption<br/>No auth"| ExecutorPods

    %% Driver to API
    DriverPod -->|"HTTPS/443<br/>TLS<br/>SA token (spark-operator-spark)"| K8sAPI

    %% Prometheus scraping
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Webhook

    %% Optional scheduler integrations
    Controller -.->|"PodGroup CRDs<br/>HTTPS/443"| Volcano
    Controller -.->|"Pod annotations"| Yunikorn
    Controller -.->|"PodGroup CRDs<br/>HTTPS/443"| KubeSched

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class User external
    class K8sAPI controlplane
    class Controller,Webhook,WebhookSvc operator
    class DriverPod,ExecutorPods,UISvc,ConnectSvc,DynIngress workload
    class Prometheus monitoring
    class Volcano,Yunikorn,KubeSched optional
