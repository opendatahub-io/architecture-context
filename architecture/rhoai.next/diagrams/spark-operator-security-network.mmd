graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>Bearer / client cert / SA token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443/TCP<br/>TLS (self-signed)<br/>HTTP/2 DISABLED"]

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>Endpoints:<br/>/mutate-*, /validate-*<br/>/mutate--v1-pod"]
        end

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>8080/TCP metrics (HTTP, no auth)<br/>8081/TCP health (HTTP, no auth)"]
        end

        WebhookSvc --> Webhook
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB

        DriverPod["Spark Driver Pod<br/>SA: spark-operator-spark<br/>7078/TCP driver-rpc (plaintext)<br/>7079/TCP block-mgr (plaintext)<br/>4040/TCP spark-ui (plaintext)"]

        ExecutorPods["Spark Executor Pods<br/>7078/TCP, 7079/TCP (plaintext)"]

        ConnectServer["Spark Connect Server<br/>(optional)<br/>15002/TCP gRPC (plaintext)<br/>7078, 7079, 4040/TCP"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor<br/>HTTP/8080 (no auth)"]
    end

    subgraph OptionalServices["OPTIONAL SERVICES"]
        CertManager["cert-manager<br/>(optional TLS issuance)"]
        Volcano["Volcano Scheduler<br/>(PodGroup CRDs)"]
        Yunikorn["Yunikorn Scheduler<br/>(annotation-based)"]
    end

    %% External flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer token"| K8sAPI

    %% API server to webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert<br/>HTTP/1.1 only"| WebhookSvc

    %% Webhook to API server
    Webhook -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller to API server
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token<br/>CRUD: pods, svcs, CRDs"| K8sAPI

    %% Controller creates workloads (via API server)
    Controller -.->|"spark-submit<br/>(local exec)"| DriverPod

    %% Driver-Executor communication
    DriverPod <-->|"HTTP/7078, 7079<br/>Plaintext<br/>No auth"| ExecutorPods

    %% Connect server
    User -->|"gRPC/15002<br/>Plaintext"| ConnectServer
    ConnectServer <-->|"HTTP/7078, 7079<br/>Plaintext"| ExecutorPods

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller

    %% Optional services
    CertManager -.->|"K8s API<br/>TLS cert issuance"| Webhook
    Controller -.->|"K8s API<br/>PodGroup CRDs"| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class K8sAPI controlplane
    class Webhook,Controller,WebhookSvc operatorns
    class DriverPod,ExecutorPods,ConnectServer userns
    class Prometheus monitoring
    class CertManager,Volcano,Yunikorn optional
