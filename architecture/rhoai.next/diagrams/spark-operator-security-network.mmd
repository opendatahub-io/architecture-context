graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer / client cert auth"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB

        Controller["spark-operator-controller<br/>SA: spark-operator-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]

        WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443/TCP → 9443/TCP<br/>TLS (self-signed CA)<br/>HTTP/2 DISABLED"]

        Webhook["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]

        SparkSubmit["spark-submit<br/>(local process exec)"]

        WebhookSvc --> Webhook
    end

    subgraph UserNS["USER NAMESPACES (Spark Workloads)"]
        direction TB

        Driver["Spark Driver Pod<br/>SA: spark-operator-spark<br/>RPC: 7078/TCP HTTP<br/>Block Mgr: 7079/TCP HTTP"]

        Executors["Spark Executor Pods<br/>Created by driver"]

        UISvc["Spark Web UI<br/>{app}-ui-svc ClusterIP<br/>4040/TCP HTTP"]

        ConnectSvc["Spark Connect Server<br/>{name}-server ClusterIP<br/>15002/TCP gRPC<br/>7078, 7079, 4040/TCP"]
    end

    subgraph Ingress["OPTIONAL INGRESS"]
        IngressRes["Ingress Resource<br/>80/443 TCP<br/>Optional TLS SIMPLE"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scraping<br/>HTTP no auth"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer token"| K8sAPI

    %% Control Plane → Webhook (admission)
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert<br/>(mTLS)"| WebhookSvc

    %% Controller → API
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (Bearer)"| K8sAPI

    %% Webhook → API (lookups)
    Webhook -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (Bearer)"| K8sAPI

    %% Controller → spark-submit
    Controller -->|"Process exec<br/>(no network)"| SparkSubmit
    SparkSubmit -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Driver ↔ Executors
    Driver -->|"HTTP/7078<br/>No encryption<br/>No auth"| Executors
    Executors -->|"HTTP/7079<br/>No encryption<br/>No auth"| Driver

    %% Driver → API
    Driver -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% User → Connect
    User -.->|"gRPC/15002<br/>No encryption<br/>App-level auth"| ConnectSvc

    %% Ingress
    IngressRes -.->|"HTTP/4040"| UISvc

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,Webhook,WebhookSvc,SparkSubmit operator
    class Driver,Executors,UISvc,ConnectSvc workload
    class Prometheus monitoring
    class IngressRes ingress
