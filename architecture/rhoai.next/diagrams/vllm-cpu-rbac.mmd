graph TD
    subgraph "vLLM CPU Authentication & Authorization Model"
        direction TB

        subgraph "Note"
            Note["vLLM CPU is a user-space application, NOT an operator.<br/>It does not define Kubernetes RBAC resources.<br/>Pod-level RBAC is managed by KServe / RHOAI."]
        end

        subgraph "Platform-Level Auth (RHOAI)"
            PlatformGateway["RHOAI Platform Gateway<br/>(Ingress)"]
            KRBACProxy["kube-rbac-proxy Sidecar<br/>Port 8443/TCP<br/>RBAC-enforced authentication"]
        end

        subgraph "Application-Level Auth (vLLM)"
            APIKeyMiddleware["FastAPI Middleware<br/>API Key Validation"]
        end

        subgraph "Protected Endpoints"
            ChatAPI["/v1/chat/completions<br/>POST"]
            CompletionsAPI["/v1/completions<br/>POST"]
            EmbeddingsAPI["/v1/embeddings<br/>POST"]
            ModelsAPI["/v1/models<br/>GET"]
            MessagesAPI["/v1/messages<br/>POST"]
            ResponsesAPI["/v1/responses<br/>POST"]
            AudioAPI["/v1/audio/*<br/>POST"]
            RealtimeAPI["/v1/realtime<br/>WebSocket"]
        end

        subgraph "Unprotected Endpoints (No Auth)"
            HealthAPI["/health<br/>GET<br/>K8s probes"]
            MetricsAPI["/metrics<br/>GET<br/>Prometheus scrape"]
            PingAPI["/ping<br/>GET/POST<br/>SageMaker health"]
        end

        subgraph "gRPC (No Auth, No TLS)"
            GRPCInference["vLLM Inference Service<br/>50051/TCP<br/>⚠ Plaintext"]
            GRPCHealth["grpc.health.v1.Health<br/>50051/TCP<br/>⚠ Plaintext"]
            GRPCReflection["grpc.reflection<br/>50051/TCP<br/>⚠ Plaintext"]
        end

        subgraph "Secrets Management"
            HFToken["HF_TOKEN<br/>(Opaque env var)<br/>HuggingFace auth<br/>No auto-rotate"]
            APIKey["VLLM_API_KEY<br/>(Opaque env var)<br/>Client auth<br/>No auto-rotate"]
            TLSCert["SSL key/cert<br/>(kubernetes.io/tls)<br/>HTTPS termination<br/>Auto-rotate: Yes<br/>(--enable-ssl-refresh)"]
        end
    end

    PlatformGateway -->|"HTTPS/443<br/>TLS termination"| KRBACProxy
    KRBACProxy -->|"HTTP/8000<br/>RBAC validated"| APIKeyMiddleware
    APIKeyMiddleware -->|"API Key valid<br/>or not configured"| ChatAPI
    APIKeyMiddleware -->|"API Key valid"| CompletionsAPI
    APIKeyMiddleware -->|"API Key valid"| EmbeddingsAPI
    APIKeyMiddleware -->|"API Key valid"| ModelsAPI
    APIKeyMiddleware -->|"API Key valid"| MessagesAPI
    APIKeyMiddleware -->|"API Key valid"| ResponsesAPI
    APIKeyMiddleware -->|"API Key valid"| AudioAPI
    APIKeyMiddleware -->|"API Key valid"| RealtimeAPI

    APIKey -.->|"configures"| APIKeyMiddleware
    TLSCert -.->|"configures TLS"| APIKeyMiddleware

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KRBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style APIKeyMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style PlatformGateway fill:#7ed321,stroke:#333,color:#000

    style ChatAPI fill:#d5e8d4,stroke:#82b366
    style CompletionsAPI fill:#d5e8d4,stroke:#82b366
    style EmbeddingsAPI fill:#d5e8d4,stroke:#82b366
    style ModelsAPI fill:#d5e8d4,stroke:#82b366
    style MessagesAPI fill:#d5e8d4,stroke:#82b366
    style ResponsesAPI fill:#d5e8d4,stroke:#82b366
    style AudioAPI fill:#d5e8d4,stroke:#82b366
    style RealtimeAPI fill:#d5e8d4,stroke:#82b366

    style HealthAPI fill:#fff2cc,stroke:#d6b656
    style MetricsAPI fill:#fff2cc,stroke:#d6b656
    style PingAPI fill:#fff2cc,stroke:#d6b656

    style GRPCInference fill:#f8cecc,stroke:#b85450
    style GRPCHealth fill:#f8cecc,stroke:#b85450
    style GRPCReflection fill:#f8cecc,stroke:#b85450

    style HFToken fill:#e1d5e7,stroke:#9673a6
    style APIKey fill:#e1d5e7,stroke:#9673a6
    style TLSCert fill:#e1d5e7,stroke:#9673a6
