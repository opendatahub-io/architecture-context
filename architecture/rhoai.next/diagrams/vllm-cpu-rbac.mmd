graph TD
    subgraph "Container Security Context"
        Container["vLLM-CPU Container<br/>odh-vllm-cpu-rhel9<br/>Base: UBI9-minimal"]
        RunAs["Run As:<br/>UID: 2000<br/>GID: 0 (root group)<br/>Non-root user"]
        Container --- RunAs
    end

    subgraph "RBAC Configuration"
        NoRBAC["No ClusterRoles Defined<br/>No RoleBindings Defined<br/><br/>vLLM-CPU runs as a regular<br/>workload pod managed by KServe.<br/>No Kubernetes API access required."]
    end

    subgraph "Application-Level Authentication"
        AuthMW["AuthenticationMiddleware<br/>(vLLM built-in)"]

        subgraph "Protected Endpoints (API Key Required)"
            EP1["/v1/chat/completions"]
            EP2["/v1/completions"]
            EP3["/v1/responses"]
            EP4["/v1/messages"]
            EP5["/v1/models"]
            EP6["/v1/embeddings"]
            EP7["/v1/score"]
            EP8["/v1/classify"]
            EP9["/v1/audio/transcriptions"]
            EP10["/tokenize"]
            EP11["/detokenize"]
        end

        subgraph "Open Endpoints (No Auth)"
            EP_H["/health"]
            EP_M["/metrics"]
            EP_V["/version"]
            EP_P["/ping"]
        end
    end

    subgraph "Secrets Used"
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HF Hub auth<br/>Provisioned: Manual<br/>Auto-rotate: No"]
        S3Creds["S3_ACCESS_KEY_ID /<br/>S3_SECRET_ACCESS_KEY<br/>Type: Opaque (env var)<br/>Purpose: S3 auth<br/>Provisioned: Manual<br/>Auto-rotate: No"]
        APIKey["VLLM_API_KEY<br/>Type: Opaque (env var)<br/>Purpose: Client API key<br/>Provisioned: Manual<br/>Auto-rotate: No"]
        TLSCert["ssl_keyfile / ssl_certfile<br/>Type: kubernetes.io/tls<br/>Purpose: HTTPS serving<br/>Provisioned: cert-manager<br/>Auto-rotate: Yes<br/>(--enable-ssl-refresh)"]
    end

    %% Relationships
    AuthMW -->|"validates API Key<br/>(--api-key or VLLM_API_KEY)"| EP1
    AuthMW -->|validates| EP2
    AuthMW -->|validates| EP3
    AuthMW -->|validates| EP4
    AuthMW -->|validates| EP5
    AuthMW -->|validates| EP6
    AuthMW -->|validates| EP7
    AuthMW -->|validates| EP8
    AuthMW -->|validates| EP9
    AuthMW -->|validates| EP10
    AuthMW -->|validates| EP11

    APIKey -->|"provides key to"| AuthMW
    HFToken -->|"used at startup"| Container
    S3Creds -->|"used for model loading"| Container
    TLSCert -->|"enables HTTPS"| Container

