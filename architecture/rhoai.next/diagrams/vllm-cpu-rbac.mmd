graph TD
    subgraph "vLLM CPU - Authentication Model"
        direction TB

        subgraph "Note"
            Note["vLLM CPU is a containerized service,<br/>NOT a Kubernetes operator.<br/>Kubernetes RBAC is managed by KServe.<br/><br/>This diagram shows the application-level<br/>authentication and authorization model."]
        end

        subgraph "KServe-Managed RBAC"
            KServeSA["KServe Service Account<br/>(manages vLLM pod lifecycle)"]
            KServeRole["KServe ClusterRole<br/>inferenceservices, pods,<br/>services, deployments"]
            KServeSA -->|bound via ClusterRoleBinding| KServeRole
        end

        subgraph "Application-Level Auth"
            APIKey["API Key Secret<br/>Type: Opaque<br/>Env: VLLM_API_KEY<br/>Provisioned: Manual"]
            HFToken["HuggingFace Token<br/>Type: Opaque<br/>Env: HF_TOKEN<br/>Provisioned: Manual"]
            TLSCert["SSL Certificate/Key<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-Rotate: --enable-ssl-refresh"]
        end

        subgraph "Endpoint Authorization Matrix"
            direction LR

            AuthEndpoints["AUTHENTICATED (/v1/*)<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>/v1/models (GET)<br/>/v1/chat/completions (POST)<br/>/v1/completions (POST)<br/>/v1/messages (POST)<br/>/v1/embeddings (POST)<br/>/v1/responses (POST/GET)<br/>/v1/realtime (WebSocket)<br/>/v1/load_lora_adapter (POST)<br/>/v1/unload_lora_adapter (POST)<br/>/v1/rerank (POST)<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>Auth: Bearer Token<br/>Validation: SHA256 + constant-time"]

            UnauthEndpoints["UNAUTHENTICATED<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>/health, /version, /load (GET)<br/>/tokenize, /detokenize (POST)<br/>/classify, /pooling (POST)<br/>/score, /rerank (POST)<br/>/v2/rerank (POST)<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>Auth: None<br/>Risk: Low-Medium"]

            CriticalEndpoints["UNAUTHENTICATED (CRITICAL)<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>/pause, /resume (POST)<br/>/sleep, /wake_up (POST)<br/>/update_weights (POST)<br/>/collective_rpc (POST)<br/>/reset_prefix_cache (POST)<br/>/reset_mm_cache (POST)<br/>/start_profile, /stop_profile<br/>━━━━━━━━━━━━━━━━━━━━━━<br/>Auth: None<br/>Risk: HIGH - CRITICAL<br/>Mitigation: NetworkPolicy<br/>or ServiceMesh AuthzPolicy"]
        end
    end

    APIKey -->|validates requests to| AuthEndpoints
    HFToken -->|authenticates to| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    TLSCert -->|enables HTTPS on| Server["vLLM API Server<br/>8000/TCP"]

    %% Styling
    style Note fill:#f0f0f0,stroke:#999,stroke-width:1px
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333
    style APIKey fill:#e74c3c,stroke:#333,color:#fff
    style HFToken fill:#e74c3c,stroke:#333,color:#fff
    style TLSCert fill:#e74c3c,stroke:#333,color:#fff
    style AuthEndpoints fill:#27ae60,stroke:#1e8449,color:#fff
    style UnauthEndpoints fill:#f39c12,stroke:#e67e22,color:#fff
    style CriticalEndpoints fill:#e74c3c,stroke:#c0392b,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style Server fill:#4a90e2,stroke:#333,color:#fff
