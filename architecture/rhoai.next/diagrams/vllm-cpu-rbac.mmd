graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["ℹ️ vllm-cpu is a stateless service container,<br/>not an operator.<br/><br/>No RBAC definitions (ClusterRoles, RoleBindings)<br/>are defined in this repository.<br/><br/>RBAC is managed externally by:<br/>- KServe (InferenceService controller)<br/>- Platform operator (RHOAI)"]
    end

    subgraph PodSecurity["Pod Security Context"]
        direction TB
        PodUser["Container User: 2000<br/>(non-root)"]
        PodGroup["Container Group: 0<br/>(root group for OpenShift compatibility)"]
        BaseImage["Base Image: UBI9<br/>(ubi9/ubi-minimal)"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB

        subgraph HTTPAuth["HTTP API Authentication"]
            APIKey["API Key (Bearer Token)<br/>via --api-key or VLLM_API_KEY<br/>Enforced by: AuthenticationMiddleware"]
            NoAuth["Unauthenticated Endpoints:<br/>/health, /metrics, /version, /ping<br/>Always accessible"]
            DevOnly["Dev-Only Endpoints:<br/>/start_profile, /stop_profile<br/>Requires: VLLM_SERVER_DEV_MODE=1"]
        end

        subgraph GRPCAuth["gRPC Authentication"]
            GRPCNoAuth["⚠️ No Authentication<br/>50051/TCP insecure port<br/>No TLS support"]
        end
    end

    subgraph Secrets["Secrets Used"]
        direction TB
        TLSCert["SSL key/cert files<br/>Type: kubernetes.io/tls<br/>Provisioned: Manual/cert-manager<br/>Rotation: SSLCertRefresher"]
        HFToken["HF_TOKEN<br/>Type: Opaque<br/>Purpose: Hugging Face Hub auth<br/>Rotation: Manual"]
        S3Creds["S3_ACCESS_KEY_ID /<br/>S3_SECRET_ACCESS_KEY<br/>Type: Opaque<br/>Purpose: S3 model storage<br/>Rotation: Manual"]
        VLLMKey["VLLM_API_KEY<br/>Type: Opaque<br/>Purpose: API request auth<br/>Rotation: Manual"]
    end

    %% Relationships
    APIKey -->|"protects"| APIEndpoints["API Endpoints<br/>/v1/chat/completions<br/>/v1/completions<br/>/v1/models<br/>/v1/embeddings<br/>/v1/messages<br/>..."]
    VLLMKey -->|"provides key for"| APIKey
    TLSCert -->|"encrypts"| HTTPTraffic["HTTP Traffic<br/>Port 8000/TCP"]

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style GRPCNoAuth fill:#f8d7da,stroke:#721c24,color:#721c24
    style APIKey fill:#d4edda,stroke:#155724,color:#155724
    style NoAuth fill:#d1ecf1,stroke:#0c5460,color:#0c5460
    style DevOnly fill:#fff3cd,stroke:#856404,color:#856404
    style PodUser fill:#d5e8d4,stroke:#82b366
    style PodGroup fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style TLSCert fill:#dae8fc,stroke:#6c8ebf
    style HFToken fill:#dae8fc,stroke:#6c8ebf
    style S3Creds fill:#dae8fc,stroke:#6c8ebf
    style VLLMKey fill:#dae8fc,stroke:#6c8ebf
