graph TD
    subgraph vLLMCPU["vLLM CPU - Authentication Model"]
        direction TB

        subgraph AuthLayer["Authentication Layer (FastAPI Middleware)"]
            AuthMW["AuthenticationMiddleware<br/>Token validation: SHA256-hashed<br/>Comparison: constant-time (secrets.compare_digest)"]
        end

        subgraph ProtectedEndpoints["Protected Endpoints (/v1/*)  -  Bearer Token Required"]
            Chat["/v1/chat/completions<br/>POST"]
            Completions["/v1/completions<br/>POST"]
            Models["/v1/models<br/>GET"]
            Embeddings["/v1/embeddings<br/>POST"]
            Messages["/v1/messages<br/>POST"]
            Responses["/v1/responses<br/>POST/GET"]
            LoRA["/v1/load_lora_adapter<br/>/v1/unload_lora_adapter<br/>POST"]
            Rerank["/v1/rerank<br/>POST"]
            Realtime["/v1/realtime<br/>WebSocket"]
        end

        subgraph OpenEndpoints["Open Endpoints - No Authentication"]
            Health["/health<br/>GET"]
            Version["/version<br/>GET"]
            Load["/load<br/>GET"]
            Tokenize["/tokenize<br/>/detokenize<br/>POST"]
            Classify["/classify<br/>/pooling<br/>/score<br/>POST"]
            ResetCache["/reset_prefix_cache<br/>/reset_mm_cache<br/>/reset_encoder_cache<br/>POST"]
        end

        subgraph OperationalEndpoints["Operational Endpoints - No Auth (Restrict via NetworkPolicy!)"]
            Pause["/pause<br/>/resume<br/>POST"]
            Sleep["/sleep<br/>/wake_up<br/>POST"]
            UpdateWeights["/update_weights<br/>POST"]
            CollectiveRPC["/collective_rpc<br/>POST"]
            Profile["/start_profile<br/>/stop_profile<br/>POST"]
        end
    end

    subgraph KServeRBAC["KServe-Managed RBAC"]
        KServeSA["KServe Service Account<br/>Manages pod lifecycle"]
        KServeRole["KServe ClusterRole<br/>InferenceService CRUD"]
    end

    subgraph Secrets["Secrets"]
        SSLCert["SSL Certificate/Key<br/>kubernetes.io/tls<br/>cert-manager or manual<br/>Auto-rotate: --enable-ssl-refresh"]
        APIKey["API Key<br/>Opaque<br/>VLLM_API_KEY env or --api-key<br/>No auto-rotation"]
        HFToken["HuggingFace Token<br/>Opaque<br/>HF_TOKEN env<br/>No auto-rotation"]
    end

    AuthMW -->|"validates"| ProtectedEndpoints
    AuthMW -.->|"bypasses"| OpenEndpoints
    AuthMW -.->|"bypasses"| OperationalEndpoints

    APIKey -->|"provides token"| AuthMW
    SSLCert -->|"TLS termination"| AuthLayer
    HFToken -->|"model access"| vLLMCPU

    KServeSA -->|"bound via"| KServeRole
    KServeRole -->|"manages"| vLLMCPU

    style AuthMW fill:#f5a623,stroke:#333,color:#fff
    style Chat fill:#4a90e2,stroke:#333,color:#fff
    style Completions fill:#4a90e2,stroke:#333,color:#fff
    style Models fill:#4a90e2,stroke:#333,color:#fff
    style Embeddings fill:#4a90e2,stroke:#333,color:#fff
    style Messages fill:#4a90e2,stroke:#333,color:#fff
    style Responses fill:#4a90e2,stroke:#333,color:#fff
    style LoRA fill:#4a90e2,stroke:#333,color:#fff
    style Rerank fill:#4a90e2,stroke:#333,color:#fff
    style Realtime fill:#4a90e2,stroke:#333,color:#fff

    style Health fill:#7ed321,stroke:#333,color:#fff
    style Version fill:#7ed321,stroke:#333,color:#fff
    style Load fill:#7ed321,stroke:#333,color:#fff
    style Tokenize fill:#7ed321,stroke:#333,color:#fff
    style Classify fill:#7ed321,stroke:#333,color:#fff
    style ResetCache fill:#7ed321,stroke:#333,color:#fff

    style Pause fill:#e74c3c,stroke:#333,color:#fff
    style Sleep fill:#e74c3c,stroke:#333,color:#fff
    style UpdateWeights fill:#e74c3c,stroke:#333,color:#fff
    style CollectiveRPC fill:#e74c3c,stroke:#333,color:#fff
    style Profile fill:#e74c3c,stroke:#333,color:#fff

    style SSLCert fill:#9b59b6,stroke:#333,color:#fff
    style APIKey fill:#9b59b6,stroke:#333,color:#fff
    style HFToken fill:#9b59b6,stroke:#333,color:#fff

    style KServeSA fill:#999,stroke:#333,color:#fff
    style KServeRole fill:#999,stroke:#333,color:#fff
