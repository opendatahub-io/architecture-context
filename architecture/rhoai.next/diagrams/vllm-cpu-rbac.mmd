graph TD
    subgraph ContainerSecurity["Container Security Model"]
        direction TB

        subgraph RuntimeUser["Runtime User"]
            User["UID: 2000 / GID: 0<br/>(non-root)"]
        end

        subgraph NoK8sAccess["No Kubernetes API Access"]
            Note1["vllm-cpu does NOT interact<br/>with the Kubernetes API"]
            Note2["No ClusterRoles<br/>No RoleBindings<br/>No ServiceAccount permissions"]
        end

        User --- Note1
    end

    subgraph AppAuth["Application-Level Authentication"]
        direction TB

        subgraph ProtectedEndpoints["Protected Endpoints (Auth Required)"]
            EP1["/v1/chat/completions — POST"]
            EP2["/v1/completions — POST"]
            EP3["/v1/models — GET"]
            EP4["/v1/embeddings — POST"]
            EP5["/v1/responses — POST"]
            EP6["/v1/audio/* — POST"]
            EP7["/v1/messages — POST"]
            EP8["/v1/load_lora_adapter — POST"]
            EP9["/tokenize, /detokenize — POST"]
            EP10["/invocations — POST"]
        end

        subgraph AuthMechanism["Auth Mechanism"]
            BearerToken["Bearer Token<br/>(--api-key flag)<br/>FastAPI AuthenticationMiddleware<br/>→ 401 if key set & token invalid"]
        end

        subgraph PublicEndpoints["Public Endpoints (No Auth)"]
            Health["/health — GET"]
            Ping["/ping — GET/POST"]
            Metrics["/metrics — GET"]
            Version["/version — GET"]
            Load["/load — GET"]
        end

        BearerToken -->|"protects"| ProtectedEndpoints
    end

    subgraph SecretsManagement["Secrets"]
        direction TB

        HFToken["HF_TOKEN<br/>Type: Opaque env var<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: User/KServe<br/>Auto-Rotate: No"]
        APIKey["VLLM_API_KEY<br/>Type: Opaque env var<br/>Purpose: HTTP API auth<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
        S3Creds["S3_ACCESS_KEY_ID /<br/>S3_SECRET_ACCESS_KEY<br/>Type: Opaque env var<br/>Purpose: S3 model storage<br/>Provisioned: User/Platform<br/>Auto-Rotate: No"]
        TLSCert["SSL cert/key<br/>Type: kubernetes.io/tls<br/>Purpose: TLS termination<br/>Provisioned: cert-manager<br/>Auto-Rotate: Yes<br/>(SSLCertRefresher)"]
    end

    subgraph GRPCSecurity["gRPC Security (Port 50051)"]
        GRPCNote["No built-in authentication<br/>No encryption<br/>Relies on network policies<br/>and service mesh for security"]
    end

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#ff6b6b,stroke:#333,color:#fff
    style Note2 fill:#ff6b6b,stroke:#333,color:#fff
    style BearerToken fill:#f5a623,stroke:#333
    style HFToken fill:#dae8fc,stroke:#6c8ebf
    style APIKey fill:#dae8fc,stroke:#6c8ebf
    style S3Creds fill:#dae8fc,stroke:#6c8ebf
    style TLSCert fill:#d5e8d4,stroke:#82b366
    style GRPCNote fill:#fff2cc,stroke:#d6b656
