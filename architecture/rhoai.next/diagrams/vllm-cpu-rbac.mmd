graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["vLLM CPU is a containerized service,<br/>not a Kubernetes operator.<br/>No CRDs, ClusterRoles, or RoleBindings<br/>are defined by this component.<br/><br/>RBAC is managed by KServe<br/>InferenceService."]
    end

    subgraph AuthModel["Application-Level Authentication"]
        direction TB

        subgraph AuthMiddleware["FastAPI AuthenticationMiddleware"]
            AuthCheck["Bearer Token Validation<br/>SHA256 hash + constant-time compare<br/>--api-key / VLLM_API_KEY"]
        end

        subgraph ProtectedPaths["/v1/* Paths (Protected)"]
            V1Models["/v1/models<br/>GET"]
            V1Chat["/v1/chat/completions<br/>POST"]
            V1Completions["/v1/completions<br/>POST"]
            V1Messages["/v1/messages<br/>POST"]
            V1Embeddings["/v1/embeddings<br/>POST"]
            V1Responses["/v1/responses<br/>POST/GET"]
            V1LoRA["/v1/load_lora_adapter<br/>POST"]
            V1Rerank["/v1/rerank<br/>POST"]
        end

        subgraph OpenPaths["Unauthenticated Paths (Open)"]
            Health["/health, /version, /load<br/>GET - Health checks"]
            Tokenize["/tokenize, /detokenize<br/>POST - Token ops"]
            Operational["/pause, /resume<br/>/sleep, /wake_up<br/>POST - ⚠️ Operational"]
            Sensitive["/update_weights<br/>/collective_rpc<br/>POST - ⚠️ Sensitive"]
            Profiling["/start_profile<br/>/stop_profile<br/>POST - ⚠️ Debug"]
            Cache["/reset_prefix_cache<br/>/reset_mm_cache<br/>/reset_encoder_cache<br/>POST - Cache mgmt"]
            Scoring["/classify, /pooling<br/>/score, /rerank, /v2/rerank<br/>POST - ML ops"]
        end
    end

    subgraph Secrets["Secrets"]
        SSLCert["SSL Certificate/Key<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-rotate: Yes"]
        APIKey["API Key<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-rotate: No"]
    end

    AuthCheck -->|"401 Reject if invalid"| ProtectedPaths
    AuthCheck -.->|"Exempt"| OpenPaths

    APIKey -->|"provides"| AuthCheck
    SSLCert -->|"TLS termination"| AuthMiddleware
    HFToken -->|"model access"| HFAccess["HuggingFace Hub<br/>Model Downloads"]

    style Note fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Info fill:#bbdefb,stroke:#1565c0
    style AuthMiddleware fill:#4a90e2,color:#fff
    style AuthCheck fill:#4a90e2,color:#fff
    style ProtectedPaths fill:#c8e6c9,stroke:#2e7d32
    style OpenPaths fill:#fff9c4,stroke:#f9a825
    style Operational fill:#ffcc80,stroke:#e65100
    style Sensitive fill:#f8cecc,stroke:#b85450
    style Profiling fill:#ffcc80,stroke:#e65100
    style SSLCert fill:#d1c4e9,stroke:#7b1fa2
    style APIKey fill:#d1c4e9,stroke:#7b1fa2
    style HFToken fill:#d1c4e9,stroke:#7b1fa2
