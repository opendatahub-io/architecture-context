graph TD
    subgraph ContainerSecurity["Container Security Context"]
        Container["odh-vllm-cpu-rhel9<br/>Base: UBI9-minimal"]
        UID["UID: 2000 (non-root)"]
        GID["GID: 0 (root group)<br/>OpenShift compatible"]
        Container --- UID
        Container --- GID
    end

    subgraph EnvSecrets["Environment Variable Secrets"]
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: Hugging Face Hub auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        S3Creds["S3_ACCESS_KEY_ID /<br/>S3_SECRET_ACCESS_KEY<br/>Type: Opaque (env var)<br/>Purpose: S3 storage auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        APIKey["VLLM_API_KEY<br/>Type: Opaque (env var)<br/>Purpose: Client API key auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph TLSSecrets["TLS Secrets"]
        TLSCert["ssl_certfile / ssl_keyfile<br/>Type: kubernetes.io/tls<br/>Purpose: HTTPS serving<br/>Provisioned: cert-manager / Manual<br/>Auto-Rotate: Yes (--enable-ssl-refresh)"]
    end

    subgraph AuthPolicy["Authentication Policy"]
        AuthMW["AuthenticationMiddleware"]
        Protected["/v1/* endpoints<br/>Methods: GET, POST<br/>Auth: Bearer Token (API Key)<br/>Enforcement: vLLM middleware"]
        Unprotected["Unauthenticated endpoints<br/>/health, /metrics, /ping, /version<br/>Auth: None<br/>Always accessible"]
    end

    subgraph KServeRBAC["KServe-Managed RBAC"]
        KServeNote["Note: vLLM-CPU is a workload,<br/>not an operator.<br/>No ClusterRoles defined.<br/>No RoleBindings defined.<br/>RBAC is managed by KServe<br/>ServingRuntime controller."]
    end

    Container -->|"reads"| HFToken
    Container -->|"reads"| S3Creds
    Container -->|"reads"| APIKey
    Container -->|"mounts"| TLSCert

    APIKey -->|"validates against"| AuthMW
    AuthMW -->|"protects"| Protected
    AuthMW -->|"bypasses"| Unprotected

