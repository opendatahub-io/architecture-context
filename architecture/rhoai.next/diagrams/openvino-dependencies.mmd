graph LR
    OpenVINO["OpenVINO Toolkit<br/>C++ Inference Framework"]

    %% Internal RHOAI Consumer
    OVMS["OpenVINO Model Server<br/>(OVMS)"] -->|"links libopenvino.so<br/>build-time dependency"| OpenVINO

    %% Core Required Dependencies
    subgraph CoreDeps["Core Dependencies (Required)"]
        oneTBB["Intel oneTBB >=2021.10.0<br/>Thread pool, parallel execution"]
        pugixml["pugixml >=1.10<br/>XML parsing (IR format)"]
        RapidJSON["RapidJSON >=1.1.0<br/>JSON parsing"]
        ADE["ADE 0.1.2d<br/>Graph framework"]
    end

    OpenVINO -->|"threading"| oneTBB
    OpenVINO -->|"IR parsing"| pugixml
    OpenVINO -->|"config"| RapidJSON
    OpenVINO -->|"graph"| ADE

    %% Frontend Dependencies
    subgraph FrontendDeps["Frontend Dependencies"]
        protobuf["protobuf 3.21.12<br/>ONNX/TF/Paddle model parsing"]
        flatbuffers["flatbuffers >=22.9.24<br/>TFLite model parsing"]
        ONNX["ONNX 1.15.0<br/>ONNX format definitions"]
        Snappy["Snappy >=1.1.7<br/>TF SavedModel compression"]
    end

    OpenVINO -->|"ONNX/TF/Paddle frontends"| protobuf
    OpenVINO -->|"TFLite frontend"| flatbuffers
    OpenVINO -->|"ONNX frontend"| ONNX
    OpenVINO -->|"TF frontend"| Snappy

    %% Plugin Dependencies
    subgraph PluginDeps["Plugin Dependencies"]
        oneDNN_CPU["oneDNN (CPU)<br/>submodule<br/>CPU compute primitives"]
        oneDNN_GPU["oneDNN (GPU)<br/>submodule<br/>GPU compute primitives"]
        OpenCL_ICD["OpenCL ICD Loader >=2023.04<br/>GPU runtime loading"]
        OpenCL_Headers["OpenCL Headers >=2023.04<br/>GPU API headers"]
        xbyak["xbyak >=6.69<br/>x86 JIT assembler"]
        ARM_CL["ARM Compute Library<br/>submodule (conditional)"]
        MLAS["MLAS<br/>submodule (conditional)<br/>MS ML Acceleration"]
    end

    OpenVINO -->|"CPU plugin"| oneDNN_CPU
    OpenVINO -->|"GPU plugin"| oneDNN_GPU
    OpenVINO -->|"GPU plugin"| OpenCL_ICD
    OpenVINO -->|"GPU plugin"| OpenCL_Headers
    OpenVINO -->|"CPU JIT kernels"| xbyak
    OpenVINO -.->|"ARM targets"| ARM_CL
    OpenVINO -.->|"CPU inference"| MLAS

    %% Binding Dependencies
    subgraph BindingDeps["Binding Dependencies"]
        pybind11["pybind11 >=2.10.1<br/>C++/Python bindings"]
    end

    OpenVINO -->|"Python API"| pybind11

    %% Optional Dependencies
    subgraph OptionalDeps["Optional Dependencies"]
        ITT["Intel ITT API >=3.24.0<br/>Performance profiling"]
        nlohmann["nlohmann JSON<br/>submodule"]
    end

    OpenVINO -.->|"profiling"| ITT
    OpenVINO -.->|"samples"| nlohmann

    %% Hardware Targets
    subgraph HW["Hardware Targets"]
        IntelCPU["Intel CPU<br/>AVX2/AVX-512/AMX"]
        IntelGPU["Intel GPU<br/>HD/Iris Graphics"]
    end

    OpenVINO -->|"inference"| IntelCPU
    OpenVINO -->|"inference"| IntelGPU

    %% Styling
    style OpenVINO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OVMS fill:#7ed321,stroke:#333,color:#fff

    style oneTBB fill:#f5a623,stroke:#333,color:#fff
    style pugixml fill:#f5a623,stroke:#333,color:#fff
    style RapidJSON fill:#f5a623,stroke:#333,color:#fff
    style ADE fill:#f5a623,stroke:#333,color:#fff

    style protobuf fill:#f5a623,stroke:#333,color:#fff
    style flatbuffers fill:#f5a623,stroke:#333,color:#fff
    style ONNX fill:#f5a623,stroke:#333,color:#fff
    style Snappy fill:#f5a623,stroke:#333,color:#fff

    style oneDNN_CPU fill:#f5a623,stroke:#333,color:#fff
    style oneDNN_GPU fill:#f5a623,stroke:#333,color:#fff
    style OpenCL_ICD fill:#f5a623,stroke:#333,color:#fff
    style OpenCL_Headers fill:#f5a623,stroke:#333,color:#fff
    style xbyak fill:#f5a623,stroke:#333,color:#fff
    style ARM_CL fill:#ddd,stroke:#333
    style MLAS fill:#ddd,stroke:#333

    style pybind11 fill:#f5a623,stroke:#333,color:#fff

    style ITT fill:#ddd,stroke:#333
    style nlohmann fill:#ddd,stroke:#333

    style IntelCPU fill:#e8e8e8,stroke:#333
    style IntelGPU fill:#e8e8e8,stroke:#333
