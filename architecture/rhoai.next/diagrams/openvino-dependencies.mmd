graph LR
    OpenVINO["OpenVINO Toolkit<br/>(C++ Inference Framework)"]

    %% Build-Time Consumer (RHOAI internal)
    OpenVINO -->|"C++ shared library<br/>linkage (build-time)"| OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core C++ Dependencies
    OpenVINO -->|"threading/parallelism"| TBB["Intel oneTBB<br/>≥2021.10.0"]
    OpenVINO -->|"XML parsing (IR format)"| pugixml["pugixml<br/>≥1.10"]
    OpenVINO -->|"JSON parsing"| RapidJSON["RapidJSON<br/>≥1.1.0"]
    OpenVINO -->|"graph framework"| ADE["ADE<br/>0.1.2d"]

    %% Frontend Dependencies
    OpenVINO -->|"ONNX/TF/Paddle parsing"| protobuf["protobuf<br/>3.21.12"]
    OpenVINO -->|"TF Lite parsing"| flatbuffers["flatbuffers<br/>≥22.9.24"]
    OpenVINO -->|"ONNX format defs"| ONNX["ONNX<br/>1.15.0"]
    OpenVINO -->|"TF SavedModel decompression"| Snappy["Snappy<br/>≥1.1.7"]

    %% CPU Plugin Dependencies (submodules)
    OpenVINO -->|"CPU compute primitives"| oneDNN_CPU["oneDNN (CPU)<br/>(git submodule)"]
    OpenVINO -->|"x86 JIT assembler"| xbyak["xbyak<br/>≥6.69"]
    OpenVINO -.->|"ARM compute kernels<br/>(conditional)"| ACL["ARM Compute Library<br/>(git submodule)"]
    OpenVINO -.->|"MS ML acceleration<br/>(conditional)"| MLAS["MLAS<br/>(git submodule)"]

    %% GPU Plugin Dependencies
    OpenVINO -->|"GPU compute API"| OpenCL_ICD["OpenCL ICD Loader<br/>≥2023.04.17"]
    OpenVINO -->|"GPU API headers"| OpenCL_Headers["OpenCL Headers<br/>≥2023.04.17"]
    OpenVINO -->|"GPU compute primitives"| oneDNN_GPU["oneDNN (GPU)<br/>(git submodule)"]

    %% Binding Dependencies
    OpenVINO -->|"Python C++ binding"| pybind11["pybind11<br/>≥2.10.1"]

    %% Optional Dependencies
    OpenVINO -.->|"perf profiling<br/>(optional)"| ITT["Intel ITT API<br/>≥3.24.0"]
    OpenVINO -.->|"JSON (samples)<br/>(optional)"| nlohmann["nlohmann JSON<br/>(git submodule)"]

    %% Hardware Targets
    OpenVINO -->|"ISA execution"| IntelCPU["Intel CPU<br/>(AVX2/AVX-512/AMX)"]
    OpenVINO -->|"OpenCL dispatch"| IntelGPU["Intel GPU<br/>(HD/Iris/Discrete)"]

    %% Styling
    style OpenVINO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OVMS fill:#7ed321,stroke:#333,color:#fff

    %% Required core deps
    style TBB fill:#999,stroke:#333,color:#fff
    style pugixml fill:#999,stroke:#333,color:#fff
    style RapidJSON fill:#999,stroke:#333,color:#fff
    style ADE fill:#999,stroke:#333,color:#fff

    %% Frontend deps
    style protobuf fill:#9ecae1,stroke:#333
    style flatbuffers fill:#9ecae1,stroke:#333
    style ONNX fill:#9ecae1,stroke:#333
    style Snappy fill:#9ecae1,stroke:#333

    %% Plugin deps (submodules)
    style oneDNN_CPU fill:#f5a623,stroke:#333,color:#fff
    style xbyak fill:#f5a623,stroke:#333,color:#fff
    style ACL fill:#f5a623,stroke:#333,color:#fff
    style MLAS fill:#f5a623,stroke:#333,color:#fff
    style oneDNN_GPU fill:#f5a623,stroke:#333,color:#fff
    style OpenCL_ICD fill:#f5a623,stroke:#333,color:#fff
    style OpenCL_Headers fill:#f5a623,stroke:#333,color:#fff

    %% Bindings
