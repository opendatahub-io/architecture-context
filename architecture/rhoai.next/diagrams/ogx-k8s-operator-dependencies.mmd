graph LR
    OGX["OGX K8s Operator<br/>(controller-runtime)"]

    %% External Dependencies
    OGX -->|"controller framework<br/>v0.22.4"| ControllerRuntime["controller-runtime"]
    OGX -->|"manifest rendering<br/>v0.21.0"| Kustomize["kustomize/api"]
    OGX -->|"webhook TLS certs"| CertManager["cert-manager /<br/>service-serving-cert-signer"]
    OGX -->|"OCI label fetch<br/>HTTPS/443"| OCIRegistry["OCI Image Registry"]

    %% Internal ODH Dependencies
    OGX -->|"CRD watch<br/>components.platform.<br/>opendatahub.io/OGX"| PlatformOp["ODH/RHOAI<br/>Platform Operator"]
    OGX -->|"container images<br/>distribution resolution"| OGXImages["OGX Distribution<br/>Images"]
    OGX -->|"Go library<br/>(compile-time)"| PlatformUtils["odh-platform-<br/>utilities"]
    OGX -.->|"creates if CRDs exist"| PrometheusOp["Prometheus<br/>Operator"]

    %% Runtime Dependencies
    OGX -->|"CR watches, CRUD<br/>HTTPS/6443"| K8sAPI["Kubernetes<br/>API Server"]
    OGX -.->|"auto-detects<br/>trusted-ca-bundle"| ODHCABundle["ODH<br/>trusted-ca-bundle"]

    %% Integration Points (other components → OGX)
    PlatformOp -->|"creates OGX CR<br/>to enable component"| OGXModule["OGX Module<br/>Operator"]
    OGXModule -->|"deploys manifests"| OGX

    %% Legacy
    OGX -.->|"adopts resources<br/>(migration)"| LegacyCRD["LlamaStackDistribution<br/>(legacy)"]

    %% Managed Resources
    OGX -->|"creates & manages"| ManagedResources["Managed Resources:<br/>Deployment, Service, PVC,<br/>NetworkPolicy, HPA, PDB,<br/>Ingress, ServiceAccount,<br/>ConfigMap"]

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Kustomize fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style OGXImages fill:#7ed321,stroke:#333,color:#fff
    style PlatformUtils fill:#7ed321,stroke:#333,color:#fff
    style PrometheusOp fill:#7ed321,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style ODHCABundle fill:#7ed321,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style OGXModule fill:#6baed6,stroke:#333,color:#fff
    style LegacyCRD fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style ManagedResources fill:#d5e8d4,stroke:#82b366
