graph LR
    OGXOperator["OGX K8s Operator<br/>(controller-runtime)"]

    %% External Dependencies (Required)
    OGXOperator -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    OGXOperator -->|"manifest rendering"| KustomizeAPI["kustomize/api<br/>v0.21.0"]
    OGXOperator -->|"image validation"| GoContainerReg["go-containerregistry<br/>v0.20.7"]

    %% External Dependencies (Optional)
    OGXOperator -.->|"webhook TLS certs<br/>(optional)"| CertManager["cert-manager"]

    %% Internal Platform Dependencies
    OGXOperator -->|"CA bundle<br/>(auto-detected)"| ODHTrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    OGXOperator -->|"image overrides"| OperatorConfig["ogx-operator-config<br/>ConfigMap"]
    OGXOperator -->|"deploys"| DistImages["OGX Distribution Images<br/>starter, remote-vllm,<br/>meta-reference-gpu,<br/>postgres-demo, rh-dev"]

    %% Platform Operators (deploy this operator)
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys as<br/>managed component"| OGXOperator

    %% Core Kubernetes
    OGXOperator -->|"CRUD resources<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    OGXOperator -->|"image ref validation<br/>HTTPS/443"| ContainerRegistries["Container Registries"]

    %% Resources watched/managed
    OGXOperator -->|"watches config"| UserConfigMaps["User ConfigMaps<br/>(ogx.io/watch: true)"]
    OGXOperator -->|"reads credentials"| UserSecrets["User Secrets<br/>(ogx.io/watch: true)"]

    %% OpenShift integration
    OGXOperator -->|"SCC: anyuid"| OpenShiftSCC["OpenShift SCC"]

    %% Legacy migration
    OGXOperator -.->|"adoption migration"| LegacyLLSD["LlamaStackDistribution<br/>(v1alpha1 - deprecated)"]

    %% Downstream consumers
    subgraph OGXServerProviders["OGX Server Provider Backends"]
        direction TB
        VLLM["vLLM"]
        OpenAI["OpenAI"]
        Azure["Azure OpenAI"]
        Bedrock["AWS Bedrock"]
        Watsonx["IBM watsonx"]
        VertexAI["Vertex AI"]
        Pgvector["pgvector"]
        Milvus["Milvus"]
        Qdrant["Qdrant"]
        BraveSearch["Brave Search"]
        Tavily["Tavily"]
        MCP["MCP Servers"]
        S3["S3 Storage"]
    end

    DistImages -.->|"connects to"| OGXServerProviders

    %% Styling
    style OGXOperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style KustomizeAPI fill:#999,stroke:#333,color:#fff
    style GoContainerReg fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ODHTrustedCA fill:#7ed321,stroke:#333,color:#fff
    style OperatorConfig fill:#7ed321,stroke:#333,color:#fff
    style DistImages fill:#7ed321,stroke:#333,color:#fff
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style ContainerRegistries fill:#f5a623,stroke:#333,color:#fff
    style UserConfigMaps fill:#fff2cc,stroke:#333,color:#333
    style UserSecrets fill:#fff2cc,stroke:#333,color:#333
    style OpenShiftSCC fill:#f5a623,stroke:#333,color:#fff
    style LegacyLLSD fill:#d0d0d0,stroke:#333,color:#333
