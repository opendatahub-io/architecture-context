graph TB
    subgraph NemoGuardrails["NeMo Guardrails Service"]
        direction TB
        Server["Guardrails Server<br/>(FastAPI, port 8000)"]
        LLMRails["LLMRails Engine<br/>(Rail Pipeline Orchestration)"]
        ColangRT["Colang Runtime<br/>(v1.0 / v2.x DSL)"]
        GuardrailLib["Guardrail Library<br/>(30+ Built-in Rails)"]
        EmbeddingProviders["Embedding Providers<br/>(FastEmbed, ONNX Runtime)"]
        TracingMod["Tracing Module<br/>(OpenTelemetry)"]

        Server -->|orchestrates| LLMRails
        LLMRails -->|interprets flows| ColangRT
        LLMRails -->|invokes| GuardrailLib
        LLMRails -->|similarity search| EmbeddingProviders
        Server -->|emits spans| TracingMod
    end

    Client[Client / Platform Component] -->|"POST /v1/chat/completions<br/>POST /v1/guardrail/checks<br/>8000/TCP HTTP"| Server

    ConfigMap["ConfigMap<br/>(config.yaml + rails.co)"] -->|volume mount<br/>/app/config/| Server

    subgraph GuardrailTypes["Rail Pipeline"]
        direction LR
        InputRails["Input Rails<br/>(content safety, injection,<br/>topic control, PII)"]
        DialogRails["Dialog / Retrieval Rails<br/>(Colang flows)"]
        OutputRails["Output Rails<br/>(hallucination, factcheck,<br/>sensitive data)"]
        ToolRails["Tool Rails<br/>(tool call validation)"]
    end

    LLMRails --> InputRails
    InputRails --> DialogRails
    DialogRails --> OutputRails
    OutputRails --> ToolRails

    subgraph UpstreamLLM["Upstream LLM Providers"]
        vLLM["vLLM<br/>(OpenAI-compat)"]
        NIM["NVIDIA NIM"]
        OpenAI["OpenAI API"]
        AzureOpenAI["Azure OpenAI"]
        Anthropic["Anthropic API"]
        Cohere["Cohere API"]
    end

    LLMRails -->|"HTTPS/443<br/>Bearer Token<br/>TLS 1.2+"| UpstreamLLM

    TracingMod -->|"OTLP gRPC/HTTP<br/>4317-4318/TCP"| OTELCollector["OpenTelemetry Collector"]

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style LLMRails fill:#4a90e2,stroke:#333,color:#fff
    style ColangRT fill:#4a90e2,stroke:#333,color:#fff
    style GuardrailLib fill:#4a90e2,stroke:#333,color:#fff
    style EmbeddingProviders fill:#4a90e2,stroke:#333,color:#fff
    style TracingMod fill:#4a90e2,stroke:#333,color:#fff
    style ConfigMap fill:#f5a623,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style InputRails fill:#7ed321,stroke:#333
    style DialogRails fill:#7ed321,stroke:#333
    style OutputRails fill:#7ed321,stroke:#333
    style ToolRails fill:#7ed321,stroke:#333
    style vLLM fill:#999,stroke:#333,color:#fff
    style NIM fill:#999,stroke:#333,color:#fff
    style OpenAI fill:#999,stroke:#333,color:#fff
    style AzureOpenAI fill:#999,stroke:#333,color:#fff
    style Anthropic fill:#999,stroke:#333,color:#fff
