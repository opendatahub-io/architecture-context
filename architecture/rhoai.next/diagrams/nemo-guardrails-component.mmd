graph TB
    subgraph NemoGuardrails["NeMo Guardrails Server (FastAPI :8000)"]
        direction TB

        subgraph CoreEngine["Core Engine"]
            GuardrailsWrapper["Guardrails Wrapper<br/>(Engine Selection)"]
            IORails["IORails Engine<br/>(Stateless I/O checks)"]
            LLMRails["LLMRails Engine<br/>(Full dialogue mgmt)"]
            GuardrailsWrapper -->|"I/O-only flows"| IORails
            GuardrailsWrapper -->|"dialogue flows"| LLMRails
        end

        subgraph ColangRT["Colang Runtime"]
            ColangV1["Colang v1.0<br/>Parser"]
            ColangV2["Colang v2.x<br/>Parser"]
            LarkParser["Lark Parser<br/>Generator"]
            ColangV1 --- LarkParser
            ColangV2 --- LarkParser
        end

        subgraph RailsLib["Guardrails Library (28+ modules)"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            SensitiveData["Sensitive Data<br/>Detection (Presidio)"]
            HallucinationCheck["Hallucination<br/>Check"]
            TopicSafety["Topic Safety"]
            SelfCheck["Self-Check"]
        end

        subgraph EmbeddingsEng["Embeddings Engine"]
            FastEmbed["FastEmbed<br/>(ONNX)"]
            SentenceTransformers["Sentence<br/>Transformers"]
            EmbeddingProviders["Provider Embeddings<br/>(OpenAI/Cohere/NIM)"]
        end

        subgraph KB["Knowledge Base"]
            DocIndex["Document Indexer"]
            ANN["Annoy ANN<br/>Search"]
            DocIndex --> ANN
        end

        subgraph TracingSys["Tracing System"]
            OTelAdapter["OpenTelemetry<br/>Adapter"]
            GenAISpans["GenAI Semantic<br/>Conventions"]
            OTelAdapter --- GenAISpans
        end

        subgraph APIs["API Layer"]
            ChatAPI["/v1/chat/completions<br/>OpenAI-compatible"]
            ChecksAPI["/v1/guardrail/checks<br/>(Fork-specific)"]
            ConfigsAPI["/v1/rails/configs"]
            ModelsAPI["/v1/models"]
            HealthAPI["/ (Health Check)"]
        end

        APIs --> GuardrailsWrapper
        GuardrailsWrapper --> RailsLib
        LLMRails --> ColangRT
        RailsLib --> EmbeddingsEng
        IORails --> RailsLib
        GuardrailsWrapper --> KB
    end

    subgraph ActionsServer["Actions Server (FastAPI :8001)"]
        ActionsRun["/v1/actions/run"]
        ActionsList["/v1/actions/list"]
    end

    subgraph EmbeddedModels["Pre-Baked ML Models (In-Process)"]
        SpaCy["spaCy<br/>en_core_web_lg"]
        NLTKModel["NLTK punkt<br/>tokenizer"]
        STModels["Sentence Transformers<br/>Models"]
        FEModels["FastEmbed<br/>Models"]
    end

    Client["Client<br/>(LLM Application)"] -->|"POST :8000<br/>Bearer Token"| APIs
    NemoGuardrails -->|"Custom Actions"| ActionsServer
    EmbeddingsEng --> EmbeddedModels
    RailsLib --> EmbeddedModels

    %% External LLM Providers
    NemoGuardrails -->|"HTTPS/443<br/>Bearer/API Key"| LLMProvider["Upstream LLM Provider<br/>(OpenAI / Azure / NIM / vLLM)"]

    %% Optional Services
    NemoGuardrails -.->|"Redis/6379<br/>Thread Storage"| Redis["Redis<br/>(Optional)"]
    TracingSys -.->|"OTLP/4317-4318<br/>Trace Export"| OTelCollector["OpenTelemetry<br/>Collector (Optional)"]

    %% Styling
    style NemoGuardrails fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CoreEngine fill:#bbdefb,stroke:#1976d2
    style ColangRT fill:#bbdefb,stroke:#1976d2
    style RailsLib fill:#c8e6c9,stroke:#388e3c
    style EmbeddingsEng fill:#bbdefb,stroke:#1976d2
    style KB fill:#bbdefb,stroke:#1976d2
    style TracingSys fill:#bbdefb,stroke:#1976d2
    style APIs fill:#fff9c4,stroke:#f9a825
    style ActionsServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style EmbeddedModels fill:#f3e5f5,stroke:#7b1fa2
    style Client fill:#f5f5f5,stroke:#616161,stroke-width:2px
    style LLMProvider fill:#fff3e0,stroke:#e65100
    style Redis fill:#fce4ec,stroke:#c62828
    style OTelCollector fill:#fce4ec,stroke:#c62828
