graph TB
    subgraph NemoGuardrails["NeMo Guardrails Service (Port 8000)"]
        direction TB
        Server["FastAPI/uvicorn Server<br/>nemoguardrails/server/api.py"]
        ColangRuntime["Colang Runtime<br/>v1.0 + v2.x DSL"]
        GuardrailsLib["Guardrails Library<br/>~14 open-source modules"]
        EmbeddingEngine["Embedding Engine<br/>FastEmbed / Sentence Transformers"]
        Tracing["Tracing System<br/>OpenTelemetry (optional)"]

        Server -->|evaluates input| ColangRuntime
        ColangRuntime -->|invokes| GuardrailsLib
        GuardrailsLib -->|semantic similarity| EmbeddingEngine
        Server -->|emits spans| Tracing
    end

    subgraph GuardrailModules["Guardrail Modules (opensource profile)"]
        direction LR
        ContentSafety["Content Safety"]
        Hallucination["Hallucination<br/>Detection"]
        SensitiveData["Sensitive Data<br/>Detection (Presidio)"]
        InjectionDetect["Injection<br/>Detection"]
        TopicSafety["Topic Safety"]
        RegexFilter["Regex Filtering"]
        LlamaGuard["LlamaGuard"]
        FactChecking["Fact Checking"]
    end

    Client["Client<br/>(User / Platform)"] -->|"POST /v1/chat/completions<br/>POST /v1/guardrail/checks<br/>8000/TCP HTTP"| Server

    Server -->|"Input Rails"| InputRails["Input Rails<br/>Engine"]
    InputRails -->|"evaluate"| GuardrailModules
    Server -->|"Output Rails"| OutputRails["Output Rails<br/>Engine"]
    OutputRails -->|"evaluate"| GuardrailModules

    subgraph LangChainLayer["LangChain LLM Integration"]
        LangChain["LangChain Abstraction<br/>langchain >=0.2.14"]
    end

    Server -->|"LLM inference<br/>via LangChain"| LangChain
    LangChain -->|"HTTPS/443<br/>Bearer Token"| LLMProvider["LLM Provider<br/>(OpenAI / NIM / Azure /<br/>Anthropic / Cohere / vLLM)"]

    GuardrailsLib -.-> GuardrailModules

    Tracing -->|"gRPC/HTTP<br/>TLS (configurable)"| OTELCollector["OpenTelemetry<br/>Collector"]

