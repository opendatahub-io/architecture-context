graph TB
    subgraph NemoGuardrails["NeMo Guardrails Service"]
        direction TB

        subgraph Server["FastAPI Server (Port 8000)"]
            API["REST API<br/>/v1/chat/completions<br/>/v1/guardrail/checks<br/>/v1/models<br/>/v1/rails/configs"]
        end

        subgraph Core["Core Engines"]
            Wrapper["Guardrails Wrapper<br/>(auto-selects engine)"]
            LLMRails["LLMRails Engine<br/>(full Colang runtime)"]
            IORails["IORails Engine<br/>(optimized I/O-only path)"]
            Wrapper -->|"complex flows"| LLMRails
            Wrapper -->|"simple I/O rails"| IORails
        end

        subgraph IORailsInternal["IORails Components"]
            ModelMgr["ModelManager<br/>(per-model HTTP clients)"]
            RailsMgr["RailsManager<br/>(rail orchestration)"]
            ModelEng["ModelEngine<br/>(OpenAI-compatible)"]
            APIEng["APIEngine<br/>(arbitrary REST)"]
            RailsMgr --> ModelMgr
            ModelMgr --> ModelEng
            ModelMgr --> APIEng
        end

        subgraph Runtime["Colang Runtime"]
            ColangV1["Colang v1.0<br/>Runtime"]
            ColangV2["Colang v2.x<br/>Runtime"]
        end

        subgraph Library["Guardrail Library (28 types)"]
            ContentSafety["Content Safety"]
            Jailbreak["Jailbreak Detection"]
            PII["PII/SDD Detection"]
            Hallucination["Hallucination Check"]
            TopicSafety["Topic Safety"]
            OtherRails["+ 23 more rails"]
        end

        subgraph KnowledgeBase["Knowledge Base"]
            Embeddings["Embedding Providers<br/>(FastEmbed/OpenAI/NIM)"]
            AnnoyIdx["Annoy Index<br/>(ANN search)"]
            Embeddings --> AnnoyIdx
        end

        API --> Wrapper
        LLMRails --> Runtime
        LLMRails --> Library
        LLMRails --> KnowledgeBase
        IORails --> IORailsInternal
    end

    subgraph ActionsServer["Actions Server (Port 8001, optional)"]
        ActionsAPI["REST API<br/>/v1/actions/run<br/>/v1/actions/list"]
    end

    Client["Client / Platform Ingress"] -->|"POST /v1/chat/completions<br/>POST /v1/guardrail/checks<br/>8000/TCP HTTP"| API

    LLMRails -->|"HTTPS/443<br/>Bearer Token"| LLMProvider["External LLM Provider<br/>(OpenAI/NIM/Anthropic/Azure)"]
    IORails -->|"HTTPS/443<br/>Bearer Token"| LLMProvider
    Embeddings -->|"HTTPS/443 or local"| EmbeddingService["Embedding Service<br/>(OpenAI/NIM/local)"]

    Library -->|"in-process"| Presidio["Presidio<br/>(PII Detection)"]
    Library -->|"in-process"| SpaCy["spaCy<br/>(NLP/NER)"]

    style NemoGuardrails fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style Core fill:#d5e8d4,stroke:#82b366
    style IORailsInternal fill:#fff2cc,stroke:#d6b656
    style Runtime fill:#f8cecc,stroke:#b85450
    style Library fill:#e1d5e7,stroke:#9673a6
    style KnowledgeBase fill:#dae8fc,stroke:#6c8ebf
    style ActionsServer fill:#f5f5f5,stroke:#666
    style Client fill:#f9f9f9,stroke:#999
    style LLMProvider fill:#fff2cc,stroke:#d6b656
    style EmbeddingService fill:#fff2cc,stroke:#d6b656
    style Presidio fill:#e8e8e8,stroke:#999
    style SpaCy fill:#e8e8e8,stroke:#999
