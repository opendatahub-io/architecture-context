graph TB
    subgraph NemoGuardrails["NeMo Guardrails Service"]
        direction TB
        Server["nemo-guardrails-server<br/>(FastAPI/Uvicorn)<br/>Port 8000/TCP"]

        subgraph Core["Core Engines"]
            Wrapper["Guardrails Wrapper<br/>(auto-selects engine)"]
            LLMRails["LLMRails Engine<br/>(full Colang runtime)"]
            IORails["IORails Engine<br/>(optimized I/O path)"]
            Wrapper -->|complex flows| LLMRails
            Wrapper -->|simple I/O rails| IORails
        end

        subgraph Runtime["Colang Runtime"]
            ColangV1["Colang v1.0 Runtime"]
            ColangV2["Colang v2.x Runtime"]
        end

        subgraph Library["Guardrail Library (28 types)"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            PIIDetect["PII/SDD Detection"]
            HallucinationDetect["Hallucination Detection"]
            TopicSafety["Topic Safety"]
            InjectionPrevention["Injection Prevention"]
            OtherRails["... 22 more rails"]
        end

        subgraph Embeddings["Embedding & Knowledge"]
            KnowledgeBase["Knowledge Base<br/>(Annoy ANN Index)"]
            EmbeddingProviders["Embedding Providers<br/>(FastEmbed / OpenAI / NIM)"]
        end

        subgraph IORailsInternal["IORails Components"]
            ModelManager["ModelManager<br/>(per-model HTTP clients)"]
            RailsManager["RailsManager<br/>(rail orchestration)"]
            ModelEngine["ModelEngine<br/>(OpenAI-compat client)"]
            APIEngine["APIEngine<br/>(REST API client)"]
        end

        ActionsServer["Actions Server<br/>(optional, port 8001)"]

        Server --> Wrapper
        LLMRails --> Runtime
        LLMRails --> Library
        LLMRails --> Embeddings
        IORails --> IORailsInternal
    end

    Client["Client / Platform"] -->|POST /v1/chat/completions<br/>POST /v1/guardrail/checks| Server

    subgraph ExternalLLM["External LLM Providers"]
        OpenAI["OpenAI API"]
        NVIDIA["NVIDIA NIM"]
        Anthropic["Anthropic API"]
        Azure["Azure OpenAI"]
        Cohere["Cohere API"]
        VertexAI["Google Vertex AI"]
    end

    LLMRails -->|HTTPS/443<br/>Bearer Token| ExternalLLM
    ModelEngine -->|HTTPS/443<br/>Bearer Token| ExternalLLM
    EmbeddingProviders -->|HTTPS/443| ExternalLLM

    Redis["Redis<br/>(optional)<br/>6379/TCP"]
    OTelCollector["OpenTelemetry Collector<br/>(optional)<br/>4317/TCP gRPC"]

    Server -.->|thread persistence| Redis
    Server -.->|trace export| OTelCollector

    Presidio["Presidio<br/>(in-process)"]
    SpaCy["spaCy<br/>(in-process)"]

    PIIDetect --> Presidio
    PIIDetect --> SpaCy

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style Wrapper fill:#4a90e2,stroke:#333,color:#fff
    style LLMRails fill:#5ba0d2,stroke:#333
    style IORails fill:#5ba0d2,stroke:#333
    style Client fill:#f5a623,stroke:#333
    style OpenAI fill:#999,stroke:#333
