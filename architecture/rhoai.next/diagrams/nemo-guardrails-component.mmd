graph TB
    subgraph NemoGuardrails["NeMo Guardrails Service"]
        direction TB

        subgraph Server["FastAPI Server (Port 8000)"]
            API["REST API<br/>/v1/chat/completions<br/>/v1/guardrail/checks<br/>/v1/models<br/>/v1/rails/configs"]
        end

        subgraph Core["Core Engines"]
            Wrapper["Guardrails Wrapper<br/>(auto-selects engine)"]
            LLMRails["LLMRails Engine<br/>(full Colang runtime)"]
            IORails["IORails Engine<br/>(optimized I/O path)"]
            Wrapper -->|full flows| LLMRails
            Wrapper -->|I/O only| IORails
        end

        subgraph Runtime["Colang Runtime"]
            ColangV1["Colang v1.0"]
            ColangV2["Colang v2.x"]
        end

        subgraph Library["Guardrail Library (28 types)"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            PII["PII/SDD Detection"]
            Hallucination["Hallucination Check"]
            TopicSafety["Topic Safety"]
            OtherRails["+ 23 more rails"]
        end

        subgraph Embeddings["Embeddings & Knowledge"]
            KnowledgeBase["Knowledge Base<br/>(Annoy Index)"]
            EmbedProviders["Embedding Providers<br/>(FastEmbed/OpenAI/NIM)"]
        end

        subgraph ActionsServer["Actions Server (Port 8001, optional)"]
            ActionsAPI["Actions API<br/>/v1/actions/run<br/>/v1/actions/list"]
        end

        API --> Wrapper
        LLMRails --> Runtime
        LLMRails --> Library
        IORails --> Library
        LLMRails --> KnowledgeBase
        KnowledgeBase --> EmbedProviders
    end

    Client["Client / Platform"] -->|POST /v1/chat/completions<br/>8000/TCP HTTP| API
    Client -->|POST /v1/guardrail/checks<br/>8000/TCP HTTP| API

    subgraph LLMProviders["External LLM Providers"]
        OpenAI["OpenAI API"]
        NIM["NVIDIA NIM"]
        Anthropic["Anthropic API"]
        Azure["Azure OpenAI"]
    end

    LLMRails -->|HTTPS/443<br/>Bearer Token| LLMProviders
    IORails -->|HTTPS/443<br/>Bearer Token| LLMProviders

    subgraph LocalLibs["Local Libraries (In-Process)"]
        Presidio["Presidio<br/>(PII Detection)"]
        SpaCy["spaCy<br/>(NLP/NER)"]
        LangChain["LangChain<br/>(LLM Abstraction)"]
    end

    Library --> Presidio
    Library --> SpaCy
    LLMRails --> LangChain

    Redis["Redis (optional)<br/>6379/TCP"]
    OTel["OTel Collector (optional)<br/>4317/TCP gRPC"]

    API -.->|thread persistence| Redis
    API -.->|traces| OTel

    style API fill:#4a90e2,stroke:#333,color:#fff
    style Wrapper fill:#4a90e2,stroke:#333,color:#fff
    style LLMRails fill:#4a90e2,stroke:#333,color:#fff
    style IORails fill:#4a90e2,stroke:#333,color:#fff
    style ColangV1 fill:#7ed321,stroke:#333
    style ColangV2 fill:#7ed321,stroke:#333
    style ContentSafety fill:#f5a623,stroke:#333
    style JailbreakDetect fill:#f5a623,stroke:#333
    style PII fill:#f5a623,stroke:#333
    style Hallucination fill:#f5a623,stroke:#333
    style TopicSafety fill:#f5a623,stroke:#333
    style OtherRails fill:#f5a623,stroke:#333
    style OpenAI fill:#999,stroke:#333
    style NIM fill:#999,stroke:#333
    style Anthropic fill:#999,stroke:#333
    style Azure fill:#999,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
