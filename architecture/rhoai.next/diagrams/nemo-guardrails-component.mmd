graph TB
    subgraph NemoGuardrails["NeMo Guardrails Server"]
        direction TB
        Server["FastAPI Server<br/>(uvicorn :8000)"]
        LLMRails["LLMRails Engine"]
        ColangV1["Colang v1.0 Runtime"]
        ColangV2["Colang v2.x Runtime"]
        ActionSystem["Action Dispatcher"]
        KnowledgeBase["Knowledge Base<br/>(Embedding Search)"]

        subgraph GuardrailsLibrary["Guardrails Library (27+ built-in)"]
            ContentSafety["Content Safety"]
            PII["PII Detection<br/>(Presidio + spaCy)"]
            Jailbreak["Jailbreak Detection"]
            Hallucination["Hallucination Detection"]
            TopicSafety["Topic Safety"]
            InjectionDetect["Injection Detection<br/>(YARA)"]
            RegexRails["Regex Rails"]
            LlamaGuard["Llama Guard"]
        end

        Server -->|routes requests| LLMRails
        LLMRails -->|selects runtime| ColangV1
        LLMRails -->|selects runtime| ColangV2
        LLMRails -->|dispatches| ActionSystem
        ActionSystem -->|executes| GuardrailsLibrary
        LLMRails -->|RAG queries| KnowledgeBase
    end

    Client[Client] -->|POST /v1/chat/completions<br/>POST /v1/guardrail/checks<br/>HTTP :8000| Server

    subgraph ExternalGuardrails["External Guardrail APIs (optional)"]
        ActiveFence["ActiveFence"]
        CiscoAI["Cisco AI Defense"]
        CrowdStrike["CrowdStrike AIDR"]
        Pangea["Pangea AI Guard"]
        Patronus["Patronus"]
        Others["+ 11 more providers"]
    end

    ActionSystem -->|HTTPS :443<br/>API Key Auth| ExternalGuardrails

    LLMInference["LLM Inference Service<br/>(vLLM / NIM / OpenAI)"]
    LLMRails -->|HTTPS :443<br/>Bearer Token| LLMInference

    ConfigMap["ConfigMap<br/>(config.yaml + rails.co)"]
    ConfigMap -->|volume mount| LLMRails

    Redis["Redis<br/>(optional)"]
    Server -.->|thread state<br/>:6379| Redis

    OTelCollector["OpenTelemetry Collector<br/>(optional)"]
    Server -.->|OTLP traces<br/>:4317/:4318| OTelCollector

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style LLMRails fill:#4a90e2,stroke:#333,color:#fff
    style ColangV1 fill:#5b9bd5,stroke:#333,color:#fff
    style ColangV2 fill:#5b9bd5,stroke:#333,color:#fff
