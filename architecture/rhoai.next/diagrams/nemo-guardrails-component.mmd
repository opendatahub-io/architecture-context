graph TB
    subgraph "NeMo Guardrails Server"
        direction TB
        API["FastAPI Server<br/>(api.py)<br/>Port 8000/TCP"]

        subgraph "Rail Pipeline Engine"
            LLMRails["LLMRails Engine<br/>Pipeline Orchestrator"]
            ColangRT["Colang Runtime<br/>v1.0 / v2.x<br/>Flow Definitions"]
            LLMRails -->|"interprets flows"| ColangRT
        end

        subgraph "Guardrail Library (30+ modules)"
            InputRails["Input Rails<br/>Content Safety, Injection<br/>Detection, Topic Control"]
            OutputRails["Output Rails<br/>Hallucination, Factcheck<br/>Sensitive Data Filtering"]
            ToolRails["Tool Rails<br/>Tool Call Validation"]
        end

        subgraph "Embedding & NLP"
            EmbedProviders["Embedding Providers<br/>FastEmbed, OpenAI, Azure<br/>SentenceTransformers, NIM"]
            SpaCy["spaCy en_core_web_lg<br/>(bundled)"]
            Presidio["Presidio Analyzer<br/>PII Detection"]
        end

        Tracing["Tracing Module<br/>OpenTelemetry Spans"]

        API -->|"routes requests"| LLMRails
        LLMRails -->|"input rails"| InputRails
        LLMRails -->|"output rails"| OutputRails
        LLMRails -->|"tool rails"| ToolRails
        LLMRails -->|"similarity search"| EmbedProviders
        InputRails -->|"PII detection"| Presidio
        InputRails -->|"NLP processing"| SpaCy
        API -->|"emits spans"| Tracing
    end

    Client["Client Application"] -->|"POST /v1/chat/completions<br/>POST /v1/guardrail/checks<br/>8000/TCP HTTP"| API

    ConfigMap["ConfigMap<br/>config.yaml + rails.co<br/>(Volume Mount)"] -->|"mounted at /app/config/"| API

    subgraph "Upstream LLM Providers"
        vLLM["vLLM Runtime<br/>(RHOAI primary)"]
        OpenAI["OpenAI API"]
        AzureOAI["Azure OpenAI"]
        NIM["NVIDIA NIM"]
        Anthropic["Anthropic API"]
        Cohere["Cohere API"]
    end

    LLMRails -->|"HTTPS/443<br/>Bearer Token<br/>via LangChain"| vLLM
    LLMRails -->|"HTTPS/443"| OpenAI
    LLMRails -->|"HTTPS/443"| AzureOAI
    LLMRails -->|"HTTPS/443"| NIM
    LLMRails -->|"HTTPS/443"| Anthropic
    LLMRails -->|"HTTPS/443"| Cohere

    OTELCollector["OpenTelemetry<br/>Collector"]
    Tracing -->|"OTLP gRPC/4317<br/>or HTTP/4318"| OTELCollector

