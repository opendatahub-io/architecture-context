graph LR
    LlamaStack["Llama Stack<br/>Server"]

    %% ═══════════════════════════════════════════════════
    %% Internal RHOAI Dependencies
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"OpenAI-compatible API<br/>8000/TCP HTTP/HTTPS"| vLLM["vLLM Model Serving"]
    LlamaStack -->|"HTTP OTLP<br/>configurable port"| OTel["OpenTelemetry<br/>Collector"]

    %% ═══════════════════════════════════════════════════
    %% External Inference Providers
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"REST API<br/>11434/TCP HTTP"| Ollama["Ollama"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| OpenAI["OpenAI API"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Anthropic["Anthropic API"]
    LlamaStack -->|"REST API SigV4<br/>443/TCP HTTPS"| Bedrock["AWS Bedrock"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Gemini["Google Gemini"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Groq["Groq API"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Together["Together AI"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Fireworks["Fireworks AI"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| SambaNova["SambaNova"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| NVIDIA["NVIDIA NIM"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| WatsonX["IBM watsonx"]
    LlamaStack -->|"REST API<br/>configurable"| HFtgi["HuggingFace TGI"]

    %% ═══════════════════════════════════════════════════
    %% Storage Dependencies
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"PostgreSQL protocol<br/>5432/TCP"| PgVector["PostgreSQL +<br/>pgvector"]
    LlamaStack -->|"Redis protocol<br/>6379/TCP"| Redis["Redis"]
    LlamaStack -->|"MongoDB protocol<br/>27017/TCP"| MongoDB["MongoDB"]
    LlamaStack -->|"HTTP<br/>8000/TCP"| Chroma["Chroma"]
    LlamaStack -->|"HTTP/gRPC<br/>6333/TCP"| Qdrant["Qdrant"]
    LlamaStack -->|"gRPC<br/>19530/TCP"| Milvus["Milvus"]
    LlamaStack -->|"HTTP (GraphQL)<br/>8080/TCP"| Weaviate["Weaviate"]

    %% ═══════════════════════════════════════════════════
    %% Auth & Security Dependencies
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"JWKS retrieval<br/>443/TCP HTTPS"| OAuth2JWKS["OAuth2 JWKS<br/>Endpoint"]
    LlamaStack -->|"Token introspection<br/>RFC 7662<br/>443/TCP HTTPS"| OAuth2Intro["OAuth2<br/>Introspection"]
    LlamaStack -->|"Token validation<br/>HTTPS"| CustomAuth["Custom Auth<br/>Endpoint"]

    %% ═══════════════════════════════════════════════════
    %% External Services
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Tavily["Tavily Search"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Brave["Brave Search"]
    LlamaStack -->|"REST API<br/>443/TCP HTTPS"| Wolfram["Wolfram Alpha"]
    LlamaStack -->|"MCP protocol<br/>HTTP/HTTPS"| MCP["MCP Servers"]

    %% ═══════════════════════════════════════════════════
    %% Runtime Dependencies
    %% ═══════════════════════════════════════════════════
    LlamaStack -->|"stdlib"| Python["Python >=3.10"]
    LlamaStack -->|"web framework"| FastAPI["FastAPI >=0.115"]
    LlamaStack -->|"data validation"| Pydantic["pydantic >=2"]
    LlamaStack -->|"HTTP client"| HTTPX["httpx 0.28.1"]

