graph LR
    LlamaStack["Llama Stack<br/>API Server"]

    %% ── Primary Inference Backends ──
    LlamaStack -->|"HTTP/HTTPS<br/>8000/TCP<br/>Bearer Token"| vLLM["vLLM<br/>(primary RHOAI)"]
    LlamaStack -->|"HTTP<br/>11434/TCP"| Ollama["Ollama<br/>(local dev)"]

    %% ── Cloud LLM Providers ──
    LlamaStack -->|"HTTPS/443<br/>API key"| OpenAI["OpenAI API"]
    LlamaStack -->|"HTTPS/443<br/>API key"| Anthropic["Anthropic API"]
    LlamaStack -->|"HTTPS/443<br/>IAM creds"| Bedrock["AWS Bedrock"]
    LlamaStack -->|"HTTPS/443<br/>API key"| NIM["NVIDIA NIM"]
    LlamaStack -->|"HTTPS/443<br/>API key"| OtherCloud["Fireworks | Together<br/>Groq | SambaNova<br/>Gemini"]

    %% ── Vector Databases ──
    LlamaStack -->|"TCP/5432<br/>user/pass"| PgVector["PostgreSQL<br/>pgvector"]
    LlamaStack -->|"HTTP/HTTPS"| ChromaDB["ChromaDB"]
    LlamaStack -->|"HTTP/gRPC<br/>API key"| Qdrant["Qdrant"]
    LlamaStack -->|"gRPC<br/>token"| Milvus["Milvus"]
    LlamaStack -->|"HTTP/HTTPS<br/>API key"| Weaviate["Weaviate"]

    %% ── Data Stores ──
    LlamaStack -->|"File I/O"| SQLite["SQLite<br/>(default persistence)"]
    LlamaStack -->|"TCP/6379<br/>password"| Redis["Redis"]
    LlamaStack -->|"TCP/27017<br/>user/pass"| MongoDB["MongoDB"]

    %% ── Auth & Identity ──
    LlamaStack -->|"HTTPS/443<br/>JWKS"| OIDC["OIDC Provider<br/>(Keycloak, etc.)"]
    LlamaStack -.->|"HTTPS/443<br/>client creds"| TokenIntro["Token Introspection<br/>(RFC 7662)"]
    LlamaStack -.->|"HTTPS"| CustomAuth["Custom Auth<br/>Endpoint"]

    %% ── Agent Tools ──
    LlamaStack -->|"HTTPS/443<br/>API key"| BraveSearch["Brave Search"]
    LlamaStack -->|"HTTPS/443<br/>API key"| Tavily["Tavily Search"]
    LlamaStack -->|"HTTPS/443<br/>API key"| Wolfram["Wolfram Alpha"]
    LlamaStack -->|"HTTPS/443<br/>HF token"| HFHub["HuggingFace Hub"]
    LlamaStack -.->|"HTTP/HTTPS"| MCP["MCP Servers"]

    %% ── Observability ──
    LlamaStack -->|"OTLP HTTP"| OTel["OpenTelemetry<br/>Collector"]

    %% ── Framework Dependencies ──
    LlamaStack -->|"runtime"| Python["Python >=3.10"]
    LlamaStack -->|"HTTP framework"| FastAPI["FastAPI"]
    LlamaStack -->|"validation"| Pydantic["Pydantic v2"]

    %% ── Styling ──
    style LlamaStack fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style vLLM fill:#7ed321,stroke:#333,color:#fff

    %% External inference
    style Ollama fill:#999,stroke:#333,color:#fff
    style OpenAI fill:#775599,stroke:#333,color:#fff
    style Anthropic fill:#775599,stroke:#333,color:#fff
    style Bedrock fill:#775599,stroke:#333,color:#fff
    style NIM fill:#775599,stroke:#333,color:#fff
    style OtherCloud fill:#775599,stroke:#333,color:#fff

    %% Vector DBs
    style PgVector fill:#2ecc71,stroke:#333,color:#fff
    style ChromaDB fill:#999,stroke:#333,color:#fff
    style Qdrant fill:#999,stroke:#333,color:#fff
    style Milvus fill:#999,stroke:#333,color:#fff
    style Weaviate fill:#999,stroke:#333,color:#fff

    %% Data stores
    style SQLite fill:#bdc3c7,stroke:#333
    style Redis fill:#999,stroke:#333,color:#fff
    style MongoDB fill:#999,stroke:#333,color:#fff

    %% Auth
    style OIDC fill:#f5a623,stroke:#333,color:#fff
    style TokenIntro fill:#f5a623,stroke:#333,color:#fff
    style CustomAuth fill:#f5a623,stroke:#333,color:#fff

    %% Tools
    style BraveSearch fill:#e67e22,stroke:#333,color:#fff
    style Tavily fill:#e67e22,stroke:#333,color:#fff
    style Wolfram fill:#e67e22,stroke:#333,color:#fff
    style HFHub fill:#e67e22,stroke:#333,color:#fff
    style MCP fill:#e67e22,stroke:#333,color:#fff

    %% Observability
    style OTel fill:#9b59b6,stroke:#333,color:#fff

    %% Framework
    style Python fill:#3776ab,stroke:#333,color:#fff
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style Pydantic fill:#e91e63,stroke:#333,color:#fff
