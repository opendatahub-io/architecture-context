graph LR
    LlamaStack["Llama Stack Server<br/>(FastAPI/uvicorn :8321)"]

    %% ─── Internal RHOAI Dependencies ───
    LlamaStack -->|"OpenAI-compatible API<br/>HTTP/HTTPS :8000"| VLLM["vLLM Model Serving"]
    LlamaStack -->|"PostgreSQL :5432<br/>Optional TLS"| PGVector["PostgreSQL + pgvector"]
    LlamaStack -->|"Redis :6379<br/>Optional TLS"| Redis["Redis"]
    LlamaStack -->|"HTTPS :443<br/>JWKS/Introspection"| OAuth2["OAuth2/OIDC Provider"]
    LlamaStack -->|"HTTP (OTLP)"| OTel["OpenTelemetry Collector"]

    %% ─── External Inference Providers ───
    LlamaStack -->|"HTTPS :443<br/>API key"| OpenAI["OpenAI API"]
    LlamaStack -->|"HTTPS :443<br/>API key"| Anthropic["Anthropic API"]
    LlamaStack -->|"HTTPS :443<br/>SigV4"| Bedrock["AWS Bedrock"]
    LlamaStack -->|"HTTPS :443<br/>API key"| Gemini["Google Gemini"]
    LlamaStack -->|"HTTPS :443<br/>API key"| NVIDIA["NVIDIA NIM"]
    LlamaStack -->|"HTTPS :443"| Groq["Groq API"]
    LlamaStack -->|"HTTPS :443"| Together["Together AI"]
    LlamaStack -->|"HTTPS :443"| Fireworks["Fireworks AI"]
    LlamaStack -->|"HTTPS :443"| SambaNova["SambaNova"]
    LlamaStack -->|"HTTPS :443"| WatsonX["IBM watsonx"]
    LlamaStack -->|"HTTP/HTTPS"| HFtgi["HuggingFace TGI"]
    LlamaStack -->|"HTTP :11434"| Ollama["Ollama"]

    %% ─── Vector Database Providers ───
    LlamaStack -->|"HTTP :8000"| Chroma["Chroma"]
    LlamaStack -->|"HTTP/gRPC :6333"| Qdrant["Qdrant"]
    LlamaStack -->|"gRPC :19530"| Milvus["Milvus"]
    LlamaStack -->|"HTTP :8080"| Weaviate["Weaviate"]

    %% ─── Data Store Alternatives ───
    LlamaStack -->|"MongoDB :27017<br/>Optional TLS"| MongoDB["MongoDB"]

    %% ─── External Services ───
    LlamaStack -->|"HTTPS :443<br/>HF token"| HFHub["HuggingFace Hub"]
    LlamaStack -->|"HTTPS :443<br/>API key"| Tavily["Tavily Search"]
    LlamaStack -->|"HTTPS :443<br/>API key"| Brave["Brave Search"]
    LlamaStack -->|"HTTPS :443<br/>API key"| Wolfram["Wolfram Alpha"]
    LlamaStack -->|"HTTP/HTTPS"| MCP["MCP Servers"]

    %% ─── Runtime Dependencies ───
    LlamaStack -.->|"runtime"| Python["Python >=3.10"]
    LlamaStack -.->|"framework"| FastAPI["FastAPI >=0.115"]
    LlamaStack -.->|"ASGI server"| Uvicorn["uvicorn"]
    LlamaStack -.->|"validation"| Pydantic["pydantic >=2"]
    LlamaStack -.->|"JWT"| PythonJose["python-jose"]

