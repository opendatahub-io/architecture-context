graph LR
    LlamaStack["Llama Stack<br/>AI Application Server"]

    %% Core Runtime Dependencies
    subgraph CoreRuntime["Core Runtime (Required)"]
        Python["Python >=3.10"]
        FastAPI["FastAPI >=0.115"]
        Uvicorn["uvicorn"]
        Pydantic["pydantic >=2"]
        Httpx["httpx 0.28.1"]
        PythonJose["python-jose 3.4.0<br/>(JWT validation)"]
    end

    LlamaStack -->|runtime| Python
    LlamaStack -->|web framework| FastAPI
    LlamaStack -->|ASGI server| Uvicorn
    LlamaStack -->|data validation| Pydantic
    LlamaStack -->|async HTTP client| Httpx
    LlamaStack -->|JWT auth| PythonJose

    %% Inference Backends (Remote Providers)
    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Server<br/>8000/TCP"]
        Ollama["Ollama<br/>11434/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
        Anthropic["Anthropic API<br/>443/TCP"]
        AWSBedrock["AWS Bedrock<br/>443/TCP"]
        GoogleGemini["Google Gemini<br/>443/TCP"]
        NVIDIANIM["NVIDIA NIM<br/>443/TCP"]
        Groq["Groq API<br/>443/TCP"]
        Together["Together AI<br/>443/TCP"]
        Fireworks["Fireworks AI<br/>443/TCP"]
        SambaNova["SambaNova<br/>443/TCP"]
        IBMWatsonx["IBM watsonx<br/>443/TCP"]
        HFTGI["HuggingFace TGI"]
    end

    LlamaStack -->|"primary (RHOAI)"| vLLM
    LlamaStack -->|alternative local| Ollama
    LlamaStack -->|remote provider| OpenAI
    LlamaStack -->|remote provider| Anthropic
    LlamaStack -->|remote provider| AWSBedrock
    LlamaStack -->|remote provider| GoogleGemini
    LlamaStack -->|remote provider| NVIDIANIM
    LlamaStack -->|remote provider| Groq
    LlamaStack -->|remote provider| Together
    LlamaStack -->|remote provider| Fireworks
    LlamaStack -->|remote provider| SambaNova
    LlamaStack -->|remote provider| IBMWatsonx
    LlamaStack -->|remote provider| HFTGI

    %% Vector Databases
    subgraph VectorDBs["Vector Databases"]
        PgVector["PostgreSQL + pgvector<br/>5432/TCP"]
        ChromaDB["ChromaDB<br/>8000/TCP"]
        QdrantDB["Qdrant<br/>6333/TCP"]
        MilvusDB["Milvus<br/>19530/TCP"]
        WeaviateDB["Weaviate<br/>8080/TCP"]
        FAISSLocal["FAISS (inline)<br/>in-process"]
        SQLiteVec["SQLite-vec (inline)<br/>in-process"]
    end

    LlamaStack -->|vector storage| PgVector
    LlamaStack -->|vector storage| ChromaDB
    LlamaStack -->|vector storage| QdrantDB
    LlamaStack -->|vector storage| MilvusDB
    LlamaStack -->|vector storage| WeaviateDB
    LlamaStack -->|vector storage| FAISSLocal
    LlamaStack -->|vector storage| SQLiteVec

    %% KV/SQL Stores
    subgraph DataStores["KV / SQL Stores"]
        PostgresSQL["PostgreSQL (SQL Store)<br/>5432/TCP"]
        Redis["Redis<br/>6379/TCP"]
        MongoDB["MongoDB<br/>27017/TCP"]
        SQLiteKV["SQLite (inline)<br/>local file"]
    end

    LlamaStack -->|state persistence| PostgresSQL
    LlamaStack -->|KV store / quota| Redis
    LlamaStack -->|alt KV store| MongoDB
    LlamaStack -->|local KV store| SQLiteKV

    %% Auth & Identity
    subgraph AuthIdentity["Authentication & Identity"]
        OAuth2JWKS["OAuth2 JWKS<br/>443/TCP"]
        OAuth2Introspect["OAuth2 Introspection<br/>443/TCP (RFC 7662)"]
        CustomAuthEP["Custom Auth Endpoint"]
    end

    LlamaStack -->|JWT validation| OAuth2JWKS
    LlamaStack -->|token introspection| OAuth2Introspect
    LlamaStack -.->|custom auth| CustomAuthEP

    %% Tools & External Services
    subgraph ToolsServices["Tools & External Services"]
        Tavily["Tavily Search<br/>443/TCP"]
        Brave["Brave Search<br/>443/TCP"]
        Wolfram["Wolfram Alpha<br/>443/TCP"]
        HFHub["HuggingFace Hub<br/>443/TCP"]
        MCPServers["MCP Servers<br/>configurable"]
    end

    LlamaStack -->|agent tools| Tavily
    LlamaStack -->|agent tools| Brave
    LlamaStack -->|agent tools| Wolfram
    LlamaStack -->|model downloads| HFHub
    LlamaStack -->|tool integration| MCPServers

    %% Observability
    subgraph ObservabilityStack["Observability"]
        OTelCollector["OpenTelemetry Collector<br/>OTLP/HTTP"]
    end

    LlamaStack -->|traces & metrics| OTelCollector

