graph LR
    LlamaStack["Llama Stack<br/>Server"]

    %% Core External Dependencies
    LlamaStack -->|"runtime"| Python["Python >=3.10"]
    LlamaStack -->|"HTTP framework"| FastAPI["FastAPI >=0.115"]
    LlamaStack -->|"ASGI server"| Uvicorn["Uvicorn"]
    LlamaStack -->|"data validation"| Pydantic["Pydantic >=2"]
    LlamaStack -->|"JWT validation"| PythonJose["python-jose<br/>⚠️ pure-Python crypto"]

    %% Inference Providers (Internal RHOAI)
    LlamaStack -->|"primary inference<br/>8000/TCP"| vLLM["vLLM<br/>(Primary RHOAI)"]
    LlamaStack -->|"local inference<br/>11434/TCP"| Ollama["Ollama"]

    %% Cloud Inference Providers
    LlamaStack -.->|"remote inference<br/>443/TCP"| OpenAI["OpenAI API"]
    LlamaStack -.->|"remote inference<br/>443/TCP"| Anthropic["Anthropic API"]
    LlamaStack -.->|"remote inference/safety<br/>443/TCP"| Bedrock["AWS Bedrock"]
    LlamaStack -.->|"remote inference/eval<br/>443/TCP"| NVIDIA["NVIDIA NIM"]
    LlamaStack -.->|"remote inference<br/>443/TCP"| OtherCloud["Fireworks / Together /<br/>Groq / SambaNova / Gemini"]

    %% Vector Databases
    LlamaStack -->|"vector storage<br/>5432/TCP"| pgvector["PostgreSQL/pgvector"]
    LlamaStack -.->|"vector storage"| ChromaDB["ChromaDB"]
    LlamaStack -.->|"vector storage"| Qdrant["Qdrant"]
    LlamaStack -.->|"vector storage"| Milvus["Milvus"]
    LlamaStack -.->|"vector storage"| Weaviate["Weaviate"]

    %% KV Stores
    LlamaStack -->|"default persistence"| SQLite["SQLite"]
    LlamaStack -.->|"KV store<br/>6379/TCP"| Redis["Redis"]
    LlamaStack -.->|"KV store<br/>27017/TCP"| MongoDB["MongoDB"]

    %% Authentication
    LlamaStack -->|"JWT validation<br/>443/TCP"| OIDC["OIDC Provider<br/>(Keycloak)"]

    %% Tool Services
    LlamaStack -.->|"web search<br/>443/TCP"| BraveSearch["Brave Search"]
    LlamaStack -.->|"web search<br/>443/TCP"| TavilySearch["Tavily Search"]
    LlamaStack -.->|"computation<br/>443/TCP"| Wolfram["Wolfram Alpha"]
    LlamaStack -.->|"tool integration"| MCPServers["MCP Servers"]

    %% Observability
    LlamaStack -->|"tracing (OTLP)"| OTel["OpenTelemetry<br/>Collector"]

    %% Data Services
    LlamaStack -->|"model/dataset<br/>download 443/TCP"| HuggingFace["HuggingFace Hub"]

