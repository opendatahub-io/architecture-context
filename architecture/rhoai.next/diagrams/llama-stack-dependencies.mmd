graph LR
    LlamaStack["Llama Stack Server<br/>(FastAPI/Uvicorn)"]

    %% ── Primary Inference Providers ──
    LlamaStack -->|"inference<br/>HTTP/8000<br/>API Key"| vLLM["vLLM<br/>(primary RHOAI backend)"]
    LlamaStack -->|"inference<br/>HTTP/11434<br/>plaintext"| Ollama["Ollama<br/>(local dev)"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| TGI["TGI / HuggingFace<br/>Inference"]

    %% ── Cloud Inference Providers ──
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| OpenAI["OpenAI API"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| Anthropic["Anthropic API"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| Gemini["Google Gemini"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>AWS IAM"| Bedrock["AWS Bedrock"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| NVIDIA["NVIDIA NIM"]
    LlamaStack -->|"inference<br/>HTTPS/443<br/>API Key"| OtherCloud["Together / Fireworks /<br/>Groq / SambaNova /<br/>Cerebras / Databricks /<br/>RunPod / WatsonX"]

    %% ── Vector Databases ──
    LlamaStack -->|"vector storage<br/>TCP/5432<br/>user/pass"| PGVector["PostgreSQL<br/>pgvector"]
    LlamaStack -->|"vector storage<br/>HTTP/8000"| ChromaDB["ChromaDB"]
    LlamaStack -->|"vector storage<br/>HTTP+gRPC/6333"| Qdrant["Qdrant"]
    LlamaStack -->|"vector storage<br/>gRPC/19530"| Milvus["Milvus"]
    LlamaStack -->|"vector storage<br/>HTTP/8080"| Weaviate["Weaviate"]

    %% ── Agent Tools ──
    LlamaStack -->|"web search<br/>HTTPS/443"| BraveSearch["Brave Search"]
    LlamaStack -->|"web search<br/>HTTPS/443"| TavilySearch["Tavily Search"]
    LlamaStack -->|"web search<br/>HTTPS/443"| BingSearch["Bing Search"]
    LlamaStack -->|"computation<br/>HTTPS/443"| WolframAlpha["Wolfram Alpha"]
    LlamaStack -.->|"MCP protocol<br/>configurable"| MCPServers["MCP Servers"]

    %% ── Infrastructure ──
    LlamaStack -->|"JWT validation<br/>HTTPS/443"| OAuth2["OAuth2 IdP<br/>(JWKS / Introspection)"]
    LlamaStack -->|"telemetry<br/>HTTP/4318"| OTLP["OTLP Collector"]
    LlamaStack -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LlamaStack -->|"metadata<br/>file I/O"| SQLite["SQLite"]

    %% ── Inline (In-Process) Providers ──
    LlamaStack -.->|"in-process"| FAISS["FAISS<br/>(inline vector)"]
    LlamaStack -.->|"in-process"| MetaRef["meta-reference<br/>(PyTorch inference)"]

    %% ── Python Dependencies ──
    LlamaStack -.->|"framework"| FastAPI["FastAPI >=0.115"]
    LlamaStack -.->|"runtime"| Python["Python >=3.10"]

    %% ── Styling ──
    style LlamaStack fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Primary inference
    style vLLM fill:#7ed321,stroke:#333,stroke-width:2px
    style Ollama fill:#999,stroke:#333
    style TGI fill:#999,stroke:#333

    %% Cloud inference
    style OpenAI fill:#999,stroke:#333
    style Anthropic fill:#999,stroke:#333
    style Gemini fill:#999,stroke:#333
    style Bedrock fill:#999,stroke:#333
    style NVIDIA fill:#999,stroke:#333
    style OtherCloud fill:#999,stroke:#333

    %% Vector databases
    style PGVector fill:#fff2cc,stroke:#d6b656
    style ChromaDB fill:#fff2cc,stroke:#d6b656
    style Qdrant fill:#fff2cc,stroke:#d6b656
    style Milvus fill:#fff2cc,stroke:#d6b656
    style Weaviate fill:#fff2cc,stroke:#d6b656

    %% Tools
    style BraveSearch fill:#e1d5e7,stroke:#9673a6
    style TavilySearch fill:#e1d5e7,stroke:#9673a6
    style BingSearch fill:#e1d5e7,stroke:#9673a6
    style WolframAlpha fill:#e1d5e7,stroke:#9673a6
    style MCPServers fill:#e1d5e7,stroke:#9673a6

    %% Infrastructure
    style OAuth2 fill:#f5a623,stroke:#333
    style OTLP fill:#f8cecc,stroke:#b85450
    style HFHub fill:#ffe6cc,stroke:#d79b00
    style SQLite fill:#d5e8d4,stroke:#82b366
    style FAISS fill:#d5e8d4,stroke:#82b366
    style MetaRef fill:#d5e8d4,stroke:#82b366
    style FastAPI fill:#dae8fc,stroke:#6c8ebf
    style Python fill:#dae8fc,stroke:#6c8ebf
