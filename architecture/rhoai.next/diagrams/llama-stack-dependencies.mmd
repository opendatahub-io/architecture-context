graph LR
    LlamaStack["Llama Stack<br/>Server"]

    %% Core Runtime Dependencies
    subgraph CoreRuntime["Core Runtime"]
        Python["Python >=3.10"]
        FastAPI["FastAPI >=0.115"]
        Uvicorn["Uvicorn"]
        Pydantic["Pydantic >=2"]
    end

    LlamaStack -->|"runtime"| Python
    LlamaStack -->|"HTTP framework"| FastAPI
    LlamaStack -->|"ASGI server"| Uvicorn
    LlamaStack -->|"validation"| Pydantic

    %% Internal RHOAI Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        vLLM["vLLM<br/>(Primary Inference)"]
    end

    LlamaStack -->|"inference<br/>8000/TCP HTTP/HTTPS"| vLLM

    %% Inference Providers
    subgraph InferenceRemote["Remote Inference Providers"]
        Ollama["Ollama<br/>11434/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
        Anthropic["Anthropic API<br/>443/TCP"]
        Bedrock["AWS Bedrock<br/>443/TCP"]
        NIM["NVIDIA NIM<br/>443/TCP"]
        Fireworks["Fireworks API<br/>443/TCP"]
        Together["Together API<br/>443/TCP"]
        Groq["Groq API<br/>443/TCP"]
        SambaNova["SambaNova API<br/>443/TCP"]
        Gemini["Gemini API<br/>443/TCP"]
    end

    LlamaStack -->|"local inference"| Ollama
    LlamaStack -->|"remote inference"| OpenAI
    LlamaStack -->|"remote inference"| Anthropic
    LlamaStack -->|"remote inference"| Bedrock
    LlamaStack -->|"remote inference"| NIM
    LlamaStack -.->|"remote inference"| Fireworks
    LlamaStack -.->|"remote inference"| Together
    LlamaStack -.->|"remote inference"| Groq
    LlamaStack -.->|"remote inference"| SambaNova
    LlamaStack -.->|"remote inference"| Gemini

    %% Vector Database Dependencies
    subgraph VectorDBs["Vector Database Providers"]
        pgvector["PostgreSQL/pgvector<br/>5432/TCP"]
        ChromaDB["ChromaDB"]
        Qdrant["Qdrant"]
        Milvus["Milvus"]
        Weaviate["Weaviate"]
    end

    LlamaStack -->|"vector storage<br/>RAG"| pgvector
    LlamaStack -.->|"vector storage"| ChromaDB
    LlamaStack -.->|"vector storage"| Qdrant
    LlamaStack -.->|"vector storage"| Milvus
    LlamaStack -.->|"vector storage"| Weaviate

    %% KV Store Dependencies
    subgraph KVStores["KV Store Backends"]
        SQLite["SQLite<br/>(default)"]
        Redis["Redis<br/>6379/TCP"]
        MongoDB["MongoDB<br/>27017/TCP"]
    end

    LlamaStack -->|"default persistence"| SQLite
    LlamaStack -.->|"KV store"| Redis
    LlamaStack -.->|"KV store"| MongoDB

    %% Tool Dependencies
    subgraph Tools["Agent Tool Providers"]
        BraveSearch["Brave Search<br/>443/TCP"]
        Tavily["Tavily Search<br/>443/TCP"]
        Wolfram["Wolfram Alpha<br/>443/TCP"]
        MCPServers["MCP Servers"]
    end

    LlamaStack -.->|"web search"| BraveSearch
    LlamaStack -.->|"web search"| Tavily
    LlamaStack -.->|"computation"| Wolfram
    LlamaStack -.->|"tool integration"| MCPServers

    %% Auth & Observability Dependencies
    subgraph AuthObs["Auth & Observability"]
        OIDC["OIDC Provider<br/>(Keycloak)<br/>443/TCP"]
        OTel["OpenTelemetry<br/>Collector"]
        HFHub["HuggingFace Hub<br/>443/TCP"]
    end

    LlamaStack -->|"JWT validation"| OIDC
    LlamaStack -.->|"tracing (OTLP)"| OTel
    LlamaStack -.->|"model/dataset download"| HFHub

    %% Key Python Libraries
    subgraph PyLibs["Key Python Libraries"]
        httpx["httpx"]
        pythonJose["python-jose<br/>(JWT)"]
        openaiSDK["openai SDK >=1.66"]
        llamaClient["llama-stack-client<br/>>=0.2.10"]
        Jinja2["Jinja2 >=3.1.6"]
    end

    LlamaStack -->|"HTTP client"| httpx
    LlamaStack -->|"JWT validation"| pythonJose
    LlamaStack -->|"OpenAI compat"| openaiSDK
    LlamaStack -->|"client SDK"| llamaClient
    LlamaStack -->|"prompt templates"| Jinja2

