graph TD
    subgraph LibraryNote["caikit-nlp RBAC"]
        Note["caikit-nlp is a Python library<br/>and does not define Kubernetes<br/>RBAC resources directly"]
    end

    subgraph PlatformManaged["Platform-Managed Security"]
        direction TB

        subgraph RuntimePod["Runtime Pod Security"]
            Container["Container Runtime<br/>Base: ubi9/ubi-minimal<br/>User: caikit (UID 1001)<br/>Non-root"]
        end

        subgraph PlatformAuth["Platform Authentication"]
            KubeRBAC["kube-rbac-proxy<br/>Endpoint AuthN/AuthZ"]
            KServeAuth["KServe InferenceService<br/>Request routing + auth"]
            GatewayAPI["Gateway API<br/>Ingress management"]
        end

        subgraph TGISSecurity["TGIS Connection Security"]
            CACert["CA Certificate<br/>(ca_cert_file)<br/>TLS verification"]
            ClientCert["Client Certificate<br/>(client_cert_file)<br/>mTLS authentication"]
            ClientKey["Client Key<br/>(client_key_file)<br/>mTLS key material"]
        end

        subgraph FIPSCompliance["FIPS Compliance"]
            UBIOpenSSL["UBI9 OpenSSL<br/>FIPS-validated crypto"]
            GRPCIOCrypto["grpcio → system OpenSSL<br/>TLS for TGIS connections"]
            NoCrypto["No direct crypto ops<br/>in caikit-nlp code"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        HTTP8080["HTTP API<br/>8080/TCP<br/>10 task endpoints"]
        GRPC8085["gRPC API<br/>8085/TCP<br/>NlpService + Health"]
    end

    KubeRBAC -->|"protects"| HTTP8080
    KubeRBAC -->|"protects"| GRPC8085
    KServeAuth -->|"routes to"| HTTP8080
    GatewayAPI -->|"manages"| KServeAuth

    CACert -->|"verifies"| TGISConn["TGIS gRPC Connection<br/>default 8033/TCP"]
    ClientCert -->|"authenticates"| TGISConn
    ClientKey -->|"signs"| TGISConn

    UBIOpenSSL -->|"provides crypto"| GRPCIOCrypto
    GRPCIOCrypto -->|"secures"| TGISConn

