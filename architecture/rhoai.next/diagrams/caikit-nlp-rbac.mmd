graph TD
    subgraph Note["caikit-nlp RBAC Model"]
        direction TB
        Info["caikit-nlp is a Python library<br/>No Kubernetes RBAC resources defined<br/>All auth/authz delegated to platform"]
    end

    subgraph PlatformAuth["Platform-Level Authentication & Authorization"]
        direction TB

        subgraph IngressAuth["Ingress Auth (Platform-Managed)"]
            KServeAuth["KServe InferenceService<br/>Auth: Platform-level"]
            GatewayAuth["Gateway API<br/>Auth: Platform-level"]
            RBACPROXY["kube-rbac-proxy<br/>Auth: Bearer Token / mTLS"]
        end

        subgraph EndpointAuth["Endpoint Auth Enforcement"]
            HTTPEndpoints["HTTP Endpoints (8080/TCP)<br/>/api/v1/task/text-generation<br/>/api/v1/task/embedding<br/>/api/v1/task/rerank<br/>/api/v1/task/text-classification<br/>/api/v1/task/tokenization<br/>Auth: Delegated to platform"]
            GRPCEndpoints["gRPC Endpoints (8085/TCP)<br/>caikit.runtime.Nlp.NlpService<br/>grpc.health.v1.Health<br/>Auth: Delegated to platform"]
        end

        KServeAuth -->|enforces| HTTPEndpoints
        KServeAuth -->|enforces| GRPCEndpoints
        GatewayAuth -->|enforces| HTTPEndpoints
        GatewayAuth -->|enforces| GRPCEndpoints
        RBACPROXY -->|enforces| HTTPEndpoints
        RBACPROXY -->|enforces| GRPCEndpoints
    end

    subgraph TGISAuth["TGIS Backend Authentication"]
        TGISConnection["TGIS gRPC Connection<br/>Auth: mTLS (optional)"]
        CACert["CA Cert<br/>(ca_cert_file)<br/>TLS verification"]
        ClientCert["Client Cert<br/>(client_cert_file)<br/>mTLS authentication"]
        ClientKey["Client Key<br/>(client_key_file)<br/>mTLS key"]

        CACert -->|verifies server| TGISConnection
        ClientCert -->|authenticates client| TGISConnection
        ClientKey -->|signs requests| TGISConnection
    end

    subgraph ContainerSecurity["Container Security"]
        NonRoot["Non-Root User<br/>caikit (UID 1001)"]
        BaseImage["Base Image<br/>ubi9/ubi-minimal"]
        FIPS["FIPS Compliance<br/>Inherited from UBI9 OpenSSL"]
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style PlatformAuth fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style TGISAuth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style ContainerSecurity fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style KServeAuth fill:#7ed321,stroke:#333
    style GatewayAuth fill:#7ed321,stroke:#333
    style RBACPROXY fill:#7ed321,stroke:#333
    style HTTPEndpoints fill:#b6d7a8,stroke:#333
    style GRPCEndpoints fill:#b6d7a8,stroke:#333
    style TGISConnection fill:#6ba3d6,stroke:#333
    style CACert fill:#f5a623,stroke:#333
    style ClientCert fill:#f5a623,stroke:#333
    style ClientKey fill:#f5a623,stroke:#333
    style NonRoot fill:#d5a6bd,stroke:#333
    style BaseImage fill:#d5a6bd,stroke:#333
    style FIPS fill:#d5a6bd,stroke:#333
