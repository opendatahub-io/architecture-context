graph TD
    subgraph LibraryContext["caikit-nlp (Python Library — No Kubernetes RBAC)"]
        direction TB

        Note["caikit-nlp is a Python library, not a<br/>Kubernetes operator. It does not define<br/>ClusterRoles, Roles, or RoleBindings.<br/><br/>RBAC is managed by the caikit runtime's<br/>Kubernetes deployment."]
    end

    subgraph SecurityConfig["Security Configuration (Application-Level)"]
        direction TB

        subgraph TLSConfig["TLS / mTLS Configuration"]
            CACert["ca_cert_file<br/>(CA certificate)<br/>Verifies TGIS server"]
            ClientCert["client_cert_file<br/>(Client certificate)<br/>mTLS to TGIS"]
            ClientKey["client_key_file<br/>(Client key)<br/>mTLS to TGIS"]
        end

        subgraph AccessControls["Access Controls (Config-Based)"]
            AllowDownloads["allow_downloads<br/>DEFAULT: false<br/>Prevents model downloading"]
            TrustRemoteCode["trust_remote_code<br/>DEFAULT: false<br/>Prevents untrusted code exec"]
            BaseModelsDir["base_models_dir<br/>Restricts model filesystem access"]
            SourcePromptBase["source_prompt_base<br/>Restricts prompt filesystem access"]
            PathValidation["TWO_DOTS_REGEX<br/>Prevents directory traversal"]
        end
    end

    subgraph AuthFlow["Authentication Flows"]
        direction LR

        TGISAuth["TGIS Connection<br/>Method: mTLS (optional)<br/>Enforcement: TLS handshake<br/>Config: runtime_config.yaml"]

        HFAuth["HuggingFace Hub<br/>Method: API Token (optional)<br/>Enforcement: HTTP header<br/>Config: HF_TOKEN env var"]
    end

    %% Connections
    CACert -->|"verifies server"| TGISAuth
    ClientCert -->|"authenticates client"| TGISAuth
    ClientKey -->|"signs handshake"| TGISAuth
    AllowDownloads -->|"gates access"| HFAuth

    %% Styling
    style Note fill:#f9f9f9,stroke:#999,stroke-width:1px
    style LibraryContext fill:#fff,stroke:#999,stroke-dasharray: 5 5
    style SecurityConfig fill:#e8f4f8,stroke:#4a90e2,stroke-width:2px
    style TLSConfig fill:#ffe6cc,stroke:#d79b00
    style AccessControls fill:#d5e8d4,stroke:#82b366
    style AuthFlow fill:#fff2cc,stroke:#d6b656

    style CACert fill:#f5a623,stroke:#333
    style ClientCert fill:#f5a623,stroke:#333
    style ClientKey fill:#f5a623,stroke:#333

    style AllowDownloads fill:#7ed321,stroke:#333
    style TrustRemoteCode fill:#7ed321,stroke:#333
    style BaseModelsDir fill:#7ed321,stroke:#333
    style SourcePromptBase fill:#7ed321,stroke:#333
    style PathValidation fill:#7ed321,stroke:#333

    style TGISAuth fill:#4a90e2,stroke:#333,color:#fff
    style HFAuth fill:#4a90e2,stroke:#333,color:#fff
