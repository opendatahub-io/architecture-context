graph TD
    subgraph Note["Caikit-NLP RBAC Model"]
        direction TB
        Info["caikit-nlp is a Python library,<br/>NOT a Kubernetes operator.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined."]
    end

    subgraph PlatformAuth["Platform-Level Authentication (RHOAI)"]
        direction TB
        KubeRBAC["kube-rbac-proxy Sidecar<br/>(RHOAI 3.x)"]
        KubeRBAC -->|"enforces"| TokenAuth["Token Validation<br/>+ Kubernetes RBAC"]
    end

    subgraph TLSConfig["TLS / mTLS Configuration"]
        direction TB

        subgraph ServerTLS["Server TLS (gRPC + HTTP)"]
            ServerKey["RUNTIME_TLS_SERVER_KEY<br/>(file path)"]
            ServerCert["RUNTIME_TLS_SERVER_CERT<br/>(file path)"]
            ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>(file path, optional mTLS)"]
        end

        subgraph BackendTLS["TGIS Backend TLS (per-connection)"]
            CACert["ca_cert_file<br/>(CA certificate)"]
            BEClientCert["client_cert_file<br/>(client cert for mTLS)"]
            BEClientKey["client_key_file<br/>(client key for mTLS)"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        direction TB
        gRPCEP["gRPC Services<br/>8085/TCP<br/>7 services"]
        HTTPEP["HTTP REST<br/>8080/TCP<br/>13 endpoints"]
    end

    KubeRBAC -->|"proxies to"| gRPCEP
    KubeRBAC -->|"proxies to"| HTTPEP
    ServerKey -->|"secures"| gRPCEP
    ServerCert -->|"secures"| gRPCEP
    ServerKey -->|"secures"| HTTPEP
    ServerCert -->|"secures"| HTTPEP

    subgraph TGISConnection["TGIS Backend Connection"]
        TGISEndpoint["TGIS gRPC<br/>Configurable Port/TCP"]
    end

    CACert -->|"verifies"| TGISEndpoint
    BEClientCert -->|"authenticates"| TGISEndpoint
    BEClientKey -->|"authenticates"| TGISEndpoint

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Info fill:#fff2cc,stroke:#d6b656
    style PlatformAuth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style KubeRBAC fill:#d79b00,stroke:#333,color:#fff
    style TokenAuth fill:#ffe6cc,stroke:#d79b00
    style TLSConfig fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ServerTLS fill:#d5e8d4,stroke:#82b366
    style BackendTLS fill:#d5e8d4,stroke:#82b366
    style Endpoints fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style gRPCEP fill:#4a90e2,stroke:#333,color:#fff
    style HTTPEP fill:#4a90e2,stroke:#333,color:#fff
    style TGISConnection fill:#f9f9f9,stroke:#999
    style TGISEndpoint fill:#999,stroke:#333,color:#fff
