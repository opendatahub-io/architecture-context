graph TD
    subgraph LibraryLevel["caikit-nlp (Python Library - No Kubernetes RBAC)"]
        direction TB
        Note1["No ClusterRoles defined"]
        Note2["No RoleBindings defined"]
        Note3["No ServiceAccounts created"]
    end

    subgraph PlatformAuth["Platform-Level Authentication (RHOAI)"]
        direction TB

        subgraph Sidecar["kube-rbac-proxy Sidecar (RHOAI 3.x)"]
            RBAC["kube-rbac-proxy<br/>Intercepts all requests<br/>Enforces AuthN/AuthZ"]
        end

        subgraph TLSConfig["TLS Configuration (Runtime-Level)"]
            direction LR
            ServerKey["RUNTIME_TLS_SERVER_KEY<br/>(file path)<br/>TLS private key"]
            ServerCert["RUNTIME_TLS_SERVER_CERT<br/>(file path)<br/>TLS certificate"]
            ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>(file path)<br/>Client cert for mTLS"]
        end

        subgraph TGISTls["TGIS Backend TLS (Per-Connection)"]
            direction LR
            CACert["ca_cert_file<br/>CA certificate"]
            TGISClientCert["client_cert_file<br/>Client certificate"]
            TGISClientKey["client_key_file<br/>Client private key"]
        end
    end

    subgraph AccessFlow["Request Access Flow"]
        Client["External Client"] -->|"1. Request"| RBAC
        RBAC -->|"2. Authenticated"| gRPCServer["gRPC Server :8085<br/>Configurable TLS"]
        RBAC -->|"2. Authenticated"| HTTPServer["HTTP Server :8080<br/>Configurable TLS"]
        gRPCServer -->|"3. in-process"| Modules["caikit-nlp Modules"]
        HTTPServer -->|"3. in-process"| Modules
        Modules -->|"4. Optional mTLS"| TGIS["TGIS Backend"]
    end

    ServerKey -->|configures| gRPCServer
    ServerCert -->|configures| gRPCServer
    ServerKey -->|configures| HTTPServer
    ServerCert -->|configures| HTTPServer
    ClientCert -->|configures| gRPCServer
    CACert -->|configures| TGIS
    TGISClientCert -->|configures| TGIS
    TGISClientKey -->|configures| TGIS

    %% Styling
    style LibraryLevel fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5
    style Note1 fill:#fff,stroke:#ccc
    style Note2 fill:#fff,stroke:#ccc
    style Note3 fill:#fff,stroke:#ccc
    style RBAC fill:#f5a623,stroke:#333,color:#fff
    style gRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style Modules fill:#7ed321,stroke:#333
    style TGIS fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style ServerKey fill:#f8cecc,stroke:#b85450
    style ServerCert fill:#f8cecc,stroke:#b85450
    style ClientCert fill:#f8cecc,stroke:#b85450
    style CACert fill:#fff2cc,stroke:#d6b656
    style TGISClientCert fill:#fff2cc,stroke:#d6b656
    style TGISClientKey fill:#fff2cc,stroke:#d6b656
