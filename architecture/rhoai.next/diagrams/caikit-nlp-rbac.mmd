graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["caikit-nlp is a Python library,<br/>not a Kubernetes operator.<br/><br/>No RBAC resources<br/>(ClusterRoles, Roles, RoleBindings)<br/>are defined by this component.<br/><br/>RBAC is managed by the consuming<br/>Caikit Runtime deployment."]
    end

    subgraph ContainerSecurity["Container Security"]
        direction TB
        BaseImage["Base Image<br/>registry.access.redhat.com/<br/>ubi9/ubi-minimal:latest"]
        RunAs["Runs As<br/>UID 1001 (non-root)<br/>Group: caikit"]
        AIPCC["AIPCC Base Images<br/>NOT USED<br/>(migration recommended)"]
    end

    subgraph LibrarySecurity["Library Security Controls"]
        direction TB
        Downloads["allow_downloads: false<br/>(default)<br/>Prevents arbitrary model<br/>downloads from HuggingFace"]
        PathValidation["Path Validation<br/>TWO_DOTS_REGEX<br/>Prevents directory traversal<br/>in PEFT configs"]
        ThreadSafe["Thread-Safe Tokenization<br/>Per-thread tokenizer copies<br/>Avoids race conditions"]
    end

    subgraph TLSConfig["TLS Configuration (TGIS)"]
        direction TB
        CACert["ca_cert_file<br/>Configurable CA certificate<br/>for TGIS server verification"]
        ClientCert["client_cert_file<br/>Configurable client certificate<br/>for mTLS to TGIS"]
        ClientKey["client_key_file<br/>Configurable client key<br/>for mTLS to TGIS"]
    end

    %% Styling
    style Note fill:#f0f0f0,stroke:#666,stroke-width:2px
    style Info fill:#fff,stroke:#999
    style ContainerSecurity fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style LibrarySecurity fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style TLSConfig fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style BaseImage fill:#82b366,color:#fff
    style RunAs fill:#82b366,color:#fff
    style AIPCC fill:#e06666,color:#fff
    style Downloads fill:#4a90e2,color:#fff
    style PathValidation fill:#4a90e2,color:#fff
    style ThreadSafe fill:#4a90e2,color:#fff
    style CACert fill:#d79b00,color:#fff
    style ClientCert fill:#d79b00,color:#fff
    style ClientKey fill:#d79b00,color:#fff
