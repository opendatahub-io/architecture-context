graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["caikit-nlp is a Python library,<br/>NOT a Kubernetes operator.<br/><br/>No RBAC resources are defined<br/>by caikit-nlp itself."]
    end

    subgraph RuntimeSecurity["Runtime Security Model"]
        direction TB

        subgraph ContainerSecurity["Container Security"]
            NonRoot["Non-root execution<br/>UID: 1001 (caikit user)<br/>Dedicated group"]
            BaseImage["Base Image: UBI 9 minimal<br/>registry.access.redhat.com/ubi9/ubi-minimal:latest<br/>FIPS-validated OpenSSL"]
        end

        subgraph AccessControl["Access Controls (Library-Level)"]
            AllowDownloads["allow_downloads: false<br/><i>Prevents arbitrary model downloads</i>"]
            TrustRemoteCode["trust_remote_code: false<br/><i>Prevents untrusted code execution</i>"]
        end

        subgraph TLSConfig["TLS Configuration (TGIS)"]
            CACert["ca_cert_file<br/><i>Custom CA bundle</i>"]
            ClientCert["client_cert_file<br/><i>Client certificate for mTLS</i>"]
            ClientKey["client_key_file<br/><i>Client private key</i>"]
        end
    end

    subgraph PlatformRBAC["Platform-Level Auth (Not caikit-nlp)"]
        direction TB
        KubeRBAC["kube-rbac-proxy<br/><i>Platform ingress AuthN/AuthZ</i>"]
        GatewayAPI["Gateway API<br/><i>Platform routing + auth</i>"]
        KServeAuth["KServe InferenceService<br/><i>Service account per deployment</i>"]
    end

    RuntimeSecurity -->|"AuthN/AuthZ delegated to"| PlatformRBAC

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Info fill:#fff3cd,stroke:none
    style RuntimeSecurity fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ContainerSecurity fill:#e8f0fe,stroke:#4a90e2
    style AccessControl fill:#e8f0fe,stroke:#4a90e2
    style TLSConfig fill:#e8f0fe,stroke:#4a90e2
    style PlatformRBAC fill:#f0f0f0,stroke:#666,stroke-width:2px
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style AllowDownloads fill:#d5e8d4,stroke:#82b366
    style TrustRemoteCode fill:#d5e8d4,stroke:#82b366
    style CACert fill:#fff2cc,stroke:#d6b656
    style ClientCert fill:#fff2cc,stroke:#d6b656
    style ClientKey fill:#fff2cc,stroke:#d6b656
    style KubeRBAC fill:#e0e0e0,stroke:#999
    style GatewayAPI fill:#e0e0e0,stroke:#999
    style KServeAuth fill:#e0e0e0,stroke:#999
