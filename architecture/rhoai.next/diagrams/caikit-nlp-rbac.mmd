graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Green = Delegated to Platform"]
        L2["Orange = Configurable by Operator"]
        L3["Blue = Runtime Identity"]
    end

    subgraph RuntimeIdentity["Caikit Runtime Pod Identity"]
        SA["ServiceAccount<br/>(platform-assigned)<br/>Namespace: {user-namespace}"]
        User["Container User<br/>caikit (UID 1001)<br/>Non-root"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (not defined by caikit-nlp)"]
        direction TB
        Note1["caikit-nlp is a Python library and<br/>does NOT define any Kubernetes RBAC resources.<br/>All RBAC is managed by the platform operator."]

        subgraph PlatformAuth["Platform Authentication"]
            KubeRBACProxy["kube-rbac-proxy<br/>Authenticates HTTP/gRPC requests"]
            KServeAuth["KServe Auth<br/>InferenceService-level auth"]
            GatewayAuth["Gateway API<br/>Route-level auth"]
        end
    end

    subgraph SecretAccess["Secrets Access (file-mounted)"]
        CACert["TGIS CA Cert<br/>(ca_cert_file)<br/>Purpose: TLS verification<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
        ClientCert["TGIS Client Cert<br/>(client_cert_file)<br/>Purpose: mTLS client auth<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
        ClientKey["TGIS Client Key<br/>(client_key_file)<br/>Purpose: mTLS client key<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
    end

    subgraph EndpointAuth["Endpoint Authentication"]
        HTTPEndpoint["HTTP :8080<br/>Auth: Delegated to platform"]
        GRPCEndpoint["gRPC :8085<br/>Auth: Delegated to platform"]
        TGISEndpoint["TGIS Backend<br/>Auth: mTLS (optional)"]
        HFEndpoint["HuggingFace Hub<br/>Auth: Token (optional)"]
    end

    SA -->|"runs as"| User
    SA -.->|"mounts"| CACert
    SA -.->|"mounts"| ClientCert
    SA -.->|"mounts"| ClientKey

    PlatformAuth -->|"protects"| HTTPEndpoint
    PlatformAuth -->|"protects"| GRPCEndpoint
    CACert -->|"verifies"| TGISEndpoint
    ClientCert -->|"authenticates"| TGISEndpoint
    ClientKey -->|"signs"| TGISEndpoint

    style SA fill:#4a90e2,color:#fff
    style User fill:#4a90e2,color:#fff
    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style KubeRBACProxy fill:#5cb85c,color:#fff
    style KServeAuth fill:#5cb85c,color:#fff
    style GatewayAuth fill:#5cb85c,color:#fff
    style CACert fill:#f5a623,color:#fff
    style ClientCert fill:#f5a623,color:#fff
    style ClientKey fill:#f5a623,color:#fff
    style HTTPEndpoint fill:#d5e8d4,stroke:#82b366
    style GRPCEndpoint fill:#d5e8d4,stroke:#82b366
    style TGISEndpoint fill:#ffe6cc,stroke:#d79b00
    style HFEndpoint fill:#fff2cc,stroke:#d6b656
