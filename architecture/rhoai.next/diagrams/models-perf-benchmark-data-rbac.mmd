graph TD
    subgraph Component["models-perf-benchmark-data"]
        Note["This component defines<br/>NO RBAC resources.<br/><br/>It is a data-only container<br/>with no Kubernetes API access.<br/><br/>RBAC for the model-catalog pod<br/>is managed by model-registry-operator."]
    end

    subgraph AuthMechanisms["Authentication & Authorization (Ingestion Layer)"]
        subgraph KafkaAuth["Kafka Authentication"]
            KafkaSASL["SASL_SSL<br/>SCRAM-SHA-512"]
            KafkaACL["Topic-level ACLs<br/>dev.aihub-public-*"]
            KafkaSASL -->|"enforced by"| KafkaACL
        end

        subgraph APIAuth["API Authentication"]
            APITLS["TLS (Server Auth Only)<br/>Custom CA cert supported"]
            APIHostname["⚠ Hostname verification<br/>optionally skipped"]
            APITLS -.->|"reduced by"| APIHostname
        end
    end

    subgraph Secrets["Secrets (CI/Dev only - Not in shipped image)"]
        KafkaCreds["Kafka SASL Credentials<br/>Type: Opaque (env vars)<br/>SASL_USERNAME / SASL_PASSWORD<br/>Provisioned: Manual/CI<br/>Auto-Rotate: No"]
        TLSCert["API TLS Certificate<br/>Type: File (PEM)<br/>Custom CA for model-validation-hub<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    KafkaCreds -->|"used by"| KafkaSASL
    TLSCert -->|"used by"| APITLS

    style Note fill:#f9f9f9,stroke:#ccc,stroke-width:1px
    style KafkaSASL fill:#4a90e2,stroke:#333,color:#fff
    style KafkaACL fill:#4a90e2,stroke:#333,color:#fff
    style APITLS fill:#f5a623,stroke:#333
    style APIHostname fill:#ff6b6b,stroke:#333,color:#fff
    style KafkaCreds fill:#e8e8e8,stroke:#333
    style TLSCert fill:#e8e8e8,stroke:#333
