graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph PlatformIngress["Platform Ingress Layer"]
        RBAC["kube-rbac-proxy Sidecar<br/>(platform-managed auth)"]
    end

    subgraph LlamaStack["Llama Stack Distribution"]
        direction TB
        Server["Llama Stack Server<br/>Port 8321/TCP HTTP<br/>Python/FastAPI/Uvicorn"]
        Config["Distribution Config<br/>(config.yaml)"]
        Entrypoint["Entrypoint Script<br/>(optional OTEL wrapping)"]

        Entrypoint -->|launches| Server
        Config -->|configures providers| Server

        subgraph Providers["Provider Architecture"]
            direction TB
            subgraph InferenceProviders["Inference Providers"]
                VLLMProv["remote::vllm"]
                BedrockProv["remote::bedrock"]
                VertexProv["remote::vertex"]
                AzureProv["remote::azure-openai"]
                WatsonxProv["remote::watsonx"]
                OpenAIProv["remote::openai"]
                STProv["inline::sentence-transformers"]
            end

            subgraph SafetyProviders["Safety Providers"]
                FMSProv["remote::trustyai_fms"]
            end

            subgraph EvalProviders["Evaluation Providers"]
                LMEvalProv["remote::trustyai_lmeval"]
                RAGASProv["remote::trustyai_ragas"]
                GarakProv["remote::trustyai_garak"]
            end

            subgraph VectorProviders["Vector I/O Providers"]
                MilvusInline["inline::milvus"]
                MilvusRemote["remote::milvus"]
                FaissInline["inline::faiss"]
                PgVectorProv["remote::pgvector"]
                QdrantProv["remote::qdrant"]
            end

            subgraph StorageProviders["Storage & Persistence"]
                KVPostgres["kv_postgres"]
                SQLPostgres["sql_postgres"]
                S3Prov["remote::s3"]
            end

            subgraph ToolProviders["Tool Runtime Providers"]
                BraveProv["brave_search"]
                TavilyProv["tavily_search"]
                RAGTool["rag_tool"]
                MCPTool["mcp_tool"]
            end
        end

        Server --> Providers
    end

    subgraph InternalPlatform["Internal Platform Services"]
        vLLM["vLLM<br/>Inference Backend"]
        TrustyFMS["TrustyAI FMS<br/>Safety"]
        TrustyLMEval["TrustyAI LM-Eval<br/>Evaluation"]
        Kubeflow["Kubeflow Pipelines<br/>Eval Orchestration"]
        Milvus["Milvus<br/>Vector DB"]
        PgVector["PgVector<br/>Vector DB"]
        Qdrant["Qdrant<br/>Vector DB"]
    end

    subgraph ExternalServices["External Services"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        S3["S3-Compatible Storage<br/>443/TCP"]
        AWSBedrock["AWS Bedrock<br/>443/TCP"]
        GoogleVertex["Google Vertex AI<br/>443/TCP"]
        AzureOpenAI["Azure OpenAI<br/>443/TCP"]
        IBMWatsonx["IBM watsonx<br/>443/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
        BraveAPI["Brave Search API<br/>443/TCP"]
        TavilyAPI["Tavily Search API<br/>443/TCP"]
        HuggingFace["HuggingFace Hub<br/>443/TCP"]
        OTELCollector["OTEL Collector"]
    end

    Client -->|HTTP| RBAC
    RBAC -->|HTTP/8321| Server

    VLLMProv -->|HTTPS| vLLM
    BedrockProv -->|HTTPS/443| AWSBedrock
