graph TB
    subgraph LlamaStack["Llama Stack Distribution"]
        direction TB
        Server["Llama Stack Server<br/>(FastAPI/Uvicorn)<br/>Port 8321/TCP"]
        Config["Distribution Config<br/>(config.yaml)"]
        Config -->|configures providers| Server

        subgraph Providers["Provider Plugin Architecture"]
            direction LR
            subgraph InferenceProviders["Inference Providers"]
                VLLMProv["remote::vllm"]
                BedrockProv["remote::bedrock"]
                WatsonxProv["remote::watsonx"]
                AzureProv["remote::azure"]
                VertexProv["remote::vertexai"]
                OpenAIProv["remote::openai"]
            end

            subgraph VectorProviders["Vector I/O Providers"]
                MilvusInline["inline::milvus"]
                MilvusRemote["remote::milvus"]
                FAISSProv["inline::faiss"]
                PgvectorProv["remote::pgvector"]
                QdrantProv["remote::qdrant"]
            end

            subgraph SafetyProviders["Safety & Eval Providers"]
                TrustyAIFMS["remote::trustyai_fms"]
                LMEval["remote::trustyai_lmeval"]
                RAGASInline["inline::trustyai_ragas"]
                RAGASRemote["remote::trustyai_ragas"]
                Garak["remote::trustyai_garak"]
            end

            subgraph ToolProviders["Tool Runtimes"]
                BraveSearch["remote::brave-search"]
                TavilySearch["remote::tavily-search"]
                MCPProv["remote::model-context-protocol"]
                RAGTool["builtin::rag"]
            end
        end

        Server -->|delegates to| Providers
    end

    subgraph BuildSystem["Build System"]
        BuildPy["build.py"]
        ContainerfileIn["Containerfile.in"]
        KonfluxDF["Dockerfile.konflux"]
        BuildPy -->|generates| ContainerfileIn
    end

    subgraph Storage["Persistent Storage"]
        PG["PostgreSQL<br/>5432/TCP"]
    end

    Client["Client"] -->|REST API<br/>8321/TCP| Server
    Server -->|KV store + SQL| PG

    %% Env-based activation
    EnvVars["Environment Variables<br/>(VLLM_URL, AWS_BEARER_TOKEN, etc.)"] -.->|activate/deactivate<br/>providers| Config

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Config fill:#f5a623,stroke:#333,color:#fff
    style PG fill:#50e3c2,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style EnvVars fill:#fff2cc,stroke:#d6b656
    style VLLMProv fill:#7ed321,stroke:#333
    style BedrockProv fill:#7ed321,stroke:#333
    style WatsonxProv fill:#7ed321,stroke:#333
    style AzureProv fill:#7ed321,stroke:#333
    style VertexProv fill:#7ed321,stroke:#333
    style OpenAIProv fill:#7ed321,stroke:#333
