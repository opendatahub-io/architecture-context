graph TB
    subgraph LlamaStack["Llama Stack Distribution (Container Image)"]
        direction TB
        Server["Llama Stack Server<br/>FastAPI/Uvicorn<br/>Port 8321/TCP"]
        Config["Distribution Config<br/>config.yaml"]
        Entrypoint["entrypoint.sh<br/>OTel Instrumentation Wrapper"]

        Entrypoint -->|starts| Server
        Config -->|configures| Server

        subgraph APIs["REST APIs (OpenAI-compatible)"]
            direction LR
            InferenceAPI["/v1/inference/*<br/>/v1/chat/completions"]
            AgentsAPI["/v1/agents/*"]
            EvalAPI["/v1/eval/*"]
            SafetyAPI["/v1/safety/*"]
            VectorAPI["/v1/vector-io/*"]
            ToolAPI["/v1/tool-runtime/*"]
            ScoringAPI["/v1/scoring/*"]
            DatasetAPI["/v1/datasetio/*"]
            FilesAPI["/v1/files/*"]
            BatchAPI["/v1/batches/*"]
        end

        Server --> APIs

        subgraph InlineProviders["Inline Providers (In-Process)"]
            direction LR
            SentenceTransformers["Sentence Transformers<br/>Embedding Model"]
            MilvusLite["Milvus Lite<br/>Local Vector DB"]
            FAISS["FAISS<br/>CPU Vector DB"]
            MetaRefAgent["Meta Reference<br/>Agent Provider"]
            RAGASInline["TrustyAI RAGAS<br/>Inline Eval"]
        end

        Server --> InlineProviders
    end

    Client["Client<br/>(Data Scientist / Application)"] -->|REST API<br/>8321/TCP| Server

    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Serving Runtime<br/>8000/TCP"]
        Bedrock["AWS Bedrock<br/>443/TCP"]
        WatsonX["IBM WatsonX<br/>443/TCP"]
        AzureOAI["Azure OpenAI<br/>443/TCP"]
        VertexAI["Google Vertex AI<br/>443/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
    end

    subgraph Storage["Storage Backends"]
        PostgreSQL["PostgreSQL 17+<br/>5432/TCP<br/>KV Store + SQL Store"]
        S3["S3-Compatible Storage<br/>443/TCP"]
    end

    subgraph VectorDBs["Remote Vector Databases"]
        MilvusRemote["Milvus (Remote)<br/>REST/gRPC"]
        PgVector["pgvector<br/>5432/TCP"]
        Qdrant["Qdrant<br/>6333/TCP REST<br/>6334/TCP gRPC"]
    end

    subgraph TrustyAI["TrustyAI Ecosystem"]
        FMS["FMS Orchestrator<br/>Safety Shields"]
        LMEval["LMEval<br/>K8s Jobs"]
        RAGASRemote["RAGAS Remote<br/>via Kubeflow"]
        Garak["Garak<br/>Security Eval"]
    end

    subgraph ExternalServices["External Services"]
        HuggingFace["HuggingFace Hub<br/>443/TCP"]
        BraveSearch["Brave Search API<br/>443/TCP"]
        TavilySearch["Tavily Search API<br/>443/TCP"]
        OTelCollector["OpenTelemetry Collector<br/>4318/TCP"]
        KubeflowPipelines["Kubeflow Pipelines"]
    end

    Server -->|inference| vLLM
    Server -->|inference| Bedrock
    Server -->|inference| WatsonX
    Server -->|inference| AzureOAI
    Server -->|inference| VertexAI
    Server -->|inference| OpenAI

    Server -->|persistence| PostgreSQL
    Server -->|file storage| S3

    Server -->|vector search| MilvusRemote
    Server -->|vector search| PgVector
    Server -->|vector search| Qdrant

    Server -->|safety| FMS
    Server -->|eval jobs| LMEval
    Server -->|remote eval| RAGASRemote
    Server -->|security eval| Garak

    Server -->|datasets/models| HuggingFace
    Server -->|web search| BraveSearch
    Server -->|web search| TavilySearch
    Server -->|traces/metrics| OTelCollector
    RAGASRemote -->|pipelines| KubeflowPipelines
    Garak -->|pipelines| KubeflowPipelines

