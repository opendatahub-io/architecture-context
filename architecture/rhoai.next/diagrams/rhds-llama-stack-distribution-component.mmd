    style PostgreSQL fill:#f5a623,stroke:#333
    style FMS fill:#9013fe,stroke:#333,color:#fff
    style LMEval fill:#9013fe,stroke:#333,color:#fff
    style RAGASRemote fill:#9013fe,stroke:#333,color:#fff
    style Garak fill:#9013fe,stroke:#333,color:#fff
    style Bedrock fill:#999,stroke:#333
    style WatsonX fill:#999,stroke:#333
    style AzureOAI fill:#999,stroke:#333
    style VertexAI fill:#999,stroke:#333
    style OpenAI fill:#999,stroke:#333
    style MilvusRemote fill:#e8e8e8,stroke:#333
    style PgVector fill:#e8e8e8,stroke:#333
    style Qdrant fill:#e8e8e8,stroke:#333
