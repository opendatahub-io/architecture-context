graph TB
    subgraph "Llama Stack Distribution"
        direction TB
        Server["Llama Stack Server<br/>Python Service<br/>Port 8321/TCP"]
        BuildScript["build.py<br/>Containerfile Generator"]
        DocsGen["gen_distro_docs.py<br/>Documentation Generator"]
        SmokeTests["smoke.sh<br/>Smoke Tests"]
        IntegrationTests["run_integration_tests.sh<br/>Integration Tests"]

        BuildScript -->|generates| Containerfile["Containerfile"]
        DocsGen -->|generates| README["README.md"]
        SmokeTests -->|tests| Server
        IntegrationTests -->|tests| Server
    end

    subgraph "APIs (Port 8321/TCP)"
        direction LR
        InferenceAPI["/v1/inference/*<br/>/v1/chat/completions"]
        AgentsAPI["/v1/agents"]
        VectorAPI["/v1/vector-io/*"]
        SafetyAPI["/v1/safety/*"]
        EvalAPI["/v1/eval/*"]
        ToolsAPI["/v1/tool-runtime/*"]
        FilesAPI["/v1/files/*"]
        ScoringAPI["/v1/scoring/*"]
        DatasetAPI["/v1/datasetio/*"]
        BatchAPI["/v1/batches/*"]
        HealthAPI["/v1/health<br/>/v1/models"]
    end

    Client[Client] -->|HTTP/8321| Server
    Server --> InferenceAPI
    Server --> AgentsAPI
    Server --> VectorAPI
    Server --> SafetyAPI
    Server --> EvalAPI
    Server --> ToolsAPI
    Server --> FilesAPI
    Server --> ScoringAPI
    Server --> DatasetAPI
    Server --> BatchAPI
    Server --> HealthAPI

    subgraph "Inference Providers"
        vLLM["vLLM<br/>remote::vllm"]
        Bedrock["AWS Bedrock<br/>remote::bedrock"]
        VertexAI["Google Vertex AI<br/>remote::vertexai"]
        AzureOAI["Azure OpenAI<br/>remote::azure"]
        WatsonX["IBM WatsonX<br/>remote::watsonx"]
        OpenAI["OpenAI<br/>remote::openai"]
        SentenceTransformers["sentence-transformers<br/>inline"]
    end

    subgraph "Vector Databases"
        MilvusLocal["Milvus Lite<br/>inline::milvus"]
        MilvusRemote["Milvus Remote<br/>remote::milvus"]
        FAISS["FAISS<br/>inline::faiss"]
        PgVector["pgvector<br/>remote::pgvector"]
        Qdrant["Qdrant<br/>remote::qdrant"]
    end

    subgraph "Safety & Evaluation"
        TrustyAIFMS["TrustyAI FMS<br/>Safety Shields"]
        TrustyAILMEval["TrustyAI LMEval<br/>Evaluation"]
        RAGAS["TrustyAI RAGAS<br/>Evaluation"]
        Garak["TrustyAI Garak<br/>Security Eval"]
    end

    subgraph "Storage & Tools"
        PostgreSQL["PostgreSQL 17+<br/>Persistent Storage"]
        S3["S3 / S3-compatible<br/>File Storage"]
        BraveSearch["Brave Search API"]
        TavilySearch["Tavily Search API"]
        MCP["MCP Servers"]
    end

    InferenceAPI --> vLLM
    InferenceAPI --> Bedrock
    InferenceAPI --> VertexAI
    InferenceAPI --> AzureOAI
    InferenceAPI --> WatsonX
    InferenceAPI --> OpenAI
    InferenceAPI --> SentenceTransformers

    VectorAPI --> MilvusLocal
    VectorAPI --> MilvusRemote
    VectorAPI --> FAISS
    VectorAPI --> PgVector
    VectorAPI --> Qdrant

    SafetyAPI --> TrustyAIFMS
    EvalAPI --> TrustyAILMEval
    EvalAPI --> RAGAS
    EvalAPI --> Garak

    Server -->|kvstore + SQL| PostgreSQL
    FilesAPI --> S3
    ToolsAPI --> BraveSearch
    ToolsAPI --> TavilySearch
    ToolsAPI --> MCP

