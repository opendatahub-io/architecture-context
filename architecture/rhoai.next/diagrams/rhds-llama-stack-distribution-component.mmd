graph TB
    subgraph LlamaStackImage["Llama Stack Container Image (llama-stack-cpu-rhel9)"]
        direction TB
        Entrypoint["distribution/entrypoint.sh<br/>Resolves config, optional OTel wrap"]
        ConfigYAML["distribution/config.yaml<br/>APIs, providers, storage, resources"]
        LlamaStack["llama-stack v0.5.0+rhai0<br/>Core Framework"]
        EmbeddingModel["granite-embedding-125m-english<br/>Pre-downloaded embedding model"]

        Entrypoint -->|"llama stack run"| LlamaStack
        LlamaStack -->|reads| ConfigYAML
        LlamaStack -->|loads| EmbeddingModel
    end

    subgraph APIs["HTTP API (Port 8321/TCP)"]
        direction LR
        ChatAPI["/v1/chat/completions<br/>OpenAI-compatible"]
        InferenceAPI["/v1/inference/*<br/>Native inference"]
        AgentsAPI["/v1/agents/*<br/>Agent sessions"]
        VectorAPI["/v1/vector-io/*<br/>Vector operations"]
        SafetyAPI["/v1/safety/*<br/>Safety shields"]
        EvalAPI["/v1/eval/*<br/>Evaluations"]
        ToolsAPI["/v1/tool-runtime/*<br/>Web search, RAG, MCP"]
        HealthAPI["/v1/health<br/>Health check"]
    end

    Client[External Client] -->|"HTTP 8321/TCP<br/>No Auth"| APIs

    APIs --> LlamaStack

    subgraph InferenceProviders["Inference Providers (env-var activated)"]
        vLLM["vLLM<br/>VLLM_URL"]
        Bedrock["AWS Bedrock<br/>AWS_BEARER_TOKEN_BEDROCK"]
        Watsonx["IBM Watsonx<br/>WATSONX_API_KEY"]
        AzureAI["Azure AI<br/>AZURE_API_KEY"]
        VertexAI["Google Vertex AI<br/>VERTEX_AI_PROJECT"]
        OpenAI["OpenAI<br/>OPENAI_API_KEY"]
        SentenceTransformers["sentence-transformers<br/>ENABLE_SENTENCE_TRANSFORMERS"]
    end

    subgraph VectorStores["Vector Stores (env-var activated)"]
        MilvusLite["Milvus Lite<br/>(default, embedded)"]
        MilvusRemote["Milvus Remote<br/>MILVUS_ENDPOINT"]
        PgVector["pgvector<br/>ENABLE_PGVECTOR"]
        QdrantStore["Qdrant<br/>ENABLE_QDRANT"]
        FAISS["FAISS<br/>(inline)"]
    end

    subgraph SafetyEval["Safety & Evaluation"]
        TrustyAISafety["TrustyAI FMS<br/>FMS_ORCHESTRATOR_URL"]
        LMEval["TrustyAI lmeval<br/>LM Evaluation Harness"]
        RAGAS["RAGAS<br/>RAG evaluation"]
        Garak["Garak<br/>Adversarial evaluation"]
    end

    PostgreSQL[(PostgreSQL 17+<br/>Mandatory)]

    LlamaStack -->|"inference requests"| InferenceProviders
    LlamaStack -->|"vector operations"| VectorStores
    LlamaStack -->|"safety shields"| SafetyEval
    LlamaStack -->|"KV store + SQL<br/>5432/TCP"| PostgreSQL

    subgraph BuildTooling["Build Tooling"]
        BuildPy["distribution/build.py<br/>Auto-generates Containerfile"]
        ContainerfileIn["Containerfile.in<br/>Template"]
        DockerfileKonflux["Dockerfile.konflux<br/>AIPCC base, wheel releases"]
        GenDocs["scripts/gen_distro_docs.py<br/>Doc generator"]
        BuildPy -->|generates| ContainerfileIn
    end

    style LlamaStackImage fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style APIs fill:#7ed321,stroke:#333,stroke-width:1px
    style InferenceProviders fill:#f5f5f5,stroke:#999,stroke-width:1px
    style VectorStores fill:#f5f5f5,stroke:#999,stroke-width:1px
    style SafetyEval fill:#f5f5f5,stroke:#999,stroke-width:1px
    style BuildTooling fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style PostgreSQL fill:#f5a623,stroke:#333,stroke-width:2px
    style Client fill:#e8e8e8,stroke:#333
