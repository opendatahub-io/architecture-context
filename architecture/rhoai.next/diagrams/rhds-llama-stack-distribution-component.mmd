graph TB
    subgraph LlamaStack["Llama Stack Distribution"]
        direction TB
        Server["Llama Stack Server<br/>Python/FastAPI<br/>Port 8321/TCP"]
        BuildScript["Build Script<br/>(distribution/build.py)"]
        DocGen["Doc Generator<br/>(scripts/gen_distro_docs.py)"]
        SmokeTests["Smoke Tests<br/>(tests/smoke.sh)"]
        IntegTests["Integration Tests<br/>(tests/run_integration_tests.sh)"]

        subgraph Providers["Provider Plugin Architecture"]
            direction LR
            subgraph InferenceProviders["Inference Providers"]
                vLLMProv["remote::vllm"]
                BedrockProv["remote::bedrock"]
                VertexProv["remote::vertexai"]
                AzureProv["remote::azure"]
                WatsonXProv["remote::watsonx"]
                OpenAIProv["remote::openai"]
                SentenceTrans["inline::sentence-transformers"]
            end

            subgraph VectorProviders["Vector I/O Providers"]
                MilvusInline["inline::milvus"]
                MilvusRemote["remote::milvus"]
                FAISSProv["inline::faiss"]
                PgvectorProv["remote::pgvector"]
                QdrantProv["remote::qdrant"]
            end

            subgraph SafetyProviders["Safety & Eval Providers"]
                FMSProv["remote::trustyai_fms"]
                LMEvalProv["remote::trustyai_lmeval"]
                RAGASProv["remote::trustyai_ragas"]
                GarakProv["remote::trustyai_garak"]
            end

            subgraph ToolProviders["Tool Runtime Providers"]
                BraveProv["remote::brave-search"]
                TavilyProv["remote::tavily-search"]
                RAGTool["builtin::rag"]
                MCPProv["remote::model-context-protocol"]
            end
        end

        Server -->|loads providers| Providers
    end

    subgraph APIs["Exposed APIs (8321/TCP)"]
        ChatAPI["/v1/chat/completions<br/>(OpenAI-compatible)"]
        InferAPI["/v1/inference/*<br/>(Llama Stack native)"]
        AgentsAPI["/v1/agents"]
        VectorAPI["/v1/vector-io/*"]
        SafetyAPI["/v1/safety/*"]
        EvalAPI["/v1/eval/*"]
        FilesAPI["/v1/files/*"]
        ToolAPI["/v1/tool-runtime/*"]
        HealthAPI["/v1/health"]
    end

    Client["Client / Platform Ingress"] -->|HTTP 8321/TCP| Server
    Server --> APIs

    subgraph ExternalBackends["External Backends"]
        vLLM["vLLM Server"]
        PostgreSQL["PostgreSQL 17+<br/>5432/TCP"]
        S3["S3 / S3-compatible"]
    end

    Server -->|inference + embedding| vLLM
    Server -->|persistent storage<br/>(kvstore, SQL)| PostgreSQL
    Server -->|file storage| S3

    ConfigYAML["config.yaml<br/>(provider wiring)"] -->|env-var driven<br/>activation| Server
    BuildScript -->|generates| Containerfile["Containerfile"]

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Providers fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style InferenceProviders fill:#dceefb,stroke:#4a90e2
    style VectorProviders fill:#dceefb,stroke:#4a90e2
    style SafetyProviders fill:#dceefb,stroke:#4a90e2
    style ToolProviders fill:#dceefb,stroke:#4a90e2
    style Client fill:#f5f5f5,stroke:#999
    style vLLM fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style ConfigYAML fill:#f5a623,stroke:#333,color:#333
    style BuildScript fill:#7ed321,stroke:#333,color:#333
    style DocGen fill:#7ed321,stroke:#333,color:#333
    style SmokeTests fill:#9b59b6,stroke:#333,color:#fff
    style IntegTests fill:#9b59b6,stroke:#333,color:#fff
