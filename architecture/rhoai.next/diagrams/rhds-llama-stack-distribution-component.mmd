graph TB
    subgraph LlamaStack["Llama Stack Distribution (8321/TCP)"]
        direction TB
        Server["Llama Stack Server<br/>(FastAPI/Uvicorn)"]
        Config["Distribution Config<br/>(config.yaml)"]
        Entrypoint["Entrypoint Script<br/>(entrypoint.sh)"]

        subgraph APIs["REST APIs (/v1/*)"]
            Inference["/v1/inference/*<br/>/v1/chat/completions"]
            Agents["/v1/agents/*"]
            Eval["/v1/eval/*"]
            Safety["/v1/safety/*"]
            VectorIO["/v1/vector-io/*"]
            ToolRuntime["/v1/tool-runtime/*"]
            Scoring["/v1/scoring/*"]
            DatasetIO["/v1/datasetio/*"]
            Files["/v1/files/*"]
            Batches["/v1/batches/*"]
        end

        subgraph InlineProviders["Inline Providers"]
            MilvusLite["Milvus Lite<br/>(embedded vector DB)"]
            FAISS["FAISS<br/>(CPU vector DB)"]
            SentenceTransformers["Sentence Transformers<br/>(embedding model)"]
            RAGASInline["RAGAS Inline<br/>(RAG evaluation)"]
        end

        Entrypoint -->|starts| Server
        Config -->|configures| Server
        Server --> APIs
        Server --> InlineProviders
    end

    subgraph OTel["Observability"]
        OTelInstrumentation["OpenTelemetry<br/>Instrumentation"]
    end

    Client[Client / Platform Ingress] -->|HTTP 8321/TCP| Server
    Entrypoint -.->|optional wrap| OTelInstrumentation
    OTelInstrumentation -.->|instruments| Server

    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Serving Runtime<br/>8000/TCP"]
        Bedrock["AWS Bedrock<br/>443/TCP"]
        WatsonX["IBM WatsonX<br/>443/TCP"]
        AzureOAI["Azure OpenAI<br/>443/TCP"]
        VertexAI["Google Vertex AI<br/>443/TCP"]
        OpenAI["OpenAI API<br/>443/TCP"]
    end

    subgraph Storage["Persistent Storage"]
        PostgreSQL["PostgreSQL 17+<br/>5432/TCP<br/>(KV + SQL store)"]
    end

    subgraph VectorDBs["Remote Vector Databases"]
        MilvusRemote["Milvus Remote<br/>REST/gRPC"]
        pgvector["pgvector<br/>5432/TCP"]
        Qdrant["Qdrant<br/>6333/6334/TCP"]
    end

    subgraph EvalSafety["Evaluation & Safety"]
        TrustyAIFMS["TrustyAI FMS<br/>Orchestrator"]
        TrustyAILMEval["TrustyAI LMEval<br/>(K8s Jobs)"]
        KubeflowPipelines["Kubeflow Pipelines<br/>(RAGAS/Garak remote)"]
    end

    subgraph ExternalServices["External Services"]
        S3["S3-compatible Storage<br/>443/TCP"]
        HuggingFace["HuggingFace Hub<br/>443/TCP"]
        BraveSearch["Brave Search API<br/>443/TCP"]
        TavilySearch["Tavily Search API<br/>443/TCP"]
        OTelCollector["OpenTelemetry Collector<br/>4318/TCP"]
    end

    Server -->|inference| vLLM
    Server -->|inference| Bedrock
    Server -->|inference| WatsonX
    Server -->|inference| AzureOAI
    Server -->|inference| VertexAI
    Server -->|inference| OpenAI
    Server -->|KV + SQL| PostgreSQL
    Server -->|vectors| MilvusRemote
    Server -->|vectors| pgvector
    Server -->|vectors| Qdrant
    Server -->|safety| TrustyAIFMS
    Server -->|eval jobs| TrustyAILMEval
    Server -->|eval pipelines| KubeflowPipelines
    Server -->|files| S3
    Server -->|datasets/models| HuggingFace
    Server -->|web search| BraveSearch
    Server -->|web search| TavilySearch
    OTelInstrumentation -->|OTLP| OTelCollector

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Config fill:#4a90e2,stroke:#333,color:#fff
    style Entrypoint fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIFMS fill:#e8744f,stroke:#333,color:#fff
    style TrustyAILMEval fill:#e8744f,stroke:#333,color:#fff
    style KubeflowPipelines fill:#e8744f,stroke:#333,color:#fff
    style MilvusLite fill:#00b4d8,stroke:#333,color:#fff
    style FAISS fill:#00b4d8,stroke:#333,color:#fff
    style SentenceTransformers fill:#00b4d8,stroke:#333,color:#fff
    style RAGASInline fill:#00b4d8,stroke:#333,color:#fff
