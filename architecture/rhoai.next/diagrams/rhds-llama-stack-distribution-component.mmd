graph TB
    subgraph LlamaStack["Llama Stack Distribution"]
        direction TB
        Server["Llama Stack Server<br/>(Python/FastAPI + uvicorn)<br/>Port: 8321/TCP"]

        subgraph APIs["API Surface"]
            direction LR
            InferenceAPI["/v1/chat/completions<br/>/v1/inference/chat_completion"]
            AgentsAPI["/v1/agents"]
            VectorAPI["/v1/vector-io/*"]
            SafetyAPI["/v1/safety/*"]
            EvalAPI["/v1/eval/*"]
            ToolAPI["/v1/tool-runtime/*"]
            FilesAPI["/v1/files/*"]
            ScoringAPI["/v1/scoring/*"]
            DatasetAPI["/v1/datasetio/*"]
            BatchAPI["/v1/batches/*"]
        end

        subgraph Providers["Provider Plugins (config.yaml driven)"]
            direction LR
            InferenceProviders["Inference Providers<br/>vLLM, Bedrock, Vertex AI,<br/>Azure, WatsonX, OpenAI,<br/>sentence-transformers"]
            VectorProviders["Vector I/O Providers<br/>Milvus (inline+remote),<br/>FAISS, pgvector, Qdrant"]
            SafetyProviders["Safety Providers<br/>TrustyAI FMS"]
            EvalProviders["Eval Providers<br/>LMEval, RAGAS, Garak"]
            ToolProviders["Tool Providers<br/>Brave Search, Tavily,<br/>RAG, MCP"]
        end

        subgraph Storage["Storage Layer"]
            PGStore["PostgreSQL Backend<br/>(kv_postgres + sql_postgres)<br/>kvstore, inference logs,<br/>agent state, conversations"]
        end

        Server --> APIs
        Server --> Providers
        Server --> Storage
    end

    Client["Client / API Consumer"] -->|"HTTP 8321/TCP<br/>No built-in auth"| Server
    PlatformIngress["Platform Ingress<br/>(kube-rbac-proxy / Gateway API)"] -->|"TLS termination<br/>+ Auth enforcement"| Server

    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Server"]
        Bedrock["AWS Bedrock"]
        VertexAI["Google Vertex AI"]
        AzureOAI["Azure OpenAI"]
        WatsonX["IBM WatsonX"]
        OpenAI["OpenAI API"]
    end

    subgraph VectorDBs["Vector Databases"]
        MilvusRemote["Milvus (remote)"]
        PGVector["pgvector"]
        Qdrant["Qdrant"]
    end

    subgraph EvalServices["Evaluation Services"]
        LMEval["TrustyAI LMEval"]
        KFPipelines["Kubeflow Pipelines<br/>(RAGAS / Garak)"]
    end

    subgraph ToolServices["Tool Services"]
        BraveSearch["Brave Search API"]
        TavilySearch["Tavily Search API"]
        MCPServers["MCP Servers"]
    end

    FMSOrchestrator["TrustyAI FMS<br/>Orchestrator"]
    PostgreSQL["PostgreSQL 17+<br/>5432/TCP"]
    S3["S3 / S3-compatible<br/>Storage"]
    OTELCollector["OTEL Collector<br/>(optional)"]
    HuggingFace["HuggingFace Hub"]

    InferenceProviders -->|"HTTP/HTTPS"| vLLM
    InferenceProviders -->|"HTTPS/443"| Bedrock
    InferenceProviders -->|"HTTPS/443"| VertexAI
    InferenceProviders -->|"HTTPS/443"| AzureOAI
    InferenceProviders -->|"HTTPS/443"| WatsonX
    InferenceProviders -->|"HTTPS/443"| OpenAI

    VectorProviders -->|"HTTP/gRPC"| MilvusRemote
    VectorProviders -->|"PostgreSQL"| PGVector
    VectorProviders -->|"HTTP/gRPC"| Qdrant

    EvalProviders -->|"HTTP"| LMEval
    EvalProviders -->|"HTTPS"| KFPipelines

    SafetyProviders -->|"HTTP/HTTPS"| FMSOrchestrator

    ToolProviders -->|"HTTPS/443"| BraveSearch
    ToolProviders -->|"HTTPS/443"| TavilySearch
    ToolProviders -->|"HTTP/HTTPS"| MCPServers

    PGStore -->|"PostgreSQL/5432"| PostgreSQL

    Server -->|"HTTPS/443"| S3
    Server -->|"HTTP (OTLP)"| OTELCollector
    Server -->|"HTTPS/443"| HuggingFace

