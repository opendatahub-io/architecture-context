graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        TASRoute["TAS Route<br/>443/TCP → 8443<br/>TLS Reencrypt"]
        GORCHOrcRoute["GORCH Orchestrator Route<br/>443/TCP → 8432<br/>TLS Reencrypt"]
        GORCHHealthRoute["GORCH Health Route<br/>443/TCP → 8034<br/>TLS Edge"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8490<br/>TLS Edge/Reencrypt"]
        GORCHBuiltinRoute["GORCH Built-in Route<br/>443/TCP → 8480<br/>TLS Edge/Reencrypt"]
        NEMORoute["NemoGuardrails Route<br/>443/TCP → 8443<br/>TLS Edge/Reencrypt"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443<br/>TLS Reencrypt"]
    end

    subgraph AuthLayer["AUTHENTICATION (kube-rbac-proxy - FIPS 140-2)"]
        direction TB
        TASProxy["TAS Proxy<br/>8443/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
        GORCHOrcProxy["GORCH Orc Proxy<br/>8432/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
        GORCHGWProxy["GORCH GW Proxy<br/>8490/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
        GORCHBuiltinProxy["GORCH Built-in Proxy<br/>8480/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
        NEMOProxy["NemoGuardrails Proxy<br/>8443/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
        EvalHubProxy["EvalHub Proxy<br/>8443/TCP HTTPS<br/>Bearer → TokenReview + SAR"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["Operator Manager<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health"]
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACES"]
        direction TB

        subgraph TASPod["TAS Pod"]
            TASApp["TrustyAI App<br/>8080/TCP HTTP"]
        end

        subgraph LMEvalPod["LMEval Pod (bare Pod, not Job)"]
            LMEvalDriver["ta-lmes-driver<br/>18080/TCP localhost<br/>seccomp: RuntimeDefault<br/>capabilities: drop ALL"]
        end

        subgraph GORCHPod["GORCH Pod"]
            GORCHOrc["Orchestrator<br/>8032/TCP HTTPS"]
            GORCHHealth["Health<br/>8034/TCP HTTP"]
            GORCHGW["Gateway<br/>8090/TCP HTTP"]
            GORCHBuiltin["Built-in Detector<br/>8080/TCP HTTP"]
        end

        subgraph NEMOPod["NemoGuardrails Pod"]
            NEMOApp["NeMo App<br/>8000/TCP HTTP"]
        end

        subgraph EvalHubPod["EvalHub Pod"]
            EvalHubApp["EvalHub App<br/>8080/TCP HTTP<br/>In-app SAR checks"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>ServiceAccount Auth"]
        KServe["KServe InferenceServices<br/>HTTP/HTTPS<br/>No Auth"]
        DB["Database (MariaDB/PostgreSQL)<br/>TCP TLS (optional)<br/>Username/Password"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS<br/>AWS IAM"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS TLS<br/>Credentials"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS TLS<br/>Token (optional)"]
        OTEL["OTEL Collector<br/>gRPC/HTTP<br/>TLS (optional)"]
        MLflowSvc["MLflow Tracking<br/>HTTPS TLS<br/>SA Bearer Token"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS"| TASRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHOrcRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHHealthRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHGWRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHBuiltinRoute
    Client -->|"HTTPS/443<br/>TLS"| NEMORoute
    Client -->|"HTTPS/443<br/>TLS"| EvalHubRoute

    %% Ingress → Auth
    TASRoute -->|"HTTPS/8443<br/>Reencrypt"| TASProxy
    GORCHOrcRoute -->|"HTTPS/8432<br/>Reencrypt"| GORCHOrcProxy
    GORCHGWRoute -->|"HTTPS/8490"| GORCHGWProxy
    GORCHBuiltinRoute -->|"HTTPS/8480"| GORCHBuiltinProxy
    NEMORoute -->|"HTTPS/8443"| NEMOProxy
    EvalHubRoute -->|"HTTPS/8443<br/>Reencrypt"| EvalHubProxy

    %% Health route bypasses proxy
    GORCHHealthRoute -->|"HTTP/8034<br/>Edge TLS"| GORCHHealth

    %% Auth → Apps
    TASProxy -->|"HTTP/8080<br/>localhost"| TASApp
    GORCHOrcProxy -->|"HTTPS/8032<br/>TLS serving cert"| GORCHOrc
    GORCHGWProxy -->|"HTTP/8090<br/>localhost"| GORCHGW
    GORCHBuiltinProxy -->|"HTTP/8080<br/>localhost"| GORCHBuiltin
    NEMOProxy -->|"HTTP/8000<br/>localhost"| NEMOApp
    EvalHubProxy -->|"HTTP/8080<br/>localhost"| EvalHubApp

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% Workload → External Services
    TASApp -->|"HTTP/HTTPS"| KServe
    TASApp -->|"TCP/TLS"| DB
    LMEvalDriver -->|"HTTPS/443<br/>AWS IAM"| S3
    LMEvalDriver -->|"HTTPS/443"| OCIReg
    LMEvalDriver -->|"HTTPS/443<br/>Token"| HFHub
    GORCHOrc -->|"HTTP/HTTPS"| KServe
    GORCHOrc -->|"gRPC/HTTP"| OTEL
    EvalHubApp -->|"TCP/TLS"| DB
    EvalHubApp -->|"HTTPS<br/>SA Token"| MLflowSvc
    EvalHubApp -->|"gRPC/HTTP"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#ffcccc,stroke:#cc3333,stroke-width:2px
    classDef operator fill:#cce5ff,stroke:#336699,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class TASRoute,GORCHOrcRoute,GORCHHealthRoute,GORCHGWRoute,GORCHBuiltinRoute,NEMORoute,EvalHubRoute ingress
    class TASProxy,GORCHOrcProxy,GORCHGWProxy,GORCHBuiltinProxy,NEMOProxy,EvalHubProxy auth
    class Operator operator
    class TASApp,LMEvalDriver,GORCHOrc,GORCHHealth,GORCHGW,GORCHBuiltin,NEMOApp,EvalHubApp workload
    class K8sAPI,KServe,DB,S3,OCIReg,HFHub,OTEL,MLflowSvc externalservice
