graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard / Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        direction TB
        TASRoute["Route: TrustyAI Service<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt"]
        GORCHRoute["Route: Guardrails Orchestrator<br/>443/TCP → 8432/TCP<br/>TLS 1.2+ reencrypt"]
        GORCHHealthRoute["Route: GORCH Health<br/>443/TCP → 8034/TCP<br/>TLS 1.2+ edge"]
        GORCHGatewayRoute["Route: GORCH Gateway<br/>443/TCP → 8490/TCP<br/>TLS 1.2+ edge/reencrypt"]
        EvalHubRoute["Route: EvalHub<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt/edge"]
        NemoRoute["Route: NemoGuardrails<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt/edge"]
    end

    subgraph AuthProxy["AUTH PROXY (kube-rbac-proxy - SubjectAccessReview)"]
        direction TB
        TASProxy["kube-rbac-proxy: TAS<br/>8443/TCP TLS<br/>SAR: get services<br/>→ 8080/TCP localhost"]
        GORCHProxy["kube-rbac-proxy: GORCH<br/>8432/TCP TLS<br/>SAR: get services<br/>→ 8032/TCP HTTPS"]
        GatewayProxy["kube-rbac-proxy: Gateway<br/>8490/TCP TLS<br/>SAR: get services<br/>→ 8090/TCP"]
        BuiltInProxy["kube-rbac-proxy: Built-in<br/>8480/TCP TLS<br/>SAR: get services<br/>→ 8080/TCP"]
        EvalHubProxy["kube-rbac-proxy: EvalHub<br/>8443/TCP TLS<br/>SAR: get services<br/>→ 8000/TCP"]
        NemoProxy["kube-rbac-proxy: Nemo<br/>8443/TCP TLS<br/>SAR: get services<br/>→ 8000/TCP"]
    end

    subgraph ClusterServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_Operator["Namespace: operator"]
            Operator["TrustyAI Service Operator<br/>SA: trustyai-service-operator-controller-manager<br/>8080/TCP metrics, 8081/TCP health<br/>Memory: 700Mi, GOMEMLIMIT=630MiB"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            TAS["TrustyAI Service<br/>8080/TCP HTTP app<br/>4443/TCP HTTPS internal"]
            GORCH["Guardrails Orchestrator<br/>8032/TCP orchestrator<br/>8090/TCP gateway<br/>8034/TCP health"]
            EvalHub["EvalHub<br/>8000/TCP app"]
            NemoGR["NeMo Guardrails<br/>8000/TCP app"]
            LMEvalPod["LMEval Job Pod<br/>5000/TCP driver RPC<br/>Ephemeral (bare Pod)"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>SA Token auth"]
        KServe["KServe InferenceService<br/>varies HTTP/HTTPS<br/>mTLS"]
        Istio["Istio Service Mesh<br/>DestinationRule + VirtualService"]
        KueueSvc["Kueue<br/>Workload admission"]
        PromSvc["Prometheus<br/>ServiceMonitor scraping"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>configurable port TCP<br/>TLS optional<br/>Username/Password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Username/Password"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token"]
        OTLP["OTLP Collector<br/>configurable gRPC/HTTP<br/>TLS configurable"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>Bearer Token"| TASRoute
    User -->|"HTTPS/443<br/>Bearer Token"| GORCHRoute
    User -->|"HTTPS/443"| GORCHHealthRoute
    User -->|"HTTPS/443<br/>Bearer Token"| EvalHubRoute
    User -->|"HTTPS/443<br/>Bearer Token"| NemoRoute

    %% Ingress → Auth Proxy
    TASRoute -->|"HTTPS/8443<br/>TLS serving cert"| TASProxy
    GORCHRoute -->|"HTTPS/8432<br/>TLS serving cert"| GORCHProxy
    GORCHGatewayRoute -->|"HTTPS/8490"| GatewayProxy
    EvalHubRoute -->|"HTTPS/8443<br/>TLS serving cert"| EvalHubProxy
    NemoRoute -->|"HTTPS/8443<br/>TLS serving cert"| NemoProxy

    %% Auth Proxy → Services
    TASProxy -->|"HTTP/8080<br/>localhost (no TLS)"| TAS
    GORCHProxy -->|"HTTPS/8032<br/>TLS serving cert"| GORCH
    EvalHubProxy -->|"HTTP/8000"| EvalHub
    NemoProxy -->|"HTTP/8000"| NemoGR

    %% Health (bypasses auth)
    GORCHHealthRoute -->|"HTTP/8034<br/>no auth"| GORCH

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% Service integrations
    TAS -->|"CRD Watch/Patch"| KServe
    GORCH -->|"CRD List/Read<br/>auto-config"| KServe
    Operator -->|"CRD Create"| Istio
    Operator -->|"Workload Create"| KueueSvc
    Operator -->|"ServiceMonitor"| PromSvc

    %% External egress
    TAS -->|"TCP TLS(opt)<br/>Username/Password"| PostgreSQL
    EvalHub -->|"TCP TLS(opt)<br/>Username/Password"| PostgreSQL
    LMEvalPod -->|"HTTPS/443<br/>AWS IAM"| S3
    LMEvalPod -->|"HTTPS/443<br/>Username/Password"| OCI
    LMEvalPod -->|"HTTPS/443<br/>API Token"| HFHub
    GORCH -->|"gRPC/HTTP TLS"| OTLP
    EvalHub -->|"gRPC/HTTP TLS"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class TASRoute,GORCHRoute,GORCHHealthRoute,GORCHGatewayRoute,EvalHubRoute,NemoRoute ingress
    class TASProxy,GORCHProxy,GatewayProxy,BuiltInProxy,EvalHubProxy,NemoProxy authproxy
    class Operator,TAS,GORCH,EvalHub,NemoGR,LMEvalPod internal
    class K8sAPI,KServe,Istio,KueueSvc,PromSvc platform
    class PostgreSQL,S3,OCI,HFHub,OTLP externalservice
