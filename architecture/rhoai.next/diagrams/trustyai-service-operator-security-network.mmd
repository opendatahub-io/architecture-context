graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        MCPClient["MCP Client"]
        ExtClient["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        TASRoute["TrustyAI Route<br/>443/TCP → 8443/TCP<br/>TLS edge"]
        EHRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        EHMCPRoute["EvalHub MCP Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        GORCHRoute["Guardrails Orch Route<br/>443/TCP → 8432/TCP<br/>TLS reencrypt"]
        GORCHGWRoute["Guardrails GW Route<br/>443/TCP → 8490/TCP<br/>TLS edge/reencrypt"]
        NemoRoute["NeMo Guardrails Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health<br/>9443/TCP webhook"]
    end

    subgraph UserNS["USER NAMESPACES (kube-rbac-proxy SAR enforcement)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            TASProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-ca<br/>Auth: SAR"]
            TASApp["TrustyAI Service<br/>8080/TCP HTTP<br/>(localhost)"]
            TASProxy -->|forward| TASApp
        end

        subgraph EHPod["EvalHub Pod"]
            EHProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-ca<br/>Auth: SAR (multi-resource)"]
            EHApp["EvalHub API<br/>8444/TCP HTTP<br/>(localhost)"]
            EHProxy -->|forward| EHApp
        end

        subgraph EHMCPPod["EvalHub MCP Pod"]
            EHMCPProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-ca<br/>Auth: SAR"]
            EHMCPApp["EvalHub MCP Server<br/>(localhost)"]
            EHMCPProxy -->|forward| EHMCPApp
        end

        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            GORCHProxy["kube-rbac-proxy<br/>8432/TCP HTTPS<br/>(conditional OAuth)<br/>Auth: SAR"]
            GORCHApp["Orchestrator<br/>+ Gateway 8490/TCP<br/>+ Detector 8480/TCP"]
            GORCHProxy -->|forward| GORCHApp
        end

        subgraph NemoPod["NeMo Guardrails Pod"]
            NemoProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-ca<br/>Auth: SAR (auth-delegator)"]
            NemoApp["NeMo Server<br/>(localhost)"]
            NemoProxy -->|forward| NemoApp
        end

        subgraph LMEvalPod["LMEval Job Pod (ephemeral)"]
            LMESDriver["LMES Driver<br/>18080/TCP HTTP<br/>(pod-internal only)"]
            LMEvalHarness["lm-evaluation-harness"]
        end
    end

    subgraph TenantNS["TENANT NAMESPACES (EvalHub multi-tenancy)"]
        TenantJobs["Batch Jobs<br/>Auto-provisioned SA/RBAC"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token Auth"]
        KServeISVC["KServe InferenceServices<br/>HTTPS/gRPC<br/>SA Token / mTLS"]
        PostgreSQL["PostgreSQL<br/>TCP, TLS optional<br/>Username/Password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>dockerconfigjson"]
        ModelEndpoints["Model Endpoints<br/>VLLM/OpenAI<br/>HTTPS, API Key"]
        OTLP["OTLP Collector<br/>gRPC/HTTP<br/>TLS configurable"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>Bearer Token"| TASRoute
    User -->|"HTTPS/443<br/>Bearer Token"| EHRoute
    User -->|"HTTPS/443<br/>Bearer Token"| GORCHRoute
    MCPClient -->|"HTTPS/443<br/>Bearer Token"| EHMCPRoute
    ExtClient -->|"HTTPS/443<br/>Bearer Token"| NemoRoute
    User -->|"HTTPS/443<br/>Bearer Token"| GORCHGWRoute

    %% Ingress → Services
    TASRoute -->|"HTTPS/8443<br/>TLS service-ca"| TASProxy
    EHRoute -->|"HTTPS/8443<br/>TLS reencrypt"| EHProxy
    EHMCPRoute -->|"HTTPS/8443<br/>TLS reencrypt"| EHMCPProxy
    GORCHRoute -->|"HTTPS/8432<br/>TLS reencrypt"| GORCHProxy
    NemoRoute -->|"HTTPS/8443<br/>TLS reencrypt"| NemoProxy

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>SA Token<br/>CRD watches + CRUD"| K8sAPI

    %% Operator manages resources
    Operator -.->|creates/manages| TASPod
    Operator -.->|creates/manages| EHPod
    Operator -.->|creates/manages| EHMCPPod
    Operator -.->|creates/manages| GORCHPod
    Operator -.->|creates/manages| NemoPod
    Operator -.->|creates/manages| LMEvalPod

    %% Service → External
    TASApp -->|"TCP<br/>TLS optional<br/>DB creds"| PostgreSQL
    EHApp -->|"TCP<br/>TLS optional<br/>DB creds"| PostgreSQL
    EHApp -.->|creates jobs| TenantJobs
    LMEvalHarness -->|"HTTPS/443<br/>API Key"| ModelEndpoints
    LMESDriver -->|"HTTPS/443<br/>AWS IAM"| S3
    LMESDriver -->|"HTTPS/443<br/>dockerconfigjson"| OCI
    GORCHApp -->|"gRPC/HTTPS<br/>TLS configurable"| KServeISVC
    EHApp -->|"gRPC/HTTP<br/>TLS configurable"| OTLP
    GORCHApp -->|"gRPC/HTTP<br/>TLS configurable"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef proxy fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef tenant fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,MCPClient,ExtClient external
    class TASRoute,EHRoute,EHMCPRoute,GORCHRoute,GORCHGWRoute,NemoRoute ingress
    class Operator operator
    class TASProxy,EHProxy,EHMCPProxy,GORCHProxy,NemoProxy proxy
    class TASApp,EHApp,EHMCPApp,GORCHApp,NemoApp,LMESDriver,LMEvalHarness app
    class TenantJobs tenant
    class K8sAPI,KServeISVC,PostgreSQL,S3,OCI,ModelEndpoints,OTLP externalservice
