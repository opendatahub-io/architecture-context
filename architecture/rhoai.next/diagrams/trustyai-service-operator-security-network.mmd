graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        direction TB
        TASRoute["{tas-instance} Route<br/>443→8443/TCP Reencrypt"]
        EHRoute["{evalhub-instance} Route<br/>443→8443/TCP Reencrypt"]
        GORCHRoute["{gorch-instance} Route<br/>443→8432/TCP Reencrypt"]
        GORCHGWRoute["{gorch-instance}-gateway Route<br/>443→8490/TCP Edge/Reencrypt"]
        NEMORoute["{nemo-instance} Route<br/>443→8443/TCP Edge/Reencrypt"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER (kube-rbac-proxy)"]
        direction TB
        KRBP_TAS["kube-rbac-proxy (TAS)<br/>8443→8080/TCP<br/>SAR: trustyaiservices"]
        KRBP_EH["kube-rbac-proxy (EvalHub)<br/>8443→8080/TCP<br/>SAR + X-Tenant scoping"]
        KRBP_GORCH["kube-rbac-proxy (GORCH)<br/>8432→8032/TCP<br/>SAR + OAuth forwarding"]
        KRBP_NEMO["kube-rbac-proxy (NeMo)<br/>8443→8000/TCP<br/>SAR: nemoguardrails"]
        KRBP_Metrics["kube-rbac-proxy (Metrics)<br/>8443→8080/TCP<br/>Token review"]
    end

    subgraph AppLayer["APPLICATION LAYER (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: operator"]
            CtrlMgr["controller-manager<br/>SA: controller-manager<br/>:8080 metrics, :8081 health"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            TASPod["TrustyAI Service<br/>:8080/TCP HTTP"]
            GORCHPod["Guardrails Orchestrator<br/>:8032, :8490, :8480, :9443"]
            NEMOPod["NeMo Guardrails<br/>:8000/TCP HTTP"]
            EHPod["EvalHub Service<br/>:8080/TCP HTTP"]
            EvalPod["LM Eval Pod<br/>ta-lmes-driver :18080 (localhost)"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>SA Token Auth"]
        KServe["KServe / ModelMesh<br/>InferenceService CRD"]
        KueueCtrl["Kueue<br/>Workload scheduling"]
        Istio["Istio (conditional)<br/>DestinationRule / VirtualService"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>Basic/Docker auth"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>HF Token"]
        MLFlow["MLFlow Tracking<br/>HTTPS<br/>Projected SA Token"]
        OTEL["OpenTelemetry<br/>gRPC/HTTP<br/>TLS (configurable)"]
        DB["PostgreSQL<br/>5432/TCP<br/>DB Credentials"]
        Git["Git Repos<br/>443/TCP HTTPS"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| TASRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| EHRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHGWRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| NEMORoute

    %% Ingress to Auth Proxy
    TASRoute -->|"HTTPS/8443<br/>TLS serving cert"| KRBP_TAS
    EHRoute -->|"HTTPS/8443<br/>TLS serving cert"| KRBP_EH
    GORCHRoute -->|"HTTPS/8432<br/>TLS serving cert"| KRBP_GORCH
    NEMORoute -->|"HTTPS/8443<br/>TLS serving cert"| KRBP_NEMO

    %% Auth Proxy to App
    KRBP_TAS -->|"HTTP/8080<br/>localhost"| TASPod
    KRBP_EH -->|"HTTP/8080<br/>localhost"| EHPod
    KRBP_GORCH -->|"HTTP/8032<br/>localhost"| GORCHPod
    KRBP_NEMO -->|"HTTP/8000<br/>localhost"| NEMOPod

    %% Controller to K8s
    CtrlMgr -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    CtrlMgr -->|"CRD Patch"| KServe
    CtrlMgr -->|"Workload CRD"| KueueCtrl
    CtrlMgr -->|"CRD Create<br/>(conditional)"| Istio

    %% App to External
    EvalPod -->|"HTTPS/443<br/>AWS IAM"| S3
    EvalPod -->|"HTTPS/443<br/>Basic auth"| OCI
    EvalPod -->|"HTTPS/443<br/>HF Token"| HFHub
    EvalPod -->|"HTTPS/443"| Git
    EHPod -->|"HTTPS<br/>SA Token"| MLFlow
    EHPod -->|"TLS"| DB
    GORCHPod -->|"gRPC/HTTP"| OTEL
    EHPod -->|"gRPC/HTTP"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef applayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class TASRoute,EHRoute,GORCHRoute,GORCHGWRoute,NEMORoute ingress
    class KRBP_TAS,KRBP_EH,KRBP_GORCH,KRBP_NEMO,KRBP_Metrics authproxy
    class CtrlMgr,TASPod,GORCHPod,NEMOPod,EHPod,EvalPod applayer
    class K8sAPI,KServe,KueueCtrl,Istio k8scontrol
    class S3,OCI,HFHub,MLFlow,OTEL,DB,Git externalsvc
