graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router - DMZ)"]
        TASRoute["Route: {tas-instance}<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        EHRoute["Route: {evalhub-instance}<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        GORCHRoute["Route: {gorch-instance}<br/>443/TCP → 8432/TCP<br/>TLS Reencrypt"]
        GORCHGWRoute["Route: {gorch-instance}-gateway<br/>443/TCP → 8490/TCP<br/>TLS Edge/Reencrypt"]
        GORCHBIRoute["Route: {gorch-instance}-built-in<br/>443/TCP → 8480/TCP<br/>TLS Edge/Reencrypt"]
        GORCHHealthRoute["Route: {gorch-instance}-health<br/>443/TCP → 9443/TCP<br/>TLS Edge"]
        NEMORoute["Route: {nemo-instance}<br/>443/TCP → 8443/TCP<br/>TLS Edge/Reencrypt"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (System)"]
        CtrlMgr["controller-manager<br/>SA: controller-manager<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)<br/>8443/TCP metrics (HTTPS kube-rbac-proxy)"]
    end

    subgraph UserNS["USER NAMESPACE (Per-namespace workloads)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            TASKRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR auth"]
            TASContainer["TrustyAI Service<br/>8080/TCP HTTP<br/>localhost only"]
            TASKRBP -->|"HTTP/8080<br/>localhost"| TASContainer
        end

        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            GORCHKRBP1["kube-rbac-proxy: orchestrator<br/>8432/TCP HTTPS<br/>SAR + OAuth fwd"]
            GORCHKRBP2["kube-rbac-proxy: gateway<br/>8490/TCP HTTPS"]
            GORCHKRBP3["kube-rbac-proxy: built-in<br/>8480/TCP HTTPS"]
            GORCHContainer["Orchestrator Container<br/>8032, 8090, 8080/TCP HTTP"]
            GORCHHealth["Health: 9443/TCP HTTPS"]
            GORCHKRBP1 -->|"HTTP/8032"| GORCHContainer
            GORCHKRBP2 -->|"HTTP/8090"| GORCHContainer
            GORCHKRBP3 -->|"HTTP/8080"| GORCHContainer
        end

        subgraph NEMOPod["NeMo Guardrails Pod"]
            NEMOKRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR auth (if enabled)"]
            NEMOContainer["NeMo Container<br/>8000/TCP HTTP"]
            NEMOKRBP -->|"HTTP/8000"| NEMOContainer
        end

        subgraph EHPod["EvalHub Pod"]
            EHKRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR + X-Tenant"]
            EHContainer["EvalHub Container<br/>8080/TCP HTTP"]
            EHKRBP -->|"HTTP/8080<br/>localhost"| EHContainer
        end

        subgraph LMESPod["LMEvalJob Pod (ephemeral)"]
            InitContainer["Init Container<br/>copies driver binary"]
            EvalContainer["Evaluation Container<br/>lm-evaluation-harness"]
            LMESDriver["ta-lmes-driver<br/>18080/TCP HTTP<br/>localhost only"]
            InitContainer -.->|"binary copy"| LMESDriver
            LMESDriver -->|"subprocess"| EvalContainer
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token"]
        KServeIS["KServe InferenceServices<br/>varies HTTPS/HTTP<br/>TLS if configured"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Basic auth"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF token"]
        MLFlow["MLFlow Tracking<br/>varies HTTPS<br/>TLS (service CA)<br/>SA token"]
        OTEL["OpenTelemetry<br/>varies gRPC/HTTP<br/>TLS configurable"]
        Git["Git Repos<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| TASRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| EHRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHGWRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| NEMORoute

    %% Ingress → Workloads
    TASRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>SAR"| TASKRBP
    EHRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>SAR+X-Tenant"| EHKRBP
    GORCHRoute -->|"HTTPS/8432<br/>TLS reencrypt<br/>SAR+OAuth"| GORCHKRBP1
    GORCHGWRoute -->|"HTTPS/8490<br/>TLS"| GORCHKRBP2
    GORCHBIRoute -->|"HTTPS/8480<br/>TLS"| GORCHKRBP3
    GORCHHealthRoute -->|"HTTPS/9443<br/>TLS edge"| GORCHHealth
    NEMORoute -->|"HTTPS/8443<br/>TLS<br/>SAR"| NEMOKRBP

    %% Operator → K8s API
    CtrlMgr -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator → KServe (via API)
    CtrlMgr -->|"HTTPS/6443<br/>Patch InferenceService"| KServeIS

    %% LMEval Pod → External
    LMESDriver -->|"HTTPS/443<br/>AWS IAM"| S3
    LMESDriver -->|"HTTPS/443<br/>Basic auth"| OCI
    LMESDriver -->|"HTTPS/443<br/>HF token"| HFHub
    LMESDriver -->|"HTTPS/443"| Git

    %% Operator polls driver
    CtrlMgr -.->|"pod exec<br/>GET /GetStatus<br/>18080/TCP localhost"| LMESDriver

    %% GORCH → external
    GORCHContainer -->|"HTTPS/HTTP<br/>varies"| KServeIS

    %% EvalHub → external
    EHContainer -->|"HTTPS<br/>SA token"| MLFlow
    EHContainer -->|"gRPC/HTTP<br/>TLS"| OTEL
    GORCHContainer -->|"gRPC/HTTP<br/>TLS"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef proxy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class TASRoute,EHRoute,GORCHRoute,GORCHGWRoute,GORCHBIRoute,GORCHHealthRoute,NEMORoute ingress
    class CtrlMgr operator
    class TASContainer,GORCHContainer,GORCHHealth,NEMOContainer,EHContainer,EvalContainer,LMESDriver,InitContainer workload
    class TASKRBP,GORCHKRBP1,GORCHKRBP2,GORCHKRBP3,NEMOKRBP,EHKRBP proxy
    class K8sAPI,KServeIS,S3,OCI,HFHub,MLFlow,OTEL,Git externalservice
