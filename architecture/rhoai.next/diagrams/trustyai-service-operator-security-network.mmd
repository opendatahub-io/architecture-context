graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes — TLS Termination)"]
        TASRoute["TrustyAI Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        EVRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        EVMCPRoute["EvalHub MCP Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        GORCHRoute["GORCH Route<br/>443/TCP → 8432/TCP<br/>TLS edge/reencrypt"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8490/TCP<br/>TLS edge/reencrypt"]
        NEMORoute["NemoGuardrails Route<br/>443/TCP → 443/TCP<br/>TLS edge/reencrypt"]
    end

    subgraph Cluster["CLUSTER INTERNAL (kube-rbac-proxy Auth)"]
        direction TB

        subgraph NS_Operator["Namespace: operator"]
            Operator["TrustyAI Operator<br/>SA: trustyai-service-operator-controller-manager<br/>8080/TCP metrics · 8081/TCP health · 9443/TCP webhook"]
        end

        subgraph NS_TAS["Namespace: {tas-namespace}"]
            TASRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS TLS 1.2+<br/>OAuth (tokenreviews + SAR)<br/>FIPS cipher suites"]
            TASApp["TrustyAI Application<br/>8080/TCP HTTP (localhost)<br/>Cert: service CA"]
        end

        subgraph NS_EvalHub["Namespace: {evalhub-namespace}"]
            EVRBAC["kube-rbac-proxy (SAR)<br/>8443/TCP HTTPS<br/>X-Tenant multi-tenant scoping"]
            EVApi["EvalHub API<br/>8444/TCP HTTP (localhost)"]
            EVMetrics["EvalHub Metrics<br/>8081/TCP HTTP"]
            EVMCP["EvalHub MCP Server<br/>8443/TCP HTTPS<br/>SAR: evalhubs/proxy"]
        end

        subgraph NS_GORCH["Namespace: {gorch-namespace}"]
            GORCHOrch["Orchestrator<br/>8432/TCP (auth) · 8032/TCP (no auth)<br/>Conditional kube-rbac-proxy"]
            GORCHGW["Gateway<br/>8490/TCP (auth) · 8090/TCP (no auth)"]
            GORCHDet["Detector<br/>8480/TCP (auth) · 8080/TCP (no auth)"]
            GORCHHealth["Health<br/>8034/TCP HTTP (no auth)"]
        end

        subgraph NS_NEMO["Namespace: {nemo-namespace}"]
            NEMOSvc["NeMo Guardrails<br/>443/TCP (auth) · 80/TCP (no auth)<br/>Conditional kube-rbac-proxy"]
            NEMOEnvoy["EnvoyFilter<br/>MCP SSE response stripping"]
        end

        subgraph NS_LMES["Namespace: {lmes-namespace}"]
            LMESPod["LMES Evaluation Pod<br/>Driver: 18080/TCP HTTP<br/>(pod-local only, no external exposure)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA token auth"]
        KServeIS["KServe InferenceService<br/>varies · HTTPS/HTTP"]
        PostgreSQL["PostgreSQL<br/>varies · TCP<br/>Conditional TLS<br/>Username/password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS-style credentials"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>dockerconfigjson"]
        OTLP["OTLP Collector<br/>varies · gRPC/HTTP<br/>Conditional TLS"]
        Git["Git Repos<br/>443/TCP HTTPS"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>OAuth / Bearer"| TASRoute
    User -->|"HTTPS/443<br/>OAuth / Bearer"| EVRoute
    User -->|"HTTPS/443<br/>OAuth / Bearer"| EVMCPRoute
    User -->|"HTTPS/443<br/>Conditional auth"| GORCHRoute
    User -->|"HTTPS/443<br/>Conditional auth"| GORCHGWRoute
    User -->|"HTTPS/443<br/>Conditional auth"| NEMORoute

    %% Ingress → Services
    TASRoute -->|"HTTPS/8443<br/>TLS 1.2+ reencrypt"| TASRBAC
    EVRoute -->|"HTTPS/8443<br/>TLS reencrypt"| EVRBAC
    EVMCPRoute -->|"HTTPS/8443<br/>TLS reencrypt"| EVMCP
    GORCHRoute -->|"HTTPS/8432<br/>Conditional TLS"| GORCHOrch
    GORCHGWRoute -->|"HTTPS/8490<br/>Conditional TLS"| GORCHGW
    NEMORoute -->|"HTTPS/443<br/>Conditional TLS"| NEMOSvc

    %% Internal proxy → app
    TASRBAC -->|"HTTP/8080<br/>localhost"| TASApp
    EVRBAC -->|"HTTP/8444<br/>localhost"| EVApi

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>SA token"| K8sAPI

    %% Service → External
    TASApp -->|"TCP · Conditional TLS<br/>DB credentials"| PostgreSQL
    EVApi -->|"HTTPS/443<br/>SA token"| K8sAPI
    LMESPod -->|"HTTPS/443<br/>AWS credentials"| S3
    LMESPod -->|"HTTPS/443<br/>dockerconfigjson"| OCI
    LMESPod -->|"HTTPS/443"| Git
    GORCHOrch -->|"HTTPS/HTTP<br/>Conditional TLS"| KServeIS
    NEMOSvc -.->|"EnvoyFilter"| NEMOEnvoy

    %% Telemetry
    GORCHOrch -.->|"gRPC/HTTP<br/>Conditional TLS"| OTLP
    EVApi -.->|"gRPC/HTTP<br/>Conditional TLS"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class TASRoute,EVRoute,EVMCPRoute,GORCHRoute,GORCHGWRoute,NEMORoute ingress
    class TASRBAC,TASApp,EVRBAC,EVApi,EVMetrics,EVMCP,GORCHOrch,GORCHGW,GORCHDet,GORCHHealth,NEMOSvc,NEMOEnvoy,LMESPod cluster
    class Operator operator
    class K8sAPI,KServeIS,PostgreSQL,S3,OCI,OTLP,Git externalservice
