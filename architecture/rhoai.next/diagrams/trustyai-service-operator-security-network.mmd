graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist<br/>Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        direction TB
        TASRoute["TAS Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt"]
        GORCHRoute["GORCH Route<br/>443/TCP → 8432/TCP<br/>TLS 1.2+ reencrypt"]
        GORCHHealthRoute["GORCH Health Route<br/>443/TCP → 8034/TCP<br/>TLS 1.2+ edge"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8490/TCP<br/>TLS 1.2+ edge/reencrypt"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt/edge"]
        NemoRoute["NemoGuardrails Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt/edge"]
    end

    subgraph AuthProxy["AUTH PROXY (kube-rbac-proxy - SubjectAccessReview)"]
        direction TB
        TASKRBAC["TAS kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR: get on services"]
        GORCHKRBAC["GORCH kube-rbac-proxy<br/>8432/TCP HTTPS<br/>SAR: get on services"]
        GORCHGWKRBAC["GORCH GW kube-rbac-proxy<br/>8490/TCP HTTPS<br/>SAR: get on services"]
        EHKRBAC["EvalHub kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR: get on services"]
        NEMOKRBAC["Nemo kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR: get on services"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>Metrics: 8080/TCP HTTPS<br/>Health: 8081/TCP HTTP"]
    end

    subgraph ManagedPods["MANAGED SERVICE PODS (User Namespaces)"]
        direction TB
        TASPod["TrustyAI Service<br/>8080/TCP HTTP<br/>Health: /q/health/*"]
        GORCHPod["Guardrails Orchestrator<br/>8032/TCP HTTPS<br/>Health: 8034/TCP"]
        LMEvalPod["LMEval Job Pod<br/>Driver: 5000/TCP HTTP<br/>Ephemeral batch"]
        NemoPod["NemoGuardrails<br/>8000/TCP HTTP<br/>Health: /"]
        EvalHubPod["EvalHub<br/>8000/TCP HTTP<br/>Multi-tenant"]
    end

    subgraph IstioMesh["ISTIO SERVICE MESH (TAS)"]
        DR["DestinationRule<br/>Port 443 SIMPLE TLS"]
        VS["VirtualService<br/>HTTP 80 → HTTPS 443"]
    end

    subgraph ExternalSvcs["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token Auth"]
        PostgreSQL["PostgreSQL<br/>configurable port<br/>TLS optional<br/>Username/Password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Token"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Username/Password"]
        OTLP["OTLP Collector<br/>configurable<br/>gRPC/HTTP<br/>TLS configurable"]
    end

    subgraph KServeSvcs["KSERVE SERVICES"]
        DetectorIS["Detector InferenceServices<br/>label: trustyai/guardrails=true"]
        GenIS["Generation InferenceService"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>Bearer Token<br/>TLS 1.2+"| TASRoute
    User -->|"HTTPS/443<br/>Bearer Token<br/>TLS 1.2+"| GORCHRoute
    User -->|"HTTPS/443<br/>TLS 1.2+"| EvalHubRoute
    User -->|"HTTPS/443<br/>TLS 1.2+"| NemoRoute

    %% Ingress → Auth Proxy
    TASRoute -->|"HTTPS/8443<br/>serving cert"| TASKRBAC
    GORCHRoute -->|"HTTPS/8432<br/>serving cert"| GORCHKRBAC
    GORCHGWRoute -->|"HTTPS/8490<br/>serving cert"| GORCHGWKRBAC
    EvalHubRoute -->|"HTTPS/8443<br/>serving cert"| EHKRBAC
    NemoRoute -->|"HTTPS/8443<br/>serving cert"| NEMOKRBAC

    %% Auth Proxy → Services
    TASKRBAC -->|"HTTP/8080<br/>localhost"| TASPod
    GORCHKRBAC -->|"HTTPS/8032<br/>serving cert"| GORCHPod
    EHKRBAC -->|"HTTP/8000<br/>localhost"| EvalHubPod
    NEMOKRBAC -->|"HTTP/8000<br/>localhost"| NemoPod

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>SA Token<br/>CRD Watch + CRUD"| K8sAPI

    %% Service → External
    TASPod -->|"TCP/configurable<br/>TLS optional<br/>Credentials"| PostgreSQL
    EvalHubPod -->|"TCP/configurable<br/>TLS optional<br/>Credentials"| PostgreSQL
    LMEvalPod -->|"HTTPS/443<br/>API Token"| HFHub
    LMEvalPod -->|"HTTPS/443<br/>AWS IAM"| S3
    LMEvalPod -->|"HTTPS/443<br/>Username/Password"| OCI
    GORCHPod -->|"gRPC/HTTP<br/>TLS configurable"| OTLP
    EvalHubPod -->|"gRPC/HTTP<br/>TLS configurable"| OTLP

    %% GORCH → KServe
    GORCHPod -->|"HTTP/HTTPS<br/>TLS 1.2+"| DetectorIS
    GORCHPod -->|"HTTP/HTTPS<br/>TLS 1.2+"| GenIS

    %% TAS → Istio
    TASPod --- DR
    TASPod --- VS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef istio fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef kserve fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class User external
    class TASRoute,GORCHRoute,GORCHHealthRoute,GORCHGWRoute,EvalHubRoute,NemoRoute ingress
    class TASKRBAC,GORCHKRBAC,GORCHGWKRBAC,EHKRBAC,NEMOKRBAC authproxy
    class Operator operator
    class TASPod,GORCHPod,LMEvalPod,NemoPod,EvalHubPod managed
    class DR,VS istio
    class K8sAPI,PostgreSQL,S3,HFHub,OCI,OTLP extsvc
    class DetectorIS,GenIS kserve
