graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        direction TB
        TASRoute["TAS Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        GORCHRoute["GORCH Route<br/>443/TCP → 8432/TCP<br/>TLS Reencrypt"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8490/TCP<br/>TLS Edge/Reencrypt"]
        GORCHBIRoute["GORCH Built-in Route<br/>443/TCP → 8480/TCP<br/>TLS Edge/Reencrypt"]
        GORCHHealthRoute["GORCH Health Route<br/>443/TCP → 9443/TCP<br/>TLS Edge"]
        NemoRoute["NeMo Route<br/>443/TCP → 8443/TCP<br/>TLS Edge/Reencrypt"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER (kube-rbac-proxy sidecars)"]
        direction TB
        TASRBAC["TAS kube-rbac-proxy<br/>8443 → 8080<br/>SAR: trustyaiservices"]
        GORCHRBAC["GORCH kube-rbac-proxy<br/>8432 → 8032<br/>SAR + OAuth fwd"]
        GORCHGWRBAC["GORCH GW kube-rbac-proxy<br/>8490 → upstream<br/>SAR (if auth)"]
        GORCHBIRBAC["GORCH BI kube-rbac-proxy<br/>8480 → upstream<br/>SAR (if auth)"]
        NemoRBAC["NeMo kube-rbac-proxy<br/>8443 → 8000<br/>SAR: nemoguardrails"]
        EvalHubRBAC["EvalHub kube-rbac-proxy<br/>8443 → upstream<br/>SAR + X-Tenant"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        direction TB
        Controller["controller-manager<br/>SA: controller-manager<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        MetricsRBAC["Metrics kube-rbac-proxy<br/>8443/TCP<br/>Token review"]
    end

    subgraph UserNS["USER NAMESPACES (Managed Workloads)"]
        direction TB

        TASPod["TrustyAI Service Pod<br/>8080/TCP HTTP"]
        LMESPod["LMEvalJob Pod<br/>ta-lmes-driver<br/>18080/TCP localhost"]
        GORCHPod["Orchestrator Pod<br/>8032/8490/8480/9443 TCP"]
        NemoPod["NeMo Guardrails Pod<br/>8000/TCP HTTP"]
        EvalHubPod["EvalHub Pod<br/>multi-tenant"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Basic/Docker auth"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token"]
        MLFlowSvc["MLFlow Tracking<br/>HTTPS<br/>TLS (service CA)<br/>Projected SA Token"]
        OTel["OpenTelemetry<br/>gRPC/HTTP<br/>TLS (configurable)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (if configured)<br/>DB Credentials"]
        GitRepos["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| TASRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| GORCHGWRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| NemoRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+"| EvalHubRoute

    %% Ingress → Auth Proxy
    TASRoute --> TASRBAC
    GORCHRoute --> GORCHRBAC
    GORCHGWRoute --> GORCHGWRBAC
    GORCHBIRoute --> GORCHBIRBAC
    NemoRoute --> NemoRBAC
    EvalHubRoute --> EvalHubRBAC

    %% Auth Proxy → Pods
    TASRBAC -->|"HTTP/8080<br/>localhost"| TASPod
    GORCHRBAC -->|"HTTP/8032<br/>localhost"| GORCHPod
    GORCHGWRBAC -->|"HTTP/upstream<br/>localhost"| GORCHPod
    GORCHBIRBAC -->|"HTTP/upstream<br/>localhost"| GORCHPod
    NemoRBAC -->|"HTTP/8000<br/>localhost"| NemoPod
    EvalHubRBAC -->|"HTTP/upstream<br/>localhost"| EvalHubPod

    %% Operator → K8s API
    Controller -->|"HTTPS/6443<br/>SA Token"| K8sAPI

    %% Pods → External Services
    LMESPod -->|"HTTPS/443<br/>AWS IAM"| S3
    LMESPod -->|"HTTPS/443<br/>Basic auth"| OCIReg
    LMESPod -->|"HTTPS/443<br/>HF Token"| HFHub
    LMESPod -->|"HTTPS/443"| GitRepos
    EvalHubPod -->|"HTTPS<br/>SA Token"| MLFlowSvc
    EvalHubPod -->|"5432/TCP<br/>DB creds"| PostgreSQL
    GORCHPod -->|"gRPC/HTTP<br/>TLS"| OTel
    EvalHubPod -->|"gRPC/HTTP<br/>TLS"| OTel

    %% ModelMesh → TAS (payload processing)
    ModelMesh["ModelMesh/KServe<br/>InferenceService"] -->|"HTTPS/8443<br/>serving cert<br/>MM_PAYLOAD_PROCESSORS"| TASRBAC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,ModelMesh external
    class TASRoute,GORCHRoute,GORCHGWRoute,GORCHBIRoute,GORCHHealthRoute,NemoRoute,EvalHubRoute ingress
    class TASRBAC,GORCHRBAC,GORCHGWRBAC,GORCHBIRBAC,NemoRBAC,EvalHubRBAC,MetricsRBAC authproxy
    class Controller operator
    class TASPod,LMESPod,GORCHPod,NemoPod,EvalHubPod workload
    class K8sAPI,S3,OCIReg,HFHub,MLFlowSvc,OTel,PostgreSQL,GitRepos externalservice
