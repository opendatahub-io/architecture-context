graph LR
    RegexDetector["Guardrails Regex Detector<br/>(Rust Service)"]

    %% Rust Crate Dependencies
    subgraph "Rust Dependencies"
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Regex["regex 1.11.1<br/>(Pattern engine)"]
        Serde["serde 1.0.215<br/>serde_json 1.0.133<br/>(JSON ser/de)"]
        Tokio["tokio 1.41.1<br/>(Async runtime)"]
        TowerHTTP["tower-http 0.6.2<br/>(HTTP middleware)"]
        Tracing["tracing 0.1.41<br/>tracing-subscriber 0.3.19<br/>(Logging)"]
    end

    RegexDetector -->|"HTTP framework"| Axum
    RegexDetector -->|"PII matching"| Regex
    RegexDetector -->|"request/response"| Serde
    RegexDetector -->|"async runtime"| Tokio
    RegexDetector -->|"request tracing"| TowerHTTP
    RegexDetector -->|"structured logging"| Tracing

    %% Internal Platform Dependencies
    subgraph "Internal RHOAI"
        Orchestrator["FMS Guardrails<br/>Orchestrator"]
    end

    Orchestrator -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| RegexDetector

    %% Container Base
    subgraph "Container"
        UBI9["ubi9/ubi-minimal<br/>(Base image)"]
        OpenSSL["compat-openssl11<br/>(System dep)"]
    end

    RegexDetector -.->|"runs on"| UBI9
    UBI9 -.->|"installed"| OpenSSL

    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Axum fill:#999,stroke:#333
    style Regex fill:#999,stroke:#333
    style Serde fill:#999,stroke:#333
    style Tokio fill:#999,stroke:#333
    style TowerHTTP fill:#999,stroke:#333
    style Tracing fill:#999,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style UBI9 fill:#f5a623,stroke:#333
    style OpenSSL fill:#f5a623,stroke:#333
