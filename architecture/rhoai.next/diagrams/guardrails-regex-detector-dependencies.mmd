graph LR
    RegexDetector["Guardrails Regex Detector<br/>(Rust Service)"]

    %% Internal Platform Dependencies
    RegexDetector -->|"inbound REST<br/>POST /api/v1/text/contents<br/>HTTP 8080/TCP"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Rust Crate Dependencies
    subgraph RustCrates["Rust Dependencies (Cargo)"]
        direction TB
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Regex["regex 1.11.1<br/>(pattern engine)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        Serde["serde 1.0.215<br/>serde_json 1.0.133<br/>(JSON ser/de)"]
        TowerHTTP["tower-http 0.6.2<br/>(HTTP middleware)"]
        TracingCrate["tracing 0.1.41<br/>tracing-subscriber 0.3.19<br/>(structured logging)"]
    end

    RegexDetector -->|"web framework"| Axum
    RegexDetector -->|"regex matching"| Regex
    RegexDetector -->|"async runtime"| Tokio
    RegexDetector -->|"JSON parsing"| Serde
    RegexDetector -->|"request tracing"| TowerHTTP
    RegexDetector -->|"logging"| TracingCrate

    %% Container Base
    RegexDetector -->|"base image"| UBI9["UBI9 minimal<br/>(container base)"]

    %% NO external service dependencies
    %% NO Kubernetes API dependency
    %% NO storage dependency

    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,stroke-width:2px
    style Axum fill:#e8e8e8,stroke:#333
    style Regex fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style Serde fill:#e8e8e8,stroke:#333
    style TowerHTTP fill:#e8e8e8,stroke:#333
    style TracingCrate fill:#e8e8e8,stroke:#333
    style UBI9 fill:#f5a623,stroke:#333,stroke-width:2px
