graph LR
    RegexDetector["Guardrails Regex Detector<br/>(Rust Service)"]

    %% Internal RHOAI Dependencies (upstream caller)
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"REST inbound<br/>POST /api/v1/text/contents<br/>8080/TCP HTTP"| RegexDetector

    %% Kubernetes Integration
    K8s["Kubernetes"] -->|"Health probe<br/>GET /health<br/>8080/TCP HTTP"| RegexDetector

    %% Rust Crate Dependencies
    subgraph "Rust Crate Dependencies"
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Tokio["tokio 1.41.1<br/>(Async runtime)"]
        Regex["regex 1.11.1<br/>(Pattern matching)"]
        Serde["serde 1.0.215<br/>serde_json 1.0.133<br/>(JSON ser/de)"]
        TowerHTTP["tower-http 0.6.2<br/>(HTTP middleware)"]
        Tracing["tracing 0.1.41<br/>tracing-subscriber 0.3.19<br/>(Logging)"]
    end

    RegexDetector -.->|"runtime"| Axum
    RegexDetector -.->|"runtime"| Tokio
    RegexDetector -.->|"runtime"| Regex
    RegexDetector -.->|"runtime"| Serde
    RegexDetector -.->|"runtime"| TowerHTTP
    RegexDetector -.->|"runtime"| Tracing

    %% System Dependencies
    OpenSSL["compat-openssl11<br/>(RPM - system lib)"]
    RegexDetector -.->|"dynamic link"| OpenSSL

    %% Styling
    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style K8s fill:#e8e8e8,stroke:#333
    style Axum fill:#ddd,stroke:#999
    style Tokio fill:#ddd,stroke:#999
    style Regex fill:#ddd,stroke:#999
    style Serde fill:#ddd,stroke:#999
    style TowerHTTP fill:#ddd,stroke:#999
    style Tracing fill:#ddd,stroke:#999
    style OpenSSL fill:#f5a623,stroke:#333,color:#fff
