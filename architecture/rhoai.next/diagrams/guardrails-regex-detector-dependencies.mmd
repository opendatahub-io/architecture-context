graph LR
    RegexDetector["Guardrails Regex<br/>Detector"]

    %% Internal RHOAI Dependencies (upstream caller)
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>8080/TCP HTTP"| RegexDetector

    %% Rust Crate Dependencies (compile-time / runtime)
    RegexDetector -->|"HTTP framework"| Axum["axum 0.7.9"]
    RegexDetector -->|"regex engine"| Regex["regex 1.11.1"]
    RegexDetector -->|"JSON serde"| Serde["serde 1.0.215 /<br/>serde_json 1.0.133"]
    RegexDetector -->|"async runtime"| Tokio["tokio 1.41.1"]
    RegexDetector -->|"HTTP tracing"| TowerHTTP["tower-http 0.6.2"]
    RegexDetector -->|"structured logging"| Tracing["tracing 0.1.41 /<br/>tracing-subscriber 0.3.19"]

    %% Build Dependencies
    RegexDetector -.->|"build toolchain"| RustToolchain["Rust 1.84.0<br/>(rustfmt + clippy)"]
    RegexDetector -.->|"base image"| UBI["UBI 9 minimal<br/>(+ compat-openssl11)"]

    %% Platform Infrastructure
    K8s["Kubernetes"] -->|"health probes<br/>GET /health"| RegexDetector

    %% Styling
    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Axum fill:#999,stroke:#333,color:#fff
    style Regex fill:#999,stroke:#333,color:#fff
    style Serde fill:#999,stroke:#333,color:#fff
    style Tokio fill:#999,stroke:#333,color:#fff
    style TowerHTTP fill:#999,stroke:#333,color:#fff
    style Tracing fill:#999,stroke:#333,color:#fff
    style RustToolchain fill:#e8e8e8,stroke:#333
    style UBI fill:#e8e8e8,stroke:#333
    style K8s fill:#f5a623,stroke:#333,color:#fff
