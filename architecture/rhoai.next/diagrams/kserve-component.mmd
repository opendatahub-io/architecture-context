graph TB
    subgraph KServe["KServe Platform (serving.kserve.io)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller<br/>Go Operator<br/>8080/TCP metrics<br/>9443/TCP webhook"]
            LLMISvcCtrl["llmisvc-controller<br/>Go Operator<br/>8443/TCP secure metrics<br/>9443/TCP webhook"]
            LocalModelCtrl["localmodel-controller<br/>Go Operator<br/>8080/TCP metrics<br/>9443/TCP webhook"]
        end

        subgraph NodeAgents["Node Agents"]
            LocalModelAgent["localmodelnode-agent<br/>Go DaemonSet<br/>Per-node model cache"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            Agent["kserve-agent<br/>Go Sidecar Proxy<br/>9081/TCP proxy"]
            StorageInit["kserve-storage-initializer<br/>Python Init Container<br/>S3/GCS/Azure/HF/HDFS"]
        end

        subgraph Routing["Routing"]
            Router["kserve-router<br/>Go Service<br/>8080/TCP HTTP<br/>InferenceGraph handler"]
        end

        subgraph SDK["Python SDK"]
            ModelServer["KServe Model Server<br/>V1/V2/OpenAI REST<br/>gRPC V2 Inference<br/>8080/TCP + 8081/TCP"]
        end
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>v1beta1"]
        LLMSVC["LLMInferenceService<br/>v1alpha1/v1alpha2"]
        IG["InferenceGraph<br/>v1alpha1"]
        LMC["LocalModelCache<br/>v1alpha1"]
        SR["ServingRuntime<br/>v1alpha1"]
        TM["TrainedModel<br/>v1alpha1"]
    end

    %% Controller → CRD relationships
    KServeCtrl -->|reconciles| ISVC
    KServeCtrl -->|reconciles| IG
    KServeCtrl -->|reconciles| TM
    KServeCtrl -->|watches| SR
    LLMISvcCtrl -->|reconciles| LLMSVC
    LocalModelCtrl -->|reconciles| LMC

    %% Controller → Created Resources
    KServeCtrl -->|creates| Deployments["Deployments<br/>Services<br/>Ingress/HTTPRoutes<br/>VirtualServices<br/>HPA/ScaledObjects"]
    LLMISvcCtrl -->|creates| LLMResources["HTTPRoutes<br/>InferencePool<br/>Scheduler Deployment<br/>DestinationRules<br/>VariantAutoscaling"]
    LocalModelCtrl -->|creates| PVResources["PersistentVolumes<br/>PersistentVolumeClaims"]
    LocalModelAgent -->|creates| Jobs["Download Jobs"]

    %% Sidecar injection
    KServeCtrl -.->|injects via webhook| Agent
    KServeCtrl -.->|injects via webhook| StorageInit

    %% Router relationship
    Router -->|routes to| ISVC
    IG -->|defines routing for| Router

    %% SDK serves models
    ModelServer -->|serves via| ISVC

    %% External dependencies
    Knative["Knative Serving"]
    Istio["Istio Service Mesh"]
    GatewayAPI["Gateway API"]
    KEDA["KEDA Autoscaler"]
    K8sAPI["Kubernetes API"]

    KServeCtrl -->|optional| Knative
    KServeCtrl -->|traffic mgmt| Istio
    LLMISvcCtrl -->|HTTPRoute| GatewayAPI
    KServeCtrl -->|autoscaling| KEDA
    KServeCtrl -->|CRUD| K8sAPI

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISvcCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelAgent fill:#4a90e2,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style Router fill:#9b59b6,stroke:#333,color:#fff
    style ModelServer fill:#e67e22,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333
    style LLMSVC fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333
    style LMC fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333
    style TM fill:#f5a623,stroke:#333
    style Knative fill:#e8e8e8,stroke:#999
    style Istio fill:#e8e8e8,stroke:#999
    style GatewayAPI fill:#e8e8e8,stroke:#999
    style KEDA fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
