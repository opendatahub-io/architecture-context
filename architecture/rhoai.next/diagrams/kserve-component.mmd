graph TB
    subgraph KServeCore["KServe Core Controllers"]
        direction TB
        ControllerMgr["kserve-controller-manager<br/><i>Go Operator</i><br/>9443/TCP webhook, 8080/TCP metrics, 8081/TCP health"]
        LLMController["llmisvc-controller<br/><i>Go Operator</i><br/>8443/TCP metrics (TLS), 9443/TCP webhook, 8081/TCP health"]
        LocalModelCtrl["localmodel-controller<br/><i>Go Operator</i><br/>8080/TCP metrics, 9443/TCP webhook, 8081/TCP health"]
        ModuleCtrl["kserve-module-controller<br/><i>Go Operator</i><br/>8081/TCP health"]
    end

    subgraph NodeAgents["Node-Level Components"]
        LocalModelAgent["localmodelnode-agent<br/><i>DaemonSet</i><br/>8080/TCP metrics, 8081/TCP health"]
    end

    subgraph Sidecars["Injected Components"]
        Agent["kserve-agent<br/><i>Sidecar</i><br/>9081/TCP proxy, 9083/TCP log"]
        StorageInit["kserve-storage-initializer<br/><i>Init Container (Python)</i>"]
    end

    subgraph Routing["Routing Components"]
        Router["kserve-router<br/><i>InferenceGraph Router</i><br/>8080/TCP"]
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        direction TB
        ISVC["InferenceService<br/><i>v1beta1</i>"]
        LLMISVC["LLMInferenceService<br/><i>v1alpha1/v1alpha2</i>"]
        IG["InferenceGraph<br/><i>v1alpha1</i>"]
        TM["TrainedModel<br/><i>v1alpha1</i>"]
        SR["ServingRuntime<br/><i>v1alpha1</i>"]
        CSR["ClusterServingRuntime<br/><i>v1alpha1</i>"]
        LMC["LocalModelCache<br/><i>v1alpha1</i>"]
        LMNC["LocalModelNamespaceCache<br/><i>v1alpha1</i>"]
        LMN["LocalModelNode<br/><i>v1alpha1</i>"]
        KserveCR["Kserve CR<br/><i>Platform</i>"]
    end

    %% Controller-CRD relationships
    ControllerMgr -->|reconciles| ISVC
    ControllerMgr -->|reconciles| TM
    ControllerMgr -->|reconciles| IG
    ControllerMgr -->|watches| SR
    ControllerMgr -->|watches| CSR
    LLMController -->|reconciles| LLMISVC
    LocalModelCtrl -->|reconciles| LMC
    LocalModelCtrl -->|reconciles| LMNC
    LocalModelAgent -->|reconciles| LMN
    ModuleCtrl -->|reconciles| KserveCR

    %% Module controller deploys KServe
    ModuleCtrl -.->|deploys| ControllerMgr
    ModuleCtrl -.->|deploys| LLMController
    ModuleCtrl -.->|deploys| LocalModelCtrl

    %% Sidecar injection
    ControllerMgr -->|injects via webhook| Agent
    ControllerMgr -->|injects via webhook| StorageInit

    %% Router relationship
    ControllerMgr -->|creates per IG| Router

    %% LLM-specific resources
    LLMController -->|creates| EPP["EPP Scheduler<br/>9002/TCP gRPC"]
    LLMController -->|creates| HTTPRoute["HTTPRoute"]
    LLMController -->|creates| InferencePool["InferencePool"]
    LLMController -->|creates| LWS["LeaderWorkerSet"]

    %% External dependencies
    subgraph External["External Dependencies"]
        Istio["Istio / Service Mesh"]
        Knative["Knative Serving"]
        CertMgr["cert-manager"]
        GatewayAPI["Gateway API"]
        KEDA_Ext["KEDA"]
    end

    ControllerMgr -->|VirtualService, mTLS| Istio
    ControllerMgr -->|Knative Service| Knative
    LLMController -->|DestinationRule| Istio
    LLMController -->|HTTPRoute| GatewayAPI
    LLMController -->|ScaledObject| KEDA_Ext

    %% Internal platform
    subgraph Platform["Internal Platform"]
        ODHOperator["rhods-operator"]
        ODHModelCtrl["odh-model-controller"]
        WVA["Workload Variant Autoscaler"]
        vLLM["vLLM Runtime"]
    end

    ODHOperator -->|creates| KserveCR
    ModuleCtrl -.->|deploys| ODHModelCtrl
    ModuleCtrl -.->|deploys| WVA
    LLMISVC -->|uses| vLLM

