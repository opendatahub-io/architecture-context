graph TB
    subgraph KServe["KServe Platform (serving.kserve.io)"]
        direction TB

        subgraph Controllers["Controllers (kserve namespace)"]
            KServeCtrl["kserve-controller<br/>Go Operator<br/>Ports: 8080, 9443, 8081"]
            LLMISVCCtrl["llmisvc-controller<br/>Go Operator<br/>Ports: 8080, 9443, 8081"]
            LocalModelCtrl["localmodel-controller<br/>Go Operator<br/>Ports: 8080, 9443, 8081"]
        end

        subgraph NodeAgents["Per-Node Agents"]
            LocalModelAgent["localmodelnode-agent<br/>Go Agent (DaemonSet)<br/>No network ports"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            Agent["kserve-agent<br/>Go Sidecar<br/>Port: 9081"]
            StorageInit["storage-initializer<br/>Python Init Container<br/>No network ports"]
        end

        subgraph UtilityServices["Utility Services"]
            Router["kserve-router<br/>Go Service<br/>Port: 8080"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>v1beta1"]
        IG["InferenceGraph<br/>v1alpha1"]
        TM["TrainedModel<br/>v1alpha1"]
        LLMISVC["LLMInferenceService<br/>v1alpha2"]
        LLMISVCConfig["LLMInferenceServiceConfig<br/>v1alpha2"]
        SR["ServingRuntime<br/>v1alpha1"]
        CSR["ClusterServingRuntime<br/>v1alpha1"]
        CSC["ClusterStorageContainer<br/>v1alpha1"]
        LMC["LocalModelCache<br/>v1alpha1"]
        LMNSC["LocalModelNamespaceCache<br/>v1alpha1"]
        LMNG["LocalModelNodeGroup<br/>v1alpha1"]
        LMN["LocalModelNode<br/>v1alpha1"]
    end

    %% Controller → CRD relationships
    KServeCtrl -->|"watches/reconciles"| ISVC
    KServeCtrl -->|"watches/reconciles"| IG
    KServeCtrl -->|"watches/reconciles"| TM
    KServeCtrl -->|"watches"| SR
    KServeCtrl -->|"watches"| CSR
    KServeCtrl -->|"watches"| CSC
    LLMISVCCtrl -->|"watches/reconciles"| LLMISVC
    LLMISVCCtrl -->|"watches"| LLMISVCConfig
    LocalModelCtrl -->|"watches/reconciles"| LMC
    LocalModelCtrl -->|"watches/reconciles"| LMNSC
    LocalModelCtrl -->|"creates"| LMN
    LocalModelAgent -->|"watches/reconciles"| LMN
    LocalModelAgent -->|"watches"| LMNG
    LocalModelAgent -->|"watches"| CSC

    %% Controller → K8s Resources
    KServeCtrl -->|"creates"| Deployments["Deployments<br/>Services, HPAs"]
    KServeCtrl -->|"creates"| KnativeSvc["Knative Services"]
    KServeCtrl -->|"creates"| VirtualSvc["VirtualServices"]
    KServeCtrl -->|"creates"| HTTPRoutes["HTTPRoutes"]

    LLMISVCCtrl -->|"creates"| LWSets["LeaderWorkerSets"]
    LLMISVCCtrl -->|"creates"| InfPools["InferencePools"]
    LLMISVCCtrl -->|"creates"| ScaledObj["ScaledObjects (KEDA)"]
    LLMISVCCtrl -->|"creates"| VarAutoScale["VariantAutoscaling (WVA)"]
    LLMISVCCtrl -->|"creates"| PodMon["PodMonitors"]

    LocalModelCtrl -->|"creates"| PVPVC["PersistentVolumes<br/>PersistentVolumeClaims"]
    LocalModelAgent -->|"creates"| DownloadJobs["Download Jobs"]

    %% Webhook injection
    KServeCtrl -->|"mutating webhook<br/>injects"| Agent
    KServeCtrl -->|"mutating webhook<br/>injects"| StorageInit

    %% Router relationship
    IG -->|"deploys"| Router
    Router -->|"routes to"| ISVC

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISVCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelAgent fill:#4a90e2,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style Router fill:#9b59b6,stroke:#333,color:#fff

    style ISVC fill:#f5a623,stroke:#333,color:#000
