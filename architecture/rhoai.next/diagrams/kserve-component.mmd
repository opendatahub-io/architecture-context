graph TB
    subgraph KServe["KServe Platform (serving.kserve.io)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller<br/>Go Operator<br/>8080/TCP metrics, 9443/TCP webhook"]
            LLMISVCCtrl["llmisvc-controller<br/>Go Operator<br/>8443/TCP metrics, 9443/TCP webhook"]
            LocalModelCtrl["localmodel-controller<br/>Go Operator<br/>8080/TCP metrics, 9443/TCP webhook"]
            LocalModelAgent["localmodelnode-agent<br/>Go DaemonSet<br/>8080/TCP metrics"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            Agent["kserve-agent<br/>Sidecar Proxy<br/>9081/TCP proxy"]
            StorageInit["storage-initializer<br/>Python Init Container<br/>S3/GCS/Azure/HF/HDFS"]
            KubeRBACProxy["kube-rbac-proxy<br/>Auth Sidecar<br/>8443/TCP HTTPS"]
        end

        subgraph Routing["Routing"]
            Router["kserve-router<br/>InferenceGraph Handler<br/>8080/TCP HTTP"]
        end

        subgraph SDK["Python SDK"]
            ModelServer["KServe Model Server<br/>V1/V2/OpenAI REST + gRPC<br/>8080/TCP HTTP, 8081/TCP gRPC"]
        end
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>(v1beta1)"]
        LLMISVC["LLMInferenceService<br/>(v1alpha1/v1alpha2)"]
        IG["InferenceGraph<br/>(v1alpha1)"]
        LMCache["LocalModelCache<br/>(v1alpha1)"]
        SR["ServingRuntime<br/>(v1alpha1)"]
        TM["TrainedModel<br/>(v1alpha1)"]
    end

    %% Controller → CRD relationships
    ISVC -->|watched by| KServeCtrl
    LLMISVC -->|watched by| LLMISVCCtrl
    IG -->|watched by| KServeCtrl
    LMCache -->|watched by| LocalModelCtrl
    SR -->|fetched by| KServeCtrl
    TM -->|watched by| KServeCtrl

    %% Controller creates resources
    KServeCtrl -->|creates| KnativeSvc["Knative Service"]
    KServeCtrl -->|creates| K8sDeploy["Deployment"]
    KServeCtrl -->|creates| K8sSvc["Service"]
    KServeCtrl -->|creates| HTTPRouteISVC["HTTPRoute / Ingress<br/>/ VirtualService"]
    KServeCtrl -->|creates| HPA["HPA / ScaledObject"]

    LLMISVCCtrl -->|creates| LLMDeploy["LLM Deployment<br/>/ LeaderWorkerSet"]
    LLMISVCCtrl -->|creates| HTTPRouteLLM["HTTPRoute"]
    LLMISVCCtrl -->|creates| InfPool["InferencePool"]
    LLMISVCCtrl -->|creates| EPPDeploy["Scheduler EPP<br/>Deployment"]
    LLMISVCCtrl -->|creates| DestRule["Istio DestinationRule"]
    LLMISVCCtrl -->|creates| VarAutoScale["VariantAutoscaling"]

    LocalModelCtrl -->|creates| PV["PersistentVolume"]
    LocalModelCtrl -->|creates| PVC["PersistentVolumeClaim"]
    LocalModelAgent -->|creates| DLJob["Download Job"]

    %% Sidecar injection
    KServeCtrl -.->|injects| Agent
    KServeCtrl -.->|injects| StorageInit
    KServeCtrl -.->|injects| KubeRBACProxy

    %% Router relationships
    Router -->|routes to| ISVC

    %% Styling
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef sidecar fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef crd fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#7ed321,stroke:#333,stroke-width:1px
    classDef routing fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef sdk fill:#1abc9c,stroke:#333,stroke-width:2px,color:#fff

    class KServeCtrl,LLMISVCCtrl,LocalModelCtrl,LocalModelAgent controller
    class Agent,StorageInit,KubeRBACProxy sidecar
    class ISVC,LLMISVC,IG,LMCache,SR,TM crd
    class KnativeSvc,K8sDeploy,K8sSvc,HTTPRouteISVC,HPA,LLMDeploy,HTTPRouteLLM,InfPool,EPPDeploy,DestRule,VarAutoScale,PV,PVC,DLJob resource
    class Router routing
    class ModelServer sdk
