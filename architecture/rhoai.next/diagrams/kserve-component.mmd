    style ControllerMgr fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    style LLMController fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    style LocalModelCtrl fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    style ModuleCtrl fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
