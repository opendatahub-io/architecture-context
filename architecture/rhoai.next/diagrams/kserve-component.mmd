    style LMNG fill:#f5a623,stroke:#333,color:#000
    style LMN fill:#f5a623,stroke:#333,color:#000

    style Deployments fill:#e8e8e8,stroke:#333
    style KnativeSvc fill:#e8e8e8,stroke:#333
    style VirtualSvc fill:#e8e8e8,stroke:#333
    style HTTPRoutes fill:#e8e8e8,stroke:#333
    style LWSets fill:#e8e8e8,stroke:#333
    style InfPools fill:#e8e8e8,stroke:#333
    style ScaledObj fill:#e8e8e8,stroke:#333
    style VarAutoScale fill:#e8e8e8,stroke:#333
    style PodMon fill:#e8e8e8,stroke:#333
