graph TB
    subgraph KServe["KServe Platform (opendatahub namespace)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller<br/>(Go Operator)<br/>8080/TCP metrics<br/>9443/TCP webhook<br/>8081/TCP health"]
            LLMISVCCtrl["llmisvc-controller<br/>(Go Operator)<br/>8080/TCP metrics<br/>9443/TCP webhook<br/>8081/TCP health"]
            LocalModelCtrl["localmodel-controller<br/>(Go Operator)<br/>8080/TCP metrics<br/>9443/TCP webhook<br/>8081/TCP health"]
        end

        subgraph Agents["Agents & Sidecars"]
            LocalModelAgent["localmodelnode-agent<br/>(Per-Node DaemonSet)<br/>No network ports"]
            KServeAgent["kserve-agent<br/>(Sidecar)<br/>9081/TCP proxy"]
        end

        subgraph Utilities["Utility Services"]
            Router["kserve-router<br/>(Per InferenceGraph)<br/>8080/TCP HTTP/HTTPS"]
            StorageInit["storage-initializer<br/>(Python Init Container)<br/>No network ports"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>(v1beta1)"]
        IG["InferenceGraph<br/>(v1alpha1)"]
        TM["TrainedModel<br/>(v1alpha1)"]
        SR["ServingRuntime<br/>(v1alpha1)"]
        CSR["ClusterServingRuntime<br/>(v1alpha1)"]
        CSC["ClusterStorageContainer<br/>(v1alpha1)"]
        LLMISVC["LLMInferenceService<br/>(v1alpha2)"]
        LLMISVCConfig["LLMInferenceServiceConfig<br/>(v1alpha2)"]
        LMC["LocalModelCache<br/>(v1alpha1)"]
        LMNSC["LocalModelNamespaceCache<br/>(v1alpha1)"]
        LMNG["LocalModelNodeGroup<br/>(v1alpha1)"]
        LMN["LocalModelNode<br/>(v1alpha1)"]
    end

    %% Controller → CRD relationships
    ISVC -->|watched by| KServeCtrl
    IG -->|watched by| KServeCtrl
    TM -->|watched by| KServeCtrl
    SR -->|watched by| KServeCtrl
    CSR -->|watched by| KServeCtrl
    CSC -->|watched by| KServeCtrl

    LLMISVC -->|watched by| LLMISVCCtrl
    LLMISVCConfig -->|watched by| LLMISVCCtrl

    LMC -->|watched by| LocalModelCtrl
    LMNSC -->|watched by| LocalModelCtrl
    LMN -->|reconciled by| LocalModelAgent

    %% Controller creates resources
    KServeCtrl -->|creates| Deployments["Deployments<br/>Services<br/>HPAs"]
    KServeCtrl -->|creates| IngressRes["VirtualServices<br/>HTTPRoutes<br/>Ingresses"]
    KServeCtrl -->|injects| KServeAgent
    KServeCtrl -->|injects| StorageInit

    LLMISVCCtrl -->|creates| LWSRes["LeaderWorkerSets<br/>Deployments<br/>HTTPRoutes<br/>InferencePools"]
    LLMISVCCtrl -->|creates| ScalingRes["ScaledObjects<br/>VariantAutoscaling<br/>HPAs"]

    LocalModelCtrl -->|creates| PVRes["PersistentVolumes<br/>PersistentVolumeClaims<br/>LocalModelNodes"]
    LocalModelAgent -->|creates| Jobs["Download Jobs"]

    %% Router connections
    IG -->|deploys| Router
    Router -->|routes to| ISVC

    %% User interaction
    User["Data Scientist / ML Engineer"] -->|creates| ISVC
    User -->|creates| LLMISVC
    User -->|creates| IG
    User -->|creates| LMC

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISVCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelAgent fill:#50a0d0,stroke:#333,color:#fff
    style KServeAgent fill:#50a0d0,stroke:#333,color:#fff
    style Router fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#fff
    style IG fill:#f5a623,stroke:#333,color:#fff
    style TM fill:#f5a623,stroke:#333,color:#fff
    style SR fill:#f5a623,stroke:#333,color:#fff
    style CSR fill:#f5a623,stroke:#333,color:#fff
    style CSC fill:#f5a623,stroke:#333,color:#fff
    style LLMISVC fill:#f5a623,stroke:#333,color:#fff
    style LLMISVCConfig fill:#f5a623,stroke:#333,color:#fff
    style LMC fill:#f5a623,stroke:#333,color:#fff
    style LMNSC fill:#f5a623,stroke:#333,color:#fff
    style LMNG fill:#f5a623,stroke:#333,color:#fff
    style LMN fill:#f5a623,stroke:#333,color:#fff
    style User fill:#e8e8e8,stroke:#333
    style Deployments fill:#d5e8d4,stroke:#82b366
    style IngressRes fill:#d5e8d4,stroke:#82b366
    style LWSRes fill:#d5e8d4,stroke:#82b366
    style ScalingRes fill:#d5e8d4,stroke:#82b366
    style PVRes fill:#d5e8d4,stroke:#82b366
    style Jobs fill:#d5e8d4,stroke:#82b366
