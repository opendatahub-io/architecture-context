graph TB
    subgraph KServe["KServe Platform (kserve namespace)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller-manager<br/><i>Go Operator (controller-runtime)</i><br/>Webhook: 9443/TCP | Metrics: 8080/TCP"]
            LLMISVCCtrl["llmisvc-controller-manager<br/><i>Go Operator (controller-runtime)</i><br/>Webhook: 9443/TCP | Metrics: 8443/TCP"]
            LocalModelCtrl["localmodel-controller<br/><i>Go Operator (controller-runtime)</i>"]
        end

        subgraph NodeAgents["Node Agents"]
            LocalModelAgent["localmodelnode-agent<br/><i>DaemonSet</i><br/>Manages per-node model downloads"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            StorageInit["storage-initializer<br/><i>Python Init Container</i><br/>Downloads models from S3/GCS/Azure/HF/OCI"]
            Agent["agent<br/><i>Go Sidecar</i><br/>Logging: 9081/TCP | Batching: 9082/TCP"]
        end

        subgraph Routing["Routing"]
            Router["router<br/><i>Go Service</i><br/>InferenceGraph routing: 8080/TCP<br/>Sequence | Splitter | Ensemble | Switch"]
        end
    end

    %% CRDs watched by controllers
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/><i>v1beta1</i>"]
        LLMISVC["LLMInferenceService<br/><i>v1alpha2</i>"]
        LLMISVCConfig["LLMInferenceServiceConfig<br/><i>v1alpha2, Cluster</i>"]
        IG["InferenceGraph<br/><i>v1alpha1</i>"]
        SR["ServingRuntime<br/><i>v1alpha1</i>"]
        CSR["ClusterServingRuntime<br/><i>v1alpha1, Cluster</i>"]
        TM["TrainedModel<br/><i>v1alpha1</i>"]
        LMC["LocalModelCache<br/><i>v1alpha1, Cluster</i>"]
        LMNC["LocalModelNamespaceCache<br/><i>v1alpha1</i>"]
        LMN["LocalModelNode<br/><i>v1alpha1, Cluster</i>"]
    end

    %% Controller → CRD relationships
    KServeCtrl -->|reconciles| ISVC
    KServeCtrl -->|reconciles| IG
    KServeCtrl -->|reconciles| TM
    KServeCtrl -->|reads| SR
    KServeCtrl -->|reads| CSR

    LLMISVCCtrl -->|reconciles| LLMISVC
    LLMISVCCtrl -->|reads| LLMISVCConfig

    LocalModelCtrl -->|reconciles| LMC
    LocalModelCtrl -->|reconciles| LMNC
    LocalModelAgent -->|reconciles| LMN

    %% Resources created
    KServeCtrl -->|creates| Deployments["Deployments<br/>Services<br/>HPA / KEDA"]
    KServeCtrl -->|creates| IngressResources["HTTPRoutes<br/>VirtualServices<br/>Ingresses"]

    LLMISVCCtrl -->|creates| LWSets["LeaderWorkerSets<br/>Deployments<br/>InferencePools"]
    LLMISVCCtrl -->|creates| LLMRoutes["HTTPRoutes<br/>DestinationRules"]
    LLMISVCCtrl -->|creates| Scaling["WVA VariantAutoscaling<br/>HPA / KEDA ScaledObjects"]

    LocalModelCtrl -->|creates| PVs["PersistentVolumes<br/>PersistentVolumeClaims<br/>Download Jobs"]

    %% Webhook injection
    KServeCtrl -.->|pod mutator injects| StorageInit
    KServeCtrl -.->|pod mutator injects| Agent

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISVCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelAgent fill:#7b68ee,stroke:#333,color:#fff
    style StorageInit fill:#e8a838,stroke:#333,color:#fff
    style Agent fill:#e8a838,stroke:#333,color:#fff
    style Router fill:#50c878,stroke:#333,color:#fff

    style ISVC fill:#f5a623,stroke:#333
    style LLMISVC fill:#f5a623,stroke:#333
    style LLMISVCConfig fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333
    style CSR fill:#f5a623,stroke:#333
    style TM fill:#f5a623,stroke:#333
    style LMC fill:#f5a623,stroke:#333
    style LMNC fill:#f5a623,stroke:#333
    style LMN fill:#f5a623,stroke:#333

    style Deployments fill:#d4edda,stroke:#333
    style IngressResources fill:#d4edda,stroke:#333
    style LWSets fill:#d4edda,stroke:#333
    style LLMRoutes fill:#d4edda,stroke:#333
    style Scaling fill:#d4edda,stroke:#333
    style PVs fill:#d4edda,stroke:#333
