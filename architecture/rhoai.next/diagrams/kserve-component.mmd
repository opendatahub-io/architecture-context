graph TB
    subgraph KServe["KServe Platform"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller-manager<br/><i>Go Operator</i><br/>InferenceService, InferenceGraph,<br/>TrainedModel reconciliation"]
            LLMCtrl["llmisvc-controller-manager<br/><i>Go Operator</i><br/>LLMInferenceService with<br/>disaggregated serving"]
            LocalModelCtrl["localmodel-controller<br/><i>Go Operator</i><br/>LocalModelCache &amp;<br/>LocalModelNamespaceCache"]
            ModuleCtrl["kserve-module-controller<br/><i>Go Operator</i><br/>ODH platform lifecycle<br/>via Kserve CR"]
        end

        subgraph NodeAgents["Node Agents"]
            NodeAgent["localmodelnode-agent<br/><i>Go DaemonSet</i><br/>Per-node model downloads<br/>PV/PVC lifecycle"]
        end

        subgraph Sidecars["Injected Sidecars &amp; Init Containers"]
            StorageInit["storage-initializer<br/><i>Python Init Container</i><br/>S3/GCS/Azure/HF/OCI<br/>model downloads"]
            Agent["inference-agent<br/><i>Go Sidecar</i><br/>Logging, batching,<br/>request capture"]
            QPExt["qpext<br/><i>Go Extension</i><br/>Knative metrics<br/>aggregation"]
        end

        subgraph Routing["Routing"]
            Router["inference-router<br/><i>Go Service</i><br/>InferenceGraph DAG routing:<br/>Sequence, Splitter, Ensemble, Switch"]
        end

        Webhook["Webhook Server<br/><i>9443/TCP HTTPS</i><br/>4 mutating + 11 validating<br/>+ 1 conversion webhook"]
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/><i>v1beta1 Namespaced</i>"]
        LLMISVC["LLMInferenceService<br/><i>v1alpha2 Namespaced</i>"]
        IG["InferenceGraph<br/><i>v1alpha1 Namespaced</i>"]
        LMC["LocalModelCache<br/><i>v1alpha1 Cluster</i>"]
        SR["ServingRuntime<br/><i>v1alpha1 Namespaced</i>"]
        TM["TrainedModel<br/><i>v1alpha1 Namespaced</i>"]
        KserveCR["Kserve CR<br/><i>v1alpha1 Cluster</i>"]
    end

    %% User interactions
    User["Data Scientist / User"] -->|creates| ISVC
    User -->|creates| LLMISVC
    User -->|creates| IG

    %% Controller watches
    ISVC -->|watched by| KServeCtrl
    LLMISVC -->|watched by| LLMCtrl
    IG -->|watched by| KServeCtrl
    LMC -->|watched by| LocalModelCtrl
    TM -->|watched by| KServeCtrl
    KserveCR -->|watched by| ModuleCtrl

    %% Controller creates
    KServeCtrl -->|creates| Deployments["Deployments<br/>Services<br/>HTTPRoutes"]
    LLMCtrl -->|creates| LLMResources["Deployments / LWS<br/>HTTPRoutes<br/>InferencePools<br/>ScaledObjects"]
    LocalModelCtrl -->|creates| PVs["PVs / PVCs<br/>Download Jobs"]

    %% Webhook validates/mutates
    KServeCtrl -->|registers| Webhook
    LLMCtrl -->|registers| Webhook

    %% Sidecar injection
    Webhook -->|injects| StorageInit
    Webhook -->|injects| Agent

    %% External dependencies
    subgraph External["External Dependencies"]
        Knative["Knative Serving"]
        Istio["Istio / Service Mesh"]
        GatewayAPI["Gateway API"]
        KEDA["KEDA"]
        OTel["OpenTelemetry Operator"]
    end

    KServeCtrl -->|serverless mode| Knative
    KServeCtrl -->|ingress routing| Istio
    KServeCtrl -->|raw mode ingress| GatewayAPI
    LLMCtrl -->|autoscaling| KEDA
    LLMCtrl -->|metrics pipeline| OTel
    LLMCtrl -->|ingress| GatewayAPI

    %% Cloud storage
    CloudStorage["Cloud Storage<br/>S3 / GCS / Azure / HF"]
    StorageInit -->|downloads models| CloudStorage

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style ModuleCtrl fill:#4a90e2,stroke:#333,color:#fff
    style NodeAgent fill:#4a90e2,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style QPExt fill:#50c878,stroke:#333,color:#fff
    style Router fill:#9b59b6,stroke:#333,color:#fff
    style Webhook fill:#e67e22,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333
    style LLMISVC fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333
    style LMC fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333
    style TM fill:#f5a623,stroke:#333
    style KserveCR fill:#f5a623,stroke:#333
    style Knative fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style CloudStorage fill:#e8e8e8,stroke:#333
