graph TB
    subgraph KServe["KServe Platform (serving.kserve.io)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller<br/>(Go Operator)<br/>Ports: 8080, 9443, 8081"]
            LLMISVCCtrl["llmisvc-controller<br/>(Go Operator)<br/>Ports: 8080, 9443, 8081"]
            LocalModelCtrl["localmodel-controller<br/>(Go Operator)<br/>Ports: 8080, 9443, 8081"]
        end

        subgraph Agents["Agents & Sidecars"]
            LocalModelAgent["localmodelnode-agent<br/>(Go Agent / DaemonSet)<br/>Per-node model mgmt"]
            KServeAgent["kserve-agent<br/>(Go Sidecar)<br/>Port: 9081 proxy"]
        end

        subgraph Utilities["Utility Services"]
            Router["kserve-router<br/>(Go Service)<br/>Port: 8080<br/>InferenceGraph DAG routing"]
            StorageInit["storage-initializer<br/>(Python 3.11 Init Container)<br/>Model download from cloud storage"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/>(v1beta1)"]
        IG["InferenceGraph<br/>(v1alpha1)"]
        TM["TrainedModel<br/>(v1alpha1)"]
        SR["ServingRuntime<br/>(v1alpha1)"]
        CSR["ClusterServingRuntime<br/>(v1alpha1)"]
        CSC["ClusterStorageContainer<br/>(v1alpha1)"]
        LLMISVC["LLMInferenceService<br/>(v1alpha2)"]
        LMC["LocalModelCache<br/>(v1alpha1)"]
        LMNSC["LocalModelNamespaceCache<br/>(v1alpha1)"]
        LMN["LocalModelNode<br/>(v1alpha1)"]
    end

    %% Controller → CRD relationships
    KServeCtrl -->|reconciles| ISVC
    KServeCtrl -->|reconciles| IG
    KServeCtrl -->|reconciles| TM
    KServeCtrl -->|watches| SR
    KServeCtrl -->|watches| CSR
    KServeCtrl -->|watches| CSC
    LLMISVCCtrl -->|reconciles| LLMISVC
    LocalModelCtrl -->|reconciles| LMC
    LocalModelCtrl -->|reconciles| LMNSC
    LocalModelCtrl -->|creates| LMN
    LocalModelAgent -->|reconciles| LMN

    %% CRD → Created Resources
    KServeCtrl -->|creates| Deploy["Deployments"]
    KServeCtrl -->|creates| KnSvc["Knative Services"]
    KServeCtrl -->|creates| VS["VirtualServices"]
    KServeCtrl -->|creates| HR["HTTPRoutes"]
    KServeCtrl -->|creates| HPA["HPAs"]
    LLMISVCCtrl -->|creates| LWS["LeaderWorkerSets"]
    LLMISVCCtrl -->|creates| IP["InferencePools"]
    LLMISVCCtrl -->|creates| SO["ScaledObjects (KEDA)"]
    LLMISVCCtrl -->|creates| VA["VariantAutoscaling"]
    LocalModelCtrl -->|creates| PV["PVs / PVCs"]
    LocalModelAgent -->|creates| Jobs["Download Jobs"]

    %% Sidecar injection
    KServeCtrl -->|injects via webhook| KServeAgent
    KServeCtrl -->|injects via webhook| StorageInit

    %% Router relationship
    Router -->|routes to| ISVC

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISVCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LocalModelAgent fill:#50c878,stroke:#333,color:#fff
    style KServeAgent fill:#50c878,stroke:#333,color:#fff
    style Router fill:#9b59b6,stroke:#333,color:#fff
    style StorageInit fill:#9b59b6,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#000
    style IG fill:#f5a623,stroke:#333,color:#000
    style TM fill:#f5a623,stroke:#333,color:#000
    style LLMISVC fill:#f5a623,stroke:#333,color:#000
    style LMC fill:#f5a623,stroke:#333,color:#000
    style LMNSC fill:#f5a623,stroke:#333,color:#000
    style LMN fill:#f5a623,stroke:#333,color:#000
    style SR fill:#f5d76e,stroke:#333,color:#000
    style CSR fill:#f5d76e,stroke:#333,color:#000
    style CSC fill:#f5d76e,stroke:#333,color:#000
