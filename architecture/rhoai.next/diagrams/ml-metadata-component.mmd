graph TB
    subgraph MLMDComponent["ML Metadata (MLMD) Component"]
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port: 8080/TCP"]
        ProtoAPI["Protocol Buffer Definitions<br/>(API Schema)<br/>46 RPCs"]
        Server -->|"implements"| ProtoAPI
    end

    subgraph Clients["gRPC Clients"]
        DSP["Data Science Pipelines<br/>(DSP)"]
        KFUI["Kubeflow Pipelines UI"]
        PythonLib["ml-metadata<br/>Python Client Library"]
    end

    subgraph Backends["Database Backends"]
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(In-Process)"]
    end

    DSP -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional TLS/mTLS"| Server
    KFUI -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional TLS"| Server
    PythonLib -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    Server -->|"MySQL protocol<br/>3306/TCP<br/>Optional SSL"| MySQL
    Server -->|"PostgreSQL protocol<br/>5432/TCP<br/>Optional SSL"| PostgreSQL
    Server -->|"In-process"| SQLite

    subgraph RPCGroups["MetadataStoreService RPCs"]
        direction LR
        TypeMgmt["Type Management<br/>(12 RPCs)"]
        NodeMgmt["Node Management<br/>(15 RPCs)"]
        ExtID["External ID Queries<br/>(6 RPCs)"]
        RelMgmt["Relationship Mgmt<br/>(7 RPCs)"]
        Lineage["Lineage<br/>(3 RPCs)"]
    end

    ProtoAPI --- RPCGroups

