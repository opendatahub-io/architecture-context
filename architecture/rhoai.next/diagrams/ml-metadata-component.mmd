graph TB
    subgraph "ML Metadata (MLMD) Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        Core["metadata_store (core)<br/>(C++ Library)<br/>DB Access & Transactions"]
        QueryEngine["Query Engine<br/>(C++ Library)<br/>ZetaSQL Filter Parsing"]
        Server -->|"delegates persistence"| Core
        Core -->|"constructs SQL queries"| QueryEngine
    end

    subgraph "Client Libraries"
        PythonLib["ml_metadata<br/>(Python Library / PyPI)<br/>Bazel-built C++ extensions"]
    end

    DSP["Data Science Pipelines<br/>(DSP Driver)"] -->|"gRPC/8080<br/>PutExecution, PutArtifacts"| Server
    TFX["TFX / Kubeflow Pipelines"] -->|"gRPC/8080<br/>Lineage Recording"| Server
    PipelineUI["ML Pipeline UI / Client"] -->|"gRPC/8080<br/>GetLineageSubgraph"| Server
    PythonLib -->|"gRPC/8080<br/>MetadataStoreService API"| Server

    Core -->|"SQL/3306<br/>MySQL wire protocol"| MySQL["MySQL / MariaDB"]
    Core -->|"SQL<br/>PostgreSQL wire protocol"| PostgreSQL["PostgreSQL"]
    Core -->|"SQL<br/>Embedded"| SQLite["SQLite<br/>(Dev/Test only)"]

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Core fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style QueryEngine fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PythonLib fill:#6cb4ee,stroke:#333,stroke-width:2px
    style DSP fill:#7ed321,stroke:#333,stroke-width:2px
    style TFX fill:#7ed321,stroke:#333,stroke-width:2px
    style PipelineUI fill:#7ed321,stroke:#333,stroke-width:2px
    style MySQL fill:#f5a623,stroke:#333,stroke-width:2px
    style PostgreSQL fill:#f5a623,stroke:#333,stroke-width:2px
    style SQLite fill:#e8e8e8,stroke:#333,stroke-width:2px
