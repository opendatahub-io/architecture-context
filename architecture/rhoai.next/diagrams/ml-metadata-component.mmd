graph TB
    subgraph "ML Metadata (MLMD) Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        ProtoAPI["Protocol Buffer Definitions<br/>(API Schema)<br/>metadata_store_service.proto"]
        ProtoModel["Data Model Protos<br/>Artifact, Execution,<br/>Context, Event"]
        Server --- ProtoAPI
        ProtoAPI --- ProtoModel
    end

    subgraph "Python Client"
        PythonLib["ml-metadata<br/>Python Client Library<br/>(PyPI package)"]
    end

    DSP["Data Science Pipelines<br/>(DSP)"] -->|"gRPC/8080<br/>PutArtifacts, PutExecutions,<br/>PutEvents, PutContexts"| Server
    PipelinesUI["Kubeflow Pipelines UI"] -->|"gRPC/8080<br/>GetLineageSubgraph,<br/>GetArtifactsByContext"| Server
    PythonLib -->|"gRPC/8080<br/>MetadataStoreService RPCs"| Server

    Server -->|"MySQL protocol/3306<br/>Metadata persistence"| MySQL["MySQL / MariaDB<br/>Database"]
    Server -->|"PostgreSQL protocol/5432<br/>Metadata persistence"| PostgreSQL["PostgreSQL<br/>Database"]
    Server -.->|"In-process<br/>(dev/test only)"| SQLite["SQLite"]

    Operator["Platform Operator<br/>(rhods-operator)"] -->|"deploys & configures"| Server

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ProtoAPI fill:#4a90e2,stroke:#333,color:#fff
    style ProtoModel fill:#4a90e2,stroke:#333,color:#fff
    style PythonLib fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelinesUI fill:#7ed321,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#e8e8e8,stroke:#333
    style Operator fill:#9b59b6,stroke:#333,color:#fff
