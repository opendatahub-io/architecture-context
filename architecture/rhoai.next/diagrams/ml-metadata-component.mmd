graph TB
    subgraph "ML Metadata (MLMD) Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        MetadataStore["MetadataStore<br/>(Business Logic Layer)"]
        DBLayer["Database Access Layer<br/>(Pluggable Backend)"]
        Proto["MetadataStoreService.proto<br/>(40+ RPC Methods)"]

        Proto -->|defines API| Server
        Server -->|delegates to| MetadataStore
        MetadataStore -->|queries via| DBLayer
    end

    subgraph "Python Client"
        PythonLib["ml-metadata<br/>(Python Client Library)<br/>pybind11 + gRPC"]
    end

    subgraph "Consumers"
        KFP["Kubeflow Pipelines<br/>(ml-pipeline-api-server)"]
        KFPSDK["Kubeflow Pipelines SDK<br/>(Python)"]
        DSP["Data Science Pipelines<br/>(RHOAI)"]
        PipelineUI["Pipeline UI / Client"]
    end

    subgraph "Database Backends"
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(Embedded / In-Memory)"]
    end

    KFP -->|gRPC/8080<br/>Optional TLS| Server
    KFPSDK -->|gRPC via| PythonLib
    PythonLib -->|gRPC/8080<br/>Optional TLS| Server
    DSP -->|gRPC/8080<br/>Optional TLS| Server
    PipelineUI -->|gRPC/8080<br/>Optional TLS| Server

    DBLayer -->|MySQL protocol<br/>Optional TLS| MySQL
    DBLayer -->|PostgreSQL protocol<br/>Optional TLS| PostgreSQL
    DBLayer -->|Embedded| SQLite

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style MetadataStore fill:#4a90e2,stroke:#333,color:#fff
    style DBLayer fill:#4a90e2,stroke:#333,color:#fff
    style Proto fill:#4a90e2,stroke:#333,color:#fff
    style PythonLib fill:#6c5ce7,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style PipelineUI fill:#7ed321,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333
