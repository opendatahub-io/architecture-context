graph TB
    subgraph "ML Metadata (MLMD) Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        Proto["Protocol Buffer Definitions<br/>(API Schema)<br/>Artifact, Execution, Context, Event"]
        PythonLib["ml-metadata Python Library<br/>(Client Library)<br/>PyPI package"]

        Proto -->|defines API for| Server
        Proto -->|generates stubs for| PythonLib
    end

    subgraph "gRPC API (46 RPCs)"
        direction TB
        TypeMgmt["Type Management<br/>(12 RPCs)<br/>PutArtifactType, GetArtifactType, ..."]
        NodeMgmt["Node Management<br/>(15 RPCs)<br/>PutArtifacts, GetArtifacts, ..."]
        RelMgmt["Relationship Management<br/>(7 RPCs)<br/>PutEvents, PutAttributions, ..."]
        ExtIDQuery["External ID Queries<br/>(6 RPCs)"]
        LineageAPI["Lineage<br/>(3 RPCs)<br/>GetLineageSubgraph, ..."]
    end

    Server --- TypeMgmt
    Server --- NodeMgmt
    Server --- RelMgmt
    Server --- ExtIDQuery
    Server --- LineageAPI

    DSP["Data Science Pipelines<br/>(gRPC Client)"] -->|gRPC/8080<br/>Metadata CRUD| Server
    KFUI["Kubeflow Pipelines UI<br/>(gRPC Client)"] -->|gRPC/8080<br/>Lineage Queries| Server

    Server -->|3306/TCP<br/>MySQL Protocol| MySQL["MySQL / MariaDB<br/>(Primary Backend)"]
    Server -->|5432/TCP<br/>PostgreSQL Protocol| PostgreSQL["PostgreSQL<br/>(Alternative Backend)"]
    Server -->|In-process| SQLite["SQLite<br/>(Dev/Testing)"]

    style Server fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Proto fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PythonLib fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style TypeMgmt fill:#d5e8d4,stroke:#82b366
    style NodeMgmt fill:#d5e8d4,stroke:#82b366
    style RelMgmt fill:#d5e8d4,stroke:#82b366
    style ExtIDQuery fill:#d5e8d4,stroke:#82b366
    style LineageAPI fill:#d5e8d4,stroke:#82b366
    style DSP fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style KFUI fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style MySQL fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style SQLite fill:#f5a623,stroke:#333,stroke-width:2px
