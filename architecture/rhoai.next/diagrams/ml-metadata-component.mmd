graph TB
    subgraph "ML Metadata Component"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        Proto["MetadataStoreService Proto<br/>(40+ RPC Methods)<br/>Protocol Buffers"]
        PythonClient["ml-metadata Python Client<br/>(pybind11 + gRPC)<br/>PyPI Package"]

        Proto -->|"defines API"| Server
        PythonClient -->|"gRPC calls"| Server
    end

    subgraph "Clients"
        KFP["Kubeflow Pipelines<br/>ml-pipeline-api-server"]
        KFPSDK["KFP SDK<br/>(Python)"]
        DSP["Data Science Pipelines<br/>(RHOAI)"]
        PipelineUI["Pipeline UI / Client"]
    end

    subgraph "Database Backends"
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(Embedded, Optional)"]
    end

    KFP -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    KFPSDK -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    DSP -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    PipelineUI -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    Server -->|"MySQL Protocol<br/>Optional TLS"| MySQL
    Server -->|"PostgreSQL Protocol<br/>Optional TLS"| PostgreSQL
    Server -->|"Embedded"| SQLite

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style Proto fill:#4a90e2,stroke:#333,color:#fff
    style PythonClient fill:#4a90e2,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff
    style KFPSDK fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelineUI fill:#7ed321,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#e8e8e8,stroke:#333
