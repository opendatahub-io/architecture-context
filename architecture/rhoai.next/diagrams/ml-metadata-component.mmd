graph TB
    subgraph MLMD["ML Metadata (MLMD) Service"]
        direction TB
        Server["metadata_store_server<br/><i>C++ gRPC Service</i><br/>Port 8080/TCP"]
        Core["metadata_store (core)<br/><i>C++ Library</i><br/>CRUD, transactions,<br/>concurrency control"]
        QueryEngine["query engine<br/><i>C++ Library</i><br/>ZetaSQL filter parsing,<br/>SQL construction"]
        Server --> Core
        Core --> QueryEngine
    end

    subgraph Clients["gRPC Clients"]
        DSP["Data Science Pipelines<br/>(DSP Driver)"]
        TFX["TFX / Kubeflow Pipelines<br/>(Legacy)"]
        PythonLib["ml_metadata<br/>Python Library<br/><i>PyPI client</i>"]
    end

    subgraph Storage["Database Backends"]
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>Configurable/TCP"]
        SQLite["SQLite<br/><i>Embedded (dev/test)</i>"]
    end

    subgraph DataModel["Core Data Model"]
        Artifacts["Artifacts<br/><i>datasets, models, metrics</i>"]
        Executions["Executions<br/><i>training runs, transforms</i>"]
        Contexts["Contexts<br/><i>pipelines, experiments</i>"]
        Events["Events<br/><i>artifact ↔ execution</i>"]
        Artifacts --- Events
        Events --- Executions
        Contexts -.->|attributions| Artifacts
        Contexts -.->|associations| Executions
    end

    DSP -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional TLS/mTLS"| Server
    TFX -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional TLS/mTLS"| Server
    PythonLib -->|"gRPC/HTTP2<br/>8080/TCP"| Server

    Core -->|"MySQL wire protocol<br/>Optional SSL"| MySQL
    Core -->|"PostgreSQL wire protocol<br/>Optional SSL"| PostgreSQL
    Core -->|"Embedded"| SQLite

    Server -.->|manages| DataModel

    style Server fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Core fill:#4a90e2,stroke:#333,color:#fff
    style QueryEngine fill:#4a90e2,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style TFX fill:#7ed321,stroke:#333,color:#fff
    style PythonLib fill:#7ed321,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333,color:#fff
    style Artifacts fill:#e8e8e8,stroke:#666
    style Executions fill:#e8e8e8,stroke:#666
    style Contexts fill:#e8e8e8,stroke:#666
    style Events fill:#e8e8e8,stroke:#666
