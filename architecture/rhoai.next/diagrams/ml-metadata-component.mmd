graph TB
    subgraph MLMD["ML Metadata (MLMD)"]
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)<br/>Port 8080/TCP"]
        ProtoAPI["MetadataStoreService<br/>(Protobuf/gRPC API)<br/>~45 RPCs"]
        Server -->|implements| ProtoAPI
    end

    subgraph PythonClient["ml_metadata Python Client"]
        PyGRPC["gRPC Client Mode<br/>(grpcio)"]
        PyDirect["Direct DB Mode<br/>(pybind11 C++ bindings)"]
    end

    subgraph Clients["Platform Clients"]
        KFP["KFP Backend /<br/>DSP API Server"]
        KFPSDK["KFP Python SDK"]
        TFX["TFX (TensorFlow Extended)"]
    end

    subgraph Storage["Database Backends"]
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(embedded, dev only)"]
    end

    %% Client connections
    KFP -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    KFPSDK -->|uses| PyGRPC
    KFPSDK -->|uses| PyDirect
    TFX -->|uses| PyGRPC
    TFX -->|uses| PyDirect

    PyGRPC -->|"gRPC/HTTP2<br/>8080/TCP"| Server
    PyDirect -->|"Direct DB connection"| MySQL
    PyDirect -->|"Direct DB connection"| PostgreSQL

    %% Server to storage
    Server -->|"MySQL protocol<br/>3306/TCP<br/>Optional SSL"| MySQL
    Server -->|"PostgreSQL protocol<br/>5432/TCP<br/>Optional SSL"| PostgreSQL
    Server -->|"Embedded"| SQLite

    %% Deployment management
    DSPOperator["Data Science Pipelines<br/>Operator"] -.->|"deploys &<br/>configures"| Server

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style ProtoAPI fill:#4a90e2,stroke:#333,color:#fff
    style PyGRPC fill:#6baed6,stroke:#333
    style PyDirect fill:#6baed6,stroke:#333
    style KFP fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style TFX fill:#7ed321,stroke:#333
    style DSPOperator fill:#7ed321,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333
