graph LR
    KVCache["llm-d-kv-cache<br/>KV-Cache Management System"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>5557/TCP"| ZeroMQ["ZeroMQ (libzmq)<br/>4.x"]
    KVCache -->|"runtime"| Python312["Python 3.12"]
    KVCache -->|"tokenization<br/>chat templates"| vLLM["vLLM<br/>0.18.0+rhaiv.4"]
    KVCache -->|"model loading"| HFTransformers["HuggingFace<br/>Transformers 4.57+"]
    KVCache -->|"IPC"| gRPC["gRPC<br/>Go 1.77+ / Py 1.78+"]
    KVCache -->|"pod watch"| ControllerRT["controller-runtime<br/>0.21"]
    KVCache -->|"block hash<br/>serialization"| CBOR["CBOR (fxamacker)<br/>2.7"]
    KVCache -->|"event decode"| Msgpack["msgpack (vmihailenco)<br/>5.4"]

    %% External Dependencies (Optional)
    KVCache -.->|"distributed index<br/>6379/TCP"| Redis["Redis / Valkey<br/>6.x+"]
    KVCache -.->|"tracing<br/>4317/TCP gRPC"| OTEL["OpenTelemetry<br/>1.39"]
    KVCache -.->|"metrics<br/>8080/TCP"| PromClient["Prometheus client<br/>1.22"]
    KVCache -.->|"cost-aware cache"| Ristretto["Ristretto<br/>2.3"]

    %% Internal Platform Dependencies
    Scheduler["llm-d-inference-scheduler"] -->|"Go library<br/>embedding"| KVCache
    KVCache -->|"ZMQ SUB<br/>5557/TCP"| VLLMPods["vLLM Inference Pods"]
    KVCache -->|"ZMQ SUB<br/>5557/TCP"| SGLangPods["SGLang Inference Pods"]
    KVCache -->|"HTTPS<br/>443/TCP"| K8sAPI["Kubernetes API"]
    KVCache -->|"POSIX<br/>filesystem"| SharedStorage["Shared Storage<br/>(NFS/PVC)"]
    KVCache -->|"HTTPS<br/>443/TCP"| HFHub["HuggingFace Hub"]

    %% Optional hardware
    KVCache -.->|"GPU-Direct<br/>Storage"| NVGDS["NVIDIA GDS<br/>(optional)"]

