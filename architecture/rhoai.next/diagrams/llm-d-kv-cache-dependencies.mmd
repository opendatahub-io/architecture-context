graph LR
    KVCache["llm-d-kv-cache<br/>Go Library / Python Sidecar"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>5557/TCP msgpack"| ZMQ["ZeroMQ<br/>(go-zeromq/zmq4 v0.17.0)"]
    KVCache -->|"CPU-mode tokenization"| vLLM["vLLM<br/>0.18.0+rhaiv.4"]
    KVCache -->|"download tokenizers<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    KVCache -->|"metrics, logging,<br/>work queues"| ControllerRuntime["controller-runtime<br/>v0.21.0"]

    %% External Dependencies (Optional)
    KVCache -.->|"block index storage<br/>6379/TCP"| Redis["Redis / Valkey<br/>(optional)"]
    KVCache -.->|"cost-aware cache"| Ristretto["Ristretto v2.3.0<br/>(optional)"]
    KVCache -.->|"metrics scrape<br/>HTTP"| Prometheus["Prometheus<br/>(optional)"]
    KVCache -.->|"trace export<br/>gRPC/4317"| OTLP["OpenTelemetry<br/>Collector (optional)"]
    KVCache -.->|"object store<br/>backend"| NIXL["NIXL<br/>(optional)"]

    %% Internal Platform Dependencies
    VLLMPods["vLLM / SGLang<br/>Inference Pods"] -->|"ZMQ PUB 5557/TCP<br/>KV-Events source"| KVCache
    EPP["llm-d EPP<br/>(Inference Scheduler)"] -->|"Go library embedding<br/>ScoreTokens() API"| KVCache
    K8sAPI["Kubernetes API"] -.->|"Pod watch<br/>HTTPS/443"| KVCache

    %% Integration Points (consumers)
    KVCache -->|"POSIX I/O<br/>KV-cache blocks"| SharedFS["Shared Storage<br/>(NFS / PVC)"]

