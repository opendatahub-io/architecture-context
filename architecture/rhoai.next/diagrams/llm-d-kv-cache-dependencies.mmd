graph LR
    KVCache["llm-d-kv-cache<br/>(Library / Sidecar / Utility)"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>event ingestion"| ZeroMQ["ZeroMQ<br/>go-zeromq/zmq4 v0.17.0"]
    KVCache -->|"CPU-mode tokenization<br/>sidecar dependency"| vLLM["vLLM<br/>0.18.0+rhaiv.4"]
    KVCache -->|"tokenizer model<br/>downloads"| HFHub["HuggingFace Hub"]
    KVCache -->|"metrics, logging,<br/>work queues"| CtrlRuntime["controller-runtime<br/>v0.21.0"]

    %% External Dependencies (Optional)
    KVCache -.->|"external index<br/>storage backend"| Redis["Redis / Valkey"]
    KVCache -.->|"cost-aware<br/>in-memory cache"| Ristretto["Ristretto v2.3.0"]
    KVCache -.->|"metrics<br/>collection"| Prometheus["Prometheus"]
    KVCache -.->|"OTLP trace<br/>export"| OpenTelemetry["OpenTelemetry<br/>Collector"]
    KVCache -.->|"object store<br/>backend"| NIXL["NIXL"]

    %% Internal Platform Dependencies
    vLLMPods["vLLM / SGLang<br/>Inference Pods"] -->|"ZMQ PUB 5557/TCP<br/>KV-Events (msgpack)"| KVCache
    EPP["llm-d Inference<br/>Scheduler (EPP)"] -->|"Go library<br/>embedding"| KVCache
    KVCache -.->|"Pod discovery<br/>HTTPS 443/TCP"| K8sAPI["Kubernetes API"]

    %% Downstream consumers
    KVCache -->|"GPU ↔ Storage<br/>block transfers"| SharedStorage["Shared Storage<br/>(NFS/PVC)"]

