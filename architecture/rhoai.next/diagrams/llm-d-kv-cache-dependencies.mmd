graph LR
    KVCache["llm-d-kv-cache<br/><b>Go Library / Service / Sidecar</b>"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>5557/TCP<br/>event ingestion"| ZeroMQ["ZeroMQ (libzmq) 4.x<br/><i>Required</i>"]
    KVCache -->|"tokenizer runtime<br/>CGo + UDS service"| Python["Python 3.12<br/><i>Required</i>"]
    KVCache -->|"OpenAI-compatible<br/>rendering"| vLLM["vLLM 0.18.0+<br/><i>Required (tokenizer)</i>"]
    KVCache -->|"AutoTokenizer<br/>model loading"| HFTransformers["HuggingFace<br/>Transformers >= 4.57<br/><i>Required (tokenizer)</i>"]
    KVCache -->|"inter-process<br/>communication"| gRPC["gRPC<br/>Go 1.77+ / Py 1.78+<br/><i>Required</i>"]
    KVCache -->|"pod watch<br/>workqueue"| CtrlRuntime["controller-runtime 0.21<br/><i>Required</i>"]
    KVCache -->|"block hash<br/>serialization"| CBOR["CBOR (fxamacker) 2.7<br/><i>Required</i>"]
    KVCache -->|"event payload<br/>decoding"| Msgpack["msgpack 5.4<br/><i>Required</i>"]

    %% External Dependencies (Optional)
    KVCache -.->|"distributed<br/>index backend<br/>RESP/6379"| Redis["Redis / Valkey 6.x+<br/><i>Optional</i>"]
    KVCache -.->|"OTLP gRPC<br/>4317/TCP"| OTel["OpenTelemetry 1.39<br/><i>Optional</i>"]
    KVCache -.->|"metrics<br/>8080/TCP"| PromClient["Prometheus client 1.22<br/><i>Optional</i>"]
    KVCache -.->|"cost-aware<br/>memory cache"| Ristretto["Ristretto 2.3<br/><i>Optional</i>"]

    %% Internal Platform Dependencies
    Scheduler["llm-d-inference-scheduler"] -->|"Go library<br/>embedding<br/>GetPodScores()"| KVCache
    KVCache -->|"ZMQ SUB<br/>5557/TCP<br/>KV events"| vLLMPods["vLLM Inference Pods"]
    KVCache -->|"Pod watch<br/>controller-runtime<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    KVCache -->|"POSIX I/O<br/>+ NVIDIA GDS"| SharedStorage["Shared Storage<br/>NFS / PVC"]

    %% External Service Dependencies
    KVCache -->|"HTTPS/443<br/>Bearer Token (opt)<br/>model downloads"| HFHub["HuggingFace Hub"]
    KVCache -.->|"HTTPS/443<br/>alternative source"| ModelScope["ModelScope API"]

