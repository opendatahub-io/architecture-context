graph LR
    KVCache["llm-d-kv-cache<br/>(Library + Sidecar + Plugins)"]

    %% Internal Platform Dependencies (primary consumers/producers)
    KVCache -->|"embedded in<br/>(Go library)"| EPP["llm-d-router (EPP)"]
    KVCache -->|"ZMQ SUB 5557/TCP<br/>(event ingestion)"| VLLMDep["vLLM"]
    KVCache -->|"ZMQ SUB 5557/TCP<br/>(event ingestion)"| SGLangDep["SGLang"]
    KVCache -->|"vLLM plugin<br/>(entry point)"| VLLMPlugin["vLLM Plugin System"]

    %% External Dependencies
    KVCache -->|"event streaming<br/>(ZMQ PUB/SUB)"| ZeroMQ["ZeroMQ (libzmq) 4.x"]
    KVCache -.->|"optional index<br/>(6379/TCP)"| Redis["Redis / Valkey 6.x+"]
    KVCache -.->|"tokenizer download<br/>(443/TCP HTTPS)"| HFHub["HuggingFace Hub"]
    KVCache -.->|"GPU transfers<br/>(CUDA 12.8+)"| CUDA["CUDA Toolkit"]
    KVCache -.->|"trace export<br/>(4317/TCP gRPC)"| OTLP["OpenTelemetry Collector"]

    %% Infrastructure Dependencies
    KVCache -->|"pod watch<br/>(443/TCP HTTPS)"| K8sAPI["Kubernetes API Server"]
    KVCache -->|"block storage<br/>(POSIX I/O)"| SharedStorage["Shared Storage<br/>NFS/PVC"]

    %% Components that integrate with KV-Cache
    Prometheus["Prometheus"] -->|"metrics scrape<br/>(HTTP)"| KVCache

    %% Styling
    style KVCache fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal dependencies
    style EPP fill:#2c3e50,stroke:#333,color:#fff
    style VLLMDep fill:#7ed321,stroke:#333,color:#fff
    style SGLangDep fill:#7ed321,stroke:#333,color:#fff
    style VLLMPlugin fill:#7ed321,stroke:#333,color:#fff

    %% External dependencies
    style ZeroMQ fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style CUDA fill:#999,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff

    %% Infrastructure
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style SharedStorage fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
