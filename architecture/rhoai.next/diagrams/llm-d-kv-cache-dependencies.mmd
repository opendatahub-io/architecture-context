graph LR
    KVCache["llm-d-kv-cache<br/>(Library / Sidecar / Utility)"]

    %% External Dependencies (Required)
    KVCache -->|"ZMQ PUB/SUB<br/>event ingestion"| ZeroMQ["ZeroMQ<br/>(go-zeromq/zmq4 v0.17.0)"]
    KVCache -->|"operator primitives<br/>metrics, logging"| CtrlRuntime["controller-runtime<br/>v0.21.0"]
    KVCache -->|"CPU-mode rendering<br/>tokenization"| VLLM["vLLM<br/>0.18.0+rhaiv.4"]
    KVCache -->|"download tokenizers"| HFHub["HuggingFace Hub<br/>HTTPS/443"]

    %% External Dependencies (Optional)
    KVCache -.->|"block index backend<br/>6379/TCP"| Redis["Redis / Valkey<br/>(optional)"]
    KVCache -.->|"cost-aware cache<br/>admission control"| Ristretto["Ristretto<br/>v2.3.0 (optional)"]
    KVCache -.->|"metrics scrape<br/>HTTP"| Prometheus["Prometheus<br/>(optional)"]
    KVCache -.->|"trace export<br/>gRPC/4317"| OTLP["OpenTelemetry<br/>Collector (optional)"]
    KVCache -.->|"object store backend"| NIXL["NIXL<br/>(optional)"]

    %% Internal Platform Dependencies
    VLLMPods["vLLM Inference Pods"] -->|"KV-Events<br/>ZMQ PUB/SUB 5557/TCP"| KVCache
    SGLangPods["SGLang Inference Pods"] -->|"KV-Events<br/>ZMQ PUB/SUB 5557/TCP"| KVCache
    EPP["llm-d Scheduler (EPP)"] -->|"embeds library<br/>Go API (in-process)"| KVCache

    %% Integration Points (consuming KVCache)
    KVCache -.->|"pod discovery<br/>HTTPS/443"| K8sAPI["Kubernetes API"]
    KVCache -->|"KV-cache offloading<br/>POSIX I/O"| SharedStorage["Shared Storage<br/>NFS / PVC"]

    %% Styling
    style KVCache fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ZeroMQ fill:#e8a838,stroke:#333,color:#fff
    style CtrlRuntime fill:#e8a838,stroke:#333,color:#fff
    style VLLM fill:#e8a838,stroke:#333,color:#fff
    style HFHub fill:#e8a838,stroke:#333,color:#fff

    %% Optional external
    style Redis fill:#999,stroke:#333,color:#fff
    style Ristretto fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff
    style NIXL fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style VLLMPods fill:#7ed321,stroke:#333,color:#fff
    style SGLangPods fill:#7ed321,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff

