graph LR
    KVCache["llm-d-kv-cache<br/><b>KV-Cache Management Suite</b>"]

    %% Required External Dependencies
    KVCache -->|"ZMQ PUB/SUB<br/>5557/TCP"| ZMQ["ZeroMQ<br/>(go-zeromq/zmq4 v0.17.0)"]
    KVCache -->|"tokenizer runtime"| vLLM["vLLM<br/>0.18.0+rhaiv.4"]
    KVCache -->|"model loading"| HFTransformers["HuggingFace<br/>Transformers >=4.57.0"]
    KVCache -->|"tensor ops"| PyTorch["PyTorch<br/>2.10.0"]

    %% Optional External Dependencies
    KVCache -.->|"block index<br/>6379/TCP"| Redis["Redis / Valkey<br/>(any version)"]
    KVCache -.->|"RDMA/object-store<br/>transport"| NIXL["NIXL<br/>(latest)"]
    KVCache -.->|"metrics"| PromClient["Prometheus Client<br/>(Go v1.22.0)"]
    KVCache -.->|"tracing<br/>4317/TCP"| OTel["OpenTelemetry<br/>(Go v1.39.0)"]
    KVCache -.->|"pod discovery<br/>443/TCP"| CtrlRuntime["controller-runtime<br/>v0.21.0"]

    %% Internal Platform Dependencies
    vLLMPods["vLLM Pods"] -->|"ZMQ PUB/SUB<br/>KV connector plugin"| KVCache
    EPP["llm-d EPP<br/>(Inference Scheduler)"] -->|"Go library<br/>embedding"| KVCache
    KVCache -->|"Pod watch<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumers/integrators)
    SGLang["SGLang Pods<br/>(experimental)"] -.->|"ZMQ PUB/SUB<br/>5557/TCP"| KVCache
    KVCache -->|"HTTPS 443/TCP<br/>Bearer Token"| HFHub["HuggingFace Hub"]
    KVCache -.->|"HTTPS 443/TCP<br/>AWS creds"| S3["S3-Compatible<br/>Object Store"]
    KVCache -->|"POSIX I/O"| PVC["PVC Filesystem<br/>(Shared Storage)"]
    KVCache -.->|"gRPC 4317/TCP"| OTLPCollector["OTLP Collector"]

    %% Styling
    style KVCache fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required (solid border)
    style ZMQ fill:#2ecc71,stroke:#333,color:#fff
    style vLLM fill:#2ecc71,stroke:#333,color:#fff
    style HFTransformers fill:#2ecc71,stroke:#333,color:#fff
    style PyTorch fill:#2ecc71,stroke:#333,color:#fff

    %% Optional (dashed style via fill)
    style Redis fill:#f39c12,stroke:#333,color:#fff
    style NIXL fill:#f39c12,stroke:#333,color:#fff
    style PromClient fill:#f39c12,stroke:#333,color:#fff
    style OTel fill:#f39c12,stroke:#333,color:#fff
    style CtrlRuntime fill:#f39c12,stroke:#333,color:#fff

    %% Internal Platform
    style vLLMPods fill:#e74c3c,stroke:#333,color:#fff
    style EPP fill:#e74c3c,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style SGLang fill:#e74c3c,stroke:#333,color:#fff

    %% External Services
    style HFHub fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style PVC fill:#999,stroke:#333
