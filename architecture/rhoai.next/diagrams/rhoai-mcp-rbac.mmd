graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["rhoai-mcp<br/>Namespace: rhoai-mcp"]
    end

    subgraph Bindings["ClusterRole Binding"]
        CRB["rhoai-mcp<br/>(cluster-wide)"]
    end

    subgraph ClusterRolePerms["ClusterRole: rhoai-mcp"]
        CR["rhoai-mcp"]
    end

    subgraph CoreResources["API Group: core ('')"]
        Namespaces["namespaces"]
        Pods["pods"]
        PodsLog["pods/log"]
        Services["services"]
        ConfigMaps["configmaps"]
        Secrets["secrets"]
        PVCs["persistentvolumeclaims"]
        Events["events"]
    end

    subgraph KubeflowResources["API Group: kubeflow.org"]
        Notebooks["notebooks"]
        Profiles["profiles"]
    end

    subgraph TektonResources["API Group: tekton.dev"]
        PipelineRuns["pipelineruns"]
        TaskRuns["taskruns"]
        TektonPipelines["pipelines"]
        Tasks["tasks"]
    end

    subgraph KServeResources["API Group: serving.kserve.io"]
        InferenceServices["inferenceservices"]
        ServingRuntimes["servingruntimes"]
    end

    subgraph OpenVinoResources["API Group: serving.openvino.ai"]
        OVMS["ovms"]
    end

    subgraph ODHResources["API Group: opendatahub.io"]
        DSC["datascienceclusters"]
        DSPApps["datasciencepipelines-<br/>applications"]
    end

    subgraph OBCResources["API Group: objectbucket.io"]
        OBCs["objectbucketclaims"]
    end

    subgraph RouteResources["API Group: route.openshift.io"]
        Routes["routes"]
    end

    subgraph ProjectResources["API Group: project.openshift.io"]
        Projects["projects"]
    end

    %% Binding chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Read-only permissions (get, list, watch)
    CR -->|"get, list, watch"| Namespaces
    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| PodsLog
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, watch"| ConfigMaps
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| PVCs
    CR -->|"get, list, watch"| Events
    CR -->|"get, list, watch"| DSC
    CR -->|"get, list, watch"| DSPApps
    CR -->|"get, list, watch"| Routes
    CR -->|"get, list, watch"| Projects

    %% Full CRUD permissions
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Notebooks
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Profiles
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| PipelineRuns
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| TaskRuns
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| TektonPipelines
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Tasks
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| InferenceServices
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| ServingRuntimes
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| OVMS
    CR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| OBCs

