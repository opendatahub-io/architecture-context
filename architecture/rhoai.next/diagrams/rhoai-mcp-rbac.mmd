graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["rhoai-mcp<br/>(Namespace: redhat-ods-applications)"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["rhoai-mcp<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["rhoai-mcp"]
        CR_OS["rhoai-mcp (OpenShift)"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CRB -->|"grants"| CR_OS

    subgraph CoreAPI["Core API ('')"]
        Pods["pods<br/>get, list, watch, create"]
        PodsLog["pods/log<br/>get"]
        Services["services<br/>get, list, watch"]
        Events["events<br/>get, list, watch"]
        Nodes["nodes<br/>get, list, watch"]
        PVs["persistentvolumes<br/>create"]
        PVCs["persistentvolumeclaims<br/>get, list, watch, create, delete"]
        Secrets["secrets<br/>get, list, watch, create, delete"]
        Namespaces["namespaces<br/>get, list, watch, create, patch, delete"]
    end

    subgraph KubeflowAPI["kubeflow.org"]
        Notebooks["notebooks<br/>get, list, watch, create, patch, delete"]
    end

    subgraph TrainerAPI["trainer.kubeflow.org"]
        TrainJobs["trainjobs<br/>get, list, watch, create,<br/>update, patch, delete"]
        TrainingRuntimes["trainingruntimes<br/>get, list, watch"]
        ClusterTrainingRuntimes["clustertrainingruntimes<br/>get, list, watch, create, delete"]
    end

    subgraph DSPipelineAPI["datasciencepipelinesapplications<br/>.opendatahub.io"]
        DSPAs["datasciencepipelinesapplications<br/>get, list, watch, create, delete"]
    end

    subgraph ServingAPI["serving.kserve.io"]
        InferenceServices["inferenceservices<br/>get, list, watch, create, delete"]
        ServingRuntimes["servingruntimes<br/>get, list, watch, create"]
    end

    subgraph AppsAPI["apps"]
        Deployments["deployments<br/>create"]
    end

    subgraph StorageAPI["storage.k8s.io"]
        StorageClasses["storageclasses<br/>list"]
    end

    subgraph OpenShiftAPI["OpenShift-Specific APIs"]
        DSClusters["datascienceclusters<br/>(datasciencecluster.opendatahub.io)<br/>get, list, watch"]
        ModelRegistries["modelregistries<br/>(components.platform.opendatahub.io)<br/>get, list, watch"]
        Templates["templates<br/>(template.openshift.io)<br/>get, list, watch"]
        Routes["routes<br/>(route.openshift.io)<br/>get, list, watch"]
        Projects["projects<br/>(project.openshift.io)<br/>get, list, watch, patch"]
        ImageStreams["imagestreams<br/>(image.openshift.io)<br/>list"]
    end

    %% Base ClusterRole permissions
    CR -->|"manages"| CoreAPI
    CR -->|"manages"| KubeflowAPI
    CR -->|"manages"| TrainerAPI
    CR -->|"manages"| DSPipelineAPI
    CR -->|"manages"| ServingAPI
    CR -->|"manages"| AppsAPI
    CR -->|"manages"| StorageAPI

    %% OpenShift-specific permissions
    CR_OS -->|"manages"| OpenShiftAPI

    %% Multi-user RBAC filtering
    subgraph AuthFlow["Per-Tool RBAC Filtering (Multi-User Mode)"]
        ToolCall["MCP Tool Call"]
        SAR["SubjectAccessReview<br/>(K8s API)"]
        Filter["Tool Visibility Filter"]
    end

    ToolCall -->|"check permissions"| SAR
    SAR -->|"allowed/denied"| Filter
    Filter -->|"show only permitted tools"| SA

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#f5a623
    style CR fill:#e8a030
    style CR_OS fill:#e8a030

    style Pods fill:#7ed321
    style PodsLog fill:#7ed321
    style Services fill:#7ed321
    style Events fill:#7ed321
    style Nodes fill:#7ed321
    style PVs fill:#7ed321
    style PVCs fill:#7ed321
    style Secrets fill:#f8cecc
    style Namespaces fill:#f8cecc

    style Notebooks fill:#7ed321
    style TrainJobs fill:#7ed321
    style TrainingRuntimes fill:#7ed321
    style ClusterTrainingRuntimes fill:#7ed321
    style DSPAs fill:#7ed321
    style InferenceServices fill:#7ed321
    style ServingRuntimes fill:#7ed321
    style Deployments fill:#7ed321
    style StorageClasses fill:#7ed321

    style DSClusters fill:#dae8fc
    style ModelRegistries fill:#dae8fc
    style Templates fill:#dae8fc
    style Routes fill:#dae8fc
    style Projects fill:#dae8fc
    style ImageStreams fill:#dae8fc

    style ToolCall fill:#fff2cc,stroke:#d6b656
    style SAR fill:#fff2cc,stroke:#d6b656
    style Filter fill:#fff2cc,stroke:#d6b656
