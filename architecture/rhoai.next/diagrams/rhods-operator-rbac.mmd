graph TD
    subgraph "Service Accounts"
        SA_Operator["rhods-operator<br/>SA: rhods-operator<br/>NS: redhat-ods-operator"]
        SA_CloudMgr["cloudmanager<br/>SA: cloudmanager<br/>NS: redhat-ods-operator"]
        SA_AuthProxy["kube-auth-proxy<br/>SA: kube-auth-proxy<br/>NS: {applications-namespace}"]
        SA_AdminGroups["Admin Groups<br/>(configured via Auth CR)"]
        SA_AllowedGroups["Allowed Groups<br/>(configured via Auth CR)"]
    end

    subgraph "ClusterRoleBindings"
        CRB_DSC["rhods-operator-dsc-binding"]
        CRB_Gateway["rhods-operator-gateway-binding"]
        CRB_DSCI["rhods-operator-dsci-binding"]
        CRB_CloudMgr["cloudmanager-binding"]
        CRB_TokenReview["kube-auth-proxy-tokenreview"]
        CRB_AdminCluster["data-science-admingroupcluster"]
        CRB_AllowedCluster["data-science-allowedgroupcluster"]
    end

    subgraph "RoleBindings (Namespaced)"
        RB_AdminApps["data-science-admingroup<br/>NS: {applications-namespace}"]
        RB_AdminMaaS["data-science-admingroup-maas<br/>NS: models-as-a-service"]
        RB_AdminKuadrant["data-science-admingroup-kuadrant<br/>NS: kuadrant-system"]
        RB_KueueAdmin["kueue-admin<br/>(cluster-wide)"]
    end

    subgraph "ClusterRoles — rhods-operator (DSC)"
        CR_DSC["rhods-operator-dsc-role"]
    end

    subgraph "DSC Role Permissions"
        DSC_ODH["datasciencecluster.opendatahub.io<br/>datascienceclusters, /status, /finalizers<br/>Verbs: full CRUD + deletecollection"]
        DSC_DSCI["dscinitialization.opendatahub.io<br/>dscinitializations, /status, /finalizers<br/>Verbs: full CRUD"]
        DSC_Components["components.platform.opendatahub.io<br/>Dashboard, Kserve, Kueue, Ray,<br/>TrustyAI, ModelRegistry, DSP,<br/>TrainingOperator, Trainer, Feast,<br/>OGX, MLflow, Spark, MaaS, ModelCtrl<br/>Verbs: full CRUD"]
        DSC_Services["services.platform.opendatahub.io<br/>auths, gatewayconfigs, monitorings<br/>Verbs: full CRUD"]
        DSC_Infra["infrastructure.opendatahub.io<br/>hardwareprofiles, /status, /finalizers<br/>Verbs: full CRUD"]
        DSC_Core["core (\"\")<br/>namespaces, secrets, configmaps,<br/>services, serviceaccounts, pods,<br/>events, endpoints, PVs, PVCs, nodes<br/>Verbs: full CRUD"]
        DSC_Apps["apps<br/>deployments, statefulsets,<br/>replicasets, daemonsets<br/>Verbs: full CRUD"]
        DSC_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles,<br/>clusterrolebindings<br/>Verbs: * (all)"]
        DSC_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>Verbs: full CRUD"]
        DSC_Admission["admissionregistration.k8s.io<br/>validating/mutatingwebhookconfigurations<br/>Verbs: full CRUD"]
        DSC_Network["networking.k8s.io<br/>networkpolicies, ingresses<br/>Verbs: full CRUD"]
        DSC_Route["route.openshift.io<br/>routes<br/>Verbs: full CRUD"]
        DSC_SCC["security.openshift.io<br/>securitycontextconstraints<br/>Verbs: full CRUD + use"]
        DSC_Monitoring["monitoring.coreos.com<br/>servicemonitors, podmonitors,<br/>prometheusrules, prometheuses<br/>Verbs: full CRUD"]
        DSC_KServe["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>llminferenceservices, llmisvcconfigs<br/>Verbs: full CRUD"]
        DSC_OLM["operators.coreos.com<br/>subscriptions, CSVs, catalogsources<br/>Verbs: full CRUD"]
    end

    subgraph "ClusterRoles — rhods-operator (Gateway)"
        CR_Gateway["rhods-operator-gateway-role"]
    end

    subgraph "Gateway Role Permissions"
        GW_GatewayAPI["gateway.networking.k8s.io<br/>gateways, gatewayclasses, httproutes<br/>Verbs: full CRUD"]
        GW_Istio["networking.istio.io<br/>envoyfilters, destinationrules<br/>Verbs: full CRUD"]
        GW_OAuth["oauth.openshift.io<br/>oauthclients<br/>Verbs: full CRUD"]
    end

    subgraph "ClusterRoles — rhods-operator (DSCI/Monitoring)"
        CR_DSCI["rhods-operator-dsci-role"]
    end

    subgraph "DSCI Role Permissions"
        DSCI_MonRHOBS["monitoring.rhobs<br/>monitoringstacks, prometheusrules,<br/>thanosqueriers<br/>Verbs: full CRUD"]
        DSCI_Tempo["tempo.grafana.com<br/>tempostacks, tempomonolithics<br/>Verbs: full CRUD"]
        DSCI_OTEL["opentelemetry.io<br/>opentelemetrycollectors, instrumentations<br/>Verbs: full CRUD"]
        DSCI_Perses["perses.dev<br/>perses, persesdatasources, persesdashboards<br/>Verbs: full CRUD"]
    end

    subgraph "ClusterRoles — cloudmanager"
        CR_CloudMgr["cloudmanager-role"]
    end

    subgraph "CloudManager Role Permissions"
        CM_Infra["infrastructure.opendatahub.io<br/>azurekubernetesengines,<br/>coreweavekubernetesengines<br/>Verbs: full CRUD"]
        CM_Sail["sailoperator.io<br/>istios<br/>Verbs: full CRUD"]
        CM_Operator["operator.openshift.io<br/>certmanagers, leaderworkersetoperators<br/>Verbs: full CRUD"]
        CM_CertMgr["cert-manager.io<br/>clusterissuers, certificates<br/>Verbs: full CRUD"]
    end

    %% Service Account → ClusterRoleBinding → ClusterRole → Permissions
    SA_Operator -->|bound via| CRB_DSC
    CRB_DSC -->|grants| CR_DSC
    CR_DSC -->|permissions| DSC_ODH
    CR_DSC -->|permissions| DSC_DSCI
    CR_DSC -->|permissions| DSC_Components
    CR_DSC -->|permissions| DSC_Services
    CR_DSC -->|permissions| DSC_Infra
    CR_DSC -->|permissions| DSC_Core
    CR_DSC -->|permissions| DSC_Apps
    CR_DSC -->|permissions| DSC_RBAC
    CR_DSC -->|permissions| DSC_CRDs
    CR_DSC -->|permissions| DSC_Admission
    CR_DSC -->|permissions| DSC_Network
    CR_DSC -->|permissions| DSC_Route
    CR_DSC -->|permissions| DSC_SCC
    CR_DSC -->|permissions| DSC_Monitoring
    CR_DSC -->|permissions| DSC_KServe
    CR_DSC -->|permissions| DSC_OLM

    SA_Operator -->|bound via| CRB_Gateway
    CRB_Gateway -->|grants| CR_Gateway
    CR_Gateway -->|permissions| GW_GatewayAPI
    CR_Gateway -->|permissions| GW_Istio
    CR_Gateway -->|permissions| GW_OAuth

    SA_Operator -->|bound via| CRB_DSCI
    CRB_DSCI -->|grants| CR_DSCI
    CR_DSCI -->|permissions| DSCI_MonRHOBS
    CR_DSCI -->|permissions| DSCI_Tempo
    CR_DSCI -->|permissions| DSCI_OTEL
    CR_DSCI -->|permissions| DSCI_Perses

    SA_CloudMgr -->|bound via| CRB_CloudMgr
    CRB_CloudMgr -->|grants| CR_CloudMgr
    CR_CloudMgr -->|permissions| CM_Infra
    CR_CloudMgr -->|permissions| CM_Sail
    CR_CloudMgr -->|permissions| CM_Operator
    CR_CloudMgr -->|permissions| CM_CertMgr

    SA_AuthProxy -->|bound via| CRB_TokenReview
    CRB_TokenReview -->|grants| AuthDelegator["system:auth-delegator"]

    SA_AdminGroups -->|bound via| CRB_AdminCluster
    SA_AdminGroups -->|bound via| RB_AdminApps
    SA_AdminGroups -->|bound via| RB_AdminMaaS
    SA_AdminGroups -->|bound via| RB_AdminKuadrant
    SA_AdminGroups -->|bound via| RB_KueueAdmin

    SA_AllowedGroups -->|bound via| CRB_AllowedCluster

