graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["opendatahub-operator-<br/>controller-manager<br/>(operator namespace)"]
        SA_AuthProxy["kube-auth-proxy<br/>(openshift-ingress)"]
        SA_NSProxy["data-science-prometheus-<br/>namespace-proxy<br/>(app namespace)"]
        SA_ClusterProxy["data-science-prometheus-<br/>cluster-proxy<br/>(app namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["opendatahub-operator-<br/>manager-rolebinding"]
        CRB_AuthDeleg1["kube-auth-proxy<br/>system:auth-delegator"]
        CRB_AuthDeleg2["ns-proxy<br/>system:auth-delegator"]
        CRB_MonView["ns-proxy<br/>cluster-monitoring-view"]
        CRB_AuthDeleg3["cluster-proxy<br/>system:auth-delegator"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["opendatahub-operator-<br/>manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_MonView["cluster-monitoring-view"]
        CR_Admin["data-science-<br/>admingroupcluster-role<br/>(auth-created)"]
        CR_Allowed["data-science-<br/>allowedgroupcluster-role<br/>(auth-created)"]
    end

    subgraph PlatformCRDs["Platform CRDs"]
        DSC_Res["datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>(+ /status, /finalizers)"]
        DSCI_Res["dscinitialization.opendatahub.io<br/>DSCInitialization<br/>(+ /status, /finalizers)"]
        Comp_Res["components.platform.opendatahub.io<br/>16 component types<br/>(+ /status, /finalizers)"]
        Svc_Res["services.platform.opendatahub.io<br/>Auth, Monitoring, GatewayConfig<br/>(+ /status, /finalizers)"]
        Infra_Res["infrastructure.opendatahub.io<br/>HardwareProfile<br/>(+ /status, /finalizers)"]
    end

    subgraph NetworkResources["Network & Ingress Resources"]
        GW_Res["gateway.networking.k8s.io<br/>Gateway, GatewayClass,<br/>HTTPRoute"]
        Istio_Res["networking.istio.io<br/>DestinationRule,<br/>EnvoyFilter"]
        Route_Res["route.openshift.io<br/>Route, Route/custom-host"]
        NP_Res["networking.k8s.io<br/>NetworkPolicy"]
    end

    subgraph CoreResources["Core K8s Resources"]
        Core_Res["core (v1)<br/>Namespace, Secret, ConfigMap,<br/>Service, ServiceAccount, PVC,<br/>Event, Pod"]
        Apps_Res["apps<br/>Deployment"]
        RBAC_Res["rbac.authorization.k8s.io<br/>ClusterRole, ClusterRoleBinding,<br/>Role, RoleBinding"]
        CRD_Res["apiextensions.k8s.io<br/>CustomResourceDefinition"]
        Admission_Res["admissionregistration.k8s.io<br/>ValidatingAdmissionPolicy,<br/>MutatingWebhookConfig,<br/>ValidatingWebhookConfig"]
    end

    subgraph ObservabilityResources["Observability Resources"]
        MonRHOBS_Res["monitoring.rhobs<br/>MonitoringStack, ThanosQuerier,<br/>ServiceMonitor, PrometheusRule"]
        MonCoreos_Res["monitoring.coreos.com<br/>ServiceMonitor, PodMonitor,<br/>PrometheusRule"]
        OTel_Res["opentelemetry.io<br/>OpenTelemetryCollector,<br/>Instrumentation"]
        Tempo_Res["tempo.grafana.com<br/>TempoMonolithic, TempoStack"]
        Perses_Res["perses.dev<br/>Perses, PersesDatasource,<br/>PersesDashboard"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        OAuth_Res["oauth.openshift.io<br/>OAuthClient"]
        OLM_Res["operators.coreos.com<br/>Subscription, CSV,<br/>OperatorGroup, CatalogSource"]
        User_Res["user.openshift.io<br/>Group, User"]
        Config_Res["config.openshift.io<br/>Ingress, ClusterVersion,<br/>Authentication"]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_AuthProxy -->|bound via| CRB_AuthDeleg1
    SA_NSProxy -->|bound via| CRB_AuthDeleg2
    SA_NSProxy -->|bound via| CRB_MonView
    SA_ClusterProxy -->|bound via| CRB_AuthDeleg3

    CRB_Manager -->|grants| CR_Manager
    CRB_AuthDeleg1 -->|grants| CR_AuthDeleg
    CRB_AuthDeleg2 -->|grants| CR_AuthDeleg
    CRB_MonView -->|grants| CR_MonView
    CRB_AuthDeleg3 -->|grants| CR_AuthDeleg

    %% Manager role permissions (full CRUD)
    CR_Manager -->|"full CRUD"| DSC_Res
    CR_Manager -->|"full CRUD"| DSCI_Res
    CR_Manager -->|"full CRUD"| Comp_Res
    CR_Manager -->|"full CRUD"| Svc_Res
    CR_Manager -->|"full CRUD"| Infra_Res
    CR_Manager -->|"full CRUD"| GW_Res
    CR_Manager -->|"full CRUD"| Istio_Res
    CR_Manager -->|"full CRUD"| Route_Res
    CR_Manager -->|"full CRUD"| NP_Res
    CR_Manager -->|"full CRUD"| Core_Res
    CR_Manager -->|"full CRUD"| Apps_Res
    CR_Manager -->|"full CRUD"| RBAC_Res
    CR_Manager -->|"full CRUD"| CRD_Res
    CR_Manager -->|"full CRUD"| Admission_Res
    CR_Manager -->|"full CRUD"| MonRHOBS_Res
    CR_Manager -->|"full CRUD"| MonCoreos_Res
    CR_Manager -->|"full CRUD"| OTel_Res
    CR_Manager -->|"full CRUD"| Tempo_Res
    CR_Manager -->|"full CRUD"| Perses_Res
    CR_Manager -->|"full CRUD"| OAuth_Res
    CR_Manager -->|"full CRUD"| OLM_Res
    CR_Manager -->|"get,list,watch,<br/>create,update,patch"| User_Res
    CR_Manager -->|"read-only"| Config_Res

    %% Auth-created roles
    CR_Admin -->|"full CRUD<br/>(admin groups)"| PlatformCRDs
    CR_Allowed -->|"read-only<br/>(allowed groups)"| PlatformCRDs

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,color:#fff
    style SA_AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style SA_NSProxy fill:#4a90e2,stroke:#333,color:#fff
    style SA_ClusterProxy fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDeleg fill:#f5a623,stroke:#333,color:#fff
    style CR_MonView fill:#f5a623,stroke:#333,color:#fff
    style CR_Admin fill:#f5a623,stroke:#333,color:#fff
    style CR_Allowed fill:#f5a623,stroke:#333,color:#fff

    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_AuthDeleg1 fill:#e8e8e8,stroke:#333
    style CRB_AuthDeleg2 fill:#e8e8e8,stroke:#333
    style CRB_MonView fill:#e8e8e8,stroke:#333
    style CRB_AuthDeleg3 fill:#e8e8e8,stroke:#333

    style DSC_Res fill:#7ed321,stroke:#333,color:#fff
    style DSCI_Res fill:#7ed321,stroke:#333,color:#fff
    style Comp_Res fill:#7ed321,stroke:#333,color:#fff
    style Svc_Res fill:#7ed321,stroke:#333,color:#fff
    style Infra_Res fill:#7ed321,stroke:#333,color:#fff
