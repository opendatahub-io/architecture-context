        CR_AdminGroup["data-science-<br/>admingroupcluster-role"]
        CR_AllowedGroup["data-science-<br/>allowedgroupcluster-role"]
    end

    subgraph PlatformCRDs["Platform CRDs"]
        DSC["datasciencecluster.opendatahub.io<br/>DataScienceCluster"]
        DSCI["dscinitialization.opendatahub.io<br/>DSCInitialization"]
    end

    subgraph ComponentCRDs["Component CRDs (components.platform.opendatahub.io)"]
        CompDashboard["Dashboard"]
        CompKServe["Kserve"]
        CompKueue["Kueue"]
        CompRay["Ray"]
        CompTrustyAI["TrustyAI"]
        CompModelReg["ModelRegistry"]
        CompTrainingOp["TrainingOperator"]
        CompTrainer["Trainer"]
        CompDSP["DataSciencePipelines"]
        CompFeast["FeastOperator"]
        CompLlama["LlamaStackOperator"]
        CompMLflow["MLflowOperator"]
        CompModelCtrl["ModelController"]
        CompMaaS["ModelsAsService"]
