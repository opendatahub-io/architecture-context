        CR_AdminGroup["data-science-<br/>admingroupcluster-role"]
        CR_AllowedGroup["data-science-<br/>allowedgroupcluster-role"]
    end

    subgraph PlatformCRDs["Platform CRDs"]
        DSC["datasciencecluster.opendatahub.io<br/>DataScienceCluster"]
        DSCI["dscinitialization.opendatahub.io<br/>DSCInitialization"]
        CompCRDs["components.platform.opendatahub.io<br/>Dashboard, KServe, Kueue, Ray,<br/>TrustyAI, ModelRegistry, TrainingOperator,<br/>Trainer, DSP, Feast, LlamaStack,<br/>MLflow, ModelController, MaaS,<br/>Spark, Workbenches"]
        SvcCRDs["services.platform.opendatahub.io<br/>Auth, Monitoring, GatewayConfig"]
        InfraCRDs["infrastructure.opendatahub.io<br/>HardwareProfile"]
    end

    subgraph NetworkCRDs["Network & Ingress CRDs"]
        GWResources["gateway.networking.k8s.io<br/>Gateway, GatewayClass, HTTPRoute"]
        IstioResources["networking.istio.io<br/>DestinationRule, EnvoyFilter"]
        Routes["route.openshift.io<br/>Route, Route/custom-host"]
        OAuth["oauth.openshift.io<br/>OAuthClient"]
        NetPol["networking.k8s.io<br/>NetworkPolicy"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        CoreAPI["core (v1)<br/>Namespace, Secret, ConfigMap,<br/>Service, ServiceAccount, PVC,<br/>Event, Pod"]
        AppsAPI["apps (v1)<br/>Deployment"]
        RBACAPI["rbac.authorization.k8s.io<br/>ClusterRole, ClusterRoleBinding,<br/>Role, RoleBinding"]
        AdmissionAPI["admissionregistration.k8s.io<br/>ValidatingAdmissionPolicy,<br/>MutatingWebhookConfig,<br/>ValidatingWebhookConfig"]
        CRDAPI["apiextensions.k8s.io<br/>CustomResourceDefinition"]
    end

    subgraph MonitoringCRDs["Monitoring CRDs"]
        RHOBSMon["monitoring.rhobs<br/>MonitoringStack, ThanosQuerier,<br/>ServiceMonitor, PrometheusRule"]
        CoreOSMon["monitoring.coreos.com<br/>ServiceMonitor, PodMonitor,<br/>PrometheusRule"]
        OTelCRDs["opentelemetry.io<br/>OpenTelemetryCollector,<br/>Instrumentation"]
        TempoCRDs["tempo.grafana.com<br/>TempoMonolithic, TempoStack"]
        PersesCRDs["perses.dev<br/>Perses, PersesDatasource,<br/>PersesDashboard"]
    end

    subgraph OLMResources["OLM Resources"]
        OLMAPI["operators.coreos.com<br/>Subscription, CSV,<br/>OperatorGroup, CatalogSource,<br/>InstallPlan, OperatorCondition"]
    end

    subgraph ReadOnlyResources["Read-Only Resources"]
        ConfigOCP["config.openshift.io<br/>Ingress, ClusterVersion,<br/>Authentication"]
        UserOCP["user.openshift.io<br/>Group, User"]
    end

    %% Bindings
    SA_Manager -->|"bound via"| CRB_Manager
