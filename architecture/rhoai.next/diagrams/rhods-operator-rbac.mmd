graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Main["opendatahub-operator-<br/>controller-manager"]
        SA_KAP["kube-auth-proxy<br/>(NS: openshift-ingress)"]
        SA_NSProxy["data-science-prometheus-<br/>namespace-proxy"]
        SA_CProxy["data-science-prometheus-<br/>cluster-proxy"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["opendatahub-operator-<br/>manager-rolebinding"]
        CRB_KAP["kube-auth-proxy-system:<br/>auth-delegator"]
        CRB_NSProxy["data-science-prometheus-<br/>namespace-proxy-auth-delegator"]
        CRB_CProxy["data-science-prometheus-<br/>cluster-proxy-auth-delegator"]
        CRB_NSView["data-science-prometheus-<br/>namespace-proxy-monitoring-view"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["opendatahub-operator-<br/>manager-role"]
