graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["redhat-ods-operator<br/>(operator manager)"]
        SA_AuthProxy["kube-auth-proxy<br/>(auth proxy)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Operator["operator ClusterRoleBinding"]
        CRB_AdminGroup["data-science-admingroupcluster-rolebinding<br/>(admin groups)"]
        CRB_AllowedGroup["data-science-allowedgroupcluster-rolebinding<br/>(allowed groups)"]
        CRB_AuthProxy["kube-auth-proxy-tokenreview"]
        CRB_Kueue["kueue-batch-admin-role-binding<br/>(admin groups from Auth CR)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Operator["operator ClusterRole<br/>(broad platform permissions)"]
        CR_AdminGroup["data-science-admingroupcluster-role"]
        CR_AllowedGroup["data-science-allowedgroupcluster-role"]
        CR_AuthDelegate["system:auth-delegator"]
    end

    subgraph ODH_APIs["ODH Platform API Resources"]
        DSC["datasciencecluster.opendatahub.io<br/>DataScienceCluster<br/>+ /status, /finalizers<br/><i>get;list;watch;create;update;<br/>patch;delete;deletecollection</i>"]
        DSCI["dscinitialization.opendatahub.io<br/>DSCInitialization<br/>+ /status, /finalizers<br/><i>get;list;watch;create;update;<br/>patch;delete;deletecollection</i>"]
        Components["components.platform.opendatahub.io<br/>16 component kinds<br/>(Dashboard, KServe, Kueue, etc.)<br/><i>get;list;watch;create;update;<br/>patch;delete</i>"]
        Services["services.platform.opendatahub.io<br/>Auth, GatewayConfig, Monitoring<br/>+ /status, /finalizers<br/><i>get;list;watch;create;update;<br/>patch;delete</i>"]
        Infra["infrastructure.opendatahub.io<br/>HardwareProfile, AWS/Azure/<br/>CoreWeave KubernetesEngine<br/><i>get;list;watch;create;update;<br/>patch;delete</i>"]
    end

    subgraph Network_APIs["Network & Ingress API Resources"]
        GatewayRes["gateway.networking.k8s.io<br/>Gateway, GatewayClass, HTTPRoute<br/><i>get;list;watch;create;update;<br/>patch;delete</i>"]
        IstioRes["networking.istio.io<br/>DestinationRule, EnvoyFilter<br/><i>get;list;watch;create;update;<br/>patch;delete</i>"]
        RouteRes["route.openshift.io<br/>Route, Route/custom-host<br/><i>get;list;watch;create;delete;<br/>update;patch</i>"]
    end

    subgraph Platform_APIs["Platform API Resources"]
        RBAC_Res["rbac.authorization.k8s.io<br/>Role, RoleBinding, ClusterRole,<br/>ClusterRoleBinding<br/><i>* (all verbs)</i>"]
        CRD_Res["apiextensions.k8s.io<br/>CustomResourceDefinitions<br/><i>get;list;watch;create;<br/>patch;delete;update</i>"]
        OLM_Res["operators.coreos.com<br/>CSV, Subscription, CRD,<br/>OperatorCondition, CatalogSource<br/><i>get;list;watch;delete;<br/>update;create;patch</i>"]
        OAuth_Res["oauth.openshift.io<br/>OAuthClient<br/><i>create;delete;list;watch;<br/>update;patch;get</i>"]
        SCC_Res["security.openshift.io<br/>SecurityContextConstraints<br/><i>create;delete;get;list;<br/>patch;update;watch</i>"]
        Config_Res["config.openshift.io<br/>Authentication, Infrastructure,<br/>APIServer, ClusterVersion<br/><i>get;watch;list</i>"]
    end

    subgraph Core_APIs["Core & Apps API Resources"]
        CoreRes["core (v1)<br/>Namespace, Service, ConfigMap,<br/>Secret, ServiceAccount, Pod,<br/>PV, PVC, Node, Event, Endpoint<br/><i>varies (generally full CRUD)</i>"]
        AppsRes["apps (v1)<br/>Deployment, ReplicaSet,<br/>StatefulSet<br/><i>get;list;watch;create;<br/>update;patch;delete</i>"]
        MonRes["monitoring.coreos.com<br/>ServiceMonitor, PodMonitor,<br/>PrometheusRule, Prometheus<br/><i>get;create;delete;update;<br/>watch;list;patch;deletecollection</i>"]
    end

    subgraph AuthProxy_APIs["Auth Proxy API Resources"]
        TokenReview["authentication.k8s.io<br/>TokenReview<br/><i>create</i>"]
        SAR["authorization.k8s.io<br/>SubjectAccessReview<br/><i>create</i>"]
    end

    subgraph AdminGroup_APIs["Admin Group API Resources"]
        AdminDSC["datascienceclusters<br/><i>get;list;watch;update;patch</i>"]
        AdminAuth["auths, modelregistries<br/><i>get;list;watch;create;delete</i>"]
        AdminMisc["storageclasses, groups, users<br/><i>get;list;watch</i>"]
    end

    subgraph AllowedGroup_APIs["Allowed Group API Resources"]
        AllowedAuth["auths, auths/status<br/><i>get;list;watch</i>"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Operator
    CRB_Operator -->|"grants"| CR_Operator

    %% Operator permissions
    CR_Operator -->|"manages"| DSC
    CR_Operator -->|"manages"| DSCI
    CR_Operator -->|"manages"| Components
    CR_Operator -->|"manages"| Services
    CR_Operator -->|"manages"| Infra
    CR_Operator -->|"manages"| GatewayRes
    CR_Operator -->|"manages"| IstioRes
    CR_Operator -->|"manages"| RouteRes
    CR_Operator -->|"manages"| RBAC_Res
    CR_Operator -->|"manages"| CRD_Res
    CR_Operator -->|"manages"| OLM_Res
    CR_Operator -->|"manages"| OAuth_Res
    CR_Operator -->|"manages"| SCC_Res
    CR_Operator -->|"reads"| Config_Res
    CR_Operator -->|"manages"| CoreRes
    CR_Operator -->|"manages"| AppsRes
    CR_Operator -->|"manages"| MonRes

    %% Auth proxy SA bindings
    SA_AuthProxy -->|"bound via"| CRB_AuthProxy
    CRB_AuthProxy -->|"grants"| CR_AuthDelegate
    CR_AuthDelegate -->|"creates"| TokenReview
    CR_AuthDelegate -->|"creates"| SAR

    %% Admin group bindings
    CRB_AdminGroup -->|"grants"| CR_AdminGroup
    CR_AdminGroup -->|"manages"| AdminDSC
    CR_AdminGroup -->|"manages"| AdminAuth
    CR_AdminGroup -->|"reads"| AdminMisc

    %% Allowed group bindings
    CRB_AllowedGroup -->|"grants"| CR_AllowedGroup
    CR_AllowedGroup -->|"reads"| AllowedAuth

    %% Kueue admin
    CRB_Kueue -.->|"grants Kueue<br/>batch admin"| KueueComp["kueue-batch-admin-role<br/>(Kueue resources)"]

