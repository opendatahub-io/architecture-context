        Routes["route.openshift.io<br/>Routes, Routes/custom-host"]
        NP["networking.k8s.io<br/>NetworkPolicies"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        Core["core<br/>Namespaces, Secrets, ConfigMaps,<br/>Services, ServiceAccounts, PVCs,<br/>Events, Pods"]
        Apps["apps<br/>Deployments"]
        RBAC_Res["rbac.authorization.k8s.io<br/>ClusterRoles, ClusterRoleBindings,<br/>Roles, RoleBindings"]
        CRDs["apiextensions.k8s.io<br/>CustomResourceDefinitions"]
        Admission["admissionregistration.k8s.io<br/>ValidatingAdmissionPolicies,<br/>MutatingWebhookConfigurations,<br/>ValidatingWebhookConfigurations"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        RHOBS["monitoring.rhobs<br/>MonitoringStacks, ThanosQueriers,<br/>ServiceMonitors, PrometheusRules"]
        CoreOS["monitoring.coreos.com<br/>ServiceMonitors, PodMonitors,<br/>PrometheusRules"]
        OTel["opentelemetry.io<br/>OpenTelemetryCollectors,<br/>Instrumentations"]
        Tempo["tempo.grafana.com<br/>TempoMonolithics, TempoStacks"]
        Perses["perses.dev<br/>Perses, PersesDatasources,<br/>PersesDashboards"]
    end

    subgraph OLMResources["OLM Resources"]
        OLM_Res["operators.coreos.com<br/>Subscriptions, CSVs,<br/>OperatorGroups, CatalogSources,<br/>InstallPlans, OperatorConditions"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        OAuth["oauth.openshift.io<br/>OAuthClients"]
        Users["user.openshift.io<br/>Groups, Users"]
        Config["config.openshift.io<br/>Ingresses, ClusterVersions,<br/>Authentications"]
        HPA["autoscaling<br/>HorizontalPodAutoscalers"]
    end

    %% Main SA → ClusterRole
    SA_Main -->|"bound via"| CRB_Main
    CRB_Main -->|"grants"| CR_Main

    %% Main ClusterRole → Resources (full CRUD)
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| PlatformCRDs
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ComponentCRDs
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ServiceCRDs
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| InfraCRDs
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| NetworkResources
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CoreResources
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| MonitoringResources
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| OLMResources
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| OAuth
    CR_Main -->|"get,list,watch,<br/>create,update,patch"| Users
    CR_Main -->|"get,list,watch"| Config
    CR_Main -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| HPA

    %% Auth delegator SAs
    SA_KAP -->|"bound via"| CRB_KAP
    CRB_KAP -->|"grants"| CR_AuthDelegator

    SA_NSProxy -->|"bound via"| CRB_NSProxy
    CRB_NSProxy -->|"grants"| CR_AuthDelegator

    SA_NSProxy -->|"bound via"| CRB_NSView
    CRB_NSView -->|"grants"| CR_MonView

    SA_CProxy -->|"bound via"| CRB_CProxy
    CRB_CProxy -->|"grants"| CR_AuthDelegator

