        HWProfile["infrastructure.opendatahub.io<br/>HardwareProfile"]
        FeatureTracker["features.opendatahub.io<br/>FeatureTracker"]
    end

    subgraph NetworkResources["Network & Istio Resources"]
        GW["gateway.networking.k8s.io<br/>Gateways, GatewayClasses, HTTPRoutes"]
