graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["opendatahub-operator-<br/>controller-manager<br/>NS: redhat-ods-applications"]
        SA_AuthProxy["kube-auth-proxy<br/>NS: openshift-ingress"]
        SA_AdminGroups["AdminGroups<br/>(rhods-admins,<br/>dedicated-admins)"]
        SA_AllowedGroups["AllowedGroups<br/>(from Auth CR)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["opendatahub-operator-<br/>manager-rolebinding"]
        CRB_AuthDeleg["kube-auth-proxy-<br/>tokenreview"]
        CRB_AdminCluster["data-science-<br/>admingroupcluster-<br/>rolebinding"]
        CRB_AllowedCluster["data-science-<br/>allowedgroupcluster-<br/>rolebinding"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Admin["data-science-<br/>admingroup-rolebinding<br/>NS: redhat-ods-applications"]
        RB_MaaS["data-science-<br/>admingroup-maas-rolebinding<br/>NS: models-as-a-service"]
        RB_Kuadrant["data-science-<br/>admingroup-kuadrant-rolebinding<br/>NS: kuadrant-system"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["opendatahub-operator-<br/>manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_AdminCluster["data-science-<br/>admingroupcluster-role"]
        CR_AllowedCluster["data-science-<br/>allowedgroupcluster-role"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Admin["data-science-<br/>admingroup-role<br/>NS: redhat-ods-applications"]
        R_MaaS["data-science-<br/>admingroup-maas-role<br/>NS: models-as-a-service"]
        R_Kuadrant["data-science-<br/>admingroup-kuadrant-role<br/>NS: kuadrant-system"]
    end

    subgraph ManagerResources["Manager Role Resources"]
        subgraph ODH_CRDs["ODH Platform CRDs"]
            DSC["datasciencecluster.opendatahub.io<br/>DataScienceCluster"]
            DSCI["dscinitialization.opendatahub.io<br/>DSCInitialization"]
            CompCRDs["components.platform.opendatahub.io<br/>16 Component CRDs<br/>(Dashboard, Kserve, Kueue, etc.)"]
            SvcCRDs["services.platform.opendatahub.io<br/>Auth, GatewayConfig, Monitoring"]
            InfraCRDs["infrastructure.opendatahub.io<br/>HardwareProfile"]
        end

        subgraph CoreResources["Core Kubernetes Resources"]
            CoreRes["core: namespaces, secrets,<br/>configmaps, services, SAs,<br/>PVCs, events, pods"]
            AppsRes["apps: deployments"]
            RBACRes["rbac.authorization.k8s.io:<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
            NetRes["networking.k8s.io:<br/>networkpolicies"]
            AutoscaleRes["autoscaling:<br/>horizontalpodautoscalers"]
        end

        subgraph OpenShiftResources["OpenShift Resources"]
            RouteRes["route.openshift.io:<br/>routes, routes/custom-host"]
            OAuthRes["oauth.openshift.io:<br/>oauthclients"]
            SCCRes["security.openshift.io:<br/>securitycontextconstraints"]
            UserRes["user.openshift.io:<br/>groups"]
            ConsoleRes["console.openshift.io:<br/>consolelinks"]
        end

        subgraph GatewayResources["Gateway & Mesh Resources"]
            GWRes["gateway.networking.k8s.io:<br/>gateways, gatewayclasses,<br/>httproutes"]
            IstioRes["networking.istio.io:<br/>destinationrules, envoyfilters"]
        end

        subgraph MonitoringResources["Monitoring Resources"]
            MonRes["monitoring.coreos.com:<br/>servicemonitors, prometheusrules,<br/>prometheuses, alertmanagers"]
        end

        subgraph AdminResources["Admin/Webhook Resources"]
            OLMRes["operators.coreos.com:<br/>subscriptions, CSVs<br/>(get, list, watch only)"]
            CRDRes["apiextensions.k8s.io:<br/>CRDs<br/>(get, list, watch only)"]
            AdmissionRes["admissionregistration.k8s.io:<br/>mutating/validating webhooks,<br/>validatingadmissionpolicies"]
        end
    end

    %% SA → CRB bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_AuthProxy -->|"bound via"| CRB_AuthDeleg
    SA_AdminGroups -->|"bound via"| CRB_AdminCluster
    SA_AllowedGroups -->|"bound via"| CRB_AllowedCluster

    %% SA → RB bindings (namespaced)
    SA_AdminGroups -->|"bound via"| RB_Admin
    SA_AdminGroups -->|"bound via"| RB_MaaS
    SA_AdminGroups -->|"bound via"| RB_Kuadrant

    %% CRB → CR
    CRB_Manager -->|"grants"| CR_Manager
    CRB_AuthDeleg -->|"grants"| CR_AuthDeleg
    CRB_AdminCluster -->|"grants"| CR_AdminCluster
    CRB_AllowedCluster -->|"grants"| CR_AllowedCluster

    %% RB → R
    RB_Admin -->|"grants"| R_Admin
    RB_MaaS -->|"grants"| R_MaaS
    RB_Kuadrant -->|"grants"| R_Kuadrant

    %% CR → Resources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| ODH_CRDs
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| CoreResources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| OpenShiftResources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| GatewayResources
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| MonitoringResources
    CR_Manager -->|"varies"| AdminResources

    CR_AuthDeleg -->|"create<br/>tokenreviews,<br/>subjectaccessreviews"| K8sTokenReview["Kubernetes<br/>Token Review API"]

    CR_AdminCluster -->|"admin-level<br/>cluster access"| ClusterWide["Cluster-wide<br/>Admin Resources"]
    CR_AllowedCluster -->|"get, list, watch"| ClusterWideRead["Cluster-wide<br/>Read Resources"]

    R_Admin -->|"admin access"| AppNS["redhat-ods-applications<br/>namespace resources"]
    R_MaaS -->|"admin access"| MaaSNS["models-as-a-service<br/>namespace resources"]
    R_Kuadrant -->|"admin access"| KuadrantNS["kuadrant-system<br/>namespace resources"]

