    style SA_Manager fill:#4a90e2,stroke:#333,color:#fff
    style SA_AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style SA_AdminGroups fill:#4a90e2,stroke:#333,color:#fff
    style SA_AllowedGroups fill:#4a90e2,stroke:#333,color:#fff

    style CRB_Manager fill:#f5a623,stroke:#333
    style CRB_AuthDeleg fill:#f5a623,stroke:#333
    style CRB_AdminCluster fill:#f5a623,stroke:#333
    style CRB_AllowedCluster fill:#f5a623,stroke:#333
    style RB_Admin fill:#f5a623,stroke:#333
    style RB_MaaS fill:#f5a623,stroke:#333
    style RB_Kuadrant fill:#f5a623,stroke:#333

    style CR_Manager fill:#e74c3c,stroke:#333,color:#fff
    style CR_AuthDeleg fill:#e74c3c,stroke:#333,color:#fff
    style CR_AdminCluster fill:#e74c3c,stroke:#333,color:#fff
    style CR_AllowedCluster fill:#e74c3c,stroke:#333,color:#fff
    style R_Admin fill:#e74c3c,stroke:#333,color:#fff
    style R_MaaS fill:#e74c3c,stroke:#333,color:#fff
    style R_Kuadrant fill:#e74c3c,stroke:#333,color:#fff

    style DSC fill:#7ed321,stroke:#333
    style DSCI fill:#7ed321,stroke:#333
    style CompCRDs fill:#7ed321,stroke:#333
    style SvcCRDs fill:#7ed321,stroke:#333
    style InfraCRDs fill:#7ed321,stroke:#333
