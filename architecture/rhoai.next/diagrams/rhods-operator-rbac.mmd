graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op["opendatahub-operator<br/>(redhat-ods-operator NS)"]
        SA_AuthProxy["kube-auth-proxy<br/>(openshift-ingress NS)"]
        SA_AdminGroup["Admin Groups<br/>(rhods-admins / odh-admins /<br/>dedicated-admins)"]
        SA_AllowedGroup["Allowed Groups<br/>(system:authenticated)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_DSC["opendatahub-operator<br/>ClusterRoleBinding"]
        CRB_AuthDelegator["kube-auth-proxy-tokenreview"]
        CRB_Admin["data-science-admingroupcluster-rolebinding"]
        CRB_Allowed["data-science-allowedgroupcluster-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_DSC["opendatahub-operator<br/>(DSC scope)"]
        CR_DSCI["opendatahub-operator<br/>(DSCI scope)"]
        CR_GW["opendatahub-operator<br/>(Gateway scope)"]
        CR_Admin["data-science-admingroupcluster-role"]
        CR_Allowed["data-science-allowedgroupcluster-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_CloudMgr["Cloud Manager<br/>(common)"]
    end

    subgraph DSC_Resources["DSC Scope — API Resources"]
        DSC_CRDs["datasciencecluster.opendatahub.io<br/>datascienceclusters (+status, +finalizers)<br/>Verbs: get,list,watch,create,update,<br/>patch,delete,deletecollection"]
        Comp_CRDs["components.platform.opendatahub.io<br/>dashboards, workbenches, kserves,<br/>kueues, datasciencepipelines, rays,<br/>trustyais, modelregistries, modelcontrollers,<br/>trainingoperators, trainers, feastoperators,<br/>ogxs, mlflowoperators, sparkoperators,<br/>modelsasservices (+status, +finalizers)<br/>Verbs: get,list,watch,create,update,patch,delete"]
        GW_CRDs["gateway.networking.k8s.io<br/>gateways, gatewayclasses, httproutes<br/>Verbs: get,list,watch,create,update,patch,delete"]
        Istio_CRDs["networking.istio.io<br/>envoyfilters, destinationrules<br/>Verbs: get,list,watch,create,update,patch,delete"]
        KServe_CRDs["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>clusterservingruntimes, llminferenceservices,<br/>llminferenceserviceconfigs (+status, +finalizers)<br/>Verbs: get,list,watch,create,update,patch,delete"]
        RBAC_CRDs["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles,<br/>clusterrolebindings<br/>Verbs: * (all)"]
        Mon_CRDs["monitoring.coreos.com<br/>servicemonitors, podmonitors,<br/>prometheusrules, prometheuses<br/>Verbs: get,create,delete,update,<br/>watch,list,patch,deletecollection"]
        CRD_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>Verbs: get,list,watch,create,patch,delete,update"]
        SCC_CRDs["security.openshift.io<br/>securitycontextconstraints<br/>Verbs: create,delete,get,list,patch,update,watch"]
    end

    subgraph DSCI_Resources["DSCI Scope — API Resources"]
        DSCI_CRDs2["dscinitialization.opendatahub.io<br/>dscinitializations (+status, +finalizers)<br/>Verbs: get,list,watch,create,update,<br/>patch,delete,deletecollection"]
        Svc_CRDs["services.platform.opendatahub.io<br/>auths, gatewayconfigs, monitorings<br/>(+status, +finalizers)<br/>Verbs: get,list,watch,create,update,patch,delete"]
        OCP_Config["config.openshift.io<br/>authentications, infrastructures<br/>Verbs: get,watch,list"]
    end

    subgraph GW_Resources["Gateway Scope — API Resources"]
        APIServer_CR["config.openshift.io<br/>apiservers<br/>Verbs: get,list,watch"]
        Routes_CR["route.openshift.io<br/>routes/custom-host<br/>Verbs: create,patch,update"]
    end

    subgraph Admin_Resources["Admin Group Scope — API Resources"]
        Admin_DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>Verbs: get,list,watch,update,patch"]
        Admin_MR["modelregistry.opendatahub.io<br/>modelregistries<br/>Verbs: watch,update,get,list,create,patch,delete"]
        Admin_SC["storage.k8s.io<br/>storageclasses<br/>Verbs: get,list,watch,update,patch"]
        Admin_Users["user.openshift.io<br/>groups, users<br/>Verbs: get,list,watch"]
    end

    subgraph Allowed_Resources["Allowed Group Scope — API Resources"]
        Allowed_Auth["services.platform.opendatahub.io<br/>auths, auths/status<br/>Verbs: get,list,watch"]
    end

    subgraph CloudMgr_Resources["Cloud Manager Scope — API Resources"]
        CM_CertMgr["operator.openshift.io<br/>certmanagers<br/>Verbs: get,list,watch,create,patch,update,delete"]
        CM_Istio["sailoperator.io<br/>istios<br/>Verbs: get,list,watch,create,patch,update,delete"]
        CM_Certs["cert-manager.io<br/>clusterissuers, certificates<br/>Verbs: get,list,watch,create,update,patch,delete"]
    end

