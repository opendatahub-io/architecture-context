graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard / Workbench"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        RouteAPI["ds-pipeline-{name} Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
        RouteMD["ds-pipeline-md-{name} Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Reencrypt"]
        RouteMinio["minio-{name} Route<br/>443/TCP HTTPS<br/>TLS 1.2+ Edge<br/>(optional)"]
    end

    subgraph AuthLayer["AUTHENTICATION (kube-rbac-proxy)"]
        KRBAC_API["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>dspa/api resource"]
        KRBAC_MD["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>dspa/api resource"]
    end

    subgraph OperatorNS["OPERATOR NS (redhat-ods-applications)"]
        DSPO["DSPO Controller Manager<br/>SA: controller-manager<br/>8080/TCP metrics<br/>8081/TCP health"]
        Webhook["PipelineVersion Webhook<br/>8443/TCP HTTPS<br/>TLS (service-ca)"]
    end

    subgraph DSPANS["DSPA NAMESPACE (NetworkPolicy enforced)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["DS Pipeline API Server<br/>SA: ds-pipeline-{name}<br/>8888/TCP REST<br/>8887/TCP gRPC<br/>PodToPodTLS optional"]
        end

        subgraph ExecLayer["Execution Layer"]
            ArgoCtrl["Argo Workflow Controller<br/>SA: ds-pipeline-workflow-controller-{name}<br/>9090/TCP metrics"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}"]
            SWF["Scheduled Workflow<br/>SA: ds-pipeline-scheduledworkflow-{name}"]
            Pods["Pipeline Step Pods<br/>SA: pipeline-runner-{name}"]
        end

        subgraph MetaLayer["Metadata Layer"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP HTTP/2 gRPC-Web"]
            MLMDGRPC["MLMD GRPC Server<br/>8080/TCP gRPC<br/>PodToPodTLS optional"]
        end

        subgraph StorLayer["Storage Layer"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>TLS optional (service-ca)<br/>Auth: User/Pass"]
            MinIO["MinIO<br/>9000/TCP HTTP<br/>Auth: AccessKey/SecretKey"]
        end
    end

    subgraph ExtServices["EXTERNAL SERVICES"]
        ExtS3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AccessKey or IAM"]
        ExtDB["External MySQL/MariaDB<br/>3306/TCP<br/>TLS optional<br/>Auth: User/Pass"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Registry creds"]
        MLflow["MLflow Service<br/>HTTP/HTTPS<br/>cluster-internal"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| RouteAPI
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| RouteMD
    User -.->|"HTTPS/443<br/>TLS 1.2+"| RouteMinio

    %% Ingress to Auth
    RouteAPI -->|"HTTPS/8443<br/>TLS (service-ca)"| KRBAC_API
    RouteMD -->|"HTTPS/8443<br/>TLS (service-ca)"| KRBAC_MD

    %% Auth to Services
    KRBAC_API -->|"HTTP/8888<br/>or HTTPS (PodToPodTLS)"| APIServer
    KRBAC_MD -->|"HTTP/2 9090<br/>localhost"| MLMDEnvoy

    %% Internal flows
    DSPO -->|"Kubernetes API<br/>TLS<br/>Reconciles DSPA CRs"| APILayer
    APIServer -->|"MySQL/3306<br/>TLS optional<br/>User/Pass"| MariaDB
    ArgoCtrl -->|"K8s API<br/>TLS<br/>SA token"| Pods
    PA -->|"HTTP/8888<br/>TLS optional<br/>Projected SA token"| APIServer
    Pods -->|"gRPC/8080<br/>TLS optional"| MLMDGRPC
    MLMDEnvoy -->|"gRPC/8080<br/>TLS optional"| MLMDGRPC
    MLMDGRPC -->|"MySQL/3306<br/>TLS optional<br/>User/Pass"| MariaDB

    %% Egress
    Pods -->|"HTTP(S)/9000 or 443<br/>TLS 1.2+<br/>AccessKey/SecretKey"| MinIO
    Pods -.->|"HTTPS/443<br/>TLS 1.2+<br/>AccessKey or IAM"| ExtS3
    APIServer -.->|"MySQL/3306<br/>TLS optional"| ExtDB
    DSPO -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry auth"| OCI
    DSPO -.->|"HTTP(S)<br/>Auto-detect"| MLflow
    RouteMinio -.->|"HTTP/9000"| MinIO

    %% K8s API for webhook
    K8sAPI["Kubernetes API Server"] -->|"HTTPS/8443<br/>Admission Review"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef dspa fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class RouteAPI,RouteMD,RouteMinio ingress
    class KRBAC_API,KRBAC_MD auth
    class DSPO,Webhook operator
    class APIServer,ArgoCtrl,PA,SWF,Pods,MLMDEnvoy,MLMDGRPC dspa
    class MariaDB,MinIO storage
    class ExtS3,ExtDB,OCI,MLflow extservice
    class K8sAPI external
