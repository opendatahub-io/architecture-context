graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard / KFP SDK"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Reencrypt)"]
        APIRoute["ds-pipeline-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        MLMDRoute["ds-pipeline-md-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>(conditional)"]
        MinIORoute["minio-{name} Route<br/>443/TCP → 9000/TCP<br/>TLS Edge<br/>(conditional)"]
    end

    subgraph AuthProxy["AUTH PROXY (kube-rbac-proxy - SAR Enforcement)"]
        APIProxy["kube-rbac-proxy<br/>(API Server sidecar)<br/>8443/TCP HTTPS<br/>SAR: DSPA subresource 'api'"]
        MLMDProxy["kube-rbac-proxy<br/>(MLMD Envoy sidecar)<br/>8443/TCP HTTPS<br/>SAR: ConfigMap policy"]
    end

    subgraph InternalServices["INTERNAL SERVICES (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_DSPA["Namespace: {DSPA namespace}"]
            APIServer["ds-pipeline-api-server<br/>SA: ds-pipeline-{name}<br/>8888/TCP REST, 8887/TCP gRPC"]
            PersistenceAgent["ds-pipeline-persistenceagent<br/>Syncs Argo → KFP DB"]
            ScheduledWF["ds-pipeline-scheduledworkflow<br/>Creates Workflows from cron"]
            ArgoCtrl["ds-pipeline-workflow-controller<br/>(Argo) Metrics: 9090/TCP"]
            MLMDgRPC["ds-pipeline-metadata-grpc<br/>8080/TCP gRPC<br/>mTLS (service-ca)"]
            Envoy["ds-pipeline-metadata-envoy<br/>9090/TCP gRPC/HTTP2"]
            Webhook["ds-pipelines-webhook<br/>8443/TCP HTTPS<br/>(conditional)"]
        end
    end

    subgraph DataLayer["DATA LAYER (NetworkPolicy Restricted)"]
        MariaDB["MariaDB (managed)<br/>3306/TCP MySQL<br/>TLS (service-ca)<br/>Auth: Password (Secret)"]
        MinIO["MinIO (managed)<br/>9000/TCP HTTP<br/>plaintext<br/>Auth: AccessKey/SecretKey"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtDB["External Database<br/>3306/TCP MySQL<br/>TLS (configurable)<br/>Auth: Password"]
        ExtS3["External S3 Store<br/>443/TCP HTTPS<br/>TLS<br/>Auth: AccessKey/SecretKey"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>TLS<br/>Auth: Registry credentials"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>Auth: ServiceAccount token"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| APIRoute
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| MLMDRoute

    %% Ingress → Auth Proxy
    APIRoute -->|"HTTPS/8443<br/>TLS Reencrypt<br/>service-ca cert"| APIProxy
    MLMDRoute -->|"HTTPS/8443<br/>TLS Reencrypt<br/>service-ca cert"| MLMDProxy

    %% Auth Proxy → Services
    APIProxy -->|"HTTP(S)/8888<br/>TLS (PodToPodTLS)<br/>None (localhost)"| APIServer
    MLMDProxy -->|"HTTP/9090<br/>plaintext<br/>None (localhost)"| Envoy

    %% Internal flows
    Envoy -->|"gRPC/8080<br/>TLS (PodToPodTLS)<br/>None"| MLMDgRPC
    PersistenceAgent -->|"HTTP(S)/8888<br/>TLS (PodToPodTLS)"| APIServer
    ArgoCtrl -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Data layer
    APIServer -->|"MySQL/3306<br/>TLS (PodToPodTLS)<br/>Password"| MariaDB
    APIServer -->|"MySQL/3306<br/>TLS<br/>Password"| ExtDB
    APIServer -->|"HTTP/9000<br/>plaintext<br/>AccessKey"| MinIO
    APIServer -->|"HTTPS/443<br/>TLS<br/>AccessKey"| ExtS3
    MLMDgRPC -->|"MySQL/3306<br/>TLS (PodToPodTLS)<br/>Password"| MariaDB
    MLMDgRPC -->|"MySQL/3306<br/>TLS<br/>Password"| ExtDB

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#e6d5f5,stroke:#9b59b6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datalayer fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f5f5f5,stroke:#666,stroke-width:2px

    class User external
    class APIRoute,MLMDRoute,MinIORoute ingress
    class APIProxy,MLMDProxy authproxy
    class APIServer,PersistenceAgent,ScheduledWF,ArgoCtrl,MLMDgRPC,Envoy,Webhook internal
    class MariaDB,MinIO datalayer
    class ExtDB,ExtS3,OCIReg,K8sAPI externalservice
