graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Dashboard<br/>External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        APIRoute["ds-pipeline-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>Conditional: enableRoute"]
        MLMDRoute["ds-pipeline-md-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>Conditional: deployRoute"]
        MinIORoute["minio-{name} Route<br/>443/TCP → 9000/TCP<br/>TLS Edge<br/>Conditional: enableExternalRoute"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER"]
        APIProxy["kube-rbac-proxy (API Server)<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>Secret: ds-pipelines-proxy-tls-{name}"]
        MLMDProxy["kube-rbac-proxy (MLMD Envoy)<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
    end

    subgraph DSPANamespace["DSPA NAMESPACE (NetworkPolicy Protected)"]
        direction TB

        subgraph APIBox["API Server Pod"]
            APIServer["DS Pipeline API Server<br/>SA: ds-pipeline-{name}<br/>8888/TCP HTTP(S), 8887/TCP gRPC"]
        end

        subgraph MLMDBox["MLMD Stack"]
            Envoy["MLMD Envoy Proxy<br/>9090/TCP gRPC"]
            MLMD["MLMD gRPC Server<br/>8080/TCP gRPC<br/>NP: pipeline steps + DSP pods"]
        end

        subgraph BackendBox["Data Backends"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>NP: DSPO + API + MLMD ONLY<br/>Auth: Password"]
            MinIO["MinIO<br/>9000/TCP S3 API<br/>TLS 1.2+<br/>Auth: Access Key/Secret Key"]
        end

        subgraph AgentBox["Workflow & Agents"]
            WFC["Workflow Controller<br/>SA: ds-pipeline-workflow-controller-{name}"]
            PA["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}"]
            SW["Scheduled Workflow<br/>SA: ds-pipeline-scheduledworkflow-{name}"]
        end

        PipelinePods["Pipeline Step Pods<br/>Label: pipelines.kubeflow.org/<br/>v2_component: true"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        DSPO["DSPO Controller Manager<br/>SA: controller-manager<br/>8080/TCP metrics, 8081/TCP health"]
        Webhook["PipelineVersion Webhook<br/>443/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>Auth: SA Token"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>Auth: Default Keychain<br/>Allowlist enforced"]
        ServiceCA["OpenShift Service CA<br/>Auto TLS cert generation"]
        Prometheus["Prometheus<br/>User Workload Monitoring<br/>ServiceMonitor"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS"| APIRoute
    Client -->|"HTTPS/443<br/>TLS"| MLMDRoute

    %% Ingress → Auth Proxy
    APIRoute -->|"HTTPS/8443<br/>TLS Reencrypt"| APIProxy
    MLMDRoute -->|"HTTPS/8443<br/>TLS Reencrypt"| MLMDProxy

    %% Auth Proxy → Services
    APIProxy -->|"HTTP(S)/8888<br/>PodToPodTLS<br/>Post-RBAC"| APIServer
    MLMDProxy -->|"gRPC/9090<br/>PodToPodTLS<br/>Post-RBAC"| Envoy

    %% Internal data flows
    Envoy -->|"gRPC/8080<br/>PodToPodTLS"| MLMD
    APIServer -->|"MySQL/3306<br/>PodToPodTLS<br/>Password Auth"| MariaDB
    APIServer -->|"S3/9000<br/>TLS 1.2+<br/>Access Key"| MinIO
    PA -->|"HTTP(S)/8888<br/>PodToPodTLS"| APIServer
    PA -->|"gRPC/8080<br/>PodToPodTLS"| MLMD
    PipelinePods -->|"gRPC/8080<br/>PodToPodTLS<br/>NetworkPolicy"| MLMD
    PipelinePods -->|"S3/9000<br/>TLS 1.2+"| MinIO

    %% Operator flows
    DSPO -->|"HTTPS/443<br/>SA Token"| K8sAPI
    DSPO -->|"HTTPS/443<br/>Keychain"| OCI
    DSPO -->|"MySQL/3306<br/>Health check"| MariaDB
    DSPO -->|"S3/9000<br/>Health check"| MinIO
    WFC -->|"HTTPS/443<br/>SA Token"| K8sAPI
    SW -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/8888<br/>ServiceMonitor"| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class APIRoute,MLMDRoute,MinIORoute ingress
    class APIProxy,MLMDProxy authproxy
    class APIServer,Envoy,MLMD,WFC,PA,SW,PipelinePods internal
    class MariaDB,MinIO backend
    class DSPO,Webhook operator
    class K8sAPI,OCI,ServiceCA,Prometheus extsvc
