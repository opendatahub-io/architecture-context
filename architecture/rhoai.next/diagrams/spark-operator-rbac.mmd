graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(Controller Manager)"]
        SA_Webhook["spark-operator-webhook<br/>(Webhook Server)"]
        SA_Spark["spark-operator-spark<br/>(Spark Driver Pods)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_Controller["spark-operator-controller<br/>(RoleBinding - leader election)"]
        RB_Webhook["spark-operator-webhook<br/>(RoleBinding - secrets/leases)"]
        RB_Spark["spark-operator-rolebinding<br/>(RoleBinding - operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["spark-operator-controller"]
        CR_Webhook["spark-operator-webhook"]
    end

    subgraph NamespacedRoles["Namespaced Roles"]
        R_Controller["spark-operator-controller<br/>(leader election)"]
        R_Webhook["spark-operator-webhook<br/>(secrets/leases)"]
        R_Spark["spark-operator-role<br/>(driver pod permissions)"]
    end

    subgraph AggregatedRoles["Aggregated User-Facing Roles"]
        EditorSA["sparkapplication-editor-role<br/>CRUD on SparkApplication"]
        ViewerSA["sparkapplication-viewer-role<br/>Read-only on SparkApplication"]
        EditorSSA["scheduledsparkapplication-editor-role<br/>CRUD on ScheduledSparkApplication"]
        ViewerSSA["scheduledsparkapplication-viewer-role<br/>Read-only on ScheduledSparkApplication"]
    end

    subgraph ControllerResources["Controller Resources"]
        Pods["core<br/>pods<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
        ConfigMaps["core<br/>configmaps<br/>get,list,create,<br/>update,patch,watch"]
        Services["core<br/>services<br/>get,list,create,delete,<br/>patch,update,watch"]
        PVCs["core<br/>persistentvolumeclaims<br/>list,watch"]
        Events["core<br/>events<br/>create,update,patch"]
        Nodes["core<br/>nodes<br/>get"]
        ResourceQuotas["core<br/>resourcequotas<br/>get,list,watch"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get"]
        Ingresses["networking.k8s.io<br/>ingresses<br/>get,list,watch,<br/>create,update,delete"]
        SparkApps["sparkoperator.k8s.io<br/>sparkapplications<br/>+status +finalizers<br/>full CRUD"]
        SchedApps["sparkoperator.k8s.io<br/>scheduledsparkapplications<br/>+status +finalizers<br/>full CRUD"]
        SparkConns["sparkoperator.k8s.io<br/>sparkconnects<br/>+status<br/>full CRUD"]
    end

    subgraph WebhookResources["Webhook Resources"]
        MutatingConfigs["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>list,watch,get,update"]
        ValidatingConfigs["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>list,watch,get,update"]
        WH_SparkApps["sparkoperator.k8s.io<br/>sparkapplications<br/>get,list,watch"]
        WH_SchedApps["sparkoperator.k8s.io<br/>scheduledsparkapplications<br/>get,list,watch"]
        WH_Pods["core<br/>pods<br/>list,watch"]
    end

    subgraph SparkResources["Spark Driver Resources"]
        SP_Pods["core<br/>pods<br/>full CRUD + deletecollection"]
        SP_ConfigMaps["core<br/>configmaps<br/>full CRUD + deletecollection"]
        SP_PVCs["core<br/>persistentvolumeclaims<br/>full CRUD + deletecollection"]
        SP_Services["core<br/>services<br/>full CRUD + deletecollection"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Controller -->|"bound via"| RB_Controller
    SA_Webhook -->|"bound via"| CRB_Webhook
    SA_Webhook -->|"bound via"| RB_Webhook
    SA_Spark -->|"bound via"| RB_Spark

    CRB_Controller -->|"grants"| CR_Controller
    CRB_Webhook -->|"grants"| CR_Webhook
    RB_Controller -->|"grants"| R_Controller
    RB_Webhook -->|"grants"| R_Webhook
    RB_Spark -->|"grants"| R_Spark

    %% Controller permissions
    CR_Controller -->|"access"| Pods
    CR_Controller -->|"access"| ConfigMaps
    CR_Controller -->|"access"| Services
    CR_Controller -->|"access"| PVCs
    CR_Controller -->|"access"| Events
    CR_Controller -->|"access"| Nodes
    CR_Controller -->|"access"| ResourceQuotas
    CR_Controller -->|"access"| CRDs
    CR_Controller -->|"access"| Ingresses
    CR_Controller -->|"access"| SparkApps
    CR_Controller -->|"access"| SchedApps
    CR_Controller -->|"access"| SparkConns

    %% Webhook permissions
    CR_Webhook -->|"access"| MutatingConfigs
    CR_Webhook -->|"access"| ValidatingConfigs
    CR_Webhook -->|"access"| WH_SparkApps
    CR_Webhook -->|"access"| WH_SchedApps
    CR_Webhook -->|"access"| WH_Pods

    %% Spark driver permissions
    R_Spark -->|"access"| SP_Pods
    R_Spark -->|"access"| SP_ConfigMaps
    R_Spark -->|"access"| SP_PVCs
    R_Spark -->|"access"| SP_Services

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Webhook fill:#4a90e2,color:#fff
    style SA_Spark fill:#4a90e2,color:#fff

    style CR_Controller fill:#f5a623
    style CR_Webhook fill:#f5a623
    style R_Controller fill:#f5a623
    style R_Webhook fill:#f5a623
    style R_Spark fill:#f5a623

    style SparkApps fill:#7ed321
    style SchedApps fill:#7ed321
    style SparkConns fill:#7ed321
    style WH_SparkApps fill:#7ed321
    style WH_SchedApps fill:#7ed321

    style EditorSA fill:#e8e8e8
    style ViewerSA fill:#e8e8e8
    style EditorSSA fill:#e8e8e8
    style ViewerSSA fill:#e8e8e8
