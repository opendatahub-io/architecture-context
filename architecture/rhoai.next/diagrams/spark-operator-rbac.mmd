graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(Operator NS)"]
        SA_Webhook["spark-operator-webhook<br/>(Operator NS)"]
        SA_Spark["spark-operator-spark<br/>(Operator NS)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (Operator Namespace)"]
        RB_Controller["spark-operator-controller<br/>(RoleBinding - leader election)"]
        RB_Webhook["spark-operator-webhook<br/>(RoleBinding - secrets/leases)"]
        RB_Spark["spark-operator-rolebinding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["spark-operator-controller"]
        CR_Webhook["spark-operator-webhook"]
        CR_SAEditor["sparkapplication-editor-role<br/>(aggregated)"]
        CR_SAViewer["sparkapplication-viewer-role<br/>(aggregated)"]
        CR_SSAEditor["scheduledsparkapplication-editor-role<br/>(aggregated)"]
        CR_SSAViewer["scheduledsparkapplication-viewer-role<br/>(aggregated)"]
    end

    subgraph NamespacedRoles["Namespaced Roles"]
        R_Spark["spark-operator-role<br/>(driver pod RBAC)"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Controller -->|"bound via"| RB_Controller
    SA_Webhook -->|"bound via"| CRB_Webhook
    SA_Webhook -->|"bound via"| RB_Webhook
    SA_Spark -->|"bound via"| RB_Spark

    CRB_Controller -->|"grants"| CR_Controller
    CRB_Webhook -->|"grants"| CR_Webhook
    RB_Spark -->|"grants"| R_Spark

    subgraph ControllerResources["Controller Resources"]
        Pods_C["core: pods<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
        ConfigMaps_C["core: configmaps<br/>get,list,create,<br/>update,patch,watch"]
        Services_C["core: services<br/>get,list,create,delete,<br/>patch,update,watch"]
        Events_C["core: events<br/>create,update,patch"]
        Nodes_C["core: nodes<br/>get"]
        RQ_C["core: resourcequotas<br/>get,list,watch"]
        PVC_C["core: pvcs<br/>list,watch"]
        CRD_C["apiextensions: crds<br/>get"]
        Ingress_C["networking/extensions:<br/>ingresses<br/>get,list,watch,create,<br/>update,delete"]
        SA_CRDs["sparkoperator.k8s.io:<br/>sparkapplications<br/>scheduledsparkapplications<br/>sparkconnects<br/>+ /status + /finalizers<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph WebhookResources["Webhook Resources"]
        MWC["admissionregistration:<br/>mutatingwebhookconfigurations<br/>list,watch,get,update"]
        VWC["admissionregistration:<br/>validatingwebhookconfigurations<br/>list,watch,get,update"]
        SA_Watch["sparkoperator.k8s.io:<br/>sparkapplications<br/>scheduledsparkapplications<br/>get,list,watch"]
        Pods_W["core: pods<br/>list,watch"]
    end

    subgraph SparkDriverResources["Spark Driver Pod Resources"]
        Pods_S["core: pods<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
        CM_S["core: configmaps<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
        PVC_S["core: pvcs<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
        Svc_S["core: services<br/>get,list,watch,create,<br/>update,patch,delete,<br/>deletecollection"]
    end

    CR_Controller -->|"permits"| Pods_C
    CR_Controller -->|"permits"| ConfigMaps_C
    CR_Controller -->|"permits"| Services_C
    CR_Controller -->|"permits"| Events_C
    CR_Controller -->|"permits"| Nodes_C
    CR_Controller -->|"permits"| RQ_C
    CR_Controller -->|"permits"| PVC_C
    CR_Controller -->|"permits"| CRD_C
    CR_Controller -->|"permits"| Ingress_C
    CR_Controller -->|"permits"| SA_CRDs

    CR_Webhook -->|"permits"| MWC
    CR_Webhook -->|"permits"| VWC
    CR_Webhook -->|"permits"| SA_Watch
    CR_Webhook -->|"permits"| Pods_W

    R_Spark -->|"permits"| Pods_S
    R_Spark -->|"permits"| CM_S
    R_Spark -->|"permits"| PVC_S
    R_Spark -->|"permits"| Svc_S

