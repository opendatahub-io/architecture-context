graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(Controller SA)"]
        SA_Webhook["spark-operator-webhook<br/>(Webhook SA)"]
        SA_Spark["spark-operator-spark<br/>(Spark Driver SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>ClusterRoleBinding"]
        CRB_Webhook["spark-operator-webhook<br/>ClusterRoleBinding"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_ControllerLE["spark-operator-controller<br/>(leader election)"]
        RB_WebhookNS["spark-operator-webhook<br/>(namespace)"]
        RB_Spark["spark-operator-rolebinding"]
    end

    subgraph ControllerClusterRole["ClusterRole: spark-operator-controller"]
        direction LR
        CR_Pods["core/pods<br/>create, delete, get,<br/>list, update, watch"]
        CR_ConfigMaps["core/configmaps<br/>create, get, list,<br/>patch, update, watch"]
        CR_Services["core/services<br/>create, delete, get,<br/>list, patch, update, watch"]
        CR_PVCs["core/persistentvolumeclaims<br/>list, watch"]
        CR_Events["core/events<br/>create, patch, update"]
        CR_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get"]
        CR_Ingress["extensions, networking.k8s.io<br/>ingresses<br/>create, delete, get, update"]
        CR_SparkApps["sparkoperator.k8s.io<br/>sparkapplications<br/>create, delete, get,<br/>list, watch"]
        CR_ScheduledApps["sparkoperator.k8s.io<br/>scheduledsparkapplications<br/>get, list, watch"]
        CR_SparkConnects["sparkoperator.k8s.io<br/>sparkconnects<br/>get, list, watch"]
        CR_Status["sparkoperator.k8s.io<br/>*/status<br/>update"]
        CR_Finalizers["sparkoperator.k8s.io<br/>*/finalizers<br/>update, patch"]
    end

    subgraph WebhookClusterRole["ClusterRole: spark-operator-webhook"]
        direction LR
        WH_MWH["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>list, watch"]
        WH_VWH["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>list, watch"]
        WH_MWH_Named["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>[spark-operator-webhook]<br/>get, update"]
        WH_VWH_Named["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>[spark-operator-webhook]<br/>get, update"]
        WH_SparkApps["sparkoperator.k8s.io<br/>sparkapplications,<br/>scheduledsparkapplications<br/>get, list, watch"]
        WH_Pods["core/pods<br/>list, watch"]
        WH_OpenShift["config.openshift.io<br/>apiservers [cluster]<br/>get"]
    end

    subgraph SparkRole["Role: spark-operator-role (Namespaced)"]
        SR_Pods["core/pods<br/>(Spark driver/executor<br/>management)"]
    end

    %% SA → Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_ControllerLE
    SA_Webhook -->|bound via| CRB_Webhook
    SA_Webhook -->|bound via| RB_WebhookNS
    SA_Spark -->|bound via| RB_Spark

    %% Bindings → Roles
    CRB_Controller -->|grants| ControllerClusterRole
    CRB_Webhook -->|grants| WebhookClusterRole
    RB_Spark -->|grants| SparkRole

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Webhook fill:#4a90e2,color:#fff
    style SA_Spark fill:#4a90e2,color:#fff
    style CRB_Controller fill:#f5a623,color:#333
    style CRB_Webhook fill:#f5a623,color:#333
    style RB_ControllerLE fill:#f5a623,color:#333
    style RB_WebhookNS fill:#f5a623,color:#333
    style RB_Spark fill:#f5a623,color:#333
