graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SAController["spark-operator-controller<br/>(controller SA)"]
        SAWebhook["spark-operator-webhook<br/>(webhook SA)"]
        SASpark["spark-operator-spark<br/>(driver SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRBController["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRBWebhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RBController["spark-operator-controller<br/>(RoleBinding - leader election)"]
        RBWebhook["spark-operator-webhook<br/>(RoleBinding - secrets, leases)"]
        RBSpark["spark-operator-rolebinding<br/>(RoleBinding - pods, configmaps)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CRController["spark-operator-controller"]
        CRWebhook["spark-operator-webhook"]
    end

    subgraph AggregatedRoles["User-Facing Aggregated Roles"]
        SAViewer["sparkapplication-viewer-role<br/>(aggregated to view)"]
        SAEditor["sparkapplication-editor-role<br/>(aggregated to edit)"]
        SSAViewer["scheduledsparkapplication-<br/>viewer-role<br/>(aggregated to view)"]
        SSAEditor["scheduledsparkapplication-<br/>editor-role<br/>(aggregated to edit)"]
    end

    subgraph ControllerResources["Controller API Resources"]
        Pods["core<br/>pods<br/>create, delete, get,<br/>list, update, watch"]
        ConfigMaps["core<br/>configmaps<br/>create, get, list,<br/>patch, update, watch"]
        CoreServices["core<br/>services<br/>create, delete, get,<br/>list, patch, update, watch"]
        PVCs["core<br/>persistentvolumeclaims<br/>list, watch"]
        Events["core<br/>events<br/>create, patch, update"]
        Nodes["core<br/>nodes<br/>get"]
        Ingresses["extensions, networking.k8s.io<br/>ingresses<br/>create, delete, get, update"]
        SparkApps["sparkoperator.k8s.io<br/>sparkapplications<br/>create, delete, get, list, watch"]
        SparkAppsStatus["sparkoperator.k8s.io<br/>sparkapplications/status<br/>update"]
        SparkAppsFinalizers["sparkoperator.k8s.io<br/>sparkapplications/finalizers<br/>update"]
        SchedApps["sparkoperator.k8s.io<br/>scheduledsparkapplications<br/>get, list, watch"]
        SchedAppsStatus["sparkoperator.k8s.io<br/>scheduledsparkapplications/status<br/>update"]
        SchedAppsFinalizers["sparkoperator.k8s.io<br/>scheduledsparkapplications/finalizers<br/>update, patch"]
        SparkConnects["sparkoperator.k8s.io<br/>sparkconnects<br/>get, list, watch"]
        SparkConnectsStatus["sparkoperator.k8s.io<br/>sparkconnects/status<br/>update"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get"]
    end

    subgraph WebhookResources["Webhook API Resources"]
        MutWebhooks["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>get, list, watch, update"]
        ValWebhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get, list, watch, update"]
        WHSparkApps["sparkoperator.k8s.io<br/>sparkapplications,<br/>scheduledsparkapplications<br/>get, list, watch"]
        WHPods["core<br/>pods<br/>list, watch"]
    end

    subgraph ViewerResources["Viewer Resources"]
        ViewSA["sparkoperator.k8s.io<br/>sparkapplications,<br/>sparkapplications/status<br/>get, list, watch"]
        ViewSSA["sparkoperator.k8s.io<br/>scheduledsparkapplications,<br/>scheduledsparkapplications/status<br/>get, list, watch"]
    end

    subgraph EditorResources["Editor Resources"]
        EditSA["sparkoperator.k8s.io<br/>sparkapplications,<br/>sparkapplications/status<br/>full CRUD"]
        EditSSA["sparkoperator.k8s.io<br/>scheduledsparkapplications,<br/>scheduledsparkapplications/status<br/>full CRUD"]
    end

    %% Controller bindings
    SAController -->|bound via| CRBController
    CRBController -->|grants| CRController
    SAController -->|bound via| RBController

    %% Webhook bindings
    SAWebhook -->|bound via| CRBWebhook
    CRBWebhook -->|grants| CRWebhook
    SAWebhook -->|bound via| RBWebhook

    %% Spark SA bindings
    SASpark -->|bound via| RBSpark

    %% Controller role permissions
    CRController -->|access| Pods
    CRController -->|access| ConfigMaps
    CRController -->|access| CoreServices
    CRController -->|access| PVCs
    CRController -->|access| Events
    CRController -->|access| Nodes
    CRController -->|access| Ingresses
    CRController -->|access| SparkApps
    CRController -->|access| SparkAppsStatus
    CRController -->|access| SparkAppsFinalizers
    CRController -->|access| SchedApps
    CRController -->|access| SchedAppsStatus
    CRController -->|access| SchedAppsFinalizers
    CRController -->|access| SparkConnects
    CRController -->|access| SparkConnectsStatus
    CRController -->|access| CRDs

    %% Webhook role permissions
    CRWebhook -->|access| MutWebhooks
    CRWebhook -->|access| ValWebhooks
    CRWebhook -->|access| WHSparkApps
    CRWebhook -->|access| WHPods

    %% Aggregated roles
    SAViewer -->|access| ViewSA
    SSAViewer -->|access| ViewSSA
    SAEditor -->|access| EditSA
    SSAEditor -->|access| EditSSA

    %% Styling
    style SAController fill:#4a90e2,stroke:#333,color:#fff
    style SAWebhook fill:#4a90e2,stroke:#333,color:#fff
    style SASpark fill:#4a90e2,stroke:#333,color:#fff
    style CRController fill:#f5a623,stroke:#333
    style CRWebhook fill:#f5a623,stroke:#333
    style CRBController fill:#e8e8e8,stroke:#333
    style CRBWebhook fill:#e8e8e8,stroke:#333
    style RBController fill:#e8e8e8,stroke:#333
    style RBWebhook fill:#e8e8e8,stroke:#333
    style RBSpark fill:#e8e8e8,stroke:#333
    style SAViewer fill:#7ed321,stroke:#333
    style SAEditor fill:#7ed321,stroke:#333
    style SSAViewer fill:#7ed321,stroke:#333
    style SSAEditor fill:#7ed321,stroke:#333
