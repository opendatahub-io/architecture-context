    style CR_ScheduledApps fill:#7ed321,color:#333
    style CR_SparkConnects fill:#7ed321,color:#333
    style CR_Status fill:#7ed321,color:#333
    style CR_Finalizers fill:#7ed321,color:#333
    style WH_MWH fill:#b8e986,color:#333
    style WH_VWH fill:#b8e986,color:#333
    style WH_MWH_Named fill:#b8e986,color:#333
    style WH_VWH_Named fill:#b8e986,color:#333
    style WH_SparkApps fill:#b8e986,color:#333
    style WH_Pods fill:#b8e986,color:#333
    style WH_OpenShift fill:#b8e986,color:#333
