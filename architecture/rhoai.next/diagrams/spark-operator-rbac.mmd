graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(operator namespace)"]
        SA_Webhook["spark-operator-webhook<br/>(operator namespace)"]
        SA_Spark["spark-operator-spark<br/>(operator namespace, driver SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_ControllerLE["spark-operator-controller<br/>(RoleBinding - leader election)"]
        RB_WebhookNS["spark-operator-webhook<br/>(RoleBinding - secrets, leases)"]
        RB_Spark["spark-operator-rolebinding<br/>(RoleBinding - pods, configmaps)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["spark-operator-controller"]
        CR_Webhook["spark-operator-webhook"]
    end

    subgraph AggregatedRoles["User-Facing Aggregated Roles"]
        CR_AppViewer["sparkapplication-viewer-role<br/>(get, list, watch)"]
        CR_AppEditor["sparkapplication-editor-role<br/>(full CRUD)"]
        CR_SchedViewer["scheduledsparkapplication-viewer-role<br/>(get, list, watch)"]
        CR_SchedEditor["scheduledsparkapplication-editor-role<br/>(full CRUD)"]
    end

    subgraph ControllerResources["Controller API Resources"]
        Pods_C["core: pods<br/>create, delete, get,<br/>list, update, watch"]
        ConfigMaps_C["core: configmaps<br/>create, get, list,<br/>patch, update, watch"]
        Services_C["core: services<br/>create, delete, get,<br/>list, patch, update, watch"]
        PVCs_C["core: persistentvolumeclaims<br/>list, watch"]
        Events_C["core: events<br/>create, patch, update"]
        Nodes_C["core: nodes<br/>get"]
        Ingresses_C["networking.k8s.io: ingresses<br/>create, delete, get, update"]
        SparkApps_C["sparkoperator.k8s.io:<br/>sparkapplications<br/>create, delete, get, list, watch"]
        SparkAppsStatus_C["sparkoperator.k8s.io:<br/>sparkapplications/status<br/>update"]
        SchedApps_C["sparkoperator.k8s.io:<br/>scheduledsparkapplications<br/>get, list, watch"]
        SchedAppsStatus_C["sparkoperator.k8s.io:<br/>scheduledsparkapplications/status<br/>update"]
        SparkConnects_C["sparkoperator.k8s.io:<br/>sparkconnects<br/>get, list, watch"]
        CRDs_C["apiextensions.k8s.io:<br/>customresourcedefinitions<br/>get"]
    end

    subgraph WebhookResources["Webhook API Resources"]
        MutWebhook_W["admissionregistration.k8s.io:<br/>mutatingwebhookconfigurations<br/>list, watch, get, update"]
        ValWebhook_W["admissionregistration.k8s.io:<br/>validatingwebhookconfigurations<br/>list, watch, get, update"]
        SparkApps_W["sparkoperator.k8s.io:<br/>sparkapplications<br/>get, list, watch"]
        Pods_W["core: pods<br/>list, watch"]
    end

    %% Service Account → Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_ControllerLE
    SA_Webhook -->|bound via| CRB_Webhook
    SA_Webhook -->|bound via| RB_WebhookNS
    SA_Spark -->|bound via| RB_Spark

    %% Bindings → Roles
    CRB_Controller -->|grants| CR_Controller
    CRB_Webhook -->|grants| CR_Webhook

    %% Controller Role → Resources
    CR_Controller -->|access| Pods_C
    CR_Controller -->|access| ConfigMaps_C
    CR_Controller -->|access| Services_C
    CR_Controller -->|access| PVCs_C
    CR_Controller -->|access| Events_C
    CR_Controller -->|access| Nodes_C
    CR_Controller -->|access| Ingresses_C
    CR_Controller -->|access| SparkApps_C
    CR_Controller -->|access| SparkAppsStatus_C
    CR_Controller -->|access| SchedApps_C
    CR_Controller -->|access| SchedAppsStatus_C
    CR_Controller -->|access| SparkConnects_C
    CR_Controller -->|access| CRDs_C

    %% Webhook Role → Resources
    CR_Webhook -->|access| MutWebhook_W
    CR_Webhook -->|access| ValWebhook_W
    CR_Webhook -->|access| SparkApps_W
    CR_Webhook -->|access| Pods_W

    %% Styles
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Webhook fill:#4a90e2,color:#fff
    style SA_Spark fill:#4a90e2,color:#fff
    style CR_Controller fill:#f5a623,color:#fff
    style CR_Webhook fill:#f5a623,color:#fff
    style CR_AppViewer fill:#9b59b6,color:#fff
    style CR_AppEditor fill:#9b59b6,color:#fff
    style CR_SchedViewer fill:#9b59b6,color:#fff
    style CR_SchedEditor fill:#9b59b6,color:#fff
    style CRB_Controller fill:#e74c3c,color:#fff
    style CRB_Webhook fill:#e74c3c,color:#fff
