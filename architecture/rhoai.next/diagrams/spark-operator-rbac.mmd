graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(ServiceAccount)"]
        SA_Webhook["spark-operator-webhook<br/>(ServiceAccount)"]
        SA_Spark["spark-operator-spark<br/>(ServiceAccount)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Spark["spark-operator-rolebinding<br/>(RoleBinding)"]
        RB_Leader["spark-operator-controller-leader-election<br/>(RoleBinding)"]
    end

    subgraph ControllerClusterRole["ClusterRole: spark-operator-controller"]
        direction LR

        subgraph CoreAPI_C["core API"]
            Pods_C["pods<br/>create, delete, get,<br/>list, update, watch"]
            ConfigMaps_C["configmaps<br/>create, get, list,<br/>patch, update, watch"]
            Services_C["services<br/>create, delete, get,<br/>list, patch, update, watch"]
            PVCs_C["persistentvolumeclaims<br/>list, watch"]
            Events_C["events<br/>create, patch, update"]
        end

        subgraph ExtAPI_C["apiextensions.k8s.io"]
            CRDs_C["customresourcedefinitions<br/>get"]
        end

        subgraph NetAPI_C["extensions / networking.k8s.io"]
            Ingresses_C["ingresses<br/>create, delete, get, update"]
        end

        subgraph SparkAPI_C["sparkoperator.k8s.io"]
            SparkApps_C["sparkapplications<br/>create, delete, get,<br/>list, watch"]
            SparkAppsStatus_C["sparkapplications/status<br/>scheduledsparkapplications/status<br/>sparkconnects/status<br/>update"]
            SparkAppsFinalizer_C["sparkapplications/finalizers<br/>scheduledsparkapplications/finalizers<br/>sparkconnects/finalizers<br/>update, patch"]
            ScheduledApps_C["scheduledsparkapplications<br/>get, list, watch"]
            SparkConnects_C["sparkconnects<br/>get, list, watch"]
        end
    end

    subgraph WebhookClusterRole["ClusterRole: spark-operator-webhook"]
        direction LR

        subgraph AdmissionAPI_W["admissionregistration.k8s.io"]
            WebhookConfigs_W["mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>list, watch"]
            WebhookConfigsNamed_W["mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>[name: spark-operator-webhook]<br/>get, update"]
        end

        subgraph SparkAPI_W["sparkoperator.k8s.io"]
            SparkApps_W["sparkapplications<br/>scheduledsparkapplications<br/>get, list, watch"]
        end

        subgraph CoreAPI_W["core API"]
            Pods_W["pods<br/>list, watch"]
        end

        subgraph OpenShiftAPI_W["config.openshift.io"]
            APIServers_W["apiservers<br/>[name: cluster]<br/>get"]
        end
    end

    subgraph SparkRole["Role: spark-operator-role (namespace-scoped)"]
        SparkDriverPerms["Spark driver SA permissions:<br/>pods, services, configmaps<br/>(for driver/executor management)"]
    end

    subgraph LeaderRole["Role: leader-election-role (namespace-scoped)"]
        LeaderPerms["configmaps, leases<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    CRB_Controller -->|"grants"| ControllerClusterRole

    SA_Webhook -->|"bound via"| CRB_Webhook
    CRB_Webhook -->|"grants"| WebhookClusterRole

    SA_Spark -->|"bound via"| RB_Spark
    RB_Spark -->|"grants"| SparkRole

    SA_Controller -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| LeaderRole

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SA_Spark fill:#4a90e2,stroke:#333,color:#fff

    style CRB_Controller fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Webhook fill:#9b59b6,stroke:#333,color:#fff
    style RB_Spark fill:#8e44ad,stroke:#333,color:#fff
    style RB_Leader fill:#8e44ad,stroke:#333,color:#fff

    style Pods_C fill:#7ed321,stroke:#333
    style ConfigMaps_C fill:#7ed321,stroke:#333
    style Services_C fill:#7ed321,stroke:#333
    style PVCs_C fill:#7ed321,stroke:#333
    style Events_C fill:#7ed321,stroke:#333
    style CRDs_C fill:#7ed321,stroke:#333
    style Ingresses_C fill:#7ed321,stroke:#333
    style SparkApps_C fill:#f5a623,stroke:#333
    style SparkAppsStatus_C fill:#f5a623,stroke:#333
    style SparkAppsFinalizer_C fill:#f5a623,stroke:#333
    style ScheduledApps_C fill:#f5a623,stroke:#333
    style SparkConnects_C fill:#f5a623,stroke:#333

    style WebhookConfigs_W fill:#7ed321,stroke:#333
    style WebhookConfigsNamed_W fill:#7ed321,stroke:#333
    style SparkApps_W fill:#f5a623,stroke:#333
    style Pods_W fill:#7ed321,stroke:#333
    style APIServers_W fill:#e8e8e8,stroke:#333

    style SparkDriverPerms fill:#b8e986,stroke:#333
    style LeaderPerms fill:#b8e986,stroke:#333
