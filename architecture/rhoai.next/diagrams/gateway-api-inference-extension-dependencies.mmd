graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR + Controllers)"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc gRPC<br/>9002/9004"| EnvoyGW["Envoy-based Gateway<br/>(Istio / Envoy GW /<br/>kgateway / GKE GW)"]
    IGW -->|"CRD routing<br/>Gateway, HTTPRoute"| GatewayAPI["Gateway API CRDs<br/>v1"]
    IGW -->|"CRD watch, Pod watch<br/>HTTPS/443"| K8s["Kubernetes<br/>v1.29+"]
    IGW -->|"metrics scraping<br/>HTTP/8000"| ModelServers["Model Servers<br/>(vLLM / SGLang /<br/>Triton / trtllm-serve)"]

    %% External Dependencies (Optional)
    IGW -.->|"metrics export<br/>HTTP/9090"| Prometheus["Prometheus"]
    IGW -.->|"trace export<br/>gRPC"| OTEL["OpenTelemetry<br/>Collector"]
    IGW -.->|"latency prediction<br/>(XGBoost)"| XGBoost["XGBoost<br/>(Python pip)"]

    %% Internal Sub-component Dependencies
    IGW -->|"training data<br/>HTTP/8000"| TrainingSrv["Latency Training<br/>Server (optional)"]
    IGW -->|"predictions<br/>HTTP/8001"| PredictionSrv["Latency Prediction<br/>Server (optional)"]
    TrainingSrv -->|"model storage"| PV["PersistentVolume"]
    PredictionSrv -->|"model sync"| PV

    %% Integration Points (other components using IGW)
    HTTPRoute["Gateway API<br/>HTTPRoute"] -->|"backendRef →<br/>InferencePool"| IGW
    IstioFilter["Istio EnvoyFilter<br/>(optional)"] -->|"inserts ext-proc<br/>filter chain"| IGW

    %% CRDs managed
    IGW -->|"watches"| InferencePool["InferencePool CR<br/>(v1 GA)"]
    IGW -->|"watches"| InferenceObjective["InferenceObjective CR<br/>(v1alpha2)"]
    IGW -->|"watches"| InferenceModelRewrite["InferenceModelRewrite CR<br/>(v1alpha2)"]
    IGW -.->|"watches"| InferencePoolImport["InferencePoolImport CR<br/>(v1alpha1 experimental)"]
    IGW -->|"watches"| ConfigMaps["ConfigMaps<br/>(bbr-managed label)"]

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EnvoyGW fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style ModelServers fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#bbb,stroke:#333
    style OTEL fill:#bbb,stroke:#333
    style XGBoost fill:#bbb,stroke:#333
    style TrainingSrv fill:#9b59b6,stroke:#333,color:#fff
    style PredictionSrv fill:#9b59b6,stroke:#333,color:#fff
    style PV fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style InferencePoolImport fill:#f5a623,stroke:#333,stroke-dasharray: 5 5
    style ConfigMaps fill:#f5a623,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style IstioFilter fill:#7ed321,stroke:#333
