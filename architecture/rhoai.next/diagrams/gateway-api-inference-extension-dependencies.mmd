graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc protocol<br/>gRPC/h2"| EnvoyGW["Envoy-based Gateway<br/>(Envoy GW / Istio /<br/>GKE / kgateway)"]
    IGW -->|"HTTPRoute, Gateway<br/>CRD reference"| GatewayAPI["Gateway API CRDs<br/>v1+"]
    IGW -->|"controller framework<br/>CRD reconciliation"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    IGW -->|"ext-proc gRPC<br/>service definitions"| GoControlPlane["go-control-plane<br/>v1.37.0"]
    IGW -->|"metrics scraping<br/>scheduling input"| ModelServers["Model Servers<br/>(vLLM / sglang /<br/>triton / trtllm-serve)"]

    %% External Dependencies (Optional)
    IGW -.->|"distributed tracing<br/>gRPC/4317"| OTLP["OpenTelemetry<br/>Collector"]
    IGW -.->|"metrics scraping<br/>HTTP/9090"| Prometheus["Prometheus"]
    IGW -.->|"TLS cert mgmt<br/>(optional)"| CertManager["cert-manager<br/>1.13+"]

    %% Internal Platform Dependencies
    IGW -->|"CRD watch<br/>Pod watch<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    IGW -->|"ConfigMap watch<br/>(bbr-managed)"| ConfigMaps["ConfigMaps<br/>(LoRA adapter mappings)"]

    %% Latency Prediction Dependencies (Optional)
    IGW -.->|"latency predictions<br/>HTTP/8001"| LatencyPred["Latency Prediction<br/>Server (Python)"]
    IGW -.->|"training data<br/>HTTP/8000"| LatencyTrain["Latency Training<br/>Server (Python)"]
    LatencyTrain -.->|"model files<br/>shared PVC"| LatencyPred

    %% CRDs managed
    InferencePoolCR["InferencePool CR<br/>(v1 stable)"] -->|"backendRef via<br/>extensionRef"| GatewayAPI
    InferenceObjectiveCR["InferenceObjective CR<br/>(v1alpha2)"] -->|"SLO priority<br/>flow control"| IGW
    InferenceModelRewriteCR["InferenceModelRewrite CR<br/>(v1alpha2)"] -->|"model name rewrite<br/>canary/A-B testing"| IGW

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EnvoyGW fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GoControlPlane fill:#999,stroke:#333,color:#fff
    style ModelServers fill:#f5a623,stroke:#333,color:#000
    style OTLP fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style Prometheus fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style K8sAPI fill:#f5a623,stroke:#333,color:#000
    style ConfigMaps fill:#f5a623,stroke:#333,color:#000
    style LatencyPred fill:#9b59b6,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style LatencyTrain fill:#9b59b6,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style InferencePoolCR fill:#7ed321,stroke:#333,color:#000
    style InferenceObjectiveCR fill:#7ed321,stroke:#333,color:#000
    style InferenceModelRewriteCR fill:#7ed321,stroke:#333,color:#000
