graph LR
    IGW["Gateway API<br/>Inference Extension"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc gRPC<br/>9002, 9004/TCP"| Envoy["Envoy / Gateway Proxy<br/>(Envoy GW, kGateway,<br/>GKE GW, Istio)<br/>Latest"]
    IGW -->|"CRD watches<br/>443/TCP"| K8s["Kubernetes<br/>v1.31+"]
    IGW -->|"HTTPRoute routing"| GatewayAPI["Gateway API CRDs<br/>v1"]
    IGW -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    IGW -->|"ext-proc protocol types"| EnvoyControlPlane["envoy-go-control-plane<br/>v1.37.0"]
    IGW -->|"metrics exposition"| PromClient["Prometheus client_golang<br/>v1.23.2"]
    IGW -->|"scrapes /metrics<br/>HTTP"| ModelServers["Model Servers<br/>(vLLM / SGLang /<br/>Triton TRT-LLM /<br/>trtllm-serve)"]

    %% External Dependencies (Optional)
    IGW -.->|"distributed tracing<br/>gRPC/4317"| OTelSDK["OpenTelemetry SDK<br/>v1.43.0"]
    IGW -.->|"latency prediction<br/>training"| XGBoost["XGBoost<br/>Latest"]

    %% Internal Platform Dependencies
    Envoy -->|"forwards requests<br/>HTTP/8000"| ModelServers
    K8s -->|"hosts"| ModelServers

    %% Integration Points - Inbound
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| IGW
    Istio["Istio Service Mesh"] -.->|"EnvoyFilter<br/>injection"| IGW

    %% Integration Points - CRD consumers
    GatewayHTTPRoute["Gateway API<br/>HTTPRoute"] -->|"references<br/>InferencePool"| IGW

