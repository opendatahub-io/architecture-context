graph LR
    GIE["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% External Dependencies (Required)
    GIE -->|"runtime platform"| K8s["Kubernetes 1.30+"]
    GIE -->|"Gateway/HTTPRoute CRDs"| GatewayAPI["Gateway API v1.0+"]
    GIE -->|"gRPC ext-proc host"| EnvoyGW["Envoy-based Gateway<br/>(Envoy GW / Istio / GKE / nginx)"]
    GIE -->|"controller framework"| CtrlRuntime["controller-runtime v0.19+"]
    GIE -->|"ext-proc protocol types"| GoControlPlane["envoy go-control-plane v1.37"]
    GIE -->|"metrics exposition"| PromClient["Prometheus client_golang v1.23"]

    %% External Dependencies (Optional)
    GIE -.->|"distributed tracing"| OtelSDK["OpenTelemetry SDK v1.43"]

    %% Internal Platform Dependencies
    GIE -->|"gRPC ext-proc stream<br/>9002/9004 TCP"| Gateway["Gateway<br/>(Envoy-based)"]
    GIE -->|"scrape Prometheus metrics"| ModelServers["Model Server Pods<br/>(vLLM / SGLang /<br/>TensorRT-LLM / trtllm-serve)"]
    GIE -->|"watch CRDs + Pods<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Integration Points (consumers)
    HTTPRoute["Gateway API HTTPRoute"] -->|"ExtensionRef<br/>backendRefs"| GIE
    Prometheus["Prometheus /<br/>ServiceMonitor"] -->|"scrape metrics<br/>HTTP/9090"| GIE

    %% Optional integrations
    GIE -.->|"export traces<br/>gRPC/4317"| OTLP["OTLP Collector"]
    GIE -.->|"latency predictions<br/>HTTP/8001"| LatencyPred["Latency Prediction<br/>Server (sidecar)"]
    GIE -.->|"training data<br/>HTTP/8000"| LatencyTrain["Latency Training<br/>Server (sidecar)"]

    %% Styling
    style GIE fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps - grey
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style EnvoyGW fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style GoControlPlane fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff

    %% Optional external deps - lighter grey
    style OtelSDK fill:#bbb,stroke:#333,color:#333

    %% Internal platform deps - green
    style Gateway fill:#7ed321,stroke:#333
    style ModelServers fill:#7ed321,stroke:#333
    style K8sAPI fill:#7ed321,stroke:#333

    %% Consumers / integrations - orange
    style HTTPRoute fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333

    %% Optional integrations - yellow
    style OTLP fill:#fff2cc,stroke:#d6b656
    style LatencyPred fill:#fff2cc,stroke:#d6b656
    style LatencyTrain fill:#fff2cc,stroke:#d6b656
