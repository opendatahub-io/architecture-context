graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% Required External Dependencies
    IGW -->|"ext-proc filter chain<br/>gRPC/9002, 9004"| EnvoyGW["Envoy-Compatible Gateway<br/>(Envoy GW / kgateway /<br/>Istio / GKE Gateway)<br/>Required"]
    IGW -->|"CRDs, Pods, Leases<br/>HTTPS/443"| K8s["Kubernetes 1.29+<br/>Required"]
    IGW -->|"HTTPRoute→InferencePool<br/>backendRef"| GatewayAPICRDs["Gateway API CRDs v1<br/>Required"]
    IGW -->|"metrics scraping<br/>HTTP/configurable"| ModelServers["Model Servers<br/>(vLLM / SGLang /<br/>Triton TensorRT-LLM)<br/>Required (one of)"]

    %% Optional External Dependencies
    IGW -.->|"metrics scrape<br/>HTTP/9090"| Prometheus["Prometheus<br/>Optional"]
    IGW -.->|"trace export<br/>gRPC/4317"| OTLP["OpenTelemetry Collector<br/>Optional"]

    %% Internal Platform Dependencies
    EnvoyGW -->|"delegates to"| IGW
    HTTPRoute["HTTPRoute<br/>(Gateway API)"] -->|"backendRef →<br/>InferencePool"| IGW

    %% Optional Sidecar Dependencies
    IGW -.->|"training data<br/>HTTP/8000"| TrainingServer["Latency Training Server<br/>Optional Sidecar"]
    IGW -.->|"predictions<br/>HTTP/8001+"| PredictionServer["Latency Prediction Server<br/>Optional Sidecar"]

    %% CRDs consumed
    subgraph CRDs["CRDs Watched"]
        InferencePool["InferencePool<br/>inference.networking.k8s.io/v1"]
        InferenceObjective["InferenceObjective<br/>x-k8s.io/v1alpha2"]
        InferenceModelRewrite["InferenceModelRewrite<br/>x-k8s.io/v1alpha2"]
        InferencePoolImport["InferencePoolImport<br/>x-k8s.io/v1alpha1"]
    end

    InferencePool -->|"pool config<br/>pod selector"| IGW
    InferenceObjective -->|"priority & SLO"| IGW
    InferenceModelRewrite -->|"model rewriting<br/>traffic splitting"| IGW
    InferencePoolImport -.->|"multi-cluster<br/>routing"| IGW

    %% BBR-specific
    ConfigMaps["ConfigMaps<br/>(bbr-managed=true)"] -->|"adapter→base model<br/>mappings"| IGW

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EnvoyGW fill:#e67e22,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPICRDs fill:#999,stroke:#333,color:#fff
    style ModelServers fill:#27ae60,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff
    style HTTPRoute fill:#f5a623,stroke:#333
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style InferencePoolImport fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
