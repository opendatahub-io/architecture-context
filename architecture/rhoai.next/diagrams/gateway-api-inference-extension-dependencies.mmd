graph LR
    IGW["Gateway API<br/>Inference Extension"]

    %% Required External Dependencies
    IGW -->|"ext-proc gRPC<br/>9002, 9004/TCP"| Envoy["Envoy / Gateway API Proxy<br/>(Envoy Gateway, kGateway,<br/>GKE Gateway, Istio)"]
    IGW -->|"CRD Watch, Pod Watch<br/>443/TCP HTTPS"| K8s["Kubernetes v1.31+"]
    IGW -->|"HTTPRoute routing"| GatewayAPI["Gateway API CRDs v1"]
    IGW -->|"controller framework"| ControllerRuntime["controller-runtime v0.23.3"]
    IGW -->|"ext-proc types"| EnvoyCP["envoy-go-control-plane v1.37.0"]
    IGW -->|"metrics exposition"| PromClient["Prometheus client_golang v1.23.2"]

    %% Required - One of these model servers
    IGW -->|"metrics scraping<br/>HTTP (configurable)"| vLLM["vLLM"]
    IGW -->|"metrics scraping<br/>HTTP (configurable)"| SGLang["SGLang"]
    IGW -->|"metrics scraping<br/>HTTP (configurable)"| Triton["Triton TensorRT-LLM"]
    IGW -->|"metrics scraping<br/>HTTP (configurable)"| TrtLLM["trtllm-serve"]

    %% Optional Dependencies
    IGW -.->|"tracing export<br/>gRPC/4317"| OTel["OpenTelemetry SDK v1.43.0"]
    IGW -.->|"latency prediction<br/>ML models"| XGBoost["XGBoost"]

    %% Integration Points - Inbound
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| IGW
    Istio["Istio<br/>(EnvoyFilter injection)"] -.->|"service mesh"| IGW

    %% CRD Resources
    InferencePool["InferencePool CR<br/>inference.networking.k8s.io/v1"] -->|"watched by EPP"| IGW
    InferenceObj["InferenceObjective CR<br/>x-k8s.io/v1alpha2"] -->|"watched by EPP"| IGW
    ModelRewrite["InferenceModelRewrite CR<br/>x-k8s.io/v1alpha2"] -->|"watched by EPP"| IGW
    PoolImport["InferencePoolImport CR<br/>x-k8s.io/v1alpha1"] -.->|"multi-cluster"| IGW
    ConfigMaps["ConfigMaps<br/>(bbr-managed)"] -->|"watched by BBR"| IGW

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Envoy fill:#e67e22,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style EnvoyCP fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style vLLM fill:#27ae60,stroke:#333,color:#fff
    style SGLang fill:#27ae60,stroke:#333,color:#fff
    style Triton fill:#27ae60,stroke:#333,color:#fff
    style TrtLLM fill:#27ae60,stroke:#333,color:#fff
    style OTel fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style XGBoost fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Prometheus fill:#f5a623,stroke:#333
    style Istio fill:#f5a623,stroke:#333
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObj fill:#f5a623,stroke:#333
    style ModelRewrite fill:#f5a623,stroke:#333
    style PoolImport fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style ConfigMaps fill:#f5a623,stroke:#333
