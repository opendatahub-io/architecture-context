graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc filter chain<br/>gRPC/9002, 9004"| EnvoyGW["Envoy-Compatible Gateway<br/>(Envoy GW / kgateway /<br/>Istio / GKE Gateway)"]
    IGW -->|"CRD hosting, Pod discovery<br/>RBAC, Leases<br/>HTTPS/443"| K8s["Kubernetes 1.29+"]
    IGW -->|"HTTPRoute → InferencePool<br/>backendRef"| GatewayAPI["Gateway API CRDs v1"]
    IGW -->|"scrape metrics<br/>HTTP/varies"| ModelServers["Model Servers<br/>(vLLM / SGLang /<br/>Triton TRT-LLM)"]

    %% External Dependencies (Optional)
    IGW -.->|"metrics scrape<br/>HTTP/9090"| Prometheus["Prometheus"]
    IGW -.->|"trace export<br/>gRPC/4317"| OTLP["OpenTelemetry<br/>Collector"]

    %% Internal Optional Components
    IGW -.->|"latency predictions<br/>HTTP/8001+"| LatencyPred["Latency Prediction<br/>Server (sidecar)"]
    IGW -.->|"training data<br/>HTTP/8000"| LatencyTrain["Latency Training<br/>Server (sidecar)"]

    %% CRDs Watched
    InferencePool["InferencePool CR<br/>inference.networking.k8s.io/v1"] -->|"pool config<br/>pod selector"| IGW
    InferenceObjective["InferenceObjective CR<br/>x-k8s.io/v1alpha2"] -.->|"priority & SLO<br/>(optional)"| IGW
    InferenceModelRewrite["InferenceModelRewrite CR<br/>x-k8s.io/v1alpha2"] -.->|"model rewriting<br/>traffic splitting<br/>(optional)"| IGW
    ConfigMaps["ConfigMaps<br/>(bbr-managed)"] -->|"adapter→base<br/>model mappings"| IGW

    %% Downstream integration (who uses IGW)
    HTTPRoute["HTTPRoute"] -->|"references InferencePool<br/>as backendRef"| EnvoyGW

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EnvoyGW fill:#e67e22,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style ModelServers fill:#27ae60,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style LatencyPred fill:#9b59b6,stroke:#333,color:#fff
    style LatencyTrain fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
    style HTTPRoute fill:#f5a623,stroke:#333
