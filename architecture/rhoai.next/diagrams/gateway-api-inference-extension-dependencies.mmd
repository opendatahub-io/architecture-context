graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc filter chain<br/>gRPC/9002, 9004"| EnvoyGateway["Envoy-compatible Gateway<br/>(Envoy Gateway / kgateway /<br/>Istio / GKE Gateway)<br/>Required"]
    IGW -->|"CRDs, Pods, Leases<br/>HTTPS/443"| K8s["Kubernetes 1.29+<br/>Required"]
    IGW -->|"HTTPRoute backendRef<br/>→ InferencePool"| GatewayAPICRDs["Gateway API CRDs v1<br/>Required"]
    IGW -->|"metrics scrape<br/>HTTP/varies"| ModelServers["Model Servers<br/>(vLLM / SGLang / Triton)<br/>Required (one)"]

    %% External Dependencies (Optional)
    IGW -.->|"metrics scrape<br/>HTTP/9090"| Prometheus["Prometheus<br/>Optional"]
    IGW -.->|"trace export<br/>gRPC/4317"| OTLP["OpenTelemetry Collector<br/>Optional"]

    %% Internal Platform Dependencies
    EnvoyGateway -->|"ext-proc delegates<br/>routing decisions"| IGW
    ModelServers -->|"Prometheus metrics:<br/>KV cache, queue depth,<br/>running requests, LoRA"| IGW

    %% Integration Points (consumers of IGW)
    HTTPRoute["HTTPRoute<br/>(Gateway API)"] -->|"backendRef →<br/>InferencePool"| IGW

    %% CRDs managed
    subgraph CRDs["CRDs (inference.networking.k8s.io)"]
        InferencePool["InferencePool v1"]
        InferenceObjective["InferenceObjective v1alpha2"]
        InferenceModelRewrite["InferenceModelRewrite v1alpha2"]
        InferencePoolImport["InferencePoolImport v1alpha1"]
    end
    IGW -->|watches/reconciles| CRDs

    %% ConfigMaps
    ConfigMaps["ConfigMaps<br/>(bbr-managed=true)"] -->|"adapter→base model<br/>mappings"| IGW

    %% Latency prediction (optional sidecars)
    subgraph LatencySidecars["Latency Prediction (optional)"]
        TrainingServer["Training Server<br/>Python / 8000/TCP"]
        PredictionServer["Prediction Server<br/>Python / 8001+/TCP"]
    end
    IGW -.->|"training data /<br/>predictions"| LatencySidecars

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EnvoyGateway fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPICRDs fill:#999,stroke:#333,color:#fff
    style ModelServers fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style InferenceObjective fill:#7ed321,stroke:#333,color:#fff
    style InferenceModelRewrite fill:#7ed321,stroke:#333,color:#fff
    style InferencePoolImport fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
