graph TB
    subgraph BatchGateway["Batch Gateway"]
        direction TB

        subgraph APIServer["API Server (8000/TCP + 8081/TCP)"]
            BatchAPI["/v1/batches Handlers<br/>POST, GET, Cancel"]
            FileAPI["/v1/files Handlers<br/>POST, GET, DELETE, Content"]
            Middleware["Middleware Stack<br/>Tenant Extraction, Security Headers,<br/>Recovery, Request Logging"]
            ObsServer["Observability Server<br/>/health, /ready, /metrics"]
            Middleware --> BatchAPI
            Middleware --> FileAPI
        end

        subgraph Processor["Processor (9090/TCP)"]
            Poller["Queue Poller<br/>poll_interval: 5s"]
            Workers["Worker Pool<br/>num_workers: 20"]
            Executor["Request Executor<br/>global_concurrency: 100<br/>per_model: 10"]
            Recovery["Crash Recovery<br/>Scans workDir on startup"]
            Poller -->|dequeue jobs| Workers
            Workers -->|dispatch requests| Executor
            Recovery -->|re-enqueue/finalize| Workers
        end

        subgraph GC["Garbage Collector"]
            Collector["Periodic Collector<br/>interval: 30m<br/>max_concurrency: 10"]
        end
    end

    %% External Client
    Client[External Client] -->|"POST /v1/batches<br/>POST /v1/files"| Gateway

    %% Gateway Layer
    Gateway["Gateway Layer<br/>(Kuadrant / Authorino)<br/>Envoy ext_authz"] -->|"X-MaaS-Username<br/>tenant identity"| Middleware

    %% Data Layer
    BatchAPI -->|"metadata CRUD"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    BatchAPI -->|"enqueue job"| Redis["Redis / Valkey<br/>6379/TCP"]
    FileAPI -->|"store/retrieve"| S3["S3-compatible Storage<br/>443/TCP"]
    FileAPI -->|"file metadata"| PostgreSQL

    Poller -->|"dequeue from<br/>priority queue"| Redis
    Workers -->|"read/update metadata"| PostgreSQL
    Executor -->|"read input files"| S3
    Executor -->|"inference requests"| InferenceGW["Inference Gateway<br/>(llm-d / vLLM)"]
    Executor -->|"upload output files"| S3
    Executor -->|"progress updates"| Redis

    Collector -->|"query expired"| PostgreSQL
    Collector -->|"query expired"| Redis
    Collector -->|"delete files"| S3

    %% Monitoring
    ObsServer -.->|"ServiceMonitor"| Prometheus["Prometheus"]
    Processor -.->|"PodMonitor"| Prometheus

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style Processor fill:#4a90e2,stroke:#333,color:#fff
    style GC fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style InferenceGW fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
