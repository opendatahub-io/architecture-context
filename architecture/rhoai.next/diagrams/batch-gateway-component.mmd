graph TB
    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph APIServer["apiserver (Go HTTP Service)"]
            BatchHandler["Batch Handler<br/>/v1/batches/*"]
            FileHandler["File Handler<br/>/v1/files/*"]
            Middleware["Request Middleware<br/>Tenant ID Extraction<br/>Security Headers"]
            HealthAPI["Health/Ready/Metrics<br/>:8081"]
            TLSConfig["TLS Config<br/>TLS 1.2+ (optional)"]
            Middleware --> BatchHandler
            Middleware --> FileHandler
        end

        subgraph Processor["batch-processor (Go Worker Service)"]
            Workers["Worker Goroutines<br/>(num_workers configurable)"]
            AIMDController["AIMD Concurrency Control<br/>Adaptive Semaphore"]
            SyncDispatch["Sync Dispatch<br/>(HTTP/HTTPS)"]
            AsyncDispatch["Async Dispatch<br/>(llm-d-async queue)"]
            ProcessorMetrics["Health/Metrics<br/>:9090"]
            Workers --> AIMDController
            AIMDController --> SyncDispatch
            AIMDController --> AsyncDispatch
        end

        subgraph GC["batch-gc (Go Background Service)"]
            Collector["Garbage Collector<br/>Expired batches/files"]
            Reconciler["Orphan Reconciler<br/>Stuck jobs recovery"]
            GCMetrics["Metrics<br/>:9091"]
        end
    end

    Client["External Client"] -->|"POST /v1/files<br/>POST /v1/batches<br/>Tenant ID Header"| Middleware
    Client -->|"GET /v1/batches/{id}<br/>POST /v1/batches/{id}/cancel"| Middleware

    BatchHandler -->|"Create/Query/Update<br/>Batch Metadata"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    BatchHandler -->|"Enqueue Jobs<br/>Priority Queue"| Redis["Redis / Valkey<br/>6379/TCP"]
    FileHandler -->|"Upload/Download<br/>File Content"| S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
    FileHandler -->|"Create/Query<br/>File Metadata"| PostgreSQL

    Workers -->|"Dequeue Jobs<br/>(PQDequeue)"| Redis
    Workers -->|"Read/Update<br/>Batch Metadata"| PostgreSQL
    Workers -->|"Download Input<br/>Upload Output/Error"| S3
    SyncDispatch -->|"POST Inference<br/>Bearer Token / mTLS"| InferenceGW["llm-d Inference Gateway"]
    AsyncDispatch -->|"Submit to Queue"| LLMDAsync["llm-d-async<br/>Redis Queue"]
    Workers -->|"Progress Updates<br/>Status Cache"| Redis

    Collector -->|"Delete Expired"| PostgreSQL
    Collector -->|"Delete Expired"| Redis
    Collector -->|"Delete Files"| S3
    Reconciler -->|"Re-enqueue/Cancel<br/>Orphaned Jobs"| Redis
    Reconciler -->|"Update Status"| PostgreSQL

    HTTPRoute["Gateway API<br/>HTTPRoute"] -->|"Route /v1/*"| APIServer

    style BatchGateway fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style APIServer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Processor fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style GC fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style PostgreSQL fill:#e8e8e8,stroke:#666
    style Redis fill:#e8e8e8,stroke:#666
    style S3 fill:#e8e8e8,stroke:#666
    style InferenceGW fill:#7ed321,stroke:#333
    style LLMDAsync fill:#7ed321,stroke:#333
    style HTTPRoute fill:#f5a623,stroke:#333
