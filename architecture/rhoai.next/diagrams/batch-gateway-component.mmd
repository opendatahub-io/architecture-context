graph TB
    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph Apiserver["batch-gateway-apiserver"]
            direction LR
            BatchAPI["Batch Handler<br/>/v1/batches/*"]
            FileAPI["File Handler<br/>/v1/files/*"]
            Middleware["Request Middleware<br/>Tenant Extraction"]
            HealthAPI["Health/Ready/Metrics<br/>:8081"]
            Middleware --> BatchAPI
            Middleware --> FileAPI
        end

        subgraph Processor["batch-gateway-processor"]
            direction LR
            Poller["Queue Poller<br/>poll_interval: 5s"]
            WorkerPool["Worker Pool<br/>num_workers: configurable"]
            Executor["Inference Executor<br/>global + per-model concurrency"]
            Recovery["Crash Recovery<br/>Startup scan"]
            Poller --> WorkerPool
            WorkerPool --> Executor
            Recovery -.->|re-enqueue| WorkerPool
        end

        subgraph GC["batch-gateway-gc"]
            direction LR
            Scanner["Expiry Scanner<br/>periodic interval"]
            Cleaner["Record & File Cleaner<br/>max_concurrency: 10"]
            Scanner --> Cleaner
        end
    end

    Client[External Client] -->|"POST /v1/files<br/>POST /v1/batches<br/>Tenant Header"| Middleware
    Client -->|"GET /v1/batches/{id}<br/>GET /v1/files/{id}/content"| Middleware

    BatchAPI -->|"enqueue job"| RedisQueue["Redis/Valkey<br/>Priority Queue<br/>6379/TCP"]
    BatchAPI -->|"store metadata"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    FileAPI -->|"store file"| FileStore["File Store<br/>S3 (443/TCP) / FS (PVC)"]
    FileAPI -->|"store metadata"| PostgreSQL

    Poller -->|"dequeue job"| RedisQueue
    Executor -->|"POST inference<br/>Bearer token"| InferenceGW["LLM Inference Gateway<br/>(llm-d / vLLM)"]
    Executor -->|"read input / write output"| FileStore
    Executor -->|"update status"| PostgreSQL

    Scanner -->|"query expired"| PostgreSQL
    Cleaner -->|"delete files"| FileStore
    Cleaner -->|"delete metadata"| PostgreSQL

    BatchAPI -->|"publish cancel"| RedisEvents["Redis/Valkey<br/>Event Channel"]
    WorkerPool -->|"subscribe cancel"| RedisEvents
    WorkerPool -->|"progress updates"| RedisStatus["Redis/Valkey<br/>Status Store"]

    style Apiserver fill:#4a90e2,stroke:#333,color:#fff
    style Processor fill:#7ed321,stroke:#333,color:#fff
    style GC fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style RedisQueue fill:#dc382d,stroke:#333,color:#fff
    style RedisEvents fill:#dc382d,stroke:#333,color:#fff
    style RedisStatus fill:#dc382d,stroke:#333,color:#fff
    style FileStore fill:#ff9900,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
