graph TB
    subgraph BatchGateway["Batch Gateway"]
        direction TB

        subgraph Apiserver["batch-gateway-apiserver<br/>(Go HTTP Service)"]
            API_BatchCreate["/v1/batches POST"]
            API_BatchList["/v1/batches GET"]
            API_BatchGet["/v1/batches/{id} GET"]
            API_BatchCancel["/v1/batches/{id}/cancel POST"]
            API_FileUpload["/v1/files POST"]
            API_FileList["/v1/files GET"]
            API_FileGet["/v1/files/{id} GET"]
            API_FileContent["/v1/files/{id}/content GET"]
            API_FileDelete["/v1/files/{id} DELETE"]
            API_Health_AS["Health/Ready/Metrics<br/>:8081"]
        end

        subgraph Processor["batch-gateway-processor<br/>(Go Background Worker)"]
            JobDequeue["Job Dequeue<br/>(BZMPOP)"]
            PlanBuilder["Per-Model<br/>Execution Plans"]
            Dispatcher["Inference Dispatcher<br/>(AIMD Concurrency)"]
            ResultWriter["Result Writer"]
            CrashRecovery["Crash Recovery<br/>(startup scan)"]
            Metrics_Proc["Health/Metrics<br/>:9090"]
        end

        subgraph GC["batch-gateway-gc<br/>(Go Background Worker)"]
            Collector["Expired Job/File<br/>Collector"]
            Reconciler["Orphan Job<br/>Reconciler"]
            Metrics_GC["Health/Metrics<br/>:9091"]
        end
    end

    %% External Clients
    Client[External Client] -->|"POST /v1/batches<br/>8000/TCP"| API_BatchCreate
    Client -->|"POST /v1/files<br/>8000/TCP"| API_FileUpload

    %% Gateway Auth
    Gateway["Kuadrant / Authorino<br/>(Gateway Auth)"] -.->|"AuthN/AuthZ<br/>before request"| Apiserver

    %% Shared Data Layer
    subgraph DataLayer["Shared Data Layer"]
        PostgreSQL[("PostgreSQL<br/>5432/TCP<br/>Metadata")]
        Redis[("Redis / Valkey<br/>6379/TCP<br/>Queue + Events")]
        S3[("S3 Storage<br/>443/TCP<br/>Files")]
    end

    %% Apiserver → Data Layer
    API_BatchCreate -->|"pgx"| PostgreSQL
    API_BatchCreate -->|"ZADD priority queue"| Redis
    API_FileUpload -->|"PutObject"| S3

    %% Processor → Data Layer
    JobDequeue -->|"BZMPOP"| Redis
    PlanBuilder -->|"query jobs"| PostgreSQL
    Dispatcher -->|"read input"| S3
    ResultWriter -->|"write output"| S3
    ResultWriter -->|"update status"| PostgreSQL

    %% Processor → Inference
    InferenceGW["llm-d Router<br/>Inference Gateway"]
    Dispatcher -->|"HTTP/HTTPS POST<br/>chat/completions"| InferenceGW

    %% GC → Data Layer
    Collector -->|"query expired"| PostgreSQL
    Collector -->|"delete files"| S3
    Reconciler -->|"scan inflight hash"| Redis

    %% Cancellation flow
    API_BatchCancel -->|"RPUSH event"| Redis
    Redis -->|"BLMPOP event"| Dispatcher

    %% Observability
    Prometheus["Prometheus"] -.->|"scrape"| API_Health_AS
    Prometheus -.->|"scrape"| Metrics_Proc
    Prometheus -.->|"scrape"| Metrics_GC

    %% Styling
    style Apiserver fill:#4a90e2,stroke:#333,color:#fff
    style Processor fill:#7ed321,stroke:#333,color:#fff
    style GC fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
