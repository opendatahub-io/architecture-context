graph TB
    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph APIServer["API Server (Go HTTP Service)"]
            APIRoutes["REST API Routes<br/>/v1/batches, /v1/files"]
            ReqMiddleware["Request Middleware<br/>Tenant extraction"]
            SecurityHeaders["Security Headers<br/>Middleware"]
            RecoveryMW["Recovery Middleware"]
            HealthAPI["Health/Ready/Metrics<br/>Port 8081/TCP"]
        end

        subgraph Processor["Batch Processor (Go Background Worker)"]
            Poller["Queue Poller<br/>BZMPop"]
            Preprocessor["Preprocessor<br/>Plan Builder"]
            Executor["Executor<br/>Inference Dispatcher"]
            Finalizer["Finalizer<br/>Result Uploader"]
            Recovery["Startup Recovery"]
            CancelWatcher["Cancel Event Watcher"]
            HealthProc["Health/Ready/Metrics<br/>Port 9090/TCP"]
        end

        subgraph GC["Garbage Collector (Go Background Worker)"]
            Scanner["Expiry Scanner"]
            Cleaner["Metadata + File Cleaner"]
        end
    end

    %% External clients
    Client["External Client<br/>(API Consumer)"]
    AuthGW["Kuadrant/Authorino<br/>Auth Gateway"]

    %% Data stores
    PostgreSQL[("PostgreSQL<br/>5432/TCP<br/>Metadata Storage")]
    Redis[("Redis/Valkey<br/>6379/TCP<br/>Queue + Events + Status")]
    S3[("S3-Compatible Storage<br/>443/TCP<br/>File Storage")]

    %% Downstream
    InferenceGW["llm-d Inference Gateway<br/>HTTP/HTTPS<br/>Global or Per-Model"]

    %% Client flow
    Client -->|"API requests"| AuthGW
    AuthGW -->|"Tenant header injected"| APIRoutes
    APIRoutes --> ReqMiddleware
    ReqMiddleware --> SecurityHeaders

    %% API Server connections
    APIServer -->|"pgx 5432/TCP"| PostgreSQL
    APIServer -->|"RESP 6379/TCP"| Redis
    APIServer -->|"HTTPS 443/TCP"| S3

    %% Processor connections
    Poller -->|"BZMPop 6379/TCP"| Redis
    Preprocessor -->|"Download input"| S3
    Executor -->|"Inference requests"| InferenceGW
    Finalizer -->|"Upload results"| S3
    Finalizer -->|"Update status"| PostgreSQL
    CancelWatcher -->|"BLMPop events"| Redis

    %% Processor internal flow
    Poller --> Preprocessor
    Preprocessor --> Executor
    Executor --> Finalizer

    %% GC connections
    GC -->|"Query expired"| PostgreSQL
    GC -->|"Query expired"| Redis
    GC -->|"Delete files"| S3

    %% Observability
    Prometheus["Prometheus<br/>Metrics Scrape"]
    OTel["OpenTelemetry Collector<br/>gRPC Trace Export"]

    HealthAPI -.->|"scrape /metrics"| Prometheus
    HealthProc -.->|"scrape /metrics"| Prometheus
    BatchGateway -.->|"OTLP traces"| OTel

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Processor fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style GC fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#569a31,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style AuthGW fill:#e67e22,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style OTel fill:#425cc7,stroke:#333,color:#fff
