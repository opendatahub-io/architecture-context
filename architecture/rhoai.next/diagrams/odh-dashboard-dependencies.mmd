graph LR
    Dashboard["ODH Dashboard<br/>(React + Node.js + Go BFFs)"]

    %% External Runtime Dependencies
    subgraph ExtDeps["External Runtime Dependencies"]
        NodeJS["Node.js >=22.0.0"]
        Go["Go 1.24-1.25"]
        Fastify["Fastify ^4.28.1"]
        React["React ^18.2.0"]
        PatternFly["PatternFly ^6.4.x"]
        ModFed["@module-federation/runtime ^0.15.0"]
        Redux["Redux ^4.2.0"]
    end

    Dashboard -->|runtime| NodeJS
    Dashboard -->|runtime| Go
    Dashboard -->|framework| Fastify
    Dashboard -->|UI| React
    Dashboard -->|design system| PatternFly
    Dashboard -->|plugin system| ModFed
    Dashboard -->|state mgmt| Redux

    %% Internal Platform Dependencies (ODH/RHOAI)
    subgraph InternalDeps["Internal Platform Dependencies (ODH/RHOAI)"]
        Operator["rhods-operator<br/>CRD Watch"]
        KServe["KServe<br/>InferenceService, ServingRuntime"]
        DSPipelines["Data Science Pipelines<br/>REST API proxy"]
        ModelReg["Model Registry<br/>REST API proxy (8080/TCP)"]
        ModelCat["Model Catalog<br/>REST API proxy (8081/TCP)"]
        TrustyAI["TrustyAI<br/>REST API proxy"]
        LlamaStack["LlamaStack (OGXServer)<br/>REST API proxy"]
        MaaSCtrl["MaaS Controller<br/>REST API"]
        NemoGuard["NeMo Guardrails<br/>REST API proxy"]
        MLflowSvc["MLflow Tracking<br/>REST API proxy"]
        EvalHubSvc["EvalHub<br/>REST API proxy"]
        FeastSvc["Feast Registry<br/>REST API proxy (8443/TCP)"]
        NotebookCtrl["Notebook Controller<br/>CRD Watch"]
    end

    Dashboard -->|CRD watch| Operator
    Dashboard -->|model serving| KServe
    Dashboard -->|pipelines| DSPipelines
    Dashboard -->|models| ModelReg
    Dashboard -->|catalog| ModelCat
    Dashboard -->|fairness| TrustyAI
    Dashboard -->|LLM inference| LlamaStack
    Dashboard -->|MaaS mgmt| MaaSCtrl
    Dashboard -->|moderation| NemoGuard
    Dashboard -->|experiments| MLflowSvc
    Dashboard -->|evaluation| EvalHubSvc
    Dashboard -->|features| FeastSvc
    Dashboard -->|notebooks| NotebookCtrl

    %% Infrastructure Dependencies
    subgraph InfraDeps["Infrastructure Dependencies"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
        Prometheus["Prometheus / Thanos<br/>443/TCP HTTPS"]
        PlatformGW["Platform Gateway<br/>(Envoy)"]
        OSConsole["OpenShift Console<br/>ConsoleLink CRD"]
    end

    Dashboard -->|resource CRUD| K8sAPI
    Dashboard -->|metrics| Prometheus
    Dashboard -->|ingress| PlatformGW
    Dashboard -->|console link| OSConsole

    %% External Services
    subgraph ExtSvcs["External Services"]
        S3["S3 (AWS/MinIO)<br/>443/TCP HTTPS"]
        MCPServers["MCP Servers<br/>dynamic HTTP/HTTPS"]
    end

    Dashboard -->|data files| S3
    Dashboard -->|tools| MCPServers

    %% Components that integrate WITH the dashboard
    subgraph Consumers["Consumers (integrate WITH dashboard)"]
        Perses["Perses<br/>Monitoring dashboards"]
    end

    Perses -.->|observes| Dashboard

