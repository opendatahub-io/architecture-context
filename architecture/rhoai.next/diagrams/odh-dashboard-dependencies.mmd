graph LR
    Dashboard["ODH Dashboard<br/>(Host + 7 BFF Sidecars)"]

    %% Platform Dependencies
    Dashboard -->|"K8s API passthrough<br/>CRD CRUD/Watch<br/>RBAC (SAR)"| K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
    Dashboard -->|"Auth enforcement<br/>SubjectAccessReview"| KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
    Dashboard -->|"External ingress<br/>HTTPRoute"| GatewayAPI["Gateway API<br/>(data-science-gateway)"]
    Dashboard -->|"PromQL queries<br/>9092/TCP"| Thanos["Thanos Querier<br/>(openshift-monitoring)"]

    %% Internal ODH Dependencies
    Dashboard -->|"Model CRUD<br/>Catalog queries"| ModelRegistry["Model Registry<br/>Service"]
    Dashboard -->|"Model catalog<br/>browsing"| ModelCatalog["Model Catalog<br/>Service"]
    Dashboard -->|"AI inference<br/>Vector stores<br/>File mgmt"| LlamaStack["LlamaStack<br/>Distribution"]
    Dashboard -->|"Subscriptions<br/>API keys<br/>Policies"| MaaSAPI["MaaS API"]
    Dashboard -->|"Experiment tracking<br/>Prompt mgmt"| MLflow["MLflow Tracking<br/>Server"]
    Dashboard -->|"Content moderation<br/>Safety guardrails"| NeMo["NeMo Guardrails"]
    Dashboard -->|"Pipeline runs<br/>CRUD"| Pipeline["Pipeline Server<br/>(DSPA)"]
    Dashboard -->|"Eval jobs<br/>Collections"| EvalHub["EvalHub<br/>(TrustyAI)"]
    Dashboard -->|"Tool discovery<br/>MCP protocol"| MCP["MCP Servers"]
    Dashboard -->|"Observability<br/>dashboards"| Perses["Perses"]
    Dashboard -->|"Feature store<br/>metadata"| Feast["Feast Registry"]

    %% External Service Dependencies
    Dashboard -->|"Data upload/<br/>download<br/>AWS IAM"| S3["S3/MinIO<br/>443/TCP HTTPS"]

    %% Consumers (components that depend on Dashboard)
    Operator["rhods-operator /<br/>opendatahub-operator"] -->|"Deploys via<br/>kustomize"| Dashboard
    DSC["DataScienceCluster"] -.->|"CRD Watch"| Dashboard

    %% CRDs Owned/Managed
    Dashboard -->|"Owns"| OdhDashboardConfig["OdhDashboardConfig<br/>CRD"]
    Dashboard -->|"Owns"| OdhApplication["OdhApplication<br/>CRD"]
    Dashboard -->|"Owns"| OdhDocument["OdhDocument<br/>CRD"]
    Dashboard -->|"Owns"| OdhQuickStart["OdhQuickStart<br/>CRD"]

    %% CRDs Watched/Used
    Dashboard -.->|"Watches"| Notebook["Notebook<br/>(kubeflow.org)"]
    Dashboard -.->|"Watches"| InferenceService["InferenceService<br/>(serving.kserve.io)"]
    Dashboard -.->|"Watches"| HardwareProfile["HardwareProfile"]
    Dashboard -.->|"CRUD"| ServingRuntime["ServingRuntime<br/>(serving.kserve.io)"]
    Dashboard -.->|"CRUD"| NIMAccount["NIM Account"]

    %% Styling
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Platform (purple)
    style K8sAPI fill:#e1d5e7,stroke:#9673a6
    style KubeRBACProxy fill:#f8cecc,stroke:#b85450
    style GatewayAPI fill:#e1d5e7,stroke:#9673a6
    style Thanos fill:#e1d5e7,stroke:#9673a6

    %% Internal ODH (green)
    style ModelRegistry fill:#d5e8d4,stroke:#82b366
    style ModelCatalog fill:#d5e8d4,stroke:#82b366
    style LlamaStack fill:#d5e8d4,stroke:#82b366
    style MaaSAPI fill:#d5e8d4,stroke:#82b366
    style MLflow fill:#d5e8d4,stroke:#82b366
    style NeMo fill:#d5e8d4,stroke:#82b366
    style Pipeline fill:#d5e8d4,stroke:#82b366
    style EvalHub fill:#d5e8d4,stroke:#82b366
    style MCP fill:#d5e8d4,stroke:#82b366
    style Perses fill:#d5e8d4,stroke:#82b366
    style Feast fill:#d5e8d4,stroke:#82b366

    %% External (yellow)
    style S3 fill:#fff2cc,stroke:#d6b656

    %% Operator/deployer (gray)
    style Operator fill:#e8e8e8,stroke:#999
    style DSC fill:#e8e8e8,stroke:#999

    %% CRDs (light green)
    style OdhDashboardConfig fill:#b8e6d0,stroke:#82b366
    style OdhApplication fill:#b8e6d0,stroke:#82b366
    style OdhDocument fill:#b8e6d0,stroke:#82b366
    style OdhQuickStart fill:#b8e6d0,stroke:#82b366
    style Notebook fill:#b8e6d0,stroke:#82b366
    style InferenceService fill:#b8e6d0,stroke:#82b366
    style HardwareProfile fill:#b8e6d0,stroke:#82b366
    style ServingRuntime fill:#b8e6d0,stroke:#82b366
    style NIMAccount fill:#b8e6d0,stroke:#82b366
