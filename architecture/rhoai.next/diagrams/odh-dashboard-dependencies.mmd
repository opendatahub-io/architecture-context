graph LR
    ODHDashboard["ODH Dashboard<br/>(Host + 7 BFF Sidecars)"]

    %% ──────────────────────────────────────────────
    %% Platform Infrastructure Dependencies
    %% ──────────────────────────────────────────────
    subgraph Platform["Platform Infrastructure"]
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        GatewayAPI["Gateway API<br/>(data-science-gateway)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
        ThanosQuerier["Thanos Querier<br/>9092/TCP"]
    end

    ODHDashboard -->|"K8s CRUD + watch<br/>HTTPS/6443"| K8sAPI
    ODHDashboard -->|"external ingress<br/>HTTPRoute"| GatewayAPI
    ODHDashboard -->|"auth enforcement<br/>8443→8080"| KubeRBACProxy
    ODHDashboard -->|"Prometheus queries<br/>HTTPS/9092"| ThanosQuerier

    %% ──────────────────────────────────────────────
    %% Internal ODH/RHOAI Dependencies
    %% ──────────────────────────────────────────────
    subgraph InternalODH["Internal ODH/RHOAI Components"]
        RHODSOperator["rhods-operator<br/>(deploys dashboard)"]
        ModelRegistrySvc["Model Registry<br/>REST API"]
        ModelCatalogSvc["Model Catalog<br/>REST API"]
        LlamaStackSvc["LlamaStack<br/>REST API · TLS 1.3"]
        MaaSAPISvc["MaaS API<br/>HTTPS"]
        MLflowSvc["MLflow Tracking<br/>REST API"]
        NeMoSvc["NeMo Guardrails<br/>HTTPS"]
        PipelineSvc["Pipeline Server<br/>(DSPA)"]
        EvalHubSvc["EvalHub<br/>(TrustyAI)"]
        PerseSvc["Perses<br/>HTTP/8080"]
        FeastSvc["Feast Registry<br/>HTTPS"]
    end

    RHODSOperator -->|"deploys via<br/>kustomize"| ODHDashboard
    ODHDashboard -->|"model CRUD<br/>via MR BFF"| ModelRegistrySvc
    ODHDashboard -->|"catalog browse<br/>via MR BFF"| ModelCatalogSvc
    ODHDashboard -->|"AI inference<br/>via Gen AI BFF"| LlamaStackSvc
    ODHDashboard -->|"subscriptions<br/>via MaaS BFF"| MaaSAPISvc
    ODHDashboard -->|"experiments<br/>via MLflow BFF"| MLflowSvc
    ODHDashboard -->|"guardrails<br/>via Gen AI BFF"| NeMoSvc
    ODHDashboard -->|"pipeline runs<br/>via AutoML/RAG BFFs"| PipelineSvc
    ODHDashboard -->|"evaluations<br/>via Eval Hub BFF"| EvalHubSvc
    ODHDashboard -->|"observability<br/>via host"| PerseSvc
    ODHDashboard -->|"feature stores<br/>via host"| FeastSvc

    %% ──────────────────────────────────────────────
    %% External Service Dependencies
    %% ──────────────────────────────────────────────
    subgraph ExternalSvc["External Services"]
        S3["S3/MinIO<br/>443/TCP HTTPS<br/>AWS IAM"]
        MCPServers["MCP Servers<br/>HTTP (no TLS)"]
    end

    ODHDashboard -->|"data upload/download<br/>via AutoML/RAG BFFs"| S3
    ODHDashboard -->|"tool discovery<br/>via Gen AI BFF"| MCPServers

    %% ──────────────────────────────────────────────
    %% CRD Dependencies (Watched/Managed)
    %% ──────────────────────────────────────────────
    subgraph CRDs["CRDs Watched / Managed"]
        OdhDashboardConfig["OdhDashboardConfig"]
        DSC["DataScienceCluster"]
        DSCI["DSCInitialization"]
        DSPA["DSPA"]
        Notebook["Notebook<br/>(kubeflow.org)"]
        InferenceService["InferenceService<br/>(serving.kserve.io)"]
        MR_CR["ModelRegistry CR"]
        LSD_CR["LlamaStackDistribution"]
        MLflow_CR["MLflow CR"]
        FeatureStore_CR["FeatureStore CR"]
        NIMAccount["NIM Account"]
        HWProfile["HardwareProfile"]
        AccProfile["AcceleratorProfile"]
        GuardrailsOrch["GuardrailsOrchestrator"]
        EvalHub_CR["EvalHub CR"]
        MaaS_CRs["MaaSSubscription<br/>MaaSAuthPolicy<br/>MaaSModelRef"]
    end

    ODHDashboard -.->|"watch + CRUD"| OdhDashboardConfig
    ODHDashboard -.->|"watch"| DSC
    ODHDashboard -.->|"watch"| DSCI
    ODHDashboard -.->|"watch + proxy"| DSPA
    ODHDashboard -.->|"CRUD"| Notebook
    ODHDashboard -.->|"watch"| InferenceService
    ODHDashboard -.->|"CRUD"| MR_CR
    ODHDashboard -.->|"CRUD"| LSD_CR
    ODHDashboard -.->|"watch"| MLflow_CR
    ODHDashboard -.->|"watch"| FeatureStore_CR
    ODHDashboard -.->|"CRUD"| NIMAccount
    ODHDashboard -.->|"read"| HWProfile
    ODHDashboard -.->|"CRUD"| AccProfile
    ODHDashboard -.->|"watch"| GuardrailsOrch
    ODHDashboard -.->|"watch"| EvalHub_CR
    ODHDashboard -.->|"CRUD"| MaaS_CRs

    %% ──────────────────────────────────────────────
    %% Build / Runtime Dependencies
    %% ──────────────────────────────────────────────
    subgraph BuildDeps["Build & Runtime Dependencies"]
        NodeJS["Node.js >=22"]
        ReactLib["React ^18.2"]
        PatternFly["PatternFly ^6.4"]
        Fastify["Fastify ^4.28"]
        Webpack["Webpack ^5.96<br/>+ Module Federation"]
        GoRuntime["Go 1.24-1.25"]
    end

    ODHDashboard -.->|"host runtime"| NodeJS
    ODHDashboard -.->|"UI framework"| ReactLib
    ODHDashboard -.->|"design system"| PatternFly
    ODHDashboard -.->|"HTTP server"| Fastify
    ODHDashboard -.->|"build + MF"| Webpack
    ODHDashboard -.->|"BFF runtime"| GoRuntime

    %% ──────────────────────────────────────────────
    %% Components that depend on ODH Dashboard
    %% ──────────────────────────────────────────────
    subgraph Consumers["Components Using Dashboard"]
        ConsoleLink["OpenShift Console<br/>(ConsoleLink)"]
    end

    ConsoleLink -.->|"links to"| ODHDashboard

