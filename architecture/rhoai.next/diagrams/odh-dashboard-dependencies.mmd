graph LR
    Dashboard["ODH Dashboard<br/>(Frontend + BFF Monorepo)"]

    %% ── Platform Dependencies ──
    subgraph Platform["Platform Dependencies"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        RHODSOp["rhods-operator<br/>(Dashboard CR)"]
        Gateway["OpenShift Gateway<br/>(HTTPRoute)"]
    end

    Dashboard -->|"REST/WebSocket<br/>all K8s ops"| K8sAPI
    RHODSOp -->|"creates Dashboard CR<br/>projects availability"| Dashboard
    Gateway -->|"ingress routing<br/>443→8443"| Dashboard

    %% ── Build Dependencies ──
    subgraph BuildDeps["Build / Runtime Dependencies"]
        NodeJS["Node.js 22+"]
        GoLang["Go 1.26"]
        PatternFly["PatternFly 6.4.x"]
        React["React 18.3.x"]
        Redux["Redux 4.2.x"]
        Fastify["Fastify 4.29.x"]
        ModFed["@module-federation<br/>/runtime 0.15.x"]
        CtrlRuntime["controller-runtime"]
    end

    Dashboard -.->|"frontend"| PatternFly
    Dashboard -.->|"frontend"| React
    Dashboard -.->|"state mgmt"| Redux
    Dashboard -.->|"module loading"| ModFed
    Dashboard -.->|"backend runtime"| NodeJS
    Dashboard -.->|"backend HTTP"| Fastify
    Dashboard -.->|"BFF compilation"| GoLang
    Dashboard -.->|"operator framework"| CtrlRuntime

    %% ── Data Science Platform Services ──
    subgraph DSServices["Data Science Platform Services (Internal RHOAI)"]
        DSPipelines["Data Science Pipelines<br/>8443/TCP HTTPS"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP"]
        TrustyAI["TrustyAI<br/>443/TCP HTTPS"]
        KServe["KServe<br/>(InferenceService CRD)"]
        Notebooks["Kubeflow Notebooks<br/>(Notebook CRD)"]
        Thanos["Thanos Querier<br/>443/TCP HTTPS"]
        Perses["Perses<br/>8080/TCP HTTP"]
    end

    Dashboard -->|"pipeline CRUD"| DSPipelines
    Dashboard -->|"model CRUD"| ModelRegistry
    Dashboard -->|"bias monitoring"| TrustyAI
    Dashboard -->|"CRD watch"| KServe
    Dashboard -->|"CRD CRUD"| Notebooks
    Dashboard -->|"Prometheus metrics"| Thanos
    Dashboard -->|"observability dashboards"| Perses

    %% ── AI/ML Services ──
    subgraph AIServices["AI/ML Services"]
        LlamaStack["LlamaStack<br/>443/TCP HTTPS"]
        MaaSGW["MaaS Gateway<br/>443/TCP HTTPS"]
        MLflow["MLflow Tracking<br/>443/TCP HTTPS"]
        NeMo["NeMo Guardrails<br/>443/TCP HTTPS"]
        OGX["OGX<br/>8443/TCP HTTPS"]
        EvalHub["EvalHub API<br/>443/TCP HTTPS"]
        Feast["Feast Registry<br/>HTTPS"]
    end

    Dashboard -->|"GenAI inference<br/>(gen-ai BFF)"| LlamaStack
    Dashboard -->|"MaaS API<br/>(maas BFF)"| MaaSGW
    Dashboard -->|"experiment tracking<br/>(mlflow BFF)"| MLflow
    Dashboard -->|"content moderation<br/>(gen-ai BFF)"| NeMo
    Dashboard -->|"models/vectors<br/>(autorag BFF)"| OGX
    Dashboard -->|"evaluation jobs<br/>(eval-hub BFF)"| EvalHub
    Dashboard -->|"feature stores<br/>(backend)"| Feast

    %% ── External Services ──
    subgraph ExtServices["External Services"]
        S3["AWS S3 / MinIO<br/>443/TCP HTTPS"]
    end

    Dashboard -->|"artifact storage<br/>(automl, autorag BFFs)"| S3

    %% ── CRD Dependencies ──
    subgraph CRDs["CRD Watch/CRUD"]
        DSC["DataScienceCluster"]
        DSCI["DSCInitialization"]
        OdhConfig["OdhDashboardConfig"]
        AgentRT["AgentRuntime<br/>(kagenti.dev)"]
        MCPReg["MCPServerRegistration"]
        NIMAcct["NIM Accounts"]
        MaaSSub["MaaSSubscription"]
    end

    Dashboard -.->|"watch"| DSC
    Dashboard -.->|"watch"| DSCI
    Dashboard -.->|"CRUD"| OdhConfig
    Dashboard -.->|"watch (agent-ops)"| AgentRT
    Dashboard -.->|"watch (agent-ops)"| MCPReg
    Dashboard -.->|"CRUD"| NIMAcct
    Dashboard -.->|"CRUD (maas)"| MaaSSub

    %% ── Consumers ──
    subgraph Consumers["Consumers of Dashboard"]
        Console["OpenShift Console<br/>(ConsoleLink CR)"]
    end

    Dashboard -->|"ConsoleLink"| Console

