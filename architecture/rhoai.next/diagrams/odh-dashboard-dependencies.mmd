graph LR
    Dashboard["ODH Dashboard<br/>(Host + 7 BFF Sidecars)"]

    %% External Dependencies (Required)
    Dashboard -->|"runtime"| NodeJS["Node.js 22+"]
    Dashboard -->|"UI framework"| React["React 18"]
    Dashboard -->|"design system"| PatternFly["PatternFly 6"]
    Dashboard -->|"HTTP server"| FastifyDep["Fastify 4.28"]
    Dashboard -->|"module federation"| Webpack["Webpack 5 + MF"]
    Dashboard -->|"BFF runtime"| Go["Go 1.24-1.25"]

    %% Platform Dependencies (Sidecar/Infrastructure)
    Dashboard -->|"auth enforcement<br/>8443→8080"| KubeRBACProxy["kube-rbac-proxy"]
    Dashboard -->|"external ingress<br/>HTTPRoute"| GatewayAPI["Gateway API<br/>(data-science-gateway)"]
    Dashboard -->|"deploys via<br/>kustomize"| Operator["rhods-operator /<br/>opendatahub-operator"]

    %% Internal ODH Dependencies (CRD Watch + API)
    Dashboard -->|"CRD Watch +<br/>API Proxy"| DSPA["DataSciencePipelines<br/>Application"]
    Dashboard -->|"CRD Watch +<br/>REST API"| ModelReg["Model Registry"]
    Dashboard -->|"CRD CRUD"| KServe["KServe /<br/>ServingRuntime"]
    Dashboard -->|"CRD Watch +<br/>API Proxy"| TrustyAI["TrustyAI /<br/>EvalHub"]
    Dashboard -->|"CRD CRUD +<br/>REST API"| LlamaStack["LlamaStack<br/>Distribution"]
    Dashboard -->|"CRD Watch +<br/>REST API"| MLflow["MLflow"]
    Dashboard -->|"CRD Watch"| Feast["Feast<br/>FeatureStore"]
    Dashboard -->|"CRD CRUD"| NIM["NIM Account"]
    Dashboard -->|"CRD Watch"| DSCluster["DataScienceCluster /<br/>DSCInitialization"]
    Dashboard -->|"CRD CRUD"| Notebooks["Notebook<br/>(kubeflow.org)"]
    Dashboard -->|"CRD Read"| HWProfile["HardwareProfile /<br/>AcceleratorProfile"]

    %% External Service Dependencies
    Dashboard -->|"all K8s ops<br/>6443/TCP"| K8sAPI["Kubernetes API"]
    Dashboard -->|"PromQL<br/>9092/TCP"| Thanos["Thanos Querier"]
    Dashboard -->|"observability<br/>8080/TCP"| Perses["Data Science Perses"]
    Dashboard -->|"model inference<br/>HTTPS"| LlamaStackSvc["LlamaStack API"]
    Dashboard -->|"model subscriptions<br/>HTTPS"| MaaSAPI["MaaS API"]
    Dashboard -->|"experiment tracking<br/>HTTPS"| MLflowSvc["MLflow Server"]
    Dashboard -->|"content moderation<br/>HTTPS"| NeMo["NeMo Guardrails"]
    Dashboard -->|"object storage<br/>443/TCP"| S3["S3/MinIO"]
    Dashboard -->|"pipeline runs<br/>HTTPS"| PipelineSvr["Pipeline Server"]
    Dashboard -->|"tool discovery<br/>HTTP"| MCP["MCP Servers"]
    Dashboard -->|"model catalog<br/>HTTPS"| ModelCatalog["Model Catalog"]

    %% Consumers of Dashboard
    Operator -.->|"deploys"| Dashboard

    %% Styling
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    classDef extDep fill:#e8e8e8,stroke:#999,stroke-width:1px
    classDef platformDep fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    classDef internalDep fill:#7ed321,stroke:#333,stroke-width:1px
    classDef externalSvc fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class NodeJS,React,PatternFly,FastifyDep,Webpack,Go extDep
    class KubeRBACProxy,GatewayAPI,Operator platformDep
    class DSPA,ModelReg,KServe,TrustyAI,LlamaStack,MLflow,Feast,NIM,DSCluster,Notebooks,HWProfile internalDep
    class K8sAPI,Thanos,Perses,LlamaStackSvc,MaaSAPI,MLflowSvc,NeMo,S3,PipelineSvr,MCP,ModelCatalog externalSvc
