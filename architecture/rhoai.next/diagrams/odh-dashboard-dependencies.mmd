graph LR
    Dashboard["odh-dashboard<br/>React SPA + Node.js BFF<br/>+ 7 Go BFF Sidecars"]

    %% External Dependencies (Build/Runtime)
    subgraph ExtDeps["External Dependencies"]
        NodeJS["Node.js 22.x"]
        React["React 18.x"]
        Fastify["Fastify 4.x"]
        Webpack["Webpack 5.x<br/>(Module Federation)"]
        PatternFly["PatternFly 6.x"]
        K8sClient["@kubernetes/client-node"]
        ModFed["@module-federation/runtime 0.15.x"]
        Redux["Redux 4.x"]
        ReactRouter["React Router 7.x"]
        GoHTTPRouter["httprouter (Go)"]
        AWSSDK["AWS SDK v2 (Go)"]
    end

    Dashboard -->|"runtime"| NodeJS
    Dashboard -->|"frontend"| React
    Dashboard -->|"backend"| Fastify
    Dashboard -->|"build"| Webpack
    Dashboard -->|"UI components"| PatternFly
