graph LR
    ODHDashboard["ODH Dashboard<br/>(React SPA + Node.js BFF<br/>+ 7 Go BFF Sidecars)"]

    %% Platform Dependencies (Required)
    ODHDashboard -->|"REST + WSS<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    ODHDashboard -->|"OAuth2<br/>443/TCP HTTPS"| OAuth["OpenShift OAuth Server"]
    ODHDashboard -->|"sidecar<br/>8443/TCP HTTPS"| KubeRBAC["kube-rbac-proxy"]
    ODHDashboard -->|"metrics<br/>9092/TCP HTTPS"| Thanos["Thanos Querier<br/>(openshift-monitoring)"]

    %% Internal RHOAI Dependencies
    ODHDashboard -->|"proxy<br/>8443/TCP HTTPS"| DSPipelines["DS Pipelines<br/>(Kubeflow Pipelines)"]
    ODHDashboard -->|"proxy<br/>8080/TCP HTTP"| ModelRegistry["Model Registry"]
    ODHDashboard -->|"proxy<br/>8080/TCP HTTP"| TrustyAI["TrustyAI / EvalHub"]
    ODHDashboard -->|"proxy<br/>8321/TCP HTTP"| LlamaStack["LlamaStack Distribution"]
    ODHDashboard -->|"proxy<br/>8443/TCP HTTPS"| MaaSAPI["MaaS API"]
    ODHDashboard -->|"proxy<br/>5000/TCP HTTP"| MLflow["MLflow Tracking Server"]
    ODHDashboard -->|"proxy<br/>9090/TCP HTTP"| MLMD["DS Pipeline Metadata<br/>(Envoy)"]

    %% CRD-based Dependencies
    ODHDashboard -.->|"CRD watch"| KServe["KServe<br/>(serving.kserve.io)"]
    ODHDashboard -.->|"CRD watch"| Feast["Feature Store<br/>(Feast)"]
    ODHDashboard -.->|"CRD watch"| DSC["Data Science Cluster<br/>(DSC/DSCI)"]
    ODHDashboard -.->|"CRD manage"| NIM["NVIDIA NIM<br/>(nim.opendatahub.io)"]
    ODHDashboard -.->|"CRD watch"| OLM["Operator Lifecycle<br/>(OLM Subscriptions)"]

    %% External Dependencies
    ODHDashboard -->|"data access<br/>443/TCP HTTPS"| S3["S3-compatible Storage"]

    %% Components that depend ON the dashboard
    Dashboard["ODH Dashboard<br/>(this component)"]
    OpenShiftConsole["OpenShift Console"] -.->|"ConsoleLink"| Dashboard
    Operator["ODH/RHOAI Operator"] -.->|"deploys"| Dashboard

    %% Build Dependencies
    subgraph BuildDeps["Build & Runtime Dependencies"]
        direction TB
        NodeJS["Node.js 22.x"]
        React["React 18.x"]
        Fastify["Fastify 4.x"]
        Webpack["Webpack 5.x<br/>Module Federation"]
        PatternFly["PatternFly 6.x"]
        Redux["Redux 4.x"]
        ReactRouter["React Router 7.x"]
        GoRuntime["Go 1.24/1.25<br/>(BFF modules)"]
        AWSSDK["AWS SDK v2 (Go)<br/>(AutoML/AutoRAG)"]
    end

