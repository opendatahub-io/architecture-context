    Dashboard -->|"S3 access"| AWSSDK

    %% Platform Dependencies
    subgraph PlatformDeps["Platform Dependencies"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        KubeRBAC["kube-rbac-proxy<br/>(sidecar)"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS"]
    end

    Dashboard -->|"all resource CRUD<br/>REST + WebSocket"| K8sAPI
    Dashboard -->|"auth enforcement<br/>(sidecar container)"| KubeRBAC
    Dashboard -->|"user authentication"| OAuth
    Dashboard -->|"Prometheus metrics"| Thanos

    %% Internal RHOAI Dependencies
    subgraph RHOAIDeps["Internal RHOAI Dependencies"]
        DSPipelines["DS Pipelines<br/>8443/TCP HTTPS"]
        MLMD["DS Pipeline Metadata Envoy<br/>9090/TCP HTTP"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP"]
        TrustyAI["TrustyAI / EvalHub<br/>8080/TCP HTTP"]
        KServe["KServe<br/>(CRD watch)"]
        LlamaStack["LlamaStack Distribution<br/>8321/TCP HTTP"]
        MaaSAPI["MaaS API<br/>8443/TCP HTTPS"]
        MLflowSvc["MLflow Tracking Server<br/>5000/TCP HTTP"]
        Feast["Feature Store (Feast)<br/>(CRD watch)"]
        DSC["Data Science Cluster<br/>(CRD watch)"]
        DSCI["DSC Initialization<br/>(CRD watch)"]
        NIM["NVIDIA NIM<br/>(CRD management)"]
        ModelCatalog["Model Catalog API<br/>8080/TCP HTTP"]
    end

    Dashboard -->|"pipeline proxy"| DSPipelines
    Dashboard -->|"metadata proxy"| MLMD
    Dashboard -->|"registry proxy"| ModelRegistry
    Dashboard -->|"explainability proxy"| TrustyAI
    Dashboard -->|"serving CRDs"| KServe
    Dashboard -->|"Gen AI proxy"| LlamaStack
    Dashboard -->|"MaaS proxy"| MaaSAPI
    Dashboard -->|"MLflow proxy"| MLflowSvc
    Dashboard -->|"feature store status"| Feast
    Dashboard -->|"platform status"| DSC
    Dashboard -->|"init status"| DSCI
    Dashboard -->|"NIM accounts"| NIM
    Dashboard -->|"catalog browse"| ModelCatalog

    %% Integration Points (consume dashboard)
    subgraph Consumers["Components That Integrate With Dashboard"]
        Console["OpenShift Console<br/>(ConsoleLink)"]
        OLM["OLM Subscriptions<br/>(operator status)"]
        Perses["Perses<br/>(observability dashboards)"]
    end

    Console -.->|"ConsoleLink CRD"| Dashboard
    OLM -.->|"subscription status"| Dashboard
    Perses -.->|"observability"| Dashboard

    %% External Services
    subgraph ExtSvc["External Services"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    end

    Dashboard -->|"data files<br/>(AutoML, AutoRAG)"| S3

