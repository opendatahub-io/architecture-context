graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["MLflow SDK Client"]
        Browser["Browser<br/>(ODH Dashboard)"]
        OTel["OTel Collector / SDK"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["ODH Data Science Gateway<br/>HTTPRoute /mlflow<br/>443/TCP → 5000/TCP<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph Application["APPLICATION (MLflow Server Pod)"]
        direction TB

        subgraph Server["MLflow Server (ClusterIP: mlflow-server)"]
            FastAPI["FastAPI + Flask<br/>Port 5000/TCP<br/>TLS terminated at pod"]
            AuthPlugin["kubernetes-auth Plugin<br/>SelfSubjectAccessReview<br/>mlflow.kubeflow.org resources"]
            WorkspacePlugin["Kubernetes Workspace Provider<br/>Namespace → Workspace mapping"]
            CryptoEngine["Secrets Encryption<br/>AES-256-GCM<br/>PBKDF2 600K iterations"]
        end

        FastAPI -->|authenticates via| AuthPlugin
        AuthPlugin -->|resolves| WorkspacePlugin
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS 1.2+ (configurable)<br/>Username/password"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / HMAC"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (disabled by default in RHOAI)"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted)"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted)"]
        Gemini["Google Gemini API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted)"]
    end

    Prometheus["Prometheus<br/>Scrapes /metrics"]

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| Gateway
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Browser session"| Gateway
    OTel -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token + x-mlflow-experiment-id"| Gateway
    Gateway -->|"HTTP/5000<br/>TLS at pod<br/>Bearer Token forwarded"| FastAPI

    %% Internal egress
    AuthPlugin -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    WorkspacePlugin -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    FastAPI -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/password"| PostgreSQL
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / HMAC"| S3

    %% External egress (AI Gateway)
    FastAPI -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI
    FastAPI -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Anthropic
    FastAPI -.->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Gemini

    %% Metrics
    Prometheus -.->|"HTTP/5000<br/>scrape"| FastAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client,Browser,OTel external
    class Gateway ingress
    class FastAPI,WorkspacePlugin application
    class AuthPlugin,CryptoEngine security
    class K8sAPI,PostgreSQL,S3 internal
    class OpenAI,Anthropic,Gemini externalservice
    class Prometheus monitoring
