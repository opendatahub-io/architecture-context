graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser<br/>OAuth/OIDC"]
        MLPod["ML Workload Pod<br/>Bearer Token (K8s SA)"]
        OTELApp["OTEL-instrumented App<br/>Bearer Token"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway<br/>HTTPRoute (Gateway API)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph AuthProxy["AUTH PROXY (Trust Boundary)"]
        KubeRBAC["kube-rbac-proxy<br/>(Sidecar Container)<br/>8443/TCP → 5000/TCP<br/>TLS termination<br/>K8s SA Token validation"]
    end

    subgraph Application["APPLICATION (Pod-Internal, Trusted)"]
        direction TB

        subgraph ServerCore["MLflow Server - 5000/TCP HTTP (plaintext, pod-local)"]
            direction TB
            AuthProvider["kubernetes-namespaced<br/>Auth Provider<br/>Workspace resolution"]
            AuthMW["Auth Middleware<br/>READ/USE/EDIT/MANAGE"]
            SecurityMW["Security Middleware<br/>CORS + Host validation<br/>DNS rebinding protection"]
            Flask["Flask REST/Protobuf API"]
            FastAPI["FastAPI<br/>(Jobs, Gateway, OTLP)"]
        end

        subgraph Unauthenticated["Unauthenticated Endpoints"]
            Health["GET /health"]
            Version["GET /version"]
        end
    end

    subgraph EgressServices["EGRESS - External Services"]
        PG["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire<br/>TLS 1.2+<br/>Username/Password"]
        S3["S3 / MinIO<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure credentials"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]
    end

    subgraph LLMProviders["EGRESS - AI Gateway Providers"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted DB)"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted DB)"]
        Gemini["Google Gemini API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted DB)"]
        Mistral["Mistral API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (encrypted DB)"]
    end

    subgraph FederationZone["MODULE FEDERATION"]
        Dashboard["RHOAI Dashboard<br/>(Federation Host)"]
        FedBundle["MLflow remoteEntry.js<br/>Experiment/Prompt/Run<br/>Wrappers"]
    end

    %% Ingress flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway
    MLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    OTELApp -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| KubeRBAC
    KubeRBAC -->|"HTTP/5000<br/>Plaintext (pod-local)<br/>Validated token forwarded"| ServerCore

    %% Egress flows
    Flask -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>Username/Password"| PG
    Flask -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Flask -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure creds"| Azure
    Flask -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% AI Gateway flows
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Anthropic
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Gemini
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Mistral

    %% Module Federation
    Dashboard -->|"HTTPS/443<br/>loads remoteEntry.js"| FedBundle

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef llmprovider fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef federation fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef unauth fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Browser,MLPod,OTELApp external
    class Gateway ingress
    class KubeRBAC authproxy
    class AuthProvider,AuthMW,SecurityMW,Flask,FastAPI application
    class Health,Version unauth
    class PG,S3,Azure,GCS,K8sAPI egress
    class OpenAI,Anthropic,Gemini,Mistral llmprovider
    class Dashboard,FedBundle federation
