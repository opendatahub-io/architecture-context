graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["MLflow SDK / Browser<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["ODH Data Science Gateway<br/>HTTPRoute: /mlflow<br/>443/TCP → 5000/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Token passthrough"]
    end

    subgraph Application["APPLICATION (MLflow Server)"]
        direction TB

        subgraph SecurityChain["Security Middleware"]
            K8sAuth["kubernetes-auth plugin<br/>Bearer Token validation<br/>SelfSubjectAccessReview<br/>Default: NO_PERMISSIONS"]
            CORS["CORS / Origin Validation<br/>block_cross_origin_state_changes<br/>MLFLOW_SERVER_CORS_ALLOWED_ORIGINS"]
            WorkspaceMixin["workspace_aware_mixin<br/>Query-scoped tenant isolation"]
        end

        subgraph ServiceEndpoints["Service Endpoints"]
            FlaskAPI["Flask REST API<br/>Tracking + Model Registry<br/>/api/2.0/mlflow/*"]
            FastAPIEndpoints["FastAPI Endpoints<br/>Gateway + Traces + Jobs<br/>/gateway/*, /v1/traces"]
            UIServing["React UI + Static Files<br/>/ + /static-files/*<br/>No auth required"]
        end

        K8sAuth --> CORS
        CORS --> WorkspaceMixin
        WorkspaceMixin --> FlaskAPI
        WorkspaceMixin --> FastAPIEndpoints
    end

    subgraph K8sCluster["KUBERNETES API (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA token auth"]
    end

    subgraph DataStores["DATA STORES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/password"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
    end

    subgraph LLMProviders["AI GATEWAY LLM PROVIDERS (External)"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Gemini["Google Gemini API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Mistral["Mistral API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 5000/TCP HTTP<br/>No auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)<br/>X-MLFLOW-WORKSPACE header"| Gateway
    Gateway -->|"HTTP/5000<br/>No encryption (cluster-internal)<br/>Bearer Token forwarded"| K8sAuth
    Gateway -->|"HTTP/5000<br/>No auth"| UIServing

    K8sAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>SelfSubjectAccessReview"| K8sAPI
    K8sAuth -->|"HTTPS/443<br/>Namespace list/watch<br/>MLflowConfig watch"| K8sAPI

    FlaskAPI -->|"TCP/5432<br/>TLS optional<br/>DB credentials"| PostgreSQL
    FlaskAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS credentials"| S3
    FastAPIEndpoints -->|"TCP/5432<br/>TLS optional<br/>DB credentials"| PostgreSQL
    FastAPIEndpoints -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS credentials"| S3

    FastAPIEndpoints -->|"HTTPS/443<br/>API key (AES-256-GCM)"| OpenAI
    FastAPIEndpoints -->|"HTTPS/443<br/>API key (AES-256-GCM)"| Anthropic
    FastAPIEndpoints -->|"HTTPS/443<br/>API key (AES-256-GCM)"| Gemini
    FastAPIEndpoints -->|"HTTPS/443<br/>API key (AES-256-GCM)"| Mistral

    Prometheus -.->|"HTTP/5000<br/>No auth<br/>/metrics"| FlaskAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef k8s fill:#e1f5fe,stroke:#0277bd,stroke-width:2px
    classDef datastore fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef llmprovider fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef monitoring fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px

    class Client external
    class Gateway ingress
    class K8sAuth,CORS,WorkspaceMixin security
    class FlaskAPI,FastAPIEndpoints,UIServing application
    class K8sAPI k8s
    class PostgreSQL,S3 datastore
    class OpenAI,Anthropic,Gemini,Mistral llmprovider
    class Prometheus monitoring
