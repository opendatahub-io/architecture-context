graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        SDK[MLflow SDK Client<br/>Data Scientist]
        Browser[Browser User]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["ODH Data Science Gateway<br/>HTTPRoute: /mlflow<br/>443/TCP → 5000/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Forwards Bearer Token"]
        HelmIngress["Helm Ingress (optional)<br/>443/TCP → 5000/TCP<br/>TLS configurable"]
    end

    subgraph Application["APPLICATION (MLflow Server)"]
        direction TB

        subgraph SecurityStack["Security Middleware"]
            HostVal["Host Header Validation<br/>(DNS rebinding protection)"]
            CORS["CORS Blocking<br/>(state-changing requests)"]
            K8sAuth["kubernetes-auth Plugin<br/>SelfSubjectAccessReview"]
            BasicAuth["HTTP Basic Auth (fallback)<br/>READ/USE/EDIT/MANAGE"]
            SecHeaders["Security Headers<br/>X-Frame-Options: DENY"]
        end

        subgraph ServerPods["MLflow Server Pod"]
            Flask["Flask App<br/>Legacy Handlers"]
            FastAPI["FastAPI/ASGI<br/>Jobs, Traces, Gateway"]
        end

        subgraph PodSecurity["Pod Security Context"]
            PSC["readOnlyRootFilesystem: true<br/>runAsNonRoot: true<br/>drop: ALL capabilities<br/>seccompProfile: RuntimeDefault"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>ServiceAccount Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>No encryption (in-cluster)<br/>DB credentials (Secret)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO Storage<br/>443/TCP or 9000/TCP<br/>TLS 1.2+ (external)<br/>AWS IAM / Access Keys"]
        LLM["External LLM Providers<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Keys"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>5000/TCP HTTP"]
    end

    %% Ingress flows
    SDK -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)<br/>X-MLFLOW-WORKSPACE"| Gateway
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OpenShift OAuth"| Gateway
    Gateway -->|"HTTP/5000<br/>Optional TLS<br/>Forwarded Bearer Token"| ServerPods
    HelmIngress -->|"HTTP/5000<br/>Optional TLS"| ServerPods

    %% Egress flows
    ServerPods -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>RBAC + NS listing"| K8sAPI
    ServerPods -->|"PostgreSQL/5432<br/>No encryption<br/>DB credentials"| PostgreSQL
    ServerPods -->|"HTTPS/443 or HTTP/9000<br/>TLS 1.2+<br/>AWS IAM"| S3
    ServerPods -->|"HTTPS/443<br/>TLS 1.2+<br/>API Keys"| LLM
    ServerPods -->|"HTTPS/443<br/>TLS 1.2+"| HF

    %% Monitoring
    Prometheus -->|"HTTP/5000<br/>GET /metrics<br/>No auth"| ServerPods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class SDK,Browser external
    class Gateway,HelmIngress ingress
    class Flask,FastAPI application
    class K8sAPI,PostgreSQL internal
    class S3,LLM,HF externalservice
    class Prometheus monitoring
    class HostVal,CORS,K8sAuth,BasicAuth,SecHeaders security
