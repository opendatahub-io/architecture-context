graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        MLPod["ML Workload Pod"]
        Browser["User Browser"]
        OTelSDK["OpenTelemetry SDK"]
        ClientApp["Client Application"]
    end

    subgraph Ingress["INGRESS (Authentication Boundary)"]
        KubeProxy["kube-rbac-proxy Sidecar<br/>8443/TCP → 5000/TCP<br/>TLS 1.2+<br/>Validates K8s SA Token"]
        PlatformGW["Platform Gateway (HTTPRoute)<br/>443/TCP<br/>TLS 1.2+ SIMPLE<br/>Managed by Operator"]
    end

    subgraph Application["APPLICATION (MLflow Server)"]
        direction TB

        subgraph SecurityChain["Security Middleware"]
            CORS["CORS + Host Validation<br/>(DNS rebinding protection)"]
            AuthProvider["kubernetes-namespaced Auth<br/>(workspace resolution)"]
            AuthMiddleware["Permission Middleware<br/>(READ/USE/EDIT/MANAGE)"]
        end

        subgraph ServerProc["Server Process - Port 5000/TCP HTTP"]
            FlaskAPI["Flask REST API<br/>(Protobuf handlers)"]
            FastAPIRoutes["FastAPI Routes<br/>(Jobs, Gateway, OTLP)"]
            GraphQLAPI["GraphQL API"]
        end

        subgraph Unauth["Unauthenticated"]
            Health["/health, /version"]
        end

        subgraph Restricted["Localhost-Only"]
            Assistant["/ajax-api/3.0/mlflow/assistant/*<br/>127.0.0.1/::1"]
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire + TLS 1.2+<br/>User/Pass"]
        S3["S3 / MinIO<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        AzureBlob["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure Credentials"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]
    end

    subgraph LLMProviders["AI GATEWAY PROVIDERS (Conditional)"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Gemini["Google Gemini API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Mistral["Mistral API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    %% Inbound flows
    MLPod -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| KubeProxy
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| PlatformGW
    OTelSDK -->|"HTTP/5000<br/>Protobuf binary<br/>Bearer Token"| KubeProxy
    ClientApp -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KubeProxy

    KubeProxy -->|"HTTP/5000<br/>Plaintext (pod-local)<br/>Validated token fwd"| CORS
    PlatformGW -->|"HTTP/5000<br/>Bearer Token"| CORS

    CORS --> AuthProvider
    AuthProvider --> AuthMiddleware
    AuthMiddleware --> FlaskAPI
    AuthMiddleware --> FastAPIRoutes
    AuthMiddleware --> GraphQLAPI

    %% Egress flows
    FlaskAPI -->|"PostgreSQL/5432<br/>TLS 1.2+<br/>User/Pass"| PostgreSQL
    FlaskAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    FlaskAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Creds"| AzureBlob
    FlaskAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    FastAPIRoutes -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SA)"| K8sAPI
    AuthProvider -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    FastAPIRoutes -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (encrypted)"| OpenAI
    FastAPIRoutes -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (encrypted)"| Anthropic
    FastAPIRoutes -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Gemini
    FastAPIRoutes -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (encrypted)"| Mistral

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef llm fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class MLPod,Browser,OTelSDK,ClientApp external
    class KubeProxy,PlatformGW ingress
    class FlaskAPI,FastAPIRoutes,GraphQLAPI,Health,Assistant application
    class CORS,AuthProvider,AuthMiddleware security
    class PostgreSQL,S3,AzureBlob,GCS,K8sAPI egress
    class OpenAI,Anthropic,Gemini,Mistral llm
