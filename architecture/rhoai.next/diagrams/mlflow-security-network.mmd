graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["MLflow SDK / Browser<br/>OTel Instrumented App"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["ODH Data Science Gateway<br/>HTTPRoute: /mlflow<br/>443/TCP → 5000/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Bearer Token forwarded"]
    end

    subgraph Application["APPLICATION (Cluster-Internal)"]
        direction TB

        subgraph SecurityChain["Security Middleware"]
            K8sAuth["kubernetes-auth plugin<br/>SelfSubjectAccessReview<br/>Bearer Token validation"]
            CORSEnforce["CORS Enforcement<br/>block_cross_origin_state_changes"]
            WSIsolation["Workspace Isolation<br/>workspace_aware_mixin<br/>Request-scoped context"]
        end

        subgraph MLflowSvc["MLflow Server (ClusterIP:5000)"]
            direction LR
            Flask["Flask WSGI<br/>Tracking + Registry APIs"]
            FastAPI["FastAPI ASGI<br/>Gateway + OTLP + Jobs"]
            ReactUI["React UI<br/>Static Files"]
        end

        subgraph KEKMgmt["Secrets Management"]
            KEK["AES-256-GCM<br/>PBKDF2-HMAC-SHA256<br/>600K iterations"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE (Kubernetes)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token Auth"]
        MLflowConfigCR["MLflowConfig CRD<br/>mlflow.kubeflow.org/v1alpha1<br/>Namespaced"]
    end

    subgraph DataLayer["DATA LAYER"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/Password"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM credentials"]
    end

    subgraph ExternalAPIs["EXTERNAL SERVICES (AI Gateway)"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Gemini["Gemini API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
        Mistral["Mistral API<br/>443/TCP HTTPS TLS 1.2+<br/>API key (KEK-encrypted)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)<br/>X-MLFLOW-WORKSPACE header"| Gateway
    Gateway -->|"HTTP/5000<br/>No encryption (cluster-internal)<br/>Bearer Token forwarded"| K8sAuth
    K8sAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAuth --> CORSEnforce
    CORSEnforce --> WSIsolation
    WSIsolation --> MLflowSvc
    WSIsolation -->|"HTTPS/443<br/>SA Token"| K8sAPI
    K8sAPI -.-> MLflowConfigCR

    MLflowSvc -->|"TCP/5432<br/>TLS optional<br/>DB credentials"| PostgreSQL
    MLflowSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>KEK-decrypted API key"| OpenAI
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>KEK-decrypted API key"| Anthropic
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>KEK-decrypted API key"| Gemini
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>KEK-decrypted API key"| Mistral

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datalayer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalapi fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class K8sAuth,CORSEnforce,WSIsolation security
    class Flask,FastAPI,ReactUI,KEK application
    class K8sAPI,MLflowConfigCR controlplane
    class PostgreSQL,S3 datalayer
    class OpenAI,Anthropic,Gemini,Mistral externalapi
