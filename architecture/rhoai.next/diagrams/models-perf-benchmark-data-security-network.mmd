graph TB
    subgraph Production["PRODUCTION (odh-model-registries namespace)"]
        direction TB

        subgraph ModelCatalogDeploy["model-catalog Deployment"]
            direction TB
            InitContainer["Init Container<br/>odh-model-performance-data<br/>Image: odh-model-performance-data-rhel9<br/>Base: UBI9-minimal<br/>Ports: NONE<br/>Network: NONE"]
            SharedVol["Shared Volume (emptyDir)<br/>Benchmark Data<br/>JSON + NDJSON"]
            ModelCatalog["model-catalog Container<br/>Reads benchmark data<br/>from shared volume"]
        end

        Operator["model-registry-operator<br/>Manages deployment<br/>Patches init container image ref"]
    end

    subgraph DevOnly["DEVELOPMENT ONLY (not in production)"]
        direction TB
        KafkaProc["kafka-processor<br/>Python 3.12 CLI<br/>Consumer Group: model-benchmark-processor"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Dev Only)"]
        Kafka["Kafka Broker<br/>dev.aihub-public-*<br/>9092/TCP or 9096/TCP<br/>SASL_SSL<br/>SCRAM-SHA-512"]
    end

    %% Production flows (no network)
    Operator -->|patches init container<br/>image reference| ModelCatalogDeploy
    InitContainer -->|Volume mount<br/>File I/O<br/>No encryption<br/>No auth| SharedVol
    SharedVol -->|Volume mount<br/>File I/O| ModelCatalog

    %% Development flows
    Kafka -->|Kafka/9092-9096<br/>TLS (SASL_SSL)<br/>SCRAM-SHA-512| KafkaProc

    %% Styling
    classDef production fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef devonly fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef initcontainer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class InitContainer initcontainer
    class SharedVol production
    class ModelCatalog production
    class Operator operator
    class KafkaProc devonly
    class Kafka external
