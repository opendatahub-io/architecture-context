graph TB
    subgraph External["EXTERNAL DATA SOURCES (Untrusted)"]
        Kafka["Kafka Brokers<br/>dev.aihub-public-* topics<br/>9092/TCP or 9096/TCP<br/>SASL_SSL (SCRAM-SHA-512)"]
        VHub["model-validation-hub<br/>REST API<br/>443/TCP HTTPS<br/>TLS (custom CA)"]
    end

    subgraph Ingestion["DATA INGESTION (CI/Dev - Not Shipped)"]
        direction TB

        KP["kafka-processor<br/>Python 3.12<br/>confluent-kafka + librdkafka<br/>No listening ports"]
        AC["api-client<br/>Python 3.12<br/>requests (urllib3/OpenSSL)<br/>No listening ports<br/>⚠ Hostname verify skipped"]
        Enrich["enrich_models.py<br/>File I/O only<br/>No network"]
        DataDir["data/ directory<br/>JSON/NDJSON<br/>provider/model hierarchy"]

        KP -->|"File I/O"| DataDir
        AC -->|"File I/O"| DataDir
        Enrich -->|"File I/O<br/>merge metadata"| DataDir
    end

    subgraph Build["CONTAINER BUILD (Konflux)"]
        ContainerBuild["Dockerfile.konflux<br/>COPY data/ → /app/benchmarks<br/>Base: UBI9-minimal"]
    end

    subgraph Production["PRODUCTION (No Network - Data Only)"]
        InitContainer["odh-model-performance-data<br/>Init Container<br/>NO executable code<br/>NO network services<br/>NO ports"]
    end

    subgraph Cluster["KUBERNETES (odh-model-registries)"]
        direction TB
        subgraph Pod["model-catalog Pod"]
            InitC["Init: odh-model-performance-data<br/>copies /app/benchmarks"]
            SharedVol["Shared Volume"]
            MainC["Main: model-catalog<br/>serves benchmark data"]
            InitC -->|"Volume mount"| SharedVol
            SharedVol --> MainC
        end
        Operator["model-registry-operator<br/>manages deployment"]
    end

    %% External flows
    Kafka -->|"Kafka/9092-9096<br/>SASL_SSL<br/>SCRAM-SHA-512<br/>Topic ACLs"| KP
    VHub -->|"HTTPS/443<br/>TLS (custom CA)<br/>No client auth<br/>⚠ No hostname check"| AC

    %% Build flow
    DataDir -->|"COPY (build step)"| ContainerBuild
    ContainerBuild -->|"Image"| InitContainer
    InitContainer -->|"Deployed as"| InitC

    %% Operator
    Operator -->|"manages"| Pod

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingestion fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef production fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:3px,stroke-dasharray: 5 5

    class Kafka,VHub external
    class KP,AC,Enrich,DataDir ingestion
    class ContainerBuild build
    class InitContainer production
    class InitC,SharedVol,MainC,Operator cluster
