graph TB
    subgraph External["EXTERNAL"]
        Registry["Container Registry<br/>quay.io / registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Cluster["CLUSTER (odh-model-registries namespace)"]
        direction TB

        subgraph Pod["Pod: model-catalog"]
            direction TB
            InitContainer["Init Container<br/>odh-model-performance-data-rhel9<br/>UID: 1001 (non-root)<br/>Ports: NONE<br/>Command: sleep infinity"]
            SharedVol["Shared emptyDir Volume<br/>/app/benchmarks<br/>JSON/NDJSON files"]
            MCatalog["model-catalog Service<br/>Reads benchmark data"]
        end

        Operator["model-registry-operator<br/>Manages Deployment spec"]
    end

    subgraph DevTime["DEVELOPMENT / BUILD TIME (Not Shipped)"]
        direction TB
        KProc["kafka-processor<br/>Python 3.12<br/>SASL_SSL credentials"]
        AClient["api-client<br/>Python 3.12<br/>Custom CA cert"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Dev Only)"]
        KafkaBroker["Kafka Broker<br/>9092-9096/TCP<br/>SASL_SSL<br/>SCRAM-SHA-512"]
        VHub["model-validation-hub<br/>us-east4.gcp.redhat.com<br/>443/TCP HTTPS<br/>TLS (custom CA)"]
    end

    %% Runtime flows
    Registry -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret auth"| InitContainer
    InitContainer -->|"Filesystem<br/>Volume mount<br/>No network"| SharedVol
    SharedVol -->|"Filesystem<br/>Volume mount<br/>No network"| MCatalog
    Operator -->|"Kubernetes API<br/>Deployment mgmt"| Pod

    %% Dev flows
    KafkaBroker -->|"Kafka/9096<br/>SASL_SSL<br/>SCRAM-SHA-512"| KProc
    VHub -->|"HTTPS/443<br/>TLS (custom CA)<br/>No auth token"| AClient

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef devtime fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef initc fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef volume fill:#f5a623,stroke:#333

    class Registry external
    class InitContainer initc
    class SharedVol volume
    class MCatalog cluster
    class Operator cluster
    class KProc,AClient devtime
    class KafkaBroker,VHub extsvc
