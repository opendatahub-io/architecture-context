graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Service"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (Trust Boundary)"]
        direction TB

        Proxy["kube-rbac-proxy<br/>0.0.0.0:8443/TCP<br/>TLS 1.2+ (configurable)<br/>FIPS: strictfipsruntime"]
        HealthCheck["Health Check<br/>/healthz<br/>(--proxy-endpoints-port)"]

        subgraph AuthN["Authentication (mutually exclusive)"]
            Delegating["Delegating<br/>(TokenReview API)<br/>2m cache TTL"]
            OIDC["OIDC JWT<br/>(--oidc-issuer)<br/>JWKS verification"]
            X509["x509 Client Cert<br/>(--client-ca-file)<br/>CN=user, O=groups"]
        end

        subgraph AuthZ["Authorization (union chain)"]
            Hardcoded["1. Hardcoded<br/>prometheus-k8s SA<br/>→ allow GET /metrics"]
            Static["2. Static<br/>(--config-file)<br/>resource attributes"]
            SAR["3. SubjectAccessReview<br/>(K8s API delegation)"]
        end

        CertReloader["CertReloader<br/>Hot-reload interval: 1m"]
        SanitizingFilter["SanitizingFilter<br/>Masks tokens in logs"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph PodLocal["POD-LOCAL (Trusted - localhost)"]
        Upstream["Upstream Application<br/>HTTP/HTTPS/h2c<br/>(localhost:configurable)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        Prometheus["Prometheus<br/>(openshift-monitoring)<br/>SA: prometheus-k8s"]
        Operator["rhods-operator<br/>(sidecar injection)"]
        CertManager["cert-manager<br/>(TLS provisioning)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        OIDCProvider["OIDC Identity Provider<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External client flow
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer / mTLS / OIDC JWT"| Proxy

    %% Prometheus flow
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (SA)"| Proxy

    %% Auth to K8s API
    Delegating -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| APIServer
    SAR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| APIServer

    %% OIDC discovery
    OIDC -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Discovery + JWKS"| OIDCProvider

    %% Upstream forwarding
    Proxy -->|"HTTP/HTTPS/h2c<br/>localhost<br/>None or mTLS<br/>+X-Forwarded-User/Groups"| Upstream

    %% Platform interactions
    Operator -.->|"container injection<br/>(deployment-time)"| Proxy
    CertManager -.->|"file mount<br/>(TLS certs)"| CertReloader

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#4a90e2,stroke:#2b6cb0,stroke-width:2px,color:#fff
    classDef authn fill:#7b68ee,stroke:#5a4fcf,stroke-width:1px,color:#fff
    classDef authz fill:#f5a623,stroke:#d4881e,stroke-width:1px,color:#fff
    classDef k8s fill:#dce8f5,stroke:#4a90e2,stroke-width:2px
    classDef podlocal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e8d5b7,stroke:#b8860b,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#82b366,stroke:#5a8a3c,stroke-width:1px,color:#fff

    class Client external
    class Proxy proxy
    class HealthCheck proxy
    class Delegating,OIDC,X509 authn
    class Hardcoded,Static,SAR authz
    class CertReloader,SanitizingFilter security
    class APIServer k8s
    class Upstream podlocal
    class Prometheus,Operator,CertManager platform
    class OIDCProvider externalsvc
