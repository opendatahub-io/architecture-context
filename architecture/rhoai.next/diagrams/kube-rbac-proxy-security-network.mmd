graph TB
    subgraph External["EXTERNAL / IN-CLUSTER CLIENTS (Variable Trust)"]
        Client["Client<br/>(Browser / API / SDK)"]
    end

    subgraph SidecarPod["POD BOUNDARY"]
        direction TB

        subgraph ProxyContainer["SIDECAR: kube-rbac-proxy"]
            direction TB
            Listener["Secure Listener<br/>0.0.0.0:8443/TCP<br/>TLS 1.2+<br/>FIPS (strictfipsruntime)"]

            subgraph AuthN["Authentication (mutually exclusive)"]
                TokenReview["Delegated TokenReview<br/>(default)"]
                OIDC["OIDC JWT Validation<br/>(if --oidc-issuer)"]
                X509["x509 Client Cert<br/>(if --client-ca-file)"]
            end

            subgraph AuthZ["Authorization (priority chain)"]
                Hardcoded["1. Hardcoded<br/>prometheus-k8s → /metrics"]
                Static["2. Static Rules<br/>(config file)"]
                SAR["3. SubjectAccessReview<br/>(K8s API)"]
            end

            Listener --> AuthN
            AuthN --> AuthZ
        end

        subgraph AppContainer["APPLICATION CONTAINER"]
            Upstream["Upstream Application<br/>(localhost, configurable port)<br/>HTTP"]
        end

        AuthZ -->|"HTTP (localhost)<br/>No encryption<br/>Authorized only"| Upstream
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Monitoring["MONITORING (Trusted - OpenShift)"]
        Prometheus["prometheus-k8s<br/>openshift-monitoring<br/>SA Token Auth"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public JWKS"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer / x509 / OIDC JWT"| Listener
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Token<br/>(hardcoded allow)"| Listener
    TokenReview -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview API"| K8sAPI
    SAR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReview API"| K8sAPI
    OIDC -.->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Discovery + JWKS"| OIDCProvider

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Listener,TokenReview,OIDC,X509,Hardcoded,Static,SAR proxy
    class Upstream app
    class K8sAPI controlplane
    class Prometheus monitoring
    class OIDCProvider externalsvc
