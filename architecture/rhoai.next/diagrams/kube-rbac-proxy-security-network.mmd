graph TB
    subgraph External["IN-CLUSTER CLIENTS (Trusted)"]
        Client["In-Cluster Service / User"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (kube-rbac-proxy v0.21.1)"]
        direction TB

        subgraph AuthN["Authentication (mutually exclusive)"]
            Delegating["Delegating<br/>(TokenReview)"]
            OIDC["OIDC<br/>(JWT Verification)"]
            X509["x509<br/>(Client Certificates)"]
        end

        subgraph AuthZ["Authorization (union, priority order)"]
            Hardcoded["1. Hardcoded<br/>ALLOW prometheus-k8s SA<br/>on GET /metrics"]
            Static["2. Static<br/>(config-file rules)"]
            SAR["3. SAR<br/>(SubjectAccessReview)"]
        end

        TLS["TLS Termination<br/>Min: TLS 1.2<br/>FIPS: strictfipsruntime<br/>Cert Hot-Reload: 1 min"]
        Proxy["Reverse Proxy<br/>(header injection)"]
    end

    subgraph K8sCluster["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph PodLocal["POD-LOCAL (localhost)"]
        UpstreamApp["Upstream Application<br/>Container<br/>HTTP/HTTPS/h2c"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        OIDCProvider["OIDC Identity Provider<br/>443/TCP HTTPS<br/>Discovery + JWKS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>prometheus-k8s SA"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token / mTLS / OIDC JWT"| TLS
    TLS --> AuthN
    AuthN --> AuthZ
    AuthZ --> Proxy

    Delegating -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| APIServer
    SAR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| APIServer
    OIDC -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| OIDCProvider

    Proxy -->|"HTTP/HTTPS/h2c<br/>localhost<br/>None or mTLS"| UpstreamApp

    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token<br/>(hardcoded ALLOW)"| TLS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authn fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef authz fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef k8s fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podlocal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e8e8e8,stroke:#666,stroke-width:2px

    class Client external
    class TLS,Proxy sidecar
    class Delegating,OIDC,X509 authn
    class Hardcoded,Static,SAR authz
    class APIServer k8s
    class UpstreamApp podlocal
    class OIDCProvider extservice
    class Prometheus monitoring
