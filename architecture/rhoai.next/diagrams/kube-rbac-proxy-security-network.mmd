graph TB
    subgraph External["EXTERNAL / IN-CLUSTER CLIENTS (Untrusted)"]
        Client["External Client / In-Cluster Service"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>SA: prometheus-k8s"]
    end

    subgraph SidecarBoundary["SIDECAR PROXY (Auth Boundary)"]
        direction TB

        subgraph ProxyContainer["kube-rbac-proxy Container"]
            direction TB
            Listener["Secure Listener<br/>0.0.0.0:8443/TCP<br/>TLS 1.2+ (configurable)<br/>FIPS: strictfipsruntime"]

            subgraph AuthNBlock["Authentication"]
                TokenReviewAuth["Delegating<br/>(TokenReview)"]
                X509Auth["X.509 Client Cert<br/>(--client-ca-file)"]
                OIDCAuth["OIDC JWT<br/>(--oidc-issuer)"]
            end

            subgraph AuthZBlock["Authorization"]
                HardcodedAllow["Hardcoded Allow<br/>prometheus-k8s SA<br/>GET /metrics"]
                SARCheck["SAR Authorizer<br/>SubjectAccessReview<br/>Format1 / Format2"]
            end

            ProxyHandler["Reverse Proxy<br/>Injects: x-remote-user<br/>x-remote-groups"]
        end

        SecurityInfo["UID: 65534 (non-root)<br/>allowPrivilegeEscalation: false<br/>Log sanitization: tokens masked"]
    end

    subgraph PodLocal["UPSTREAM (Trusted - localhost)"]
        UpstreamApp["Application Container<br/>localhost:8080/TCP<br/>HTTP (no encryption)<br/>Metrics / API endpoints"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public endpoint"]
    end

    subgraph Operators["PLATFORM OPERATORS"]
        RhodsOperator["rhods-operator<br/>Injects sidecar container<br/>Provisions TLS certs"]
        CertManager["cert-manager<br/>TLS certificate provisioning<br/>Auto-rotation"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token / mTLS / OIDC JWT"| Listener
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token<br/>GET /metrics"| Listener

    %% Internal proxy flow
    Listener --> AuthNBlock
    AuthNBlock --> AuthZBlock
    AuthZBlock --> ProxyHandler

    %% Egress to upstream
    ProxyHandler -->|"HTTP/8080<br/>No encryption (localhost)<br/>+ auth headers"| UpstreamApp

    %% Egress to K8s API
    TokenReviewAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST tokenreviews"| K8sAPI
    SARCheck -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST subjectaccessreviews"| K8sAPI

    %% Egress to OIDC
    OIDCAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Discovery + JWKS"| OIDCProvider

    %% Operator relationships
    RhodsOperator -.->|"Injects sidecar<br/>Configures RBAC"| ProxyContainer
    CertManager -.->|"Provisions TLS certs<br/>Auto-rotation"| ProxyContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#4a90e2,color:#fff,stroke:#2c5f9e,stroke-width:2px
    classDef authn fill:#e67e22,color:#fff,stroke:#c0651a,stroke-width:1px
    classDef authz fill:#e74c3c,color:#fff,stroke:#c0392b,stroke-width:1px
    classDef upstream fill:#27ae60,color:#fff,stroke:#1e8449,stroke-width:2px
    classDef k8s fill:#326ce5,color:#fff,stroke:#2553b0,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#ddd,stroke:#999,stroke-width:1px
    classDef info fill:#f0f0f0,stroke:#ccc,stroke-width:1px,font-size:10px

    class Client,Prometheus external
    class Listener,ProxyHandler proxy
    class TokenReviewAuth,X509Auth,OIDCAuth authn
    class HardcodedAllow,SARCheck authz
    class UpstreamApp upstream
    class K8sAPI k8s
    class OIDCProvider extservice
    class RhodsOperator,CertManager operator
    class SecurityInfo info
