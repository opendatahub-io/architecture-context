graph TB
    subgraph External["INTERNAL CLIENTS (Cluster Services)"]
        Client["In-Cluster Client<br/>(Component Pod)"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>prometheus-k8s SA"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (kube-rbac-proxy)"]
        direction TB

        SecureListener["Secure Listener<br/>8443/TCP HTTPS<br/>TLS 1.2+ (configurable)<br/>FIPS: strictfipsruntime"]

        subgraph AuthN["Authentication Layer"]
            DelegatingAuth["Delegating Authenticator<br/>TokenReview (2min cache)"]
            OIDCAuth["OIDC Authenticator<br/>JWT Validation"]
            X509Auth["x509 Authenticator<br/>Client Certificate"]
        end

        subgraph AuthZ["Authorization Layer (Union)"]
            HardcodedAuth["1. Hardcoded Authorizer<br/>Allow prometheus-k8s SA<br/>GET /metrics"]
            StaticAuth["2. Static Authorizer<br/>(--config-file)"]
            SARAuth["3. SubjectAccessReview<br/>Authorizer"]
        end

        HealthEndpoint["Health Endpoint<br/>/healthz<br/>Separate Port<br/>Unauthenticated"]

        SanitizingLog["SanitizingFilter<br/>Token Masking in Logs"]
        CertReload["CertReloader<br/>Hot-reload (1min default)"]
    end

    subgraph PodLocal["UPSTREAM APPLICATION (Pod-Local)"]
        UpstreamApp["Application Container<br/>localhost<br/>HTTP/HTTPS/h2c<br/>No Auth (trusted loopback)"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        OIDCProvider["OIDC Identity Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token / mTLS / OIDC JWT"| SecureListener
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (SA)<br/>GET /metrics"| SecureListener

    %% Internal proxy flow
    SecureListener --> AuthN
    AuthN --> AuthZ

    %% Egress to upstream
    AuthZ -->|"HTTP (localhost)<br/>No encryption<br/>No auth (trusted)"| UpstreamApp

    %% Egress to K8s API
    DelegatingAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST tokenreviews"| K8sAPI
    SARAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST subjectaccessreviews"| K8sAPI

    %% Egress to OIDC
    OIDCAuth -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Discovery + JWKS"| OIDCProvider

    %% Cert reload
    CertReload -.->|"reload certs"| SecureListener

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef authn fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authz fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podlocal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,Prometheus external
    class SecureListener,HealthEndpoint,SanitizingLog,CertReload sidecar
    class DelegatingAuth,OIDCAuth,X509Auth authn
    class HardcodedAuth,StaticAuth,SARAuth authz
    class UpstreamApp podlocal
    class K8sAPI k8s
    class OIDCProvider extservice
