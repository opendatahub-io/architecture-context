graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(browser, SDK, curl)"]
        Prometheus["prometheus-k8s<br/>NS: openshift-monitoring<br/>SA: prometheus-k8s"]
    end

    subgraph Pod["COMPONENT POD (Same Network Namespace)"]
        subgraph SidecarProxy["SIDECAR PROXY (AuthN/AuthZ Boundary)"]
            KRP["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS<br/>TLS 1.2+ (configurable)<br/>FIPS: strictfipsruntime<br/>Cert reload: hot-reload"]

            subgraph AuthN["Authentication"]
                TokenReview["Delegating Authenticator<br/>(TokenReview API)"]
                OIDC["OIDC Authenticator<br/>(JWT validation)"]
                X509["X.509 Client Cert<br/>(CA validation)"]
            end

            subgraph AuthZ["Authorization (union, first-match)"]
                Hardcoded["Hardcoded Metrics Authz<br/>(prometheus-k8s → /metrics)"]
                Static["Static Authorizer"]
                SAR["SAR Authorizer<br/>(SubjectAccessReview API)"]
            end
        end

        Upstream["Upstream Application<br/>Port: 8081/TCP HTTP<br/>Plaintext (localhost loopback)<br/>Receives: X-Remote-User,<br/>X-Remote-Groups headers"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>Port: 443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
    end

    subgraph ExternalIdP["EXTERNAL IDENTITY (Optional)"]
        OIDCIssuer["OIDC Issuer<br/>Port: 443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None"]
    end

    subgraph HealthEndpoint["HEALTH CHECK (Separate Port)"]
        Healthz["/healthz endpoint<br/>--proxy-endpoints-port<br/>HTTPS, No Auth<br/>Returns: ok"]
    end

    %% Inbound flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token / OIDC JWT / X.509"| KRP
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Bearer Token<br/>GET /metrics"| KRP

    %% AuthN flows
    KRP --> TokenReview
    KRP --> OIDC
    KRP --> X509

    %% AuthN to external
    TokenReview -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST tokenreviews"| APIServer
    OIDC -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS fetch"| OIDCIssuer

    %% AuthZ flows
    TokenReview --> Hardcoded
    OIDC --> Hardcoded
    X509 --> Hardcoded
    Hardcoded --> Static
    Static --> SAR
    SAR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>POST subjectaccessreviews"| APIServer

    %% Proxy to upstream
    SAR -->|"authorized"| Upstream
    Hardcoded -->|"fast-path<br/>(prometheus-k8s)"| Upstream

    %% Styling - Trust zones
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#dbeafe,stroke:#2563eb,stroke-width:2px
    classDef authn fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef authz fill:#fce7f3,stroke:#db2777,stroke-width:2px
    classDef upstream fill:#d1fae5,stroke:#059669,stroke-width:2px
    classDef controlplane fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    classDef externalservice fill:#fff7ed,stroke:#c2410c,stroke-width:2px
    classDef health fill:#f3e8ff,stroke:#7c3aed,stroke-width:2px

    class Client,Prometheus external
    class KRP sidecar
    class TokenReview,OIDC,X509 authn
    class Hardcoded,Static,SAR authz
    class Upstream upstream
    class APIServer controlplane
    class OIDCIssuer externalservice
    class Healthz health
