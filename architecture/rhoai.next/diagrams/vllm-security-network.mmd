graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress<br/>(Gateway API / Istio)<br/>443/TCP → 8443/TCP<br/>TLS 1.3 Termination<br/>JWT Validation"]
    end

    subgraph PodBoundary["POD BOUNDARY (KServe-Managed)"]
        direction TB

        subgraph Sidecar["Auth Sidecar"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS → 8000/8033 plaintext<br/>JWT Validation + RBAC"]
        end

        subgraph Container["odh-vllm-cuda-rhel9<br/>UID: 2000 (non-root)<br/>Base: rhaiis/vllm-cuda-rhel9:3.2.2"]
            HTTP_API["OpenAI HTTP API<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models, /health"]
            GRPC_API["TGIS gRPC Service<br/>8033/TCP gRPC<br/>GenerationService"]
            MetricsEP["/metrics<br/>8000/TCP HTTP"]
        end

        subgraph HW["Hardware"]
            GPU["NVIDIA GPU<br/>CUDA API<br/>Driver ≥525.60.13"]
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
    end

    subgraph ModelStorage["MODEL STORAGE"]
        PVC["PVC Volume Mount<br/>Filesystem<br/>No network"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP Scrape"]
    end

    %% Inbound flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token (JWT)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>JWT validated"| KRBP
    KRBP -->|"HTTP/8000<br/>plaintext (localhost)<br/>no auth"| HTTP_API
    KRBP -->|"gRPC/8033<br/>plaintext (localhost)<br/>no auth"| GRPC_API

    %% Compute
    HTTP_API -->|"CUDA API"| GPU
    GRPC_API -->|"CUDA API"| GPU

    %% Egress flows
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3

    %% Storage
    PVC -->|"Filesystem mount"| Container

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>scrapes /metrics"| MetricsEP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egresssvc fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#f5f5f5,stroke:#666,stroke-width:1px

    class Client external
    class Gateway ingress
    class KRBP sidecar
    class HTTP_API,GRPC_API,MetricsEP container
    class GPU gpu
    class HFHub,S3 egresssvc
    class PVC storage
    class Prometheus monitoring
