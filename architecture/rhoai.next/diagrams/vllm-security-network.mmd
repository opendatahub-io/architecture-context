graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["HTTPRoute / Gateway<br/>443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Managed by KServe"]
    end

    subgraph InferencePod["INFERENCE POD (KServe InferenceService)"]
        direction TB

        subgraph SidecarZone["Auth Boundary"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>JWT Validation<br/>Kubernetes RBAC"]
        end

        subgraph ContainerZone["vLLM Container (UID 2000)"]
            OpenAI["OpenAI API<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/v1/embeddings"]
            TGISgRPC["TGIS gRPC<br/>8033/TCP<br/>GenerationService"]
            HealthMetrics["/health + /metrics<br/>8000/TCP HTTP"]
            VLLMEngine["vLLM Engine<br/>(vllm_tgis_adapter)"]
            OpenAI --> VLLMEngine
            TGISgRPC --> VLLMEngine
        end

        subgraph GPUZone["GPU Boundary"]
            GPU["NVIDIA GPU<br/>CUDA 12.x+<br/>Model in VRAM"]
        end

        KRBP -->|"HTTP/8000<br/>plaintext localhost<br/>pre-authenticated"| OpenAI
        KRBP -->|"gRPC/8033<br/>plaintext localhost<br/>pre-authenticated"| TGISgRPC
        VLLMEngine -->|"CUDA API<br/>in-process"| GPU
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / HMAC"]
        PVC["PVC Volume Mount<br/>Filesystem<br/>No network"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>OpenShift Monitoring"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (JWT)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>JWT forwarded"| KRBP
    VLLMEngine -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    VLLMEngine -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    VLLMEngine -.->|"filesystem<br/>local mount"| PVC
    Prometheus -.->|"HTTP/8000<br/>scrape /metrics"| HealthMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authboundary fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#76b900,stroke:#333,stroke-width:2px,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class Client external
    class Gateway ingress
    class KRBP authboundary
    class OpenAI,TGISgRPC,HealthMetrics,VLLMEngine container
    class GPU gpu
    class HF,S3,PVC externalservice
    class Prometheus monitoring
