graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) — KServe Managed"]
        Gateway["KServe Gateway / Istio Ingress<br/>443/TCP → 8000/8033<br/>TLS 1.2+<br/>Bearer Token / OAuth"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            Sidecar["Istio Sidecar Proxy<br/>mTLS STRICT<br/>Auto-injected"]

            subgraph Container["vLLM CUDA Container (USER 2000)"]
                direction TB
                TGISAdapter["vllm_tgis_adapter<br/>8033/TCP gRPC<br/>TGIS GenerationService"]
                VLLMServer["vLLM HTTP Server<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models, /health"]
                GPURuntime["NVIDIA GPU (CUDA)<br/>nvidia.com/gpu<br/>Model VRAM"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["Model Storage (S3)<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        PVC["Model Storage (PVC)<br/>Filesystem mount<br/>No network"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway

    %% Ingress to Service Mesh
    Gateway -->|"HTTP/8000 or gRPC/8033<br/>mTLS STRICT<br/>Service Identity"| Sidecar

    %% Sidecar to Container (localhost)
    Sidecar -->|"HTTP/8000<br/>localhost (no encryption)"| VLLMServer
    Sidecar -->|"gRPC/8033<br/>localhost (no encryption)"| TGISAdapter

    %% Internal container flows
    TGISAdapter -->|"HTTP/8000<br/>localhost bridge"| VLLMServer
    VLLMServer -->|"CUDA calls"| GPURuntime

    %% Egress
    VLLMServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    VLLMServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    VLLMServer -->|"Filesystem<br/>No network"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Sidecar servicemesh
    class TGISAdapter,VLLMServer,GPURuntime container
    class S3,HFHub,PVC externalservice
