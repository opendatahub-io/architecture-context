graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["KServe Gateway / Istio Ingress<br/>443/TCP → 8000,8033/TCP<br/>TLS 1.2+<br/>AuthN: Bearer Token / OAuth"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph IstioProxy["Istio Sidecar Proxy"]
            Sidecar["Sidecar Proxy<br/>mTLS STRICT<br/>Service Identity"]
        end

        subgraph AppPod["vLLM Inference Pod<br/>User: 2000 (non-root)"]
            vLLMHTTP["vLLM HTTP Server<br/>8000/TCP HTTP<br/>OpenAI-compatible API<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/health"]
            TGISAdapter["vllm_tgis_adapter<br/>8033/TCP gRPC<br/>TGIS GenerationService"]
        end

        TGISAdapter -->|"HTTP/8000<br/>localhost"| vLLMHTTP
    end

    subgraph GPULayer["GPU RESOURCES"]
        GPU["NVIDIA GPU<br/>CUDA VRAM<br/>nvidia.com/gpu"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        HuggingFace["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer (optional)"]
        PVC["PVC Storage<br/>Filesystem<br/>Auth: ServiceAccount"]
    end

    %% Ingress Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTP/8000<br/>mTLS STRICT<br/>Service Identity"| Sidecar
    Gateway -->|"gRPC/8033<br/>mTLS STRICT<br/>Service Identity"| Sidecar
    Sidecar -->|"HTTP/8000<br/>plaintext (localhost)"| vLLMHTTP
    Sidecar -->|"gRPC/8033<br/>plaintext (localhost)"| TGISAdapter

    %% GPU Flow
    vLLMHTTP -->|"CUDA<br/>Model inference"| GPU

    %% Egress Flows
    vLLMHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    vLLMHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HuggingFace
    vLLMHTTP -->|"Filesystem<br/>ServiceAccount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpulayer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class Sidecar servicemesh
    class vLLMHTTP,TGISAdapter app
    class GPU gpulayer
    class S3,HuggingFace,PVC externalservice
