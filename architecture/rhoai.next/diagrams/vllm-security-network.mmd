graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["RHOAI Gateway<br/>HTTPRoute / OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)"]
    end

    subgraph Pod["POD BOUNDARY (InferenceService Pod)"]
        direction TB

        KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar - injected by platform)<br/>Listen: 8443/TCP HTTPS<br/>Auth: SubjectAccessReview"]

        subgraph Container["vLLM CUDA Container (UID 2000, non-root)"]
            direction TB
            HTTPServer["vLLM HTTP Server<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models, /health"]
            GRPCServer["vllm_tgis_adapter<br/>8033/TCP gRPC<br/>TGIS GenerationService"]
            Engine["vLLM Inference Engine<br/>Python 3 / RHEL 9<br/>RHAIIS base 3.2.2"]
            GPU["NVIDIA GPU<br/>CUDA Runtime"]

            HTTPServer --> Engine
            GRPCServer -->|"in-process"| Engine
            Engine -->|"CUDA API"| GPU
        end

        KubeRBACProxy -->|"HTTP/8000<br/>localhost<br/>No encryption"| HTTPServer
        KubeRBACProxy -->|"gRPC/8033<br/>localhost<br/>No encryption"| GRPCServer
    end

    subgraph ExternalServices["EGRESS - EXTERNAL SERVICES"]
        S3["S3 / Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP HTTP"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>ServiceAccount Token"| KubeRBACProxy
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Prometheus -->|"HTTP/8000<br/>No encryption"| HTTPServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef proxy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef gpu fill:#76b900,stroke:#333,stroke-width:2px,color:#fff

    class Client external
    class Gateway ingress
    class KubeRBACProxy proxy
    class HTTPServer,GRPCServer,Engine container
    class GPU gpu
    class S3,HFHub externalservice
    class Prometheus monitoring
