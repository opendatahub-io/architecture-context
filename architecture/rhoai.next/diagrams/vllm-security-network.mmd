graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["RHOAI Gateway<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Bearer Token / OAuth"]
    end

    subgraph Pod["POD (kube-rbac-proxy + vLLM Container)"]
        direction TB

        subgraph Sidecar["kube-rbac-proxy Sidecar"]
            KRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS Termination<br/>SA Token Auth"]
        end

        subgraph Container["vLLM CUDA Container (UID 2000, non-root)"]
            direction TB
            HTTPServer["vLLM HTTP Server<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models | /health"]
            TGISAdapter["vllm_tgis_adapter<br/>8033/TCP gRPC<br/>TGIS GenerationService"]
            Engine["vLLM Inference Engine"]
            GPU["NVIDIA GPU<br/>CUDA Runtime"]

            HTTPServer --> Engine
            TGISAdapter -->|"in-process Python"| Engine
            Engine -->|"CUDA compute"| GPU
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP HTTP"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SA Token"| KRBAC
    KRBAC -->|"HTTP/8000<br/>None (localhost)"| HTTPServer
    KRBAC -->|"gRPC/8033<br/>None (localhost)"| TGISAdapter
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / access key"| S3
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Prometheus -->|"HTTP/8000<br/>scrape"| HTTPServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#76b900,stroke:#333,stroke-width:2px,color:#fff
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class KRBAC sidecar
    class HTTPServer,TGISAdapter,Engine container
    class GPU gpu
    class S3,HFHub externalservice
    class Prometheus monitoring
