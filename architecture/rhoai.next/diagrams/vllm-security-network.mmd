graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe Gateway / DMZ)"]
        Gateway["KServe Gateway<br/>(Istio Ingress)<br/>443/TCP → 8000/8033<br/>TLS 1.2+<br/>Bearer Token / OAuth"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            Sidecar["Istio Sidecar<br/>mTLS termination"]

            subgraph Pod["vLLM Pod (User: 2000, non-root)"]
                TGISAdapter["vllm_tgis_adapter<br/>gRPC/8033<br/>TGIS GenerationService"]
                vLLMHTTP["vLLM HTTP Server<br/>HTTP/8000<br/>OpenAI-compatible API<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/health"]
                GPUDevice["NVIDIA GPU<br/>CUDA<br/>nvidia.com/gpu"]
            end
        end
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        S3["S3 Storage / PVC<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA"]
        HuggingFace["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTP/8000 or gRPC/8033<br/>mTLS STRICT<br/>Service Identity"| Sidecar
    Sidecar -->|"HTTP/8000<br/>localhost (no TLS)"| vLLMHTTP
    Sidecar -->|"gRPC/8033<br/>localhost (no TLS)"| TGISAdapter
    TGISAdapter -->|"HTTP/8000<br/>localhost bridge"| vLLMHTTP
    vLLMHTTP -->|"CUDA API<br/>device-local"| GPUDevice
    vLLMHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / SA"| S3
    vLLMHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef gpu fill:#e6b8af,stroke:#cc0000,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Sidecar servicemesh
    class TGISAdapter,vLLMHTTP pod
    class GPUDevice gpu
    class S3,HuggingFace externalservice
