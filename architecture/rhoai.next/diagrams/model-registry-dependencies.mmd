graph LR
    MR["Model Registry<br/>(proxy + controller + BFF<br/>+ catalog + CSI + async-upload)"]

    %% External Dependencies
    MR -->|"metadata storage<br/>3306/TCP MySQL protocol"| MySQL["MySQL 8.3+"]
    MR -->|"metadata/catalog storage<br/>5432/TCP PostgreSQL protocol"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"CRD watch<br/>InferenceService v1beta1"| KServe["KServe"]
    MR -->|"model catalog import<br/>443/TCP HTTPS"| HuggingFace["Hugging Face API"]
    MR -->|"OCI image push/pull<br/>443/TCP HTTPS"| Skopeo["skopeo (UBI RPM)"]

    %% Internal ODH Dependencies
    MR -->|"traffic routing, mTLS<br/>VirtualService, DestinationRule"| Istio["Istio Service Mesh"]
    MR -->|"storage plugin<br/>ClusterStorageContainer"| KServeCSI["KServe<br/>(ClusterStorageContainer)"]

    %% Integration Points - Consumers of Model Registry
    Dashboard["RHOAI Dashboard"] -->|"BFF API consumer<br/>HTTP/8080"| MR
    Operator["rhods-operator /<br/>opendatahub-operator"] -->|"Kustomize deployment<br/>manifests"| MR

    %% External Services
    MR -->|"model storage<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    MR -->|"model images<br/>443/TCP HTTPS"| OCIReg["OCI Registries"]
    MR -->|"API server<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    MR -->|"metrics scraping<br/>8443/TCP HTTPS"| Prometheus["Prometheus"]

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (gray)
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff

    %% Internal ODH dependencies (green)
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style KServeCSI fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCIReg fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
