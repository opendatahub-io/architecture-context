graph LR
    MR["Model Registry<br/>(multi-component)"]

    %% External Dependencies
    MR -->|"metadata storage<br/>:3306/TCP"| MySQL["MySQL 8.3+"]
    MR -->|"metadata storage<br/>:5432/TCP"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"ISVC reconciliation<br/>CRD v1beta1"| KServe["KServe"]
    MR -->|"model catalog import<br/>:443/TCP HTTPS"| HuggingFace["Hugging Face API"]
    MR -->|"OCI image push/pull<br/>(async upload)"| Skopeo["skopeo (UBI RPM)"]

    %% Internal ODH/RHOAI Dependencies
    MR -->|"VirtualService<br/>DestinationRule<br/>AuthorizationPolicy"| Istio["Istio Service Mesh"]
    MR -->|"CRD Watch<br/>InferenceService"| KServeCRD["KServe (CRD Watch)"]
    MR -->|"ClusterStorageContainer<br/>model-registry:// protocol"| KServeCSI["KServe (Storage Plugin)"]

    %% Platform operator
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"Kustomize deployment"| MR

    %% Integration Points (consumers)
    Dashboard["RHOAI Dashboard"] -->|"BFF API consumer<br/>:8080/TCP HTTP"| MR
    DSPipelines["Data Science Pipelines"] -.->|"potential integration"| MR

    %% External Services
    MR -->|"model file storage<br/>:443/TCP HTTPS"| S3["S3-Compatible Storage"]
    MR -->|"resource management<br/>:443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    MR -->|"OCI artifact storage<br/>:443/TCP HTTPS"| OCIReg["OCI Registries"]
    Prometheus["Prometheus"] -->|"metrics scraping<br/>:8443/TCP HTTPS"| MR

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps (grey)
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff

    %% Internal ODH deps (green)
    style Istio fill:#7ed321,stroke:#333,color:#333
    style KServeCRD fill:#7ed321,stroke:#333,color:#333
    style KServeCSI fill:#7ed321,stroke:#333,color:#333
    style RhodsOp fill:#7ed321,stroke:#333,color:#333
    style Dashboard fill:#7ed321,stroke:#333,color:#333
    style DSPipelines fill:#7ed321,stroke:#333,color:#333

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#333
    style K8sAPI fill:#f5a623,stroke:#333,color:#333
    style OCIReg fill:#f5a623,stroke:#333,color:#333
    style Prometheus fill:#f5a623,stroke:#333,color:#333
