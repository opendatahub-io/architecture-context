graph LR
    MR["Model Registry<br/>(Core API + Controller + BFF<br/>+ Catalog + CSI + Async Job)"]

    %% External Dependencies (Required)
    MR -->|"metadata storage<br/>3306/TCP MySQL protocol"| MySQL["MySQL 8.3+<br/>(or PostgreSQL)"]
    MR -->|"metadata storage<br/>5432/TCP PostgreSQL protocol"| PostgreSQL["PostgreSQL 16+<br/>(or MySQL)"]

    %% External Dependencies (Optional)
    MR -.->|"CRD watch<br/>InferenceService v1beta1"| KServe["KServe"]
    MR -.->|"model metadata import<br/>443/TCP HTTPS"| HuggingFace["Hugging Face API"]
    MR -.->|"OCI push/pull<br/>443/TCP HTTPS"| Skopeo["skopeo<br/>(via async-upload)"]

    %% Internal Platform Dependencies
    MR -->|"VirtualService<br/>DestinationRule<br/>AuthorizationPolicy<br/>mTLS"| Istio["Istio Service Mesh"]
    MR -->|"watch ISVCs<br/>service discovery<br/>RBAC checks<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Internal ODH Dependencies
    MR -->|"ClusterStorageContainer<br/>model-registry:// protocol"| KServeSI["KServe<br/>(Storage Plugin)"]

    %% Components that depend on Model Registry
    Dashboard["RHOAI Dashboard"] -->|"UI model mgmt<br/>8080/TCP HTTP"| MR
    Operator["rhods-operator"] -->|"kustomize deployment<br/>lifecycle management"| MR
    Prometheus["Prometheus"] -->|"metrics scraping<br/>8443/TCP HTTPS"| MR

    %% External Services consumed
    MR -->|"model download<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    MR -->|"model push/pull<br/>443/TCP HTTPS"| OCIRegistry["OCI Registries"]

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff

    %% Optional external
    style KServe fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style Istio fill:#2e86c1,stroke:#333,color:#fff
    style K8sAPI fill:#2e86c1,stroke:#333,color:#fff

    %% Internal ODH
    style KServeSI fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#2e86c1,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
