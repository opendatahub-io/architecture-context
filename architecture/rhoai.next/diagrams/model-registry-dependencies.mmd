graph LR
    MR["Model Registry<br/>(multi-component)"]

    %% External Dependencies
    MR -->|"metadata storage<br/>3306/TCP"| MySQL["MySQL 8.3+"]
    MR -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"ISVC CRD watch"| KServe["KServe v1beta1"]
    MR -->|"model metadata<br/>443/TCP HTTPS"| HuggingFace["HuggingFace API v2"]
    MR -->|"model signing<br/>443/TCP HTTPS"| Sigstore["Sigstore v4.3<br/>(Fulcio/Rekor/TUF)"]
    MR -->|"OCI image push"| Skopeo["skopeo (bundled)"]

    %% Internal ODH/RHOAI Dependencies
    MR -->|"mTLS + AuthZ"| Istio["Istio Service Mesh"]
    MR -.->|"ClusterStorageContainer"| KServeCSC["KServe CSI Protocol"]

    %% Integration Points - Consumers of Model Registry
    Dashboard["ODH Dashboard /<br/>model-registry-ui"] -->|"REST API client<br/>8080/TCP HTTP"| MR
    Operator["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize manifests"| MR

    %% External Services (Egress)
    MR -->|"model download<br/>443/TCP HTTPS"| S3["AWS S3"]
    MR -->|"model push<br/>443/TCP HTTPS"| OCIReg["OCI Registry"]
    MR -->|"K8s API calls<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps - gray
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style Sigstore fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff

    %% Internal platform - green
    style Istio fill:#7ed321,stroke:#333
    style KServeCSC fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333

    %% External services - orange
    style S3 fill:#f5a623,stroke:#333
    style OCIReg fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
