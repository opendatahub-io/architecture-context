graph LR
    MR["Model Registry<br/>(proxy + controller + CSI)"]

    %% External Dependencies (Required)
    MR -->|"metadata storage<br/>3306/TCP"| MySQL["MySQL 8.3+"]
    MR -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"HTTP router"| GoChi["go-chi/chi v5.2.5"]
    MR -->|"ORM"| GORM["GORM v1.31.1"]
    MR -->|"schema migrations"| GoMigrate["golang-migrate v4.19.1"]
    MR -->|"CLI framework"| Cobra["spf13/cobra v1.10.2"]
    MR -->|"config mgmt"| Viper["spf13/viper v1.21.0"]

    %% External Dependencies (Controller/CSI only)
    MR -->|"controller framework<br/>(controller only)"| CtrlRuntime["controller-runtime"]
    MR -->|"CRD + storage providers<br/>(controller/CSI)"| KServeAPI["kserve v1beta1 API"]

    %% External Dependencies (Optional - async job)
    MR -.->|"model signing<br/>443/TCP"| Sigstore["Sigstore<br/>(fulcio, rekor)"]
    MR -.->|"OCI operations<br/>(async job)"| Skopeo["skopeo"]

    %% Internal Platform Dependencies
    MR -->|"CRD Watch<br/>InferenceService"| KServe["KServe"]
    MR -->|"ClusterStorageContainer<br/>model-registry:// protocol"| KServeCSC["KServe CSC"]
    MR -->|"VirtualService + mTLS<br/>DestinationRule"| Istio["Istio Service Mesh"]

    %% Integration Points (Components that interact with MR)
    Dashboard["ODH Dashboard /<br/>RHOAI UI"] -->|"REST API client<br/>8080/TCP"| MR
    Operator["RHOAI Platform<br/>Operator"] -->|"deploys via<br/>kustomize"| MR
    MR -->|"model metadata<br/>443/TCP"| HuggingFace["Hugging Face Hub"]
    MR -->|"artifact storage<br/>443/TCP"| S3["S3-compatible Storage"]
    MR -->|"image push/pull<br/>443/TCP"| OCI["OCI Registries"]

    %% External Services
    MR -->|"CRD watch + patch<br/>443/TCP"| K8sAPI["Kubernetes API"]

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style GoChi fill:#e8e8e8,stroke:#333
    style GORM fill:#e8e8e8,stroke:#333
    style GoMigrate fill:#e8e8e8,stroke:#333
    style Cobra fill:#e8e8e8,stroke:#333
    style Viper fill:#e8e8e8,stroke:#333
    style CtrlRuntime fill:#e8e8e8,stroke:#333
    style KServeAPI fill:#e8e8e8,stroke:#333
    style Sigstore fill:#e8e8e8,stroke:#333
    style Skopeo fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style KServeCSC fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OCI fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
