graph LR
    MR["Model Registry<br/>(proxy + catalog + controller + CSI)"]

    %% External Dependencies
    MR -->|"metadata storage<br/>3306/TCP MySQL protocol"| MySQL["MySQL 8.3"]
    MR -->|"metadata storage<br/>5432/TCP PostgreSQL protocol"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"CRD watch<br/>InferenceService v1beta1"| KServe["KServe"]
    MR -->|"mTLS + routing<br/>VirtualService/DestinationRule"| Istio["Istio 1.x"]
    MR -->|"OCI image push<br/>via skopeo"| Skopeo["skopeo (latest)"]
    MR -->|"code signing<br/>HTTPS/443"| Cosign["cosign (latest)"]

    %% Internal RHOAI Dependencies
    MR -->|"CRD Watch<br/>serving.kserve.io/v1beta1"| KServeCRD["KServe InferenceService CRD"]
    MR -->|"model-registry:// URI<br/>ClusterStorageContainer"| KServeCSC["KServe ClusterStorageContainer"]
    MR -->|"external traffic routing<br/>kubeflow-gateway"| IstioGW["Istio Ingress Gateway"]
    MR -->|"Python SDK<br/>pip: model-registry>=0.3.7"| PythonClient["Model Registry Python Client"]

    %% Integration Points (other components → MR)
    Dashboard["ODH Dashboard"] -->|"REST API calls<br/>8080/TCP HTTP"| MR
    Pipelines["Data Science Pipelines"] -.->|"model registration"| MR

    %% External Services
    MR -->|"model artifacts<br/>HTTPS/443 AWS IAM"| S3["S3-compatible Storage"]
    MR -->|"OCI images<br/>HTTPS/443 Docker creds"| OCI["OCI Registry"]
    MR -->|"model metadata + download<br/>HTTPS/443 HF Token"| HF["HuggingFace Hub"]
    MR -->|"artifact signing<br/>HTTPS/443 OIDC"| Sigstore["Sigstore (Fulcio/Rekor)"]
    MR -->|"resource mgmt<br/>HTTPS/443 SA Token"| K8sAPI["Kubernetes API"]

