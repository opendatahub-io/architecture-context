graph LR
    MR["Model Registry<br/>(monorepo)"]

    %% Core sub-components
    MR --- Proxy["Proxy Server<br/>(Go REST)"]
    MR --- CatalogSrv["Catalog Server<br/>(Go REST)"]
    MR --- Ctrl["Controller<br/>(Go K8s)"]
    MR --- CSI_Comp["CSI Initializer<br/>(Go)"]
    MR --- AsyncJob["Async Upload<br/>(Python)"]
    MR --- UI["UI BFF + SPA<br/>(Go + React)"]

    %% External Dependencies (Required)
    Proxy -->|"SQL/GORM<br/>5432/TCP"| PostgreSQL["PostgreSQL 16+"]
    Proxy -->|"SQL/GORM<br/>3306/TCP"| MySQL["MySQL 8.3+"]

    %% External Dependencies (Optional)
    CatalogSrv -->|"REST<br/>443/TCP"| HuggingFace["HuggingFace API"]
    AsyncJob -->|"HTTPS<br/>443/TCP"| S3["S3 Storage"]
    AsyncJob -->|"skopeo + olot<br/>443/TCP"| OCI["OCI Registry"]
    AsyncJob -.->|"REST<br/>443/TCP"| Sigstore["Sigstore<br/>(Fulcio/Rekor/TUF)"]
    AsyncJob -.->|"huggingface_hub<br/>443/TCP"| HuggingFace

    %% Internal ODH Dependencies
    Ctrl -->|"CRD Watch<br/>InferenceService"| KServe["KServe"]
    CSI_Comp -->|"ClusterStorageContainer<br/>model-registry://"| KServe
    Proxy -.->|"sidecar + mTLS"| Istio["Istio Service Mesh"]
    CatalogSrv -.->|"sidecar + mTLS"| Istio

    %% Internal Platform Dependencies
    Ctrl -->|"HTTPS/443<br/>SA token"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -->|"REST API<br/>8080/TCP"| Proxy
    PythonSDK["Python SDK"] -->|"REST API<br/>8080 or 443/TCP"| Proxy
    UI -->|"forwards API<br/>8080/TCP"| Proxy
    UI -->|"forwards catalog<br/>8080/TCP"| CatalogSrv
    Ctrl -->|"syncs metadata<br/>8080/TCP Bearer"| Proxy
    CSI_Comp -->|"resolves URIs<br/>8080/TCP"| Proxy
    AsyncJob -->|"registers model<br/>443/TCP Bearer"| Proxy

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style CatalogSrv fill:#4a90e2,stroke:#333,color:#fff
    style Ctrl fill:#50a0d0,stroke:#333,color:#fff
    style CSI_Comp fill:#50a0d0,stroke:#333,color:#fff
    style AsyncJob fill:#50a0d0,stroke:#333,color:#fff
    style UI fill:#6ab0e0,stroke:#333,color:#fff

    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style MySQL fill:#4479a1,stroke:#333,color:#fff
    style HuggingFace fill:#ffd21e,stroke:#333,color:#000
    style S3 fill:#f5a623,stroke:#333,color:#000
    style OCI fill:#f5a623,stroke:#333,color:#000
    style Sigstore fill:#c0c0c0,stroke:#333

    style KServe fill:#7ed321,stroke:#333,color:#000
    style Istio fill:#466bb0,stroke:#333,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff

    style Dashboard fill:#7ed321,stroke:#333,color:#000
    style PythonSDK fill:#7ed321,stroke:#333,color:#000
