graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → sidecar<br/>TLS 1.2+ SIMPLE<br/>Dynamic per workbench"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (StatefulSet)"]
        direction TB

        subgraph AuthSidecar["Auth Sidecar (Injected)"]
            RBAC["kube-rbac-proxy (3.x)<br/>oauth-proxy (2.x)<br/>OpenShift OAuth"]
        end

        subgraph WorkbenchContainer["Workbench Container (No Auth)"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>token DISABLED"]
            RStudio["RStudio Server<br/>8787/TCP HTTP<br/>via NGINX proxy"]
            CodeSrv["code-server<br/>8787/TCP HTTP<br/>via NGINX proxy"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Trusted)"]
        K8sAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph BuildTimeEgress["BUILD-TIME EGRESS (Image Build Only)"]
        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS"]
        NVIDIA["NVIDIA CUDA Repo<br/>developer.download.nvidia.com<br/>443/TCP HTTPS"]
        AMD["AMD ROCm Repo<br/>repo.radeon.com<br/>443/TCP HTTPS"]
    end

    subgraph Registry["CONTAINER REGISTRY"]
        Quay["quay.io/modh<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull/Push Secret"]
    end

    %% Runtime flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2/OIDC"| Route
    Route -->|"HTTP (post-TLS)<br/>No encryption"| RBAC
    RBAC -->|"HTTP/8888 or 8787<br/>localhost<br/>No auth (verified)"| Jupyter
    RBAC -->|"HTTP/8787<br/>localhost<br/>No auth (verified)"| RStudio
    RBAC -->|"HTTP/8787<br/>localhost<br/>No auth (verified)"| CodeSrv

    %% Workbench to platform
    Jupyter -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    RStudio -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    CodeSrv -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authsidecar fill:#e6d5f7,stroke:#7c3aed,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef buildegress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef registry fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff

    class User external
    class Route ingress
    class RBAC authsidecar
    class Jupyter,RStudio,CodeSrv workbench
    class K8sAPI platform
    class PyPI,NVIDIA,AMD buildegress
    class Quay registry
