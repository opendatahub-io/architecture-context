graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → 8888 or 8787/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Created by: ODH Notebook Controller"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction LR

        subgraph AuthSidecar["Auth Sidecar (Injected)"]
            KRBP["kube-rbac-proxy<br/>(RHOAI 3.x)<br/>Bearer Token authz"]
            OAuthProxy["oauth-proxy<br/>(RHOAI 2.x)<br/>OAuth2 authz"]
        end

        subgraph WorkbenchContainer["Workbench Container"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>Token: DISABLED<br/>UID: 1001 (non-root)"]
            CodeSvr["code-server<br/>8787/TCP HTTP<br/>NGINX proxy<br/>UID: 1001"]
            RStudio["RStudio Server<br/>8787/TCP HTTP<br/>NGINX proxy<br/>UID: 1001"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sService["ClusterIP Service<br/>notebook (per-workbench)<br/>8888/TCP → 8888<br/>HTTP, No encryption<br/>Internal only"]
    end

    subgraph EgressRuntime["EGRESS (Runtime)"]
        K8sAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (SA)"]
    end

    subgraph EgressBuild["EGRESS (Build-Time Only)"]
        PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        NVIDIARepo["NVIDIA CUDA Repo<br/>developer.download.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ROCmRepo["AMD ROCm Repo<br/>repo.radeon.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        QuayRegistry["quay.io/modh<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Push secret"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 / OIDC"| Route
    Route -->|"HTTP/8888 or 8787<br/>Plaintext (internal)<br/>TLS terminated"| AuthSidecar
    AuthSidecar -->|"HTTP<br/>Authenticated request"| WorkbenchContainer
    WorkbenchContainer --- K8sService
    WorkbenchContainer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Build-time flows (dashed)
    WorkbenchContainer -.->|"Build-time only"| PyPI
    WorkbenchContainer -.->|"Build-time only"| NVIDIARepo
    WorkbenchContainer -.->|"Build-time only"| ROCmRepo
    WorkbenchContainer -.->|"Build-time only"| QuayRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authsidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egressbuild fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Route ingress
    class KRBP,OAuthProxy authsidecar
    class Jupyter,CodeSvr,RStudio workbench
    class K8sService internal
    class K8sAPI egress
    class PyPI,NVIDIARepo,ROCmRepo,QuayRegistry egressbuild
