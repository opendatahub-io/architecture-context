graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(Browser)"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP<br/>TLS 1.2+ SIMPLE<br/>Managed by Notebook Controller"]
    end

    subgraph AuthLayer["AUTHENTICATION SIDECAR (Injected)"]
        direction TB
        AuthProxy["kube-rbac-proxy (RHOAI 3.x)<br/>oauth-proxy (RHOAI 2.x)<br/>Injected by ODH Notebook Controller<br/>Validates user identity"]
    end

    subgraph WorkbenchPods["WORKBENCH CONTAINERS (This Component)"]
        direction TB

        subgraph JupyterPod["Jupyter Workbench"]
            Jupyter["JupyterLab Server<br/>8888/TCP HTTP<br/>Auth: DISABLED<br/>UID: 1001 (non-root)"]
        end

        subgraph RStudioPod["RStudio Workbench"]
            NGINX_R["NGINX Proxy<br/>8787/TCP"]
            RStudio["RStudio Server<br/>supervisord managed"]
            NGINX_R --> RStudio
        end

        subgraph CodeServerPod["code-server Workbench"]
            NGINX_C["NGINX Proxy<br/>8787/TCP"]
            CS["code-server v4.98.0<br/>supervisord managed"]
            NGINX_C --> CS
        end
    end

    subgraph RuntimePods["PIPELINE RUNTIMES (Headless)"]
        Runtime["Pipeline Runtime<br/>No ports (batch exec)<br/>UID: 1001 (non-root)<br/>Launched by DSP/Elyra"]
    end

    subgraph EgressBuild["EGRESS - BUILD-TIME"]
        PyPI["PyPI (pypi.org)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        NVIDIARepo["NVIDIA CUDA Repo<br/>developer.download.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        AMDRepo["AMD ROCm Repo<br/>repo.radeon.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph EgressRuntime["EGRESS - RUNTIME"]
        Quay["quay.io/modh<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
        OSAPI["OpenShift API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2/OIDC"| Route
    Route -->|"HTTP (pod-internal)<br/>No encryption"| AuthProxy
    AuthProxy -->|"HTTP/8888<br/>No auth (validated)<br/>localhost"| Jupyter
    AuthProxy -->|"HTTP/8787<br/>No auth (validated)<br/>localhost"| NGINX_R
    AuthProxy -->|"HTTP/8787<br/>No auth (validated)<br/>localhost"| NGINX_C

    Jupyter -.->|"HTTPS/6443<br/>Bearer Token<br/>oc CLI"| OSAPI
    RStudio -.->|"HTTPS/6443<br/>Bearer Token<br/>oc CLI"| OSAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egressbuild fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef egressrun fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class User external
    class Route ingress
    class AuthProxy auth
    class Jupyter,NGINX_R,RStudio,NGINX_C,CS workbench
    class Runtime runtime
    class PyPI,NVIDIARepo,AMDRepo egressbuild
    class Quay,OSAPI egressrun
