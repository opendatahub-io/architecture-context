graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["RHOAI Gateway / Envoy<br/>443/TCP → 8443/TCP<br/>TLS 1.3 Termination<br/>OAuth Token Validation"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (StatefulSet, per-user namespace)"]
        direction TB

        KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>Bearer Token AuthZ<br/>Per-user namespace isolation"]

        subgraph WorkbenchTypes["Workbench Container (one of)"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>No TLS / No Auth"]
            CodeServerWB["Code Server + nginx<br/>8585/TCP HTTP<br/>No TLS / No Auth"]
            RStudioWB["RStudio + nginx<br/>8787/TCP HTTP<br/>No TLS / No Auth"]
            RuntimeWB["Elyra Runtime<br/>8080/TCP HTTP<br/>No TLS / No Auth"]
        end

        KubeRBAC -->|"HTTP/8888-8787<br/>localhost<br/>No encryption<br/>Already authorized"| WorkbenchTypes
    end

    subgraph EgressTargets["EGRESS (User-Configured)"]
        direction TB
        PyPIEgress["PyPI<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        S3Egress["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        PostgreSQLEgress["PostgreSQL<br/>5432/TCP<br/>TLS Optional<br/>User Credentials"]
        MongoDBEgress["MongoDB<br/>27017/TCP<br/>TLS Optional<br/>User Credentials"]
        MySQLEgress["MySQL<br/>3306/TCP<br/>TLS Optional<br/>User Credentials"]
        KafkaEgress["Kafka Brokers<br/>9092/TCP<br/>Configurable<br/>Configurable"]
    end

    subgraph BuildTime["BUILD-TIME (CI/CD - Not Hermetic)"]
        Tekton["Tekton/Konflux Pipeline"]
        GitHub["GitHub<br/>443/TCP HTTPS<br/>Git Auth Secret"]
        PyPIBuild["PyPI<br/>443/TCP HTTPS<br/>No Auth"]
        UBIRepos["Red Hat UBI Repos<br/>443/TCP HTTPS<br/>No Auth"]
        QuayReg["quay.io Registry<br/>443/TCP HTTPS<br/>Registry Credentials"]
    end

    %% Runtime flows
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC

    WorkbenchTypes -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| PyPIEgress
    WorkbenchTypes -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3Egress
    WorkbenchTypes -->|"TCP/5432<br/>User Creds"| PostgreSQLEgress
    WorkbenchTypes -->|"TCP/27017<br/>User Creds"| MongoDBEgress
    WorkbenchTypes -->|"TCP/3306<br/>User Creds"| MySQLEgress
    WorkbenchTypes -->|"TCP/9092<br/>Configurable"| KafkaEgress

    %% Build-time flows
    Tekton -->|"HTTPS/443<br/>TLS 1.2+"| GitHub
    Tekton -->|"HTTPS/443<br/>TLS 1.2+"| PyPIBuild
    Tekton -->|"HTTPS/443<br/>TLS 1.2+"| UBIRepos
    Tekton -->|"HTTPS/443<br/>TLS 1.2+"| QuayReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC,JupyterLab,CodeServerWB,RStudioWB,RuntimeWB workbench
    class PyPIEgress,S3Egress,PostgreSQLEgress,MongoDBEgress,MySQLEgress,KafkaEgress egress
    class Tekton,GitHub,PyPIBuild,UBIRepos,QuayReg buildtime
