graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP → HTTPRoute<br/>TLS 1.3<br/>OIDC/OAuth"]
    end

    subgraph AuthSidecar["AUTH SIDECAR (Pod boundary)"]
        KubeRBAC["kube-rbac-proxy<br/>8443/TCP TLS<br/>SubjectAccessReview<br/>Injected by Notebook Controller"]
    end

    subgraph WorkbenchPod["WORKBENCH CONTAINERS (User namespace)<br/>UID 1001 / GID 0 (non-root)"]
        direction TB

        subgraph JupyterOption["Option A: Jupyter"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>auth: none (internal)"]
        end

        subgraph CodeServerOption["Option B: Code Server"]
            NGINX_CS["NGINX Proxy<br/>8080/TCP HTTP<br/>/api/status health"]
            CS["code-server v4.98<br/>8787/TCP HTTP<br/>auth: none"]
        end

        subgraph RStudioOption["Option C: RStudio"]
            NGINX_RS["NGINX Proxy<br/>8080/TCP HTTP<br/>/api/status health"]
            RS["RStudio Server 2024.12<br/>8787/TCP HTTP<br/>R 4.4.3"]
        end
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        PyPI["PyPI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        CRAN["CRAN<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
    end

    subgraph Databases["USER DATABASES (Various)"]
        MongoDB["MongoDB<br/>27017/TCP<br/>mongocli auth"]
        MSSQL["MSSQL Server<br/>1433/TCP<br/>SQL auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>SQL auth"]
    end

    subgraph PipelineRuntime["PIPELINE RUNTIME (Ephemeral)"]
        KFP["KFP API<br/>443/TCP HTTPS"]
        RuntimePod["Runtime Image Pod<br/>Headless (no ports)<br/>ServiceAccount auth"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OIDC/OAuth"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC

    %% Auth → Workbench
    KubeRBAC -->|"HTTP/8888<br/>None (pod-local)<br/>No auth"| Jupyter
    KubeRBAC -->|"HTTP/8080<br/>None (pod-local)<br/>No auth"| NGINX_CS
    KubeRBAC -->|"HTTP/8080<br/>None (pod-local)<br/>No auth"| NGINX_RS
    NGINX_CS -->|"HTTP/8787<br/>pod-local"| CS
    NGINX_RS -->|"HTTP/8787<br/>pod-local"| RS

    %% Egress
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+"| PyPI
    RS -->|"HTTPS/443<br/>TLS 1.2+"| CRAN
    Jupyter -->|"Various ports<br/>User credentials"| MongoDB
    Jupyter -->|"Various ports<br/>User credentials"| MSSQL
    Jupyter -->|"Various ports<br/>User credentials"| PostgreSQL

    %% Pipeline flow
    Jupyter -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| KFP
    KFP -->|"K8s API<br/>ServiceAccount"| RuntimePod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef database fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef pipeline fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC auth
    class Jupyter,CS,RS,NGINX_CS,NGINX_RS workbench
    class K8sAPI,PyPI,CRAN egress
    class MongoDB,MSSQL,PostgreSQL database
    class KFP,RuntimePod pipeline
