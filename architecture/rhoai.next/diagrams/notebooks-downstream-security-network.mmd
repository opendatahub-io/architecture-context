graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP → HTTPRoute<br/>TLS 1.3<br/>OIDC/OAuth"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (per-user namespace)"]
        direction TB

        KRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>Injected by Notebook Controller"]

        subgraph JupyterPath["Jupyter Variant"]
            JupyterLab["JupyterLab Server<br/>8888/TCP HTTP<br/>UID 1001 / GID 0<br/>Auth: None (internal)"]
        end

        subgraph CodeServerPath["CodeServer / RStudio Variant"]
            NGINX["NGINX Reverse Proxy<br/>8080/TCP HTTP<br/>Health: /api/status"]
            IDE["code-server v4.98 /<br/>RStudio 2024.12<br/>8787/TCP HTTP<br/>UID 1001 / GID 0<br/>Auth: None"]
        end

        KRBAC -->|HTTP/8888<br/>pod-local<br/>No encryption| JupyterLab
        KRBAC -->|HTTP/8080<br/>pod-local<br/>No encryption| NGINX
        NGINX -->|HTTP/8787<br/>localhost<br/>No encryption| IDE
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        direction TB
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        PyPI["PyPI / pip<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        CRAN["CRAN<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        UserDB["User Databases<br/>MongoDB: 27017/TCP<br/>MSSQL: 1433/TCP<br/>PostgreSQL: 5432/TCP<br/>User Credentials"]
    end

    subgraph PipelineRuntime["PIPELINE RUNTIME (Ephemeral)"]
        KFP["KFP Orchestrator"]
        RuntimePod["Runtime Image Pod<br/>No ports (headless)<br/>UID 1001 / GID 0<br/>quay.io/modh/runtime-images"]
        KFP -->|Creates Pod<br/>ServiceAccount| RuntimePod
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.3<br/>OIDC/OAuth| Gateway
    Gateway -->|HTTPS/8443<br/>TLS<br/>Bearer Token<br/>SubjectAccessReview| KRBAC

    JupyterLab -->|HTTPS/443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    JupyterLab -->|HTTPS/443<br/>TLS 1.2+| PyPI
    JupyterLab -->|Various ports<br/>User creds| UserDB
    JupyterLab -->|HTTPS/443<br/>TLS<br/>Bearer Token| KFP
    IDE -->|HTTPS/443<br/>TLS 1.2+| PyPI
    IDE -->|HTTPS/443<br/>TLS 1.2+| CRAN

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBAC sidecar
    class JupyterLab,NGINX,IDE pod
    class K8sAPI,PyPI,CRAN,UserDB egress
    class KFP,RuntimePod runtime
