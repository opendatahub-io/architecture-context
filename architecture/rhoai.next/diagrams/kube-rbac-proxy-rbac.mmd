graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kube-rbac-proxy<br/>(example SA)"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kube-rbac-proxy<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["kube-rbac-proxy<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph HardcodedAccess["Hardcoded Access (Built-in)"]
        MetricsAllow["Hardcoded Authorizer<br/>Always allows GET /metrics<br/>for prometheus-k8s SA"]
    end

    subgraph AuthMethods["Request Authorization (Runtime)"]
        direction TB

        subgraph Format1["Format1 Config"]
            F1Desc["Static resourceAttributes<br/>+ optional rewrites<br/>(query params / headers)"]
        end

        subgraph Format2["Format2 Config"]
            F2Desc["Per-path endpoint rules<br/>Per-method resource mappings<br/>Template expansion"]
        end
    end

    %% RBAC flow
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Hardcoded access
    PromSA -->|"hardcoded allow<br/>GET /metrics<br/>(no SAR check)"| MetricsAllow

    %% SAR authorization methods
    CR -.->|"used by proxy to<br/>perform SAR checks<br/>on behalf of callers"| Format1
    CR -.->|"used by proxy to<br/>perform SAR checks<br/>on behalf of callers"| Format2

    %% Notes
    Note1["Note: The proxy's own SA needs<br/>tokenreviews + subjectaccessreviews<br/>create permission.<br/><br/>Actual RBAC is defined by<br/>rhods-operator, not this repo."]

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style PromSA fill:#e6522c,color:#fff
    style CRB fill:#9b59b6,color:#fff
    style CR fill:#f5a623,color:#fff
    style TokenReviews fill:#27ae60,color:#fff
    style SAR fill:#27ae60,color:#fff
    style MetricsAllow fill:#e74c3c,color:#fff
    style F1Desc fill:#3498db,color:#fff
    style F2Desc fill:#3498db,color:#fff
    style Note1 fill:#f9f9f9,stroke:#ccc,font-size:11px
