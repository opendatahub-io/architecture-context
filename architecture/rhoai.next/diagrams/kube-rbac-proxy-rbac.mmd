graph TD
    subgraph ServiceAccounts["Service Accounts"]
        ComponentSA["Component ServiceAccount<br/>(defined by deploying operator)"]
        PrometheusSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["ClusterRoleBinding<br/>(defined by deploying operator)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["ClusterRole: kube-rbac-proxy<br/>(defined by rhods-operator)"]
    end

    subgraph APIResources["API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph HardcodedAccess["Hardcoded Access (No RBAC Needed)"]
        MetricsEndpoint["GET /metrics<br/>(hardcoded allow in proxy code)"]
    end

    subgraph AuthPipeline["Authentication & Authorization Pipeline"]
        direction TB

        subgraph AuthNMethods["AuthN Methods (mutually exclusive)"]
            BearerToken["Bearer Token AuthN<br/>→ K8s TokenReview API"]
            OIDCToken["OIDC JWT AuthN<br/>→ External JWKS validation"]
            ClientCert["X.509 Client Cert AuthN<br/>→ CA validation, CN as identity"]
        end

        subgraph AuthZChain["AuthZ Chain (priority order)"]
            Authz1["1. Hardcoded Metrics<br/>Auto-allow prometheus-k8s<br/>GET /metrics"]
            Authz2["2. Static Authorizer<br/>Config file rules"]
            Authz3["3. SAR Authorizer<br/>K8s SubjectAccessReview"]
        end
    end

    %% RBAC bindings
    ComponentSA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Hardcoded access
    PrometheusSA -->|"hardcoded allow<br/>(no SAR needed)"| MetricsEndpoint

    %% Auth pipeline flow
    BearerToken -->|"identity"| Authz1
    OIDCToken -->|"identity"| Authz1
    ClientCert -->|"identity"| Authz1
    Authz1 -->|"if not matched"| Authz2
    Authz2 -->|"if not matched"| Authz3

    %% SAR uses the RBAC
    Authz3 -->|"checks caller's<br/>RBAC permissions"| SAR

    %% Styling
    style ComponentSA fill:#4a90e2,stroke:#333,color:#fff
    style PrometheusSA fill:#e6522c,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style TokenReviews fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style MetricsEndpoint fill:#f8cecc,stroke:#b85450
    style BearerToken fill:#dae8fc,stroke:#6c8ebf
    style OIDCToken fill:#dae8fc,stroke:#6c8ebf
    style ClientCert fill:#dae8fc,stroke:#6c8ebf
    style Authz1 fill:#fff2cc,stroke:#d6b656
    style Authz2 fill:#fff2cc,stroke:#d6b656
    style Authz3 fill:#fff2cc,stroke:#d6b656
