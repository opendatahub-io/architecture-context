graph TD
    subgraph "Service Account"
        SA["kube-rbac-proxy<br/>(in deploying namespace)"]
    end

    subgraph "ClusterRole Binding"
        CRB["kube-rbac-proxy<br/>(cluster-wide)"]
    end

    subgraph "ClusterRole"
        CR["kube-rbac-proxy"]
    end

    subgraph "API Resources"
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "Hardcoded Authorization (in-process)"
        HardcodedRule["Hardcoded Allow Rule<br/>(pkg/hardcodedauthorizer/metrics.go)"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["GET /metrics"]
    end

    subgraph "Authentication Mechanisms"
        BearerToken["Bearer Token<br/>(TokenReview API)"]
        ClientCert["x509 Client Certificate<br/>(--client-ca-file)"]
        OIDCJWT["OIDC JWT<br/>(--oidc-issuer)"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    CR -->|"create"| TokenReviews
    CR -->|"create"| SubjectAccessReviews

    HardcodedRule -->|"unconditionally allows"| PromSA
    HardcodedRule -->|"on path"| MetricsEndpoint

    BearerToken -->|"validated via"| TokenReviews
    BearerToken -->|"authorized via"| SubjectAccessReviews
    ClientCert -->|"authorized via"| SubjectAccessReviews
    OIDCJWT -->|"authorized via"| SubjectAccessReviews

    style SA fill:#4a90e2,color:#fff
    style CRB fill:#5ba0d9,color:#fff
    style CR fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SubjectAccessReviews fill:#7ed321,color:#fff
    style HardcodedRule fill:#e8744f,color:#fff
    style PromSA fill:#f9f9f9,stroke:#999
    style MetricsEndpoint fill:#f9f9f9,stroke:#999
    style BearerToken fill:#d5e8d4,stroke:#82b366
    style ClientCert fill:#d5e8d4,stroke:#82b366
    style OIDCJWT fill:#d5e8d4,stroke:#82b366
