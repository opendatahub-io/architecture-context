graph TD
    subgraph "Service Account"
        SA["kube-rbac-proxy<br/>(per-component namespace)"]
    end

    subgraph "ClusterRole Binding"
        CRB["kube-rbac-proxy<br/>(cluster-scoped)"]
    end

    subgraph "ClusterRole"
        CR["kube-rbac-proxy"]
    end

    subgraph "API Resources"
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "Hardcoded Authorization"
        HardcodedRule["Always Allow Rule"]
        PrometheusIdentity["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
        MetricsEndpoint["GET /metrics"]
    end

    subgraph "Authorization Formats"
        Format1["Format1: Top-level<br/>resourceAttributes<br/>(simple SAR)"]
        Format2["Format2: Path-scoped<br/>endpoint rules<br/>(per-method SAR)"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    PrometheusIdentity -->|"matches"| HardcodedRule
    HardcodedRule -->|"allows"| MetricsEndpoint

    SA -->|"evaluates requests<br/>using"| Format1
    SA -->|"evaluates requests<br/>using"| Format2

    style SA fill:#4a90e2,color:#fff
    style CRB fill:#9b59b6,color:#fff
    style CR fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SAR fill:#7ed321,color:#fff
    style HardcodedRule fill:#e74c3c,color:#fff
    style PrometheusIdentity fill:#e1d5e7,stroke:#333
    style MetricsEndpoint fill:#e1d5e7,stroke:#333
    style Format1 fill:#dae8fc,stroke:#6c8ebf
    style Format2 fill:#dae8fc,stroke:#6c8ebf
