graph TD
    subgraph "Service Accounts"
        ComponentSA["(Component ServiceAccount)<br/>e.g., dashboard-sa, notebook-controller-sa"]
        PrometheusSA["system:serviceaccount:<br/>openshift-monitoring:prometheus-k8s"]
    end

    subgraph "ClusterRole Bindings"
        CRB["(Component ClusterRoleBinding)<br/>Defined by rhods-operator"]
    end

    subgraph "ClusterRole: kube-rbac-proxy"
        CR["kube-rbac-proxy ClusterRole<br/>(defined by deploying operator)"]
    end

    subgraph "API Resources Required by Proxy"
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        BearerAuth["Bearer Token Auth<br/>Kubernetes TokenReview<br/>2-minute cache TTL"]
        OIDCAuth["OIDC JWT Auth<br/>External JWKS validation<br/>Claims → user/groups"]
        X509Auth["X.509 Client Cert Auth<br/>CA validation<br/>CN → identity"]
    end

    subgraph "Authorization Chain (Priority Order)"
        direction TB
        HardcodedAuthZ["1. Hardcoded Metrics Authorizer<br/>Auto-allows prometheus-k8s SA<br/>GET /metrics ONLY<br/>No API calls needed"]
        StaticAuthZ["2. Static Authorizer<br/>Config file rules<br/>User/verb/resource matching<br/>No API calls needed"]
        SARAuthZ["3. SAR Authorizer<br/>SubjectAccessReview API call<br/>Allow cache: 5 minutes<br/>Deny cache: 30 seconds"]
    end

    subgraph "Hardcoded Allow Rule"
        HardcodedRule["Unconditional Allow:<br/>Subject: system:serviceaccount:openshift-monitoring:prometheus-k8s<br/>Verb: GET<br/>Path: /metrics<br/>No ClusterRole/Binding needed"]
    end

    subgraph "Request Path Bypass"
        IgnorePaths["--ignore-paths<br/>Matching paths bypass ALL<br/>authn/authz entirely<br/>(e.g., /healthz, /ready)"]
    end

    %% RBAC Flow
    ComponentSA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Authentication to Authorization flow
    BearerAuth -->|"identity resolved"| HardcodedAuthZ
    OIDCAuth -->|"identity resolved"| HardcodedAuthZ
    X509Auth -->|"identity resolved"| HardcodedAuthZ
    HardcodedAuthZ -->|"not matched"| StaticAuthZ
    StaticAuthZ -->|"not matched"| SARAuthZ

    %% Prometheus special path
    PrometheusSA -->|"GET /metrics<br/>hardcoded allow"| HardcodedRule

    %% Styling
    style ComponentSA fill:#4a90e2,color:#fff
    style PrometheusSA fill:#f5a623,color:#fff
    style CR fill:#f5a623
    style CRB fill:#e8e8e8
    style TokenReviews fill:#7ed321
    style SAR fill:#7ed321
    style BearerAuth fill:#6baed6,color:#fff
    style OIDCAuth fill:#6baed6,color:#fff
    style X509Auth fill:#6baed6,color:#fff
    style HardcodedAuthZ fill:#d5e8d4
    style StaticAuthZ fill:#fff2cc
    style SARAuthZ fill:#f8cecc
    style HardcodedRule fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style IgnorePaths fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
