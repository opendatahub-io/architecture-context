graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kube-rbac-proxy<br/>(per-namespace,<br/>set by deploying operator)"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kube-rbac-proxy<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["kube-rbac-proxy"]
    end

    subgraph APIResources["API Resources Accessed"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph Verbs["Allowed Verbs"]
        Create["create"]
    end

    subgraph HardcodedAuth["Hardcoded Authorization (No RBAC)"]
        MetricsAllow["GET /metrics<br/>(non-resource URL)<br/>Always ALLOW"]
    end

    %% RBAC chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Hardcoded authorization
    PromSA -->|"hardcoded allow<br/>(no SAR needed)"| MetricsAllow

    %% What the permissions enable
    TokenReviews -->|"enables"| AuthnCheck["Authenticate<br/>bearer tokens<br/>via K8s API"]
    SAR -->|"enables"| AuthzCheck["Authorize requests<br/>via K8s RBAC"]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style PromSA fill:#ee0000,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style Create fill:#ddd,stroke:#333
    style MetricsAllow fill:#fce4ec,stroke:#c62828
    style AuthnCheck fill:#e3f2fd,stroke:#1565c0
    style AuthzCheck fill:#e3f2fd,stroke:#1565c0
