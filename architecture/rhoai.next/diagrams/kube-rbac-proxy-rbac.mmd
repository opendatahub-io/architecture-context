graph TD
    subgraph "Service Account"
        SA["kube-rbac-proxy<br/>(in deploying namespace)"]
    end

    subgraph "ClusterRole Binding"
        CRB["kube-rbac-proxy<br/>(cluster-wide)"]
    end

    subgraph "ClusterRole: kube-rbac-proxy"
        CR["kube-rbac-proxy"]
    end

    subgraph "API Resources"
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"create"| TokenReviews
    CR -->|"create"| SubjectAccessReviews

    %% Hardcoded Authorization (built into binary)
    subgraph "Hardcoded Authorizer (in-binary)"
        HardcodedRule["Allow Rule:<br/>GET /metrics"]
    end

    subgraph "Hardcoded Allowed Service Account"
        PromSA["system:serviceaccount:<br/>openshift-monitoring:<br/>prometheus-k8s"]
    end

    PromSA -->|"hardcoded allow<br/>(no RBAC needed)"| HardcodedRule
    HardcodedRule -.->|"bypasses SAR for"| SubjectAccessReviews

    %% Auth Header Injection
    subgraph "Injected Request Headers"
        XForwardedUser["X-Forwarded-User<br/>(authenticated username)"]
        XForwardedGroups["X-Forwarded-Groups<br/>(authenticated groups)"]
    end

    SA -.->|"after auth, injects"| XForwardedUser
    SA -.->|"after auth, injects"| XForwardedGroups

    %% Runtime Authorization Flow
    subgraph "Runtime Authorization Flow"
        direction LR
        Step1["1. Authenticate<br/>(TokenReview/OIDC/x509)"]
        Step2["2. Check Hardcoded<br/>(prometheus-k8s → /metrics)"]
        Step3["3. Check Static Config<br/>(--config-file)"]
        Step4["4. Check SAR<br/>(SubjectAccessReview)"]
        Step1 --> Step2
        Step2 -->|"not matched"| Step3
        Step3 -->|"not matched"| Step4
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#2b6cb0,color:#fff
    style CRB fill:#7b68ee,stroke:#5a4fcf,color:#fff
    style CR fill:#f5a623,stroke:#d4881e,color:#fff
    style TokenReviews fill:#7ed321,stroke:#5a8a3c
    style SubjectAccessReviews fill:#7ed321,stroke:#5a8a3c
    style HardcodedRule fill:#e8d5b7,stroke:#b8860b
    style PromSA fill:#e8d5b7,stroke:#b8860b
    style XForwardedUser fill:#dce8f5,stroke:#4a90e2
    style XForwardedGroups fill:#dce8f5,stroke:#4a90e2
    style Step1 fill:#4a90e2,color:#fff
    style Step2 fill:#f5a623,color:#fff
    style Step3 fill:#f5a623,color:#fff
    style Step4 fill:#f5a623,color:#fff
