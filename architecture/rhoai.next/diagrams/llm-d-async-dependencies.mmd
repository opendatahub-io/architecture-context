graph LR
    AP["llm-d Async Processor<br/>(async-processor)"]

    %% External Dependencies (Required)
    AP -->|"Redis protocol/6379<br/>queues, retries, results<br/>budget keys, quota"| Redis["Redis<br/>(go-redis v9)<br/>Required*"]
    AP -->|"HTTP(S)/80,443<br/>POST inference requests<br/>TLS 1.2+ / mTLS"| IGW["Inference Gateway<br/>(IGW)<br/>Required"]
    AP -->|"HTTPS/443<br/>SA Token auth<br/>TokenReview, SAR"| K8sAPI["Kubernetes API<br/>v1.34+<br/>Required"]

    %% External Dependencies (Optional / Alternative)
    AP -.->|"HTTPS/443<br/>gRPC via Go client<br/>OAuth2"| GCPPubSub["GCP Pub/Sub<br/>(v2 API)<br/>Required*"]
    AP -.->|"HTTP/9090<br/>PromQL queries<br/>gate metrics"| Prometheus["Prometheus<br/>(v1 API)<br/>Optional"]
    AP -.->|"HTTPS/443<br/>PromQL (GCP alt)<br/>OAuth2"| GMP["Google Managed<br/>Prometheus (GMP)<br/>Optional"]

    %% Internal Platform Dependencies (Indirect via metrics)
    AP -.->|"Prometheus metrics<br/>(indirect)<br/>flow control queue size"| EPP["llm-d Inference<br/>Scheduler (EPP)"]
    AP -.->|"Prometheus metrics<br/>(indirect)<br/>running request count"| vLLM["vLLM Model<br/>Servers"]
    AP -.->|"Prometheus metrics<br/>(indirect)<br/>ready pods count"| InferencePool["Gateway API<br/>InferencePool"]

    %% Producer SDK (client library)
    ProducerApp["Producer<br/>Application"] -->|"Go SDK import<br/>producer/ package"| ProducerSDK["Producer SDK<br/>(Go Library)"]
    ProducerSDK -->|"Redis/6379<br/>ZADD/BRPOP"| Redis

    %% Note annotations
    Note1["* Redis required for redis-pubsub<br/>and redis-sortedset impls.<br/>GCP Pub/Sub required for<br/>gcp-pubsub impl."]

