graph TB
    subgraph KubeRay["KubeRay Operator (ray-operator)"]
        direction TB
        subgraph Controllers["Controllers"]
            RCC[RayCluster Controller]
            RJC[RayJob Controller]
            RSC[RayService Controller]
            AuthC[Authentication Controller]
            MTLSC[MTLS Controller]
            NPC[NetworkPolicy Controller]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutWH[Mutating Webhook<br/>mraycluster.kb.io]
            ValWH[Validating Webhook<br/>vraycluster.kb.io]
        end

        subgraph Metrics["Observability"]
            MetricsEP[Metrics Endpoint<br/>8080/TCP]
            HealthEP[Health/Ready<br/>8082/TCP]
        end
    end

    %% CRDs
    RayClusterCR[RayCluster CR<br/>ray.io/v1]
    RayJobCR[RayJob CR<br/>ray.io/v1]
    RayServiceCR[RayService CR<br/>ray.io/v1]

    %% User interactions
    User[User / Data Scientist] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% Webhook interception
    RayClusterCR -->|intercepts| MutWH
    MutWH -->|defaults annotations| ValWH
    ValWH -->|validates name/workers| RCC

    %% Controller watches
    RayClusterCR -->|watched by| RCC
    RayClusterCR -->|watched by| AuthC
    RayClusterCR -->|watched by| MTLSC
    RayClusterCR -->|watched by| NPC
    RayJobCR -->|watched by| RJC
    RayServiceCR -->|watched by| RSC

    %% Resources created by controllers
    RCC -->|creates| HeadPod[Head Pod]
    RCC -->|creates| WorkerPods[Worker Pods]
    RCC -->|creates| HeadSvc[Head Service<br/>10001,8265,6379,8080,8000]
    RCC -->|creates| ServeSvc[Serve Service<br/>8000/TCP]
    RCC -->|creates| AutoscalerRBAC[Autoscaler RBAC<br/>Role + RoleBinding]

    RJC -->|creates ephemeral| RayClusterCR
    RJC -->|submits jobs via| RayDashboard[Ray Dashboard API<br/>8265/TCP]

    RSC -->|manages active/pending| RayClusterCR
    RSC -->|updates Serve config via| RayDashboard

    AuthC -->|creates| HTTPRoute[HTTPRoute<br/>in platform namespace]
    AuthC -->|creates| RefGrant[ReferenceGrant]
    AuthC -->|injects| AuthProxy[OAuth/kube-rbac-proxy<br/>sidecar on 8443]

    MTLSC -->|creates| Issuer[cert-manager Issuer]
    MTLSC -->|creates| Certs[cert-manager Certificates<br/>head + worker TLS]

    NPC -->|creates| NetPol[NetworkPolicy<br/>per-cluster isolation]

    %% External dependencies
    RCC -->|depends on| K8sAPI[Kubernetes API<br/>443/TCP]
    AuthC -->|reads config| OAuthAPI[OpenShift OAuth<br/>config.openshift.io]
    HTTPRoute -->|parent ref| Gateway[data-science-gateway<br/>Gateway]

    %% Prometheus scrape
    Prometheus[Prometheus] -->|scrapes| MetricsEP

    %% Styling
    style KubeRay fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8d4,stroke:#82b366
    style Webhooks fill:#fff2cc,stroke:#d6b656
    style Metrics fill:#f8cecc,stroke:#b85450

    style RCC fill:#4a90e2,color:#fff
    style RJC fill:#4a90e2,color:#fff
    style RSC fill:#4a90e2,color:#fff
    style AuthC fill:#4a90e2,color:#fff
    style MTLSC fill:#4a90e2,color:#fff
    style NPC fill:#4a90e2,color:#fff

    style MutWH fill:#f5a623,color:#fff
    style ValWH fill:#f5a623,color:#fff

    style RayClusterCR fill:#f5a623
    style RayJobCR fill:#f5a623
    style RayServiceCR fill:#f5a623

    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OAuthAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
