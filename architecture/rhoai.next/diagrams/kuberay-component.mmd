graph TB
    subgraph KubeRayOperator["KubeRay Operator"]
        direction TB
        RayClusterCtrl["RayCluster Controller<br/>Pod, Service, Ingress mgmt"]
        RayJobCtrl["RayJob Controller<br/>Job submission & lifecycle"]
        RayServiceCtrl["RayService Controller<br/>Zero-downtime Serve upgrades"]
        AuthCtrl["Authentication Controller<br/>Gateway API HTTPRoute & OIDC proxy"]
        mTLSCtrl["mTLS Controller<br/>cert-manager certificate mgmt"]
        NetPolCtrl["NetworkPolicy Controller<br/>Annotation-driven isolation"]
        Webhook["Webhook Server<br/>9443/TCP TLS"]
    end

    User[User / Data Scientist] -->|creates/updates| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    User -->|creates/updates| RayJobCR["RayJob CR<br/>ray.io/v1"]
    User -->|creates/updates| RayServiceCR["RayService CR<br/>ray.io/v1"]

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod<br/>Ports: 6379, 8265, 10001"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    RayClusterCtrl -->|creates| ServeSvc["{cluster}-serve-svc<br/>ClusterIP :8000"]
    RayClusterCtrl -->|creates| HeadlessSvc["{cluster}-headless<br/>DNS Discovery"]

    AuthCtrl -->|creates| HTTPRoute["HTTPRoute<br/>Gateway API"]
    AuthCtrl -->|injects| RBACProxy["kube-rbac-proxy<br/>Sidecar :8443"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant<br/>Cross-namespace"]

    mTLSCtrl -->|creates| Issuer["cert-manager Issuer"]
    mTLSCtrl -->|creates| HeadCert["Head TLS Certificate<br/>90-day validity"]
    mTLSCtrl -->|creates| WorkerCert["Worker TLS Certificate<br/>90-day validity"]

    NetPolCtrl -->|creates| NetPol["NetworkPolicy<br/>Fine-grained ingress"]

    RayJobCtrl -->|creates| SubmitterJob["K8s Job (Submitter)"]
    RayJobCtrl -->|queries| DashboardAPI["Ray Dashboard API<br/>:8265"]

    RayServiceCtrl -->|manages| ActiveCluster["Active RayCluster"]
    RayServiceCtrl -->|manages| PendingCluster["Pending RayCluster"]

    HTTPRoute -->|references| Gateway["data-science-gateway<br/>:443 HTTPS"]

    RayClusterCR -->|validated by| Webhook
    Webhook -->|validates & mutates| RayClusterCR

    %% Styling
    style KubeRayOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,color:#fff
    style RayJobCtrl fill:#4a90e2,color:#fff
    style RayServiceCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#4a90e2,color:#fff
    style mTLSCtrl fill:#4a90e2,color:#fff
    style NetPolCtrl fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,color:#fff
    style RayJobCR fill:#f5a623,color:#fff
    style RayServiceCR fill:#f5a623,color:#fff
    style HeadPod fill:#7ed321
    style WorkerPods fill:#7ed321
    style HeadSvc fill:#7ed321
    style ServeSvc fill:#7ed321
    style HeadlessSvc fill:#7ed321
    style HTTPRoute fill:#9b59b6,color:#fff
    style RBACProxy fill:#e74c3c,color:#fff
    style Gateway fill:#999,color:#fff
    style Issuer fill:#f39c12
    style HeadCert fill:#f39c12
    style WorkerCert fill:#f39c12
    style NetPol fill:#e74c3c,color:#fff
