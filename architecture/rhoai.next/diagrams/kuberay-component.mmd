graph TB
    subgraph KubeRayOperator["KubeRay Operator"]
        direction TB
        RayClusterCtrl["RayCluster Controller<br/>Pod/Service lifecycle"]
        RayJobCtrl["RayJob Controller<br/>Job submission & tracking"]
        RayServiceCtrl["RayService Controller<br/>Zero-downtime serving upgrades"]
        AuthCtrl["Authentication Controller<br/>OIDC proxy & HTTPRoute mgmt"]
        NetPolCtrl["NetworkPolicy Controller<br/>Pod network isolation"]
        mTLSCtrl["mTLS Controller<br/>cert-manager certificate chain"]
        Webhook["Admission Webhooks<br/>9443/TCP HTTPS"]
        Metrics["Metrics Server<br/>8080/TCP HTTP"]
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|creates| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|creates| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% Webhook intercepts
    RayClusterCR -->|mutate/validate| Webhook
    Webhook -->|admitted| RayClusterCR

    %% Controller watches
    RayClusterCR -->|watched by| RayClusterCtrl
    RayClusterCR -->|watched by| AuthCtrl
    RayClusterCR -->|watched by| NetPolCtrl
    RayClusterCR -->|watched by| mTLSCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Created resources
    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod<br/>8265, 10001, 6379"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["Head Service<br/>ClusterIP"]
    RayClusterCtrl -->|creates| ServeSvc["Serve Service<br/>8000/TCP"]

    AuthCtrl -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant"]
    AuthCtrl -->|injects| KubeRBACProxy["kube-rbac-proxy<br/>sidecar 8443/TCP"]

    NetPolCtrl -->|creates| NetworkPolicy["NetworkPolicy"]

    mTLSCtrl -->|creates| Issuer["cert-manager Issuer"]
    mTLSCtrl -->|creates| Certificate["cert-manager Certificate"]

    RayJobCtrl -->|submits jobs via| HeadPod
    RayServiceCtrl -->|manages| HeadPod

    %% External dependencies
    HTTPRoute -->|references| PlatformGW["Platform Gateway<br/>(data-science-gateway)"]
    KubeRBACProxy -->|TokenReview| K8sAPI["Kubernetes API<br/>443/TCP"]
    Certificate -.->|issued by| CertManager["cert-manager"]

    %% Styling
    style KubeRayOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,color:#fff
    style RayJobCtrl fill:#4a90e2,color:#fff
    style RayServiceCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#4a90e2,color:#fff
    style NetPolCtrl fill:#4a90e2,color:#fff
    style mTLSCtrl fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,color:#fff
    style RayJobCR fill:#f5a623,color:#fff
    style RayServiceCR fill:#f5a623,color:#fff
    style HeadPod fill:#7ed321,color:#fff
    style WorkerPods fill:#7ed321,color:#fff
    style HeadSvc fill:#7ed321
    style ServeSvc fill:#7ed321
    style HTTPRoute fill:#7ed321
    style RefGrant fill:#7ed321
    style NetworkPolicy fill:#7ed321
    style Issuer fill:#7ed321
    style Certificate fill:#7ed321
    style KubeRBACProxy fill:#e8e8e8,stroke:#333
    style PlatformGW fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
