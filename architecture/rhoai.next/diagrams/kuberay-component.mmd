graph TB
    subgraph KubeRayOperator["KubeRay Operator"]
        direction TB
        RCController["RayCluster Controller<br/>Reconciles head/worker pods,<br/>services, ingress, RBAC"]
        RJController["RayJob Controller<br/>Manages job submission,<br/>retries, deletion policies"]
        RSController["RayService Controller<br/>Zero-downtime upgrades<br/>via pending cluster promotion"]
        AuthController["Authentication Controller<br/>OAuth/OIDC — HTTPRoutes,<br/>ReferenceGrants, kube-rbac-proxy"]
        NPController["NetworkPolicy Controller<br/>Head and worker<br/>NetworkPolicies"]
        MTLSController["mTLS Controller<br/>cert-manager Issuers<br/>and Certificates"]
        MutWebhook["Mutating Webhook<br/>Defaults secure-trusted-network,<br/>enforces enableIngress=false"]
        ValWebhook["Validating Webhook<br/>Name format, worker group<br/>uniqueness validation"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% User interactions
    User["User / Platform Operator"]
    User -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CRD watches
    RayClusterCR -->|watched by| RCController
    RayClusterCR -->|watched by| AuthController
    RayClusterCR -->|watched by| NPController
    RayClusterCR -->|watched by| MTLSController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController

    %% Webhook intercepts
    RayClusterCR -.->|intercepts create/update| MutWebhook
    RayClusterCR -.->|intercepts create/update| ValWebhook

    %% Created resources
    RCController -->|creates| HeadPod["Head Pod"]
    RCController -->|creates| WorkerPods["Worker Pods"]
    RCController -->|creates| HeadSvc["Head Service"]
    RCController -->|creates| ServeSvc["Serve Service"]
    RJController -->|creates| K8sJob["K8s Job<br/>(submitter)"]
    RSController -->|manages| PendingCluster["Pending RayCluster<br/>(upgrade)"]

    %% Auth resources
    AuthController -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthController -->|creates| RefGrant["ReferenceGrant"]
    AuthController -->|injects| KRBProxy["kube-rbac-proxy<br/>sidecar"]

    %% mTLS resources
    MTLSController -->|creates| Issuer["cert-manager Issuer"]
    MTLSController -->|creates| Certificate["cert-manager Certificate"]

    %% NetworkPolicy resources
    NPController -->|creates| NetPol["NetworkPolicies"]

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"]
    CertManager["cert-manager"]
    Gateway["data-science-gateway<br/>(Gateway CR)"]
    RayDashboard["Ray Dashboard<br/>8265/TCP"]

    RCController -->|CRUD| K8sAPI
    RJController -->|polls status| RayDashboard
    RSController -->|serve config| RayDashboard
    MTLSController -->|creates certs| CertManager
    HTTPRoute -->|references| Gateway

    %% Styling
    style KubeRayOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style RCController fill:#4a90e2,color:#fff
    style RJController fill:#4a90e2,color:#fff
    style RSController fill:#4a90e2,color:#fff
    style AuthController fill:#4a90e2,color:#fff
    style NPController fill:#4a90e2,color:#fff
    style MTLSController fill:#4a90e2,color:#fff
    style MutWebhook fill:#9b59b6,color:#fff
    style ValWebhook fill:#9b59b6,color:#fff
    style RayClusterCR fill:#f5a623
    style RayJobCR fill:#f5a623
    style RayServiceCR fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style CertManager fill:#e8e8e8
    style Gateway fill:#7ed321,color:#fff
    style RayDashboard fill:#e8e8e8
    style HeadPod fill:#d5e8d4
    style WorkerPods fill:#d5e8d4
    style HeadSvc fill:#d5e8d4
    style ServeSvc fill:#d5e8d4
    style K8sJob fill:#d5e8d4
    style PendingCluster fill:#d5e8d4
    style HTTPRoute fill:#d5e8d4
    style RefGrant fill:#d5e8d4
    style KRBProxy fill:#d5e8d4
    style Issuer fill:#d5e8d4
    style Certificate fill:#d5e8d4
    style NetPol fill:#d5e8d4
