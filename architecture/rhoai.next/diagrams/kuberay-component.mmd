graph TB
    subgraph KubeRay["KubeRay Operator"]
        direction TB
        subgraph Controllers["Controllers"]
            RCCtrl["RayCluster Controller"]
            RJCtrl["RayJob Controller"]
            RSCtrl["RayService Controller"]
            AuthCtrl["Authentication Controller"]
            mTLSCtrl["mTLS Controller"]
            NPCtrl["NetworkPolicy Controller"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutWebhook["Mutating Webhook<br/>mraycluster.kb.io"]
            ValWebhook["Validating Webhook<br/>vraycluster.kb.io"]
        end

        Metrics["Metrics Endpoint<br/>8080/TCP"]
        Health["Health/Ready<br/>8081/TCP"]
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|creates| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|creates| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% Webhook intercept
    RayClusterCR -->|admission| MutWebhook
    MutWebhook -->|defaults security annotation<br/>blocks enableIngress| ValWebhook
    ValWebhook -->|validates name + worker groups| RayClusterCR

    %% Controller watches
    RayClusterCR -->|watched by| RCCtrl
    RayJobCR -->|watched by| RJCtrl
    RayServiceCR -->|watched by| RSCtrl
    RayClusterCR -->|watched by| AuthCtrl
    RayClusterCR -->|watched by| mTLSCtrl
    RayClusterCR -->|watched by| NPCtrl

    %% Created resources
    RCCtrl -->|creates| HeadPod["Head Pod<br/>(with auth sidecar)"]
    RCCtrl -->|creates| WorkerPods["Worker Pods"]
    RCCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    RCCtrl -->|creates| ServeSvc["{cluster}-serve-svc<br/>8000/TCP"]
    RJCtrl -->|creates| SubmitterJob["K8s Job<br/>(submitter pod)"]
    RJCtrl -->|creates auto| RayClusterCR

    AuthCtrl -->|creates in platform ns| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    AuthCtrl -->|injects| AuthSidecar["kube-rbac-proxy<br/>sidecar (8443/TCP)"]

    mTLSCtrl -->|creates| CAIssuer["CA Issuer<br/>(cert-manager)"]
    mTLSCtrl -->|creates| NodeCerts["Head/Worker Certs<br/>(90-day validity)"]

    NPCtrl -->|creates| NetPol["NetworkPolicies"]

    %% External dependencies
    HTTPRoute -->|references| Gateway["data-science-gateway<br/>(Gateway CR)"]
    AuthCtrl -->|watches| OAuthConfig["OpenShift OAuth/OIDC<br/>Config"]

    %% Styling
    style KubeRay fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controllers fill:#bbdefb,stroke:#1565c0
    style Webhooks fill:#bbdefb,stroke:#1565c0
    style RCCtrl fill:#4a90e2,color:#fff
    style RJCtrl fill:#4a90e2,color:#fff
    style RSCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#4a90e2,color:#fff
    style mTLSCtrl fill:#4a90e2,color:#fff
    style NPCtrl fill:#4a90e2,color:#fff
    style MutWebhook fill:#7b1fa2,color:#fff
    style ValWebhook fill:#7b1fa2,color:#fff
    style RayClusterCR fill:#f5a623
    style RayJobCR fill:#f5a623
    style RayServiceCR fill:#f5a623
    style HTTPRoute fill:#7ed321
    style RefGrant fill:#7ed321
    style Gateway fill:#999
    style OAuthConfig fill:#999
    style CAIssuer fill:#ff9800
    style NodeCerts fill:#ff9800
    style NetPol fill:#e91e63,color:#fff
    style AuthSidecar fill:#e91e63,color:#fff
