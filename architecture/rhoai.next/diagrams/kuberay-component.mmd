graph TB
    subgraph KubeRayOperator["KubeRay Operator (ray-operator)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            RayClusterCtrl["RayCluster Controller<br/>Reconciles RayCluster CRs"]
            RayJobCtrl["RayJob Controller<br/>Reconciles RayJob CRs"]
            RayServiceCtrl["RayService Controller<br/>Reconciles RayService CRs"]
        end

        subgraph SecurityControllers["Security Controllers (RHOAI)"]
            AuthCtrl["Authentication Controller<br/>OAuth/OIDC proxy, HTTPRoutes,<br/>ReferenceGrants, ServiceAccounts"]
            MTLSCtrl["MTLS Controller<br/>cert-manager Issuers &<br/>Certificates for mTLS"]
            NetPolCtrl["NetworkPolicy Controller<br/>Per-cluster NetworkPolicies"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutatingWH["Mutating Webhook<br/>Defaults RayCluster annotations"]
            ValidatingWH["Validating Webhook<br/>Validates name format &<br/>worker group uniqueness"]
        end

        RayClusterCtrl --> AuthCtrl
        RayClusterCtrl --> MTLSCtrl
        RayClusterCtrl --> NetPolCtrl
    end

    %% CRDs
    User["User / Data Scientist"] -->|kubectl apply| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|kubectl apply| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|kubectl apply| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    %% Created Resources
    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod<br/>(with optional auth sidecar)"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    RayJobCtrl -->|creates ephemeral| RayClusterCR
    RayJobCtrl -->|submits job via| RayDashboard["Ray Dashboard API<br/>8265/TCP"]
    RayServiceCtrl -->|manages| ActiveCluster["Active RayCluster"]
    RayServiceCtrl -->|creates| PendingCluster["Pending RayCluster<br/>(blue-green upgrade)"]
    RayServiceCtrl -->|manages| ServeSvc["{cluster}-serve<br/>8000/TCP"]

    AuthCtrl -->|creates in platform ns| HTTPRoute["HTTPRoute<br/>/ray/{ns}/{cluster}/*"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    MTLSCtrl -->|creates| Issuer["cert-manager Issuer<br/>(per-cluster CA)"]
    MTLSCtrl -->|creates| Certs["TLS Certificates<br/>(head + worker, 90d)"]
    NetPolCtrl -->|creates| NetPol["NetworkPolicy<br/>(per-cluster isolation)"]

    %% External Dependencies
    RayClusterCtrl -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP"]
    AuthCtrl -->|reads config| OAuthConfig["OpenShift OAuth<br/>config.openshift.io"]
    HTTPRoute -->|parent ref| Gateway["data-science-gateway<br/>(shared Gateway)"]
    MTLSCtrl -->|depends on| CertManager["cert-manager"]

    %% Webhook flow
    K8sAPI -->|admission request| MutatingWH
    K8sAPI -->|admission request| ValidatingWH

    %% Styling
    style KubeRayOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style SecurityControllers fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Webhooks fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style RayClusterCtrl fill:#4a90e2,color:#fff
    style RayJobCtrl fill:#4a90e2,color:#fff
    style RayServiceCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#f5a623,color:#fff
    style MTLSCtrl fill:#f5a623,color:#fff
    style NetPolCtrl fill:#f5a623,color:#fff
    style MutatingWH fill:#e06666,color:#fff
    style ValidatingWH fill:#e06666,color:#fff
    style RayClusterCR fill:#b4a7d6,stroke:#674ea7
    style RayJobCR fill:#b4a7d6,stroke:#674ea7
    style RayServiceCR fill:#b4a7d6,stroke:#674ea7
    style Gateway fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style OAuthConfig fill:#999,stroke:#333
