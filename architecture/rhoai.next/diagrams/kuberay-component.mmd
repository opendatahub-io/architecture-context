graph TB
    subgraph KubeRayOperator["KubeRay Operator"]
        direction TB
        RayClusterCtrl["RayCluster Controller<br/>Pod, Service, Ingress mgmt"]
        RayJobCtrl["RayJob Controller<br/>Job submission & lifecycle"]
        RayServiceCtrl["RayService Controller<br/>Zero-downtime serving upgrades"]
        AuthCtrl["Authentication Controller<br/>Gateway API HTTPRoute & OIDC proxy"]
        mTLSCtrl["mTLS Controller<br/>cert-manager certificate mgmt"]
        NetPolCtrl["NetworkPolicy Controller<br/>Annotation-driven network isolation"]
        Webhook["Webhook Server<br/>9443/TCP TLS"]
        Metrics["Metrics Server<br/>8080/TCP"]
    end

    User["Data Scientist / User"] -->|"kubectl apply"| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|"kubectl apply"| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|"kubectl apply"| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    RayClusterCR -->|"watched by"| RayClusterCtrl
    RayJobCR -->|"watched by"| RayJobCtrl
    RayServiceCR -->|"watched by"| RayServiceCtrl

    RayClusterCtrl -->|"creates"| HeadPod["Ray Head Pod<br/>8265/TCP Dashboard<br/>6379/TCP GCS<br/>10001/TCP Client"]
    RayClusterCtrl -->|"creates"| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|"creates"| HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    RayClusterCtrl -->|"creates"| ServeSvc["{cluster}-serve-svc<br/>8000/TCP"]
    RayClusterCtrl -->|"creates"| HeadlessSvc["{cluster}-headless<br/>DNS Discovery"]

    RayJobCtrl -->|"creates"| SubmitterJob["K8s Job<br/>(Submitter Pod)"]
    SubmitterJob -->|"submits via"| HeadPod

    RayServiceCtrl -->|"manages"| ActiveCluster["Active RayCluster"]
    RayServiceCtrl -->|"manages"| PendingCluster["Pending RayCluster<br/>(during upgrade)"]

    AuthCtrl -->|"creates"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    AuthCtrl -->|"injects"| RBACProxy["kube-rbac-proxy<br/>sidecar 8443/TCP"]
    AuthCtrl -->|"creates"| RefGrant["ReferenceGrant<br/>(cross-namespace)"]

    mTLSCtrl -->|"creates"| Issuer["cert-manager Issuer"]
    mTLSCtrl -->|"creates"| Certs["TLS Certificates<br/>(head + worker)"]

    NetPolCtrl -->|"creates"| NetPol["NetworkPolicies<br/>(ingress isolation)"]

    HTTPRoute -->|"references"| Gateway["data-science-gateway<br/>(Platform Gateway)"]

    RayClusterCR -.->|"validates"| Webhook
    HeadPod -->|"optional"| Redis["Redis<br/>6379/TCP<br/>GCS Fault Tolerance"]

    style KubeRayOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style RayClusterCtrl fill:#4a90e2,color:#fff
    style RayJobCtrl fill:#4a90e2,color:#fff
    style RayServiceCtrl fill:#4a90e2,color:#fff
    style AuthCtrl fill:#4a90e2,color:#fff
    style mTLSCtrl fill:#4a90e2,color:#fff
    style NetPolCtrl fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,color:#fff
    style RayJobCR fill:#f5a623,color:#fff
    style RayServiceCR fill:#f5a623,color:#fff
    style HeadPod fill:#7ed321,color:#fff
    style WorkerPods fill:#7ed321,color:#fff
    style HTTPRoute fill:#9b59b6,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style RBACProxy fill:#e74c3c,color:#fff
