graph TD
    subgraph Note["RBAC Model for FMS HF Tuning"]
        direction TB
        Info["ℹ️ FMS HF Tuning does not define its own RBAC roles.<br/>RBAC is managed by the Kubeflow Training Operator<br/>and the PyTorchJob service account."]
    end

    subgraph KFTOManaged["RBAC Managed by Kubeflow Training Operator"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            PodSA["PyTorchJob Pod SA<br/>(created by KFTO per job)"]
        end

        subgraph Permissions["Inherited Permissions"]
            PodPerms["Pod Permissions:<br/>- Read ConfigMaps<br/>- Read Secrets (HF_TOKEN)<br/>- Mount PVCs"]
        end

        subgraph Resources["Resources Accessed"]
            PVC_R["PersistentVolumeClaim<br/>/data/input, /data/output, /data/models"]
            Secrets_R["Secrets<br/>imagePullSecrets, HF_TOKEN"]
            ConfigMap_R["ConfigMaps<br/>(training configuration)"]
        end
    end

    subgraph ExternalAuth["External Authentication (Non-RBAC)"]
        direction TB

        HFAuth["HuggingFace Hub<br/>Auth: Bearer Token (HF_TOKEN env)<br/>Scope: Read access to model repos"]
        MLflowAuth["MLflow Server<br/>Auth: URI-based (MLFLOW_TRACKING_URI)<br/>Scope: Depends on server config"]
        ClearMLAuth["ClearML Server<br/>Auth: API Key (clearml-init)<br/>Scope: Project/task write access"]
    end

    subgraph ImagePull["Container Image Pull"]
        ImagePullSecret["imagePullSecrets<br/>Type: kubernetes.io/dockerconfigjson<br/>Registry: quay.io/modh/fms-hf-tuning<br/>Provisioned: Manual / Cluster admin<br/>Auto-Rotate: No"]
    end

    %% Relationships
    PodSA -->|"bound by KFTO"| PodPerms
    PodPerms -->|"mounts"| PVC_R
    PodPerms -->|"reads"| Secrets_R
    PodPerms -->|"reads"| ConfigMap_R

    PodSA -->|"uses"| ImagePullSecret

    PodSA -.->|"env var: HF_TOKEN"| HFAuth
    PodSA -.->|"env var: MLFLOW_TRACKING_URI"| MLflowAuth
    PodSA -.->|"local config"| ClearMLAuth

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style PodSA fill:#4a90e2,stroke:#333,color:#fff
    style PodPerms fill:#d5e8d4,stroke:#82b366
    style PVC_R fill:#7ed321,stroke:#333,color:#fff
    style Secrets_R fill:#f5a623,stroke:#333,color:#fff
    style ConfigMap_R fill:#7ed321,stroke:#333,color:#fff
    style HFAuth fill:#e8e8e8,stroke:#333
    style MLflowAuth fill:#e8e8e8,stroke:#333
    style ClearMLAuth fill:#e8e8e8,stroke:#333
    style ImagePullSecret fill:#f5a623,stroke:#333,color:#fff
