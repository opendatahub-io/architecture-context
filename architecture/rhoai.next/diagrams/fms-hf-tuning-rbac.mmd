graph TD
    subgraph Legend["RBAC Context for fms-hf-tuning"]
        direction TB
        Note["This component does NOT define its own RBAC.<br/>RBAC is managed by the Kubeflow Training Operator (KFTO).<br/>The diagram below shows the RBAC context in which<br/>fms-hf-tuning training pods operate."]
    end

    subgraph KFTO_RBAC["KFTO-Managed RBAC (External to this component)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            KFTOManagerSA["kfto-controller-manager<br/>(KFTO namespace)"]
            PodSA["PyTorchJob Pod SA<br/>(user namespace)"]
        end

        subgraph ClusterRoles["Cluster Roles (managed by KFTO)"]
            KFTORole["kfto-manager-role<br/>Manages PyTorchJob lifecycle"]
        end

        subgraph Permissions["KFTO Permissions on Training Resources"]
            PyTorchJobs["kubeflow.org<br/>PyTorchJob<br/>get, list, watch,<br/>create, update, delete"]
            Pods["core<br/>Pods<br/>get, list, watch,<br/>create, delete"]
            Services["core<br/>Services<br/>get, list, watch,<br/>create, delete"]
            ConfigMaps["core<br/>ConfigMaps<br/>get, list, watch"]
            Events["core<br/>Events<br/>create, patch"]
        end

        KFTOManagerSA -->|"ClusterRoleBinding"| KFTORole
        KFTORole -->|"manages"| PyTorchJobs
        KFTORole -->|"manages"| Pods
        KFTORole -->|"manages"| Services
        KFTORole -->|"reads"| ConfigMaps
        KFTORole -->|"writes"| Events
    end

    subgraph PodAccess["Training Pod Access (Runtime)"]
        direction TB

        PodSA2["Pod ServiceAccount<br/>(from PyTorchJob spec)"]

        subgraph PodResources["Resources Accessed by Training Pod"]
            PVCAccess["PVC Mounts<br/>(model weights, data, output)<br/>Access: filesystem only"]
            ConfigMapAccess["ConfigMap Mount<br/>(/etc/config/config.json)<br/>Access: filesystem only"]
            GPUAccess["GPU Resources<br/>(nvidia.com/gpu)<br/>Access: device plugin"]
            TermLog["Termination Log<br/>(/dev/termination-log)<br/>Access: filesystem"]
        end

        PodSA2 -.->|"no K8s API calls<br/>needed by container"| PodResources
    end

    subgraph Secrets["Secrets Used"]
        HFToken["HF_TOKEN<br/>(Opaque, env var)<br/>HuggingFace Hub auth<br/>Provisioned by: User"]
        ImagePull["imagePullSecrets<br/>(dockerconfigjson)<br/>Registry credentials<br/>Provisioned by: User"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KFTOManagerSA fill:#4a90e2,color:#fff
    style PodSA fill:#4a90e2,color:#fff
    style PodSA2 fill:#4a90e2,color:#fff
    style KFTORole fill:#f5a623,color:#fff
    style PyTorchJobs fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Events fill:#7ed321,color:#fff
    style PVCAccess fill:#e8e8e8,stroke:#333
    style ConfigMapAccess fill:#e8e8e8,stroke:#333
    style GPUAccess fill:#e8e8e8,stroke:#333
    style TermLog fill:#e8e8e8,stroke:#333
    style HFToken fill:#f8cecc,stroke:#b85450
    style ImagePull fill:#f8cecc,stroke:#b85450
