graph TD
    subgraph "fms-hf-tuning RBAC Model"
        direction TB

        subgraph Note["Component RBAC Note"]
            Info["ℹ️ fms-hf-tuning does NOT define<br/>its own RBAC resources.<br/>RBAC is managed externally by<br/>Kubeflow Training Operator (KFTO)."]
        end

        subgraph "KFTO-Managed RBAC (External)"
            direction TB
            SA_KFTO["ServiceAccount<br/>kubeflow-training-operator<br/>(operator namespace)"]
            CR_KFTO["ClusterRole<br/>kubeflow-training-operator"]
            CRB_KFTO["ClusterRoleBinding<br/>kubeflow-training-operator"]

            SA_KFTO -->|"bound via"| CRB_KFTO
            CRB_KFTO -->|"grants"| CR_KFTO
        end

        subgraph "KFTO Permissions on Training Resources"
            PyTorchJob["kubeflow.org<br/>PyTorchJob<br/>get, list, watch,<br/>create, update, delete"]
            Pods["core<br/>Pods<br/>get, list, watch,<br/>create, delete"]
            Services["core<br/>Services<br/>get, list, watch,<br/>create, delete"]
            Events["core<br/>Events<br/>create, patch"]
        end

        CR_KFTO -->|"manages"| PyTorchJob
        CR_KFTO -->|"manages"| Pods
        CR_KFTO -->|"manages"| Services
        CR_KFTO -->|"manages"| Events

        subgraph "Training Pod Identity"
            SA_Pod["ServiceAccount<br/>{user-provided-sa}<br/>(project namespace)"]
            PodAccess["Pod Permissions:<br/>- Read PVCs (model, data)<br/>- Write PVCs (output)<br/>- Pull container images<br/>- Access GPU devices"]
        end

        SA_Pod -->|"runs as"| PodAccess
    end

    subgraph "Secrets Access"
        HFToken["HF_TOKEN<br/>(env var / Secret mount)<br/>HuggingFace auth"]
        ImagePull["imagePullSecrets<br/>(dockerconfigjson)<br/>Registry auth"]
    end

    SA_Pod -.->|"reads"| HFToken
    SA_Pod -.->|"uses"| ImagePull

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style SA_KFTO fill:#4a90e2,stroke:#333,color:#fff
    style CR_KFTO fill:#f5a623,stroke:#333
    style CRB_KFTO fill:#e8e8e8,stroke:#333
    style SA_Pod fill:#4a90e2,stroke:#333,color:#fff
    style PodAccess fill:#d5e8d4,stroke:#82b366
    style PyTorchJob fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style HFToken fill:#f8cecc,stroke:#b85450
    style ImagePull fill:#f8cecc,stroke:#b85450
