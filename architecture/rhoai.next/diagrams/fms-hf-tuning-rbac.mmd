graph TD
    subgraph Component["FMS HF Tuning - RBAC Model"]
        direction TB
        Note["This component defines NO RBAC roles.<br/>RBAC is managed externally by:<br/>Kubeflow Training Operator (KFTO)"]
    end

    subgraph ManagedByKFTO["Managed by Kubeflow Training Operator"]
        direction TB

        SA["ServiceAccount<br/>(PyTorchJob-assigned)<br/>per training job"]

        subgraph Permissions["Effective Permissions (via KFTO)"]
            K8sAPI["Kubernetes API Server<br/>Pod lifecycle management"]
            PodAccess["Pods<br/>get, list, watch"]
            JobAccess["Jobs/PyTorchJobs<br/>get, list, watch, update status"]
        end
    end

    subgraph Secrets["Secrets & Credentials"]
        direction TB

        ImagePull["imagePullSecrets<br/>Type: kubernetes.io/dockerconfigjson<br/>Purpose: Pull from Quay.io<br/>Provisioned: Manual / Cluster admin<br/>Auto-Rotate: No"]

        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>for gated model downloads<br/>Provisioned: Manual / User<br/>Auto-Rotate: No"]
    end

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB

        HFAuth["HuggingFace Hub API<br/>Method: GET<br/>Auth: Bearer Token (HF_TOKEN)<br/>Enforcement: HF server<br/>Policy: Read access to model repo"]

        MLflowAuth["MLflow Tracking<br/>Method: POST<br/>Auth: URI-based (MLFLOW_TRACKING_URI)<br/>Enforcement: MLflow server<br/>Policy: Server-dependent"]

        ClearMLAuth["ClearML API<br/>Method: POST<br/>Auth: API key (clearml-init config)<br/>Enforcement: ClearML server<br/>Policy: Project/task write access"]
    end

    SA -->|"uses"| K8sAPI
    K8sAPI -->|"grants"| PodAccess
    K8sAPI -->|"grants"| JobAccess

    SA -.->|"mounts"| ImagePull
    SA -.->|"env var"| HFToken

    HFToken -->|"provides token"| HFAuth

    style Component fill:#e8f4f8,stroke:#4a90e2,stroke-width:2px
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,color:#fff
    style K8sAPI fill:#4a90e2,color:#fff
    style PodAccess fill:#7ed321,color:#fff
    style JobAccess fill:#7ed321,color:#fff
    style ImagePull fill:#f5a623,color:#fff
    style HFToken fill:#f5a623,color:#fff
    style HFAuth fill:#e8e8e8,stroke:#333
    style MLflowAuth fill:#e8e8e8,stroke:#333
    style ClearMLAuth fill:#e8e8e8,stroke:#333
