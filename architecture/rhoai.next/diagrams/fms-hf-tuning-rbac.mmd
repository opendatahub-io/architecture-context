graph TD
    subgraph "fms-hf-tuning RBAC Model"
        direction TB

        Note["NOTE: fms-hf-tuning does not define its own<br/>Kubernetes RBAC resources. RBAC is managed by<br/>the Kubeflow Training Operator (KFTO) that<br/>orchestrates the PyTorchJob."]
    end

    subgraph "Kubeflow Training Operator RBAC (External)"
        direction TB

        SA_KFTO["ServiceAccount<br/>training-operator<br/>Namespace: kubeflow"]

        CRB_KFTO["ClusterRoleBinding<br/>training-operator-binding"]

        CR_KFTO["ClusterRole<br/>training-operator"]

        subgraph "API Resources Managed"
            PyTorchJob["kubeflow.org<br/>PyTorchJob"]
            Pods["core<br/>Pods"]
            Services["core<br/>Services"]
            ConfigMaps["core<br/>ConfigMaps"]
            Events["core<br/>Events"]
        end

        SA_KFTO -->|"bound via"| CRB_KFTO
        CRB_KFTO -->|"grants"| CR_KFTO
        CR_KFTO -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| PyTorchJob
        CR_KFTO -->|"get,list,watch,<br/>create,delete"| Pods
        CR_KFTO -->|"get,list,watch,<br/>create,delete"| Services
        CR_KFTO -->|"get,list,watch"| ConfigMaps
        CR_KFTO -->|"create,patch"| Events
    end

    subgraph "Training Job Pod Security"
        direction TB

        JobSA["ServiceAccount<br/>(job-specific)<br/>Namespace: {user-namespace}"]

        PodSec["Pod Security Context<br/>runAsUser: 1000 (tuning)<br/>runAsNonRoot: true"]

        subgraph "Secrets Accessed"
            ConfigEnv["SFT_TRAINER_CONFIG_JSON_ENV_VAR<br/>Type: Opaque (env var)<br/>Base64-encoded JSON config"]
            ConfigFile["SFT_TRAINER_CONFIG_JSON_PATH<br/>Type: Opaque (file mount)<br/>JSON config file path"]
        end

        JobSA -->|"runs as"| PodSec
        JobSA -->|"accesses"| ConfigEnv
        JobSA -->|"accesses"| ConfigFile
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA_KFTO fill:#4a90e2,color:#fff
    style CRB_KFTO fill:#e8e8e8
    style CR_KFTO fill:#f5a623,color:#fff
    style PyTorchJob fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Events fill:#7ed321,color:#fff
    style JobSA fill:#4a90e2,color:#fff
    style PodSec fill:#e1d5e7,stroke:#9673a6
    style ConfigEnv fill:#f8cecc,stroke:#b85450
    style ConfigFile fill:#f8cecc,stroke:#b85450
