graph TD
    subgraph FMSNote["FMS HF Tuning - RBAC Model"]
        direction TB
        Note["ℹ️ FMS HF Tuning does NOT define its own RBAC roles.<br/>RBAC is managed by the Kubeflow Training Operator (KFTO)<br/>and the PyTorchJob service account."]
    end

    subgraph KFTOManaged["Managed by Kubeflow Training Operator"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            JobSA["PyTorchJob ServiceAccount<br/>(job-specific, per-namespace)"]
        end

        subgraph Permissions["Inherited Permissions"]
            KubeAPI["Kubernetes API<br/>Access via ServiceAccount token<br/>TLS 1.2+"]
        end

        subgraph Resources["Resources Accessed"]
            Pods["core/v1<br/>Pods<br/>get, list, watch"]
            PVCs["core/v1<br/>PersistentVolumeClaims<br/>get, list"]
            ConfigMaps["core/v1<br/>ConfigMaps<br/>get, list"]
            Secrets["core/v1<br/>Secrets<br/>get (HF_TOKEN, imagePullSecrets)"]
        end
    end

    subgraph SecretsDetail["Secrets Used by Training Pods"]
        direction TB
        ImagePull["imagePullSecrets<br/>Type: kubernetes.io/dockerconfigjson<br/>Purpose: Pull from quay.io/modh/<br/>Provisioned: Manual/Cluster admin<br/>Auto-Rotate: No"]
        HFToken["HF_TOKEN (env var)<br/>Type: Opaque<br/>Purpose: HuggingFace Hub auth<br/>for gated model downloads<br/>Provisioned: Manual/User<br/>Auto-Rotate: No"]
    end

    subgraph ExternalAuth["External Authentication"]
        direction TB
        HFAuth["HuggingFace Hub API<br/>Method: GET<br/>Auth: Bearer Token (HF_TOKEN)<br/>Policy: Read access to model repo"]
        MLflowAuth["MLflow Tracking<br/>Method: POST<br/>Auth: URI-based (MLFLOW_TRACKING_URI)<br/>Policy: Server-dependent"]
        ClearMLAuth["ClearML API<br/>Method: POST<br/>Auth: API key (clearml-init config)<br/>Policy: Project/task write access"]
    end

    %% Relationships
    JobSA -->|"authenticates via"| KubeAPI
    KubeAPI -->|"accesses"| Pods
    KubeAPI -->|"accesses"| PVCs
    KubeAPI -->|"accesses"| ConfigMaps
    KubeAPI -->|"accesses"| Secrets

    Secrets -->|"provides"| ImagePull
    Secrets -->|"provides"| HFToken

    HFToken -->|"used for"| HFAuth

    %% Styling
    style FMSNote fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Note fill:#fff2cc,stroke:#d6b656
    style KFTOManaged fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style KubeAPI fill:#dae8fc,stroke:#6c8ebf
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PVCs fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#f5a623,stroke:#333,color:#fff
    style SecretsDetail fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style ImagePull fill:#f8cecc,stroke:#b85450
    style HFToken fill:#f8cecc,stroke:#b85450
    style ExternalAuth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style HFAuth fill:#e1d5e7,stroke:#9673a6
    style MLflowAuth fill:#e1d5e7,stroke:#9673a6
    style ClearMLAuth fill:#e1d5e7,stroke:#9673a6
