graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        UserBrowser["User Browser"]
        RayClient["Ray Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        DashboardRoute["ray-dashboard-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["rayclient-{name} Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["CodeFlare Operator<br/>SA: controller-manager"]
        WebhookSvc["Webhook Service<br/>443 → 9443/TCP<br/>TLS (cert-controller)"]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACE (per RayCluster)"]
        direction TB

        subgraph HeadPod["Ray Head Pod"]
            RayHead["ray-head<br/>8265/TCP (dashboard)<br/>10001/TCP (client)"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth"]
        end

        subgraph WorkerPods["Ray Worker Pod(s)"]
            RayWorker["ray-worker<br/>mTLS (cluster CA)"]
        end

        OAuthSvc["{raycluster}-oauth Service<br/>443 → 8443/TCP HTTPS<br/>OpenShift serving cert"]
        CASecret["ca-secret-{cluster}<br/>RSA 2048-bit CA"]
        NetPol["NetworkPolicies<br/>Restrict head/worker traffic"]
    end

    subgraph ExternalServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ServingCert["OpenShift Serving Cert<br/>Annotation-triggered"]
        IngressConfig["Cluster Ingress Config<br/>config.openshift.io"]
        Prometheus["Prometheus Monitoring<br/>8080/TCP HTTP"]
    end

    %% External flows
    UserBrowser -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (→ OAuth redirect)"| DashboardRoute
    RayClient -->|"HTTPS/443<br/>TLS Passthrough<br/>mTLS (cluster CA cert)"| ClientRoute

    %% Ingress to pods
    DashboardRoute -->|"HTTPS/8443<br/>TLS Reencrypt<br/>Serving cert"| OAuthProxy
    ClientRoute -->|"Ray/10001<br/>mTLS Passthrough<br/>Cluster CA cert"| RayHead

    %% OAuth flow
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth redirect flow"| OAuthServer
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>Authenticated cookie"| RayHead

    %% Service routing
    OAuthSvc -.->|routes to| OAuthProxy

    %% Inter-node mTLS
    RayHead <-->|"Ray/10001<br/>mTLS (cluster CA)<br/>Client cert"| RayWorker

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>Webhook call"| WebhookSvc
    Operator -.->|reads| IngressConfig
    Prometheus -->|"HTTP/8080<br/>No TLS<br/>ServiceMonitor"| MetricsSvc

    %% Secrets
    Operator -->|generates| CASecret

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class UserBrowser,RayClient external
    class DashboardRoute,ClientRoute ingress
    class Operator,WebhookSvc,MetricsSvc operatorns
    class RayHead,OAuthProxy,RayWorker,OAuthSvc,CASecret,NetPol userns
    class K8sAPI,OAuthServer,ServingCert,IngressConfig,Prometheus platform
