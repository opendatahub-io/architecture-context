graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        UserBrowser["User Browser"]
        RayClient["Ray Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Ingress Controller)"]
        DashboardRoute["ray-dashboard-{cluster} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["rayclient-{cluster} Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        OperatorPod["codeflare-operator<br/>SA: codeflare-operator-controller-manager"]

        WebhookSvc["Webhook Service<br/>443→9443/TCP<br/>TLS (cert-controller)"]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP"]
        HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph UserNS["USER NAMESPACE (mTLS + NetworkPolicy)"]
        direction TB

        subgraph HeadPod["RayCluster Head Pod"]
            RayHead["ray-head<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS serving-cert"]
            InitCert1["init: create-cert<br/>Signs TLS cert with cluster CA"]
        end

        subgraph WorkerPods["RayCluster Worker Pods"]
            RayWorker["ray-worker<br/>10001/TCP gRPC"]
            InitCert2["init: create-cert<br/>Signs TLS cert with cluster CA"]
        end

        OAuthSvc["{cluster}-oauth Service<br/>443→8443/TCP HTTPS<br/>OpenShift serving-cert"]

        subgraph NetPol["NetworkPolicies"]
            WorkerPolicy["Worker: ingress ONLY from<br/>same RayCluster pods"]
            HeadPolicy["Head: ingress from<br/>cluster pods, namespace,<br/>KubeRay NS, monitoring"]
        end
    end

    subgraph Platform["PLATFORM SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS"]
        ServingCertSigner["serving-cert-signer<br/>Auto-provisions TLS"]
        KubeRay["KubeRay Operator"]
        Prometheus["OpenShift Monitoring<br/>8080/TCP HTTP"]
        ODHOperator["opendatahub-operator<br/>DSCInitialization CR"]
        Kueue["Kueue (optional)<br/>Quota scheduling"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ConfigAPI["OpenShift Config API<br/>443/TCP HTTPS"]
    end

    %% External flows
    UserBrowser -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (→ OAuth)"| DashboardRoute
    RayClient -->|"HTTPS/443<br/>TLS Passthrough<br/>mTLS client cert"| ClientRoute

    %% Ingress to pods
    DashboardRoute -->|"HTTPS/8443<br/>TLS Reencrypt<br/>OAuth Token"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>mTLS Passthrough<br/>Client cert"| RayHead
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>No auth (proxied)"| RayHead

    %% Inter-node mTLS
    RayHead -->|"gRPC/10001<br/>mTLS (cluster CA)<br/>RAY_USE_TLS=1"| RayWorker

    %% Operator flows
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| ConfigAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>Webhook calls"| WebhookSvc

    %% Platform flows
    OAuthProxy -.->|"HTTPS/443<br/>OAuth delegation"| OAuthServer
    ServingCertSigner -.->|"Annotation-based<br/>cert provisioning"| OAuthSvc
    Prometheus -->|"HTTP/8080<br/>Metrics scrape"| MetricsSvc
    KubeRay -.->|"Creates RayCluster CRs"| K8sAPI
    ODHOperator -.->|"DSCInitialization"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef netpol fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class UserBrowser,RayClient external
    class DashboardRoute,ClientRoute ingress
    class OperatorPod,WebhookSvc,MetricsSvc,HealthProbe operator
    class RayHead,OAuthProxy,InitCert1,RayWorker,InitCert2,OAuthSvc userns
    class OAuthServer,ServingCertSigner,KubeRay,Prometheus,ODHOperator,Kueue platform
    class K8sAPI,ConfigAPI controlplane
    class WorkerPolicy,HeadPolicy netpol
