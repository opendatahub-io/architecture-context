graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        DashRoute["ray-dashboard-{cluster} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["rayclient-{cluster} Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["CodeFlare Operator<br/>SA: controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Webhook: 9443/TCP HTTPS"]
        WebhookSvc["webhook-service<br/>ClusterIP 443→9443<br/>TLS (cert-controller)"]
        MetricsSvc["metrics-service<br/>ClusterIP 8080→8080<br/>HTTP (no auth)"]
    end

    subgraph UserNS["USER NAMESPACE (per RayCluster)"]
        direction TB

        subgraph HeadPod["Ray Head Pod - SA: {cluster}-oauth-proxy"]
            RayHead["ray-head container<br/>8265/TCP Dashboard (HTTP)<br/>10001/TCP Client (gRPC mTLS)<br/>8080/TCP Metrics (HTTP)"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>OpenShift OAuth"]
            InitCert1["create-cert init<br/>OpenSSL cert gen"]
        end

        subgraph WorkerPod["Ray Worker Pod(s)"]
            RayWorker["ray-worker container<br/>10001/TCP (gRPC mTLS)"]
            InitCert2["create-cert init<br/>OpenSSL cert gen"]
        end

        OAuthSvc["{cluster}-oauth Service<br/>ClusterIP 443→oauth-proxy<br/>HTTPS (serving cert)"]
        CASecret["ca-secret-{cluster}<br/>RSA 2048-bit CA<br/>Self-signed, 1yr validity"]
        OAuthConfig["{cluster}-oauth-config<br/>Cookie secret (SHA1)"]
        ProxyTLS["{cluster}-proxy-tls-secret<br/>Serving cert (auto-rotate)"]

        subgraph NetPol["NetworkPolicy Rules"]
            NPWorker["Worker: ONLY same<br/>ray.io/cluster pods"]
            NPHead["Head: layered rules<br/>cluster→all, ns→10001/8265<br/>kuberay-ns→8265/10001<br/>monitoring→8080<br/>all→8443/10001 (secured)"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
        OSHOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+"]
        OSHIngress["OpenShift Ingress Config<br/>config.openshift.io/v1"]
        Prometheus["OpenShift Monitoring<br/>Prometheus"]
        CertCtrl["cert-controller (OPA)<br/>Webhook cert rotation"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| DashRoute
    User -->|"HTTPS/443<br/>TLS 1.2+"| ClientRoute

    %% Ingress to pods
    DashRoute -->|"HTTPS/8443<br/>TLS (reencrypt)<br/>OAuth token"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>mTLS passthrough<br/>Client cert"| RayHead

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>No auth (proxied)"| RayHead
    RayHead -->|"gRPC/10001<br/>mTLS<br/>Per-pod certs"| RayWorker

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| OSHIngress
    K8sAPI -->|"HTTPS/443<br/>Webhook calls"| WebhookSvc
    OAuthProxy -->|"HTTPS/443<br/>OAuth flow"| OSHOAuth
    Prometheus -->|"HTTP/8080<br/>ServiceMonitor"| MetricsSvc
    CertCtrl -->|"Manages certs"| WebhookSvc

    %% Secret flows
    CASecret -.->|"volume mount"| InitCert1
    CASecret -.->|"volume mount"| InitCert2
    OAuthConfig -.->|"env"| OAuthProxy
    ProxyTLS -.->|"volume mount"| OAuthProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef netpol fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class User external
    class DashRoute,ClientRoute ingress
    class Operator,WebhookSvc,MetricsSvc operator
    class RayHead,OAuthProxy,InitCert1,RayWorker,InitCert2,OAuthSvc userns
    class K8sAPI,OSHOAuth,OSHIngress,Prometheus,CertCtrl cluster
    class CASecret,OAuthConfig,ProxyTLS secret
    class NPWorker,NPHead netpol
