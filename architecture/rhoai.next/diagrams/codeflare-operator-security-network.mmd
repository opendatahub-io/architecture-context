graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        UserBrowser["User Browser"]
        RayClient["Ray Client SDK"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        DashboardRoute["ray-dashboard Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>OpenShift OAuth"]
        ClientRoute["rayclient Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough<br/>mTLS"]
    end

    subgraph PodNetwork["POD NETWORK (RayCluster Namespace)<br/>NetworkPolicy: head + worker rules"]
        direction TB

        subgraph HeadPod["RayCluster Head Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS serving cert"]
            RayDashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>localhost only"]
            RayHead["Ray Head Process<br/>10001/TCP gRPC mTLS<br/>6379/TCP GCS"]
            InitCertHead["Init: create-cert<br/>openssl RSA 2048"]
        end

        subgraph WorkerPods["RayCluster Worker Pod(s)"]
            RayWorker["Ray Worker Process<br/>10001/TCP gRPC mTLS"]
            InitCertWorker["Init: create-cert<br/>openssl RSA 2048"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["CodeFlare Operator Manager<br/>SA: controller-manager<br/>9443/TCP Webhooks (HTTPS)<br/>8081/TCP Health (HTTP)<br/>8080/TCP Metrics (HTTP)"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        OSOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth"]
        OSIngress["OpenShift Ingress Config<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus Monitoring<br/>8080/TCP HTTP"]
    end

    %% External → Ingress
    UserBrowser -->|"HTTPS/443<br/>TLS 1.2+"| DashboardRoute
    RayClient -->|"HTTPS/443<br/>TLS passthrough<br/>mTLS cert"| ClientRoute

    %% Ingress → Pods
    DashboardRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>mTLS passthrough"| RayHead

    %% Intra-pod
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>post-auth"| RayDashboard

    %% Inter-node mTLS
    RayHead <-->|"gRPC/10001<br/>mTLS<br/>CA-signed certs"| RayWorker

    %% OAuth delegation
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth delegation"| OSOAuth

    %% Operator → Platform
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OSIngress

    %% Prometheus scrape
    Prometheus -.->|"HTTP/8080<br/>metrics scrape"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class UserBrowser,RayClient external
    class DashboardRoute,ClientRoute ingress
    class OAuthProxy,RayDashboard,RayHead,RayWorker,InitCertHead,InitCertWorker podnetwork
    class Operator operator
    class K8sAPI,OSOAuth,OSIngress,Prometheus platform
