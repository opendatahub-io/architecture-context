graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        DashRoute["ray-dashboard-{cluster} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["rayclient-{cluster} Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["CodeFlare Operator Manager<br/>SA: controller-manager<br/>Probes: 8081/TCP<br/>Metrics: 8080/TCP HTTP<br/>Webhook: 9443/TCP HTTPS"]
    end

    subgraph UserNS["USER NAMESPACE (per RayCluster)"]
        direction TB

        subgraph HeadPod["Ray Head Pod"]
            OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth<br/>TLS: serving cert"]
            RayHead["Ray Head Container<br/>Dashboard: 8265/TCP HTTP<br/>Client: 10001/TCP gRPC<br/>mTLS: per-pod cert"]
        end

        subgraph WorkerPods["Ray Worker Pods"]
            RayWorker["Ray Worker Container<br/>10001/TCP gRPC<br/>mTLS: per-pod cert<br/>NetworkPolicy: same cluster only"]
        end

        NetPolHead["NetworkPolicy (Head)<br/>same-cluster: all ports<br/>same-ns: 10001, 8265<br/>KubeRay ns: 8265, 10001<br/>monitoring: 8080<br/>all: 8443 (OAuth), 10001 (mTLS)"]
        NetPolWorker["NetworkPolicy (Worker)<br/>same ray.io/cluster: all<br/>all other: DENIED"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ServingCert["OpenShift Serving<br/>Cert Signer"]
        Prometheus["Prometheus<br/>openshift-monitoring<br/>8080/TCP HTTP"]
        KubeRay["KubeRay Operator"]
        CertCtrl["cert-controller (OPA)<br/>Webhook cert rotation"]
        ODHOp["opendatahub-operator<br/>DSCInitialization CR"]
        Kueue["Kueue (optional)<br/>Quota management"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| DashRoute
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Client cert"| ClientRoute

    %% Ingress to pods
    DashRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth token"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>TLS passthrough<br/>mTLS"| RayHead

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>no auth"| RayHead
    RayHead -->|"gRPC/10001<br/>mTLS<br/>per-pod certs"| RayWorker
    RayWorker -->|"gRPC/10001<br/>mTLS<br/>per-pod certs"| RayHead

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>Webhook calls"| Operator

    %% Platform service flows
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth exchange"| OAuthServer
    ServingCert -.->|"Generates TLS cert<br/>for oauth service"| OAuthProxy
    CertCtrl -.->|"Rotates webhook<br/>TLS cert"| Operator
    Prometheus -->|"HTTP/8080<br/>ServiceMonitor"| Operator
    KubeRay -.->|"Creates<br/>RayCluster CRs"| K8sAPI
    ODHOp -.->|"DSCInitialization<br/>namespace discovery"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class DashRoute,ClientRoute ingress
    class Operator operator
    class OAuthProxy,RayHead,RayWorker userns
    class K8sAPI,OAuthServer,ServingCert,Prometheus,KubeRay,CertCtrl,ODHOp,Kueue platform
    class NetPolHead,NetPolWorker netpol
