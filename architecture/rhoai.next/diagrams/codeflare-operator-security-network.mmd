graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
        RayClient["Ray Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Ingress Controller / HAProxy)"]
        DashRoute["ray-dashboard-{cluster} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        ClientRoute["rayclient-{cluster} Route<br/>443/TCP → 10001/TCP<br/>TLS Passthrough"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph HeadPod["RayCluster Head Pod"]
                OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>OpenShift serving-cert<br/>OAuth delegation"]
                Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>localhost only"]
                HeadNode["Ray Head Node<br/>10001/TCP gRPC<br/>mTLS (cluster CA)"]
            end

            subgraph WorkerPods["RayCluster Worker Pods"]
                Worker["Ray Workers<br/>10001/TCP gRPC<br/>mTLS (cluster CA)<br/>NetworkPolicy: same-cluster only"]
            end
        end

        subgraph NS_Operator["Namespace: opendatahub"]
            Operator["codeflare-operator<br/>controller-manager<br/>SA: codeflare-operator-controller-manager"]
            WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>TLS (cert-controller)<br/>Endpoints: /mutate, /validate"]
            MetricsSvc["Metrics Service<br/>8080/TCP HTTP"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth delegation"]
        ServingCert["OpenShift<br/>serving-cert-signer<br/>Auto-provisions TLS"]
        Prometheus["OpenShift Monitoring<br/>(Prometheus)<br/>8080/TCP HTTP"]
        KubeRay["KubeRay Operator<br/>Owns RayCluster CRD"]
        DSCI["opendatahub-operator<br/>DSCInitialization"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (→ OAuth)"| DashRoute
    RayClient -->|"HTTPS/443<br/>TLS passthrough<br/>mTLS client cert"| ClientRoute

    %% Ingress to pods
    DashRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth token"| OAuthProxy
    ClientRoute -->|"gRPC/10001<br/>mTLS passthrough<br/>Client cert"| HeadNode

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>No auth (proxied)"| Dashboard
    HeadNode -->|"gRPC/10001<br/>mTLS (cluster CA)<br/>Per-pod cert"| Worker

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-controller)<br/>Webhook callbacks"| WebhookSvc
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth delegation"| OAuthServer
    ServingCert -.->|"Auto-provisions<br/>TLS cert"| OAuthProxy
    Prometheus -->|"HTTP/8080<br/>Metrics scrape"| MetricsSvc
    KubeRay -.->|"Creates RayCluster CRs"| HeadPod
    Operator -->|"K8s API<br/>CRD read"| DSCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,RayClient external
    class DashRoute,ClientRoute ingress
    class OAuthProxy,Dashboard,HeadNode,Worker internal
    class Operator,WebhookSvc,MetricsSvc operator
    class K8sAPI,OAuthServer,ServingCert,Prometheus,KubeRay,DSCI platform
