graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (TLS Termination)"]
        Gateway["Envoy-compatible Gateway<br/>(Envoy Gateway / kgateway / Istio / GKE)<br/>443/TCP → internal routing<br/>TLS 1.2+ termination<br/>HTTPRoute → InferencePool backendRef"]
    end

    subgraph ExtProc["EXT-PROC SERVICES (ClusterIP — Internal Only)"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            BBR["Body-Based Router (BBR)<br/>SA: {bbr-name}-{release}<br/>9004/TCP gRPC TLS (self-signed)<br/>9005/TCP gRPC health (plaintext)<br/>9090/TCP HTTP metrics (RBAC)"]

            EPP["Endpoint Picker (EPP)<br/>SA: {epp-name}<br/>9002/TCP gRPC TLS (self-signed/custom)<br/>9003/TCP gRPC health (plaintext)<br/>9090/TCP HTTP metrics (RBAC)<br/>9090/TCP pprof (no auth)"]
        end

        subgraph Sidecars["EPP Pod Sidecars (optional)"]
            Training["Latency Training Server<br/>8000/TCP HTTP<br/>No encryption, No auth"]
            Prediction["Latency Prediction Server<br/>8001+/TCP HTTP<br/>No encryption, No auth"]
        end
    end

    subgraph ModelLayer["MODEL SERVER LAYER"]
        ModelServers["Model Server Pods<br/>(vLLM / SGLang / Triton)<br/>Namespace: {pool-namespace}<br/>varies/TCP inference<br/>varies/TCP /metrics"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount Token"]
    end

    subgraph OptionalServices["OPTIONAL EXTERNAL SERVICES"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP<br/>HTTP, Bearer Token RBAC"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No encryption, No auth"]
    end

    %% External → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / API Key"| Gateway

    %% Gateway → ext-proc
    Gateway -->|"gRPC/9004<br/>TLS (self-signed)<br/>No auth (proxy-local)"| BBR
    Gateway -->|"gRPC/9002<br/>TLS (self-signed/custom)<br/>No auth (proxy-local)"| EPP

    %% Gateway → Model Servers (after ext-proc response)
    Gateway -->|"HTTP/gRPC<br/>per-gateway config<br/>Routed to EPP-selected endpoint"| ModelServers

    %% EPP → Model Servers (metrics)
    EPP -->|"HTTP(S)/varies<br/>InsecureSkipVerify=true<br/>No auth"| ModelServers

    %% EPP/BBR → K8s API
    EPP -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watches: InferencePool,<br/>InferenceObjective,<br/>InferenceModelRewrite,<br/>Pods, Leases"| K8sAPI
    BBR -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watches: ConfigMaps"| K8sAPI

    %% EPP → Sidecars
    EPP -.->|"HTTP/8000<br/>plaintext"| Training
    EPP -.->|"HTTP/8001+<br/>plaintext"| Prediction

    %% Monitoring
    Prometheus -.->|"HTTP/9090<br/>Bearer Token"| EPP
    Prometheus -.->|"HTTP/9090<br/>Bearer Token"| BBR
    EPP -.->|"gRPC/4317<br/>plaintext"| OTLP
    BBR -.->|"gRPC/4317<br/>plaintext"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef extproc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef modelserver fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray:5

    class Client external
    class Gateway gateway
    class BBR,EPP extproc
    class Training,Prediction extproc
    class ModelServers modelserver
    class K8sAPI k8s
    class Prometheus,OTLP optional
