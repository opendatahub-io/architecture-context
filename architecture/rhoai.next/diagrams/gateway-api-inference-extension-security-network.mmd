graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Gateway / Envoy Proxy<br/>443/TCP → internal routing<br/>TLS 1.2+ termination<br/>ext-proc filter enabled"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (ext-proc Services)"]
        direction TB

        subgraph NS_BBR["BBR Service"]
            BBR["Body Based Router<br/>SA: body-based-router-{release}<br/>9004/TCP ext-proc gRPC<br/>9005/TCP health<br/>9090/TCP metrics"]
        end

        subgraph NS_EPP["EPP Service"]
            EPP["Endpoint Picker<br/>SA: {release}-inference-extension<br/>9002/TCP ext-proc gRPC<br/>9003/TCP health<br/>9090/TCP metrics<br/>Strategy: Recreate"]
            LatencyPredictor["Latency Predictor (optional)<br/>Training: 8000/TCP<br/>Prediction: 8001/TCP<br/>No TLS (pod-internal)"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]

        subgraph ModelServers["Model Server Pods"]
            ModelPod["vLLM / SGLang / Triton<br/>8000/TCP inference<br/>/metrics Prometheus endpoint"]
        end
    end

    subgraph OptionalServices["OPTIONAL EXTERNAL SERVICES"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>Plaintext"]
        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>Optional TokenReview auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Gateway-defined auth"| Gateway
    Gateway -->|"gRPC/9004<br/>TLS (self-signed/provided)<br/>No auth"| BBR
    Gateway -->|"gRPC/9002<br/>TLS (self-signed/provided)<br/>No auth"| EPP
    Gateway -->|"HTTP/8000<br/>Cluster internal<br/>No auth"| ModelPod

    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    EPP -->|"HTTP(S)/configurable<br/>Configurable TLS<br/>No auth"| ModelPod

    EPP -.->|"gRPC/4317<br/>Plaintext<br/>No auth"| OTel
    Prometheus -->|"HTTP/9090<br/>No TLS<br/>Optional TokenReview"| EPP
    Prometheus -->|"HTTP/9090<br/>No TLS<br/>No auth"| BBR

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelserver fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,BBR,LatencyPredictor clusterservice
    class K8sAPI k8s
    class ModelPod modelserver
    class OTel,Prometheus optional
