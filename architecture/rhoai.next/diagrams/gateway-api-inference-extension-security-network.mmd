graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Gateway / Envoy Proxy<br/>443/TCP → ext-proc chain<br/>TLS 1.2+<br/>HTTPRoute → InferencePool"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (ext-proc Services)"]
        direction TB

        subgraph NS_BBR["Namespace: {release-ns} (Optional)"]
            BBR["Body Based Router (BBR)<br/>SA: body-based-router-{release}<br/>9004/TCP gRPC TLS<br/>9005/TCP health<br/>9090/TCP metrics"]
        end

        subgraph NS_EPP["Namespace: {release-ns}"]
            EPP["Endpoint Picker (EPP)<br/>SA: {release}-inference-extension<br/>9002/TCP gRPC TLS<br/>9003/TCP health<br/>9090/TCP metrics<br/>Strategy: Recreate"]

            subgraph Sidecars["Optional Sidecars"]
                Training["Latency Training<br/>8000/TCP HTTP"]
                Prediction["Latency Prediction<br/>8001+/TCP HTTP"]
            end
        end

        subgraph NS_User["Namespace: {user-ns}"]
            ModelPods["Model Server Pods<br/>(vLLM / SGLang / Triton)<br/>8000/TCP inference<br/>configurable/TCP metrics"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>Plaintext"]
        Prometheus["Prometheus<br/>scrapes 9090/TCP HTTP<br/>Optional TokenReview auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Gateway-defined auth"| Gateway
    Gateway -->|"gRPC ext-proc/9004<br/>TLS (self-signed RSA 4096)<br/>No auth"| BBR
    BBR -->|"Returns<br/>X-Gateway-Model-Name header"| Gateway
    Gateway -->|"gRPC ext-proc/9002<br/>TLS (self-signed RSA 4096)<br/>No auth"| EPP
    EPP -->|"Returns<br/>selected endpoint"| Gateway
    Gateway -->|"HTTP/8000<br/>No encryption<br/>No auth"| ModelPods

    EPP -->|"HTTP/configurable<br/>Configurable encryption<br/>No auth"| ModelPods

    EPP -->|"HTTP/8001+<br/>No encryption<br/>No auth"| Prediction
    Training -->|"Model sync/30s"| Prediction

    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    EPP -.->|"gRPC/4317<br/>Plaintext<br/>No auth"| OTel
    Prometheus -.->|"HTTP/9090<br/>No encryption<br/>Optional TokenReview"| EPP
    Prometheus -.->|"HTTP/9090<br/>No encryption<br/>No auth"| BBR

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef modelpod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class BBR,EPP,Training,Prediction clusterservice
    class ModelPods modelpod
    class K8sAPI controlplane
    class OTel,Prometheus externalservice
