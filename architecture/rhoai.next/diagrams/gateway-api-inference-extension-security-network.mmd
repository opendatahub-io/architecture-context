graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (TLS Termination)"]
        Gateway["Envoy-Compatible Gateway<br/>(Envoy GW / kgateway / Istio / GKE)<br/>443/TCP → internal<br/>TLS 1.2+<br/>Bearer Token / API Key"]
    end

    subgraph IGW_Services["IGW SERVICES (Cluster-Internal)"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            BBR["Body-Based Router (BBR)<br/>SA: {bbr-name}-{release}<br/>9004/TCP gRPC TLS (self-signed)<br/>9005/TCP health (plaintext)<br/>9090/TCP metrics (Bearer RBAC)"]

            EPP["Endpoint Picker (EPP)<br/>SA: {epp-name}<br/>9002/TCP gRPC TLS (self-signed/custom)<br/>9003/TCP health (plaintext)<br/>9090/TCP metrics (Bearer RBAC)"]

            TrainingServer["Latency Training Server<br/>(optional sidecar)<br/>8000/TCP HTTP<br/>No Auth"]

            PredictionServer["Latency Prediction Server<br/>(optional sidecar)<br/>8001+/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph ModelLayer["MODEL SERVING LAYER"]
        ModelServers["Model Server Pods<br/>(vLLM / SGLang / Triton)<br/>configurable/TCP<br/>HTTP/HTTPS"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS, SA Token Auth"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP<br/>Bearer Token RBAC"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No Encryption<br/>No Auth"]
    end

    %% External → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / API Key"| Gateway

    %% Gateway → BBR (ext-proc filter chain, BBR first)
    Gateway -->|"gRPC ext-proc/9004<br/>TLS (self-signed)<br/>No Client Auth"| BBR

    %% BBR → Gateway (response)
    BBR -.->|"ext-proc response<br/>model-name headers injected"| Gateway

    %% Gateway → EPP (ext-proc filter chain, EPP second)
    Gateway -->|"gRPC ext-proc/9002<br/>TLS (self-signed/custom)<br/>No Client Auth"| EPP

    %% EPP → Gateway (response)
    EPP -.->|"ext-proc response<br/>target-endpoint header"| Gateway

    %% Gateway → Model Servers
    Gateway -->|"HTTP/gRPC<br/>configurable port<br/>per-gateway config"| ModelServers

    %% EPP → Model Servers (metrics scraping)
    EPP -->|"HTTP(S)/configurable<br/>InsecureSkipVerify=true<br/>No Auth (50ms interval)"| ModelServers

    %% EPP → Kubernetes API
    EPP -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% BBR → Kubernetes API
    BBR -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% EPP → Sidecars
    EPP -.->|"HTTP/8000<br/>No TLS, No Auth"| TrainingServer
    EPP -.->|"HTTP/8001+<br/>No TLS, No Auth"| PredictionServer

    %% Monitoring
    Prometheus -.->|"HTTP/9090<br/>Bearer Token RBAC"| EPP
    Prometheus -.->|"HTTP/9090<br/>Bearer Token RBAC"| BBR
    EPP -.->|"gRPC/4317<br/>No TLS"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef igwservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef modelserver fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clusterservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:1px,stroke-dasharray:5

    class Client external
    class Gateway gateway
    class EPP,BBR igwservice
    class ModelServers modelserver
    class K8sAPI,Prometheus,OTLP clusterservice
    class TrainingServer,PredictionServer optional
