graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Envoy-based Gateway<br/>(Istio / Envoy GW / kgateway)<br/>80/TCP HTTP<br/>Per gateway TLS config"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted - optional Istio mTLS)"]
        direction TB

        subgraph NS_IGW["Namespace: {pool-namespace}"]
            direction TB

            BBR["Body Based Router (BBR)<br/>9004/TCP gRPC ext-proc<br/>9005/TCP gRPC health<br/>9090/TCP HTTP metrics<br/>SA: bbr-{release}<br/>Optional self-signed TLS"]

            EPP["Endpoint Picker (EPP)<br/>9002/TCP gRPC ext-proc<br/>9003/TCP gRPC health<br/>9090/TCP HTTP metrics<br/>SA: {release}-epp<br/>Optional self-signed TLS"]

            TrainingServer["Latency Training Server<br/>8000/TCP HTTP<br/>No TLS / No Auth"]

            PredictionServer["Latency Prediction Server<br/>8001/TCP HTTP<br/>No TLS / No Auth"]

            PV["PersistentVolume<br/>XGBoost Models<br/>Filesystem access"]
        end

        subgraph NS_Models["Namespace: {model-namespace}"]
            ModelServers["Model Server Pods<br/>(vLLM / SGLang / Triton)<br/>8000/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP"]
        OTELCollector["OpenTelemetry Collector<br/>gRPC (configurable port)<br/>Configurable TLS"]
    end

    %% Request flow
    Client -->|"HTTP/80<br/>Per gateway config"| Gateway
    Gateway -->|"gRPC/9004<br/>Optional TLS<br/>No Auth"| BBR
    Gateway -->|"gRPC/9002<br/>Optional TLS<br/>No Auth"| EPP
    Gateway -->|"HTTP/8000<br/>No TLS<br/>No Auth"| ModelServers

    %% EPP interactions
    EPP -->|"HTTP/8000<br/>InsecureSkipVerify=true (default)<br/>No Auth"| ModelServers
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    EPP -->|"HTTP/8000<br/>No TLS / No Auth"| TrainingServer
    EPP -->|"HTTP/8001<br/>No TLS / No Auth"| PredictionServer

    %% BBR interactions
    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Latency predictor
    TrainingServer -->|"Filesystem"| PV
    PredictionServer -->|"Filesystem<br/>or HTTP/8000"| PV

    %% Optional
    Prometheus -.->|"HTTP/9090<br/>No TLS"| EPP
    Prometheus -.->|"HTTP/9090<br/>No TLS"| BBR
    EPP -.->|"gRPC<br/>Configurable"| OTELCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class BBR,EPP,TrainingServer,PredictionServer,PV,ModelServers internal
    class K8sAPI controlplane
    class Prometheus,OTELCollector optional
