graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Envoy-based Gateway<br/>(Envoy GW / Istio / GKE / kgateway)<br/>443/TCP → ext-proc chain<br/>TLS termination<br/>Auth: Gateway-dependent"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_BBR["Namespace: bbr-namespace"]
            BBR["Body Based Router (BBR)<br/>SA: bbr-name-release<br/>9004/TCP gRPC/h2<br/>TLS: self-signed RSA-4096<br/>No client cert verification"]
            BBR_Health["BBR Health<br/>9005/TCP gRPC<br/>No encryption"]
            BBR_Metrics["BBR Metrics<br/>9090/TCP HTTP<br/>Auth: Optional"]
        end

        subgraph NS_Pool["Namespace: pool-namespace"]
            EPP["Endpoint Picker (EPP)<br/>SA: release<br/>9002/TCP gRPC/h2<br/>TLS: self-signed RSA-4096<br/>No client cert verification"]
            EPP_Health["EPP Health<br/>9003/TCP gRPC<br/>No encryption"]
            EPP_Metrics["EPP Metrics<br/>9090/TCP HTTP<br/>Auth: TokenReview + SAR (optional)"]
            EPP_Debug["EPP Debug<br/>9090/TCP /debug/pprof/*<br/>No auth"]

            subgraph LatencySidecar["Latency Prediction Sidecar (Optional)"]
                TrainingSrv["Training Server<br/>8000/TCP HTTP<br/>No encryption, No auth"]
                PredictionSrv["Prediction Server<br/>8001/TCP HTTP<br/>No encryption, No auth"]
                SharedPVC["Shared PVC<br/>Model files"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>Auth: ServiceAccount token"]
        ModelServers["Model Server Pods<br/>(vLLM / sglang / triton)<br/>HTTP/HTTPS Configurable<br/>⚠ InsecureSkipVerify=true default"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No encryption"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Auth: Gateway-dependent"| Gateway

    %% Gateway to ext-proc
    Gateway -->|"gRPC/9004<br/>TLS (self-signed)<br/>No client auth"| BBR
    BBR -->|"Headers: model-name,<br/>base-model"| Gateway
    Gateway -->|"gRPC/9002<br/>TLS (self-signed)<br/>No client auth"| EPP
    EPP -->|"Endpoint selection<br/>+ routing headers"| Gateway
    Gateway -->|"Routed request<br/>HTTP or gRPC"| ModelServers

    %% EPP outbound
    EPP -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    EPP -->|"HTTP(S)/configurable<br/>⚠ InsecureSkipVerify"| ModelServers
    EPP -->|"gRPC/4317<br/>No encryption"| OTLP
    EPP -->|"HTTP/8000<br/>No encryption"| TrainingSrv
    EPP -->|"HTTP/8001<br/>No encryption"| PredictionSrv

    %% BBR outbound
    BBR -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% Latency subsystem internal
    TrainingSrv -->|"Filesystem<br/>Model files"| SharedPVC
    PredictionSrv -->|"Filesystem<br/>Model sync"| SharedPVC

    %% Prometheus scraping
    Prometheus -->|"HTTP/9090<br/>Scrape"| EPP_Metrics
    Prometheus -->|"HTTP/9090<br/>Scrape"| BBR_Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#000
    classDef sidecar fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000

    class Client external
    class Gateway ingress
    class BBR,EPP,BBR_Health,EPP_Health,BBR_Metrics,EPP_Metrics,EPP_Debug internal
    class K8sAPI,OTLP,Prometheus externalservice
    class ModelServers warning
    class TrainingSrv,PredictionSrv,SharedPVC sidecar
