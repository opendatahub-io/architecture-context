graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph Ingress["INGRESS (Platform Auth Boundary)"]
        Proxy["kube-rbac-proxy Sidecar<br/>TLS termination<br/>OAuth/OIDC validation<br/>K8s RBAC AuthZ"]
    end

    subgraph Application["APPLICATION (No Built-in Auth ⚠️)"]
        LS["Llama Stack Server<br/>8321/TCP HTTP<br/>No TLS, No Auth<br/>Python/FastAPI/Uvicorn<br/>Base: AIPCC CPU (RHEL 9.6 UBI)"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS"]
        vLLM["vLLM<br/>configurable port<br/>HTTPS TLS<br/>Bearer: VLLM_API_TOKEN"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer: AWS_BEARER_TOKEN_BEDROCK"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 ADC"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key: AZURE_API_KEY"]
        Watsonx["IBM watsonx<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key: WATSONX_API_KEY"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key: OPENAI_API_KEY"]
    end

    subgraph SafetyEval["SAFETY & EVALUATION (Internal Platform)"]
        FMS["TrustyAI FMS<br/>configurable port<br/>HTTPS TLS (custom cert)<br/>No auth"]
        LMEval["TrustyAI LM-Eval<br/>configurable port<br/>HTTP/HTTPS<br/>No auth"]
        Kubeflow["Kubeflow Pipelines<br/>configurable port<br/>HTTPS TLS 1.2+<br/>Bearer: KUBEFLOW_PIPELINES_TOKEN"]
    end

    subgraph VectorDBs["VECTOR DATABASES"]
        Milvus["Milvus (remote)<br/>configurable port<br/>HTTPS (CA/client certs)<br/>Token: MILVUS_TOKEN"]
        PgVec["PgVector<br/>5432/TCP<br/>PostgreSQL wire<br/>Username/password"]
        Qdrant["Qdrant<br/>6333/TCP REST, 6334/TCP gRPC<br/>HTTPS configurable<br/>API key: QDRANT_API_KEY"]
    end

    subgraph Persistence["PERSISTENCE & STORAGE"]
        PG["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire<br/>plaintext (configurable)<br/>Username/password"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph ToolAPIs["TOOL RUNTIME & EXTERNAL APIs"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public/token"]
        MCP["MCP Servers<br/>configurable<br/>REST/SSE<br/>configurable"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTEL["OTEL Collector<br/>configurable port<br/>OTLP HTTPS<br/>TLS 1.2+<br/>Conditional: OTEL_SERVICE_NAME"]
    end

    %% External to Ingress
    Client -->|"HTTPS (platform TLS)<br/>OAuth/OIDC token"| Proxy

    %% Ingress to Application
    Proxy -->|"HTTP/8321<br/>No encryption (pod-internal)<br/>Pre-authorized"| LS

    %% Application to Inference
    LS -->|"HTTPS<br/>TLS (VLLM_TLS_VERIFY)<br/>Bearer token"| vLLM
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Bedrock
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 ADC"| Vertex
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Azure
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Watsonx
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI

    %% Application to Safety & Eval
    LS -->|"HTTPS<br/>TLS (custom cert)<br/>No auth"| FMS
    LS -->|"HTTP/HTTPS<br/>configurable<br/>No auth"| LMEval
    LS -->|"HTTPS<br/>TLS 1.2+<br/>Bearer token"| Kubeflow

    %% Application to Vector DBs
    LS -->|"HTTPS<br/>TLS (CA/client certs)<br/>Token"| Milvus
    LS -->|"PostgreSQL/5432<br/>plaintext<br/>Username/password"| PgVec
    LS -->|"REST/gRPC<br/>6333-6334/TCP<br/>API key"| Qdrant

    %% Application to Persistence
    LS -->|"PostgreSQL/5432<br/>plaintext (configurable)<br/>Username/password"| PG
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Application to Tools
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Brave
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Tavily
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>Public/token"| HF
    LS -->|"configurable<br/>REST/SSE"| MCP

    %% Application to Observability
    LS -.->|"OTLP HTTPS<br/>TLS 1.2+<br/>No auth<br/>(conditional)"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef persistence fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Client external
    class Proxy ingress
    class LS application
    class vLLM,FMS,LMEval,Kubeflow,Milvus,PgVec,Qdrant platform
    class Bedrock,Vertex,Azure,Watsonx,OpenAI,Brave,Tavily,HF,MCP,S3 externalservice
    class PG persistence
    class OTEL observability
