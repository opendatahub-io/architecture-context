graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / API Consumer"]
    end

    subgraph Ingress["INGRESS (Platform-Managed DMZ)"]
        Gateway["Platform Ingress Layer<br/>kube-rbac-proxy / Gateway API<br/>TLS 1.2+ Termination<br/>AuthN/AuthZ Enforcement"]
    end

    subgraph AppLayer["APPLICATION LAYER (Container)"]
        direction TB

        LlamaStack["Llama Stack Server<br/>8321/TCP HTTP (plaintext)<br/>Python 3.12 / FastAPI / uvicorn<br/>UBI9 (FIPS OpenSSL)<br/>Auth: NONE (app level)"]
    end

    subgraph InferenceZone["INFERENCE BACKENDS (Outbound)"]
        direction LR
        vLLM["vLLM Server<br/>Configurable port<br/>HTTP/HTTPS<br/>Bearer Token"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ADC"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    subgraph StorageZone["STORAGE (Outbound)"]
        direction LR
        PostgreSQL["PostgreSQL 17+<br/>5432/TCP<br/>No encryption (in-cluster)<br/>Username/password"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph VectorZone["VECTOR DATABASES (Outbound)"]
        direction LR
        Milvus["Milvus (remote)<br/>Configurable<br/>HTTP/gRPC<br/>mTLS + Token"]
        PGVector["pgvector<br/>Configurable<br/>PostgreSQL<br/>Username/password"]
        Qdrant["Qdrant<br/>Configurable<br/>HTTP/gRPC<br/>API Key"]
    end

    subgraph EvalZone["EVALUATION & SAFETY (Outbound)"]
        direction LR
        FMS["TrustyAI FMS<br/>Configurable<br/>HTTP/HTTPS<br/>SSL cert"]
        KFP["Kubeflow Pipelines<br/>Configurable<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    subgraph ToolZone["TOOL SERVICES (Outbound)"]
        direction LR
        Brave["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        MCP["MCP Servers<br/>Configurable<br/>HTTP/HTTPS"]
    end

    subgraph ObsZone["OBSERVABILITY (Optional)"]
        OTEL["OTEL Collector<br/>Configurable<br/>HTTP OTLP<br/>No auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"HTTP/8321<br/>Plaintext (in-cluster)<br/>No auth"| LlamaStack

    LlamaStack -->|"HTTP/HTTPS<br/>Bearer Token<br/>(VLLM_API_TOKEN)"| vLLM
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>Google ADC"| VertexAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| AzureOAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WatsonX
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI

    LlamaStack -->|"PostgreSQL/5432<br/>No encryption<br/>Username/password"| PostgreSQL
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    LlamaStack -->|"HTTP/gRPC<br/>mTLS + Token"| Milvus
    LlamaStack -->|"PostgreSQL<br/>Username/password"| PGVector
    LlamaStack -->|"HTTP/gRPC<br/>API Key"| Qdrant

    LlamaStack -->|"HTTP/HTTPS<br/>SSL cert"| FMS
    LlamaStack -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| KFP
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Brave
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Tavily
    LlamaStack -->|"HTTP/HTTPS<br/>Configurable"| MCP

    LlamaStack -.->|"HTTP OTLP<br/>(optional)"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef vector fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef eval fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef tool fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    classDef obs fill:#e8e8e8,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class LlamaStack app
    class vLLM,Bedrock,VertexAI,AzureOAI,WatsonX,OpenAI inference
    class PostgreSQL,S3 storage
    class Milvus,PGVector,Qdrant vector
    class FMS,KFP,K8sAPI eval
    class Brave,Tavily,MCP tool
    class OTEL obs
