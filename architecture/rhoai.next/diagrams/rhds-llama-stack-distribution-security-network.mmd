graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist"]
    end

    subgraph Ingress["PLATFORM INGRESS (DMZ)<br/>Managed by rhods-operator"]
        OAuthProxy["OAuth Proxy / kube-rbac-proxy<br/>TLS Termination<br/>AuthN: OAuth / RBAC"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph LlamaStackNS["Namespace: llama-stack"]
            LSServer["Llama Stack Server<br/>ClusterIP: 8321/TCP<br/>HTTP (plaintext in-cluster)<br/>Python 3.12 / FastAPI / Uvicorn<br/>No direct K8s API access"]
        end

        subgraph InferenceNS["Inference Backends (Internal)"]
            vLLM["vLLM Serving Runtime<br/>8000/TCP HTTP/HTTPS<br/>Auth: Bearer Token"]
            vLLMEmbed["vLLM Embedding Server<br/>configurable port<br/>Auth: Bearer Token"]
        end

        subgraph StorageNS["Storage (Internal)"]
            PostgreSQL["PostgreSQL 17+<br/>5432/TCP PostgreSQL wire<br/>Encryption: plaintext<br/>Auth: Password<br/>Purpose: KV + SQL + logs"]
        end

        subgraph VectorNS["Vector Databases (Optional)"]
            MilvusRemote["Milvus Remote<br/>REST/gRPC<br/>Configurable mTLS<br/>Auth: Token"]
            PgVector["pgvector<br/>5432/TCP PostgreSQL<br/>Auth: Password"]
            Qdrant["Qdrant<br/>6333/TCP REST, 6334/TCP gRPC<br/>Configurable HTTPS<br/>Auth: API Key"]
        end

        subgraph TrustyAINS["TrustyAI Ecosystem"]
            FMS["FMS Orchestrator<br/>HTTP/HTTPS<br/>Configurable SSL<br/>Auth: None"]
            LMEval["LMEval<br/>K8s API (mTLS)<br/>Auth: ServiceAccount"]
            KFP["Kubeflow Pipelines<br/>HTTP<br/>Auth: Bearer Token"]
        end

        subgraph ObsNS["Observability"]
            OTel["OpenTelemetry Collector<br/>4318/TCP HTTP OTLP<br/>Auth: None"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token (12h TTL)"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Google ADC"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: None (public)"]
        BraveSearch["Brave Search API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key"]
        TavilySearch["Tavily Search API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API Key"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth / kube-rbac-proxy"| OAuthProxy

    %% Ingress to Llama Stack
    OAuthProxy -->|"HTTP/8321<br/>plaintext (in-cluster)<br/>Auth delegated"| LSServer

    %% Internal connections
    LSServer -->|"HTTP(S)/8000<br/>Configurable TLS<br/>Bearer Token"| vLLM
    LSServer -->|"HTTP(S)/configurable<br/>Configurable TLS<br/>Bearer Token"| vLLMEmbed
    LSServer -->|"PostgreSQL/5432<br/>plaintext<br/>Password"| PostgreSQL
    LSServer -->|"REST-gRPC/configurable<br/>Configurable mTLS<br/>Token"| MilvusRemote
    LSServer -->|"PostgreSQL/5432<br/>plaintext<br/>Password"| PgVector
    LSServer -->|"REST-gRPC/6333-6334<br/>Configurable HTTPS<br/>API Key"| Qdrant
    LSServer -->|"HTTP(S)/configurable<br/>Configurable SSL<br/>None"| FMS
    LSServer -->|"K8s API<br/>mTLS<br/>ServiceAccount"| LMEval
    LSServer -->|"HTTP/configurable<br/>None<br/>Bearer Token"| KFP
    LSServer -->|"HTTP OTLP/4318<br/>Configurable<br/>None"| OTel

    %% External egress
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WatsonX
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Azure
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Google ADC"| Vertex
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>None"| HuggingFace
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| BraveSearch
    LSServer -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| TavilySearch

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef trustyai fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class OAuthProxy ingress
    class LSServer internal
    class vLLM,vLLMEmbed internal
    class PostgreSQL,PgVector storage
    class MilvusRemote,Qdrant storage
    class FMS,LMEval,KFP trustyai
    class OTel internal
    class Bedrock,WatsonX,Azure,Vertex,OpenAI,S3,HuggingFace,BraveSearch,TavilySearch externalservice
