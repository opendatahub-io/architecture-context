graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB
        LS["Llama Stack Server<br/>ClusterIP: 8321/TCP HTTP<br/>Non-root user<br/>No built-in auth"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS (Egress)"]
        direction TB
        vLLM["vLLM Inference<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Bearer Token"]
        vLLMEmb["vLLM Embedding<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Bearer Token"]
    end

    subgraph CloudProviders["CLOUD INFERENCE PROVIDERS (Egress - TLS 1.2+)"]
        direction TB
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>Bearer Token<br/>(12h auto-rotate)"]
        Watsonx["IBM watsonx<br/>443/TCP HTTPS<br/>API Key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>API Key"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>Google ADC"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>API Key"]
    end

    subgraph VectorDBs["VECTOR DATABASES (Egress)"]
        direction TB
        Milvus["Milvus (remote)<br/>configurable/TCP<br/>HTTP/HTTPS (mTLS)<br/>Token"]
        Pgvector["pgvector<br/>configurable/TCP<br/>PostgreSQL<br/>Username/Password"]
        Qdrant["Qdrant<br/>6333/TCP HTTP, 6334/TCP gRPC<br/>Configurable HTTPS<br/>API Key"]
    end

    subgraph SafetyEval["SAFETY & EVALUATION (Egress)"]
        direction TB
        TrustyAI["TrustyAI FMS<br/>configurable/TCP<br/>HTTPS (custom cert)<br/>No Auth"]
        KFP["Kubeflow Pipelines<br/>configurable/TCP<br/>HTTP/HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ToolServices["TOOL RUNTIMES (Egress - TLS 1.2+)"]
        direction TB
        Brave["Brave Search<br/>443/TCP HTTPS<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>API Key"]
        MCP["MCP Servers<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Configurable"]
    end

    subgraph Persistence["PERSISTENCE & OBSERVABILITY (Egress)"]
        direction TB
        PG["PostgreSQL<br/>5432/TCP<br/>PostgreSQL protocol<br/>Username/Password"]
        OTLP["OTLP Collector<br/>configurable/TCP<br/>HTTP<br/>No Auth"]
    end

    subgraph ExternalData["EXTERNAL DATA SERVICES (Egress - TLS 1.2+)"]
        direction TB
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>None/Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
    end

    %% Flows
    Client -->|"HTTP/8321<br/>No Auth<br/>No built-in encryption"| LS

    LS -->|"HTTP/HTTPS<br/>Bearer Token<br/>TLS configurable"| vLLM
    LS -->|"HTTP/HTTPS<br/>Bearer Token<br/>TLS configurable"| vLLMEmb

    LS -->|"HTTPS/443<br/>Bearer Token<br/>TLS 1.2+"| Bedrock
    LS -->|"HTTPS/443<br/>API Key<br/>TLS 1.2+"| Watsonx
    LS -->|"HTTPS/443<br/>API Key<br/>TLS 1.2+"| Azure
    LS -->|"HTTPS/443<br/>Google ADC<br/>TLS 1.2+"| Vertex
    LS -->|"HTTPS/443<br/>API Key<br/>TLS 1.2+"| OpenAI

    LS -->|"HTTP/HTTPS<br/>Token + mTLS<br/>Configurable"| Milvus
    LS -->|"PostgreSQL<br/>Username/Password<br/>No encryption"| Pgvector
    LS -->|"HTTP/gRPC<br/>API Key<br/>Configurable HTTPS"| Qdrant

    LS -->|"HTTPS<br/>Custom cert<br/>No auth"| TrustyAI
    LS -->|"HTTP/HTTPS<br/>Bearer Token<br/>TLS 1.2+"| KFP

    LS -->|"HTTPS/443<br/>API Key"| Brave
    LS -->|"HTTPS/443<br/>API Key"| Tavily
    LS -->|"HTTP/HTTPS<br/>Configurable"| MCP

    LS -->|"PostgreSQL/5432<br/>Password<br/>No encryption"| PG
    LS -->|"HTTP<br/>No auth<br/>No encryption"| OTLP

    LS -->|"HTTPS/443<br/>None/Token"| HF
    LS -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cloud fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef vector fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef safety fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef tool fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef persist fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class LS app
    class vLLM,vLLMEmb inference
    class Bedrock,Watsonx,Azure,Vertex,OpenAI cloud
    class Milvus,Pgvector,Qdrant vector
    class TrustyAI,KFP safety
    class Brave,Tavily,MCP tool
    class PG,OTLP persist
    class HF,S3 data
