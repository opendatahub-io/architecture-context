graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        PlatformIngress["Platform Ingress<br/>443/TCP → 8321/TCP<br/>TLS 1.2+ termination<br/>kube-rbac-proxy / OAuth"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        LlamaStack["Llama Stack Server<br/>8321/TCP HTTP<br/>Python 3.12 / FastAPI<br/>UBI9 base image<br/>No app-level auth<br/>No K8s API access"]
    end

    subgraph InternalInference["INTERNAL INFERENCE"]
        vLLM["vLLM Inference<br/>8000/TCP HTTP/HTTPS<br/>Bearer Token"]
        vLLMEmbed["vLLM Embedding<br/>configurable port<br/>Bearer Token"]
    end

    subgraph PersistentStorage["PERSISTENT STORAGE"]
        PostgreSQL["PostgreSQL 17+<br/>5432/TCP<br/>plaintext (in-cluster)<br/>Password auth"]
    end

    subgraph CloudInference["CLOUD INFERENCE (External)"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (12h)"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Google ADC"]
        OpenAIAPI["OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
    end

    subgraph VectorDBs["VECTOR DATABASES"]
        MilvusRemote["Milvus Remote<br/>REST/gRPC<br/>Configurable mTLS<br/>Token auth"]
        pgvector["pgvector<br/>5432/TCP<br/>plaintext<br/>Password"]
        Qdrant["Qdrant<br/>6333/6334 TCP<br/>Configurable HTTPS<br/>API Key"]
    end

    subgraph EvalSafety["EVALUATION & SAFETY"]
        FMS["TrustyAI FMS<br/>HTTP/HTTPS<br/>Configurable SSL<br/>No auth"]
        LMEval["TrustyAI LMEval<br/>K8s API<br/>mTLS/SA token"]
        KFP["Kubeflow Pipelines<br/>HTTP<br/>No encryption<br/>Bearer Token"]
    end

    subgraph ExtServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>No auth (public)"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        OTelCollector["OTEL Collector<br/>4318/TCP HTTP OTLP<br/>No auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/kube-rbac-proxy"| PlatformIngress
    PlatformIngress -->|"HTTP/8321<br/>plaintext (in-cluster)<br/>auth already validated"| LlamaStack

    LlamaStack -->|"HTTP(S)/8000<br/>configurable TLS<br/>Bearer Token"| vLLM
    LlamaStack -->|"HTTP(S)<br/>configurable TLS<br/>Bearer Token"| vLLMEmbed
    LlamaStack -->|"PostgreSQL/5432<br/>plaintext<br/>Password"| PostgreSQL

    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| Bedrock
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| WatsonX
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| Azure
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| Vertex
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| OpenAIAPI

    LlamaStack -->|"REST/gRPC<br/>mTLS configurable"| MilvusRemote
    LlamaStack -->|"PostgreSQL/5432<br/>plaintext"| pgvector
    LlamaStack -->|"REST/gRPC<br/>6333-6334"| Qdrant

    LlamaStack -->|"HTTP(S)<br/>configurable SSL"| FMS
    LlamaStack -->|"K8s API<br/>mTLS"| LMEval
    LlamaStack -->|"HTTP<br/>Bearer Token"| KFP

    LlamaStack -->|"HTTPS/443<br/>AWS IAM"| S3
    LlamaStack -->|"HTTPS/443"| HuggingFace
    LlamaStack -->|"HTTPS/443<br/>API Key"| BraveSearch
    LlamaStack -->|"HTTPS/443<br/>API Key"| Tavily
    LlamaStack -.->|"HTTP/4318<br/>OTLP"| OTelCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cloud fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef eval fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class PlatformIngress ingress
    class LlamaStack app
    class vLLM,vLLMEmbed internal
    class PostgreSQL storage
    class Bedrock,WatsonX,Azure,Vertex,OpenAIAPI cloud
    class MilvusRemote,pgvector,Qdrant storage
    class FMS,LMEval,KFP eval
    class S3,HuggingFace,BraveSearch,Tavily,OTelCollector extservice
