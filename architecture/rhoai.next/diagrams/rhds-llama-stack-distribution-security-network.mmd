graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AppLayer["APPLICATION LAYER (No Auth at Application Level)"]
        direction TB
        LlamaStack["Llama Stack Server<br/>Port: 8321/TCP<br/>Protocol: HTTP (plaintext)<br/>Auth: NONE<br/>⚠️ No application-level auth<br/>Relies on platform ingress"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS (External Services)"]
        direction TB
        vLLM["vLLM Inference Server<br/>8000/TCP (configurable)<br/>HTTP/HTTPS<br/>TLS: Configurable (VLLM_TLS_VERIFY)<br/>Auth: API token"]
        vLLMEmbed["vLLM Embedding Server<br/>configurable port<br/>HTTP/HTTPS<br/>TLS: Configurable<br/>Auth: API token"]
    end

    subgraph CloudProviders["CLOUD INFERENCE PROVIDERS (External, TLS 1.2+)"]
        direction TB
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer token"]
        Watsonx["IBM Watsonx<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        AzureAI["Azure AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: OAuth2 ADC"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
    end

    subgraph DataStores["DATA STORES"]
        direction TB
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>Encryption: NONE<br/>Auth: Username/password<br/>⚠️ Plaintext connection"]
        MilvusRemote["Milvus (remote)<br/>configurable port<br/>gRPC/HTTP<br/>TLS: CA + client certs<br/>Auth: Token"]
        PgVector["pgvector<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>Encryption: NONE<br/>Auth: Username/password"]
        Qdrant["Qdrant<br/>6333/TCP (HTTP), 6334/TCP (gRPC)<br/>HTTPS (configurable)<br/>Auth: API key"]
    end

    subgraph SafetyServices["SAFETY & EVALUATION SERVICES"]
        direction TB
        TrustyAI["TrustyAI FMS Orchestrator<br/>configurable port<br/>HTTPS<br/>TLS: Custom cert (FMS_SSL_CERT_PATH)<br/>Auth: None"]
        Kubeflow["Kubeflow Pipelines<br/>configurable port<br/>HTTPS TLS 1.2+<br/>Auth: API token"]
    end

    subgraph ExternalAPIs["EXTERNAL APIs (TLS 1.2+)"]
        direction TB
        S3["S3 / S3-compatible<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None/HF token"]
        BraveSearch["Brave Search API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        TavilySearch["Tavily Search API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        OTelCollector["OpenTelemetry Collector<br/>configurable<br/>HTTP (OTLP)<br/>Auth: None"]
        MCPServers["MCP Servers<br/>configurable<br/>HTTP (configurable)<br/>Auth: Configurable"]
    end

    %% Client to Application
    Client -->|"HTTP/8321<br/>PLAINTEXT<br/>No Auth ⚠️"| LlamaStack

    %% Application to Inference
    LlamaStack -->|"HTTP(S)/8000<br/>TLS configurable<br/>API token"| vLLM
    LlamaStack -->|"HTTP(S)/configurable<br/>TLS configurable<br/>API token"| vLLMEmbed

    %% Application to Cloud Providers
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Bedrock
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Watsonx
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| AzureAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2"| VertexAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI

    %% Application to Data Stores
    LlamaStack -->|"PostgreSQL/5432<br/>PLAINTEXT ⚠️<br/>Username/password"| PostgreSQL
    LlamaStack -->|"gRPC-HTTP/configurable<br/>TLS (CA + client certs)<br/>Token"| MilvusRemote
    LlamaStack -->|"PostgreSQL/5432<br/>PLAINTEXT ⚠️<br/>Username/password"| PgVector
    LlamaStack -->|"HTTP-gRPC/6333-6334<br/>HTTPS configurable<br/>API key"| Qdrant

    %% Application to Safety/Eval
    LlamaStack -->|"HTTPS/configurable<br/>TLS (custom cert)<br/>None"| TrustyAI
    LlamaStack -->|"HTTPS/configurable<br/>TLS 1.2+<br/>API token"| Kubeflow

    %% Application to External APIs
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>None/HF token"| HFHub
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| BraveSearch
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| TavilySearch
    LlamaStack -->|"HTTP/configurable<br/>OTLP<br/>None"| OTelCollector
    LlamaStack -->|"HTTP/configurable<br/>MCP protocol<br/>Configurable"| MCPServers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef app fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef inference fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cloud fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datastore fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef safety fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extapi fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class LlamaStack app
    class vLLM,vLLMEmbed inference
    class Bedrock,Watsonx,AzureAI,VertexAI,OpenAI cloud
    class PostgreSQL,MilvusRemote,PgVector,Qdrant datastore
    class TrustyAI,Kubeflow safety
    class S3,HFHub,BraveSearch,TavilySearch,OTelCollector,MCPServers extapi
