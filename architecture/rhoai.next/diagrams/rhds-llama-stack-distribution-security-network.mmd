graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Application["APPLICATION (No Built-in Auth)"]
        direction TB
        Server["Llama Stack Server<br/>8321/TCP HTTP<br/>UBI9 / Python 3.12<br/>⚠️ No application-level auth"]
    end

    subgraph InferenceBackends["INFERENCE BACKENDS (Cloud APIs)"]
        direction LR
        vLLM["vLLM Server<br/>Configurable port<br/>HTTP/HTTPS<br/>Bearer Token"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ADC"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        OpenAIAPI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    subgraph Storage["STORAGE & DATABASES"]
        direction LR
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>No encryption (in-cluster)<br/>Username/password<br/>⚠️ Single point of failure"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph VectorDBs["VECTOR DATABASES"]
        direction LR
        MilvusRemote["Milvus Remote<br/>Configurable<br/>HTTP/gRPC<br/>mTLS + Token"]
        PgVector["pgvector<br/>Configurable<br/>PostgreSQL<br/>Username/password"]
        QdrantRemote["Qdrant<br/>Configurable<br/>HTTP/gRPC<br/>API Key"]
    end

    subgraph SafetyEval["SAFETY & EVALUATION"]
        direction LR
        FMS["TrustyAI FMS<br/>Configurable<br/>HTTP/HTTPS<br/>SSL Cert"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        KFP["Kubeflow Pipelines<br/>Configurable<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ToolAPIs["TOOL RUNTIMES & EXTERNAL APIS"]
        direction LR
        BraveAPI["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        TavilyAPI["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>None"]
        MCPServers["MCP Servers<br/>Configurable<br/>HTTP/HTTPS<br/>Configurable"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTEL["OTEL Collector<br/>Configurable<br/>HTTP OTLP<br/>None"]
    end

    %% Flows
    Client -->|"HTTP/8321<br/>No encryption<br/>No app auth<br/>⚠️ Platform ingress required"| Server

    Server -->|"HTTP/HTTPS<br/>Configurable TLS<br/>Bearer Token"| vLLM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| VertexAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| AzureOAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WatsonX
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAIAPI

    Server -->|"PostgreSQL/5432<br/>No encryption<br/>Password"| PostgreSQL
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    Server -->|"HTTP/gRPC<br/>Configurable mTLS<br/>Token"| MilvusRemote
    Server -->|"PostgreSQL<br/>No encryption<br/>Password"| PgVector
    Server -->|"HTTP/gRPC<br/>Configurable HTTPS<br/>API Key"| QdrantRemote

    Server -->|"HTTP/HTTPS<br/>SSL Cert<br/>None"| FMS
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Server -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| KFP

    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| BraveAPI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| TavilyAPI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>None"| HFHub
    Server -->|"HTTP/HTTPS<br/>Configurable"| MCPServers

    Server -.->|"HTTP OTLP<br/>Conditional<br/>(OTEL_SERVICE_NAME)"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef application fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef cloud fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#e8eaf6,stroke:#3949ab,stroke-width:2px
    classDef vectordb fill:#e0f7fa,stroke:#00838f,stroke-width:2px
    classDef safety fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef tools fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef observability fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px

    class Client external
    class Server application
    class vLLM,Bedrock,VertexAI,AzureOAI,WatsonX,OpenAIAPI cloud
    class PostgreSQL,S3 storage
    class MilvusRemote,PgVector,QdrantRemote vectordb
    class FMS,K8sAPI,KFP safety
    class BraveAPI,TavilyAPI,HFHub,MCPServers tools
    class OTEL observability
