graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress / Gateway<br/>443/TCP → 8321/TCP<br/>TLS 1.2+ Termination<br/>AuthN: kube-rbac-proxy / Gateway API"]
    end

    subgraph Application["APPLICATION (No App-Level Auth)"]
        LS["Llama Stack Server<br/>8321/TCP HTTP (plaintext)<br/>FastAPI + uvicorn<br/>Auth: NONE at app layer<br/>All /v1/* unauthenticated"]
    end

    subgraph InternalPlatform["INTERNAL PLATFORM SERVICES"]
        direction TB

        vLLM["vLLM Server<br/>Configurable port<br/>HTTP/HTTPS<br/>Bearer Token (VLLM_API_TOKEN)<br/>TLS: VLLM_TLS_VERIFY"]

        PG["PostgreSQL 17+<br/>5432/TCP<br/>PostgreSQL protocol<br/>Username/password<br/>Encryption: None"]

        FMS["TrustyAI FMS Orchestrator<br/>Configurable port<br/>HTTP/HTTPS<br/>TLS: FMS_SSL_CERT_PATH<br/>Auth: None"]

        LMEval["TrustyAI LMEval<br/>Configurable port<br/>HTTP<br/>Auth: None"]

        KFP["Kubeflow Pipelines<br/>Configurable port<br/>HTTPS/TLS 1.2+<br/>Bearer Token"]

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph VectorDBs["VECTOR DATABASES"]
        direction TB
        Milvus["Milvus (remote)<br/>Configurable port<br/>HTTP/HTTPS/gRPC<br/>mTLS (client certs)<br/>Token auth"]
        PGVector["pgvector<br/>Configurable port<br/>PostgreSQL<br/>No encryption<br/>Username/password"]
        Qdrant["Qdrant<br/>Configurable port<br/>HTTP/HTTPS/gRPC<br/>API Key"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (HTTPS/TLS 1.2+)"]
        direction TB
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>Bearer Token<br/>(12h TTL auto-rotate)"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>ADC"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>API Key"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS<br/>API Key"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>API Key"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>No auth"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>API Key"]
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        OTEL["OTEL Collector<br/>Configurable port<br/>HTTP (OTLP)<br/>No auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"HTTP/8321<br/>Plaintext<br/>No Auth"| LS

    LS -->|"HTTP(S)<br/>Bearer Token<br/>TLS configurable"| vLLM
    LS -->|"PostgreSQL/5432<br/>No encryption<br/>Password"| PG
    LS -->|"HTTP(S)<br/>TLS configurable"| FMS
    LS -->|"HTTP<br/>No encryption"| LMEval
    LS -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| KFP
    LS -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    LS -->|"HTTP(S)/gRPC<br/>mTLS<br/>Token"| Milvus
    LS -->|"PostgreSQL<br/>Password"| PGVector
    LS -->|"HTTP(S)/gRPC<br/>API Key"| Qdrant

    LS -->|"HTTPS/443<br/>Bearer Token"| Bedrock
    LS -->|"HTTPS/443<br/>ADC"| Vertex
    LS -->|"HTTPS/443<br/>API Key"| Azure
    LS -->|"HTTPS/443<br/>API Key"| WatsonX
    LS -->|"HTTPS/443<br/>API Key"| OpenAI
    LS -->|"HTTPS/443<br/>AWS IAM"| S3
    LS -->|"HTTPS/443"| HF
    LS -->|"HTTPS/443<br/>API Key"| Brave
    LS -->|"HTTPS/443<br/>API Key"| Tavily

    LS -.->|"HTTP (OTLP)<br/>Optional"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef internalservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef vectordb fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class LS application
    class vLLM,PG,FMS,LMEval,KFP,K8sAPI internalservice
    class Milvus,PGVector,Qdrant vectordb
    class Bedrock,Vertex,Azure,WatsonX,OpenAI,S3,HF,Brave,Tavily externalservice
    class OTEL observability
