graph TB
    subgraph "odh-cli (kubectl-odh / rhai-cli)"
        direction TB

        subgraph "Command Layer (Cobra)"
            LintCmd[lint command<br/>37 diagnostic checks]
            BackupCmd[backup command<br/>concurrent pipeline]
            GetCmd[get command<br/>resource listing]
            DepsCmd[deps command<br/>dependency checking]
            ComponentsCmd[components command<br/>health & management]
            MigrateCmd[migrate command<br/>prepare / run phases]
            VersionCmd[version command]
        end

        subgraph "Core Framework"
            CmdInterface["Command Interface<br/>AddFlags → Complete → Validate → Run"]
            Envelope["Output Envelope<br/>cli.opendatahub.io/v1"]
            Printer["Printer (table / JSON / YAML)"]
        end

        subgraph "Lint Engine"
            CheckRegistry["Check Registry<br/>37 checks, 5 groups"]
            Executor["Check Executor<br/>sequential, deterministic"]
            Validators["Fluent Validators<br/>Component / Workload / Operator"]
            DiagResult["DiagnosticResult<br/>multi-condition, impact levels"]
        end

        subgraph "Backup Pipeline"
            Discovery["Discovery Stage"]
            Resolver["Dependency Resolver<br/>Notebook / DSPA resolvers"]
            Writer["Resource Writer<br/>YAML to filesystem"]
        end

        subgraph "Migration Framework"
            ActionRegistry["Action Registry"]
            PreparePhase["Prepare Phase<br/>backup resources"]
            RunPhase["Run Phase<br/>install, patch, verify"]
            StepRecorder["Step Recorder<br/>tree-structured progress"]
        end

        subgraph "Infrastructure"
            ClientWrapper["K8s Client Wrapper<br/>QPS=50, Burst=100"]
            ResourceTypes["Resource Type Registry<br/>40+ GVK/GVR definitions"]
            VersionDetector["Version Detector<br/>DSC / DSCI / CSV sources"]
            OLMReader["OLM Reader<br/>nil-safe degradation"]
        end

        LintCmd --> Executor
        Executor --> CheckRegistry
        Executor --> Validators
        Validators --> DiagResult
        BackupCmd --> Discovery
        Discovery --> Resolver
        Resolver --> Writer
        MigrateCmd --> ActionRegistry
        ActionRegistry --> PreparePhase
        ActionRegistry --> RunPhase
        RunPhase --> StepRecorder

        CmdInterface --> LintCmd
        CmdInterface --> BackupCmd
        CmdInterface --> GetCmd
        CmdInterface --> DepsCmd
        CmdInterface --> ComponentsCmd
        CmdInterface --> MigrateCmd

        Envelope --> Printer

        ClientWrapper --> ResourceTypes
        ClientWrapper --> OLMReader
        LintCmd --> ClientWrapper
        BackupCmd --> ClientWrapper
        GetCmd --> ClientWrapper
        DepsCmd --> ClientWrapper
        ComponentsCmd --> ClientWrapper
        MigrateCmd --> ClientWrapper
        ComponentsCmd --> VersionDetector
        LintCmd --> VersionDetector
    end

    User[Platform Administrator] -->|kubectl odh ...| CmdInterface

    subgraph "Kubernetes Cluster"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        DSC[DataScienceCluster CR]
        DSCI[DSCInitialization CR]
        WorkloadCRs["Workload CRs<br/>Notebooks, ISVCs, RayClusters,<br/>PyTorchJobs, DSPAs, etc."]
        OLMResources["OLM Resources<br/>Subscriptions, CSVs,<br/>PackageManifests"]
        ComponentCRs["Component CRs<br/>platform.opendatahub.io"]
    end

    ClientWrapper -->|"HTTPS/6443<br/>Bearer Token<br/>TLS 1.2+"| K8sAPI
    K8sAPI --- DSC
    K8sAPI --- DSCI
    K8sAPI --- WorkloadCRs
    K8sAPI --- OLMResources
    K8sAPI --- ComponentCRs

    GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS"] -.->|"optional --refresh"| DepsCmd

