graph TB
    subgraph CLI["odh-cli (rhai-cli / kubectl-odh)"]
        direction TB

        subgraph Commands["Command Layer (Cobra)"]
            LintCmd["lint<br/>37 upgrade readiness checks"]
            GetCmd["get<br/>ODH/RHOAI resource queries"]
            BackupCmd["backup<br/>Workload backup with deps"]
            ComponentsCmd["components<br/>Lifecycle management"]
            DepsCmd["deps<br/>Dependency status"]
            MigrateCmd["migrate<br/>list / prepare / run"]
            VersionCmd["version"]
        end

        subgraph Framework["Core Framework"]
            CheckRegistry["CheckRegistry<br/>37 checks, 5 groups"]
            ActionRegistry["ActionRegistry<br/>Migration actions"]
            DepResolverRegistry["DependencyResolverRegistry<br/>Backup resolvers"]
            VersionDetector["VersionDetector<br/>DSC/DSCI/CSV sources"]
        end

        subgraph Validation["Lint Check Groups"]
            DepChecks["Dependency Checks<br/>cert-manager, OpenShift,<br/>Service Mesh"]
            PlatformChecks["Platform Checks<br/>DSC readiness,<br/>DSCI readiness"]
            ComponentChecks["Component Checks<br/>KServe, Kueue, Dashboard,<br/>ModelMesh, Ray, Training"]
            WorkloadChecks["Workload Checks<br/>Notebooks, ISVC, Kueue,<br/>Ray, DSPA, Guardrails,<br/>LlamaStack"]
        end

        subgraph Client["Kubernetes Client Layer"]
            Reader["Reader Interface<br/>QPS: 50, Burst: 100"]
            Writer["Writer Interface<br/>Patch, Create"]
            OLMReader["OLM Reader<br/>nil-safe degradation"]
        end

        LintCmd --> CheckRegistry
        BackupCmd --> DepResolverRegistry
        MigrateCmd --> ActionRegistry
        GetCmd --> Reader
        ComponentsCmd --> Reader
        ComponentsCmd --> Writer
        DepsCmd --> OLMReader

        CheckRegistry --> DepChecks
        CheckRegistry --> PlatformChecks
        CheckRegistry --> ComponentChecks
        CheckRegistry --> WorkloadChecks

        DepChecks --> Reader
        PlatformChecks --> Reader
        ComponentChecks --> Reader
        WorkloadChecks --> Reader
    end

    subgraph Bundled["Bundled Tools (Container Image)"]
        YQ["yq (vendored)<br/>YAML processor<br/>FIPS-compliant"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Shell/Python scripts<br/>ray_cluster_migration.py"]
        OC["oc / kubectl<br/>from ose-cli-rhel9"]
    end

    subgraph K8sResources["Kubernetes Resources (Read)"]
        DSC["DataScienceCluster"]
        DSCI["DSCInitialization"]
        OLMSubs["OLM Subscriptions/CSVs"]
        WorkloadCRDs["Workload CRDs<br/>Notebooks, ISVC,<br/>RayCluster, PyTorchJob,<br/>DSPA, ClusterQueue"]
        ComponentCRs["Component CRs<br/>13 types"]
        CoreResources["Core Resources<br/>ConfigMaps, Secrets,<br/>PVCs, Namespaces"]
    end

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]

    Reader -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    Writer -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    OLMReader -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI

    K8sAPI --> DSC
    K8sAPI --> DSCI
    K8sAPI --> OLMSubs
    K8sAPI --> WorkloadCRDs
    K8sAPI --> ComponentCRs
    K8sAPI --> CoreResources

    GitHub["odh-gitops<br/>GitHub (443/TCP)"]
    DepsCmd -->|"HTTPS/443<br/>--refresh mode"| GitHub

    LocalFS["Local Filesystem"]
    BackupCmd -->|"Write YAML"| LocalFS

    style CLI fill:#4a90e2,stroke:#333,color:#fff
    style Commands fill:#5ba3f5,stroke:#333,color:#fff
    style Framework fill:#5ba3f5,stroke:#333,color:#fff
    style Validation fill:#5ba3f5,stroke:#333,color:#fff
    style Client fill:#5ba3f5,stroke:#333,color:#fff
    style Bundled fill:#7ed321,stroke:#333,color:#fff
    style K8sResources fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style GitHub fill:#e8e8e8,stroke:#333
    style LocalFS fill:#e8e8e8,stroke:#333
