graph TB
    subgraph CLI["odh-cli (rhai-cli / kubectl-odh)"]
        direction TB

        subgraph Commands["Command Layer (cmd/)"]
            LintCmd[lint]
            StatusCmd[status]
            GetCmd[get]
            ComponentsCmd[components]
            DepsCmd[deps]
            LogsCmd[logs]
            BackupCmd[backup]
            MigrateCmd[migrate]
            VersionCmd[version]
        end

        subgraph Core["Core Libraries (pkg/)"]
            LintEngine["Lint Engine<br/>37 checks / 5 groups"]
            StatusEngine["Status Engine<br/>clusterhealth integration"]
            ComponentMgr["Component Manager<br/>discovery + health"]
            DepsMgr["Dependency Manager<br/>odh-gitops manifests"]
            MigrateFramework["Migration Framework<br/>2-phase actions"]
            BackupEngine["Backup Engine<br/>resource serialization"]
            LogStreamer["Log Streamer<br/>multi-container"]
        end

        subgraph Utilities["Shared Utilities (pkg/util/)"]
            K8sClient["K8s Client<br/>Reader/Writer split"]
            OLMReader["OLM Reader<br/>CSV + Subscription"]
            VersionDetector["Version Detector<br/>RHOAI + OCP"]
            Discovery["API Discovery<br/>CRD detection"]
            ErrorHandler["Error Handler<br/>6-level exit codes"]
        end

        subgraph Output["Output Layer"]
            TablePrinter["Table Printer"]
            JSONOutput["JSON/YAML Output"]
            Envelope["Output Envelope"]
            SchemaGen["JSON Schema"]
        end
    end

    subgraph Bundled["Bundled Tools (Container Image)"]
        YQ["yq<br/>YAML/JSON processor<br/>FIPS-compliant"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Shell scripts"]
        PythonHelpers["Python helpers<br/>ray_cluster_migration.py"]
    end

    %% Command to Core connections
    LintCmd --> LintEngine
    StatusCmd --> StatusEngine
    GetCmd --> K8sClient
    ComponentsCmd --> ComponentMgr
    DepsCmd --> DepsMgr
    LogsCmd --> LogStreamer
    BackupCmd --> BackupEngine
    MigrateCmd --> MigrateFramework

    %% Core to Utilities connections
    LintEngine --> K8sClient
    LintEngine --> Discovery
    LintEngine --> VersionDetector
    StatusEngine --> K8sClient
    StatusEngine --> OLMReader
    ComponentMgr --> K8sClient
    ComponentMgr --> Discovery
    DepsMgr --> OLMReader
    MigrateFramework --> K8sClient
    BackupEngine --> K8sClient
    LogStreamer --> K8sClient

    %% Core to Output
    LintEngine --> TablePrinter
    LintEngine --> Envelope
    StatusEngine --> TablePrinter
    ComponentMgr --> TablePrinter
    GetCmd --> JSONOutput

    %% External targets
    K8sClient -->|"HTTPS/6443<br/>TLS 1.2+"| K8sAPI["Kubernetes API Server"]
    DepsMgr -->|"HTTPS/443<br/>TLS 1.2+"| GitHub["GitHub<br/>odh-gitops manifests"]

    %% K8s API to CRDs
    K8sAPI --> DSC["DataScienceCluster CR"]
    K8sAPI --> DSCI["DSCInitialization CR"]
    K8sAPI --> OLM["OLM<br/>Subscriptions / CSVs"]
    K8sAPI --> WorkloadCRDs["Workload CRDs<br/>Notebooks, InferenceServices,<br/>RayClusters, PyTorchJobs"]

    %% Styling
    style CLI fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Commands fill:#bbdefb,stroke:#1565c0
    style Core fill:#c8e6c9,stroke:#2e7d32
    style Utilities fill:#fff9c4,stroke:#f9a825
    style Output fill:#f3e5f5,stroke:#7b1fa2
    style Bundled fill:#fff3e0,stroke:#e65100
    style K8sAPI fill:#ef9a9a,stroke:#c62828
    style GitHub fill:#ef9a9a,stroke:#c62828
    style DSC fill:#ffcc80,stroke:#e65100
    style DSCI fill:#ffcc80,stroke:#e65100
    style OLM fill:#ffcc80,stroke:#e65100
    style WorkloadCRDs fill:#ffcc80,stroke:#e65100
