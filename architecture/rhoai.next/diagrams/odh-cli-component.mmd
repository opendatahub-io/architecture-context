graph TB
    subgraph CLI["odh-cli (rhai-cli / kubectl-odh)"]
        direction TB

        subgraph Commands["Command Layer"]
            StatusCmd["status<br/>Platform Health"]
            GetCmd["get<br/>Resource Listing"]
            ComponentsCmd["components<br/>Component State"]
            DepsCmd["deps<br/>Dependency Graph"]
            EventsCmd["events<br/>Event Monitor"]
            LogsCmd["logs<br/>Log Viewer"]
            BackupCmd["backup<br/>Workload Backup"]
            LintCmd["lint<br/>Upgrade Readiness"]
            MigrateCmd["migrate<br/>Version Migration"]
            VersionCmd["version<br/>CLI Version"]
        end

        subgraph Engines["Core Engines"]
            LintEngine["Lint Engine<br/>38 checks / 5 groups<br/>(dependency, service,<br/>platform, component,<br/>workload)"]
            MigrateEngine["Migrate Engine<br/>19 actions<br/>(prepare + run phases)"]
            BackupPipeline["Backup Pipeline<br/>Dependency resolver<br/>Field stripping<br/>Parallel writer"]
        end

        subgraph Libraries["Library Layer"]
            K8sClient["K8s Client Layer<br/>Reader/Writer separation<br/>OLM integration<br/>Discovery & RBAC check"]
            OutputSystem["Output System<br/>Table / JSON / YAML<br/>cli.opendatahub.io/v1<br/>JSON Schema gen"]
            ResourceTypes["Resource Types<br/>40+ types<br/>15+ API groups"]
            EmbeddedDeps["Embedded Deps<br/>odh-gitops manifest<br/>(go:embed)"]
        end
    end

    %% Command → Engine connections
    LintCmd -->|invokes| LintEngine
    MigrateCmd -->|invokes| MigrateEngine
    BackupCmd -->|invokes| BackupPipeline

    %% Engine → Library connections
    LintEngine -->|read-only| K8sClient
    MigrateEngine -->|read+write| K8sClient
    BackupPipeline -->|read-only| K8sClient
    StatusCmd -->|read-only| K8sClient
    GetCmd -->|read-only| K8sClient
    ComponentsCmd -->|read-only| K8sClient
    DepsCmd -->|uses| EmbeddedDeps
    EventsCmd -->|read-only| K8sClient

    LintEngine -->|renders| OutputSystem
    MigrateEngine -->|renders| OutputSystem
    BackupPipeline -->|renders| OutputSystem
    K8sClient -->|uses| ResourceTypes

    %% External interactions
    K8sClient -->|6443/TCP HTTPS| K8sAPI["Kubernetes API Server"]
    K8sClient -->|6443/TCP HTTPS| OLMAPI["OLM API"]
    K8sClient -->|6443/TCP HTTPS| OpenShiftAPI["OpenShift API"]
    MigrateEngine -->|443/TCP HTTPS| TrustyAI["TrustyAI Service Route"]

    OutputSystem -->|stdout| User["User / Automation"]
    BackupPipeline -->|file I/O| Filesystem["Local Filesystem"]

    %% Styling
    style CLI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Commands fill:#dbeafe,stroke:#3b82f6
    style Engines fill:#fef3c7,stroke:#f59e0b
    style Libraries fill:#d1fae5,stroke:#10b981
    style LintEngine fill:#fbbf24
    style MigrateEngine fill:#fbbf24
    style BackupPipeline fill:#fbbf24
    style K8sClient fill:#34d399
    style OutputSystem fill:#34d399
    style ResourceTypes fill:#34d399
    style EmbeddedDeps fill:#34d399
    style K8sAPI fill:#e5e7eb,stroke:#6b7280
    style OLMAPI fill:#e5e7eb,stroke:#6b7280
    style OpenShiftAPI fill:#e5e7eb,stroke:#6b7280
    style TrustyAI fill:#e5e7eb,stroke:#6b7280
    style User fill:#f9fafb,stroke:#9ca3af
    style Filesystem fill:#f9fafb,stroke:#9ca3af
