graph TB
    subgraph CLI["odh-cli (kubectl-odh / rhai-cli)"]
        direction TB

        subgraph CoreCLI["Core CLI Framework"]
            Main["main.go<br/>Cobra Root Command"]
            CmdIface["pkg/cmd.Command Interface<br/>AddFlags → Complete → Validate → Run"]
            Printer["pkg/printer<br/>Table | JSON | YAML"]
            Envelope["pkg/output/envelope<br/>cli.opendatahub.io/v1"]
            Client["pkg/util/client<br/>QPS=50, Burst=100<br/>Reader/Writer split"]
            ResourceTypes["pkg/resources/types.go<br/>40+ GVK/GVR definitions"]
        end

        subgraph Commands["Command Modules"]
            Lint["cmd/lint<br/>Upgrade Readiness<br/>37 checks, 5 groups"]
            Backup["cmd/backup<br/>Workload Backup<br/>Concurrent pipeline"]
            Get["cmd/get<br/>Resource Listing"]
            Deps["cmd/deps<br/>Dependency Check"]
            Components["cmd/components<br/>Component Health"]
            Migrate["cmd/migrate<br/>Kueue → RHBOK<br/>Two-phase execution"]
            Version["cmd/version<br/>Version Info"]
        end

        subgraph LintFramework["Lint Check Framework"]
            CheckRegistry["check/registry.go<br/>37 registered checks"]
            Executor["check/executor.go<br/>Sequential execution"]
            Validators["validate/*<br/>Fluent builder APIs<br/>Component, Workload,<br/>Operator, DSC, DSCI"]
            DiagResult["check/result<br/>DiagnosticResult<br/>Multi-condition status"]
        end

        subgraph BackupPipeline["Backup Pipeline"]
            Discovery["pipeline/discovery<br/>Workload discovery"]
            Resolver["pipeline/resolver<br/>Dependency resolution"]
            Writer["pipeline/writer<br/>YAML file output"]
            NBResolver["dependencies/notebooks<br/>ConfigMap, Secret, PVC"]
            DSPAResolver["dependencies/dspa<br/>9 JQ paths"]
        end

        subgraph MigrateFramework["Migration Framework"]
            ActionRegistry["action/registry<br/>Migration registry"]
            ActionExecutor["action/executor<br/>Action execution"]
            StepRecorder["action/recorder<br/>Progress tracking"]
            RHBOKAction["actions/kueue/rhbok<br/>Prepare + Run phases"]
        end

        subgraph Utilities["Shared Utilities"]
            VersionDetector["util/version<br/>DSC/DSCI/CSV detection"]
            KubeHelpers["util/kube<br/>Annotations, Dependencies"]
            OLMInstaller["util/kube/olm<br/>Subscription management"]
            DiscoveryUtil["util/kube/discovery<br/>API group detection"]
        end
    end

    subgraph ContainerImage["Container Image (quay.io/rhoai/rhoai-upgrade-helpers-rhel9)"]
        YQ["yq (FIPS build)<br/>YAML processing"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Python/Shell scripts"]
        KubectlOC["kubectl + oc<br/>CLI tools"]
    end

    subgraph BuildSystem["Build System"]
        Tekton["Tekton PipelineRuns<br/>Hermetic multi-arch builds"]
        GoReleaser[".goreleaser.yml<br/>Standalone binary releases"]
        Konflux["Konflux<br/>FIPS: CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime"]
    end

    %% Internal connections
    Main --> CmdIface
    CmdIface --> Lint
    CmdIface --> Backup
    CmdIface --> Get
    CmdIface --> Deps
    CmdIface --> Components
    CmdIface --> Migrate
    CmdIface --> Version

    Lint --> CheckRegistry
    CheckRegistry --> Executor
    Executor --> Validators
    Validators --> DiagResult

    Backup --> Discovery
    Discovery --> Resolver
    Resolver --> Writer
    Resolver --> NBResolver
    Resolver --> DSPAResolver

    Migrate --> ActionRegistry
    ActionRegistry --> ActionExecutor
    ActionExecutor --> StepRecorder
    ActionExecutor --> RHBOKAction

    %% Shared dependencies
    Lint --> Client
    Backup --> Client
    Get --> Client
    Deps --> Client
    Components --> Client
    Migrate --> Client

    Lint --> Printer
    Backup --> Printer
    Get --> Printer
    Deps --> Printer
    Components --> Printer

    Client --> ResourceTypes

    %% External connections
    User[Platform Admin] -->|kubectl odh| Main
    Client -->|HTTPS/6443<br/>TLS 1.2+| K8sAPI["Kubernetes API<br/>+ OpenShift API"]
    Deps -->|HTTPS/443<br/>Optional --refresh| GitHub["raw.githubusercontent.com<br/>odh-gitops manifests"]

