graph TB
    subgraph CLI["odh-cli (kubectl-odh / rhai-cli)"]
        direction TB

        subgraph CmdLayer["Command Layer (Cobra)"]
            LintCmd[lint<br/>Upgrade Readiness]
            BackupCmd[backup<br/>Workload Backup]
            GetCmd[get<br/>Resource Listing]
            DepsCmd[deps<br/>Dependency Check]
            ComponentsCmd[components<br/>Component Mgmt]
            MigrateCmd[migrate<br/>Automated Migration]
            VersionCmd[version<br/>CLI Version]
        end

        subgraph LintEngine["Lint Framework (37 Checks)"]
            direction LR
            DepChecks["Dependency Checks<br/>(cert-manager, servicemesh, openshift)"]
            SvcChecks["Service Checks"]
            PlatChecks["Platform Checks<br/>(DSC readiness, DSCI)"]
            CompChecks["Component Checks<br/>(kserve, kueue, modelmesh, ray)"]
            WkldChecks["Workload Checks<br/>(notebooks, ISVCs, DSPA, guardrails)"]
        end

        subgraph BackupPipeline["Backup Pipeline (Concurrent)"]
            Discovery[Discovery Stage]
            Resolver[Dependency Resolver]
            Writer[YAML Writer]
            Discovery -->|channel| Resolver
            Resolver -->|channel| Writer
        end

        subgraph MigrateEngine["Migration Framework"]
            Prepare[Prepare Phase<br/>Backup Resources]
            Run[Run Phase<br/>Execute Migration]
            Prepare --> Run
        end

        subgraph SharedInfra["Shared Infrastructure"]
            ClientWrapper["client.Reader / client.Writer<br/>QPS=50, Burst=100"]
            ResourceTypes["Resource Type Registry<br/>40+ GVK/GVR definitions"]
            VersionDetector["Version Detector<br/>DSC → DSCI → CSV fallback"]
            Printer["Output Printer<br/>Table / JSON / YAML"]
            Envelope["Output Envelope<br/>cli.opendatahub.io/v1"]
        end

        LintCmd --> LintEngine
        BackupCmd --> BackupPipeline
        MigrateCmd --> MigrateEngine

        LintEngine --> ClientWrapper
        BackupPipeline --> ClientWrapper
        MigrateEngine --> ClientWrapper
        GetCmd --> ClientWrapper
        DepsCmd --> ClientWrapper
        ComponentsCmd --> ClientWrapper

        ClientWrapper --> ResourceTypes
        LintEngine --> VersionDetector
        DepsCmd --> VersionDetector

        GetCmd --> Printer
        ComponentsCmd --> Printer
        LintCmd --> Printer
        DepsCmd --> Printer
        Printer --> Envelope
    end

    User[Platform Admin / SRE] -->|kubectl odh ...| CLI

    subgraph K8sCluster["Kubernetes / OpenShift Cluster"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        DSC["DataScienceCluster CR"]
        DSCI["DSCInitialization CR"]
        OLM["OLM<br/>Subscriptions / CSVs"]
        Workloads["User Workloads<br/>Notebooks, ISVCs, DSPA,<br/>RayClusters, PyTorchJobs"]
        Kueue["Kueue Resources<br/>ClusterQueues, LocalQueues"]
    end

    ClientWrapper -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI --- DSC
    K8sAPI --- DSCI
    K8sAPI --- OLM
    K8sAPI --- Workloads
    K8sAPI --- Kueue

    GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS"]
    DepsCmd -.->|"optional --refresh<br/>HTTPS/443"| GitHub

    LocalFS["Local Filesystem<br/>Backup YAML Files"]
    Writer -->|writes| LocalFS
    Prepare -->|writes| LocalFS

    style CLI fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CmdLayer fill:#bbdefb,stroke:#1565c0
    style LintEngine fill:#c8e6c9,stroke:#2e7d32
    style BackupPipeline fill:#fff9c4,stroke:#f9a825
    style MigrateEngine fill:#f3e5f5,stroke:#7b1fa2
    style SharedInfra fill:#e0e0e0,stroke:#616161
    style K8sCluster fill:#fce4ec,stroke:#c62828
    style User fill:#fff,stroke:#333,stroke-width:2px
    style GitHub fill:#f5f5f5,stroke:#999
    style LocalFS fill:#f5f5f5,stroke:#999
