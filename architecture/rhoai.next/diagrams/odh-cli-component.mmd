graph TB
    subgraph CLI["odh-cli (rhai-cli / kubectl-odh)"]
        direction TB
        Main["main.go<br/>Cobra Root Command"]

        subgraph Commands["CLI Commands"]
            direction LR
            LintCmd["lint<br/>Upgrade Readiness"]
            BackupCmd["backup<br/>Workload Backup"]
            MigrateCmd["migrate<br/>list | prepare | run"]
            GetCmd["get<br/>Resource Query"]
            DepsCmd["deps<br/>Dependency Status"]
            ComponentsCmd["components<br/>Lifecycle Mgmt"]
        end

        subgraph LintFramework["Lint Framework (37 Checks)"]
            direction TB
            CheckRegistry["CheckRegistry<br/>Explicit registration"]
            Executor["Executor<br/>Canonical order"]
            DiagnosticResult["DiagnosticResult<br/>Multi-outcome conditions"]

            subgraph CheckGroups["Check Groups"]
                direction LR
                DepChecks["dependency<br/>cert-manager, OpenShift,<br/>ServiceMesh"]
                PlatformChecks["platform<br/>DSC readiness,<br/>DSCI readiness"]
                ComponentChecks["component<br/>KServe, Kueue, Dashboard,<br/>ModelMesh, Ray, Training"]
                WorkloadChecks["workload<br/>Notebook, ISVC,<br/>Kueue, Ray, DSP,<br/>Guardrails, LlamaStack"]
            end

            CheckRegistry --> Executor
            Executor --> DiagnosticResult
        end

        subgraph BackupFramework["Backup Pipeline"]
            direction LR
            Discovery["Discovery<br/>List workloads"]
            DependencyResolver["Dependency Resolver<br/>ConfigMaps, Secrets, PVCs"]
            ResourceWriter["Resource Writer<br/>Strip cluster metadata"]
        end

        subgraph MigrateFramework["Migration Framework"]
            direction LR
            ActionRegistry["ActionRegistry"]
            ActionExecutor["Action Executor"]
            RHBOKAction["RHBOK Migration<br/>Kueue → Red Hat Build of Kueue"]
        end

        subgraph ClientLayer["Kubernetes Client Layer"]
            direction LR
            Reader["Reader Interface<br/>(read-only)"]
            Writer["Writer Interface<br/>(mutations)"]
            OLMReader["OLM Reader<br/>(nil-safe)"]
        end

        Main --> Commands
        LintCmd --> LintFramework
        BackupCmd --> BackupFramework
        MigrateCmd --> MigrateFramework
        LintFramework --> ClientLayer
        BackupFramework --> ClientLayer
        MigrateFramework --> ClientLayer
    end

    subgraph Bundled["Bundled Tools (Container Image)"]
        YQ["yq (vendored Go)<br/>FIPS-compliant"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Shell/Python scripts"]
        OC["oc / kubectl<br/>(from base image)"]
    end

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    OLMAPI["OLM API<br/>Subscriptions, CSVs"]
    GitHubAPI["GitHub (odh-gitops)<br/>443/TCP HTTPS"]

    ClientLayer -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    ClientLayer -->|"HTTPS/6443<br/>Bearer Token"| OLMAPI
    DepsCmd -->|"HTTPS/443<br/>Manifest fetch"| GitHubAPI

    style CLI fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style LintFramework fill:#e8f5e9,stroke:#2e7d32
    style BackupFramework fill:#fff3e0,stroke:#e65100
    style MigrateFramework fill:#fce4ec,stroke:#c62828
    style ClientLayer fill:#f3e5f5,stroke:#6a1b9a
    style Bundled fill:#f5f5f5,stroke:#616161
    style K8sAPI fill:#bbdefb,stroke:#1565c0
    style OLMAPI fill:#bbdefb,stroke:#1565c0
    style GitHubAPI fill:#fff9c4,stroke:#f9a825
