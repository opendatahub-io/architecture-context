graph TB
    subgraph User["CLI User"]
        Operator["Platform Operator / Admin"]
    end

    subgraph "odh-cli (kubectl-odh / rhai-cli)"
        direction TB

        subgraph CLI["Cobra CLI Framework"]
            MainCmd["main.go<br/>Root Command"]
        end

        subgraph LintEngine["Lint Framework (pkg/lint/)"]
            LintCmd["lint Command"]
            CheckRegistry["Check Registry<br/>38 Checks"]
            CheckExecutor["Check Executor<br/>Glob Matching + Ordering"]
            ValidateBuilders["Fluent Validators<br/>Component / Workload / Operator"]
            ResultEngine["Result Engine<br/>Prohibited > Blocking > Advisory > None"]
            LintCmd --> CheckRegistry
            CheckRegistry --> CheckExecutor
            CheckExecutor --> ValidateBuilders
            CheckExecutor --> ResultEngine
        end

        subgraph MigrateEngine["Migration Framework (pkg/migrate/)"]
            MigrateCmd["migrate Command<br/>prepare / run / list"]
            ActionRegistry["Action Registry<br/>19 Actions"]
            ActionExecutor["Action Executor<br/>Prepare/Run Lifecycle"]
            StepRecorder["Hierarchical Step Recorder<br/>Audit Trail"]
            RBACPrecheck["RBAC Pre-Validator<br/>SelfSubjectAccessReview"]
            MigrateCmd --> ActionRegistry
            ActionRegistry --> ActionExecutor
            ActionExecutor --> StepRecorder
            ActionExecutor --> RBACPrecheck
        end

        subgraph BackupEngine["Backup Pipeline (pkg/backup/)"]
            BackupCmd["backup Command"]
            Discovery["Stage 1: Discovery<br/>Resource Discovery"]
            DependencyResolver["Stage 2: Dependency Resolution<br/>DSPA + Notebooks"]
            Writer["Stage 3: Writer<br/>JQ Field Stripping"]
            BackupCmd --> Discovery
            Discovery --> DependencyResolver
            DependencyResolver --> Writer
        end

        subgraph OtherCmds["Operational Commands"]
            ComponentsCmd["components<br/>Enable/Disable"]
            DepsCmd["deps<br/>Dependency Install"]
            StatusCmd["status<br/>Platform Health"]
            LogsCmd["logs<br/>Aggregation"]
            EventsCmd["events<br/>Streaming + Follow"]
            GetCmd["get<br/>Resource Listing"]
        end

        MainCmd --> LintCmd
        MainCmd --> MigrateCmd
        MainCmd --> BackupCmd
        MainCmd --> ComponentsCmd
        MainCmd --> DepsCmd
        MainCmd --> StatusCmd
        MainCmd --> LogsCmd
        MainCmd --> EventsCmd
        MainCmd --> GetCmd
    end

    subgraph K8sCluster["Kubernetes / OpenShift Cluster"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]

        subgraph PlatformCRDs["Platform CRDs"]
            DSC["DataScienceCluster<br/>v2 / v1"]
            DSCI["DSCInitialization<br/>v2 / v1"]
        end

        subgraph WorkloadCRDs["Workload CRDs (Read/Write)"]
            InferenceService["InferenceService"]
            ServingRuntime["ServingRuntime"]
            Notebook["Notebook"]
            DSPA["DSPA v1 / v1alpha1"]
            RayCluster["RayCluster"]
            TrustyAISvc["TrustyAIService"]
            LlamaStackDist["LlamaStackDistribution"]
        end

        subgraph OLMResources["OLM Resources"]
            Subscription["Subscription"]
            CSV["ClusterServiceVersion"]
            PackageManifest["PackageManifest"]
        end

        subgraph SchedulingCRDs["Scheduling CRDs"]
            ClusterQueue["ClusterQueue"]
            LocalQueue["LocalQueue"]
        end
    end

    subgraph ExternalSvc["External Services"]
        TrustyAIRoute["TrustyAI Route<br/>443/TCP HTTPS"]
        GitHub["GitHub (raw.githubusercontent.com)<br/>443/TCP HTTPS"]
    end

    %% User interaction
    Operator -->|"kubectl odh lint / migrate / backup"| MainCmd

    %% Cluster interactions
    LintCmd -->|reads| K8sAPI
    MigrateCmd -->|reads + writes| K8sAPI
    BackupCmd -->|reads| K8sAPI
    ComponentsCmd -->|reads + patches| K8sAPI
    DepsCmd -->|reads + installs| K8sAPI
    StatusCmd -->|reads| K8sAPI
    LogsCmd -->|reads| K8sAPI
    EventsCmd -->|reads + watches| K8sAPI
    GetCmd -->|reads| K8sAPI

    K8sAPI --- PlatformCRDs
    K8sAPI --- WorkloadCRDs
    K8sAPI --- OLMResources
    K8sAPI --- SchedulingCRDs

    %% External services
    MigrateCmd -->|"TrustyAI metrics backup<br/>Bearer Token"| TrustyAIRoute
    DepsCmd -->|"Dependency manifest refresh"| GitHub

    %% Output
    BackupCmd -->|"YAML files"| LocalFS["Local Filesystem"]
    ResultEngine -->|"stdout<br/>Exit codes 0/1/2"| Operator

    %% Styling
    style Operator fill:#e1f5fe,stroke:#0288d1,stroke-width:2px
    style K8sAPI fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style LintEngine fill:#e8f5e9,stroke:#388e3c,stroke-width:1px
    style MigrateEngine fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style BackupEngine fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px
    style TrustyAIRoute fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style GitHub fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style LocalFS fill:#e0e0e0,stroke:#616161,stroke-width:1px
