graph LR
    KubeflowSDK["Kubeflow SDK<br/>(Python Client Library)"]

    %% Internal Platform Dependencies (ODH/RHOAI)
    KubeflowSDK -->|"CRD CRUD<br/>TrainJob, TrainingRuntime"| TrainerOperator["Kubeflow Trainer Operator"]
    KubeflowSDK -->|"CRD CRUD<br/>Experiment"| Katib["Kubeflow Katib"]
    KubeflowSDK -->|"CRD CRUD<br/>SparkApplication"| SparkOperator["Kubeflow Spark Operator"]
    KubeflowSDK -->|"REST API<br/>HTTP/HTTPS"| ModelRegistry["Model Registry Server"]
    KubeflowSDK -->|"Annotations +<br/>HTTP 28080 polling"| RHOAIController["RHOAI Trainer Controller"]
    KubeflowSDK -->|"ConfigMap read<br/>kubeflow-trainer-public"| TrainerConfigMap["kubeflow-trainer-public<br/>ConfigMap"]

    %% Reverse dependencies (components that integrate with SDK)
    Dashboard["ODH Dashboard"] -.->|"UI for training jobs"| TrainerOperator
    Pipelines["Data Science Pipelines"] -.->|"Pipeline steps"| TrainerOperator

    %% External Services
    KubeflowSDK -->|"443/TCP HTTPS<br/>Bearer Token"| K8sAPI["Kubernetes API Server"]
    KubeflowSDK -->|"443/TCP HTTPS<br/>AWS IAM"| S3["S3-compatible Storage"]
    KubeflowSDK -->|"443/TCP HTTPS<br/>Bearer Token"| HFHub["HuggingFace Hub"]
    KubeflowSDK -->|"443/TCP HTTPS"| PyPI["PyPI / Package Index"]
    KubeflowSDK -->|"Unix socket<br/>Local only"| Docker["Docker / Podman"]

    %% Python Library Dependencies
    subgraph PythonDeps["Python Dependencies"]
        direction TB
        kubernetes_py["kubernetes >=27.2.0<br/>(Required)"]
        pydantic["pydantic >=2.10.0<br/>(Required)"]
