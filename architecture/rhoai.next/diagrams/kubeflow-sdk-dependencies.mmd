        katib_api["kubeflow-katib-api >=0.19.0<br/>(Required)"]
        docker_py["docker >=6.1.3<br/>(Optional)"]
        podman_py["podman >=5.6.0<br/>(Optional)"]
        pyspark["pyspark-connect ==4.0.1<br/>(Optional, spark extra)"]
        spark_api["kubeflow-spark-api >=2.4.0<br/>(Optional, spark extra)"]
        model_reg["model-registry >=0.3.6<br/>(Optional, hub extra)"]
        fsspec["fsspec >=2025.3.0<br/>(Optional, rhai extra)"]
        s3fs["s3fs >=2025.3.0<br/>(Optional, rhai extra)"]
        transformers_py["transformers (HuggingFace)<br/>(Optional, RHAI runtime)"]
        torch["torch<br/>(Optional, RHAI runtime)"]
    end

