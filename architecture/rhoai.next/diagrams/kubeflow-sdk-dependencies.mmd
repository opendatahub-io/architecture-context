graph LR
    SDK["Kubeflow SDK<br/>(Python Client Library)"]

    %% Internal Platform Dependencies
    SDK -->|"CRD CRUD<br/>TrainJob, TrainingRuntime"| TrainerOp["Kubeflow Trainer<br/>Operator"]
    SDK -->|"CRD CRUD<br/>Experiment, Trial"| Katib["Katib Controller"]
    SDK -->|"CRD CRUD<br/>SparkConnect"| SparkOp["Spark Operator"]
    SDK -->|"REST API<br/>443/8080 TCP"| ModelReg["Model Registry<br/>Server"]
    SDK -.->|"CRD (via Trainer)"| JobSet["JobSet Controller"]

    %% External Python Dependencies (required)
    SDK -->|"K8s API client"| K8sPython["kubernetes<br/>Python >=27.2.0"]
    SDK -->|"type validation"| Pydantic["pydantic<br/>>=2.10.0"]
    SDK -->|"CRD models"| TrainerAPI["kubeflow-trainer-api<br/>>=2.0.0"]
    SDK -->|"CRD models"| KatibAPI["kubeflow-katib-api<br/>>=0.19.0"]

    %% Optional Python Dependencies
    SDK -.->|"container backend"| Docker["docker<br/>>=6.1.3"]
    SDK -.->|"container backend"| Podman["podman<br/>>=5.6.0"]
    SDK -.->|"S3 checkpoints"| Fsspec["fsspec + s3fs<br/>>=2025.3.0"]
    SDK -.->|"Spark sessions"| PySpark["pyspark-connect<br/>==4.0.1"]
    SDK -.->|"Spark CRD models"| SparkAPI["kubeflow-spark-api<br/>>=2.4.0"]
    SDK -.->|"model registry"| ModelRegPy["model-registry<br/>>=0.3.6"]

    %% External Services
    SDK -->|"CRD operations<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    SDK -.->|"gRPC/15002"| SparkDriver["Spark Driver<br/>Pod"]
    SDK -.->|"checkpoint upload<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    SDK -.->|"model/dataset download<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]
    SDK -.->|"pip install<br/>443/TCP HTTPS"| PyPI["PyPI"]
    SDK -.->|"JAR download<br/>443/TCP HTTPS"| Maven["Maven Central"]

    %% Downstream consumers
    Dashboard["ODH Dashboard"] -.->|"user-facing UI"| SDK
    Pipelines["Data Science<br/>Pipelines"] -.->|"pipeline steps"| SDK
    Notebooks["Jupyter<br/>Notebooks"] -.->|"interactive use"| SDK

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (green)
    style TrainerOp fill:#7ed321,stroke:#333,color:#fff
    style Katib fill:#7ed321,stroke:#333,color:#fff
    style SparkOp fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style JobSet fill:#7ed321,stroke:#333,color:#fff

    %% Required Python deps (blue-gray)
    style K8sPython fill:#6c8ebf,stroke:#333,color:#fff
    style Pydantic fill:#6c8ebf,stroke:#333,color:#fff
    style TrainerAPI fill:#6c8ebf,stroke:#333,color:#fff
    style KatibAPI fill:#6c8ebf,stroke:#333,color:#fff

    %% Optional Python deps (light gray)
    style Docker fill:#999,stroke:#333,color:#fff
    style Podman fill:#999,stroke:#333,color:#fff
    style Fsspec fill:#999,stroke:#333,color:#fff
    style PySpark fill:#999,stroke:#333,color:#fff
    style SparkAPI fill:#999,stroke:#333,color:#fff
    style ModelRegPy fill:#999,stroke:#333,color:#fff

    %% External services (orange)
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style SparkDriver fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style PyPI fill:#f5a623,stroke:#333,color:#fff
    style Maven fill:#f5a623,stroke:#333,color:#fff

    %% Consumers (light blue)
    style Dashboard fill:#b3d9ff,stroke:#333
    style Pipelines fill:#b3d9ff,stroke:#333
    style Notebooks fill:#b3d9ff,stroke:#333
