graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Pod["EPP Pod"]
            EPP["Endpoint Picker (EPP)<br/>Go ext-proc Service<br/>9002/TCP gRPC"]
            EPP_Health["EPP Health Server<br/>9003/TCP gRPC"]
            EPP_Metrics["EPP Metrics<br/>9090/TCP HTTP"]
            LatencyTrain["Latency Training Server<br/>Python Sidecar<br/>8000/TCP HTTP<br/>(optional)"]
            LatencyPredict["Latency Prediction Server<br/>Python Sidecar<br/>8001/TCP HTTP<br/>(optional)"]
            EPP -->|queries predictions| LatencyPredict
            LatencyTrain -->|syncs models| LatencyPredict
        end

        subgraph BBR_Pod["BBR Pod"]
            BBR["Body Based Router (BBR)<br/>Go ext-proc Service<br/>9004/TCP gRPC"]
            BBR_Health["BBR Health Server<br/>9005/TCP gRPC"]
            BBR_Metrics["BBR Metrics<br/>9090/TCP HTTP"]
        end

        subgraph Scheduling["EPP Scheduling Framework"]
            direction LR
            Filter["Filter Plugins<br/>prefix-cache-affinity<br/>slo-headroom-tier"]
            Score["Score Plugins<br/>queue-scorer (w:2)<br/>kv-cache-scorer (w:2)<br/>prefix-cache-scorer (w:3)"]
            Pick["Pick Plugin<br/>weighted-random / max-score"]
            Filter --> Score --> Pick
        end

        EPP --> Scheduling
    end

    Client["External Client"] -->|HTTPS/443| Gateway
    Gateway["Gateway / Envoy Proxy<br/>ext-proc filter"]
    Gateway -->|gRPC/9004<br/>TLS| BBR
    BBR -->|X-Gateway-Model-Name<br/>header injection| Gateway
    Gateway -->|gRPC/9002<br/>TLS| EPP
    EPP -->|selected endpoint<br/>address:port| Gateway
    Gateway -->|HTTP/8000| ModelServer["Model Server Pod<br/>(vLLM / SGLang / Triton)"]

    subgraph CRDs["Custom Resource Definitions"]
        InferencePool["InferencePool<br/>v1"]
        InferenceObjective["InferenceObjective<br/>v1alpha2"]
        InferenceModelRewrite["InferenceModelRewrite<br/>v1alpha2"]
        InferencePoolImport["InferencePoolImport<br/>v1alpha1"]
        EPPConfig["EndpointPickerConfig<br/>v1alpha1"]
    end

    InferencePool -->|watched by| EPP
    InferenceObjective -->|watched by| EPP
    InferenceModelRewrite -->|watched by| EPP
    EPPConfig -->|configures| EPP
    EPP -->|scrapes /metrics| ModelServer

    BBR -->|watches ConfigMaps<br/>bbr-managed=true| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    EPP -->|watches CRDs + Pods| K8sAPI

    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style LatencyTrain fill:#9b59b6,stroke:#333,color:#fff
    style LatencyPredict fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e67e22,stroke:#333,color:#fff
    style ModelServer fill:#27ae60,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style InferencePoolImport fill:#f5a623,stroke:#333
    style EPPConfig fill:#f5a623,stroke:#333
    style Filter fill:#dfe6e9,stroke:#636e72
    style Score fill:#dfe6e9,stroke:#636e72
    style Pick fill:#dfe6e9,stroke:#636e72
