graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Pod["EPP Pod"]
            EPP["Endpoint Picker (EPP)<br/>Go gRPC Service<br/>9002/TCP ext-proc<br/>9003/TCP health<br/>9090/TCP metrics"]
            LatencyPredictor["Latency Predictor<br/>Sidecar Library<br/>(Go, async client)"]
            TrainingServer["Latency Training Server<br/>Python, 8000/TCP<br/>(optional sidecar)"]
            PredictionServer["Latency Prediction Server<br/>Python, 8001+/TCP<br/>(optional sidecar)"]
            EPP -->|training data| TrainingServer
            EPP -->|prediction queries| PredictionServer
            LatencyPredictor -->|async client| TrainingServer
            LatencyPredictor -->|async client| PredictionServer
        end

        subgraph BBR_Pod["BBR Pod"]
            BBR["Body-Based Router (BBR)<br/>Go gRPC Service<br/>9004/TCP ext-proc<br/>9005/TCP health<br/>9090/TCP metrics"]
        end
    end

    subgraph Gateway["Envoy-Compatible Gateway"]
        EnvoyProxy["Envoy Proxy<br/>(ext-proc filter chain)"]
    end

    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token / API Key"| EnvoyProxy

    EnvoyProxy -->|"1. Body parsing<br/>gRPC/9004 TLS"| BBR
    BBR -->|"Model name headers"| EnvoyProxy
    EnvoyProxy -->|"2. Endpoint selection<br/>gRPC/9002 TLS"| EPP
    EPP -->|"Selected endpoint"| EnvoyProxy

    EnvoyProxy -->|"3. Forward request"| ModelServer

    %% CRDs
    InferencePoolCR["InferencePool CR"] -->|watched by| EPP
    InferenceObjectiveCR["InferenceObjective CR"] -->|watched by| EPP
    InferenceModelRewriteCR["InferenceModelRewrite CR"] -->|watched by| EPP
    ConfigMaps["ConfigMaps<br/>(bbr-managed)"] -->|watched by| BBR

    %% Metrics scraping
    EPP -->|"scrape /metrics<br/>HTTP"| ModelServer["Model Server Pods<br/>(vLLM / SGLang / Triton)"]

    %% Kubernetes API
    EPP -->|"Watch CRDs, Pods<br/>HTTPS/443"| K8sAPI["Kubernetes API"]
    BBR -->|"Watch ConfigMaps<br/>HTTPS/443"| K8sAPI

    %% Optional integrations
    EPP -.->|"traces<br/>gRPC/4317"| OTLP["OTLP Collector"]
    EPP -.->|"metrics<br/>HTTP/9090"| Prometheus["Prometheus"]

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style LatencyPredictor fill:#6ab0de,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style EnvoyProxy fill:#e67e22,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjectiveCR fill:#f5a623,stroke:#333
    style InferenceModelRewriteCR fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
    style ModelServer fill:#27ae60,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
