graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Pod["EPP Pod"]
            EPP["Endpoint Picker (EPP)<br/>Go ext-proc Service<br/>9002/TCP gRPC"]
            EPP_Health["EPP Health Server<br/>9003/TCP gRPC"]
            EPP_Metrics["EPP Metrics<br/>9090/TCP HTTP"]
            EPP --> EPP_Health
            EPP --> EPP_Metrics

            subgraph Scheduling["Scheduling Framework"]
                Filter["Filter Plugins"]
                Score["Score Plugins<br/>(queue, kv-cache,<br/>prefix-cache)"]
                Pick["Pick Plugin<br/>(weighted random)"]
                Filter --> Score --> Pick
            end

            EPP --> Scheduling
        end

        subgraph LatencyPred["Latency Predictor (Optional Sidecars)"]
            TrainingServer["Training Server<br/>Python/XGBoost<br/>8000/TCP"]
            PredictionServer["Prediction Server<br/>Python<br/>8001+/TCP"]
            TrainingServer -->|model sync| PredictionServer
        end

        subgraph BBR_Pod["BBR Pod (Optional)"]
            BBR["Body Based Router<br/>Go ext-proc Service<br/>9004/TCP gRPC"]
            BBR_Health["BBR Health Server<br/>9005/TCP gRPC"]
            BBR_Metrics["BBR Metrics<br/>9090/TCP HTTP"]
            BBR --> BBR_Health
            BBR --> BBR_Metrics

            subgraph Plugins["BBR Plugins"]
                BodyField["body-field-to-header<br/>(extract model name)"]
                BaseModel["base-model-to-header<br/>(LoRA → base model)"]
            end

            BBR --> Plugins
        end

        EPP -.->|queries latency| PredictionServer
    end

    %% External Actors
    Client["External Client"] -->|HTTPS/443| Gateway
    Gateway["Gateway / Envoy Proxy"]

    %% CRDs
    InferencePoolCR["InferencePool CR"]
    InferenceObjCR["InferenceObjective CR"]
    ModelRewriteCR["InferenceModelRewrite CR"]
    PoolImportCR["InferencePoolImport CR"]
    EPPConfigCR["EndpointPickerConfig"]

    %% Flow
    Gateway -->|gRPC ext-proc<br/>9004/TCP TLS| BBR
    BBR -->|X-Gateway-Model-Name<br/>header added| Gateway
    Gateway -->|gRPC ext-proc<br/>9002/TCP TLS| EPP
    EPP -->|selected endpoint<br/>returned| Gateway
    Gateway -->|HTTP/8000| ModelServer["Model Server Pods<br/>(vLLM / SGLang / Triton)"]

    %% CRD watches
    InferencePoolCR -->|watched by| EPP
    InferenceObjCR -->|watched by| EPP
    ModelRewriteCR -->|watched by| EPP
    EPPConfigCR -->|configures| EPP

    %% Metrics scraping
    EPP -->|scrapes /metrics<br/>HTTP| ModelServer

    %% BBR ConfigMap
    ConfigMap["ConfigMaps<br/>(bbr-managed)"] -->|watched by| BBR

    %% K8s API
    EPP -->|watches Pods| K8sAPI["Kubernetes API Server"]
    BBR -->|watches ConfigMaps| K8sAPI

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style EPP_Health fill:#6ab0f3,stroke:#333,color:#fff
    style BBR_Health fill:#6ab0f3,stroke:#333,color:#fff
    style EPP_Metrics fill:#6ab0f3,stroke:#333,color:#fff
    style BBR_Metrics fill:#6ab0f3,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e67e22,stroke:#333,color:#fff
    style ModelServer fill:#27ae60,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjCR fill:#f5a623,stroke:#333
    style ModelRewriteCR fill:#f5a623,stroke:#333
    style PoolImportCR fill:#f5a623,stroke:#333
    style EPPConfigCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Filter fill:#dce6f1,stroke:#4a90e2
    style Score fill:#dce6f1,stroke:#4a90e2
    style Pick fill:#dce6f1,stroke:#4a90e2
    style BodyField fill:#dce6f1,stroke:#4a90e2
    style BaseModel fill:#dce6f1,stroke:#4a90e2
