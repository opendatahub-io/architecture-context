graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Box["Endpoint Picker (EPP)"]
            EPP_ExtProc["ext-proc gRPC Server<br/>9002/TCP"]
            EPP_Health["Health Server<br/>9003/TCP gRPC"]
            EPP_Metrics["Metrics Server<br/>9090/TCP HTTP"]
            Scheduler["Scheduling Framework<br/>(Filters → Scorers → Pickers)"]
            FlowControl["Flow Controller<br/>(Priority Queuing / Admission)"]
            Datastore["In-Memory Datastore<br/>(Endpoints, Metrics, CRDs)"]
            AsyncClient["Latency Predictor<br/>Async Client (in-process)"]

            EPP_ExtProc --> FlowControl
            FlowControl --> Scheduler
            Scheduler --> Datastore
            AsyncClient -.->|predictions| Scheduler
        end

        subgraph BBR_Box["Body Based Router (BBR)"]
            BBR_ExtProc["ext-proc gRPC Server<br/>9004/TCP"]
            BBR_Health["Health Server<br/>9005/TCP gRPC"]
            BBR_Plugins["Plugins<br/>(BodyFieldToHeader,<br/>BaseModelExtractor)"]

            BBR_ExtProc --> BBR_Plugins
        end

        subgraph Controllers["Controller Reconcilers"]
            PoolReconciler["InferencePool<br/>Reconciler"]
            ObjectiveReconciler["InferenceObjective<br/>Reconciler"]
            RewriteReconciler["InferenceModelRewrite<br/>Reconciler"]
            PodReconciler["Pod Reconciler"]
        end

        subgraph LatencyPredictor["Latency Prediction Subsystem (optional)"]
            TrainingServer["Training Server<br/>8000/TCP HTTP<br/>Python/FastAPI"]
            PredictionServer["Prediction Server<br/>8001/TCP HTTP<br/>Python/FastAPI"]
            PV["PersistentVolume<br/>(XGBoost Models)"]

            TrainingServer -->|stores models| PV
            PredictionServer -->|loads models| PV
        end

        Controllers -->|updates| Datastore
        AsyncClient -->|training data| TrainingServer
        AsyncClient -->|predictions| PredictionServer
    end

    %% External Actors
    Client["External Client"]
    Gateway["Envoy-based Gateway<br/>(Istio / Envoy GW / kgateway)"]

    %% CRDs
    InferencePoolCR["InferencePool CR<br/>(v1 GA)"]
    InferenceObjectiveCR["InferenceObjective CR<br/>(v1alpha2)"]
    InferenceModelRewriteCR["InferenceModelRewrite CR<br/>(v1alpha2)"]

    %% Backend
    ModelServers["Model Servers<br/>(vLLM / SGLang / Triton)"]
    K8sAPI["Kubernetes API Server"]

    %% Request Flow
    Client -->|HTTP inference request| Gateway
    Gateway -->|gRPC ext-proc| BBR_ExtProc
    Gateway -->|gRPC ext-proc| EPP_ExtProc
    Gateway -->|forwards to selected endpoint| ModelServers

    %% Metrics Scraping
    EPP_ExtProc -.->|scrapes /metrics| ModelServers

    %% CRD Watches
    PoolReconciler -->|watches| InferencePoolCR
    ObjectiveReconciler -->|watches| InferenceObjectiveCR
    RewriteReconciler -->|watches| InferenceModelRewriteCR
    PodReconciler -->|watches pods via| K8sAPI
    Controllers -->|watches CRDs via| K8sAPI

    %% Styling
    style EPP_ExtProc fill:#4a90e2,color:#fff
    style BBR_ExtProc fill:#4a90e2,color:#fff
    style Scheduler fill:#5b9bd5,color:#fff
    style FlowControl fill:#5b9bd5,color:#fff
    style Datastore fill:#5b9bd5,color:#fff
    style TrainingServer fill:#9b59b6,color:#fff
    style PredictionServer fill:#9b59b6,color:#fff
    style Gateway fill:#e67e22,color:#fff
    style ModelServers fill:#e67e22,color:#fff
    style InferencePoolCR fill:#f5a623
    style InferenceObjectiveCR fill:#f5a623
    style InferenceModelRewriteCR fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style Client fill:#2ecc71,color:#fff
