graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Service["Endpoint Picker (EPP)"]
            EPP_ExtProc["EPP ext-proc Server<br/>9002/TCP gRPC/h2 TLS"]
            EPP_Health["Health Server<br/>9003/TCP gRPC"]
            EPP_Metrics["Metrics Server<br/>9090/TCP HTTP"]

            subgraph Scheduling["Scheduling Framework"]
                Filters["Filters"]
                Scorers["Scorers<br/>(KV-cache, queue depth,<br/>prefix affinity, LoRA,<br/>token load, latency)"]
                Pickers["Pickers"]
                Filters --> Scorers --> Pickers
            end

            subgraph FlowControl["Flow Control"]
                FlowController["FlowController<br/>(JSQ-Bytes)"]
                FlowRegistry["FlowRegistry<br/>(sync.Map)"]
                FlowController --> FlowRegistry
            end

            EPP_ExtProc --> Scheduling
            EPP_ExtProc --> FlowControl
        end

        subgraph BBR_Service["Body Based Router (BBR)"]
            BBR_ExtProc["BBR ext-proc Server<br/>9004/TCP gRPC/h2 TLS"]
            BBR_Health["Health Server<br/>9005/TCP gRPC"]
            BBR_Plugins["Plugins<br/>(body-field-to-header,<br/>base-model-to-header)"]
            BBR_ExtProc --> BBR_Plugins
        end

        subgraph CRD_Controllers["CRD Controllers"]
            PoolReconciler["InferencePool<br/>Reconciler"]
            ObjectiveReconciler["InferenceObjective<br/>Reconciler"]
            RewriteReconciler["InferenceModelRewrite<br/>Reconciler"]
            PodReconciler["Pod Reconciler"]
        end

        subgraph LatencyPredictor["Latency Prediction Subsystem"]
            TrainingServer["Training Server<br/>8000/TCP HTTP<br/>(Python)"]
            PredictionServer["Prediction Server<br/>8001/TCP HTTP<br/>(Python)"]
            AsyncClient["Async Client<br/>(Go Sidecar)"]
            AsyncClient -->|train data| TrainingServer
            AsyncClient -->|predictions| PredictionServer
            TrainingServer -->|shared PVC| PredictionServer
        end
    end

    %% External entities
    Client["External Client"]
    Gateway["Envoy Gateway<br/>(ext-proc capable)"]

    subgraph CRDs["Custom Resources"]
        InferencePoolCR["InferencePool CR<br/>(v1 stable)"]
        InferenceObjectiveCR["InferenceObjective CR<br/>(v1alpha2)"]
        InferenceModelRewriteCR["InferenceModelRewrite CR<br/>(v1alpha2)"]
    end

    ModelServers["Model Server Pods<br/>(vLLM, sglang, triton)"]
    K8sAPI["Kubernetes API Server"]

    %% Flows
    Client -->|HTTPS/443| Gateway
    Gateway -->|gRPC ext-proc<br/>9002/TCP TLS| EPP_ExtProc
    Gateway -->|gRPC ext-proc<br/>9004/TCP TLS| BBR_ExtProc
    Gateway -->|routed request| ModelServers

    InferencePoolCR -->|watched by| PoolReconciler
    InferenceObjectiveCR -->|watched by| ObjectiveReconciler
    InferenceModelRewriteCR -->|watched by| RewriteReconciler

    CRD_Controllers -->|updates| EPP_ExtProc
    EPP_ExtProc -->|scrape metrics| ModelServers
    EPP_ExtProc -->|latency queries| AsyncClient

    BBR_Plugins -->|watch ConfigMaps| K8sAPI
    CRD_Controllers -->|watch CRDs/Pods| K8sAPI

    %% Styling
    style EPP_ExtProc fill:#4a90e2,color:#fff
    style BBR_ExtProc fill:#4a90e2,color:#fff
    style EPP_Health fill:#7fb3e0,color:#fff
    style BBR_Health fill:#7fb3e0,color:#fff
    style EPP_Metrics fill:#7fb3e0,color:#fff
    style TrainingServer fill:#9b59b6,color:#fff
    style PredictionServer fill:#9b59b6,color:#fff
    style AsyncClient fill:#9b59b6,color:#fff
    style InferencePoolCR fill:#f5a623,color:#000
    style InferenceObjectiveCR fill:#f5a623,color:#000
    style InferenceModelRewriteCR fill:#f5a623,color:#000
    style Gateway fill:#e8e8e8,color:#000
    style ModelServers fill:#7ed321,color:#000
    style K8sAPI fill:#e8e8e8,color:#000
    style Client fill:#f9f9f9,color:#000
