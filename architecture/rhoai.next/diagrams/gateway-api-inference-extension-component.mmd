graph TB
    subgraph GIE["Gateway API Inference Extension"]
        direction TB

        subgraph EPPService["Endpoint Picker Proxy (EPP)"]
            EPP["EPP Server<br/>9002/TCP gRPC ext-proc<br/>9003/TCP gRPC health<br/>9090/TCP HTTP metrics"]
            Scheduler["Scheduling Framework<br/>Filters → Scorers → Pickers"]
            Director["Director<br/>Model Rewriting &<br/>Traffic Splitting"]
            FlowControl["Flow Control Layer<br/>Priority Queuing &<br/>Admission Control"]
            DataLayer["Data Layer<br/>Metrics Collection &<br/>Endpoint State"]
            EPP --> Scheduler
            EPP --> Director
            EPP --> FlowControl
            Scheduler --> DataLayer
        end

        subgraph BBRService["Body-Based Router (BBR)"]
            BBR["BBR Server<br/>9004/TCP gRPC ext-proc<br/>9005/TCP gRPC health<br/>9090/TCP HTTP metrics"]
            BBRPlugins["BBR Plugins<br/>BodyFieldToHeader<br/>BaseModelExtractor"]
            BBR --> BBRPlugins
        end

        subgraph LatencyPredictor["Latency Prediction (Optional Sidecars)"]
            AsyncClient["Async Client<br/>(Go Library in EPP)"]
            TrainingServer["Training Server<br/>8000/TCP HTTP<br/>Python"]
            PredictionServer["Prediction Server<br/>8001+/TCP HTTP<br/>Python"]
            AsyncClient -->|training data| TrainingServer
            AsyncClient -->|predictions| PredictionServer
            TrainingServer -->|trained models| PredictionServer
        end
    end

    %% CRDs
    InferencePool["InferencePool CR<br/>inference.networking.k8s.io/v1"]
    InferenceObjective["InferenceObjective CR<br/>x-k8s.io/v1alpha2"]
    InferenceModelRewrite["InferenceModelRewrite CR<br/>x-k8s.io/v1alpha2"]
    InferencePoolImport["InferencePoolImport CR<br/>x-k8s.io/v1alpha1"]

    %% External systems
    Client["External Client"]
    Gateway["Envoy-based Gateway<br/>(Envoy Gateway / Istio / GKE)"]
    K8sAPI["Kubernetes API Server"]
    ModelServers["Model Server Pods<br/>(vLLM / SGLang /<br/>TensorRT-LLM / trtllm-serve)"]

    %% Client flow
    Client -->|"HTTPS/443"| Gateway
    Gateway -->|"gRPC ext-proc/9002"| EPP
    Gateway -->|"gRPC ext-proc/9004"| BBR
    EPP -->|"routing decision"| Gateway
    BBR -->|"header mutations"| Gateway
    Gateway -->|"HTTP/gRPC"| ModelServers

    %% CRD watches
    InferencePool -->|"watched by"| EPP
    InferenceObjective -->|"watched by"| EPP
    InferenceModelRewrite -->|"watched by"| EPP
    InferencePoolImport -->|"watched by"| EPP

    %% Data layer
    DataLayer -->|"scrape metrics"| ModelServers
    EPP -->|"watch pods/CRDs"| K8sAPI
    BBR -->|"watch ConfigMaps"| K8sAPI

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style Scheduler fill:#5b9bd5,stroke:#333,color:#fff
    style Director fill:#5b9bd5,stroke:#333,color:#fff
    style FlowControl fill:#5b9bd5,stroke:#333,color:#fff
    style DataLayer fill:#5b9bd5,stroke:#333,color:#fff
    style BBRPlugins fill:#5b9bd5,stroke:#333,color:#fff
    style AsyncClient fill:#9b59b6,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style InferencePoolImport fill:#f5a623,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ModelServers fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
