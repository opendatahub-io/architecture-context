graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Sub["Endpoint Picker (EPP)"]
            EPP_ExtProc["ext-proc Server<br/>9002/TCP gRPC<br/>TLS"]
            EPP_Health["Health Server<br/>9003/TCP gRPC"]
            EPP_Metrics["Metrics Server<br/>9090/TCP HTTP"]

            subgraph Scheduling["Scheduling Pipeline"]
                Filters["Filters<br/>(prefix cache, SLO headroom)"]
                Scorers["Scorers<br/>(KV cache, queue depth,<br/>LoRA affinity, latency)"]
                Pickers["Pickers<br/>(max score, random,<br/>weighted random)"]
                Filters --> Scorers --> Pickers
            end

            subgraph FlowControl["Flow Control (experimental)"]
                PriorityQueue["Priority Queuing"]
                Fairness["Fairness Policies"]
                Eviction["Eviction System"]
                PriorityQueue --> Fairness
                Fairness --> Eviction
            end

            Datastore["In-Memory Datastore<br/>(endpoints, metrics, models)"]
            MetricsCollector["Metrics Collector<br/>(scrapes model server /metrics)"]
        end

        subgraph BBR_Sub["Body-Based Router (BBR)"]
            BBR_ExtProc["ext-proc Server<br/>9004/TCP gRPC<br/>TLS"]
            BBR_Health["Health Server<br/>9005/TCP gRPC"]
            BBR_Plugins["Plugins<br/>(BodyFieldToHeader,<br/>BaseModelExtractor)"]
            AdapterStore["Adapter Store<br/>(ConfigMap-backed)"]
            BBR_Plugins --> AdapterStore
        end

        subgraph Latency["Latency Prediction (optional)"]
            LatencyClient["Latency Predictor<br/>Async Client<br/>(Go sidecar library)"]
            TrainingServer["Training Server<br/>8000/TCP HTTP<br/>(Python)"]
            PredictionServer["Prediction Server<br/>8001+/TCP HTTP<br/>(Python)"]
            LatencyClient --> TrainingServer
            LatencyClient --> PredictionServer
        end
    end

    %% External actors
    Client["External Client"]
    Gateway["Envoy-compatible Gateway<br/>(Envoy Gateway / kgateway /<br/>Istio / GKE Gateway)"]

    %% CRDs
    InferencePoolCR["InferencePool CR"]
    InferenceObjectiveCR["InferenceObjective CR"]
    InferenceModelRewriteCR["InferenceModelRewrite CR"]
    ConfigMapCR["ConfigMaps<br/>(bbr-managed)"]

    %% Model servers
    ModelServers["Model Server Pods<br/>(vLLM / SGLang / Triton)"]

    %% K8s API
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Flow
    Client -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"gRPC ext-proc<br/>9004/TCP TLS"| BBR_ExtProc
    Gateway -->|"gRPC ext-proc<br/>9002/TCP TLS"| EPP_ExtProc
    EPP_ExtProc --> Scheduling
    Scheduling --> Datastore

    %% CRD watches
    K8sAPI -->|watches| InferencePoolCR
    K8sAPI -->|watches| InferenceObjectiveCR
    K8sAPI -->|watches| InferenceModelRewriteCR
    K8sAPI -->|watches| ConfigMapCR
    InferencePoolCR -->|"reconciled by"| Datastore
    InferenceObjectiveCR -->|"reconciled by"| FlowControl
    InferenceModelRewriteCR -->|"reconciled by"| Datastore
    ConfigMapCR -->|"reconciled by"| AdapterStore

    %% Metrics scraping
    MetricsCollector -->|"HTTP scrape<br/>(KV cache, queue depth)"| ModelServers
    MetricsCollector --> Datastore

    %% Routing result
    EPP_ExtProc -->|"selected endpoint<br/>(response headers)"| Gateway
    BBR_ExtProc -->|"model name header<br/>(response headers)"| Gateway
    Gateway -->|"routed request"| ModelServers

    %% Styling
    style EPP_ExtProc fill:#4a90e2,color:#fff
    style BBR_ExtProc fill:#4a90e2,color:#fff
    style EPP_Health fill:#7bb8f5,color:#fff
    style BBR_Health fill:#7bb8f5,color:#fff
    style EPP_Metrics fill:#7bb8f5,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style ModelServers fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePoolCR fill:#7ed321,color:#fff
    style InferenceObjectiveCR fill:#7ed321,color:#fff
    style InferenceModelRewriteCR fill:#7ed321,color:#fff
    style ConfigMapCR fill:#7ed321,color:#fff
    style TrainingServer fill:#9b59b6,color:#fff
    style PredictionServer fill:#9b59b6,color:#fff
    style Datastore fill:#3498db,color:#fff
