graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Group["Endpoint Picker (EPP)"]
            EPP["EPP Server<br/>9002/TCP gRPC ext-proc<br/>9003/TCP gRPC health<br/>9090/TCP metrics"]
            Scheduler["Scheduling Pipeline<br/>Filter → Score → Pick"]
            FlowControl["Flow Control<br/>JSQ-Bytes, Priority Queuing<br/>Fairness & Eviction"]
            DataStore["In-Memory Datastore<br/>Endpoints, Models, Metrics"]
            DataLayer["Data Layer<br/>Source/Extractor Pattern"]

            EPP -->|schedules via| Scheduler
            Scheduler -->|queries| DataStore
            EPP -->|admission| FlowControl
            DataLayer -->|feeds| DataStore
        end

        subgraph BBR_Group["Body-Based Router (BBR)"]
            BBR["BBR Server<br/>9004/TCP gRPC ext-proc<br/>9005/TCP gRPC health<br/>9090/TCP metrics"]
            BodyParser["Body Parser<br/>Model Name Extraction"]
            AdapterStore["Adapter Store<br/>LoRA → Base Model Map"]

            BBR -->|parses via| BodyParser
            BodyParser -->|resolves| AdapterStore
        end

        subgraph LatencyPredictor["Latency Predictor (Optional Sidecar)"]
            PredictorClient["Predictor Async Client<br/>Go Library"]
            TrainingServer["Training Server<br/>8000/TCP HTTP<br/>Python"]
            PredictionServer["Prediction Server<br/>8001+/TCP HTTP<br/>Python"]

            PredictorClient -->|submit data| TrainingServer
            PredictorClient -->|query predictions| PredictionServer
        end

        EPP -.->|latency estimates| PredictorClient
    end

    %% External actors
    Client["External Client"] -->|HTTPS/443| Gateway

    %% Gateway integration
    Gateway["Envoy-Compatible Gateway<br/>(Envoy Gateway / kgateway /<br/>Istio / GKE Gateway)"]
    Gateway -->|"gRPC ext-proc<br/>9004/TCP TLS"| BBR
    BBR -->|"headers injected<br/>back to gateway"| Gateway
    Gateway -->|"gRPC ext-proc<br/>9002/TCP TLS"| EPP
    EPP -->|"endpoint selected<br/>back to gateway"| Gateway
    Gateway -->|"forward request"| ModelServers

    %% CRDs
    InferencePoolCR["InferencePool CR"]
    InferenceObjectiveCR["InferenceObjective CR"]
    InferenceModelRewriteCR["InferenceModelRewrite CR"]

    InferencePoolCR -->|watched by| DataStore
    InferenceObjectiveCR -->|watched by| FlowControl
    InferenceModelRewriteCR -->|watched by| DataStore

    %% Model servers
    ModelServers["Model Server Pods<br/>(vLLM / SGLang / Triton)"]
    ModelServers -->|"/metrics scraped by"| DataLayer

    %% ConfigMaps for BBR
    ConfigMaps["ConfigMaps<br/>bbr-managed=true"] -->|watched by| AdapterStore

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    DataStore -->|watch Pods| K8sAPI
    AdapterStore -->|watch ConfigMaps| K8sAPI

    %% Optional dependencies
    Prometheus["Prometheus"] -.->|scrape /metrics| EPP
    OTLP["OTLP Collector<br/>4317/TCP gRPC"] -.->|traces from| EPP

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style Scheduler fill:#5ba3f5,stroke:#333,color:#fff
    style FlowControl fill:#5ba3f5,stroke:#333,color:#fff
    style DataStore fill:#5ba3f5,stroke:#333,color:#fff
    style DataLayer fill:#5ba3f5,stroke:#333,color:#fff
    style BodyParser fill:#5ba3f5,stroke:#333,color:#fff
    style AdapterStore fill:#5ba3f5,stroke:#333,color:#fff
    style PredictorClient fill:#9b59b6,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e67e22,stroke:#333,color:#fff
    style ModelServers fill:#27ae60,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjectiveCR fill:#f5a623,stroke:#333
    style InferenceModelRewriteCR fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
