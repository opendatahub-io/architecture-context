graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Inference Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Gateway API / Envoy Proxy<br/>80/TCP → 8000/TCP<br/>HTTP<br/>ext-proc filter enabled"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph EPPPod["EPP Pod — SA: ${EPP_NAME}"]
            EPP["EPP gRPC ext-proc<br/>9002/TCP gRPC<br/>TLS 1.2+ (configurable)<br/>Auth: None (Envoy trust)"]
            HealthGRPC["gRPC Health<br/>9003/TCP<br/>TLS 1.2+ (configurable)<br/>Auth: None"]
            MetricsSrv["Prometheus Metrics<br/>9090/TCP HTTP<br/>Auth: TokenReview+SAR (opt)"]
            ZMQSub["ZMQ KV-Events SUB<br/>5557/TCP<br/>No encryption"]
            UDSTok["UDS Tokenizer Sidecar<br/>/tmp/tokenizer UDS gRPC<br/>No encryption"]
        end

        subgraph ModelPod["Model Server Pod (vLLM)"]
            ModelInference["vLLM Inference API<br/>8000/TCP HTTP/HTTPS<br/>Configurable TLS"]
            ModelDecoder["vLLM Decoder<br/>8001/TCP HTTP<br/>localhost only"]
            ModelMetrics["vLLM Metrics<br/>3000/TCP HTTP<br/>No auth"]

            subgraph SidecarBox["PD Sidecar (when P/D enabled)"]
                PDProxy["PD Sidecar Proxy<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (--secure-proxy)<br/>Auth: SSRF allowlist<br/>Self-signed RSA 4096"]
            end
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer token"]

        subgraph RemotePods["Remote Model Instances"]
            Prefiller["Prefiller Instances<br/>Dynamic port HTTP/HTTPS<br/>Configurable TLS<br/>SSRF allowlist"]
            Encoder["Encoder Instances<br/>Dynamic port HTTP/HTTPS<br/>Configurable TLS<br/>SSRF allowlist"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>No encryption"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP<br/>Auth: TokenReview+SAR (opt)"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No TLS<br/>No auth"| Gateway

    %% Ingress → EPP (ext-proc)
    Gateway -->|"gRPC/9002<br/>TLS 1.2+<br/>Envoy-internal trust"| EPP

    %% EPP routing decision back to Envoy
    EPP -.->|"ext-proc response<br/>target-endpoint header"| Gateway

    %% Envoy → Model Server (after routing)
    Gateway -->|"HTTP/8000<br/>Configurable TLS<br/>No auth"| ModelInference

    %% Envoy → PD Sidecar (P/D mode)
    Gateway -->|"HTTP(S)/8000<br/>TLS 1.2+<br/>Routing headers"| PDProxy

    %% PD Sidecar → Remote instances
    PDProxy -->|"HTTP(S)/Dynamic<br/>Configurable TLS<br/>SSRF allowlist"| Prefiller
    PDProxy -->|"HTTP(S)/Dynamic<br/>Configurable TLS<br/>SSRF allowlist"| Encoder
    PDProxy -->|"HTTP/8001<br/>No TLS (localhost)<br/>No auth"| ModelDecoder

    %% EPP → K8s API
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer token"| K8sAPI

    %% EPP → Model metrics
    EPP -->|"HTTP/3000<br/>No TLS<br/>No auth"| ModelMetrics

    %% EPP → OTEL
    EPP -.->|"gRPC/4317<br/>OTLP<br/>No auth"| OTEL
    PDProxy -.->|"gRPC/4317<br/>OTLP<br/>No auth"| OTEL

    %% Prometheus → EPP
    Prometheus -.->|"HTTP/9090<br/>Scrape /metrics"| MetricsSrv

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef epp fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef model fill:#7ed321,stroke:#333,stroke-width:2px
    classDef k8s fill:#999,stroke:#333,stroke-width:2px,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,HealthGRPC,MetricsSrv,ZMQSub,UDSTok epp
    class ModelInference,ModelDecoder,ModelMetrics,Prefiller,Encoder model
    class K8sAPI k8s
    class OTEL,Prometheus externalservice
    class PDProxy sidecar
