graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Gateway<br/>80/TCP HTTP<br/>No TLS (dev config)"]
        Envoy["Envoy Proxy<br/>ext_proc filter"]
        Gateway --> Envoy
    end

    subgraph EPPZone["EPP SERVICE ZONE"]
        direction TB

        subgraph EPPPod["EPP Pod — SA: ${EPP_NAME}"]
            ExtProc["ext_proc gRPC Server<br/>9002/TCP gRPC<br/>Optional TLS<br/>No Auth (Envoy-internal)"]
            HealthSvc["Health Server<br/>9003/TCP gRPC<br/>No Encryption"]
            MetricsSvc["Metrics Endpoint<br/>9090/TCP HTTP<br/>No Encryption<br/>Optional TokenReview+SAR"]
            ZMQSvc["ZMQ Listener<br/>5557/TCP<br/>No Encryption<br/>No Auth"]
        end

        subgraph TokenizerPod["UDS Tokenizer Sidecar"]
            Tokenizer["Tokenizer<br/>UDS gRPC<br/>/tmp/tokenizer/<br/>tokenizer-uds.socket"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ModelServerZone["MODEL SERVER ZONE"]
        direction TB

        subgraph vLLMPod["vLLM Model Server Pod"]
            vLLMMetrics["Metrics Endpoint<br/>configurable/TCP<br/>HTTP/HTTPS<br/>⚠ InsecureSkipVerify=true"]
            vLLMZMQ["KV Events Publisher<br/>5556/TCP ZMQ PUB<br/>No Encryption<br/>No Auth"]
            vLLMDecoder["Decoder<br/>8001/TCP HTTP/S<br/>Optional TLS"]
        end

        subgraph SidecarPod["P/D Routing Sidecar"]
            Sidecar["Sidecar Proxy<br/>8000/TCP HTTP/S<br/>TLS 1.2+ (self-signed/provided)<br/>ECDHE+AES-GCM, CHACHA20<br/>SSRF Allowlist"]
        end

        Prefiller["Prefiller Pod<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
        EncoderPod["Encoder Pod (E/P/D)<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>ServiceMonitor 15s<br/>HTTP scrape"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>Optional TLS"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Gateway

    %% Ingress → EPP
    Envoy -->|"gRPC/9002<br/>Optional TLS<br/>No Auth"| ExtProc

    %% Ingress → Model Servers
    Envoy -->|"HTTP/8000<br/>Optional TLS<br/>No Auth"| Sidecar
    Envoy -->|"HTTP/8001<br/>Direct (non-P/D)<br/>No Auth"| vLLMDecoder

    %% EPP → K8s API
    ExtProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% EPP → Model Servers
    ExtProc -->|"HTTP(S)<br/>⚠ InsecureSkipVerify<br/>No Auth"| vLLMMetrics
    ExtProc -->|"ZMQ SUB/5556<br/>No Encryption<br/>No Auth"| vLLMZMQ

    %% Tokenizer
    Tokenizer -.->|"gRPC over UDS<br/>Pod-local"| ExtProc

    %% Sidecar → Model Servers
    Sidecar -->|"HTTP(S)<br/>Optional TLS<br/>SSRF Validated"| Prefiller
    Sidecar -->|"HTTP(S)/8001<br/>Optional TLS"| vLLMDecoder
    Sidecar -->|"HTTP(S)<br/>Optional TLS"| EncoderPod

    %% Sidecar → K8s API
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Observability
    Prometheus -.->|"HTTP/9090<br/>Scrape /metrics"| MetricsSvc
    ExtProc -.->|"gRPC OTLP/4317<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef eppzone fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelzone fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8scontrol fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,Envoy ingress
    class ExtProc,HealthSvc,MetricsSvc,ZMQSvc,Tokenizer eppzone
    class vLLMMetrics,vLLMZMQ,vLLMDecoder,Sidecar,Prefiller,EncoderPod modelzone
    class K8sAPI k8scontrol
    class Prometheus,OTel observability
