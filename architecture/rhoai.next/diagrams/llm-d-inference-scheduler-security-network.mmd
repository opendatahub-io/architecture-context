graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Inference Gateway (Envoy)<br/>80/TCP → HTTPRoute<br/>No TLS (dev config)<br/>No Auth"]
    end

    subgraph EPPZone["EPP SERVICE (Scheduling Tier)"]
        direction TB

        subgraph EPPPorts["EPP (Endpoint Picker)"]
            EPP_ExtProc["ext_proc gRPC<br/>9002/TCP<br/>Optional TLS<br/>No Auth"]
            EPP_Health["Health gRPC<br/>9003/TCP<br/>Plaintext"]
            EPP_Metrics["Metrics HTTP<br/>9090/TCP<br/>Plaintext<br/>Optional TokenReview+SAR"]
            EPP_ZMQ["ZMQ Subscriber<br/>5557/TCP<br/>Plaintext"]
        end

        EPPInfo["SA: ${EPP_NAME}<br/>NS: ${NAMESPACE}<br/>Image: odh-llm-d-inference-scheduler<br/>FIPS: ⚠️ No strictfipsruntime"]
    end

    subgraph SidecarZone["P/D SIDECAR (Pod-Local)"]
        Sidecar["P/D Routing Sidecar<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (self-signed or provided)<br/>Ciphers: ECDHE+AES-GCM, CHACHA20<br/>SSRF: InferencePool allowlist<br/>FIPS: ✅ strictfipsruntime"]
    end

    subgraph TokenizerZone["UDS TOKENIZER (Pod-Local)"]
        Tokenizer["UDS Tokenizer<br/>Unix Socket<br/>/tmp/tokenizer/tokenizer-uds.socket<br/>No Auth (filesystem ACL)"]
    end

    subgraph K8sZone["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph ModelServerZone["MODEL SERVERS (vLLM Pods)"]
        vLLM_Metrics["vLLM Metrics<br/>configurable/TCP<br/>HTTP/HTTPS<br/>⚠️ InsecureSkipVerify=true"]
        vLLM_KV["vLLM KV Events<br/>5556/TCP ZMQ PUB<br/>⚠️ No encryption<br/>⚠️ No auth"]
        vLLM_Prefill["Prefiller Pod<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
        vLLM_Decode["Decoder (local)<br/>8001/TCP<br/>HTTP/HTTPS<br/>Optional TLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor 15s<br/>HTTP scrape"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>Optional TLS"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Gateway

    %% Ingress → EPP
    Gateway -->|"gRPC ext_proc/9002<br/>Optional TLS<br/>No Auth (Envoy-internal)"| EPP_ExtProc

    %% EPP → Kubernetes
    EPP_ExtProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% EPP → Model Servers
    EPP_ExtProc -->|"HTTP/var<br/>⚠️ InsecureSkipVerify=true"| vLLM_Metrics
    vLLM_KV -->|"ZMQ/5556<br/>⚠️ Plaintext<br/>⚠️ No Auth"| EPP_ZMQ

    %% Tokenizer → EPP
    Tokenizer -.->|"gRPC/UDS<br/>No Auth"| EPP_ExtProc

    %% Gateway → Model Servers (direct routing)
    Gateway -->|"HTTP/8000<br/>Routed by EPP"| vLLM_Decode

    %% Gateway → Sidecar (P/D mode)
    Gateway -->|"HTTP-HTTPS/8000<br/>TLS 1.2+"| Sidecar

    %% Sidecar → Model Servers
    Sidecar -->|"HTTP-HTTPS/var<br/>Optional TLS<br/>SSRF validated"| vLLM_Prefill
    Sidecar -->|"HTTP-HTTPS/8001<br/>Optional TLS"| vLLM_Decode

    %% Sidecar → K8s (allowlist)
    Sidecar -->|"HTTPS/443<br/>SA Token<br/>Watch InferencePool"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/9090<br/>Plaintext<br/>Optional Auth"| EPP_Metrics
    EPP_ExtProc -.->|"gRPC OTLP/4317<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef eppzone fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef sidecarzone fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8szone fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef modelserver fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#ffcccc,stroke:#cc0000,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP_ExtProc,EPP_Health,EPP_Metrics,EPP_ZMQ,EPPInfo eppzone
    class Sidecar sidecarzone
    class Tokenizer sidecarzone
    class K8sAPI k8szone
    class vLLM_Metrics,vLLM_KV,vLLM_Prefill,vLLM_Decode modelserver
    class Prometheus,OTel monitoring
