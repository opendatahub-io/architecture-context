graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Envoy Gateway<br/>80/TCP → 8000/TCP<br/>Envoy v1.37+<br/>ext-proc filter"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_EPP["EPP Deployment (${NAMESPACE})"]
            EPP["EPP (Endpoint Picker)<br/>SA: ${EPP_NAME}<br/>Image: odh-llm-d-inference-scheduler"]
            EPP_ExtProc["ext-proc: 9002/TCP gRPC<br/>TLS 1.2+ (configurable)"]
            EPP_Health["Health: 9003/TCP gRPC<br/>TLS 1.2+ (configurable)"]
            EPP_Metrics["Metrics: 9090/TCP HTTP<br/>Auth: TokenReview (optional)"]
            EPP_ZMQ["ZMQ: 5557/TCP<br/>Plaintext"]
            UDS["UDS Tokenizer Sidecar<br/>/tmp/tokenizer (UDS)<br/>gRPC, No encryption"]
        end

        subgraph NS_ModelPod["Model Server Pod"]
            PD["PD Sidecar Proxy<br/>Image: odh-llm-d-routing-sidecar"]
            PD_Proxy["Proxy: 8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (configurable)<br/>SSRF allowlist"]
            PD_Decoder["Decoder: 8001/TCP HTTP<br/>localhost only"]
            vLLM["Local vLLM Decoder"]
        end

        subgraph ModelServers["vLLM Model Servers"]
            MS_Metrics["Metrics: 3000/TCP<br/>HTTP/HTTPS"]
            MS_Inference["Inference: 8000/TCP<br/>HTTP"]
        end

        Prefiller["Prefiller Instances<br/>Dynamic port HTTP/HTTPS<br/>SSRF allowlist required"]
        Encoder["Encoder Instances<br/>Dynamic port HTTP/HTTPS<br/>SSRF allowlist required"]

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP<br/>Auth: Optional TokenReview"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>No encryption"]
    end

    %% External flows
    Client -->|"HTTP/80<br/>No encryption<br/>No auth"| Gateway

    %% Gateway to EPP (ext-proc)
    Gateway -->|"gRPC/9002<br/>TLS 1.2+<br/>Envoy-internal trust"| EPP_ExtProc

    %% Gateway to backends
    Gateway -->|"HTTP/8000<br/>Routed by EPP decision"| MS_Inference
    Gateway -->|"HTTP/HTTPS 8000<br/>TLS 1.2+ (configurable)"| PD_Proxy

    %% EPP internal
    EPP -->|"gRPC over UDS<br/>/tmp/tokenizer<br/>No encryption"| UDS
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    EPP -->|"HTTP/3000<br/>Configurable scheme<br/>No auth"| MS_Metrics
    EPP_ZMQ -->|"ZMQ SUB/5557<br/>Plaintext TCP"| MS_Metrics

    %% PD Sidecar flows
    PD_Proxy -->|"HTTP/8001<br/>localhost only<br/>No encryption"| vLLM
    PD_Proxy -->|"HTTP/HTTPS Dynamic<br/>TLS configurable<br/>SSRF allowlist"| Prefiller
    PD_Proxy -->|"HTTP/HTTPS Dynamic<br/>TLS configurable<br/>SSRF allowlist"| Encoder

    %% PD Sidecar to K8s (for SSRF allowlist)
    PD -->|"HTTPS/443<br/>SA Token<br/>Watch InferencePool"| K8sAPI

    %% Observability
    Prometheus -->|"HTTP/9090<br/>Optional auth"| EPP_Metrics
    EPP -->|"gRPC/4317<br/>OTLP<br/>No encryption"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,EPP_ExtProc,EPP_Health,EPP_Metrics,EPP_ZMQ,UDS clusterinternal
    class PD,PD_Proxy,PD_Decoder,vLLM clusterinternal
    class MS_Metrics,MS_Inference clusterinternal
    class Prefiller,Encoder clusterinternal
    class K8sAPI externalservice
    class Prometheus,OTel observability
