graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        EnvoyGW["Envoy Gateway<br/>80/TCP → HTTPRoute<br/>ext-proc filter configured"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL"]
        direction TB

        subgraph EPP_Pod["EPP Pod — SA: ${EPP_NAME}"]
            EPPServer["EPP ext-proc Server<br/>9002/TCP gRPC TLS<br/>9003/TCP gRPC Health<br/>9090/TCP HTTP Metrics<br/>Image: odh-llm-d-inference-scheduler"]
            UDSTokenizer["UDS Tokenizer Sidecar<br/>/tmp/tokenizer UDS"]
        end

        subgraph ModelPod["Model Server Pod (P/D enabled)"]
            PDSidecar["PD Sidecar Proxy<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ ECDHE+ChaCha20/AES-GCM<br/>FIPS: strictfipsruntime<br/>Image: odh-llm-d-routing-sidecar"]
            vLLMDecoder["vLLM Decoder<br/>8001/TCP HTTP<br/>(localhost)"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
        KVCache["llm-d-kv-cache<br/>5557/TCP ZMQ<br/>No encryption"]
        ModelMetrics["Model Server /metrics<br/>HTTP/HTTPS<br/>InsecureSkipVerify option"]
    end

    subgraph RemotePods["REMOTE MODEL PODS"]
        Prefiller["Remote Prefiller Pods<br/>HTTP/HTTPS<br/>TLS configurable"]
        Encoder["Remote Encoder Pods<br/>HTTP/HTTPS<br/>TLS configurable"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No encryption (dev)"| EnvoyGW

    %% Ingress → EPP
    EnvoyGW -->|"gRPC/9002<br/>TLS (self-signed/provided)<br/>No auth (cluster-internal)"| EPPServer

    %% EPP routing decision back to Envoy
    EPPServer -.->|"routing decision<br/>target-pod header"| EnvoyGW

    %% Envoy → Model Pod
    EnvoyGW -->|"HTTP/8000<br/>routed request"| PDSidecar

    %% EPP → Platform Services
    EPPServer -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    EPPServer -->|"ZMQ SUB/5557<br/>No encryption"| KVCache
    EPPServer -->|"HTTP(S)<br/>InsecureSkipVerify"| ModelMetrics

    %% EPP → Monitoring
    EPPServer -->|"gRPC/4317<br/>No encryption"| OTLP
    Prometheus -->|"HTTP/9090<br/>TokenReview/SAR"| EPPServer

    %% PD Sidecar flows
    PDSidecar -->|"HTTP/8001<br/>No encryption<br/>localhost"| vLLMDecoder
    PDSidecar -->|"HTTP(S)<br/>TLS configurable<br/>SSRF allowlist"| Prefiller
    PDSidecar -->|"HTTP(S)<br/>TLS configurable<br/>SSRF allowlist"| Encoder

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterint fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class EnvoyGW ingress
    class EPPServer,UDSTokenizer,PDSidecar,vLLMDecoder clusterint
    class Prometheus,OTLP monitoring
    class K8sAPI,KVCache,ModelMetrics platform
    class Prefiller,Encoder remote
