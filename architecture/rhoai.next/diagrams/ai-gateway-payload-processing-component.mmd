graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph AIGateway["AI Gateway (Istio Gateway)"]
        Envoy["Envoy Proxy<br/>EnvoyFilter ext_proc"]
    end

    subgraph PayloadProcessing["AI Gateway Payload Processing"]
        direction TB

        subgraph ExtProc["ext_proc gRPC Service (9004/TCP)"]
            direction TB
            HeadersGuard["maas-headers-guard<br/>Strip x-maas-* headers"]
            ModelResolver["model-provider-resolver<br/>Resolve model → provider"]
            APITranslation["api-translation<br/>OpenAI ↔ Provider format"]
            APIKeyInjection["apikey-injection<br/>Inject credentials"]
            NemoReqGuard["nemo-request-guard<br/>(optional)"]
            NemoRespGuard["nemo-response-guard<br/>(optional)"]

            HeadersGuard --> ModelResolver
            ModelResolver --> APITranslation
            APITranslation --> APIKeyInjection
            NemoReqGuard -.->|optional| HeadersGuard
            NemoRespGuard -.->|optional| APITranslation
        end

        subgraph Controllers["Kubernetes Controllers"]
            EPController["ExternalProvider<br/>Controller"]
            EMController["ExternalModel<br/>Controller"]
            LegacyController["Legacy Migration<br/>Controller"]
        end

        HealthCheck["Health Check<br/>9005/TCP /healthz"]
    end

    subgraph CRDs["Custom Resources"]
        ExternalModelCR["ExternalModel CR<br/>inference.opendatahub.io/v1alpha1"]
        ExternalProviderCR["ExternalProvider CR<br/>inference.opendatahub.io/v1alpha1"]
        LegacyModelCR["ExternalModel CR<br/>maas.opendatahub.io/v1alpha1<br/>(legacy)"]
    end

    subgraph K8sResources["Created Resources"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
        SvcEntry["ServiceEntry<br/>(Istio MESH_EXTERNAL)"]
        DestRule["DestinationRule<br/>(TLS SIMPLE)"]
        ExtNameSvc["ExternalName Service"]
    end

    subgraph Providers["External LLM Providers"]
        OpenAI["OpenAI<br/>api.openai.com"]
        Anthropic["Anthropic<br/>api.anthropic.com"]
        Azure["Azure OpenAI<br/>{resource}.openai.azure.com"]
        Bedrock["AWS Bedrock<br/>bedrock-runtime.{region}.amazonaws.com"]
        VertexAI["Google Vertex AI<br/>aiplatform.googleapis.com"]
    end

    K8sAPI["Kubernetes API Server"]
    NeMo["NeMo Guardrails<br/>(optional)"]
    Secrets["Kubernetes Secrets<br/>(provider credentials)"]

    %% Client flow
    Client -->|HTTPS/443| Envoy
    Envoy -->|gRPC/9004<br/>mTLS| ExtProc

    %% Controller watches
    ExternalProviderCR -->|watched by| EPController
    ExternalModelCR -->|watched by| EMController
    LegacyModelCR -->|watched by| LegacyController

    %% Controller creates
    EPController -->|creates| ExtNameSvc
    EPController -->|creates| SvcEntry
    EPController -->|creates| DestRule
    EMController -->|creates| HTTPRoute
    LegacyController -->|migrates to| ExternalModelCR
    LegacyController -->|migrates to| ExternalProviderCR

    %% Plugin dependencies
    ModelResolver -->|reads from| ExternalModelCR
    ModelResolver -->|reads from| ExternalProviderCR
    APIKeyInjection -->|reads from| Secrets
    NemoReqGuard -.->|HTTP POST| NeMo
    NemoRespGuard -.->|HTTP POST| NeMo

    %% Egress via mesh
    Envoy -->|HTTPS/443<br/>TLS via DestRule| OpenAI
    Envoy -->|HTTPS/443<br/>TLS via DestRule| Anthropic
    Envoy -->|HTTPS/443<br/>TLS via DestRule| Azure
    Envoy -->|HTTPS/443<br/>TLS via DestRule| Bedrock
    Envoy -->|HTTPS/443<br/>TLS via DestRule| VertexAI

    %% K8s API
    Controllers -->|HTTPS/443| K8sAPI

    %% Styling
    style ExtProc fill:#4a90e2,stroke:#2c5d8f,color:#fff
    style HeadersGuard fill:#5ba3f5,stroke:#2c5d8f,color:#fff
    style ModelResolver fill:#5ba3f5,stroke:#2c5d8f,color:#fff
    style APITranslation fill:#5ba3f5,stroke:#2c5d8f,color:#fff
    style APIKeyInjection fill:#5ba3f5,stroke:#2c5d8f,color:#fff
    style NemoReqGuard fill:#7bb8f7,stroke:#2c5d8f,color:#fff
    style NemoRespGuard fill:#7bb8f7,stroke:#2c5d8f,color:#fff
    style EPController fill:#4a90e2,stroke:#2c5d8f,color:#fff
    style EMController fill:#4a90e2,stroke:#2c5d8f,color:#fff
    style LegacyController fill:#4a90e2,stroke:#2c5d8f,color:#fff
    style ExternalModelCR fill:#f5a623,stroke:#c7841a
    style ExternalProviderCR fill:#f5a623,stroke:#c7841a
    style LegacyModelCR fill:#f5a623,stroke:#c7841a
    style HTTPRoute fill:#7ed321,stroke:#5a9a17
    style SvcEntry fill:#7ed321,stroke:#5a9a17
    style DestRule fill:#7ed321,stroke:#5a9a17
    style ExtNameSvc fill:#7ed321,stroke:#5a9a17
    style OpenAI fill:#e8e8e8,stroke:#999
    style Anthropic fill:#e8e8e8,stroke:#999
    style Azure fill:#e8e8e8,stroke:#999
    style Bedrock fill:#e8e8e8,stroke:#999
    style VertexAI fill:#e8e8e8,stroke:#999
