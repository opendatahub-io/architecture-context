graph TB
    subgraph BBR["AI Gateway Payload Processing (BBR Plugin Host)"]
        direction TB

        subgraph PluginPipeline["Plugin Pipeline (ext_proc)"]
            direction LR
            ModelResolver["model-provider-resolver<br/>RequestProcessor"]
            APITranslation["api-translation<br/>Req + Resp Processor"]
            APIKeyInjection["apikey-injection<br/>RequestProcessor"]
            NemoReqGuard["nemo-request-guard<br/>RequestProcessor"]
            NemoRespGuard["nemo-response-guard<br/>ResponseProcessor"]
        end

        subgraph Controllers["Kubernetes Controllers"]
            direction LR
            EMController["ExternalModel<br/>Controller"]
            EPController["ExternalProvider<br/>Controller"]
        end
    end

    %% CRDs
    ExternalModelCR["ExternalModel CR<br/>(inference.opendatahub.io/v1alpha1)"]
    ExternalProviderCR["ExternalProvider CR<br/>(inference.opendatahub.io/v1alpha1)"]
    MaaSModelCR["ExternalModel CR<br/>(maas.opendatahub.io)"]

    %% Created Resources
    HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    ExtNameSvc["ExternalName Service"]
    ServiceEntry["Istio ServiceEntry"]
    DestRule["Istio DestinationRule"]

    %% External Systems
    Envoy["Istio Gateway<br/>(Envoy)"]
    K8sAPI["Kubernetes API"]
    Secrets["Kubernetes Secrets<br/>(labeled)"]
    NeMo["NeMo Guardrails<br/>(optional)"]

    %% External Providers
    Providers["External LLM Providers<br/>(OpenAI, Anthropic, Azure,<br/>Bedrock, Vertex AI)"]

    %% Connections - Plugin Pipeline
    Envoy -->|"gRPC ext_proc<br/>9004/TCP"| PluginPipeline
    ModelResolver -->|"reads model mapping"| MaaSModelCR
    APIKeyInjection -->|"reads API keys"| Secrets
    NemoReqGuard -->|"HTTP POST"| NeMo
    NemoRespGuard -->|"HTTP POST"| NeMo

    %% Connections - Controllers
    ExternalModelCR -->|"watched by"| EMController
    ExternalProviderCR -->|"watched by"| EPController
    EMController -->|"creates"| HTTPRoute
    EPController -->|"creates"| ExtNameSvc
    EPController -->|"creates"| ServiceEntry
    EPController -->|"creates"| DestRule
    EMController -->|"validates"| K8sAPI
    EPController -->|"validates"| K8sAPI

    %% Traffic Flow
    HTTPRoute -->|"references"| Envoy
    Envoy -->|"routes via mesh"| Providers

    %% Styling
    style BBR fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PluginPipeline fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Controllers fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style ModelResolver fill:#4a90e2,color:#fff
    style APITranslation fill:#4a90e2,color:#fff
    style APIKeyInjection fill:#4a90e2,color:#fff
    style NemoReqGuard fill:#4a90e2,color:#fff
    style NemoRespGuard fill:#4a90e2,color:#fff
    style EMController fill:#4a90e2,color:#fff
    style EPController fill:#4a90e2,color:#fff
    style ExternalModelCR fill:#f5a623,color:#fff
    style ExternalProviderCR fill:#f5a623,color:#fff
    style MaaSModelCR fill:#f5a623,color:#fff
    style HTTPRoute fill:#7ed321,color:#fff
    style ExtNameSvc fill:#7ed321,color:#fff
    style ServiceEntry fill:#7ed321,color:#fff
    style DestRule fill:#7ed321,color:#fff
    style Envoy fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Secrets fill:#e8e8e8,stroke:#999
    style NeMo fill:#e8e8e8,stroke:#999
    style Providers fill:#f9f,stroke:#333
