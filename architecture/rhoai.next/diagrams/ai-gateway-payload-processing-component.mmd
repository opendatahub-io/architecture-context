graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph GatewayAPI["Gateway API Data Plane"]
        Gateway["Gateway API Gateway<br/>(Envoy Proxy)<br/>443/TCP HTTPS"]
        EnvoyFilter["Istio EnvoyFilter<br/>(attaches ExtProc)"]
        Gateway --- EnvoyFilter
    end

    subgraph PayloadProcessing["AI Gateway Payload Processing<br/>(BBR ExtProc Host - 9004/TCP gRPC)"]
        direction TB

        subgraph PluginPipeline["Plugin Pipeline (ordered)"]
            direction TB
            ModelExtractor["body-field-to-header<br/>(upstream plugin)<br/>Extracts model field →<br/>X-Gateway-Model-Name header"]
            ModelResolver["model-provider-resolver<br/>(RequestProcessor)<br/>Resolves model name →<br/>provider/credentials in CycleState"]
            APITranslation["api-translation<br/>(Request + ResponseProcessor)<br/>OpenAI ↔ Provider format<br/>(Anthropic, Azure, Bedrock, Vertex)"]
            APIKeyInjection["apikey-injection<br/>(RequestProcessor)<br/>Injects provider auth headers<br/>from cached Secrets"]
            NemoRequest["nemo-request-guard<br/>(RequestProcessor)<br/>Input content policy enforcement"]
            NemoResponse["nemo-response-guard<br/>(ResponseProcessor)<br/>Output content policy enforcement"]

            ModelExtractor --> ModelResolver
            ModelResolver --> APITranslation
            APITranslation --> APIKeyInjection
            APIKeyInjection --> NemoRequest
            NemoRequest --> NemoResponse
        end

        CycleState["CycleState<br/>(per-request shared memory)"]
        HealthCheck["Health Check<br/>9005/TCP HTTP"]
    end

    subgraph CRDs["Custom Resource Definitions"]
        ExternalModel["ExternalModel CR<br/>inference.opendatahub.io/v1alpha1"]
        ExternalProvider["ExternalProvider CR<br/>inference.opendatahub.io/v1alpha1"]
    end

    subgraph K8sResources["Kubernetes Resources"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
        Secrets["Labeled Secrets<br/>inference.networking.k8s.io/<br/>bbr-managed=true"]
    end

    subgraph LLMProviders["External LLM Providers (443/TCP HTTPS)"]
        OpenAI["OpenAI<br/>api.openai.com"]
        Anthropic["Anthropic<br/>api.anthropic.com"]
        AzureOpenAI["Azure OpenAI"]
        Bedrock["AWS Bedrock<br/>bedrock.amazonaws.com"]
        VertexAI["Google Vertex AI<br/>aiplatform.googleapis.com"]
    end

    NemoService["NeMo Guardrails Service<br/>HTTP (configurable port)<br/>/v1/guardrail/checks"]

    %% Request flow
    Client -->|"HTTPS/443"| Gateway
    Gateway -->|"gRPC ExtProc/9004<br/>plaintext"| ModelExtractor
    NemoResponse -->|"gRPC response/9004<br/>mutated request"| Gateway

    %% CRD watches
    ModelResolver -->|"watches"| ExternalModel
    ExternalModel -.->|"references"| ExternalProvider
    ModelResolver -->|"controller-runtime<br/>watch/list"| K8sAPI

    %% Secret watches
    APIKeyInjection -->|"watches labeled"| Secrets
    APIKeyInjection -->|"controller-runtime<br/>watch/list"| K8sAPI

    %% CycleState sharing
    ModelResolver -.->|"writes provider info"| CycleState
    APITranslation -.->|"reads provider info"| CycleState
    APIKeyInjection -.->|"reads credential refs"| CycleState

    %% Egress to providers (via Envoy)
    Gateway -->|"HTTPS/443"| OpenAI
    Gateway -->|"HTTPS/443"| Anthropic
    Gateway -->|"HTTPS/443"| AzureOpenAI
    Gateway -->|"HTTPS/443"| Bedrock
    Gateway -->|"HTTPS/443"| VertexAI

    %% NeMo calls
    NemoRequest -->|"HTTP POST"| NemoService
    NemoResponse -->|"HTTP POST"| NemoService

    %% Styling
    style PayloadProcessing fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ModelExtractor fill:#6bb3f0,stroke:#333
    style ModelResolver fill:#6bb3f0,stroke:#333
    style APITranslation fill:#6bb3f0,stroke:#333
    style APIKeyInjection fill:#6bb3f0,stroke:#333
    style NemoRequest fill:#6bb3f0,stroke:#333
    style NemoResponse fill:#6bb3f0,stroke:#333
    style CycleState fill:#b8d4f0,stroke:#333
    style HealthCheck fill:#b8d4f0,stroke:#333
    style ExternalModel fill:#f5a623,stroke:#333
    style ExternalProvider fill:#f5a623,stroke:#333
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style EnvoyFilter fill:#ffe6cc,stroke:#d79b00
    style OpenAI fill:#999,stroke:#333
    style Anthropic fill:#999,stroke:#333
    style AzureOpenAI fill:#999,stroke:#333
    style Bedrock fill:#999,stroke:#333
    style VertexAI fill:#999,stroke:#333
    style NemoService fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Secrets fill:#e8e8e8,stroke:#333
