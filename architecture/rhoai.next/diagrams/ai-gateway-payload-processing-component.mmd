graph TB
    subgraph BBRService["AI Gateway Payload Processing<br/>(BBR ext_proc Host)"]
        direction TB

        subgraph PluginChain["Plugin Chain (ordered)"]
            direction LR
            BodyFieldToHeader["body-field-to-header<br/>(upstream)<br/>Extracts model name<br/>→ X-Gateway-Model-Name"]
            ModelProviderResolver["model-provider-resolver<br/>Resolves model →<br/>provider + credentials"]
            APITranslation["api-translation<br/>OpenAI ↔ Provider<br/>format translation"]
            APIKeyInjection["apikey-injection<br/>Injects provider<br/>auth headers"]
        end

        subgraph GuardPlugins["Guard Plugins (optional)"]
            NemoRequestGuard["nemo-request-guard<br/>Input content rails"]
            NemoResponseGuard["nemo-response-guard<br/>Output content rails"]
        end

        subgraph Reconcilers["Controller-Runtime Reconcilers"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
            SecretReconciler["Secret<br/>Reconciler"]
        end

        subgraph InMemoryStores["In-Memory Stores (RWMutex)"]
            ModelInfoStore["modelInfoStore<br/>model → provider mapping"]
            SecretStore["secretStore<br/>API keys cache"]
        end

        BodyFieldToHeader --> ModelProviderResolver
        ModelProviderResolver --> APITranslation
        APITranslation --> APIKeyInjection

        ExternalModelReconciler -->|populates| ModelInfoStore
        SecretReconciler -->|populates| SecretStore
        ModelProviderResolver -->|reads| ModelInfoStore
        APIKeyInjection -->|reads| SecretStore
    end

    %% External Inputs
    Client[Client] -->|HTTPS/443| IstioGateway["Istio Gateway<br/>(Envoy Proxy)"]
    IstioGateway -->|gRPC ext_proc<br/>9004/TCP| BBRService

    %% CRD Watches
    ExternalModelCR["ExternalModel CR<br/>(maas.opendatahub.io/v1alpha1)"] -->|watched by| ExternalModelReconciler
    LabeledSecrets["Kubernetes Secrets<br/>(bbr-managed=true)"] -->|watched by| SecretReconciler

    %% Guard Egress
    NemoRequestGuard -->|HTTP POST<br/>/v1/guardrail/checks| NemoService["NeMo Guardrails<br/>Service"]
    NemoResponseGuard -->|HTTP POST<br/>/v1/guardrail/checks| NemoService

    %% Provider Egress (via Gateway)
    IstioGateway -->|HTTPS/443<br/>API key injected| Providers["Cloud Providers<br/>(OpenAI, Anthropic, Azure,<br/>Bedrock, Vertex AI)"]

    %% K8s API
    ExternalModelReconciler -->|Watch| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    SecretReconciler -->|Watch| K8sAPI

    %% MaaS dependency
    MaaS["models-as-a-service<br/>(MaaS)"] -->|creates| ExternalModelCR

    %% Styling
    style BBRService fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PluginChain fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style GuardPlugins fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Reconcilers fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style InMemoryStores fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style BodyFieldToHeader fill:#dae8fc,stroke:#6c8ebf
    style ModelProviderResolver fill:#dae8fc,stroke:#6c8ebf
    style APITranslation fill:#dae8fc,stroke:#6c8ebf
    style APIKeyInjection fill:#dae8fc,stroke:#6c8ebf
    style NemoRequestGuard fill:#fff2cc,stroke:#d6b656
    style NemoResponseGuard fill:#fff2cc,stroke:#d6b656
    style IstioGateway fill:#ffe6cc,stroke:#d79b00
    style Client fill:#f9f9f9,stroke:#999
    style ExternalModelCR fill:#f5a623,stroke:#333
    style LabeledSecrets fill:#f5a623,stroke:#333
    style NemoService fill:#e8e8e8,stroke:#999
    style Providers fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style MaaS fill:#7ed321,stroke:#333
