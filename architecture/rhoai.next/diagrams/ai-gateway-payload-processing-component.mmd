graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph IstioGW["Istio Gateway"]
        Envoy["Envoy Proxy<br/>443/TCP HTTPS"]
    end

    subgraph BBR["AI Gateway Payload Processing (BBR ext_proc)"]
        direction TB
        BodyFieldToHeader["body-field-to-header<br/>(upstream plugin)"]
        ModelProviderResolver["model-provider-resolver<br/>plugin"]
        APITranslation["api-translation<br/>plugin"]
        APIKeyInjection["apikey-injection<br/>plugin"]
        NemoRequestGuard["nemo-request-guard<br/>plugin"]
        NemoResponseGuard["nemo-response-guard<br/>plugin"]

        subgraph Stores["In-Memory Stores"]
            ModelInfoStore["modelInfoStore<br/>(ExternalModel cache)"]
            SecretStore["secretStore<br/>(API key cache)"]
        end

        subgraph Reconcilers["Controller-Runtime Reconcilers"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
            SecretReconciler["Secret<br/>Reconciler"]
        end

        BodyFieldToHeader -->|"X-Gateway-Model-Name header"| ModelProviderResolver
        ModelProviderResolver -->|"CycleState: provider, model"| APITranslation
        APITranslation -->|"CycleState: translated body"| APIKeyInjection

        ModelProviderResolver -->|reads| ModelInfoStore
        APIKeyInjection -->|reads| SecretStore
        ExternalModelReconciler -->|populates| ModelInfoStore
        SecretReconciler -->|populates| SecretStore
    end

    subgraph K8sAPI["Kubernetes API Server"]
        ExternalModelCR["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]
        Secrets["Secrets<br/>(bbr-managed=true)"]
    end

    subgraph Providers["External Model Providers"]
        OpenAI["OpenAI API"]
        Anthropic["Anthropic API"]
        Azure["Azure OpenAI"]
        Bedrock["AWS Bedrock"]
        Vertex["Google Vertex AI"]
    end

    subgraph NemoService["NeMo Guardrails Service"]
        NemoAPI["NeMo API<br/>/v1/guardrail/checks"]
    end

    Client -->|"HTTPS/443"| Envoy
    Envoy -->|"gRPC ext_proc/9004"| BodyFieldToHeader
    NemoRequestGuard -->|"HTTP POST"| NemoAPI
    NemoResponseGuard -->|"HTTP POST"| NemoAPI
    ExternalModelReconciler -->|"HTTPS/443<br/>Watch"| ExternalModelCR
    SecretReconciler -->|"HTTPS/443<br/>Watch"| Secrets
    Envoy -->|"HTTPS/443<br/>API key injected"| Providers

    style BBR fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style BodyFieldToHeader fill:#999,stroke:#333
    style ModelProviderResolver fill:#4a90e2,stroke:#333,color:#fff
    style APITranslation fill:#4a90e2,stroke:#333,color:#fff
    style APIKeyInjection fill:#4a90e2,stroke:#333,color:#fff
    style NemoRequestGuard fill:#9b59b6,stroke:#333,color:#fff
    style NemoResponseGuard fill:#9b59b6,stroke:#333,color:#fff
    style ModelInfoStore fill:#f5a623,stroke:#333
    style SecretStore fill:#f5a623,stroke:#333
    style ExternalModelReconciler fill:#7ed321,stroke:#333
    style SecretReconciler fill:#7ed321,stroke:#333
    style Envoy fill:#ffe6cc,stroke:#d79b00
    style ExternalModelCR fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style NemoAPI fill:#e1d5e7,stroke:#9673a6
