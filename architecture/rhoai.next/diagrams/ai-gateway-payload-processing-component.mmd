    style ExtProc fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style PluginPipeline fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px
    style ModelExtractor fill:#4a90e2,color:#fff
    style ModelResolver fill:#4a90e2,color:#fff
    style APITranslation fill:#4a90e2,color:#fff
    style APIKeyInjection fill:#4a90e2,color:#fff
