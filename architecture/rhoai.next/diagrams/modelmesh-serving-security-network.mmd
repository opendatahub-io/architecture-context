graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph CtrlNS["Controller Namespace"]
            Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Webhook: 9443/TCP HTTPS"]
        end

        subgraph ModelNS["User / Model Namespace"]
            subgraph RuntimePod["Runtime Pod"]
                direction TB
                OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>TLS: model-serving-proxy-tls<br/>Auth: OAuth Bearer Token<br/>Enforcement: OpenShift SAR"]
                RESTProxy["REST Proxy<br/>8008/TCP HTTP<br/>No encryption<br/>No auth (pod-internal)"]
                MMesh["ModelMesh (mm)<br/>8033/TCP gRPC<br/>Optional TLS/mTLS<br/>Metrics: 2112/TCP HTTPS"]
                PullerSidecar["Puller Sidecar<br/>8086/TCP gRPC<br/>No encryption (pod-internal)"]
                RuntimeSvr["Runtime Container<br/>(model server)"]
            end
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount token"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd Cluster<br/>2379/TCP gRPC<br/>Optional TLS/mTLS<br/>Auth: username/password<br/>(from Secret)"]
        S3["Object Storage (S3/MinIO)<br/>443/TCP HTTPS TLS<br/>Auth: AWS IAM / access key<br/>(from storage-config Secret)"]
        OSAuth["OpenShift OAuth<br/>Token validation<br/>via oauth-proxy"]
    end

    %% External flows
    Client -->|"gRPC/8033<br/>Optional TLS/mTLS"| MMesh
    Client -->|"HTTPS/8443<br/>TLS<br/>OAuth Bearer Token"| OAuthProxy

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8008<br/>No encryption<br/>Pre-authenticated"| RESTProxy
    RESTProxy -->|"gRPC/8033<br/>Pod-internal"| MMesh
    MMesh -->|"UDS/localhost<br/>Pod-internal"| RuntimeSvr
    MMesh -->|"gRPC/8086<br/>Pod-internal"| PullerSidecar

    %% Controller flows
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    Controller -->|"gRPC/8033<br/>Optional TLS"| MMesh

    %% Egress flows
    Controller -->|"gRPC/2379<br/>Optional TLS/mTLS<br/>username/password"| etcd
    MMesh -->|"gRPC/2379<br/>Optional TLS/mTLS<br/>username/password"| etcd
    PullerSidecar -->|"HTTPS/443<br/>TLS<br/>access key/secret"| S3
    OAuthProxy -->|"Token validation"| OSAuth

    %% Monitoring
    Prometheus -->|"Scrape HTTPS/2112"| MMesh
    Prometheus -->|"Scrape HTTP/8080"| Controller

    %% Webhook
    K8sAPI -->|"HTTPS/9443<br/>Admission webhook"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infra fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Controller controller
    class OAuthProxy,RESTProxy,MMesh,PullerSidecar,RuntimeSvr runtime
    class etcd,S3,OSAuth externalservice
    class K8sAPI,Prometheus infra
