graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        ClientGRPC["gRPC Client"]
        ClientREST["REST Client"]
    end

    subgraph ServingPod["MODELMESH SERVING POD<br/>Namespace: user-namespace<br/>SA: modelmesh-serving-sa<br/>SCC: restricted"]
        direction TB

        OAuthProxy["oauth-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS (serving-cert-signer)<br/>OAuth token + SAR"]

        RESTProxy["REST Proxy Sidecar<br/>8008/TCP HTTP<br/>REST→gRPC translation"]

        MM["ModelMesh Container<br/>8033/TCP gRPC<br/>Optional TLS/mTLS<br/>2112/TCP metrics"]

        RuntimeC["Runtime Container<br/>(Triton/MLServer/OVMS/TorchServe)"]

        PullerC["Puller Sidecar<br/>8086/TCP gRPC<br/>Model download"]

        AdapterC["Built-in Adapter<br/>8085/TCP gRPC"]

        OAuthProxy -->|"HTTP/8008<br/>localhost<br/>pre-authenticated"| RESTProxy
        RESTProxy -->|"gRPC/8033<br/>Optional TLS<br/>localhost"| MM
        MM -->|"gRPC<br/>localhost/UDS<br/>No encryption"| RuntimeC
        PullerC -->|"gRPC/8085<br/>localhost"| AdapterC
        AdapterC -->|"manages models"| RuntimeC
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE<br/>Namespace: opendatahub<br/>SA: modelmesh-controller"]
        direction TB

        Controller["modelmesh-controller<br/>8080/TCP metrics<br/>8081/TCP probes<br/>9999/TCP pprof (Basic Auth)"]

        WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS (cert-manager)<br/>Admission validation"]

        EventStreamC["ModelMesh Event Stream<br/>etcd watcher<br/>→ GenericEvent dispatch"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcdC["etcd Cluster<br/>2379/TCP gRPC<br/>Optional TLS/mTLS<br/>Username/password or client certs"]

        K8sAPIc["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]

        S3c["S3 Storage<br/>443/TCP HTTPS TLS<br/>AWS IAM / access keys"]

        GCSc["GCS Storage<br/>443/TCP HTTPS TLS<br/>GCP credentials"]

        AzureC["Azure Blob<br/>443/TCP HTTPS TLS<br/>Azure credentials"]
    end

    %% External flows
    ClientGRPC -->|"gRPC/8033<br/>Optional TLS/mTLS<br/>Optional client cert"| MM
    ClientREST -->|"HTTPS/8443<br/>TLS<br/>OAuth token"| OAuthProxy

    %% etcd flows
    MM -->|"gRPC/2379<br/>Optional TLS/mTLS<br/>Credentials"| etcdC
    EventStreamC -->|"gRPC/2379<br/>Watch model state<br/>Optional TLS/mTLS"| etcdC

    %% K8s API flows
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPIc

    %% Storage flows
    PullerC -->|"HTTPS/443<br/>TLS<br/>Storage creds"| S3c
    PullerC -->|"HTTPS/443<br/>TLS<br/>GCP creds"| GCSc
    PullerC -->|"HTTPS/443<br/>TLS<br/>Azure creds"| AzureC

    %% Controller to serving pod
    Controller -->|"gRPC/8033<br/>Optional TLS<br/>Model lifecycle"| MM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servingpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class ClientGRPC,ClientREST external
    class OAuthProxy ingress
    class RESTProxy,MM,RuntimeC,PullerC,AdapterC servingpod
    class Controller,WebhookSvc,EventStreamC controller
    class etcdC,K8sAPIc,S3c,GCSc,AzureC externalservice
