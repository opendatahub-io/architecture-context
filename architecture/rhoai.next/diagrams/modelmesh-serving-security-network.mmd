graph TB
    subgraph External["EXTERNAL (No External Ingress by Default)"]
        Client["Inference Client<br/>(Cluster-internal only)"]
    end

    subgraph ClusterInternal["KUBERNETES CLUSTER"]
        direction TB

        subgraph ControllerNS["Controller Namespace"]
            Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>SCC: restricted"]
            WebhookSvc["Webhook Service<br/>9443/TCP HTTPS<br/>TLS: cert-manager/serving-certs"]
        end

        subgraph RuntimeNS["Runtime Namespace(s)<br/>(modelmesh-enabled=true)"]
            subgraph RuntimePod["Runtime Pod (Multi-Container)"]
                direction TB
                OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>TLS: model-serving-proxy-tls<br/>Auth: OpenShift OAuth<br/>SAR: get services"]
                RESTProxy["REST Proxy<br/>configurable/TCP HTTP<br/>No Auth"]
                ModelMesh["ModelMesh Sidecar (Java)<br/>8033/TCP gRPC<br/>TLS: optional (tls.secretName)<br/>Auth: mTLS optional (tls.clientAuth)"]
                Puller["Puller (runtime-adapter)<br/>8086/TCP gRPC<br/>No encryption (pod-local)"]
                Runtime["Model Runtime<br/>(Triton/OVMS/MLServer/TorchServe)<br/>Unix socket (pod-local)"]
            end

            InferenceSvc["modelmesh-serving Service (ClusterIP)<br/>8033/TCP gRPC | 8443/TCP HTTPS | 2112/TCP metrics"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        etcd["etcd<br/>2379/TCP gRPC<br/>TLS: auto-detected<br/>Auth: user/pass + optional mTLS certs<br/>Secret: model-serving-etcd"]
        Storage["Model Storage (S3/GCS/Azure)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Storage-specific credentials<br/>Secret: storage-config"]
    end

    %% Client flows
    Client -->|"HTTPS/8443<br/>TLS<br/>OAuth token"| OAuthProxy
    Client -->|"gRPC/8033<br/>TLS(opt)<br/>mTLS(opt)"| ModelMesh

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8008<br/>No encryption<br/>pod-local"| RESTProxy
    RESTProxy -->|"gRPC<br/>pod-local"| ModelMesh
    ModelMesh -->|"unix socket<br/>pod-local"| Runtime
    ModelMesh -->|"gRPC/8086<br/>pod-local"| Puller

    %% Controller flows
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Controller -->|"gRPC/8033<br/>TLS(opt)<br/>SetVModel"| ModelMesh

    %% K8s API flows
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server cert"| WebhookSvc

    %% Egress flows
    ModelMesh -->|"gRPC/2379<br/>TLS(auto)<br/>user/pass + mTLS"| etcd
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| Storage

    %% Service routing
    InferenceSvc -.->|"routes to"| RuntimePod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controller fill:#4a90e2,stroke:#2c6fbb,stroke-width:2px,color:#fff
    classDef runtimepod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#9b59b6,stroke:#7d3c98,stroke-width:2px,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef infra fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Controller,WebhookSvc controller
    class ModelMesh,Puller,Runtime,RESTProxy runtimepod
    class OAuthProxy auth
    class etcd,Storage externalservice
    class InferenceSvc service
    class K8sAPI infra
