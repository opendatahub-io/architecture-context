graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph InferenceDataPlane["INFERENCE DATA PLANE (Runtime Pods)"]
        direction TB

        subgraph RuntimePod["Runtime Pod"]
            OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>TLS<br/>OpenShift OAuth (SAR)"]
            RESTProxy["REST Proxy<br/>8008/TCP HTTP<br/>No encryption<br/>KServe v2 API"]
            ModelMesh["ModelMesh<br/>8033/TCP gRPC<br/>TLS (optional)<br/>mTLS (configurable)"]
            RuntimeContainer["Model Runtime<br/>Triton/MLServer/OVMS/TorchServe<br/>UDS or TCP<br/>No encryption"]
            Puller["Storage Puller<br/>8086/TCP gRPC<br/>No encryption<br/>pod-internal"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE"]
        direction TB

        Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (cert-manager)<br/>K8s API server mTLS"]
    end

    subgraph CoordinationLayer["COORDINATION LAYER"]
        etcd["etcd Cluster<br/>2379/TCP gRPC<br/>TLS (mTLS supported)<br/>Username/password + client certs"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA key"]
        Azure["Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Account key"]
        Prometheus["Prometheus<br/>2112/TCP HTTPS<br/>TLS<br/>InsecureSkipVerify"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS<br/>OAuth Bearer + SAR"| OAuthProxy

    %% Pod-internal flows
    OAuthProxy -->|"HTTP/8008<br/>No encryption<br/>pod-internal"| RESTProxy
    RESTProxy -->|"gRPC/8033<br/>TLS (optional)<br/>pod-internal"| ModelMesh
    ModelMesh -->|"gRPC (UDS/TCP)<br/>No encryption<br/>pod-internal"| RuntimeContainer
    ModelMesh -->|"gRPC/8086<br/>No encryption<br/>pod-internal"| Puller

    %% Direct gRPC inference (non-REST path)
    Client -.->|"gRPC/8033<br/>TLS (optional)<br/>mTLS (optional)"| ModelMesh

    %% Control plane flows
    Controller -->|"gRPC/8033<br/>TLS (optional)<br/>kube:// resolver"| ModelMesh
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>mTLS"| WebhookServer

    %% Coordination flows
    ModelMesh -->|"gRPC/2379<br/>TLS mTLS<br/>user/pass + certs"| etcd
    Controller -->|"gRPC/2379<br/>TLS mTLS<br/>EtcdRangeWatcher"| etcd

    %% External service flows
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM creds"| S3
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA key"| GCS
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Account key"| Azure

    %% Prometheus scraping
    Prometheus -.->|"HTTPS/2112<br/>TLS<br/>InsecureSkipVerify"| ModelMesh

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef coordination fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class OAuthProxy,RESTProxy,ModelMesh,RuntimeContainer,Puller dataplane
    class Controller,WebhookServer controlplane
    class etcd coordination
    class K8sAPI k8s
    class S3,GCS,Azure,Prometheus externalservice
