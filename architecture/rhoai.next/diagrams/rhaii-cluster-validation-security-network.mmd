graph TB
    subgraph External["EXTERNAL (User Workstation / CI)"]
        CLI["kubectl rhaii-validate<br/>Go CLI binary"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["kube-apiserver<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
        CRDAPI["apiextensions.k8s.io<br/>CRD API"]
    end

    subgraph ValidationNS["VALIDATION NAMESPACE (rhaii-validation)<br/>SA: rhaii-validator"]
        direction TB

        subgraph NodeChecks["Per-Node GPU Check Jobs (privileged)"]
            GPUJob["GPU Check Pod<br/>Image: odh-rhaii-cluster-validator<br/>hostPID: true, privileged: true<br/>Host mounts: /sys, /dev, /run/udev"]
        end

        subgraph NetworkTests["Network Test Jobs (tools image)"]
            direction TB
            TCPLat["TCP Latency Server<br/>12865/TCP raw<br/>No encryption"]
            IperfSrv["iperf3 Server<br/>5201/TCP<br/>No encryption"]
            IperfCli["iperf3 Client"]
            RDMASrv["ib_write_bw Server<br/>18515/TCP RDMA<br/>No encryption<br/>GPUDirect CUDA"]
            RDMACli["ib_write_bw Client"]
            PingSrv["ibv_rc_pingpong Server<br/>dynamic/TCP RDMA RC<br/>No encryption"]
            PingCli["ibv_rc_pingpong Client"]
        end

        subgraph Storage["Result Storage (ConfigMaps)"]
            ReportCM["rhaii-validate-report"]
            ConfigCM["rhaii-validate-config"]
            PingCM["rhaii-validate-pingmesh-failures"]
        end
    end

    subgraph CheckedNS["CHECKED NAMESPACES (read-only probes)"]
        CertMgr["cert-manager<br/>cert-manager-operator"]
        Istio["istio-system"]
        LWS["openshift-lws-operator"]
    end

    %% Flows
    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig credentials"| APIServer
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| CRDAPI
    APIServer -->|"Job creation<br/>SA Bearer Token<br/>RBAC: rhaii-validator"| GPUJob
    APIServer -->|"Job creation<br/>SA Bearer Token"| IperfSrv
    APIServer -->|"Job creation<br/>SA Bearer Token"| RDMASrv

    GPUJob -->|"exec nvidia-smi<br/>hostPID + privileged"| GPUJob
    GPUJob -->|"sysfs read<br/>host volume mount"| GPUJob

    IperfCli -->|"TCP/5201<br/>No encryption<br/>No auth"| IperfSrv
    RDMACli -->|"RDMA/18515<br/>No encryption<br/>GPUDirect"| RDMASrv
    PingCli -->|"RDMA RC/dynamic<br/>No encryption<br/>N-choose-2 pairs"| PingSrv

    APIServer -.->|"LIST pods<br/>SA Bearer Token"| CertMgr
    APIServer -.->|"LIST pods<br/>SA Bearer Token"| Istio
    APIServer -.->|"LIST pods<br/>SA Bearer Token"| LWS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef validation fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef privileged fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef network fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef checked fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class CLI external
    class APIServer,CRDAPI controlplane
    class GPUJob privileged
    class TCPLat,IperfSrv,IperfCli,RDMASrv,RDMACli,PingSrv,PingCli network
    class ReportCM,ConfigCM,PingCM storage
    class CertMgr,Istio,LWS checked
