graph TB
    subgraph DSP["Data Science Pipelines (KFP v2)"]
        direction TB

        subgraph ControlPlane["Control Plane Services"]
            APIServer["API Server<br/>Go Service<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP webhook"]
            PersistenceAgent["Persistence Agent<br/>Go Service<br/>gRPC client to API Server"]
            SWController["Scheduled Workflow Controller<br/>Go Controller<br/>9090/TCP metrics"]
            CacheServer["Cache Server<br/>Go Webhook<br/>443/TCP → 8443/TCP HTTPS"]
            ViewerController["Viewer Controller<br/>Go Controller"]
        end

        subgraph RuntimeSidecars["Runtime Sidecars (per pipeline step)"]
            Driver["Driver<br/>Go CLI sidecar<br/>Resolves inputs, checks cache, patches pod specs"]
            Launcher["Launcher<br/>Go CLI sidecar<br/>Executes user code, manages artifact I/O"]
        end
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    WorkflowCR["Workflow CR<br/>argoproj.io/v1alpha1"]

    %% Users
    User["User<br/>(SDK / Dashboard UI)"]

    %% External Dependencies
    ArgoWF["Argo Workflow Controller"]
    Database["MySQL / PostgreSQL<br/>3306/5432/TCP"]
    ObjectStore["S3-compatible Store<br/>(MinIO/SeaweedFS)<br/>9000/TCP"]
    MLMD["ML Metadata (MLMD)<br/>gRPC 8080/TCP"]
    K8sAPI["Kubernetes API<br/>443/TCP"]

    %% User interactions
    User -->|"REST/gRPC<br/>Pipeline CRUD, Run submission"| APIServer
    User -->|creates| PipelineCR
    User -->|creates| ScheduledWorkflowCR

    %% API Server flows
    APIServer -->|"read/write"| Database
    APIServer -->|"store/retrieve artifacts"| ObjectStore
    APIServer -->|"submit Workflows"| K8sAPI
    APIServer -->|"validates/mutates"| PipelineVersionCR
    APIServer -->|watches| PipelineCR

    %% Controller flows
    SWController -->|watches| ScheduledWorkflowCR
    SWController -->|"CreateRun gRPC"| APIServer
    PersistenceAgent -->|watches| WorkflowCR
    PersistenceAgent -->|"ReportWorkflow gRPC"| APIServer
    ViewerController -->|watches| ViewerCR
    CacheServer -->|"intercepts pod CREATE"| K8sAPI
    CacheServer -->|"cache lookup"| Database

    %% Argo flows
    K8sAPI -->|"watch Workflows"| ArgoWF
    ArgoWF -->|"executes steps"| Driver
    Driver -->|"cache check"| APIServer
    Driver -->|"execution context"| MLMD
    ArgoWF -->|"executes steps"| Launcher
    Launcher -->|"artifact upload/download"| ObjectStore
    Launcher -->|"publish results"| MLMD

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style SWController fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style ViewerController fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#50c878,stroke:#333,color:#fff
    style Launcher fill:#50c878,stroke:#333,color:#fff

    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style ScheduledWorkflowCR fill:#f5a623,stroke:#333
    style ViewerCR fill:#f5a623,stroke:#333
    style WorkflowCR fill:#f5a623,stroke:#333

    style Database fill:#e8e8e8,stroke:#333
    style ObjectStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ArgoWF fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
