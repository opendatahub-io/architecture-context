graph TB
    subgraph DSP["Data Science Pipelines Platform"]
        direction TB

        subgraph CoreServices["Core Services"]
            APIServer["API Server<br/>Go | 8888/TCP REST, 8887/TCP gRPC, 8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>Go | Watches Workflows"]
            ScheduledWF["Scheduled Workflow Controller<br/>Go | 9090/TCP Metrics"]
        end

        subgraph ExecutionEngine["Pipeline Step Execution (per-pod)"]
            Driver["Driver (init container)<br/>Go CLI | Resolves inputs, checks cache"]
            Launcher["Launcher (sidecar)<br/>Go CLI | Executes user code, manages artifacts"]
            UserContainer["User Container<br/>Pipeline step code"]
            Driver -->|"generates pod spec patch"| Launcher
            Launcher -->|"exec"| UserContainer
        end

        subgraph CacheSystem["Caching Layer"]
            CacheServer["Cache Server<br/>Go | 8443/TCP Webhook"]
            CacheDeployer["Cache Deployer<br/>Go | TLS cert management"]
            CacheDeployer -->|"provisions TLS"| CacheServer
        end

        subgraph FrontendStack["Frontend"]
            FrontendUI["Frontend UI<br/>React/TypeScript"]
            FrontendServer["Frontend Server<br/>Express.js | 3000/TCP"]
            FrontendUI -->|"served by"| FrontendServer
        end

        subgraph MetadataServices["Metadata & Visualization"]
            MetadataWriter["Metadata Writer<br/>Python | Watches pods"]
            VisualizationServer["Visualization Server<br/>Python | 8888/TCP"]
            ViewerController["Viewer Controller<br/>Go | Manages TensorBoard"]
        end
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>v3.7.11"]
    Database["MySQL 8.x / PostgreSQL 15.x"]
    ObjectStore["MinIO / S3 / GCS"]
    MLMD["ML Metadata (MLMD)<br/>gRPC Service"]
    K8sAPI["Kubernetes API"]

    %% Internal Dependencies
    DSPAOperator["DSPA Operator<br/>Deploys DSP components"]
    Istio["Istio Service Mesh<br/>mTLS, AuthorizationPolicy"]
    OSRoute["OpenShift Routes"]

    %% User
    User["Data Scientist / KFP SDK"]

    %% Connections
    User -->|"REST/gRPC"| APIServer
    User -->|"Web UI"| FrontendUI
    FrontendServer -->|"proxy"| APIServer

    APIServer -->|"creates"| ArgoWF
    APIServer -->|"stores state"| Database
    APIServer -->|"stores artifacts"| ObjectStore
    APIServer -->|"lineage"| MLMD
    APIServer -->|"RBAC checks"| K8sAPI

    PipelineCR -->|"watched by"| APIServer
    PipelineVersionCR -->|"validated/mutated"| APIServer
    ScheduledWorkflowCR -->|"reconciled by"| ScheduledWF
    ViewerCR -->|"reconciled by"| ViewerController

    ArgoWF -->|"runs"| Driver
    Driver -->|"queries"| MLMD
    Driver -->|"cache check"| APIServer
    Launcher -->|"uploads/downloads"| ObjectStore
    Launcher -->|"publishes results"| MLMD

    PersistenceAgent -->|"watches"| ArgoWF
    PersistenceAgent -->|"reports state"| APIServer

    ScheduledWF -->|"creates runs"| APIServer
    MetadataWriter -->|"watches pods"| K8sAPI
    MetadataWriter -->|"writes metadata"| MLMD

    CacheServer -->|"intercepts pods"| K8sAPI
    CacheServer -->|"cache lookup"| Database

    DSPAOperator -->|"deploys/manages"| DSP
    Istio -->|"mTLS"| DSP
    OSRoute -->|"external access"| FrontendServer

