graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB

        subgraph ControlPlane["Control Plane (Long-Running Services)"]
            APIServer["API Server<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>(outbound-only)"]
            SWFController["Scheduled Workflow<br/>Controller<br/>9090/TCP metrics"]
        end

        subgraph DataPlane["Data Plane (Ephemeral CLIs)"]
            Driver["Driver<br/>(Argo init step)<br/>Input resolution, cache check,<br/>pod spec patching"]
            Launcher["Launcher<br/>(container wrapper)<br/>Artifact download, execution,<br/>output publishing"]
        end
    end

    %% CRDs
    SWF_CR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    Pipeline_CR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersion_CR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ArgoWF_CR["Argo Workflow CR<br/>argoproj.io/v1alpha1"]

    %% External consumers
    Client["Client<br/>(SDK / Dashboard / CLI)"]

    %% External dependencies
    Database["MySQL / PostgreSQL<br/>3306/TCP or 5432/TCP"]
    ObjectStore["MinIO / S3 / GCS<br/>443/TCP HTTPS"]
    MLMD["ML Metadata (MLMD)<br/>8080/TCP gRPC"]
    ArgoEngine["Argo Workflows Engine"]
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Client flows
    Client -->|"REST 8888 / gRPC 8887"| APIServer

    %% API Server interactions
    APIServer -->|"metadata persistence"| Database
    APIServer -->|"pipeline specs & artifacts"| ObjectStore
    APIServer -->|"submit workflows"| ArgoWF_CR
    APIServer -->|"execution metadata"| MLMD
    APIServer -->|"CRD ops, RBAC checks"| K8sAPI
    APIServer -->|"create/manage"| SWF_CR
    APIServer -->|"validates/mutates"| PipelineVersion_CR
    APIServer -->|"manages"| Pipeline_CR

    %% SWF Controller
    SWFController -->|"watches"| SWF_CR
    SWFController -->|"creates"| ArgoWF_CR
    SWFController -->|"create run record"| APIServer

    %% Persistence Agent
    PersistenceAgent -->|"watches"| ArgoWF_CR
    PersistenceAgent -->|"watches"| SWF_CR
    PersistenceAgent -->|"reports status"| APIServer

    %% Argo execution
    ArgoEngine -->|"runs init step"| Driver
    ArgoEngine -->|"runs main container"| Launcher

    %% Driver interactions
    Driver -->|"cache check gRPC 8887"| APIServer
    Driver -->|"execution context"| MLMD

    %% Launcher interactions
    Launcher -->|"publish outputs"| MLMD
    Launcher -->|"upload artifacts"| ObjectStore

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style SWFController fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#50c878,stroke:#333,color:#fff
    style Launcher fill:#50c878,stroke:#333,color:#fff
    style SWF_CR fill:#f5a623,stroke:#333,color:#fff
    style Pipeline_CR fill:#f5a623,stroke:#333,color:#fff
    style PipelineVersion_CR fill:#f5a623,stroke:#333,color:#fff
    style ArgoWF_CR fill:#f5a623,stroke:#333,color:#fff
    style Database fill:#e8e8e8,stroke:#333
    style ObjectStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style ArgoEngine fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Client fill:#d4edda,stroke:#333
