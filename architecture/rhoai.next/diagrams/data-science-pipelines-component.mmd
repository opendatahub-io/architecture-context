graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["API Server<br/>(ml-pipeline)<br/>Go Service<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP Webhook"]
            CacheServer["Cache Server<br/>Go Webhook<br/>443/TCP HTTPS"]
        end

        subgraph ExecutionEngine["Execution Engine (Argo Step Containers)"]
            Driver["Driver<br/>Go CLI<br/>Orchestrates pipeline steps"]
            Launcher["Launcher v2<br/>Go CLI<br/>Executes user containers"]
        end

        subgraph Controllers["Controllers & Agents"]
            PersistenceAgent["Persistence Agent<br/>Go Agent (informer-based)<br/>Syncs workflow state"]
            SWFController["Scheduled Workflow<br/>Controller<br/>Go Controller<br/>9090/TCP metrics"]
            ViewerController["Viewer Controller<br/>Go Controller<br/>(controller-runtime)"]
        end
    end

    %% CRDs
    SWF_CR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    Viewer_CR["Viewer CR<br/>kubeflow.org/v1beta1"]
    Pipeline_CR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersion_CR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]

    %% External Users
    User["User / Client"]
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]
    DSPA_CR["DataSciencePipelinesApplication CR"]

    %% User interactions
    User -->|"REST/gRPC"| APIServer
    DSPO -->|"manages lifecycle"| DSPA_CR
    DSPA_CR -->|"deploys"| DSP

    %% CRD interactions
    APIServer -->|"validates/mutates"| PipelineVersion_CR
    APIServer -->|"manages"| Pipeline_CR
    SWFController -->|"reconciles"| SWF_CR
    SWFController -->|"creates Workflows"| ArgoWF
    ViewerController -->|"reconciles"| Viewer_CR

    %% Internal data flows
    APIServer -->|"creates"| ArgoWF["Argo Workflow"]
    ArgoWF -->|"runs"| Driver
    ArgoWF -->|"runs"| Launcher
    Driver -->|"gRPC 8887"| APIServer
    PersistenceAgent -->|"watches"| ArgoWF
    PersistenceAgent -->|"gRPC 8887"| APIServer
    SWFController -->|"gRPC 8887"| APIServer
    CacheServer -->|"intercepts pods"| ArgoWF

    %% External dependencies
    APIServer -->|"SQL 3306/5432"| DB["MySQL / PostgreSQL"]
    APIServer -->|"S3 API"| ObjStore["MinIO / S3 / GCS"]
    Driver -->|"gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    Launcher -->|"S3 API"| ObjStore
    Launcher -->|"gRPC 8080"| MLMD
    Driver -->|"S3 API"| ObjStore
    APIServer -->|"gRPC 8080"| MLMD

    %% Kubernetes API
    APIServer -->|"HTTPS 443"| K8sAPI["Kubernetes API"]
    PersistenceAgent -->|"HTTPS 443"| K8sAPI
    SWFController -->|"HTTPS 443"| K8sAPI
    Driver -->|"HTTPS 443"| K8sAPI

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#5bb5e0,stroke:#333,color:#fff
    style Launcher fill:#5bb5e0,stroke:#333,color:#fff
    style PersistenceAgent fill:#6bc4a0,stroke:#333,color:#fff
    style SWFController fill:#6bc4a0,stroke:#333,color:#fff
    style ViewerController fill:#6bc4a0,stroke:#333,color:#fff
    style SWF_CR fill:#f5a623,stroke:#333,color:#333
    style Viewer_CR fill:#f5a623,stroke:#333,color:#333
    style Pipeline_CR fill:#f5a623,stroke:#333,color:#333
    style PipelineVersion_CR fill:#f5a623,stroke:#333,color:#333
    style DB fill:#e8e8e8,stroke:#333
    style ObjStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ArgoWF fill:#f5a623,stroke:#333,color:#333
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style DSPA_CR fill:#f5a623,stroke:#333,color:#333
