graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB

        subgraph CoreServices["Core Services"]
            APIServer["API Server<br/>Go | 8888/TCP REST, 8887/TCP gRPC, 8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>Go | Watches Argo Workflows"]
            ScheduledWFCtrl["Scheduled Workflow Controller<br/>Go | 9090/TCP Metrics"]
            CacheServer["Cache Server<br/>Go | 8443/TCP Mutating Webhook"]
            CacheDeployer["Cache Deployer<br/>Go | Manages Webhook TLS Certs"]
        end

        subgraph Frontend["Frontend"]
            FrontendUI["Frontend UI<br/>React/TypeScript | 3000/TCP"]
            FrontendServer["Frontend Server<br/>Express/TypeScript | Auth Proxy"]
        end

        subgraph Execution["Pipeline Step Execution (per-pod)"]
            Driver["Driver<br/>Go CLI | Init Container"]
            Launcher["Launcher<br/>Go CLI | Sidecar"]
        end

        subgraph Supporting["Supporting Services"]
            MetadataWriter["Metadata Writer<br/>Python | Watches Argo Pods"]
            ViewerController["Viewer Controller<br/>Go | Manages TensorBoard"]
            VisualizationServer["Visualization Server<br/>Python | 8888/TCP"]
        end

        subgraph Compiler["Build-Time"]
            ArgoCompiler["Argo Compiler<br/>Go Library | KFP → Argo Workflow"]
        end
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    %% External Users
    User["Data Scientist / User"]
    KFPSDK["KFP Python SDK"]

    %% Interactions
    User -->|"browses UI"| FrontendUI
    KFPSDK -->|"HTTP/gRPC"| APIServer
    FrontendUI -->|"proxies API calls"| FrontendServer
    FrontendServer -->|"REST 8888/TCP"| APIServer

    PipelineCR -->|"watched by"| APIServer
    PipelineVersionCR -->|"validated/mutated by"| APIServer
    ScheduledWorkflowCR -->|"reconciled by"| ScheduledWFCtrl
    ViewerCR -->|"reconciled by"| ViewerController

    APIServer -->|"creates Argo Workflows"| ArgoWF
    PersistenceAgent -->|"watches & reports"| APIServer
    ScheduledWFCtrl -->|"creates runs via gRPC"| APIServer

    Driver -->|"resolves inputs, checks cache"| MLMD
    Driver -->|"cache lookup"| APIServer
    Launcher -->|"publishes results"| MLMD
    Launcher -->|"uploads/downloads artifacts"| ObjectStore
    MetadataWriter -->|"records metadata"| MLMD

    CacheServer -->|"intercepts pod creation"| K8sAPI

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>v3.7.11"]
    Database["MySQL / PostgreSQL"]
    ObjectStore["MinIO / S3 / GCS"]
    MLMD["ML Metadata<br/>(MLMD) gRPC"]
    K8sAPI["Kubernetes API"]

    APIServer -->|"3306/5432 TCP"| Database
    APIServer -->|"9000/443 TCP"| ObjectStore
    APIServer -->|"gRPC 8080"| MLMD
    APIServer -->|"HTTPS 443"| K8sAPI

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style ScheduledWFCtrl fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style CacheDeployer fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#50c878,stroke:#333,color:#fff
    style Launcher fill:#50c878,stroke:#333,color:#fff
    style FrontendUI fill:#9b59b6,stroke:#333,color:#fff
    style FrontendServer fill:#9b59b6,stroke:#333,color:#fff
    style MetadataWriter fill:#e67e22,stroke:#333,color:#fff
    style ViewerController fill:#e67e22,stroke:#333,color:#fff
    style VisualizationServer fill:#e67e22,stroke:#333,color:#fff
    style ArgoCompiler fill:#95a5a6,stroke:#333,color:#fff
    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style ScheduledWorkflowCR fill:#f5a623,stroke:#333
    style ViewerCR fill:#f5a623,stroke:#333
    style ArgoWF fill:#e8e8e8,stroke:#333
    style Database fill:#e8e8e8,stroke:#333
    style ObjectStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
    style KFPSDK fill:#fff,stroke:#333
