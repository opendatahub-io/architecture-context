graph TB
    subgraph DSP["Data Science Pipelines (KFP v2)"]
        direction TB

        subgraph ControlPlane["Control Plane Services"]
            APIServer["API Server<br/>Go Service<br/>8888/TCP HTTP | 8887/TCP gRPC<br/>8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>Go Service<br/>Watches Argo Workflows"]
            SWController["Scheduled Workflow<br/>Controller<br/>Go Controller<br/>9090/TCP metrics"]
            CacheServer["Cache Server<br/>Go Webhook<br/>443/TCP → 8443/TCP"]
            ViewerController["Viewer Controller<br/>Go Controller<br/>Tensorboard management"]
        end

        subgraph Sidecars["Pipeline Step Sidecars"]
            Driver["Driver<br/>Go CLI (sidecar)<br/>Pre-execution orchestrator"]
            Launcher["Launcher<br/>Go CLI (sidecar)<br/>In-container executor"]
        end
    end

    %% User interactions
    User["User<br/>(SDK / Dashboard UI)"] -->|"REST 8888/TCP<br/>Pipeline CRUD"| APIServer
    User -->|"gRPC 8887/TCP<br/>Pipeline submit"| APIServer

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    APIServer -->|"creates/validates"| PipelineCR
    APIServer -->|"creates/validates"| PipelineVersionCR
    APIServer -->|"creates"| ScheduledWorkflowCR
    SWController -->|"watches/reconciles"| ScheduledWorkflowCR
    SWController -->|"gRPC CreateRun"| APIServer
    ViewerController -->|"watches/reconciles"| ViewerCR

    %% Argo integration
    ArgoWF["Argo Workflow CRDs"]
    APIServer -->|"submits"| ArgoWF
    PersistenceAgent -->|"watches"| ArgoWF
    PersistenceAgent -->|"gRPC ReportWorkflow"| APIServer

    %% Sidecar flow
    ArgoWF -->|"spawns step"| Driver
    Driver -->|"patches pod spec"| Launcher
    Launcher -->|"executes user code"| UserContainer["User Container"]

    %% Cache webhook
    K8sAdmission["K8s Pod Admission"] -->|"intercepts pod CREATE"| CacheServer

    %% External dependencies
    Database["MySQL / PostgreSQL<br/>3306/5432/TCP"]
    ObjectStore["S3-compatible<br/>(MinIO/SeaweedFS)<br/>9000/TCP"]
    MLMD["ML Metadata<br/>gRPC 8080/TCP"]

    APIServer -->|"SQL"| Database
    CacheServer -->|"SQL (cache lookup)"| Database
    APIServer -->|"artifacts/specs"| ObjectStore
    Launcher -->|"upload/download artifacts"| ObjectStore
    Driver -->|"execution context"| MLMD
    Launcher -->|"publish results"| MLMD

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style SWController fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style ViewerController fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#6c5ce7,stroke:#333,color:#fff
    style Launcher fill:#6c5ce7,stroke:#333,color:#fff
    style UserContainer fill:#a29bfe,stroke:#333,color:#fff
    style PipelineCR fill:#f5a623,stroke:#333,color:#000
    style PipelineVersionCR fill:#f5a623,stroke:#333,color:#000
    style ScheduledWorkflowCR fill:#f5a623,stroke:#333,color:#000
    style ViewerCR fill:#f5a623,stroke:#333,color:#000
    style ArgoWF fill:#f5a623,stroke:#333,color:#000
    style Database fill:#e8e8e8,stroke:#333
    style ObjectStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style User fill:#7ed321,stroke:#333,color:#000
    style K8sAdmission fill:#e8e8e8,stroke:#333
