graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB

        subgraph ControlPlane["Control Plane Services"]
            APIServer["API Server<br/>Go Service<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP Webhook"]
            PersistenceAgent["Persistence Agent<br/>Go Service<br/>Syncs Argo Workflow state to DB"]
            SWController["Scheduled Workflow Controller<br/>Go Controller<br/>9090/TCP metrics"]
            CacheServer["Cache Server<br/>Go Webhook<br/>443/TCP → 8443/TCP HTTPS"]
            ViewerController["Viewer Controller<br/>Go Controller<br/>Manages Tensorboard"]
        end

        subgraph RuntimeSidecars["Runtime Sidecars (per pipeline step)"]
            Driver["Driver<br/>Go CLI<br/>Resolves inputs, checks cache, patches pod specs"]
            Launcher["Launcher<br/>Go CLI<br/>Executes user code, manages artifacts"]
        end
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    %% Users
    User["User<br/>(SDK / Dashboard UI)"]
    User -->|"REST/gRPC"| APIServer

    %% CRD relationships
    APIServer -->|"creates/manages"| PipelineCR
    APIServer -->|"creates/manages"| PipelineVersionCR
    APIServer -->|"validates/mutates (webhook)"| PipelineVersionCR
    APIServer -->|"creates"| ScheduledWorkflowCR
    SWController -->|"watches/reconciles"| ScheduledWorkflowCR
    SWController -->|"gRPC CreateRun"| APIServer
    ViewerController -->|"watches/reconciles"| ViewerCR
    PersistenceAgent -->|"gRPC ReportWorkflow"| APIServer

    %% Runtime flow
    APIServer -->|"submits Workflow"| ArgoWorkflows["Argo Workflows"]
    ArgoWorkflows -->|"executes"| Driver
    Driver -->|"patches pod spec"| Launcher
    Launcher -->|"runs user code"| UserContainer["User Container"]

    %% External dependencies
    APIServer -->|"SQL 3306/5432"| Database["MySQL / PostgreSQL"]
    APIServer -->|"HTTP 9000"| ObjectStore["S3-compatible Store<br/>(MinIO/SeaweedFS)"]
    Driver -->|"gRPC 8080"| MLMD["ML Metadata (MLMD)"]
    Launcher -->|"gRPC 8080"| MLMD
    Launcher -->|"HTTP 9000"| ObjectStore
    CacheServer -->|"SQL 3306"| Database

    %% K8s API
    APIServer -->|"HTTPS 443"| K8sAPI["Kubernetes API"]
    PersistenceAgent -->|"watches Workflows"| K8sAPI
    SWController -->|"watches CRDs"| K8sAPI

    %% Cache webhook
    K8sAPI -->|"pod admission"| CacheServer

    %% Styling
    style APIServer fill:#4a90e2,color:#fff
    style PersistenceAgent fill:#4a90e2,color:#fff
    style SWController fill:#4a90e2,color:#fff
    style CacheServer fill:#4a90e2,color:#fff
    style ViewerController fill:#4a90e2,color:#fff
    style Driver fill:#50c878,color:#fff
    style Launcher fill:#50c878,color:#fff
    style PipelineCR fill:#f5a623,color:#fff
    style PipelineVersionCR fill:#f5a623,color:#fff
    style ScheduledWorkflowCR fill:#f5a623,color:#fff
    style ViewerCR fill:#f5a623,color:#fff
    style ArgoWorkflows fill:#999,color:#fff
    style Database fill:#999,color:#fff
    style ObjectStore fill:#999,color:#fff
    style MLMD fill:#999,color:#fff
    style K8sAPI fill:#999,color:#fff
    style UserContainer fill:#d5e8d4,stroke:#82b366
