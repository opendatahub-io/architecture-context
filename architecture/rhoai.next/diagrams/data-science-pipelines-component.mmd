graph TB
    subgraph DSP["Data Science Pipelines (DSP)"]
        direction TB

        subgraph ControlPlane["Control Plane Services"]
            APIServer["API Server<br/>(Go)<br/>8888/TCP REST<br/>8887/TCP gRPC<br/>8443/TCP Webhooks"]
            PersistenceAgent["Persistence Agent<br/>(Go)<br/>Workflow status sync"]
            SWController["Scheduled Workflow<br/>Controller (Go)<br/>Cron/periodic runs"]
            ViewerController["Viewer CRD<br/>Controller (Go)<br/>TensorBoard instances"]
        end

        subgraph CacheLayer["Cache Layer"]
            CacheServer["Cache Server<br/>(Go Webhook)<br/>8443/TCP HTTPS<br/>Mutating Admission"]
            CacheDeployer["Cache Deployer<br/>(Go)<br/>Cert + Webhook mgmt"]
        end

        subgraph ExecutionEngine["V2 Execution Engine (Argo sidecar)"]
            Driver["V2 Driver<br/>(Go CLI)<br/>Input resolution<br/>Cache key computation<br/>Pod spec patches"]
            Launcher["V2 Launcher<br/>(Go CLI)<br/>Artifact I/O<br/>Result publishing"]
        end

        subgraph UILayer["Frontend"]
            Frontend["Frontend UI<br/>(Node.js BFF + React)<br/>3000/TCP HTTP"]
        end

        MetadataWriter["Metadata Writer<br/>(Go/Python)<br/>Annotation propagation"]
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    SWCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>v3.7.14"]
    SQLDB["MySQL / PostgreSQL"]
    ObjectStore["SeaweedFS / MinIO<br/>(S3-compatible)"]
    MLMD["ML Metadata<br/>(gRPC)"]
    K8sAPI["Kubernetes API<br/>Server"]

    %% Users
    User["Data Scientist / SDK"]
    DSPA["DSPA Operator<br/>(Platform deployer)"]

    %% User interactions
    User -->|REST API / gRPC| APIServer
    User -->|Web UI| Frontend
    DSPA -->|creates DSP instance| DSP

    %% Internal flows
    Frontend -->|proxy API requests| APIServer
    APIServer -->|validates| CacheServer
    APIServer -->|submits workflows| ArgoWF
    APIServer -->|CRUD| SQLDB
    APIServer -->|artifacts| ObjectStore
    APIServer -->|metadata| MLMD
    APIServer -->|webhook validation| PipelineVersionCR

    PersistenceAgent -->|watches| ArgoWF
    PersistenceAgent -->|reports status| APIServer

    SWController -->|watches| SWCR
    SWController -->|creates runs| APIServer
    SWController -->|creates workflows| ArgoWF

    ViewerController -->|watches| ViewerCR

    Driver -->|metadata records| MLMD
    Driver -->|cache lookup| APIServer
    Launcher -->|artifact I/O| ObjectStore
    Launcher -->|publish results| MLMD

    MetadataWriter -->|watches pods| K8sAPI

    CacheDeployer -->|manages certs| CacheServer

    %% CRD relationships
    APIServer -->|CRUD| PipelineCR
    APIServer -->|CRUD| PipelineVersionCR
    APIServer -->|creates| SWCR

    %% Styling
    style APIServer fill:#4a90e2,color:#fff
    style PersistenceAgent fill:#4a90e2,color:#fff
    style SWController fill:#4a90e2,color:#fff
    style ViewerController fill:#4a90e2,color:#fff
    style CacheServer fill:#4a90e2,color:#fff
    style CacheDeployer fill:#4a90e2,color:#fff
    style Driver fill:#50b4e2,color:#fff
    style Launcher fill:#50b4e2,color:#fff
    style Frontend fill:#4a90e2,color:#fff
    style MetadataWriter fill:#4a90e2,color:#fff

    style PipelineCR fill:#f5a623,color:#fff
    style PipelineVersionCR fill:#f5a623,color:#fff
    style SWCR fill:#f5a623,color:#fff
    style ViewerCR fill:#f5a623,color:#fff

    style ArgoWF fill:#e8e8e8,stroke:#333
    style SQLDB fill:#e8e8e8,stroke:#333
    style ObjectStore fill:#e8e8e8,stroke:#333
    style MLMD fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333

    style User fill:#7ed321,color:#fff
    style DSPA fill:#7ed321,color:#fff
