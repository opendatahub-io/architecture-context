graph TB
    subgraph External["EXTERNAL (No Ingress)"]
        NoIngress["No external ingress<br/>Cluster-internal operator only"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_Platform["Platform Operator"]
            PlatformOp["opendatahub-operator<br/>Deploys module operator<br/>Creates AIGateway CR"]
        end

        subgraph NS_RHOAI["Namespace: redhat-ods-applications"]
            direction TB

            AIGO["ai-gateway-operator<br/>SA: ai-gateway-operator<br/>Image: odh-ai-gateway-operator<br/>FIPS: strictfipsruntime + CGO<br/>GOMEMLIMIT: 410MiB"]

            MetricsSvc["ai-gateway-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS + TLS<br/>Auth: Bearer Token<br/>(TokenReview + SAR)"]

            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>No auth"]

            BatchOp["batch-gateway-operator<br/>SA: llm-d-batch-gateway-operator<br/>Image: odh-batch-gateway-operator"]

            subgraph Operands["Batch Gateway Operands"]
                APIServer["batch-gateway-apiserver"]
                Processor["batch-gateway-processor"]
                GarbageCol["batch-gateway-gc"]
            end
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]

        Prometheus["Prometheus<br/>(via ServiceMonitor)"]
    end

    subgraph CRDs["Custom Resources"]
        AIGatewayCR["AIGateway CR<br/>Cluster-scoped<br/>components.platform.opendatahub.io"]
        LLMBatchCR["LLMBatchGateway CR<br/>Namespaced<br/>batch.llm-d.ai"]
    end

    %% Flows
    PlatformOp -->|"Deploys via<br/>module handler"| AIGO
    PlatformOp -->|"Creates"| AIGatewayCR
    AIGatewayCR -->|"Watched by"| AIGO

    AIGO -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    AIGO -->|"serves"| MetricsSvc
    AIGO -->|"serves"| HealthProbe
    AIGO -->|"Deploys when<br/>batchGateway=Managed"| BatchOp

    BatchOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LLMBatchCR -->|"Watched by"| BatchOp
    BatchOp -->|"Creates"| APIServer
    BatchOp -->|"Creates"| Processor
    BatchOp -->|"Creates"| GarbageCol

    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef subcomponent fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef operand fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef infra fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crd fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class NoIngress external
    class PlatformOp platform
    class AIGO operator
    class BatchOp subcomponent
    class APIServer,Processor,GarbageCol operand
    class K8sAPI,Prometheus infra
    class AIGatewayCR,LLMBatchCR crd
    class MetricsSvc,HealthProbe service
