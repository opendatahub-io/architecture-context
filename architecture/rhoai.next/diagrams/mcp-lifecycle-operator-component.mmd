graph TB
    subgraph "MCP Lifecycle Operator"
        direction TB
        Controller["MCPServerReconciler<br/>(controller-runtime)"]
        Handshake["MCP Handshake Client<br/>(go-sdk StreamableHTTP)"]
        ConfigHash["Config Hash Computer<br/>(SHA-256)"]
        Ownership["Ownership Validator"]
        Metrics["Prometheus Metrics<br/>8443/TCP HTTPS"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]

        Controller -->|"verifies protocol"| Handshake
        Controller -->|"computes hash"| ConfigHash
        Controller -->|"validates ownership"| Ownership
        Controller -->|"registers"| Metrics
    end

    User["Platform User / GitOps"] -->|"creates/updates"| MCPServerCR["MCPServer CR<br/>(mcp.x-k8s.io/v1alpha1)"]
    MCPServerCR -->|"watched by"| Controller

    Controller -->|"creates/updates<br/>(ownerReferences)"| Deployment["Deployment<br/>(per MCPServer)"]
    Controller -->|"creates/updates<br/>(ownerReferences)"| Service["ClusterIP Service<br/>(per MCPServer)"]

    Deployment -->|"runs"| MCPPod["MCP Server Pod<br/>(user container image)"]

    Handshake -->|"HTTP POST<br/>MCP initialize"| MCPPod

    ConfigHash -->|"reads data"| ConfigMaps["ConfigMaps"]
    ConfigHash -->|"reads data"| Secrets["Secrets"]
    ConfigHash -->|"triggers rolling update<br/>via annotation"| Deployment

    Controller -->|"patches status<br/>(conditions, capabilities)"| MCPServerCR

    Prometheus["Prometheus"] -->|"scrapes<br/>HTTPS/8443"| Metrics

    K8sAPI["Kubernetes API Server"] -.->|"CRUD operations<br/>HTTPS/443"| Controller

    style Controller fill:#4a90e2,color:#fff
    style Handshake fill:#4a90e2,color:#fff
    style ConfigHash fill:#4a90e2,color:#fff
    style Ownership fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style HealthProbes fill:#4a90e2,color:#fff
    style MCPServerCR fill:#f5a623,color:#fff
    style Deployment fill:#7ed321,color:#fff
    style Service fill:#7ed321,color:#fff
    style MCPPod fill:#7ed321,color:#fff
    style ConfigMaps fill:#e8e8e8,stroke:#999
    style Secrets fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
