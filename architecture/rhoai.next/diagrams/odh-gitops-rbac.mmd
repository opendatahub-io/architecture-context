graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["rhai-operator-controller-manager<br/>Namespace: redhat-ods-operator"]
        SA_Hook["rhai-post-install-hook<br/>Namespace: release namespace"]
        SA_Azure["azure-cloud-manager-operator<br/>Namespace: rhai-cloudmanager-system"]
        SA_CoreWeave["coreweave-cloud-manager-operator<br/>Namespace: rhai-cloudmanager-system"]
        SA_AWS["aws-cloud-manager-operator<br/>Namespace: rhai-cloudmanager-system"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_Op["rhai-operator-rolebinding<br/>(cluster-scoped)"]
        CRB_Hook["rhai-post-install-hook-binding<br/>(cluster-scoped)"]
        CRB_Azure["rhai-azure-cloud-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_CoreWeave["rhai-coreweave-cloud-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_AWS["rhai-aws-cloud-manager-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph Roles["ClusterRoles"]
        CR_Op["rhai-operator-role"]
        CR_Hook["rhai-post-install-hook"]
        CR_Azure["rhai-azure-cloud-manager-role"]
        CR_CoreWeave["rhai-coreweave-cloud-manager-role"]
        CR_AWS["rhai-aws-cloud-manager-role"]
    end

    subgraph OperatorResources["rhai-operator-role Resources"]
        direction TB
        Core["core (v1)<br/>configmaps, events, namespaces,<br/>pods, secrets, services,<br/>serviceaccounts"]
        Apps["apps (v1)<br/>deployments, daemonsets,<br/>statefulsets, replicasets"]
        GW["gateway.networking.k8s.io<br/>gateways, gatewayclasses,<br/>httproutes"]
        KServeAPI["serving.kserve.io<br/>inferenceservices,<br/>clusterservingruntimes,<br/>servingruntimes"]
        ODHComponents["components.platform.opendatahub.io<br/>kserves, dashboards, kueues,<br/>modelregistries, rays, workbenches"]
        CertMgrAPI["cert-manager.io<br/>certificates, issuers,<br/>clusterissuers"]
        IstioNet["networking.istio.io<br/>destinationrules,<br/>envoyfilters"]
        IstioSec["security.istio.io<br/>authorizationpolicies,<br/>peerauthentications"]
    end

    subgraph HookResources["rhai-post-install-hook Resources"]
        direction TB
        HookODH["components.platform.opendatahub.io<br/>kserves"]
        HookInfra["infrastructure.opendatahub.io<br/>azurekubernetesengines,<br/>coreweavekubernetesengines,<br/>awskubernetesengines"]
        HookGW["gateway.networking.k8s.io<br/>gateways, gatewayclasses"]
        HookCert["cert-manager.io<br/>clusterissuers, certificates"]
    end

    %% SA → Binding
    SA_Operator -->|"bound via"| CRB_Op
    SA_Hook -->|"bound via"| CRB_Hook
    SA_Azure -->|"bound via"| CRB_Azure
    SA_CoreWeave -->|"bound via"| CRB_CoreWeave
    SA_AWS -->|"bound via"| CRB_AWS

    %% Binding → Role
    CRB_Op -->|"grants"| CR_Op
    CRB_Hook -->|"grants"| CR_Hook
    CRB_Azure -->|"grants"| CR_Azure
    CRB_CoreWeave -->|"grants"| CR_CoreWeave
    CRB_AWS -->|"grants"| CR_AWS

    %% Role → Resources (operator)
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| Core
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| Apps
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| GW
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| KServeAPI
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| ODHComponents
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| CertMgrAPI
    CR_Op -->|"get,list,watch,create,<br/>update,patch,delete"| IstioNet
    CR_Op -->|"get,list,watch,create,<br/>update,patch"| IstioSec

    %% Role → Resources (hook)
    CR_Hook -->|"get,create,<br/>patch,update"| HookODH
    CR_Hook -->|"get,create,<br/>patch,update"| HookInfra
    CR_Hook -->|"get,create,<br/>patch,update"| HookGW
    CR_Hook -->|"get,create,<br/>patch,update"| HookCert

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_Hook fill:#4a90e2,stroke:#333,color:#fff
    style SA_Azure fill:#4a90e2,stroke:#333,color:#fff
    style SA_CoreWeave fill:#4a90e2,stroke:#333,color:#fff
    style SA_AWS fill:#4a90e2,stroke:#333,color:#fff

    style CRB_Op fill:#b8d4f0,stroke:#333
    style CRB_Hook fill:#b8d4f0,stroke:#333
    style CRB_Azure fill:#b8d4f0,stroke:#333
    style CRB_CoreWeave fill:#b8d4f0,stroke:#333
    style CRB_AWS fill:#b8d4f0,stroke:#333

    style CR_Op fill:#f5a623,stroke:#333,color:#fff
    style CR_Hook fill:#f5a623,stroke:#333,color:#fff
    style CR_Azure fill:#f5a623,stroke:#333,color:#fff
    style CR_CoreWeave fill:#f5a623,stroke:#333,color:#fff
    style CR_AWS fill:#f5a623,stroke:#333,color:#fff

    style Core fill:#7ed321,stroke:#333,color:#fff
    style Apps fill:#7ed321,stroke:#333,color:#fff
    style GW fill:#7ed321,stroke:#333,color:#fff
    style KServeAPI fill:#7ed321,stroke:#333,color:#fff
    style ODHComponents fill:#7ed321,stroke:#333,color:#fff
    style CertMgrAPI fill:#7ed321,stroke:#333,color:#fff
    style IstioNet fill:#7ed321,stroke:#333,color:#fff
    style IstioSec fill:#7ed321,stroke:#333,color:#fff

    style HookODH fill:#82c8a0,stroke:#333,color:#fff
    style HookInfra fill:#82c8a0,stroke:#333,color:#fff
    style HookGW fill:#82c8a0,stroke:#333,color:#fff
    style HookCert fill:#82c8a0,stroke:#333,color:#fff
