        MTLS_modelreg["model-registry-op metrics<br/>8443/TCP Server TLS<br/>service-ca"]
    end

    subgraph ServiceTLS["Service-Level TLS"]
        STLS_krbac["kube-rbac-proxy<br/>8443/TCP Server TLS<br/>Hot-reloaded CertReloader"]
        STLS_kauth["kube-auth-proxy<br/>4180, 8443/TCP Server TLS<br/>Secret or auto-generated"]
        STLS_kuberay["kuberay inter-node<br/>6379, 10001/TCP mTLS<br/>cert-manager (90d rotation)"]
        STLS_modelreg["model-registry<br/>8080/TCP Server TLS<br/>TLS 1.2 min, FIPS ciphers"]
        STLS_dashboard["odh-dashboard BFFs<br/>8043-8743/TCP Server TLS<br/>TLS 1.3 minimum (Go)"]
        STLS_modelmesh["modelmesh metrics<br/>2112/TCP Server TLS<br/>Self-signed (BouncyCastle)"]
        STLS_vlorch["vllm-orchestrator-gw<br/>8090/TCP mTLS upstream<br/>native-tls (system OpenSSL)"]
        STLS_tgis["text-generation-inference<br/>3000/TCP Server TLS (opt)<br/>rustls + OpenSSL dual stack"]
    end

    subgraph ContainerSec["Container Security Patterns"]
        CS_nonroot["Non-root execution<br/>All 70 components<br/>UBI9 default or explicit UID"]
        CS_ubi9["UBI9 base image<br/>68 of 70 components<br/>RHEL compat + CVE patching"]
        CS_capdrop["Capability drop (ALL)<br/>All Go/Rust/Java components<br/>SecurityContext enforcement"]
        CS_readonly["Read-only root filesystem<br/>All Go operators/controllers<br/>Immutable container FS"]
        CS_hermetic["Hermetic builds (Konflux)<br/>~35 Go/Python components<br/>Hermeto/cachi2 prefetch"]
        CS_nonhermetic["Non-hermetic builds<br/>vllm, vllm-rocm, vllm-spyre,<br/>vllm-gaudi, vllm-cpu, OVMS,<br/>notebooks-downstream<br/>hermetic: false"]
    end

    subgraph FIPSCompliance["FIPS Compliance Status"]
        FIPS_go["Go strictfipsruntime<br/>21 components<br/>CGO_ENABLED=1 + OpenSSL"]
        FIPS_java["Java PKCS11<br/>modelmesh only<br/>SunPKCS11 provider"]
        FIPS_missing["FIPS not enabled<br/>spark-operator, wva,<br/>llm-d EPP, llm-d-routing,<br/>gateway-api-inf-ext"]
        FIPS_removed["FIPS explicitly removed<br/>vllm-gaudi<br/>rpm -e openssl-fips-provider"]
        FIPS_none["No FIPS crypto<br/>Python components (python-jose),<br/>Rust components (rustls/ring)<br/>Not FIPS-validated"]
    end

    subgraph MeshSec["Service Mesh Security"]
        PA_default["PeerAuthentication<br/>Mode: PERMISSIVE (default)<br/>All mesh-enrolled components"]
        PA_strict["PeerAuthentication<br/>Mode: STRICT<br/>model-registry, kserve NS"]
        AP_modelreg["AuthorizationPolicy<br/>model-registry<br/>Restrict source principals"]
        AP_maas["AuthorizationPolicy<br/>models-as-a-service<br/>API key + Kuadrant"]
        AP_kserve["AuthorizationPolicy<br/>kserve<br/>Inference namespace scoped"]
    end

    %% RBAC Bindings
    SA_rhods -->|bound to| CR_rhods
    SA_kserve -->|bound to| CR_kserve
    SA_kserve -->|bound to| CR_kserve_llm
    SA_kueue -->|bound to| CR_kueue
    SA_kuberay -->|bound to| CR_kuberay
    SA_training -->|bound to| CR_training
    SA_trustyai -->|bound to| CR_trustyai
    SA_maas -->|bound to| CR_maas
    SA_dashboard -->|bound to| CR_dashboard

    %% Secret usage
    SA_kserve -->|uses| Sec_storage
    SA_dashboard -->|uses| Sec_cookie
    SA_dashboard -->|uses| Sec_client
    SA_modelreg -->|uses| Sec_db_creds
    SA_mlflow -->|uses| Sec_mlflow_kek

    %% Auth mechanism usage
    OAuth -->|used by| SA_dashboard
    KRBAC -->|sidecar for| SA_kserve
    KRBAC -->|sidecar for| SA_kubeflow
    KRBAC -->|sidecar for| SA_kuberay
    KRBAC -->|sidecar for| SA_kueue
    KRBAC -->|sidecar for| SA_dashboard
    IstioAuth -->|protects| SA_modelreg
    IstioAuth -->|protects| SA_maas
    Kuadrant -->|protects| SA_maas
    JWT -->|used by| SA_kserve

    %% Mesh enforcement
    PA_strict -->|enforces| mTLSAuth
    AP_modelreg -->|allows| SA_modelreg
    AP_maas -->|allows| SA_maas
    AP_kserve -->|allows| SA_kserve

