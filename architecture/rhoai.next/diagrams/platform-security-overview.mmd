        IstioAuth["Istio AuthorizationPolicy<br/>model-registry, MaaS, kserve"]
        Kuadrant["Kuadrant (Authorino)<br/>HTTP callback API key<br/>models-as-a-service"]
        JWT["Bearer Token / JWT<br/>llama-stack,<br/>model-serving-api"]
        OAuthProxy["OAuth proxy sidecar<br/>modelmesh-serving,<br/>Prometheus, Alertmanager"]
        MLflowAuth["MLflow kubernetes-auth<br/>SelfSubjectAccessReview<br/>mlflow"]
        APIKey["API key (Bearer)<br/>vllm-cpu, MaaS<br/>(optional)"]
        mTLSAuth["mTLS (cert-manager)<br/>kuberay inter-node,<br/>vllm-orchestrator-gw"]
        NoAuth["No auth (NetworkPolicy)<br/>guardrails-regex-detector,<br/>guardrails-detectors,<br/>llm-d-scheduler,<br/>llm-d-routing-sidecar,<br/>NeMo-Guardrails,<br/>rhds-llama-stack-dist"]
    end

    subgraph KeySAs["Key ServiceAccounts"]
        SA_rhods["rhods-operator<br/>NS: redhat-ods-operator"]
