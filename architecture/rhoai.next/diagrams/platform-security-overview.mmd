        SA_kubeflow["notebook-controller<br/>NS: redhat-ods-applications"]
        SA_kuberay["kuberay-operator<br/>NS: redhat-ods-applications"]
        SA_kueue["kueue-controller-manager<br/>NS: redhat-ods-applications"]
