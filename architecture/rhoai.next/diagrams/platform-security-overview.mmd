graph TD
    subgraph AuthMechanisms["Authentication Mechanisms"]
        Auth1[Gateway ext_authz<br/>kube-auth-proxy<br/>OIDC / OpenShift OAuth]
        Auth2[kube-rbac-proxy<br/>TokenReview + SAR<br/>Metrics + API protection]
        Auth3[Kuadrant AuthPolicy<br/>Authorino<br/>Model serving auth]
        Auth4[API Key Auth<br/>maas-api callback<br/>Subscription validation]
        Auth5[mTLS Certificates<br/>Istio DestinationRule<br/>Service-to-service]
        Auth6[OAuth Proxy (Legacy)<br/>Port 8443<br/>ModelMesh only]
    end

    subgraph GatewayAuth["Gateway Authentication Stack"]
        GW1[Envoy Proxy<br/>TLS termination<br/>443/TCP external]
        GW2[EnvoyFilter<br/>ext_authz delegate<br/>Lua cookie stripping]
        GW3[kube-auth-proxy<br/>OIDC/OAuth flows<br/>FIPS-compliant replacement<br/>for oauth-proxy]
        GW4[Bearer Token Injection<br/>Cookie stripped, token<br/>in Authorization header]
    end

    subgraph KubeRBACProxySA["kube-rbac-proxy Protected Components"]
        KRBP1[KubeRay Operator]
        KRBP2[Model Registry Operator]
        KRBP3[Notebooks Controller]
        KRBP4[EvalHub]
        KRBP5[odh-dashboard]
        KRBP6[odh-model-controller]
        KRBP7[TrustyAI Operator]
        KRBP8[Kueue Controller]
        KRBP9[DSPO Controller]
        KRBP10[Spark Operator]
    end

    subgraph ServiceAccounts["Key ServiceAccounts"]
        SA1[rhods-operator<br/>NS: redhat-ods-operator<br/>Platform root SA]
        SA2[kserve-controller-manager<br/>NS: redhat-ods-applications<br/>Serving controller]
        SA3[odh-model-controller<br/>NS: redhat-ods-applications<br/>Serving infra]
        SA4[odh-dashboard<br/>NS: redhat-ods-applications<br/>UI + BFFs]
        SA5[data-science-pipelines-operator<br/>NS: redhat-ods-applications<br/>Pipeline infra]
        SA6[maas-controller<br/>NS: redhat-ods-applications<br/>External model mgmt]
    end

    subgraph ClusterRoles["Key ClusterRoles (High Privilege)"]
        CR1[rhods-operator-role<br/>16+ component CRs<br/>DSCInitialization, DSC<br/>All namespaces RBAC]
        CR2[kserve-manager-role<br/>InferenceService, LLMInferenceService<br/>Deployments, Services, HTTPRoutes<br/>LeaderWorkerSet, ConfigMaps]
        CR3[odh-model-controller-role<br/>InferenceService reconciliation<br/>AuthPolicy, ServiceMonitor<br/>EnvoyFilter, KEDA ScaledObject]
        CR4[odh-dashboard-role<br/>All component CRs (read)<br/>Notebooks, Projects, RBAC<br/>Module federation resources]
        CR5[dspo-manager-role<br/>DataSciencePipelinesApplication<br/>Argo Workflows, MLMD<br/>User namespace resources]
        CR6[maas-controller-role<br/>MaaSModelRef, MaaSSubscription<br/>HTTPRoutes, AuthPolicies<br/>RateLimitPolicies]
    end

    subgraph Secrets["Critical Secrets"]
        Sec1[storage-config<br/>Type: Opaque<br/>S3 credentials for model storage<br/>Used by: KServe, DSPA]
        Sec2[webhook-server-cert<br/>Type: kubernetes.io/tls<br/>Webhook TLS certificates<br/>Used by: All operators]
        Sec3[kube-auth-proxy-tls<br/>Type: kubernetes.io/tls<br/>Gateway auth proxy TLS<br/>Rotation: cert-manager]
        Sec4[maas-provider-credentials<br/>Type: Opaque<br/>External LLM provider API keys<br/>Used by: AI Gateway ext_proc]
        Sec5[mlflow-db-credentials<br/>Type: Opaque<br/>MLflow database connection<br/>Used by: MLflow instances]
    end

    subgraph TLSConfig["TLS Configuration"]
        TLS1[Webhooks<br/>9443/TCP Server TLS<br/>cert-manager issued<br/>All operators with webhooks]
        TLS2[Metrics Endpoints<br/>8443/TCP Server TLS<br/>kube-rbac-proxy terminated<br/>10+ components]
        TLS3[Gateway Ingress<br/>443/TCP Server TLS<br/>Envoy-terminated<br/>All HTTPRoute services]
        TLS4[Service-to-Service<br/>Istio DestinationRule<br/>TLS origination<br/>KServe, MaaS backends]
        TLS5[Inter-Pod mTLS<br/>Certificate injection<br/>Init containers<br/>KubeRay, CodeFlare]
    end

    subgraph ContainerSecurity["Container Security Patterns"]
        CS1[UBI 9 Base Images<br/>ubi9-minimal / ubi9-micro<br/>All Go operators,<br/>Python services]
        CS2[FIPS-Compliant Go Crypto<br/>CGO_ENABLED=1<br/>-tags strictfipsruntime<br/>15+ Go operators]
        CS3[Non-Root Execution<br/>runAsNonRoot: true<br/>UID 1001 or 65532<br/>All containers]
        CS4[Digest-Pinned Images<br/>SHA256 digest refs<br/>Konflux-built images<br/>Supply chain integrity]
        CS5[Capability Drops<br/>capabilities.drop: ALL<br/>KubeRay, KServe, Kueue,<br/>Spark, OGX Operators]
        CS6[RELATED_IMAGE Pattern<br/>Env var image refs<br/>OLM relatedImages<br/>Disconnected support]
        CS7[Multi-Stage Builds<br/>Builder + runtime stages<br/>Minimal attack surface<br/>Nearly all components]
        CS8[CentOS Stream 9 (c9s)<br/>CUDA/ROCm GPU images<br/>Notebooks, vLLM, llm-d<br/>AIPCC packages]
    end

    subgraph FIPSGaps["FIPS Compliance Gaps"]
        FG1[KServe module-controller<br/>CGO_ENABLED=0<br/>Non-FIPS Go crypto]
        FG2[llm-d EPP<br/>Missing strictfipsruntime<br/>build tag]
        FG3[Python Components<br/>MLflow, Feast, vLLM,<br/>Caikit, OGX<br/>Rely on UBI system OpenSSL<br/>No app-level FIPS verify]
    end

    subgraph NetworkSecurity["Network Security"]
        NP1[NetworkPolicies<br/>Per-component ingress rules<br/>Deployed by rhods-operator<br/>+ component operators]
        NP2[Namespace Isolation<br/>4 namespace tiers<br/>Operator, Platform,<br/>Monitoring, User]
        NP3[Allowed Ingress Sources<br/>Gateway namespace<br/>Monitoring namespace<br/>Operator namespace]
    end

    %% Authentication flow
    GW1 -->|ext_authz| GW2
    GW2 -->|delegate| GW3
    GW3 -->|inject| GW4

    Auth1 ---|implemented by| GW1
    Auth2 ---|protects| KubeRBACProxySA
    Auth3 ---|enforced by| Authorino_node
    Auth4 ---|validated by| MaaSAPI_node

    %% RBAC bindings
    SA1 -->|bound to| CR1
    SA2 -->|bound to| CR2
    SA3 -->|bound to| CR3
    SA4 -->|bound to| CR4
    SA5 -->|bound to| CR5
    SA6 -->|bound to| CR6

    %% Secret usage
    SA2 -->|uses| Sec1
    SA2 -->|uses| Sec2
    SA3 -->|uses| Sec2
    SA6 -->|uses| Sec4

    %% TLS relationships
    TLS1 -->|cert from| Sec2
    TLS3 -->|cert from| Sec3
    TLS2 -->|via| Auth2

    %% FIPS
    CS2 -.->|gaps| FIPSGaps

