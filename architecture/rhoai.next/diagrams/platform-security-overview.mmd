graph TD
    subgraph "Authentication Mechanisms"
        OAuth["kube-auth-proxy<br/>OIDC/OAuth2<br/>3 modes: OpenShift OAuth,<br/>External OIDC, Unmanaged"]
        SAR["kube-rbac-proxy<br/>SubjectAccessReview<br/>Pod boundary enforcement"]
        OAuthProxy["OpenShift OAuth Proxy<br/>Ray Dashboard"]
        APIKey["API Key / Bearer Token<br/>MaaS (Kuadrant AuthPolicy),<br/>Llama Stack, vllm-orch-gateway"]
        SATokens["ServiceAccount Tokens<br/>All operators & controllers"]
        mTLSAuth["mTLS Certificates<br/>Ray inter-node, KServe LLMIS,<br/>ModelMesh"]
    end

    subgraph "Key ServiceAccounts"
        SA_Rhods["rhods-operator-controller-manager<br/>Namespace: redhat-ods-operator"]
        SA_KServe["kserve-controller-manager<br/>Namespace: redhat-ods-applications"]
        SA_Kueue["kueue-controller-manager<br/>Namespace: redhat-ods-applications"]
        SA_Kuberay["kuberay-operator<br/>Namespace: redhat-ods-applications"]
        SA_DSPO["dspo-controller-manager<br/>Namespace: redhat-ods-applications"]
        SA_Dashboard["odh-dashboard<br/>Namespace: redhat-ods-applications"]
        SA_ODHModel["odh-model-controller<br/>Namespace: redhat-ods-applications"]
        SA_MaaS["maas-controller<br/>Namespace: redhat-ods-applications"]
    end

    subgraph "ClusterRoles (Most Privileged)"
        CR_Rhods["opendatahub-operator-manager-role<br/>DSC/DSCI, all component CRDs,<br/>namespaces, configmaps, secrets"]
        CR_KServe["kserve-manager-role<br/>InferenceService, LLMInferenceService,<br/>InferenceGraph, ServingRuntime,<br/>LocalModelCache"]
        CR_Kueue["kueue-manager-role<br/>ClusterQueue, Workload,<br/>ResourceFlavor, AdmissionCheck,<br/>jobs, pods"]
        CR_Kuberay["kuberay-operator-role<br/>RayCluster, RayJob, RayService,<br/>deployments, services, HTTPRoutes"]
        CR_DSPO["dspo-manager-role<br/>DSPA, deployments, services,<br/>secrets, routes"]
        CR_ODHModel["odh-model-controller-role<br/>InferenceService, ServingRuntime,<br/>routes, HTTPRoutes, gateways,<br/>EnvoyFilters"]
        CR_MaaS["maas-controller-role<br/>ExternalModel, MaaSModelRef,<br/>MaaSAuthPolicy, Tenant"]
        CR_TrustyAI["trustyai-operator-role<br/>TrustyAIService, LMEvalJob,<br/>GuardrailsOrchestrator,<br/>NemoGuardrails, EvalHub"]
        CR_Training["kubeflow-training-operator<br/>PyTorchJob, TFJob, MPIJob,<br/>XGBoostJob, PaddleJob, JAXJob"]
        CR_Trainer["trainer-controller-manager-role<br/>TrainJob, TrainingRuntime,<br/>ClusterTrainingRuntime"]
        CR_ModelReg["model-registry-operator-manager-role<br/>ModelRegistry, deployments,<br/>services, routes, secrets"]
    end

    subgraph "Critical Secrets"
        Sec_AuthConfig["auth-config<br/>Type: Opaque<br/>OIDC provider config<br/>(client ID, secret, issuer)"]
        Sec_KubeAuthTLS["kube-auth-proxy-tls<br/>Type: kubernetes.io/tls<br/>Gateway auth proxy cert"]
        Sec_StorageConfig["storage-config<br/>Type: Opaque<br/>S3/GCS/Azure creds<br/>for model downloads"]
        Sec_DSPDB["ds-pipeline-db-*<br/>Type: Opaque<br/>MariaDB/MySQL credentials"]
        Sec_DSPS3["ds-pipeline-s3-*<br/>Type: Opaque<br/>S3 object storage creds"]
        Sec_MRDB["model-registry-db-credential<br/>Type: Opaque<br/>PostgreSQL credentials"]
        Sec_MlflowDB["mlflow-*-db<br/>Type: Opaque<br/>PostgreSQL credentials"]
        Sec_MlflowS3["mlflow-*-objstore<br/>Type: Opaque<br/>S3 artifact store creds"]
        Sec_MaaSKey["maas-api-key-*<br/>Type: Opaque<br/>Per-user API keys"]
        Sec_RayTLS["ray-tls-*<br/>Type: kubernetes.io/tls<br/>Per-cluster mTLS certs"]
        Sec_TrustyDB["trustyai-db-credentials<br/>Type: Opaque<br/>Database credentials"]
    end

    subgraph "TLS Configuration"
        TLS_Webhook["Webhook Servers<br/>9443/TCP Server TLS<br/>cert-manager or service-ca<br/>Components: kserve, kueue,<br/>kuberay, training-op, trainer"]
        TLS_Metrics["Metrics Endpoints<br/>8443/TCP Server TLS<br/>kube-rbac-proxy + service-ca<br/>Components: most operators"]
        TLS_Gateway["Gateway TLS<br/>443/TCP TLS Termination<br/>Envoy + service-ca<br/>Reencrypt to backends"]
        TLS_RayMTLS["Ray Inter-Node mTLS<br/>6379/TCP, 8265/TCP<br/>cert-manager per-cluster<br/>Issuer + Certificate"]
        TLS_OperatorWH["Operator Webhooks<br/>8443/TCP Server TLS<br/>OLM-managed certs<br/>rhods-operator"]
        TLS_ModelmeshOpt["ModelMesh Optional TLS<br/>8033/TCP Configurable<br/>Per deployment"]
        TLS_MLMetaOpt["ml-metadata Optional TLS<br/>8080/TCP SSLConfig<br/>Configurable"]
    end

    subgraph "Container Security Patterns"
        CS_NonRoot["Non-root execution<br/>All components<br/>runAsNonRoot: true"]
        CS_ReadOnly["Read-only root filesystem<br/>kube-rbac-proxy, kube-auth-proxy,<br/>operators<br/>emptyDir for writable paths"]
        CS_DropCaps["Drop ALL capabilities<br/>Most operators and services<br/>capabilities.drop: ALL"]
        CS_FIPS["FIPS-compliant crypto<br/>kube-auth-proxy, rhods-operator<br/>Go crypto/tls with FIPS"]
        CS_SCC["SecurityContextConstraints<br/>kserve (LocalModel),<br/>training-operator<br/>Privileged SCC for host access"]
        CS_NetPol["Network Policies<br/>llama-stack-k8s-operator,<br/>odh-deployer, trainer,<br/>modelmesh-serving"]
    end

    subgraph "Service Mesh & Network Security"
        SM_GatewayAPI["Gateway API (Envoy)<br/>Central data-science-gateway<br/>HTTPRoute-based routing"]
        SM_mTLS["mTLS Support<br/>STRICT/PERMISSIVE per<br/>DestinationRule<br/>KServe LLMIS, Ray inter-node"]
        SM_NetPol["Network Policies<br/>Per-component ingress/egress<br/>restriction"]
        SM_FIPS_Crypto["FIPS Cryptography<br/>Go BoringCrypto for core infra"]
    end

    %% RBAC Bindings (ServiceAccount → ClusterRole)
    SA_Rhods -->|bound to| CR_Rhods
    SA_KServe -->|bound to| CR_KServe
    SA_Kueue -->|bound to| CR_Kueue
    SA_Kuberay -->|bound to| CR_Kuberay
    SA_DSPO -->|bound to| CR_DSPO
    SA_ODHModel -->|bound to| CR_ODHModel
    SA_MaaS -->|bound to| CR_MaaS
    SA_Dashboard -->|bound to| SA_Dashboard

    %% Secret Usage
    SA_Rhods -->|uses| Sec_AuthConfig
    SA_Rhods -->|uses| Sec_KubeAuthTLS
    SA_KServe -->|uses| Sec_StorageConfig
    SA_DSPO -->|uses| Sec_DSPDB
    SA_DSPO -->|uses| Sec_DSPS3
    SA_MaaS -->|manages| Sec_MaaSKey

    %% Auth mechanism usage
    OAuth -->|fronts| SA_Dashboard
    SAR -.->|sidecar for| SA_Dashboard
    SAR -.->|sidecar for| SA_DSPO
    SAR -.->|sidecar for| SA_ODHModel
    SAR -.->|sidecar for| SA_Kueue
    SAR -.->|sidecar for| SA_Kuberay
    OAuthProxy -->|fronts| SA_Kuberay
    APIKey -->|used by| SA_MaaS
    SATokens -->|used by| SA_Rhods
    SATokens -->|used by| SA_KServe
    SATokens -->|used by| SA_Kueue
    mTLSAuth -->|secures| Sec_RayTLS

    %% TLS relationships
    TLS_Gateway -->|certs from| Sec_KubeAuthTLS
    TLS_RayMTLS -->|certs from| Sec_RayTLS

    %% Service mesh enforcement
    SM_GatewayAPI -->|routes via| TLS_Gateway
    SM_mTLS -->|enforces| mTLSAuth
    SM_NetPol -->|restricts| CS_NetPol

