graph TD
    subgraph AuthMech["Authentication Mechanisms"]
        OAuth["OAuth2/OIDC<br/>kube-auth-proxy<br/>Gateway-level"]
        SAR["SubjectAccessReview<br/>kube-rbac-proxy<br/>Sidecar-level"]
        APIKey["API Key (sk-oai-*)<br/>Kuadrant/Authorino<br/>MaaS endpoints"]
        BearerToken["Bearer Token<br/>Kubernetes SA<br/>TokenReview API"]
        mTLSCM["mTLS (cert-manager)<br/>CodeFlare/Ray<br/>Cluster certificates"]
        mTLSSS["mTLS (self-signed)<br/>LLMInferenceService<br/>Controller-generated"]
        NoAuth["Platform-delegated<br/>vLLM, TGIS, Caikit,<br/>OpenVINO (no built-in)"]
    end

    subgraph ServiceAccounts["Key ServiceAccounts"]
        SA_Rhods["rhods-operator-controller-manager<br/>NS: redhat-ods-applications"]
        SA_KServe["kserve-controller-manager<br/>NS: redhat-ods-applications"]
        SA_LLMISVC["llmisvc-controller-manager<br/>NS: redhat-ods-applications"]
        SA_Kueue["kueue-controller-manager<br/>NS: redhat-ods-applications"]
        SA_DSP["dspo-controller-manager<br/>NS: redhat-ods-applications"]
        SA_MaaS["maas-controller<br/>NS: redhat-ods-applications"]
        SA_Training["training-operator<br/>NS: redhat-ods-applications"]
        SA_Trainer["trainer-controller-manager<br/>NS: redhat-ods-applications"]
        SA_TrustyAI["trustyai-service-operator<br/>NS: redhat-ods-applications"]
        SA_ModelMesh["modelmesh-controller<br/>NS: redhat-ods-applications"]
    end

    subgraph ClusterRoles["ClusterRoles (Top Privileged)"]
        CR_Rhods["opendatahub-operator-manager-role<br/>datascienceclusters, dscinitializations,<br/>16 component CRDs, namespaces,<br/>deployments, routes, oauthclients,<br/>gateways, httproutes, envoyfilters"]
        CR_KServe["kserve-manager-role<br/>inferenceservices, servingruntimes,<br/>deployments, services, httproutes,<br/>virtualservices, scaledobjects"]
        CR_LLMISVC["llmisvc-manager-role<br/>llminferenceservices, inferencepools,<br/>inferencemodels, httproutes,<br/>leaderworkersets, variantautoscalings"]
        CR_Kueue["kueue-manager-role<br/>clusterqueues, localqueues, workloads,<br/>admissionchecks, resourceflavors,<br/>pytorchjobs, tfjobs, rayclusters"]
        CR_DSP["manager-role (DSP)<br/>datasciencepipelinesapplications,<br/>deployments, secrets, routes,<br/>workflows, servicemonitors"]
        CR_MaaS["maas-controller-role<br/>externalmodels, maasmodelrefs,<br/>maasauthpolicies, httproutes,<br/>authpolicies, tokenratelimitpolicies"]
    end

    subgraph Secrets["Critical Secrets"]
        Sec_AuthProxy["kube-auth-proxy-creds<br/>Type: Opaque<br/>OAuth2 client ID/secret + cookie secret"]
        Sec_AuthProxyTLS["kube-auth-proxy-tls<br/>Type: kubernetes.io/tls<br/>TLS cert for auth proxy"]
        Sec_KServeWH["kserve-webhook-server-cert<br/>Type: kubernetes.io/tls<br/>Webhook TLS certificate"]
        Sec_StorageConfig["storage-config<br/>Type: Opaque<br/>S3/GCS/Azure/HF credentials"]
        Sec_LLMTls["llmSvc-kserve-self-signed-certs<br/>Type: kubernetes.io/tls<br/>LLM workload self-signed TLS"]
        Sec_DSP_DB["ds-pipeline-db-*<br/>Type: Opaque<br/>MariaDB credentials"]
        Sec_DSP_S3["ds-pipeline-s3-*<br/>Type: Opaque<br/>S3 storage credentials"]
        Sec_MaaS_DB["maas-db-secret<br/>Type: Opaque<br/>PostgreSQL connection URL"]
        Sec_RayTLS["Ray cluster TLS secrets<br/>Type: kubernetes.io/tls<br/>cert-manager mTLS certs"]
    end

    subgraph TLSConfig["TLS Configuration"]
        TLS_Webhooks["Webhooks<br/>9443/TCP Server TLS<br/>cert-manager or service-ca<br/>Components: rhods-operator, kserve,<br/>kueue, spark-operator, trainer"]
        TLS_Metrics["Metrics<br/>8443/TCP Server TLS<br/>kube-rbac-proxy / direct TLS<br/>Components: rhods-operator, kserve,<br/>kueue, DSP, MaaS, TrustyAI, Trainer"]
        TLS_ServiceCA["OpenShift Service-CA<br/>Automatic provisioning<br/>Components: DSP, kserve,<br/>rhods-operator, modelmesh"]
        TLS_SelfSigned["Self-Signed<br/>Controller-generated<br/>Components: LLMInferenceService,<br/>MaaS API (RSA-4096)"]
        TLS_CertManager["cert-manager mTLS<br/>Per-cluster certificates<br/>Components: CodeFlare/Ray,<br/>fms-guardrails-orchestrator"]
        TLS_HotReload["Certificate Hot-Reload<br/>8000/TCP Server TLS<br/>Components: vllm-cpu"]
    end

    subgraph ContainerSec["Container Security Patterns"]
        CS_NonRoot["Non-root execution<br/>UID 1001, 2000, or 65532<br/>ALL components"]
        CS_UBI9["UBI9 base images<br/>FIPS-validated crypto<br/>ALL components"]
        CS_FIPS["FIPS compliance<br/>GOEXPERIMENT=strictfipsruntime<br/>Go operators"]
        CS_ReadOnly["Read-only root filesystem<br/>kube-rbac-proxy,<br/>kube-auth-proxy"]
        CS_CapDrop["ALL capabilities dropped<br/>kube-rbac-proxy,<br/>kueue, trainer"]
        CS_SCC["SecurityContextConstraints<br/>Privileged operations<br/>localmodelnode-agent,<br/>LLMInferenceService"]
        CS_Hermetic["Hermetic builds<br/>Konflux + cachi2<br/>ALL images"]
        CS_Digest["Digest pinning<br/>SHA256 image refs<br/>ALL operator CSVs"]
    end

    subgraph ServiceMeshSec["Service Mesh Security"]
        PA_Strict["PeerAuthentication<br/>Mode: STRICT mTLS<br/>KServe InferenceService,<br/>CodeFlare/Ray pods"]
        DR_Simple["DestinationRule<br/>SIMPLE TLS (insecureSkipVerify)<br/>data-science-gateway → backends"]
        EF_Auth["EnvoyFilter<br/>ext_authz + Lua filter<br/>data-science-gateway"]
        NP_Webhook["NetworkPolicy<br/>Restrict webhook ingress<br/>kueue, DSP, trainer, spark"]
    end

    %% RBAC Bindings
    SA_Rhods -->|bound to| CR_Rhods
    SA_KServe -->|bound to| CR_KServe
    SA_LLMISVC -->|bound to| CR_LLMISVC
    SA_Kueue -->|bound to| CR_Kueue
    SA_DSP -->|bound to| CR_DSP
    SA_MaaS -->|bound to| CR_MaaS

    %% Secret usage
    SA_Rhods -->|uses| Sec_AuthProxy
    SA_Rhods -->|uses| Sec_AuthProxyTLS
    SA_KServe -->|uses| Sec_KServeWH
    SA_KServe -->|uses| Sec_StorageConfig
    SA_LLMISVC -->|generates| Sec_LLMTls
    SA_DSP -->|uses| Sec_DSP_DB
    SA_DSP -->|uses| Sec_DSP_S3
    SA_MaaS -->|uses| Sec_MaaS_DB

    %% Auth mechanism usage
    OAuth -->|gateway auth| SA_Rhods
    SAR -->|sidecar auth| SA_KServe
    SAR -->|sidecar auth| SA_DSP
    SAR -->|sidecar auth| SA_TrustyAI
    APIKey -->|MaaS auth| SA_MaaS
    BearerToken -->|token validation| SA_KServe
    mTLSCM -->|Ray clusters| Sec_RayTLS
    mTLSSS -->|LLM workloads| Sec_LLMTls

    %% Service mesh relationships
    PA_Strict -->|enforces| mTLSCM
    PA_Strict -->|enforces| mTLSSS
    EF_Auth -->|delegates to| OAuth
    NP_Webhook -->|restricts| TLS_Webhooks

    %% TLS → Secrets
    TLS_Webhooks -->|cert from| Sec_KServeWH
    TLS_SelfSigned -->|generates| Sec_LLMTls
    TLS_CertManager -->|provisions| Sec_RayTLS

