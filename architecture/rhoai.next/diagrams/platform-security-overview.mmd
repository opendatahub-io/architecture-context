    subgraph MetricsTLS["Metrics TLS (kube-rbac-proxy)"]
        MTLS_kserve["kserve metrics<br/>9443/TCP Server TLS<br/>service-ca"]
        MTLS_kubeflow["kubeflow metrics<br/>8443/TCP Server TLS<br/>service-ca"]
        MTLS_kuberay["kuberay metrics<br/>8443/TCP Server TLS<br/>service-ca"]
