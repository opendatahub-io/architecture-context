        SA_maas["maas-controller<br/>NS: redhat-ods-applications"]
        SA_dashboard["odh-dashboard<br/>NS: redhat-ods-applications"]
    end

    subgraph CRoles["ClusterRoles (Most Privileged)"]
        CR_rhods["rhods-operator-manager-role<br/>DataScienceCluster, DSCInitialization,<br/>16+ component CRDs, Deployments, ConfigMaps<br/>Verbs: * (full CRUD)"]
        CR_kserve["kserve-manager-role<br/>InferenceService, ServingRuntime,<br/>Pods, Services, Events<br/>Verbs: * (full CRUD)"]
        CR_kserve_llm["kserve-llmisvc-manager-role<br/>LLMInferenceService, InferencePool,<br/>InferenceModel<br/>Verbs: * (full CRUD)"]
        CR_kueue["kueue-manager-role<br/>ClusterQueue, LocalQueue, Workload,<br/>Jobs, JobSets, Pods<br/>Verbs: * (full CRUD)"]
        CR_kuberay["kuberay-operator-role<br/>RayCluster, RayJob, RayService,<br/>Pods, Services, NetworkPolicy<br/>Verbs: * (full CRUD)"]
        CR_training["training-operator-role<br/>PyTorchJob, TFJob, MPIJob,<br/>JAXJob, XGBoostJob, PaddleJob<br/>Verbs: * (full CRUD)"]
        CR_trustyai["trustyai-operator-role<br/>TrustyAIService, LMEvalJob,<br/>GuardrailsOrchestrator, EvalHub<br/>Verbs: * (full CRUD)"]
        CR_maas["maas-controller-role<br/>Tenant, MaaSModelRef,<br/>MaaSAuthPolicy, MaaSSubscription<br/>Verbs: * (full CRUD)"]
        CR_dashboard["dashboard-role<br/>OdhDashboardConfig, ConfigMaps, Secrets<br/>Verbs: get, list, watch<br/>(read-only)"]
    end

    subgraph Secrets["Critical Secrets"]
        Sec_storage["storage-config<br/>Type: Opaque<br/>S3/GCS/Azure model creds<br/>Components: kserve, modelmesh"]
        Sec_cookie["cookie-secret<br/>Type: Opaque<br/>AES-CFB/GCM session key<br/>Component: kube-auth-proxy"]
        Sec_client["client-secret<br/>Type: Opaque<br/>OAuth2 client secret<br/>Component: kube-auth-proxy"]
        Sec_etcd["etcd-secret<br/>Type: Opaque<br/>etcd connection creds<br/>Component: modelmesh-serving"]
        Sec_mlflow_kek["MLFLOW_CRYPTO_KEK<br/>Type: Opaque<br/>AES-256-GCM KEK passphrase<br/>Component: mlflow"]
        Sec_maas_keys["sk-oai-{key_id}<br/>Type: Opaque<br/>SHA-256 hashed API keys<br/>Component: models-as-a-service"]
        Sec_db_creds["database credentials<br/>Type: Opaque<br/>PostgreSQL/MariaDB creds<br/>Components: model-registry-op,<br/>DS Pipelines, mlflow"]
    end

    subgraph WebhookTLS["Webhook TLS Certificates"]
        TLS_kserve["kserve webhook<br/>8443/TCP Server TLS<br/>cert-manager / self-signed"]
