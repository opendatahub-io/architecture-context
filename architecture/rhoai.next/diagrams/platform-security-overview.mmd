graph TD
    subgraph AuthMechanisms["Authentication Mechanisms"]
        OAuth["kube-auth-proxy<br/>(OAuth2/OIDC)<br/>Centralized gateway auth<br/>Replaces per-component<br/>oauth-proxy (2.x)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(SubjectAccessReview)<br/>Per-service sidecar<br/>Bearer → TokenReview + SAR"]
        KuadrantAuth["Kuadrant AuthPolicy<br/>(Authorino)<br/>API keys, OIDC JWT,<br/>TokenReview, OPA policies"]
        BearerPassthrough["Bearer Token<br/>Passthrough<br/>User tokens → K8s API<br/>native RBAC enforcement"]
        RayMTLS["Ray mTLS<br/>Self-signed per-cluster CA<br/>Init container generated<br/>Cert rotation = cluster recreate"]
        NoneAuth["None<br/>(Platform-delegated)<br/>Unauthenticated runtimes<br/>Auth at ingress layer"]
    end

    subgraph KeyServiceAccounts["Key ServiceAccounts"]
        SA_rhods["rhods-operator-<br/>controller-manager<br/>NS: redhat-ods-operator"]
        SA_kserve["kserve-controller-<br/>manager<br/>NS: redhat-ods-applications"]
        SA_dashboard["odh-dashboard<br/>NS: redhat-ods-applications"]
        SA_kueue["kueue-controller-<br/>manager<br/>NS: redhat-ods-applications"]
        SA_odmctrl["odh-model-controller<br/>NS: redhat-ods-applications"]
        SA_maas["maas-controller-<br/>manager<br/>NS: redhat-ods-applications"]
        SA_dspo["data-science-pipelines-<br/>operator<br/>NS: redhat-ods-applications"]
        SA_modelreg["model-registry-operator<br/>NS: redhat-ods-applications"]
        SA_codeflare["codeflare-operator<br/>NS: redhat-ods-applications"]
        SA_trustyai["trustyai-service-<br/>operator<br/>NS: redhat-ods-applications"]
    end

    subgraph ClusterRoles["ClusterRoles (Most Privileged)"]
        CR_rhods["rhods-operator-controller-manager<br/>Resources: 28 owned CRDs,<br/>DSC/DSCI reconciliation,<br/>namespaces, deployments, RBAC<br/>Scope: CLUSTER-WIDE"]
        CR_kserve["kserve-controller-manager<br/>Resources: serving.kserve.io/*,<br/>core/services, apps/deployments,<br/>networking.istio.io/*,<br/>serving.knative.dev/*<br/>Scope: CLUSTER-WIDE"]
        CR_kueue["kueue-controller-manager<br/>Resources: kueue.x-k8s.io/*,<br/>batch/jobs, rayjob.io/*,<br/>kubeflow.org/pytorchjobs<br/>Scope: CLUSTER-WIDE"]
        CR_odmctrl["odh-model-controller<br/>Resources: serving.kserve.io/*,<br/>gateway.networking.k8s.io/*,<br/>kuadrant.io/authpolicies<br/>Scope: CLUSTER-WIDE"]
        CR_maas["maas-controller-manager<br/>Resources: modelsaas.opendatahub.io/*,<br/>kuadrant.io/*, serving.kserve.io/*<br/>Scope: CLUSTER-WIDE"]
    end

    subgraph RBACStats["RBAC Statistics"]
        RBACCount["674 Roles across platform<br/>23 NetworkPolicies<br/>135 CRDs total"]
    end

    subgraph CriticalSecrets["Critical Secrets"]
        SecWebhook["Webhook TLS Certificates<br/>Type: kubernetes.io/tls<br/>Components: KServe, Kueue,<br/>CodeFlare, KubeRay, Training Op,<br/>Model Registry Op, MaaS<br/>Rotation: service-ca auto"]
        SecStorage["storage-config<br/>Type: Opaque<br/>S3 credentials for model storage<br/>Used by: KServe, runtimes"]
        SecOAuth["OAuth/OIDC Configuration<br/>Type: Opaque<br/>kube-auth-proxy credentials<br/>Used by: centralized gateway"]
        SecRay["Per-cluster TLS CA<br/>Type: generated at pod init<br/>Self-signed CA + per-pod certs<br/>Used by: Ray head/workers"]
        SecMLflow["MLflow Storage Secrets<br/>Type: Opaque<br/>SeaweedFS credentials<br/>per-namespace instances"]
    end

    subgraph TLSConfig["TLS Configuration"]
        TLS_ext["External Ingress<br/>Port: 443/TCP<br/>TLS 1.3<br/>Source: OpenShift Router"]
        TLS_webhook["Webhook Servers<br/>Port: 9443/TCP<br/>Server TLS<br/>Source: service-ca"]
        TLS_metrics["Metrics Endpoints<br/>Port: 8443/TCP<br/>Server TLS<br/>Source: kube-rbac-proxy"]
        TLS_mesh["Service Mesh<br/>Istio mTLS STRICT<br/>KServe/Knative workloads<br/>Source: Istio CA"]
        TLS_internal["Internal Services<br/>service-ca signed certs<br/>DSPO, Model Registry,<br/>dashboard BFF, kube-rbac-proxy"]
        TLS_ray["Ray Clusters<br/>Self-signed per-cluster CA<br/>Init container generated<br/>Head + worker mTLS"]
    end

    subgraph ContainerSecurity["Container Security Patterns"]
        CS_nonroot["Non-root (USER 1001)<br/>127 Dockerfiles, 40+ components<br/>No privilege escalation"]
        CS_distroless["Distroless (USER 65532)<br/>74 Dockerfiles<br/>No shell, no pkg manager<br/>Go controllers, KServe, Kueue"]
        CS_ubi["UBI Base Images<br/>149 Dockerfiles<br/>RHEL-compatible, CVE-patched"]
        CS_fips["FIPS Cryptography<br/>All 71 components<br/>Go: boringcrypto/systemcrypto<br/>Python: UBI FIPS OpenSSL"]
        CS_hermetic["Hermetic Builds<br/>Konflux/cachi2<br/>Zero-network builds<br/>Supply chain integrity"]
        CS_multistage["Multi-stage Builds<br/>Builder → Runtime only<br/>No build toolchain in prod<br/>vLLM, llm-d, Go operators"]
    end

    subgraph ServiceMeshSecurity["Service Mesh Security"]
        PA["PeerAuthentication<br/>Mode: STRICT<br/>Scope: KServe/Knative workloads<br/>Istio mTLS enforcement"]
        AP_kserve["AuthorizationPolicies<br/>KServe controller access"]
        AP_gateway["AuthorizationPolicies<br/>Gateway ext_authz integration"]
        NP["NetworkPolicies<br/>23 policies platform-wide<br/>Pod-to-pod isolation<br/>CodeFlare-managed for Ray"]
    end

    subgraph MaaSSecurityLayer["MaaS Security (3-Layer)"]
        MaaS_Authorino["Layer 1: Authorino<br/>API key validation (HTTP callback)<br/>K8s TokenReview<br/>OIDC JWT validation"]
        MaaS_OPA["Layer 2: OPA Policies<br/>Group membership checks<br/>Subscription validity"]
        MaaS_Limitador["Layer 3: Limitador<br/>Per-subscription rate limits<br/>Quota enforcement"]
    end

    %% Auth → ServiceAccount bindings
    OAuth -->|used by| SA_dashboard
    KubeRBACProxy -->|sidecar for| SA_dashboard
    KubeRBACProxy -->|sidecar for| SA_modelreg
    KubeRBACProxy -->|sidecar for| SA_kserve
    KubeRBACProxy -->|sidecar for| SA_codeflare
    KubeRBACProxy -->|sidecar for| SA_dspo
    KubeRBACProxy -->|sidecar for| SA_trustyai
    KuadrantAuth -->|policy for| SA_maas
    KuadrantAuth -->|policy for| SA_odmctrl
    BearerPassthrough -->|used by| SA_dashboard
    RayMTLS -->|managed by| SA_codeflare
    NoneAuth -.->|delegated| SA_kserve

    %% SA → ClusterRole bindings
    SA_rhods -->|bound to| CR_rhods
    SA_kserve -->|bound to| CR_kserve
    SA_kueue -->|bound to| CR_kueue
    SA_odmctrl -->|bound to| CR_odmctrl
    SA_maas -->|bound to| CR_maas

    %% Secrets usage
    SA_kserve -->|uses| SecWebhook
    SA_kserve -->|uses| SecStorage
    SA_dashboard -->|uses| SecOAuth
    SA_codeflare -->|generates| SecRay

    %% Service mesh enforcement
    PA -->|enforces| TLS_mesh
    AP_kserve -->|allows| SA_kserve
    AP_gateway -->|integrates| OAuth
    NP -->|isolates| SA_codeflare

    %% MaaS security chain
    MaaS_Authorino -->|feeds| MaaS_OPA
    MaaS_OPA -->|gates| MaaS_Limitador
    KuadrantAuth -->|implements| MaaS_Authorino

    %% TLS relationships
    TLS_webhook -->|cert from| SecWebhook
    TLS_ray -->|cert from| SecRay

