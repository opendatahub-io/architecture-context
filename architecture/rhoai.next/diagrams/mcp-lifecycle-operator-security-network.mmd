graph TB
    subgraph External["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(mcp-lifecycle-operator-system)"]
        direction TB
        Operator["MCP Lifecycle Operator<br/>SA: controller-manager<br/>Image: UBI9-minimal (FIPS)<br/>non-root, read-only rootfs"]
        MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS: self-signed<br/>Auth: Bearer → TokenReview<br/>HTTP/2 DISABLED"]
        HealthEndpoint["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz<br/>No auth"]
        Operator --- MetricsEndpoint
        Operator --- HealthEndpoint
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph UserNS["USER NAMESPACES (any)"]
        direction TB
        MCPServerCR["MCPServer CR<br/>mcp.x-k8s.io/v1alpha1<br/>Namespaced"]
        subgraph ManagedResources["Managed Resources (per MCPServer)"]
            direction TB
            Deploy["Deployment<br/>SecurityContext: restricted PSS<br/>non-root, drop ALL, seccomp"]
            Svc["ClusterIP Service<br/>{port}/TCP HTTP<br/>No encryption<br/>Internal only"]
            MCPPod["MCP Server Pod<br/>User container image<br/>{spec.config.port}/TCP"]
            Deploy --> MCPPod
        end
        MCPServerCR -->|"ownerReferences"| Deploy
        MCPServerCR -->|"ownerReferences"| Svc
        Svc -->|"routes to"| MCPPod
    end

    subgraph ConfigData["CONFIGURATION DATA"]
        ConfigMaps["ConfigMaps<br/>(referenced by MCPServer)"]
        Secrets["Secrets<br/>(referenced by MCPServer)"]
    end

    %% Flows with security details
    Prometheus -->|"HTTPS/8443<br/>TLS self-signed<br/>Bearer Token<br/>metrics-reader role"| MetricsEndpoint

    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SA)<br/>CRUD Deployments, Services<br/>PATCH MCPServer/status"| K8sAPI

    Operator -->|"HTTP/{port}<br/>Plaintext<br/>No auth<br/>MCP initialize handshake<br/>(401/403 = reachable)"| MCPPod

    Operator -->|"via K8s API<br/>GET/LIST/WATCH"| ConfigMaps
    Operator -->|"via K8s API<br/>GET/LIST/WATCH"| Secrets

    %% Styling
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef configdata fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Operator,MetricsEndpoint,HealthEndpoint operatorns
    class K8sAPI controlplane
    class MCPServerCR,Deploy,Svc,MCPPod userns
    class Prometheus monitoring
    class ConfigMaps,Secrets configdata
