graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>/ KServe Router"]
    end

    subgraph PodBoundary["POD BOUNDARY (InferenceService Pod)"]
        direction TB

        subgraph AuthLayer["AUTH LAYER"]
            Proxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS 1.2+ Termination<br/>Bearer Token AuthN/AuthZ"]
        end

        subgraph AppLayer["APPLICATION LAYER (No TLS — plaintext)"]
            direction TB
            REST["REST Server (FastAPI/Uvicorn)<br/>8080/TCP HTTP<br/>No Auth (delegated to sidecar)<br/>CORS restricted in production"]
            GRPC["gRPC Server (grpc.aio)<br/>8081/TCP gRPC<br/>No Auth (delegated to sidecar)<br/>add_insecure_port()"]
            Metrics["Metrics Server<br/>8082/TCP HTTP<br/>No Auth<br/>Prometheus /metrics"]
        end

        subgraph SecurityControls["SECURITY CONTROLS"]
            TrustedRT["Trusted Runtime Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>Blocks arbitrary code execution"]
            ProdMode["Production Mode<br/>No env tarballs<br/>No wildcard CORS<br/>No dynamic sys.path"]
        end

        subgraph Storage["MODEL STORAGE"]
            Models["/mnt/models<br/>Read-only mount<br/>PVC or Storage Initializer"]
        end
    end

    subgraph EgressServices["EGRESS (Optional External Services)"]
        Prom["Prometheus<br/>Scrapes 8082/TCP<br/>HTTP, No TLS, No Auth"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>insecure=True, No Auth"]
        Kafka["Apache Kafka Brokers<br/>9092/TCP Kafka protocol<br/>Encryption: Configurable<br/>Auth: Configurable"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| Proxy
    Proxy -->|"HTTP/8080<br/>plaintext (pod-local)<br/>No Auth"| REST
    Proxy -->|"gRPC/8081<br/>plaintext (pod-local)<br/>No Auth"| GRPC

    %% Egress flows
    Metrics -.->|"HTTP/8082<br/>No TLS, No Auth"| Prom
    REST -.->|"gRPC/4317<br/>insecure=True"| OTel
    REST -.->|"Kafka/9092<br/>Configurable"| Kafka

    %% Security controls
    TrustedRT -.->|"validates runtime loading"| REST
    TrustedRT -.->|"validates runtime loading"| GRPC
    Models -.->|"model artifacts"| REST

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef auth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef security fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class Proxy auth
    class REST,GRPC,Metrics app
    class TrustedRT,ProdMode security
    class Models storage
    class Prom,OTel,Kafka egress
