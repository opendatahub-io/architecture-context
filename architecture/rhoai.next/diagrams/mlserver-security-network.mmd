graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (TLS Termination)"]
        Gateway["KServe Gateway / Istio /<br/>kube-rbac-proxy<br/>TLS 1.2+ Termination<br/>AuthN/AuthZ Enforcement"]
    end

    subgraph MLServerPod["MLSERVER POD (Internal - No Direct External Access)"]
        direction TB

        subgraph Servers["Network Listeners"]
            RESTServer["REST Server<br/>FastAPI/Uvicorn<br/>0.0.0.0:8080/TCP<br/>HTTP (plaintext)"]
            GRPCServer["gRPC Server<br/>grpc.aio<br/>0.0.0.0:8081/TCP<br/>gRPC/HTTP2 (plaintext)"]
            MetricsServer["Metrics Server<br/>starlette-exporter<br/>0.0.0.0:8082/TCP<br/>HTTP (plaintext)"]
        end

        subgraph SecurityLayer["Application Security"]
            TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>RHOAI: sklearn, xgboost, lightgbm, onnx"]
            CORSPolicy["CORS Policy<br/>Production: No wildcard origins"]
        end

        subgraph InferenceEngine["Inference Engine"]
            DataPlane["DataPlane + ModelRegistry"]
            Runtimes["ML Runtimes<br/>(sklearn/xgboost/lightgbm/onnx)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelStorage["Model Storage (PVC)<br/>/mnt/models<br/>Filesystem"]
        OTelCollector["OTel Collector<br/>4317/TCP gRPC<br/>insecure=True (plaintext)"]
        KafkaCluster["Kafka Cluster (optional)<br/>9092/TCP Kafka protocol<br/>Encryption: Configurable"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443 or gRPC+TLS<br/>TLS 1.2+<br/>Bearer Token / kube-rbac-proxy"| Gateway

    %% Ingress to MLServer (plaintext after TLS termination)
    Gateway -->|"HTTP/8080<br/>PLAINTEXT<br/>No Auth (enforced at ingress)"| RESTServer
    Gateway -->|"gRPC/8081<br/>PLAINTEXT<br/>No Auth (enforced at ingress)"| GRPCServer

    %% Internal flows
    RESTServer --> DataPlane
    GRPCServer --> DataPlane
    TrustedRuntimes -.->|"validates runtime loading"| DataPlane
    CORSPolicy -.->|"validates origins"| RESTServer
    DataPlane --> Runtimes

    %% Egress
    Runtimes -->|"Filesystem<br/>/mnt/models"| ModelStorage
    RESTServer -->|"gRPC/4317<br/>PLAINTEXT (insecure=True)<br/>No Auth"| OTelCollector
    RESTServer -.->|"Kafka/9092<br/>Configurable encryption<br/>No Auth"| KafkaCluster
    Prometheus -->|"HTTP/8082<br/>PLAINTEXT<br/>No Auth"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef server fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef security fill:#f5a623,stroke:#d79b00,stroke-width:2px
    classDef engine fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class RESTServer,GRPCServer,MetricsServer server
    class TrustedRuntimes,CORSPolicy security
    class DataPlane,Runtimes engine
    class ModelStorage,OTelCollector,KafkaCluster,Prometheus externalservice
