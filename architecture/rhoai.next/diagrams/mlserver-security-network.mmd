graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe-Managed)"]
        KServeIngress["KServe InferenceService<br/>Istio Gateway / Gateway API<br/>443/TCP HTTPS<br/>TLS Termination<br/>AuthN: kube-rbac-proxy / oauth-proxy"]
    end

    subgraph PodNetwork["POD NETWORK (MLServer Container - Plaintext)"]
        direction TB

        RESTServer["REST Server (FastAPI/Uvicorn)<br/>8080/TCP HTTP<br/>Encryption: NONE<br/>Auth: NONE<br/>V2 Inference Protocol"]

        GRPCServer["gRPC Server (grpcio)<br/>8081/TCP gRPC<br/>Encryption: NONE (insecure_port)<br/>Auth: NONE<br/>V2 Inference Protocol"]

        MetricsServer["Metrics Server<br/>8082/TCP HTTP<br/>Encryption: NONE<br/>Auth: NONE<br/>/metrics endpoint"]

        ModelAgent["KServe Model Agent (sidecar)<br/>→ 8080/TCP HTTP<br/>Model load/unload lifecycle"]

        TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>PRODUCTION mode enforcement"]
    end

    subgraph Egress["EGRESS (Outbound)"]
        KafkaBrokers["Kafka Brokers<br/>9092/TCP<br/>Protocol: TCP<br/>Encryption: None (configurable)<br/>Auth: None"]
        OTelCollector["OpenTelemetry Collector<br/>Configurable Port<br/>Protocol: gRPC<br/>Encryption: None (insecure=True)<br/>Auth: None"]
    end

    subgraph Volumes["FILESYSTEM / VOLUMES"]
        ModelStorage["/mnt/models<br/>Model Artifacts<br/>PVC or S3-backed<br/>Read-only"]
        SANamespace["/var/run/secrets/.../namespace<br/>ServiceAccount<br/>Read-only"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>8082/TCP HTTP"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer/OAuth"| KServeIngress
    KServeIngress -->|"HTTP/8080<br/>Plaintext<br/>Post-TLS-termination"| RESTServer
    KServeIngress -->|"gRPC/8081<br/>Plaintext<br/>Post-TLS-termination"| GRPCServer
    ModelAgent -->|"HTTP/8080<br/>Plaintext<br/>load/unload"| RESTServer
    RESTServer -->|"gRPC<br/>insecure=True"| OTelCollector
    GRPCServer -->|"gRPC<br/>insecure=True"| OTelCollector
    RESTServer -.->|"TCP/9092"| KafkaBrokers
    Prometheus -->|"HTTP/8082<br/>Plaintext"| MetricsServer
    ModelStorage -.->|"Local FS<br/>Read-only"| RESTServer
    SANamespace -.->|"Local FS<br/>Read-only"| RESTServer
    TrustedRuntimes -.->|"Validates runtime<br/>implementations"| RESTServer
    TrustedRuntimes -.->|"Validates runtime<br/>implementations"| GRPCServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef volumes fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class KServeIngress ingress
    class RESTServer,GRPCServer,MetricsServer,ModelAgent podnetwork
    class TrustedRuntimes security
    class KafkaBrokers,OTelCollector egress
    class ModelStorage,SANamespace volumes
    class Prometheus monitoring
