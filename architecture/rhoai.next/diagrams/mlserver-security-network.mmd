graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Managed by KServe"]
        Gateway["Istio Gateway / KServe Ingress<br/>443/TCP → 8080/8081<br/>TLS Termination<br/>Platform AuthN/AuthZ"]
    end

    subgraph Application["APPLICATION (MLServer Pod - UID 1000)"]
        direction TB

        subgraph Servers["Server Processes"]
            REST["REST Server<br/>0.0.0.0:8080/TCP<br/>HTTP (FastAPI/Uvicorn)<br/>No App-Level Auth"]
            GRPC["gRPC Server<br/>0.0.0.0:8081/TCP<br/>gRPC (insecure)<br/>No App-Level Auth"]
            Metrics["Metrics Server<br/>0.0.0.0:8082/TCP<br/>HTTP /metrics<br/>No Auth"]
        end

        subgraph RuntimeSec["Runtime Security (PRODUCTION)"]
            Allowlist["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>LightGBM, ONNX, SKLearn, XGBoost<br/>Blocks arbitrary code execution"]
        end
    end

    subgraph EgressZone["EGRESS"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>Encryption: None (insecure)<br/>No Auth"]
        Kafka["Kafka Brokers<br/>9092/TCP AMQP<br/>Encryption: Configurable<br/>No Auth"]
        UpstreamModel["Inference Model Endpoint<br/>(Alibi Explain)<br/>HTTP/HTTPS, Configurable"]
    end

    subgraph Storage["LOCAL STORAGE"]
        ModelPVC["Model Storage (PVC/S3)<br/>/mnt/models<br/>Filesystem mount<br/>Provisioned by KServe"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8082/TCP<br/>HTTP /metrics"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8080<br/>No encryption (post-TLS)<br/>Service Identity"| REST
    Gateway -->|"gRPC/8081<br/>No encryption (post-TLS)<br/>Service Identity"| GRPC

    %% Egress flows
    REST -->|"gRPC/4317<br/>OTLP insecure<br/>No Auth"| OTel
    GRPC -->|"gRPC/4317<br/>OTLP insecure<br/>No Auth"| OTel
    REST -.->|"AMQP/9092<br/>Configurable"| Kafka
    REST -.->|"HTTP(S)/varies<br/>ssl_verify_path"| UpstreamModel

    %% Storage
    ModelPVC -->|"Filesystem<br/>/mnt/models"| Application

    %% Monitoring
    Prometheus -->|"HTTP/8082<br/>Scrape /metrics"| Metrics

    %% Security enforcement
    Allowlist -.->|"restricts"| Servers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class REST,GRPC,Metrics application
    class OTel,Kafka,UpstreamModel egress
    class ModelPVC storage
    class Prometheus monitoring
    class Allowlist security
