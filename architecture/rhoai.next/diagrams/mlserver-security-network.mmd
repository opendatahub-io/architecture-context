graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist"]
    end

    subgraph Platform["PLATFORM LAYER (KServe-managed)"]
        Route["KServe Route / Istio Gateway<br/>443/TCP → internal<br/>TLS Termination<br/>Host-based routing"]
    end

    subgraph AuthBoundary["AUTH SIDECAR (Trust Boundary)"]
        RBAC["kube-rbac-proxy<br/>(RHOAI 3.x)<br/>Bearer token validation<br/>RBAC authorization"]
    end

    subgraph Pod["MLSERVER POD (No TLS, No Auth)"]
        direction TB

        REST["REST Server<br/>8080/TCP HTTP<br/>Plaintext<br/>No Auth"]
        GRPC["gRPC Server<br/>8081/TCP gRPC<br/>add_insecure_port()<br/>No Auth"]
        MetricsSrv["Metrics Server<br/>8082/TCP HTTP<br/>Plaintext<br/>/metrics"]

        subgraph RuntimeSec["Runtime Security"]
            TrustedRT["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>Blocks unlisted runtimes"]
        end

        subgraph InferenceEngine["Inference Engine"]
            DataPlane["DataPlane Handler"]
            Models["MLModel Runtimes<br/>sklearn | xgboost | lightgbm | onnx"]
        end
    end

    subgraph Egress["EGRESS (Outbound)"]
        KafkaBroker["Kafka Broker<br/>9092/TCP Kafka<br/>Optional SSL<br/>No Auth"]
        OTelCollector["OpenTelemetry Collector<br/>configurable/TCP<br/>gRPC OTLP<br/>No Auth"]
        RemoteModel["Remote Inference<br/>configurable/TCP HTTP<br/>Optional TLS<br/>(alibi-explain only)"]
    end

    subgraph Support["SUPPORTING INFRASTRUCTURE"]
        KServe["KServe Controller<br/>K8s API (pod lifecycle)"]
        StorageInit["Storage Initializer<br/>Init Container<br/>/mnt/models"]
        Prometheus["Prometheus<br/>Metrics scrape"]
        Istio["Istio/Envoy Sidecar<br/>mTLS (if enabled)"]
    end

    %% External → Platform
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| Route

    %% Platform → Auth
    Route -->|"HTTP/internal<br/>mTLS (if mesh)"| RBAC

    %% Auth → MLServer
    RBAC -->|"HTTP/8080<br/>Plaintext<br/>Pod-internal"| REST
    RBAC -->|"gRPC/8081<br/>Plaintext<br/>Pod-internal"| GRPC

    %% Internal flow
    REST --> DataPlane
    GRPC --> DataPlane
    DataPlane --> Models
    TrustedRT -.->|"validates"| Models

    %% Egress
    DataPlane -->|"Kafka/9092<br/>Optional SSL"| KafkaBroker
    REST -->|"gRPC OTLP"| OTelCollector
    GRPC -->|"gRPC OTLP"| OTelCollector
    Models -.->|"HTTP<br/>Optional TLS"| RemoteModel

    %% Support
    KServe -.->|"K8s API"| Pod
    StorageInit -.->|"volume mount"| Models
    Prometheus -->|"HTTP/8082<br/>scrape"| MetricsSrv
    Istio -.->|"transparent<br/>mTLS proxy"| Pod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authboundary fill:#f8cecc,stroke:#b85450,stroke-width:3px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef support fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef danger fill:#e74c3c,stroke:#333,color:#fff

    class Client external
    class Route platform
    class RBAC authboundary
    class REST,GRPC,MetricsSrv,DataPlane,Models pod
    class TrustedRT danger
    class KafkaBroker,OTelCollector,RemoteModel egress
    class KServe,StorageInit,Prometheus,Istio support
