graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe-Managed, TLS Terminated)"]
        Gateway["KServe Ingress<br/>Istio Gateway / Gateway API<br/>443/TCP → 8080/8081<br/>TLS Termination<br/>AuthN: kube-rbac-proxy / oauth-proxy"]
    end

    subgraph Pod["POD NETWORK (KServe InferenceService Pod - Plaintext)"]
        direction TB

        subgraph Servers["Listening Services"]
            REST["REST Server<br/>8080/TCP HTTP (plaintext)<br/>FastAPI/Uvicorn<br/>No Auth"]
            gRPC["gRPC Server<br/>8081/TCP gRPC (plaintext)<br/>add_insecure_port()<br/>No Auth"]
            Metrics["Metrics Server<br/>8082/TCP HTTP (plaintext)<br/>Prometheus format<br/>No Auth"]
        end

        subgraph SecurityControls["Security Controls (Application-Level)"]
            TrustedRT["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>PRODUCTION mode<br/>Blocks untrusted implementations"]
            CORSBlock["CORS Validation<br/>Wildcards blocked in production<br/>Regex origins blocked"]
            EnvBlock["Environment Injection Block<br/>environment_tarball rejected<br/>environment_path rejected"]
        end

        subgraph ModelLayer["Model Layer"]
            DataPlane["DataPlane Handler"]
            Models["ML Model Runtimes<br/>sklearn, xgboost, lgbm, onnx"]
            Storage["/mnt/models<br/>Read-only Volume Mount<br/>PVC or S3 (via KServe)"]
        end

        subgraph Workers["Parallel Workers (Optional)"]
            IPC["multiprocessing.Queue<br/>Pickle IPC<br/>Pod-internal only"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Cluster-Internal)"]
        KServeAgent["KServe Model Agent<br/>(sidecar in same pod)"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
        OTELCollector["OpenTelemetry Collector<br/>gRPC (insecure=True)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        Kafka["Kafka Brokers<br/>9092/TCP<br/>TCP (no encryption default)<br/>No Auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8080 (plaintext)<br/>No Auth<br/>(TLS terminated)"| REST
    Gateway -->|"gRPC/8081 (plaintext)<br/>No Auth<br/>(TLS terminated)"| gRPC

    REST --> DataPlane
    gRPC --> DataPlane
    DataPlane -->|validates| TrustedRT
    DataPlane --> Models
    Models -->|reads| Storage

    KServeAgent -->|"HTTP/8080<br/>load/unload<br/>Pod-internal"| REST
    Prometheus -->|"HTTP/8082<br/>GET /metrics<br/>Cluster-internal"| Metrics
    REST -.->|"gRPC<br/>OTLP traces<br/>insecure=True"| OTELCollector
    gRPC -.->|"gRPC<br/>OTLP traces<br/>insecure=True"| OTELCollector
    REST <-.->|"TCP/9092<br/>No encryption<br/>Async inference"| Kafka

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class REST,gRPC,Metrics,DataPlane,Models,Storage,IPC pod
    class TrustedRT,CORSBlock,EnvBlock security
    class KServeAgent,Prometheus,OTELCollector platform
    class Kafka externalservice
