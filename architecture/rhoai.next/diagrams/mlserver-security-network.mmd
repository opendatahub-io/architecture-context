graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Managed by KServe"]
        Gateway["KServe / Istio Gateway<br/>TLS Termination<br/>AuthN/AuthZ enforced"]
    end

    subgraph AppPod["APPLICATION (MLServer Pod)<br/>Non-root UID 1000 | No K8s RBAC"]
        direction TB

        RESTServer["REST Server<br/>0.0.0.0:8080/TCP<br/>HTTP | No App Auth<br/>V2 Dataplane API"]

        GRPCServer["gRPC Server<br/>0.0.0.0:8081/TCP<br/>gRPC (insecure) | No App Auth<br/>GRPCInferenceService"]

        MetricsServer["Metrics Server<br/>0.0.0.0:8082/TCP<br/>HTTP | No Auth<br/>/metrics (Prometheus)"]

        RuntimeSec["Runtime Security<br/>PRODUCTION: trusted-runtimes.json<br/>Allows: LightGBM, ONNX, SKLearn, XGBoost<br/>Blocks: arbitrary imports, wildcard CORS"]
    end

    subgraph EgressServices["EGRESS DESTINATIONS"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>insecure=True | No Auth"]
        Kafka["Kafka Brokers<br/>9092/TCP AMQP<br/>Encryption: Configurable"]
        ModelStore["Model Storage<br/>PVC/S3<br/>Varies | Managed by KServe"]
        InferenceEP["Inference Model Endpoint<br/>(Alibi Explain only)<br/>HTTP/HTTPS | Configurable"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 8082/TCP<br/>HTTP | No Auth"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS (terminated at ingress)<br/>Auth: KServe/Istio/kube-rbac-proxy"| Gateway

    %% Ingress to App
    Gateway -->|"HTTP/8080<br/>No encryption (post-TLS)<br/>mTLS if Service Mesh"| RESTServer
    Gateway -->|"gRPC/8081<br/>No encryption (post-TLS)<br/>mTLS if Service Mesh"| GRPCServer

    %% App to Egress
    RESTServer -->|"gRPC/4317<br/>OTLP insecure<br/>No Auth"| OTel
    GRPCServer -->|"gRPC/4317<br/>OTLP insecure<br/>No Auth"| OTel
    RESTServer -.->|"AMQP/9092<br/>Configurable encryption<br/>Optional"| Kafka
    RESTServer -->|"Varies<br/>HTTP/HTTPS/FS<br/>Managed by KServe"| ModelStore
    RESTServer -.->|"HTTP/HTTPS<br/>ssl_verify_path<br/>Alibi Explain only"| InferenceEP

    %% Monitoring
    Prometheus -->|"HTTP/8082<br/>No encryption<br/>Scrape /metrics"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class Gateway ingress
    class RESTServer,GRPCServer,MetricsServer app
    class RuntimeSec security
    class OTel,Kafka,ModelStore,InferenceEP egress
    class Prometheus monitoring
