graph LR
    Kueue["Kueue Controller<br/>Manager"]

    %% External Dependencies
    Kueue -->|"controller framework<br/>v0.19.4"| ControllerRuntime["controller-runtime"]
    Kueue -->|"target cluster API<br/>1.32+"| K8s["Kubernetes API"]
    Kueue -->|"certificates<br/>(optional)"| CertManager["cert-manager<br/>v1.17.1"]
    Kueue -->|"node provisioning<br/>(feature-gated)"| ClusterAutoscaler["Cluster Autoscaler"]
    Kueue -->|"kubeconfig watch<br/>v1.8.0"| FSNotify["fsnotify"]

    %% Internal RHOAI Platform Dependencies
    Kueue -->|"PyTorchJob, TFJob,<br/>PaddleJob, XGBoostJob,<br/>MPIJob CRD watch"| TrainingOperator["Training Operator<br/>(Kubeflow)"]
    Kueue -->|"RayJob, RayCluster<br/>CRD watch"| RayOperator["Ray Operator<br/>(KubeRay)"]
    Kueue -->|"JobSet<br/>CRD watch"| JobSetCtrl["JobSet Controller"]
    Kueue -->|"AppWrapper<br/>CRD watch"| CodeFlare["CodeFlare Operator<br/>(AppWrapper)"]
    Kueue -->|"LeaderWorkerSet<br/>CRD watch"| LWSCtrl["LeaderWorkerSet<br/>Controller"]

    %% Platform operator deploys Kueue
    RHOAIOp["RHOAI Operator"] -->|"deploys via<br/>kustomize"| Kueue

    %% Kubernetes native resources watched
    Kueue -->|"watch/manage"| BatchJobs["batch/v1 Jobs"]
    Kueue -->|"watch"| Nodes["Nodes<br/>(TAS topology)"]
    Kueue -->|"watch"| Namespaces["Namespaces<br/>(queue selectors)"]
    Kueue -->|"watch"| LimitRanges["LimitRanges"]
    Kueue -->|"watch"| RuntimeClasses["RuntimeClasses"]
    Kueue -->|"watch"| PriorityClasses["PriorityClasses"]

    %% Monitoring integration
    Kueue -.->|"metrics<br/>8443/TCP"| Prometheus["Prometheus<br/>ServiceMonitor +<br/>PrometheusRule"]

    %% MultiKueue (disabled)
    Kueue -.->|"workload federation<br/>(disabled in RHOAI)"| RemoteCluster["Remote Cluster<br/>(MultiKueue)"]

    %% Managed workload types (CRDs Kueue owns)
    Kueue -->|"owns"| KueueCRDs["Kueue CRDs<br/>ClusterQueue, LocalQueue,<br/>Workload, ResourceFlavor,<br/>AdmissionCheck, Cohort,<br/>Topology, etc."]

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style K8s fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style ClusterAutoscaler fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style FSNotify fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI platform deps
    style TrainingOperator fill:#7ed321,stroke:#333,color:#fff
    style RayOperator fill:#7ed321,stroke:#333,color:#fff
    style JobSetCtrl fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style LWSCtrl fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff

    %% Kubernetes resources
    style BatchJobs fill:#f5a623,stroke:#333,color:#fff
    style Nodes fill:#f5a623,stroke:#333,color:#fff
    style Namespaces fill:#f5a623,stroke:#333,color:#fff
    style LimitRanges fill:#f5a623,stroke:#333,color:#fff
    style RuntimeClasses fill:#f5a623,stroke:#333,color:#fff
    style PriorityClasses fill:#f5a623,stroke:#333,color:#fff

    %% Monitoring
    style Prometheus fill:#f5a623,stroke:#333,color:#fff

    %% Disabled
    style RemoteCluster fill:#e1d5e7,stroke:#9673a6,stroke-dasharray: 5 5

    %% Kueue CRDs
    style KueueCRDs fill:#dae8fc,stroke:#6c8ebf
