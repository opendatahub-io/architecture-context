graph LR
    Kueue["Kueue Controller Manager<br/>(kueue-controller-manager)"]

    %% External Dependencies
    Kueue -->|"controller framework<br/>v0.19.4"| ControllerRuntime["controller-runtime"]
    Kueue -->|"cluster API<br/>HTTPS/6443"| K8sAPI["Kubernetes 1.32+"]
    Kueue -->|"TLS certs (optional)"| CertManager["cert-manager 1.17.1"]
    Kueue -->|"kubeconfig watch"| FSNotify["fsnotify v1.8.0"]

    %% Internal Platform Dependencies (RHOAI)
    Kueue -->|"CRD Watch + Webhook<br/>PyTorchJob, TFJob,<br/>MPIJob, PaddleJob,<br/>XGBoostJob"| TrainingOp["Training Operator<br/>(Kubeflow)"]
    Kueue -->|"CRD Watch + Webhook<br/>RayJob, RayCluster"| RayOp["Ray Operator<br/>(KubeRay)"]
    Kueue -->|"CRD Watch + Webhook<br/>JobSet"| JobSetCtrl["JobSet Controller"]
    Kueue -->|"CRD Watch<br/>AppWrapper"| CodeFlare["CodeFlare<br/>(AppWrapper)"]
    Kueue -->|"CRD Watch + Webhook<br/>LeaderWorkerSet"| LWSCtrl["LeaderWorkerSet<br/>Controller"]

    %% Platform Integration
    RHOAIOp["RHOAI Operator"] -->|"deploys via<br/>kustomize"| Kueue

    %% Optional External Services
    Kueue -.->|"ProvisioningRequest<br/>CRD (feature-gated)"| ClusterAS["Cluster Autoscaler"]
    Kueue -.->|"MultiKueue federation<br/>HTTPS/6443<br/>(feature-gated)"| RemoteK8s["Remote Kubernetes<br/>Cluster(s)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTPS/8443"| Kueue

    %% Native K8s resources watched
    Kueue -->|"CRD Watch + Webhook"| BatchJobs["batch/v1 Job"]
    Kueue -->|"CRD Watch + Webhook"| Pods["v1/Pod"]
    Kueue -->|"CRD Watch + Webhook"| Deployments["apps/v1 Deployment"]
    Kueue -->|"CRD Watch + Webhook"| StatefulSets["apps/v1 StatefulSet"]

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style ControllerRuntime fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style FSNotify fill:#999,stroke:#333
    style ClusterAS fill:#999,stroke:#333
    style RemoteK8s fill:#999,stroke:#333

    style TrainingOp fill:#7ed321,stroke:#333,color:#fff
    style RayOp fill:#7ed321,stroke:#333,color:#fff
    style JobSetCtrl fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style LWSCtrl fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff

    style Prometheus fill:#f5a623,stroke:#333
    style BatchJobs fill:#e8e8e8,stroke:#333
    style Pods fill:#e8e8e8,stroke:#333
    style Deployments fill:#e8e8e8,stroke:#333
    style StatefulSets fill:#e8e8e8,stroke:#333
