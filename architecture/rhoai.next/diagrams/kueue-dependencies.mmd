graph LR
    Kueue["Kueue Controller Manager<br/>(opendatahub namespace)"]

    %% External Dependencies (Required)
    Kueue -->|"watches, CRUD, leader election<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>1.32+"]

    %% External Dependencies (Optional)
    Kueue -.->|"optional cert mgmt"| CertManager["cert-manager<br/>v1.17.1"]
    Kueue -.->|"ProvisioningRequest CRDs<br/>(ProvisioningACC feature)"| ClusterAutoscaler["Cluster Autoscaler"]

    %% Internal ODH Dependencies (CRD Watch + Webhook)
    Kueue -->|"webhook intercept<br/>9443/TCP HTTPS"| KubeflowTraining["Kubeflow Training Operator<br/>(PyTorch, TF, MPI,<br/>Paddle, XGBoost)"]
    Kueue -->|"webhook intercept<br/>9443/TCP HTTPS"| KubeRay["KubeRay Operator<br/>(RayJob, RayCluster)"]
    Kueue -->|"webhook intercept<br/>9443/TCP HTTPS"| JobSet["JobSet Controller"]
    Kueue -->|"webhook intercept<br/>9443/TCP HTTPS"| CodeFlare["CodeFlare Operator<br/>(AppWrapper)"]
    Kueue -->|"webhook intercept<br/>9443/TCP HTTPS"| LeaderWorkerSet["LeaderWorkerSet<br/>Controller"]

    %% Monitoring
    Prometheus["Prometheus<br/>(OpenShift Monitoring)"] -->|"scrape metrics<br/>8443/TCP HTTPS"| Kueue

    %% External Webhooks (peer components intercepting Kueue resources)
    CodeFlare -.->|"external webhooks<br/>mappwrapper, vraycluster"| Kueue
    KubeRay -.->|"external webhook<br/>mraycluster"| Kueue
    KubeflowTraining -.->|"external webhooks<br/>validator.*.training-operator"| Kueue

    %% Kubernetes native resources watched
    Kueue -->|"watch"| K8sNodes["Kubernetes Nodes<br/>(labels for ResourceFlavor<br/>+ topology discovery)"]
    Kueue -->|"watch"| K8sPriorityClass["PriorityClasses<br/>(workload priority mapping)"]
    Kueue -->|"watch"| K8sLimitRanges["LimitRanges<br/>(resource defaults)"]

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ClusterAutoscaler fill:#999,stroke:#333,color:#fff
    style KubeflowTraining fill:#7ed321,stroke:#333,color:#fff
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style JobSet fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style LeaderWorkerSet fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333
    style K8sNodes fill:#e8e8e8,stroke:#333
    style K8sPriorityClass fill:#e8e8e8,stroke:#333
    style K8sLimitRanges fill:#e8e8e8,stroke:#333
