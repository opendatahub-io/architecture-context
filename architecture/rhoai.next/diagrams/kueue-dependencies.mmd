graph LR
    Kueue["Kueue Controller<br/>Manager"]

    %% External Dependencies (Required)
    Kueue -->|"controller framework<br/>(required)"| K8s["Kubernetes 1.32+"]
    Kueue -->|"controller-runtime<br/>v0.19.4 (required)"| CtrlRuntime["controller-runtime"]

    %% External Dependencies (Optional)
    Kueue -.->|"TLS certs<br/>(optional)"| CertManager["cert-manager 1.17.1"]
    Kueue -.->|"node provisioning<br/>(feature-gated)"| ClusterAutoscaler["Cluster Autoscaler"]
    Kueue -.->|"kubeconfig watch<br/>(MultiKueue)"| FSNotify["fsnotify v1.8.0"]

    %% Internal Platform Dependencies (CRD Watch)
    Kueue -->|"PyTorchJob, TFJob,<br/>MPIJob, PaddleJob,<br/>XGBoostJob"| TrainingOp["Training Operator<br/>(Kubeflow)"]
    Kueue -->|"RayJob,<br/>RayCluster"| RayOp["KubeRay Operator"]
    Kueue -->|"JobSet"| JobSetCtrl["JobSet Controller"]
    Kueue -->|"AppWrapper"| CodeFlare["CodeFlare<br/>(AppWrapper)"]
    Kueue -.->|"LeaderWorkerSet"| LWSCtrl["LeaderWorkerSet<br/>Controller"]

    %% Platform Deployment
    RHOAIOp["RHOAI Operator"] -->|"deploys via<br/>kustomize"| Kueue

    %% Kubernetes Resources Watched
    Kueue -->|"batch/v1 Jobs<br/>Deployments<br/>StatefulSets<br/>Pods"| K8sWorkloads["K8s Workload<br/>Resources"]
    Kueue -->|"Nodes, Namespaces<br/>LimitRanges<br/>RuntimeClasses<br/>PriorityClasses"| K8sCluster["K8s Cluster<br/>Resources"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| Kueue

