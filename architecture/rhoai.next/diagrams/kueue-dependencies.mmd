graph LR
    Kueue["Kueue<br/>Controller Manager"]

    %% External Dependencies (Required)
    Kueue -->|"API server<br/>HTTPS/6443"| K8sAPI["Kubernetes 1.32+"]
    Kueue -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.19.4"]

    %% External Dependencies (Optional)
    Kueue -.->|"TLS certs"| CertManager["cert-manager<br/>v1.17.1"]
    Kueue -.->|"alt cert mgmt"| CertController["OPA cert-controller<br/>v0.12.0"]

    %% Internal Platform Dependencies - ML Frameworks
    subgraph MLFrameworks["ML Job Frameworks"]
        KubeflowTraining["Kubeflow Training<br/>(PyTorchJob, TFJob,<br/>XGBoostJob, PaddleJob)"]
        KubeflowMPI["Kubeflow MPI<br/>(MPIJob)"]
        KubeRay["KubeRay<br/>(RayCluster, RayJob)"]
    end

    Kueue -->|"CRD Watch<br/>kubeflow.org/v1"| KubeflowTraining
    Kueue -->|"CRD Watch<br/>kubeflow.org/v2beta1"| KubeflowMPI
    Kueue -->|"CRD Watch<br/>ray.io/v1"| KubeRay

    %% Internal Platform Dependencies - Workload Orchestration
    subgraph WorkloadOrch["Workload Orchestration"]
        JobSet["JobSet Controller<br/>jobset.x-k8s.io/v1alpha2"]
        AppWrapper["AppWrapper Controller<br/>workload.codeflare.dev/v1beta2"]
        LeaderWorkerSet["LeaderWorkerSet<br/>leaderworkerset.x-k8s.io/v1"]
    end

    Kueue -->|"CRD Watch"| JobSet
    Kueue -->|"CRD Watch"| AppWrapper
    Kueue -->|"CRD Watch"| LeaderWorkerSet

    %% Native K8s Workloads
    subgraph NativeK8s["Native K8s Workloads"]
        BatchJob["batch/v1 Job"]
        Deployment["apps/v1 Deployment"]
        StatefulSet["apps/v1 StatefulSet"]
        Pod["v1 Pod"]
    end

    Kueue -->|"CRD Watch<br/>+ Webhook"| BatchJob
    Kueue -->|"CRD Watch<br/>+ Webhook"| Deployment
    Kueue -->|"CRD Watch<br/>+ Webhook"| StatefulSet
    Kueue -->|"CRD Watch<br/>+ Webhook"| Pod

    %% Infrastructure Integration
    Kueue -.->|"ProvisioningRequest<br/>CRD"| Autoscaler["Cluster Autoscaler<br/>autoscaling.x-k8s.io/v1beta1"]
    Kueue -.->|"MultiKueue<br/>HTTPS/6443"| RemoteK8s["Remote K8s Clusters"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTPS/8443"| Kueue

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style CertController fill:#999,stroke:#333,color:#fff
    style Autoscaler fill:#999,stroke:#333,color:#fff
    style RemoteK8s fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#9673a6

    style KubeflowTraining fill:#7ed321,stroke:#333,color:#fff
    style KubeflowMPI fill:#7ed321,stroke:#333,color:#fff
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style JobSet fill:#7ed321,stroke:#333,color:#fff
    style AppWrapper fill:#7ed321,stroke:#333,color:#fff
    style LeaderWorkerSet fill:#7ed321,stroke:#333,color:#fff

    style BatchJob fill:#dae8fc,stroke:#6c8ebf
    style Deployment fill:#dae8fc,stroke:#6c8ebf
    style StatefulSet fill:#dae8fc,stroke:#6c8ebf
    style Pod fill:#dae8fc,stroke:#6c8ebf
