graph LR
    Kueue["Kueue Controller Manager<br/>(opendatahub namespace)"]

    %% External Dependencies
    Kueue -->|"CRD registration,<br/>controller-runtime"| K8s["Kubernetes 1.27+"]
    Kueue -.->|"optional TLS cert<br/>management"| CertMgr["cert-manager v1+"]
    Kueue -.->|"optional node<br/>provisioning"| ClusterAS["Cluster Autoscaler<br/>(ProvisioningRequest)"]

    %% Internal Platform Dependencies (Job Frameworks)
    Kueue -->|"CRD Watch + Webhook<br/>PyTorchJob, TFJob,<br/>MPIJob, XGBoostJob,<br/>PaddleJob"| KubeflowTraining["Kubeflow Training<br/>Operator"]
    Kueue -->|"CRD Watch + Webhook<br/>RayJob, RayCluster"| RayOp["Ray Operator"]
    Kueue -->|"CRD Watch + Webhook<br/>JobSet"| JobSetCtrl["JobSet Controller"]
    Kueue -->|"CRD Watch + Webhook<br/>AppWrapper"| CodeFlare["CodeFlare Operator"]
    Kueue -->|"CRD Watch<br/>LeaderWorkerSet"| LWS["LeaderWorkerSet<br/>Controller"]

    %% Kubernetes Native Resources
    Kueue -->|"CRD Watch + Webhook<br/>batch/v1 Job"| BatchJob["Kubernetes Jobs"]
    Kueue -->|"CRD Watch + Webhook<br/>v1 Pod, apps/v1"| PodIntegration["Pod / Deployment /<br/>StatefulSet"]
    Kueue -->|"Watch<br/>scheduling.k8s.io"| PriorityClass["PriorityClass"]
    Kueue -->|"Watch<br/>node.k8s.io"| RuntimeClass["RuntimeClass"]
    Kueue -->|"Watch<br/>v1"| LimitRange["LimitRange"]
    Kueue -->|"Watch<br/>v1"| Nodes["Nodes<br/>(TAS topology)"]

    %% Optional Multi-Cluster
    Kueue -.->|"REST client<br/>kubeconfig Secret<br/>(disabled in RHOAI)"| RemoteKueue["Remote Kueue<br/>Clusters<br/>(MultiKueue)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape metrics<br/>8443/TCP HTTPS"| Kueue

    %% API Priority & Fairness
    Kueue -->|"Watch + Patch<br/>FlowSchemas"| FlowControl["API Priority &<br/>Fairness"]

    %% Styling
    style Kueue fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps - grey
    style K8s fill:#999,stroke:#333,color:#fff
    style CertMgr fill:#999,stroke:#333,color:#fff
    style ClusterAS fill:#999,stroke:#333,color:#fff
    style RemoteKueue fill:#999,stroke:#333,color:#fff

    %% Internal platform deps - green
    style KubeflowTraining fill:#7ed321,stroke:#333,color:#fff
    style RayOp fill:#7ed321,stroke:#333,color:#fff
    style JobSetCtrl fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style LWS fill:#7ed321,stroke:#333,color:#fff

    %% K8s native resources - orange
    style BatchJob fill:#f5a623,stroke:#333
    style PodIntegration fill:#f5a623,stroke:#333
    style PriorityClass fill:#f5a623,stroke:#333
    style RuntimeClass fill:#f5a623,stroke:#333
    style LimitRange fill:#f5a623,stroke:#333
    style Nodes fill:#f5a623,stroke:#333
    style FlowControl fill:#f5a623,stroke:#333

    %% Monitoring - purple
    style Prometheus fill:#9b59b6,stroke:#333,color:#fff
