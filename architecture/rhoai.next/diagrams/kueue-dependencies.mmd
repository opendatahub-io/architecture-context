graph LR
    Kueue["Kueue Controller Manager<br/>(kueue-controller-manager)"]

    %% External Dependencies (Required)
    Kueue -->|"API operations<br/>6443/TCP HTTPS"| K8s["Kubernetes 1.32+"]
    Kueue -->|"operator framework"| CR["controller-runtime v0.19.4"]

    %% External Dependencies (Optional)
    Kueue -.->|"TLS certs<br/>(optional)"| CertManager["cert-manager v1.17.1"]
    Kueue -.->|"internal certs<br/>(alternative)"| CertCtrl["cert-controller v0.12.0"]

    %% Internal Platform Dependencies - Job Frameworks
    Kueue -->|"CRD Watch<br/>kubeflow.org/v1"| KubeflowTraining["Kubeflow Training Operator<br/>(PyTorchJob, TFJob,<br/>XGBoostJob, PaddleJob)"]
    Kueue -->|"CRD Watch<br/>kubeflow.org/v2beta1"| KubeflowMPI["Kubeflow MPI Operator<br/>(MPIJob)"]
    Kueue -->|"CRD Watch<br/>ray.io/v1"| KubeRay["KubeRay Operator<br/>(RayCluster, RayJob)"]
    Kueue -->|"CRD Watch<br/>jobset.x-k8s.io/v1alpha2"| JobSet["JobSet Controller"]
    Kueue -->|"CRD Watch<br/>workload.codeflare.dev/v1beta2"| AppWrapper["AppWrapper Controller<br/>(CodeFlare)"]
    Kueue -->|"CRD Watch<br/>leaderworkerset.x-k8s.io/v1"| LWS["LeaderWorkerSet Controller"]

    %% Autoscaler Integration
    Kueue -->|"ProvisioningRequest CRD<br/>autoscaling.x-k8s.io/v1beta1"| Autoscaler["Cluster Autoscaler"]

    %% MultiKueue (Optional)
    Kueue -.->|"workload distribution<br/>6443/TCP HTTPS"| RemoteK8s["Remote K8s Clusters<br/>(MultiKueue workers)"]

    %% Built-in K8s Resources Watched
    Kueue -->|"watch/manage"| BatchJobs["K8s batch/v1 Jobs"]
    Kueue -->|"watch/manage"| Deployments["K8s Deployments"]
    Kueue -->|"watch/manage"| StatefulSets["K8s StatefulSets"]
    Kueue -->|"watch/manage"| Pods["K8s Pods"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| Kueue

