graph LR
    Kueue["Kueue<br/>Job Queueing System"]

    %% Required External Dependencies
    K8s["Kubernetes v1.32+"]
    CR["controller-runtime v0.19.4"]

    Kueue -->|"target platform<br/>(required)"| K8s
    Kueue -->|"controller framework<br/>(required)"| CR

    %% Optional External Dependencies
    CertMgr["cert-manager v1.17.1"]
    ClusterAS["cluster-autoscaler<br/>ProvisioningRequest API v1beta1"]

    Kueue -.->|"optional TLS certs"| CertMgr
    Kueue -.->|"optional node provisioning"| ClusterAS

    %% Optional Job Framework Dependencies
    subgraph JobFrameworks["Optional Job Framework Integrations"]
        KubeflowTrain["Kubeflow Training<br/>Operator v1.9.0<br/>(PyTorchJob, TFJob,<br/>XGBoostJob, PaddleJob)"]
        KubeflowMPI["Kubeflow MPI<br/>Operator v0.6.0<br/>(MPIJob)"]
        KubeRay["KubeRay v1.3.1<br/>(RayJob, RayCluster)"]
        JobSetCtrl["JobSet v0.8.0"]
        LWSCtrl["LeaderWorkerSet v0.5.1"]
        AppWrapperCtrl["AppWrapper<br/>(CodeFlare) v1.1.0"]
    end

    Kueue -.->|"watch + webhook"| KubeflowTrain
    Kueue -.->|"watch + webhook"| KubeflowMPI
    Kueue -.->|"watch + webhook"| KubeRay
    Kueue -.->|"watch + webhook"| JobSetCtrl
    Kueue -.->|"watch + webhook"| LWSCtrl
    Kueue -.->|"watch + webhook"| AppWrapperCtrl

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    RhodsOp -->|"deploys via<br/>Kustomize overlay"| Kueue
    Prometheus -->|"scrapes metrics<br/>8443/TCP HTTPS"| Kueue

    %% External Services
    RemoteK8s["Remote Kubernetes<br/>Clusters"]

    Kueue -.->|"MultiKueue dispatch<br/>443/TCP HTTPS"| RemoteK8s

    %% Peer Webhook Interactions
    subgraph PeerWebhooks["Peer Components (External Webhooks)"]
        CodeflareOp["codeflare-operator"]
        KubeRayOp["kuberay"]
        TrainingOp["training-operator"]
    end

    CodeflareOp -.->|"webhooks on<br/>AppWrapper, RayCluster"| Kueue
    KubeRayOp -.->|"webhook on<br/>RayCluster"| Kueue
    TrainingOp -.->|"webhooks on<br/>PyTorch/TF/XGBoost/PaddleJob"| Kueue

    %% Styling
    style Kueue fill:#1565c0,stroke:#333,stroke-width:4px,color:#fff

    style K8s fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style CertMgr fill:#bdbdbd,stroke:#333
    style ClusterAS fill:#bdbdbd,stroke:#333

    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    style RemoteK8s fill:#f5a623,stroke:#333

    style KubeflowTrain fill:#e8e8e8,stroke:#333
    style KubeflowMPI fill:#e8e8e8,stroke:#333
    style KubeRay fill:#e8e8e8,stroke:#333
    style JobSetCtrl fill:#e8e8e8,stroke:#333
    style LWSCtrl fill:#e8e8e8,stroke:#333
    style AppWrapperCtrl fill:#e8e8e8,stroke:#333

    style CodeflareOp fill:#ffcc80,stroke:#333
    style KubeRayOp fill:#ffcc80,stroke:#333
    style TrainingOp fill:#ffcc80,stroke:#333

    style JobFrameworks fill:#f5f5f5,stroke:#999,stroke-width:1px
    style PeerWebhooks fill:#fff8e1,stroke:#f9a825,stroke-width:1px
