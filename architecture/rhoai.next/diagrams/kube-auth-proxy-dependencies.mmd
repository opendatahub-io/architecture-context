graph LR
    KAP["kube-auth-proxy<br/>(Go Reverse Proxy)"]

    %% Identity Providers
    KAP -->|"OAuth2/OIDC<br/>authz code flow,<br/>JWKS, userinfo"| OIDC["OIDC Provider<br/>(e.g., Keycloak)"]
    KAP -->|"OAuth2<br/>discovery, authz,<br/>token exchange"| OShiftOAuth["OpenShift OAuth<br/>Server"]

    %% Kubernetes / OpenShift APIs
    KAP -->|"TokenReview API<br/>SA token validation"| K8sAPI["Kubernetes<br/>API Server"]
    KAP -->|"User info,<br/>OAuthAccessToken<br/>deletion"| OShiftAPI["OpenShift API<br/>(kubernetes.default.svc)"]

    %% Session Store
    KAP -.->|"Session store<br/>(optional)<br/>TCP/TLS 6379"| Redis["Redis<br/>(Standalone / Sentinel /<br/>Cluster)"]

    %% Upstream
    KAP -->|"Reverse proxy<br/>HTTP/HTTPS/Unix"| Upstream["Upstream<br/>Application"]

    %% Integration Points (inbound)
    Envoy["Envoy Gateway<br/>(RHOAI 3.x)"] -->|"ext_authz<br/>subrequest"| KAP
    Prometheus["Prometheus"] -->|"HTTP scrape<br/>/metrics"| KAP
    Operator["rhods-operator"] -->|"Deploys as sidecar<br/>configures RBAC"| KAP

    %% Go Library Dependencies
    subgraph "Key Go Libraries"
        direction TB
        GoOIDC["coreos/go-oidc v3.18.0<br/>OIDC discovery, JWKS"]
        OAuth2Lib["golang.org/x/oauth2 v0.36.0<br/>OAuth2 flow"]
        GoRedis["go-redis v9.17.0<br/>Redis client"]
        ClientGo["k8s.io/client-go v0.35.3<br/>TokenReview API"]
        JWT["golang-jwt v5.3.0<br/>JWT parsing"]
        Viper["spf13/viper v1.21.0<br/>Configuration"]
        PromClient["prometheus/client_golang v1.23.2<br/>Metrics"]
        Mux["gorilla/mux v1.8.1<br/>HTTP routing"]
    end

    KAP -->|"uses"| GoOIDC
    KAP -->|"uses"| OAuth2Lib
    KAP -.->|"optional"| GoRedis
    KAP -.->|"optional"| ClientGo
    KAP -->|"uses"| JWT
    KAP -->|"uses"| Viper
    KAP -->|"uses"| PromClient
    KAP -->|"uses"| Mux

