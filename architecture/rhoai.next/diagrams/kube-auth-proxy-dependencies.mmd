    style UBI9 fill:#e8e8e8,stroke:#333
    style GoOIDC fill:#e8e8e8,stroke:#333
    style Mux fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style JWT fill:#e8e8e8,stroke:#333
    style ClientGo fill:#e8e8e8,stroke:#333
    style APIServer fill:#e8e8e8,stroke:#333
    style GoRedis fill:#e8e8e8,stroke:#333
