graph LR
    KAP["kube-auth-proxy<br/>(Dual-Mode Proxy)"]

    %% Cluster Service Dependencies
    KAP -->|"TokenReview (authn)<br/>SubjectAccessReview (authz)<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    KAP -->|"OAuth2 flow<br/>HTTPS/443"| OSAuth["OpenShift OAuth Server"]
    KAP -->|"User info retrieval<br/>HTTPS/443"| OSUser["OpenShift User API"]
    KAP -->|"OAuthAccessToken DELETE<br/>HTTPS/443"| OSTokenAPI["OpenShift OAuthAccessToken API"]

    %% External Service Dependencies
    KAP -->|"OIDC discovery +<br/>token exchange<br/>HTTPS/443"| OIDC["OIDC Provider<br/>(Keycloak, DEX)"]
    KAP -->|"Session storage<br/>TCP/6379"| Redis["Redis<br/>(Optional)"]

    %% Build Dependencies
    KAP -.->|"build"| GoToolset["Go 1.25.3<br/>(FIPS strictfipsruntime)"]
    KAP -.->|"base image"| UBI9["UBI 9 ubi-minimal"]

    %% Go Library Dependencies
    KAP -.->|"OIDC/JWT"| GoOIDC["coreos/go-oidc/v3<br/>v3.18.0"]
    KAP -.->|"routing"| Mux["gorilla/mux<br/>v1.8.1"]
    KAP -.->|"metrics"| Prometheus["prometheus/client_golang<br/>v1.23.2"]
    KAP -.->|"JWT parsing"| JWT["golang-jwt/jwt/v5<br/>v5.3.0"]
    KAP -.->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.35.3"]
    KAP -.->|"apiserver auth"| APIServer["k8s.io/apiserver<br/>v0.35.3"]
    KAP -.->|"redis client"| GoRedis["redis/go-redis/v9<br/>v9.17.0"]

    %% Internal RHOAI Integration Points
    Operator["rhods-operator"] -->|"deploys as<br/>sidecar container"| KAP
    Envoy["Envoy / Gateway API"] -->|"ext_authz subrequest<br/>HTTP/4180"| KAP
    KAP -->|"proxied requests<br/>HTTP/HTTPS"| UpstreamApp["Upstream Application<br/>(Protected Component)"]

    %% Styling
    style KAP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#5a9a3e,stroke:#333,color:#fff
    style OSAuth fill:#5a9a3e,stroke:#333,color:#fff
    style OSUser fill:#5a9a3e,stroke:#333,color:#fff
    style OSTokenAPI fill:#5a9a3e,stroke:#333,color:#fff
    style OIDC fill:#f5a623,stroke:#333,color:#fff
    style Redis fill:#f5a623,stroke:#333,color:#fff
