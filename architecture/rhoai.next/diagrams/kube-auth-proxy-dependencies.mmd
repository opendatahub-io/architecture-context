graph LR
    KAP["kube-auth-proxy<br/>(dual-binary sidecar)"]

    %% External Dependencies (build/runtime)
    KAP -->|"OIDC authn<br/>HTTPS/443"| OIDC["OIDC Provider<br/>(Keycloak, Azure AD, etc.)"]
    KAP -->|"OAuth authn<br/>HTTPS/443"| OSAuth["OpenShift OAuth Server"]
    KAP -->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    KAP -->|"Session store<br/>Redis/6379"| Redis["Redis<br/>(optional)"]

    %% Internal RHOAI Dependencies
    RHODSOp["rhods-operator"] -->|"deploys as<br/>sidecar"| KAP
    EnvoyGW["Envoy Gateway<br/>(Gateway API)"] -->|"ext_authz<br/>HTTP/4180"| KAP
    KAP -->|"proxies to"| Dashboard["ODH Dashboard"]
    KAP -->|"proxies to"| Notebook["Notebook Controller"]
    KAP -->|"proxies to"| UpstreamApps["Other RHOAI<br/>Components"]

    %% Monitoring
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"scrapes /metrics<br/>HTTPS/8443"| KAP

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        direction TB
        Go["Go 1.25.3"]
        UBI["UBI 9 Minimal"]
        GoToolset["UBI 9 Go Toolset 1.25"]
    end

    subgraph KeyLibraries["Key Go Libraries"]
        direction TB
        GorillaMux["gorilla/mux v1.8.1<br/>(HTTP router)"]
        GoOIDC["coreos/go-oidc/v3 v3.18.0<br/>(OIDC verification)"]
        GoRedis["redis/go-redis/v9 v9.17.0<br/>(Redis client)"]
        PromClient["prometheus/client_golang v1.23.2<br/>(metrics)"]
        K8sClientGo["k8s.io/client-go v0.35.3<br/>(K8s API client)"]
        K8sAPIServer["k8s.io/apiserver v0.35.3<br/>(delegating authn/authz)"]
    end

    KAP -.- BuildDeps
    KAP -.- KeyLibraries

