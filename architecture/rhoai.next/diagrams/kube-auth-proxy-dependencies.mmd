graph LR
    KAP["kube-auth-proxy<br/>(dual-mode proxy)"]

    %% Platform Dependencies
    KAP -->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    KAP -->|"OAuth2 flow<br/>HTTPS/443"| OSAuth["OpenShift OAuth Server"]
    KAP -->|"User info retrieval<br/>HTTPS/443"| OSUserAPI["OpenShift User API"]
    KAP -->|"OAuthAccessToken delete<br/>HTTPS/443"| OSOAuthToken["OpenShift OAuthAccessToken API"]

    %% External Identity Providers
    KAP -->|"OIDC discovery +<br/>token exchange<br/>HTTPS/443"| OIDCProvider["OIDC Provider<br/>(Keycloak / DEX)"]

    %% Optional Dependencies
    KAP -.->|"session storage<br/>TCP/6379"| Redis["Redis<br/>(optional)"]

    %% Runtime Dependencies
    KAP -->|"proxied traffic<br/>HTTP/HTTPS"| UpstreamApp["Upstream Application<br/>(protected service)"]

    %% Deployer
    Operator["rhods-operator"] -->|"sidecar injection<br/>container spec"| KAP

    %% Integration Points (consumers)
    Envoy["Envoy / Gateway API"] -->|"ext_authz<br/>HTTP/4180<br/>/oauth2/auth"| KAP

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        direction TB
        Go["Go 1.25.3<br/>(FIPS: strictfipsruntime)"]
        UBI9Build["UBI 9 go-toolset 1.25"]
        UBI9Runtime["UBI 9 ubi-minimal"]
    end

    subgraph GoModules["Key Go Modules"]
        direction TB
        GoOIDC["coreos/go-oidc/v3 v3.18.0"]
        GorillaMux["gorilla/mux v1.8.1"]
        PromClient["prometheus/client_golang v1.23.2"]
        GoRedis["redis/go-redis/v9 v9.17.0"]
        JWT["golang-jwt/jwt/v5 v5.3.0"]
        K8sClient["k8s.io/client-go v0.35.3"]
        K8sAPIServer["k8s.io/apiserver v0.35.3"]
    end

    KAP -.->|"built with"| BuildDeps
    KAP -.->|"imports"| GoModules

    %% Styling
    style KAP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#7ed321,stroke:#333,color:#fff
    style OSAuth fill:#7ed321,stroke:#333,color:#fff
    style OSUserAPI fill:#7ed321,stroke:#333,color:#fff
    style OSOAuthToken fill:#7ed321,stroke:#333,color:#fff
    style OIDCProvider fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style UpstreamApp fill:#f5a623,stroke:#333
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Envoy fill:#7ed321,stroke:#333,color:#fff
    style Go fill:#e8e8e8,stroke:#333
    style UBI9Build fill:#e8e8e8,stroke:#333
    style UBI9Runtime fill:#e8e8e8,stroke:#333
    style GoOIDC fill:#e8e8e8,stroke:#333
    style GorillaMux fill:#e8e8e8,stroke:#333
