graph LR
    KAP["kube-auth-proxy<br/>(Dual-binary sidecar)"]

    %% External Dependencies (Build & Runtime)
    KAP -->|"OIDC auth<br/>HTTPS/443"| OIDC["OIDC Provider<br/>(BYOIDC)"]
    KAP -->|"OAuth2 auth<br/>HTTPS/443"| OSAuth["OpenShift OAuth<br/>Server"]
    KAP -->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    KAP -->|"Session storage<br/>Redis/6379"| Redis["Redis<br/>(optional)"]

    %% Internal RHOAI Dependencies
    Operator["rhods-operator"] -->|"Sidecar injection<br/>+ RBAC provisioning"| KAP
    Envoy["Envoy Proxy<br/>(Gateway API)"] -->|"ext_authz<br/>HTTP/4180"| KAP

    %% Integration Points (consumers)
    KAP -->|"Proxies to"| Upstream["Upstream RHOAI<br/>Components<br/>(Dashboard, Model Registry,<br/>etc.)"]
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"Scrapes /metrics<br/>HTTPS/8443"| KAP

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        Go["Go 1.25.3"]
        UBI["UBI 9 Minimal<br/>(FIPS OpenSSL)"]
        GoToolset["UBI 9 Go Toolset 1.25"]
    end

    subgraph GoLibs["Key Go Libraries"]
        GorillaMux["gorilla/mux v1.8.1<br/>(HTTP router)"]
        GoOIDC["coreos/go-oidc/v3<br/>v3.18.0"]
        GoRedis["redis/go-redis/v9<br/>v9.17.0"]
        PromClient["prometheus/<br/>client_golang v1.23.2"]
        K8sClientGo["k8s.io/client-go<br/>v0.35.3"]
        K8sAPIServer["k8s.io/apiserver<br/>v0.35.3"]
    end

    KAP -.->|"built with"| Go
    KAP -.->|"base image"| UBI
    KAP -.->|"build image"| GoToolset
    KAP -.->|"HTTP routing"| GorillaMux
    KAP -.->|"OIDC tokens"| GoOIDC
