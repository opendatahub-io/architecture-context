graph LR
    KAP["kube-auth-proxy<br/>Go Reverse Proxy / Sidecar"]

    %% External Dependencies (libraries/runtime)
    subgraph ExtDeps["External Dependencies"]
        direction TB
        Go["Go 1.25"]
        GorillaMux["gorilla/mux v1.8.1<br/>HTTP routing"]
        GoOIDC["coreos/go-oidc/v3 v3.18.0<br/>OIDC discovery + verification"]
        GolangJWT["golang-jwt/jwt/v5 v5.3.0<br/>JWT parsing"]
        GoRedis["redis/go-redis/v9 v9.17.0<br/>Redis client"]
        PromClient["prometheus/client_golang v1.23.2<br/>Metrics instrumentation"]
        Viper["spf13/viper v1.21.0<br/>Configuration"]
        K8sClientGo["k8s.io/client-go v0.35.3<br/>TokenReview client"]
        HMACAuth["mbland/hmacauth<br/>Optional GAP-Signature"]
        UBI9["UBI 9 Minimal<br/>FIPS container base"]
    end

    %% Internal Platform Dependencies
    subgraph IntDeps["Internal RHOAI Platform"]
        direction TB
        RhodsOperator["rhods-operator<br/>Deploys as sidecar"]
        UpstreamApp["Upstream Application<br/>Protected component"]
    end

    %% External Services
    subgraph ExtServices["External Services"]
        direction TB
        OIDCIdP["OIDC Identity Provider<br/>443/TCP HTTPS"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
        Redis["Redis (optional)<br/>6379/TCP"]
    end

    %% Integration Points (consumers)
    subgraph Consumers["Consumers / Integrators"]
        direction TB
        Envoy["Envoy (ext_authz)<br/>4180/TCP HTTP"]
        MLflow["MLflow Python SDK<br/>4180/TCP HTTP"]
        Prometheus["Prometheus<br/>Metrics scrape"]
    end

    %% Build/Library Dependencies
    KAP -->|"build"| Go
    KAP -->|"routing"| GorillaMux
    KAP -->|"OIDC auth"| GoOIDC
    KAP -->|"JWT parsing"| GolangJWT
    KAP -->|"sessions"| GoRedis
    KAP -->|"metrics"| PromClient
    KAP -->|"config"| Viper
    KAP -->|"TokenReview"| K8sClientGo
    KAP -.->|"optional signing"| HMACAuth
    KAP -->|"base image"| UBI9

    %% Platform Dependencies
    RhodsOperator -->|"deploys sidecar"| KAP
    KAP -->|"proxies to"| UpstreamApp

    %% External Service Dependencies
    KAP -->|"OIDC flows<br/>HTTPS/443"| OIDCIdP
    KAP -->|"OAuth flows<br/>HTTPS/443"| OSAuth
    KAP -->|"TokenReview<br/>User info<br/>HTTPS/443"| K8sAPI
    KAP -.->|"session store<br/>6379/TCP"| Redis

    %% Consumer Dependencies
    Envoy -->|"ext_authz check<br/>/oauth2/auth"| KAP
    MLflow -->|"auth requests<br/>JSON error responses"| KAP
    Prometheus -->|"scrape /metrics"| KAP

