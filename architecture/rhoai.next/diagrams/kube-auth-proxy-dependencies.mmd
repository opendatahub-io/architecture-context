graph LR
    KAP["kube-auth-proxy<br/>(Dual-mode Sidecar Proxy)"]

    %% Platform Operator (deployer)
    RhodsOp["rhods-operator"] -->|"deploys sidecar<br/>configures mode + flags"| KAP

    %% Cluster Dependencies
    KAP -->|"TokenReview<br/>SubjectAccessReview<br/>OAuthAccessToken deletion<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Identity Provider Dependencies
    KAP -->|"OIDC discovery<br/>token exchange<br/>userinfo<br/>HTTPS/443"| OIDCProvider["OIDC Provider"]
    KAP -->|"OAuth2 authorization<br/>token exchange<br/>HTTPS/443"| OpenShiftOAuth["OpenShift OAuth Server"]

    %% Optional Dependencies
    KAP -.->|"session storage<br/>distributed locking<br/>TCP/6379"| Redis["Redis<br/>(optional)"]

    %% Upstream (protected service)
    KAP -->|"proxied requests<br/>HTTP/HTTPS/Unix/h2c"| Upstream["Upstream Application<br/>(protected service)"]

    %% Monitoring
    Prometheus["OpenShift Prometheus"] -->|"/metrics scrape<br/>HTTPS/8443"| KAP

    %% Envoy Integration
    Envoy["Envoy ext_authz"] -->|"/auth check<br/>202/401<br/>HTTPS/4443"| KAP

    %% Go Library Dependencies
    subgraph GoLibs["Key Go Libraries"]
        direction TB
        OIDC_Lib["coreos/go-oidc/v3<br/>v3.18.0"]
        OAuth2_Lib["golang.org/x/oauth2<br/>v0.36.0"]
        GoRedis["redis/go-redis/v9<br/>v9.17.0"]
        K8sClient["k8s.io/client-go<br/>v0.35.3"]
        K8sAPIServer["k8s.io/apiserver<br/>v0.35.3"]
        PromClient["prometheus/client_golang<br/>v1.23.2"]
        GorillaMux["gorilla/mux<br/>v1.8.1"]
        JWT["golang-jwt/jwt/v5<br/>v5.3.0"]
    end

    KAP -.->|"imports"| GoLibs

