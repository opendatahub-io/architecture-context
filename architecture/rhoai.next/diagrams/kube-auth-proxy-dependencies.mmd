graph LR
    KAP["kube-auth-proxy<br/>(Sidecar Proxy)"]

    %% Platform Operator
    RhodsOp["rhods-operator"] -->|"deploys as sidecar<br/>creates RBAC"| KAP

    %% External Dependencies (auth mode)
    KAP -->|"OAuth2/OIDC<br/>443/TCP HTTPS"| OIDC["OIDC Provider<br/>(Keycloak, Azure AD, etc.)"]
    KAP -->|"OAuth2<br/>443/TCP HTTPS"| OShiftOAuth["OpenShift OAuth Server"]
    KAP -->|"TokenReview<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Authorization (rbac mode)
    KAP -->|"SubjectAccessReview<br/>443/TCP HTTPS"| K8sAPI

    %% Optional dependencies
    KAP -.->|"sessions (optional)<br/>6379/TCP Redis"| Redis["Redis<br/>(Standalone/Sentinel/Cluster)"]

    %% Integration - Envoy
    EnvoyGW["Envoy Gateway<br/>(Gateway API)"] -->|"ext_authz<br/>4180/TCP HTTP"| KAP

    %% Integration - Prometheus
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"metrics scrape<br/>8443/TCP HTTPS"| KAP

    %% Upstream
    KAP -->|"reverse proxy<br/>HTTP/HTTPS/h2c"| Upstream["Upstream Application<br/>(Dashboard, Model Registry, etc.)"]

    %% OpenShift-specific APIs
    KAP -->|"User API<br/>443/TCP HTTPS"| OShiftUser["OpenShift User API<br/>/apis/user.openshift.io"]
    KAP -->|"Token deletion<br/>443/TCP HTTPS"| OShiftOAuthToken["OpenShift OAuthAccessToken API<br/>/apis/oauth.openshift.io"]

    %% Build dependencies (not runtime)
    subgraph BuildDeps["Build Dependencies"]
        Go["Go 1.25.3"]
        UBI["UBI 9 Minimal"]
        GoToolset["UBI 9 Go Toolset 1.25"]
    end

    %% Key libraries
    subgraph Libraries["Key Go Libraries"]
        GorillaMux["gorilla/mux v1.8.1"]
        GoOIDC["coreos/go-oidc/v3 v3.18.0"]
        GoRedis["redis/go-redis/v9 v9.17.0"]
        PromClient["prometheus/client_golang v1.23.2"]
        K8sClient["k8s.io/client-go v0.35.3"]
        K8sApiserver["k8s.io/apiserver v0.35.3"]
    end

    %% Styling
    style KAP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style OIDC fill:#999,stroke:#333,color:#fff
    style OShiftOAuth fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style EnvoyGW fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Upstream fill:#7ed321,stroke:#333,color:#fff
    style OShiftUser fill:#999,stroke:#333,color:#fff
    style OShiftOAuthToken fill:#999,stroke:#333,color:#fff
    style BuildDeps fill:#f0f0f0,stroke:#ccc
    style Libraries fill:#f0f0f0,stroke:#ccc
