graph LR
    MLServer["MLServer<br/>ML Inference Server<br/>v1.7.1+rhaiv.8"]

    %% Core Framework Dependencies
    MLServer -->|"REST API framework"| FastAPI["FastAPI >=0.88.0"]
    MLServer -->|"ASGI server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC server"| grpcio["grpcio >=1.67.1"]
    MLServer -->|"serialization"| protobuf["protobuf >=5.27.2"]
    MLServer -->|"config/validation"| Pydantic["Pydantic ^2.7.1"]

    %% Runtime Plugin Dependencies
    MLServer -->|"sklearn serving"| ScikitLearn["scikit-learn"]
    MLServer -->|"xgboost serving"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm serving"| LightGBM["LightGBM"]
    MLServer -->|"onnx serving"| ONNX["onnxruntime >=1.20.0"]

    %% Observability Dependencies
    MLServer -->|"metrics middleware"| StarletteExporter["starlette-exporter"]
    MLServer -->|"gRPC metrics"| GrpcPrometheus["py-grpc-prometheus"]
    MLServer -->|"metrics client"| PrometheusClient["prometheus-client 0.25.0"]
    MLServer -->|"tracing SDK"| OTelSDK["opentelemetry-sdk ^1.22.0"]
    MLServer -->|"trace export"| OTelExporter["opentelemetry-exporter-otlp"]

    %% Data Processing Dependencies
    MLServer -->|"tensor handling"| NumPy["NumPy"]
    MLServer -->|"dataframe codec"| Pandas["Pandas"]
    MLServer -->|"fast JSON"| orjson["orjson"]

    %% Async/Concurrency Dependencies
    MLServer -->|"async kafka"| aiokafka["aiokafka"]
    MLServer -->|"greenlets"| gevent["gevent"]
    MLServer -->|"event loop"| uvloop["uvloop"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>InferenceService"] -->|"container runtime<br/>lifecycle mgmt"| MLServer
    KServeAgent["KServe Model Agent<br/>(sidecar)"] -->|"model load/unload<br/>REST 8080/TCP"| MLServer
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8082/TCP HTTP"| MLServer
    OTelCollector["OpenTelemetry<br/>Collector"] <-.->|"OTLP traces<br/>gRPC (insecure)"| MLServer
    KafkaBrokers["Kafka Brokers"] <-.->|"async inference<br/>9092/TCP"| MLServer
    ModelStorage["Model Storage<br/>(PVC/S3)"] -.->|"model artifacts<br/>/mnt/models"| MLServer

    %% Base Image
    MLServer -->|"base image"| BaseImage["quay.io/aipcc/<br/>base-images/cpu:3.5.0-ea.1<br/>(UBI-based)"]

