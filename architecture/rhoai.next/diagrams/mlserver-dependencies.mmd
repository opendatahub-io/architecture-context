graph LR
    MLServer["MLServer<br/>Inference Server"]

    %% Internal RHOAI Dependencies
    MLServer -->|"deployed by<br/>InferenceService CRD"| KServe["KServe"]

    %% Infrastructure Dependencies
    MLServer -->|"model artifacts<br/>/mnt/models"| ModelStorage["Model Storage<br/>(PVC / S3)"]
    MLServer -->|"traces<br/>gRPC/4317"| OTelCollector["OpenTelemetry<br/>Collector"]
    MLServer -->|"event I/O<br/>AMQP/9092"| Kafka["Apache Kafka<br/>(optional)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes<br/>HTTP/8082"| MLServer

    %% Platform Ingress
    Istio["KServe/Istio<br/>Gateway"] -->|"routes traffic<br/>TLS termination"| MLServer

    %% Runtime Plugin Dependencies (optional)
    subgraph RuntimeDeps["Optional Runtime Dependencies"]
        SKLearn["scikit-learn"]
        XGBoost["XGBoost"]
        LightGBM["LightGBM"]
        ONNXRuntime["ONNX Runtime"]
        HuggingFace["HuggingFace<br/>Transformers"]
        MLflowLib["MLflow"]
        CatBoostLib["CatBoost"]
        AlibiDetect["alibi-detect"]
        AlibiExplain["alibi"]
        PySpark["PySpark<br/>MLlib"]
    end

    MLServer -.->|"runtime plugins"| RuntimeDeps

    %% Core Framework Dependencies
    subgraph CoreDeps["Core Dependencies"]
        FastAPI["FastAPI<br/>>=0.88.0"]
        Uvicorn["Uvicorn"]
        GRPCIO["grpcio<br/>>=1.67.1"]
        Protobuf["protobuf<br/>>=5.27.2"]
        Pydantic["Pydantic v2"]
        NumPy["NumPy"]
        Pandas["Pandas"]
        OTelSDK["OpenTelemetry SDK<br/>^1.22.0"]
    end

    MLServer -->|"core framework"| CoreDeps

    %% Integration Points (consumers of MLServer)
    AlibiExplainRT["Alibi Explain<br/>Runtime"] -.->|"HTTP client<br/>upstream model"| InferenceEP["Inference Model<br/>Endpoint"]
    TritonClient["Triton Client<br/>(batch processing)"] -.->|"HTTP/gRPC<br/>batch inference"| MLServer

    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#f5a623,stroke:#333,color:#fff
