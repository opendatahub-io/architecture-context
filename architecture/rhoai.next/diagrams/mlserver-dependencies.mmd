graph LR
    MLServer["MLServer<br/>Multi-Model Inference Server"]

    %% Internal Platform Dependencies
    MLServer -->|"container runtime<br/>lifecycle, routing, scaling"| KServe["KServe<br/>InferenceService"]
    MLServer -->|"reads namespace<br/>from service account"| K8sAPI["Kubernetes API"]

    %% Auth Sidecar (platform-provided)
    KubeRBACProxy["kube-rbac-proxy<br/>(RHOAI 3.x sidecar)"] -->|"TLS termination<br/>8443→8080/8081"| MLServer

    %% Core Framework Dependencies
    MLServer -->|"REST framework"| FastAPI["FastAPI<br/>>=0.134.0"]
    MLServer -->|"ASGI server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC framework"| GRPCIO["grpcio<br/>>=1.67.1"]
    MLServer -->|"data validation"| Pydantic["pydantic<br/>^2.7.1"]

    %% ML Runtime Dependencies (RHOAI shipped)
    MLServer -->|"sklearn models"| ScikitLearn["scikit-learn<br/>1.9.0"]
    MLServer -->|"xgboost models"| XGBoost["XGBoost<br/>3.3.0"]
    MLServer -->|"lightgbm models"| LightGBM["LightGBM<br/>4.6.0"]
    MLServer -->|"onnx models"| ONNXRuntime["onnxruntime<br/>1.24.4"]

    %% Data & Serialization Dependencies
    MLServer -->|"tensor handling"| NumPy["NumPy"]
    MLServer -->|"DataFrame codec"| Pandas["Pandas"]
    MLServer -->|"fast JSON"| OrJSON["orjson"]
    MLServer -->|"protobuf"| Protobuf["protobuf<br/>>=5.27.2"]

    %% Observability Dependencies
    MLServer -.->|"metrics<br/>8082/TCP"| PromClient["prometheus-client<br/>0.25.0"]
    MLServer -.->|"tracing<br/>4317/TCP gRPC"| OTelSDK["opentelemetry-sdk<br/>^1.22.0"]

    %% Optional Dependencies
    MLServer -.->|"streaming inference<br/>9092/TCP"| AIOKafka["aiokafka"]
    MLServer -.->|"batch processing"| TritonClient["tritonclient[http]<br/>>=2.42"]

    %% Integration Points (other platform components)
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    ModelStorage["Model Storage<br/>(PVC / S3)"] -->|"/mnt/models"| MLServer

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e8a838,stroke:#333,color:#fff

    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style GRPCIO fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff

    style ScikitLearn fill:#50c878,stroke:#333,color:#fff
    style XGBoost fill:#50c878,stroke:#333,color:#fff
    style LightGBM fill:#50c878,stroke:#333,color:#fff
    style ONNXRuntime fill:#50c878,stroke:#333,color:#fff

    style NumPy fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style OrJSON fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff

    style PromClient fill:#bbb,stroke:#333
    style OTelSDK fill:#bbb,stroke:#333
    style AIOKafka fill:#bbb,stroke:#333
    style TritonClient fill:#bbb,stroke:#333

    style Dashboard fill:#7ed321,stroke:#333,color:#fff
