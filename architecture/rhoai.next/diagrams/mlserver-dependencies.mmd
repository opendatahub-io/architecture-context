graph LR
    MLServer["MLServer<br/>Inference Server<br/>(V2 Dataplane API)"]

    %% Internal RHOAI Dependencies
    MLServer -->|"deployed by<br/>InferenceService CRD"| KServe["KServe"]
    MLServer -.->|"ingress routing<br/>TLS + Auth"| Istio["Istio /<br/>Service Mesh"]

    %% Core Framework Dependencies
    subgraph CoreDeps["Core Dependencies"]
        FastAPI["FastAPI<br/>>=0.88.0,<0.116.0"]
        Uvicorn["Uvicorn"]
        grpcio["grpcio<br/>>=1.67.1"]
        Protobuf["protobuf<br/>>=5.27.2,<7.0"]
        Pydantic["pydantic<br/>^2.7.1"]
    end
    MLServer -->|"REST framework"| FastAPI
    MLServer -->|"ASGI server"| Uvicorn
    MLServer -->|"gRPC framework"| grpcio
    MLServer -->|"serialization"| Protobuf
    MLServer -->|"settings/validation"| Pydantic

    %% Observability Dependencies
    subgraph Observability["Observability"]
        OTel["OpenTelemetry SDK<br/>^1.22.0"]
        OTelFastAPI["OTel FastAPI<br/>instrumentation"]
        OTelgRPC["OTel gRPC<br/>instrumentation"]
        StarletteExporter["starlette-exporter<br/>(Prometheus)"]
        GRPCPrometheus["py-grpc-prometheus"]
    end
    MLServer -->|"tracing"| OTel
    MLServer -->|"REST metrics"| StarletteExporter
    MLServer -->|"gRPC metrics"| GRPCPrometheus

    %% External Service Dependencies
    subgraph ExternalServices["External Services"]
        OTelCollector["OpenTelemetry<br/>Collector<br/>4317/TCP gRPC"]
        Prometheus["Prometheus<br/>(scrapes 8082)"]
        KafkaBrokers["Apache Kafka<br/>9092/TCP"]
        ModelStorageSvc["Model Storage<br/>PVC / S3<br/>/mnt/models"]
    end
    MLServer -->|"export traces<br/>OTLP gRPC insecure"| OTelCollector
    Prometheus -->|"scrape /metrics<br/>HTTP"| MLServer
    MLServer -.->|"event-driven<br/>inference (optional)"| KafkaBrokers
    ModelStorageSvc -->|"model artifacts<br/>filesystem mount"| MLServer

    %% Runtime Plugin Dependencies (Optional)
    subgraph RuntimeDeps["Runtime Plugins (Optional)"]
        SKLearn["scikit-learn"]
        XGBoost["XGBoost"]
        LightGBM["LightGBM"]
        ONNXRuntime["ONNX Runtime"]
        HuggingFace["HuggingFace<br/>Transformers"]
        MLflow["MLflow"]
        CatBoost["CatBoost"]
        AlibiDetect["alibi-detect"]
        AlibiExplain["alibi"]
        PySpark["PySpark MLlib"]
    end
    MLServer -.->|"runtime"| SKLearn
    MLServer -.->|"runtime"| XGBoost
    MLServer -.->|"runtime"| LightGBM
    MLServer -.->|"runtime"| ONNXRuntime
    MLServer -.->|"runtime"| HuggingFace
    MLServer -.->|"runtime"| MLflow
    MLServer -.->|"runtime"| CatBoost
    MLServer -.->|"runtime"| AlibiDetect
    MLServer -.->|"runtime"| AlibiExplain
    MLServer -.->|"runtime"| PySpark

    %% Data Dependencies
    subgraph DataLibs["Data Libraries"]
        NumPy["NumPy"]
        Pandas["Pandas"]
        orjson["orjson"]
    end
    MLServer -->|"tensor handling"| NumPy
    MLServer -->|"DataFrame codec"| Pandas
    MLServer -->|"JSON perf"| orjson

