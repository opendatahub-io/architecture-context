graph LR
    MLServer["MLServer<br/>ML Inference Server<br/>V2 Protocol"]

    %% Internal RHOAI Platform Dependencies
    MLServer -->|"runs inside pod"| KServe["KServe<br/>InferenceService"]
    MLServer -->|"metrics scraping<br/>8082/TCP"| Prometheus["Prometheus"]
    MLServer -.->|"OTLP traces<br/>gRPC (insecure)"| OTelCollector["OpenTelemetry<br/>Collector"]
    MLServer -.->|"async inference<br/>9092/TCP"| Kafka["Kafka Brokers"]

    %% KServe manages MLServer
    KServeAgent["KServe Model Agent"] -->|"load/unload models<br/>REST 8080/TCP"| MLServer

    %% Platform integration
    Istio["Istio / Gateway API"] -->|"TLS termination<br/>ingress routing"| MLServer

    %% External Dependencies (Runtime)
    MLServer -->|"model artifacts<br/>filesystem"| ModelStorage["/mnt/models<br/>PVC / S3 Volume"]

    %% Core Python Dependencies
    subgraph PythonDeps["Core Python Dependencies"]
        direction TB
        FastAPI["FastAPI<br/>>=0.88.0,<0.116.0"]
        Uvicorn["Uvicorn<br/>ASGI Server"]
        GRPCIO["grpcio<br/>>=1.67.1"]
        Protobuf["protobuf<br/>>=5.27.2,<7.0.0"]
        Pydantic["Pydantic v2<br/>^2.7.1"]
        NumPy["NumPy"]
        Pandas["Pandas"]
        OTelSDK["opentelemetry-sdk<br/>^1.22.0"]
    end

    MLServer --- FastAPI
    MLServer --- Uvicorn
    MLServer --- GRPCIO
    MLServer --- Protobuf
    MLServer --- Pydantic
    MLServer --- NumPy
    MLServer --- OTelSDK

    %% ML Runtime Dependencies
    subgraph MLRuntimes["ML Runtime Libraries"]
        direction TB
        ScikitLearn["scikit-learn"]
        XGBoost["XGBoost"]
        LightGBM["LightGBM"]
        ONNXRuntime["onnxruntime<br/>>=1.20.0"]
    end

    MLServer --- ScikitLearn
    MLServer --- XGBoost
    MLServer --- LightGBM
    MLServer --- ONNXRuntime

    %% Base Image
    MLServer -->|"base image"| BaseImage["quay.io/aipcc/<br/>base-images/cpu<br/>3.5.0-ea.1<br/>(UBI-based)"]

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeAgent fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style OTelCollector fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff

    style Kafka fill:#f5a623,stroke:#333,color:#fff
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style BaseImage fill:#f5a623,stroke:#333,color:#fff

    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style GRPCIO fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style NumPy fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style OTelSDK fill:#999,stroke:#333,color:#fff

