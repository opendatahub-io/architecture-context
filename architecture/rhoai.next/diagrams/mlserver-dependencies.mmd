graph LR
    MLServer["MLServer<br/>v1.7.1+rhaiv.8"]

    %% Internal Platform Dependencies
    MLServer -->|"container runtime<br/>pod lifecycle"| KServe["KServe<br/>Controller"]
    MLServer -->|"init container<br/>/mnt/models"| StorageInit["Storage<br/>Initializer"]

    %% Core Framework Dependencies
    MLServer -->|"REST API<br/>framework"| FastAPI["FastAPI<br/>>=0.134.0"]
    MLServer -->|"ASGI server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC server<br/>& client"| gRPC["gRPC<br/>>=1.67.1"]
    MLServer -->|"serialization"| Protobuf["Protobuf<br/>>=5.27.2"]
    MLServer -->|"settings &<br/>validation"| Pydantic["Pydantic<br/>^2.7.1"]

    %% Data Dependencies
    MLServer -->|"tensor handling"| NumPy["NumPy"]
    MLServer -->|"DataFrame codec"| Pandas["Pandas"]
    MLServer -->|"JSON parsing"| orjson["orjson"]

    %% Messaging Dependencies
    MLServer -->|"async Kafka<br/>consumer/producer"| aiokafka["aiokafka"]

    %% Observability Dependencies
    MLServer -->|"distributed<br/>tracing"| OTel["OpenTelemetry<br/>SDK ^1.22.0"]
    MLServer -->|"REST metrics"| StarletteExp["starlette-<br/>exporter"]
    MLServer -->|"gRPC metrics"| GRPCProm["py-grpc-<br/>prometheus"]

    %% Runtime Dependencies
    MLServer -->|"sklearn models"| Sklearn["scikit-learn"]
    MLServer -->|"xgboost models"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm models"| LightGBM["LightGBM"]
    MLServer -->|"ONNX inference"| ONNXRuntime["onnxruntime<br/>>=1.20.0"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>8082/TCP"| MLServer
    KubeRBAC["kube-rbac-proxy<br/>(RHOAI 3.x)"] -->|"auth sidecar"| MLServer
    Istio["Istio / Envoy"] -.->|"mTLS sidecar"| MLServer

    %% External Services (outbound)
    MLServer -->|"async inference<br/>9092/TCP"| KafkaBroker["Kafka Broker"]
    MLServer -->|"trace export<br/>OTLP/gRPC"| OTelCollector["OpenTelemetry<br/>Collector"]

