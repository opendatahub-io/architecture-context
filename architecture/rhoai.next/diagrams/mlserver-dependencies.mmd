graph LR
    MLServer["MLServer<br/>V2 Inference Server"]

    %% Platform Dependencies (deploying platforms)
    MLServer -->|"container image<br/>deployed inside pods"| KServe["KServe<br/>InferenceService"]
    MLServer -->|"container image<br/>serving runtime"| ModelMesh["ModelMesh<br/>ServingRuntime"]

    %% Core Framework Dependencies
    MLServer -->|"REST API framework"| FastAPI["FastAPI >=0.88"]
    MLServer -->|"ASGI server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC framework"| GRPCIO["grpcio >=1.67.1"]
    MLServer -->|"protobuf serialization"| Protobuf["protobuf >=5.27"]
    MLServer -->|"settings/validation"| Pydantic["pydantic ^2.7.1"]

    %% Data Processing Dependencies
    MLServer -->|"tensor data"| NumPy["NumPy"]
    MLServer -->|"DataFrame codec"| Pandas["Pandas"]
    MLServer -->|"fast JSON"| Orjson["orjson"]

    %% ML Runtime Dependencies
    MLServer -->|"sklearn runtime"| Sklearn["scikit-learn"]
    MLServer -->|"xgboost runtime"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm runtime"| LightGBM["LightGBM"]
    MLServer -->|"onnx runtime"| ONNX["onnxruntime >=1.20"]

    %% Observability Dependencies
    MLServer -->|"REST metrics"| StarletteExporter["starlette-exporter"]
    MLServer -->|"gRPC metrics"| GRPCPrometheus["py-grpc-prometheus"]
    MLServer -->|"tracing SDK"| OTelSDK["opentelemetry-sdk ^1.22"]
    MLServer -->|"trace export"| OTelExporter["otlp-proto-grpc ^1.22"]

    %% Infrastructure Dependencies
    MLServer -->|"async Kafka"| AioKafka["aiokafka"]
    MLServer -->|"event loop"| Uvloop["uvloop"]
    MLServer -->|"cooperative threads"| Gevent["gevent"]
    MLServer -->|"Triton compat"| TritonClient["tritonclient >=2.42"]

    %% Integration Points (other components that use MLServer)
    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTP/8082"| MLServer
    OTelCollector["OTel Collector"] -.->|"receives traces<br/>gRPC/4317"| MLServer
    KafkaCluster["Kafka Cluster"] -.->|"async inference<br/>9092/TCP"| MLServer

    %% Storage
    MLServer -->|"model artifacts<br/>/mnt/models"| ModelStorage["Model Storage<br/>(PVC / S3)"]

    %% Runtime dependency
    MLServer -->|"runtime language"| Python["Python >=3.10,<3.13"]

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Platform (blue-grey)
    style KServe fill:#5c6bc0,stroke:#333,color:#fff
    style ModelMesh fill:#5c6bc0,stroke:#333,color:#fff

    %% Core frameworks (grey)
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style GRPCIO fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style Python fill:#999,stroke:#333,color:#fff

    %% Data processing (light grey)
    style NumPy fill:#bbb,stroke:#333,color:#333
    style Pandas fill:#bbb,stroke:#333,color:#333
    style Orjson fill:#bbb,stroke:#333,color:#333

    %% ML runtimes (green)
    style Sklearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff

    %% Observability (purple)
    style StarletteExporter fill:#7B68EE,stroke:#333,color:#fff
    style GRPCPrometheus fill:#7B68EE,stroke:#333,color:#fff
    style OTelSDK fill:#7B68EE,stroke:#333,color:#fff
    style OTelExporter fill:#7B68EE,stroke:#333,color:#fff

    %% Infrastructure (orange)
    style AioKafka fill:#f5a623,stroke:#333,color:#fff
    style Uvloop fill:#f5a623,stroke:#333,color:#fff
    style Gevent fill:#f5a623,stroke:#333,color:#fff
    style TritonClient fill:#f5a623,stroke:#333,color:#fff

    %% External services
    style Prometheus fill:#e65100,stroke:#333,color:#fff
    style OTelCollector fill:#7B68EE,stroke:#333,color:#fff
    style KafkaCluster fill:#f5a623,stroke:#333,color:#fff
