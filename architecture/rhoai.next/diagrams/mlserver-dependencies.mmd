graph LR
    MLServer["MLServer<br/>ML Inference Server<br/>v1.7.1+rhaiv.8"]

    %% Internal RHOAI Dependencies
    MLServer -->|"container runtime<br/>lifecycle mgmt"| KServe["KServe<br/>InferenceService"]
    MLServer -->|"metrics scraping<br/>8082/TCP HTTP"| Prometheus["Prometheus"]
    MLServer -.->|"OTLP traces<br/>gRPC (insecure)"| OTELCollector["OpenTelemetry<br/>Collector"]

    %% Platform Infrastructure (Managed by KServe)
    KServe -->|"TLS termination<br/>traffic routing"| Istio["Istio / Gateway API"]
    KServe -->|"authn sidecars"| AuthProxy["kube-rbac-proxy /<br/>oauth-proxy"]
    KServe -->|"model storage init"| StorageInit["Storage Initializer"]

    %% External Service Dependencies
    MLServer -->|"model artifacts<br/>filesystem /mnt/models"| ModelStorage["Model Storage<br/>(PVC / S3)"]
    MLServer -.->|"async inference<br/>9092/TCP"| Kafka["Kafka Brokers"]

    %% Core Python Dependencies
    MLServer -->|"REST API"| FastAPI["FastAPI >=0.88"]
    MLServer -->|"ASGI server"| Uvicorn["Uvicorn"]
    MLServer -->|"gRPC server"| GRPCIO["grpcio >=1.67.1"]
    MLServer -->|"serialization"| Protobuf["protobuf >=5.27"]
    MLServer -->|"config/validation"| Pydantic["Pydantic ^2.7.1"]
    MLServer -->|"metrics"| PromClient["prometheus-client<br/>0.25.0"]
    MLServer -->|"tracing"| OpenTelemetry["opentelemetry-sdk<br/>^1.22.0"]

    %% Runtime Plugin Dependencies
    MLServer -->|"sklearn models"| Sklearn["scikit-learn"]
    MLServer -->|"xgboost models"| XGBoost["XGBoost"]
    MLServer -->|"lightgbm models"| LightGBM["LightGBM"]
    MLServer -->|"onnx models"| ONNXRuntime["onnxruntime >=1.20"]

    %% Base Image
    MLServer -->|"base image"| BaseImage["quay.io/aipcc/<br/>base-images/cpu<br/>3.5.0-ea.1 (UBI)"]

    %% Integration Points (other components using MLServer)
    KServeAgent["KServe Model Agent"] -->|"model load/unload<br/>8080/TCP HTTP"| MLServer

    %% Styling
    style MLServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style OTELCollector fill:#7ed321,stroke:#333,color:#fff
    style KServeAgent fill:#7ed321,stroke:#333,color:#fff
    style AuthProxy fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style Kafka fill:#f5a623,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff

    %% Python Dependencies
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style GRPCIO fill:#e8e8e8,stroke:#333
    style Protobuf fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
    style OpenTelemetry fill:#e8e8e8,stroke:#333

    %% Runtime Plugins
    style Sklearn fill:#f5d6ab,stroke:#333
    style XGBoost fill:#f5d6ab,stroke:#333
    style LightGBM fill:#f5d6ab,stroke:#333
    style ONNXRuntime fill:#f5d6ab,stroke:#333

