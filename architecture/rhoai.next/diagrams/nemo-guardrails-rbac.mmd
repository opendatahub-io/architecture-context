graph TD
    subgraph "NeMo Guardrails RBAC & Auth Model"
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            Note1["No ClusterRoles defined<br/>(RBAC managed by platform operator)"]
            Note2["No RoleBindings defined<br/>(deployment managed externally)"]
        end

        subgraph AuthModel["Authentication Model"]
            direction TB

            subgraph Inbound["Inbound Authentication"]
                ClientReq["Client Request"]
                HeaderForward["Header Forwarding<br/>(X-* headers, Authorization)"]
                NoBuiltInAuth["No Built-in Auth<br/>(relies on upstream provider)"]
                ClientReq --> HeaderForward
                HeaderForward --> NoBuiltInAuth
            end

            subgraph Outbound["Outbound Authentication (to LLM Providers)"]
                direction TB
                OpenAIKey["OPENAI_API_KEY<br/>(Bearer Token)"]
                AnthropicKey["ANTHROPIC_API_KEY<br/>(Bearer Token)"]
                AzureKey["AZURE_OPENAI_API_KEY<br/>(api-key header)"]
                CohereKey["COHERE_API_KEY<br/>(Bearer Token)"]
            end
        end

        subgraph Secrets["Secrets Management"]
            LLMKeys["LLM API Keys (Opaque)<br/>Provisioned: Manual / platform operator<br/>Auto-Rotate: No"]
        end

        subgraph Endpoints["Endpoint Authentication Matrix"]
            EP1["/v1/chat/completions<br/>POST<br/>Auth: Header forwarding<br/>Enforcement: Application-level"]
            EP2["/v1/guardrail/checks<br/>POST<br/>Auth: Header forwarding<br/>Enforcement: Application-level"]
            EP3["/v1/models<br/>GET<br/>Auth: Bearer Token forwarded<br/>Enforcement: Application-level"]
            EP4["/v1/rails/configs<br/>GET<br/>Auth: None<br/>Enforcement: None"]
        end
    end

    LLMKeys -->|env vars| OpenAIKey
    LLMKeys -->|env vars| AnthropicKey
    LLMKeys -->|env vars| AzureKey
    LLMKeys -->|env vars| CohereKey

    style Note1 fill:#f9f9f9,stroke:#ccc
    style Note2 fill:#f9f9f9,stroke:#ccc
    style ClientReq fill:#e8e8e8,stroke:#333
    style HeaderForward fill:#dae8fc,stroke:#6c8ebf
    style NoBuiltInAuth fill:#f8cecc,stroke:#b85450
    style OpenAIKey fill:#fff2cc,stroke:#d6b656
    style AnthropicKey fill:#fff2cc,stroke:#d6b656
    style AzureKey fill:#fff2cc,stroke:#d6b656
    style CohereKey fill:#fff2cc,stroke:#d6b656
    style LLMKeys fill:#ffe6cc,stroke:#d79b00
    style EP1 fill:#d5e8d4,stroke:#82b366
    style EP2 fill:#d5e8d4,stroke:#82b366
    style EP3 fill:#d5e8d4,stroke:#82b366
    style EP4 fill:#d5e8d4,stroke:#82b366
