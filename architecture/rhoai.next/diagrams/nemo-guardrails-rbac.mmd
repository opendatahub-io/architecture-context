graph TD
    subgraph "NeMo Guardrails Authentication Model"
        direction TB

        subgraph "Note: No Kubernetes RBAC"
            NoRBAC["NeMo Guardrails is a stateless service<br/>(not a K8s operator/controller)<br/>No ClusterRoles, RoleBindings, or CRDs defined<br/>Deployment RBAC managed by RHOAI platform operator"]
        end

        subgraph "Application-Level Auth (Header Forwarding)"
            direction TB
            ClientReq["Client Request<br/>Authorization: Bearer {token}<br/>X-Custom-Header: {value}"]
            Server["NeMo Guardrails Server<br/>Port 8000/TCP"]
            Upstream["Upstream LLM Provider"]

            ClientReq -->|"Headers forwarded<br/>(X-* headers + Authorization)"| Server
            Server -->|"Bearer Token forwarded<br/>Auth tokens redacted in X-* headers"| Upstream
        end

        subgraph "Endpoint Authentication Matrix"
            EP1["/v1/chat/completions<br/>POST<br/>Auth: Header forwarding<br/>No built-in auth"]
            EP2["/v1/guardrail/checks<br/>POST<br/>Auth: Header forwarding<br/>No built-in auth"]
            EP3["/v1/models<br/>GET<br/>Auth: Bearer Token forwarded<br/>to upstream for model listing"]
            EP4["/v1/rails/configs<br/>GET<br/>Auth: None"]
            EP5["/v1/challenges<br/>GET<br/>Auth: None"]
        end

        subgraph "Secrets Management"
            direction LR
            Secret["LLM API Keys (Opaque)<br/>Provisioned by: Manual / Platform Operator<br/>Auto-Rotate: No"]
            Key1["OPENAI_API_KEY"]
            Key2["ANTHROPIC_API_KEY"]
            Key3["AZURE_OPENAI_API_KEY"]
            Key4["COHERE_API_KEY"]

            Secret --- Key1
            Secret --- Key2
            Secret --- Key3
            Secret --- Key4
        end

        subgraph "Access Control (Platform-Enforced)"
            direction TB
            MeshPolicy["Service Mesh Policies<br/>(Istio/OSSM)<br/>PeerAuthentication<br/>AuthorizationPolicy"]
            NetPolicy["Network Policies<br/>Ingress: 8000/TCP from platform NS<br/>Egress: 443/TCP to LLM providers<br/>Egress: 4317-4318/TCP to OTEL"]
            GatewayAuth["External Gateway/Ingress<br/>Authentication<br/>(platform-managed)"]
        end
    end

    style NoRBAC fill:#fff3cd,stroke:#856404,stroke-width:2px
    style ClientReq fill:#e8e8e8,stroke:#333
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style Upstream fill:#999,stroke:#333,color:#fff
    style EP1 fill:#d5e8d4,stroke:#82b366
    style EP2 fill:#d5e8d4,stroke:#82b366
    style EP3 fill:#d5e8d4,stroke:#82b366
    style EP4 fill:#dae8fc,stroke:#6c8ebf
    style EP5 fill:#dae8fc,stroke:#6c8ebf
    style Secret fill:#f8cecc,stroke:#b85450
    style Key1 fill:#f8cecc,stroke:#b85450
    style Key2 fill:#f8cecc,stroke:#b85450
    style Key3 fill:#f8cecc,stroke:#b85450
    style Key4 fill:#f8cecc,stroke:#b85450
    style MeshPolicy fill:#e1d5e7,stroke:#9673a6
    style NetPolicy fill:#e1d5e7,stroke:#9673a6
    style GatewayAuth fill:#e1d5e7,stroke:#9673a6
