graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["🟢 No Kubernetes RBAC defined"]
        L2["🟡 Auth via header passthrough"]
        L3["🔴 Platform-dependent enforcement"]
    end

    subgraph ServiceIdentity["Service Identity"]
        Pod["NeMo Guardrails Pod<br/>(stateless service container)"]
        SA["Default ServiceAccount<br/>(no custom SA defined)"]
        Pod -->|"runs as"| SA
    end

    subgraph NoRBAC["Kubernetes RBAC (None Defined)"]
        direction TB
        NoCR["No ClusterRoles"]
        NoR["No Roles"]
        NoCRB["No ClusterRoleBindings"]
        NoRB["No RoleBindings"]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

        subgraph PlatformAuth["Platform-Level Auth (External)"]
            KubeRBACProxy["kube-rbac-proxy<br/>or Gateway API<br/>(enforces AuthN/AuthZ)"]
        end

        subgraph AppAuth["Application-Level Auth (Passthrough)"]
            HeaderFwd["Authorization Header<br/>Forwarding"]
            TokenRedact["Token Redaction<br/>(logging/callbacks.py)"]
        end

        subgraph ProviderAuth["Upstream Provider Auth"]
            BearerToken["Bearer Token<br/>(OpenAI, NIM, Cohere)"]
            APIKey["API Key Header<br/>(Anthropic: x-api-key<br/>Azure: api-key)"]
            GCPCreds["GCP Credentials<br/>(Vertex AI)"]
            EnvVarKey["Env Var API Key<br/>(api_key_env_var config)"]
        end
    end

    subgraph Secrets["Secrets"]
        LLMKeys["LLM API Keys<br/>Type: Opaque (env vars)<br/>Provisioned: Manual / External<br/>Auto-Rotate: No"]
    end

    SA -.->|"no RBAC bindings"| NoRBAC

    KubeRBACProxy -->|"enforces auth before<br/>request reaches service"| Pod
    Pod -->|"extracts & forwards<br/>auth headers"| HeaderFwd
    HeaderFwd -->|"Bearer Token"| BearerToken
    HeaderFwd -->|"API Key"| APIKey
    HeaderFwd -->|"GCP credentials"| GCPCreds
    EnvVarKey -->|"fallback: shared key<br/>from environment"| BearerToken
    HeaderFwd -->|"redacts tokens in logs"| TokenRedact

    LLMKeys -->|"mounted as env vars"| Pod

    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style NoCR fill:#d5e8d4,stroke:#82b366
    style NoR fill:#d5e8d4,stroke:#82b366
    style NoCRB fill:#d5e8d4,stroke:#82b366
    style NoRB fill:#d5e8d4,stroke:#82b366
    style KubeRBACProxy fill:#ffe6cc,stroke:#d79b00
    style HeaderFwd fill:#fff2cc,stroke:#d6b656
    style TokenRedact fill:#d5e8d4,stroke:#82b366
    style BearerToken fill:#f5a623,stroke:#333
    style APIKey fill:#f5a623,stroke:#333
    style GCPCreds fill:#f5a623,stroke:#333
    style EnvVarKey fill:#f5a623,stroke:#333
    style LLMKeys fill:#e1d5e7,stroke:#9673a6
