graph TD
    subgraph NoRBAC["No RBAC Resources Defined"]
        direction TB
        Note["NeMo Guardrails is a standalone Python service,<br/>not a Kubernetes operator.<br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined in this repository."]
    end

    subgraph PlatformAuth["Platform-Level Authentication & Authorization"]
        direction TB

        subgraph AuthMechanisms["Auth Enforcement"]
            KRBAC["kube-rbac-proxy Sidecar<br/>(RHOAI pattern)"]
            GatewayAPI["Gateway API Auth<br/>(RHOAI 3.x)"]
            NetworkPolicy["Network Policies<br/>(namespace isolation)"]
        end

        subgraph Endpoints["API Endpoints (All /v1/*)"]
            ChatAPI["POST /v1/chat/completions"]
            CheckAPI["POST /v1/guardrail/checks"]
            ConfigAPI["GET /v1/rails/configs"]
            ModelsAPI["GET /v1/models"]
            ChallengesAPI["GET /v1/challenges"]
        end

        AuthMechanisms -->|"enforces access to"| Endpoints
    end

    subgraph Secrets["Secrets Management"]
        direction TB
        LLMKey["LLM API Key<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        GuardrailKeys["Guardrail API Keys<br/>Type: Opaque (per provider)<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        RedisPass["Redis Password<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph UpstreamAuth["Upstream Auth (Egress)"]
        direction TB
        LLMAuth["LLM Inference Service<br/>Auth: Bearer Token<br/>(forwarded from client)"]
        ExtAPIAuth["External Guardrail APIs<br/>Auth: API Key / Bearer Token<br/>(from env vars)"]
    end

    Secrets -->|"provides credentials"| UpstreamAuth

    subgraph SecurityControls["Application Security Controls"]
        ThreadID["Thread ID: min 16 chars"]
        PathTraversal["Path traversal protection<br/>(regex + resolved-path check)"]
        TokenRedact["Auth token redaction in logs"]
        CORSDisabled["CORS: Disabled by default"]
        Telemetry["DO_NOT_TRACK=1 by default"]
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KRBAC fill:#d5e8d4,stroke:#82b366
    style GatewayAPI fill:#d5e8d4,stroke:#82b366
    style NetworkPolicy fill:#d5e8d4,stroke:#82b366
    style ChatAPI fill:#dae8fc,stroke:#6c8ebf
    style CheckAPI fill:#dae8fc,stroke:#6c8ebf
    style ConfigAPI fill:#dae8fc,stroke:#6c8ebf
    style ModelsAPI fill:#dae8fc,stroke:#6c8ebf
    style ChallengesAPI fill:#dae8fc,stroke:#6c8ebf
    style LLMKey fill:#f8cecc,stroke:#b85450
    style GuardrailKeys fill:#f8cecc,stroke:#b85450
    style RedisPass fill:#f8cecc,stroke:#b85450
    style LLMAuth fill:#ffe6cc,stroke:#d79b00
    style ExtAPIAuth fill:#ffe6cc,stroke:#d79b00
    style ThreadID fill:#e8e8e8,stroke:#666
    style PathTraversal fill:#e8e8e8,stroke:#666
    style TokenRedact fill:#e8e8e8,stroke:#666
    style CORSDisabled fill:#e8e8e8,stroke:#666
    style Telemetry fill:#e8e8e8,stroke:#666
