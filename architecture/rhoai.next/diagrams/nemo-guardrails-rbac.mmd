graph TD
    subgraph NoRBAC["No Kubernetes RBAC Defined"]
        direction TB
        Note["NeMo Guardrails is a standalone<br/>Python service, not a Kubernetes operator.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined."]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

        subgraph Passthrough["Bearer Token Passthrough"]
            ClientToken["Client Bearer Token<br/>(Authorization header)"]
            ServerFwd["Server forwards token<br/>to upstream LLM provider"]
            Redaction["Auth token redaction<br/>in forwarded headers<br/>(fork customization)"]
            ClientToken --> ServerFwd
            ServerFwd --> Redaction
        end

        subgraph Unauthenticated["Unauthenticated Endpoints"]
            EP1["GET /v1/rails/configs"]
            EP2["GET /v1/challenges"]
            EP3["GET / (Health check)"]
            EP4["POST /v1/actions/run"]
            EP5["GET /v1/actions/list"]
        end

        subgraph Authenticated["Bearer Passthrough Endpoints"]
            EP6["POST /v1/chat/completions"]
            EP7["POST /v1/guardrail/checks"]
            EP8["GET /v1/models"]
        end
    end

    subgraph Secrets["Secrets (Environment Variables)"]
        direction TB
        S1["OPENAI_API_KEY<br/>Manual provisioning<br/>No auto-rotation"]
        S2["AZURE_OPENAI_API_KEY<br/>Manual provisioning<br/>No auto-rotation"]
        S3["ANTHROPIC_API_KEY<br/>Manual provisioning<br/>No auto-rotation"]
        S4["COHERE_API_KEY<br/>Manual provisioning<br/>No auto-rotation"]
        S5["Redis credentials<br/>URL / env var (optional)<br/>No auto-rotation"]
    end

    Authenticated -->|"Token forwarded to"| LLMProviders["Upstream LLM Providers<br/>(OpenAI, Azure, Anthropic,<br/>Cohere, NIM, vLLM)"]
    Secrets -->|"Used for direct<br/>provider auth"| LLMProviders

    %% Styling
    style NoRBAC fill:#f5f5f5,stroke:#999,stroke-width:2px
    style Note fill:#fff9c4,stroke:#f9a825
    style Passthrough fill:#e3f2fd,stroke:#1565c0
    style Unauthenticated fill:#ffcdd2,stroke:#c62828
    style Authenticated fill:#c8e6c9,stroke:#388e3c
    style Secrets fill:#fff3e0,stroke:#e65100
    style LLMProviders fill:#f5a623,stroke:#333
