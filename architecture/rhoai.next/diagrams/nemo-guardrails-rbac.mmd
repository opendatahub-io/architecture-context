graph TD
    subgraph "NeMo Guardrails — No Kubernetes RBAC"
        Note["This component is a stateless Python service.<br/>No Kubernetes RBAC resources are defined.<br/><br/>No ClusterRoles<br/>No ClusterRoleBindings<br/>No Roles<br/>No RoleBindings<br/>No ServiceAccounts (beyond default)"]
    end

    subgraph "Authentication Model"
        direction TB
        AuthPattern["Authorization Header Passthrough"]

        subgraph "Pattern 1: Header Forwarding"
            Client1["Client"] -->|"Authorization: Bearer {token}"| Server1["NeMo Guardrails Server"]
            Server1 -->|"Authorization: Bearer {token}<br/>(forwarded)"| LLM1["Upstream LLM Provider"]
        end

        subgraph "Pattern 2: Environment Variable"
            Server2["NeMo Guardrails Server"] -->|"api_key from env var<br/>(shared key)"| LLM2["Upstream LLM Provider"]
        end

        subgraph "Platform Auth Enforcement"
            PlatformAuth["Platform Ingress<br/>(kube-rbac-proxy / Gateway API)"]
            PlatformAuth -->|"Auth enforced here"| ServiceInternal["nemo-guardrails Service<br/>(no built-in auth)"]
        end
    end

    subgraph "Secrets"
        Secret1["LLM API Keys<br/>Type: Opaque (env vars)<br/>Provisioned: Manual / External<br/>Auto-Rotate: No"]
    end

    subgraph "Security Controls"
        TokenRedaction["Token Redaction<br/>logging/callbacks.py<br/>Auth tokens stripped from logs"]
        FIPSFallback["FIPS-Aware Crypto<br/>utils.py:410-416<br/>MD5 → SHA-256 fallback"]
    end

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthPattern fill:#f5f5f5,stroke:#999
    style Client1 fill:#f9f9f9,stroke:#999
    style Server1 fill:#4a90e2,stroke:#333,color:#fff
    style Server2 fill:#4a90e2,stroke:#333,color:#fff
    style LLM1 fill:#f5a623,stroke:#333
    style LLM2 fill:#f5a623,stroke:#333
    style PlatformAuth fill:#ffe6cc,stroke:#d79b00
    style ServiceInternal fill:#d5e8d4,stroke:#82b366
    style Secret1 fill:#f8cecc,stroke:#b85450
    style TokenRedaction fill:#d5e8d4,stroke:#82b366
    style FIPSFallback fill:#d5e8d4,stroke:#82b366
