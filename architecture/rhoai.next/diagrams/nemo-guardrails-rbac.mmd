graph TD
    subgraph AuthModel["NeMo Guardrails Authentication Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRoles["No ClusterRoles defined"]
            NoBindings["No RoleBindings defined"]
            NoSA["No custom ServiceAccount<br/>(uses default)"]
            Note1["Stateless Python service<br/>No Kubernetes API access required"]
        end

        subgraph ApplicationAuth["Application-Level Authentication"]
            direction TB

            subgraph HeaderPassthrough["Header Passthrough Pattern"]
                ClientHeader["Client sends<br/>Authorization: Bearer {token}"]
                ServerForward["Server extracts header<br/>and forwards to LLM provider"]
                LLMAuth["LLM Provider validates<br/>Bearer Token / API key"]
                ClientHeader --> ServerForward
                ServerForward --> LLMAuth
            end

            subgraph EnvVarAuth["Environment Variable Pattern"]
                EnvVar["api_key_env_var<br/>(from model config YAML)"]
                SecretMount["Kubernetes Secret<br/>→ env var injection"]
                LLMAuthEnv["LLM Provider validates<br/>shared API key"]
                SecretMount --> EnvVar
                EnvVar --> LLMAuthEnv
            end
        end

        subgraph PlatformAuth["Platform-Level Auth Enforcement"]
            Ingress["Platform Ingress<br/>(Gateway API / OpenShift Route)"]
            KRBAC["kube-rbac-proxy<br/>(optional)"]
            GatewayAuth["Gateway API AuthPolicy<br/>(optional)"]
            Ingress --> KRBAC
            Ingress --> GatewayAuth
        end

        subgraph Endpoints["Endpoint Auth Matrix"]
            EP1["/v1/chat/completions<br/>Auth: Header passthrough<br/>Enforcement: Platform ingress"]
            EP2["/v1/guardrail/checks<br/>Auth: Header passthrough<br/>Enforcement: Platform ingress"]
            EP3["/v1/models<br/>Auth: Header forwarded to provider<br/>Enforcement: Platform ingress"]
            EP4["/v1/rails/configs<br/>Auth: None<br/>Enforcement: Platform ingress"]
            EP5["/ (health)<br/>Auth: None<br/>Enforcement: None"]
        end

        subgraph Secrets["Secret Management"]
            LLMKeys["LLM API Keys<br/>Type: Opaque<br/>Provisioned by: Manual / External<br/>Auto-rotate: No"]
            TokenRedaction["Auth token redaction<br/>in invocation logs<br/>(logging/callbacks.py)"]
        end
    end

    PlatformAuth -->|"enforces auth before<br/>requests reach service"| Endpoints
    Endpoints -->|"forwarded auth headers"| ApplicationAuth

    style AuthModel fill:#f9f9f9,stroke:#333
    style NoK8sRBAC fill:#e8e8e8,stroke:#999
    style ApplicationAuth fill:#d5e8d4,stroke:#82b366
    style HeaderPassthrough fill:#fff2cc,stroke:#d6b656
    style EnvVarAuth fill:#fff2cc,stroke:#d6b656
    style PlatformAuth fill:#ffe6cc,stroke:#d79b00
    style Endpoints fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#f8cecc,stroke:#b85450

    style NoRoles fill:#e8e8e8,stroke:#999
    style NoBindings fill:#e8e8e8,stroke:#999
    style NoSA fill:#e8e8e8,stroke:#999
    style Note1 fill:#e8e8e8,stroke:#999

    style ClientHeader fill:#fff2cc,stroke:#d6b656
    style ServerForward fill:#fff2cc,stroke:#d6b656
    style LLMAuth fill:#fff2cc,stroke:#d6b656
    style EnvVar fill:#fff2cc,stroke:#d6b656
    style SecretMount fill:#fff2cc,stroke:#d6b656
    style LLMAuthEnv fill:#fff2cc,stroke:#d6b656

    style LLMKeys fill:#f8cecc,stroke:#b85450
    style TokenRedaction fill:#f8cecc,stroke:#b85450
