graph TD
    subgraph NoK8sRBAC["No Kubernetes RBAC"]
        Note1["This component is a stateless service<br/>with no K8s API access.<br/>No ClusterRoles, Roles, or RoleBindings."]
    end

    subgraph AppLevelAuth["Application-Level Authentication"]
        direction TB

        subgraph InboundHeaders["Inbound Request Headers"]
            AuthHeader["Authorization Header<br/>(K8s / Proxy Auth)"]
            XAuthHeader["X-Authorization Header<br/>(Application Bearer Token)"]
        end

        subgraph HeaderHandling["Header Isolation Logic<br/>(nemoguardrails/actions/llm/utils.py:62-88)"]
            BlockAuth["BLOCKED<br/>Authorization header<br/>NOT forwarded to LLM"]
            ForwardXAuth["FORWARDED<br/>X-Authorization → Authorization<br/>Only for auth-registered LLM instances"]
            RedactLogs["REDACTED<br/>Bearer tokens removed<br/>from callback logs"]
        end

        AuthHeader -->|"Excluded"| BlockAuth
        XAuthHeader -->|"Forwarded as Authorization"| ForwardXAuth
        ForwardXAuth -->|"Logged safely"| RedactLogs
    end

    subgraph Endpoints["Endpoint Auth Requirements"]
        ChatEndpoint["/v1/chat/completions<br/>POST<br/>Auth: X-Authorization forwarded"]
        ChecksEndpoint["/v1/guardrail/checks<br/>POST<br/>Auth: X-Authorization forwarded"]
        ModelsEndpoint["/v1/models<br/>GET<br/>Auth: Authorization passthrough"]
        ConfigsEndpoint["/v1/rails/configs<br/>GET<br/>Auth: None"]
        HealthEndpoint["/<br/>GET<br/>Auth: None"]
    end

    ForwardXAuth --> ChatEndpoint
    ForwardXAuth --> ChecksEndpoint
    ForwardXAuth --> ModelsEndpoint

    subgraph Secrets["Secrets"]
        LLMKey["LLM API Key<br/>(env var: varies by provider)<br/>Type: Opaque<br/>Provisioned: Manual / Platform Operator<br/>Auto-Rotate: No"]
        OTELCreds["OTEL Credentials<br/>(optional)<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    %% Styling
    style Note1 fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style BlockAuth fill:#f8d7da,stroke:#dc3545,stroke-width:2px
    style ForwardXAuth fill:#d4edda,stroke:#28a745,stroke-width:2px
    style RedactLogs fill:#d1ecf1,stroke:#17a2b8,stroke-width:2px
    style AuthHeader fill:#f5f5f5,stroke:#999
    style XAuthHeader fill:#f5f5f5,stroke:#999
    style ChatEndpoint fill:#e8e8e8,stroke:#666
    style ChecksEndpoint fill:#e8e8e8,stroke:#666
    style ModelsEndpoint fill:#e8e8e8,stroke:#666
    style ConfigsEndpoint fill:#e8e8e8,stroke:#666
    style HealthEndpoint fill:#e8e8e8,stroke:#666
    style LLMKey fill:#fff2cc,stroke:#d6b656
    style OTELCreds fill:#fff2cc,stroke:#d6b656
