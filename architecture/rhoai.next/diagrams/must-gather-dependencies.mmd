graph LR
    MustGather["Must-Gather<br/>Diagnostic Container"]

    %% Build / Runtime Dependencies
    subgraph BuildDeps["Build & Runtime Dependencies"]
        BaseImage["ose-must-gather-rhel9<br/>v4.20<br/>(base image)"]
        CliImage["ose-cli-rhel9<br/>v4.20<br/>(kubectl source)"]
        HelmBin["helm v4.1.4<br/>(Git LFS binary)"]
        KubectlBin["kubectl v1.33.3<br/>(Konflux)"]
        OcCli["oc CLI<br/>(from base image)"]
    end

    MustGather -->|"base image"| BaseImage
    MustGather -->|"builder stage"| CliImage
    MustGather -->|"bundled binary"| HelmBin
    CliImage -->|"provides"| KubectlBin
    BaseImage -->|"provides"| OcCli

    %% Platform Operator
    subgraph PlatformDep["Platform Operator"]
        RhodsOp["rhods-operator<br/>DSCInitialization,<br/>DataScienceCluster"]
    end

    MustGather -->|"CRD Read"| RhodsOp

    %% RHOAI Component Dependencies (all read-only)
    subgraph RHOAIComponents["RHOAI Components (CRD Read)"]
        KServe["KServe / LLM-D<br/>InferenceService,<br/>ServingRuntime"]
        DSP["Data Science Pipelines<br/>DSPA, Argo Workflows"]
        Dashboard["Dashboard<br/>OdhDashboardConfig"]
        KubeRay["KubeRay<br/>RayCluster, RayJob"]
        Kueue["Kueue<br/>ClusterQueue, Workload"]
        KFTO["Training Operator<br/>PyTorchJob, TrainJob"]
        ModelReg["Model Registry<br/>ModelRegistry"]
        TrustyAI["TrustyAI<br/>TrustyAIService, LMEvalJob"]
        Feast["Feast Operator<br/>FeatureStore"]
        LlamaStack["LlamaStack Operator<br/>LlamaStackDistribution"]
        MLflow["MLflow Operator<br/>MLflow"]
        Spark["Spark Operator<br/>SparkApplication"]
        MaaS["Models as a Service<br/>MaaSModelRef, Tenant"]
    end

    MustGather -->|"CRD Read"| KServe
    MustGather -->|"CRD Read"| DSP
    MustGather -->|"CRD Read"| Dashboard
    MustGather -->|"CRD Read"| KubeRay
    MustGather -->|"CRD Read"| Kueue
    MustGather -->|"CRD Read"| KFTO
    MustGather -->|"CRD Read"| ModelReg
    MustGather -->|"CRD Read"| TrustyAI
    MustGather -->|"CRD Read"| Feast
    MustGather -->|"CRD Read"| LlamaStack
    MustGather -->|"CRD Read"| MLflow
    MustGather -->|"CRD Read"| Spark
    MustGather -->|"CRD Read"| MaaS

    %% Networking Dependencies
    subgraph NetworkDeps["Networking (CRD Read)"]
        Istio["Istio / Sail Operator<br/>VirtualService,<br/>AuthorizationPolicy"]
        GatewayAPI["Gateway API<br/>Gateway, HTTPRoute,<br/>GRPCRoute"]
        Authorino["Authorino / Kuadrant<br/>AuthConfig, AuthPolicy,<br/>RateLimitPolicy"]
    end

    MustGather -->|"CRD Read"| Istio
    MustGather -->|"CRD Read"| GatewayAPI
    MustGather -->|"CRD Read"| Authorino

    %% Infrastructure Dependencies
    subgraph InfraDeps["Infrastructure (CRD Read)"]
        CertManager["cert-manager<br/>Issuer, Certificate"]
        LWS["LeaderWorkerSet<br/>LeaderWorkerSet"]
        Prometheus["Prometheus Operator<br/>ServiceMonitor,<br/>PrometheusRule"]
        NIM["NIM Account Operator<br/>Account"]
        GatewayIE["Gateway API IE<br/>InferencePool,<br/>InferenceObjective"]
    end

    MustGather -->|"CRD Read"| CertManager
    MustGather -->|"CRD Read"| LWS
    MustGather -->|"CRD Read"| Prometheus
    MustGather -->|"CRD Read"| NIM
    MustGather -->|"CRD Read"| GatewayIE

    %% Optional Dependencies
    subgraph OptionalDeps["Optional (Feature-Gated)"]
        KEDA["KEDA<br/>ScaledObject,<br/>TriggerAuthentication"]
        AMP["Azure Managed Prometheus<br/>ama-metrics pods"]
    end

    MustGather -.->|"ENABLE_WVA=true"| KEDA
    MustGather -.->|"AKS only"| AMP

    %% Core Dependency
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    MustGather -->|"ALL access via<br/>443/TCP HTTPS<br/>TLS 1.2+"| K8sAPI

