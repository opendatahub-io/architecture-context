graph LR
    MustGather["must-gather<br/>Diagnostic Image"]

    %% External Dependencies (Required Tools)
    MustGather -->|"CLI tool (OCP)"| OC["oc CLI 4.20+"]
    MustGather -->|"CLI tool (xKS)"| Kubectl["kubectl v1.33+"]
    MustGather -->|"Helm inspection"| Helm["helm v4.1.4"]
    MustGather -->|"base image (Konflux)"| BaseKonflux["ose-must-gather-rhel9<br/>v4.20"]
    MustGather -->|"base image (upstream)"| BaseUpstream["origin-must-gather<br/>4.21.0"]

    %% Internal RHOAI Components (CRD Read)
    MustGather -->|"CRD read"| RhodsOperator["rhods-operator<br/>DSC, DSCI"]
    MustGather -->|"CRD read"| KServe["KServe<br/>InferenceService, ServingRuntime"]
    MustGather -->|"CRD read"| DSP["Data Science Pipelines<br/>DSPA, Workflow"]
    MustGather -->|"CRD read"| Dashboard["Dashboard<br/>ODHDashboardConfig"]
    MustGather -->|"CRD read"| KubeRay["KubeRay<br/>RayCluster, RayJob"]
    MustGather -->|"CRD read"| Kueue["Kueue<br/>ClusterQueue, Workload"]
    MustGather -->|"CRD read"| KFTO["Training Operator<br/>PyTorchJob, TrainJob"]
    MustGather -->|"CRD read"| ModelReg["Model Registry<br/>ModelRegistry"]
    MustGather -->|"CRD read"| TrustyAI["TrustyAI<br/>LMEvalJob, Guardrails"]
    MustGather -->|"CRD read"| Feast["Feast Operator<br/>FeatureStore"]
    MustGather -->|"CRD read"| LlamaStack["Llama-stack<br/>LlamaStackDistribution"]
    MustGather -->|"CRD read"| MLflow["MLflow<br/>MLflow CR"]
    MustGather -->|"CRD read"| Spark["Spark Operator<br/>SparkApplication"]
    MustGather -->|"CRD read"| MaaS["Models as a Service<br/>MaaSModelRef, Tenant"]

    %% External Platform Dependencies (CRD Read)
    MustGather -->|"CRD read"| Authorino["Authorino<br/>AuthConfig"]
    MustGather -->|"CRD read"| Kuadrant["Kuadrant<br/>RateLimitPolicy"]
    MustGather -->|"CRD read"| NIM["NIM<br/>Account"]
    MustGather -->|"CRD read"| Istio["Sail / Istio<br/>EnvoyFilter, VirtualService"]
    MustGather -->|"CRD read"| CertManager["cert-manager<br/>Certificate, Issuer"]
    MustGather -->|"CRD read"| LWS["LeaderWorkerSet<br/>LeaderWorkerSet"]
    MustGather -->|"CRD read"| GatewayAPI["Gateway API<br/>Gateway, HTTPRoute"]
    MustGather -->|"CRD read"| GatewayInference["Gateway API Inference Ext<br/>InferencePool, InferenceObjective"]
    MustGather -->|"CRD read"| Prometheus["Prometheus Operator<br/>ServiceMonitor, PrometheusRule"]
    MustGather -->|"CRD read (optional)"| KEDA["KEDA<br/>ScaledObject (WVA)"]

    %% Cluster Infrastructure
    MustGather -->|"API calls"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

