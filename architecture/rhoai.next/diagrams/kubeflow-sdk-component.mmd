graph TB
    subgraph SDK["Kubeflow SDK (Python Client Library)"]
        direction TB

        subgraph TrainerModule["kubeflow.trainer"]
            TrainerClient["TrainerClient<br/>create/get/list/delete TrainJobs"]
            CustomTrainer["CustomTrainer<br/>User-defined training functions"]
            BuiltinTrainer["BuiltinTrainer<br/>TorchTune built-in recipes"]
        end

        subgraph RHAIModule["kubeflow.trainer.rhai"]
            TransformersTrainer["TransformersTrainer<br/>HuggingFace/TRL with JIT checkpointing<br/>& progression tracking"]
            TrainingHubTrainer["TrainingHubTrainer<br/>SFT, OSFT, LoRA SFT, LoRA GRPO"]
            AlgorithmRegistry["Algorithm Registry<br/>SFT | OSFT | LoRA SFT | LoRA GRPO"]
        end

        subgraph Backends["Runtime Backends"]
            KubernetesBackend["KubernetesBackend<br/>Production: creates TrainJob CRs"]
            ContainerBackend["ContainerBackend<br/>Local: Docker/Podman + torchrun"]
            LocalProcessBackend["LocalProcessBackend<br/>Dev: Python subprocesses"]
        end

        subgraph OptimizerModule["kubeflow.optimizer"]
            OptimizerClient["OptimizerClient<br/>Creates Katib Experiment CRs"]
        end

        subgraph SparkModule["kubeflow.spark"]
            SparkClient["SparkClient<br/>Creates SparkApplication CRs"]
        end

        subgraph HubModule["kubeflow.hub"]
            ModelRegistryClient["ModelRegistryClient<br/>Model registration & query"]
        end

        subgraph CommonModule["kubeflow.common"]
            CommonUtils["Utils & Types<br/>Namespace detection, K8s config"]
        end
    end

    %% User interaction
    User["Data Scientist / ML Engineer"] -->|"pip install kubeflow<br/>Python API calls"| TrainerClient
    User -->|"HPO experiments"| OptimizerClient
    User -->|"Spark jobs"| SparkClient
    User -->|"Model registration"| ModelRegistryClient

    %% Internal relationships
    TrainerClient --> CustomTrainer
    TrainerClient --> BuiltinTrainer
    TrainerClient --> TransformersTrainer
    TrainerClient --> TrainingHubTrainer
    TrainingHubTrainer --> AlgorithmRegistry
    TrainerClient --> KubernetesBackend
    TrainerClient --> ContainerBackend
    TrainerClient --> LocalProcessBackend
    TrainerClient --> CommonUtils
    OptimizerClient --> CommonUtils
    SparkClient --> CommonUtils
    ModelRegistryClient --> CommonUtils

    %% CRDs consumed
    KubernetesBackend -->|"creates"| TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1alpha1"]
    KubernetesBackend -->|"reads"| RuntimeCR["ClusterTrainingRuntime /<br/>TrainingRuntime CRs"]
    OptimizerClient -->|"creates"| ExperimentCR["Experiment CR<br/>Katib"]
    SparkClient -->|"creates"| SparkAppCR["SparkApplication CR"]

    %% External services
    KubernetesBackend -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    ModelRegistryClient -->|"HTTP/HTTPS"| ModelRegistry["Model Registry Server"]
    TransformersTrainer -.->|"injects metrics server<br/>28080/TCP HTTP"| MetricsServer["In-Pod Metrics Server"]
    TrainingHubTrainer -.->|"injects metrics server<br/>28080/TCP HTTP"| MetricsServer

    %% Styling
    style SDK fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style TrainerModule fill:#d4e6f1,stroke:#2980b9,stroke-width:1px
    style RHAIModule fill:#fadbd8,stroke:#e74c3c,stroke-width:1px
    style Backends fill:#d5f5e3,stroke:#27ae60,stroke-width:1px
    style OptimizerModule fill:#fdebd0,stroke:#f39c12,stroke-width:1px
    style SparkModule fill:#fdebd0,stroke:#f39c12,stroke-width:1px
    style HubModule fill:#fdebd0,stroke:#f39c12,stroke-width:1px
    style CommonModule fill:#f2f3f4,stroke:#95a5a6,stroke-width:1px
    style TrainJobCR fill:#f5a623,stroke:#333
    style RuntimeCR fill:#f5a623,stroke:#333
    style ExperimentCR fill:#f5a623,stroke:#333
    style SparkAppCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style MetricsServer fill:#fce4ec,stroke:#c0392b
    style User fill:#fff,stroke:#333,stroke-width:2px
