graph TB
    subgraph SDK["Kubeflow SDK (Python Client Library)"]
        direction TB

        subgraph Common["kubeflow.common"]
            Types["Shared Types<br/>(KubernetesBackendConfig)"]
            Utils["Namespace Resolution<br/>Utilities"]
            Constants["Constants"]
        end

        subgraph Trainer["kubeflow.trainer"]
            TrainerClient["TrainerClient<br/>(Facade)"]

            subgraph Backends["Runtime Backends"]
                K8sBackend["KubernetesBackend<br/>(Production)"]
                ContainerBackend["ContainerBackend<br/>(Docker/Podman)"]
                LocalBackend["LocalProcessBackend<br/>(Subprocess)"]
            end

            TrainerClient -->|delegates to| K8sBackend
            TrainerClient -->|delegates to| ContainerBackend
            TrainerClient -->|delegates to| LocalBackend
        end

        subgraph RHAI["kubeflow.trainer.rhai (RHOAI-only)"]
            TransformersTrainer["TransformersTrainer<br/>(HuggingFace TRL)"]
            TrainingHubTrainer["TrainingHubTrainer<br/>(SFT/OSFT/LoRA)"]
            CheckpointMgr["CheckpointManager<br/>(JIT S3 Checkpointing)"]
            ProgressionServer["Progression HTTP Server<br/>(Metrics Injection)"]
            TransformersTrainer --> CheckpointMgr
            TransformersTrainer --> ProgressionServer
            TrainingHubTrainer --> ProgressionServer
        end

        subgraph Optimizer["kubeflow.optimizer"]
            OptimizerClient["OptimizerClient"]
            OptimizerK8s["KubernetesBackend"]
            OptimizerClient -->|delegates to| OptimizerK8s
        end

        subgraph Spark["kubeflow.spark"]
            SparkClient["SparkClient"]
            SparkK8s["KubernetesBackend"]
            SparkClient -->|delegates to| SparkK8s
        end

        subgraph Hub["kubeflow.hub"]
            HubClient["ModelRegistryClient"]
        end

        TrainerClient -.->|uses| Types
        OptimizerClient -.->|uses| Types
        SparkClient -.->|uses| Types
        TransformersTrainer -->|extends| TrainerClient
        TrainingHubTrainer -->|extends| TrainerClient
    end

    %% CRDs consumed
    TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    RuntimeCR["TrainingRuntime CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    ExperimentCR["Experiment CR<br/>(kubeflow.org/v1beta1)"]
    SparkConnectCR["SparkConnect CR<br/>(sparkoperator.k8s.io/v1alpha1)"]

    K8sBackend -->|creates/watches| TrainJobCR
    K8sBackend -->|reads| RuntimeCR
    OptimizerK8s -->|creates/watches| ExperimentCR
    SparkK8s -->|creates/watches| SparkConnectCR

    %% External connections
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    ModelRegistry["Model Registry Server<br/>443 or 8080/TCP"]
    SparkDriver["Spark Driver Pod<br/>15002/TCP gRPC"]
    S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    DockerRuntime["Docker/Podman<br/>Unix Socket"]

    K8sBackend -->|HTTPS/443| K8sAPI
    OptimizerK8s -->|HTTPS/443| K8sAPI
    SparkK8s -->|HTTPS/443| K8sAPI
    HubClient -->|REST API| ModelRegistry
    SparkClient -->|gRPC/15002| SparkDriver
    CheckpointMgr -->|fsspec/s3fs| S3
    ContainerBackend -->|Unix socket| DockerRuntime

    %% Styling
    style SDK fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Common fill:#f0f0f0,stroke:#999
    style Trainer fill:#d5e8d4,stroke:#82b366
    style RHAI fill:#fff2cc,stroke:#d6b656
    style Optimizer fill:#d5e8d4,stroke:#82b366
    style Spark fill:#d5e8d4,stroke:#82b366
    style Hub fill:#d5e8d4,stroke:#82b366
    style Backends fill:#e8e8e8,stroke:#999

    style TrainerClient fill:#4a90e2,color:#fff
    style OptimizerClient fill:#4a90e2,color:#fff
    style SparkClient fill:#4a90e2,color:#fff
    style HubClient fill:#4a90e2,color:#fff
    style TransformersTrainer fill:#f5a623,color:#fff
    style TrainingHubTrainer fill:#f5a623,color:#fff

    style TrainJobCR fill:#f5a623
    style RuntimeCR fill:#f5a623
    style ExperimentCR fill:#f5a623
    style SparkConnectCR fill:#f5a623

    style K8sAPI fill:#e8e8e8,stroke:#333
    style ModelRegistry fill:#7ed321
    style SparkDriver fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style DockerRuntime fill:#e8e8e8,stroke:#333
