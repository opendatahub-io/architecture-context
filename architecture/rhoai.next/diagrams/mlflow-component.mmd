graph TB
    subgraph "MLflow Component"
        direction TB

        subgraph "Server Layer"
            FlaskApp["Flask App<br/>(REST/Protobuf API)"]
            FastAPIApp["FastAPI App<br/>(Jobs, Gateway, OTLP, Assistant)"]
            GraphQL["GraphQL Endpoint<br/>(ajax-api)"]
            FlaskApp --- FastAPIApp
            FlaskApp --- GraphQL
        end

        subgraph "Auth Layer"
            AuthPlugin["Kubernetes Auth Provider<br/>(kubernetes-namespaced)"]
            AuthMiddleware["Auth Middleware<br/>(Permissions: READ/USE/EDIT/MANAGE)"]
            SecurityMW["Security Middleware<br/>(CORS, Host validation)"]
        end

        subgraph "Storage Layer"
            TrackingStore["Tracking Store<br/>(SQLAlchemy)"]
            ModelRegistryStore["Model Registry Store<br/>(SQLAlchemy)"]
            WorkspaceStore["Workspace Store<br/>(SQLAlchemy)"]
            ArtifactRepo["Artifact Repository<br/>(S3/MinIO/Azure/GCS/Local)"]
        end

        subgraph "Features"
            AIGateway["AI Gateway<br/>(LLM Provider Proxy)"]
            JobEngine["Job Engine<br/>(Huey Task Queue)"]
            OTLPIngestion["OTLP Trace Ingestion<br/>(OpenTelemetry)"]
            CryptoManager["Crypto Manager<br/>(KEK Envelope Encryption)"]
        end

        FlaskApp --> AuthMiddleware
        FastAPIApp --> AuthMiddleware
        AuthMiddleware --> AuthPlugin
        AuthMiddleware --> SecurityMW

        FlaskApp --> TrackingStore
        FlaskApp --> ModelRegistryStore
        FastAPIApp --> WorkspaceStore
        FlaskApp --> ArtifactRepo

        FastAPIApp --> AIGateway
        FastAPIApp --> JobEngine
        FastAPIApp --> OTLPIngestion
        AIGateway --> CryptoManager
    end

    subgraph "Frontend"
        StandaloneUI["MLflow Standalone UI<br/>(React/TypeScript)"]
        FederatedUI["MLflow Federated UI<br/>(Module Federation Remote)"]
        FederatedUI -->|"exposes"| ExpWrapper["MlflowExperimentWrapper"]
        FederatedUI -->|"exposes"| PromptWrapper["MlflowPromptsWrapper"]
        FederatedUI -->|"exposes"| RunWrapper["MlflowRunTabsWrapper"]
    end

    subgraph "Platform Infrastructure"
        KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"]
        Dashboard["RHOAI Dashboard<br/>(Module Federation Host)"]
        PlatformGW["Platform Gateway<br/>(HTTPRoute)"]
    end

    User["Data Scientist / ML Engineer"] -->|"HTTPS/443"| PlatformGW
    PlatformGW -->|"HTTPS/8443"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/5000<br/>Token validated"| FlaskApp

    Dashboard -->|"loads remoteEntry.js"| FederatedUI
    StandaloneUI -->|"API calls"| FlaskApp

    TrackingStore -->|"5432/TCP"| PostgreSQL["PostgreSQL"]
    ModelRegistryStore -->|"5432/TCP"| PostgreSQL
    WorkspaceStore -->|"5432/TCP"| PostgreSQL
    ArtifactRepo -->|"443/TCP"| S3["S3 / MinIO"]
    AIGateway -->|"443/TCP"| LLMProviders["LLM Providers<br/>(OpenAI, Anthropic,<br/>Gemini, Mistral)"]
    AuthPlugin -->|"443/TCP"| K8sAPI["Kubernetes API"]
    JobEngine -->|"443/TCP"| K8sAPI

    style FlaskApp fill:#4a90e2,color:#fff
    style FastAPIApp fill:#4a90e2,color:#fff
    style GraphQL fill:#4a90e2,color:#fff
    style AuthPlugin fill:#9b59b6,color:#fff
    style AuthMiddleware fill:#9b59b6,color:#fff
    style SecurityMW fill:#9b59b6,color:#fff
