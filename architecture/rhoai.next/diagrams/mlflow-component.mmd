graph TB
    subgraph MLflow["MLflow Service (Port 5000/TCP)"]
        direction TB

        subgraph CoreServer["Core Server (Flask + FastAPI/Uvicorn)"]
            TrackingServer["MLflow Tracking Server<br/>Flask/FastAPI/Uvicorn<br/>Experiment & Run CRUD"]
            AuthModule["Auth Module<br/>Flask Plugin<br/>kubernetes-auth RBAC"]
            SecurityMW["Security Middleware<br/>Host Validation + CORS"]
        end

        subgraph WebUI["Frontend"]
            ReactUI["MLflow Web UI<br/>React/TypeScript<br/>Module Federation"]
        end

        subgraph Registry["Model Registry"]
            ModelRegistry["Model Registry<br/>Versioning, Staging, Aliasing"]
        end

        subgraph Gateway["AI Gateway"]
            AIGateway["AI Gateway Router<br/>FastAPI<br/>LLM Provider Proxy"]
            Encryption["Envelope Encryption<br/>AES-256-GCM<br/>KEK/DEK with PBKDF2"]
        end

        subgraph Observability["Observability"]
            OTLPEndpoint["Tracing Endpoint<br/>/v1/traces<br/>OTLP Ingestion"]
            Metrics["Prometheus Metrics<br/>/metrics"]
        end

        subgraph Jobs["Background Jobs"]
            JobExecutor["Job Executor<br/>Huey Task Queue<br/>Async Operations"]
        end

        subgraph Workspace["Multi-Tenancy"]
            K8sWorkspace["Kubernetes Workspace Store<br/>Namespace-based Isolation"]
        end

        subgraph Maintenance["Maintenance"]
            GarbageCollection["Garbage Collection<br/>Helm CronJob<br/>Soft-delete Cleanup"]
        end
    end

    %% External Users
    MLClient["ML Client<br/>(mlflow-skinny / mlflow-tracing)"]
    WebUser["Web User<br/>(Browser)"]

    %% User Interactions
    MLClient -->|"REST API<br/>POST /api/2.0/mlflow/*"| TrackingServer
    MLClient -->|"POST /v1/traces"| OTLPEndpoint
    WebUser -->|"HTTP/HTTPS"| ReactUI
    ReactUI -->|"/ajax-api/2.0/mlflow/*"| TrackingServer

    %% Internal flows
    TrackingServer --> AuthModule
    AuthModule --> SecurityMW
    AIGateway --> Encryption
    TrackingServer --> ModelRegistry
    K8sWorkspace -->|"Namespace resolution"| TrackingServer

    %% External Dependencies
    PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Backend Store"]
    S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>Artifact Store"]
    K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>Workspace Resolution"]
    LLMProviders["LLM Providers<br/>(OpenAI, Anthropic, Bedrock,<br/>Gemini, Mistral)<br/>443/TCP HTTPS"]

    TrackingServer -->|"SQL (SQLAlchemy)"| PostgreSQL
    TrackingServer -->|"HTTPS / AWS IAM"| S3
    AIGateway -->|"HTTPS / API Keys"| LLMProviders
    K8sWorkspace -->|"ServiceAccount Token"| K8sAPI

