graph TB
    subgraph MLflowComponent["MLflow Component"]
        direction TB

        subgraph ServerLayer["Server Layer"]
            FlaskApp["Flask App<br/>(REST API - Protobuf handlers)"]
            FastAPIApp["FastAPI App<br/>(Jobs, Gateway, OTLP, Assistant)"]
            GraphQL["GraphQL Endpoint<br/>(/ajax-api/2.0/mlflow/graphql)"]
            FlaskApp -->|mounted via WSGIMiddleware| FastAPIApp
        end

        subgraph AuthLayer["Authentication Layer"]
            KubeAuthProvider["Kubernetes Auth Provider<br/>(kubernetes-namespaced)"]
            AuthMiddleware["Auth Middleware<br/>(permissions: READ, USE, EDIT, MANAGE)"]
            SecurityMiddleware["Security Middleware<br/>(CORS + DNS rebinding protection)"]
            KubeAuthProvider -->|injects X-MLFLOW-WORKSPACE| AuthMiddleware
        end

        subgraph CoreServices["Core Services"]
            ExperimentTracking["Experiment Tracking<br/>(experiments, runs, metrics, params)"]
            ModelRegistry["Model Registry<br/>(versions, aliases, stages)"]
            ArtifactStore["Artifact Store<br/>(S3, Azure, GCS, local)"]
            WorkspaceManager["Workspace Manager<br/>(namespace → workspace isolation)"]
            AIGateway["AI Gateway<br/>(LLM provider proxy)"]
            OTLPIngestion["OTLP Trace Ingestion<br/>(OpenTelemetry)"]
            JobExecutor["Job Executor<br/>(Huey task queue)"]
        end

        subgraph Frontend["Frontend"]
            StandaloneUI["Standalone React UI<br/>(yarn build)"]
            FederatedUI["Federated UI Bundle<br/>(remoteEntry.js)"]
            FederatedUI -->|exposes| ExpWrapper["MlflowExperimentWrapper"]
            FederatedUI -->|exposes| PromptWrapper["MlflowPromptsWrapper"]
            FederatedUI -->|exposes| RunWrapper["MlflowRunTabsWrapper"]
        end
    end

    %% External actors
    User["Data Scientist / ML Engineer"]
    MLWorkload["ML Workload Pod"]
    Browser["User Browser"]

    %% External dependencies
    KubeRBACProxy["kube-rbac-proxy<br/>(8443/TCP → 5000/TCP)"]
    PostgreSQL["PostgreSQL<br/>(5432/TCP)"]
    S3["S3 / MinIO<br/>(443/TCP)"]
    K8sAPI["Kubernetes API<br/>(443/TCP)"]
    Dashboard["RHOAI Dashboard<br/>(Module Federation Host)"]
    LLMProviders["LLM Providers<br/>(OpenAI, Anthropic, Gemini, Mistral)"]

    %% Connections
    MLWorkload -->|HTTPS 8443| KubeRBACProxy
    KubeRBACProxy -->|HTTP 5000| FlaskApp
    KubeRBACProxy -->|HTTP 5000| FastAPIApp

    Browser -->|HTTPS 443| Dashboard
    Dashboard -->|loads remoteEntry.js| FederatedUI

    ExperimentTracking -->|SQL| PostgreSQL
    ModelRegistry -->|SQL| PostgreSQL
    WorkspaceManager -->|SQL| PostgreSQL
    ArtifactStore -->|HTTPS| S3
    KubeAuthProvider -->|HTTPS| K8sAPI
    JobExecutor -->|BatchV1 Jobs| K8sAPI
    AIGateway -->|HTTPS| LLMProviders

    %% Styling
    style FlaskApp fill:#4a90e2,color:#fff
    style FastAPIApp fill:#4a90e2,color:#fff
    style GraphQL fill:#4a90e2,color:#fff
    style KubeAuthProvider fill:#e74c3c,color:#fff
    style AuthMiddleware fill:#e74c3c,color:#fff
    style SecurityMiddleware fill:#e74c3c,color:#fff
    style ExperimentTracking fill:#27ae60,color:#fff
    style ModelRegistry fill:#27ae60,color:#fff
    style ArtifactStore fill:#27ae60,color:#fff
    style WorkspaceManager fill:#27ae60,color:#fff
    style AIGateway fill:#27ae60,color:#fff
    style OTLPIngestion fill:#27ae60,color:#fff
    style JobExecutor fill:#27ae60,color:#fff
    style StandaloneUI fill:#8e44ad,color:#fff
    style FederatedUI fill:#8e44ad,color:#fff
    style KubeRBACProxy fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style LLMProviders fill:#f5a623,stroke:#333
