graph TB
    subgraph MLflowServer["MLflow Server (Port 5000/TCP)"]
        direction TB

        subgraph FlaskApp["Flask App (Legacy REST APIs)"]
            TrackingAPI["Tracking API<br/>/api/2.0/mlflow/*"]
            RegistryAPI["Model Registry API<br/>/api/2.0/mlflow/registered-models/*"]
            ArtifactAPI["Artifact API<br/>/api/2.0/mlflow/artifacts/*"]
            GraphQLAPI["GraphQL API<br/>/graphql"]
        end

        subgraph FastAPIApp["FastAPI App (Modern APIs)"]
            GatewayAPI["AI Gateway<br/>/gateway/*"]
            OTLPEndpoint["OTLP Trace Ingestion<br/>/v1/traces"]
            JobsAPI["Jobs API<br/>/ajax-api/3.0/jobs/*"]
            WorkspaceAPI["Workspace API<br/>/api/3.0/mlflow/workspaces/*"]
            TracesAPI["Traces API<br/>/api/3.0/mlflow/traces/*"]
        end

        subgraph AuthMiddleware["Authentication & Authorization"]
            K8sAuthPlugin["Kubernetes Auth Plugin<br/>(before_request handler)"]
            WorkspaceProvider["Kubernetes Workspace Provider<br/>(namespace → workspace mapping)"]
            CORSMiddleware["CORS / Origin Validation<br/>(block_cross_origin_state_changes)"]
        end

        subgraph DataLayer["Data Layer"]
            SQLAlchemyStore["SQLAlchemy Store<br/>(workspace_aware_mixin)"]
            ArtifactStore["Artifact Repository<br/>(pluggable backends)"]
        end

        ReactUI["React UI<br/>(TypeScript / PatternFly)"]
        PrometheusExporter["Prometheus Exporter<br/>/metrics"]
    end

    %% Internal connections
    TrackingAPI --> K8sAuthPlugin
    RegistryAPI --> K8sAuthPlugin
    ArtifactAPI --> K8sAuthPlugin
    GraphQLAPI --> K8sAuthPlugin
    GatewayAPI --> K8sAuthPlugin
    OTLPEndpoint --> K8sAuthPlugin
    WorkspaceAPI --> K8sAuthPlugin
    TracesAPI --> K8sAuthPlugin
    K8sAuthPlugin --> WorkspaceProvider
    WorkspaceProvider --> SQLAlchemyStore
    TrackingAPI --> SQLAlchemyStore
    RegistryAPI --> SQLAlchemyStore
    ArtifactAPI --> ArtifactStore
    TracesAPI --> SQLAlchemyStore

    %% External connections
    User["Data Scientist / SDK Client"] -->|"POST /api/2.0/mlflow/*<br/>Bearer Token"| TrackingAPI
    User -->|"Browser"| ReactUI
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1alpha1)"] -->|"watched by"| WorkspaceProvider

    K8sAuthPlugin -->|"SelfSubjectAccessReview"| K8sAPI["Kubernetes API Server"]
    WorkspaceProvider -->|"namespace list/watch"| K8sAPI
    WorkspaceProvider -->|"MLflowConfig get/watch"| K8sAPI
    SQLAlchemyStore -->|"5432/TCP"| PostgreSQL["PostgreSQL"]
    ArtifactStore -->|"443/TCP HTTPS"| S3["S3-compatible Storage"]
    GatewayAPI -->|"443/TCP HTTPS<br/>KEK-decrypted API key"| LLMProviders["LLM Providers<br/>(OpenAI / Anthropic /<br/>Gemini / Mistral)"]

    %% Operator
    MLflowOperator["MLflow Operator"] -->|"deploys via Helm"| MLflowServer
    ODHGateway["ODH Gateway<br/>(HTTPRoute /mlflow)"] -->|"5000/TCP HTTP"| MLflowServer

    %% Styling
    style MLflowServer fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style FlaskApp fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style FastAPIApp fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style AuthMiddleware fill:#fef3c7,stroke:#d97706,stroke-width:1px
    style DataLayer fill:#d1fae5,stroke:#059669,stroke-width:1px
    style K8sAuthPlugin fill:#f5a623,stroke:#333
    style WorkspaceProvider fill:#f5a623,stroke:#333
    style ReactUI fill:#4a90e2,stroke:#333,color:#fff
    style PrometheusExporter fill:#4a90e2,stroke:#333,color:#fff
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style LLMProviders fill:#e8e8e8,stroke:#333
    style MLflowOperator fill:#7ed321,stroke:#333
    style ODHGateway fill:#7ed321,stroke:#333
    style User fill:#f9f9f9,stroke:#999
