graph TB
    subgraph MLflowComponent["MLflow Component"]
        direction TB
        subgraph Server["MLflow Server (Flask + FastAPI/ASGI)"]
            FlaskApp[Flask App<br/>Legacy Handlers]
            FastAPIApp[FastAPI/ASGI App<br/>Jobs, Traces, Gateway]
            FlaskApp -->|WSGI middleware| FastAPIApp
        end

        subgraph Plugins["Kubernetes Plugins"]
            AuthPlugin[Kubernetes Auth Plugin<br/>SelfSubjectAccessReview]
            WorkspaceProvider[Kubernetes Workspace Provider<br/>Namespace-to-Workspace Mapping]
        end

        subgraph UI["MLflow UI"]
            ReactUI[React/TypeScript Frontend<br/>Experiment Management]
        end

        GCJob[Garbage Collection CronJob<br/>mlflow gc]
    end

    subgraph SDKs["Client SDKs"]
        Skinny[MLflow Skinny<br/>Lightweight Client]
        Tracing[MLflow Tracing<br/>OpenTelemetry-based]
    end

    %% CRD
    MLflowConfigCR[MLflowConfig CR<br/>mlflow.kubeflow.org/v1]

    %% External access
    User[Data Scientist] -->|SDK calls| Skinny
    User -->|Browser| ReactUI
    Skinny -->|REST API| FlaskApp
    Tracing -->|OTLP/HTTP| FastAPIApp

    %% Plugin interactions
    FastAPIApp -->|authenticates via| AuthPlugin
    FlaskApp -->|authenticates via| AuthPlugin
    FastAPIApp -->|resolves workspace| WorkspaceProvider
    FlaskApp -->|resolves workspace| WorkspaceProvider
    WorkspaceProvider -->|reads| MLflowConfigCR

    %% External dependencies
    AuthPlugin -->|SelfSubjectAccessReview| K8sAPI[Kubernetes API Server]
    WorkspaceProvider -->|list namespaces| K8sAPI

    Server -->|metadata store| PostgreSQL[PostgreSQL]
    Server -->|artifact storage| S3[S3/MinIO Storage]

    %% Platform integration
    Gateway[ODH Data Science Gateway] -->|HTTPRoute /mlflow| FastAPIApp
    Operator[MLflow Operator] -->|deploys via Helm| MLflowComponent
    Prometheus[Prometheus] -->|scrapes /metrics| Server

    %% Styling
    style FlaskApp fill:#4a90e2,stroke:#333,color:#fff
    style FastAPIApp fill:#4a90e2,stroke:#333,color:#fff
    style AuthPlugin fill:#9b59b6,stroke:#333,color:#fff
    style WorkspaceProvider fill:#9b59b6,stroke:#333,color:#fff
    style ReactUI fill:#3498db,stroke:#333,color:#fff
    style GCJob fill:#95a5a6,stroke:#333,color:#fff
    style MLflowConfigCR fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Gateway fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Skinny fill:#2ecc71,stroke:#333,color:#fff
    style Tracing fill:#2ecc71,stroke:#333,color:#fff
