graph TB
    subgraph MLflowServer["MLflow Server (Port 5000/TCP)"]
        direction TB

        subgraph FlaskLayer["Flask WSGI Layer"]
            TrackingAPI["Tracking REST API<br/>/api/2.0/mlflow/*"]
            ModelRegistryAPI["Model Registry API<br/>/api/2.0/mlflow/registered-models/*"]
            ArtifactAPI["Artifact API<br/>/get-artifact, /api/2.0/mlflow/artifacts/*"]
            GraphQLAPI["GraphQL API<br/>/graphql"]
            AjaxAPI["Ajax API<br/>/ajax-api/2.0/*"]
        end

        subgraph FastAPILayer["FastAPI ASGI Layer"]
            GatewayAPI["AI Gateway<br/>/gateway/*"]
            OTLPEndpoint["OTLP Trace Ingestion<br/>/v1/traces"]
            JobAPI["Job Management<br/>/ajax-api/3.0/jobs/*"]
            WorkspaceAPI["Workspace API<br/>/api/3.0/mlflow/workspaces/*"]
            TraceAPI["Trace API<br/>/api/3.0/mlflow/traces/*"]
        end

        subgraph SecurityLayer["Security & Auth"]
            K8sAuthPlugin["Kubernetes Auth Plugin<br/>before_request handler"]
            CORSMiddleware["CORS / Origin Validation<br/>block_cross_origin_state_changes"]
        end

        subgraph DataLayer["Data Layer"]
            WorkspaceProvider["K8s Workspace Provider<br/>Namespace → Workspace mapping"]
            WorkspaceMixin["workspace_aware_mixin<br/>Query-level tenant isolation"]
            SQLAlchemyStore["SQLAlchemy Store<br/>Tracking + Model Registry"]
        end

        ReactUI["React UI<br/>PatternFly + React 18<br/>/static-files/*"]
        PrometheusExp["Prometheus Exporter<br/>/metrics (optional)"]
    end

    %% External inputs
    User["Data Scientist / SDK Client"] -->|"HTTPS/443<br/>Bearer Token"| ODHGateway["ODH Gateway<br/>HTTPRoute /mlflow"]
    ODHGateway -->|"HTTP/5000"| K8sAuthPlugin
    K8sAuthPlugin -->|validates| TrackingAPI
    K8sAuthPlugin -->|validates| ModelRegistryAPI
    K8sAuthPlugin -->|validates| GatewayAPI
    K8sAuthPlugin -->|validates| OTLPEndpoint

    Browser["Browser"] -->|"HTTPS/443"| ODHGateway
    ODHGateway -->|"HTTP/5000"| ReactUI

    %% CRD
    MLflowConfigCR["MLflowConfig CR<br/>mlflow.kubeflow.org/v1alpha1"] -->|"watched by"| WorkspaceProvider

    %% External dependencies
    K8sAuthPlugin -->|"SelfSubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    WorkspaceProvider -->|"Namespace list/watch<br/>HTTPS/443"| K8sAPI
    SQLAlchemyStore -->|"TCP/5432"| PostgreSQL["PostgreSQL"]
    SQLAlchemyStore -->|"HTTPS/443"| S3["S3-compatible Storage"]

    %% AI Gateway egress
    GatewayAPI -->|"HTTPS/443<br/>API key (KEK-encrypted)"| OpenAI["OpenAI API"]
    GatewayAPI -->|"HTTPS/443"| Anthropic["Anthropic API"]
    GatewayAPI -->|"HTTPS/443"| Gemini["Google Gemini API"]
    GatewayAPI -->|"HTTPS/443"| Mistral["Mistral API"]

    %% Operator
    MLflowOperator["MLflow Operator"] -->|"deploys via Helm"| MLflowServer

    %% Styling
    style MLflowServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style FlaskLayer fill:#bbdefb,stroke:#1976d2
    style FastAPILayer fill:#c8e6c9,stroke:#388e3c
    style SecurityLayer fill:#fff3e0,stroke:#e65100
    style DataLayer fill:#f3e5f5,stroke:#7b1fa2
    style K8sAuthPlugin fill:#ffcc80,stroke:#e65100
    style WorkspaceProvider fill:#ce93d8,stroke:#7b1fa2
    style ODHGateway fill:#fff9c4,stroke:#f57f17
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OpenAI fill:#fce4ec,stroke:#c62828
    style Anthropic fill:#fce4ec,stroke:#c62828
    style Gemini fill:#fce4ec,stroke:#c62828
    style Mistral fill:#fce4ec,stroke:#c62828
    style MLflowOperator fill:#7ed321,stroke:#333
    style ReactUI fill:#4a90e2,stroke:#333,color:#fff
