graph TB
    subgraph MLflowComponent["MLflow Server Component"]
        direction TB
        subgraph FastAPILayer["FastAPI Layer (ASGI)"]
            GatewayRouter["Gateway Router<br/>/gateway/*"]
            OTelRouter["OTLP Router<br/>/v1/traces"]
            JobRouter["Job Router<br/>/ajax-api/3.0/jobs/*"]
            GraphQLRouter["GraphQL Router<br/>/graphql"]
        end

        subgraph FlaskLayer["Flask Layer (WSGI via WSGIMiddleware)"]
            TrackingAPI["Tracking API<br/>/api/2.0/mlflow/*"]
            ModelRegistryAPI["Model Registry API<br/>/api/2.0/mlflow/registered-models/*"]
            AjaxAPI["AJAX API<br/>/ajax-api/2.0/mlflow/*"]
            WorkspaceAPI["Workspace API<br/>/api/3.0/mlflow/workspaces/*"]
        end

        subgraph Plugins["Kubernetes Plugins (mlflow-kubernetes-plugins)"]
            K8sAuth["Kubernetes Auth Plugin<br/>SelfSubjectAccessReview"]
            K8sWorkspace["Kubernetes Workspace Provider<br/>Namespace-to-Workspace mapping"]
        end

        subgraph Security["Security Layer"]
            CryptoEngine["Secrets Encryption Engine<br/>AES-256-GCM / PBKDF2"]
            FastAPISec["FastAPI Security<br/>Bearer Token extraction"]
        end

        PrometheusExp["Prometheus Exporter<br/>/metrics"]

        FastAPILayer -->|mounts via WSGIMiddleware| FlaskLayer
        FlaskLayer -->|authenticates via| K8sAuth
        FastAPILayer -->|authenticates via| FastAPISec
        FastAPISec -->|delegates to| K8sAuth
        K8sAuth -->|resolves workspace| K8sWorkspace
        GatewayRouter -->|encrypts/decrypts keys| CryptoEngine
    end

    subgraph UI["MLflow UI"]
        ReactUI["React/TypeScript Frontend<br/>Module Federation"]
    end

    User["Data Scientist / SDK Client"] -->|HTTPS/443| ODHGateway["ODH Data Science Gateway<br/>HTTPRoute /mlflow"]
    Browser["Browser (ODH Dashboard)"] -->|HTTPS/443| ODHGateway
    ODHGateway -->|HTTP/5000| FastAPILayer

    ReactUI -->|/ajax-api/*<br/>X-MLFLOW-WORKSPACE header| AjaxAPI

    K8sAuth -->|SelfSubjectAccessReview<br/>HTTPS/6443| K8sAPI["Kubernetes API Server"]
    K8sWorkspace -->|Namespace list/watch<br/>HTTPS/6443| K8sAPI

    TrackingAPI -->|SQL/5432| PostgreSQL["PostgreSQL<br/>Metadata Store"]
    ModelRegistryAPI -->|SQL/5432| PostgreSQL
    TrackingAPI -->|HTTPS/443| S3["S3-compatible Storage<br/>Artifact Store"]

    GatewayRouter -->|HTTPS/443| LLMProviders["LLM Provider APIs<br/>(OpenAI, Anthropic, Gemini)"]

    PrometheusExp -.->|scrape /metrics| Prometheus["Prometheus"]

    style MLflowComponent fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style FastAPILayer fill:#d5e8d4,stroke:#82b366
    style FlaskLayer fill:#dae8fc,stroke:#6c8ebf
    style Plugins fill:#fff2cc,stroke:#d6b656
    style Security fill:#f8cecc,stroke:#b85450
    style UI fill:#e1d5e7,stroke:#9673a6

    style ODHGateway fill:#ffe6cc,stroke:#d79b00
    style K8sAPI fill:#f5f5f5,stroke:#666
    style PostgreSQL fill:#f5f5f5,stroke:#666
    style S3 fill:#f5f5f5,stroke:#666
    style LLMProviders fill:#f5f5f5,stroke:#666
    style Prometheus fill:#f5f5f5,stroke:#666
    style User fill:#fff,stroke:#333
    style Browser fill:#fff,stroke:#333
