graph TB
    subgraph MLflowServer["MLflow Server (Port 5000/TCP)"]
        direction TB

        subgraph FlaskApp["Flask WSGI Layer"]
            TrackingAPI["Tracking API<br/>/api/2.0/mlflow/*"]
            ModelRegistryAPI["Model Registry API<br/>/api/2.0/mlflow/registered-models/*"]
            ArtifactAPI["Artifact API<br/>/api/2.0/mlflow/artifacts/*"]
            GraphQLEndpoint["GraphQL Endpoint<br/>/graphql"]
        end

        subgraph FastAPIApp["FastAPI ASGI Layer"]
            GatewayAPI["AI Gateway API<br/>/gateway/*"]
            OTLPEndpoint["OTLP Trace Ingestion<br/>/v1/traces"]
            JobAPI["Job Management API<br/>/ajax-api/3.0/jobs/*"]
            WorkspaceAPI["Workspace API<br/>/api/3.0/mlflow/workspaces/*"]
            TraceAPI["Trace API<br/>/api/3.0/mlflow/traces/*"]
        end

        subgraph AuthLayer["Authentication & Authorization"]
            K8sAuthPlugin["Kubernetes Auth Plugin<br/>before_request handler"]
            WorkspaceProvider["Workspace Provider<br/>Namespace-to-Workspace mapping"]
        end

        subgraph DataLayer["Data Layer"]
            SQLAlchemyStore["SQLAlchemy Store<br/>Workspace-aware mixin"]
            ArtifactStore["Artifact Repository<br/>Pluggable backends"]
        end

        ReactUI["React UI<br/>PatternFly + React 18"]
        PrometheusExporter["Prometheus Exporter<br/>/metrics"]
    end

    %% External actors
    User["Data Scientist / ML Engineer"]
    SDKClient["MLflow SDK Client<br/>(Python/TS)"]
    OTelCollector["OpenTelemetry<br/>Instrumented App"]

    %% CRDs
    MLflowConfigCR["MLflowConfig CR<br/>mlflow.kubeflow.org/v1alpha1"]

    %% External dependencies
    K8sAPI["Kubernetes API Server"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    S3Storage["S3-compatible Storage<br/>443/TCP HTTPS"]
    ODHGateway["ODH Gateway<br/>HTTPRoute /mlflow"]

    %% LLM Providers
    subgraph LLMProviders["LLM Providers (AI Gateway)"]
        OpenAI["OpenAI API"]
        Anthropic["Anthropic API"]
        Gemini["Gemini API"]
        Mistral["Mistral API"]
    end

    %% User flows
    User -->|"HTTPS/443"| ODHGateway
    SDKClient -->|"HTTPS/443"| ODHGateway
    OTelCollector -->|"HTTPS/443"| ODHGateway
    ODHGateway -->|"HTTP/5000"| MLflowServer

    %% Internal flows
    K8sAuthPlugin -->|"SelfSubjectAccessReview"| K8sAPI
    WorkspaceProvider -->|"list/watch namespaces"| K8sAPI
    WorkspaceProvider -->|"watch"| MLflowConfigCR
    MLflowConfigCR -.->|"read by"| WorkspaceProvider

    %% Data flows
    SQLAlchemyStore -->|"5432/TCP"| PostgreSQL
    ArtifactStore -->|"443/TCP HTTPS"| S3Storage

    %% AI Gateway flows
    GatewayAPI -->|"443/TCP HTTPS"| OpenAI
    GatewayAPI -->|"443/TCP HTTPS"| Anthropic
    GatewayAPI -->|"443/TCP HTTPS"| Gemini
    GatewayAPI -->|"443/TCP HTTPS"| Mistral

    %% Auth chain
    TrackingAPI --> K8sAuthPlugin
    ModelRegistryAPI --> K8sAuthPlugin
    GatewayAPI --> K8sAuthPlugin
    OTLPEndpoint --> K8sAuthPlugin
    K8sAuthPlugin --> WorkspaceProvider

    %% Styling
    style MLflowServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style FlaskApp fill:#5b9bd5,stroke:#333,color:#fff
    style FastAPIApp fill:#5b9bd5,stroke:#333,color:#fff
    style AuthLayer fill:#e8744f,stroke:#333,color:#fff
    style DataLayer fill:#6bb56b,stroke:#333,color:#fff
    style K8sAuthPlugin fill:#d9534f,stroke:#333,color:#fff
    style WorkspaceProvider fill:#d9534f,stroke:#333,color:#fff
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style S3Storage fill:#e8a838,stroke:#333
    style ODHGateway fill:#7ed321,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style LLMProviders fill:#f9f9f9,stroke:#999
    style ReactUI fill:#61dafb,stroke:#333
    style PrometheusExporter fill:#e6522c,stroke:#333,color:#fff
