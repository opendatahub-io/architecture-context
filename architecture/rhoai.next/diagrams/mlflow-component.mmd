    style ModelRegistryStore fill:#2ecc71,color:#fff
    style WorkspaceStore fill:#2ecc71,color:#fff
    style ArtifactRepo fill:#2ecc71,color:#fff
    style AIGateway fill:#e67e22,color:#fff
    style JobEngine fill:#e67e22,color:#fff
    style OTLPIngestion fill:#e67e22,color:#fff
    style CryptoManager fill:#e67e22,color:#fff
    style KubeRBACProxy fill:#e74c3c,color:#fff
    style Dashboard fill:#7ed321,color:#fff
    style PlatformGW fill:#e74c3c,color:#fff
    style PostgreSQL fill:#999,color:#fff
    style S3 fill:#999,color:#fff
    style LLMProviders fill:#999,color:#fff
