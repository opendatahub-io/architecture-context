graph LR
    MMC["model-metadata-collection<br/>(Build-Time Data Pipeline)"]

    %% External Dependencies (Required for build)
    MMC -->|"fetch collections,<br/>model details, READMEs<br/>HTTPS/443"| HuggingFace["HuggingFace API<br/>v1"]
    MMC -->|"fetch manifests,<br/>layer blobs, modelcards<br/>HTTPS/443"| OCIRegistry["OCI Container Registries<br/>v2 (registry.redhat.io)"]

    %% Build Dependencies
    MMC -->|"build language"| Go["Go 1.24+"]
    MMC -->|"OCI/Docker image<br/>inspection"| ContainersImage["containers/image/v5<br/>v5.36.1"]
    MMC -->|"YAML parsing &<br/>generation"| YAMLv3["gopkg.in/yaml.v3<br/>v3.0.1"]
    MMC -->|"text case<br/>conversion"| XText["golang.org/x/text<br/>v0.28.0"]

    %% Internal Platform Dependencies
    Dashboard["RHOAI Dashboard"] -->|"volume mount<br/>/app/data/*.yaml<br/>File I/O"| MMC
    Konflux["Konflux CI/CD<br/>(Tekton Pipelines)"] -->|"builds & publishes<br/>data container"| MMC
    MMC -->|"source of<br/>modelcar images"| RHCR["Red Hat Container Registry<br/>registry.redhat.io"]

    %% CI/CD
    GitHubCI["GitHub Actions CI"] -->|"lint + test<br/>build + push"| MMC

    %% Build Outputs
    MMC -->|"publishes image"| Quay["quay.io/opendatahub/<br/>odh-model-metadata-collection"]

