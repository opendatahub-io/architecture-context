graph LR
    MMC["Model Metadata<br/>Collection<br/>(Build-Time Pipeline)"]

    %% External Dependencies (build-time network)
    MMC -->|"REST API<br/>HTTPS/443<br/>model collections,<br/>details, READMEs"| HuggingFace["HuggingFace API<br/>huggingface.co"]
    MMC -->|"OCI Distribution v2<br/>HTTPS/443<br/>manifests, blobs,<br/>model card layers"| OCIRegistry["OCI Registry<br/>registry.redhat.io"]
    MMC -->|"OCI Distribution v2<br/>HTTPS/443<br/>MCP server images"| OCIOther["Other OCI<br/>Registries"]

    %% Go Library Dependencies
    MMC -->|"Go library"| ContainersImage["containers/image/v5<br/>v5.36.1"]
    MMC -->|"Go library"| YAMLv3["gopkg.in/yaml.v3<br/>v3.0.1"]
    MMC -->|"Go library"| GolangText["golang.org/x/text<br/>v0.28.0"]

    %% Internal RHOAI Dependencies
    Dashboard["RHOAI Dashboard"] -->|"volume mount<br/>/app/data/<br/>read-only"| MMC

    %% CI/CD Dependencies
    Konflux["Konflux / Tekton"] -->|"builds image<br/>PipelineRun"| MMC
    ODHKonflux["ODH Konflux Central"] -->|"shared multi-arch<br/>build pipeline"| Konflux
    GitHubActions["GitHub Actions"] -->|"upstream builds<br/>& tests"| MMC

    %% Input File Dependencies
    ModelsIndex["models-index.yaml"] -.->|"model definitions"| MMC
    SupplementalCat["supplemental-<br/>catalog.yaml"] -.->|"static entries"| MMC
    VLLMConfig["vllm-config/<br/>*.yaml"] -.->|"serving configs"| MMC
    MCPIndex["mcp-servers-<br/>index.yaml"] -.->|"MCP server defs"| MMC
    MCPServerFiles["mcp_servers/<br/>**/*.yaml"] -.->|"server metadata"| MMC

    %% Output
    MMC -->|"pushes to"| Quay["quay.io<br/>Container Registry"]

