graph LR
    MMC["Model Metadata<br/>Collection"]

    %% External Dependencies (Build-Time)
    MMC -->|"model metadata<br/>HTTPS/443"| HF["HuggingFace API<br/>v1"]
    MMC -->|"OCI manifests<br/>HTTPS/443"| RHIO["registry.redhat.io<br/>Registry API v2"]
    MMC -->|"MCP server metadata<br/>HTTPS/443"| RHACCESS["registry.access.redhat.com<br/>Registry API v2"]

    %% Go Library Dependencies
    MMC -->|"YAML parsing"| YAML["gopkg.in/yaml.v3<br/>v3.0.1"]
    MMC -->|"OCI image ops"| ContainersImage["containers/image/v5<br/>v5.36.1"]
    MMC -->|"text casing"| GoText["golang.org/x/text<br/>v0.28.0"]

    %% Internal Platform Dependencies (Runtime)
    Dashboard["RHOAI Dashboard"] -->|"volume mount<br/>/app/data"| MMC
