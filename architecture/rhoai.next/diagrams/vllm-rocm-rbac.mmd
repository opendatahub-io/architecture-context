graph TD
    subgraph "vllm-rocm RBAC Model"
        direction TB

        subgraph "Container Security Context"
            UID["UID: 2000<br/>(non-root)"]
            NoPriv["No privileged escalation"]
        end

        subgraph "RBAC Delegation"
            Note1["This component defines NO<br/>ClusterRoles or RoleBindings"]
            Note2["All RBAC is managed by KServe"]
        end

        subgraph "KServe-Managed RBAC"
            SA["ServiceAccount<br/>(KServe-managed)"]
            SRT["ServingRuntime<br/>InferenceService"]
        end

        subgraph "Resource Access"
            GPU_Access["AMD ROCm GPU<br/>amd.com/gpu device plugin"]
            PVC_Access["PVC Volume<br/>Model weight storage"]
            Secret_Access["Secrets<br/>Model storage credentials<br/>(Opaque)"]
        end
    end

    SA -->|"bound by KServe"| SRT
    SRT -->|"grants access"| GPU_Access
    SRT -->|"mounts"| PVC_Access
    SRT -->|"references"| Secret_Access

    UID -.->|"runs as"| SA

    style UID fill:#4a90e2,stroke:#333,color:#fff
    style NoPriv fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style Note2 fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#7ed321,stroke:#333,color:#fff
    style SRT fill:#7ed321,stroke:#333,color:#fff
    style GPU_Access fill:#f5a623,stroke:#333,color:#fff
    style PVC_Access fill:#f5a623,stroke:#333,color:#fff
    style Secret_Access fill:#e74c3c,stroke:#333,color:#fff
