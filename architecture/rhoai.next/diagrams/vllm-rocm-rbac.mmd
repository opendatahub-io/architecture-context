graph TD
    subgraph "vllm-rocm RBAC Overview"
        direction TB

        Note["This component is a container image,<br/>not an operator or controller.<br/>No RBAC resources are defined<br/>in this repository."]

        subgraph "RBAC Managed Externally"
            direction TB

            KServe["KServe Controller<br/>(manages pod RBAC)"]
            SA["Pod ServiceAccount<br/>(created by KServe<br/>InferenceService)"]
            Platform["rhods-operator<br/>(platform RBAC)"]
        end

        subgraph "Runtime Security Context"
            direction TB

            NonRoot["Non-Root User<br/>UID: 2000"]
            BaseImage["Base Image: UBI9<br/>rhaiis/vllm-rocm-rhel9"]
            FIPS["FIPS: Delegated to<br/>system OpenSSL (UBI9)"]
        end

        KServe -->|"creates SA for"| SA
        Platform -->|"configures ServingRuntime<br/>with image ref"| KServe

        subgraph "Auth Enforcement (External)"
            direction TB

            AuthProxy["Auth Proxy Sidecar<br/>(kube-rbac-proxy<br/>or oauth-proxy)"]
            Gateway["KServe Gateway<br/>(TLS termination)"]
        end

        Gateway -->|"routes to"| AuthProxy
        AuthProxy -->|"proxies to pod<br/>after auth check"| SA
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Platform fill:#7ed321,stroke:#333
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style FIPS fill:#d5e8d4,stroke:#82b366
    style AuthProxy fill:#ffe6cc,stroke:#d79b00
    style Gateway fill:#ffe6cc,stroke:#d79b00
