graph TD
    subgraph "vLLM ROCm — No Direct RBAC"
        direction TB
        Note["This component is a container image,<br/>not an operator.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined."]
    end

    subgraph "Authentication Enforcement (Platform-Managed)"
        direction TB

        subgraph "RHOAI 3.x Pattern"
            KubeRBAC["kube-rbac-proxy Sidecar"]
            BearerToken["Bearer Token<br/>(from client)"]
            SAR["SubjectAccessReview<br/>(Kubernetes API)"]

            BearerToken -->|"validates via"| KubeRBAC
            KubeRBAC -->|"checks authz"| SAR
            SAR -->|"allow/deny"| KubeRBAC
        end

        subgraph "RHOAI 2.x Pattern"
            OAuthProxy["oauth-proxy Sidecar"]
            OAuthToken["OAuth Token<br/>(from client)"]

            OAuthToken -->|"validates via"| OAuthProxy
        end
    end

    subgraph "Proxied Access to vLLM"
        direction TB
        HTTPAPI["vLLM HTTP API<br/>8000/TCP<br/>No auth (localhost)"]
        GRPCAPI["TGIS gRPC API<br/>8033/TCP<br/>No auth (pod-level)"]
    end

    KubeRBAC -->|"HTTP/8000<br/>trusted localhost"| HTTPAPI
    OAuthProxy -->|"HTTP/8000<br/>trusted localhost"| HTTPAPI

    subgraph "Model Credential Injection"
        direction TB
        ISSpec["InferenceService Spec"]
        HFToken["HF_TOKEN<br/>(env var)"]
        AWSCreds["AWS IAM Credentials<br/>(env var / IRSA)"]

        ISSpec -->|"injects"| HFToken
        ISSpec -->|"injects"| AWSCreds
    end

    style Note fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style KubeRBAC fill:#f5a623,stroke:#333
    style OAuthProxy fill:#f5a623,stroke:#333
    style HTTPAPI fill:#7ed321,stroke:#333
    style GRPCAPI fill:#7ed321,stroke:#333
    style SAR fill:#4a90e2,stroke:#333,color:#fff
    style ISSpec fill:#4a90e2,stroke:#333,color:#fff
    style HFToken fill:#e8e8e8,stroke:#333
    style AWSCreds fill:#e8e8e8,stroke:#333
    style BearerToken fill:#e8e8e8,stroke:#333
    style OAuthToken fill:#e8e8e8,stroke:#333
