graph TD
    subgraph "vllm-rocm Container Security Model"
        direction TB

        subgraph "Container Identity"
            User["Container User<br/>UID: 2000 (non-root)"]
            Image["Image: odh-vllm-rocm-rhel9<br/>Base: rhaiis/vllm-rocm-rhel9:3.2.1"]
        end

        subgraph "Auth Enforcement (Not in this component)"
            KubeRBAC["kube-rbac-proxy Sidecar<br/>(injected by KServe/platform)"]
            SAR["SubjectAccessReview<br/>Kubernetes RBAC check"]
        end

        subgraph "Platform RBAC (Managed by KServe)"
            KServeSA["KServe ServiceAccount<br/>(manages pod lifecycle)"]
            KServeCR["KServe ClusterRole<br/>(ServingRuntime, InferenceService)"]
            KServeCRB["KServe ClusterRoleBinding"]
        end

        subgraph "No Direct RBAC Definitions"
            NoClusterRole["No ClusterRoles<br/>(container image only)"]
            NoRoleBindings["No RoleBindings<br/>(container image only)"]
            NoCRDs["No CRDs<br/>(deployed by KServe)"]
        end

        subgraph "Secrets Access"
            HFToken["HF_TOKEN<br/>Type: Opaque<br/>Purpose: Hugging Face auth<br/>Provisioned by: User/Admin<br/>Auto-rotate: No"]
            S3Creds["S3 Credentials<br/>Type: Opaque<br/>Purpose: Model storage auth<br/>Provisioned by: User/Admin<br/>Auto-rotate: No"]
        end
    end

    %% Relationships
    KubeRBAC -->|"validates via"| SAR
    SAR -->|"checks"| KServeCR
    KServeSA -->|"bound via"| KServeCRB
    KServeCRB -->|"grants"| KServeCR
    KServeSA -->|"deploys"| Image
    Image -->|"runs as"| User
    User -.->|"reads (optional)"| HFToken
    User -.->|"reads (optional)"| S3Creds

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style Image fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBAC fill:#ffcccc,stroke:#cc0000
    style SAR fill:#ffcccc,stroke:#cc0000
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeCR fill:#f5a623,stroke:#333,color:#fff
    style KServeCRB fill:#f5a623,stroke:#333,color:#fff
    style NoClusterRole fill:#e8e8e8,stroke:#999
    style NoRoleBindings fill:#e8e8e8,stroke:#999
    style NoCRDs fill:#e8e8e8,stroke:#999
    style HFToken fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#fff2cc,stroke:#d6b656
