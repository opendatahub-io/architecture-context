graph TD
    subgraph "vllm-rocm Security Model"
        direction TB

        subgraph "Container Identity"
            Container["vllm-rocm Container<br/>UID: 2000 (non-root)"]
            SA["ServiceAccount<br/>(KServe-managed)"]
        end

        subgraph "RBAC (Platform-Managed)"
            Note1["No ClusterRoles defined<br/>No Roles defined<br/>No RoleBindings defined"]
            Note2["All RBAC is managed by KServe<br/>at the platform level"]
        end

        subgraph "Authentication & Authorization"
            AuthNote["AuthN/AuthZ delegated to<br/>KServe platform layer"]
            KRBAC["kube-rbac-proxy sidecar<br/>or Route/HTTPRoute auth"]
        end

        subgraph "Secrets Access"
            ModelCreds["(model storage credentials)<br/>Type: Opaque<br/>Purpose: S3/storage credentials<br/>Provisioned by: Platform admin / KServe<br/>Auto-Rotate: No"]
        end

        subgraph "Network Exposure"
            HTTP["Port 8000/TCP<br/>Plaintext HTTP<br/>No Auth (pod-level)"]
            GRPC["Port 8033/TCP<br/>Plaintext gRPC<br/>No Auth (pod-level)"]
        end
    end

    Container -->|"runs as"| SA
    SA -.->|"no direct RBAC"| Note1
    AuthNote -->|"enforced by"| KRBAC
    KRBAC -->|"protects"| HTTP
    KRBAC -->|"protects"| GRPC
    SA -->|"mounts"| ModelCreds

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#f9f9f9,stroke:#999
    style Note2 fill:#f9f9f9,stroke:#999
    style AuthNote fill:#ffe6cc,stroke:#d79b00
    style KRBAC fill:#ffe6cc,stroke:#d79b00
    style ModelCreds fill:#f8cecc,stroke:#b85450
    style HTTP fill:#d5e8d4,stroke:#82b366
    style GRPC fill:#d5e8d4,stroke:#82b366
