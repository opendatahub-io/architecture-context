graph TD
    subgraph "vllm-rocm RBAC Model"
        direction TB
        Note["No RBAC resources defined<br/>in this repository"]
    end

    subgraph "Platform-Managed RBAC"
        direction TB
        KServeSA["KServe-managed<br/>Service Account"]
        PlatformOperator["Platform Operator<br/>RBAC Configuration"]
    end

    subgraph "Container Security Context"
        direction TB
        UID["UID 2000 (non-root)"]
        NoTLS["No TLS at container level"]
        NoAuth["No AuthN/AuthZ at container level"]
    end

    subgraph "Auth Enforcement Points"
        direction TB
        IngressAuth["Platform Ingress<br/>(kube-rbac-proxy /<br/>Gateway API)"]
        ModelCreds["Model Credentials<br/>(Opaque Secret)<br/>S3 IAM / SA Token"]
    end

    PlatformOperator -->|"manages"| KServeSA
    KServeSA -->|"assigned to<br/>inference pod"| UID
    IngressAuth -->|"enforces auth<br/>before traffic reaches"| NoAuth
    ModelCreds -->|"mounted into pod<br/>for model download"| UID

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KServeSA fill:#4a90e2,color:#fff
    style PlatformOperator fill:#7ed321,color:#fff
    style UID fill:#dae8fc,stroke:#6c8ebf
    style NoTLS fill:#f8d7da,stroke:#721c24
    style NoAuth fill:#f8d7da,stroke:#721c24
    style IngressAuth fill:#d4edda,stroke:#155724
    style ModelCreds fill:#fff3cd,stroke:#856404
