graph TD
    subgraph "vllm-rocm RBAC (Delegated)"
        direction TB
        Note["This component defines no RBAC.<br/>All RBAC is managed by KServe at the platform level."]
    end

    subgraph "KServe-Managed RBAC"
        SA["ServiceAccount<br/>{kserve-assigned-sa}<br/>Namespace: {user-namespace}"]
    end

    subgraph "Pod Security Context"
        PodSecurity["vllm-rocm Pod<br/>UID: 2000 (non-root)<br/>No privileged access"]
    end

    subgraph "Platform Auth (KServe-managed)"
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>(optional)"]
        RouteAuth["Route/HTTPRoute Auth<br/>(platform-level)"]
    end

    subgraph "Secrets Access"
        ModelCreds["(model storage credentials)<br/>Type: Opaque<br/>Purpose: S3/storage credentials<br/>Provisioned by: Platform admin / KServe<br/>Auto-Rotate: No"]
    end

    SA -->|"runs as"| PodSecurity
    SA -->|"accesses"| ModelCreds
    KubeRBACProxy -->|"protects"| PodSecurity
    RouteAuth -->|"authenticates<br/>external requests"| KubeRBACProxy

