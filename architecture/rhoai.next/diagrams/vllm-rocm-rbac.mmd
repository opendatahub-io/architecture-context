graph TD
    subgraph "vllm-rocm RBAC Model"
        direction TB

        Note["Note: vllm-rocm defines NO RBAC resources.<br/>All RBAC is managed by KServe and the<br/>platform operator."]

        subgraph "Platform-Managed RBAC"
            direction TB

            SA["Service Account<br/>(KServe-managed)<br/>Namespace: user-namespace"]

            subgraph "KServe-Managed Permissions"
                KServeSA["KServe Controller SA<br/>kserve-controller-manager"]
                KServeRole["KServe ClusterRole<br/>Manages ServingRuntime,<br/>InferenceService CRs"]
            end

            subgraph "Pod Security"
                PodSec["Pod Security Context<br/>UID: 2000 (non-root)<br/>No privileged escalation"]
                GPUAccess["GPU Device Access<br/>AMD ROCm device plugin<br/>Resource: amd.com/gpu"]
            end
        end

        subgraph "Auth Enforcement (Platform Ingress)"
            IngressAuth["kube-rbac-proxy / Gateway API<br/>Enforces AuthN/AuthZ<br/>before traffic reaches container"]
        end

        subgraph "Container-Level Auth"
            NoAuth["No authentication<br/>No authorization<br/>No TLS<br/>(Delegated to platform)"]
        end
    end

    SA -->|"runs as"| PodSec
    SA -->|"accesses"| GPUAccess
    KServeSA -->|"creates/manages pods using"| SA
    KServeSA -->|"granted by"| KServeRole
    IngressAuth -->|"protects"| NoAuth

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333,color:#fff
    style PodSec fill:#d5e8d4,stroke:#82b366
    style GPUAccess fill:#d5e8d4,stroke:#82b366
    style IngressAuth fill:#ffe6cc,stroke:#d79b00
    style NoAuth fill:#f8d7da,stroke:#721c24
