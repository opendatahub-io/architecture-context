graph TD
    subgraph Note["RBAC Model for kserve-autogluon-server"]
        direction TB
        Info["ℹ️ This component is a model server process,<br/>NOT an operator.<br/>It does not interact with the Kubernetes API directly."]
    end

    subgraph PodSecurity["Pod Security (Configured by KServe Controller)"]
        SA["ServiceAccount<br/>(configured by InferenceService CR)"]
        Pod["AutoGluon Server Pod<br/>Namespace: {user-namespace}<br/>Non-root user"]
    end

    subgraph AuthDelegation["Authentication & Authorization Delegation"]
        direction TB
        IngressAuth["KServe Ingress Layer<br/>Handles ALL auth before<br/>traffic reaches server"]
        RBACPROXY["kube-rbac-proxy<br/>(Kubernetes RBAC)"]
        IstioAuth["Istio AuthorizationPolicy<br/>(Service mesh auth)"]
        RouteAuth["OpenShift Route<br/>(OAuth proxy)"]
    end

    subgraph SecretsAccess["Secrets Access"]
        StorageConfig["storage-config<br/>Type: Opaque<br/>Purpose: S3/GCS/Azure credentials<br/>Provisioned by: User / platform admin<br/>Auto-rotate: No"]
    end

    subgraph NoDirectK8sAPI["No Direct Kubernetes API Access"]
        NoCRDs["No CRDs defined or watched"]
        NoClusterRole["No ClusterRoles created"]
        NoRoleBindings["No RoleBindings created"]
    end

    %% Relationships
    SA -->|"runs as"| Pod
    IngressAuth -->|"one of"| RBACPROXY
    IngressAuth -->|"one of"| IstioAuth
    IngressAuth -->|"one of"| RouteAuth
    IngressAuth -->|"auth validated<br/>before reaching"| Pod
    Pod -->|"reads at startup"| StorageConfig

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Pod fill:#d5e8d4,stroke:#82b366
    style IngressAuth fill:#ffe6cc,stroke:#d79b00
    style RBACPROXY fill:#ffe6cc,stroke:#d79b00
    style IstioAuth fill:#ffe6cc,stroke:#d79b00
    style RouteAuth fill:#ffe6cc,stroke:#d79b00
    style StorageConfig fill:#f8cecc,stroke:#b85450
    style NoCRDs fill:#f5f5f5,stroke:#999
    style NoClusterRole fill:#f5f5f5,stroke:#999
    style NoRoleBindings fill:#f5f5f5,stroke:#999
