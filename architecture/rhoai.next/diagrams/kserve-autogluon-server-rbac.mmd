graph TD
    subgraph "Runtime Pod Identity"
        SA["ServiceAccount<br/>(configured by KServe operator)"]
    end

    subgraph "Auth Enforcement (Platform-Injected)"
        RBAC["kube-rbac-proxy sidecar<br/>Injected by RHOAI platform operator<br/>Listens: 8443/TCP HTTPS"]
    end

    subgraph "No Direct RBAC Defined"
        direction TB
        Note["This component defines NO ClusterRoles,<br/>Roles, or RoleBindings.<br/>All RBAC is managed externally by<br/>the KServe operator and platform."]
    end

    subgraph "Platform-Managed Auth Flow"
        direction TB
        Client["Client Request<br/>Bearer Token"]
        Ingress["Platform Ingress<br/>443/TCP HTTPS TLS 1.2+"]
        Proxy["kube-rbac-proxy<br/>Token Validation"]
        Server["autogluonserver<br/>8080/TCP HTTP<br/>(no auth, trusted)"]

        Client -->|"HTTPS/443"| Ingress
        Ingress -->|"HTTPS/8443"| Proxy
        Proxy -->|"validates token<br/>enforces RBAC"| Proxy
        Proxy -->|"HTTP/8080<br/>localhost"| Server
    end

    subgraph "Secrets Access"
        StorageCreds["Storage Credentials Secret<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>or GCP SA / Azure / HF Token"]
    end

    SA -->|"pod runs as"| RBAC
    SA -->|"mounts"| StorageCreds

    subgraph "Webhook RBAC (KServe Operator)"
        direction TB
        WH_CSR["ClusterServingRuntime<br/>Validating Webhook"]
        WH_ISVC_V["InferenceService<br/>Validating Webhook"]
        WH_ISVC_M["InferenceService<br/>Mutating Webhook"]
        WH_POD["Pod Mutator<br/>(storage init, sidecars)"]
    end

    WH_POD -->|"injects kube-rbac-proxy<br/>into serving pod"| RBAC
    WH_POD -->|"injects storage-initializer<br/>init-container"| SA

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style RBAC fill:#f5a623,color:#fff
    style Note fill:#fff3cd,stroke:#856404
    style Client fill:#f9f9f9,stroke:#999
    style Ingress fill:#ffe6cc,stroke:#d79b00
    style Proxy fill:#f5a623,color:#fff
    style Server fill:#d5e8d4,stroke:#82b366
    style StorageCreds fill:#f8d7da,stroke:#721c24
    style WH_CSR fill:#e8e8e8,stroke:#333
    style WH_ISVC_V fill:#e8e8e8,stroke:#333
    style WH_ISVC_M fill:#e8e8e8,stroke:#333
    style WH_POD fill:#e8e8e8,stroke:#333
