graph TD
    subgraph Note["RBAC Configuration"]
        direction TB
        Info["ℹ This component is a model server process,<br/>NOT a Kubernetes operator.<br/><br/>It does not interact with the Kubernetes API directly.<br/>It does not define ClusterRoles, Roles, or RoleBindings.<br/><br/>RBAC for the pod is configured externally by the<br/>KServe Controller via the InferenceService's ServiceAccount."]
    end

    subgraph ExternalRBAC["External RBAC (managed by KServe Controller)"]
        direction TB

        SA["ServiceAccount<br/>(configured by InferenceService)"]
        ISvc["InferenceService CR<br/>(defines serving runtime)"]
        Controller["KServe Controller<br/>(assigns SA to pod)"]

        ISvc -->|"specifies"| SA
        Controller -->|"reads InferenceService<br/>assigns SA to pod"| SA
    end

    subgraph Secrets["Secrets Access"]
        direction TB

        StorageConfig["storage-config (Opaque)<br/>Optional<br/>S3/GCS/Azure credentials"]
        ProvisionedBy["Provisioned by:<br/>User / Platform Admin"]
        AutoRotate["Auto-Rotate: No"]

        StorageConfig --- ProvisionedBy
        StorageConfig --- AutoRotate
    end

    subgraph AuthDelegation["Authentication & Authorization"]
        direction TB

        ServerAuth["Server-Level Auth: NONE<br/>(all endpoints unprotected at server)"]
        IngressAuth["Auth Enforcement: KServe Ingress Layer<br/>• kube-rbac-proxy<br/>• Istio sidecar (mTLS)<br/>• OpenShift Route"]

        ServerAuth -->|"delegated to"| IngressAuth
    end

    SA -->|"mounted into"| Pod["AutoGluon Server Pod"]
    Pod -->|"reads"| StorageConfig
    Pod -->|"protected by"| IngressAuth

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#7ed321,stroke:#333
    style ISvc fill:#f5a623,stroke:#333
    style StorageConfig fill:#e8e8e8,stroke:#333
    style ServerAuth fill:#ffcccc,stroke:#cc0000
    style IngressAuth fill:#d5e8d4,stroke:#82b366
    style Pod fill:#4a90e2,stroke:#333,color:#fff
