graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Component defines no RBAC resources"]
        L2["Auth delegated to platform ingress"]
    end

    subgraph PodSecurity["Pod Security Context"]
        Pod["AutoGluon Server Pod<br/>UID: 1001 (non-root)<br/>Namespace: {user-namespace}"]
        SA["ServiceAccount<br/>(managed by KServe Controller)"]
        SA -->|"runs as"| Pod
    end

    subgraph SecretAccess["Secret Access"]
        StorageCreds["storage-credentials<br/>Type: Opaque<br/>Provisioned by: User / Platform<br/>Auto-Rotate: No"]
        StorageCreds -->|"mounted into"| Pod
    end

    subgraph DelegatedAuth["Delegated Authentication & Authorization"]
        direction TB

        IngressAuth["Platform Ingress Layer<br/>(kube-rbac-proxy / Istio / Gateway API)"]

        subgraph AuthMechanisms["Auth Mechanisms at Ingress"]
            Bearer["Bearer Token"]
            OAuth["OAuth / OIDC"]
            RBAC["kube-rbac-proxy"]
        end

        IngressAuth --> Bearer
        IngressAuth --> OAuth
        IngressAuth --> RBAC
    end

    subgraph ServerEndpoints["Server Endpoints (No Auth)"]
        direction TB
        EP1["POST /v1/models/{name}:predict"]
        EP2["POST /v2/models/{name}/infer"]
        EP3["GET /v2/models/{name}"]
        EP4["GET /v1/models"]
        EP5["GET /v2/health/live"]
        EP6["GET /v2/health/ready"]
        EP7["gRPC GRPCInferenceService:8081"]
    end

    IngressAuth -->|"forwards authenticated<br/>requests"| ServerEndpoints

    subgraph ExternalCreds["External Credential Types"]
        direction TB
        AWSCreds["AWS IAM / STS<br/>S3 Access"]
        GCPCreds["GCP Service Account<br/>GCS Access"]
        AzureCreds["Azure Credentials<br/>Blob Access"]
        HFToken["Bearer Token (optional)<br/>HuggingFace Hub"]
    end

    StorageCreds -->|"contains"| AWSCreds
    StorageCreds -->|"contains"| GCPCreds
    StorageCreds -->|"contains"| AzureCreds
    StorageCreds -->|"contains"| HFToken

    %% Styling
    style Pod fill:#4a90e2,color:#fff
    style SA fill:#4a90e2,color:#fff
    style StorageCreds fill:#f5a623,stroke:#333
    style IngressAuth fill:#7ed321,stroke:#333,color:#fff
    style Legend fill:#f9f9f9,stroke:#ccc

    style AWSCreds fill:#fff2cc,stroke:#d6b656
    style GCPCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style HFToken fill:#fff2cc,stroke:#d6b656

    style EP1 fill:#e8e8e8,stroke:#333
    style EP2 fill:#e8e8e8,stroke:#333
    style EP3 fill:#e8e8e8,stroke:#333
    style EP4 fill:#e8e8e8,stroke:#333
    style EP5 fill:#e8e8e8,stroke:#333
    style EP6 fill:#e8e8e8,stroke:#333
    style EP7 fill:#e8e8e8,stroke:#333

    style Bearer fill:#dae8fc,stroke:#6c8ebf
    style OAuth fill:#dae8fc,stroke:#6c8ebf
    style RBAC fill:#dae8fc,stroke:#6c8ebf
