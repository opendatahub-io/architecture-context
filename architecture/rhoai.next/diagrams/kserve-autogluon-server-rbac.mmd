graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["No RBAC roles defined"]
        L2["Auth delegated to sidecar"]
    end

    subgraph PodSecurity["Pod Security Context"]
        direction TB
        Container["autogluonserver Container<br/>UID: 1001 (non-root)<br/>No K8s API access<br/>No ServiceAccount privileges"]
    end

    subgraph AuthDelegation["Authentication & Authorization (Delegated)"]
        direction TB

        subgraph RHOAI3x["RHOAI 3.x Pattern"]
            KRBP["kube-rbac-proxy Sidecar<br/>Port: 8443/TCP HTTPS<br/>TLS 1.3"]
        end

        subgraph Endpoints["Protected Endpoints"]
            E1["POST /v1/models/{name}:predict"]
            E2["POST /v2/models/{name}/infer"]
            E3["GET /metrics"]
        end

        subgraph UnprotectedEndpoints["Unprotected Endpoints (Health)"]
            H1["GET /v2/health/ready"]
            H2["GET /v2/health/live"]
        end
    end

    subgraph CredentialInjection["Credential Injection (by KServe Controller)"]
        direction TB
        EnvVars["Environment Variables<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>GOOGLE_APPLICATION_CREDENTIALS<br/>AZURE_STORAGE_CONNECTION_STRING"]
        SAAnnotations["Service Account Annotations<br/>GCP Workload Identity<br/>AWS IRSA"]
        SecretMount["Secret Volume Mount<br/>storage-config (Opaque)"]
    end

    Client["External Client<br/>Bearer Token"] -->|"HTTPS/8443<br/>TLS 1.3<br/>Bearer Token"| KRBP
    KRBP -->|"validates token<br/>enforces platform<br/>auth policy"| E1
    KRBP -->|"validates token"| E2
    KRBP -->|"validates token"| E3

    Container -->|"listens on<br/>8080/TCP plaintext"| E1
    Container -->|"listens on<br/>8080/TCP plaintext"| E2
    Container -->|"listens on<br/>8080/TCP plaintext"| E3
    Container -->|"listens on<br/>8080/TCP plaintext"| H1
    Container -->|"listens on<br/>8080/TCP plaintext"| H2

    KServeCtrl["KServe Controller"] -->|"injects at pod creation"| EnvVars
    KServeCtrl -->|"configures"| SAAnnotations
    KServeCtrl -->|"mounts"| SecretMount

    EnvVars -->|"used by kserve-storage<br/>for model download"| Container
    SAAnnotations -->|"provides cloud identity"| Container
    SecretMount -->|"provides credentials"| Container

