graph TD
    subgraph ContainerSecurity["Container Security Profile"]
        direction TB
        Pod["AutoGluon Server Pod<br/>UID: 1001 (non-root)<br/>No privilege escalation<br/>No host network"]
    end

    subgraph NoRBAC["RBAC — Not Applicable"]
        direction TB
        Note["This component defines NO RBAC<br/><br/>• No ClusterRoles<br/>• No RoleBindings<br/>• No ServiceAccount permissions<br/>• No Kubernetes API access<br/><br/>RBAC is managed externally by:<br/>1. KServe Controller (manages InferenceService pods)<br/>2. Platform Operator (rhods-operator)"]
    end

    subgraph AuthDelegation["Authentication & Authorization Delegation"]
        direction TB
        IstioAuth["Istio Sidecar<br/>mTLS STRICT<br/>SPIFFE identity verification"]
        GatewayAuth["KServe Gateway<br/>RequestAuthentication<br/>JWT validation"]
        KubeRBAC["kube-rbac-proxy<br/>(if configured by platform)"]
    end

    subgraph SecretsAccess["Secrets Access"]
        direction TB
        StorageCreds["storage-credentials<br/>Type: Opaque<br/>Purpose: S3/GCS model download<br/>Provisioned by: User / platform operator<br/>Auto-rotate: No"]
    end

    subgraph Endpoints["Endpoint Auth Summary"]
        direction TB
        AllEndpoints["All inference endpoints<br/>(GET, POST on 8080/TCP, 8081/TCP)<br/><br/>Auth at container: NONE<br/>Auth enforcement:<br/>→ Istio sidecar (mTLS)<br/>→ KServe Gateway (JWT)<br/>→ kube-rbac-proxy (platform)"]
    end

    Pod -->|"runs with"| NoRBAC
    Pod -->|"auth delegated to"| AuthDelegation
    Pod -->|"mounts"| StorageCreds
    AuthDelegation -->|"protects"| Endpoints

