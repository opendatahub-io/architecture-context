graph TD
    subgraph ServerModel["kserve-autogluon-server — RBAC Model"]
        direction TB

        Note["This component is a model server process,<br/>NOT a Kubernetes operator.<br/><br/>It does NOT interact with the Kubernetes API directly.<br/>It does NOT define ClusterRoles or RoleBindings."]

        subgraph PodIdentity["Pod Identity (configured by KServe Controller)"]
            SA["ServiceAccount<br/>(configured per InferenceService)"]
            NS["Namespace<br/>{user-namespace}"]
        end

        subgraph DelegatedAuth["Authentication & Authorization (Delegated)"]
            direction LR
            KubeRBAC["kube-rbac-proxy<br/>(Kubernetes RBAC)"]
            IstioAuth["Istio<br/>RequestAuthentication +<br/>AuthorizationPolicy"]
            OCPRoute["OpenShift Route<br/>+ OAuth Proxy"]
        end

        subgraph SecretAccess["Secret Access"]
            StorageConfig["storage-config (Opaque)<br/>Optional<br/>S3/GCS/Azure credentials<br/>Provisioned by: User / Admin<br/>Auto-Rotate: No"]
        end

        subgraph IngressEnforcement["Auth Enforcement Point"]
            IngressLayer["KServe Ingress Layer<br/>(OUTSIDE this component)<br/><br/>All inference endpoints:<br/>GET, POST on /v1/*, /v2/*<br/>Auth: None at server level<br/>Enforced by ingress stack"]
        end
    end

    SA -->|"pod runs as"| NS
    SA -.->|"mounts (if configured)"| StorageConfig
    IngressLayer -->|"enforced by one of"| KubeRBAC
    IngressLayer -->|"enforced by one of"| IstioAuth
    IngressLayer -->|"enforced by one of"| OCPRoute

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style SA fill:#4a90e2,color:#fff
    style NS fill:#e8eaf6,stroke:#3949ab
    style StorageConfig fill:#f5a623,color:#fff
    style KubeRBAC fill:#d5e8d4,stroke:#82b366
    style IstioAuth fill:#d5e8d4,stroke:#82b366
    style OCPRoute fill:#d5e8d4,stroke:#82b366
    style IngressLayer fill:#ffe6cc,stroke:#d79b00
