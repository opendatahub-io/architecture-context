graph TD
    subgraph ContainerSecurity["Container Security Context"]
        Container["AutoGluon Server Container<br/>UID: 1001 (non-root)<br/>Read-only root filesystem<br/>No privileged escalation<br/>No host network/PID/IPC"]
    end

    subgraph NoRBAC["RBAC: Not Applicable"]
        direction TB
        NoRoles["No ClusterRoles defined"]
        NoBindings["No RoleBindings defined"]
        NoAPIAccess["No Kubernetes API access"]
        Note1["RBAC managed externally by:<br/>- KServe Controller<br/>- Platform Operator (rhods-operator)"]
    end

    subgraph AuthDelegation["Authentication & Authorization (Delegated)"]
        direction TB

        subgraph EnforcementPoints["Enforcement Points"]
            IstioSidecar["Istio Sidecar<br/>mTLS STRICT enforcement<br/>Service identity (SPIFFE)"]
            KServeGateway["KServe Gateway<br/>TLS termination<br/>JWT validation"]
            KubeRBACProxy["kube-rbac-proxy<br/>(if configured by platform)"]
        end

        subgraph Endpoints["All Inference Endpoints"]
            V1["v1 REST endpoints<br/>8080/TCP"]
            V2["v2 OIP endpoints<br/>8080/TCP"]
            GRPC["gRPC endpoint<br/>8081/TCP"]
        end
    end

    subgraph SecretsAccess["Secrets"]
        StorageCreds["storage-credentials<br/>Type: Opaque<br/>Purpose: S3/GCS credentials<br/>Provisioned by: User/Platform Operator<br/>Auto-Rotate: No"]
    end

    %% Relationships
    Container -->|"no auth at container level"| Endpoints
    IstioSidecar -->|"enforces mTLS"| V1
    IstioSidecar -->|"enforces mTLS"| V2
    IstioSidecar -->|"enforces mTLS"| GRPC
    KServeGateway -->|"TLS + JWT"| IstioSidecar
    StorageCreds -->|"mounted as env vars<br/>or volume"| Container

    %% Styling
    style Container fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NoRoles fill:#f9f9f9,stroke:#ccc
    style NoBindings fill:#f9f9f9,stroke:#ccc
    style NoAPIAccess fill:#f9f9f9,stroke:#ccc
    style Note1 fill:#fff3cd,stroke:#856404
    style IstioSidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style KServeGateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style KubeRBACProxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style V1 fill:#dae8fc,stroke:#6c8ebf
    style V2 fill:#dae8fc,stroke:#6c8ebf
    style GRPC fill:#dae8fc,stroke:#6c8ebf
    style StorageCreds fill:#f8cecc,stroke:#b85450
