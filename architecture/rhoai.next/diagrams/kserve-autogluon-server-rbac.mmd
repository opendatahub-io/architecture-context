    style GatewayAuth fill:#d5e8d4,stroke:#82b366
    style KubeRBAC fill:#d5e8d4,stroke:#82b366
    style StorageCreds fill:#fff2cc,stroke:#d6b656
    style AllEndpoints fill:#ffe6cc,stroke:#d79b00
