graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client"]
    end

    subgraph OGXServer["ogx (Llama Stack) SERVER — Port 8321/TCP"]
        direction TB

        TLSLayer["TLS/mTLS Termination<br/>Uvicorn ssl stdlib<br/>Configurable cert+key+CA<br/>mTLS: ssl.CERT_REQUIRED"]

        AuthMW["AuthenticationMiddleware (ASGI)<br/>Bearer Token extraction<br/>Claims → attributes mapping<br/>(roles, teams, projects, namespaces)"]

        QuotaMW["QuotaMiddleware<br/>Per-client rate limiting<br/>Separate anon/auth quotas"]

        ABACEngine["Cedar-like ABAC Engine<br/>Forbid-first evaluation<br/>Default: DENY<br/>Owner-based + wildcard rules"]

        APIRouters["76 API Endpoints<br/>19 API Modules<br/>Inference, Agents, Safety,<br/>Vector IO, Eval, Tools, ..."]
    end

    subgraph AuthProviders["AUTHENTICATION PROVIDERS"]
        JWKS["OAuth2 JWKS Endpoint<br/>configurable/TCP<br/>HTTPS, TLS 1.2+"]
        Introspection["Token Introspection<br/>(RFC 7662)<br/>configurable/TCP<br/>HTTPS, Client creds"]
        CustomAuthEP["Custom Auth Endpoint<br/>configurable/TCP<br/>HTTPS"]
    end

    subgraph InferenceProviders["INFERENCE PROVIDERS (Egress)"]
        vLLM["vLLM Server<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Bearer Token / None"]
        Ollama["Ollama Server<br/>11434/TCP<br/>HTTP<br/>No encryption"]
        OpenAI["OpenAI API<br/>443/TCP<br/>HTTPS, TLS 1.2+<br/>API Key"]
        Anthropic["Anthropic API<br/>443/TCP<br/>HTTPS, TLS 1.2+<br/>API Key"]
        Bedrock["AWS Bedrock<br/>443/TCP<br/>HTTPS, TLS 1.2+<br/>IAM credentials"]
        TGI["HuggingFace TGI<br/>configurable/TCP<br/>HTTP/HTTPS"]
    end

    subgraph VectorDBs["VECTOR DATABASES (Egress)"]
        ChromaDB["ChromaDB<br/>configurable/TCP<br/>HTTP/HTTPS"]
        PGVector["PostgreSQL pgvector<br/>5432/TCP<br/>PostgreSQL proto<br/>Password/Cert"]
        Qdrant["Qdrant<br/>configurable/TCP<br/>HTTP/HTTPS<br/>API Key"]
        Milvus["Milvus<br/>configurable/TCP<br/>gRPC/HTTP<br/>Token"]
        Weaviate["Weaviate<br/>configurable/TCP<br/>HTTP/HTTPS<br/>API Key"]
    end

    subgraph ToolServices["TOOL RUNTIMES & SERVICES (Egress)"]
        Brave["Brave Search<br/>443/TCP, HTTPS<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP, HTTPS<br/>API Key"]
        Wolfram["Wolfram Alpha<br/>443/TCP, HTTPS<br/>App ID"]
        MCP["MCP Servers<br/>configurable<br/>HTTP/stdio"]
        HFHub["HuggingFace Hub<br/>443/TCP, HTTPS<br/>Bearer Token"]
        OTEL["OpenTelemetry<br/>Collector<br/>configurable/TCP<br/>HTTP (OTLP)"]
    end

    %% Ingress flow
    Client -->|"HTTP/HTTPS 8321/TCP<br/>Configurable TLS<br/>Bearer Token (JWT/Custom)"| TLSLayer
    TLSLayer --> AuthMW
    AuthMW --> QuotaMW
    QuotaMW --> ABACEngine
    ABACEngine --> APIRouters

    %% Auth provider egress
    AuthMW -->|"HTTPS<br/>TLS 1.2+<br/>No auth"| JWKS
    AuthMW -->|"HTTPS<br/>TLS 1.2+<br/>Client credentials"| Introspection
    AuthMW -->|"HTTPS<br/>Configurable"| CustomAuthEP

    %% Inference egress
    APIRouters -->|"HTTP/HTTPS<br/>Configurable TLS<br/>Bearer Token"| vLLM
    APIRouters -->|"HTTP :11434<br/>No encryption"| Ollama
    APIRouters -->|"HTTPS :443<br/>TLS 1.2+<br/>API Key"| OpenAI
    APIRouters -->|"HTTPS :443<br/>TLS 1.2+<br/>API Key"| Anthropic
    APIRouters -->|"HTTPS :443<br/>TLS 1.2+<br/>IAM"| Bedrock
    APIRouters -->|"HTTP/HTTPS<br/>Configurable"| TGI

    %% Vector DB egress
    APIRouters -->|"HTTP/HTTPS"| ChromaDB
    APIRouters -->|"PostgreSQL :5432<br/>Configurable TLS"| PGVector
    APIRouters -->|"HTTP/HTTPS<br/>API Key"| Qdrant
    APIRouters -->|"gRPC/HTTP<br/>Configurable TLS"| Milvus
    APIRouters -->|"HTTP/HTTPS<br/>API Key"| Weaviate

    %% Tool & service egress
    APIRouters -->|"HTTPS :443<br/>API Key"| Brave
    APIRouters -->|"HTTPS :443<br/>API Key"| Tavily
    APIRouters -->|"HTTPS :443<br/>App ID"| Wolfram
    APIRouters -->|"HTTP/stdio"| MCP
    APIRouters -->|"HTTPS :443<br/>Bearer Token"| HFHub
    APIRouters -->|"HTTP OTLP"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef server fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef vectordb fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef toolservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Client external
    class TLSLayer,AuthMW,QuotaMW,ABACEngine,APIRouters server
    class JWKS,Introspection,CustomAuthEP authprovider
    class vLLM,Ollama,OpenAI,Anthropic,Bedrock,TGI inference
    class ChromaDB,PGVector,Qdrant,Milvus,Weaviate vectordb
    class Brave,Tavily,Wolfram,MCP,HFHub,OTEL toolservice
