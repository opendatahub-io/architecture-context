graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>Data Scientist / API Consumer"]
    end

    subgraph AppBoundary["APPLICATION BOUNDARY (Llama Stack Server)"]
        direction TB

        subgraph Middleware["Middleware Pipeline"]
            Tracing["Tracing Middleware<br/>W3C TraceContext"]
            Auth["Authentication Middleware<br/>OAuth2 JWT / Custom<br/>(OPTIONAL - disabled by default)"]
            Quota["Quota Middleware<br/>Per-client rate limiting<br/>(OPTIONAL)"]
            ABACEngine["ABAC Engine<br/>Cedar-like permit/forbid<br/>(OPTIONAL)"]
        end

        subgraph PublicEndpoints["Public Endpoints (no auth)"]
            Health["/health, /version<br/>/docs, /openapi.json"]
        end

        subgraph ProtectedEndpoints["Protected Endpoints (auth when configured)"]
            APIs["/v1/inference/* /v1/openai/v1/*<br/>/v1/agents/* /v1/safety/*<br/>/v1/vector-io/* /v1/eval/*<br/>/v1/models /v1/datasets<br/>+ 10 more API groups"]
        end

        subgraph Providers["Provider Framework"]
            Inline["Inline Providers (19)<br/>In-process, no network"]
            Remote["Remote Providers (41)<br/>External service adapters"]
        end
    end

    subgraph InferenceProviders["EGRESS: INFERENCE PROVIDERS"]
        vLLM["vLLM Server<br/>configurable (default 8000/TCP)<br/>HTTP/HTTPS<br/>None/API key"]
        Ollama["Ollama Server<br/>11434/TCP HTTP<br/>No encryption<br/>No auth"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS<br/>TLS 1.2+ (via litellm)<br/>API key"]
        Gemini["Google Gemini<br/>443/TCP HTTPS<br/>TLS 1.2+ (via litellm)<br/>API key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        NIM["NVIDIA NIM<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
    end

    subgraph VectorDBs["EGRESS: VECTOR DATABASES"]
        PGVector["PostgreSQL pgvector<br/>5432/TCP<br/>Optional TLS<br/>Password"]
        Chroma["Chroma<br/>configurable HTTP/HTTPS<br/>Configurable<br/>None"]
        Qdrant["Qdrant<br/>configurable HTTP/gRPC<br/>Configurable<br/>API key"]
        Milvus["Milvus<br/>configurable gRPC<br/>Configurable<br/>None"]
        Weaviate["Weaviate<br/>configurable HTTP/HTTPS<br/>Configurable<br/>API key"]
    end

    subgraph DataStores["EGRESS: DATA / KV STORES"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password"]
        MongoDB["MongoDB<br/>27017/TCP<br/>Optional TLS<br/>Password"]
        SQLite["SQLite<br/>Local file I/O<br/>No network"]
    end

    subgraph AuthProviders["EGRESS: AUTHENTICATION"]
        JWKS["OIDC JWKS Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>None"]
        Introspect["Token Introspection<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Basic Auth"]
        CustomAuth["Custom Auth Endpoint<br/>configurable<br/>Configurable<br/>None"]
    end

    subgraph ToolServices["EGRESS: TOOLS & SERVICES"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        TavilySearch["Tavily Search<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        WolframAlpha["Wolfram Alpha<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        MCPServers["MCP Servers<br/>configurable HTTP/HTTPS<br/>Configurable<br/>Configurable"]
    end

    subgraph Observability["EGRESS: OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>configurable HTTP OTLP<br/>Configurable<br/>None"]
    end

    %% Client to Server
    Client -->|"HTTP(S)/8321<br/>Configurable TLS<br/>Bearer Token (optional)"| Auth

    %% Middleware flow
    Tracing --> Auth
    Auth --> Quota
    Quota --> ABACEngine
    ABACEngine --> APIs
    Client -.->|"No auth"| Health

    %% Provider routing
    APIs --> Inline
    APIs --> Remote

    %% Auth egress
    Auth -->|"HTTPS/443<br/>TLS 1.2+"| JWKS
    Auth -->|"HTTPS/443<br/>TLS 1.2+<br/>Basic Auth"| Introspect
    Auth -->|"Configurable"| CustomAuth

    %% Inference egress
    Remote -->|"HTTP(S)/8000<br/>Configurable"| vLLM
    Remote -->|"HTTP/11434<br/>No encryption"| Ollama
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Anthropic
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Gemini
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| Bedrock
    Remote -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| NIM

    %% Vector DB egress
    Remote -->|"PostgreSQL/5432<br/>Optional TLS"| PGVector
    Remote -->|"HTTP(S)"| Chroma
    Remote -->|"HTTP/gRPC"| Qdrant
    Remote -->|"gRPC"| Milvus
    Remote -->|"HTTP(S)"| Weaviate

    %% Data store egress
    Remote -->|"Redis/6379<br/>Optional TLS"| Redis
    Remote -->|"MongoDB/27017<br/>Optional TLS"| MongoDB
    Inline -.->|"File I/O"| SQLite

    %% Tool egress
    Remote -->|"HTTPS/443<br/>HF Token"| HFHub
    Remote -->|"HTTPS/443<br/>API key"| BraveSearch
    Remote -->|"HTTPS/443<br/>API key"| TavilySearch
    Remote -->|"HTTPS/443<br/>API key"| WolframAlpha
    Remote -->|"HTTP(S)<br/>Configurable"| MCPServers

    %% Observability egress
    Tracing -->|"HTTP OTLP<br/>Configurable"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef middleware fill:#fecaca,stroke:#ef4444,stroke-width:2px
    classDef inference fill:#e0e7ff,stroke:#6366f1,stroke-width:2px
    classDef vectordb fill:#d1fae5,stroke:#10b981,stroke-width:2px
    classDef datastore fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef authprov fill:#fce7f3,stroke:#ec4899,stroke-width:2px
    classDef tools fill:#fff7ed,stroke:#f97316,stroke-width:2px
    classDef observ fill:#f3e8ff,stroke:#8b5cf6,stroke-width:2px

    class Client external
    class Auth,Quota,ABACEngine,Tracing middleware
    class vLLM,Ollama,OpenAI,Anthropic,Gemini,Bedrock,NIM inference
    class PGVector,Chroma,Qdrant,Milvus,Weaviate vectordb
    class Redis,MongoDB,SQLite datastore
    class JWKS,Introspect,CustomAuth authprov
    class HFHub,BraveSearch,TavilySearch,WolframAlpha,MCPServers tools
    class OTel observ
