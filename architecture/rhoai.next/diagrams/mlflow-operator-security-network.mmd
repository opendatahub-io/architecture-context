graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Platform Auth"]
    end

    subgraph Namespace["NAMESPACE: redhat-ods-applications"]
        direction TB

        subgraph OperatorPod["MLflow Operator Pod"]
            Operator["MLflow Controller<br/>SA: controller-manager<br/>8081/TCP HTTP (probes)<br/>8443/TCP HTTPS (metrics)"]
        end

        subgraph MLflowPod["MLflow Server Pod (Helm-rendered)"]
            MLflow["MLflow Server<br/>SA: mlflow-sa<br/>8443/TCP HTTPS (uvicorn SSL)<br/>Auth: K8s RBAC (SSAR)"]
            CASidecar["CA Bundle Sidecar<br/>Watches ConfigMaps<br/>Regenerates every 30s"]
        end

        NetPol["NetworkPolicy<br/>Ingress: 8443 from ANY ns<br/>Egress: allowlisted ports"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
        DNS["CoreDNS<br/>53/UDP+TCP, 5353/UDP+TCP<br/>No encryption"]
        ServiceCA["OpenShift service-ca<br/>Auto-provisions TLS certs"]
        Prometheus["Prometheus<br/>8443/TCP HTTPS<br/>TLS (service-ca)<br/>SA Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (optional, PGSSLMODE)<br/>Connection string creds"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS (optional)<br/>Connection string creds"]
        S3["S3-compatible Storage<br/>443/TCP, 9000/TCP<br/>8333/TCP, 8334/TCP<br/>TLS (optional)<br/>AWS IAM creds"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Forwarded Bearer Token"| MLflow
    MLflow -->|"HTTPS/6443<br/>TLS 1.2+<br/>SelfSubjectAccessReview"| K8sAPI
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    MLflow -->|"TCP/5432<br/>TLS (optional)<br/>Credentials"| PostgreSQL
    MLflow -->|"TCP/3306<br/>TLS (optional)<br/>Credentials"| MySQL
    MLflow -->|"HTTPS/443,9000<br/>TLS (optional)<br/>AWS IAM"| S3
    MLflow -->|"DNS/53,5353"| DNS
    Prometheus -->|"HTTPS/8443<br/>TLS (service-ca)<br/>SA Bearer Token"| MLflow
    ServiceCA -.->|"provisions certs"| MLflow

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef namespace fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class Operator,MLflow,CASidecar namespace
    class NetPol netpol
    class K8sAPI,DNS,ServiceCA,Prometheus clusterservice
    class PostgreSQL,MySQL,S3 externalservice
