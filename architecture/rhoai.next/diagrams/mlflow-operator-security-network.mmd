graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE"]
    end

    subgraph Internal["INTERNAL (Namespace: redhat-ods-applications)"]
        direction TB

        subgraph OperatorPod["Operator Pod"]
            Operator["MLflow Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS"]
        end

        subgraph MLflowPod["MLflow Server Pod"]
            MLflow["MLflow Server<br/>SA: mlflow-sa<br/>8443/TCP HTTPS (uvicorn SSL)<br/>TLS: mlflow-tls (service-ca)<br/>Auth: K8s RBAC (SelfSubjectAccessReview)"]
            CASidecar["CA Bundle Sidecar<br/>Watches ConfigMap changes<br/>Rebuilds CA bundle every 30s"]
        end

        NP["NetworkPolicy<br/>Ingress: 8443 from any NS<br/>Egress: allowlist"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]
        ServiceCA["OpenShift service-ca<br/>TLS cert provisioning"]
        Console["OpenShift Console<br/>ConsoleLink CRD"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>8443/TCP HTTPS"]
        CABundle["odh-trusted-ca-bundle<br/>Platform CAs"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DB_PG["PostgreSQL<br/>5432/TCP<br/>TLS (optional)<br/>Credentials"]
        DB_MY["MySQL<br/>3306/TCP<br/>TLS (optional)<br/>Credentials"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        MinIO["MinIO<br/>9000/TCP<br/>TLS (optional)<br/>AWS IAM"]
        SeaweedFS["SeaweedFS<br/>8333/TCP HTTP<br/>8334/TCP HTTPS<br/>AWS IAM"]
    end

    subgraph DNS["DNS"]
        CoreDNS["CoreDNS<br/>53/UDP, 53/TCP<br/>5353/UDP, 5353/TCP<br/>(OVN-K post-DNAT)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Forwarded Bearer Token"| MLflow

    %% Internal flows
    MLflow -->|"HTTPS/6443<br/>TLS 1.2+<br/>SelfSubjectAccessReview"| K8sAPI
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Platform integration
    ServiceCA -.->|"provisions cert"| MLflow
    CASidecar -.->|"watches"| CABundle
    Operator -.->|"creates ConsoleLink"| Console
    Prometheus -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token"| MLflow

    %% Egress to external services
    MLflow -->|"PostgreSQL/5432<br/>TLS (optional)<br/>Credentials"| DB_PG
    MLflow -->|"MySQL/3306<br/>TLS (optional)<br/>Credentials"| DB_MY
    MLflow -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    MLflow -->|"HTTP(S)/9000<br/>TLS (optional)<br/>AWS IAM"| MinIO
    MLflow -->|"HTTP(S)/8333-8334<br/>TLS (8334)<br/>AWS IAM"| SeaweedFS

    %% DNS
    MLflow -->|"DNS/53,5353"| CoreDNS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef dns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class Operator,MLflow,CASidecar,NP internal
    class K8sAPI,ServiceCA,Console,Prometheus,CABundle platform
    class DB_PG,DB_MY,S3,MinIO,SeaweedFS externalservice
    class CoreDNS dns
