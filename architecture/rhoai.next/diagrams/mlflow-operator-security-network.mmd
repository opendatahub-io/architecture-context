graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ termination + re-encrypt"]
    end

    subgraph AppNamespace["APPLICATION NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph OperatorZone["Operator"]
            Operator["MLflow Operator<br/>SA: controller-manager<br/>Image: odh-mlflow-operator-rhel9<br/>8081/TCP health, 8443/TCP metrics"]
        end

        subgraph ServerZone["MLflow Server (NetworkPolicy enforced)"]
            MLflowServer["MLflow Server Deployment<br/>SA: mlflow-sa<br/>8443/TCP HTTPS (service-ca TLS)<br/>Auth: K8s SelfSubjectAccessReview<br/>FIPS: strictfipsruntime"]
        end

        subgraph JobZone["Jobs"]
            MigrationJob["Migration Job<br/>SA: mlflow-sa<br/>mlflow db upgrade<br/>NetworkPolicy: DNS + DB only"]
            GCCronJob["GC CronJob<br/>SA: mlflow-gc-sa<br/>Scheduled cleanup"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>SA Token Auth"]
        ServiceCA["OpenShift service-ca<br/>Auto TLS provisioning<br/>mlflow-tls Secret"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape<br/>8443/TCP HTTPS"]
        Console["OpenShift Console<br/>ConsoleLink integration"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap (volume mount)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS verify-full<br/>Connection string auth"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS (configurable)<br/>Connection string auth"]
        S3["S3-Compatible Storage<br/>443/TCP, 9000/TCP, 8333/TCP<br/>HTTPS/TLS<br/>AWS IAM credentials"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Forwarded Bearer"| MLflowServer

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS<br/>SA Token"| K8sAPI
    Operator -->|"SSA creates/manages"| MLflowServer
    Operator -->|"creates"| MigrationJob
    Operator -->|"creates"| GCCronJob

    %% MLflow Server flows
    MLflowServer -->|"HTTPS/6443<br/>TLS<br/>SelfSubjectAccessReview"| K8sAPI
    MLflowServer -->|"TCP/5432<br/>TLS verify-full<br/>Conn string"| PostgreSQL
    MLflowServer -->|"TCP/3306<br/>TLS<br/>Conn string"| MySQL
    MLflowServer -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3

    %% Job flows
    MigrationJob -->|"TCP/5432 or 3306<br/>TLS<br/>Conn string"| PostgreSQL
    GCCronJob -->|"TCP/5432 or 3306<br/>Direct DB"| PostgreSQL
    GCCronJob -->|"HTTPS/8443<br/>K8s auth"| MLflowServer

    %% Platform integrations
    ServiceCA -.->|"provisions TLS cert"| MLflowServer
    Prometheus -->|"scrapes /metrics<br/>HTTPS/8443"| MLflowServer
    CABundle -.->|"volume mount"| MLflowServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef server fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef job fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class Operator app
    class MLflowServer server
    class MigrationJob,GCCronJob job
    class K8sAPI,ServiceCA,Prometheus,Console,CABundle platform
    class PostgreSQL,MySQL,S3 extsvc
