graph TB
    subgraph UserEnv["User Environment (Jupyter Workbench)"]
        subgraph SDK["CodeFlare SDK (Python Library)"]
            direction TB
            ClusterMod["codeflare_sdk.ray.cluster<br/>Cluster lifecycle management"]
            AppWrapperMod["codeflare_sdk.ray.appwrapper<br/>AppWrapper submission/status"]
            ClientMod["codeflare_sdk.ray.client<br/>Ray Job submission"]
            K8sAuth["codeflare_sdk.common.kubernetes_cluster<br/>K8s Auth (Token/KubeConfig)"]
            KueueMod["codeflare_sdk.common.kueue<br/>LocalQueue discovery"]
            GenCert["codeflare_sdk.common.utils.generate_cert<br/>TLS cert generation"]
            Widgets["codeflare_sdk.common.widgets<br/>Jupyter ipywidgets UI"]
            Template["base-template.yaml<br/>RayCluster CR template"]
        end
    end

    %% Internal module relationships
    ClusterMod -->|generates YAML from| Template
    ClusterMod -->|uses| K8sAuth
    ClusterMod -->|optionally wraps| AppWrapperMod
    ClusterMod -->|labels for| KueueMod
    ClusterMod -->|TLS setup| GenCert
    ClientMod -->|discovers endpoint via| ClusterMod
    Widgets -->|manages| ClusterMod

    %% CRDs created/consumed
    ClusterMod -->|creates/deletes| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    AppWrapperMod -->|creates/deletes| AppWrapperCR["AppWrapper CR<br/>workload.codeflare.dev/v1beta2"]
    KueueMod -->|reads| LocalQueueCR["LocalQueue CR<br/>kueue.x-k8s.io/v1beta1"]

    %% External dependencies (operators that reconcile CRs)
    RayClusterCR -->|reconciled by| KubeRay["KubeRay Operator"]
    AppWrapperCR -->|reconciled by| CFOperator["CodeFlare Operator"]
    LocalQueueCR -->|managed by| Kueue["Kueue Controller"]

    %% Kubernetes API
    K8sAuth -->|authenticates to| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]

    %% Ray cluster interaction
    ClientMod -->|job submission| RayDashboard["Ray Dashboard<br/>8265/TCP HTTP"]
    GenCert -->|mTLS connection| RayClient["Ray Head Node<br/>10001/TCP gRPC"]

    %% Route/Ingress discovery
    ClusterMod -->|discovers| OSRoute["OpenShift Route<br/>ray-dashboard-*"]

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,color:#fff
    style ClusterMod fill:#5b9bd5,stroke:#333,color:#fff
    style AppWrapperMod fill:#5b9bd5,stroke:#333,color:#fff
    style ClientMod fill:#5b9bd5,stroke:#333,color:#fff
    style K8sAuth fill:#5b9bd5,stroke:#333,color:#fff
    style KueueMod fill:#5b9bd5,stroke:#333,color:#fff
    style GenCert fill:#5b9bd5,stroke:#333,color:#fff
    style Widgets fill:#5b9bd5,stroke:#333,color:#fff
    style Template fill:#8db4e2,stroke:#333,color:#333

    style RayClusterCR fill:#f5a623,stroke:#333,color:#333
    style AppWrapperCR fill:#f5a623,stroke:#333,color:#333
    style LocalQueueCR fill:#f5a623,stroke:#333,color:#333

    style KubeRay fill:#7ed321,stroke:#333,color:#333
    style CFOperator fill:#7ed321,stroke:#333,color:#333
    style Kueue fill:#7ed321,stroke:#333,color:#333

    style K8sAPI fill:#e8e8e8,stroke:#333,color:#333
    style RayDashboard fill:#e8e8e8,stroke:#333,color:#333
    style RayClient fill:#e8e8e8,stroke:#333,color:#333
    style OSRoute fill:#e8e8e8,stroke:#333,color:#333
    style UserEnv fill:#f0f7ff,stroke:#4a90e2,color:#333
