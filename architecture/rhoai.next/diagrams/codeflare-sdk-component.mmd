graph TB
    subgraph "CodeFlare SDK"
        direction TB

        subgraph "ray.cluster"
            Cluster["Cluster<br/>(lifecycle management)"]
            Config["ClusterConfiguration<br/>(resource requirements)"]
            GenerateYAML["generate_yaml<br/>(YAML rendering)"]
            Status["Status Enums<br/>(cluster states)"]
            PrettyPrint["pretty_print<br/>(Rich terminal output)"]
            BaseTemplate["base-template.yaml<br/>(RayCluster template)"]
        end

        subgraph "ray.appwrapper"
            AWManager["AWManager<br/>(AppWrapper CRUD)"]
        end

        subgraph "ray.client"
            RayJobClient["RayJobClient<br/>(Ray job submission)"]
        end

        subgraph "common.kubernetes_cluster"
            Auth["auth<br/>(TokenAuth / KubeConfig /<br/>InCluster)"]
        end

        subgraph "common.kueue"
            Kueue["kueue<br/>(LocalQueue discovery<br/>& validation)"]
        end

        subgraph "common.utils"
            GenerateCert["generate_cert<br/>(CA + client TLS certs)"]
            Demos["demos<br/>(copy demo notebooks)"]
        end

        subgraph "common.widgets"
            Widgets["widgets<br/>(ipywidgets for Jupyter)"]
        end
    end

    %% Internal relationships
    Cluster -->|uses| Config
    Cluster -->|calls| GenerateYAML
    Cluster -->|reads| Status
    Cluster -->|calls| PrettyPrint
    Cluster -->|calls| Kueue
    Cluster -->|uses| Auth
    GenerateYAML -->|renders| BaseTemplate
    GenerateYAML -->|wraps in| AWManager
    RayJobClient -->|uses| Auth
    GenerateCert -->|uses| Auth
    Widgets -->|manages| Cluster
    Widgets -->|displays| Status

    %% External interactions
    User[Data Scientist<br/>Jupyter Notebook] -->|instantiates| Cluster
    User -->|submits jobs via| RayJobClient
    User -->|interacts via| Widgets

    Cluster -->|creates CRs on| K8sAPI[Kubernetes API<br/>6443/TCP]
    RayJobClient -->|submits to| RayDashboard[Ray Dashboard<br/>8265/TCP]
    GenerateCert -->|retrieves CA from| K8sSecrets[Kubernetes Secrets API]

    %% Styling
    style Cluster fill:#4a90e2,color:#fff
    style Config fill:#4a90e2,color:#fff
    style GenerateYAML fill:#4a90e2,color:#fff
    style Auth fill:#9b59b6,color:#fff
    style Kueue fill:#9b59b6,color:#fff
    style GenerateCert fill:#9b59b6,color:#fff
    style RayJobClient fill:#4a90e2,color:#fff
    style AWManager fill:#4a90e2,color:#fff
    style Widgets fill:#e67e22,color:#fff
    style User fill:#2ecc71,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
    style K8sSecrets fill:#e8e8e8,stroke:#333
