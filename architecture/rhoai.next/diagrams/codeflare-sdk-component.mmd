graph TB
    subgraph UserEnv["User Environment (Jupyter Workbench)"]
        direction TB
        SDK["CodeFlare SDK<br/>(Python Library)"]

        subgraph RayModule["codeflare_sdk.ray"]
            Cluster["ray.cluster<br/>Cluster lifecycle mgmt"]
            AppWrapper["ray.appwrapper<br/>AppWrapper submission"]
            Client["ray.client<br/>Job submission client"]
        end

        subgraph CommonModule["codeflare_sdk.common"]
            KubeCluster["kubernetes_cluster<br/>K8s auth (Token/KubeConfig)"]
            KueueMod["kueue<br/>LocalQueue discovery"]
            GenCert["utils.generate_cert<br/>TLS cert generation"]
            Widgets["widgets<br/>Jupyter ipywidgets UI"]
        end

        Template["base-template.yaml<br/>RayCluster CR template"]
    end

    %% Internal relationships
    SDK --> Cluster
    SDK --> AppWrapper
    SDK --> Client
    Cluster --> KubeCluster
    Cluster --> KueueMod
    Cluster --> GenCert
    Cluster --> Template
    AppWrapper --> KubeCluster
    Client --> Cluster

    %% CRDs created/consumed
    Cluster -->|"creates/deletes"| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    AppWrapper -->|"creates/deletes"| AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]
    KueueMod -->|"reads"| LocalQueueCR["LocalQueue CR<br/>(kueue.x-k8s.io/v1beta1)"]

    %% External connections
    KubeCluster -->|"6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    Client -->|"8265/TCP HTTP/HTTPS"| RayDashboard["Ray Dashboard"]
    Client -->|"10001/TCP gRPC mTLS"| RayHead["Ray Head Node"]

    %% Platform dependencies
    RayClusterCR -->|"reconciled by"| KubeRay["KubeRay Operator"]
    AppWrapperCR -->|"reconciled by"| CFOperator["CodeFlare Operator"]
    LocalQueueCR -->|"managed by"| Kueue["Kueue"]

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,color:#fff
    style Cluster fill:#5ba0f2,stroke:#333,color:#fff
    style AppWrapper fill:#5ba0f2,stroke:#333,color:#fff
    style Client fill:#5ba0f2,stroke:#333,color:#fff
    style KubeCluster fill:#6bb0f2,stroke:#333,color:#fff
    style KueueMod fill:#6bb0f2,stroke:#333,color:#fff
    style GenCert fill:#6bb0f2,stroke:#333,color:#fff
    style Widgets fill:#6bb0f2,stroke:#333,color:#fff
    style Template fill:#f5a623,stroke:#333,color:#333
    style RayClusterCR fill:#f5a623,stroke:#333,color:#333
    style AppWrapperCR fill:#f5a623,stroke:#333,color:#333
    style LocalQueueCR fill:#f5a623,stroke:#333,color:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
    style RayHead fill:#e8e8e8,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333,color:#333
    style CFOperator fill:#7ed321,stroke:#333,color:#333
    style Kueue fill:#7ed321,stroke:#333,color:#333
