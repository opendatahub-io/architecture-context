graph TB
    subgraph UserEnv["User Environment (Workbench / Notebook)"]
        direction TB
        subgraph SDK["CodeFlare SDK (Python Library)"]
            direction TB
            subgraph RayModule["codeflare_sdk.ray"]
                Cluster["Cluster<br/>(ray.cluster)"]
                ClusterConfig["ClusterConfiguration<br/>(ray.cluster.config)"]
                GenerateYAML["generate_yaml<br/>(YAML Generation)"]
                RayJobClient["RayJobClient<br/>(ray.client)"]
                AWManager["AWManager<br/>(ray.appwrapper)"]
                BaseTemplate["base-template.yaml<br/>(RayCluster Template)"]
            end

            subgraph CommonModule["codeflare_sdk.common"]
                AuthHelpers["TokenAuthentication<br/>KubeConfigFileAuthentication<br/>(kubernetes_cluster)"]
                KueueIntegration["Kueue LocalQueue<br/>(kueue)"]
                Widgets["Jupyter Widgets<br/>(widgets)"]
                CertGen["TLS Certificate<br/>Generator<br/>(generate_cert)"]
            end
        end
    end

    %% Internal SDK flows
    ClusterConfig -->|configures| Cluster
    Cluster -->|uses| GenerateYAML
    GenerateYAML -->|reads| BaseTemplate
    Cluster -->|optionally wraps| AWManager
    Cluster -->|submits jobs via| RayJobClient
    Cluster -->|authenticates via| AuthHelpers
    Cluster -->|queries queues via| KueueIntegration
    Cluster -->|secures via| CertGen
    Widgets -->|manages| Cluster

    %% CRDs created/consumed
    Cluster -->|creates/deletes| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    AWManager -->|creates/deletes| AppWrapperCR["AppWrapper CR<br/>(workload.codeflare.dev/v1beta2)"]
    KueueIntegration -->|reads| LocalQueueCR["LocalQueue CR<br/>(kueue.x-k8s.io/v1beta1)"]

    %% External interactions
    AuthHelpers -->|authenticates| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    RayClusterCR -->|watched by| KubeRayOp["KubeRay Operator"]
    AppWrapperCR -->|watched by| AppWrapperCtrl["AppWrapper Controller"]
    KubeRayOp -->|creates| RayHeadSvc["{name}-head-svc<br/>6379, 8265, 10001/TCP"]
    RayJobClient -->|submits jobs| RayDashboard["Ray Head Node<br/>Dashboard 8265/TCP"]
    CertGen -->|enables mTLS| RayClient["Ray Head Node<br/>Client 10001/TCP"]

    %% Route/Ingress discovery
    Cluster -->|reads| Route["OpenShift Route<br/>(route.openshift.io/v1)"]
    Cluster -->|reads| Ingress["Kubernetes Ingress<br/>(networking.k8s.io/v1)"]

