graph TB
    subgraph UserEnv["User Environment (Jupyter Notebook / Workbench)"]
        subgraph SDK["CodeFlare SDK (Python Library)"]
            direction TB
            ClusterMod["ray.cluster<br/>Cluster class<br/>Lifecycle management"]
            AWMod["ray.appwrapper<br/>AWManager<br/>AppWrapper submission"]
            ClientMod["ray.client<br/>RayJobClient<br/>Job submission"]
            AuthMod["common.kubernetes_cluster<br/>TokenAuthentication<br/>KubeConfigFileAuthentication"]
            KueueMod["common.kueue<br/>LocalQueue discovery"]
            CertMod["common.utils.generate_cert<br/>TLS cert generation"]
            WidgetsMod["common.widgets<br/>Jupyter ipywidgets UI"]
            Template["ray/templates<br/>base-template.yaml"]
        end
    end

    %% Internal SDK relationships
    ClusterMod -->|generates YAML from| Template
    ClusterMod -->|wraps via| AWMod
    ClusterMod -->|discovers queue| KueueMod
    ClusterMod -->|authenticates via| AuthMod
    ClientMod -->|uses certs from| CertMod
    WidgetsMod -->|manages clusters via| ClusterMod

    %% CRDs consumed
    subgraph CRDs["Custom Resources (consumed, not owned)"]
        RayClusterCR["RayCluster CR<br/>ray.io/v1"]
        AppWrapperCR["AppWrapper CR<br/>workload.codeflare.dev/v1beta2"]
        LocalQueueCR["LocalQueue CR<br/>kueue.x-k8s.io/v1beta1"]
        RouteCR["Route CR<br/>route.openshift.io/v1"]
    end

    ClusterMod -->|creates/deletes| RayClusterCR
    AWMod -->|creates/deletes| AppWrapperCR
    KueueMod -->|reads| LocalQueueCR
    ClusterMod -->|reads| RouteCR

    %% External dependencies
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    RayDashboard["Ray Dashboard<br/>8265/TCP HTTP/HTTPS"]
    KubeRay["KubeRay Operator"]
    CFOperator["CodeFlare Operator"]
    Kueue["Kueue Controller"]

    %% CRDs to operators
    RayClusterCR -->|reconciled by| KubeRay
    AppWrapperCR -->|reconciled by| CFOperator
    LocalQueueCR -->|managed by| Kueue

    %% SDK to external
    AuthMod -->|authenticates| K8sAPI
    ClientMod -->|submits jobs| RayDashboard

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ClusterMod fill:#5b9bd5,stroke:#333,color:#fff
    style AWMod fill:#5b9bd5,stroke:#333,color:#fff
    style ClientMod fill:#5b9bd5,stroke:#333,color:#fff
    style AuthMod fill:#5b9bd5,stroke:#333,color:#fff
    style KueueMod fill:#5b9bd5,stroke:#333,color:#fff
    style CertMod fill:#5b9bd5,stroke:#333,color:#fff
    style WidgetsMod fill:#5b9bd5,stroke:#333,color:#fff
    style Template fill:#5b9bd5,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style LocalQueueCR fill:#f5a623,stroke:#333
    style RouteCR fill:#f5a623,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333
    style CFOperator fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
