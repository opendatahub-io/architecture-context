graph TB
    subgraph SDK["CodeFlare SDK (Python Client Library)"]
        direction TB

        subgraph RayLayer["Ray Management Layer"]
            ClusterMod["ray.cluster<br/>Cluster Lifecycle<br/>(create, apply, delete,<br/>status, wait_ready)"]
            RayJobsMod["ray.rayjobs<br/>RayJob Submission<br/>(submit, suspend,<br/>resubmit, delete)"]
            ClientMod["ray.client<br/>JobSubmissionClient<br/>(direct HTTP job submission)"]
        end

        subgraph CommonLayer["Common Services Layer"]
            KubeAuth["common.kubernetes_cluster<br/>K8s Auth & API Client<br/>(OIDC, OAuth, Token, kubeconfig)"]
            KueueMod["common.kueue<br/>LocalQueue Listing<br/>Default Queue Resolution<br/>WorkloadPriorityClass Validation"]
            Utils["common.utils<br/>TLS Cert Generation<br/>Ray Image Selection<br/>Constants & Validation"]
            Widgets["common.widgets<br/>Jupyter/IPython Widgets<br/>Interactive Cluster Mgmt"]
        end

        subgraph VendoredLayer["Vendored Dependencies"]
            KubeRayClient["vendored.python_client<br/>RayClusterApi<br/>RayjobApi<br/>(CustomObjectsApi wrapper)"]
        end
    end

    %% Internal relationships
    ClusterMod -->|"delegates CRD ops"| KubeRayClient
    RayJobsMod -->|"delegates CRD ops"| KubeRayClient
    ClusterMod -->|"authenticates via"| KubeAuth
    RayJobsMod -->|"authenticates via"| KubeAuth
    ClientMod -->|"authenticates via"| KubeAuth
    ClusterMod -->|"TLS certs"| Utils
    RayJobsMod -->|"TLS certs"| Utils
    ClusterMod -->|"queue integration"| KueueMod
    RayJobsMod -->|"queue integration"| KueueMod
    Widgets -->|"manages"| ClusterMod
    ClientMod -->|"connects to"| RayDashboard

    %% External CRDs created
    ClusterMod -->|"creates"| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobsMod -->|"creates"| RayJobCR["RayJob CR<br/>(ray.io/v1)"]

    %% External systems
    RayClusterCR -->|"watched by"| KubeRayOp["KubeRay Operator"]
    RayJobCR -->|"watched by"| KubeRayOp
    KubeRayOp -->|"provisions"| RayHead["Ray Head Node<br/>Ports: 6379, 8265, 10001"]
    RayDashboard["Ray Dashboard<br/>8265/TCP"]

    KueueMod -->|"reads"| KueueCtrl["Kueue Controller<br/>(LocalQueue, Workload,<br/>WorkloadPriorityClass)"]

    KubeAuth -->|"authenticates"| K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
    KubeRayClient -->|"CRUD via"| K8sAPI

    %% Notebook user
    User["Data Scientist<br/>(Jupyter Notebook)"] -->|"Python API"| ClusterMod
    User -->|"Python API"| RayJobsMod
    User -->|"interactive UI"| Widgets

    %% Styling
    style SDK fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    style RayLayer fill:#bbdefb,stroke:#1976d2,stroke-width:2px
    style CommonLayer fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    style VendoredLayer fill:#fff9c4,stroke:#f9a825,stroke-width:2px

    style ClusterMod fill:#4a90e2,color:#fff
    style RayJobsMod fill:#4a90e2,color:#fff
    style ClientMod fill:#4a90e2,color:#fff
    style KubeAuth fill:#66bb6a,color:#fff
    style KueueMod fill:#66bb6a,color:#fff
    style Utils fill:#66bb6a,color:#fff
    style Widgets fill:#66bb6a,color:#fff
    style KubeRayClient fill:#fdd835,color:#333

    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style KubeRayOp fill:#999,stroke:#333,color:#fff
    style KueueCtrl fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style RayHead fill:#999,stroke:#333,color:#fff
    style RayDashboard fill:#999,stroke:#333,color:#fff
    style User fill:#e1bee7,stroke:#7b1fa2
