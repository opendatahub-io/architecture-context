graph TB
    subgraph UserEnv["User Environment (Jupyter Notebook / Python)"]
        direction TB
        subgraph SDK["CodeFlare SDK (pip package)"]
            direction TB
            Cluster["ray.cluster<br/>Cluster Class<br/>Lifecycle Management"]
            AWManager["ray.appwrapper<br/>AWManager<br/>AppWrapper CRD Ops"]
            RayJobClient["ray.client<br/>RayJobClient<br/>Job Submission"]
            Auth["common.kubernetes_cluster<br/>Auth (Token/KubeConfig)"]
            KueueMod["common.kueue<br/>LocalQueue Discovery"]
            GenCert["common.utils.generate_cert<br/>TLS Cert Generation"]
            Widgets["common.widgets<br/>Jupyter ipywidgets UI"]
        end
    end

    %% Internal SDK relationships
    Cluster -->|wraps in| AWManager
    Cluster -->|submits jobs via| RayJobClient
    Cluster -->|authenticates via| Auth
    Cluster -->|discovers queues via| KueueMod
    Cluster -->|generates certs via| GenCert
    Widgets -->|manages| Cluster

    %% CRDs consumed
    Cluster -->|creates/deletes| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    AWManager -->|creates/deletes| AppWrapperCR["AppWrapper CR<br/>workload.codeflare.dev/v1beta2"]
    KueueMod -->|reads| LocalQueueCR["LocalQueue CR<br/>kueue.x-k8s.io/v1beta1"]
    Cluster -->|reads| RouteCR["Route CR<br/>route.openshift.io/v1"]

    %% External systems
    Auth -->|authenticates| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    RayJobClient -->|submits jobs| RayDashboard["Ray Dashboard<br/>8265/TCP HTTP/HTTPS"]
    GenCert -->|reads CA secret| K8sSecrets["Kubernetes Secrets"]

    %% Downstream operators
    RayClusterCR -->|reconciled by| KubeRay["KubeRay Operator"]
    AppWrapperCR -->|reconciled by| CFOperator["CodeFlare Operator"]
    LocalQueueCR -->|managed by| Kueue["Kueue Controller"]

    %% KubeRay creates pods
    KubeRay -->|creates| RayPods["Ray Head + Worker Pods"]

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Cluster fill:#5ba3f5,stroke:#333,color:#fff
    style AWManager fill:#5ba3f5,stroke:#333,color:#fff
    style RayJobClient fill:#5ba3f5,stroke:#333,color:#fff
    style Auth fill:#5ba3f5,stroke:#333,color:#fff
    style KueueMod fill:#5ba3f5,stroke:#333,color:#fff
    style GenCert fill:#5ba3f5,stroke:#333,color:#fff
    style Widgets fill:#5ba3f5,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style AppWrapperCR fill:#f5a623,stroke:#333
    style LocalQueueCR fill:#f5a623,stroke:#333
    style RouteCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
    style K8sSecrets fill:#e8e8e8,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333
    style CFOperator fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style RayPods fill:#d5e8d4,stroke:#333
