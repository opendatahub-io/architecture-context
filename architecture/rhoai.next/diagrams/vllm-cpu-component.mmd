graph TB
    subgraph VllmCPU["vLLM CPU Inference Server"]
        direction TB

        subgraph APILayer["API Layer"]
            OpenAIServer["vllm-openai<br/>FastAPI HTTP Server<br/>Port 8000/TCP"]
            GRPCServer["gRPC Server<br/>smg-grpc-servicer<br/>Port 50051/TCP"]
        end

        subgraph EngineLayer["V1 Engine"]
            InputProc["Input Processor<br/>Tokenization & Preprocessing"]
            EngineCore["EngineCore<br/>Scheduler + KV Cache Mgmt"]
            OutputProc["Output Processor<br/>Detokenization & Streaming"]
        end

        subgraph WorkerLayer["CPU Worker"]
            ModelRunner["CPU Model Runner<br/>CPU tensor execution"]
            CPUPlatform["CPU Platform<br/>x86/ARM/PPC64LE/S390X detection"]
        end

        OpenAIServer --> InputProc
        GRPCServer --> InputProc
        InputProc --> EngineCore
        EngineCore --> ModelRunner
        ModelRunner --> OutputProc
        CPUPlatform -.->|arch config| ModelRunner
    end

    subgraph Clients["Clients"]
        ExtClient["External Client"]
        KServeGW["KServe Gateway"]
    end

    subgraph Metrics["Observability"]
        PromEndpoint["Prometheus Metrics<br/>Port 8000/TCP"]
        OTLPExporter["OTLP Exporter<br/>Distributed Tracing"]
    end

    ExtClient -->|"HTTP(S)/8000<br/>Bearer API Key"| OpenAIServer
    KServeGW -->|"HTTP(S)/8000"| OpenAIServer
    ExtClient -->|"gRPC/50051"| GRPCServer

    OpenAIServer --> PromEndpoint
    EngineCore --> OTLPExporter

    ModelRunner -->|"in-process"| PyTorch["PyTorch CPU Backend<br/>2.10.0+cpu"]
    InputProc -->|"in-process"| HFTransformers["HuggingFace transformers<br/>Tokenization"]

    style VllmCPU fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style APILayer fill:#bbdefb,stroke:#1565c0
    style EngineLayer fill:#c8e6c9,stroke:#2e7d32
    style WorkerLayer fill:#fff9c4,stroke:#f9a825
    style OpenAIServer fill:#4a90e2,color:#fff
    style GRPCServer fill:#4a90e2,color:#fff
    style EngineCore fill:#66bb6a,color:#fff
    style ModelRunner fill:#fdd835
    style CPUPlatform fill:#fdd835
    style PyTorch fill:#e8e8e8,stroke:#333
    style HFTransformers fill:#e8e8e8,stroke:#333
    style ExtClient fill:#f5f5f5,stroke:#999
    style KServeGW fill:#7ed321,stroke:#333
    style PromEndpoint fill:#ffcc80,stroke:#e65100
    style OTLPExporter fill:#ffcc80,stroke:#e65100
