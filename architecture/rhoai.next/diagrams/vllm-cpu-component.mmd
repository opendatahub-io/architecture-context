graph TB
    subgraph "vLLM CPU Service"
        direction TB

        subgraph "API Layer"
            APIServer["vllm-openai API Server<br/>FastAPI + uvicorn<br/>Port 8000/TCP"]
            GRPCServer["gRPC Server<br/>smg-grpc-servicer<br/>Port 50051/TCP"]
            AuthMiddleware["Auth Middleware<br/>Bearer Token (SHA256)<br/>Constant-time compare"]
        end

        subgraph "V1 Engine Pipeline"
            InputProcessor["Input Processor<br/>Tokenization + Validation"]
            EngineCore["EngineCore<br/>Scheduler + KV Cache Mgmt<br/>Continuous Batching"]
            OutputProcessor["Output Processor<br/>Detokenization + Streaming"]
        end

        subgraph "CPU Execution"
            CPUModelRunner["CPU Model Runner<br/>CPU tensor execution<br/>GPU API shim layer"]
            CPUPlatform["CPU Platform<br/>Arch detection: x86/ARM/PPC64LE/S390X<br/>NUMA binding, OMP pinning"]
        end

        subgraph "Engine Client Modes"
            InprocClient["InprocClient<br/>Single-process"]
            SyncMPClient["SyncMPClient<br/>Multiprocess sync"]
            AsyncMPClient["AsyncMPClient<br/>Multiprocess async"]
        end
    end

    %% Internal flows
    APIServer -->|validates| AuthMiddleware
    APIServer -->|request| InputProcessor
    GRPCServer -->|request| InputProcessor
    InputProcessor -->|tokens| EngineCore
    EngineCore -->|execute| CPUModelRunner
    CPUModelRunner -->|platform info| CPUPlatform
    EngineCore -->|results| OutputProcessor
    OutputProcessor -->|SSE/JSON| APIServer

    %% Engine client connections
    EngineCore -.->|deployment mode| InprocClient
    EngineCore -.->|deployment mode| SyncMPClient
    EngineCore -.->|deployment mode| AsyncMPClient

    %% External interactions
    Client[Client / KServe Gateway] -->|HTTP 8000/TCP| APIServer
    ClientGRPC[gRPC Client] -->|gRPC 50051/TCP| GRPCServer
    Prometheus[Prometheus] -->|scrape 8000/TCP| APIServer

    CPUModelRunner -->|tensors| PyTorch["PyTorch CPU Backend"]
    InputProcessor -->|tokenize| HFTransformers["HuggingFace transformers"]

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AuthMiddleware fill:#e74c3c,stroke:#333,color:#fff
    style EngineCore fill:#f5a623,stroke:#333,color:#fff
    style InputProcessor fill:#f5a623,stroke:#333
    style OutputProcessor fill:#f5a623,stroke:#333
    style CPUModelRunner fill:#9b59b6,stroke:#333,color:#fff
    style CPUPlatform fill:#9b59b6,stroke:#333,color:#fff
    style InprocClient fill:#95a5a6,stroke:#333
    style SyncMPClient fill:#95a5a6,stroke:#333
    style AsyncMPClient fill:#95a5a6,stroke:#333
    style Client fill:#e8e8e8,stroke:#999
    style ClientGRPC fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
    style PyTorch fill:#7ed321,stroke:#333
    style HFTransformers fill:#7ed321,stroke:#333
