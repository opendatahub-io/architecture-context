graph TB
    subgraph vllmcpu["vllm-cpu (odh-vllm-cpu-rhel9)"]
        direction TB

        subgraph APILayer["API Layer"]
            OpenAIServer["OpenAI API Server<br/>(FastAPI)<br/>Port 8000/TCP"]
            GRPCServer["gRPC Server<br/>Port 50051/TCP"]
        end

        subgraph Engine["Inference Engine"]
            AsyncLLM["V1 Async Engine<br/>(AsyncLLM)<br/>VLLM_USE_V1=1"]
            CPUKernels["CPU Kernels<br/>(C++ Extensions)<br/>x86_64 / ppc64le / s390x"]
        end

        subgraph Observability["Observability"]
            Prometheus["Prometheus<br/>Instrumentator<br/>/metrics"]
            OTel["OpenTelemetry<br/>Tracing<br/>OTLP Export"]
        end

        OpenAIServer -->|"Python call"| AsyncLLM
        GRPCServer -->|"Python call"| AsyncLLM
        AsyncLLM -->|"Python/C++"| CPUKernels
    end

    %% External Clients
    Client["External Client"] -->|"POST /v1/chat/completions<br/>HTTP 8000/TCP<br/>API Key (optional)"| OpenAIServer
    GRPCClient["gRPC Client"] -->|"gRPC 50051/TCP<br/>Insecure"| GRPCServer

    %% Platform Integration
    KServe["KServe<br/>InferenceService"] -->|"manages as<br/>runtime container"| vllmcpu

    %% External Dependencies
    AsyncLLM -->|"model loading"| PyTorch["PyTorch CPU<br/>(torch 2.10.0)"]
    PyTorch -->|"native ops"| CPUKernels

    %% Model Sources
    AsyncLLM -->|"HTTPS 443<br/>HF_TOKEN"| HFHub["Hugging Face Hub"]
    AsyncLLM -->|"HTTPS 443<br/>AWS IAM"| S3["S3-compatible<br/>Storage"]

    %% Observability Exports
    Prometheus -->|"scrape /metrics"| PromServer["Prometheus Server"]
    OTel -->|"OTLP export<br/>HTTPS/gRPC"| OTelCollector["OpenTelemetry<br/>Collector"]

    %% Styling
    style OpenAIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncLLM fill:#4a90e2,stroke:#333,color:#fff
    style CPUKernels fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#4a90e2,stroke:#333,color:#fff
    style OTel fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style PyTorch fill:#e8e8e8,stroke:#333
    style PromServer fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style GRPCClient fill:#f9f9f9,stroke:#999
