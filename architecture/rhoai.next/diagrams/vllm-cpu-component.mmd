graph TB
    subgraph "vLLM CPU Component"
        subgraph "API Layer"
            OpenAIServer["vllm-openai<br/>(FastAPI/uvicorn)<br/>Port 8000/TCP"]
            GRPCServer["vLLM gRPC Server<br/>(grpcio)<br/>Port 50051/TCP"]
        end

        subgraph "Engine Layer"
            AsyncEngine["vLLM Engine v1<br/>Async Scheduling<br/>KV Cache Management"]
            ZMQ["ZeroMQ IPC<br/>Engine-Frontend<br/>Communication"]
        end

        subgraph "Execution Layer"
            ModelExecutor["Model Executor<br/>(CPU Worker)"]
            CppExtensions["C++ Extensions<br/>(csrc/)<br/>CPU-Optimized Kernels"]
            PyTorch["PyTorch CPU Backend<br/>Tensor Computation"]
        end

        OpenAIServer -->|"requests"| ZMQ
        GRPCServer -->|"requests"| ZMQ
        ZMQ -->|"dispatches"| AsyncEngine
        AsyncEngine -->|"schedules"| ModelExecutor
        ModelExecutor -->|"custom ops"| CppExtensions
        ModelExecutor -->|"forward pass"| PyTorch
    end

    Client["External Client"] -->|"POST /v1/chat/completions<br/>HTTP/HTTPS 8000/TCP<br/>API Key (optional)"| OpenAIServer
    GRPCClient["gRPC Client"] -->|"gRPC 50051/TCP<br/>Plaintext"| GRPCServer

    KServe["KServe / ModelMesh<br/>(Platform Operator)"] -->|"manages lifecycle<br/>autoscaling, ingress"| OpenAIServer
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrapes /metrics<br/>HTTP 8000/TCP"| OpenAIServer

    AsyncEngine -->|"downloads models<br/>HTTPS 443/TCP"| HFHub["HuggingFace Hub"]
    AsyncEngine -->|"loads models<br/>HTTPS 443/TCP"| S3["S3 / Object Storage"]
    AsyncEngine -->|"exports traces<br/>gRPC 4317/TCP"| OTEL["OpenTelemetry<br/>Collector"]

    style OpenAIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncEngine fill:#4a90e2,stroke:#333,color:#fff
    style ZMQ fill:#4a90e2,stroke:#333,color:#fff
    style ModelExecutor fill:#4a90e2,stroke:#333,color:#fff
    style CppExtensions fill:#4a90e2,stroke:#333,color:#fff
    style PyTorch fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#000
    style Prometheus fill:#7ed321,stroke:#333,color:#000
    style HFHub fill:#f5a623,stroke:#333,color:#000
    style S3 fill:#f5a623,stroke:#333,color:#000
    style OTEL fill:#f5a623,stroke:#333,color:#000
    style Client fill:#e8e8e8,stroke:#999
    style GRPCClient fill:#e8e8e8,stroke:#999
