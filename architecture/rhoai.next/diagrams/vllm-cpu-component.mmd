graph TB
    subgraph vllmcpu["vLLM CPU Component"]
        direction TB

        subgraph APILayer["API Layer"]
            OpenAIServer["OpenAI API Server<br/>(FastAPI/Uvicorn)<br/>Port 8000/TCP"]
            GRPCServer["gRPC Server<br/>(gRPC AsyncIO)<br/>Port 50051/TCP"]
        end

        subgraph EngineLayer["Inference Engine"]
            Engine["vLLM Engine (V1)<br/>Continuous Batching<br/>KV Cache Management"]
        end

        subgraph KernelLayer["CPU Kernels"]
            Attention["CPU Attention Kernels<br/>(cpu_attn.cpp)"]
            MoE["MoE Fusion<br/>(cpu_fused_moe.cpp)"]
            Quant["Quantization<br/>(cpu_wna16.cpp)"]
            DNNL["Intel DNNL<br/>(dnnl_kernels.cpp)"]
            SGL["SGL Kernels<br/>INT4/INT8/FP8 GEMM"]
        end

        subgraph CLI_["CLI"]
            CLITool["vLLM CLI<br/>serve / benchmark / batch"]
        end

        OpenAIServer -->|inference requests| Engine
        GRPCServer -->|inference requests| Engine
        CLITool -->|launches| OpenAIServer
        Engine -->|executes| Attention
        Engine -->|executes| MoE
        Engine -->|executes| Quant
        Engine -->|executes| DNNL
        Engine -->|executes| SGL
    end

    %% External Clients
    Client["Client<br/>(KServe Proxy / User)"]
    Client -->|"POST /v1/chat/completions<br/>HTTP 8000/TCP<br/>API Key Auth"| OpenAIServer
    Client -->|"gRPC Inference<br/>50051/TCP"| GRPCServer

    %% Health & Metrics
    Prometheus["Prometheus"]
    Prometheus -->|"GET /metrics<br/>8000/TCP"| OpenAIServer

    K8s["Kubernetes<br/>Liveness/Readiness"]
    K8s -->|"GET /health<br/>8000/TCP"| OpenAIServer

    %% Model Sources
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    PVC["Local Model Storage<br/>(PVC)"]

    Engine -->|"download models<br/>HF Token"| HFHub
    Engine -->|"load models<br/>AWS IAM"| S3
    Engine -->|"read weights"| PVC

    %% Platform
    KServe["KServe<br/>InferenceService"]
    KServe -->|"deploys as<br/>serving container"| vllmcpu

    %% Styling
    style OpenAIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style Engine fill:#7ed321,stroke:#333
    style Attention fill:#f5a623,stroke:#333
    style MoE fill:#f5a623,stroke:#333
    style Quant fill:#f5a623,stroke:#333
    style DNNL fill:#f5a623,stroke:#333
    style SGL fill:#f5a623,stroke:#333
    style CLITool fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8s fill:#e8e8e8,stroke:#333
    style HFHub fill:#fff2cc,stroke:#d6b656
    style S3 fill:#fff2cc,stroke:#d6b656
    style PVC fill:#fff2cc,stroke:#d6b656
    style KServe fill:#d5e8d4,stroke:#82b366
