graph TB
    subgraph "vLLM-CPU Component"
        direction TB
        subgraph "HTTP Layer"
            APIServer["OpenAI API Server<br/>(FastAPI/Uvicorn)<br/>Port 8000/TCP"]
            ChatRouter["Chat Completion Router<br/>/v1/chat/completions"]
            CompletionRouter["Completion Router<br/>/v1/completions"]
            ResponsesRouter["Responses Router<br/>/v1/responses"]
            AnthropicRouter["Anthropic Router<br/>/v1/messages"]
            EmbeddingsRouter["Embeddings Router<br/>/v1/embeddings"]
            HealthRouter["Health/Metrics<br/>/health, /metrics"]
        end

        subgraph "gRPC Layer"
            GRPCServer["gRPC Server<br/>(grpc.aio)<br/>Port 50051/TCP"]
        end

        subgraph "Engine Layer"
            AsyncEngine["AsyncLLM Engine (V1)<br/>PagedAttention<br/>Continuous Batching<br/>KV Cache Management"]
        end

        subgraph "Execution Layer"
            ModelExecutor["Model Executor<br/>Python + C/C++ Native Kernels<br/>CPU-Optimized (OpenBLAS)"]
        end

        subgraph "Instrumentation"
            PrometheusInstr["Prometheus Instrumentator<br/>Middleware"]
        end
    end

    %% Internal connections
    APIServer --> ChatRouter
    APIServer --> CompletionRouter
    APIServer --> ResponsesRouter
    APIServer --> AnthropicRouter
    APIServer --> EmbeddingsRouter
    APIServer --> HealthRouter
    PrometheusInstr -.->|instruments| APIServer

    ChatRouter --> AsyncEngine
    CompletionRouter --> AsyncEngine
    ResponsesRouter --> AsyncEngine
    AnthropicRouter --> AsyncEngine
    EmbeddingsRouter --> AsyncEngine
    GRPCServer --> AsyncEngine

    AsyncEngine --> ModelExecutor

    %% External actors
    Client[Client] -->|"HTTP 8000/TCP<br/>API Key (optional)"| APIServer
    GRPCClient[gRPC Client] -->|"gRPC 50051/TCP<br/>plaintext"| GRPCServer

    %% External dependencies
    ModelExecutor -->|"model download<br/>HTTPS 443"| HFHub["Hugging Face Hub"]
    ModelExecutor -->|"model download<br/>HTTPS 443"| S3["S3 Storage"]

    %% Platform integration
    KServe["KServe<br/>ServingRuntime"] -->|"routes traffic<br/>deploys container"| APIServer
    Prometheus["Prometheus"] -->|"scrapes /metrics"| HealthRouter

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncEngine fill:#7ed321,stroke:#333,color:#fff
    style ModelExecutor fill:#f5a623,stroke:#333,color:#fff
    style PrometheusInstr fill:#9b59b6,stroke:#333,color:#fff
    style ChatRouter fill:#5dade2,stroke:#333,color:#fff
    style CompletionRouter fill:#5dade2,stroke:#333,color:#fff
    style ResponsesRouter fill:#5dade2,stroke:#333,color:#fff
    style AnthropicRouter fill:#5dade2,stroke:#333,color:#fff
    style EmbeddingsRouter fill:#5dade2,stroke:#333,color:#fff
    style HealthRouter fill:#5dade2,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style GRPCClient fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
