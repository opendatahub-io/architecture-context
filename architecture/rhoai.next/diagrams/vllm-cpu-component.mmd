graph TB
    subgraph VllmCPU["vLLM-CPU Component"]
        direction TB
        APIServer["OpenAI API Server<br/>(FastAPI/Uvicorn)<br/>Port 8000/TCP"]
        GRPCServer["gRPC Server<br/>(grpc.aio)<br/>Port 50051/TCP"]
        AsyncEngine["AsyncLLM Engine (V1)<br/>PagedAttention + Continuous Batching"]
        ModelExecutor["Model Executor<br/>(Python + C/C++ native kernels)"]
        PrometheusInstr["Prometheus Instrumentator<br/>/metrics endpoint"]

        APIServer -->|async calls| AsyncEngine
        GRPCServer -->|async calls| AsyncEngine
        AsyncEngine -->|inference| ModelExecutor
        APIServer --- PrometheusInstr
    end

    subgraph APIRouters["API Routers"]
        direction LR
        ChatRouter["/v1/chat/completions"]
        CompletionRouter["/v1/completions"]
        ResponsesRouter["/v1/responses"]
        AnthropicRouter["/v1/messages"]
        ModelsRouter["/v1/models"]
        EmbeddingsRouter["/v1/embeddings"]
        HealthRouter["/health"]
    end

    Client["External Client"] -->|HTTP 8000/TCP| APIServer
    Client -->|gRPC 50051/TCP| GRPCServer
    APIRouters ---|registered on| APIServer

    subgraph KServeIntegration["KServe Integration"]
        ServingRuntime["KServe ServingRuntime CRD"]
        KServeIngress["KServe Ingress<br/>443/TCP HTTPS"]
    end

    KServeIngress -->|routes traffic| APIServer
    ServingRuntime -->|deploys| VllmCPU

    subgraph ExternalDeps["External Services"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        OTelCollector["OpenTelemetry Collector<br/>(optional)"]
    end

    AsyncEngine -->|model download| HFHub
    AsyncEngine -->|model load via tensorizer| S3
    PrometheusInstr -.->|scrape target| Prometheus["Prometheus"]
    APIServer -.->|tracing export| OTelCollector

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncEngine fill:#4a90e2,stroke:#333,color:#fff
    style ModelExecutor fill:#4a90e2,stroke:#333,color:#fff
    style PrometheusInstr fill:#4a90e2,stroke:#333,color:#fff
    style ServingRuntime fill:#f5a623,stroke:#333
    style KServeIngress fill:#f5a623,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
