graph TB
    subgraph vLLMCPU["vLLM CPU Service"]
        direction TB

        subgraph API["API Layer"]
            OpenAIServer["vllm-openai<br/>FastAPI Server<br/>8000/TCP"]
            GRPCServer["gRPC Server<br/>50051/TCP"]
        end

        subgraph Engine["V1 Engine"]
            InputProc["Input Processor<br/>Tokenization & Preprocessing"]
            EngineCore["EngineCore<br/>Scheduler + KV Cache Mgmt"]
            OutputProc["Output Processor<br/>Detokenization & Streaming"]
        end

        subgraph Worker["CPU Worker"]
            CPURunner["CPU Model Runner<br/>CPU Tensor Execution"]
            CPUPlatform["CPU Platform<br/>x86/ARM/PPC64LE/S390X Detection"]
        end

        subgraph MultiArch["Multi-Arch Builder"]
            Konflux["Konflux Pipeline<br/>hermetic: false"]
            PPC64LE["build_vllm_ppc64le.sh<br/>IBM DevPI Wheels"]
            S390X["build_vllm_s390x.sh<br/>Arrow from Source"]
        end

        OpenAIServer -->|requests| InputProc
        GRPCServer -->|requests| InputProc
        InputProc -->|tokenized input| EngineCore
        EngineCore -->|scheduled batch| CPURunner
        CPURunner -->|inference result| OutputProc
        OutputProc -->|streaming response| OpenAIServer
        CPUPlatform -->|arch config| CPURunner

        Konflux --> PPC64LE
        Konflux --> S390X
    end

    Client["Client / KServe Gateway"] -->|HTTP 8000<br/>Bearer API Key| OpenAIServer
    Client -->|gRPC 50051| GRPCServer

    CPURunner -->|tensor ops| PyTorch["PyTorch CPU<br/>2.10.0+cpu"]
    InputProc -->|tokenization| HFTransformers["HuggingFace<br/>transformers"]
    OpenAIServer -->|metrics| Prometheus["Prometheus<br/>8000/TCP scrape"]
    EngineCore -.->|distributed| Gloo["Gloo Backend<br/>Tensor Parallelism"]

    style OpenAIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style EngineCore fill:#4a90e2,stroke:#333,color:#fff
    style InputProc fill:#4a90e2,stroke:#333,color:#fff
    style OutputProc fill:#4a90e2,stroke:#333,color:#fff
    style CPURunner fill:#4a90e2,stroke:#333,color:#fff
    style CPUPlatform fill:#4a90e2,stroke:#333,color:#fff
    style Konflux fill:#9b59b6,stroke:#333,color:#fff
    style PPC64LE fill:#9b59b6,stroke:#333,color:#fff
    style S390X fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style HFTransformers fill:#e8e8e8,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Gloo fill:#e8e8e8,stroke:#333
