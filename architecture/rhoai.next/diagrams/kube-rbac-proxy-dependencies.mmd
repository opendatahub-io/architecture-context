graph LR
    KubeRBACProxy["kube-rbac-proxy<br/>v0.21.1<br/>Go HTTP Reverse Proxy"]

    %% External Dependencies (Required)
    KubeRBACProxy -->|"TokenReview &<br/>SubjectAccessReview"| K8sAPI["Kubernetes API Server<br/>v1.35+"]
    KubeRBACProxy -->|"authn/authz<br/>framework"| K8sAPIServer["k8s.io/apiserver<br/>v0.35.2"]
    KubeRBACProxy -->|"API client for<br/>TokenReview & SAR"| K8sClientGo["k8s.io/client-go<br/>v0.35.2"]

