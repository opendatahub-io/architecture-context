graph LR
    KRP["kube-rbac-proxy<br/>v0.21.1<br/>Go HTTP Reverse Proxy"]

    %% External Dependencies (Required)
    KRP -->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server<br/>v1.35+"]
    KRP -->|"authn/authz framework<br/>TLS utilities"| K8sAPIServer["k8s.io/apiserver<br/>v0.35.2"]
    KRP -->|"API client for<br/>authn/authz calls"| K8sClientGo["k8s.io/client-go<br/>v0.35.2"]
    KRP -->|"HTTP/2 + h2c<br/>support"| GoNet["golang.org/x/net<br/>v0.52.0"]

