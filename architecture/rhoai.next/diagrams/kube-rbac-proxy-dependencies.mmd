    KubeRBACProxy -->|"reverse proxy<br/>HTTP/HTTPS/h2c"| UpstreamApp["Upstream Application<br/>(component container)"]
    KubeRBACProxy -.->|"JWKS / discovery<br/>HTTPS/443"| OIDCIssuer["OIDC Issuer<br/>(external)"]

