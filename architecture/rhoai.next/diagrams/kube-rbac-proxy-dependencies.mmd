    KubeRBACProxy -.->|"OIDC JWT<br/>validation"| GoOIDC["coreos/go-oidc<br/>v2.3.0"]

    %% Build Dependencies
    KubeRBACProxy -.->|"build"| GoToolchain["Go 1.25.7"]
    KubeRBACProxy -.->|"build image"| UBI9GoToolset["UBI 9 Go Toolset"]
    KubeRBACProxy -.->|"runtime image"| UBI9Minimal["UBI 9 Minimal"]

    %% Internal Platform Dependencies
    RhodsOperator["rhods-operator"] -->|"sidecar injection"| KubeRBACProxy
