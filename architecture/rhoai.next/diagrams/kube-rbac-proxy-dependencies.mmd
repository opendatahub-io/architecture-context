graph LR
    KRP["kube-rbac-proxy<br/>(Sidecar Proxy)"]

    %% External Dependencies (Required)
    KRP -->|"TokenReview +<br/>SubjectAccessReview<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>v1.35+"]

    %% External Dependencies (Optional)
    KRP -.->|"OIDC Discovery +<br/>JWKS retrieval<br/>443/TCP HTTPS"| OIDCProvider["OIDC Provider<br/>(optional)"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator"] -->|"sidecar injection<br/>(pod template)"| KRP
    KRP -->|"reverse proxy<br/>localhost HTTP"| ComponentPods["Component Pods<br/>(notebooks, model servers,<br/>dashboard)"]
    CertMgr["cert-manager /<br/>Platform Secrets"] -->|"TLS certificates<br/>(hot-reloaded)"| KRP

    %% Monitoring Integration
    Prometheus["OpenShift Monitoring<br/>(prometheus-k8s)"] -->|"GET /metrics<br/>8443/TCP HTTPS<br/>(hardcoded allow)"| KRP

    %% Go Library Dependencies
    subgraph "Key Go Libraries"
        direction TB
        K8sClientGo["k8s.io/client-go<br/>v0.35.2"]
        K8sApiserver["k8s.io/apiserver<br/>v0.35.2"]
        Cobra["spf13/cobra<br/>v1.10.2"]
        OklogRun["oklog/run<br/>v1.2.0"]
        GoOIDC["coreos/go-oidc<br/>v2.3.0"]
    end

    KRP -.->|"API client"| K8sClientGo
    KRP -.->|"authn/authz factories"| K8sApiserver
    KRP -.->|"CLI framework"| Cobra
    KRP -.->|"goroutine lifecycle"| OklogRun
    KRP -.->|"OIDC verification"| GoOIDC

    style KRP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OIDCProvider fill:#999,stroke:#333,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style ComponentPods fill:#7ed321,stroke:#333,color:#fff
    style CertMgr fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#333
    style K8sClientGo fill:#f5a623,stroke:#333,color:#fff
    style K8sApiserver fill:#f5a623,stroke:#333,color:#fff
    style Cobra fill:#f5a623,stroke:#333,color:#fff
    style OklogRun fill:#f5a623,stroke:#333,color:#fff
    style GoOIDC fill:#f5a623,stroke:#333,color:#fff
