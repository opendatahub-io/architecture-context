graph LR
    KRP["kube-rbac-proxy<br/>(Sidecar Proxy)"]

    %% Kubernetes API Dependencies (Required)
    KRP -->|"TokenReview +<br/>SubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Go Module Dependencies (Required)
    KRP -->|"authn/authz framework"| APIServer["k8s.io/apiserver<br/>v0.35.2"]
    KRP -->|"API client"| ClientGo["k8s.io/client-go<br/>v0.35.2"]
    KRP -->|"API types"| K8sAPI_lib["k8s.io/api<br/>v0.35.2"]
    KRP -->|"CLI + TLS config"| CompBase["k8s.io/component-base<br/>v0.35.2"]
    KRP -->|"HTTP/2, h2c"| GoNet["golang.org/x/net<br/>v0.52.0"]
    KRP -->|"OIDC verification"| GoOIDC["go-oidc<br/>v2.3.0"]
    KRP -->|"CLI framework"| Cobra["cobra<br/>v1.10.2"]

    %% Internal Platform Dependencies
    KRP -.->|"sidecar injection<br/>(deployment-time)"| Operator["rhods-operator"]
    KRP -.->|"protects<br/>(localhost proxy)"| Upstream["Upstream App<br/>(component container)"]

    %% Platform Services
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"scrapes /metrics<br/>HTTPS/8443"| KRP
    CertManager["cert-manager /<br/>Platform TLS"] -.->|"provisions certs<br/>(file mount)"| KRP

    %% Optional External
    KRP -.->|"OIDC discovery + JWKS<br/>HTTPS/443<br/>(when --oidc-issuer set)"| OIDCProvider["OIDC Provider<br/>(optional)"]

    %% Styling
    style KRP fill:#4a90e2,stroke:#2b6cb0,stroke-width:4px,color:#fff

    %% Required K8s
    style K8sAPI fill:#dce8f5,stroke:#4a90e2,stroke-width:2px

    %% Go libraries
    style APIServer fill:#999,stroke:#666
    style ClientGo fill:#999,stroke:#666
    style K8sAPI_lib fill:#999,stroke:#666
    style CompBase fill:#999,stroke:#666
    style GoNet fill:#999,stroke:#666
    style GoOIDC fill:#999,stroke:#666
    style Cobra fill:#999,stroke:#666

    %% Internal RHOAI
    style Operator fill:#7ed321,stroke:#5a8a3c
    style Upstream fill:#7ed321,stroke:#5a8a3c

    %% Platform
    style Prometheus fill:#f5a623,stroke:#d4881e
    style CertManager fill:#f5a623,stroke:#d4881e

    %% External optional
    style OIDCProvider fill:#fff2cc,stroke:#d6b656
