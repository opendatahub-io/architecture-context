graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy, TokenRateLimitPolicy,<br/>TelemetryPolicy CRUD +<br/>Authorino callbacks HTTPS/8443"| Kuadrant["Kuadrant / RHCL<br/>1.4.2+ / 1.3+<br/>(Required)"]
    MaaS -->|"HTTPRoute CRUD,<br/>Gateway validation"| GatewayAPI["Gateway API<br/>1.2+<br/>(Required)"]
    MaaS -->|"ServiceEntry, DestinationRule,<br/>EnvoyFilter CRUD,<br/>mTLS, ext_proc pipeline"| Istio["Istio Service Mesh<br/>(Required)"]
    MaaS -->|"API key hash storage<br/>TCP/5432 TLS"| PostgreSQL["PostgreSQL<br/>(Required)"]
    MaaS -->|"Platform runtime,<br/>service certs, OAuth,<br/>OIDC issuer"| OpenShift["OpenShift<br/>4.19.9+<br/>(Required)"]

    %% External Dependencies (Optional)
    MaaS -.->|"LLMInferenceService<br/>CRD Watch"| KServe["KServe<br/>0.15+<br/>(Optional)"]

    %% Internal ODH Dependencies
    ODHOperator["opendatahub-operator /<br/>rhods-operator"] -->|"ModelsAsService<br/>feature gate"| MaaS
    MaaS -->|"Discovers model<br/>endpoints + HTTPRoutes"| KServeLLM["KServe<br/>LLMInferenceService"]
    MaaS -->|"AuthConfig<br/>presence check"| AuthorinoConfig["Authorino<br/>(AuthConfig CRD)"]

    %% Integration Points (Consumed by)
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(future)"| MaaS

    %% External Services (Egress)
    MaaS -->|"Inference forwarding<br/>HTTPS/443 TLS 1.2+<br/>API key injection"| ExternalLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CRD CRUD, SSA,<br/>informer caches<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

    %% Observability
    Prometheus["Prometheus"] -->|"Metrics scrape<br/>9090/TCP, 8080/TCP,<br/>15090/TCP"| MaaS
    MaaS -->|"PodMonitor,<br/>ServiceMonitor,<br/>PrometheusRule"| Prometheus
    MaaS -->|"Perses Dashboards<br/>CRD CRUD"| Perses["Perses<br/>Dashboards"]

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
