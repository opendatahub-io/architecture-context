    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style KServeLLM fill:#7ed321,stroke:#333,color:#fff
    style AuthorinoConfig fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
