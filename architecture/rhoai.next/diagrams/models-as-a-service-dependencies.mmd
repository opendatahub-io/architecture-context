graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy +<br/>TokenRateLimitPolicy +<br/>TelemetryPolicy"| Kuadrant["Kuadrant / RHCL<br/>1.4.2+ / 1.3+"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"HTTPRoute routing<br/>Gateway controller"| GatewayAPI["OpenShift<br/>Gateway API v1"]
    MaaS -->|"EnvoyFilter +<br/>DestinationRule +<br/>ServiceEntry +<br/>Telemetry"| Istio["Istio / OpenShift<br/>Service Mesh"]

    %% External Dependencies (Optional)
    MaaS -.->|"LLMInferenceService<br/>model backends"| KServe["KServe v0.15+<br/>(optional)"]

    %% Internal Platform Dependencies
    ODHOperator["opendatahub-operator /<br/>rhods-operator"] -->|"DSC modelsAsService<br/>enables/disables"| MaaS
    MaaS -->|"HTTP callbacks<br/>8443/TCP HTTPS"| Authorino["Authorino"]
    MaaS -->|"ext_proc pipeline<br/>EnvoyFilter injection"| Envoy["Envoy<br/>(Gateway data plane)"]
    MaaS -.->|"Perses dashboards<br/>(optional)"| COO["Cluster Observability<br/>Operator (COO)"]

    %% External Service Integrations
    MaaS -->|"model inference<br/>443/TCP HTTPS"| ExternalLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CRD watches + SAR<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    MaaS -->|"service-ca certs<br/>webhook certs"| OpenShiftCA["OpenShift<br/>Service CA Operator"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scrape<br/>9090 + 8080/TCP"| MaaS

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required External (dark gray)
    style Kuadrant fill:#666,stroke:#333,color:#fff
    style PostgreSQL fill:#666,stroke:#333,color:#fff
    style GatewayAPI fill:#666,stroke:#333,color:#fff
    style Istio fill:#666,stroke:#333,color:#fff

    %% Optional External (light gray)
    style KServe fill:#999,stroke:#333,color:#fff

    %% Internal Platform (green)
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style Authorino fill:#7ed321,stroke:#333,color:#fff
    style Envoy fill:#7ed321,stroke:#333,color:#fff
    style COO fill:#7ed321,stroke:#333,color:#fff

    %% External Services (orange)
    style ExternalLLM fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333
    style OpenShiftCA fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
