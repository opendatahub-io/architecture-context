graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"auth policies<br/>AuthPolicy, TokenRateLimitPolicy"| Kuadrant["Kuadrant<br/>RHCL 1.3+"]
    MaaS -->|"auth engine<br/>API key + OIDC + K8s token"| Authorino["Authorino<br/>0.23.1+ (via Kuadrant)"]
    MaaS -->|"distributed rate limiting<br/>token counters"| Limitador["Limitador<br/>(via Kuadrant)"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"model serving<br/>LLMInferenceService"| KServe["KServe<br/>0.15+"]
    MaaS -->|"traffic routing<br/>Gateway, HTTPRoute"| GatewayAPI["Gateway API<br/>1.2+"]
    MaaS -->|"service mesh<br/>ServiceEntry, DestinationRule<br/>EnvoyFilter, Telemetry"| Istio["Istio"]
    MaaS -->|"platform<br/>Gateway controller, certs, Routes"| OpenShift["OpenShift<br/>4.19.9+"]

    %% Internal RHOAI Dependencies
    MaaS -->|"component enablement<br/>DataScienceCluster"| RHOAIOperator["RHOAI Operator"]
    MaaS -.->|"OIDC audience<br/>issuer URL discovery"| OSAuth["OpenShift<br/>Authentication"]
    MaaS -.->|"prerequisite check<br/>showback metrics"| UWM["User Workload<br/>Monitoring"]

    %% Integration Points (bidirectional)
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(planned)"| MaaS
    Perses["Perses"] <-.->|"dashboard deployment<br/>(graceful if missing)"| MaaS

    %% External Services
    MaaS -->|"external inference<br/>443/TCP HTTPS"| ExtLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CRD CRUD, RBAC<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>8080, 9005, 15090/TCP"| MaaS

