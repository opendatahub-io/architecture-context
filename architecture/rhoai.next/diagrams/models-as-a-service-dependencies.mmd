graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy,<br/>TokenRateLimitPolicy"| Kuadrant["Kuadrant<br/>RHCL 1.3+"]
    MaaS -->|"API key + OIDC +<br/>K8s token auth"| Authorino["Authorino<br/>0.23.1+ (via Kuadrant)"]
    MaaS -->|"Token-based<br/>rate limiting"| Limitador["Limitador<br/>(via Kuadrant)"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"LLMInferenceService<br/>model serving"| KServe["KServe<br/>0.15+"]
    MaaS -->|"Gateway, HTTPRoute<br/>traffic routing"| GatewayAPI["Gateway API<br/>1.2+"]
    MaaS -->|"ServiceEntry,<br/>DestinationRule,<br/>EnvoyFilter"| Istio["Istio<br/>(Service Mesh)"]
    MaaS -->|"Gateway controller,<br/>service-ca, Routes"| OpenShift["OpenShift<br/>4.19.9+"]

    %% Internal Platform Dependencies
    ODHOperator["ODH / RHODS Operator"] -->|"enables component<br/>(DataScienceCluster)"| MaaS
    MaaS -->|"watches status,<br/>HTTPRoute ownership"| KServeLLM["KServe<br/>LLMInferenceService"]
    MaaS -->|"validates gateway,<br/>listener hostnames"| GatewayRead["Gateway API<br/>Gateway (Read)"]
    MaaS -->|"dependency check<br/>(AuthConfig CRD)"| AuthorinoOp["Authorino Operator"]
    MaaS -->|"issuer URL<br/>discovery"| OSAuth["OpenShift<br/>Authentication"]
    MaaS -->|"showback/FinOps<br/>metrics prerequisite"| UWM["User Workload<br/>Monitoring"]

    %% External Services (Egress)
    MaaS -->|"model inference<br/>443/TCP HTTPS<br/>provider API key"| ExternalLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]

    %% Integration Points (consumed by others)
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(future)"| MaaS
    Perses["Perses Dashboards"] -.->|"observability<br/>(optional)"| MaaS
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>8080, 9005, 15090/TCP"| MaaS

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Limitador fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#000
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#466BB0,stroke:#333,color:#fff
    style OpenShift fill:#EE0000,stroke:#333,color:#fff

    %% Internal platform
    style ODHOperator fill:#7ed321,stroke:#333,color:#000
    style KServeLLM fill:#7ed321,stroke:#333,color:#000
    style GatewayRead fill:#7ed321,stroke:#333,color:#000
    style AuthorinoOp fill:#7ed321,stroke:#333,color:#000
    style OSAuth fill:#7ed321,stroke:#333,color:#000
    style UWM fill:#7ed321,stroke:#333,color:#000

    %% External services
    style ExternalLLM fill:#f39c12,stroke:#333,color:#000

    %% Consumers
    style Dashboard fill:#b8d4e3,stroke:#333,color:#000
    style Perses fill:#b8d4e3,stroke:#333,color:#000
    style Prometheus fill:#b8d4e3,stroke:#333,color:#000
