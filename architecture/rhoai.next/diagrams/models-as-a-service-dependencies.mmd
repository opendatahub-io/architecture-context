graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy +<br/>TokenRateLimitPolicy CRDs"| Kuadrant["Kuadrant<br/>1.4.2+ (ODH) /<br/>RHCL 1.3+ (RHOAI)"]
    MaaS -->|"API key hash storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"HTTPRoute + Gateway CRDs<br/>ingress routing"| GatewayAPI["Gateway API<br/>v1"]
    MaaS -->|"ServiceEntry + DestinationRule +<br/>EnvoyFilter + mTLS"| Istio["Istio /<br/>OpenShift Service Mesh"]
    MaaS -->|"LLMInferenceService CRD<br/>internal model serving"| KServe["KServe<br/>v0.15+ (odh fork)"]

    %% Internal Platform Dependencies
    ODHOperator["ODH / RHOAI Operator"] -->|"DataScienceCluster<br/>modelsasservice component"| MaaS

    %% Kuadrant sub-components
    Kuadrant --- Authorino["Authorino<br/>(Authentication)"]
    Kuadrant --- Limitador["Limitador<br/>(Rate Limiting)"]

    %% Integration Points (bidirectional)
    Authorino -->|"HTTP callbacks<br/>/internal/v1/*"| MaaS
    MaaS -->|"token quota enforcement<br/>gRPC/8081"| Limitador

    %% External Services
    MaaS -->|"model inference<br/>HTTPS/443"| ExtProviders["External Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CRD watches + CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    MaaS -->|"gateway hosting<br/>external traffic"| OSIngress["OpenShift Ingress<br/>(openshift-ingress ns)"]

    %% Observability
    Prometheus["Prometheus<br/>(User Workload Monitoring)"] -->|"PodMonitor +<br/>ServiceMonitor scrape"| MaaS
    MaaS -.->|"TelemetryPolicy +<br/>Istio Telemetry"| Observability["Observability Stack"]
    MaaS -.->|"Perses dashboards<br/>(optional, if CRD exists)"| Perses["Perses<br/>(Cluster Observability Operator)"]

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style Authorino fill:#bbb,stroke:#333
    style Limitador fill:#bbb,stroke:#333
    style ExtProviders fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style OSIngress fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Observability fill:#e8e8e8,stroke:#333
    style Perses fill:#e8e8e8,stroke:#333
