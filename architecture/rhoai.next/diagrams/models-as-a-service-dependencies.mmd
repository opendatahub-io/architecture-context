graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthN/AuthZ<br/>AuthPolicy CRD"| Kuadrant["Kuadrant 1.4.2+<br/>(RHCL 1.3+ for RHOAI)"]
    MaaS -->|"rate limiting<br/>TokenRateLimitPolicy CRD"| Kuadrant
    MaaS -->|"API key hash<br/>storage 5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"HTTPRoute, Gateway<br/>CRDs"| GatewayAPI["Gateway API v1"]
    MaaS -->|"ServiceEntry, DestinationRule<br/>EnvoyFilter, mTLS"| Istio["Istio /<br/>OpenShift Service Mesh"]
    MaaS -->|"LLMInferenceService<br/>CRD watch"| KServe["KServe v0.15+<br/>(opendatahub-io fork)"]

    %% Kuadrant sub-components
    Kuadrant --- Authorino["Authorino<br/>(AuthN/AuthZ)"]
    Kuadrant --- Limitador["Limitador<br/>(Rate Limiting)"]

    %% Internal Platform Dependencies
    ODHOperator["ODH / RHOAI<br/>Operator"] -->|"DataScienceCluster<br/>modelsasservice"| MaaS
    MaaS -.->|"Authorino HTTP<br/>callbacks 8080/TCP"| Authorino
    MaaS -.->|"token quota<br/>enforcement 8081/TCP"| Limitador
    MaaS -.->|"hosts default gateway<br/>openshift-ingress"| OpenShiftIngress["OpenShift Ingress"]

    %% External Services
    MaaS -->|"inference routing<br/>443/TCP HTTPS"| ExtProviders["External Providers<br/>OpenAI, Anthropic, etc."]
    MaaS -->|"CRD watches<br/>resource CRUD 443/TCP"| K8sAPI["Kubernetes API"]
    MaaS -->|"TokenReview<br/>SubjectAccessReview"| K8sAPI
    MaaS -.->|"service account<br/>issuer detection"| OpenShiftAuth["OpenShift Authentication<br/>(config.openshift.io)"]

    %% Observability Integration
    Prometheus["Prometheus<br/>(User Workload Monitoring)"] -.->|"PodMonitor/<br/>ServiceMonitor scrape"| MaaS
    MaaS -.->|"TelemetryPolicy<br/>dashboards (optional)"| Perses["Perses<br/>(Cluster Observability)"]

    %% Styles
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Kuadrant fill:#e74c3c,stroke:#333,color:#fff
    style Authorino fill:#c0392b,stroke:#333,color:#fff
    style Limitador fill:#c0392b,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KServe fill:#3498db,stroke:#333,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftIngress fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftAuth fill:#7ed321,stroke:#333,color:#fff
    style ExtProviders fill:#f39c12,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#666
    style Perses fill:#e8e8e8,stroke:#666
