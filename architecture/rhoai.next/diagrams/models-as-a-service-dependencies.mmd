graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy<br/>TokenRateLimitPolicy<br/>RateLimitPolicy"| Kuadrant["Kuadrant<br/>RHCL 1.3+"]
    MaaS -->|"API key validation<br/>K8s TokenReview<br/>OIDC JWT"| Authorino["Authorino<br/>0.23.1+<br/>(via Kuadrant)"]
    MaaS -->|"Token rate counting<br/>per userId"| Limitador["Limitador<br/>(via Kuadrant)"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"LLMInferenceService<br/>model serving"| KServe["KServe<br/>0.15+"]
    MaaS -->|"Gateway<br/>HTTPRoute"| GatewayAPI["Gateway API<br/>1.2+"]
    MaaS -->|"ServiceEntry<br/>DestinationRule<br/>EnvoyFilter<br/>Telemetry"| Istio["Istio<br/>(service mesh)"]
    MaaS -->|"Gateway controller<br/>serving certs<br/>Routes"| OpenShift["OpenShift<br/>4.19.9+"]

    %% Internal Platform Dependencies
    ODHOperator["ODH / RHODS Operator"] -->|"enables via<br/>DataScienceCluster CR"| MaaS
    MaaS -->|"CRD Watch<br/>model status<br/>HTTPRoute discovery"| KServeLLMISvc["KServe<br/>LLMInferenceService"]
    MaaS -->|"CRD Read<br/>listener hostnames"| GatewayResource["Gateway API<br/>Gateway Resource"]
    MaaS -->|"CRD Watch<br/>dependency check"| AuthorinoOp["Authorino Operator<br/>(AuthConfig CRD)"]
    MaaS -->|"API Read<br/>issuer URL"| OSAuth["OpenShift<br/>Authentication"]
    MaaS -.->|"ConfigMap Read<br/>prerequisite check"| UWM["User Workload<br/>Monitoring"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|"scrape metrics<br/>8080, 9005, 15090"| MaaS
    MaaS -.->|"dashboards<br/>(optional)"| Perses["Perses"]

    %% External Model Providers
    MaaS -->|"inference routing<br/>443/TCP HTTPS<br/>via ServiceEntry"| ExtProviders["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required dependencies
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Limitador fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff

    %% Internal platform dependencies
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style KServeLLMISvc fill:#7ed321,stroke:#333,color:#fff
    style GatewayResource fill:#7ed321,stroke:#333,color:#fff
    style AuthorinoOp fill:#7ed321,stroke:#333,color:#fff
    style OSAuth fill:#7ed321,stroke:#333,color:#fff
    style UWM fill:#7ed321,stroke:#333,color:#fff

    %% Monitoring
    style Prometheus fill:#e8e8e8,stroke:#333,color:#333
    style Perses fill:#e8e8e8,stroke:#333,color:#333

