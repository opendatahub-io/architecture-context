graph LR
    MaaS["MaaS Platform<br/>(maas-controller +<br/>maas-api +<br/>payload-processing)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy, TRLP,<br/>TelemetryPolicy"| Kuadrant["Kuadrant<br/>1.4.2+ (ODH)<br/>RHCL 1.3+ (RHOAI)"]
    MaaS -->|"API key storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MaaS -->|"LLMInferenceService<br/>CRD watch"| KServe["KServe<br/>v0.15.0+"]
    MaaS -->|"HTTPRoute, Gateway<br/>traffic routing"| GatewayAPI["Gateway API<br/>v1.2.1+"]
    MaaS -->|"EnvoyFilter, DestinationRule,<br/>Telemetry, ServiceEntry"| Istio["Istio"]
    MaaS -->|"GatewayClass, OAuth,<br/>OIDC discovery"| OpenShift["OpenShift<br/>4.19.9+"]

    %% External Dependencies (Optional)
    MaaS -.->|"PersesDashboard,<br/>PersesDatasource"| COO["Cluster Observability<br/>Operator (optional)"]

    %% Internal Platform Dependencies
    ODHOperator["ODH / RHOAI<br/>Operator"] -->|"DSC.modelsAsService<br/>enables/disables"| MaaS

    %% Kuadrant sub-components
    Kuadrant --- Authorino["Authorino<br/>(authentication)"]
    Kuadrant --- Limitador["Limitador<br/>(rate limiting)"]
    Authorino -->|"HTTP callback<br/>:8080/:8443"| MaaS

    %% Integration Points (consume MaaS)
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(future)"| MaaS
    Pipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>(future)"| MaaS

    %% External Services
    MaaS -->|"model inference<br/>443/TCP HTTPS"| ExtProviders["External Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CR reconciliation<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    MaaS -->|"metrics scrape"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Kuadrant fill:#e74c3c,stroke:#333,color:#fff
    style Authorino fill:#c0392b,stroke:#333,color:#fff
    style Limitador fill:#c0392b,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style KServe fill:#2ecc71,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#466bb0,stroke:#333,color:#fff
    style OpenShift fill:#ee0000,stroke:#333,color:#fff
    style COO fill:#bdc3c7,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff
