graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Gateway["llm-d Gateway<br/>(API Consumer)"]
        MetricsPipeline["llm-d Metrics Pipeline<br/>(Data Producer)"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (No Service Mesh / No mTLS)"]
        direction TB

        subgraph PredService["Service: prediction-service (LoadBalancer)"]
            PredLB["LoadBalancer<br/>80/TCP → 8001/TCP<br/>HTTP | No TLS | No Auth"]
        end

        subgraph PredPods["Prediction Server (10 replicas)"]
            PredServer["Prediction Server Pods<br/>SA: default<br/>Image: odh-latency-predictor-prediction<br/>Port: 8001/TCP (FastAPI, 8 workers)<br/>Volume: emptyDir /local_models/"]
        end

        subgraph TrainService["Service: training-service (ClusterIP + optional LoadBalancer)"]
            TrainClusterIP["ClusterIP<br/>8000/TCP → 8000/TCP<br/>HTTP | No TLS | No Auth"]
            TrainLB["LoadBalancer (optional)<br/>8080/TCP → 8000/TCP<br/>HTTP | No TLS | No Auth"]
        end

        subgraph TrainPods["Training Server (1 replica - singleton)"]
            TrainServer["Training Server Pod<br/>SA: default<br/>Image: odh-latency-predictor-training<br/>Port: 8000/TCP (FastAPI)<br/>Volume: PVC /models/"]
        end

        K8sProbes["Kubernetes<br/>Liveness & Readiness Probes"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% External flows
    Gateway -->|"HTTP/80 → 8001<br/>No TLS | No Auth<br/>POST /predict/bulk/strict"| PredLB
    MetricsPipeline -->|"HTTP/8080 → 8000<br/>No TLS | No Auth<br/>POST /add_training_data_bulk"| TrainLB

    %% Service to pod flows
    PredLB --> PredServer
    TrainClusterIP --> TrainServer
    TrainLB --> TrainServer

    %% Internal flows
    PredServer -->|"HTTP/8000<br/>No TLS | No Auth<br/>GET /model/{name}/download<br/>Model sync every 10s"| TrainClusterIP

    %% Infrastructure flows
    K8sProbes -->|"HTTP/8001<br/>GET /healthz, /readyz"| PredServer
    K8sProbes -->|"HTTP/8000<br/>GET /healthz, /readyz"| TrainServer
    Prometheus -->|"HTTP/8000<br/>GET /metrics"| TrainServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef loadbalancer fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterip fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef infra fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Gateway,MetricsPipeline external
    class PredLB,TrainLB loadbalancer
    class TrainClusterIP clusterip
    class PredServer,TrainServer pod
    class K8sProbes,Prometheus infra
