graph TB
    subgraph "RHAII Cluster Validation"
        direction TB
        subgraph "rhaii-validator (Go CLI / kubectl plugin)"
            CLI["CLI Entry Point<br/>kubectl rhaii-validate"]
            Controller["Controller<br/>Job orchestration"]
            Agent["Per-Node Agent<br/>Hardware checks via chroot /host"]
            TCPLatServer["TCP Latency Server<br/>12865/TCP"]
            TCPLatClient["TCP Latency Client"]
            CLI --> Controller
            Controller -->|"hidden 'run' subcommand"| Agent
            Controller -->|"deploys as Job pod"| TCPLatServer
            Controller -->|"deploys as Job pod"| TCPLatClient
        end

        subgraph "rhaii-validator-tools (CUDA + perftest)"
            Iperf3["iperf3<br/>5201/TCP"]
            IBWriteBW["ib_write_bw<br/>18515/TCP<br/>GPUDirect CUDA"]
            IBVPingpong["ibv_rc_pingpong<br/>18515+N/TCP"]
        end
    end

    User["Data Scientist / SRE<br/>(User Workstation)"] -->|"kubectl rhaii-validate all"| CLI

    Controller -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI["Kubernetes API Server"]
    Controller -->|"creates per-node Jobs"| Agent
    Controller -->|"creates multi-node Jobs"| Iperf3
    Controller -->|"creates RDMA Jobs"| IBWriteBW
    Controller -->|"creates pingmesh Jobs"| IBVPingpong

    Agent -->|"chroot /host"| HostFS["Host Filesystem<br/>nvidia-smi / rocm-smi<br/>sysfs / PCIe topology"]

    Controller -->|"stores results"| ConfigMap["ConfigMap<br/>JSON Reports"]

    subgraph "Platform Auto-Detection"
        OCP["OpenShift (OCP)"]
        AKS["Azure (AKS)"]
        EKS["AWS (EKS)"]
        CW["CoreWeave"]
    end

    Controller -->|"detects from node labels"| OCP
    Controller -->|"detects from node labels"| AKS
    Controller -->|"detects from node labels"| EKS
    Controller -->|"detects from node labels"| CW

    %% Styling
    style CLI fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Agent fill:#4a90e2,stroke:#333,color:#fff
    style TCPLatServer fill:#4a90e2,stroke:#333,color:#fff
    style TCPLatClient fill:#4a90e2,stroke:#333,color:#fff
    style Iperf3 fill:#7b68ee,stroke:#333,color:#fff
    style IBWriteBW fill:#7b68ee,stroke:#333,color:#fff
    style IBVPingpong fill:#7b68ee,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style HostFS fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style User fill:#d5e8d4,stroke:#82b366
    style OCP fill:#e8e8e8,stroke:#333
    style AKS fill:#e8e8e8,stroke:#333
    style EKS fill:#e8e8e8,stroke:#333
    style CW fill:#e8e8e8,stroke:#333
