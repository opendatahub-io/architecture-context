graph TB
    subgraph "RHAII Cluster Validation"
        direction TB

        subgraph "CLI Layer"
            CLI["rhaii-validator CLI<br/>(kubectl plugin)"]
        end

        subgraph "Orchestration Layer"
            Controller["controller<br/>Validation lifecycle orchestrator"]
            JobRunner["jobrunner<br/>Multi-node test scheduler"]
            Config["config<br/>Platform detection &amp; config"]
        end

        subgraph "Check Modules"
            CRDCheck["checks/crd<br/>CRD presence"]
            OperatorCheck["checks/operator<br/>Operator health"]
            GPUCheck["checks/gpu<br/>Driver &amp; ECC"]
            RDMACheck["checks/rdma<br/>Devices &amp; topology"]
            NetCheck["checks/networking<br/>TCP bandwidth"]
        end
    end

    subgraph "Container Images"
        ValidatorImage["rhaii-validator<br/>(Go binary)"]
        ToolsImage["rhaii-validator-tools<br/>(perftest + iperf3 + CUDA)"]
    end

    subgraph "Kubernetes Resources (Ephemeral)"
        NodeJob["Node Check Job<br/>(privileged, per GPU node)"]
        IperfServer["iperf3 Server Job<br/>5201/TCP"]
        IperfClient["iperf3 Client Job"]
        RDMAServer["ib_write_bw Server Job<br/>18515/TCP"]
        RDMAClient["ib_write_bw Client Job"]
        PingServer["ibv_rc_pingpong Server"]
        PingClient["ibv_rc_pingpong Client"]
        ReportCM["ConfigMap<br/>rhaii-validate-report"]
    end

    CLI -->|subcommands| Controller
    Controller -->|delegates| JobRunner
    Controller -->|reads| Config
    Controller -->|runs| CRDCheck
    Controller -->|runs| OperatorCheck
    Controller -->|deploys| NodeJob
    JobRunner -->|schedules| IperfServer
    JobRunner -->|schedules| IperfClient
    JobRunner -->|schedules| RDMAServer
    JobRunner -->|schedules| RDMAClient
    JobRunner -->|schedules| PingServer
    JobRunner -->|schedules| PingClient

    NodeJob -->|runs| GPUCheck
    NodeJob -->|runs| RDMACheck
    NodeJob -->|uses| ValidatorImage

    IperfServer -->|uses| ToolsImage
    IperfClient -->|uses| ToolsImage
    RDMAServer -->|uses| ToolsImage
    RDMAClient -->|uses| ToolsImage
    PingServer -->|uses| ToolsImage
    PingClient -->|uses| ToolsImage

    IperfClient -->|5201/TCP| IperfServer
    RDMAClient -->|18515/TCP RDMA| RDMAServer
    PingClient -->|dynamic RDMA RC| PingServer

    Controller -->|stores results| ReportCM

