graph TB
    subgraph "vLLM CUDA Runtime Container"
        subgraph "RHAIIS Base Image (vllm-cuda-rhel9)"
            vLLMEngine["vLLM Inference Engine<br/>Port 8000/TCP HTTP"]
            TGISAdapter["vllm_tgis_adapter<br/>Port 8033/TCP gRPC"]
            CUDARuntime["CUDA Runtime"]
            PythonEnv["Python Environment"]
        end

        TGISAdapter -->|"HTTP/8000<br/>(localhost)"| vLLMEngine
        vLLMEngine --> CUDARuntime
        vLLMEngine --> PythonEnv
    end

    subgraph "APIs Exposed"
        HTTPEndpoints["HTTP API (OpenAI-compatible)<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/health"]
        GRPCEndpoint["gRPC API (TGIS)<br/>GenerationService"]
    end

    HTTPEndpoints -->|"8000/TCP"| vLLMEngine
    GRPCEndpoint -->|"8033/TCP"| TGISAdapter

    Client["Client / Application"] -->|"HTTPS/443<br/>via KServe Gateway"| HTTPEndpoints
    Client -->|"HTTPS/443<br/>via KServe Gateway"| GRPCEndpoint

    subgraph "Platform Integration"
        KServe["KServe<br/>ServingRuntime"]
        Istio["Istio Service Mesh<br/>mTLS Sidecar"]
        GPU["NVIDIA GPU<br/>Device Plugin"]
    end

    KServe -->|"deploys"| vLLMEngine
    Istio -->|"sidecar injection<br/>mTLS"| vLLMEngine
    GPU -->|"nvidia.com/gpu<br/>resource allocation"| CUDARuntime

    subgraph "Model Storage"
        S3["S3 / Object Storage<br/>443/TCP HTTPS"]
        PVC["PVC<br/>Filesystem"]
        HuggingFace["Hugging Face Hub<br/>443/TCP HTTPS"]
    end

    vLLMEngine -->|"model loading<br/>at startup"| S3
    vLLMEngine -->|"model loading<br/>at startup"| PVC
    vLLMEngine -->|"model/tokenizer<br/>download"| HuggingFace

    subgraph "Build Infrastructure"
        Konflux["Konflux Build System"]
        KonfluxCentral["konflux-central<br/>Shared Pipelines"]
        RHAIISBase["RHAIIS Base Image<br/>registry.redhat.io/rhaiis/vllm-cuda-rhel9:3.2.2"]
    end

    Konflux -->|"multi-arch build<br/>amd64/arm64"| vLLMEngine
    KonfluxCentral -->|"pipeline definitions<br/>.tekton/ sync"| Konflux
    RHAIISBase -->|"FROM base"| vLLMEngine

    style vLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style CUDARuntime fill:#4a90e2,stroke:#333,color:#fff
    style PythonEnv fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style GPU fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style KonfluxCentral fill:#999,stroke:#333,color:#fff
    style RHAIISBase fill:#999,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
