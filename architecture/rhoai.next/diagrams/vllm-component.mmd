graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Platform["RHOAI Platform Layer"]
        Gateway["Platform Ingress<br/>(Gateway API / Istio)<br/>443/TCP HTTPS"]
        KServe["KServe Controller"]
        ServingRuntime["ServingRuntime CR"]
        InferenceService["InferenceService CR"]
    end

    subgraph Pod["KServe-Managed Pod"]
        KRBP["kube-rbac-proxy<br/>Sidecar<br/>8443/TCP HTTPS"]

        subgraph VLLMContainer["odh-vllm-cuda-rhel9 Container"]
            TGISAdapter["TGIS Adapter<br/>(vllm_tgis_adapter)<br/>Entrypoint"]
            VLLMEngine["vLLM Inference Engine<br/>(inherited from RHAIIS base)"]
            OpenAI_API["OpenAI-Compatible API<br/>8000/TCP HTTP"]
            TGIS_gRPC["TGIS gRPC Service<br/>8033/TCP gRPC"]
            Metrics["/metrics Endpoint<br/>8000/TCP HTTP"]

            TGISAdapter --> VLLMEngine
            TGISAdapter --> OpenAI_API
            TGISAdapter --> TGIS_gRPC
            VLLMEngine --> OpenAI_API
        end
    end

    subgraph ExternalServices["External Services"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        GPU["NVIDIA GPU<br/>CUDA API"]
    end

    subgraph Storage["Model Storage"]
        PVC["PVC Volume Mount"]
    end

    %% Platform flows
    Client -->|HTTPS/443| Gateway
    Gateway -->|HTTPS/8443| KRBP
    KRBP -->|HTTP/8000| OpenAI_API
    KRBP -->|gRPC/8033| TGIS_gRPC

    %% KServe management
    KServe -->|manages| InferenceService
    InferenceService -->|references| ServingRuntime
    ServingRuntime -->|deploys| VLLMContainer

    %% External dependencies
    VLLMEngine -->|model download| HFHub
    VLLMEngine -->|model download| S3
    VLLMEngine -->|inference compute| GPU
    VLLMEngine -->|model weights| PVC

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes /metrics| Metrics

    %% Styling
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style OpenAI_API fill:#5bb5f0,stroke:#333
    style TGIS_gRPC fill:#5bb5f0,stroke:#333
    style KRBP fill:#f5a623,stroke:#333
    style Gateway fill:#f5a623,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style GPU fill:#e74c3c,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style InferenceService fill:#f5d76e,stroke:#333
    style ServingRuntime fill:#f5d76e,stroke:#333
