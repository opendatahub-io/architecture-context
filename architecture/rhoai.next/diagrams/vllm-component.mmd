graph TB
    subgraph "vLLM CUDA Container"
        direction TB
        VLLMEngine["vLLM Engine<br/>(Python/C++ LLM Inference)"]
        TGISAdapter["vllm_tgis_adapter<br/>(gRPC Entry Point)"]
        HTTPServer["vLLM HTTP Server<br/>Port 8000/TCP"]
        GRPCServer["TGIS gRPC Server<br/>Port 8033/TCP"]
        CUDA["NVIDIA CUDA Runtime"]

        TGISAdapter -->|"in-process"| VLLMEngine
        HTTPServer -->|"native API"| VLLMEngine
        GRPCServer -->|"adapter"| TGISAdapter
        VLLMEngine -->|"GPU compute"| CUDA
    end

    subgraph "Platform Layer (KServe / RHOAI)"
        KServe["KServe Controller"]
        ServingRuntime["ServingRuntime CR"]
        InferenceService["InferenceService CR"]
        KubeRBACProxy["kube-rbac-proxy<br/>Sidecar 8443/TCP"]
        Gateway["RHOAI Gateway<br/>443/TCP HTTPS"]
    end

    subgraph "External Services"
        S3["S3 / Object Storage"]
        HFHub["Hugging Face Hub"]
    end

    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8000<br/>localhost"| HTTPServer
    KubeRBACProxy -->|"gRPC/8033<br/>localhost"| GRPCServer

    KServe -->|"manages"| InferenceService
    InferenceService -->|"references"| ServingRuntime
    ServingRuntime -->|"specifies image"| VLLMEngine

    VLLMEngine -->|"model download<br/>HTTPS/443"| S3
    VLLMEngine -->|"model download<br/>HTTPS/443"| HFHub

    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTP/8000"| HTTPServer

    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style CUDA fill:#76b900,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#f5a623,stroke:#333,color:#fff
    style InferenceService fill:#f5a623,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style HFHub fill:#ffd21e,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
