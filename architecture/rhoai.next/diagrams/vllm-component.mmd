graph TB
    subgraph "vLLM CUDA Container Image"
        direction TB
        Adapter["vllm_tgis_adapter<br/>(Entry Point)"]
        VLLMEngine["vLLM Inference Engine<br/>(Upstream Python/C++)"]
        CUDA["NVIDIA CUDA Runtime"]

        Adapter -->|"in-process Python"| VLLMEngine
        VLLMEngine -->|"CUDA compute"| CUDA
    end

    subgraph "Platform Layer (KServe / RHOAI)"
        direction TB
        KServe["KServe Controller"]
        ServingRuntime["ServingRuntime CR"]
        InferenceService["InferenceService CR"]
        KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"]
        Gateway["RHOAI Gateway<br/>(HTTPRoute)"]
    end

    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTPS/443<br/>TLS 1.2+"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8000<br/>localhost"| Adapter
    KubeRBACProxy -->|"gRPC/8033<br/>localhost"| Adapter

    KServe -->|"manages"| InferenceService
    InferenceService -->|"references"| ServingRuntime
    ServingRuntime -->|"specifies image"| Adapter

    Adapter -->|"OpenAI API<br/>HTTP/8000"| HTTPPort["Port 8000/TCP<br/>OpenAI-compatible API"]
    Adapter -->|"TGIS gRPC<br/>gRPC/8033"| GRPCPort["Port 8033/TCP<br/>TGIS GenerationService"]

    VLLMEngine -->|"HTTPS/443"| S3["S3 / Object Storage<br/>Model Weights"]
    VLLMEngine -->|"HTTPS/443"| HFHub["Hugging Face Hub<br/>(Optional)"]

    Prometheus["Prometheus"] -->|"HTTP scrape<br/>8000/TCP"| Adapter

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style CUDA fill:#76b900,stroke:#333,color:#fff
    style KubeRBACProxy fill:#f5a623,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333
    style InferenceService fill:#7ed321,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style HTTPPort fill:#dae8fc,stroke:#6c8ebf
    style GRPCPort fill:#dae8fc,stroke:#6c8ebf
