graph TB
    subgraph "vLLM CUDA Runtime Container"
        direction TB
        subgraph "RHAIIS Base Image (vllm-cuda-rhel9:3.2.2)"
            VLLMEngine["vLLM Inference Engine<br/>Port 8000/TCP HTTP"]
            TGISAdapter["vllm_tgis_adapter<br/>Port 8033/TCP gRPC"]
            CUDARuntime["CUDA Runtime"]
            PythonEnv["Python Environment"]
        end
        TGISAdapter -->|"HTTP localhost:8000"| VLLMEngine
        VLLMEngine -->|"CUDA calls"| CUDARuntime
    end

    subgraph "KServe Infrastructure"
        ServingRuntime["KServe ServingRuntime CR"]
        InferenceService["KServe InferenceService CR"]
        KServeGateway["KServe Gateway"]
    end

    subgraph "Service Mesh"
        IstioSidecar["Istio Sidecar<br/>mTLS"]
    end

    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token / OAuth"| KServeGateway
    KServeGateway -->|"HTTP/8000 or gRPC/8033<br/>mTLS"| IstioSidecar
    IstioSidecar -->|"HTTP/8000<br/>localhost"| VLLMEngine
    IstioSidecar -->|"gRPC/8033<br/>localhost"| TGISAdapter

    ServingRuntime -->|"references image"| VLLMEngine
    InferenceService -->|"creates pod"| ServingRuntime

    VLLMEngine -->|"loads model"| ModelStorage["Model Storage<br/>(S3 / PVC)"]
    VLLMEngine -->|"GPU memory"| GPU["NVIDIA GPU<br/>nvidia.com/gpu"]

    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style CUDARuntime fill:#6c7ae0,stroke:#333,color:#fff
    style PythonEnv fill:#6c7ae0,stroke:#333,color:#fff
    style KServeGateway fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333,color:#fff
    style InferenceService fill:#7ed321,stroke:#333,color:#fff
    style IstioSidecar fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
    style GPU fill:#e8e8e8,stroke:#333
