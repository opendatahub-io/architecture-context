graph TB
    subgraph "vLLM CUDA Runtime"
        direction TB
        TGISAdapter["vllm_tgis_adapter<br/>(Python Entrypoint)"]
        VLLMEngine["vLLM Serving Engine<br/>PagedAttention / Continuous Batching"]
        OpenAIAPI["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        TGISGRPC["TGIS gRPC Service<br/>Port 8033/TCP"]

        TGISAdapter --> VLLMEngine
        TGISAdapter --> OpenAIAPI
        TGISAdapter --> TGISGRPC
        VLLMEngine --> GPU["NVIDIA CUDA<br/>GPU Compute"]
    end

    subgraph "Container Image Layers"
        direction TB
        BaseImage["rhaiis/vllm-cuda-rhel9:3.2.2<br/>(RHAIIS Base Image)<br/>Python, CUDA, vLLM, TGIS Adapter"]
        ConfigLayer["odh-vllm-cuda-rhel9<br/>(Config Layer)<br/>ENV, USER 2000, ENTRYPOINT"]
        BaseImage --> ConfigLayer
    end

    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway["RHOAI Gateway<br/>kube-rbac-proxy / Gateway API"] -->|"HTTP/8000"| OpenAIAPI
    InternalSvc["Internal Service"] -->|"gRPC/8033"| TGISGRPC

    KServe["KServe Operator"] -->|"manages via<br/>ServingRuntime CR"| TGISAdapter
    ModelStorage["Model Storage<br/>(S3 / HuggingFace / PVC)"] -.->|"HTTPS/443<br/>Model Weights"| VLLMEngine

    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style OpenAIAPI fill:#50c878,stroke:#333,color:#fff
    style TGISGRPC fill:#50c878,stroke:#333,color:#fff
    style GPU fill:#f5a623,stroke:#333,color:#fff
    style BaseImage fill:#9b59b6,stroke:#333,color:#fff
    style ConfigLayer fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style InternalSvc fill:#f9f9f9,stroke:#999
