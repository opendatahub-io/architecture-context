graph TB
    subgraph "vLLM Inference Pod"
        direction TB
        subgraph "kube-rbac-proxy Sidecar"
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>JWT Auth Enforcement"]
        end

        subgraph "vLLM Container (odh-vllm-cuda-rhel9)"
            TGIS["vllm_tgis_adapter<br/>(Entrypoint)"]
            OpenAI["OpenAI-Compatible API<br/>8000/TCP HTTP"]
            TGISgRPC["TGIS gRPC Service<br/>8033/TCP gRPC"]
            Metrics["Prometheus Metrics<br/>/metrics on 8000"]
            Health["Health Check<br/>/health on 8000"]
            VLLMEngine["vLLM Engine<br/>(from RHAIIS base image)"]
            TGIS --> OpenAI
            TGIS --> TGISgRPC
            OpenAI --> VLLMEngine
            TGISgRPC --> VLLMEngine
        end

        KRBP -->|"HTTP 8000<br/>pre-authenticated"| OpenAI
        KRBP -->|"gRPC 8033<br/>pre-authenticated"| TGISgRPC
    end

    GPU["NVIDIA GPU<br/>CUDA 12.x+"]
    VLLMEngine -->|"CUDA API"| GPU

    Client["Client / KServe Router"] -->|"HTTPS 8443<br/>Bearer Token JWT"| KRBP

    subgraph "Model Sources"
        PVC["PVC Volume Mount"]
        S3["S3 / MinIO<br/>443/TCP HTTPS"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS"]
    end

    VLLMEngine -.->|"filesystem"| PVC
    VLLMEngine -.->|"HTTPS 443<br/>IAM / HMAC"| S3
    VLLMEngine -.->|"HTTPS 443<br/>HF_TOKEN"| HF

    KServe["KServe Controller"] -->|"deploys via<br/>InferenceService CR"| TGIS
    ServingRuntime["KServe ServingRuntime CR"] -->|"configures args,<br/>resources, model format"| TGIS

    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -.->|"scrape /metrics<br/>8000/TCP HTTP"| Metrics

    style KRBP fill:#e8a838,stroke:#333,stroke-width:2px
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:2px
    style OpenAI fill:#4a90e2,stroke:#333,stroke-width:1px
    style TGISgRPC fill:#4a90e2,stroke:#333,stroke-width:1px
    style VLLMEngine fill:#4a90e2,stroke:#333,stroke-width:1px
    style GPU fill:#76b900,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:1px
    style ServingRuntime fill:#7ed321,stroke:#333,stroke-width:1px
    style PVC fill:#f5a623,stroke:#333,stroke-width:1px
    style S3 fill:#f5a623,stroke:#333,stroke-width:1px
    style HF fill:#f5a623,stroke:#333,stroke-width:1px
    style Prometheus fill:#999,stroke:#333,stroke-width:1px
    style Client fill:#f9f9f9,stroke:#333,stroke-width:1px
    style Metrics fill:#4a90e2,stroke:#333,stroke-width:1px
    style Health fill:#4a90e2,stroke:#333,stroke-width:1px
