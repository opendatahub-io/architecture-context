graph TB
    subgraph External["External Client"]
        Client[Client Application]
    end

    subgraph KServeGW["KServe Gateway"]
        Gateway["KServe Gateway<br/>443/TCP HTTPS"]
    end

    subgraph IstioMesh["Istio Service Mesh (mTLS)"]
        Sidecar["Istio Sidecar<br/>mTLS Proxy"]
    end

    subgraph vLLMPod["vLLM Inference Pod (User: 2000)"]
        TGISAdapter["vllm_tgis_adapter<br/>gRPC Server<br/>Port 8033/TCP"]
        vLLMEngine["vLLM Inference Engine<br/>HTTP Server<br/>Port 8000/TCP"]
        TGISAdapter -->|"HTTP localhost"| vLLMEngine
    end

    subgraph BaseImage["RHAIIS Base Image"]
        RHAIISImage["registry.redhat.io/rhaiis/<br/>vllm-cuda-rhel9:3.2.2<br/>(vLLM + CUDA + Python + TGIS adapter)"]
    end

    subgraph GPUHardware["GPU Hardware"]
        GPU["NVIDIA GPU<br/>CUDA-compatible"]
    end

    subgraph Storage["Model Storage"]
        S3["S3 / PVC<br/>Model Weights"]
        HuggingFace["Hugging Face Hub<br/>443/TCP HTTPS"]
    end

    Client -->|"HTTPS/443<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTP/8000 or gRPC/8033<br/>mTLS"| Sidecar
    Sidecar -->|"HTTP/8000"| vLLMEngine
    Sidecar -->|"gRPC/8033"| TGISAdapter
    vLLMEngine -->|"CUDA"| GPU
    vLLMEngine -->|"Model download<br/>HTTPS or filesystem"| S3
    vLLMEngine -->|"Model download<br/>HTTPS/443"| HuggingFace
    RHAIISImage -.->|"provides runtime"| vLLMPod

    %% KServe Integration
    KServeCR["KServe ServingRuntime CR"] -.->|"references image"| vLLMPod
    InferenceService["InferenceService CR"] -.->|"triggers deployment"| vLLMPod

    style vLLMEngine fill:#4a90e2,stroke:#333,stroke-width:2px
    style TGISAdapter fill:#4a90e2,stroke:#333,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style GPU fill:#e6b8af,stroke:#cc0000,stroke-width:2px
    style RHAIISImage fill:#f5a623,stroke:#333,stroke-width:2px
    style S3 fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style HuggingFace fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style KServeCR fill:#e8e8e8,stroke:#999,stroke-dasharray:5 5
    style InferenceService fill:#e8e8e8,stroke:#999,stroke-dasharray:5 5
