graph TB
    subgraph NotebooksDownstream["Notebooks (Workbench Images)"]
        direction TB

        subgraph JupyterImages["Jupyter Workbenches"]
            JupMin["Jupyter Minimal<br/>UBI9 Python 3.11/3.12<br/>JupyterLab 4.2<br/>Port: 8888/TCP"]
            JupDS["Jupyter Data Science<br/>pandas, scikit-learn, boto3<br/>MongoDB CLI, Elyra"]
            JupPT["Jupyter PyTorch (CUDA)<br/>PyTorch + CUDA 12.6.3"]
            JupTF["Jupyter TensorFlow (CUDA)<br/>TensorFlow + CUDA 12.6.3"]
            JupTAI["Jupyter TrustyAI<br/>Explainability + Java 17"]
            JupROCmPT["Jupyter ROCm PyTorch<br/>PyTorch + ROCm 6.2.4"]
            JupROCmTF["Jupyter ROCm TensorFlow<br/>TensorFlow + ROCm 6.2.4"]

            JupMin -->|extends| JupDS
            JupDS -->|extends| JupPT
            JupDS -->|extends| JupTF
            JupDS -->|extends| JupTAI
            JupDS -->|extends| JupROCmPT
            JupDS -->|extends| JupROCmTF
        end

        subgraph AltWorkbenches["Alternative Workbenches"]
            CodeServer["Code Server<br/>code-server 4.98<br/>NGINX 1.24 proxy<br/>Port: 8585/TCP"]
            RStudioC9S["RStudio (C9S)<br/>R 4.4.3<br/>Port: 8585/TCP"]
            RStudioRHEL["RStudio (RHEL9)<br/>R 4.4.3<br/>Port: 8585/TCP"]
            RStudioCUDA["RStudio CUDA<br/>R 4.4.3 + CUDA<br/>Port: 8585/TCP"]
        end

        subgraph RuntimeImages["Pipeline Runtimes"]
            RTMin["Runtime Minimal<br/>Python only"]
            RTDS["Runtime Data Science<br/>science libraries"]
            RTPT["Runtime PyTorch CUDA"]
            RTTF["Runtime TensorFlow CUDA"]
            RTROCmPT["Runtime ROCm PyTorch"]
            RTROCmTF["Runtime ROCm TensorFlow"]

            RTMin -->|extends| RTDS
            RTDS -->|extends| RTPT
            RTDS -->|extends| RTTF
            RTDS -->|extends| RTROCmPT
            RTDS -->|extends| RTROCmTF
        end

        subgraph BuildSystem["Build & Manifests"]
            Manifests["ImageStream Manifests<br/>kustomize base + overlays"]
            TektonPipelines["Tekton PipelineRuns<br/>.tekton/ directory"]
            Sandbox["sandbox.py + buildinputs<br/>Isolated build contexts"]
        end
    end

    %% External consumers
    User["Data Scientist / Developer"]
    Dashboard["RHOAI Dashboard"]
    NotebookController["odh-notebook-controller"]
    RHODSOp["rhods-operator"]
    KFP["Kubeflow Pipelines"]
    Konflux["Konflux CI"]

    %% Interactions
    User -->|selects workbench| Dashboard
    Dashboard -->|reads annotations| Manifests
    RHODSOp -->|deploys| Manifests
    NotebookController -->|creates StatefulSet with| JupMin
    NotebookController -->|creates StatefulSet with| JupDS
    NotebookController -->|creates StatefulSet with| CodeServer
    NotebookController -->|creates StatefulSet with| RStudioC9S
    KFP -->|runs pipeline steps with| RTMin
    KFP -->|runs pipeline steps with| RTDS
    Konflux -->|builds via| TektonPipelines
    TektonPipelines -->|uses| Sandbox

