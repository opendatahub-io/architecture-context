graph TB
    subgraph NotebooksDownstream["Notebooks-Downstream (Workbench Images)"]
        direction TB

        subgraph JupyterImages["Jupyter Notebook Images"]
            JupMinCPU["Jupyter Minimal<br/>CPU<br/>Py 3.11/3.12"]
            JupDS["Jupyter Data Science<br/>CPU<br/>Py 3.11/3.12"]
            JupPyTorchCUDA["Jupyter PyTorch<br/>CUDA 12.6.3<br/>Py 3.11/3.12"]
            JupTFCUDA["Jupyter TensorFlow<br/>CUDA 12.6.3<br/>Py 3.11/3.12"]
            JupTrustYAI["Jupyter TrustYAI<br/>CPU + Java 17<br/>Py 3.11/3.12"]
            JupMinCUDA["Jupyter Minimal<br/>CUDA 12.6.3<br/>Py 3.11/3.12"]
            JupMinROCm["Jupyter Minimal<br/>ROCm 6.2.4<br/>Py 3.11/3.12"]
            JupPyTorchROCm["Jupyter PyTorch<br/>ROCm 6.2.4<br/>Py 3.11/3.12"]
            JupTFROCm["Jupyter TensorFlow<br/>ROCm 6.2.4<br/>Py 3.11/3.12"]
        end

        subgraph CodeServerImages["Code Server Images"]
            CodeServer["Code Server<br/>v4.98.0 + NGINX<br/>Py 3.11/3.12"]
        end

        subgraph RStudioImages["RStudio Server Images"]
            RStudioC9S["RStudio Server<br/>C9S CPU<br/>R 4.4.3"]
            RStudioC9SCUDA["RStudio Server<br/>C9S CUDA"]
            RStudioRHEL9["RStudio Server<br/>RHEL9 CPU"]
            RStudioRHEL9CUDA["RStudio Server<br/>RHEL9 CUDA"]
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            RTMinimal["Runtime Minimal<br/>CPU<br/>Py 3.11/3.12"]
            RTDataSci["Runtime Data Science<br/>CPU<br/>Py 3.11/3.12"]
            RTPyTorchCUDA["Runtime PyTorch<br/>CUDA<br/>Py 3.11/3.12"]
            RTTFCuda["Runtime TensorFlow<br/>CUDA<br/>Py 3.11/3.12"]
            RTPyTorchROCm["Runtime PyTorch<br/>ROCm<br/>Py 3.11/3.12"]
            RTTFROCm["Runtime TensorFlow<br/>ROCm<br/>Py 3.11/3.12"]
        end

        subgraph BuildSystem["Build System"]
            Makefile["Makefile<br/>Build Orchestration"]
            Konflux["Tekton/Konflux<br/>CI/CD Pipelines"]
            GoHelpers["Go Build Helpers<br/>Dependency Analysis"]
        end
    end

    %% Image layering relationships
    JupMinCPU -->|extends| JupDS
    JupDS -->|extends| JupPyTorchCUDA
    JupDS -->|extends| JupTFCUDA
    JupDS -->|extends| JupTrustYAI
    JupMinCUDA -->|extends| JupPyTorchCUDA
    JupMinROCm -->|extends| JupPyTorchROCm
    JupMinROCm -->|extends| JupTFROCm

    %% Platform consumers
    NotebookController["ODH Notebook Controller"]
    Dashboard["RHOAI Dashboard"]
    RhodsOperator["rhods-operator"]
    DSPipelines["Data Science Pipelines<br/>(Elyra)"]

    NotebookController -->|launches as StatefulSets| JupyterImages
    NotebookController -->|launches as StatefulSets| CodeServerImages
    NotebookController -->|launches as StatefulSets| RStudioImages
    Dashboard -->|reads ImageStream annotations| NotebooksDownstream
    RhodsOperator -->|applies kustomize manifests| NotebooksDownstream
    DSPipelines -->|executes pipeline steps| RuntimeImages

    %% Build outputs
    Konflux -->|builds & pushes| QuayRegistry["quay.io/modh<br/>Container Registry"]

    %% Styling
    style NotebooksDownstream fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterImages fill:#dcedc8,stroke:#689f38,stroke-width:1px
    style CodeServerImages fill:#fff3e0,stroke:#ef6c00,stroke-width:1px
    style RStudioImages fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style RuntimeImages fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style BuildSystem fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px

    style NotebookController fill:#4a90e2,color:#fff
    style Dashboard fill:#4a90e2,color:#fff
    style RhodsOperator fill:#4a90e2,color:#fff
    style DSPipelines fill:#4a90e2,color:#fff
    style QuayRegistry fill:#f5a623,stroke:#333
