    style JupyterMinimal fill:#4a90e2,stroke:#333,color:#fff
    style JupyterDS fill:#4a90e2,stroke:#333,color:#fff
    style JupyterPyTorch fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTF fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTrustyAI fill:#4a90e2,stroke:#333,color:#fff
    style CodeServer fill:#7ed321,stroke:#333,color:#fff
    style RStudio fill:#7ed321,stroke:#333,color:#fff
    style RuntimeMinimal fill:#f5a623,stroke:#333,color:#fff
    style RuntimeDS fill:#f5a623,stroke:#333,color:#fff
    style RuntimePyTorch fill:#f5a623,stroke:#333,color:#fff
    style RuntimeTF fill:#f5a623,stroke:#333,color:#fff
    style CUDABase fill:#76b900,stroke:#333,color:#fff
    style ROCmBase fill:#ed1c24,stroke:#333,color:#fff
