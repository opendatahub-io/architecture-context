graph TB
    subgraph NotebooksDownstream["notebooks-downstream (Container Image Factory)"]
        direction TB

        subgraph JupyterImages["Jupyter Workbench Images"]
            JupyterMinimal["Jupyter Minimal<br/>UBI9 Python 3.11/3.12<br/>Port: 8888/TCP"]
            JupyterDS["Jupyter Data Science<br/>NumPy, Pandas, Scikit-learn<br/>Port: 8888/TCP"]
            JupyterPyTorch["Jupyter PyTorch<br/>PyTorch 2.6 + CUDA 12.6<br/>Port: 8888/TCP"]
            JupyterTF["Jupyter TensorFlow<br/>TensorFlow + CUDA 12.6<br/>Port: 8888/TCP"]
            JupyterTrustyAI["Jupyter TrustyAI<br/>AI Fairness + Java 17<br/>Port: 8888/TCP"]
            JupyterROCmPT["Jupyter ROCm PyTorch<br/>ROCm 6.2 + PyTorch<br/>Port: 8888/TCP"]
            JupyterROCmTF["Jupyter ROCm TensorFlow<br/>ROCm 6.2 + TensorFlow<br/>Port: 8888/TCP"]
        end

        subgraph AltWorkbenches["Alternative Workbench Images"]
            CodeServer["Code Server<br/>VS Code (code-server 4.98)<br/>nginx reverse proxy<br/>Port: 8585/TCP"]
            RStudio["RStudio Server<br/>R 4.4 + Python 3.11<br/>nginx reverse proxy<br/>Port: 8787/TCP"]
        end

        subgraph RuntimeImages["Elyra Runtime Images"]
            RuntimeMinimal["Runtime Minimal<br/>Port: 8080/TCP"]
            RuntimeDS["Runtime Data Science<br/>Port: 8080/TCP"]
            RuntimePyTorch["Runtime PyTorch CUDA<br/>Port: 8080/TCP"]
            RuntimeTF["Runtime TensorFlow CUDA<br/>Port: 8080/TCP"]
            RuntimeROCmPT["Runtime ROCm PyTorch<br/>Port: 8080/TCP"]
            RuntimeROCmTF["Runtime ROCm TensorFlow<br/>Port: 8080/TCP"]
        end

        subgraph BuildInfra["Build Infrastructure"]
            Makefile["Makefile<br/>Build orchestration"]
            Sandbox["sandbox.py<br/>Build context isolation"]
            BuildInputs["buildinputs (Go)<br/>Dockerfile static analysis"]
            KustomizeManifests["Kustomize Manifests<br/>ImageStreams + BuildConfigs"]
            TektonPipelines["Tekton/Konflux Pipelines<br/>Multi-arch CI/CD"]
        end
    end

    %% Image layering
    JupyterMinimal -->|extends| JupyterDS
    JupyterDS -->|extends| JupyterPyTorch
    JupyterDS -->|extends| JupyterTF
    JupyterDS -->|extends| JupyterTrustyAI
    JupyterDS -->|extends| JupyterROCmPT
    JupyterDS -->|extends| JupyterROCmTF

    %% Build tooling relationships
    Makefile -->|invokes| Sandbox
    Sandbox -->|uses| BuildInputs
    BuildInputs -->|analyzes| JupyterMinimal
    TektonPipelines -->|builds| JupyterImages
    TektonPipelines -->|builds| AltWorkbenches
    TektonPipelines -->|builds| RuntimeImages

    %% External consumers
    NotebookController["odh-notebook-controller<br/>(deploys as StatefulSets)"]
    Dashboard["RHOAI Dashboard<br/>(image selector UI)"]
    Operator["rhods-operator<br/>(deploys ImageStreams)"]
    Elyra["Elyra Pipeline Engine<br/>(executes runtime images)"]

    KustomizeManifests -->|ImageStream manifests| Operator
    Operator -->|deploys| NotebookController
    NotebookController -->|deploys workbenches| JupyterImages
    NotebookController -->|deploys workbenches| AltWorkbenches
    Dashboard -->|reads annotations| KustomizeManifests
    Elyra -->|executes nodes| RuntimeImages

    %% Registries
    QuayODH["quay.io/opendatahub<br/>(upstream)"]
    QuayMODH["quay.io/modh<br/>(downstream)"]

    TektonPipelines -->|publishes| QuayODH
    TektonPipelines -->|publishes| QuayMODH

    %% Styling
    style NotebooksDownstream fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterImages fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style AltWorkbenches fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style RuntimeImages fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style BuildInfra fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style NotebookController fill:#dae8fc,stroke:#6c8ebf
    style Dashboard fill:#dae8fc,stroke:#6c8ebf
    style Operator fill:#dae8fc,stroke:#6c8ebf
    style Elyra fill:#dae8fc,stroke:#6c8ebf
    style QuayODH fill:#e1d5e7,stroke:#9673a6
    style QuayMODH fill:#e1d5e7,stroke:#9673a6
