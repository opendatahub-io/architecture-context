graph TB
    subgraph NotebooksDownstream["Notebooks-Downstream (Workbench Images)"]
        direction TB

        subgraph JupyterFamily["Jupyter Notebook Images"]
            JupMinCPU["Jupyter Minimal<br/>CPU<br/>Py 3.11 / 3.12"]
            JupDS["Jupyter Data Science<br/>CPU<br/>NumPy, Pandas, Sklearn, Elyra"]
            JupPyTorchCUDA["Jupyter PyTorch<br/>CUDA 12.6.3"]
            JupTFCUDA["Jupyter TensorFlow<br/>CUDA 12.6.3"]
            JupTrustYAI["Jupyter TrustYAI<br/>CPU + Java 17"]
            JupMinCUDA["Jupyter Minimal<br/>CUDA 12.6.3"]
            JupMinROCm["Jupyter Minimal<br/>ROCm 6.2.4"]
            JupPyTorchROCm["Jupyter PyTorch<br/>ROCm 6.2.4"]
            JupTFROCm["Jupyter TensorFlow<br/>ROCm 6.2.4"]
        end

        subgraph AltWorkbenches["Alternative Workbenches"]
            CodeServer["Code Server<br/>VS Code v4.98.0<br/>NGINX + supervisord"]
            RStudioC9S["RStudio Server<br/>C9S CPU/CUDA<br/>R 4.4.3"]
            RStudioRHEL9["RStudio Server<br/>RHEL9 CPU/CUDA<br/>Entitled Builds"]
        end

        subgraph Runtimes["Pipeline Runtime Images"]
            RTMinimal["Runtime Minimal<br/>CPU"]
            RTDS["Runtime Data Science<br/>CPU"]
            RTPyTorchCUDA["Runtime PyTorch<br/>CUDA"]
            RTTFCuda["Runtime TensorFlow<br/>CUDA"]
            RTPyTorchROCm["Runtime PyTorch<br/>ROCm"]
            RTTFROCm["Runtime TensorFlow<br/>ROCm"]
        end

        subgraph BuildSystem["Build Infrastructure"]
            MakeBuild["Makefile Build System<br/>podman/docker"]
            TektonCI["Tekton Pipelines<br/>Konflux CI/CD"]
            GoHelpers["Go Build Helpers<br/>Dockerfile analysis"]
        end
    end

    %% Image Layering
    JupMinCPU -->|extends| JupDS
    JupDS -->|extends| JupPyTorchCUDA
    JupDS -->|extends| JupTFCUDA
    JupDS -->|extends| JupTrustYAI
    JupMinCPU -->|CUDA layer| JupMinCUDA
    JupMinCPU -->|ROCm layer| JupMinROCm

    %% Platform Consumers
    NotebookCtrl["ODH Notebook Controller"]
    Dashboard["RHOAI Dashboard"]
    Operator["rhods-operator"]
    DSPipelines["Data Science Pipelines / Elyra"]

    NotebookCtrl -->|launches as StatefulSet| JupyterFamily
    NotebookCtrl -->|launches as StatefulSet| AltWorkbenches
    Dashboard -->|reads ImageStream annotations| NotebooksDownstream
    Operator -->|applies kustomize manifests| NotebooksDownstream
    DSPipelines -->|executes pipeline steps| Runtimes

    %% Base Images
    UBI9["Red Hat UBI 9<br/>Base OS"]
    UBI9 -.->|base layer| JupyterFamily
    UBI9 -.->|base layer| Runtimes
    UBI9 -.->|base layer| CodeServer

    %% Registry
    Quay["quay.io/modh<br/>Container Registry"]
    TektonCI -->|pushes images| Quay
    Quay -->|pulls images| NotebookCtrl

    %% Styling
    style NotebooksDownstream fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterFamily fill:#d5e8d4,stroke:#82b366
    style AltWorkbenches fill:#fff2cc,stroke:#d6b656
    style Runtimes fill:#dae8fc,stroke:#6c8ebf
    style BuildSystem fill:#f8cecc,stroke:#b85450
    style NotebookCtrl fill:#4a90e2,color:#fff
    style Dashboard fill:#4a90e2,color:#fff
    style Operator fill:#4a90e2,color:#fff
    style DSPipelines fill:#4a90e2,color:#fff
    style UBI9 fill:#999,color:#fff
    style Quay fill:#f5a623,color:#fff
