    style JupTF fill:#7b68ee,color:#fff
    style JupTAI fill:#4a90e2,color:#fff
    style JupROCmPT fill:#e74c3c,color:#fff
    style JupROCmTF fill:#e74c3c,color:#fff
    style CodeServer fill:#2ecc71,color:#fff
    style RStudioC9S fill:#27ae60,color:#fff
    style RStudioRHEL fill:#27ae60,color:#fff
    style RStudioCUDA fill:#27ae60,color:#fff
    style RTMin fill:#f39c12,color:#fff
    style RTDS fill:#f39c12,color:#fff
    style RTPT fill:#e67e22,color:#fff
    style RTTF fill:#e67e22,color:#fff
    style RTROCmPT fill:#d35400,color:#fff
    style RTROCmTF fill:#d35400,color:#fff
    style Manifests fill:#95a5a6,color:#fff
    style TektonPipelines fill:#95a5a6,color:#fff
    style Sandbox fill:#95a5a6,color:#fff
    style Dashboard fill:#7ed321
    style NotebookController fill:#7ed321
