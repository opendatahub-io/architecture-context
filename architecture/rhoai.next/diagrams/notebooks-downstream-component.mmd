graph TB
    subgraph "Notebooks-Downstream (Workbench Images)"
        direction TB

        subgraph "Common Base Layer"
            UBI9Base["UBI9 Python Base<br/>oc CLI + micropipenv"]
        end

        subgraph "Jupyter Image Family"
            direction TB
            JupyterMinimal["Jupyter Minimal<br/>8888/TCP<br/>Base JupyterLab"]
            JupyterDS["Jupyter Data Science<br/>8888/TCP<br/>pandas, sklearn, Elyra,<br/>DB clients"]
            JupyterPyTorch["Jupyter PyTorch<br/>8888/TCP<br/>CUDA 12.6.3 + PyTorch"]
            JupyterTF["Jupyter TensorFlow<br/>8888/TCP<br/>CUDA 12.6.3 + TensorFlow"]
            JupyterTrustyAI["Jupyter TrustyAI<br/>8888/TCP<br/>TrustyAI + Java 17"]
        end

        subgraph "Alternative IDE Family"
            direction TB
            CodeServer["Code Server<br/>8787/TCP → NGINX 8080/TCP<br/>VS Code v4.98 in-browser"]
            RStudio["RStudio Server<br/>8787/TCP → NGINX 8080/TCP<br/>R 4.4.3 + supervisord"]
        end

        subgraph "Pipeline Runtime Images"
            direction TB
            RuntimeMinimal["Runtime Minimal<br/>Headless Python"]
            RuntimeDS["Runtime Data Science<br/>Headless + DS libs"]
            RuntimePyTorch["Runtime PyTorch<br/>Headless + CUDA + PyTorch"]
            RuntimeTF["Runtime TensorFlow<br/>Headless + CUDA + TF"]
        end

        subgraph "GPU Acceleration Layers"
            CUDABase["CUDA Base<br/>CUDA 12.6.3 + cuDNN 9.5<br/>+ NCCL 2.23.4"]
            ROCmBase["ROCm Base<br/>AMD ROCm 6.2.4"]
        end

        subgraph "Build Artifacts"
            JLabAddons["JupyterLab Addons<br/>TypeScript/webpack"]
            KustomizeManifests["Kustomize Manifests<br/>ImageStream definitions"]
        end
    end

    %% Build chain relationships
    UBI9Base -->|extends| JupyterMinimal
    JupyterMinimal -->|extends| JupyterDS
    JupyterDS -->|extends| JupyterTrustyAI
    UBI9Base -->|extends| CUDABase
    CUDABase -->|extends| JupyterPyTorch
    CUDABase -->|extends| JupyterTF
    UBI9Base -->|extends| CodeServer
    UBI9Base -->|extends| RuntimeMinimal
    RuntimeMinimal -->|extends| RuntimeDS
    CUDABase -->|extends| RuntimePyTorch
    CUDABase -->|extends| RuntimeTF

    %% External platform interactions
    NotebookController["ODH Notebook Controller"]
    Dashboard["RHOAI Dashboard"]
    RhodsOperator["rhods-operator"]
    Elyra["Elyra Pipeline Editor"]
    KFP["Kubeflow Pipelines"]

    NotebookController -->|"launches pods +<br/>injects kube-rbac-proxy"| JupyterMinimal
    NotebookController -->|launches pods| CodeServer
    NotebookController -->|launches pods| RStudio
    Dashboard -->|"reads ImageStream<br/>annotations"| KustomizeManifests
    RhodsOperator -->|"deploys ImageStreams"| KustomizeManifests
    Elyra -->|"executes pipeline nodes"| RuntimeMinimal
    KFP -->|"orchestrates pods"| RuntimePyTorch

    JLabAddons -->|injected at build| JupyterMinimal

    %% Styling
    style UBI9Base fill:#4a90e2,stroke:#333,color:#fff
    style CUDABase fill:#76b900,stroke:#333,color:#fff
    style ROCmBase fill:#ed1c24,stroke:#333,color:#fff
    style JupyterMinimal fill:#f5a623,stroke:#333
    style JupyterDS fill:#f5a623,stroke:#333
    style JupyterPyTorch fill:#f5a623,stroke:#333
    style JupyterTF fill:#f5a623,stroke:#333
    style JupyterTrustyAI fill:#f5a623,stroke:#333
    style CodeServer fill:#007acc,stroke:#333,color:#fff
    style RStudio fill:#75aadb,stroke:#333,color:#fff
    style RuntimeMinimal fill:#9b59b6,stroke:#333,color:#fff
    style RuntimeDS fill:#9b59b6,stroke:#333,color:#fff
    style RuntimePyTorch fill:#9b59b6,stroke:#333,color:#fff
    style RuntimeTF fill:#9b59b6,stroke:#333,color:#fff
    style NotebookController fill:#e8e8e8,stroke:#333
    style Dashboard fill:#e8e8e8,stroke:#333
    style RhodsOperator fill:#e8e8e8,stroke:#333
    style Elyra fill:#7ed321,stroke:#333
    style KFP fill:#7ed321,stroke:#333
    style JLabAddons fill:#50e3c2,stroke:#333
    style KustomizeManifests fill:#50e3c2,stroke:#333
