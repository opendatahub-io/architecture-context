graph TB
    subgraph NotebooksDownstream["Notebooks Downstream (Workbench Images)"]
        direction TB

        subgraph JupyterImages["Jupyter Notebook Images"]
            direction LR
            JupMinCPU["Jupyter Minimal<br/>CPU<br/>py3.11/3.12"]
            JupDS["Jupyter DataScience<br/>CPU<br/>py3.11/3.12"]
            JupPyTorchCUDA["Jupyter PyTorch<br/>CUDA 12.6.3<br/>py3.11/3.12"]
            JupTFCUDA["Jupyter TensorFlow<br/>CUDA 12.6.3<br/>py3.11/3.12"]
            JupTrustYAI["Jupyter TrustYAI<br/>CPU + Java 17<br/>py3.11/3.12"]
            JupMinCUDA["Jupyter Minimal<br/>CUDA 12.6.3<br/>py3.11/3.12"]
            JupMinROCm["Jupyter Minimal<br/>ROCm 6.2.4<br/>py3.11/3.12"]
            JupPyTorchROCm["Jupyter PyTorch<br/>ROCm 6.2.4<br/>py3.11/3.12"]
            JupTFROCm["Jupyter TensorFlow<br/>ROCm 6.2.4<br/>py3.11/3.12"]
        end

        subgraph AltWorkbenches["Alternative Workbenches"]
            direction LR
            CodeServer["Code Server<br/>v4.98.0 + NGINX<br/>py3.11/3.12"]
            RStudioC9S["RStudio Server<br/>C9S CPU/CUDA<br/>py3.11"]
            RStudioRHEL9["RStudio Server<br/>RHEL9 CPU/CUDA<br/>py3.11"]
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            direction LR
            RTMinimal["Runtime Minimal<br/>CPU<br/>py3.11/3.12"]
            RTDS["Runtime DataScience<br/>CPU<br/>py3.11/3.12"]
            RTPyTorchCUDA["Runtime PyTorch<br/>CUDA<br/>py3.11/3.12"]
            RTTFCuda["Runtime TensorFlow<br/>CUDA<br/>py3.11/3.12"]
            RTPyTorchROCm["Runtime PyTorch<br/>ROCm<br/>py3.11/3.12"]
            RTTFROCm["Runtime TensorFlow<br/>ROCm<br/>py3.11/3.12"]
        end

        subgraph BuildTooling["Build Tooling"]
            direction LR
            MakeBuild["Makefile Build System<br/>podman/docker"]
            TektonCI["Tekton Pipelines<br/>Konflux CI/CD"]
            GoHelpers["Go Build Helpers<br/>Dockerfile analysis"]
        end
    end

    %% Image layering
    JupMinCPU -->|extends| JupDS
    JupDS -->|extends| JupPyTorchCUDA
    JupDS -->|extends| JupTFCUDA
    JupDS -->|extends| JupTrustYAI
    JupMinCUDA -->|extends| JupPyTorchCUDA
    JupMinROCm -->|extends| JupPyTorchROCm
    JupMinROCm -->|extends| JupTFROCm

    %% Platform consumers
    NotebookController["ODH Notebook Controller"] -->|launches as StatefulSet| JupyterImages
    NotebookController -->|launches as StatefulSet| AltWorkbenches
    Dashboard["RHOAI Dashboard"] -->|reads ImageStream annotations| NotebooksDownstream
    RhodsOperator["rhods-operator"] -->|applies kustomize manifests| NotebooksDownstream
    DSPipelines["Data Science Pipelines / Elyra"] -->|executes pipeline steps| RuntimeImages
    TektonCI -->|builds & pushes| QuayRegistry["quay.io/modh"]

    %% Base images
    UBI9["Red Hat UBI 9"] -.->|base image| JupyterImages
    UBI9 -.->|base image| RuntimeImages
    UBI9 -.->|base image| CodeServer
    C9S["CentOS Stream 9"] -.->|base image| RStudioC9S
    RHEL9["RHEL 9"] -.->|base image| RStudioRHEL9

    %% Styling
    style NotebooksDownstream fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterImages fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style AltWorkbenches fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style RuntimeImages fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style BuildTooling fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style NotebookController fill:#4a90e2,color:#fff
    style Dashboard fill:#4a90e2,color:#fff
    style RhodsOperator fill:#4a90e2,color:#fff
    style DSPipelines fill:#4a90e2,color:#fff
    style QuayRegistry fill:#f5a623,color:#fff
    style UBI9 fill:#e8e8e8,stroke:#999
    style C9S fill:#e8e8e8,stroke:#999
    style RHEL9 fill:#e8e8e8,stroke:#999
