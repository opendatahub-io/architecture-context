graph TB
    subgraph "Notebooks-Downstream (Workbench Images)"
        direction TB

        subgraph JupyterFamily["Jupyter Image Family"]
            direction TB
            JupyterMinimal["Jupyter Minimal<br/>UBI9 + Python 3.11/3.12<br/>Port: 8888/TCP"]
            JupyterDS["Jupyter Data Science<br/>pandas, scikit-learn, boto3<br/>Elyra Pipeline Editor<br/>Port: 8888/TCP"]
            JupyterPyTorch["Jupyter PyTorch<br/>CUDA 12.6.3 + PyTorch<br/>Port: 8888/TCP"]
            JupyterTF["Jupyter TensorFlow<br/>CUDA 12.6.3 + TensorFlow<br/>Port: 8888/TCP"]
            JupyterTrustyAI["Jupyter TrustyAI<br/>TrustyAI + Java 17<br/>Port: 8888/TCP"]

            JupyterMinimal -->|extends| JupyterDS
            JupyterDS -->|extends| JupyterPyTorch
            JupyterDS -->|extends| JupyterTF
            JupyterDS -->|extends| JupyterTrustyAI
        end

        subgraph AltIDEs["Alternative IDE Images"]
            direction TB
            CodeServer["Code Server<br/>code-server v4.98<br/>NGINX Reverse Proxy<br/>Port: 8787/TCP → 8080/TCP"]
            RStudio["RStudio Server<br/>RStudio 2024.12 + R 4.4.3<br/>NGINX Reverse Proxy<br/>Port: 8787/TCP → 8080/TCP"]
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            direction TB
            RuntimeMinimal["Runtime Minimal<br/>Headless Python"]
            RuntimeDS["Runtime Data Science<br/>Data science libs"]
            RuntimePyTorch["Runtime PyTorch<br/>CUDA + PyTorch"]
            RuntimeTF["Runtime TensorFlow<br/>CUDA + TensorFlow"]

            RuntimeMinimal -->|extends| RuntimeDS
            RuntimeMinimal -->|extends| RuntimePyTorch
            RuntimeMinimal -->|extends| RuntimeTF
        end

        subgraph GPUVariants["GPU Acceleration Variants"]
            direction LR
            CUDABase["CUDA Base<br/>CUDA 12.6.3<br/>cuDNN 9.5<br/>NCCL 2.23.4"]
            ROCmBase["ROCm Base<br/>AMD ROCm 6.2.4"]
        end

        subgraph BuildInfra["Build & Deploy"]
            direction LR
            Addons["JupyterLab Addons<br/>TypeScript/webpack"]
            Manifests["Kustomize Manifests<br/>ImageStream definitions"]
        end
    end

    %% External interactions
    User["Data Scientist"] -->|selects workbench| Dashboard["RHOAI Dashboard"]
    Dashboard -->|reads ImageStream annotations| Manifests
    NotebookController["ODH Notebook Controller"] -->|creates pod + injects sidecar| JupyterMinimal
    NotebookController -->|creates pod + injects sidecar| CodeServer
    NotebookController -->|creates pod + injects sidecar| RStudio
    Operator["rhods-operator"] -->|deploys| Manifests
    Elyra["Elyra Pipeline Editor"] -->|launches| RuntimeMinimal
    KFP["Kubeflow Pipelines"] -->|orchestrates| RuntimeImages
    Konflux["Konflux / Tekton"] -->|builds images| JupyterFamily
    Konflux -->|builds images| AltIDEs
    Konflux -->|builds images| RuntimeImages

    %% Base images
    UBI9["UBI9 Python 3.11/3.12<br/>registry.access.redhat.com"] -.->|base image| JupyterMinimal
    UBI9 -.->|base image| RuntimeMinimal
    C9S["CentOS Stream 9<br/>Python 3.11"] -.->|base image| RStudio

