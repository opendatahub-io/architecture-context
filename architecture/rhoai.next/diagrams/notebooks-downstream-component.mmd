graph TB
    subgraph UserAccess["User Access"]
        User[Data Scientist / Developer]
        Dashboard[RHOAI Dashboard]
    end

    subgraph Platform["Platform Control Plane"]
        Operator[rhods-operator]
        NotebookCtrl[odh-notebook-controller]
        ImageStreams["ImageStream Resources<br/>(manifests/base/ + overlays/)"]
    end

    subgraph WorkbenchImages["Workbench Images (Interactive IDEs)"]
        direction TB

        subgraph JupyterCPU["Jupyter CPU Workbenches"]
            JupMinimal["Jupyter Minimal<br/>Python 3.11/3.12<br/>Port: 8888/TCP"]
            JupDataSci["Jupyter Data Science<br/>pandas, scikit-learn, Elyra<br/>Port: 8888/TCP"]
            JupTrustyAI["Jupyter TrustyAI<br/>Java 17, AI fairness<br/>Port: 8888/TCP"]
        end

        subgraph JupyterGPU["Jupyter GPU Workbenches"]
            JupPyTorchCUDA["Jupyter PyTorch CUDA<br/>CUDA 12.6.3<br/>Port: 8888/TCP"]
            JupTFCUDA["Jupyter TensorFlow CUDA<br/>CUDA 12.6.3<br/>Port: 8888/TCP"]
            JupMinCUDA["Jupyter Minimal CUDA<br/>CUDA 12.6.3<br/>Port: 8888/TCP"]
            JupMinROCm["Jupyter Minimal ROCm<br/>ROCm 6.2.4<br/>Port: 8888/TCP"]
            JupPyTorchROCm["Jupyter PyTorch ROCm<br/>ROCm 6.2.4<br/>Port: 8888/TCP"]
            JupTFROCm["Jupyter TensorFlow ROCm<br/>ROCm 6.2.4<br/>Port: 8888/TCP"]
        end

        subgraph OtherIDEs["Non-Jupyter Workbenches"]
            CodeServer["Code Server (VS Code)<br/>code-server v4.98.0<br/>nginx + supervisord<br/>Port: 8787/TCP"]
            RStudio["RStudio Server<br/>RStudio 2024.12.1 + R 4.4.3<br/>nginx + supervisord<br/>Port: 8787/TCP"]
            RStudioCUDA["RStudio CUDA<br/>CUDA 12.6.3<br/>Port: 8787/TCP"]
        end
    end

    subgraph RuntimeImages["Pipeline Runtime Images (Headless)"]
        RTMinimal["Runtime Minimal<br/>Python (CPU)"]
        RTDataSci["Runtime Data Science<br/>Python (CPU)"]
        RTPyTorchCUDA["Runtime PyTorch<br/>CUDA"]
        RTTFCUDA["Runtime TensorFlow<br/>CUDA"]
        RTPyTorchROCm["Runtime PyTorch<br/>ROCm"]
        RTTFROCm["Runtime TensorFlow<br/>ROCm"]
    end

    subgraph AuthSidecar["Auth Sidecar (injected by controller)"]
        KubeRBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS<br/>(RHOAI 3.x)"]
    end

    %% User flows
    User -->|selects workbench| Dashboard
    Dashboard -->|reads ImageStream annotations| ImageStreams
    User -->|HTTPS/8443| KubeRBACProxy

    %% Platform flows
    Operator -->|deploys kustomize manifests| ImageStreams
    NotebookCtrl -->|creates StatefulSet + injects sidecar| KubeRBACProxy
    ImageStreams -->|references| WorkbenchImages
    ImageStreams -->|references| RuntimeImages

    %% Sidecar proxy
    KubeRBACProxy -->|HTTP/8888 pod-local| JupMinimal
    KubeRBACProxy -->|HTTP/8787 pod-local| CodeServer

    %% Elyra integration
    ElyraCtrl[Elyra Pipeline Controller] -->|uses as container image| RuntimeImages

    %% Styling
    style User fill:#e1f5fe,stroke:#0288d1,stroke-width:2px
    style Dashboard fill:#e1f5fe,stroke:#0288d1,stroke-width:2px
    style Operator fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style NotebookCtrl fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style ImageStreams fill:#f5a623,stroke:#333,stroke-width:2px
    style KubeRBACProxy fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    style ElyraCtrl fill:#fff3e0,stroke:#f57c00,stroke-width:2px

    style JupMinimal fill:#4a90e2,stroke:#333,color:#fff
    style JupDataSci fill:#4a90e2,stroke:#333,color:#fff
    style JupTrustyAI fill:#4a90e2,stroke:#333,color:#fff
    style JupPyTorchCUDA fill:#7b1fa2,stroke:#333,color:#fff
    style JupTFCUDA fill:#7b1fa2,stroke:#333,color:#fff
    style JupMinCUDA fill:#7b1fa2,stroke:#333,color:#fff
    style JupMinROCm fill:#c62828,stroke:#333,color:#fff
    style JupPyTorchROCm fill:#c62828,stroke:#333,color:#fff
    style JupTFROCm fill:#c62828,stroke:#333,color:#fff
    style CodeServer fill:#2e7d32,stroke:#333,color:#fff
    style RStudio fill:#2e7d32,stroke:#333,color:#fff
    style RStudioCUDA fill:#2e7d32,stroke:#333,color:#fff

    style RTMinimal fill:#78909c,stroke:#333,color:#fff
    style RTDataSci fill:#78909c,stroke:#333,color:#fff
    style RTPyTorchCUDA fill:#78909c,stroke:#333,color:#fff
    style RTTFCUDA fill:#78909c,stroke:#333,color:#fff
