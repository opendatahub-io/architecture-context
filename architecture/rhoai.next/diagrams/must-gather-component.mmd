graph TB
    subgraph User["User / SRE"]
        UserActor[User]
    end

    subgraph MustGather["Must-Gather Diagnostic Container"]
        direction TB

        subgraph EntryPoint["Entry Point"]
            Gather["gather.sh<br/>Main Orchestrator"]
        end

        subgraph Libraries["Shared Libraries"]
            Common["common.sh<br/>run_mustgather, get_all_namespace,<br/>rhoai_version, collect_helm_releases"]
            XksUtil["xks_util.sh<br/>detect_k8s_distro, kubectl_inspect,<br/>auto_discover_resources"]
        end

        subgraph OpenShiftPath["OpenShift Collection Path"]
            direction TB
            GatherServing["gather_serving.sh<br/>KServe, Authorino, NIM,<br/>llm-d, MaaS, Gateway API IE"]
            GatherDSP["gather_data_science_pipelines.sh<br/>DSPA, Argo Workflows"]
            GatherNotebooks["gather_notebooks.sh<br/>Notebook, ImageStream"]
            GatherDashboard["gather_dashboard.sh<br/>OdhDashboardConfig,<br/>AcceleratorProfiles"]
            GatherKubeRay["gather_kuberay.sh<br/>RayCluster, RayJob"]
            GatherKueue["gather_kueue.sh<br/>ClusterQueue, LocalQueue,<br/>Workload"]
            GatherKFTO["gather_kfto.sh<br/>PyTorchJob, TrainJob"]
            GatherMR["gather_mr.sh<br/>ModelRegistry"]
            GatherTrustyAI["gather_trustyai.sh<br/>TrustyAI, LMEvalJob,<br/>GuardrailsOrchestrator"]
            GatherFeast["gather_feastoperator.sh<br/>FeatureStore"]
            GatherLLS["gather_lls.sh<br/>LlamaStackDistribution"]
            GatherMLflow["gather_mlflow.sh<br/>MLflow"]
            GatherSpark["gather_sparkoperator.sh<br/>SparkApplication"]
            GatherMaaS["gather_models_as_a_service.sh<br/>MaaSModelRef, Tenant"]
        end

        subgraph XksPath["xKS Collection Path (AKS/EKS/CKS)"]
            direction TB
            GatherLLMD["gather_llmd.sh<br/>LLM-D: cluster info,<br/>KServe, Gateway API"]
            GatherCluster["gather_cluster.sh<br/>Cluster info, nodes,<br/>API resources"]
            GatherO11y["gather_o11y.sh<br/>Prometheus/AMP metrics"]

            subgraph Dependencies["Dependency Collection (parallel)"]
                CertManager["cert-manager.sh<br/>Issuers, Certificates"]
                Sail["sail.sh<br/>Istio, networking,<br/>security, telemetry"]
                LWS["lws.sh<br/>LeaderWorkerSet"]
            end

            subgraph Optional["Optional Modules"]
                GatherWVA["gather_wva.sh<br/>KEDA, VariantAutoscaling"]
                GatherBatch["gather_batch_gateway.sh<br/>Batch Gateway, Helm"]
            end
        end

        subgraph CLIs["Bundled CLI Tools"]
            OC["oc CLI<br/>(OpenShift)"]
            Kubectl["kubectl<br/>(xKS platforms)"]
            Helm["helm v4.1.4<br/>(Helm releases)"]
        end
    end

    subgraph Target["Target Cluster"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    end

    subgraph Output["Collection Output"]
        LocalFS["/must-gather/<br/>Collected Resources"]
    end

    %% User invocation
    UserActor -->|"oc adm must-gather (OpenShift)<br/>kubectl apply job.yaml (xKS)"| Gather

    %% Platform detection
    Gather -->|sources| Common
    Gather -->|sources| XksUtil
    XksUtil -->|detects| Gather

    %% OpenShift dispatch
    Gather -->|"OpenShift detected:<br/>parallel dispatch"| GatherServing
    Gather -->|parallel| GatherDSP
    Gather -->|parallel| GatherNotebooks
    Gather -->|parallel| GatherDashboard
    Gather -->|parallel| GatherKubeRay
    Gather -->|parallel| GatherKueue
    Gather -->|parallel| GatherKFTO
    Gather -->|parallel| GatherMR
    Gather -->|parallel| GatherTrustyAI
    Gather -->|parallel| GatherFeast
    Gather -->|parallel| GatherLLS
    Gather -->|parallel| GatherMLflow
    Gather -->|parallel| GatherSpark
    Gather -->|parallel| GatherMaaS

    %% xKS dispatch
    Gather -->|"xKS detected:<br/>llm-d path"| GatherLLMD
    GatherLLMD --> GatherCluster
    GatherLLMD --> CertManager
    GatherLLMD --> Sail
    GatherLLMD --> LWS
    GatherLLMD --> GatherO11y
    GatherLLMD -.->|"ENABLE_WVA=true"| GatherWVA
    GatherLLMD -.->|"ENABLE_BATCH_GATEWAY=true"| GatherBatch

    %% API access
    GatherServing -->|"oc adm inspect /<br/>kubectl get"| K8sAPI
    GatherDSP --> K8sAPI
    GatherLLMD --> K8sAPI
    GatherCluster --> K8sAPI
    Helm -->|"helm get values/manifest"| K8sAPI

    %% CLI usage
    OpenShiftPath -.->|uses| OC
    XksPath -.->|uses| Kubectl
    Gather -.->|uses| Helm

    %% Output
    Gather -->|writes collected data| LocalFS

    %% Styles
    style Gather fill:#4a90e2,stroke:#333,color:#fff
    style Common fill:#6c8ebf,stroke:#333,color:#fff
    style XksUtil fill:#6c8ebf,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style LocalFS fill:#7ed321,stroke:#333,color:#fff
    style GatherLLMD fill:#e07a5f,stroke:#333,color:#fff
    style UserActor fill:#9b59b6,stroke:#333,color:#fff
