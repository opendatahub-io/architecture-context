graph TB
    subgraph "must-gather Tool"
        direction TB

        subgraph "Core Framework"
            Gather["gather.sh<br/>(Main Entrypoint)"]
            Common["common.sh<br/>(Shared Library)"]
            XKSUtil["xks_util.sh<br/>(Non-OpenShift Utilities)"]
            Gather -->|sources| Common
            Gather -->|sources on xKS| XKSUtil
        end

        subgraph "RHOAI Component Collectors"
            direction LR
            Serving["gather_serving.sh<br/>KServe / Authorino / NIM /<br/>LLM-D / MaaS Rate Limiting"]
            DSP["gather_data_science_pipelines.sh<br/>DSP Applications / Argo"]
            Notebooks["gather_notebooks.sh<br/>Notebooks / ImageStreams"]
            Dashboard["gather_dashboard.sh<br/>DashboardConfig / Accelerators /<br/>HardwareProfiles"]
            KubeRay["gather_kuberay.sh<br/>RayCluster / RayJob / RayService"]
            Kueue["gather_kueue.sh<br/>ClusterQueue / LocalQueue /<br/>Workload"]
            KFTO["gather_kfto.sh<br/>PyTorchJob / TrainJob /<br/>TrainingRuntime"]
            MR["gather_mr.sh<br/>ModelRegistry"]
            TrustyAI["gather_trustyai.sh<br/>TrustyAIService / LMEvalJob /<br/>EvalHub / Guardrails"]
            Feast["gather_feastoperator.sh<br/>FeatureStore"]
            LLS["gather_lls.sh<br/>LlamaStackDistribution"]
            MLflow["gather_mlflow.sh<br/>MLflow"]
            Spark["gather_sparkoperator.sh<br/>SparkApplication / SparkConnect"]
            MaaS["gather_models_as_a_service.sh<br/>MaaSModelRef / MaaSAuthPolicy /<br/>Tenant / ExternalModel"]
        end

        subgraph "LLM-D Collection"
            direction LR
            LLMD["gather_llmd.sh<br/>LLMInferenceService /<br/>Gateway API / Inference Extension"]
            WVA["gather_wva.sh<br/>WVA / KEDA<br/>(opt-in: ENABLE_WVA)"]
            O11y["gather_o11y.sh<br/>Prometheus Operator /<br/>Azure Managed Prometheus"]
            Cluster["gather_cluster.sh<br/>Nodes / API Resources /<br/>Cluster-Scoped Resources"]
        end

        subgraph "LLM-D Dependency Collectors"
            direction LR
            CertMgr["cert-manager.sh<br/>Certificates / Issuers"]
            Sail["sail.sh<br/>Istio / VirtualService /<br/>DestinationRule / EnvoyFilter"]
            LWS["lws.sh<br/>LeaderWorkerSet"]
        end
    end

