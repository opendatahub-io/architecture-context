graph TB
    subgraph "must-gather Container Image"
        direction TB

        subgraph "Entry Point"
            Gather["gather.sh<br/>(Main Entrypoint)"]
        end

        subgraph "Shared Libraries"
            Common["common.sh<br/>(Shared Functions)"]
            XKSUtil["xks_util.sh<br/>(K8s Distro Detection)"]
        end

        subgraph "Component Gatherers (13 parallel)"
            direction LR
            GatherServing["gather_serving.sh<br/>KServe / Authorino / NIM / LLM-D"]
            GatherDSP["gather_data_science_pipelines.sh<br/>DSP / Argo Workflows"]
            GatherNotebooks["gather_notebooks.sh<br/>Workbenches / ImageStreams"]
            GatherDashboard["gather_dashboard.sh<br/>Dashboard Config"]
            GatherKubeRay["gather_kuberay.sh<br/>RayCluster / RayJob"]
            GatherKueue["gather_kueue.sh<br/>Kueue Queues / Workloads"]
            GatherKFTO["gather_kfto.sh<br/>Training Operator Jobs"]
            GatherMR["gather_mr.sh<br/>Model Registry"]
            GatherTrustyAI["gather_trustyai.sh<br/>TrustyAI / LMEval / Guardrails"]
            GatherFeast["gather_feastoperator.sh<br/>FeatureStore"]
            GatherLLS["gather_lls.sh<br/>LlamaStack"]
            GatherMLflow["gather_mlflow.sh<br/>MLflow"]
            GatherSpark["gather_sparkoperator.sh<br/>SparkApplication"]
        end

        subgraph "Additional Gatherers"
            GatherMaaS["gather_models_as_a_service.sh<br/>MaaS Resources"]
            GatherCluster["gather_cluster.sh<br/>Cluster-Scoped Resources"]
            GatherO11y["gather_o11y.sh<br/>Observability / Prometheus"]
        end

        subgraph "LLM-D Sub-Gatherers"
            GatherLLMD["gather_llmd.sh<br/>LLM-D Orchestrator"]
            GatherWVA["gather_wva.sh<br/>KEDA / WVA (optional)"]
            GatherBatch["gather_batch_gateway.sh<br/>Batch Gateway (optional)"]
        end

        subgraph "Dependency Collectors"
            CertManager["cert-manager.sh<br/>Certificates / Issuers"]
            LWS["lws.sh<br/>LeaderWorkerSet"]
            Sail["sail.sh<br/>Istio / Sail Operator"]
        end
    end

    %% Entry point flow
    Gather -->|"detects distro"| XKSUtil
    Gather -->|"loads shared funcs"| Common
    Gather -->|"dispatches parallel"| GatherServing
    Gather -->|"dispatches parallel"| GatherDSP
    Gather -->|"dispatches parallel"| GatherNotebooks
    Gather -->|"dispatches parallel"| GatherDashboard
    Gather -->|"dispatches parallel"| GatherKubeRay
    Gather -->|"dispatches parallel"| GatherKueue
    Gather -->|"dispatches parallel"| GatherKFTO
    Gather -->|"dispatches parallel"| GatherMR
    Gather -->|"dispatches parallel"| GatherTrustyAI
    Gather -->|"dispatches parallel"| GatherFeast
    Gather -->|"dispatches parallel"| GatherLLS
    Gather -->|"dispatches parallel"| GatherMLflow
    Gather -->|"dispatches parallel"| GatherSpark
    Gather --> GatherMaaS
    Gather --> GatherCluster
    Gather --> GatherO11y

    GatherServing --> GatherLLMD
    GatherLLMD --> GatherWVA
    GatherLLMD --> GatherBatch
    GatherLLMD -->|"parallel deps"| CertManager
    GatherLLMD -->|"parallel deps"| LWS
    GatherLLMD -->|"parallel deps"| Sail

    %% External targets
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    AllGatherers["All Gather Scripts"] -->|"oc adm inspect /<br/>kubectl get"| K8sAPI
    Gather --> AllGatherers

    LocalFS["Local Filesystem<br/>$DST_DIR"]
    AllGatherers -->|"write YAML/logs"| LocalFS

    %% Users
    User["User / SRE"] -->|"oc adm must-gather<br/>or kubectl create job"| Gather

    %% Styling
    style Gather fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Common fill:#6c9bd2,stroke:#333,color:#fff
    style XKSUtil fill:#6c9bd2,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style LocalFS fill:#e8e8e8,stroke:#333
    style User fill:#f5a623,stroke:#333,color:#fff
    style GatherLLMD fill:#9b59b6,stroke:#333,color:#fff
    style GatherServing fill:#7ed321,stroke:#333
    style GatherDSP fill:#7ed321,stroke:#333
    style GatherNotebooks fill:#7ed321,stroke:#333
    style GatherDashboard fill:#7ed321,stroke:#333
    style GatherKubeRay fill:#7ed321,stroke:#333
    style GatherKueue fill:#7ed321,stroke:#333
    style GatherKFTO fill:#7ed321,stroke:#333
    style GatherMR fill:#7ed321,stroke:#333
    style GatherTrustyAI fill:#7ed321,stroke:#333
    style GatherFeast fill:#7ed321,stroke:#333
    style GatherLLS fill:#7ed321,stroke:#333
    style GatherMLflow fill:#7ed321,stroke:#333
    style GatherSpark fill:#7ed321,stroke:#333
    style CertManager fill:#d4a5e8,stroke:#333
    style LWS fill:#d4a5e8,stroke:#333
    style Sail fill:#d4a5e8,stroke:#333
