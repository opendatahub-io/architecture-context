graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal Platform Dependencies
    GD -->|"deployed via<br/>InferenceService"| KServe["KServe"]
    GD -->|"mTLS sidecar<br/>injection"| Istio["Istio Service Mesh"]
    GD -->|"called by<br/>HTTP/8080,8000"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% External Service Dependencies
    GD -->|"model storage<br/>HTTP/9000"| S3["S3/MinIO<br/>Storage"]
    GD -->|"LLM inference<br/>HTTP/8080"| VLLM["vLLM Server"]
    GD -.->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Python Framework Dependencies
    GD -->|"web framework"| FastAPI["FastAPI 0.121.2"]
    GD -->|"ASGI server"| Uvicorn["uvicorn 0.30.5"]
    GD -->|"metrics"| PromClient["prometheus_client<br/>>=0.18.0"]
    GD -->|"auto metrics"| PromFastAPI["prometheus-fastapi-<br/>instrumentator >=7.0.0"]

    %% ML Dependencies (HuggingFace Detector)
    GD -->|"ML inference<br/>(HF detector)"| PyTorch["PyTorch 2.6.0"]
    GD -->|"model loading<br/>(HF detector)"| Transformers["transformers 4.57.1"]
    GD -->|"tokenizer<br/>(HF detector)"| SentencePiece["sentencepiece 0.2.1"]
    GD -->|"BPE tokenizer<br/>(HF detector)"| Tiktoken["tiktoken 0.12.0"]

    %% LLM Judge Dependencies
    GD -->|"judge framework<br/>(Judge detector)"| VllmJudge["vllm-judge 0.1.8"]

    %% Built-in Dependencies
    GD -->|"JSON validation<br/>(built-in)"| JSONSchema["jsonschema 4.24.0"]
    GD -->|"XML validation<br/>(built-in)"| XMLSchema["xmlschema 4.1.0"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|"scrapes /metrics"| GD

    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style VLLM fill:#f5a623,stroke:#333
    style HFHub fill:#999,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
    style PromFastAPI fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style SentencePiece fill:#e8e8e8,stroke:#333
    style Tiktoken fill:#e8e8e8,stroke:#333
    style VllmJudge fill:#e8e8e8,stroke:#333
    style JSONSchema fill:#e8e8e8,stroke:#333
    style XMLSchema fill:#e8e8e8,stroke:#333
