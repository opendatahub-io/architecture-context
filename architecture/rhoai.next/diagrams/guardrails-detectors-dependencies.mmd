graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal RHOAI Dependencies
    GD -->|"consumer calls detector<br/>HTTP/8080,8000"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployment runtime<br/>InferenceService"| KServe["KServe"]
    GD -->|"custom runtime definition<br/>ServingRuntime CR"| KServeRT["KServe<br/>ServingRuntime"]
    GD -->|"model provisioning<br/>init container"| StorageInit["KServe Storage<br/>Initializer"]
    GD -->|"sidecar injection<br/>mTLS"| Istio["Istio Service Mesh"]
    GD -->|"metrics scrape<br/>HTTP /metrics"| Prometheus["Prometheus"]

    %% External Service Dependencies
    GD -->|"model weight storage<br/>HTTP(S)/9000,443"| S3["S3/MinIO<br/>Storage"]
    GD -->|"LLM evaluation API<br/>HTTP/8080"| vLLM["vLLM Server"]
    GD -.->|"model download<br/>HTTPS/443 (dev only)"| HFHub["HuggingFace Hub"]

    %% Python Library Dependencies (key ones)
    subgraph PythonDeps["Key Python Dependencies"]
        direction TB
        FastAPI["FastAPI 0.136.3"]
        Uvicorn["uvicorn 0.34.0"]
        PyTorch["PyTorch 2.6.0<br/>(HF only)"]
        Transformers["transformers 4.57.3<br/>(HF only)"]
        VLLMJudge["vllm-judge 0.1.8<br/>(judge only)"]
        PromClient["prometheus_client<br/>>=0.18.0"]
    end

    GD -->|"HTTP framework"| FastAPI
    GD -->|"ASGI server"| Uvicorn
    GD -->|"ML inference"| PyTorch
    GD -->|"model loading"| Transformers
    GD -->|"LLM evaluation"| VLLMJudge
    GD -->|"metrics"| PromClient

    %% Integration Points (other components that integrate with us)
    Orchestrator -->|"routes text content<br/>POST /api/v1/text/contents"| GD

    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI styling
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeRT fill:#7ed321,stroke:#333,color:#fff
