graph LR
    GD["Guardrails Detectors<br/>(3 microservices)"]

    %% Internal Platform Dependencies
    GD -->|incoming API calls| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|deployed as ISVC| KServe["KServe"]
    GD -->|mTLS sidecar| Istio["Istio Service Mesh"]

    %% External Service Dependencies
    GD -->|model storage<br/>9000/TCP| S3["S3/MinIO Storage"]
    GD -->|LLM inference<br/>8080/TCP| vLLM["vLLM Server"]
    GD -.->|model download<br/>443/TCP| HFHub["HuggingFace Hub"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|scrapes /metrics| GD

    %% Python Framework Dependencies
    subgraph Frameworks["Python Frameworks"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["uvicorn 0.30.5"]
        PromClient["prometheus_client >=0.18.0"]
    end

    subgraph MLLibs["ML Libraries (HF Detector)"]
        PyTorch["PyTorch 2.6.0"]
        Transformers["transformers 4.57.1"]
        SentencePiece["sentencepiece 0.2.1"]
        Tiktoken["tiktoken 0.12.0"]
    end

    subgraph JudgeLibs["Judge Libraries"]
        VllmJudge["vllm-judge 0.1.8"]
    end

    subgraph ValidationLibs["Validation Libraries (Built-in)"]
        JsonSchema["jsonschema 4.24.0"]
        XmlSchema["xmlschema 4.1.0"]
    end

    GD --> Frameworks
    GD --> MLLibs
    GD --> JudgeLibs
    GD --> ValidationLibs

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style vLLM fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style SentencePiece fill:#e8e8e8,stroke:#333
    style Tiktoken fill:#e8e8e8,stroke:#333
    style VllmJudge fill:#e8e8e8,stroke:#333
    style JsonSchema fill:#e8e8e8,stroke:#333
    style XmlSchema fill:#e8e8e8,stroke:#333
