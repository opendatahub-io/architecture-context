graph LR
    GD["Guardrails Detectors<br/>(3 microservices)"]

    %% Internal Platform Dependencies
    GD -->|"called by<br/>HTTP REST"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployed via<br/>InferenceService"| KServe["KServe"]
    GD -->|"mTLS sidecar"| Istio["Istio Service Mesh"]

    %% External Service Dependencies
    GD -->|"model storage<br/>HTTP/9000"| S3["S3/MinIO Storage"]
    GD -->|"LLM inference<br/>HTTP/8080"| VLLM["vLLM Server"]
    GD -.->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics"| GD

    %% Framework Dependencies
    subgraph PythonDeps["Python Framework Dependencies"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["uvicorn 0.30.5"]
        PromClient["prometheus_client >=0.18.0"]
        PromFastAPI["prometheus-fastapi-<br/>instrumentator >=7.0.0"]
        HTTPX["httpx 0.27.0"]
    end

    subgraph HFDeps["HuggingFace Detector Dependencies"]
        PyTorch["PyTorch 2.6.0"]
        Transformers["transformers 4.57.1"]
        SentencePiece["sentencepiece 0.2.1"]
        Tiktoken["tiktoken 0.12.0"]
    end

    subgraph JudgeDeps["LLM Judge Dependencies"]
        VLLMJudge["vllm-judge 0.1.8"]
    end

    subgraph BuiltInDeps["Built-in Detector Dependencies"]
        JSONSchema["jsonschema 4.24.0"]
        XMLSchema["xmlschema 4.1.0"]
    end

    GD -->|"all detectors"| PythonDeps
    GD -->|"HF detector"| HFDeps
    GD -->|"Judge detector"| JudgeDeps
    GD -->|"built-in detector"| BuiltInDeps

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style VLLM fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333,color:#333
    style FastAPI fill:#ddd,stroke:#666
    style Uvicorn fill:#ddd,stroke:#666
    style PromClient fill:#ddd,stroke:#666
    style PromFastAPI fill:#ddd,stroke:#666
    style HTTPX fill:#ddd,stroke:#666
    style PyTorch fill:#ddd,stroke:#666
    style Transformers fill:#ddd,stroke:#666
    style SentencePiece fill:#ddd,stroke:#666
    style Tiktoken fill:#ddd,stroke:#666
    style VLLMJudge fill:#ddd,stroke:#666
    style JSONSchema fill:#ddd,stroke:#666
    style XMLSchema fill:#ddd,stroke:#666
