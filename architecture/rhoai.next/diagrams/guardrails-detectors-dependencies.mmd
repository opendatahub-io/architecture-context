graph LR
    GD["Guardrails Detectors<br/>(3 microservices)"]

    %% Internal Platform Dependencies
    GD -->|"inbound REST API<br/>8080/8000 TCP"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployment platform<br/>InferenceService"| KServe["KServe"]
    GD -->|"sidecar mTLS<br/>network security"| Istio["Istio Service Mesh"]

    %% External Service Dependencies
    GD -->|"model storage<br/>9000/TCP HTTP"| S3["S3/Minio Storage"]
    GD -->|"LLM evaluation<br/>HTTP"| vLLM["vLLM Server"]
    GD -->|"model download<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"metrics scrape<br/>/metrics"| GD

    %% Python Framework Dependencies
    subgraph "Python Dependencies (All Detectors)"
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["uvicorn 0.30.5"]
        PromClient["prometheus_client >= 0.18.0"]
        PromFastAPI["prometheus-fastapi-instrumentator >= 7.0.0"]
        PyYAML["PyYAML 6.0.2"]
        HTTPX["httpx 0.27.0"]
    end

    subgraph "Python Dependencies (HuggingFace)"
        Transformers["transformers 4.57.1"]
        PyTorch["torch 2.6.0 (Konflux)"]
        SentencePiece["sentencepiece 0.2.1"]
        TikToken["tiktoken 0.12.0"]
    end

    subgraph "Python Dependencies (Built-in)"
        JSONSchema["jsonschema 4.24.0"]
        XMLSchema["xmlschema 4.1.0"]
    end

    subgraph "Python Dependencies (LLM Judge)"
        VLLMJudge["vllm-judge 0.1.8"]
    end

    GD -.-> FastAPI
    GD -.-> Uvicorn
    GD -.-> PromClient
    GD -.-> Transformers
    GD -.-> PyTorch
    GD -.-> JSONSchema
    GD -.-> VLLMJudge

    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
