graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal Platform Dependencies
    GD -->|"inbound: invokes detectors<br/>HTTP :8080/:8000"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployment: InferenceService<br/>+ ServingRuntime CRDs"| KServe["KServe"]
    GD -->|"mTLS sidecar injection"| Istio["Istio Service Mesh"]
    GD -->|"model download<br/>HTTP :9000"| S3["S3/MinIO<br/>(Model Storage)"]
    GD -->|"evaluation prompts<br/>HTTP configurable"| vLLM["vLLM / OpenAI<br/>LLM Server"]
    GD -.->|"optional model download<br/>HTTPS :443"| HFHub["HuggingFace Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics"| GD

    %% CI/CD
    Konflux["Konflux / Tekton"] -.->|"builds multi-arch<br/>container images"| GD

    %% Python Dependencies (Built-in)
    subgraph CoreDeps["Core Dependencies (All Detectors)"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["Uvicorn 0.30.5"]
        PromClient["prometheus_client"]
        PromFastAPI["prometheus-fastapi-<br/>instrumentator"]
        HTTPX["httpx 0.27.0"]
        PyYAML["PyYAML 6.0.2"]
    end

    subgraph HFDeps["HuggingFace Detector Deps"]
        Transformers["transformers 4.57.1"]
        PyTorch["torch 2.9.1"]
        SentencePiece["sentencepiece 0.2.1"]
        Tiktoken["tiktoken 0.12.0"]
    end

    subgraph LJDeps["LLM Judge Detector Deps"]
        VLLMJudge["vllm-judge 0.1.8"]
    end

    subgraph BIDeps["Built-in Detector Deps"]
        JSONSchema["jsonschema 4.24.0"]
        XMLSchema["xmlschema 4.1.0"]
        Markdown["markdown 3.8.2"]
    end

    GD --- CoreDeps
    GD --- HFDeps
    GD --- LJDeps
    GD --- BIDeps

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
