graph LR
    GD["Guardrails Detectors"]

    %% Internal Platform Dependencies
    GD -->|"inbound API<br/>HTTP/8080, 8000"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"CRD: InferenceService<br/>ServingRuntime"| KServe["KServe"]
    GD -->|"model storage<br/>HTTP/9000"| S3["S3/MinIO"]
    GD -->|"evaluation prompts<br/>HTTP"| vLLM["vLLM / OpenAI-compatible<br/>LLM Server"]

    %% Platform Infrastructure
    GD -->|"sidecar mTLS"| Istio["Istio Service Mesh"]
    GD -->|"metrics scraping<br/>HTTP /metrics"| Prometheus["Prometheus"]

    %% Optional External
    GD -.->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% CI/CD
    Konflux["Konflux / Tekton"] -->|"builds multi-arch<br/>container images"| GD

    %% Key Python Dependencies
    subgraph PythonDeps["Key Python Dependencies"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["Uvicorn 0.30.5"]
        Transformers["transformers 4.57.1<br/>(HF only)"]
        PyTorch["torch 2.9.1<br/>(HF only)"]
        VLLMJudge["vllm-judge 0.1.8<br/>(LLM Judge only)"]
        PromClient["prometheus_client"]
    end

    GD -->|"runtime"| FastAPI
    GD -->|"server"| Uvicorn
    GD -->|"ML models"| Transformers
    GD -->|"inference"| PyTorch
    GD -->|"judge library"| VLLMJudge
    GD -->|"metrics"| PromClient

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style VLLMJudge fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
