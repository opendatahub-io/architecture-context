graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal Platform Dependencies
    GD -->|"inbound REST<br/>8080/8000 TCP<br/>mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"InferenceService<br/>ServingRuntime CRDs"| KServe["KServe"]
    GD -->|"sidecar injection<br/>mTLS"| Istio["Istio<br/>Service Mesh"]

    %% External Service Dependencies
    GD -->|"model weights<br/>9000/TCP HTTP"| S3["S3 / MinIO<br/>Storage"]
    GD -->|"LLM evaluation<br/>8080/TCP HTTP"| vLLM["vLLM Server<br/>(OpenAI-compatible)"]
    GD -.->|"model download<br/>443/TCP HTTPS<br/>(init only)"| HFHub["HuggingFace Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP"| GD

    %% Build Dependencies
    Konflux["Konflux / Tekton"] -.->|"CI/CD pipelines"| GD

    %% Key Python Dependencies
    subgraph PythonDeps["Key Python Libraries"]
        FastAPI["FastAPI 0.136.3"]
        Uvicorn["uvicorn 0.34.0"]
        Transformers["transformers 4.57.3"]
        PyTorch["torch 2.6.0/2.11.0"]
        VLLMJudge["vllm-judge 0.1.8"]
        PromClient["prometheus_client"]
    end

    GD -->|"web framework"| FastAPI
    GD -->|"ASGI server"| Uvicorn
    GD -->|"HF model loading"| Transformers
    GD -->|"ML inference"| PyTorch
    GD -->|"judge evaluation"| VLLMJudge
    GD -->|"metrics"| PromClient

    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style VLLMJudge fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
