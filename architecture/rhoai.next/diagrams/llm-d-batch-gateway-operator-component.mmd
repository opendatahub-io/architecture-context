graph TB
    subgraph Operator["LLM-D Batch Gateway Operator"]
        direction TB
        Controller["LLMBatchGateway Controller<br/>(Reconcile Loop)"]
        MetricsCtrl["MetricsController<br/>(Self-healing Observability)"]
        HelmRenderer["HelmRenderer<br/>(Embedded Chart Engine)"]
        SecretSync["Secret Sync<br/>(Cross-NS via ReferenceGrant)"]

        Controller -->|renders chart| HelmRenderer
        Controller -->|resolves secrets| SecretSync
    end

    %% User interaction
    User[Platform Admin / User] -->|creates/updates| LLMBatchGatewayCR["LLMBatchGateway CR<br/>(batch.llm-d.ai/v1alpha1)"]
    LLMBatchGatewayCR -->|watched by| Controller

    %% Platform operator interaction
    PlatformOp["opendatahub-operator /<br/>rhods-operator"] -->|deploys via kustomize<br/>+ params.env images| Operator

    %% Managed workloads created by Helm rendering
    Controller -->|Server-Side Apply| APIServer["batch-gateway-apiserver<br/>Deployment + Service<br/>8000/TCP"]
    Controller -->|Server-Side Apply| Processor["batch-gateway-processor<br/>Deployment<br/>(inference dispatch)"]
    Controller -->|Server-Side Apply| GC["batch-gateway-gc<br/>Deployment<br/>(job cleanup)"]

    %% Optional resources
    Controller -.->|optional| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -.->|optional| Certificate["Certificate<br/>(cert-manager)"]
    Controller -.->|optional| ServiceMonitor["ServiceMonitor /<br/>PodMonitor"]

    %% MetricsController managed resources
    MetricsCtrl -->|self-heals| MetricsSvc["Operator Metrics Service<br/>8443/TCP"]
    MetricsCtrl -->|self-heals| OperatorSM["Operator ServiceMonitor"]
    MetricsCtrl -->|self-heals| PromRule["PrometheusRule<br/>(reconcile errors, leader loss)"]

    %% Secret sync flow
    SecretSync -->|checks| ReferenceGrant["ReferenceGrant<br/>(source namespace)"]
    SecretSync -->|copies secret to| CRNamespace["CR Namespace"]

    %% External dependencies
    APIServer -->|stores jobs| DB["PostgreSQL / Redis"]
    APIServer -->|stores files| S3["S3 / MinIO"]
    Processor -->|dispatches inference| InferenceGW["Inference Gateway<br/>(vLLM / GIE/EPP)"]
    Processor -->|polls jobs| DB
    Processor -->|writes results| S3

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style MetricsCtrl fill:#4a90e2,stroke:#333,color:#fff
    style HelmRenderer fill:#4a90e2,stroke:#333,color:#fff
    style SecretSync fill:#4a90e2,stroke:#333,color:#fff
    style LLMBatchGatewayCR fill:#f5a623,stroke:#333,color:#fff
    style APIServer fill:#7ed321,stroke:#333,color:#fff
    style Processor fill:#7ed321,stroke:#333,color:#fff
    style GC fill:#7ed321,stroke:#333,color:#fff
    style PlatformOp fill:#9b59b6,stroke:#333,color:#fff
    style DB fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style InferenceGW fill:#e8e8e8,stroke:#333
    style HTTPRoute fill:#d5e8d4,stroke:#82b366
    style Certificate fill:#d5e8d4,stroke:#82b366
    style ServiceMonitor fill:#d5e8d4,stroke:#82b366
