graph TD
    subgraph ServiceAccounts["Service Accounts"]
        OperatorSA["ogx-k8s-operator-<br/>controller-manager"]
        InstanceSA["{instance}-sa<br/>(per OGXServer)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["manager-rolebinding"]
    end

    subgraph InstanceRoleBindings["Per-Instance Role Bindings"]
        IRB["{instance}-rb"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        ManagerRole["manager-role"]
        SCCRole["system:openshift:scc:anyuid"]
    end

    subgraph OGXResources["ogx.io API Group"]
        OGXServers["ogxservers<br/>get, list, watch,<br/>create, update, patch, delete"]
        OGXStatus["ogxservers/status<br/>get, update, patch"]
        OGXFinalizers["ogxservers/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Group"]
        Services["services<br/>get, list, watch,<br/>create, update, patch, delete"]
        ServiceAccts["serviceaccounts<br/>get, list, watch,<br/>create, update, patch, delete"]
        ConfigMaps["configmaps<br/>get, list, watch,<br/>create, update, patch"]
        PVCs["persistentvolumeclaims<br/>get, list, watch,<br/>create, update, patch"]
        Pods["pods<br/>list"]
    end

    subgraph AppsResources["apps API Group"]
        Deployments["deployments<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        NetworkPolicies["networkpolicies<br/>get, list, watch,<br/>create, update, patch, delete"]
        Ingresses["ingresses<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph PolicyResources["policy API Group"]
        PDBs["poddisruptionbudgets<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph AutoscalingResources["autoscaling API Group"]
        HPAs["horizontalpodautoscalers<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        RoleBindingsRes["rolebindings<br/>get, list, watch,<br/>create, update, patch, delete"]
        ClusterRoleBindingsRes["clusterrolebindings<br/>get, list, delete"]
        ClusterRolesRes["clusterroles<br/>get, list, watch"]
    end

    subgraph SecurityResources["security.openshift.io"]
        SCCs["securitycontextconstraints<br/>use"]
        AnyuidSCC["securitycontextconstraints<br/>(anyuid) - use"]
    end

    %% Operator SA bindings
    OperatorSA -->|"bound via"| CRB
    CRB -->|"grants"| ManagerRole

    %% Instance SA bindings
    InstanceSA -->|"bound via"| IRB
    IRB -->|"grants"| SCCRole

    %% Manager role permissions
    ManagerRole -->|"full CRUD"| OGXServers
    ManagerRole -->|"status update"| OGXStatus
    ManagerRole -->|"finalizer"| OGXFinalizers
    ManagerRole -->|"full CRUD"| Deployments
    ManagerRole -->|"full CRUD"| Services
    ManagerRole -->|"full CRUD"| ServiceAccts
    ManagerRole -->|"read + update"| ConfigMaps
    ManagerRole -->|"read + update"| PVCs
    ManagerRole -->|"list only"| Pods
    ManagerRole -->|"full CRUD"| NetworkPolicies
    ManagerRole -->|"full CRUD"| Ingresses
    ManagerRole -->|"full CRUD"| PDBs
    ManagerRole -->|"full CRUD"| HPAs
    ManagerRole -->|"full CRUD"| RoleBindingsRes
    ManagerRole -->|"read + delete"| ClusterRoleBindingsRes
    ManagerRole -->|"read only"| ClusterRolesRes
    ManagerRole -->|"use"| SCCs
    ManagerRole -->|"use"| AnyuidSCC

    %% SCC role
    SCCRole -->|"allows anyuid<br/>FSGroup 1001"| AnyuidSCC

    %% Styling
    style OperatorSA fill:#4a90e2,color:#fff
    style InstanceSA fill:#4a90e2,color:#fff
    style ManagerRole fill:#f5a623,color:#fff
    style SCCRole fill:#f5a623,color:#fff
    style CRB fill:#e8e8e8,color:#333
    style IRB fill:#e8e8e8,color:#333
    style OGXServers fill:#7ed321,color:#fff
    style OGXStatus fill:#7ed321,color:#fff
    style OGXFinalizers fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ServiceAccts fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style PVCs fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style NetworkPolicies fill:#7ed321,color:#fff
    style Ingresses fill:#7ed321,color:#fff
    style PDBs fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style RoleBindingsRes fill:#7ed321,color:#fff
    style ClusterRoleBindingsRes fill:#7ed321,color:#fff
    style ClusterRolesRes fill:#7ed321,color:#fff
    style SCCs fill:#d4380d,color:#fff
    style AnyuidSCC fill:#d4380d,color:#fff
