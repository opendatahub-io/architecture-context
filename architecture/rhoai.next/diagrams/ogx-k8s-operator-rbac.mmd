    style ControllerSA fill:#4a90e2,stroke:#333,color:#fff
    style InstanceSA fill:#4a90e2,stroke:#333,color:#fff
    style ManagerRole fill:#f5a623,stroke:#333,color:#fff
    style LeaderElectionRole fill:#f5a623,stroke:#333,color:#fff
    style AnyuidSCC fill:#f5a623,stroke:#333,color:#fff
    style ManagerBinding fill:#dae8fc,stroke:#6c8ebf
    style LeaderElectionBinding fill:#dae8fc,stroke:#6c8ebf
    style InstanceSCCBinding fill:#dae8fc,stroke:#6c8ebf
