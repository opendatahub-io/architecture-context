graph TD
    subgraph ServiceAccounts["Service Accounts"]
        ControllerSA["controller-manager<br/>(operator namespace)"]
        InstanceSA["{instance}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        ManagerBinding["manager-rolebinding<br/>(cluster-scoped)"]
        LeaderElectionBinding["leader-election-role-binding<br/>(operator namespace)"]
        InstanceSCCBinding["{instance}-rb<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        ManagerRole["manager-role"]
        LeaderElectionRole["leader-election-role"]
        AnyuidSCC["system:openshift:scc:anyuid"]
    end

    subgraph OGXResources["ogx.io Resources"]
        OGXServers["ogxservers<br/>get, list, watch, create,<br/>update, patch, delete"]
        OGXServersStatus["ogxservers/status<br/>get, update, patch"]
        OGXServersFinalizers["ogxservers/finalizers<br/>update"]
    end

    subgraph AppResources["apps Resources"]
        Deployments["deployments<br/>get, list, watch, create,<br/>update, patch, delete"]
        ReplicaSets["replicasets<br/>get, list, watch"]
    end

    subgraph CoreResources["core Resources"]
        Services["services, serviceaccounts<br/>get, list, watch, create,<br/>update, patch, delete"]
        ConfigMapsPVCs["configmaps, persistentvolumeclaims<br/>get, list, watch, create,<br/>update, patch"]
        Secrets["secrets<br/>get, list, watch"]
        Pods["pods<br/>list"]
    end

    subgraph NetworkResources["networking.k8s.io Resources"]
        NetworkPolicies["networkpolicies<br/>full CRUD"]
        Ingresses["ingresses<br/>full CRUD"]
    end

    subgraph PolicyResources["policy Resources"]
        PDBs["poddisruptionbudgets<br/>full CRUD"]
    end

    subgraph AutoscalingResources["autoscaling Resources"]
        HPAs["horizontalpodautoscalers<br/>full CRUD"]
    end

    subgraph MonitoringResources["monitoring.coreos.com Resources"]
        ServiceMonitors["servicemonitors<br/>full CRUD"]
        PrometheusRules["prometheusrules<br/>full CRUD"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io Resources"]
        RoleBindings["rolebindings<br/>full CRUD"]
        ClusterRoleBindingsRes["clusterrolebindings<br/>get, list, delete"]
        ClusterRolesRes["clusterroles<br/>get, list, watch"]
    end

    subgraph SecurityResources["security.openshift.io Resources"]
        SCCUse["securitycontextconstraints<br/>use"]
        SCCAnyuid["securitycontextconstraints (anyuid)<br/>use"]
    end

    subgraph APIExtResources["apiextensions.k8s.io Resources"]
        CRDs["customresourcedefinitions<br/>get, list, watch"]
    end

    %% Bindings
    ControllerSA -->|"bound via"| ManagerBinding
    ControllerSA -->|"bound via"| LeaderElectionBinding
    InstanceSA -->|"bound via"| InstanceSCCBinding

    ManagerBinding -->|"grants"| ManagerRole
    LeaderElectionBinding -->|"grants"| LeaderElectionRole
    InstanceSCCBinding -->|"grants"| AnyuidSCC

    %% Manager role permissions
    ManagerRole -->|"permits"| OGXServers
    ManagerRole -->|"permits"| OGXServersStatus
    ManagerRole -->|"permits"| OGXServersFinalizers
    ManagerRole -->|"permits"| Deployments
    ManagerRole -->|"permits"| ReplicaSets
    ManagerRole -->|"permits"| Services
    ManagerRole -->|"permits"| ConfigMapsPVCs
    ManagerRole -->|"permits"| Secrets
    ManagerRole -->|"permits"| Pods
    ManagerRole -->|"permits"| NetworkPolicies
    ManagerRole -->|"permits"| Ingresses
    ManagerRole -->|"permits"| PDBs
    ManagerRole -->|"permits"| HPAs
    ManagerRole -->|"permits"| ServiceMonitors
    ManagerRole -->|"permits"| PrometheusRules
    ManagerRole -->|"permits"| RoleBindings
    ManagerRole -->|"permits"| ClusterRoleBindingsRes
    ManagerRole -->|"permits"| ClusterRolesRes
    ManagerRole -->|"permits"| SCCUse
    ManagerRole -->|"permits"| SCCAnyuid
    ManagerRole -->|"permits"| CRDs

