graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance}-sa<br/>(per user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Proxy["proxy-rolebinding<br/>(cluster-scoped)"]
        CRB_Instance["{instance}-rb<br/>(per namespace)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Proxy
    SA_Manager -->|bound via| RB_Leader
    SA_Instance -->|bound via| CRB_Instance

    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    CRB_Instance -->|grants| CR_SCC
    RB_Leader -->|grants| R_Leader

    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB

        subgraph OGXResources["ogx.io"]
            OGXServers["ogxservers<br/>get, list, watch, create,<br/>update, patch, delete"]
            OGXStatus["ogxservers/status<br/>get, patch, update"]
            OGXFinalizers["ogxservers/finalizers<br/>update"]
        end

        subgraph CoreResources["core ('')"]
            ConfigMaps["configmaps, pvcs<br/>create, get, list,<br/>patch, update, watch"]
            Secrets["secrets<br/>get, list, watch<br/>(read-only)"]
            Services["services, serviceaccounts<br/>create, delete, get, list,<br/>patch, update, watch"]
            Pods["pods<br/>list"]
        end

        subgraph AppsResources["apps"]
            Deployments["deployments<br/>create, delete, get, list,<br/>patch, update, watch"]
            ReplicaSets["replicasets<br/>get, list, watch"]
        end

        subgraph NetworkResources["networking.k8s.io"]
            Ingresses["ingresses, networkpolicies<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph AutoscalingResources["autoscaling"]
            HPAs["horizontalpodautoscalers<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph PolicyResources["policy"]
            PDBs["poddisruptionbudgets<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph MonitoringResources["monitoring.coreos.com"]
            Monitors["servicemonitors,<br/>prometheusrules<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph RBACResources["rbac.authorization.k8s.io"]
            CRBs["clusterrolebindings<br/>delete, get, list"]
            CRs["clusterroles<br/>get, list, watch"]
            RBs["rolebindings<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph APIExtResources["apiextensions.k8s.io"]
            CRDs["customresourcedefinitions<br/>get, list, watch"]
        end

        subgraph SCCResources["security.openshift.io"]
            SCC["securitycontextconstraints<br/>(anyuid) → use"]
        end
    end

    CR_Manager -->|grants access to| OGXResources
    CR_Manager -->|grants access to| CoreResources
    CR_Manager -->|grants access to| AppsResources
    CR_Manager -->|grants access to| NetworkResources
    CR_Manager -->|grants access to| AutoscalingResources
    CR_Manager -->|grants access to| PolicyResources
    CR_Manager -->|grants access to| MonitoringResources
    CR_Manager -->|grants access to| RBACResources
    CR_Manager -->|grants access to| APIExtResources
    CR_Manager -->|grants access to| SCCResources

    subgraph ProxyPermissions["proxy-role Permissions"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews → create"]
        SubjectAccess["authorization.k8s.io<br/>subjectaccessreviews → create"]
    end

    CR_Proxy -->|grants access to| ProxyPermissions

    subgraph LeaderPermissions["leader-election-role Permissions"]
        LeaderConfigMaps["configmaps<br/>full CRUD"]
        LeaderLeases["coordination.k8s.io/leases<br/>full CRUD"]
        LeaderEvents["events<br/>create, patch"]
    end

    R_Leader -->|grants access to| LeaderPermissions

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Proxy fill:#f5a623,stroke:#333,color:#fff
    style CR_SCC fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_Proxy fill:#e8e8e8,stroke:#333
    style CRB_Instance fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style OGXServers fill:#7ed321,stroke:#333
    style OGXStatus fill:#7ed321,stroke:#333
    style OGXFinalizers fill:#7ed321,stroke:#333
    style Secrets fill:#ffcccc,stroke:#cc0000
