graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Browser / CLI Client"]
    end

    subgraph Ingress["INGRESS (Istio Gateway - kubeflow-gateway)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP external → 8080/TCP internal<br/>TLS 1.2+ Termination<br/>VirtualService routing"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT - DestinationRule ISTIO_MUTUAL)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            direction TB

            MRService["model-registry-service<br/>ClusterIP :8080/TCP<br/>SA: default<br/>AuthZ: ALLOW all (mesh)<br/>Image: quay.io/opendatahub/model-registry"]

            CatalogService["model-catalog<br/>ClusterIP :8080/TCP<br/>API: /api/model_catalog/v1alpha1/*<br/>API: /api/mcp_catalog/v1alpha1/*"]

            UIService["model-registry-ui-service<br/>ClusterIP :8080/TCP<br/>SA: model-registry-ui<br/>Auth: kubeflow-userid / Bearer"]

            ControllerMetrics["controller-manager-metrics<br/>ClusterIP :8443/TCP HTTPS<br/>SA: controller-manager<br/>Auth: TokenReview+SAR<br/>NetworkPolicy: metrics label"]

            MRDB["model-registry-db<br/>ClusterIP :3306/TCP<br/>MySQL 8.3+<br/>Auth: Username/password"]

            CatalogDB["model-catalog-postgres<br/>ClusterIP :5432/TCP<br/>PostgreSQL 16+<br/>Auth: Username/password"]
        end

        subgraph NS_KServe["KServe Init Containers"]
            CSI["storage-initializer<br/>Init Container<br/>Resolves model-registry:// URIs"]
        end

        subgraph NS_Jobs["Batch Jobs"]
            AsyncJob["async-upload-job<br/>Python K8s Job<br/>On-demand"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>ServiceAccount token"]
        HuggingFace["Hugging Face API<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>API key (optional)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / access keys"]
        OCIReg["OCI Registries<br/>443/TCP HTTPS TLS 1.2+<br/>Registry credentials"]
        Prometheus["Prometheus<br/>Scrapes :8443/TCP HTTPS<br/>TokenReview+SAR"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform auth"| Gateway

    %% Ingress → Services (mTLS)
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| MRService
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| CatalogService
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| UIService

    %% Internal service communication
    UIService -->|"HTTP/8080<br/>Forwarded token"| MRService
    UIService -->|"HTTP/8080<br/>Forwarded token"| CatalogService
    UIService -->|"HTTPS/443<br/>User/SA token"| K8sAPI

    %% Controller
    ControllerMetrics -->|"HTTP/8080<br/>Bearer Token"| MRService
    ControllerMetrics -->|"HTTPS/443<br/>SA token"| K8sAPI

    %% Database connections
    MRService -->|"MySQL/3306 or PG/5432<br/>Optional TLS<br/>Username/password"| MRDB
    CatalogService -->|"PG/5432<br/>Username/password"| CatalogDB

    %% CSI & Jobs
    CSI -->|"HTTP/8080<br/>No auth"| MRService
    AsyncJob -->|"HTTP/8080<br/>Bearer Token"| MRService
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| OCIReg

    %% External egress
    CatalogService -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| HuggingFace
    Prometheus -->|"HTTPS/8443<br/>TLS self-signed<br/>TokenReview+SAR"| ControllerMetrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef job fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class MRService,CatalogService,UIService,ControllerMetrics servicemesh
    class MRDB,CatalogDB database
    class CSI,AsyncJob job
    class K8sAPI,HuggingFace,S3,OCIReg,Prometheus externalservice
