graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist<br/>Pipeline"]
    end

    subgraph Ingress["INGRESS (Istio Service Mesh)"]
        VS["Istio VirtualService<br/>kubeflow-gateway<br/>8080/TCP<br/>mTLS ISTIO_MUTUAL"]
        DR["DestinationRule<br/>mTLS ISTIO_MUTUAL"]
        AP["AuthorizationPolicy<br/>ALLOW authenticated mesh"]
    end

    subgraph CoreServices["CORE SERVICES (Internal - mTLS mesh)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            MRService["model-registry-service<br/>SA: model-registry-sa<br/>8080/TCP HTTP<br/>No app-level auth"]
            MRUI["model-registry-ui-service<br/>8080/TCP HTTP"]
            Catalog["model-catalog<br/>8080/TCP HTTP"]
        end

        subgraph NS_DB["Database Layer"]
            MySQL["MySQL 8.3<br/>3306/TCP<br/>Optional TLS 1.2+<br/>User/Pass from Secret"]
            PostgreSQL["PostgreSQL 16+<br/>5432/TCP<br/>Optional TLS 1.2+<br/>User/Pass from Secret"]
            CatalogPG["model-catalog-postgres<br/>5432/TCP<br/>User/Pass from Secret"]
        end

        subgraph NS_Controller["Controller"]
            ISController["inferenceservice-controller<br/>SA: controller-manager<br/>8081/TCP (probes)"]
        end

        subgraph NS_CSI["KServe Init Container"]
            CSI["mr-storage-initializer<br/>No listening port<br/>CLI tool"]
        end

        subgraph NS_Job["On-demand Job"]
            AsyncJob["async-upload Job<br/>Python batch<br/>No listening port"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Creds"]
        Sigstore["Sigstore<br/>(Fulcio/Rekor/TSA)<br/>443/TCP HTTPS<br/>K8s SA Token OIDC"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (optional)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    %% Ingress flows
    Client -->|"HTTP/8080<br/>Istio mTLS<br/>AuthorizationPolicy"| VS
    VS --> DR
    DR -->|"HTTP/8080<br/>mTLS STRICT<br/>Service Identity"| MRService

    %% Internal service flows
    MRUI -->|"HTTP/8080<br/>Istio mTLS"| MRService
    ISController -->|"HTTP/8080<br/>Bearer Token"| MRService
    CSI -->|"HTTP/8080<br/>No auth"| MRService
    AsyncJob -->|"HTTP/8080<br/>Bearer Token"| MRService

    %% Database flows
    MRService -->|"MySQL/3306<br/>Optional TLS 1.2+<br/>User/Pass Secret"| MySQL
    MRService -->|"PostgreSQL/5432<br/>Optional TLS 1.2+<br/>User/Pass Secret"| PostgreSQL
    Catalog -->|"PostgreSQL/5432<br/>User/Pass Secret"| CatalogPG

    %% External service flows
    Catalog -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| HFHub
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Creds"| OCI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>K8s SA OIDC"| Sigstore
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage Creds"| S3
    ISController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef coreservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class VS,DR,AP ingress
    class MRService,MRUI,Catalog,ISController,CSI,AsyncJob coreservice
    class MySQL,PostgreSQL,CatalogPG database
    class S3,OCI,Sigstore,HFHub,K8sAPI externalservice
