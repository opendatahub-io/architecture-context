graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Istio Gateway"]
        Gateway["Istio Gateway<br/>(kubeflow-gateway)<br/>443/TCP → 8080/TCP<br/>TLS 1.2+<br/>AuthorizationPolicy: ALLOW"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Model Registry Services"]
            MRService["model-registry-service<br/>ClusterIP 8080/TCP<br/>HTTP + Istio mTLS<br/>No built-in auth<br/>FIPS: strictfipsruntime"]
            CatalogService["model-catalog<br/>ClusterIP 8080/TCP<br/>HTTP + Istio mTLS<br/>No built-in auth"]
            UIService["model-registry-ui-service<br/>ClusterIP 8080/TCP<br/>HTTP + Istio mTLS<br/>Auth: kubeflow-userid / Bearer"]
        end

        subgraph NS_Controller["Controller"]
            ControllerMgr["controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>SA: controller-manager<br/>Auth: TokenReview+SAR"]
        end

        subgraph NS_Utilities["Utility Components"]
            CSI["storage-initializer<br/>(init container)<br/>No listening port<br/>ClusterStorageContainer"]
            AsyncJob["async-upload-job<br/>(Python K8s Job)<br/>No listening port<br/>Image: ubi9/python-312"]
        end
    end

    subgraph DataLayer["DATA LAYER (Internal)"]
        MySQL["MySQL 8.3+<br/>ClusterIP 3306/TCP<br/>Optional TLS<br/>Auth: Username/password<br/>Secret: model-registry-db-secrets"]
        PostgreSQL["PostgreSQL 16+<br/>ClusterIP 5432/TCP<br/>Optional TLS<br/>Auth: Username/password<br/>Secret: model-catalog-postgres"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["Hugging Face API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key (optional)"]
        OCIRegistry["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Registry credentials"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access keys"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>Auth: SA token / User token"]
        Prometheus["Prometheus<br/>Scrapes 8443/TCP"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway

    %% Ingress → Services
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| MRService
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| CatalogService
    Gateway -->|"HTTP/8080<br/>Istio mTLS<br/>VirtualService"| UIService

    %% BFF → Internal
    UIService -->|"HTTP/8080<br/>Forwarded token"| MRService
    UIService -->|"HTTP/8080<br/>Forwarded token"| CatalogService
    UIService -->|"HTTPS/443<br/>User token / SA"| K8sAPI

    %% Controller → Internal
    ControllerMgr -->|"HTTP/8080<br/>Bearer Token"| MRService
    ControllerMgr -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    %% CSI → Internal + External
    CSI -->|"HTTP/8080<br/>No Auth"| MRService
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3

    %% Async Job → Internal + External
    AsyncJob -->|"HTTP/8080<br/>Bearer Token"| MRService
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| OCIRegistry

    %% Services → Data Layer
    MRService -->|"MySQL/3306<br/>Optional TLS<br/>Username/password"| MySQL
    MRService -->|"PostgreSQL/5432<br/>Optional TLS<br/>Username/password"| PostgreSQL
    CatalogService -->|"PostgreSQL/5432<br/>Username/password"| PostgreSQL
    CatalogService -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| HuggingFace

    %% Prometheus → Controller
    Prometheus -->|"HTTPS/8443<br/>TLS (self-signed)<br/>TokenReview+SAR"| ControllerMgr

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datalayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef utility fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class MRService,CatalogService,UIService servicemesh
    class ControllerMgr servicemesh
    class CSI,AsyncJob utility
    class MySQL,PostgreSQL datalayer
    class HuggingFace,OCIRegistry,S3,K8sAPI,Prometheus externalservice
