graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist"]
        UIBFF["Model Registry UI (BFF)<br/>8080/TCP"]
    end

    subgraph Ingress["INGRESS (Istio Service Mesh)"]
        Gateway["Istio VirtualService<br/>kubeflow-gateway<br/>8080/TCP<br/>mTLS: ISTIO_MUTUAL<br/>AuthorizationPolicy: ALLOW"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            MRProxy["model-registry (proxy)<br/>SA: model-registry<br/>8080/TCP HTTP<br/>v1alpha3 REST API (50+ routes)"]
            MRCatalog["model-catalog<br/>8080/TCP HTTP"]
        end

        subgraph NS_DB["Database Layer"]
            MySQL["MySQL 8.3<br/>3306/TCP<br/>Optional TLS 1.2+"]
            PostgreSQL["PostgreSQL 16+<br/>5432/TCP<br/>Optional TLS 1.2+"]
            CatalogPG["Catalog PostgreSQL<br/>5432/TCP"]
        end

        subgraph NS_Controller["Controller (Optional)"]
            ISVCCtrl["inferenceservice-controller<br/>SA: controller-manager<br/>8081/TCP (health)"]
        end

        subgraph NS_KServe["KServe Pod (Init Container)"]
            CSI["mr-storage-initializer<br/>model-registry:// protocol"]
        end
    end

    subgraph BatchJobs["BATCH JOBS (Ephemeral)"]
        AsyncJob["async-upload job<br/>Python K8s Job<br/>Bearer Token auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Creds"]
        HF["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (optional)"]
        Sigstore["Sigstore<br/>(Fulcio/Rekor/TSA)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>K8s SA Token"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    %% External to Ingress
    Client -->|"HTTP/8080<br/>Istio mTLS<br/>AuthzPolicy"| Gateway
    UIBFF -->|"HTTP/8080<br/>Istio mTLS"| Gateway

    %% Ingress to Service
    Gateway -->|"HTTP/8080<br/>mTLS ISTIO_MUTUAL<br/>Service Identity"| MRProxy

    %% Service to Database
    MRProxy -->|"MySQL/3306<br/>Optional TLS 1.2+<br/>User/Pass (Secret)"| MySQL
    MRProxy -->|"PostgreSQL/5432<br/>Optional TLS 1.2+<br/>User/Pass (Secret)"| PostgreSQL
    MRCatalog -->|"PostgreSQL/5432<br/>User/Pass (Secret)"| CatalogPG

    %% Controller flows
    ISVCCtrl -->|"HTTP/8080<br/>Bearer Token"| MRProxy
    ISVCCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% CSI flows
    CSI -->|"HTTP/8080<br/>No Auth<br/>In-cluster"| MRProxy
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage Creds"| S3

    %% Async job flows
    AsyncJob -->|"HTTP/8080<br/>Bearer Token"| MRProxy
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Creds"| OCI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>K8s SA (OIDC)"| Sigstore

    %% Catalog external
    MRCatalog -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef batch fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,UIBFF external
    class Gateway ingress
    class MRProxy,MRCatalog,ISVCCtrl,CSI servicemesh
    class MySQL,PostgreSQL,CatalogPG database
    class AsyncJob batch
    class S3,OCI,HF,Sigstore,K8sAPI externalservice
