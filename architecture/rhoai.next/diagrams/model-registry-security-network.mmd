graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(UI / CLI / API)"]
    end

    subgraph Ingress["INGRESS (DMZ) - Istio"]
        Gateway["Istio Ingress Gateway<br/>kubeflow-gateway<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ / ISTIO_MUTUAL<br/>AuthorizationPolicy"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Namespace: {model-registry-namespace}"]
            Proxy["Model Registry Proxy<br/>SA: model-registry<br/>:8080/TCP HTTP<br/>FIPS: strictfipsruntime<br/>TLS 1.2+ min, FIPS ciphers"]

            Catalog["Model Registry Catalog<br/>:8080/TCP HTTP<br/>Leader election: pglock<br/>/api/model_catalog/v1alpha1/*<br/>/api/mcp_catalog/v1alpha1/*"]

            Controller["ISVC Controller<br/>SA: controller-manager<br/>:8081/TCP health<br/>:8443/TCP metrics (HTTPS)<br/>Authn/Authz: TokenReview"]

            CSI["CSI Storage Initializer<br/>(init container)<br/>model-registry:// URI"]

            UI["model-registry-ui<br/>:8080/TCP HTTP<br/>No auth (platform-delegated)"]

            UploadJob["Async Upload Job<br/>(K8s Job, on-demand)<br/>Python + skopeo"]
        end
    end

    subgraph DataStores["INTERNAL DATA STORES"]
        MySQL[("MySQL 8.3+<br/>:3306/TCP<br/>Optional TLS<br/>Auth: user/pass")]
        PostgresProxy[("PostgreSQL 16+<br/>:5432/TCP<br/>Optional TLS<br/>Auth: user/pass")]
        PostgresCatalog[("Catalog PostgreSQL<br/>:5432/TCP<br/>No encryption<br/>Auth: user/pass")]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace API<br/>huggingface.co<br/>:443 HTTPS TLS 1.2+<br/>Auth: Bearer (HF_API_KEY)"]
        S3["AWS S3<br/>s3.amazonaws.com<br/>:443 HTTPS TLS 1.2+<br/>Auth: AWS IAM"]
        OCIReg["OCI Registry<br/>:443 HTTPS TLS<br/>Auth: Docker registry"]
        SigstoreSvc["Sigstore<br/>(Fulcio/Rekor/TUF)<br/>:443 HTTPS TLS 1.2+<br/>Auth: Identity token"]
        K8sAPI["Kubernetes API<br/>:443 HTTPS TLS<br/>Auth: SA token"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway

    %% Ingress → Services
    Gateway -->|"HTTP/8080<br/>Istio mTLS STRICT<br/>AuthorizationPolicy"| Proxy
    Gateway -->|"HTTP/8080<br/>Istio mTLS STRICT<br/>AuthorizationPolicy"| Catalog

    %% Internal service flows
    Controller -->|"HTTP/8080<br/>No encryption<br/>Bearer token (optional)"| Proxy
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    CSI -->|"HTTP/8080<br/>No encryption<br/>No auth"| Proxy
    UI -->|"HTTP/8080<br/>No encryption"| Proxy
    UI -->|"HTTP/8080<br/>No encryption"| Catalog
    UploadJob -->|"HTTP(S)/8080-443<br/>Configurable<br/>Bearer token"| Proxy

    %% Service → Data stores
    Proxy -->|"MySQL/3306 or PG/5432<br/>Optional TLS<br/>user/pass"| MySQL
    Proxy -->|"MySQL/3306 or PG/5432<br/>Optional TLS<br/>user/pass"| PostgresProxy
    Catalog -->|"PG/5432<br/>No encryption<br/>user/pass"| PostgresCatalog

    %% Service → External
    Catalog -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_API_KEY"| HF
    UploadJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    UploadJob -->|"HTTPS/443<br/>TLS<br/>Docker auth"| OCIReg
    UploadJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Identity token"| SigstoreSvc
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Provider auth"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datastore fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Proxy,Catalog,Controller,CSI,UI,UploadJob servicemesh
    class MySQL,PostgresProxy,PostgresCatalog datastore
    class HF,S3,OCIReg,SigstoreSvc,K8sAPI externalservice
