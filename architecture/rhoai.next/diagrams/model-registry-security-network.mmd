graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Dashboard / SDK"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP &rarr; 8080/TCP<br/>TLS 1.3 Termination<br/>RequestAuthentication"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            direction TB
            MRProxy["model-registry proxy<br/>SA: model-registry<br/>ClusterIP :8080/TCP<br/>Image: odh-model-registry-container"]
            Catalog["model-catalog server<br/>ClusterIP :8080/TCP<br/>Leader election: PG advisory locks"]
            UIBFF["model-registry UI BFF<br/>ClusterIP :8080/TCP<br/>Auth: Bearer token / SA"]
            MRController["model-registry controller<br/>SA: controller-manager<br/>:8081/TCP health, :8443/TCP metrics<br/>Metrics auth: RBAC + TLS"]

            subgraph DB_Zone["Database (excluded from Istio mesh)"]
                MRDB["model-registry-db<br/>ClusterIP :3306/TCP or :5432/TCP<br/>Auth: username/password"]
                CatalogDB["model-catalog-postgres<br/>ClusterIP :5432/TCP<br/>Auth: username/password"]
            end

            MRProxy -->|"SQL (GORM)<br/>Configurable TLS<br/>Client cert + CA"| MRDB
            Catalog -->|"SQL<br/>Username/password"| CatalogDB
            UIBFF -->|"HTTP/8080<br/>Forwards API"| MRProxy
            UIBFF -->|"HTTP/8080<br/>Forwards catalog"| Catalog
            MRController -->|"HTTP/8080<br/>mTLS<br/>Bearer Token"| MRProxy
        end

        subgraph NS_User["Namespace: user-namespace"]
            CSI["CSI storage initializer<br/>Init Container<br/>model-registry:// URI"]
            AsyncJob["async-upload job<br/>Python 3.12 K8s Job<br/>odh-model-registry-job-async-upload-rhel9"]
        end

        CSI -->|"HTTP/8080<br/>Resolve URI"| MRProxy
    end

    subgraph PlatformDeps["INTERNAL PLATFORM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        KServe["KServe<br/>InferenceService CRD<br/>ClusterStorageContainer"]
        Dashboard["OpenShift AI Dashboard<br/>REST Consumer"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HF["HuggingFace API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key (optional)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker config auth"]
        SigStore["Sigstore<br/>(Fulcio/Rekor/TUF)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>OAuth2 / kubeflow-userid"| Gateway
    Gateway -->|"HTTP/8080<br/>Istio mTLS (ISTIO_MUTUAL)<br/>AuthorizationPolicy"| MRProxy
    Gateway -->|"HTTP/8080<br/>Istio mTLS"| Catalog

    %% Controller flows
    MRController -->|"HTTPS/443<br/>TLS<br/>SA token<br/>Watch InferenceService"| K8sAPI
    KServe -.->|"CRD Watch"| MRController

    %% Dashboard
    Dashboard -->|"HTTP/8080<br/>Istio mTLS"| MRProxy

    %% Catalog external
    Catalog -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| HF

    %% CSI external
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Provider auth"| S3

    %% Async job flows
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / Docker / API key"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker config"| OCI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC token"| SigStore
    AsyncJob -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| MRProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#e6d5f5,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class MRProxy,Catalog,UIBFF,MRController,CSI,AsyncJob servicemesh
    class MRDB,CatalogDB database
    class K8sAPI,KServe,Dashboard platform
    class HF,S3,OCI,SigStore externalservice
