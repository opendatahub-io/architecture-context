graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["RHOAI Gateway /<br/>KServe HTTPRoute<br/>TLS Termination"]
        KRBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP → 8000/TCP<br/>RBAC Authentication"]
    end

    subgraph Application["APPLICATION (Pod Boundary)"]
        direction TB

        subgraph HTTPLayer["HTTP API (Port 8000/TCP)"]
            OpenAIAPI["vLLM OpenAI API Server<br/>(FastAPI/uvicorn)<br/>TLS: Optional (hot-reload)<br/>Auth: API Key (optional)"]
        end

        subgraph GRPCLayer["gRPC API (Port 50051/TCP)"]
            GRPCServer["vLLM gRPC Server<br/>⚠ PLAINTEXT (no TLS)<br/>Auth: None"]
        end

        subgraph EngineLayer["Engine (In-Process)"]
            Engine["vLLM Engine v1<br/>+ CPU Model Executor<br/>+ C++ Extensions<br/>ZeroMQ IPC"]
        end

        OpenAIAPI --> Engine
        GRPCServer --> Engine
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Trusted)"]
        Prometheus["Prometheus /<br/>OpenShift Monitoring<br/>HTTP scrape"]
        KServe["KServe / ModelMesh<br/>Lifecycle Management"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>TLS (configurable)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Credentials"]
        PyTorchHub["PyTorch Model Hub<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        MCPServers["MCP Tool Servers<br/>HTTP (SSE)<br/>Configurable"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway

    %% Ingress → Application
    Gateway -->|"HTTPS/8443<br/>TLS<br/>RBAC"| KRBACProxy
    KRBACProxy -->|"HTTP/8000<br/>localhost<br/>API Key (optional)"| OpenAIAPI

    %% Cluster Internal → Application
    Prometheus -->|"HTTP/8000<br/>No Auth<br/>/metrics"| OpenAIAPI
    KServe -.->|"manages lifecycle<br/>autoscaling, routing"| Application

    %% Application → Cluster Internal
    Engine -->|"OTLP gRPC/4317<br/>TLS (configurable)"| OTEL

    %% Application → External Services
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Engine -->|"HTTPS/443<br/>TLS 1.2+"| PyTorchHub
    Engine -->|"HTTP (SSE)<br/>Configurable"| MCPServers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,KRBACProxy ingress
    class OpenAIAPI,Engine application
    class GRPCServer warning
    class Prometheus,KServe,OTEL clusterinternal
    class HFHub,S3,PyTorchHub,MCPServers externalservice
