graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Managed by KServe)"]
        KServeGW["KServe InferenceService Gateway<br/>HTTPRoute/Route → vLLM<br/>TLS managed by KServe/Istio"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph VllmPod["vLLM CPU Pod"]
            HTTPServer["vllm-openai<br/>ClusterIP 8000/TCP<br/>HTTP(S) - Configurable TLS<br/>Bearer API Key on /v1/* only<br/>⚠️ 20+ unauthenticated endpoints"]
            GRPCServer["vllm-grpc<br/>ClusterIP 50051/TCP<br/>gRPC - No encryption<br/>No auth"]
            MetricsEP["Prometheus Metrics<br/>8000/TCP (shared)<br/>HTTP - No auth"]
        end

        subgraph Optional["Optional Distributed (No Encryption)"]
            Gloo["Gloo Backend<br/>TCP - No encryption"]
            Ray["Ray Cluster<br/>6379/TCP - No encryption"]
        end

        Prometheus["Prometheus<br/>Metrics Collection"]
    end

    subgraph EgressServices["EGRESS (External Services)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer HF_TOKEN"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM credentials"]
        OTLPCol["OTLP Collector<br/>gRPC/HTTP Configurable<br/>⚠️ Insecure by default"]
        RHStats["Red Hat Stats<br/>console.redhat.com<br/>443/TCP HTTPS TLS 1.2+<br/>No auth"]
    end

    %% External flows
    Client -->|"HTTP(S)/8000<br/>Configurable TLS<br/>Bearer API Key"| KServeGW
    KServeGW -->|"HTTP(S)/8000<br/>Configurable TLS<br/>Bearer forwarded"| HTTPServer
    Client -->|"gRPC/50051<br/>No encryption<br/>No auth"| GRPCServer

    %% Internal flows
    HTTPServer -.->|"TCP"| Gloo
    HTTPServer -.->|"Ray/6379"| Ray
    Prometheus -->|"HTTP/8000<br/>Scrape"| MetricsEP

    %% Egress flows
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    HTTPServer -->|"gRPC/HTTP<br/>⚠️ Insecure default"| OTLPCol
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+"| RHStats

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egresssvc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class KServeGW ingress
    class HTTPServer,MetricsEP internal
    class GRPCServer danger
    class Gloo,Ray warning
    class Prometheus internal
    class HFHub,S3,RHStats egresssvc
    class OTLPCol danger
