graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Gateway"]
    end

    subgraph ServiceBoundary["SERVICE BOUNDARY (vLLM Pod)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["vLLM OpenAI API Server<br/>FastAPI + uvicorn<br/>8000/TCP HTTP(S)<br/>Configurable TLS<br/>Bearer Token on /v1/* only"]
            GRPCServer["gRPC Server<br/>smg-grpc-servicer<br/>50051/TCP gRPC<br/>No encryption<br/>No auth"]
            MetricsEndpoint["Prometheus Metrics<br/>8000/TCP (shared)<br/>HTTP<br/>No auth"]
        end

        subgraph UnauthEndpoints["UNAUTHENTICATED ENDPOINTS (Risk)"]
            HealthEndpoints["/health, /version, /load<br/>Read-only (Low Risk)"]
            OpEndpoints["/pause, /resume, /sleep,<br/>/wake_up, /update_weights,<br/>/collective_rpc<br/>(CRITICAL Risk)"]
            CacheEndpoints["/reset_prefix_cache,<br/>/reset_mm_cache<br/>(Medium Risk)"]
        end
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        direction TB
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
        OTLPCollector["OTLP Collector<br/>Configurable port<br/>gRPC/HTTP<br/>Default: INSECURE"]
        RHStats["Red Hat Stats<br/>console.redhat.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        S3Storage["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph DistributedOpt["OPTIONAL DISTRIBUTED"]
        Gloo["Gloo Backend<br/>TCP (no encryption)<br/>Tensor parallelism"]
        RayCluster["Ray Cluster<br/>6379/TCP<br/>No encryption"]
    end

    %% Inbound flows
    Client -->|"HTTP(S)/8000<br/>Configurable TLS<br/>Bearer API Key"| APIServer
    Client -->|"gRPC/50051<br/>No encryption"| GRPCServer

    %% Internal
    APIServer -.-> HealthEndpoints
    APIServer -.-> OpEndpoints
    APIServer -.-> CacheEndpoints

    %% Egress flows
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    APIServer -->|"gRPC (insecure default)<br/>OpenTelemetry traces"| OTLPCollector
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| RHStats
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3Storage

    %% Observability
    Prometheus["Prometheus Scraper"] -->|"HTTP/8000<br/>Configurable TLS<br/>No auth"| MetricsEndpoint

    %% Distributed
    APIServer -.->|"TCP<br/>No encryption"| Gloo
    APIServer -.->|"Ray protocol/6379<br/>No encryption"| RayCluster

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef service fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef grpc fill:#3498db,stroke:#333,stroke-width:2px,color:#fff
    classDef metrics fill:#2ecc71,stroke:#333,stroke-width:2px
    classDef risk fill:#e74c3c,stroke:#c0392b,stroke-width:2px,color:#fff
    classDef lowrisk fill:#f39c12,stroke:#e67e22,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef distributed fill:#ddd,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class Client,Prometheus external
    class APIServer service
    class GRPCServer grpc
    class MetricsEndpoint metrics
    class OpEndpoints risk
    class HealthEndpoints,CacheEndpoints lowrisk
    class HFHub,OTLPCollector,RHStats,S3Storage egress
    class Gloo,RayCluster distributed
