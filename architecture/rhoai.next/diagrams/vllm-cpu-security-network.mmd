graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>KServe Proxy / User"]
    end

    subgraph Ingress["INGRESS (Managed by KServe)"]
        KServeRoute["KServe Route / HTTPRoute<br/>TLS termination at gateway<br/>Auth policies by platform operator"]
    end

    subgraph Application["APPLICATION (vllm-cpu Container)<br/>UID: 2000 / GID: 0 (non-root)<br/>Image: odh-vllm-cpu-rhel9<br/>Base: UBI9 minimal"]
        direction TB

        subgraph HTTPService["HTTP API Server (FastAPI/Uvicorn)"]
            APIEndpoints["/v1/* endpoints<br/>Port: 8000/TCP<br/>Protocol: HTTP/HTTPS<br/>Auth: Bearer API Key"]
            HealthEndpoints["/health, /ping, /metrics<br/>Port: 8000/TCP<br/>Protocol: HTTP/HTTPS<br/>Auth: None"]
        end

        subgraph GRPCService["gRPC Server"]
            GRPCEndpoints["VllmEngineServicer<br/>Port: 50051/TCP<br/>Protocol: gRPC (HTTP/2)<br/>Encryption: None<br/>Auth: None"]
        end

        subgraph EngineCore["vLLM Engine (V1)"]
            CPUKernels["CPU Kernels<br/>Attention, MoE, Quantization<br/>Intel DNNL, SGL GEMM"]
        end

        APIEndpoints --> EngineCore
        GRPCEndpoints --> EngineCore
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN"]
        ModelScope["ModelScope<br/>modelscope.cn<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Token"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        VLLMStats["vLLM Stats<br/>stats.vllm.ai<br/>443/TCP HTTPS<br/>Auth: None<br/>(disabled by default)"]
    end

    subgraph LocalStorage["LOCAL STORAGE"]
        PVC["PVC / Volume Mount<br/>Filesystem<br/>Model weights"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
        OTel["OpenTelemetry Collector<br/>OTLP gRPC/HTTP<br/>TLS (optional)"]
    end

    %% Inbound flows
    Client -->|"HTTP(S)/8000<br/>TLS optional<br/>Bearer API Key"| KServeRoute
    KServeRoute -->|"HTTP/8000<br/>mTLS if mesh enabled"| APIEndpoints

    %% Health/metrics (no auth)
    Prometheus -->|"HTTP/8000<br/>GET /metrics<br/>No Auth"| HealthEndpoints

    %% Egress flows
    EngineCore -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    EngineCore -->|"HTTPS/443<br/>TLS 1.2+<br/>Token"| ModelScope
    EngineCore -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    EngineCore -->|"Filesystem"| PVC
    EngineCore -.->|"HTTPS/443<br/>No Auth<br/>(disabled)"| VLLMStats
    EngineCore -.->|"OTLP<br/>TLS<br/>(optional)"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class KServeRoute ingress
    class APIEndpoints,HealthEndpoints,GRPCEndpoints,CPUKernels application
    class HFHub,ModelScope,S3,VLLMStats externalservice
    class Prometheus,OTel monitoring
    class PVC storage
