graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        GRPCClient["gRPC Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed by KServe)"]
        KServeRoute["KServe Route/HTTPRoute<br/>TLS termination at platform level"]
    end

    subgraph Service["SERVICE (ClusterIP - Internal)"]
        direction TB

        subgraph Pod["vllm-cpu Pod<br/>User: 2000 (non-root) | Group: 0<br/>Base: UBI9 ubi-minimal"]
            direction TB

            OpenAIAPI["OpenAI API Server (FastAPI)<br/>Service: vllm-openai<br/>8000/TCP HTTP<br/>Optional TLS (ssl module)<br/>Auth: API Key (optional)<br/>Cert reload: SSLCertRefresher"]

            GRPCServer["gRPC Server<br/>Service: vllm-grpc<br/>50051/TCP gRPC (HTTP/2)<br/>⚠️ No TLS (add_insecure_port)<br/>⚠️ No Auth"]

            Engine["V1 AsyncLLM Engine<br/>VLLM_USE_V1=1<br/>PyTorch CPU Backend<br/>x86_64 / ppc64le / s390x"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM<br/>(S3_ACCESS_KEY_ID)"]
        OTel["OpenTelemetry Collector<br/>configurable port<br/>HTTPS/gRPC TLS 1.2+"]
        MCP["MCP Tool Servers<br/>configurable port<br/>HTTP/HTTPS"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>8000/TCP HTTP"]
    end

    %% Ingress Flows
    Client -->|"HTTP 8000/TCP<br/>Optional TLS<br/>API Key (Bearer)"| KServeRoute
    KServeRoute -->|"HTTP 8000/TCP<br/>Optional TLS<br/>API Key forwarded"| OpenAIAPI
    GRPCClient -->|"gRPC 50051/TCP<br/>⚠️ No TLS<br/>⚠️ No Auth"| GRPCServer

    %% Internal Flows
    OpenAIAPI -->|"in-process<br/>Python call"| Engine
    GRPCServer -->|"in-process<br/>Python call"| Engine

    %% Egress Flows
    Engine -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Engine -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>AWS IAM"| S3
    Engine -->|"HTTPS/gRPC<br/>TLS 1.2+"| OTel
    Engine -->|"HTTP/HTTPS<br/>Configurable"| MCP

    %% Monitoring
    Prometheus -->|"HTTP 8000/TCP<br/>/metrics<br/>No Auth"| OpenAIAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client,GRPCClient external
    class KServeRoute ingress
    class OpenAIAPI,Engine service
    class GRPCServer warning
    class HFHub,S3,OTel,MCP externalservice
    class Prometheus monitoring
