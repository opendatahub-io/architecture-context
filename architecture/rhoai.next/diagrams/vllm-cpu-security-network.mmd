graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Gateway"]
    end

    subgraph ServiceLayer["SERVICE LAYER (ClusterIP - Internal)"]
        direction TB

        subgraph MainService["vLLM OpenAI API Server"]
            API["vllm-openai<br/>8000/TCP HTTP(S)<br/>Configurable TLS<br/>UBI 9 Base Image"]
            AuthMW["AuthenticationMiddleware<br/>SHA256 + constant-time compare<br/>/v1/* paths only"]
        end

        subgraph GRPCService["vLLM gRPC Server"]
            GRPC["vllm-grpc<br/>50051/TCP gRPC<br/>No encryption<br/>No auth"]
        end

        subgraph Metrics["Prometheus Metrics"]
            MetricsEP["prometheus-metrics<br/>8000/TCP HTTP<br/>No auth<br/>Scraped by Prometheus"]
        end
    end

    subgraph Egress["EGRESS (Outbound)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
        OTLP["OTLP Collector<br/>Configurable port<br/>gRPC (insecure default)<br/>No auth"]
        RHStats["Red Hat Stats<br/>console.redhat.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph Distributed["DISTRIBUTED (Optional)"]
        Gloo["Gloo Backend<br/>TCP (no encryption)<br/>Tensor Parallelism"]
        Ray["Ray Cluster<br/>6379/TCP<br/>Ray Protocol"]
    end

    subgraph BuildTime["BUILD-TIME ONLY"]
        DevPI["IBM DevPI<br/>wheels.developerfirst.ibm.com<br/>443/TCP HTTPS<br/>ppc64le wheels"]
    end

    %% Inbound flows
    Client -->|"HTTP(S)/8000<br/>Configurable TLS<br/>Bearer API Key (/v1/*)"| API
    API --> AuthMW
    Client -->|"gRPC/50051<br/>No encryption<br/>No auth"| GRPC

    %% Egress flows
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HF
    API -->|"gRPC (insecure)<br/>Configurable port"| OTLP
    API -->|"HTTPS/443<br/>TLS 1.2+"| RHStats
    API -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Distributed flows
    API -.->|"TCP<br/>No encryption"| Gloo
    API -.->|"Ray/6379<br/>No encryption"| Ray

    %% Prometheus scrape
    MetricsEP -.->|"HTTP/8000<br/>Scraped"| API

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef distributed fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef buildtime fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class API,GRPC,MetricsEP service
    class AuthMW auth
    class HF,OTLP,RHStats,S3 egress
    class Gloo,Ray distributed
    class DevPI buildtime
