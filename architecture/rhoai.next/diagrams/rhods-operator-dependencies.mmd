graph LR
    RhodsOp["rhods-operator<br/>(Platform Operator)"]

    %% Infrastructure Dependencies
    subgraph Infrastructure["Infrastructure"]
        K8sAPI["Kubernetes API<br/>Server"]
        GatewayAPI["Gateway API<br/>(Envoy) v1.3.0"]
        Istio["Istio / Service Mesh<br/>(EnvoyFilter, DestinationRule)"]
        OLM["OLM<br/>(Operator Lifecycle Manager)"]
    end

    %% OpenShift Dependencies
    subgraph OpenShift["OpenShift Platform"]
        OAuthServer["OpenShift OAuth<br/>Server"]
        IngressCtrl["OpenShift Ingress<br/>Controller"]
        ServiceCA["OpenShift Service<br/>CA Operator"]
        SCC["SecurityContext<br/>Constraints"]
    end

    %% Operator Dependencies
    subgraph OperatorDeps["Operator Dependencies"]
        MonStackOp["MonitoringStack<br/>Operator"]
        TempoOp["Tempo<br/>Operator"]
        OTELOp["OpenTelemetry<br/>Operator"]
        PersesOp["Perses<br/>Operator"]
        KueueOp["Kueue<br/>Operator"]
        JobSetOp["JobSet<br/>Operator"]
        CertManager["cert-manager<br/>(optional, xKS)"]
        Kuadrant["Kuadrant"]
    end

    %% Managed Components
    subgraph ManagedComponents["Managed Components (16)"]
        Dashboard["Dashboard"]
        Kserve["KServe"]
        Kueue["Kueue"]
        Workbenches["Workbenches"]
        ModelReg["Model Registry"]
        DSPipelines["Data Science<br/>Pipelines"]
        TrustyAI["TrustyAI"]
        Ray["Ray"]
        TrainingOp["Training<br/>Operator"]
        Trainer["Trainer"]
        Feast["Feast Operator"]
        LlamaStack["LlamaStack<br/>Operator"]
        MLflow["MLflow Operator"]
        ModelCtrl["Model Controller"]
        MaaS["Models-as-a-<br/>Service"]
        Spark["Spark Operator"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        ExtOIDC["External OIDC<br/>Provider"]
    end

    %% Library Dependencies
    subgraph Libraries["Go Libraries"]
        CtrlRuntime["controller-runtime<br/>v0.23.3"]
        ManifestKit["k8s-manifest-kit<br/>v0.2.1"]
        HelmRenderer["renderer-helm<br/>v0.3.1"]
        Kustomize["kustomize/api<br/>v0.21.1"]
    end

    %% Infrastructure connections
    RhodsOp -->|CRD watches<br/>resource CRUD<br/>6443/TCP| K8sAPI
    RhodsOp -->|creates Gateway<br/>GatewayClass<br/>HTTPRoute| GatewayAPI
    RhodsOp -->|creates EnvoyFilter<br/>DestinationRule| Istio
    RhodsOp -->|reads Subscription<br/>CSV| OLM

    %% OpenShift connections
    RhodsOp -->|creates OAuthClient<br/>443/TCP| OAuthServer
    RhodsOp -->|detects cluster domain<br/>ingress cert| IngressCtrl
    RhodsOp -->|triggers TLS cert<br/>generation| ServiceCA
    RhodsOp -->|manages SCCs| SCC

    %% Operator dependency connections
    RhodsOp -->|creates MonitoringStack| MonStackOp
    RhodsOp -->|creates Tempo CRs| TempoOp
    RhodsOp -->|creates OTEL CRs| OTELOp
    RhodsOp -->|creates Perses CRs| PersesOp
    RhodsOp -.->|watches Kueue CRDs| KueueOp
    RhodsOp -.->|watches JobSet CRD| JobSetOp
    RhodsOp -.->|optional certs<br/>xKS only| CertManager
    RhodsOp -.->|namespace RBAC| Kuadrant

    %% Managed component connections
    RhodsOp -->|deploys| Dashboard
    RhodsOp -->|deploys| Kserve
    RhodsOp -->|deploys| Kueue
    RhodsOp -->|deploys| Workbenches
    RhodsOp -->|deploys| ModelReg
    RhodsOp -->|deploys| DSPipelines
    RhodsOp -->|deploys| TrustyAI
    RhodsOp -->|deploys| Ray
    RhodsOp -->|deploys| TrainingOp
    RhodsOp -->|deploys| Trainer
    RhodsOp -->|deploys| Feast
    RhodsOp -->|deploys| LlamaStack
    RhodsOp -->|deploys| MLflow
    RhodsOp -->|deploys| ModelCtrl
    RhodsOp -->|deploys| MaaS
    RhodsOp -->|deploys| Spark

    %% External service connections
    RhodsOp -.->|OIDC auth<br/>when configured| ExtOIDC

    %% Library connections
    RhodsOp -->|uses| CtrlRuntime
    RhodsOp -->|uses| ManifestKit
    RhodsOp -->|uses| HelmRenderer
    RhodsOp -->|uses| Kustomize

