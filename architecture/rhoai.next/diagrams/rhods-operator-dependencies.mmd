    RHODS -->|"Helm rendering"| HelmKit["k8s-manifest-kit<br/>v0.3.1"]
    RHODS -->|"monitoring CRDs"| PromOp["prometheus-operator<br/>v0.74.0"]
    RHODS -->|"MaaS types"| MaaSLib["models-as-a-service<br/>v0.0.0-20260420"]

    %% ═══════════════════════════════════════════
    %% Internal Platform Dependencies (CRD-based)
    %% ═══════════════════════════════════════════
    RHODS -->|"TLS certificates"| CertMgr["cert-manager<br/>Certificates,<br/>ClusterIssuers"]
    RHODS -->|"EnvoyFilter,<br/>DestinationRule"| Istio["Istio / Sail Operator"]
    RHODS -->|"MonitoringStack,<br/>ThanosQuerier"| COO["Monitoring Stack<br/>Operator (COO)"]
    RHODS -->|"TempoMonolithic,<br/>TempoStack"| TempoOp["Tempo Operator"]
    RHODS -->|"OTelCollector,<br/>Instrumentation"| OTelOp["OpenTelemetry<br/>Operator"]
    RHODS -->|"Perses,<br/>PersesDashboard"| PersesOp["Perses Operator"]
    RHODS -->|"API auth<br/>(kuadrant.io)"| Authorino["Authorino"]
    RHODS -->|"LLM inference<br/>pod mgmt"| LWS["LeaderWorkerSet<br/>Operator"]
    RHODS -->|"auto TLS certs<br/>(annotation)"| ServiceCA["OpenShift<br/>Service CA"]
    RHODS -->|"CA bundle<br/>(label injection)"| CNO["OpenShift Cluster<br/>Network Operator"]

    %% ═══════════════════════════════════════════
    %% Optional Dependencies
    %% ═══════════════════════════════════════════
    RHODS -.->|"workflows<br/>(required by DSP)"| Argo["Argo Workflows"]
    RHODS -.->|"job queuing<br/>(required by Kueue)"| KueueCRD["Kueue CRDs"]
    RHODS -.->|"autoscaling<br/>(optional for WVA)"| KEDA["Custom Metrics<br/>Autoscaler (KEDA)"]
    RHODS -.->|"job sets<br/>(required by Trainer)"| JobSet["JobSet Operator"]

