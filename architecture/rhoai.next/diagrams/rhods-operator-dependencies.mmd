graph LR
    RHODS["RHODS Operator<br/>(rhods-operator)"]

    %% ──────────────────────────────────────
    %% Internal Platform Dependencies
    %% ──────────────────────────────────────
    RHODS -->|"EnvoyFilter,<br/>DestinationRule CRs"| Istio["Istio / Sail Operator"]
    RHODS -->|"MonitoringStack,<br/>ThanosQuerier CRs"| COO["Cluster Observability<br/>Operator"]
    RHODS -->|"OpenTelemetryCollector,<br/>Instrumentation CRs"| OTel["OpenTelemetry<br/>Operator"]
    RHODS -->|"TempoMonolithic,<br/>TempoStack CRs"| Tempo["Tempo Operator"]
    RHODS -->|"Perses,<br/>PersesDatasource CRs"| Perses["Perses Operator"]
    RHODS -->|"Certificate,<br/>Issuer CRs (XKS)"| CertManager["cert-manager<br/>Operator"]
    RHODS -->|"LeaderWorkerSet<br/>CRs (XKS)"| LWS["LeaderWorkerSet<br/>Operator"]
    RHODS -->|"OAuthClient CRs"| OAuth["OpenShift OAuth<br/>Server"]
    RHODS -->|"Route CRs,<br/>cert propagation"| Router["OpenShift Router"]
    RHODS -->|"CA bundle injection"| CNO["Cluster Network<br/>Operator (CNO)"]
    RHODS -->|"Subscription, CSV,<br/>InstallPlan watches"| OLM["OLM"]

    %% ──────────────────────────────────────
    %% Managed Components (deployed by operator)
    %% ──────────────────────────────────────
    RHODS -->|"deploys"| Dashboard["Dashboard"]
    RHODS -->|"deploys"| KServe["KServe"]
    RHODS -->|"deploys"| Kueue["Kueue"]
    RHODS -->|"deploys"| Ray["KubeRay"]
    RHODS -->|"deploys"| TrustyAI["TrustyAI"]
    RHODS -->|"deploys"| ModelReg["Model Registry"]
    RHODS -->|"deploys"| TrainOp["Training Operator"]
    RHODS -->|"deploys"| Trainer["Trainer"]
    RHODS -->|"deploys"| DSP["Data Science<br/>Pipelines"]
    RHODS -->|"deploys"| Feast["Feast Operator"]
    RHODS -->|"deploys"| LlamaStack["LlamaStack<br/>Operator"]
    RHODS -->|"deploys"| MLflow["MLflow Operator"]
    RHODS -->|"deploys"| Spark["Spark Operator"]
    RHODS -->|"deploys"| MaaS["Models-as-a-Service"]
    RHODS -->|"deploys"| ModelCtrl["Model Controller"]
    RHODS -->|"deploys"| Workbenches["Workbenches"]

    %% ──────────────────────────────────────
    %% External Services
    %% ──────────────────────────────────────
    RHODS -->|"all reconciliation<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    RHODS -->|"GatewayClass, Gateway,<br/>HTTPRoute CRs"| GatewayAPI["Gateway API<br/>(envoy-gateway /<br/>openshift)"]
    MaaS -->|"AuthPolicy,<br/>RateLimitPolicy"| Kuadrant["Kuadrant Operator"]
    RHODS -.->|"ServiceMonitor<br/>discovery"| NvidiaGPU["NVIDIA GPU<br/>Operator"]

    %% ──────────────────────────────────────
    %% Build-time Dependencies
    %% ──────────────────────────────────────
    RHODS -.->|"controller-runtime<br/>v0.23.3"| CR["controller-runtime"]
    RHODS -.->|"gateway-api v1.3.0"| GWAPI_LIB["sigs.k8s.io/gateway-api"]
    RHODS -.->|"helm/v4 v4.1.1"| Helm["Helm"]
    RHODS -.->|"k8s-manifest-kit"| ManifestKit["k8s-manifest-kit"]

    %% ──────────────────────────────────────
    %% Styling
    %% ──────────────────────────────────────
    style RHODS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform deps
    style Istio fill:#438dd5,stroke:#333,color:#fff
    style COO fill:#438dd5,stroke:#333,color:#fff
    style OTel fill:#438dd5,stroke:#333,color:#fff
    style Tempo fill:#438dd5,stroke:#333,color:#fff
    style Perses fill:#438dd5,stroke:#333,color:#fff
    style CertManager fill:#438dd5,stroke:#333,color:#fff
    style LWS fill:#438dd5,stroke:#333,color:#fff
    style OAuth fill:#438dd5,stroke:#333,color:#fff
    style Router fill:#438dd5,stroke:#333,color:#fff
    style CNO fill:#438dd5,stroke:#333,color:#fff
    style OLM fill:#438dd5,stroke:#333,color:#fff

    %% Managed components
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style Ray fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style TrainOp fill:#7ed321,stroke:#333,color:#fff
    style Trainer fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Feast fill:#7ed321,stroke:#333,color:#fff
    style LlamaStack fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Spark fill:#7ed321,stroke:#333,color:#fff
    style MaaS fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style Workbenches fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style GatewayAPI fill:#f5a623,stroke:#333,color:#fff
    style Kuadrant fill:#f5a623,stroke:#333,color:#fff
    style NvidiaGPU fill:#f5a623,stroke:#333

    %% Build-time deps (lighter)
    style CR fill:#e8e8e8,stroke:#999
    style GWAPI_LIB fill:#e8e8e8,stroke:#999
    style Helm fill:#e8e8e8,stroke:#999
    style ManifestKit fill:#e8e8e8,stroke:#999
