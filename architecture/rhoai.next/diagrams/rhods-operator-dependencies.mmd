graph LR
    RHODS["rhods-operator<br/>(Platform Operator)"]

    %% ═══════════════════════════════════════════
    %% External Framework Dependencies
    %% ═══════════════════════════════════════════
    RHODS -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    RHODS -->|"ingress CRDs"| GatewayAPI["Gateway API<br/>v1.3.0"]
    RHODS -->|"OpenShift types"| OSAPI["openshift/api<br/>v0.0.0-20260521"]
    RHODS -->|"OLM integration"| OFAPI["operator-framework/api<br/>v0.42.0"]
