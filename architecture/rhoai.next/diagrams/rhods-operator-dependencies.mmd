graph LR
    RhodsOp["rhods-operator<br/>(Platform Operator)"]

    %% === External Runtime Dependencies ===
    RhodsOp -->|"TLS certs<br/>webhook + operator"| CertManager["cert-manager<br/>(Runtime, Required)"]
    RhodsOp -->|"Gateway data plane<br/>EnvoyFilter, DestinationRule"| Istio["Istio / OSSM<br/>(Sail Operator)<br/>(Runtime, Conditional)"]
    RhodsOp -->|"MonitoringStack,<br/>Thanos, Perses"| COO["Cluster Observability<br/>Operator<br/>(Runtime, Conditional)"]
    RhodsOp -->|"Metrics/traces<br/>collection"| OTelOp["OpenTelemetry<br/>Operator<br/>(Runtime, Conditional)"]
    RhodsOp -->|"Distributed tracing<br/>backend"| TempoOp["Tempo Operator<br/>(Runtime, Conditional)"]
    RhodsOp -->|"LLM distributed<br/>inference"| LWSOp["LeaderWorkerSet<br/>Operator<br/>(Runtime, Conditional)"]
    RhodsOp -->|"Operator lifecycle<br/>management"| OLM["OLM<br/>(Runtime)"]

    %% === External Build Dependencies ===
    RhodsOp -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    RhodsOp -->|"Gateway API types"| GatewayAPI["sigs.k8s.io/gateway-api<br/>v1.3.0"]
    RhodsOp -->|"Route, OAuth,<br/>Config APIs"| OSApi["openshift/api<br/>v0.0.0-20260521"]
    RhodsOp -->|"OLM Subscription/CSV"| OFApi["operator-framework/api<br/>v0.42.0"]
    RhodsOp -->|"Prometheus CRD types"| PromOp["prometheus-operator<br/>v0.74.0"]
    RhodsOp -->|"manifest rendering"| ManifestKit["k8s-manifest-kit<br/>engine v0.2.1<br/>renderer-helm v0.3.1"]

    %% === Internal RHOAI Components (Managed) ===
    Dashboard["ODH Dashboard"] -->|"UI management"| RhodsOp
    KServe["KServe"] -->|"CRD + Manifests"| RhodsOp
    Kueue["Kueue"] -->|"CRD + Manifests"| RhodsOp
    Workbenches["Workbenches"] -->|"Manifests"| RhodsOp
    DSPipelines["DataScience<br/>Pipelines"] -->|"CRD + Manifests"| RhodsOp
    Ray["KubeRay"] -->|"Manifests"| RhodsOp
    TrustyAI["TrustyAI"] -->|"CRD + Manifests"| RhodsOp
    ModelReg["Model Registry"] -->|"CRD + Manifests"| RhodsOp
    ModelCtrl["Model Controller"] -->|"Manifests"| RhodsOp
    TrainingOp["Training Operator"] -->|"Manifests"| RhodsOp
    Trainer["Trainer"] -->|"Manifests"| RhodsOp
    Feast["Feast Operator"] -->|"CRD + Manifests"| RhodsOp
    OGX["OGX (LlamaStack)"] -->|"Manifests"| RhodsOp
    MLflow["MLflow Operator"] -->|"Manifests"| RhodsOp
    SparkOp["Spark Operator"] -->|"Manifests"| RhodsOp
    MaaS["Models as a Service"] -->|"CRD + Manifests<br/>+ Kustomize"| RhodsOp

    %% === External Services ===
    RhodsOp -->|"all reconciliation<br/>6443/TCP"| K8sAPI["Kubernetes API<br/>Server"]
    RhodsOp -->|"OAuth registration<br/>443/TCP"| OAuthServer["OpenShift OAuth<br/>Server"]
    RhodsOp -->|"component images<br/>443/TCP"| Quay["quay.io/rhoai/*"]

    %% === Integration Points (other operators that interact) ===
    Kuadrant["Kuadrant<br/>(Authorino)"] -.->|"AuthPolicy<br/>for MaaS"| RhodsOp
    JobSet["JobSet Operator"] -.->|"CRD Watch<br/>(Trainer dep)"| RhodsOp
    CMA["Custom Metrics<br/>Autoscaler"] -.->|"Subscription Watch<br/>(WVA dep)"| RhodsOp

