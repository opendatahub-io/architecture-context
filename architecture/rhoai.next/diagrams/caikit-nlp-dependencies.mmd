graph LR
    CaikitNLP["caikit-nlp<br/>(NLP Module Library)"]

    %% Internal Platform Dependencies
    CaikitNLP -->|"runtime library loading"| CaikitCore["caikit<br/>>=0.26.34,<0.28.0"]
    CaikitNLP -->|"TGIS client mgmt"| CaikitTGIS["caikit-tgis-backend<br/>>=0.1.36,<0.2.0"]

    %% Core ML Dependencies
    CaikitNLP -->|"model inference<br/>& training"| PyTorch["torch (PyTorch)<br/>>=2.3.1,<2.5.0"]
    CaikitNLP -->|"transformer models"| Transformers["transformers<br/>>=4.38.0,<4.44.0"]
    CaikitNLP -->|"embeddings &<br/>reranking"| SentenceTransformers["sentence-transformers<br/>>=3.0.0,<3.1.0"]
    CaikitNLP -->|"prompt tuning"| PEFT["peft<br/>==0.6.0"]
    CaikitNLP -->|"distributed training"| Accelerate["accelerate<br/>>=0.22.0"]

    %% Data & Scientific Dependencies
    CaikitNLP -->|"training data"| Datasets["datasets<br/>>=2.4.0"]
    CaikitNLP -->|"model hub"| HFHub["huggingface-hub"]
    CaikitNLP -->|"tokenization"| Tokenizers["tokenizers<br/>>=0.13.3"]

    %% gRPC Dependencies
    CaikitNLP -->|"TGIS gRPC client"| gRPC["grpcio<br/>>=1.62.2"]
    CaikitNLP -->|"service discovery"| gRPCReflect["grpcio-reflection<br/>>=1.62.2"]
    CaikitNLP -->|"health checking"| gRPCHealth["grpcio-health-checking<br/>>=1.62.2"]

    %% Scientific Computing
    CaikitNLP -->|"numerical ops"| NumPy["numpy<br/>>=1.22.4"]
    CaikitNLP -->|"data manipulation"| Pandas["pandas<br/>>=1.5.0"]
    CaikitNLP -->|"ML utilities"| Sklearn["scikit-learn<br/>>=1.1"]
    CaikitNLP -->|"scientific computing"| SciPy["scipy<br/>>=1.8.1"]

    %% Runtime Integration (how caikit-nlp is consumed)
    CaikitRuntime["Caikit Runtime<br/>(gRPC/HTTP Server)"] -->|"loads as<br/>RUNTIME_LIBRARY"| CaikitNLP

    %% Remote Service Dependencies
    CaikitNLP -.->|"gRPC :8033-8034<br/>Optional TLS/mTLS"| TGIS["TGIS Server<br/>(Remote Inference)"]
    CaikitNLP -.->|"HTTPS :443<br/>Optional (disabled by default)"| HFHubService["HuggingFace Hub<br/>(Model Downloads)"]

    %% Optional Dependencies
    CaikitNLP -.->|"Intel optimization<br/>(optional)"| IPEX["Intel IPEX"]

    %% Styling
    style CaikitNLP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform
    style CaikitCore fill:#7ed321,stroke:#333
    style CaikitTGIS fill:#7ed321,stroke:#333
    style CaikitRuntime fill:#7ed321,stroke:#333

    %% Core ML (required)
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style Transformers fill:#ff9d00,stroke:#333
    style SentenceTransformers fill:#ff9d00,stroke:#333
    style PEFT fill:#ff9d00,stroke:#333
    style Accelerate fill:#ff9d00,stroke:#333

    %% Data deps
    style Datasets fill:#ffd700,stroke:#333
    style HFHub fill:#ffd700,stroke:#333
    style Tokenizers fill:#ffd700,stroke:#333

    %% gRPC
    style gRPC fill:#2ca02c,stroke:#333,color:#fff
    style gRPCReflect fill:#2ca02c,stroke:#333,color:#fff
    style gRPCHealth fill:#2ca02c,stroke:#333,color:#fff

    %% Scientific
    style NumPy fill:#4dabcf,stroke:#333
    style Pandas fill:#4dabcf,stroke:#333
    style Sklearn fill:#4dabcf,stroke:#333
    style SciPy fill:#4dabcf,stroke:#333

    %% Remote services
    style TGIS fill:#f5a623,stroke:#333
    style HFHubService fill:#999,stroke:#333

    %% Optional
    style IPEX fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
