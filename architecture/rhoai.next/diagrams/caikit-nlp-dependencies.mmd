graph LR
    CaikitNLP["caikit-nlp<br/>Python Library"]

    %% Core Framework Dependencies (Required)
    CaikitNLP -->|"core framework<br/>>=0.26.34,<0.28.0"| Caikit["caikit<br/>(AI framework)"]
    CaikitNLP -->|"TGIS backend<br/>>=0.1.36,<0.2.0"| CaikitTGIS["caikit-tgis-backend"]

    %% ML Framework Dependencies
    CaikitNLP -->|"model inference/training<br/>>=2.3.1,<2.5.0"| PyTorch["PyTorch"]
    CaikitNLP -->|"transformer models<br/>>=4.38.0,<4.44.0"| Transformers["HuggingFace<br/>transformers"]
    CaikitNLP -->|"embeddings<br/>>=3.0.0,<3.1.0"| SentenceTransformers["sentence-<br/>transformers"]
    CaikitNLP -->|"prompt tuning<br/>==0.6.0"| PEFT["PEFT"]
    CaikitNLP -->|"mixed-precision<br/>>=0.22.0"| Accelerate["HuggingFace<br/>Accelerate"]

    %% Data & Scientific Libraries
    CaikitNLP -->|"datasets<br/>>=2.4.0"| Datasets["HuggingFace<br/>datasets"]
    CaikitNLP -->|"ML utilities"| ScikitLearn["scikit-learn"]
    CaikitNLP -->|"numerics"| NumPy["NumPy"]
    CaikitNLP -->|"data manipulation"| Pandas["Pandas"]

    %% gRPC & Network
    CaikitNLP -->|"gRPC framework<br/>>=1.62.2"| GRPCIO["grpcio"]

    %% Runtime Dependencies (Platform)
    CaikitNLP -.->|"remote inference<br/>gRPC"| TGIS["TGIS Server"]
    CaikitNLP -.->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    CaikitNLP -.->|"hosts modules<br/>HTTP/gRPC"| CaikitRuntime["caikit Runtime"]

    %% Platform Integration
    PlatformOp["RHOAI Operator"] -->|"deploys runtime"| CaikitRuntime
    KServe["KServe"] -->|"routes traffic"| CaikitRuntime
    CaikitRuntime -->|"loads library"| CaikitNLP

    %% Multi-GPU Training
    CaikitNLP -.->|"distributed training<br/>TCP/29550"| TorchDist["PyTorch Distributed<br/>(torchrun)"]

