graph LR
    CaikitNLP["caikit-nlp<br/>NLP Runtime Module"]

    %% Core Framework Dependencies (Required)
    CaikitNLP -->|"RUNTIME_LIBRARY<br/>>=0.26.34,<0.28.0"| Caikit["caikit<br/>(Core Framework)"]
    CaikitNLP -->|"TGIS integration<br/>>=0.1.36,<0.2.0"| CaikitTGIS["caikit-tgis-backend"]

    %% ML Framework Dependencies (Required)
    CaikitNLP -->|"model loading/training<br/>>=4.38.0,<4.44.0"| Transformers["transformers<br/>(HuggingFace)"]
    CaikitNLP -->|"deep learning<br/>>=2.3.1,<2.5.0"| PyTorch["torch<br/>(PyTorch)"]
    CaikitNLP -->|"prompt tuning<br/>==0.6.0"| PEFT["peft"]
    CaikitNLP -->|"distributed training<br/>>=0.22.0"| Accelerate["accelerate"]
    CaikitNLP -->|"embeddings/reranking<br/>>=3.0.0,<3.1.0"| SentenceTransformers["sentence-transformers"]

    %% Data & Utility Dependencies
    CaikitNLP -->|"dataset loading<br/>>=2.4.0"| Datasets["datasets"]
    CaikitNLP -->|"model download"| HFHub["huggingface-hub"]
    CaikitNLP -->|"gRPC client<br/>>=1.62.2"| gRPC["grpcio"]

    %% Optional Dependencies
    CaikitNLP -.->|"optional optimization"| IPEX["Intel IPEX"]

    %% Internal Platform Dependencies
    CaikitNLP -->|"gRPC client<br/>(configurable port)"| TGIS["TGIS Backend<br/>(Remote Inference)"]
    Caikit -->|"hosts as runtime"| CaikitRuntime["Caikit Runtime<br/>(gRPC + HTTP Server)"]
    KServe["KServe / ModelMesh"] -->|"container orchestration"| CaikitRuntime

    %% Integration Points
    Dashboard["RHOAI Dashboard"] -->|"UI management"| KServe
    DSP["Data Science Pipelines"] -.->|"model deployment"| KServe

    %% Styling
    style CaikitNLP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core framework - green
    style Caikit fill:#7ed321,stroke:#333
    style CaikitTGIS fill:#7ed321,stroke:#333
    style CaikitRuntime fill:#7ed321,stroke:#333

    %% ML frameworks - blue
    style Transformers fill:#dae8fc,stroke:#6c8ebf
    style PyTorch fill:#dae8fc,stroke:#6c8ebf
    style PEFT fill:#dae8fc,stroke:#6c8ebf
    style Accelerate fill:#dae8fc,stroke:#6c8ebf
    style SentenceTransformers fill:#dae8fc,stroke:#6c8ebf

    %% Data/utility - light gray
    style Datasets fill:#f5f5f5,stroke:#999
    style HFHub fill:#f5f5f5,stroke:#999
    style gRPC fill:#f5f5f5,stroke:#999
    style IPEX fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5

    %% Platform - yellow/orange
    style TGIS fill:#f5a623,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333,stroke-dasharray: 5 5
