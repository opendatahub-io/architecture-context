graph LR
    CaikitNLP["caikit-nlp<br/>(Python NLP Library)"]

    %% Core Framework Dependencies
    CaikitNLP -->|"core framework<br/>module system, runtime"| Caikit["caikit<br/>>=0.26.34,<0.28.0"]
    CaikitNLP -->|"TGIS backend<br/>gRPC client"| CaikitTGIS["caikit-tgis-backend<br/>>=0.1.36,<0.2.0"]

    %% ML Framework Dependencies
    CaikitNLP -->|"model loading<br/>fine-tuning"| Transformers["transformers<br/>>=4.38.0,<4.44.0"]
    CaikitNLP -->|"deep learning<br/>inference & training"| PyTorch["torch<br/>>=2.3.1,<2.5.0"]
    CaikitNLP -->|"embeddings<br/>semantic search"| SentenceTransformers["sentence-transformers<br/>>=3.0.0,<3.1.0"]
    CaikitNLP -->|"prompt tuning<br/>PEFT/MPT"| PEFT["peft<br/>==0.6.0"]
    CaikitNLP -->|"mixed-precision<br/>distributed training"| Accelerate["accelerate<br/>>=0.22.0"]

    %% Data & Utility Dependencies
    CaikitNLP -->|"training data"| Datasets["datasets<br/>>=2.4.0"]
    CaikitNLP -->|"model hub access"| HFHub["huggingface-hub"]
    CaikitNLP -->|"tokenization"| Tokenizers["tokenizers<br/>>=0.13.3"]

    %% gRPC Dependencies
    CaikitNLP -->|"gRPC framework"| GRPC["grpcio<br/>>=1.62.2"]

    %% Internal Platform Dependencies
    CaikitNLP -->|"remote inference<br/>gRPC (configurable port)"| TGIS["TGIS Server"]
    CaikitNLP -.->|"hosts modules<br/>HTTP/gRPC APIs"| CaikitRuntime["caikit Runtime"]
    CaikitNLP -.->|"model weights<br/>HTTPS/443"| HFModels["HuggingFace<br/>Model Files"]

    %% Platform Integration
    KServe["KServe /<br/>Gateway API"] -->|"manages deployment<br/>ingress, auth"| CaikitRuntime
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    Operator["rhods-operator"] -->|"creates<br/>ServingRuntime CRs"| CaikitRuntime

    %% Multi-GPU Training
    CaikitNLP -->|"multi-GPU coord<br/>TCP/29550"| TorchDistributed["PyTorch Distributed<br/>(torchrun)"]

