graph TD
    subgraph "Guardrails Regex Detector — RBAC Summary"
        direction TB

        subgraph NoRBAC["No RBAC Configuration"]
            Note["This component defines no RBAC resources.<br/><br/>• No ClusterRoles<br/>• No RoleBindings<br/>• No ServiceAccount requirements<br/>• No Kubernetes API interaction<br/><br/>The service is a stateless HTTP server<br/>that performs regex matching on text.<br/>It does not read or write any<br/>Kubernetes resources."]
        end

        subgraph SecurityModel["Security Model"]
            direction LR
            NetworkIsolation["Network-Level Isolation<br/>• ClusterIP service (internal only)<br/>• No external ingress<br/>• No egress to external services"]
            PlatformProvided["Platform-Provided Security<br/>• Pod network policies (by operator)<br/>• Service mesh mTLS (by operator)<br/>• Authorization policies (by operator)"]
        end

        subgraph AuthEndpoints["Endpoint Authentication"]
            Health["/health<br/>GET — Unauthenticated"]
            Detection["/api/v1/text/contents<br/>POST — Unauthenticated<br/>(relies on network isolation)"]
        end
    end

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NetworkIsolation fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style PlatformProvided fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Health fill:#d5e8d4,stroke:#82b366
    style Detection fill:#ffe6cc,stroke:#d79b00
