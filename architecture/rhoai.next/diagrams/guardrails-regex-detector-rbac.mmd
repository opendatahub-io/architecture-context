        SA["ServiceAccount<br/>guardrails-regex-detector"]
        AuthPolicy["AuthorizationPolicy<br/>(Istio / Service Mesh)"]
        NetPolicy["NetworkPolicy<br/>(Kubernetes)"]

        SA -.->|"should restrict to"| AuthPolicy
        AuthPolicy -.->|"allow only orchestrator SA"| NetPolicy
    end

    style Note fill:#f9f9f9,stroke:#ccc,stroke-width:1px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style AuthPolicy fill:#f5a623,stroke:#333,color:#fff
    style NetPolicy fill:#f5a623,stroke:#333,color:#fff
