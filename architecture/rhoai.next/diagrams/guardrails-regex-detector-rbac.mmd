graph TD
    subgraph "Guardrails Regex Detector - RBAC"
        direction TB

        subgraph "Security Model"
            NoRBAC["No RBAC Configured<br/><br/>This service has no ClusterRoles,<br/>RoleBindings, or ServiceAccount-specific<br/>permissions defined in the repository."]
        end

        subgraph "Authentication"
            NoAuth["No Application-Level Auth<br/><br/>POST /api/v1/text/contents — No Auth<br/>GET /health — No Auth"]
        end

        subgraph "Network Security (Recommended)"
            NetworkPolicy["Kubernetes NetworkPolicy<br/>(restrict ingress to orchestrator pod)"]
            ServiceMesh["Service Mesh mTLS<br/>(if Istio/OSSM sidecar injected)"]
        end

        NoRBAC --> NoAuth
        NoAuth -->|"security relies on"| NetworkPolicy
        NoAuth -->|"security relies on"| ServiceMesh
    end

    style NoRBAC fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NoAuth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NetworkPolicy fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ServiceMesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
