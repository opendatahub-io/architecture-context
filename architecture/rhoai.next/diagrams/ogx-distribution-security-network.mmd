graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Application["APPLICATION (OGX Server Container)"]
        direction TB
        OGX["OGX Server<br/>odh-ogx-core<br/>8321/TCP HTTP (plaintext)<br/>Base: AIPCC cpu:3.5.0-ea.2<br/>Python 3.12, RHEL 9.6<br/>Auth: OAuth2 JWT (optional)"]
    end

    subgraph InferenceProviders["INFERENCE PROVIDERS (TLS 1.2+)"]
        direction TB
        vLLM_Inf["vLLM Inference<br/>8000/TCP HTTP/S<br/>Bearer Token"]
        vLLM_Emb["vLLM Embedding<br/>8001/TCP HTTP/S<br/>Bearer Token"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>IAM Role + Web Identity"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS<br/>API Key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>API Key"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>GCP ADC"]
        OpenAI["OpenAI<br/>443/TCP HTTPS<br/>API Key (Bearer)"]
        Gemini["Google Gemini<br/>443/TCP HTTPS<br/>API Key"]
        Anthropic["Anthropic<br/>443/TCP HTTPS<br/>API Key"]
    end

    subgraph StateStore["STATE STORE"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PG Wire Protocol<br/>Plaintext (configurable)<br/>Username/Password"]
    end

    subgraph VectorDatabases["VECTOR DATABASES"]
        Milvus["Milvus<br/>Configurable Port<br/>gRPC/HTTPS<br/>TLS + mTLS<br/>Token Auth"]
        PGVector["pgvector<br/>5432/TCP<br/>PG Wire Protocol<br/>Plaintext<br/>Username/Password"]
        Qdrant["Qdrant<br/>6333/TCP HTTP<br/>6334/TCP gRPC<br/>HTTPS (configurable)<br/>API Key"]
    end

    subgraph ToolRuntimes["TOOL RUNTIMES (TLS 1.2+)"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>API Key"]
        MCP["MCP Servers<br/>Configurable<br/>HTTP/HTTPS"]
        Docling["Docling Serve<br/>Configurable<br/>HTTP/HTTPS<br/>API Key"]
    end

    subgraph ExternalStorage["EXTERNAL STORAGE (TLS 1.2+)"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>IAM Credentials"]
    end

    subgraph AuthServices["AUTH SERVICES"]
        OIDC["OAuth2/OIDC Issuer<br/>443/TCP HTTPS<br/>TLS (AUTH_VERIFY_TLS)<br/>JWKS Retrieval"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>Configurable<br/>gRPC/HTTP (OTLP)"]
    end

    %% Client to OGX
    Client -->|"HTTP/8321<br/>Plaintext<br/>OAuth2 Bearer (optional)<br/>JWT audience: ogx"| OGX

    %% OGX to Inference
    OGX -->|"HTTP(S)/8000<br/>TLS configurable<br/>Bearer Token"| vLLM_Inf
    OGX -->|"HTTP(S)/8001<br/>TLS configurable<br/>Bearer Token"| vLLM_Emb
    OGX -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM IRSA"| Bedrock
    OGX -->|"HTTPS/443<br/>API Key"| WatsonX
    OGX -->|"HTTPS/443<br/>API Key"| Azure
    OGX -->|"HTTPS/443<br/>GCP ADC"| Vertex
    OGX -->|"HTTPS/443<br/>API Key"| OpenAI
    OGX -->|"HTTPS/443<br/>API Key"| Gemini
    OGX -->|"HTTPS/443<br/>API Key"| Anthropic

    %% OGX to State
    OGX -->|"PG/5432<br/>Plaintext<br/>User/Pass"| PostgreSQL

    %% OGX to Vector DBs
    OGX -->|"gRPC/HTTPS<br/>TLS + mTLS<br/>Token"| Milvus
    OGX -->|"PG/5432<br/>Plaintext<br/>User/Pass"| PGVector
    OGX -->|"HTTP(S)/6333-6334<br/>API Key"| Qdrant

    %% OGX to Tools
    OGX -->|"HTTPS/443<br/>API Key"| Brave
    OGX -->|"HTTPS/443<br/>API Key"| Tavily
    OGX -->|"HTTP(S)<br/>Configurable"| MCP
    OGX -->|"HTTP(S)<br/>API Key"| Docling

    %% OGX to Storage
    OGX -->|"HTTPS/443<br/>IAM Creds"| S3

    %% OGX to Auth
    OGX -.->|"HTTPS/443<br/>JWKS fetch"| OIDC

    %% OGX to Observability
    OGX -.->|"OTLP gRPC/HTTP<br/>Traces + Metrics"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef inference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef state fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef vectordb fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tools fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef auth fill:#d5e8d4,stroke:#82b366,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class OGX application
    class vLLM_Inf,vLLM_Emb,Bedrock,WatsonX,Azure,Vertex,OpenAI,Gemini,Anthropic inference
    class PostgreSQL state
    class Milvus,PGVector,Qdrant vectordb
    class Brave,Tavily,MCP,Docling tools
    class S3 storage
    class OIDC auth
    class OTel auth
