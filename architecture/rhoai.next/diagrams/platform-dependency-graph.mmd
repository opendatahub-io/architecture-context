graph TB
    subgraph MetaOperator["Meta-Operator"]
        RhodsOp["rhods-operator<br/>Meta-operator<br/>209 watches, 27 CRDs"]
    end

    subgraph ModelServing["Model Serving"]
        KServe["KServe<br/>InferenceService / LLMInferenceService<br/>18 reverse deps"]
        ODHModelCtrl["odh-model-controller<br/>Routes, Monitoring, AuthPolicy"]
        ModelMeshCtrl["ModelMesh Serving Controller<br/>Multi-model serving"]
        ModelMesh["ModelMesh<br/>Distributed LRU cache"]
        RuntimeAdapter["ModelMesh Runtime Adapter"]
        RestProxy["rest-proxy<br/>REST-to-gRPC"]
    end

    subgraph InferenceRuntimes["Inference Runtimes"]
        vLLMCUDA["vLLM CUDA<br/>LLM inference"]
        vLLMROCM["vllm-rocm<br/>AMD GPU"]
        OVMS["OpenVINO Model Server"]
        MLServer["MLServer<br/>Multi-framework"]
        CaikitTGIS["Caikit-TGIS<br/>NLP serving"]
    end

    subgraph DisaggregatedServing["Disaggregated Serving - llm-d"]
        LLMD["llm-d<br/>Core orchestration"]
        LLMDRouter["llm-d-router<br/>60+ scheduling plugins"]
        LLMDKVCache["llm-d-kv-cache<br/>KV-cache disaggregation"]
        LLMDSidecar["llm-d-routing-sidecar<br/>Per-pod routing"]
        LLMDLatency["llm-d-latency-predictor<br/>TTFT/TPOT prediction"]
        LLMDPlanner["llm-d-planner<br/>Capacity planning"]
        GWAPIInfExt["Gateway API Inference Ext<br/>InferencePool/InferenceModel"]
    end

    subgraph DistributedWorkloads["Distributed Workloads"]
        Kueue["Kueue<br/>Resource queuing<br/>10 reverse deps"]
        CodeFlare["CodeFlare Operator<br/>Cluster orchestration"]
        KubeRay["KubeRay Operator<br/>Ray cluster management"]
        TrainingOp["Training Operator<br/>PyTorchJob / TrainJob"]
        TrainerV2["Trainer V2<br/>TrainingRuntime CRDs"]
    end

    subgraph Pipelines["Data Science Pipelines"]
        DSPO["DS Pipelines Operator<br/>DSPA lifecycle"]
        ArgoWF["Argo Workflows<br/>DAG execution"]
        MLMD["ML Metadata<br/>Experiment tracking"]
    end

    subgraph AIGateway["AI Gateway and MaaS"]
        AIGWOp["AI Gateway Operator"]
        AIGWPayload["AI Gateway Payload Processing<br/>ext_proc, NeMo guardrails"]
        MaaS["Models as a Service<br/>ExternalModel/ExternalProvider"]
        BatchGW["Batch Gateway<br/>Async inference"]
    end

    subgraph AIAgents["AI Agents"]
        Kagenti["Kagenti Operator<br/>Agent lifecycle, AuthBridge"]
        MCPLifecycle["MCP Lifecycle Operator<br/>MCP server management"]
    end

    subgraph PlatformServices["Platform Services"]
        Dashboard["ODH Dashboard<br/>Web UI"]
        ModelRegistry["Model Registry<br/>Model metadata"]
        ModelRegistryOp["Model Registry Operator"]
        Notebooks["Kubeflow Notebook Controller<br/>Workbenches"]
        WorkbenchesOp["Workbenches Operator"]
        TrustyAI["TrustyAI Operator<br/>AI fairness/explainability"]
        MLflowOp["MLflow Operator<br/>Experiment tracking"]
        Feast["Feast<br/>Feature store"]
        SparkOp["Spark Operator"]
    end

    subgraph Infrastructure["Platform Infrastructure"]
        KubeRBACProxy["kube-rbac-proxy<br/>SAR auth sidecar<br/>9+ components"]
        KubeAuthProxy["kube-auth-proxy<br/>Gateway auth"]
        Authorino["Authorino / Kuadrant<br/>API-level auth"]
        IstioGW["Istio Gateway API<br/>data-science-gateway"]
    end

    subgraph ExternalDeps["External Platform Dependencies"]
        K8sAPI["Kubernetes API"]
        OLM["OLM<br/>Operator Lifecycle Manager"]
        ServiceCA["OpenShift service-ca"]
        CertManager["cert-manager"]
    end

    %% Meta-operator manages everything
    RhodsOp -->|deploys/manages| KServe
    RhodsOp -->|deploys| ODHModelCtrl
    RhodsOp -->|deploys| DSPO
    RhodsOp -->|deploys| CodeFlare
    RhodsOp -->|deploys| KubeRay
    RhodsOp -->|deploys| TrainingOp
    RhodsOp -->|deploys| Kueue
    RhodsOp -->|deploys| Dashboard
    RhodsOp -->|deploys| ModelRegistryOp
    RhodsOp -->|deploys| Notebooks
    RhodsOp -->|deploys| TrustyAI
    RhodsOp -->|deploys| MLflowOp
    RhodsOp -->|deploys| Kagenti
    RhodsOp -->|deploys| AIGWOp
    RhodsOp -->|deploys| MaaS
    RhodsOp -->|deploys| WorkbenchesOp
    RhodsOp -->|deploys| Feast
    RhodsOp -->|deploys| SparkOp
    RhodsOp -->|deploys| MCPLifecycle
    RhodsOp -->|configures| IstioGW
    RhodsOp -->|injects| KubeRBACProxy

    %% KServe ecosystem
    KServe -->|deploys| vLLMCUDA
    KServe -->|deploys| vLLMROCM
    KServe -->|deploys| CaikitTGIS
    KServe -->|deploys| MLServer
    vLLMROCM -->|alt runtime| ModelMesh
    OVMS -->|deployed via| KServe
    OVMS -->|deployed via| ModelMeshCtrl
    ModelMeshCtrl -->|injects| ModelMesh
    ModelMeshCtrl -->|injects| RuntimeAdapter
    ModelMeshCtrl -->|injects| RestProxy

    %% odh-model-controller bridges KServe to platform
    ODHModelCtrl -->|watches| KServe
    ODHModelCtrl -->|creates Routes for| IstioGW
    ODHModelCtrl -->|registers with| ModelRegistry
    ODHModelCtrl -->|creates AuthPolicy| Authorino

    %% Disaggregated serving
    KServe -->|LLMInferenceService| LLMD
    LLMD -->|routing decisions| LLMDRouter
    LLMDRouter -->|ext_proc| IstioGW
    LLMDKVCache -->|KV events| vLLMCUDA
    LLMDSidecar -->|co-located with| vLLMCUDA
    LLMDLatency -->|prediction| LLMDRouter
    LLMD -->|endpoint| GWAPIInfExt

    %% Distributed workloads
    Kueue -->|quota mgmt| CodeFlare
    Kueue -->|quota mgmt| KubeRay
    Kueue -->|quota mgmt| TrainingOp
    CodeFlare -->|CRD watch| KubeRay
    TrainingOp -->|V2 runtime| TrainerV2

    %% Pipelines
    DSPO -->|orchestrates| ArgoWF
    DSPO -->|metadata| MLMD
    DSPO -->|can create| KServe
    DSPO -->|can create| CodeFlare
    DSPO -->|auto-detect| MLflowOp

    %% AI Gateway
    AIGWOp -->|manages| AIGWPayload
    AIGWPayload -->|ext_proc| IstioGW
    MaaS -->|auth via| Authorino
    BatchGW -->|async| KServe

    %% Platform services
    Dashboard -->|UI for| KServe
    Dashboard -->|UI for| ModelRegistry
    Dashboard -->|UI for| DSPO
    Dashboard -->|UI for| Notebooks
    ModelRegistryOp -->|deploys| ModelRegistry
    ModelRegistry -->|metadata for| KServe

    %% Infrastructure
    KubeRBACProxy -->|auth for| KServe
    KubeRBACProxy -->|auth for| KubeRay
    KubeRBACProxy -->|auth for| Dashboard
    KubeRBACProxy -->|auth for| OVMS
    KubeAuthProxy -->|gateway auth| IstioGW

    %% External
    RhodsOp -->|installed via| OLM
    KubeRay -->|TLS certs| CertManager
    CodeFlare -->|TLS certs| CertManager

