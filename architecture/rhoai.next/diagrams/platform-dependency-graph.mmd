graph TB
    subgraph "Platform Root"
        RhodsOp[rhods-operator<br/>Platform Orchestrator<br/>16+ component CRs]
    end

    subgraph "Core Infrastructure"
        Gateway[Gateway Infrastructure<br/>Envoy + kube-auth-proxy<br/>ext_authz + Lua]
        KubeRBAC[kube-rbac-proxy<br/>Security Sidecar]
        Kueue[Kueue<br/>Workload Admission]
    end

    subgraph "Model Serving"
        KServe[KServe<br/>InferenceService + LLMInferenceService]
        ODMC[odh-model-controller<br/>Serving Infrastructure]
        vLLM[vLLM<br/>LLM Inference Engine]
        ModelMesh[ModelMesh Serving<br/>Multi-Model Serving]
        LLMdEPP[llm-d Inference Scheduler<br/>Intelligent Routing EPP]
        LLMdSidecar[llm-d Routing Sidecar<br/>Disaggregated P/D]
        WVA[WVA<br/>LLM Autoscaler]
        AIGateway[AI Gateway Payload Processing<br/>API Translation]
        GatewayInfExt[Gateway API Inference Extension<br/>Body-Based Routing]
    end

    subgraph "Model Management"
        ModelReg[Model Registry Operator<br/>ML Model Registry]
        ModelRegSvc[Model Registry<br/>Catalog API]
        MaaS[Models as a Service<br/>External LLM Providers]
        NeMo[NeMo Guardrails<br/>Content Moderation]
    end

    subgraph "Training & Evaluation"
        KFTrainer[Kubeflow Trainer<br/>TrainJob CRD]
        KFTrainingOp[Kubeflow Training Operator<br/>Distributed Training]
        KubeRay[KubeRay Operator<br/>Ray Clusters]
        CodeFlare[CodeFlare Operator<br/>Ray Cluster Lifecycle]
        EvalHub[EvalHub<br/>Model Evaluation]
        TrustyAI[TrustyAI Operator<br/>Explainability + Bias]
        SparkOp[Spark Operator<br/>Spark Jobs]
    end

    subgraph "Data & Experiment Management"
        DSPO[DS Pipelines Operator<br/>ML Pipelines]
        DSP[DS Pipelines<br/>Argo Workflows + MLMD]
        MLflow[MLflow Operator<br/>Experiment Tracking]
        Feast[Feast Operator<br/>Feature Store]
    end

    subgraph "User Interface"
        Dashboard[odh-dashboard<br/>Module Federation UI<br/>10+ BFF servers]
    end

    subgraph "Notebooks & Development"
        KFNotebook[Kubeflow Notebook Controller<br/>Notebook Lifecycle]
        Notebooks[Notebooks<br/>Workbench + Runtime Images]
        OGX[OGX K8s Operator<br/>LlamaStack Inference]
        OGXServer[ogx - Llama Stack<br/>GenAI Server]
        MCP[RHOAI MCP Server<br/>Model Context Protocol]
    end

    %% rhods-operator deploys everything
    RhodsOp -->|deploys| KServe
    RhodsOp -->|deploys| Dashboard
    RhodsOp -->|deploys| ODMC
    RhodsOp -->|deploys| DSPO
    RhodsOp -->|deploys| KFNotebook
    RhodsOp -->|deploys| ModelReg
    RhodsOp -->|deploys| KubeRay
    RhodsOp -->|deploys| Kueue
    RhodsOp -->|deploys| TrustyAI
    RhodsOp -->|deploys| Feast
    RhodsOp -->|deploys| SparkOp
    RhodsOp -->|deploys| KFTrainer
    RhodsOp -->|deploys| KFTrainingOp
    RhodsOp -->|deploys| OGX
    RhodsOp -->|deploys| MaaS
    RhodsOp -->|deploys| MLflow
    RhodsOp -->|deploys| Gateway
    RhodsOp -->|deploys| WVA

    %% KServe serving hub
    KServe -->|creates| vLLM
    KServe -->|creates HTTPRoutes| Gateway
    KServe -->|creates EPP| LLMdEPP
    KServe -->|CRD| WVA
    ODMC -->|reconciles InferenceService| KServe
    ODMC -->|creates AuthPolicy| Gateway
    ODMC -->|creates ServiceMonitor| KServe
    LLMdEPP -->|scrapes metrics| vLLM
    LLMdEPP -->|ext_proc| Gateway
    LLMdSidecar -->|local decoder| vLLM
    GatewayInfExt -->|ext_proc EPP| Gateway
    ModelMesh -->|optional ISVC| KServe

    %% Dashboard integrations
    Dashboard -->|pipeline CRUD| DSP
    Dashboard -->|notebook mgmt| KFNotebook
    Dashboard -->|model CRUD| ModelRegSvc
    Dashboard -->|serving mgmt| KServe
    Dashboard -->|evaluation jobs| EvalHub
    Dashboard -->|feature stores| Feast
    Dashboard -->|experiment tracking| MLflow
    Dashboard -->|MaaS mgmt| MaaS
    Dashboard -->|GenAI agents| OGXServer

    %% Model management
    ModelReg -->|API| ModelRegSvc
    ModelRegSvc -->|syncs ISVC status| KServe
    MaaS -->|routing| KServe
    MaaS -->|HTTPRoutes + AuthPolicy| Gateway
    MaaS -->|API translation| AIGateway
    NeMo -->|deployed by| TrustyAI

    %% Training stack
    KFTrainer -->|pre-built images| KFTrainingOp
    KFTrainingOp -->|workload admission| Kueue
    KubeRay -->|workload admission| Kueue
    TrustyAI -->|workload admission| Kueue
    EvalHub -->|workload admission| Kueue
    EvalHub -->|experiment tracking| MLflow
    EvalHub -->|inference calls| vLLM

    %% Pipelines
    DSPO -->|manages| DSP
    DSP -->|auto-deploy| KServe
    DSP -->|stores models| ModelRegSvc

    %% Notebooks
    KFNotebook -->|manages| Notebooks
    Notebooks -->|auto-inject connections| DSP
    Notebooks -->|feature store config| Feast

    %% OGX / MCP
    OGX -->|manages| OGXServer
    OGXServer -->|inference backend| vLLM
    MCP -->|pipelines| DSPO
    MCP -->|serving| KServe
    MCP -->|notebooks| KFNotebook
    MCP -->|model metadata| ModelRegSvc
    MCP -->|training| KFTrainingOp

    %% Security sidecar
    KubeRBAC -.->|sidecar| KubeRay
    KubeRBAC -.->|sidecar| ModelReg
    KubeRBAC -.->|sidecar| Notebooks
    KubeRBAC -.->|sidecar| EvalHub
    KubeRBAC -.->|sidecar| Dashboard
    KubeRBAC -.->|sidecar| ODMC
    KubeRBAC -.->|sidecar| TrustyAI

