graph TB
    subgraph CorePlatform["Core Platform Services"]
        direction TB
        RhodsOp[rhods-operator<br/>RHOAI Platform Operator<br/>OLM-managed root operator]
        KRBACProxy[kube-rbac-proxy<br/>Auth Sidecar<br/>TokenReview + SAR]
    end

    subgraph ModelServing["Model Serving"]
        direction TB
        KServe[KServe<br/>Model Serving Control Plane<br/>InferenceService + LLMInferenceService]
        ModelMeshCtrl[ModelMesh Serving Controller<br/>Multi-model serving]
        ModelMesh[ModelMesh<br/>Distributed model cache]
        OdhModelCtrl[odh-model-controller<br/>Route/NetworkPolicy/ServiceMonitor]
        VLLM[vLLM CUDA<br/>LLM inference engine]
        LlmD[llm-d<br/>Disaggregated P/D serving]
        LlmDScheduler[llm-d-inference-scheduler<br/>KV-cache-aware routing]
        GatewayAPIExt[Gateway API Inference Extension<br/>Envoy ext-proc routing]
        MaaS[Models as a Service<br/>Multi-tenant model serving]
    end

    subgraph MLLifecycle["ML Lifecycle"]
        direction TB
        Dashboard[ODH Dashboard<br/>Platform UI + BFF sidecars]
        DSP[Data Science Pipelines<br/>KFP API Server]
        DSPO[DS Pipelines Operator<br/>DSPA lifecycle]
        ModelRegistry[Model Registry<br/>REST/gRPC metadata store]
        ModelRegistryOp[Model Registry Operator<br/>CR lifecycle]
        MLflowOp[MLflow Operator<br/>Helm-based deployment]
        MLflow[MLflow<br/>Experiment tracking]
        TrustyAIOp[TrustyAI Service Operator<br/>5 CRD controllers]
        TrustyAI[TrustyAI Explainability<br/>Bias/drift monitoring]
        EvalHub[Eval Hub<br/>Model evaluation]
    end

    subgraph TrainingBatch["Training & Batch Scheduling"]
        direction TB
        Kueue[Kueue<br/>Quota-aware batch scheduling]
        CodeFlareOp[CodeFlare Operator<br/>AppWrapper lifecycle]
        KubeRay[KubeRay Operator<br/>RayCluster management]
        TrainingOp[Training Operator<br/>PyTorchJob/XGBoostJob]
        Trainer[Kubeflow Trainer<br/>TrainJob/TrainingRuntime]
        SparkOp[Spark Operator<br/>SparkApplication lifecycle]
    end

    subgraph AISafety["AI Safety & Guardrails"]
        direction TB
        FMSOrch[FMS Guardrails Orchestrator<br/>Content safety pipeline]
        NeMo[NeMo Guardrails<br/>Content moderation]
        GuardrailsDet[Guardrails Detectors<br/>HF + LLM Judge classifiers]
    end

    subgraph FeatureData["Feature Engineering & Notebooks"]
        direction TB
        Feast[Feast<br/>Feature Store]
        Notebooks[Kubeflow Notebook Controllers<br/>Workbench lifecycle]
        NotebookImages[Notebook Images<br/>JupyterLab + runtimes]
    end

    subgraph ExternalDeps["External Dependencies"]
        direction TB
        Istio[Istio<br/>Service Mesh]
        Knative[Knative Serving<br/>Serverless]
        CertManager[cert-manager<br/>Certificate Management]
        ArgoWF[Argo Workflows<br/>Pipeline execution]
        S3[Object Storage<br/>S3/MinIO]
        K8sAPI[Kubernetes API]
    end

    %% rhods-operator deploys components
    RhodsOp -->|deploys| KServe
    RhodsOp -->|deploys| DSPO
    RhodsOp -->|deploys| Dashboard
    RhodsOp -->|deploys| Notebooks
    RhodsOp -->|deploys| Feast
    RhodsOp -->|deploys| ModelRegistryOp
    RhodsOp -->|deploys| MLflowOp
    RhodsOp -->|deploys| TrustyAIOp
    RhodsOp -->|deploys| CodeFlareOp
    RhodsOp -->|deploys| Kueue
    RhodsOp -->|deploys| ModelMeshCtrl
    RhodsOp -->|deploys| Trainer
    RhodsOp -->|deploys| SparkOp
    RhodsOp -->|deploys| KRBACProxy

    %% KServe serving dependencies
    KServe -->|traffic mgmt| Istio
    KServe -->|serverless autoscaling| Knative
    KServe -->|deploys| VLLM
    KServe -->|disaggregated topology| LlmD
    LlmD -->|ext-proc scheduling| LlmDScheduler
    LlmD -->|ext-proc routing| GatewayAPIExt
    KServe -->|model metadata| ModelRegistry
    OdhModelCtrl -->|route/netpol creation| KServe

    %% ModelMesh
    ModelMeshCtrl -->|deploys| ModelMesh
    ModelMeshCtrl -->|deploys| RhodsOp

    %% Dashboard integrations (forward deps)
    Dashboard -->|pipeline management| DSP
    Dashboard -->|model registration| ModelRegistry
    Dashboard -->|model serving| KServe
    Dashboard -->|experiment tracking| MLflowOp
    Dashboard -->|feature store mgmt| Feast
    Dashboard -->|model explainability| TrustyAIOp
    Dashboard -->|content moderation| NeMo
    Dashboard -->|model evaluation| EvalHub
    Dashboard -->|LLM inference + RAG| MaaS

    %% DS Pipelines chain
    DSPO -->|deploys| DSP
    DSP -->|compiles to| ArgoWF
    DSP -->|stores models| ModelRegistry
    DSP -->|model artifacts| S3

    %% Training & Batch
    CodeFlareOp -->|manages| KubeRay
    CodeFlareOp -->|quota admission| Kueue
    KubeRay -->|batch scheduling| Kueue
    TrainingOp -->|batch scheduling| Kueue
    TrustyAIOp -->|LMEval job scheduling| Kueue
    EvalHub -->|evaluation scheduling| Kueue

    %% Guardrails pipeline
    TrustyAIOp -->|auto-configures| FMSOrch
    FMSOrch -->|content detection| GuardrailsDet
    FMSOrch -->|safe requests| VLLM

    %% Model lifecycle
    ModelRegistryOp -->|deploys| ModelRegistry
    MLflowOp -->|deploys| MLflow
    TrustyAI -->|payload monitoring| KServe
    TrustyAIOp -->|deploys| TrustyAI
    EvalHub -->|result tracking| MLflow

    %% Notebooks
    Notebooks -->|workbench images| NotebookImages
    NotebookImages -->|pipeline credentials| DSP

    %% kube-rbac-proxy usage
    KRBACProxy -.->|auth sidecar| TrustyAIOp
    KRBACProxy -.->|auth sidecar| ModelRegistryOp
    KRBACProxy -.->|auth sidecar| Notebooks
    KRBACProxy -.->|auth sidecar| Dashboard
    KRBACProxy -.->|auth sidecar| KServe

    %% KubeRay mTLS
    KubeRay -->|mTLS certs| CertManager

    %% External service deps
    KServe -->|model artifacts| S3
    ModelRegistry -->|artifact storage| S3
    MLflow -->|artifact storage| S3

