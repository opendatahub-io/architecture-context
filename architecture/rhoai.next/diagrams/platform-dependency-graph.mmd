    %% rhods-operator manages all components
    rhods -->|manages| kserve
    rhods -->|manages| kueue
    rhods -->|manages| dashboard
    rhods -->|manages| kubeflow
    rhods -->|manages| mrop
    rhods -->|manages| trainop
    rhods -->|manages| trustyaiop
    rhods -->|manages| feast
    rhods -->|manages| dspo
    rhods -->|manages| kuberay
    rhods -->|manages| codeflareo
    rhods -->|manages| mlflowop
    rhods -->|manages| llamaop
    rhods -->|manages| maas
    rhods -->|manages| spark
    rhods -->|manages| odmctrl
    rhods -->|manages| trainer
    rhods -->|provisions| gateway
    rhods -->|provisions| kubeauthproxy

    %% KServe ecosystem
    kserve -->|extends| odmctrl
    odmctrl -->|Routes, EnvoyFilter| gateway
    kserve -->|predictor pods| vllm
    kserve -->|predictor pods| tgis
    kserve -->|predictor pods| ovms
    kserve -->|predictor pods| caikit
    kserve -->|predictor pods| mlserver
    modelmesh -->|routes requests| modelmeshrt
    modelmeshrt -->|invokes| tgis
    modelmeshrt -->|invokes| ovms
    modelmeshrt -->|invokes| mlserver

    %% llm-d stack
    gaieext -->|ext-proc routing| llmdsched
    llmdsched -->|KV-cache scoring| vllm
    llmdsched -->|cache mgmt| llmdkv
    llmdsidecar -->|prefill/decode| vllm
    wva -->|autoscales| vllm
    batchgw -->|batch inference| vllm

    %% Guardrails
    fmsguard -->|orchestrates| guarddet
    fmsguard -->|orchestrates| guardregex
    vllmorch -->|filters via| fmsguard
    vllmorch -->|inference via| vllm
    trustyaiop -->|manages| fmsguard
    trustyaiop -->|manages| nemoguard

    %% ML Pipelines
    dspo -->|deploys| dsp
    dsp -->|workflow exec| argo
    dsp -->|lineage tracking| mlmeta

    %% Training
    kueue -->|admission| trainop
    kueue -->|admission| trainer
    kueue -->|admission| kuberay
    codeflareo -->|secures| kuberay
    codeflaresdk -->|submits to| kuberay

    %% Model management
    mrop -->|deploys| mr
    mlflowop -->|deploys| mlflow

    %% Trust & Eval
    trustyaiop -->|deploys| trustyai
    trustyaiop -->|manages| evalhub
    evalhub -->|runs| lmeval

    %% Llama Stack
    llamaop -->|deploys| llama

    %% Dashboard integrations
    dashboard -->|proxies API| dsp
    dashboard -->|proxies API| mr
    dashboard -->|manages| kserve
    dashboard -->|manages| kubeflow

    %% Auth infrastructure
    gateway -->|auth| kubeauthproxy
    kuberbacproxy -.->|sidecar| dashboard
    kuberbacproxy -.->|sidecar| kubeflow
    kuberbacproxy -.->|sidecar| dspo
    kuberbacproxy -.->|sidecar| mrop
    kuberbacproxy -.->|sidecar| trustyaiop

    %% External dependencies
    kserve -->|model artifacts| s3
    dsp -->|pipeline artifacts| s3
    mr -->|artifact metadata| s3
    mlflow -->|artifacts| s3
    maas -->|remote inference| llmproviders
    llama -->|remote inference| llmproviders
    kserve -->|pull images| registry
    notebooks -->|packages| k8sapi

