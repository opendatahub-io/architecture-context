graph TB
    subgraph PlatformOperator["Platform Operator"]
        rhods["rhods-operator<br/>(opendatahub-operator)<br/>Go"]
    end

    subgraph InferenceStack["Model Serving & Inference"]
        KServe["KServe<br/>InferenceService +<br/>LLMInferenceService<br/>Go"]
        ModelMesh["ModelMesh Serving<br/>Multi-model serving<br/>Go + Java"]
        vLLM["vLLM Stack<br/>CUDA/ROCm/Gaudi/Spyre/CPU<br/>Python + C++"]
        TGIS["TGIS<br/>Text Generation<br/>Rust + Python"]
        Caikit["Caikit + caikit-tgis<br/>Runtime framework<br/>Python"]
        MLServer["MLServer<br/>Multi-framework<br/>Python"]
        OpenVINO["OpenVINO Model Server<br/>Intel optimized<br/>C++ + Python"]
    end

    subgraph LLMdStack["llm-d Disaggregated Inference"]
        llmd["llm-d<br/>P/D orchestration<br/>Go + Python"]
        EPP["llm-d-inference-scheduler<br/>Endpoint Picker (EPP)<br/>Go"]
        KVCache["llm-d-kv-cache<br/>KV transfer + indexing<br/>Go"]
        RoutingSidecar["llm-d-routing-sidecar<br/>Decode handoff<br/>Go"]
        WVA["Workload Variant Autoscaler<br/>Traffic-aware scaling<br/>Go"]
        BatchGW["batch-gateway<br/>OpenAI batch API<br/>Go"]
    end

    subgraph GatewayInfra["Gateway & Auth Infrastructure"]
        Gateway["data-science-gateway<br/>Envoy-based Gateway<br/>Go + Envoy"]
        KubeAuthProxy["kube-auth-proxy<br/>Centralized OAuth2/OIDC<br/>Go"]
        KubeRBACProxy["kube-rbac-proxy<br/>SAR auth sidecar<br/>Go"]
        GatewayAPIExt["Gateway API<br/>Inference Extension<br/>Go"]
    end

    subgraph MaaSGuardrails["MaaS & Guardrails"]
        MaaS["Models as a Service<br/>Multi-tenant marketplace<br/>Go"]
        AIGateway["AI Gateway<br/>Payload Processing<br/>Go"]
        NeMo["NeMo Guardrails<br/>Input/output rails<br/>Python"]
        Authorino["Authorino<br/>Gateway auth<br/>Go"]
        Limitador["Limitador<br/>Rate limiting<br/>Rust"]
    end

    subgraph TrainingStack["Training & Scheduling"]
        Kueue["Kueue<br/>Job queueing<br/>Go"]
        TrainingOp["Training Operator<br/>PyTorchJob<br/>Go"]
        Trainer["Trainer (v2)<br/>TrainJob + TrainingRuntime<br/>Go"]
        CodeFlare["CodeFlare Operator<br/>RayCluster lifecycle<br/>Go"]
        KubeRay["KubeRay Operator<br/>Ray cluster mgmt<br/>Go"]
        FMSTuning["FMS HF Tuning<br/>SFT/LoRA fine-tuning<br/>Python"]
        SparkOp["Spark Operator<br/>SparkApplication<br/>Go"]
    end

    subgraph Pipelines["Data Science Pipelines"]
        DSPO["DSP Operator<br/>Pipeline lifecycle<br/>Go"]
        DSP["DSP API Server<br/>KFP v2<br/>Go"]
        ArgoWF["Argo Workflows<br/>DAG execution<br/>Go"]
        MLMD["ML Metadata<br/>Lineage tracking<br/>C++"]
    end

    subgraph RegistryExperiments["Registry, Experiments & Evaluation"]
        ModelReg["Model Registry<br/>Model metadata<br/>Go + Python"]
        ModelRegOp["Model Registry Operator<br/>Lifecycle mgmt<br/>Go"]
        MLflow["MLflow<br/>Experiment tracking<br/>Python"]
        MLflowOp["MLflow Operator<br/>Helm-as-template<br/>Go"]
        TrustyAI["TrustyAI Service<br/>Explainability + guardrails<br/>Java"]
        TrustyAIOp["TrustyAI Operator<br/>LMEval + orchestration<br/>Go"]
        EvalHub["Eval Hub<br/>Evaluation orchestration<br/>Go"]
        LMEvalHarness["lm-evaluation-harness<br/>Batch evaluation<br/>Python"]
    end

    subgraph Notebooks["Notebooks & Feature Stores"]
        Dashboard["RHOAI Dashboard<br/>Web console<br/>TypeScript"]
        NotebookCtrl["Kubeflow Notebook Controller<br/>Notebook lifecycle<br/>Go"]
        Feast["Feast Operator<br/>Feature store<br/>Go"]
    end

    subgraph LlamaStack["Llama Stack"]
        LlamaStackOp["Llama Stack K8s Operator<br/>API server lifecycle<br/>Go"]
        LlamaStackDist["RHDS Llama Stack<br/>Distribution<br/>Python"]
    end

    subgraph ExternalDeps["External Platform Dependencies"]
        Istio["Istio / OSSM<br/>Service Mesh"]
        Knative["Knative Serving<br/>Serverless"]
        OCP["OpenShift Container Platform<br/>v4.14-4.17"]
        OLM["OLM<br/>Operator Lifecycle"]
        Prometheus["Prometheus<br/>Metrics"]
    end

    %% Platform operator deploys everything
    rhods -->|deploys + manages| KServe
    rhods -->|deploys + manages| Dashboard
    rhods -->|deploys + manages| Kueue
    rhods -->|deploys + manages| DSPO
    rhods -->|deploys + manages| ModelRegOp
    rhods -->|deploys + manages| CodeFlare
    rhods -->|deploys + manages| TrainingOp
    rhods -->|deploys + manages| TrustyAIOp
    rhods -->|deploys + manages| SparkOp
    rhods -->|deploys + manages| MLflowOp
    rhods -->|deploys + manages| Feast
    rhods -->|deploys + manages| NotebookCtrl
    rhods -->|deploys + manages| LlamaStackOp
    rhods -->|deploys + manages| MaaS
    rhods -->|deploys Gateway| Gateway
    rhods -->|deploys auth| KubeAuthProxy

    %% KServe inference dependencies
    KServe -->|orchestrates| vLLM
    KServe -->|orchestrates| TGIS
    KServe -->|orchestrates| MLServer
    KServe -->|orchestrates| Caikit
    KServe -->|orchestrates| OpenVINO
    KServe -->|serverless scaling| Knative
    KServe -->|traffic mgmt| Istio
    KServe -->|InferencePool| GatewayAPIExt

    %% ModelMesh
    ModelMesh -->|runtime adapter| vLLM
    ModelMesh -->|runtime adapter| TGIS
    ModelMesh -->|runtime adapter| MLServer

    %% llm-d stack
    llmd -->|scheduling| EPP
    llmd -->|KV transfer| KVCache
    llmd -->|decode routing| RoutingSidecar
    llmd -->|ext_proc routing| GatewayAPIExt
    WVA -->|autoscales| llmd
    WVA -->|reads metrics| EPP
    BatchGW -->|batch inference| llmd
    vLLM -->|P/D execution| llmd

    %% Gateway infrastructure
    Gateway -->|auth delegation| KubeAuthProxy
    Gateway -->|ext_proc| GatewayAPIExt
    Gateway -->|ext_proc| AIGateway
    Dashboard -->|HTTPRoute| Gateway
    MaaS -->|HTTPRoute| Gateway
    MLflow -->|HTTPRoute| Gateway

    %% MaaS + Guardrails
    MaaS -->|auth| Authorino
    MaaS -->|rate limiting| Limitador
    AIGateway -->|input/output rails| NeMo

    %% Training stack
    Kueue -->|quota + admission| TrainingOp
    Kueue -->|quota + admission| Trainer
    Kueue -->|quota + admission| CodeFlare
    Kueue -->|quota + admission| SparkOp
    CodeFlare -->|manages| KubeRay
    TrainingOp -->|worker pods| FMSTuning
    Trainer -->|worker pods| FMSTuning

    %% Pipelines
    DSPO -->|deploys| DSP
    DSPO -->|deploys| ArgoWF
    DSP -->|DAG execution| ArgoWF
    DSP -->|lineage| MLMD

    %% Registry + Experiments
    ModelRegOp -->|manages| ModelReg
    MLflowOp -->|manages| MLflow
    TrustyAIOp -->|manages| TrustyAI
    TrustyAIOp -->|runs| LMEvalHarness
    EvalHub -->|orchestrates| LMEvalHarness

    %% Cross-component integrations
    Dashboard -->|UI for| KServe
    Dashboard -->|UI for| ModelReg
    Dashboard -->|UI for| DSP
    Dashboard -->|UI for| NotebookCtrl
    FMSTuning -->|registers models| ModelReg
    DSP -->|deploys models| KServe
    DSP -->|stores metadata| ModelReg
    KServe -->|model metadata| ModelReg

    %% Llama Stack
    LlamaStackOp -->|deploys| LlamaStackDist

    %% External platform dependencies
    KServe -->|mTLS| Istio
    ModelReg -->|mTLS| Istio
    rhods -->|managed by| OLM
    KServe -.->|metrics| Prometheus
    Dashboard -.->|metrics| Prometheus
    Kueue -.->|metrics| Prometheus
    DSPO -.->|metrics| Prometheus

