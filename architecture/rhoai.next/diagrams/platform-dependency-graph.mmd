graph TB
    subgraph "Platform Operator"
        RhodsOp[rhods-operator<br/>Central Orchestrator]
    end

    subgraph "Infrastructure Services"
        DSCI[DSCInitialization<br/>Namespaces, Gateway,<br/>Monitoring, Auth]
        DSC[DataScienceCluster<br/>Component Lifecycle]
        ServiceCRDs[Service CRDs<br/>Auth, Gateway, Monitoring]
    end

    subgraph "Gateway & Auth"
        Gateway[data-science-gateway<br/>Envoy]
        KubeAuthProxy[kube-auth-proxy<br/>OAuth2/OIDC]
        KubeRBACProxy[kube-rbac-proxy<br/>SubjectAccessReview]
    end

    subgraph "Core Data Science Components"
        Dashboard[ODH Dashboard<br/>7 BFF Modules]
        KServe[KServe<br/>InferenceService +<br/>LLMInferenceService]
        Kueue[Kueue<br/>Job Queueing + Quota]
        DSP[Data Science Pipelines<br/>KFP v2]
        ModelReg[Model Registry<br/>ML Metadata REST API]
        TrustyAI[TrustyAI<br/>Explainability + Fairness]
        MaaS[Models-as-a-Service<br/>Multi-Tenant LLM Gateway]
    end

    subgraph "Training & Compute"
        TrainingOp[Training Operator<br/>6 Job Types]
        Trainer[Trainer<br/>TrainJob + TrainingRuntime]
        KubeRay[KubeRay<br/>Ray Clusters]
        CodeFlare[CodeFlare Operator<br/>Ray OAuth + mTLS]
        Spark[Spark Operator<br/>SparkApplication]
    end

    subgraph "Model Serving Runtimes"
        vLLM[vLLM Variants<br/>CUDA, ROCm, CPU,<br/>Gaudi, Spyre]
        TGIS[Text Generation<br/>Inference Service]
        Caikit[Caikit<br/>gRPC/HTTP Serving]
        OpenVINO[OpenVINO<br/>Model Server]
        MLServer[MLServer<br/>V2 Dataplane]
        ModelMesh[ModelMesh Serving<br/>Distributed LRU Cache]
    end

    subgraph "LLM-d Distributed Inference"
        LLMD[llm-d Stack<br/>Configuration]
        EPP[llm-d-inference-scheduler<br/>KV-Cache Routing]
        KVCache[llm-d-kv-cache<br/>Indexer]
        RoutingSidecar[llm-d-routing-sidecar<br/>P/D Disaggregation]
        WVA[workload-variant-autoscaler<br/>Saturation Scaling]
        GwInfExt[gateway-api-inference-ext<br/>Envoy ext_proc]
    end

    subgraph "AI Safety & Evaluation"
        Guardrails[fms-guardrails-orchestrator<br/>Detector Pipeline]
        NemoGR[NeMo-Guardrails<br/>Colang DSL]
        LMES[LM Evaluation Harness<br/>Batch Evaluation]
        EvalHub[eval-hub<br/>Evaluation Orchestration]
    end

    subgraph "Additional Services"
        MLflow[MLflow<br/>Experiment Tracking]
        Feast[Feast<br/>Feature Store]
        LlamaStack[LlamaStack<br/>AI Inference/Agent Server]
        ModelController[odh-model-controller<br/>KServe Extension]
    end

    subgraph "External Dependencies"
        S3[S3/Object Storage]
        OAuthServer[OpenShift OAuth]
        K8sAPI[Kubernetes API]
        ContainerReg[Container Registry<br/>quay.io]
        Kuadrant[Kuadrant/Authorino<br/>Rate Limiting]
        MariaDB[MariaDB<br/>Pipeline Metadata]
        PostgreSQL[PostgreSQL<br/>MaaS + LlamaStack]
    end

    %% Operator hierarchy
    RhodsOp -->|provisions| DSCI
    RhodsOp -->|manages| DSC
    RhodsOp -->|configures| ServiceCRDs

    DSCI -->|creates| Gateway
    DSCI -->|deploys| KubeAuthProxy

    DSC -->|deploys| Dashboard
    DSC -->|deploys| KServe
    DSC -->|deploys| Kueue
    DSC -->|deploys| DSP
    DSC -->|deploys| ModelReg
    DSC -->|deploys| TrustyAI
    DSC -->|deploys| MaaS
    DSC -->|deploys| TrainingOp
    DSC -->|deploys| Trainer
    DSC -->|deploys| KubeRay
    DSC -->|deploys| Feast
    DSC -->|deploys| LlamaStack
    DSC -->|deploys| MLflow
    DSC -->|deploys| Spark
    DSC -->|deploys| ModelController

    %% Gateway auth
    Gateway -->|ext_authz| KubeAuthProxy
    KubeAuthProxy -->|OAuth flow| OAuthServer

    %% Dashboard integrations
    Dashboard -->|UI management| KServe
    Dashboard -->|model listing| ModelReg
    Dashboard -->|pipeline UI| DSP
    Dashboard -->|model metrics| TrustyAI
    Dashboard -->|MaaS module| MaaS
    Dashboard -->|experiment UI| MLflow

    %% KServe ecosystem
    KServe -->|creates| vLLM
    KServe -->|creates| TGIS
    KServe -->|creates| Caikit
    KServe -->|creates| OpenVINO
    KServe -->|creates| MLServer
    KServe -->|routing| GwInfExt
    KServe -->|model metadata| ModelReg
    KServe -->|model storage| S3
    ModelController -->|OpenShift extensions| KServe

    %% LLM-d stack
    LLMD -->|configures| EPP
    LLMD -->|configures| KVCache
    LLMD -->|configures| RoutingSidecar
    EPP -->|KV-aware routing| vLLM
    WVA -->|autoscales| vLLM
    GwInfExt -->|ext_proc routing| EPP

    %% MaaS integrations
    MaaS -->|rate limiting| Kuadrant
    MaaS -->|API key storage| PostgreSQL
    MaaS -->|inference proxy| KServe

    %% Kueue job scheduling
    TrainingOp -->|quota mgmt| Kueue
    Trainer -->|quota mgmt| Kueue
    KubeRay -->|quota mgmt| Kueue
    DSP -->|quota mgmt| Kueue

    %% CodeFlare → Ray
    CodeFlare -->|mTLS + OAuth| KubeRay

    %% DSP dependencies
    DSP -->|artifact storage| S3
    DSP -->|pipeline metadata| MariaDB

    %% TrustyAI integrations
    TrustyAI -->|monitors| KServe
    TrustyAI -->|evaluation| LMES

    %% Guardrails
    Guardrails -->|safety checks| vLLM
    NemoGR -->|guardrails| vLLM

    %% ModelMesh
    ModelMesh -->|distributed serving| KServe

    %% Auth sidecar usage
    KubeRBACProxy -.->|sidecar auth| Dashboard
    KubeRBACProxy -.->|sidecar auth| DSP
    KubeRBACProxy -.->|sidecar auth| TrustyAI
    KubeRBACProxy -.->|sidecar auth| KServe
    KubeRBACProxy -.->|sidecar auth| RhodsOp

    %% LlamaStack
    LlamaStack -->|persistence| PostgreSQL

