graph TD
    subgraph "Service Accounts (Pod Identity Only)"
        SA_API["{release}-batch-gateway-apiserver<br/>ServiceAccount"]
        SA_PROC["{release}-batch-gateway-processor<br/>ServiceAccount"]
        SA_GC["{release}-batch-gateway-gc<br/>ServiceAccount"]
    end

    subgraph "Deployments"
        Deploy_API["apiserver Deployment<br/>Ports: service.port, 8081"]
        Deploy_PROC["processor Deployment<br/>Port: configurable addr"]
        Deploy_GC["gc Deployment<br/>No ports"]
    end

    subgraph "Secrets"
        Secret_Main["batch-gateway-secrets (Opaque)<br/>• redis-url<br/>• postgresql-url<br/>• inference-api-key<br/>• s3-secret-access-key"]
        Secret_TLS["{release}-batch-gateway-apiserver-tls<br/>(kubernetes.io/tls)<br/>• tls.crt<br/>• tls.key<br/>Provisioned by: cert-manager / manual"]
    end

    subgraph "Authentication Model"
        AuthNote["No RBAC ClusterRoles or RoleBindings<br/><br/>Tenant isolation via HTTP header:<br/>• Header: X-MaaS-Username (configurable)<br/>• All queries scoped by tenant ID<br/>• File paths use SHA256(tenant_id)<br/><br/>No authentication at gateway layer:<br/>• Relies on upstream auth proxy<br/>• e.g., kube-rbac-proxy, external auth service"]
    end

    SA_API -->|"runs as"| Deploy_API
    SA_PROC -->|"runs as"| Deploy_PROC
    SA_GC -->|"runs as"| Deploy_GC

    Deploy_API -->|"mounts"| Secret_Main
    Deploy_API -->|"mounts (when TLS enabled)"| Secret_TLS
    Deploy_PROC -->|"mounts"| Secret_Main
    Deploy_GC -->|"mounts"| Secret_Main

    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#7ed321,stroke:#333,color:#fff
    style SA_GC fill:#f5a623,stroke:#333,color:#fff
    style Secret_Main fill:#e74c3c,stroke:#333,color:#fff
    style Secret_TLS fill:#e74c3c,stroke:#333,color:#fff
    style AuthNote fill:#f9f9f9,stroke:#999
    style Deploy_API fill:#d5e8d4,stroke:#82b366
    style Deploy_PROC fill:#d5e8d4,stroke:#82b366
    style Deploy_GC fill:#d5e8d4,stroke:#82b366
