graph TD
    subgraph ServiceAccounts["Service Accounts (Pod Identity Only)"]
        SA_API["batch-gateway-apiserver<br/>SA: {release}-batch-gateway-apiserver"]
        SA_PROC["batch-gateway-processor<br/>SA: {release}-batch-gateway-processor"]
        SA_GC["batch-gateway-gc<br/>SA: {release}-batch-gateway-gc"]
    end

    subgraph TenantAuth["Application-Level Multi-Tenancy"]
        direction TB
        Middleware["Request Middleware<br/>(request_middleware.go)"]
        TenantHeader["Tenant Header Extraction<br/>Default: X-MaaS-Username"]
        TenantScope["Tenant-Scoped Queries<br/>All DB queries filtered by tenant ID"]
        FileIsolation["File Path Isolation<br/>SHA256-derived folders<br/>incorporating tenant ID"]
    end

    subgraph Secrets["Kubernetes Secrets"]
        direction TB
        BGSecret["batch-gateway-secrets<br/>Type: Opaque<br/>Provisioned: Manual"]
        TLSSecret["{release}-batch-gateway-apiserver-tls<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager or manual"]
    end

    subgraph SecretKeys["Secret Contents"]
        RedisURL["redis-url<br/>Redis/Valkey connection URL"]
        PGURL["postgresql-url<br/>PostgreSQL connection URL"]
        APIKey["inference-api-key<br/>Bearer token for inference gateway"]
        S3Key["s3-secret-access-key<br/>AWS secret access key"]
        TLSCert["tls.crt + tls.key<br/>Apiserver TLS certificate"]
    end

    subgraph Endpoints["Endpoint Authentication"]
        direction TB
        BatchEndpoint["/v1/batches/*<br/>Auth: Tenant header<br/>No authn - upstream proxy"]
        FileEndpoint["/v1/files/*<br/>Auth: Tenant header<br/>No authn - upstream proxy"]
        ObsEndpoint["/health, /ready, /metrics<br/>Auth: None<br/>Unauthenticated"]
        InferenceEndpoint["Inference Gateway<br/>Auth: Bearer token (API key)"]
    end

    %% Service Account relationships
    SA_API -->|"pod identity"| Middleware
    SA_PROC -->|"pod identity"| InferenceEndpoint
    SA_GC -->|"pod identity<br/>no network access"| BGSecret

    %% Tenant auth flow
    Middleware --> TenantHeader
    TenantHeader --> TenantScope
    TenantHeader --> FileIsolation

    %% Secret usage
    BGSecret --> RedisURL
    BGSecret --> PGURL
    BGSecret --> APIKey
    BGSecret --> S3Key
    TLSSecret --> TLSCert

    %% Endpoint auth
    Middleware --> BatchEndpoint
    Middleware --> FileEndpoint

    %% Notes
    NoRBAC["Note: No ClusterRoles or<br/>RoleBindings defined.<br/>ServiceAccounts are used<br/>for pod identity only.<br/>Auth relies on upstream proxy."]

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#7ed321,stroke:#333,color:#fff
    style SA_GC fill:#f5a623,stroke:#333,color:#fff
    style BGSecret fill:#e74c3c,stroke:#333,color:#fff
    style TLSSecret fill:#e74c3c,stroke:#333,color:#fff
    style Middleware fill:#9b59b6,stroke:#333,color:#fff
    style TenantHeader fill:#9b59b6,stroke:#333,color:#fff
    style TenantScope fill:#9b59b6,stroke:#333,color:#fff
    style FileIsolation fill:#9b59b6,stroke:#333,color:#fff
    style BatchEndpoint fill:#3498db,stroke:#333,color:#fff
    style FileEndpoint fill:#3498db,stroke:#333,color:#fff
    style ObsEndpoint fill:#95a5a6,stroke:#333,color:#fff
    style InferenceEndpoint fill:#3498db,stroke:#333,color:#fff
    style NoRBAC fill:#fff3cd,stroke:#856404,color:#856404
    style RedisURL fill:#ffcccc,stroke:#333
    style PGURL fill:#ffcccc,stroke:#333
    style APIKey fill:#ffcccc,stroke:#333
    style S3Key fill:#ffcccc,stroke:#333
    style TLSCert fill:#ffcccc,stroke:#333
