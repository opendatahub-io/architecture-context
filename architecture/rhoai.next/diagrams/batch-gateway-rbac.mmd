graph TD
    subgraph "Service Accounts"
        SA_API["batch-gateway-apiserver<br/>(apiserver pods)"]
        SA_PROC["batch-gateway-processor<br/>(processor pods)"]
        SA_GC["batch-gateway-gc<br/>(GC pods)"]
    end

    subgraph "Application-Level Auth (No K8s RBAC Roles)"
        direction TB
        Note["No ClusterRoles or RoleBindings defined.<br/>Auth is application-level, not K8s RBAC."]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        TenantAuth["Tenant ID Header<br/>(X-MaaS-Username)<br/>Middleware enforcement"]
        InferenceAuth["Inference API Key<br/>(Bearer token)<br/>From mounted secret"]
        PostgreSQLAuth["PostgreSQL DSN<br/>(username/password)<br/>From mounted secret"]
        RedisAuth["Redis URL Auth<br/>+ Optional TLS/mTLS client certs<br/>From mounted secret"]
        S3Auth["AWS Credentials<br/>(AccessKeyID + SecretAccessKey)<br/>From mounted secret"]
    end

    subgraph "Multi-Tenant Isolation"
        direction TB
        DBFilter["DB Queries Filtered<br/>by tenant_id"]
        S3Folder["S3 Tenant Folder<br/>t-SHA256(tenant_id)"]
        NotFound["Cross-Tenant Access<br/>Returns 404 (not 403)"]
    end

    subgraph "Secrets"
        GlobalSecret["global.secretName (Opaque)<br/>Keys: redis-url, postgresql-url,<br/>inference-api-key, s3-secret-access-key<br/>Provisioned: Manual / External operator<br/>Auto-Rotate: No"]
        TLSSecret["apiserver-tls (kubernetes.io/tls)<br/>Keys: tls.crt, tls.key<br/>Provisioned: cert-manager or manual<br/>Auto-Rotate: Yes (cert-manager)"]
    end

    SA_API -->|"uses"| TenantAuth
    SA_API -->|"mounts"| GlobalSecret
    SA_API -->|"mounts"| TLSSecret
    SA_PROC -->|"uses"| InferenceAuth
    SA_PROC -->|"mounts"| GlobalSecret
    SA_GC -->|"mounts"| GlobalSecret

    TenantAuth --> DBFilter
    TenantAuth --> S3Folder
    TenantAuth --> NotFound

    GlobalSecret -->|"provides"| PostgreSQLAuth
    GlobalSecret -->|"provides"| RedisAuth
    GlobalSecret -->|"provides"| S3Auth
    GlobalSecret -->|"provides"| InferenceAuth

    style SA_API fill:#4a90e2,color:#fff
    style SA_PROC fill:#4a90e2,color:#fff
    style SA_GC fill:#4a90e2,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style TenantAuth fill:#f5a623,color:#fff
    style InferenceAuth fill:#f5a623,color:#fff
    style PostgreSQLAuth fill:#f5a623,color:#fff
    style RedisAuth fill:#f5a623,color:#fff
    style S3Auth fill:#f5a623,color:#fff
    style DBFilter fill:#7ed321,color:#fff
    style S3Folder fill:#7ed321,color:#fff
    style NotFound fill:#7ed321,color:#fff
    style GlobalSecret fill:#e8e8e8,stroke:#666
    style TLSSecret fill:#e8e8e8,stroke:#666
