graph TD
    subgraph "Service Accounts (Helm-created)"
        SA_API["{release}-apiserver<br/>ServiceAccount"]
        SA_PROC["{release}-processor<br/>ServiceAccount"]
        SA_GC["{release}-gc<br/>ServiceAccount"]
    end

    subgraph "RBAC Bindings"
        NoBind["No ClusterRoleBindings<br/>No RoleBindings<br/>(stateless service,<br/>no K8s API access)"]
    end

    subgraph "Kubernetes API Access"
        NoAccess["No Kubernetes API calls<br/>No watch/list/create permissions<br/>Not an operator"]
    end

    subgraph "Application-Level Authorization"
        direction TB

        TenantAuth["Tenant Isolation Model"]
        ExtAuth["External AuthN<br/>(Kuadrant / Authorino)<br/>Envoy ext_authz"]
        TenantHeader["Tenant Header Extraction<br/>X-MaaS-Username (last value)<br/>Envoy appends verified identity"]
        DataScoping["Data Access Scoping<br/>All DB queries filtered by tenant_id<br/>Cross-tenant: HTTP 404"]

        ExtAuth -->|"authenticates request"| TenantHeader
        TenantHeader -->|"extracts tenant ID"| DataScoping
        TenantAuth --- ExtAuth
    end

    subgraph "Secrets Access"
        Secret1["batch-gateway-secrets<br/>(Opaque)<br/>- redis-url<br/>- postgresql-url<br/>- inference-api-key<br/>- s3-secret-access-key<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        Secret2["{release}-apiserver-tls<br/>(kubernetes.io/tls)<br/>- tls.crt<br/>- tls.key<br/>Provisioned: cert-manager (optional)<br/>Auto-Rotate: Yes (cert-manager)"]
    end

    SA_API -->|"mounts"| Secret1
    SA_API -->|"mounts (optional)"| Secret2
    SA_PROC -->|"mounts"| Secret1
    SA_GC -->|"mounts"| Secret1

    SA_API -.->|"no RBAC bindings"| NoBind
    SA_PROC -.->|"no RBAC bindings"| NoBind
    SA_GC -.->|"no RBAC bindings"| NoBind
    NoBind -.->|"no API access"| NoAccess

    SA_API -->|"uses"| TenantAuth

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#4a90e2,stroke:#333,color:#fff
    style SA_GC fill:#4a90e2,stroke:#333,color:#fff
    style NoBind fill:#e8e8e8,stroke:#999
    style NoAccess fill:#e8e8e8,stroke:#999
    style ExtAuth fill:#ffe6cc,stroke:#d79b00
    style TenantHeader fill:#d5e8d4,stroke:#82b366
    style DataScoping fill:#d5e8d4,stroke:#82b366
    style TenantAuth fill:#fff2cc,stroke:#d6b656
    style Secret1 fill:#f8cecc,stroke:#b85450
    style Secret2 fill:#f8cecc,stroke:#b85450
