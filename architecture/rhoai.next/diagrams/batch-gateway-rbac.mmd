graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["No Kubernetes RBAC defined"]
        L2["Authorization is application-level only"]
    end

    subgraph ServiceAccounts["Service Accounts (Pod Identity Only)"]
        SA_API["{release}-batch-gateway-apiserver"]
        SA_PROC["{release}-batch-gateway-processor"]
        SA_GC["{release}-batch-gateway-gc"]
    end

    subgraph ApplicationAuth["Application-Level Authorization"]
        direction TB
        TenantHeader["Tenant Header Extraction<br/>Header: X-MaaS-Username (configurable)<br/>Middleware: request_middleware.go"]
        TenantScope["Tenant-Scoped Data Isolation<br/>All DB queries filtered by tenant_id<br/>File paths use SHA256(tenant_id)"]
        UpstreamProxy["Upstream Auth Proxy<br/>(kube-rbac-proxy / external auth)<br/>Validates identity, injects tenant header"]
    end

    subgraph ProtectedEndpoints["Protected Endpoints (Tenant-Scoped)"]
        BatchAPI["/v1/batches/*<br/>GET, POST"]
        FileAPI["/v1/files/*<br/>GET, POST, DELETE"]
    end

    subgraph UnprotectedEndpoints["Unprotected Endpoints (No Auth)"]
        Health["/health<br/>GET, HEAD"]
        Ready["/ready<br/>GET, HEAD"]
        Metrics["/metrics<br/>GET"]
    end

    subgraph Secrets["Secrets"]
        SecretMain["batch-gateway-secrets (Opaque)<br/>- redis-url<br/>- postgresql-url<br/>- inference-api-key<br/>- s3-secret-access-key<br/>Provisioned: Manual | Auto-Rotate: No"]
        SecretTLS["{release}-batch-gateway-apiserver-tls<br/>(kubernetes.io/tls)<br/>- tls.crt, tls.key<br/>Provisioned: cert-manager or manual<br/>Auto-Rotate: Yes (cert-manager)"]
    end

    %% Flows
    UpstreamProxy -->|"validates identity"| TenantHeader
    TenantHeader -->|"extracts tenant_id"| TenantScope
    TenantScope -->|"scopes access"| BatchAPI
    TenantScope -->|"scopes access"| FileAPI

    SA_API -->|"pod identity for"| Apiserver["Apiserver Pod"]
    SA_PROC -->|"pod identity for"| Processor["Processor Pod"]
    SA_GC -->|"pod identity for"| GCPod["GC Pod"]

    Apiserver -->|"uses"| SecretMain
    Apiserver -->|"uses"| SecretTLS
    Processor -->|"uses"| SecretMain
    GCPod -->|"uses"| SecretMain

    %% Styling
    style SA_API fill:#4a90e2,color:#fff
    style SA_PROC fill:#4a90e2,color:#fff
    style SA_GC fill:#4a90e2,color:#fff
    style TenantHeader fill:#f5a623,color:#fff
    style TenantScope fill:#f5a623,color:#fff
    style UpstreamProxy fill:#e74c3c,color:#fff
    style BatchAPI fill:#7ed321,color:#fff
    style FileAPI fill:#7ed321,color:#fff
    style Health fill:#e8e8e8,stroke:#333
    style Ready fill:#e8e8e8,stroke:#333
    style Metrics fill:#e8e8e8,stroke:#333
    style SecretMain fill:#9b59b6,color:#fff
    style SecretTLS fill:#9b59b6,color:#fff
    style Legend fill:#fff,stroke:#ccc,stroke-dasharray:5
