graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["SA: {release}-batch-gateway-apiserver<br/>Component: API Server"]
        SA_PROC["SA: {release}-batch-gateway-processor<br/>Component: Processor"]
        SA_GC["SA: {release}-batch-gateway-gc<br/>Component: Garbage Collector"]
    end

    subgraph RBAC["Kubernetes RBAC"]
        NoRBAC["No ClusterRoles or Roles<br/>No Kubernetes API permissions required<br/>All components operate purely as<br/>data-plane services"]
    end

    subgraph TenantIsolation["Tenant Isolation (Application-Level)"]
        TenantHeader["X-MaaS-Username Header<br/>(configurable)"]
        TenantScope["All DB queries scoped<br/>to tenant ID"]
        CrossTenant["Cross-tenant access<br/>returns 404 (not 403)<br/>to prevent info leakage"]
        TenantHeader --> TenantScope
        TenantScope --> CrossTenant
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        ExternalAuth["External Auth<br/>(Kuadrant/Authorino)"]
        InferenceAuth["Inference Auth Options"]
        APIKey["Option 1: API key<br/>from named file"]
        SecretMount["Option 2: API key<br/>from /etc/.secrets/<br/>(K8s secret mount)"]
        SAToken["Option 3: SA token<br/>(standard mount)"]
        mTLS["Option 4: mTLS<br/>with custom CA"]
        InferenceAuth --> APIKey
        InferenceAuth --> SecretMount
        InferenceAuth --> SAToken
        InferenceAuth --> mTLS
    end

    subgraph Secrets["Kubernetes Secrets"]
        BGSecrets["batch-gateway-secrets<br/>Type: Opaque<br/>Provisioned: Manual"]
        TLSSecret["{release}-batch-gateway-apiserver-tls<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-rotate: Yes"]

        RedisURL["redis-url"]
        PGURL["postgresql-url"]
        InfKey["inference-api-key"]
        S3Key["s3-secret-access-key"]

        BGSecrets --> RedisURL
        BGSecrets --> PGURL
        BGSecrets --> InfKey
        BGSecrets --> S3Key
    end

    subgraph SecurityHardening["Pod Security Hardening"]
        ReadOnly["readOnlyRootFilesystem: true"]
        NonRoot["runAsNonRoot: true<br/>runAsUser: 65532"]
        DropCaps["drop ALL capabilities"]
        Seccomp["seccompProfile: RuntimeDefault"]
        PathSafe["os.OpenInRoot() for<br/>path traversal prevention"]
        Slowloris["read_header_timeout: 10s<br/>Slowloris protection"]
    end

    SA_API --> NoRBAC
    SA_PROC --> NoRBAC
    SA_GC --> NoRBAC

    SA_API -->|"uses"| TenantHeader
    SA_API -->|"mounts"| BGSecrets
    SA_API -->|"mounts"| TLSSecret
    SA_PROC -->|"mounts"| BGSecrets
    SA_PROC -->|"authenticates via"| InferenceAuth
    SA_GC -->|"mounts"| BGSecrets

    ExternalAuth -->|"injects"| TenantHeader

    style ServiceAccounts fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#d5e8d4,stroke:#82b366
    style TenantIsolation fill:#fff2cc,stroke:#d6b656
    style AuthMechanisms fill:#e8d5f5,stroke:#9b59b6
    style Secrets fill:#ffe6cc,stroke:#d79b00
    style SecurityHardening fill:#d5e8d4,stroke:#82b366
    style BGSecrets fill:#f5a623,stroke:#333,color:#fff
    style TLSSecret fill:#f5a623,stroke:#333,color:#fff
