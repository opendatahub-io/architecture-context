graph TD
    subgraph "Service Accounts"
        SA_API["{release}-batch-gateway-apiserver<br/>ServiceAccount"]
        SA_PROC["{release}-batch-gateway-processor<br/>ServiceAccount"]
        SA_GC["{release}-batch-gateway-gc<br/>ServiceAccount"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No Kubernetes ClusterRoles<br/>or RoleBindings defined"]
    end

    subgraph "Application-Level Access Control"
        direction TB

        TenantIsolation["Tenant Isolation Layer<br/>X-MaaS-Username header → tenant ID<br/>All data access scoped by tenant<br/>Cross-tenant: 404 (not 403)"]

        FilePathIsolation["File Path Isolation<br/>SHA256(tenant_id) → folder name<br/>Prevents path traversal<br/>S3-compatible naming"]
    end

    subgraph "Gateway-Level AuthN/AuthZ"
        direction TB

        AuthPolicy["Kuadrant / Authorino<br/>Batch API Admission Policy"]

        AuthMethods["Auth Methods:<br/>1. API key<br/>2. ServiceAccount token<br/>3. OpenShift user token"]

        AuthEndpoints["Protected Endpoints:<br/>/v1/batches/* (GET, POST)<br/>/v1/files/* (GET, POST, DELETE)"]

        UnauthEndpoints["Unauthenticated Endpoints:<br/>/health, /ready, /metrics"]
    end

    subgraph "Secrets Access"
        Secret_Main["batch-gateway-secrets (Opaque)<br/>├─ redis-url<br/>├─ postgresql-url<br/>├─ inference-api-key<br/>└─ s3-secret-access-key<br/>Provisioned: Manual<br/>Auto-rotate: No"]

        Secret_TLS["{release}-batch-gateway-apiserver-tls<br/>(kubernetes.io/tls)<br/>Provisioned: cert-manager (optional)<br/>Auto-rotate: Yes (if cert-manager)"]
    end

    %% Service Account → RBAC
    SA_API -.->|"no k8s RBAC"| NoRBAC
    SA_PROC -.->|"no k8s RBAC"| NoRBAC
    SA_GC -.->|"no k8s RBAC"| NoRBAC

    %% Service Account → Secrets
    SA_API -->|"mounts"| Secret_Main
    SA_API -->|"mounts (optional)"| Secret_TLS
    SA_PROC -->|"mounts"| Secret_Main
    SA_GC -->|"mounts"| Secret_Main

    %% Auth flow
    AuthPolicy -->|"validates"| AuthMethods
    AuthMethods -->|"protects"| AuthEndpoints
    AuthPolicy -->|"passes tenant ID"| TenantIsolation
    TenantIsolation -->|"scopes file paths"| FilePathIsolation

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#7ed321,stroke:#333,color:#fff
    style SA_GC fill:#f5a623,stroke:#333,color:#fff
    style NoRBAC fill:#e8e8e8,stroke:#999,color:#666
    style TenantIsolation fill:#d5e8d4,stroke:#82b366
    style FilePathIsolation fill:#d5e8d4,stroke:#82b366
    style AuthPolicy fill:#ffe6cc,stroke:#d79b00
    style Secret_Main fill:#f8cecc,stroke:#b85450
    style Secret_TLS fill:#f8cecc,stroke:#b85450
    style AuthMethods fill:#fff2cc,stroke:#d6b656
    style AuthEndpoints fill:#fff2cc,stroke:#d6b656
    style UnauthEndpoints fill:#e8e8e8,stroke:#999
