graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["{release}-batch-gateway-apiserver"]
        SA_PROC["{release}-batch-gateway-processor"]
        SA_GC["{release}-batch-gateway-gc"]
    end

    subgraph KubernetesRBAC["Kubernetes RBAC"]
        NoRoles["No ClusterRoles or Roles<br/>created by Helm chart"]
        NoBindings["No ClusterRoleBindings<br/>or RoleBindings"]
    end

    subgraph SecurityContext["Pod Security Context (All Pods)"]
        ReadOnly["readOnlyRootFilesystem: true"]
        NonRoot["runAsNonRoot: true<br/>UID: 65532"]
        DropCaps["drop: ALL capabilities"]
        Seccomp["seccompProfile: RuntimeDefault"]
    end

    subgraph Secrets["Kubernetes Secrets"]
        MainSecret["batch-gateway-secrets<br/>(Opaque)<br/>Manual provisioning<br/>No auto-rotate"]
        TLSSecret["{release}-batch-gateway-apiserver-tls<br/>(kubernetes.io/tls)<br/>cert-manager provisioned<br/>Auto-rotate: Yes"]
    end

    subgraph SecretContents["Secret Contents (batch-gateway-secrets)"]
        RedisURL["redis-url<br/>Redis/Valkey connection URL"]
        PgURL["postgresql-url<br/>PostgreSQL connection URL"]
        InferKey["inference-api-key<br/>Inference gateway API key"]
        S3Key["s3-secret-access-key<br/>AWS S3 secret access key"]
    end

    subgraph TenantIsolation["Tenant Isolation (Application-Level)"]
        TenantHeader["X-MaaS-Username Header<br/>(configurable)"]
        TenantScope["All queries scoped by tenant ID"]
        CrossTenant["Cross-tenant access → 404<br/>(prevents info leakage)"]
    end

    subgraph PathSecurity["Path Traversal Protection"]
        OpenInRoot["os.OpenInRoot()<br/>Prevents path traversal<br/>on secret file reads"]
        SecretMount["Secret mounts at<br/>/etc/.secrets/"]
    end

    %% Service account → No K8s RBAC
    SA_API --> NoRoles
    SA_PROC --> NoRoles
    SA_GC --> NoRoles

    %% Security context applies to all
    SA_API --> SecurityContext
    SA_PROC --> SecurityContext
    SA_GC --> SecurityContext

    %% Secret access
    SA_API -->|"mounts"| MainSecret
    SA_PROC -->|"mounts"| MainSecret
    SA_GC -->|"mounts"| MainSecret
    SA_API -->|"optional mount"| TLSSecret

    MainSecret --> SecretContents

    %% Tenant isolation
    SA_API -->|"enforces"| TenantIsolation

    %% Path security
    SA_PROC -->|"uses"| PathSecurity

    %% Inference auth patterns
    subgraph InferenceAuth["Inference Gateway Auth Patterns"]
        APIKeyFile["API key from named file"]
        APIKeySecret["API key from K8s secret mount"]
        SAToken["ServiceAccount token<br/>(standard mount)"]
        mTLS["mTLS with custom CA<br/>tls_ca_cert_file<br/>tls_client_cert_file<br/>tls_client_key_file"]
    end

    SA_PROC -->|"authenticates via"| InferenceAuth

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#7ed321,stroke:#333,color:#fff
    style SA_GC fill:#f5a623,stroke:#333,color:#fff
    style NoRoles fill:#e8e8e8,stroke:#999
    style NoBindings fill:#e8e8e8,stroke:#999
    style MainSecret fill:#f8cecc,stroke:#b85450
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style TenantHeader fill:#d5e8d4,stroke:#82b366
    style TenantScope fill:#d5e8d4,stroke:#82b366
    style CrossTenant fill:#d5e8d4,stroke:#82b366
    style OpenInRoot fill:#dae8fc,stroke:#6c8ebf
