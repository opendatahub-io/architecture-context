graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph ProxyLayer["PLATFORM PROXY LAYER (Auth Boundary)"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.2+ termination<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph OVMSPod["OVMS POD (No Internal TLS)"]
        direction TB

        subgraph RESTServer["REST Server (Drogon)"]
            REST["HTTP/1.1 Plaintext<br/>configurable/TCP<br/>Auth: API key (v3 only, optional)"]
            TFSv1Route["/v1/models/* — No auth"]
            KServev2Route["/v2/* — No auth"]
            OpenAIv3Route["/v3/* — API key optional"]
            MetricsRoute["/metrics — No auth"]
        end

        subgraph GRPCServer["gRPC Server"]
            GRPC["gRPC HTTP/2 Plaintext<br/>configurable/TCP<br/>InsecureServerCredentials<br/>Auth: None"]
        end

        subgraph InferenceEngine["Inference Engine"]
            OVRuntime["OpenVINO Runtime<br/>CPU / GPU / NPU"]
        end

        NginxMTLS["nginx-mtls-auth (Optional)<br/>443/TCP mTLS<br/>Client cert required"]
    end

    subgraph IstioMesh["ISTIO SERVICE MESH (Optional)"]
        Envoy["Envoy Sidecar<br/>mTLS pod-to-pod"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Model Storage)"]
        S3["Amazon S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP Service Account"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Connection String"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF_TOKEN Bearer"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>HTTP plaintext"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>K8s Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP (localhost)<br/>Plaintext<br/>No auth (trusted)"| REST
    Client -.->|"gRPC HTTP/2<br/>Plaintext<br/>No auth"| GRPC

    REST --> TFSv1Route
    REST --> KServev2Route
    REST --> OpenAIv3Route
    REST --> MetricsRoute

    TFSv1Route --> OVRuntime
    KServev2Route --> OVRuntime
    OpenAIv3Route --> OVRuntime
    GRPC --> OVRuntime

    OVRuntime -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    OVRuntime -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA JSON"| GCS
    OVRuntime -->|"HTTPS/443<br/>TLS 1.2+<br/>Connection string"| Azure
    OVRuntime -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HuggingFace

    Prometheus -->|"HTTP<br/>Plaintext<br/>Scrape /metrics"| MetricsRoute

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef ovmspod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef restsvr fill:#e0f2fe,stroke:#0284c7
    classDef grpcsvr fill:#e0f2fe,stroke:#0284c7
    classDef engine fill:#d1fae5,stroke:#10b981
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f3e8ff,stroke:#9333ea
    classDef istio fill:#fecaca,stroke:#dc2626,stroke-dasharray:5 5

    class Client external
    class KubeRBAC proxy
    class REST,TFSv1Route,KServev2Route,OpenAIv3Route,MetricsRoute restsvr
    class GRPC grpcsvr
    class OVRuntime engine
    class S3,GCS,Azure,HuggingFace externalservice
    class Prometheus monitoring
    class Envoy istio
    class NginxMTLS proxy
