graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe-managed)"]
        Gateway["KServe Gateway<br/>443/TCP<br/>TLS Termination<br/>kube-rbac-proxy (3.x)<br/>oauth-proxy (2.x)"]
    end

    subgraph InferencePod["INFERENCE POD (OVMS Container)"]
        direction TB

        subgraph RESTLayer["REST API Layer"]
            DrogonHTTP["Drogon HTTP Server<br/>REST port/TCP (default 8080)<br/>HTTP (configurable TLS)<br/>Bearer Token (optional)"]
        end

        subgraph GRPCLayer["gRPC API Layer"]
            GRPCServer["gRPC Server<br/>gRPC port/TCP (default 8085)<br/>gRPC/HTTP2<br/>No built-in auth"]
        end

        subgraph InternalModules["Internal Processing"]
            APIHandler["HttpRestApiHandler<br/>(API key validation)"]
            ModelMgr["Model Manager"]
            MediaPipe["MediaPipe Executor"]
            OpenVINO["OpenVINO Runtime"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["Amazon S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ADC"]
        AzureBlob["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection String/SAS"]
        AzureFile["Azure File Shares<br/>*.file.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection String/SAS"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/REST port<br/>No encryption (in-mesh)<br/>Auth passthrough"| DrogonHTTP
    Gateway -->|"gRPC/gRPC port<br/>HTTP2<br/>Auth passthrough"| GRPCServer
    DrogonHTTP --> APIHandler
    APIHandler --> ModelMgr
    APIHandler --> MediaPipe
    GRPCServer --> ModelMgr
    MediaPipe --> OpenVINO
    ModelMgr --> OpenVINO
    Prometheus -->|"HTTP/REST port<br/>/metrics<br/>Unauthenticated"| DrogonHTTP

    ModelMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    ModelMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| GCS
    ModelMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn String"| AzureBlob
    ModelMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn String"| AzureFile
    ModelMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class DrogonHTTP,GRPCServer,APIHandler,ModelMgr,MediaPipe,OpenVINO pod
    class S3,GCS,AzureBlob,AzureFile,HuggingFace externalservice
    class Prometheus monitoring
