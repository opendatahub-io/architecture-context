graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Inference Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Gateway)"]
        Gateway["KServe Gateway / OpenShift Route<br/>443/TCP<br/>TLS 1.2+ termination<br/>kube-rbac-proxy (RHOAI 3.x)<br/>oauth-proxy (RHOAI 2.x)"]
    end

    subgraph OVMSPod["OVMS POD"]
        direction TB

        NginxSidecar["Optional: nginx mTLS Sidecar<br/>443/TCP → REST port<br/>mTLS (X.509 client certs)"]

        subgraph RESTServer["REST Server"]
            Drogon["Drogon HTTP Server<br/>REST port/TCP (default 8080)<br/>HTTP (TLS configurable)<br/>API key auth (Bearer Token)<br/>Path traversal prevention"]
        end

        subgraph GRPCServer["gRPC Server"]
            GRPC["gRPC Server<br/>gRPC port/TCP (default 8081)<br/>gRPC/HTTP2<br/>No built-in auth<br/>Max message: 1GB"]
        end

        subgraph HealthMetrics["Health & Metrics"]
            Health["/v2/health/ready<br/>/v2/health/live<br/>Unauthenticated"]
            Metrics["/metrics<br/>Unauthenticated<br/>Prometheus format"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["Amazon S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ADC"]
        AzureBlob["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection string / SAS"]
        AzureFile["Azure File Shares<br/>*.file.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection string / SAS"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Scraper<br/>REST port/TCP HTTP<br/>No auth"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway
    Gateway -->|"HTTP/REST port<br/>No encryption (in-cluster)<br/>or mTLS (service mesh)"| Drogon
    Gateway -->|"gRPC/gRPC port<br/>HTTP2<br/>No encryption (in-cluster)"| GRPC
    NginxSidecar -->|"HTTP/REST port<br/>Forwarded after mTLS"| Drogon

    Drogon -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Drogon -->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| GCS
    Drogon -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn string"| AzureBlob
    Drogon -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn string"| AzureFile
    Drogon -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub

    Prometheus -->|"HTTP/REST port<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef ovmspod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef sidecar fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class Drogon,GRPC,Health,Metrics ovmspod
    class NginxSidecar sidecar
    class S3,GCS,AzureBlob,AzureFile,HFHub externalservice
    class Prometheus monitoring
