graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Application"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Istio Gateway /<br/>OpenShift Route<br/>443/TCP<br/>TLS 1.2+"]
    end

    subgraph Pod["OVMS POD (Trust Boundary)"]
        direction TB

        subgraph AuthProxy["AUTH PROXY (Sidecar)"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>RBAC Authorization"]
        end

        subgraph OVMSContainer["OVMS Container (UID 5000, UBI 9)"]
            direction TB
            RESTServer["Drogon HTTP Server<br/>8080/TCP HTTP<br/>API Key (optional)<br/><br/>v1: TFS predict/metadata<br/>v2: KServe infer/health<br/>v3: OpenAI chat/embed/rerank<br/>/metrics: Prometheus"]
            GRPCServer["gRPC Server<br/>8085/TCP HTTP/2<br/>No built-in auth<br/><br/>KServe v2 Inference<br/>TFS Prediction/Model"]
        end
    end

    subgraph KServeControl["KSERVE (Control Plane)"]
        KServeCtrl["KServe Controller<br/>Manages InferenceService<br/>Creates/configures pods"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
        S3["AWS S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection String"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP Credentials"]
    end

    subgraph LocalStorage["LOCAL STORAGE"]
        PVC["PVC / Local Filesystem<br/>No network<br/>POSIX permissions (UID 5000)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus /<br/>OpenShift Monitoring<br/>Scrapes /metrics"]
        K8sProbes["Kubernetes Probes<br/>GET /v2/health/live<br/>GET /v2/health/ready"]
    end

    %% Inbound flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Service Identity"| KRBP
    KRBP -->|"HTTP/8080<br/>plaintext (pod-local)<br/>Authenticated"| RESTServer
    KRBP -->|"gRPC/8085<br/>plaintext (pod-local)<br/>Authenticated"| GRPCServer

    %% Control plane
    KServeCtrl -.->|"deploys &<br/>manages pod"| Pod

    %% Egress flows
    OVMSContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HF
    OVMSContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM creds"| S3
    OVMSContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn string"| Azure
    OVMSContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| GCS
    OVMSContainer -->|"filesystem<br/>POSIX"| PVC

    %% Monitoring
    Prometheus -.->|"HTTP GET<br/>/metrics<br/>No auth"| RESTServer
    K8sProbes -.->|"HTTP GET<br/>/v2/health/*<br/>No auth"| RESTServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef control fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class KRBP authproxy
    class RESTServer,GRPCServer application
    class HF,S3,Azure,GCS externalservice
    class PVC storage
    class Prometheus,K8sProbes monitoring
    class KServeCtrl control
