graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS)"]
        Gateway["RHOAI Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>OAuth/OIDC"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP → 8080/TCP<br/>TLS<br/>K8s SubjectAccessReview"]
    end

    subgraph OVMSPod["OVMS POD (No Built-in TLS)"]
        direction TB

        HTTPServer["OVMS HTTP Server (Drogon)<br/>8080/TCP HTTP<br/>No TLS (InsecureCredentials)<br/>API Key (optional)"]
        GRPCServer["OVMS gRPC Server<br/>8443/TCP gRPC/HTTP2<br/>No TLS (InsecureCredentials)<br/>No built-in auth"]

        subgraph Endpoints["API Endpoints"]
            TFS["/v1/models/* (TFS REST)"]
            KServeV2["/v2/models/* (KServe v2)"]
            OpenAI["/v3/*/chat/completions (OpenAI)"]
            Health["/v2/health/live,ready<br/>(No auth required)"]
            Metrics["/metrics (Prometheus)"]
        end

        HTTPServer --- TFS
        HTTPServer --- KServeV2
        HTTPServer --- OpenAI
        HTTPServer --- Health
        HTTPServer --- Metrics
    end

    subgraph CloudStorage["EGRESS (Cloud Storage)"]
        S3["S3-compatible Storage<br/>(AWS S3, MinIO, Ceph)<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM credentials"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Service Account JSON"]
        AzureBlob["Azure Blob/File Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Connection String"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS TLS 1.2+<br/>HF_TOKEN Bearer"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>8080/TCP HTTP"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth/OIDC)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>ServiceAccount Token"| KubeRBAC
    KubeRBAC -->|"HTTP/8080<br/>No encryption (pod-local)<br/>No auth (trusted)"| HTTPServer

    Client -.->|"gRPC/8443<br/>No TLS (Insecure)<br/>No auth"| GRPCServer

    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCS SA"| GCS
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Conn String"| AzureBlob
    HTTPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub

    Prometheus -->|"HTTP/8080<br/>No TLS<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef appPod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef endpoint fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef cloudStorage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,KubeRBAC ingress
    class HTTPServer,GRPCServer warning
    class TFS,KServeV2,OpenAI,Health,Metrics endpoint
    class S3,GCS,AzureBlob,HFHub cloudStorage
    class Prometheus monitoring
