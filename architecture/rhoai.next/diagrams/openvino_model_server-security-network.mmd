graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Inference Consumer"]
    end

    subgraph PlatformSecurity["PLATFORM SECURITY LAYER (RHOAI)"]
        direction TB
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.2+<br/>K8s TokenReview + SubjectAccessReview"]
        IstioSidecar["Istio Envoy Sidecar<br/>(optional)<br/>mTLS STRICT<br/>SPIFFE Identity"]
    end

    subgraph OVMSPod["OVMS POD (KServe InferenceService)<br/>UID: 5000 / GID: 5000 (non-root)<br/>No K8s API access"]
        direction TB

        subgraph RESTEndpoint["REST Endpoint (Drogon)"]
            REST["HTTP/1.1 Plaintext<br/>configurable/TCP<br/>Workers: 10"]
            V1API["/v1/* TFS v1<br/>No auth"]
            V2API["/v2/* KServe v2<br/>No auth"]
            V3API["/v3/* OpenAI/Cohere<br/>API key (optional)"]
            MetricsAPI["/metrics Prometheus<br/>No auth"]
        end

        subgraph GRPCEndpoint["gRPC Endpoint"]
            GRPC["gRPC HTTP/2 Plaintext<br/>InsecureServerCredentials<br/>configurable/TCP<br/>Memory Quota: 2GB"]
        end

        InferenceCore["Inference Core<br/>OpenVINO Runtime 2026.0"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Model Storage)"]
        S3["Amazon S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Connection String"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN Bearer"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>HTTP configurable/TCP"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>K8s Bearer Token"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/configurable<br/>Plaintext (localhost)<br/>No auth"| REST
    Client -.->|"HTTP or gRPC<br/>(direct, non-RHOAI)"| REST
    Client -.->|"gRPC/configurable<br/>Plaintext<br/>No auth"| GRPC
    IstioSidecar -.->|"mTLS envelope<br/>SPIFFE identity"| OVMSPod

    %% Internal routing
    REST --- V1API
    REST --- V2API
    REST --- V3API
    REST --- MetricsAPI
    V1API --> InferenceCore
    V2API --> InferenceCore
    V3API --> InferenceCore
    GRPC --> InferenceCore

    %% Egress flows
    InferenceCore -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM credentials"| S3
    InferenceCore -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA JSON"| GCS
    InferenceCore -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure conn string"| Azure
    InferenceCore -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HuggingFace

    %% Monitoring
    Prometheus -->|"HTTP/configurable<br/>No auth"| MetricsAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef noauth fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Client external
    class KubeRBACProxy,IstioSidecar platform
    class REST,GRPC,InferenceCore,V1API,V2API,V3API,MetricsAPI app
    class S3,GCS,Azure,HuggingFace externalservice
    class Prometheus monitoring
