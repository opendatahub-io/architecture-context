graph LR
    vllmCpu["vLLM CPU<br/>Inference Engine"]

    %% External Dependencies (Runtime)
    vllmCpu -->|"inference framework"| PyTorch["PyTorch 2.11.0+cpu"]
    vllmCpu -->|"model loading<br/>tokenization"| Transformers["Transformers >= 4.56.0"]
    vllmCpu -->|"HTTP API"| FastAPI["FastAPI >= 0.120.1"]
    vllmCpu -->|"gRPC server"| gRPC["gRPC >= 1.76.0"]
    vllmCpu -->|"gRPC servicer"| SmgGrpc["smg-grpc-servicer >= 0.5.2"]
    vllmCpu -->|"linear algebra"| OpenBLAS["OpenBLAS (system)"]
    vllmCpu -->|"x86_64 optimization"| IPEX["Intel Extension<br/>for PyTorch 2.7.0"]
    vllmCpu -->|"memory allocator"| TCMalloc["tcmalloc (LD_PRELOAD)"]
    vllmCpu -->|"metrics"| PromClient["Prometheus client >= 0.18.0"]
    vllmCpu -.->|"tracing (optional)"| OTel["OpenTelemetry >= 1.27.0"]
    vllmCpu -->|"TLS/crypto"| OpenSSL["OpenSSL (UBI9 system)"]

    %% Internal RHOAI Dependencies
    vllmCpu -->|"deployed as<br/>serving container"| KServe["KServe<br/>InferenceService"]
    vllmCpu -->|"container compliance"| ModelHosting["model-hosting-<br/>container-standards"]
    vllmCpu -->|"model storage"| ModelStorage["Model Storage<br/>(PVC/S3)"]

    %% External Services (Egress)
    vllmCpu -->|"model download<br/>HTTPS/443<br/>HF Token"| HFHub["HuggingFace Hub"]
    vllmCpu -->|"model download<br/>HTTPS/443"| ModelScope["ModelScope"]
    vllmCpu -->|"model artifacts<br/>HTTPS/443<br/>AWS IAM"| S3["S3 Storage"]

    %% Integration Points (other components using vllm-cpu)
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/8000"| vllmCpu
    OTelCollector["OpenTelemetry<br/>Collector"] -.->|"receives traces<br/>OTLP"| vllmCpu

    %% Styling
    style vllmCpu fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style SmgGrpc fill:#999,stroke:#333,color:#fff
    style OpenBLAS fill:#999,stroke:#333,color:#fff
    style IPEX fill:#999,stroke:#333,color:#fff
    style TCMalloc fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelHosting fill:#7ed321,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style HFHub fill:#f5a623,stroke:#333
    style ModelScope fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333

    %% Monitoring
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style OTelCollector fill:#e1d5e7,stroke:#9673a6
