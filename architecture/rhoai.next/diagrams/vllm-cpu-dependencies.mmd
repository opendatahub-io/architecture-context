graph LR
    VllmCPU["vLLM CPU<br/>Inference Server"]

    %% Internal RHOAI Dependencies
    VllmCPU -->|"deployed as runtime"| KServe["KServe<br/>InferenceService"]
    VllmCPU -.->|"configured via"| Dashboard["RHOAI Dashboard"]
    VllmCPU -.->|"lifecycle mgmt"| ModelCtrl["Model Mesh /<br/>Model Controller"]

    %% Core Runtime Dependencies (Required)
    VllmCPU -->|"CPU inference"| PyTorch["PyTorch 2.10.0+cpu"]
    VllmCPU -->|"tokenization"| Transformers["transformers<br/>>= 4.56.0"]
    VllmCPU -->|"HTTP server"| FastAPI["FastAPI >= 0.120.1<br/>+ uvicorn + uvloop"]
    VllmCPU -->|"validation"| Pydantic["Pydantic >= 2.12.0"]

    %% API Compatibility Dependencies
    VllmCPU -->|"OpenAI compat"| OpenAISDK["OpenAI SDK<br/>>= 1.99.1"]
    VllmCPU -->|"Anthropic compat"| Anthropic["anthropic<br/>>= 0.71.0"]
    VllmCPU -->|"gRPC serving"| GRPC["grpcio >= 1.76.0<br/>+ protobuf"]

    %% Tokenizer Dependencies
    VllmCPU -->|"fast tokenize"| Tokenizers["tokenizers >= 0.21.1"]
    VllmCPU -->|"LLaMA tokenize"| SentencePiece["sentencepiece"]

    %% IPC and Communication
    VllmCPU -->|"engine IPC"| ZMQ["pyzmq >= 25.0.0"]

    %% External Services
    VllmCPU -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    VllmCPU -.->|"model storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]

    %% Observability (Optional)
    VllmCPU -->|"metrics export"| PromClient["prometheus-client<br/>>= 0.18.0"]
    VllmCPU -.->|"tracing"| OTEL["opentelemetry-sdk<br/>>= 1.27.0"]

    %% Optional Dependencies
    VllmCPU -.->|"distributed"| Gloo["Gloo Backend<br/>(tensor parallelism)"]
    VllmCPU -.->|"orchestration"| Ray["Ray Cluster<br/>6379/TCP"]
    VllmCPU -.->|"MCP protocol"| MCP["MCP<br/>(Model Context Protocol)"]
    VllmCPU -.->|"fast model load"| Tensorizer["tensorizer 2.10.1"]

    %% Platform-Specific
    VllmCPU -.->|"x86_64 only"| IntelOMP["intel-openmp<br/>2024.2.1"]
    VllmCPU -.->|"container std"| MHCS["model-hosting-<br/>container-standards"]

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"HTTP scrape<br/>8000/TCP"| VllmCPU
    OTLPCollector["OTLP Collector"] -.->|"trace collect"| VllmCPU

    %% Styling
    style VllmCPU fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff

    %% Core dependencies - gray
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style OpenAISDK fill:#999,stroke:#333,color:#fff
    style Anthropic fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Tokenizers fill:#999,stroke:#333,color:#fff
    style SentencePiece fill:#999,stroke:#333,color:#fff
    style ZMQ fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff

    %% External services - orange
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff

    %% Optional - light gray
    style OTEL fill:#ccc,stroke:#333
    style Gloo fill:#ccc,stroke:#333
    style Ray fill:#ccc,stroke:#333
    style MCP fill:#ccc,stroke:#333
    style Tensorizer fill:#ccc,stroke:#333
    style IntelOMP fill:#ccc,stroke:#333
    style MHCS fill:#ccc,stroke:#333

    %% Consumers - blue-gray
    style Prometheus fill:#78909c,stroke:#333,color:#fff
    style OTLPCollector fill:#78909c,stroke:#333,color:#fff
