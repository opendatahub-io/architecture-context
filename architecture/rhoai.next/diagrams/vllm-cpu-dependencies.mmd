graph LR
    VllmCPU["vLLM CPU<br/>LLM Inference Runtime"]

    %% Internal RHOAI Dependencies
    VllmCPU -->|deployed as runtime| KServe["KServe<br/>InferenceService"]
    VllmCPU -.->|configured via| Dashboard["RHOAI Dashboard"]
    VllmCPU -.->|lifecycle mgmt| ModelController["Model Mesh /<br/>Model Controller"]

    %% Core Runtime Dependencies
    VllmCPU -->|model execution| PyTorch["PyTorch 2.10.0+cpu"]
    VllmCPU -->|model loading| Transformers["transformers >= 4.56"]
    VllmCPU -->|HTTP server| FastAPI["FastAPI >= 0.120.1"]
    VllmCPU -->|async server| Uvicorn["uvicorn + uvloop"]
    VllmCPU -->|validation| Pydantic["Pydantic >= 2.12"]

    %% API Compatibility Dependencies
    VllmCPU -->|response models| OpenAISDK["OpenAI SDK >= 1.99"]
    VllmCPU -->|messages API| Anthropic["anthropic >= 0.71"]
    VllmCPU -->|gRPC serving| GRPC["grpcio >= 1.76<br/>+ protobuf >= 5.29"]

    %% Tokenization Dependencies
    VllmCPU -->|tokenization| SentencePiece["sentencepiece"]
    VllmCPU -->|fast detokenize| Tokenizers["tokenizers >= 0.21"]

    %% Observability Dependencies
    VllmCPU -->|metrics| PromClient["prometheus-client >= 0.18"]
    VllmCPU -.->|tracing| OTelSDK["opentelemetry-sdk >= 1.27<br/>(disabled on s390x)"]

    %% Infrastructure Dependencies
    VllmCPU -->|IPC| PyZMQ["pyzmq >= 25.0<br/>(ZeroMQ)"]
    VllmCPU -.->|distributed| Gloo["Gloo Backend<br/>(tensor parallelism)"]
    VllmCPU -.->|distributed| Ray["Ray Cluster"]

    %% External Services
    VllmCPU -->|model downloads| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    VllmCPU -.->|model storage| S3["S3-Compatible Storage<br/>443/TCP HTTPS"]

    %% Optional Dependencies
    VllmCPU -.->|fast loading| Tensorizer["tensorizer 2.10.1"]
    VllmCPU -.->|x86 threading| IntelOMP["intel-openmp 2024.2.1"]
    VllmCPU -.->|speculative decode| Numba["numba 0.61.2<br/>(disabled on s390x)"]
    VllmCPU -.->|container std| MHCS["model-hosting-container-standards"]
    VllmCPU -.->|agentic| MCP["MCP (Model Context Protocol)"]

    %% Platform Integrations
    Prometheus["Prometheus Scraper"] -->|scrapes metrics| VllmCPU
    OTLPCollector["OTLP Collector"] -.->|receives traces| VllmCPU

    %% Styling
    style VllmCPU fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style ModelController fill:#7ed321,stroke:#333

    %% Core Runtime
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style Transformers fill:#ff9d00,stroke:#333
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style Uvicorn fill:#009688,stroke:#333,color:#fff
    style Pydantic fill:#e92063,stroke:#333,color:#fff

    %% API Compat
    style OpenAISDK fill:#74aa9c,stroke:#333
    style Anthropic fill:#d4a574,stroke:#333
    style GRPC fill:#244c5a,stroke:#333,color:#fff

    %% External Services
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style OTLPCollector fill:#425cc7,stroke:#333,color:#fff

    %% Observability
    style PromClient fill:#e6522c,stroke:#333,color:#fff
    style OTelSDK fill:#425cc7,stroke:#333,color:#fff

    %% Optional
    style Tensorizer fill:#999,stroke:#333
    style IntelOMP fill:#999,stroke:#333
    style Numba fill:#999,stroke:#333
    style Ray fill:#999,stroke:#333
    style Gloo fill:#999,stroke:#333
    style MCP fill:#999,stroke:#333
    style MHCS fill:#999,stroke:#333

    %% Infrastructure
    style PyZMQ fill:#666,stroke:#333,color:#fff
    style SentencePiece fill:#666,stroke:#333,color:#fff
    style Tokenizers fill:#666,stroke:#333,color:#fff
