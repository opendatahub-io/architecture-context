graph LR
    VllmCPU["vLLM-CPU<br/>LLM Inference Server"]

    %% Internal RHOAI Dependencies
    VllmCPU -->|"deployed by<br/>ServingRuntime CRD"| KServe["KServe"]
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8000/TCP HTTP"| VllmCPU

    %% Core Runtime Dependencies
    VllmCPU -->|"HTTP server"| FastAPI["FastAPI >= 0.120.1<br/>+ Uvicorn"]
    VllmCPU -->|"gRPC server"| gRPC["grpcio >= 1.76.0"]
    VllmCPU -->|"deep learning"| PyTorch["PyTorch 2.10.0+cpu"]
    VllmCPU -->|"model loading"| Transformers["transformers >= 4.56.0"]

    %% CPU Optimization Dependencies
    VllmCPU -->|"linear algebra"| OpenBLAS["OpenBLAS<br/>(built from source)"]
    VllmCPU -->|"NUMA memory"| Numactl["numactl<br/>(built from source)"]
    VllmCPU -.->|"OpenMP threading<br/>(x86_64 only)"| IntelOMP["intel-openmp 2024.2.1"]

    %% API Protocol Dependencies
    VllmCPU -->|"OpenAI types"| OpenAIPkg["openai >= 1.99.1"]
    VllmCPU -->|"Anthropic types"| AnthropicPkg["anthropic >= 0.71.0"]
    VllmCPU -->|"validation"| Pydantic["pydantic >= 2.12.0"]

    %% Structured Output Dependencies
    VllmCPU -.->|"grammar decoding"| XGrammar["xgrammar >= 0.1.32"]
    VllmCPU -->|"regex/JSON schema"| OutlinesCore["outlines_core == 0.2.11"]

    %% Tokenizer Dependencies
    VllmCPU -->|"LLaMA tokenizer"| SentencePiece["sentencepiece"]
    VllmCPU -->|"DBRX tokenizer"| Tiktoken["tiktoken >= 0.12.0"]

    %% Monitoring Dependencies
    VllmCPU -->|"metrics"| PromClient["prometheus_client >= 0.18.0"]
    VllmCPU -.->|"tracing<br/>(not on s390x)"| OTelSDK["opentelemetry-sdk >= 1.27.0"]

    %% External Service Dependencies
    VllmCPU -->|"model download<br/>443/TCP HTTPS"| HFHub["Hugging Face Hub"]
    VllmCPU -.->|"model load<br/>443/TCP HTTPS"| S3["S3-Compatible Storage"]
    VllmCPU -.->|"tracing export"| OTelCollector["OpenTelemetry Collector"]

    %% Styling
    style VllmCPU fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    style FastAPI fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff

    style OpenBLAS fill:#e67e22,stroke:#333,color:#fff
    style Numactl fill:#e67e22,stroke:#333,color:#fff
    style IntelOMP fill:#e67e22,stroke:#333,color:#fff

    style OpenAIPkg fill:#999,stroke:#333,color:#fff
    style AnthropicPkg fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff

    style XGrammar fill:#999,stroke:#333,color:#fff
    style OutlinesCore fill:#999,stroke:#333,color:#fff
    style SentencePiece fill:#999,stroke:#333,color:#fff
    style Tiktoken fill:#999,stroke:#333,color:#fff

    style PromClient fill:#999,stroke:#333,color:#fff
