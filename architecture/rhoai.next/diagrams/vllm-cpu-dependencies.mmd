graph LR
    vLLM["vLLM CPU<br/>LLM Inference Runtime"]

    %% External Dependencies (Required)
    vLLM -->|"tensor computation<br/>2.10.0+cpu"| PyTorch["PyTorch CPU"]
    vLLM -->|"model loading<br/>>= 4.56.0"| Transformers["HuggingFace<br/>transformers"]
    vLLM -->|"HTTP server<br/>>= 0.120.1"| FastAPI["FastAPI /<br/>uvicorn / uvloop"]
    vLLM -->|"validation<br/>>= 2.12.0"| Pydantic["Pydantic"]
    vLLM -->|"metrics<br/>>= 0.18.0"| PromClient["prometheus-client"]
    vLLM -->|"API models<br/>>= 1.99.1"| OpenAISDK["OpenAI SDK"]
    vLLM -->|"Messages API<br/>>= 0.71.0"| AnthropicSDK["anthropic"]
    vLLM -->|"gRPC server<br/>>= 1.76.0"| gRPCio["grpcio /<br/>protobuf"]
    vLLM -->|"IPC multiprocess<br/>>= 25.0.0"| ZeroMQ["pyzmq"]
    vLLM -->|"tokenization"| Tokenizers["tokenizers /<br/>sentencepiece"]

    %% External Dependencies (Optional)
    vLLM -.->|"tracing<br/>(disabled s390x)"| OpenTelemetry["opentelemetry-sdk<br/>+ OTLP exporter"]
    vLLM -.->|"speculative decode<br/>(disabled s390x)"| Numba["numba"]
    vLLM -.->|"threading<br/>(x86_64 only)"| IntelOMP["intel-openmp"]
    vLLM -.->|"fast model load"| Tensorizer["tensorizer"]
    vLLM -.->|"gRPC serving"| SMG["smg-grpc-servicer"]

    %% Internal RHOAI Dependencies
    KServe["KServe"] -->|"deploys as<br/>InferenceService"| vLLM
    Dashboard["RHOAI Dashboard"] -->|"UI configuration"| vLLM
    ModelCtrl["Model Mesh /<br/>Model Controller"] -->|"pod lifecycle"| vLLM

    %% External Services
    vLLM -->|"model downloads<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]
    vLLM -.->|"model storage<br/>443/TCP HTTPS"| S3["S3 Storage"]
    vLLM -.->|"parallelism<br/>TCP"| Gloo["Gloo Backend"]
    vLLM -.->|"distributed exec<br/>6379/TCP"| Ray["Ray Cluster"]

    %% Observability
    Prometheus["Prometheus"] -->|"scrape metrics<br/>8000/TCP"| vLLM
    vLLM -.->|"trace export<br/>gRPC/HTTP"| OTLPCollector["OTLP Collector"]

