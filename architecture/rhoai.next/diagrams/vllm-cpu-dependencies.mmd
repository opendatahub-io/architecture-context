graph LR
    vllmcpu["vllm-cpu<br/>(odh-vllm-cpu-rhel9)"]

    %% Core Runtime Dependencies
    vllmcpu -->|"tensor computation<br/>v2.10.0 CPU"| PyTorch["PyTorch"]
    vllmcpu -->|"model loading<br/>>= 4.56.0"| Transformers["transformers"]
    vllmcpu -->|"HTTP API framework<br/>>= 0.120.1"| FastAPI["FastAPI"]
    vllmcpu -->|"ASGI server"| Uvicorn["uvicorn + uvloop"]
    vllmcpu -->|"gRPC server<br/>>= 1.76.0"| GRPC["grpcio"]

    %% Architecture-Specific
    vllmcpu -.->|"x86_64 only<br/>v2.7.0"| IPEX["Intel Extension<br/>for PyTorch"]
    vllmcpu -.->|"ppc64le only<br/>source-built"| OpenBLAS["OpenBLAS"]

    %% ML/NLP Libraries
    vllmcpu -->|"tokenization"| SentencePiece["sentencepiece"]
    vllmcpu -->|"tokenization<br/>>= 0.12.0"| Tiktoken["tiktoken"]
    vllmcpu -->|"grammar-guided gen<br/>>= 0.1.32"| XGrammar["xgrammar"]
    vllmcpu -->|"structured output<br/>v0.2.11"| OutlinesCore["outlines_core"]
    vllmcpu -->|"JIT compilation<br/>v0.61.2"| Numba["numba"]

    %% API Compatibility
    vllmcpu -->|"Responses API<br/>>= 2.0.0"| OpenAISDK["openai SDK"]
    vllmcpu -->|"Messages API<br/>>= 0.71.0"| AnthropicSDK["anthropic SDK"]

    %% Observability
    vllmcpu -->|"metrics export<br/>>= 0.18.0"| PromClient["prometheus_client"]
    vllmcpu -.->|"optional tracing<br/>>= 1.27.0"| OTelSDK["opentelemetry-sdk"]

    %% Platform & Standards
    vllmcpu -->|"container standards<br/>>= 0.1.13"| MHCS["model-hosting-<br/>container-standards"]
    vllmcpu -->|"tool server"| MCP["mcp"]

    %% Internal Platform Dependencies
    KServe["KServe"] -->|"deploys as<br/>runtime container"| vllmcpu
    vllmcpu -->|"model download<br/>HTTPS 443<br/>Bearer HF_TOKEN"| HFHub["Hugging Face Hub"]
    vllmcpu -->|"model download<br/>HTTPS 443<br/>AWS IAM"| S3["S3-compatible<br/>Storage"]

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP 8000"| vllmcpu
    OTelCollector["OpenTelemetry<br/>Collector"] -.->|"receives traces<br/>OTLP"| vllmcpu
    MCPServers["MCP Tool Servers"] -.->|"tool execution<br/>HTTP/HTTPS"| vllmcpu

