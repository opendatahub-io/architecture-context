graph LR
    VllmCPU["vLLM-CPU<br/>LLM Inference Server"]

    %% Core Runtime Dependencies
    VllmCPU -->|"deep learning framework"| PyTorch["PyTorch 2.10.0+cpu"]
    VllmCPU -->|"model loading & tokenization"| Transformers["transformers >= 4.56.0"]
    VllmCPU -->|"HTTP API framework"| FastAPI["FastAPI >= 0.120.1"]
    VllmCPU -->|"ASGI server"| Uvicorn["uvicorn"]
    VllmCPU -->|"gRPC framework"| gRPCio["grpcio >= 1.76.0"]

    %% CPU Optimization Libraries
    VllmCPU -->|"linear algebra (CPU)"| OpenBLAS["OpenBLAS<br/>(built from source)"]
    VllmCPU -->|"NUMA-aware memory"| Numactl["numactl<br/>(built from source)"]
    VllmCPU -.->|"OpenMP threading<br/>(x86_64 only)"| IntelOMP["intel-openmp 2024.2.1"]

    %% API Protocol Libraries
    VllmCPU -->|"OpenAI protocol types"| OpenAILib["openai >= 1.99.1"]
    VllmCPU -->|"Anthropic protocol types"| AnthropicLib["anthropic >= 0.71.0"]
    VllmCPU -->|"data validation"| Pydantic["pydantic >= 2.12.0"]

    %% Structured Output
    VllmCPU -.->|"grammar-guided decoding<br/>(optional)"| XGrammar["xgrammar >= 0.1.32"]
    VllmCPU -->|"regex/JSON schema output"| OutlinesCore["outlines_core == 0.2.11"]

    %% Tokenizer Support
    VllmCPU -->|"LLaMA tokenizer"| SentencePiece["sentencepiece"]
    VllmCPU -->|"DBRX tokenizer"| Tiktoken["tiktoken >= 0.12.0"]

    %% Observability
    VllmCPU -->|"metrics collection"| PromClient["prometheus_client >= 0.18.0"]
    VllmCPU -->|"FastAPI instrumentation"| PromFastAPI["prometheus-fastapi-<br/>instrumentator >= 7.0.0"]
    VllmCPU -.->|"distributed tracing<br/>(optional, not s390x)"| OTelSDK["opentelemetry-sdk >= 1.27.0"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>ServingRuntime"] -->|"deploys & routes traffic"| VllmCPU
    Prometheus["Prometheus"] -->|"scrapes /metrics"| VllmCPU

    %% External Service Dependencies
    VllmCPU -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    VllmCPU -->|"model loading<br/>HTTPS/443"| S3["S3-Compatible Storage"]

    %% Optional Integration
    VllmCPU -.->|"tool calling<br/>(optional)"| MCP["MCP Tool Servers"]
    VllmCPU -.->|"trace export<br/>(optional)"| OTelCollector["OpenTelemetry Collector"]

    %% Styling
    style VllmCPU fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - blue
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style Transformers fill:#ee4c2c,stroke:#333,color:#fff
    style FastAPI fill:#009688,stroke:#333,color:#fff
    style Uvicorn fill:#009688,stroke:#333,color:#fff
    style gRPCio fill:#009688,stroke:#333,color:#fff

    %% CPU optimization - orange
    style OpenBLAS fill:#f5a623,stroke:#333,color:#fff
    style Numactl fill:#f5a623,stroke:#333,color:#fff
    style IntelOMP fill:#f5a623,stroke:#333,color:#fff

    %% API protocol - purple
    style OpenAILib fill:#9b59b6,stroke:#333,color:#fff
    style AnthropicLib fill:#9b59b6,stroke:#333,color:#fff
    style Pydantic fill:#9b59b6,stroke:#333,color:#fff

    %% Structured output - teal
    style XGrammar fill:#2ecc71,stroke:#333,color:#fff
    style OutlinesCore fill:#2ecc71,stroke:#333,color:#fff

    %% Tokenizers - pink
    style SentencePiece fill:#e91e63,stroke:#333,color:#fff
    style Tiktoken fill:#e91e63,stroke:#333,color:#fff

    %% Observability - grey
    style PromClient fill:#607d8b,stroke:#333,color:#fff
    style PromFastAPI fill:#607d8b,stroke:#333,color:#fff
    style OTelSDK fill:#607d8b,stroke:#333,color:#fff

    %% Platform - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% External services - yellow
    style HFHub fill:#ffd700,stroke:#333
    style S3 fill:#ffd700,stroke:#333
    style MCP fill:#ffd700,stroke:#333
    style OTelCollector fill:#ffd700,stroke:#333
