    vLLM -->|"tensor computation<br/>v2.11.0+cpu"| PyTorch["PyTorch<br/>(CPU backend)"]
    vLLM -->|"model loading<br/>>= 4.56.0"| Transformers["HuggingFace<br/>Transformers"]
