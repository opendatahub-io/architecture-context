    %% Observability
    vLLM -->|"metrics export<br/>>= 0.18.0"| PromClient["prometheus<br/>client"]
    vLLM -.->|"distributed tracing<br/>>= 1.27.0"| OTELSdk["OpenTelemetry<br/>SDK"]

    %% API Compatibility
    vLLM -->|"Responses API<br/>>= 2.0.0"| OpenAILib["openai<br/>(library)"]
    vLLM -->|"Anthropic compat<br/>>= 0.71.0"| AnthropicLib["anthropic<br/>(library)"]

