graph TB
    subgraph Operator["TrustyAI Service Operator (controller-manager)"]
        direction TB
        Main["cmd/main.go<br/>--enable-services flag"]

        subgraph Controllers["Controllers (independently selectable)"]
            direction LR
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
            JOBMGR["JOB_MGR Controller<br/>Kueue Integration"]
        end

        Main -->|enables| Controllers
        Metrics["Metrics :8080/TCP"]
        Health["Health Probes :8081/TCP"]
    end

    subgraph Driver["ta-lmes-driver (sidecar)"]
        DriverBin["Driver Binary<br/>:18080/TCP localhost"]
        DriverBin -->|executes| LMHarness["lm-evaluation-harness"]
    end

    %% CRDs
    TASCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMESCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NEMOCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
    EVALHUBCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD watches
    TASCR -->|watched by| TAS
    LMESCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NEMOCR -->|watched by| NEMO
    EVALHUBCR -->|watched by| EVALHUB

    %% What each controller creates
    TAS -->|creates| TASDeployment["TrustyAI Service<br/>Deployment + Route"]
    TAS -->|patches| InferenceService["KServe InferenceService<br/>(payload processors)"]
    TAS -->|creates| IstioResources["DestinationRule /<br/>VirtualService<br/>(conditional)"]

    LMES -->|creates| EvalPod["Evaluation Pod<br/>(with ta-lmes-driver)"]
    LMES -->|monitors| DriverBin

    GORCH -->|creates| OrchestratorDeploy["Orchestrator Deployment<br/>+ Gateway Routes"]
    GORCH -->|auto-discovers| InferenceService
    GORCH -->|discovers| DetectorSvc["Detector Services"]

    NEMO -->|creates| NemoDeployment["NeMo Guardrails<br/>Deployment + Route"]

    EVALHUB -->|creates| EvalHubDeploy["EvalHub Deployment<br/>+ Route + RBAC"]
    EVALHUB -->|provisions| TenantRBAC["Per-Tenant<br/>ServiceAccounts & Roles"]
    EVALHUB -->|integrates| MLFlow["MLFlow Tracking"]

    JOBMGR -->|creates| KueueWorkload["Kueue Workload CR"]
    JOBMGR -->|schedules| EvalPod

    %% Auth sidecars
    TASDeployment -.-|kube-rbac-proxy| RBACPROXY["kube-rbac-proxy<br/>SAR enforcement"]
    OrchestratorDeploy -.-|kube-rbac-proxy| RBACPROXY
    NemoDeployment -.-|kube-rbac-proxy| RBACPROXY
    EvalHubDeploy -.-|kube-rbac-proxy| RBACPROXY

    %% Styling
    style Operator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Driver fill:#fef3e2,stroke:#f5a623,stroke-width:2px
    style Controllers fill:#f0f8e8,stroke:#82b366,stroke-width:1px

    style TAS fill:#4a90e2,color:#fff
    style LMES fill:#4a90e2,color:#fff
    style GORCH fill:#4a90e2,color:#fff
    style NEMO fill:#4a90e2,color:#fff
    style EVALHUB fill:#4a90e2,color:#fff
    style JOBMGR fill:#4a90e2,color:#fff

    style TASCR fill:#f5a623,color:#fff
    style LMESCR fill:#f5a623,color:#fff
    style GORCHCR fill:#f5a623,color:#fff
    style NEMOCR fill:#f5a623,color:#fff
    style EVALHUBCR fill:#f5a623,color:#fff

    style RBACPROXY fill:#e74c3c,color:#fff
    style InferenceService fill:#7ed321,color:#fff
    style KueueWorkload fill:#7ed321,color:#fff
    style MLFlow fill:#7ed321,color:#fff
