graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        OperatorBinary["trustyai-service-operator<br/>Go Operator (controller-runtime)<br/>Ports: 8080, 8081, 9443"]

        subgraph Controllers["Controllers (--enable-services)"]
            direction LR
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails<br/>Controller"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
        end

        OperatorBinary --> TAS
        OperatorBinary --> LMES
        OperatorBinary --> GORCH
        OperatorBinary --> NEMO
        OperatorBinary --> EVALHUB
    end

    subgraph ManagedResources["Managed Resources"]
        direction TB

        subgraph TAS_Resources["TAS Resources"]
            TASDeployment["TrustyAI Service<br/>Deployment<br/>+ kube-rbac-proxy"]
            TASRoute["OpenShift Route<br/>(reencrypt)"]
            TASServiceMonitor["ServiceMonitor"]
            TASDest["DestinationRule<br/>VirtualService"]
        end

        subgraph LMES_Resources["LMES Resources"]
            LMESPod["Evaluation Pod<br/>(lmes-driver init container)"]
            LMESDriver["odh-ta-lmes-driver<br/>Port: 18080/TCP"]
        end

        subgraph GORCH_Resources["GORCH Resources"]
            GORCHDeployment["Orchestrator<br/>Deployment<br/>+ kube-rbac-proxy"]
            GORCHRoute["OpenShift Routes<br/>(orchestrator, gateway,<br/>health, built-in)"]
            GORCHConfig["Auto-generated<br/>ConfigMap"]
        end

        subgraph NEMO_Resources["NemoGuardrails Resources"]
            NEMODeployment["NeMo Guardrails<br/>Deployment<br/>+ kube-rbac-proxy"]
            NEMOEnvoyFilter["EnvoyFilter<br/>(MCP SSE)"]
            NEMORoute["OpenShift Route"]
        end

        subgraph EVALHUB_Resources["EvalHub Resources"]
            EVALDeployment["EvalHub API Server<br/>+ MCP Server<br/>+ kube-rbac-proxy"]
            EVALRoute["OpenShift Routes<br/>(API, MCP)"]
            EVALTenantRBAC["Per-Tenant RBAC<br/>(Roles, RoleBindings)"]
            EVALDiscovery["evalhub-discovery<br/>ConfigMap"]
        end
    end

    %% Controller → Resource connections
    TAS -->|creates/manages| TASDeployment
    TAS -->|creates| TASRoute
    TAS -->|creates| TASServiceMonitor
    TAS -->|creates| TASDest
    LMES -->|creates| LMESPod
    LMESPod -->|contains| LMESDriver
    GORCH -->|creates/manages| GORCHDeployment
    GORCH -->|creates| GORCHRoute
    GORCH -->|auto-generates| GORCHConfig
    NEMO -->|creates/manages| NEMODeployment
    NEMO -->|creates| NEMOEnvoyFilter
    NEMO -->|creates| NEMORoute
    EVALHUB -->|creates/manages| EVALDeployment
    EVALHUB -->|creates| EVALRoute
    EVALHUB -->|reconciles| EVALTenantRBAC
    EVALHUB -->|injects| EVALDiscovery

    %% CRDs
    TASCR["TrustyAIService CR"] -->|watched by| TAS
    LMESCR["LMEvalJob CR"] -->|watched by| LMES
    GORCHCR["GuardrailsOrchestrator CR"] -->|watched by| GORCH
    NEMOCR["NemoGuardrails CR"] -->|watched by| NEMO
    EVALHUBCR["EvalHub CR"] -->|watched by| EVALHUB

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"] --- OperatorBinary
    KServe["KServe<br/>InferenceService"] --- TAS
    KServe --- GORCH
    Kueue["Kueue<br/>Workload Scheduling"] --- LMES
    Kueue --- EVALHUB
    Istio["Istio / Service Mesh"] --- TAS
    Istio --- NEMO
    MCPGateway["MCPGatewayExtension<br/>(Kuadrant)"] --- NEMO
    Prometheus["Prometheus<br/>ServiceMonitor"] --- OperatorBinary

    %% User
    User["User / Data Scientist"] -->|creates CRs| TASCR
    User -->|creates CRs| LMESCR
    User -->|creates CRs| GORCHCR
    User -->|creates CRs| NEMOCR
    User -->|creates CRs| EVALHUBCR

    %% Styling
    style OperatorBinary fill:#4a90e2,stroke:#333,color:#fff
    style TAS fill:#5ba3f5,stroke:#333,color:#fff
    style LMES fill:#5ba3f5,stroke:#333,color:#fff
    style GORCH fill:#5ba3f5,stroke:#333,color:#fff
    style NEMO fill:#5ba3f5,stroke:#333,color:#fff
    style EVALHUB fill:#5ba3f5,stroke:#333,color:#fff
    style TASCR fill:#f5a623,stroke:#333
    style LMESCR fill:#f5a623,stroke:#333
    style GORCHCR fill:#f5a623,stroke:#333
    style NEMOCR fill:#f5a623,stroke:#333
    style EVALHUBCR fill:#f5a623,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style MCPGateway fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#d4edda,stroke:#333
