graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        subgraph Controllers["Feature-Gated Controllers"]
            TASCtrl["TrustyAIService Controller<br/>--enable-services=TAS"]
            LMESCtrl["LMEvalJob Controller<br/>--enable-services=LMES"]
            EvalHubCtrl["EvalHub Controller<br/>--enable-services=EVALHUB"]
            GORCHCtrl["GuardrailsOrchestrator Controller<br/>--enable-services=GORCH"]
            NemoCtrl["NemoGuardrails Controller<br/>--enable-services=NEMO_GUARDRAILS"]
        end
        Webhook["EvalHub Conversion Webhook<br/>v1alpha1 ↔ v1<br/>9443/TCP"]
        Metrics["Metrics Endpoint<br/>8080/TCP"]
        Health["Health/Readiness Probes<br/>8081/TCP"]
    end

    subgraph CRDs["Custom Resource Definitions"]
        TASCR["TrustyAIService<br/>v1 / v1alpha1"]
        LMESCR["LMEvalJob<br/>v1alpha1"]
        EvalHubCR["EvalHub<br/>v1 / v1alpha1"]
        GORCHCR["GuardrailsOrchestrator<br/>v1alpha1"]
        NemoCR["NemoGuardrails<br/>v1alpha1"]
    end

    subgraph ManagedResources["Managed Resources"]
        TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy<br/>8443/TCP HTTPS"]
        LMESPod["LMEval Job Pod<br/>Driver init + lm-eval container"]
        EvalHubDeployment["EvalHub API<br/>Deployment + kube-rbac-proxy<br/>8443/TCP HTTPS"]
        EvalHubMCP["EvalHub MCP Server<br/>Deployment + kube-rbac-proxy<br/>8443/TCP HTTPS"]
        GORCHDeployment["Guardrails Orchestrator<br/>Deployment + kube-rbac-proxy<br/>8432/8490/8480 TCP"]
        NemoDeployment["NeMo Guardrails Server<br/>Deployment + kube-rbac-proxy<br/>8443/TCP HTTPS"]
        Routes["OpenShift Routes<br/>443/TCP HTTPS"]
        ServiceMonitors["ServiceMonitors<br/>Prometheus scraping"]
    end

    %% CRD → Controller relationships
    TASCR -->|watched by| TASCtrl
    LMESCR -->|watched by| LMESCtrl
    EvalHubCR -->|watched by| EvalHubCtrl
    GORCHCR -->|watched by| GORCHCtrl
    NemoCR -->|watched by| NemoCtrl

    %% Controller → Managed Resources
    TASCtrl -->|creates| TASDeployment
    LMESCtrl -->|creates| LMESPod
    EvalHubCtrl -->|creates| EvalHubDeployment
    EvalHubCtrl -->|creates| EvalHubMCP
    GORCHCtrl -->|creates| GORCHDeployment
    NemoCtrl -->|creates| NemoDeployment

    TASCtrl -->|creates| Routes
    EvalHubCtrl -->|creates| Routes
    GORCHCtrl -->|creates| Routes
    NemoCtrl -->|creates| Routes

    TASCtrl -->|creates| ServiceMonitors
    EvalHubCtrl -->|creates| ServiceMonitors
    GORCHCtrl -->|creates| ServiceMonitors

    %% Conversion webhook
    EvalHubCR -.->|conversion| Webhook

    %% External dependencies
    KServe["KServe<br/>InferenceServices"]
    ModelMesh["ModelMesh Serving"]
    Kueue["Kueue<br/>Workload CRs"]
    Istio["Istio<br/>DestinationRule / VirtualService<br/>EnvoyFilter"]
    ServiceCA["OpenShift service-ca-operator<br/>TLS certificates"]
    ConfigMap["trustyai-service-operator-config<br/>Image refs & settings"]
    KuadrantMCP["Kuadrant MCPGatewayExtension"]

    TASCtrl -->|patches InferenceLogger| KServe
    TASCtrl -->|patches MM_PAYLOAD_PROCESSORS| ModelMesh
    TASCtrl -->|creates| Istio
    LMESCtrl -->|creates Workloads| Kueue
    GORCHCtrl -->|watches ISVCs| KServe
    NemoCtrl -->|creates EnvoyFilter| Istio
    NemoCtrl -->|watches| KuadrantMCP
    Operator -->|reads| ConfigMap
    Operator -->|uses| ServiceCA

    %% User interaction
    User["User / Data Scientist"] -->|creates| TASCR
    User -->|creates| LMESCR
    User -->|creates| EvalHubCR
    User -->|creates| GORCHCR
    User -->|creates| NemoCR

    PlatformOp["rhods-operator"] -->|deploys & configures| Operator

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style TASCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style LMESCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style EvalHubCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style GORCHCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style NemoCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style Webhook fill:#5ba3f5,stroke:#333,color:#fff
    style TASCR fill:#f5a623,stroke:#333
    style LMESCR fill:#f5a623,stroke:#333
    style EvalHubCR fill:#f5a623,stroke:#333
    style GORCHCR fill:#f5a623,stroke:#333
    style NemoCR fill:#f5a623,stroke:#333
    style TASDeployment fill:#7ed321,stroke:#333
    style LMESPod fill:#7ed321,stroke:#333
    style EvalHubDeployment fill:#7ed321,stroke:#333
    style EvalHubMCP fill:#7ed321,stroke:#333
    style GORCHDeployment fill:#7ed321,stroke:#333
    style NemoDeployment fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style ServiceMonitors fill:#7ed321,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style KuadrantMCP fill:#e8e8e8,stroke:#333
    style PlatformOp fill:#9b59b6,stroke:#333,color:#fff
