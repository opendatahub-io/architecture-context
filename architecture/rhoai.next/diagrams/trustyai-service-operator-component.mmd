graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        Main["Main Binary<br/>Go 1.23<br/>controller-runtime"]

        subgraph Controllers["Controllers (--enable-services)"]
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
            JOBMGR["JobMgr Controller<br/>Kueue GenericJob"]
        end

        Main -->|registers| TAS
        Main -->|registers| LMES
        Main -->|registers| GORCH
        Main -->|registers| NEMO
        Main -->|registers| EVALHUB
        Main -->|registers| JOBMGR
    end

    subgraph CRDs["Custom Resource Definitions"]
        TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
        LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
        GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
        NemoCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
        EvalHubCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]
    end

    subgraph ManagedResources["Managed Resources"]
        TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy"]
        LMESPod["LMEval Job Pod<br/>+ ta-lmes-driver sidecar"]
        GORCHDeployment["Guardrails Orchestrator<br/>Deployment + gateway + detectors"]
        NemoDeployment["NeMo Guardrails<br/>Deployment + kube-rbac-proxy"]
        EvalHubDeployment["EvalHub<br/>Deployment + kube-rbac-proxy"]
    end

    %% CRD → Controller watches
    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NemoCR -->|watched by| NEMO
    EvalHubCR -->|watched by| EVALHUB
    LMEvalJobCR -.->|wrapped by| JOBMGR

    %% Controller → Resource creation
    TAS -->|creates| TASDeployment
    LMES -->|creates| LMESPod
    GORCH -->|creates| GORCHDeployment
    NEMO -->|creates| NemoDeployment
    EVALHUB -->|creates| EvalHubDeployment

    %% External integrations
    KServe["KServe InferenceService"]
    Istio["Istio Service Mesh"]
    Kueue["Kueue"]
    OSRouter["OpenShift Router"]
    Prometheus["Prometheus"]

    TAS -->|patches| KServe
    TAS -->|creates DestinationRule/VirtualService| Istio
    GORCH -->|discovers services from| KServe
    JOBMGR -->|creates Workload| Kueue
    TAS -->|creates Routes| OSRouter
    GORCH -->|creates Routes| OSRouter
    EVALHUB -->|creates Routes| OSRouter
    NEMO -->|creates Routes| OSRouter
    TAS -->|creates ServiceMonitor| Prometheus

    %% Styling
    style Main fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style TAS fill:#5ba0d2,stroke:#333,color:#fff
    style LMES fill:#5ba0d2,stroke:#333,color:#fff
    style GORCH fill:#5ba0d2,stroke:#333,color:#fff
    style NEMO fill:#5ba0d2,stroke:#333,color:#fff
    style EVALHUB fill:#5ba0d2,stroke:#333,color:#fff
    style JOBMGR fill:#5ba0d2,stroke:#333,color:#fff
    style TrustyAIServiceCR fill:#f5a623,stroke:#333
    style LMEvalJobCR fill:#f5a623,stroke:#333
    style GORCHCR fill:#f5a623,stroke:#333
    style NemoCR fill:#f5a623,stroke:#333
    style EvalHubCR fill:#f5a623,stroke:#333
    style TASDeployment fill:#7ed321,stroke:#333
    style LMESPod fill:#7ed321,stroke:#333
    style GORCHDeployment fill:#7ed321,stroke:#333
    style NemoDeployment fill:#7ed321,stroke:#333
    style EvalHubDeployment fill:#7ed321,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style Kueue fill:#e8e8e8,stroke:#333
    style OSRouter fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
