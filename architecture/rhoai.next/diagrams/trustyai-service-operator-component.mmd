graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        CM["controller-manager<br/>Go Operator (controller-runtime)<br/>:8080 metrics, :8081 health"]

        subgraph Controllers["Enabled Controllers (--enable-services)"]
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
            JOBMGR["JOB_MGR Controller<br/>Kueue Integration"]
        end

        CM --> TAS
        CM --> LMES
        CM --> GORCH
        CM --> NEMO
        CM --> EVALHUB
        CM --> JOBMGR
    end

    subgraph Driver["ta-lmes-driver"]
        DRIVER["ta-lmes-driver<br/>Go CLI (sidecar/init container)<br/>:18080 status (localhost)"]
    end

    %% CRDs
    TASCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMESCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NEMOCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
    EVALHUBCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD watches
    TASCR -->|watched by| TAS
    LMESCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NEMOCR -->|watched by| NEMO
    EVALHUBCR -->|watched by| EVALHUB

    %% TAS creates
    TAS -->|creates| TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy"]
    TAS -->|creates| TASRoute["OpenShift Route<br/>TLS Reencrypt"]
    TAS -->|patches| InferenceService["KServe<br/>InferenceService"]
    TAS -->|creates| IstioResources["Istio DestinationRule<br/>& VirtualService<br/>(conditional)"]

    %% LMES creates
    LMES -->|creates| EvalPod["LM Evaluation Pod<br/>+ ta-lmes-driver"]
    DRIVER -.->|runs inside| EvalPod

    %% GORCH creates
    GORCH -->|creates| GORCHDeployment["Guardrails Orchestrator<br/>Deployment + kube-rbac-proxy"]
    GORCH -->|auto-discovers| InferenceService

    %% NEMO creates
    NEMO -->|creates| NEMODeployment["NeMo Guardrails<br/>Deployment + kube-rbac-proxy"]

    %% EVALHUB creates
    EVALHUB -->|creates| EVALHUBDeployment["EvalHub Service<br/>Deployment + kube-rbac-proxy"]
    EVALHUB -->|provisions| TenantRBAC["Per-Tenant RBAC<br/>SA + RoleBindings"]

    %% JOBMGR
    JOBMGR -->|creates| KueueWorkload["Kueue Workload CR"]
    LMESCR -.->|scheduled by| JOBMGR

    %% External dependencies
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    KServe["KServe / ModelMesh"]
    Kueue["Kueue"]
    Prometheus["Prometheus<br/>ServiceMonitor"]
    ServiceCA["OpenShift Service CA"]

    CM -->|reconciles via| K8sAPI
    JOBMGR -->|integrates| Kueue
    TAS -->|integrates| KServe
    TAS -->|creates| Prometheus
    TASDeployment -->|TLS certs| ServiceCA

    %% User
    User["Data Scientist / Admin"] -->|creates CRs via kubectl| K8sAPI

    %% Styling
    style CM fill:#4a90e2,stroke:#333,color:#fff
    style TAS fill:#5ba5f5,stroke:#333,color:#fff
    style LMES fill:#5ba5f5,stroke:#333,color:#fff
    style GORCH fill:#5ba5f5,stroke:#333,color:#fff
    style NEMO fill:#5ba5f5,stroke:#333,color:#fff
    style EVALHUB fill:#5ba5f5,stroke:#333,color:#fff
    style JOBMGR fill:#5ba5f5,stroke:#333,color:#fff
    style DRIVER fill:#4a90e2,stroke:#333,color:#fff
    style TASCR fill:#f5a623,stroke:#333
    style LMESCR fill:#f5a623,stroke:#333
    style GORCHCR fill:#f5a623,stroke:#333
    style NEMOCR fill:#f5a623,stroke:#333
    style EVALHUBCR fill:#f5a623,stroke:#333
    style InferenceService fill:#7ed321,stroke:#333
    style KServe fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style User fill:#e8e8e8,stroke:#333
