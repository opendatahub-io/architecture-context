graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        Main["Main Binary<br/>Go 1.23<br/>controller-runtime"]

        subgraph Controllers["Controllers (--enable-services)"]
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
            JOBMGR["JobMgr Controller<br/>Kueue GenericJob"]
        end

        Main -->|registers| TAS
        Main -->|registers| LMES
        Main -->|registers| GORCH
        Main -->|registers| NEMO
        Main -->|registers| EVALHUB
        Main -->|registers| JOBMGR
    end

    subgraph ManagedCRDs["Custom Resource Definitions"]
        TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
        LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
        GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
        NEMOCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
        EVALHUBCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]
    end

    subgraph ManagedResources["Managed Resources"]
        Deployments["Deployments"]
        Services["Services + Routes"]
        RBAC["ServiceAccounts<br/>ClusterRoles<br/>ClusterRoleBindings"]
        ConfigMaps["ConfigMaps"]
        KubeRBACProxy["kube-rbac-proxy<br/>Sidecars"]
    end

    %% CRD Watches
    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NEMOCR -->|watched by| NEMO
    EVALHUBCR -->|watched by| EVALHUB

    %% Resource Creation
    TAS -->|creates| Deployments
    TAS -->|creates| Services
    TAS -->|creates| KubeRBACProxy
    LMES -->|creates Pods| Deployments
    GORCH -->|creates| Deployments
    GORCH -->|creates| KubeRBACProxy
    NEMO -->|creates| Deployments
    NEMO -->|creates| KubeRBACProxy
    EVALHUB -->|creates| Deployments
    EVALHUB -->|creates| KubeRBACProxy

    %% Driver
    Driver["ta-lmes-driver<br/>Sidecar Binary<br/>5000/TCP"]
    LMES -->|injects| Driver

    %% External Dependencies
    KServeIS["KServe<br/>InferenceService"]
    Istio["Istio Service Mesh<br/>DestinationRule<br/>VirtualService"]
    Kueue["Kueue<br/>Workload Admission"]
    PostgreSQL["PostgreSQL<br/>Database"]
    OSRoute["OpenShift Router<br/>Routes"]

    TAS -->|watches/patches| KServeIS
    TAS -->|creates| Istio
    GORCH -->|discovers services| KServeIS
    JOBMGR -->|wraps as GenericJob| Kueue
    TAS -->|connects| PostgreSQL
    EVALHUB -->|connects| PostgreSQL
    TAS -->|creates| OSRoute
    GORCH -->|creates| OSRoute
    EVALHUB -->|creates| OSRoute
    NEMO -->|creates| OSRoute

    %% Users
    User["User / Data Scientist"]
    User -->|creates CRs via kubectl| ManagedCRDs

    %% Styling
    style Main fill:#4a90e2,stroke:#333,color:#fff
    style TAS fill:#5ba3e6,stroke:#333,color:#fff
    style LMES fill:#5ba3e6,stroke:#333,color:#fff
    style GORCH fill:#5ba3e6,stroke:#333,color:#fff
    style NEMO fill:#5ba3e6,stroke:#333,color:#fff
    style EVALHUB fill:#5ba3e6,stroke:#333,color:#fff
    style JOBMGR fill:#5ba3e6,stroke:#333,color:#fff
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,color:#333
    style LMEvalJobCR fill:#f5a623,stroke:#333,color:#333
    style GORCHCR fill:#f5a623,stroke:#333,color:#333
    style NEMOCR fill:#f5a623,stroke:#333,color:#333
    style EVALHUBCR fill:#f5a623,stroke:#333,color:#333
    style Driver fill:#9b59b6,stroke:#333,color:#fff
    style KServeIS fill:#7ed321,stroke:#333,color:#333
    style Istio fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style OSRoute fill:#e8e8e8,stroke:#333
    style KubeRBACProxy fill:#e74c3c,stroke:#333,color:#fff
    style User fill:#2ecc71,stroke:#333,color:#fff
