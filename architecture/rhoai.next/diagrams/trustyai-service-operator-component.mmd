graph TB
    subgraph Operator["TrustyAI Service Operator (controller-manager)"]
        direction TB
        Main["cmd/main.go<br/>--enable-services flag"]

        subgraph Controllers["Controllers (selectable)"]
            TAS["TAS Controller<br/>TrustyAIService"]
            LMES["LMES Controller<br/>LMEvalJob"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails"]
            EVALHUB["EvalHub Controller<br/>EvalHub"]
            JOBMGR["JOB_MGR Controller<br/>Kueue Integration"]
        end

        Main --> Controllers
    end

    subgraph Driver["ta-lmes-driver (sidecar)"]
        DriverBin["Driver Binary<br/>18080/TCP localhost"]
        LMEvalHarness["lm-evaluation-harness"]
        DriverBin --> LMEvalHarness
    end

    %% CRDs
    TASCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMESCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NEMOCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
    EVALHUBCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD Watches
    TASCR -->|watched by| TAS
    LMESCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NEMOCR -->|watched by| NEMO
    EVALHUBCR -->|watched by| EVALHUB

    %% Managed Resources
    TAS -->|creates| TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy"]
    TAS -->|creates| TASRoute["OpenShift Route<br/>TLS Reencrypt"]
    TAS -->|patches| InferenceService["KServe InferenceService<br/>Payload Processor Injection"]
    TAS -->|creates conditionally| IstioResources["DestinationRule<br/>VirtualService"]

    LMES -->|creates| EvalPod["LMEval Pod<br/>+ init container"]
    EvalPod -->|runs| Driver
    LMES -->|polls status| DriverBin

    GORCH -->|creates| GORCHDeployment["Orchestrator Deployment<br/>+ 3x kube-rbac-proxy"]
    GORCH -->|auto-discovers| InferenceService
    GORCH -->|creates| GORCHConfig["ConfigMaps<br/>Detectors + Generators"]

    NEMO -->|creates| NEMODeployment["NeMo Deployment<br/>+ kube-rbac-proxy"]
    NEMO -->|creates| NEMORoute["OpenShift Route"]

    EVALHUB -->|creates| EHDeployment["EvalHub Deployment<br/>+ kube-rbac-proxy"]
    EVALHUB -->|provisions| TenantRBAC["Per-Tenant<br/>ServiceAccounts + RoleBindings"]
    EVALHUB -->|watches| Namespaces["Namespace Labels<br/>(tenant discovery)"]

    JOBMGR -->|creates| KueueWorkload["Kueue Workload CR"]
    JOBMGR -->|monitors| KueueWorkload

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style Controllers fill:#3a7bd5,stroke:#333,color:#fff
    style Driver fill:#50a0d0,stroke:#333,color:#fff
    style TASCR fill:#f5a623,stroke:#333
    style LMESCR fill:#f5a623,stroke:#333
    style GORCHCR fill:#f5a623,stroke:#333
    style NEMOCR fill:#f5a623,stroke:#333
    style EVALHUBCR fill:#f5a623,stroke:#333
    style InferenceService fill:#7ed321,stroke:#333
    style IstioResources fill:#e8e8e8,stroke:#333
    style KueueWorkload fill:#7ed321,stroke:#333
    style TASDeployment fill:#b8d4f0,stroke:#333
    style GORCHDeployment fill:#b8d4f0,stroke:#333
    style NEMODeployment fill:#b8d4f0,stroke:#333
    style EHDeployment fill:#b8d4f0,stroke:#333
    style EvalPod fill:#b8d4f0,stroke:#333
    style TASRoute fill:#d5e8d4,stroke:#333
    style NEMORoute fill:#d5e8d4,stroke:#333
    style TenantRBAC fill:#ffe6cc,stroke:#333
    style Namespaces fill:#ffe6cc,stroke:#333
