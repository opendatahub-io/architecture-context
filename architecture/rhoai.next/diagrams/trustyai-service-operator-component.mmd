graph TB
    subgraph Operator["TrustyAI Service Operator (manager)"]
        direction TB
        Manager["Manager Binary<br/>Go 1.24 / controller-runtime<br/>8080/TCP metrics, 8081/TCP health"]

        subgraph Controllers["Controller Registry (--enable-services)"]
            TAS["TAS Controller<br/>TrustyAI Explainability"]
            LMES["LMES Controller<br/>LMEval Jobs"]
            JOB_MGR["Job Manager Controller<br/>Kueue Adapter"]
            GORCH["GORCH Controller<br/>Guardrails Orchestrator"]
            NEMO["NemoGuardrails Controller<br/>NVIDIA NeMo"]
            EVALHUB["EvalHub Controller<br/>Centralized Evaluation"]
        end

        Manager --> TAS
        Manager --> LMES
        Manager --> JOB_MGR
        Manager --> GORCH
        Manager --> NEMO
        Manager --> EVALHUB
    end

    subgraph CRDs["Custom Resource Definitions"]
        TrustyAIServiceCR["TrustyAIService CR<br/>v1 / v1alpha1"]
        LMEvalJobCR["LMEvalJob CR<br/>v1alpha1"]
        GuardrailsOrchestratorCR["GuardrailsOrchestrator CR<br/>v1alpha1"]
        NemoGuardrailsCR["NemoGuardrails CR<br/>v1alpha1"]
        EvalHubCR["EvalHub CR<br/>v1alpha1"]
    end

    subgraph ManagedResources["Managed Kubernetes Resources"]
        Deployments["Deployments"]
        Services["Services<br/>(ClusterIP)"]
        Routes["OpenShift Routes<br/>(HTTPS)"]
        ConfigMaps["ConfigMaps"]
        ServiceMonitors["ServiceMonitors<br/>(Prometheus)"]
        RBAC["RBAC Resources<br/>(SA, CR, CRB)"]
    end

    subgraph Sidecars["Security Sidecars"]
        KRBP["kube-rbac-proxy<br/>Bearer Token Auth<br/>FIPS 140-2 TLS"]
    end

    subgraph Driver["ta-lmes-driver"]
        DriverBin["Driver Binary<br/>Init + Sidecar<br/>18080/TCP status"]
    end

    %% CRD to Controller mappings
    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    LMEvalJobCR -->|scheduled by| JOB_MGR
    GuardrailsOrchestratorCR -->|watched by| GORCH
    NemoGuardrailsCR -->|watched by| NEMO
    EvalHubCR -->|watched by| EVALHUB

    %% Controllers create resources
    TAS -->|creates| Deployments
    TAS -->|creates| Services
    TAS -->|creates| Routes
    TAS -->|creates| ServiceMonitors
    GORCH -->|creates| Deployments
    GORCH -->|creates| Services
    GORCH -->|creates| Routes
    GORCH -->|creates| ConfigMaps
    NEMO -->|creates| Deployments
    NEMO -->|creates| Services
    NEMO -->|creates| Routes
    EVALHUB -->|creates| Deployments
    EVALHUB -->|creates| Services
    EVALHUB -->|creates| Routes
    EVALHUB -->|creates| RBAC
    LMES -->|creates pods with| DriverBin

    %% Security sidecar
    Deployments -->|includes| KRBP

    %% External integrations
    TAS -->|patches| KServeISVC["KServe InferenceService"]
    GORCH -->|auto-discovers| KServeISVC
    TAS -.->|conditional| Istio["Istio DestinationRule<br/>VirtualService"]
    EVALHUB -->|watches| TenantNS["Tenant Namespaces"]
    EVALHUB -->|integrates| MLflow["MLflow Tracking"]
    JOB_MGR -->|creates| KueueWL["Kueue Workloads"]

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style TAS fill:#5ba0d2,stroke:#333,color:#fff
    style LMES fill:#5ba0d2,stroke:#333,color:#fff
    style JOB_MGR fill:#5ba0d2,stroke:#333,color:#fff
    style GORCH fill:#5ba0d2,stroke:#333,color:#fff
    style NEMO fill:#5ba0d2,stroke:#333,color:#fff
    style EVALHUB fill:#5ba0d2,stroke:#333,color:#fff
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,color:#333
    style LMEvalJobCR fill:#f5a623,stroke:#333,color:#333
    style GuardrailsOrchestratorCR fill:#f5a623,stroke:#333,color:#333
    style NemoGuardrailsCR fill:#f5a623,stroke:#333,color:#333
    style EvalHubCR fill:#f5a623,stroke:#333,color:#333
    style KRBP fill:#e74c3c,stroke:#333,color:#fff
    style DriverBin fill:#9b59b6,stroke:#333,color:#fff
    style KServeISVC fill:#7ed321,stroke:#333
    style Istio fill:#999,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style KueueWL fill:#7ed321,stroke:#333
    style TenantNS fill:#7ed321,stroke:#333
