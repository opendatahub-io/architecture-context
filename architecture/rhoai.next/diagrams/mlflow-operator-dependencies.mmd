graph LR
    MLflowOp["MLflow Operator<br/>(mlflow-operator)"]

    %% Go Library Dependencies
    MLflowOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"manifest templating"| Helm["helm/v3<br/>v3.19.2"]
    MLflowOp -->|"config mgmt"| Viper["spf13/viper<br/>v1.21.0"]

    %% Conditional API Dependencies
    MLflowOp -->|"HTTPRoute types<br/>(conditional)"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -->|"ConsoleLink types<br/>(conditional)"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260209"]
    MLflowOp -->|"ServiceMonitor types<br/>(conditional)"| PromOperator["prometheus-operator<br/>v0.89.0"]

    %% Internal RHOAI Platform Dependencies
    MLflowOp -->|"HTTPRoute parent ref<br/>external ingress"| DSGateway["data-science-gateway<br/>(Platform Gateway)"]
    MLflowOp -->|"TLS CA bundles<br/>volume mount"| CABundle["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    MLflowOp -->|"auto TLS certs<br/>annotation-based"| ServiceCA["openshift-service-ca<br/>(controller)"]
    MLflowOp -->|"metrics scraping<br/>ServiceMonitor CRD"| PromOp["Prometheus Operator"]

    %% External Service Dependencies
    MLflowOp -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLflowOp -->|"metadata store<br/>3306/TCP"| MySQL["MySQL"]
    MLflowOp -->|"artifact storage<br/>443/9000/TCP"| S3["S3-compatible<br/>Storage"]
    MLflowOp -->|"CRs, RBAC, SSA<br/>6443/TCP"| K8sAPI["Kubernetes API"]

    %% Integration Points (other components using MLflow)
    Console["OpenShift Console"] -->|"ConsoleLink CR<br/>app menu entry"| MLflowOp

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Go libraries
    style ControllerRuntime fill:#b3d9ff,stroke:#333,color:#333
    style Helm fill:#b3d9ff,stroke:#333,color:#333
    style Viper fill:#b3d9ff,stroke:#333,color:#333

    %% Conditional API types
    style GatewayAPI fill:#d9b3ff,stroke:#333,color:#333
    style OpenShiftAPI fill:#d9b3ff,stroke:#333,color:#333
    style PromOperator fill:#d9b3ff,stroke:#333,color:#333

    %% Internal RHOAI
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style PromOp fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff

    %% Integration consumers
    style Console fill:#7ed321,stroke:#333,color:#fff
