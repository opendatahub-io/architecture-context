graph LR
    MLflowOp["MLflow Operator<br/>mlflow-operator"]

    %% External Library Dependencies
    MLflowOp -->|"controller framework<br/>v0.22.4"| ControllerRuntime["controller-runtime"]
    MLflowOp -->|"chart rendering<br/>v3.19.2"| Helm["Helm SDK"]
    MLflowOp -->|"config mgmt<br/>v1.21.0"| Viper["Viper"]

    %% Optional CRD Dependencies (conditional on cluster capabilities)
    MLflowOp -.->|"HTTPRoute types<br/>v1.4.1 (optional)"| GatewayAPI["Gateway API"]
    MLflowOp -.->|"ConsoleLink types<br/>(optional)"| OpenShiftAPI["OpenShift API"]
    MLflowOp -.->|"ServiceMonitor types<br/>v0.89.0 (optional)"| PromOperator["prometheus-operator"]

    %% Internal RHOAI/ODH Dependencies
    MLflowOp -->|"HTTPRoute parentRef<br/>external ingress"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    MLflowOp -->|"TLS cert provisioning<br/>service annotation"| ServiceCA["OpenShift service-ca"]
    MLflowOp -->|"CA trust chain<br/>volume mount"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    MLflowOp -->|"ConsoleLink<br/>app menu"| Console["OpenShift Console"]
    MLflowOp -->|"ServiceMonitor<br/>metrics scraping"| Prometheus["Prometheus Operator"]
    MLflowOp -->|"deployed workload"| MLflowImage["MLflow Server Image"]

    %% Downstream consumers (what depends on MLflow)
    Dashboard["ODH/RHOAI Dashboard"] -.->|"ConsoleLink<br/>app menu link"| MLflowOp
    DSPipelines["Data Science Pipelines"] -.->|"experiment tracking<br/>model registry"| MLflowOp

    %% External Services (runtime dependencies of deployed MLflow)
    MLflowOp -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLflowOp -->|"metadata store<br/>3306/TCP"| MySQL["MySQL"]
    MLflowOp -->|"artifact storage<br/>443/9000/8333 TCP"| S3["S3-compatible Storage<br/>(AWS, MinIO, SeaweedFS)"]
    MLflowOp -->|"resource mgmt<br/>6443/TCP"| K8sAPI["Kubernetes API"]

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Library dependencies
    style ControllerRuntime fill:#bbb,stroke:#333
    style Helm fill:#bbb,stroke:#333
    style Viper fill:#bbb,stroke:#333

    %% Optional dependencies
    style GatewayAPI fill:#ddd,stroke:#999,stroke-dasharray:5 5
    style OpenShiftAPI fill:#ddd,stroke:#999,stroke-dasharray:5 5
    style PromOperator fill:#ddd,stroke:#999,stroke-dasharray:5 5

    %% Internal RHOAI dependencies
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style MLflowImage fill:#7ed321,stroke:#333,color:#fff

    %% Downstream consumers
    style Dashboard fill:#b8d4e3,stroke:#333,stroke-dasharray:5 5
    style DSPipelines fill:#b8d4e3,stroke:#333,stroke-dasharray:5 5

    %% External services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
