graph LR
    MLflowOp["MLflow Operator<br/>(Go, controller-runtime)"]

    %% Required External Dependencies
    MLflowOp -->|"controller framework"| CR["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"chart rendering"| Helm["helm/v3<br/>v3.19.2"]
    MLflowOp -->|"version comparison"| Semver["semver/v3<br/>v3.4.0"]
    MLflowOp -->|"env config"| Viper["viper<br/>v1.21.0"]

    %% Optional External Dependencies (capability-detected)
    MLflowOp -.->|"HTTPRoute CRD<br/>(optional, detected)"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -.->|"ConsoleLink CRD<br/>(optional, detected)"| OpenShiftAPI["openshift/api"]
    MLflowOp -.->|"ServiceMonitor CRD<br/>(optional, detected)"| PromOp["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"external ingress<br/>(HTTPRoute parent)"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    MLflowOp -->|"TLS cert provisioning<br/>(service annotation)"| ServiceCA["openshift-service-ca"]
    MLflowOp -->|"CA bundle volume<br/>(TLS verification)"| CABundle["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    MLflowOp -->|"CRD reconciliation<br/>SSAR, discovery"| K8sAPI["Kubernetes API<br/>Server"]
    MLflowOp -->|"metrics scraping<br/>(ServiceMonitor)"| Prometheus["Prometheus"]

    %% Integration Points (other components depend on MLflow)
    Console["OpenShift Console"] -->|"ConsoleLink CR"| MLflowOp
    Prometheus -->|"scrape /metrics"| MLflowOp

    %% Managed Workload Dependencies
    MLflowServer["MLflow Server<br/>(managed workload)"]
    MLflowOp -->|"deploys & manages"| MLflowServer
    MLflowServer -->|"metadata store"| PG["PostgreSQL<br/>5432/TCP"]
    MLflowServer -.->|"metadata store (alt)"| MySQL["MySQL<br/>3306/TCP"]
    MLflowServer -->|"artifact storage"| S3["S3-compatible<br/>Storage<br/>443/TCP"]
    MLflowServer -->|"auth (SSAR)"| K8sAPI

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MLflowServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    %% Required deps (gray)
    style CR fill:#999,stroke:#333,color:#fff
    style Helm fill:#999,stroke:#333,color:#fff
    style Semver fill:#999,stroke:#333,color:#fff
    style Viper fill:#999,stroke:#333,color:#fff

    %% Optional deps (lighter gray)
    style GatewayAPI fill:#bbb,stroke:#666,color:#333
    style OpenShiftAPI fill:#bbb,stroke:#666,color:#333
    style PromOp fill:#bbb,stroke:#666,color:#333

    %% Internal platform (green)
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style PG fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
