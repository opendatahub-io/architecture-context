graph LR
    MLflowOp["MLflow Operator<br/>(controller-runtime + Helm)"]

    %% Required External Dependencies
    subgraph RequiredExt["Required External Dependencies"]
        ControllerRuntime["controller-runtime<br/>v0.22.4"]
        HelmLib["Helm v3 Library<br/>v3.19.2"]
        MLflowImg["MLflow Server Image<br/>v3.13.0"]
    end

    MLflowOp -->|"controller framework"| ControllerRuntime
    MLflowOp -->|"chart rendering engine"| HelmLib
    MLflowOp -->|"deploys"| MLflowImg

    %% Optional External Dependencies (conditional CRD detection)
    subgraph OptionalExt["Optional External Dependencies (conditional)"]
        GatewayAPI["gateway-api<br/>v1.4.1"]
        OpenShiftAPI["openshift/api<br/>(ConsoleLink CRD)"]
        PromOperator["prometheus-operator<br/>v0.89.0"]
    end

    MLflowOp -.->|"HTTPRoute ingress<br/>(if CRD available)"| GatewayAPI
    MLflowOp -.->|"ConsoleLink menu<br/>(if CRD available)"| OpenShiftAPI
    MLflowOp -.->|"ServiceMonitor metrics<br/>(if CRD available)"| PromOperator

    %% Internal Platform Dependencies
    subgraph InternalPlatform["Internal Platform Dependencies"]
        DSGateway["data-science-gateway<br/>(Gateway in openshift-ingress)"]
        ServiceCA["OpenShift service-ca<br/>(auto TLS provisioning)"]
        CABundle["odh-trusted-ca-bundle<br/>(ConfigMap)"]
        Console["OpenShift Console<br/>(application menu)"]
        Prometheus["Prometheus<br/>(metrics scraping)"]
    end

    MLflowOp -->|"HTTPRoute parent ref"| DSGateway
    MLflowOp -->|"TLS cert annotation"| ServiceCA
    MLflowOp -->|"watches CA bundle"| CABundle
    MLflowOp -->|"ConsoleLink CRD"| Console
    MLflowOp -->|"ServiceMonitor CRD"| Prometheus

    %% Backend Data Stores
    subgraph DataStores["Backend Data Stores"]
        PostgreSQL["PostgreSQL<br/>5432/TCP TLS"]
        MySQL["MySQL<br/>3306/TCP TLS"]
        SQLite["SQLite<br/>(requires PVC)"]
    end

    MLflowImg -->|"metadata store"| PostgreSQL
    MLflowImg -->|"metadata store (alt)"| MySQL
    MLflowImg -->|"metadata store (dev)"| SQLite

    %% Artifact Storage
    subgraph ArtifactStorage["Artifact Storage Backends"]
        S3["S3-Compatible<br/>(MinIO, SeaweedFS, AWS S3)"]
        GCS["Google Cloud Storage"]
        AzureBlob["Azure Blob Storage"]
    end

    MLflowImg -->|"artifact storage"| S3
    MLflowImg -->|"artifact storage (alt)"| GCS
    MLflowImg -->|"artifact storage (alt)"| AzureBlob

    %% Platform components that depend on MLflow
    subgraph Dependents["Components That Integrate With MLflow"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
    end

    MLflowOp -->|"CRD watches, SSA, RBAC"| K8sAPI
    MLflowImg -->|"SelfSubjectAccessReview"| K8sAPI

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style HelmLib fill:#999,stroke:#333,color:#fff
    style MLflowImg fill:#4a90e2,stroke:#333,color:#fff
    style GatewayAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style OpenShiftAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
