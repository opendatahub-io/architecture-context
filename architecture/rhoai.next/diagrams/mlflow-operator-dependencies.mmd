graph LR
    MLflowOp["MLflow Operator<br/>(Go 1.24.6)"]

    %% External Dependencies (libraries/frameworks)
    MLflowOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"manifest templating"| Helm["helm.sh/helm/v3<br/>v3.19.2"]
    MLflowOp -->|"configuration"| Viper["spf13/viper<br/>v1.21.0"]

    %% Conditional External Dependencies (cluster features)
    MLflowOp -.->|"ingress routing<br/>(if available)"| GatewayAPI["Gateway API<br/>v1.4.1"]
    MLflowOp -.->|"console integration<br/>(if OpenShift)"| OpenshiftAPI["openshift/api<br/>v0.0.0-20260209"]
    MLflowOp -.->|"metrics monitoring<br/>(if CRD present)"| PrometheusOp["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"HTTPRoute parent ref<br/>external ingress"| DSGateway["data-science-gateway<br/>(Gateway)"]
    MLflowOp -->|"TLS cert provisioning<br/>service annotation"| ServiceCA["openshift-service-ca<br/>(controller)"]
    MLflowOp -->|"CA bundle volume<br/>TLS verification"| TrustedCA["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    MLflowOp -->|"metrics scraping<br/>ServiceMonitor CRD"| Prometheus["Prometheus Operator"]

    %% MLflow Server Dependencies (deployed by operator)
    MLflowServer["MLflow Server<br/>(Python)"]
    MLflowOp -->|"deploys"| MLflowServer

    MLflowServer -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLflowServer -->|"metadata store<br/>3306/TCP"| MySQL["MySQL"]
    MLflowServer -->|"artifact storage<br/>443/9000/8333 TCP"| S3["S3-compatible Storage<br/>(AWS S3, MinIO, SeaweedFS)"]
    MLflowServer -->|"authz checks<br/>6443/TCP"| K8sAPI["Kubernetes API Server"]

    %% Integration Points (other components that interact)
    Console["OpenShift Console"] -->|"ConsoleLink"| MLflowOp
    DSPipelines["Data Science Pipelines"] -.->|"mlflow-integration<br/>ClusterRole"| MLflowServer

