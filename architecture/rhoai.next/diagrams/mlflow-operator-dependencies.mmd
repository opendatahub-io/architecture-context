graph LR
    MLflowOp["MLflow Operator<br/>(Go Operator)"]

    %% External Dependencies (libraries)
    MLflowOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"manifest templating"| Helm["helm.sh/helm/v3<br/>v3.19.2"]
    MLflowOp -->|"HTTPRoute types"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -->|"ConsoleLink types"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260209"]
    MLflowOp -->|"ServiceMonitor types"| PromOperator["prometheus-operator<br/>v0.89.0"]
    MLflowOp -->|"configuration"| Viper["spf13/viper<br/>v1.21.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"HTTPRoute parent ref<br/>external ingress"| Gateway["data-science-gateway<br/>(Gateway)"]
    MLflowOp -->|"CA certificates<br/>volume mount"| CABundle["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    MLflowOp -->|"TLS cert provisioning<br/>service annotation"| ServiceCA["openshift-service-ca<br/>(controller)"]
    MLflowOp -->|"metrics scraping<br/>ServiceMonitor"| Prometheus["Prometheus Operator"]

    %% Runtime Dependencies (MLflow server)
    MLflowSrv["MLflow Server<br/>(Python/Uvicorn)"]
    MLflowOp -->|"deploys &<br/>manages"| MLflowSrv

    MLflowSrv -->|"RBAC authorization<br/>SelfSubjectAccessReview<br/>6443/TCP"| K8sAPI["Kubernetes API<br/>Server"]
    MLflowSrv -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLflowSrv -->|"metadata store<br/>3306/TCP"| MySQL["MySQL"]
    MLflowSrv -->|"artifact storage<br/>443/9000/TCP"| S3["S3-compatible<br/>Storage"]

    %% Integration Points (consumers of MLflow)
    Dashboard["ODH Dashboard"] -.->|"console integration<br/>ConsoleLink"| MLflowOp
    Prometheus -.->|"scrapes metrics<br/>8443/TCP"| MLflowSrv

