graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller-manager<br/>(opendatahub namespace)"]
        SA_API["maas-api<br/>(opendatahub namespace)"]
        SA_BBR["payload-processing<br/>(openshift-ingress namespace)"]
    end

    subgraph ControllerBindings["Controller Bindings"]
        CRB_Controller["maas-controller-manager-rolebinding<br/>(ClusterRoleBinding)"]
        RB_LeaderElect["maas-controller-leader-election<br/>(RoleBinding → kube-system)"]
    end

    subgraph APIBindings["API Bindings"]
        CRB_API["maas-api-clusterrolebinding<br/>(ClusterRoleBinding)"]
        CRB_API_Supp["maas-api-supplemental-clusterrolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph BBRBindings["BBR Bindings"]
        CRB_BBR["payload-processing-reader-binding<br/>(ClusterRoleBinding)"]
    end

    subgraph ControllerRole["ClusterRole: maas-controller-manager"]
        CR_MaaS["maas.opendatahub.io<br/>tenants, maasmodelrefs,<br/>maasauthpolicies, maassubscriptions,<br/>externalmodels<br/>+ status, finalizers<br/>✏️ Full CRUD"]
        CR_Gateway["gateway.networking.k8s.io<br/>gateways (read)<br/>httproutes (full CRUD)"]
        CR_Kuadrant["kuadrant.io<br/>authpolicies,<br/>tokenratelimitpolicies,<br/>ratelimitpolicies<br/>✏️ Full CRUD"]
        CR_KuadrantExt["extensions.kuadrant.io<br/>telemetrypolicies<br/>✏️ CRUD"]
        CR_Istio["networking.istio.io<br/>serviceentries,<br/>destinationrules,<br/>envoyfilters<br/>✏️ Full CRUD"]
        CR_IstioTel["telemetry.istio.io<br/>telemetries<br/>✏️ CRUD"]
        CR_Core["core (v1)<br/>secrets, namespaces,<br/>serviceaccounts, services,<br/>configmaps<br/>✏️ CRUD"]
        CR_Apps["apps<br/>deployments<br/>✏️ CRUD"]
        CR_Batch["batch<br/>cronjobs<br/>✏️ CRUD"]
        CR_RBAC["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings<br/>✏️ CRUD"]
        CR_Auth["authentication.k8s.io<br/>tokenreviews (create)<br/>authorization.k8s.io<br/>subjectaccessreviews (create)"]
        CR_OCP["config.openshift.io<br/>authentications (read)"]
        CR_Perses["perses.dev<br/>persesdashboards,<br/>persesdatasources<br/>✏️ CRUD"]
    end

    subgraph APIRole["ClusterRole: maas-api"]
        CR_API_Core["core (v1)<br/>secrets (get: maas-db-config)<br/>namespaces, serviceaccounts,<br/>pods, services, endpoints<br/>👁️ Read + create"]
        CR_API_Auth["authentication.k8s.io<br/>tokenreviews (create)<br/>authorization.k8s.io<br/>subjectaccessreviews (create)"]
        CR_API_MaaS["maas.opendatahub.io<br/>maasmodelrefs,<br/>maassubscriptions<br/>👁️ Read-only"]
        CR_API_GW["gateway.networking.k8s.io<br/>httproutes<br/>👁️ Read-only"]
    end

    subgraph BBRRole["ClusterRole: payload-processing-reader"]
        CR_BBR_Core["core (v1)<br/>configmaps, secrets<br/>👁️ Read-only"]
        CR_BBR_MaaS["maas.opendatahub.io<br/>externalmodels<br/>👁️ Read-only"]
    end

    subgraph AggregateRoles["Aggregate User-Facing Roles"]
        CR_Owner["maas-controller-owner<br/>maasmodelrefs, externalmodels<br/>✏️ Full CRUD"]
        CR_Viewer["maas-controller-viewer<br/>maasmodelrefs, externalmodels<br/>👁️ Read-only"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Controller -->|"bound via"| RB_LeaderElect
    CRB_Controller -->|"grants"| ControllerRole

    SA_API -->|"bound via"| CRB_API
    SA_API -->|"bound via"| CRB_API_Supp
    CRB_API -->|"grants"| APIRole

    SA_BBR -->|"bound via"| CRB_BBR
    CRB_BBR -->|"grants"| BBRRole

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_API fill:#4a90e2,color:#fff
    style SA_BBR fill:#4a90e2,color:#fff

    style CRB_Controller fill:#b8d4f0,color:#333
    style RB_LeaderElect fill:#b8d4f0,color:#333
    style CRB_API fill:#b8d4f0,color:#333
    style CRB_API_Supp fill:#b8d4f0,color:#333
    style CRB_BBR fill:#b8d4f0,color:#333

    style CR_MaaS fill:#7ed321,color:#fff
    style CR_Gateway fill:#7ed321,color:#fff
    style CR_Kuadrant fill:#7ed321,color:#fff
    style CR_KuadrantExt fill:#7ed321,color:#fff
    style CR_Istio fill:#7ed321,color:#fff
    style CR_IstioTel fill:#7ed321,color:#fff
    style CR_Core fill:#7ed321,color:#fff
    style CR_Apps fill:#7ed321,color:#fff
    style CR_Batch fill:#7ed321,color:#fff
    style CR_RBAC fill:#7ed321,color:#fff
    style CR_Auth fill:#7ed321,color:#fff
    style CR_OCP fill:#7ed321,color:#fff
    style CR_Perses fill:#7ed321,color:#fff

    style CR_API_Core fill:#f5a623,color:#fff
    style CR_API_Auth fill:#f5a623,color:#fff
    style CR_API_MaaS fill:#f5a623,color:#fff
    style CR_API_GW fill:#f5a623,color:#fff

    style CR_BBR_Core fill:#bd10e0,color:#fff
    style CR_BBR_MaaS fill:#bd10e0,color:#fff

    style CR_Owner fill:#50e3c2,color:#333
    style CR_Viewer fill:#50e3c2,color:#333
