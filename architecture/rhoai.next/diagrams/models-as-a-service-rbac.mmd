graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller-manager<br/>(opendatahub)"]
        SA_API["maas-api<br/>(opendatahub)"]
        SA_BBR["payload-processing<br/>(openshift-ingress)"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-manager<br/>-rolebinding"]
        CRB_API["maas-api<br/>-clusterrolebinding"]
        CRB_API_Supp["maas-api-supplemental<br/>-clusterrolebinding"]
        CRB_BBR["payload-processing<br/>-reader-binding"]
        RB_Leader["maas-controller<br/>-leader-election<br/>(RoleBinding, kube-system)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["maas-controller-manager"]
        CR_API["maas-api"]
        CR_API_Supp["maas-api-supplemental"]
        CR_BBR["payload-processing-reader"]
        CR_Owner["maas-controller-owner<br/>(aggregate label)"]
        CR_Viewer["maas-controller-viewer<br/>(aggregate label)"]
        R_Leader["maas-controller<br/>-leader-election<br/>(Role)"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Leader
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_API_Supp
    SA_BBR -->|bound via| CRB_BBR

    CRB_Controller -->|grants| CR_Controller
    CRB_API -->|grants| CR_API
    CRB_API_Supp -->|grants| CR_API_Supp
    CRB_BBR -->|grants| CR_BBR
    RB_Leader -->|grants| R_Leader

    subgraph MaaSCRDs["maas.opendatahub.io Resources"]
        Tenants["Tenants<br/>+ status + finalizers"]
        ModelRefs["MaaSModelRefs<br/>+ status + finalizers"]
        AuthPolicies["MaaSAuthPolicies<br/>+ status + finalizers"]
        Subscriptions["MaaSSubscriptions<br/>+ status + finalizers"]
        ExternalModels["ExternalModels<br/>+ status + finalizers"]
    end

    subgraph GatewayResources["gateway.networking.k8s.io"]
        Gateways["Gateways"]
        HTTPRoutes["HTTPRoutes<br/>+ finalizers"]
    end

    subgraph KuadrantResources["kuadrant.io"]
        KAuthPolicies["AuthPolicies"]
        KTRP["TokenRateLimitPolicies"]
        KRLP["RateLimitPolicies"]
        KTP["TelemetryPolicies<br/>(extensions.kuadrant.io)"]
    end

    subgraph IstioResources["networking.istio.io / telemetry.istio.io"]
        ServiceEntries["ServiceEntries"]
        DestRules["DestinationRules"]
        EnvoyFilters["EnvoyFilters"]
        Telemetries["Telemetries"]
    end

    subgraph CoreResources["Core / Apps / Batch / RBAC"]
        Secrets["Secrets<br/>(maas-db-config)"]
        CoreResAll["Namespaces, SAs,<br/>Services, ConfigMaps"]
        Deployments["Deployments"]
        CronJobs["CronJobs"]
        RBACRes["ClusterRoles,<br/>ClusterRoleBindings"]
        TokenReviews["TokenReviews"]
        SARs["SubjectAccessReviews"]
        Pods["Pods, Services,<br/>Endpoints"]
    end

    %% Controller permissions
    CR_Controller -->|"CRUD + status + finalizers"| Tenants
    CR_Controller -->|"CRUD + status + finalizers"| ModelRefs
    CR_Controller -->|"CRUD + status + finalizers"| AuthPolicies
    CR_Controller -->|"CRUD + status + finalizers"| Subscriptions
    CR_Controller -->|"CRUD + status + finalizers"| ExternalModels
    CR_Controller -->|"get, list, watch"| Gateways
    CR_Controller -->|"CRUD"| HTTPRoutes
    CR_Controller -->|"CRUD"| KAuthPolicies
    CR_Controller -->|"CRUD"| KTRP
    CR_Controller -->|"CRUD"| KRLP
    CR_Controller -->|"CRUD"| KTP
    CR_Controller -->|"CRUD"| ServiceEntries
    CR_Controller -->|"CRUD"| DestRules
    CR_Controller -->|"CRUD"| EnvoyFilters
    CR_Controller -->|"CRUD"| Telemetries
    CR_Controller -->|"get"| Secrets
    CR_Controller -->|"CRUD"| CoreResAll
    CR_Controller -->|"CRUD"| Deployments
    CR_Controller -->|"CRUD"| CronJobs
    CR_Controller -->|"CRUD"| RBACRes
    CR_Controller -->|"create"| TokenReviews
    CR_Controller -->|"create"| SARs

    %% API permissions
    CR_API -->|"get"| Secrets
    CR_API -->|"get, list, watch"| ModelRefs
    CR_API -->|"get, list, watch"| Subscriptions
    CR_API -->|"get, list, watch"| HTTPRoutes
    CR_API -->|"get, list, watch"| Pods
    CR_API -->|"create"| TokenReviews
    CR_API -->|"create"| SARs

    %% BBR permissions
    CR_BBR -->|"get, list, watch"| Secrets
    CR_BBR -->|"get, list, watch"| ExternalModels

    %% Aggregate roles
    CR_Owner -->|"CRUD"| ModelRefs
    CR_Owner -->|"CRUD"| ExternalModels
    CR_Viewer -->|"get, list, watch"| ModelRefs
    CR_Viewer -->|"get, list, watch"| ExternalModels

