graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>NS: opendatahub"]
        SA_API["maas-api<br/>NS: per-tenant"]
        SA_Payload["payload-processing<br/>NS: openshift-ingress"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Controller["maas-controller-role-binding<br/>(cluster-wide)"]
        CRB_API["maas-api<br/>(cluster-wide)"]
        CRB_API_Supp["maas-api-supplemental<br/>(cluster-wide)"]
        CRB_Payload["payload-processing-reader-binding<br/>(cluster-wide)"]
        RB_Leader["maas-controller-leader-election<br/>(NS: opendatahub)"]
    end

    subgraph ControllerRole["ClusterRole: maas-controller-role"]
        direction LR
        CR_MaasCRDs["maas.opendatahub.io<br/>aitenants, tenants, configs,<br/>maasmodelrefs, maassubscriptions,<br/>maasauthpolicies, externalmodels<br/>→ full CRUD"]
        CR_InferenceCRDs["inference.opendatahub.io<br/>externalmodels, externalproviders<br/>→ full CRUD"]
        CR_Gateway["gateway.networking.k8s.io<br/>gateways → get,list,watch<br/>httproutes → full CRUD"]
        CR_Kuadrant["kuadrant.io<br/>authpolicies,<br/>tokenratelimitpolicies<br/>→ full CRUD"]
        CR_KServe["serving.kserve.io<br/>llminferenceservices<br/>→ get,list,watch"]
        CR_Istio["networking.istio.io<br/>destinationrules, envoyfilters,<br/>serviceentries<br/>→ full CRUD"]
        CR_Apps["apps<br/>deployments<br/>→ full CRUD"]
        CR_Core["core<br/>configmaps, serviceaccounts,<br/>services, namespaces<br/>→ CRUD"]
        CR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>→ full CRUD"]
        CR_Monitoring["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/>→ CRUD"]
        CR_OpenShift["config.openshift.io<br/>authentications<br/>→ get,list,watch"]
    end

    subgraph APIRole["ClusterRole: maas-api"]
        direction LR
        API_Secrets["core<br/>secrets (maas-db-config)<br/>→ get"]
        API_NS["core<br/>namespaces<br/>→ get,list,watch,create"]
        API_SA["core<br/>serviceaccounts<br/>→ get,list,watch,create,delete"]
        API_SAToken["core<br/>serviceaccounts/token<br/>→ create"]
        API_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
        API_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>→ create"]
        API_MaasCRDs["maas.opendatahub.io<br/>maasauthpolicies,<br/>maasmodelrefs,<br/>maassubscriptions<br/>→ get,list,watch"]
        API_HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>→ get,list,watch"]
    end

    subgraph PayloadRole["ClusterRole: payload-processing-reader"]
        direction LR
        PP_Secrets["core<br/>configmaps, secrets<br/>→ get,list,watch"]
        PP_Services["core<br/>services<br/>→ get,list,watch,create,<br/>update,delete"]
        PP_MaasCRDs["maas.opendatahub.io<br/>externalmodels<br/>→ get,list,watch"]
        PP_InferenceCRDs["inference.opendatahub.io<br/>externalproviders,<br/>externalmodels<br/>→ get,list,watch,<br/>create,update"]
        PP_Gateway["gateway.networking.k8s.io<br/>httproutes<br/>→ CRUD"]
        PP_Istio["networking.istio.io<br/>serviceentries,<br/>destinationrules<br/>→ CRUD"]
    end

    subgraph AggregatedRoles["Aggregated Roles (User-Facing)"]
        OwnerRole["maas-owner-role<br/>maasmodelrefs, externalmodels<br/>→ full CRUD"]
        ViewerRole["maas-viewer-role<br/>maasmodelrefs, externalmodels<br/>→ get,list,watch"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Controller
    SA_Controller -->|"bound via"| RB_Leader
    CRB_Controller -->|"grants"| ControllerRole

    SA_API -->|"bound via"| CRB_API
    SA_API -->|"bound via"| CRB_API_Supp
    CRB_API -->|"grants"| APIRole

    SA_Payload -->|"bound via"| CRB_Payload
    CRB_Payload -->|"grants"| PayloadRole

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#50c878,stroke:#333,color:#fff
    style SA_Payload fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Controller fill:#e8e8e8,stroke:#333
    style CRB_API fill:#e8e8e8,stroke:#333
    style CRB_API_Supp fill:#e8e8e8,stroke:#333
    style CRB_Payload fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style OwnerRole fill:#f5a623,stroke:#333,color:#000
    style ViewerRole fill:#f5a623,stroke:#333,color:#000
