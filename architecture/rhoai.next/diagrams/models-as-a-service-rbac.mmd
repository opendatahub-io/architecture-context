graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>(opendatahub namespace)"]
        SA_API["maas-api<br/>(opendatahub namespace)"]
        SA_BBR["payload-processing<br/>(openshift-ingress namespace)"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-rolebinding<br/>(cluster-scoped)"]
        CRB_API["maas-api-clusterrolebinding<br/>(cluster-scoped)"]
        CRB_API_Supp["maas-api-supplemental-binding<br/>(cluster-scoped)"]
        CRB_BBR["payload-processing-rolebinding<br/>(cluster-scoped)"]
        RB_Leader["maas-controller-leader-election<br/>(opendatahub namespace)"]
    end

    subgraph Roles["ClusterRoles"]
        CR_Controller["maas-controller-role"]
        CR_API["maas-api"]
        CR_API_Supp["maas-api-supplemental"]
        CR_BBR["payload-processing-reader"]
        R_Leader["leader-election-role"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Leader
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_API_Supp
    SA_BBR -->|bound via| CRB_BBR

    CRB_Controller -->|grants| CR_Controller
    CRB_API -->|grants| CR_API
    CRB_API_Supp -->|grants| CR_API_Supp
    CRB_BBR -->|grants| CR_BBR
    RB_Leader -->|grants| R_Leader

    %% Controller Role Resources
    subgraph ControllerResources["maas-controller-role Permissions"]
        MaaSCRDs["maas.opendatahub.io<br/>externalmodels, maasauthpolicies,<br/>maasmodelrefs, maassubscriptions,<br/>tenants, */status, */finalizers<br/>FULL CRUD"]
        GatewayRes["gateway.networking.k8s.io<br/>httproutes: FULL CRUD<br/>gateways: read-only"]
        KuadrantRes["kuadrant.io<br/>authpolicies, tokenratelimitpolicies,<br/>ratelimitpolicies<br/>FULL CRUD"]
        KServeRes["serving.kserve.io<br/>llminferenceservices<br/>read-only"]
        IstioRes["networking.istio.io<br/>destinationrules, envoyfilters,<br/>serviceentries<br/>FULL CRUD"]
        TelemetryRes["telemetry.istio.io,<br/>extensions.kuadrant.io<br/>telemetries, telemetrypolicies<br/>FULL CRUD"]
        CoreRes["core (v1)<br/>configmaps, serviceaccounts,<br/>services: FULL CRUD<br/>secrets: read-only<br/>namespaces: get, create"]
        WorkloadRes["apps, batch,<br/>networking.k8s.io<br/>deployments, cronjobs,<br/>networkpolicies<br/>FULL CRUD"]
        RBACRes["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>FULL CRUD"]
        AuthRes["authentication.k8s.io<br/>tokenreviews: create<br/>authorization.k8s.io<br/>subjectaccessreviews: create"]
        OSRes["config.openshift.io<br/>authentications: read-only<br/>apiextensions.k8s.io<br/>CRDs: read-only<br/>operator.authorino.kuadrant.io<br/>authorinos: read-only"]
    end

    CR_Controller -->|grants access to| MaaSCRDs
    CR_Controller -->|grants access to| GatewayRes
    CR_Controller -->|grants access to| KuadrantRes
    CR_Controller -->|grants access to| KServeRes
    CR_Controller -->|grants access to| IstioRes
    CR_Controller -->|grants access to| TelemetryRes
    CR_Controller -->|grants access to| CoreRes
    CR_Controller -->|grants access to| WorkloadRes
    CR_Controller -->|grants access to| RBACRes
    CR_Controller -->|grants access to| AuthRes
    CR_Controller -->|grants access to| OSRes

    %% API Role Resources
    subgraph APIResources["maas-api Permissions"]
        APISecrets["core (v1)<br/>secrets (maas-db-config): get<br/>namespaces: CRUD<br/>serviceaccounts: CRUD + token<br/>pods, services, endpoints: read"]
        APIAuth["authentication.k8s.io<br/>tokenreviews: create<br/>authorization.k8s.io<br/>subjectaccessreviews: create"]
        APIMaaS["maas.opendatahub.io<br/>maasmodelrefs, maassubscriptions<br/>read-only"]
        APIGateway["gateway.networking.k8s.io<br/>httproutes: read-only"]
    end

    CR_API -->|grants access to| APISecrets
    CR_API -->|grants access to| APIAuth
    CR_API -->|grants access to| APIMaaS
    CR_API -->|grants access to| APIGateway

    %% BBR Role Resources
    subgraph BBRResources["payload-processing-reader Permissions"]
        BBRCore["core (v1)<br/>configmaps, secrets<br/>read-only"]
        BBRMaaS["maas.opendatahub.io<br/>externalmodels<br/>read-only"]
    end

    CR_BBR -->|grants access to| BBRCore
    CR_BBR -->|grants access to| BBRMaaS

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff
    style CR_Controller fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style CR_API_Supp fill:#f5a623,stroke:#333
    style CR_BBR fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style MaaSCRDs fill:#7ed321,stroke:#333
    style GatewayRes fill:#7ed321,stroke:#333
    style KuadrantRes fill:#7ed321,stroke:#333
    style KServeRes fill:#7ed321,stroke:#333
    style IstioRes fill:#7ed321,stroke:#333
    style TelemetryRes fill:#7ed321,stroke:#333
    style CoreRes fill:#7ed321,stroke:#333
    style WorkloadRes fill:#7ed321,stroke:#333
    style RBACRes fill:#e74c3c,stroke:#333,color:#fff
    style AuthRes fill:#7ed321,stroke:#333
    style OSRes fill:#7ed321,stroke:#333
    style APISecrets fill:#7ed321,stroke:#333
    style APIAuth fill:#7ed321,stroke:#333
    style APIMaaS fill:#7ed321,stroke:#333
    style APIGateway fill:#7ed321,stroke:#333
    style BBRCore fill:#7ed321,stroke:#333
    style BBRMaaS fill:#7ed321,stroke:#333
