graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["maas-api<br/>Namespace: opendatahub"]
        SA_Controller["maas-controller<br/>Namespace: opendatahub"]
        SA_Payload["payload-processing<br/>Namespace: openshift-ingress"]
    end

    subgraph Bindings["ClusterRoleBindings"]
        CRB_API["maas-api<br/>+ maas-api-supplemental"]
        CRB_Controller["maas-controller-rolebinding"]
        CRB_Payload["payload-processing"]
    end

    subgraph Roles["ClusterRoles"]
        CR_API["maas-api"]
        CR_Controller["maas-controller-role"]
        CR_Payload["payload-processing-reader"]
    end

    %% SA → Binding → Role
    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Controller
    SA_Payload -->|bound via| CRB_Payload
    CRB_Payload -->|grants| CR_Payload

    %% maas-api resources
    subgraph API_Resources["maas-api Permissions"]
        API_Secrets["core: secrets<br/>(maas-db-config)<br/>get"]
        API_NS["core: namespaces<br/>get, list, watch, create"]
        API_SA["core: serviceaccounts<br/>get, list, watch,<br/>create, delete"]
        API_SAToken["core: serviceaccounts/token<br/>create"]
        API_TokenReview["authentication.k8s.io:<br/>tokenreviews<br/>create"]
        API_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        API_MaasCRDs["maas.opendatahub.io:<br/>maasmodelrefs,<br/>maassubscriptions<br/>get, list, watch"]
        API_HTTPRoutes["gateway.networking.k8s.io:<br/>httproutes<br/>get, list, watch"]
        API_Core["core: pods, services,<br/>endpoints<br/>get, list, watch"]
    end

    CR_API -->|grants access to| API_Secrets
    CR_API -->|grants access to| API_NS
    CR_API -->|grants access to| API_SA
    CR_API -->|grants access to| API_SAToken
    CR_API -->|grants access to| API_TokenReview
    CR_API -->|grants access to| API_SAR
    CR_API -->|grants access to| API_MaasCRDs
    CR_API -->|grants access to| API_HTTPRoutes
    CR_API -->|grants access to| API_Core

    %% maas-controller resources
    subgraph Controller_Resources["maas-controller Permissions"]
        Ctrl_Core["core: configmaps, serviceaccounts,<br/>events, namespaces, services<br/>full CRUD + watch"]
        Ctrl_ReadOnly["core: endpoints, pods,<br/>secrets<br/>get, list, watch"]
        Ctrl_Apps["apps: deployments<br/>full CRUD + watch"]
        Ctrl_Batch["batch: cronjobs<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_Kuadrant["kuadrant.io: authpolicies,<br/>tokenratelimitpolicies,<br/>ratelimitpolicies<br/>full CRUD + watch"]
        Ctrl_KuadrantExt["extensions.kuadrant.io:<br/>telemetrypolicies<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_GW["gateway.networking.k8s.io:<br/>gateways (read),<br/>httproutes (full CRUD)"]
        Ctrl_Istio["networking.istio.io:<br/>destinationrules,<br/>envoyfilters, serviceentries<br/>full CRUD + watch"]
        Ctrl_Telemetry["telemetry.istio.io:<br/>telemetries<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_MaaS["maas.opendatahub.io:<br/>all CRDs (tenants,<br/>maasmodelrefs, etc.)<br/>full CRUD + watch"]
        Ctrl_KServe["serving.kserve.io:<br/>llminferenceservices<br/>get, list, watch"]
        Ctrl_RBAC["rbac.authorization.k8s.io:<br/>clusterroles,<br/>clusterrolebindings<br/>full CRUD + watch"]
        Ctrl_NetPol["networking.k8s.io:<br/>networkpolicies<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_Monitor["monitoring.coreos.com:<br/>podmonitors<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_Perses["perses.dev:<br/>persesdashboards,<br/>persesdatasources<br/>create, delete, get,<br/>list, patch, watch"]
        Ctrl_OS["config.openshift.io:<br/>authentications<br/>get, list, watch"]
        Ctrl_Authorino["operator.authorino.kuadrant.io:<br/>authorinos<br/>get, list, watch"]
        Ctrl_CRD["apiextensions.k8s.io:<br/>customresourcedefinitions<br/>get, list, watch"]
    end

    CR_Controller -->|grants access to| Ctrl_Core
    CR_Controller -->|grants access to| Ctrl_ReadOnly
    CR_Controller -->|grants access to| Ctrl_Apps
    CR_Controller -->|grants access to| Ctrl_Batch
    CR_Controller -->|grants access to| Ctrl_Kuadrant
    CR_Controller -->|grants access to| Ctrl_KuadrantExt
    CR_Controller -->|grants access to| Ctrl_GW
    CR_Controller -->|grants access to| Ctrl_Istio
    CR_Controller -->|grants access to| Ctrl_Telemetry
    CR_Controller -->|grants access to| Ctrl_MaaS
    CR_Controller -->|grants access to| Ctrl_KServe
    CR_Controller -->|grants access to| Ctrl_RBAC
    CR_Controller -->|grants access to| Ctrl_NetPol
    CR_Controller -->|grants access to| Ctrl_Monitor
    CR_Controller -->|grants access to| Ctrl_Perses
    CR_Controller -->|grants access to| Ctrl_OS
    CR_Controller -->|grants access to| Ctrl_Authorino
    CR_Controller -->|grants access to| Ctrl_CRD

    %% payload-processing resources
    subgraph Payload_Resources["payload-processing Permissions"]
        Pay_CM["core: configmaps<br/>get, list, watch"]
        Pay_Secrets["core: secrets<br/>get, list, watch"]
        Pay_ExtModel["maas.opendatahub.io:<br/>externalmodels<br/>get, list, watch"]
    end

    CR_Payload -->|grants access to| Pay_CM
    CR_Payload -->|grants access to| Pay_Secrets
    CR_Payload -->|grants access to| Pay_ExtModel

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Payload fill:#4a90e2,stroke:#333,color:#fff
    style CR_API fill:#f5a623,stroke:#333
    style CR_Controller fill:#f5a623,stroke:#333
    style CR_Payload fill:#f5a623,stroke:#333
    style CRB_API fill:#d5e8d4,stroke:#82b366
    style CRB_Controller fill:#d5e8d4,stroke:#82b366
    style CRB_Payload fill:#d5e8d4,stroke:#82b366
