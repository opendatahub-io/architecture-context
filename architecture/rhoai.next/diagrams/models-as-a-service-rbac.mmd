        CRB_BBR["payload-processing<br/>-reader-binding"]
        RB_Leader["maas-controller<br/>-leader-election<br/>(NS: kube-system)"]
    end

    subgraph Roles["ClusterRoles"]
        CR_Controller["maas-controller-manager"]
        CR_API["maas-api"]
        CR_API_Supp["maas-api-supplemental"]
        CR_BBR["payload-processing-reader"]
        CR_Owner["maas-controller-owner<br/>(aggregate label)"]
        CR_Viewer["maas-controller-viewer<br/>(aggregate label)"]
        R_Leader["maas-controller<br/>-leader-election<br/>(Role)"]
    end

    subgraph MaaSResources["maas.opendatahub.io Resources"]
        Tenants["Tenants<br/>+status/finalizers"]
        ModelRefs["MaaSModelRefs<br/>+status/finalizers"]
        AuthPolicies["MaaSAuthPolicies<br/>+status/finalizers"]
        Subscriptions["MaaSSubscriptions<br/>+status/finalizers"]
        ExternalModels["ExternalModels<br/>+status/finalizers"]
    end

    subgraph GatewayResources["gateway.networking.k8s.io"]
        Gateways["Gateways"]
        HTTPRoutes["HTTPRoutes<br/>+finalizers"]
    end

    subgraph KuadrantResources["kuadrant.io"]
        AuthPoliciesK["AuthPolicies"]
        TRLP["TokenRateLimitPolicies"]
        RLP["RateLimitPolicies"]
        TelPolicy["TelemetryPolicies<br/>(extensions.kuadrant.io)"]
    end

    subgraph IstioResources["networking.istio.io / telemetry.istio.io"]
        ServiceEntries["ServiceEntries"]
        DestRules["DestinationRules"]
        EnvoyFilters["EnvoyFilters"]
        Telemetries["Telemetries"]
    end

    subgraph CoreResources["Core Kubernetes"]
        Secrets["Secrets"]
        ConfigMaps["ConfigMaps"]
        Namespaces["Namespaces"]
        SvcAccounts["ServiceAccounts<br/>+token"]
        Services["Services"]
        Deployments["Deployments"]
        CronJobs["CronJobs"]
        Pods["Pods"]
        Endpoints["Endpoints"]
        CRoles["ClusterRoles"]
        CRBindings["ClusterRoleBindings"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["TokenReviews"]
        SAR["SubjectAccessReviews"]
        OSAuth["OpenShift<br/>Authentications"]
        CRDs["CustomResource<br/>Definitions"]
    end

    subgraph ObsResources["Observability"]
        PersesDash["PersesDashboards"]
        PersesDS["PersesDatasources"]
    end

    %% SA → Binding → Role
    SA_Controller -->|bound via| CRB_Controller
