graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller-manager<br/>NS: opendatahub"]
        SA_API["maas-api<br/>NS: opendatahub"]
        SA_BBR["payload-processing<br/>NS: openshift-ingress"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-manager<br/>-rolebinding"]
        CRB_API["maas-api<br/>-clusterrolebinding"]
