graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>(opendatahub)"]
        SA_API["maas-api<br/>(opendatahub)"]
        SA_PayloadProc["payload-processing<br/>(openshift-ingress)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-rolebinding"]
        CRB_Config["maas-controller-cluster-config-rolebinding"]
        CRB_API["maas-api"]
        CRB_API_Supp["maas-api-supplemental"]
        CRB_Payload["payload-processing-reader"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["maas-controller-role"]
        CR_Config["maas-controller-<br/>cluster-config-role"]
        CR_API["maas-api"]
        CR_Payload["payload-processing-reader"]
    end

    subgraph TenantRoles["Tenant RBAC"]
        CR_Owner["maas-owner-role"]
        CR_Viewer["maas-viewer-role"]
    end

    %% Binding relationships
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_Config
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_API_Supp
    SA_PayloadProc -->|bound via| CRB_Payload

    CRB_Controller -->|grants| CR_Controller
    CRB_Config -->|grants| CR_Config
    CRB_API -->|grants| CR_API
    CRB_Payload -->|grants| CR_Payload

    %% Controller Role Resources
    subgraph ControllerResources["maas-controller-role Resources"]
        direction LR
        CR_Core["Core API<br/>configmaps, secrets,<br/>services, sa, events,<br/>namespaces, pods,<br/>endpoints"]
        CR_Apps["apps<br/>deployments,<br/>deployments/finalizers"]
        CR_Batch["batch<br/>cronjobs"]
        CR_GatewayAPI["gateway.networking.k8s.io<br/>gateways, httproutes,<br/>httproutes/finalizers"]
        CR_Kuadrant["kuadrant.io<br/>authpolicies,<br/>tokenratelimitpolicies,<br/>ratelimitpolicies"]
        CR_MaaS["maas.opendatahub.io<br/>aitenants, tenants,<br/>maasmodelrefs,<br/>maasauthpolicies,<br/>maassubscriptions<br/>(+status, +finalizers)"]
        CR_Istio["networking.istio.io<br/>serviceentries,<br/>destinationrules"]
        CR_NetPol["networking.k8s.io<br/>networkpolicies"]
        CR_Inference["inference.opendatahub.io<br/>externalmodels,<br/>externalproviders<br/>(+status, +finalizers)"]
        CR_Telemetry["extensions.kuadrant.io<br/>telemetrypolicies"]
        CR_AuthN["authentication.k8s.io<br/>tokenreviews"]
        CR_AuthZ["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    %% API Role Resources
    subgraph APIResources["maas-api Resources"]
        direction LR
        API_Core["Core API<br/>secrets, namespaces,<br/>sa, sa/token, pods,<br/>services, endpoints"]
        API_AuthN["authentication.k8s.io<br/>tokenreviews"]
        API_AuthZ["authorization.k8s.io<br/>subjectaccessreviews"]
        API_MaaS["maas.opendatahub.io<br/>maasauthpolicies,<br/>maasmodelrefs,<br/>maassubscriptions<br/>(read-only)"]
        API_Gateway["gateway.networking.k8s.io<br/>httproutes<br/>(read-only)"]
    end

    %% Payload Processing Resources
    subgraph PayloadResources["payload-processing-reader Resources"]
        direction LR
        PP_Core["Core API<br/>configmaps, secrets,<br/>services"]
        PP_MaaS["maas.opendatahub.io<br/>externalmodels,<br/>externalmodels/finalizers"]
        PP_Inference["inference.opendatahub.io<br/>externalproviders,<br/>externalmodels<br/>(+status, +finalizers)"]
        PP_Gateway["gateway.networking.k8s.io<br/>httproutes"]
        PP_Istio["networking.istio.io<br/>serviceentries,<br/>destinationrules"]
    end

    %% Tenant Role Resources
    subgraph TenantResources["Tenant Role Resources"]
        direction LR
        Owner_Res["maas.opendatahub.io<br/>maasmodelrefs,<br/>externalmodels<br/>(full CRUD)"]
        Viewer_Res["maas.opendatahub.io<br/>maasmodelrefs,<br/>externalmodels<br/>(get, list, watch)"]
    end

    CR_Controller -->|"full CRUD"| ControllerResources
    CR_API -->|"mixed verbs"| APIResources
    CR_Payload -->|"full CRUD"| PayloadResources
    CR_Owner -->|"full CRUD"| Owner_Res
    CR_Viewer -->|"read-only"| Viewer_Res

    %% Styles
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#50c878,stroke:#333,color:#fff
    style SA_PayloadProc fill:#9b59b6,stroke:#333,color:#fff

    style CR_Controller fill:#f5a623,stroke:#333
    style CR_Config fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style CR_Payload fill:#f5a623,stroke:#333
    style CR_Owner fill:#e67e22,stroke:#333
    style CR_Viewer fill:#e67e22,stroke:#333

    style CR_MaaS fill:#7ed321,stroke:#333
    style CR_Kuadrant fill:#7ed321,stroke:#333
    style CR_GatewayAPI fill:#7ed321,stroke:#333
    style CR_Istio fill:#7ed321,stroke:#333
    style CR_Inference fill:#7ed321,stroke:#333
    style API_MaaS fill:#7ed321,stroke:#333
    style PP_MaaS fill:#7ed321,stroke:#333
    style PP_Inference fill:#7ed321,stroke:#333
    style Owner_Res fill:#7ed321,stroke:#333
    style Viewer_Res fill:#7ed321,stroke:#333
