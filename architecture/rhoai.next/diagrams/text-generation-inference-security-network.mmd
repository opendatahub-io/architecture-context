graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe Layer)"]
        KServeGW["KServe InferenceService<br/>Gateway / kube-rbac-proxy<br/>Auth enforcement"]
    end

    subgraph PodBoundary["POD BOUNDARY (Single Container)<br/>User: tgis (UID 2000, GID 0)<br/>allowPrivilegeEscalation: false<br/>seccompProfile: RuntimeDefault"]
        direction TB

        subgraph RouterProcess["text-generation-router (Rust)"]
            gRPCServer["fmaas.GenerationService<br/>8033/TCP gRPC<br/>Optional TLS<br/>Optional mTLS"]
            HTTPServer["HTTP Server<br/>3000/TCP plaintext<br/>/health + /metrics<br/>Unauthenticated"]
        end

        subgraph ShardProcesses["text-generation-server (Python) × N"]
            InternalAPI["generate.v1.TextGenerationService<br/>UDS /tmp/text-generation-server-{rank}<br/>No encryption, No auth"]
            NCCL["Inter-shard NCCL/GLOO<br/>29500/TCP loopback<br/>No encryption"]
        end
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        K8sProbes["Kubernetes Probes<br/>Liveness + Readiness"]
        Prometheus["Prometheus<br/>Metrics scraping"]
        ModelPVC["Shared Model PVC<br/>/shared_model_storage<br/>Filesystem access"]
    end

    subgraph GPULayer["GPU HARDWARE"]
        GPU["NVIDIA GPU<br/>CUDA 12.1.0<br/>NCCL 2.18.3"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Optional auth token"]
    end

    %% Flows
    Client -->|"gRPC/8033<br/>Optional TLS<br/>Optional mTLS"| KServeGW
    KServeGW -->|"gRPC/8033 + HTTP/3000<br/>Platform auth"| gRPCServer

    gRPCServer -->|"UDS gRPC<br/>No encryption<br/>Process-local"| InternalAPI
    InternalAPI -->|"CUDA runtime<br/>Hardware bus"| GPU

    K8sProbes -->|"HTTP GET /health<br/>3000/TCP plaintext<br/>No auth"| HTTPServer
    Prometheus -->|"HTTP GET /metrics<br/>3000/TCP plaintext<br/>No auth"| HTTPServer

    InternalAPI -->|"Filesystem<br/>Volume mount"| ModelPVC
    InternalAPI -.->|"HTTPS/443<br/>TLS 1.2+<br/>Optional token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef router fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef shard fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef gpu fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeGW ingress
    class gRPCServer,HTTPServer router
    class InternalAPI,NCCL shard
    class K8sProbes,Prometheus,ModelPVC cluster
    class GPU gpu
    class HFHub extsvc
