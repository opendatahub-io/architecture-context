graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe Layer)"]
        KServeGW["KServe InferenceService<br/>Gateway / kube-rbac-proxy<br/>Auth enforced here"]
    end

    subgraph TGISPod["TGIS POD (Non-Root UID 2000)"]
        direction TB

        subgraph RouterProcess["Router Process (Rust)"]
            Router["text-generation-router<br/>gRPC :8033 | HTTP :3000<br/>Optional TLS/mTLS"]
        end

        subgraph ShardProcesses["Shard Processes (Python)"]
            Shard0["text-generation-server<br/>Shard 0<br/>UDS /tmp/tgs-0"]
            ShardN["text-generation-server<br/>Shard N<br/>UDS /tmp/tgs-N"]
        end

        Router -->|"gRPC via UDS<br/>No encryption<br/>Process-local"| Shard0
        Router -->|"gRPC via UDS<br/>No encryption<br/>Process-local"| ShardN
        Shard0 <-->|"NCCL 29500/TCP<br/>Plaintext<br/>Intra-pod only"| ShardN
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        Service["inference-server Service<br/>Headless ClusterIP: None<br/>8033/TCP gRPC"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
        K8sProbes["K8s Probes<br/>/health"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Optional auth token"]
        GPU["NVIDIA GPU<br/>CUDA 12.1<br/>GPU Operator"]
    end

    subgraph Volumes["VOLUMES"]
        SHM["/dev/shm (2Gi)<br/>NCCL shared memory"]
        ModelPVC["models-pvc<br/>/shared_model_storage"]
    end

    %% External flows
    Client -->|"gRPC 8033/TCP<br/>Optional TLS<br/>Optional mTLS"| KServeGW
    KServeGW -->|"gRPC 8033/TCP<br/>Platform auth enforced"| Service
    Service -->|"Direct pod access<br/>(headless)"| Router

    %% Monitoring flows
    Prometheus -->|"HTTP GET :3000<br/>Plaintext<br/>No auth"| Router
    K8sProbes -->|"HTTP GET :3000<br/>Plaintext<br/>No auth"| Router

    %% Egress flows
    Shard0 -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Optional token"| HFHub
    Shard0 -->|"CUDA kernel calls"| GPU
    ShardN -->|"CUDA kernel calls"| GPU

    %% Volume mounts
    SHM -.->|"mount"| ShardProcesses
    ModelPVC -.->|"mount"| ShardProcesses

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef router fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef shard fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef volume fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class KServeGW ingress
    class Router router
    class Shard0,ShardN shard
    class Service,Prometheus,K8sProbes internal
    class HFHub,GPU externalservice
    class SHM,ModelPVC volume
