graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe Managed)"]
        KServeRoute["KServe Route / HTTPRoute<br/>443/TCP → 8033/TCP<br/>TLS 1.2+ (SIMPLE/MUTUAL)"]
    end

    subgraph TGISPod["TGIS POD (Single Container)"]
        direction TB

        subgraph RouterLayer["text-generation-router (Rust)"]
            GRPCEndpoint["gRPC Server<br/>8033/TCP<br/>fmaas.GenerationService<br/>TLS/mTLS configurable<br/>rustls 0.22.4"]
            HTTPEndpoint["HTTP Server<br/>3000/TCP<br/>/health, /metrics<br/>TLS configurable<br/>No auth"]
        end

        subgraph ShardLayer["text-generation-server (Python)"]
            direction LR
            Shard0["Shard 0<br/>UDS /tmp/tgs-0<br/>plaintext gRPC"]
            ShardN["Shard N<br/>UDS /tmp/tgs-N<br/>plaintext gRPC"]
        end

        GPUDevice["NVIDIA GPU<br/>CUDA 12.1<br/>Device driver"]
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
        OTel["OpenTelemetry Collector<br/>gRPC (configurable port)<br/>Configurable encryption"]
    end

    subgraph Monitoring["MONITORING / PROBES"]
        Kubelet["Kubernetes Kubelet<br/>HTTP probe"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| KServeRoute
    KServeRoute -->|"gRPC/8033<br/>TLS/mTLS configurable<br/>Client cert auth"| GRPCEndpoint

    %% Internal flows
    GRPCEndpoint -->|"gRPC/UDS<br/>plaintext<br/>no auth"| Shard0
    GRPCEndpoint -->|"gRPC/UDS<br/>plaintext<br/>no auth"| ShardN
    Shard0 <-->|"NCCL/29500<br/>plaintext<br/>allreduce"| ShardN
    Shard0 -->|"CUDA"| GPUDevice
    ShardN -->|"CUDA"| GPUDevice

    %% Monitoring
    Kubelet -->|"HTTP GET /health<br/>3000/TCP<br/>no TLS, no auth"| HTTPEndpoint
    Prometheus -->|"HTTP GET /metrics<br/>3000/TCP<br/>no TLS, no auth"| HTTPEndpoint

    %% Egress
    Shard0 -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub
    GRPCEndpoint -->|"gRPC<br/>configurable"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef router fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef shard fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#76b900,stroke:#333,stroke-width:2px,color:#fff
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e8e8e8,stroke:#666,stroke-width:1px

    class Client external
    class KServeRoute ingress
    class GRPCEndpoint,HTTPEndpoint router
    class Shard0,ShardN shard
    class GPUDevice gpu
    class HFHub,OTel egress
    class Kubelet,Prometheus monitoring
