graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["data-science-gateway<br/>443/TCP → HTTPRoute routing<br/>TLS 1.2+<br/>OIDC/Bearer Token"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS (self-signed)<br/>OIDC validation<br/>SubjectAccessReview authz"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK"]
        direction TB

        subgraph NS_Platform["Namespace: opendatahub / redhat-ods-applications"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP metrics<br/>9443/TCP webhook (TLS)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            HeadPod["Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client<br/>mTLS: optional"]
            WorkerPods["Ray Worker Pods<br/>mTLS: optional"]
            HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>6379, 8265, 10001/TCP"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token Auth"]
        CertManager["cert-manager<br/>Issuer + Certificate CRDs<br/>90d certs, 15d renewal"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Password auth (optional)<br/>GCS fault tolerance"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Token"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS (self-signed)<br/>OIDC Token forwarded"| RBACProxy

    %% Auth → Dashboard
    RBACProxy -->|"HTTP/8265<br/>localhost<br/>No auth (local)"| HeadPod

    %% Operator → Head Pod
    Operator -->|"HTTP/8265<br/>None or mTLS<br/>Job status, Serve config"| HeadPod

    %% Operator → Control Plane
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD watches, CRUD"| K8sAPI

    %% Auth → Control Plane
    RBACProxy -->|"HTTPS/443<br/>TokenReview +<br/>SubjectAccessReview"| K8sAPI

    %% Operator → cert-manager
    Operator -->|"CRD Create<br/>Issuer + Certificate"| CertManager

    %% Head ↔ Workers
    HeadPod <-->|"6379/TCP<br/>None or mTLS"| WorkerPods

    %% Head → Redis
    HeadPod -->|"TCP/6379<br/>Configurable encryption<br/>Password (optional)"| Redis

    %% Services
    HeadSvc -.->|routes to| HeadPod
    ServeSvc -.->|routes to| HeadPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class RBACProxy auth
    class Operator,HeadPod,WorkerPods,HeadSvc,ServeSvc cluster
    class K8sAPI,CertManager controlplane
    class Redis externalservice
