graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["External User / Data Scientist"]
    end

    subgraph PlatformNS["INGRESS - Platform Namespace (redhat-ods-applications)"]
        Gateway["data-science-gateway<br/>(Envoy / Gateway API)<br/>HTTPRoute: /ray/{ns}/{cluster}/*<br/>TLS 1.2+ termination"]
    end

    subgraph UserNS["RAY CLUSTER - User Namespace (NetworkPolicy Protected)"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            AuthProxy["kube-rbac-proxy / oauth-proxy<br/>8443/TCP HTTPS<br/>TLS: self-signed RSA 2048<br/>AuthZ: SubjectAccessReview"]
        end

        subgraph HeadPodGroup["Ray Head Pod"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP"]
            GCS["GCS Server<br/>6379/TCP"]
            ClientPort["Client Port<br/>10001/TCP"]
            Serve["Ray Serve<br/>8000/TCP"]
            Metrics["Metrics<br/>8080/TCP"]
        end

        subgraph WorkerPodsGroup["Ray Worker Pods"]
            WorkerClient["Client Port<br/>10001/TCP"]
            WorkerServe["Ray Serve<br/>8000/TCP"]
            WorkerMetrics["Metrics<br/>8080/TCP"]
        end

        subgraph NetworkPolicies["NetworkPolicy Rules"]
            NP["Head: intra-cluster all ports<br/>Head: ns-local 10001, 8265<br/>Head: operator ns health checks<br/>Head: gateway ns → 8443<br/>Workers: intra-cluster only"]
        end
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP metrics (HTTP)<br/>8082/TCP probes (HTTP)<br/>9443/TCP webhooks (HTTPS)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: SA Token"]
        CertMgr["cert-manager<br/>CRD: Issuer, Certificate<br/>Auth: SA Token"]
        OAuth["OpenShift OAuth API<br/>443/TCP HTTPS TLS 1.2+<br/>config.openshift.io"]
        Prometheus["Prometheus<br/>Scrape: 8080/TCP HTTP"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Session cookie"| Gateway

    %% Ingress → Auth Layer
    Gateway -->|"HTTPS/8443<br/>TLS (self-signed)<br/>SubjectAccessReview"| AuthProxy

    %% Auth Layer → Dashboard
    AuthProxy -->|"HTTP/8265<br/>localhost (no TLS)<br/>No auth"| Dashboard

    %% Head ↔ Workers (mTLS)
    GCS ---|"gRPC + TCP<br/>mTLS (cert-manager)<br/>Per-cluster CA<br/>90-day certs"| WorkerClient

    %% Operator → Platform Services
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| CertMgr
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OAuth

    %% Operator → Ray Cluster
    Operator -.->|"HTTP/8265<br/>No TLS<br/>Health checks"| Dashboard

    %% Prometheus scraping
    Prometheus -.->|"HTTP/8080<br/>No auth"| Metrics
    Prometheus -.->|"HTTP/8080<br/>No auth"| Operator

    %% K8s API → Operator Webhooks
    K8sAPI -->|"HTTPS/9443<br/>serving-cert TLS<br/>Admission control"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Gateway ingress
    class AuthProxy auth
    class Dashboard,GCS,ClientPort,Serve,Metrics,WorkerClient,WorkerServe,WorkerMetrics servicemesh
    class Operator operator
    class K8sAPI,CertMgr,OAuth,Prometheus platform
    class NP netpol
