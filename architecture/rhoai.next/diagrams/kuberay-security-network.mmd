graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["External User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform Namespace)"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP → HTTPRoute<br/>TLS 1.2+ SIMPLE<br/>Path: /ray/{ns}/{cluster}/*"]
        HTTPRoute["HTTPRoute: {ns}-{cluster}<br/>Cross-namespace via ReferenceGrant"]
        Gateway --> HTTPRoute
    end

    subgraph AuthBoundary["AUTHENTICATION BOUNDARY (User Namespace)"]
        AuthProxy["kube-rbac-proxy / OAuth proxy<br/>8443/TCP HTTPS<br/>Self-signed TLS (RSA 2048)<br/>SubjectAccessReview / OAuth"]
    end

    subgraph RayCluster["RAY CLUSTER (User Namespace - NetworkPolicy Enforced)"]
        direction TB
        HeadPod["Ray Head Pod<br/>SA: default<br/>Ports: 6379, 8265, 10001,<br/>8080, 8000, 8443<br/>mTLS: cert-manager (90d cert)"]
        WorkerPods["Ray Worker Pods<br/>SA: default<br/>DNS: {cluster}-headless<br/>mTLS: cert-manager (90d cert)"]
        HeadPod <-->|"gRPC + Ray protocol<br/>mTLS (per-cluster CA)<br/>Mutual TLS certs"| WorkerPods
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP metrics (HTTP)<br/>8082/TCP health (HTTP)<br/>9443/TCP webhook (HTTPS)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        CertManager["cert-manager<br/>CRD-based (Issuer, Certificate)<br/>CA: RSA 4096, 10yr<br/>Node: 90d, auto-renewal 15d"]
        OAuthConfig["OpenShift OAuth<br/>config.openshift.io<br/>443/TCP HTTPS"]
        Prometheus["Prometheus<br/>Scrape 8080/TCP HTTP"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Session cookie"| Gateway
    HTTPRoute -->|"HTTPS/8443<br/>Self-signed TLS<br/>SubjectAccessReview"| AuthProxy
    AuthProxy -->|"HTTP/8265<br/>localhost (loopback)<br/>No auth"| HeadPod

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| CertManager
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OAuthConfig
    Operator -->|"HTTP/8265<br/>cluster-internal<br/>No auth"| HeadPod
    Operator -->|"HTTP/8000<br/>cluster-internal<br/>No auth"| HeadPod
    Prometheus -->|"HTTP/8080<br/>No auth"| Operator

    %% K8s API webhook callback
    K8sAPI -->|"HTTPS/9443<br/>OpenShift serving-cert<br/>API server mTLS"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef raycluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway,HTTPRoute ingress
    class AuthProxy auth
    class HeadPod,WorkerPods raycluster
    class Operator operator
    class K8sAPI,CertManager,OAuthConfig,Prometheus platform
