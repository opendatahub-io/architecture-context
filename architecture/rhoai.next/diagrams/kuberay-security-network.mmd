graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway<br/>(data-science-gateway)<br/>443/TCP → HTTPRoute<br/>TLS 1.2+ SIMPLE<br/>OIDC Validation"]
    end

    subgraph AuthSidecar["AUTHENTICATION SIDECAR"]
        KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS TLS<br/>TokenReview + SubjectAccessReview<br/>Image: ose-kube-rbac-proxy-rhel9"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>TLS (serving cert)<br/>Mutate + Validate"]
    end

    subgraph RayClusterNS["RAY CLUSTER (user-namespace)"]
        direction TB

        HeadPod["Ray Head Pod<br/>8265/TCP Dashboard<br/>10001/TCP Client<br/>6379/TCP GCS<br/>+ kube-rbac-proxy sidecar"]
        HeadSvc["Head Service (ClusterIP)<br/>8265, 10001, 6379"]
        WorkerPods["Ray Worker Pods<br/>mTLS certs via init container"]
        ServeSvc["Serve Service (ClusterIP)<br/>8000/TCP"]
        NetPol["NetworkPolicy<br/>(pod isolation)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        CertManager["cert-manager<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Issuer/Certificate CRs"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Configurable encryption<br/>Username/password"]
        OAuthAPI["OpenShift OAuth API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>PodMonitor scrape"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Token"| Gateway

    %% Ingress to Auth Sidecar
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC

    %% Auth Sidecar to Ray
    KubeRBAC -->|"HTTP/8265<br/>None (localhost)<br/>No Auth"| HeadPod
    KubeRBAC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview"| K8sAPI

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD CRUD, Pod mgmt"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server cert<br/>Admission"| WebhookSvc

    %% Operator to Ray
    Operator -->|"HTTP/8265<br/>None<br/>Job submission"| HeadPod

    %% Ray internal
    HeadPod -->|"Ray/10001<br/>mTLS (CA-signed)<br/>Client cert"| WorkerPods

    %% Operator to external
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| CertManager
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OAuthAPI
    HeadPod -.->|"TCP/6379<br/>Configurable<br/>Password"| Redis
    Prometheus -.->|"HTTP/8080<br/>None<br/>PodMonitor"| HeadPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef raycluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC auth
    class Operator,WebhookSvc operatorns
    class HeadPod,WorkerPods,HeadSvc,ServeSvc,NetPol raycluster
    class K8sAPI,CertManager,Redis,OAuthAPI,Prometheus externalservice
