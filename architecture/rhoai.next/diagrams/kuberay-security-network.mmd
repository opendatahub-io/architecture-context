graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["data-science-gateway<br/>443/TCP<br/>TLS 1.2+<br/>OIDC/OAuth"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: opendatahub / redhat-ods-applications"]
            Operator["kuberay-operator<br/>SA: kuberay-operator<br/>Ports: 8080 (metrics),<br/>8082 (health), 9443 (webhook)"]
            WebhookSvc["kuberay-webhook-service<br/>443→9443/TCP<br/>HTTPS (OpenShift serving cert)"]
            HTTPRoute["HTTPRoute<br/>/ray/{ns}/{cluster}/<br/>→ cross-namespace backend"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            HeadPod["Ray Head Pod<br/>SA: {cluster}-head-sa"]

            subgraph HeadContainers["Head Pod Containers"]
                RayHead["ray-head<br/>6379 (GCS), 8265 (Dashboard),<br/>10001 (Client), 8000 (Serve)<br/>None or mTLS"]
                KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (self-signed)<br/>OIDC → SubjectAccessReview"]
            end

            WorkerPods["Ray Worker Pods<br/>SA: {cluster}-worker-sa<br/>mTLS (when enabled)"]
            HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>6379, 8265, 10001"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP :8000"]
            NetPolicy["NetworkPolicy<br/>Fine-grained ingress rules"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        CertManager["cert-manager<br/>Certificate lifecycle<br/>90-day certs, 15-day renewal"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Configurable encryption<br/>Password auth (optional)"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (self-signed)<br/>OIDC Token fwd"| KubeRBACProxy

    %% Auth flow
    KubeRBACProxy -->|"HTTPS/443<br/>TokenReview +<br/>SubjectAccessReview"| K8sAPI
    KubeRBACProxy -->|"HTTP/8265<br/>localhost<br/>No auth"| RayHead

    %% Operator flows
    Operator -->|"HTTP/8265<br/>None or mTLS<br/>Job status & Serve config"| RayHead
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch/CRUD resources"| K8sAPI
    Operator -.->|"CRD Create/Watch<br/>Issuer, Certificate"| CertManager

    %% Internal cluster flows
    WorkerPods -->|"TCP/6379<br/>None or mTLS<br/>GCS connection"| RayHead
    HeadPod -->|"TCP/6379<br/>Configurable<br/>Password (optional)"| Redis

    %% Webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (serving cert)<br/>Admission webhook"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef networkpolicy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class Operator,RayHead,WorkerPods,HeadSvc,ServeSvc,HTTPRoute,WebhookSvc internal
    class KubeRBACProxy security
    class K8sAPI,CertManager,Redis externalservice
    class NetPolicy networkpolicy
