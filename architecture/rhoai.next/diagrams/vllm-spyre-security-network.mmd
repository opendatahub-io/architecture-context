graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        KServe["KServe / ModelMesh"]
    end

    subgraph Pod["POD BOUNDARY (InferenceService Pod)"]
        direction TB

        subgraph Sidecar["Platform-Injected Sidecar"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP<br/>TLS 1.2+<br/>Bearer Token (JWT)<br/>SubjectAccessReview AuthZ"]
        end

        subgraph AppContainer["Application Container (UID 2000, restricted SCC)"]
            direction TB

            subgraph Adapter["vllm-tgis-adapter"]
                HTTPApi["HTTP API<br/>8000/TCP<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"]
                GRPCApi["gRPC API<br/>8033/TCP<br/>TGIS GenerationService"]
            end

            subgraph EngineLayer["vLLM Engine"]
                VLLMEngine["vLLM Engine<br/>+ vllm-spyre Plugin<br/>HF_HUB_OFFLINE=1"]
            end

            HTTPApi -->|"in-process<br/>Python call"| VLLMEngine
            GRPCApi -->|"in-process<br/>Python call"| VLLMEngine
        end

        RBACProxy -->|"HTTP/8000<br/>localhost<br/>No TLS<br/>Pre-authenticated"| HTTPApi
        RBACProxy -->|"gRPC/8033<br/>localhost<br/>No TLS<br/>Pre-authenticated"| GRPCApi
    end

    subgraph Hardware["HARDWARE"]
        SpyreAccel["IBM Spyre AI Accelerator<br/>VFIO Passthrough<br/>Device I/O"]
    end

    subgraph Storage["STORAGE (Pre-provisioned)"]
        ModelPVC["Model Weights PVC<br/>HuggingFace Artifacts<br/>Filesystem Mount"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (JWT)"| RBACProxy
    KServe -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| RBACProxy

    %% Hardware flow
    VLLMEngine -->|"VFIO Passthrough<br/>Device I/O<br/>No Network"| SpyreAccel

    %% Storage flow
    ModelPVC -.->|"Volume Mount<br/>Filesystem<br/>Read-Only"| VLLMEngine

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,KServe external
    class RBACProxy sidecar
    class HTTPApi,GRPCApi,VLLMEngine app
    class SpyreAccel hardware
    class ModelPVC storage
