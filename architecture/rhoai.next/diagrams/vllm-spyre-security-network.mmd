graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (DMZ)"]
        KServeRouter["KServe Router / Platform Ingress<br/>Auth: kube-rbac-proxy / Gateway API / OAuth proxy<br/>TLS termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Plaintext in-cluster)"]
        direction TB

        subgraph VLLMContainer["vllm-spyre Container (UID: 2000)"]
            direction LR
            HTTPAPI["HTTP API (uvicorn)<br/>8000/TCP HTTP<br/>No auth (delegated)<br/>/v1/completions<br/>/v1/chat/completions<br/>/health, /v1/models"]
            GRPCAPI["gRPC TGIS Server<br/>8033/TCP gRPC<br/>No auth (delegated)<br/>GenerationService"]
            VLLMEngine["vLLM Inference<br/>Engine"]
            HTTPAPI --> VLLMEngine
            GRPCAPI --> VLLMEngine
        end

        subgraph Hardware["IBM SPYRE HARDWARE"]
            SpyreCard["IBM Spyre AI<br/>Accelerator Card<br/>Hardware interface"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / ServiceAccount"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        PVC["PVC / Local Filesystem<br/>Volume mount<br/>No network"]
    end

    %% Flows
    Client -->|"HTTPS / gRPC<br/>TLS (platform-managed)<br/>Bearer Token / OAuth"| KServeRouter
    KServeRouter -->|"HTTP/8000<br/>Plaintext in-cluster<br/>No auth (already enforced)"| HTTPAPI
    KServeRouter -->|"gRPC/8033<br/>Plaintext in-cluster<br/>No auth (already enforced)"| GRPCAPI
    VLLMEngine -->|"Hardware interface<br/>IBM Spyre driver"| SpyreCard
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    VLLMEngine -->|"Filesystem<br/>Volume mount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeRouter ingress
    class HTTPAPI,GRPCAPI,VLLMEngine internal
    class SpyreCard hardware
    class S3,HFHub,PVC externalservice
