graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS Termination)"]
        Gateway["RHOAI Gateway / KServe Ingress<br/>443/TCP → 8000/8033<br/>TLS 1.3 Termination<br/>AuthN: Platform-managed"]
    end

    subgraph Workload["WORKLOAD (Container - UID 2000 Non-Root)"]
        direction TB

        subgraph Container["vllm-spyre Container (odh-vllm-spyre-rhel9)"]
            direction TB
            HTTPServer["OpenAI HTTP Server<br/>8000/TCP HTTP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/health<br/>/metrics"]
            GRPCServer["TGIS gRPC Server<br/>8033/TCP gRPC<br/>GenerationService"]
            VLLMEngine["vLLM Inference Engine<br/>Speculative Decoding<br/>(logprobs enabled)"]
        end

        subgraph Hardware["Hardware Accelerator"]
            SpyreCard["IBM Spyre Card<br/>PCIe Bus<br/>No network encryption"]
        end

        HTTPServer --> VLLMEngine
        GRPCServer --> VLLMEngine
        VLLMEngine -->|PCIe/driver| SpyreCard
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["Model Storage (S3/PVC)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM / SA"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token (optional)"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP HTTP<br/>Path: /metrics"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token (platform)"| Gateway
    Gateway -->|"HTTP/8000<br/>No encryption<br/>Pod-internal"| HTTPServer
    Gateway -->|"gRPC/8033<br/>No encryption<br/>Pod-internal"| GRPCServer
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Prometheus -->|"HTTP/8000<br/>No encryption<br/>Cluster-internal"| HTTPServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class HTTPServer,GRPCServer,VLLMEngine workload
    class SpyreCard hardware
    class S3,HFHub,Prometheus externalservice
