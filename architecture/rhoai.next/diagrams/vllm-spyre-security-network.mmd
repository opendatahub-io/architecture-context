graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        KServeRouter["KServe Router /<br/>Platform Ingress<br/>443/TCP<br/>TLS 1.2+<br/>kube-rbac-proxy / OAuth"]
    end

    subgraph Container["CONTAINER (In-Cluster — No Auth)"]
        direction TB

        subgraph VllmSpyre["vllm-spyre (UID 2000, non-root)<br/>Image: odh-vllm-spyre-rhel9<br/>Base: rhaiis/vllm-spyre-rhel9:3.2.2"]
            HTTPApi["HTTP API Server<br/>8000/TCP HTTP<br/>No Encryption<br/>No Auth<br/>/v1/completions<br/>/v1/chat/completions<br/>/health, /v1/models"]
            GRPCApi["gRPC API Server<br/>8033/TCP gRPC<br/>No Encryption<br/>No Auth<br/>TGIS GenerationService"]
            VLLMEngine["vLLM Engine"]
        end

        SpyreHW["IBM Spyre<br/>Hardware Accelerator<br/>Hardware Interface"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        PVC["PVC / Local Storage<br/>Filesystem<br/>No Network"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer / OAuth"| KServeRouter
    KServeRouter -->|"HTTP/8000<br/>Plaintext (in-cluster)<br/>No Auth (delegated)"| HTTPApi
    KServeRouter -->|"gRPC/8033<br/>Plaintext (in-cluster)<br/>No Auth (delegated)"| GRPCApi
    HTTPApi --> VLLMEngine
    GRPCApi --> VLLMEngine
    VLLMEngine -->|"Hardware Interface<br/>Proprietary"| SpyreHW
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    VLLMEngine -->|"Filesystem<br/>Volume Mount"| PVC
    VLLMEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeRouter ingress
    class HTTPApi,GRPCApi,VLLMEngine container
    class SpyreHW hardware
    class S3,PVC,HFHub externalservice
