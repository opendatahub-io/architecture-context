graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AuthProxy["AUTH PROXY (kube-rbac-proxy - RHOAI 3.x)"]
        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP → 8000, 8033/TCP<br/>TLS Termination<br/>Bearer Token + K8s RBAC"]
    end

    subgraph AltMesh["ALTERNATIVE: SERVICE MESH (Istio)"]
        IstioSidecar["Istio Envoy Sidecar<br/>mTLS STRICT<br/>SPIFFE Identity<br/>AuthorizationPolicy"]
    end

    subgraph Container["APPLICATION CONTAINER (UID 2000)"]
        direction TB

        subgraph Ports["Exposed Ports"]
            HTTPPort["OpenAI HTTP API<br/>8000/TCP<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /health"]
            GRPCPort["TGIS gRPC API<br/>8033/TCP<br/>GenerationService"]
        end

        subgraph Runtime["Runtime"]
            Adapter["vllm_tgis_adapter<br/>(Entrypoint)"]
            Engine["vLLM Engine"]
        end

        HTTPPort --> Adapter
        GRPCPort --> Adapter
        Adapter --> Engine
    end

    subgraph Hardware["HARDWARE ACCELERATOR"]
        Spyre["IBM Spyre<br/>v1.2.1<br/>s390x / ppc64le / x86_64<br/>IBM-signed RPMs"]
    end

    subgraph BaseImage["BASE IMAGE (Build-time)"]
        RHAIIS["RHAIIS vllm-spyre-rhel9:3.2.2<br/>UBI/RHEL 9<br/>All runtime dependencies"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| KubeRBAC
    Client -.->|"HTTP or gRPC<br/>mTLS STRICT<br/>Service Identity"| IstioSidecar

    %% Proxy to container
    KubeRBAC -->|"HTTP/8000<br/>No encryption (pod-local)<br/>Pre-validated"| HTTPPort
    KubeRBAC -->|"gRPC/8033<br/>No encryption (pod-local)<br/>Pre-validated"| GRPCPort

    IstioSidecar -.->|"HTTP/8000<br/>mTLS<br/>Service Identity"| HTTPPort
    IstioSidecar -.->|"gRPC/8033<br/>mTLS<br/>Service Identity"| GRPCPort

    %% Hardware
    Engine -->|"Hardware interface<br/>Direct"| Spyre

    %% Base image
    RHAIIS -.->|"FROM (build-time)<br/>Provides all deps"| Container

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authproxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef mesh fill:#e6d5f5,stroke:#9673a6,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef baseimage fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KubeRBAC authproxy
    class IstioSidecar mesh
    class HTTPPort,GRPCPort,Adapter,Engine container
    class Spyre hardware
    class RHAIIS baseimage
