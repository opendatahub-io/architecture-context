graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External API Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["RHOAI Gateway / KServe Ingress<br/>443/TCP → 8000/TCP<br/>TLS 1.3 Termination<br/>AuthN: Platform-managed"]
    end

    subgraph InternalCluster["INTERNAL CLUSTER (KServe-Managed)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            KServeService["KServe Service (ClusterIP)<br/>8000/TCP, 8033/TCP"]

            subgraph VllmPod["vllm-spyre Pod"]
                direction TB
                VllmHTTP["OpenAI HTTP API<br/>Port 8000/TCP<br/>/v1/completions, /v1/chat/completions<br/>/v1/models, /health, /metrics"]
                VllmGRPC["TGIS gRPC API<br/>Port 8033/TCP<br/>GenerationService"]
                SpyreHW["IBM Spyre Accelerator<br/>PCIe Device Driver"]
            end

            KServeXformer["KServe Transformer/<br/>Predictor"]
        end

        Prometheus["Prometheus<br/>Metric Scraper"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["Model Storage (S3)<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        PVC["Model Storage (PVC)<br/>Filesystem Volume<br/>No network egress"]
        HuggingFace["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token<br/>(platform-managed)"| Gateway

    %% Ingress → Internal
    Gateway -->|"HTTP/8000<br/>No encryption<br/>(pod-internal)"| KServeService

    %% KServe Service → Container
    KServeService -->|"HTTP/8000"| VllmHTTP
    KServeService -->|"gRPC/8033"| VllmGRPC

    %% Internal KServe communication
    KServeXformer -->|"gRPC/8033<br/>Pod-internal"| VllmGRPC

    %% Container → Hardware
    VllmHTTP --> SpyreHW
    VllmGRPC --> SpyreHW

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>scrape /metrics"| VllmHTTP

    %% Egress
    VllmHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    VllmHTTP -->|"Volume mount<br/>Filesystem"| PVC
    VllmHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HuggingFace

    %% Container security note
    VllmPod -.- SecurityNote["UID 2000 (non-root)<br/>Base: rhaiis/vllm-spyre-rhel9:3.2.2<br/>No self-managed TLS or auth"]

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef note fill:#f5f5f5,stroke:#ccc,stroke-dasharray:5 5

    class Client external
    class Gateway ingress
    class KServeService,KServeXformer,Prometheus internal
    class VllmHTTP,VllmGRPC container
    class SpyreHW hardware
    class S3,PVC,HuggingFace externalservice
    class SecurityNote note
