graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Auth Enforcement Boundary)"]
        Ingress["KServe / Platform Ingress<br/>TLS Termination<br/>AuthN: OAuth / Bearer Token<br/>AuthZ: RBAC / Platform Policy<br/><i>kube-rbac-proxy | Gateway API | OAuth proxy</i>"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (In-Cluster Pod Network)"]
        direction TB

        subgraph VllmPod["vllm-spyre Container<br/>UID: 2000 (non-root)<br/>Base: RHAIIS vllm-spyre-rhel9:3.2.2"]
            HTTPApi["HTTP API (OpenAI-compat)<br/>Port 8000/TCP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models, /health<br/>Auth: NONE"]
            GRPCApi["gRPC API (TGIS)<br/>Port 8033/TCP<br/>GenerationService<br/>Auth: NONE"]
            VllmEngine["vLLM Engine<br/>(vllm_tgis_adapter)"]
            HTTPApi --> VllmEngine
            GRPCApi --> VllmEngine
        end

        subgraph HW["Hardware"]
            Spyre["IBM Spyre<br/>AI Accelerator<br/>Hardware Interface"]
        end
    end

    subgraph EgressTargets["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        HF["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        PVC["PVC / Local Storage<br/>Filesystem<br/>SA Permissions"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS (platform)<br/>Bearer Token / OAuth"| Ingress

    %% Ingress → Container (plaintext in-cluster)
    Ingress -->|"HTTP/8000<br/>Plaintext (in-cluster)<br/>Auth: pre-validated"| HTTPApi
    Ingress -->|"gRPC/8033<br/>Plaintext (in-cluster)<br/>Auth: pre-validated"| GRPCApi

    %% Engine → Hardware
    VllmEngine -->|"Hardware Interface<br/>PCIe / Device Driver"| Spyre

    %% Egress
    VllmEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    VllmEngine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    VllmEngine -->|"Filesystem<br/>Volume Mount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef hardware fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef unauthPort fill:#e6b8af,stroke:#cc0000,stroke-width:2px

    class Client external
    class Ingress ingress
    class VllmPod internal
    class HTTPApi,GRPCApi unauthPort
    class VllmEngine container
    class Spyre hardware
    class S3,HF,PVC egress
