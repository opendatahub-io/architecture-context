    subgraph ObservabilityResources["Observability Resources"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors"]
        PodMonitors["monitoring.coreos.com<br/>PodMonitors"]
        TriggerAuths["keda.sh<br/>TriggerAuthentications"]
    end

    subgraph RBACResources["RBAC Resources"]
        CRBs["rbac.authorization.k8s.io<br/>ClusterRoleBindings"]
        Roles["rbac.authorization.k8s.io<br/>Roles"]
        RoleBindings["rbac.authorization.k8s.io<br/>RoleBindings"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
        Kuadrants["kuadrant.io<br/>Kuadrants"]
        Authorinos["operator.authorino<br/>Authorinos"]
    end

    %% SA → CRB → CR bindings
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| CRB_Leader
    SA_Controller -->|bound via| CRB_Proxy
    SA_API -->|bound via| CRB_API
    SA_CM -->|bound via| CRB_Metrics

    CRB_Main -->|grants| CR_Main
    CRB_Leader -->|grants| CR_Leader
    CRB_Proxy -->|grants| CR_Proxy
    CRB_API -->|grants| CR_API
    CRB_Metrics -->|grants| CR_Metrics

    %% CR_Main → Resources
    CR_Main -->|"CRUD + watch"| ConfigMaps
    CR_Main -->|"CRUD + watch"| Secrets
    CR_Main -->|"CRUD + watch"| Services
    CR_Main -->|"CRUD + watch"| ServiceAccts
    CR_Main -->|"get,list,watch"| Endpoints
    CR_Main -->|"get,list,watch"| Namespaces
    CR_Main -->|"CRUD + watch"| Pods
    CR_Main -->|"create,patch"| Events

    CR_Main -->|"get,list,watch,<br/>patch,update"| ISVC
    CR_Main -->|"CRUD + watch"| LLMISVC
    CR_Main -->|"create,get,list,<br/>update,watch"| SR
    CR_Main -->|"get,list,watch"| IG
    CR_Main -->|"get,list,watch"| LLMConfig

    CR_Main -->|"CRUD + watch"| Routes
    CR_Main -->|"CRUD + watch"| Templates
    CR_Main -->|"get,list,watch,<br/>patch,update"| NIMAccounts
    CR_Main -->|"get,list,watch"| DSC
    CR_Main -->|"get,list,watch"| DSCI
    CR_Main -->|"get,list,watch"| OSAuth

    CR_Main -->|"get,list,watch,<br/>patch,update"| Gateways
    CR_Main -->|"get,list,watch"| HTTPRoutes
    CR_Main -->|"CRUD + watch"| EnvoyFilters
    CR_Main -->|"CRUD + watch"| AuthPolicies
    CR_Main -->|"CRUD + watch"| NetworkPolicies

    CR_Main -->|"CRUD + watch"| ServiceMonitors
    CR_Main -->|"CRUD + watch"| PodMonitors
    CR_Main -->|"CRUD + watch"| TriggerAuths

    CR_Main -->|"CRUD + watch"| CRBs
    CR_Main -->|"CRUD + watch"| Roles
    CR_Main -->|"CRUD + watch"| RoleBindings

    CR_Main -->|"get,list,watch"| Kuadrants
    CR_Main -->|"get,list,watch"| Authorinos

    %% CR_Leader → Resources
    CR_Leader -->|"CRUD + watch"| ConfigMaps
    CR_Leader -->|"CRUD + watch"| Events

    %% CR_Proxy → Resources
    CR_Proxy -->|"create"| TokenReviews
    CR_Proxy -->|"create"| SAR

    %% CR_API → Resources
    CR_API -->|"list"| Gateways
    CR_API -->|"get"| Namespaces

