graph TD
    subgraph "Service Accounts"
        SA_Controller["odh-model-controller<br/>(controller SA)"]
        SA_API["model-serving-api<br/>(API server SA)"]
        SA_Dynamic["{isvc}-sa<br/>(dynamic per InferenceService)"]
        SA_KEDA["inference-prometheus-auth<br/>(dynamic per namespace)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller["odh-model-controller-rolebinding-opendatahub<br/>(Cluster-scoped)"]
        CRB_API["model-serving-api<br/>(Cluster-scoped)"]
        CRB_AuthDelegator["{isvcNS}-{sa}-auth-delegator<br/>(Cluster-scoped, dynamic)"]
        RB_Leader["leader-election-rolebinding<br/>(Namespace-scoped)"]
        RB_KEDA["inference-prometheus-auth<br/>(Namespace-scoped, dynamic)"]
    end

    subgraph "ClusterRoles"
        CR_Controller["odh-model-controller-role"]
        CR_API["model-serving-api"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Leader["leader-election-role"]
    end

    subgraph "KServe Resources (serving.kserve.io)"
        InferenceService["InferenceService<br/>+ finalizers"]
        ServingRuntime["ServingRuntime<br/>+ finalizers"]
        InferenceGraph["InferenceGraph<br/>+ finalizers"]
        LLMInferenceService["LLMInferenceService<br/>+ status + finalizers"]
        LLMISVCConfig["LLMInferenceServiceConfig"]
    end

    subgraph "OpenShift Resources"
        Routes["route.openshift.io<br/>routes, routes/custom-host"]
        Templates["template.openshift.io<br/>templates"]
        Authentications["config.openshift.io<br/>authentications"]
    end

    subgraph "Networking & Security Resources"
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
        EnvoyFilters["networking.istio.io<br/>envoyfilters"]
        AuthPolicies["kuadrant.io<br/>authpolicies + status"]
        Kuadrants["kuadrant.io<br/>kuadrants"]
        Authorinos["operator.authorino.kuadrant.io<br/>authorinos"]
        Gateways["gateway.networking.k8s.io<br/>gateways + finalizers"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
    end

    subgraph "Monitoring Resources"
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
        PodMonitors["monitoring.coreos.com<br/>podmonitors"]
        MetricsAPI["metrics.k8s.io<br/>pods, nodes"]
    end

    subgraph "Core Resources"
        CoreRW["core: namespaces, pods,<br/>endpoints, secrets, configmaps,<br/>serviceaccounts, services, events"]
    end

    subgraph "Platform Resources"
        DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations"]
        KEDA_TA["keda.sh<br/>triggerauthentications"]
        NIM_Accounts["nim.opendatahub.io<br/>accounts + status + finalizers"]
    end

    subgraph "RBAC Resources"
        RBACResources["rbac.authorization.k8s.io<br/>clusterrolebindings, roles,<br/>rolebindings"]
    end

    %% SA → Binding → Role chain
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Leader
    CRB_Controller -->|grants| CR_Controller
    RB_Leader -->|grants| CR_Leader

    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API

    SA_Dynamic -->|bound via| CRB_AuthDelegator
    CRB_AuthDelegator -->|grants| CR_AuthDelegator

    SA_KEDA -->|bound via| RB_KEDA

    %% Controller Role → Resources (full CRUD)
    CR_Controller -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| InferenceService
    CR_Controller -->|"get,list,watch,<br/>create,update"| ServingRuntime
    CR_Controller -->|"get,list,watch,<br/>update"| InferenceGraph
    CR_Controller -->|"get,list,watch,<br/>update,patch,post"| LLMInferenceService
    CR_Controller -->|"get,list,watch"| LLMISVCConfig
    CR_Controller -->|"full CRUD"| Routes
    CR_Controller -->|"full CRUD"| Templates
    CR_Controller -->|"get,list,watch"| Authentications
    CR_Controller -->|"full CRUD"| NetworkPolicies
    CR_Controller -->|"full CRUD"| EnvoyFilters
    CR_Controller -->|"full CRUD"| AuthPolicies
    CR_Controller -->|"full CRUD"| Kuadrants
    CR_Controller -->|"get,list,watch"| Authorinos
    CR_Controller -->|"get,list,watch,<br/>update,patch"| Gateways
    CR_Controller -->|"get,list,watch,<br/>update,patch"| HTTPRoutes
    CR_Controller -->|"full CRUD"| ServiceMonitors
    CR_Controller -->|"full CRUD"| PodMonitors
    CR_Controller -->|"get,list,watch"| MetricsAPI
    CR_Controller -->|"full CRUD"| CoreRW
    CR_Controller -->|"get,list,watch"| DSC
    CR_Controller -->|"get,list,watch"| DSCI
    CR_Controller -->|"full CRUD"| KEDA_TA
    CR_Controller -->|"get,list,watch,<br/>update,patch"| NIM_Accounts
    CR_Controller -->|"full CRUD"| RBACResources

    %% API Role → Resources (minimal)
    CR_API -->|"list"| Gateways
    CR_API -->|"get"| CoreRW

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dynamic fill:#4a90e2,stroke:#333,color:#fff
    style SA_KEDA fill:#4a90e2,stroke:#333,color:#fff
    style CR_Controller fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style CR_AuthDelegator fill:#f5a623,stroke:#333
    style CR_Leader fill:#f5a623,stroke:#333
    style InferenceService fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style InferenceGraph fill:#7ed321,stroke:#333
    style LLMInferenceService fill:#7ed321,stroke:#333
    style LLMISVCConfig fill:#7ed321,stroke:#333
    style NIM_Accounts fill:#7ed321,stroke:#333
