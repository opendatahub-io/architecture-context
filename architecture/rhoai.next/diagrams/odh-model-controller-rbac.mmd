graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_OMC["odh-model-controller<br/>(operator namespace)"]
        SA_MSA["model-serving-api<br/>(operator namespace)"]
        SA_Dynamic["Per-ISVC ServiceAccount<br/>(user namespace, dynamic)"]
        SA_Prom["inference-prometheus-auth<br/>(user namespace, dynamic)"]
    end

    subgraph Bindings["Role/ClusterRole Bindings"]
        CRB_OMC["odh-model-controller-rolebinding<br/><i>ClusterRoleBinding</i>"]
        CRB_MSA["model-serving-api-binding<br/><i>ClusterRoleBinding</i>"]
        RB_Leader["leader-election-rolebinding<br/><i>RoleBinding (operator ns)</i>"]
        CRB_AuthDel["{ns}-{sa}-auth-delegator<br/><i>ClusterRoleBinding (dynamic)</i>"]
        RB_Prom["inference-prometheus-auth<br/><i>RoleBinding (user ns, dynamic)</i>"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_OMC["odh-model-controller-role<br/><i>ClusterRole</i>"]
        CR_MSA["model-serving-api<br/><i>ClusterRole</i>"]
        CR_Leader["leader-election-role<br/><i>Role (operator ns)</i>"]
        CR_AuthDel["system:auth-delegator<br/><i>ClusterRole (built-in)</i>"]
        CR_Prom["inference-prometheus-auth<br/><i>Role (user ns)</i>"]
    end

    %% SA → Binding → Role
    SA_OMC -->|bound via| CRB_OMC
    CRB_OMC -->|grants| CR_OMC
    SA_OMC -->|bound via| RB_Leader
    RB_Leader -->|grants| CR_Leader

    SA_MSA -->|bound via| CRB_MSA
    CRB_MSA -->|grants| CR_MSA

    SA_Dynamic -->|bound via| CRB_AuthDel
    CRB_AuthDel -->|grants| CR_AuthDel

    SA_Prom -->|bound via| RB_Prom
    RB_Prom -->|grants| CR_Prom

    subgraph Resources_OMC["odh-model-controller-role Permissions"]
        direction TB

        subgraph Core["Core API ('')"]
            R_CM["configmaps<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            R_Sec["secrets<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            R_SA["serviceaccounts<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            R_Svc["services<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            R_EP["endpoints<br/><i>create,get,list,<br/>patch,update,watch</i>"]
            R_NS["namespaces<br/><i>create,get,list,<br/>patch,update,watch</i>"]
            R_Pod["pods<br/><i>create,get,list,<br/>patch,update,watch</i>"]
            R_Evt["events<br/><i>create,patch</i>"]
        end

        subgraph KServeAPIs["serving.kserve.io"]
            R_ISVC["inferenceservices<br/><i>get,list,patch,update,watch</i>"]
            R_LLMISVC["llminferenceservices<br/><i>get,list,patch,post,<br/>update,watch</i>"]
            R_SR["servingruntimes<br/><i>create,get,list,<br/>update,watch</i>"]
            R_IG["inferencegraphs<br/><i>get,list,watch</i>"]
        end

        subgraph AuthAPIs["Auth & Gateway APIs"]
            R_AP["kuadrant.io/authpolicies<br/><i>full CRUD + status</i>"]
            R_EF["networking.istio.io/envoyfilters<br/><i>full CRUD</i>"]
            R_GW["gateway.networking.k8s.io/gateways<br/><i>get,list,patch,update,watch</i>"]
            R_HR["gateway.networking.k8s.io/httproutes<br/><i>get,list,watch</i>"]
        end

        subgraph MonitorAPIs["Monitoring & Scaling"]
            R_SM["monitoring.coreos.com/servicemonitors<br/><i>full CRUD</i>"]
            R_PM["monitoring.coreos.com/podmonitors<br/><i>full CRUD</i>"]
            R_TA["keda.sh/triggerauthentications<br/><i>full CRUD</i>"]
        end

        subgraph PlatformAPIs["Platform APIs"]
            R_Route["route.openshift.io/routes<br/><i>full CRUD + custom-host</i>"]
            R_Tmpl["template.openshift.io/templates<br/><i>full CRUD</i>"]
            R_NIM["nim.opendatahub.io/accounts<br/><i>get,list,patch,update,watch<br/>+ finalizers, status</i>"]
            R_DSC["datasciencecluster.opendatahub.io<br/><i>get,list,watch</i>"]
            R_DSCI["dscinitialization.opendatahub.io<br/><i>get,list,watch</i>"]
        end

        subgraph RBACAPIs["RBAC APIs"]
            R_CRB["clusterrolebindings<br/><i>full CRUD</i>"]
            R_RB["rolebindings<br/><i>full CRUD</i>"]
            R_Roles["roles<br/><i>full CRUD</i>"]
        end
    end

    CR_OMC -->|permissions| Resources_OMC

    subgraph Resources_MSA["model-serving-api Permissions"]
        R_GWList["gateway.networking.k8s.io/gateways<br/><i>list</i>"]
        R_NSGet["namespaces<br/><i>get</i>"]
        R_SSAR["+ SelfSubjectAccessReview<br/><i>(via user Bearer token impersonation)</i>"]
    end

    CR_MSA -->|permissions| Resources_MSA

    %% Styling
    style SA_OMC fill:#4a90e2,stroke:#333,color:#fff
    style SA_MSA fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dynamic fill:#4a90e2,stroke:#333,color:#fff
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff

    style CR_OMC fill:#f5a623,stroke:#333,color:#fff
    style CR_MSA fill:#f5a623,stroke:#333,color:#fff
    style CR_Leader fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDel fill:#f5a623,stroke:#333,color:#fff
    style CR_Prom fill:#f5a623,stroke:#333,color:#fff

    style CRB_OMC fill:#b8d4e3,stroke:#333
    style CRB_MSA fill:#b8d4e3,stroke:#333
    style RB_Leader fill:#b8d4e3,stroke:#333
    style CRB_AuthDel fill:#b8d4e3,stroke:#333
    style RB_Prom fill:#b8d4e3,stroke:#333
