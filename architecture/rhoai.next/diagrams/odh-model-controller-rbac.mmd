graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["odh-model-controller<br/>(controller SA)"]
        SA_API["model-serving-api<br/>(API server SA)"]
        SA_CM["controller-manager<br/>(metrics SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["odh-model-controller-<br/>rolebinding-opendatahub"]
        CRB_Leader["leader-election-<br/>rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_API["model-serving-api<br/>binding"]
        CRB_Metrics["metrics-auth-<br/>rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["odh-model-controller-role"]
