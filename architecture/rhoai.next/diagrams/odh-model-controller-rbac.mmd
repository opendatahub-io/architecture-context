graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["odh-model-controller<br/>(controller SA)"]
        SA_API["model-serving-api<br/>(API server SA)"]
        SA_Dynamic["{ns}-{sa}<br/>(per-InferenceService SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["odh-model-controller-rolebinding<br/>(cluster-wide)"]
        CRB_API["model-serving-api<br/>(cluster-wide)"]
        CRB_Dynamic["{ns}-{sa}-auth-delegator<br/>(cluster-wide, dynamic)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["odh-model-controller-role"]
        CR_API["model-serving-api"]
        CR_AuthDelegator["system:auth-delegator"]
    end

    subgraph ControllerPermissions["odh-model-controller-role Permissions"]
        direction TB

        subgraph CoreAPI["Core API ('')"]
            CoreRW["configmaps, secrets,<br/>serviceaccounts, services<br/>create,delete,get,list,<br/>patch,update,watch"]
            CoreRW2["endpoints, namespaces, pods<br/>create,get,list,<br/>patch,update,watch"]
            CoreEvents["events<br/>create,patch"]
        end

        subgraph OpenShiftAPI["OpenShift APIs"]
            AuthCfg["config.openshift.io<br/>authentications<br/>get,list,watch"]
            RoutesAPI["route.openshift.io<br/>routes, routes/custom-host<br/>full CRUD"]
            TemplatesAPI["template.openshift.io<br/>templates<br/>full CRUD"]
        end

        subgraph ODHAPI["ODH / KServe APIs"]
            DSC_API["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get,list,watch"]
            DSCI_API["dscinitialization.opendatahub.io<br/>dscinitializations<br/>get,list,watch"]
            ISVC_API["serving.kserve.io<br/>inferenceservices (+finalizers)<br/>full CRUD"]
            LLMISVC_API["serving.kserve.io<br/>llminferenceservices<br/>(+status,finalizers)<br/>get,list,patch,post,<br/>update,watch"]
            IG_API["serving.kserve.io<br/>inferencegraphs (+finalizers)<br/>servingruntimes/finalizers<br/>get,list,update,watch"]
            SR_API["serving.kserve.io<br/>llminferenceserviceconfigs,<br/>servingruntimes<br/>get,list,watch,create,update"]
            NIM_API["nim.opendatahub.io<br/>accounts (+finalizers,status)<br/>get,list,patch,update,watch"]
        end

        subgraph NetworkAPI["Network / Mesh APIs"]
            GW_API["gateway.networking.k8s.io<br/>gateways (+finalizers)<br/>get,list,patch,update,watch"]
            HR_API["gateway.networking.k8s.io<br/>httproutes<br/>get,list,watch"]
            Envoy_API["networking.istio.io<br/>envoyfilters<br/>full CRUD"]
            NetPol_API["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
        end

        subgraph AuthAPI["Auth / Policy APIs"]
            Kuadrant_API["kuadrant.io<br/>authpolicies (+status)<br/>full CRUD"]
            KuadrantRead["kuadrant.io<br/>kuadrants<br/>get,list,watch"]
            AuthorinoRead["operator.authorino.kuadrant.io<br/>authorinos<br/>get,list,watch"]
            RBAC_API["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/>full CRUD"]
        end

        subgraph MonitoringAPI["Monitoring APIs"]
            Monitor_API["monitoring.coreos.com<br/>podmonitors, servicemonitors<br/>full CRUD"]
            Metrics_API["metrics.k8s.io<br/>nodes, pods<br/>get,list,watch"]
            KEDA_API["keda.sh<br/>triggerauthentications<br/>full CRUD"]
        end
    end

    subgraph APIPermissions["model-serving-api Permissions"]
        GW_List["gateway.networking.k8s.io<br/>gateways<br/>list"]
        NS_Get["Core API<br/>namespaces<br/>get"]
    end

    subgraph AuthDelegatorPerms["system:auth-delegator Permissions"]
        AuthDeleg["authentication.k8s.io<br/>tokenreviews<br/>create"]
        AuthDeleg2["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Controller
    CR_Controller --- ControllerPermissions

    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API
    CR_API --- APIPermissions

    SA_Dynamic -->|bound via| CRB_Dynamic
    CRB_Dynamic -->|grants| CR_AuthDelegator
    CR_AuthDelegator --- AuthDelegatorPerms

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dynamic fill:#4a90e2,stroke:#333,stroke-dasharray:5,color:#fff

    style CRB_Controller fill:#f5a623,stroke:#333,color:#fff
    style CRB_API fill:#f5a623,stroke:#333,color:#fff
    style CRB_Dynamic fill:#f5a623,stroke:#333,stroke-dasharray:5,color:#fff

    style CR_Controller fill:#e57373,stroke:#333,color:#fff
    style CR_API fill:#e57373,stroke:#333,color:#fff
    style CR_AuthDelegator fill:#e57373,stroke:#333,color:#fff
