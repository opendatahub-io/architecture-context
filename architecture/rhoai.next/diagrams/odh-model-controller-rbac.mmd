graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_OMC["odh-model-controller<br/>(operator)"]
        SA_MSA["model-serving-api<br/>(API server)"]
        SA_DYN["Per-ISVC ServiceAccount<br/>(dynamic)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_OMC["odh-model-controller-<br/>rolebinding<br/>(Cluster)"]
        CRB_MSA["model-serving-api-<br/>binding<br/>(Cluster)"]
        CRB_DYN["{ns}-{sa}-auth-delegator<br/>(Cluster, dynamic)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_LE["leader-election-<br/>rolebinding<br/>(operator ns)"]
        RB_PROM["inference-prometheus-<br/>auth<br/>(user ns, dynamic)"]
    end

    subgraph CR_OMC_Role["ClusterRole: odh-model-controller-role"]
        direction LR
        subgraph Core["Core API"]
            CoreRes["configmaps, secrets,<br/>serviceaccounts, services<br/>endpoints, namespaces,<br/>pods, events"]
        end
        subgraph Serving["serving.kserve.io"]
            ServingRes["inferenceservices<br/>llminferenceservices<br/>servingruntimes<br/>inferencegraphs<br/>llminferenceserviceconfigs"]
        end
        subgraph GW["gateway.networking.k8s.io"]
            GWRes["gateways<br/>gateways/finalizers<br/>httproutes"]
        end
        subgraph Auth["kuadrant.io"]
            AuthRes["authpolicies<br/>authpolicies/status<br/>kuadrants"]
        end
        subgraph Network["networking.istio.io /<br/>networking.k8s.io"]
            NetRes["envoyfilters<br/>networkpolicies"]
        end
        subgraph Monitor["monitoring.coreos.com"]
            MonRes["podmonitors<br/>servicemonitors"]
        end
        subgraph NIM["nim.opendatahub.io"]
            NIMRes["accounts<br/>accounts/finalizers<br/>accounts/status"]
        end
        subgraph RBAC_Res["rbac.authorization.k8s.io"]
            RBACRes["clusterrolebindings<br/>rolebindings<br/>roles"]
        end
        subgraph OCP["OpenShift APIs"]
            OCPRes["routes, routes/custom-host<br/>templates<br/>authentications<br/>datascienceclusters<br/>dscinitializations"]
        end
        subgraph Scaling["keda.sh / metrics.k8s.io"]
            ScaleRes["triggerauthentications<br/>nodes, pods (metrics)"]
        end
    end

    subgraph CR_MSA_Role["ClusterRole: model-serving-api"]
        MSA_Perm["gateway.networking.k8s.io: gateways → list<br/>core: namespaces → get"]
    end

    subgraph CR_LE_Role["Role: leader-election-role"]
        LE_Perm["core: configmaps → get, list, watch,<br/>create, update, patch, delete<br/>coordination.k8s.io: leases → same"]
    end

    subgraph CR_AuthDel["ClusterRole: system:auth-delegator"]
        AuthDel_Perm["authentication.k8s.io:<br/>tokenreviews → create<br/>authorization.k8s.io:<br/>subjectaccessreviews → create"]
    end

    %% Bindings
    SA_OMC -->|bound via| CRB_OMC
    SA_OMC -->|bound via| RB_LE
    SA_MSA -->|bound via| CRB_MSA
    SA_DYN -->|bound via| CRB_DYN

    CRB_OMC -->|grants| CR_OMC_Role
    CRB_MSA -->|grants| CR_MSA_Role
    RB_LE -->|grants| CR_LE_Role
    CRB_DYN -->|grants| CR_AuthDel

    %% Styling
    style SA_OMC fill:#4a90e2,stroke:#333,color:#fff
    style SA_MSA fill:#4a90e2,stroke:#333,color:#fff
    style SA_DYN fill:#4a90e2,stroke:#333,color:#fff

    style CRB_OMC fill:#f5a623,stroke:#333
    style CRB_MSA fill:#f5a623,stroke:#333
    style CRB_DYN fill:#f5a623,stroke:#333
    style RB_LE fill:#ffcc80,stroke:#333
    style RB_PROM fill:#ffcc80,stroke:#333

    style CoreRes fill:#c8e6c9,stroke:#2e7d32
    style ServingRes fill:#c8e6c9,stroke:#2e7d32
    style GWRes fill:#c8e6c9,stroke:#2e7d32
    style AuthRes fill:#c8e6c9,stroke:#2e7d32
    style NetRes fill:#c8e6c9,stroke:#2e7d32
    style MonRes fill:#c8e6c9,stroke:#2e7d32
    style NIMRes fill:#c8e6c9,stroke:#2e7d32
    style RBACRes fill:#c8e6c9,stroke:#2e7d32
    style OCPRes fill:#c8e6c9,stroke:#2e7d32
    style ScaleRes fill:#c8e6c9,stroke:#2e7d32
    style MSA_Perm fill:#c8e6c9,stroke:#2e7d32
    style LE_Perm fill:#c8e6c9,stroke:#2e7d32
    style AuthDel_Perm fill:#c8e6c9,stroke:#2e7d32
