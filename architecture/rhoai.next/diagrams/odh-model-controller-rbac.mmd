        CR_Proxy["proxy-role"]
        CR_API["model-serving-api"]
        CR_Metrics["metrics-auth-role"]
        CR_Prom["kserve-prometheus-k8s"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>ConfigMaps"]
        Secrets["core<br/>Secrets"]
        Services["core<br/>Services"]
        ServiceAccts["core<br/>ServiceAccounts"]
        Endpoints["core<br/>Endpoints"]
        Namespaces["core<br/>Namespaces"]
        Pods["core<br/>Pods"]
        Events["core<br/>Events"]
    end

    subgraph KServeResources["KServe API Resources"]
        ISVC["serving.kserve.io<br/>InferenceServices"]
        LLMISVC["serving.kserve.io<br/>LLMInferenceServices"]
        SR["serving.kserve.io<br/>ServingRuntimes"]
        IG["serving.kserve.io<br/>InferenceGraphs"]
        LLMConfig["serving.kserve.io<br/>LLMInferenceServiceConfigs"]
    end

    subgraph PlatformResources["Platform API Resources"]
        Routes["route.openshift.io<br/>Routes"]
        Templates["template.openshift.io<br/>Templates"]
        NIMAccounts["nim.opendatahub.io<br/>Accounts"]
        DSC["datasciencecluster<br/>DataScienceClusters"]
        DSCI["dscinitialization<br/>DSCInitializations"]
        OSAuth["config.openshift.io<br/>Authentications"]
    end

    subgraph NetworkResources["Network / Mesh Resources"]
        Gateways["gateway.networking.k8s.io<br/>Gateways"]
