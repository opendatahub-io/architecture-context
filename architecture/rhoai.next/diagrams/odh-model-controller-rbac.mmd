graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Ctrl["odh-model-controller<br/>(operator namespace)"]
        SA_API["model-serving-api<br/>(operator namespace)"]
        SA_ISVC["per-ISVC ServiceAccount<br/>(user namespace, dynamic)"]
        SA_Prom["inference-prometheus-auth<br/>(user namespace, dynamic)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Ctrl["odh-model-controller-rolebinding<br/>(Cluster)"]
        CRB_API["model-serving-api-binding<br/>(Cluster)"]
        CRB_AuthDel["{ns}-{sa}-auth-delegator<br/>(Cluster, dynamic per ISVC)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Prom["inference-prometheus-auth<br/>(user namespace, dynamic)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Ctrl["odh-model-controller-role"]
        CR_API["model-serving-api"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
        R_Prom["inference-prometheus-auth"]
    end

    subgraph CoreAPI["Core API Resources"]
        ConfigMaps["configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Secrets["secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        ServiceAccts["serviceaccounts<br/>create,delete,get,list,<br/>patch,update,watch"]
        Services_R["services<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["endpoints<br/>create,get,list,<br/>patch,update,watch"]
        Namespaces["namespaces<br/>create,get,list,<br/>patch,update,watch"]
        Pods["pods<br/>create,get,list,<br/>patch,update,watch"]
        Events["events<br/>create,patch"]
    end

    subgraph KServeAPI["KServe API Resources (serving.kserve.io)"]
        ISVC_R["inferenceservices<br/>+ finalizers<br/>get,list,patch,update,watch"]
        LLMISVC_R["llminferenceservices<br/>+ finalizers, status<br/>get,list,patch,post,update,watch"]
        SR_R["servingruntimes<br/>create,get,list,update,watch"]
        IG_R["inferencegraphs<br/>get,list,watch"]
        LLMConfig["llminferenceserviceconfigs<br/>get,list,watch"]
    end

    subgraph GatewayAPI_R["Gateway API Resources"]
        Gateways_R["gateways + finalizers<br/>get,list,patch,update,watch"]
        HTTPRoutes_R["httproutes<br/>get,list,watch"]
    end

    subgraph AuthResources["Auth & Mesh Resources"]
        AuthPolicy["kuadrant.io/authpolicies<br/>+ status<br/>full CRUD + watch"]
        Kuadrants["kuadrant.io/kuadrants<br/>get,list,watch"]
        Authorinos["authorinos<br/>get,list,watch"]
        EnvoyFilters["networking.istio.io/envoyfilters<br/>full CRUD + watch"]
        NetworkPolicies["networking.k8s.io/networkpolicies<br/>full CRUD + watch"]
    end

    subgraph MonitorResources["Monitoring & Scaling Resources"]
        SvcMonitors["monitoring.coreos.com/<br/>servicemonitors<br/>full CRUD + watch"]
        PodMonitors["monitoring.coreos.com/<br/>podmonitors<br/>full CRUD + watch"]
        TrigAuth_R["keda.sh/<br/>triggerauthentications<br/>full CRUD + watch"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        Routes_R["route.openshift.io/routes<br/>+ custom-host<br/>full CRUD + watch"]
        Templates_R["template.openshift.io/templates<br/>full CRUD + watch"]
        OSAuth["config.openshift.io/<br/>authentications<br/>get,list,watch"]
    end

    subgraph PlatformResources["Platform Resources"]
        DSC["datascienceclusters<br/>get,list,watch"]
        DSCI["dscinitializations<br/>get,list,watch"]
        NIMAcct["nim.opendatahub.io/accounts<br/>+ finalizers, status<br/>get,list,patch,update,watch"]
        RBAC_R["rbac.authorization.k8s.io/<br/>clusterrolebindings,<br/>rolebindings, roles<br/>full CRUD + watch"]
    end

    subgraph APIServerResources["model-serving-api Resources"]
        GW_List["gateway.networking.k8s.io/<br/>gateways<br/>list"]
        NS_Get["namespaces<br/>get"]
    end

    %% Controller SA bindings
    SA_Ctrl -->|bound via| CRB_Ctrl
    CRB_Ctrl -->|grants| CR_Ctrl
    SA_Ctrl -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% API Server SA bindings
    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API

    %% Dynamic per-ISVC bindings
    SA_ISVC -->|bound via| CRB_AuthDel
    CRB_AuthDel -->|grants| CR_AuthDel
    SA_Prom -->|bound via| RB_Prom
    RB_Prom -->|grants| R_Prom

    %% Controller role → resources
    CR_Ctrl -->|manages| CoreAPI
    CR_Ctrl -->|manages| KServeAPI
    CR_Ctrl -->|manages| GatewayAPI_R
    CR_Ctrl -->|manages| AuthResources
    CR_Ctrl -->|manages| MonitorResources
    CR_Ctrl -->|manages| OpenShiftResources
    CR_Ctrl -->|manages| PlatformResources

    %% API Server role → resources
    CR_API -->|reads| APIServerResources

    %% Styling
    style SA_Ctrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_ISVC fill:#4a90e2,stroke:#333,color:#fff
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff

    style CR_Ctrl fill:#f5a623,stroke:#333,color:#fff
    style CR_API fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDel fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333
    style R_Prom fill:#f5a623,stroke:#333

    style CRB_Ctrl fill:#d4edda,stroke:#333
    style CRB_API fill:#d4edda,stroke:#333
    style CRB_AuthDel fill:#d4edda,stroke:#333
    style RB_Leader fill:#d4edda,stroke:#333
    style RB_Prom fill:#d4edda,stroke:#333
