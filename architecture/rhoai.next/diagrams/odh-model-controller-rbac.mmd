graph TD
    subgraph "Service Accounts"
        SA_Ctrl["odh-model-controller<br/>(controller SA)"]
        SA_API["model-serving-api<br/>(API server SA)"]
        SA_CM["controller-manager<br/>(metrics auth SA)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Main["odh-model-controller-<br/>rolebinding-opendatahub<br/>(cluster-wide)"]
        CRB_Proxy["proxy-rolebinding<br/>(cluster-wide)"]
        CRB_Leader["leader-election-<br/>rolebinding<br/>(namespace-scoped)"]
        CRB_API["model-serving-api<br/>(cluster-wide)"]
        CRB_Metrics["metrics-auth-<br/>rolebinding<br/>(cluster-wide)"]
    end

    subgraph "ClusterRoles"
        CR_Main["odh-model-controller-role"]
        CR_Proxy["proxy-role"]
        CR_Leader["leader-election-role"]
        CR_API["model-serving-api"]
        CR_Prom["kserve-prometheus-k8s"]
        CR_Metrics["metrics-auth-role"]
    end

    subgraph "API Resources - Core"
        Core_CM["core<br/>configmaps"]
        Core_Sec["core<br/>secrets"]
        Core_SA["core<br/>serviceaccounts"]
        Core_Svc["core<br/>services"]
        Core_EP["core<br/>endpoints"]
        Core_NS["core<br/>namespaces"]
        Core_Pod["core<br/>pods"]
        Core_Evt["core<br/>events"]
    end

    subgraph "API Resources - KServe"
        KS_ISVC["serving.kserve.io<br/>inferenceservices<br/>+ finalizers"]
        KS_LLMISVC["serving.kserve.io<br/>llminferenceservices<br/>+ finalizers, status"]
        KS_SR["serving.kserve.io<br/>servingruntimes<br/>+ finalizers"]
        KS_IG["serving.kserve.io<br/>inferencegraphs<br/>+ finalizers"]
        KS_LLMCfg["serving.kserve.io<br/>llminference-<br/>serviceconfigs"]
    end

    subgraph "API Resources - Gateway/Network"
        GW["gateway.networking.k8s.io<br/>gateways + finalizers"]
        HR["gateway.networking.k8s.io<br/>httproutes"]
        EF["networking.istio.io<br/>envoyfilters"]
        NP["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph "API Resources - Auth/Monitoring"
        AP["kuadrant.io<br/>authpolicies + status"]
        KQ["kuadrant.io<br/>kuadrants"]
        SM["monitoring.coreos.com<br/>servicemonitors"]
        PM["monitoring.coreos.com<br/>podmonitors"]
        TA["keda.sh<br/>triggerauthentications"]
        AU["operator.authorino.kuadrant.io<br/>authorinos"]
    end

    subgraph "API Resources - Platform"
        NIM["nim.opendatahub.io<br/>accounts + finalizers<br/>+ status"]
        DSC["datasciencecluster.<br/>opendatahub.io<br/>datascienceclusters"]
        DSCI["dscinitialization.<br/>opendatahub.io<br/>dscinitializations"]
        OA["config.openshift.io<br/>authentications"]
        Route["route.openshift.io<br/>routes + custom-host"]
        Tmpl["template.openshift.io<br/>templates"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>roles, rolebindings"]
    end

    %% Service Account → Binding → Role chains
    SA_Ctrl -->|bound via| CRB_Main
    SA_Ctrl -->|bound via| CRB_Proxy
    SA_Ctrl -->|bound via| CRB_Leader
    SA_API -->|bound via| CRB_API
    SA_CM -->|bound via| CRB_Metrics

    CRB_Main -->|grants| CR_Main
    CRB_Proxy -->|grants| CR_Proxy
    CRB_Leader -->|grants| CR_Leader
    CRB_API -->|grants| CR_API
    CRB_Metrics -->|grants| CR_Metrics

    %% Main role permissions
    CR_Main -->|"CRUD + watch"| Core_CM
    CR_Main -->|"CRUD + watch"| Core_Sec
    CR_Main -->|"CRUD + watch"| Core_SA
    CR_Main -->|"CRUD + watch"| Core_Svc
    CR_Main -->|"get,list,watch"| Core_EP
    CR_Main -->|"get,list,watch"| Core_NS
    CR_Main -->|"get,list,watch"| Core_Pod
    CR_Main -->|"create,patch"| Core_Evt
    CR_Main -->|"CRUD + watch"| KS_ISVC
    CR_Main -->|"CRUD + watch"| KS_LLMISVC
    CR_Main -->|"CRUD + watch"| KS_SR
    CR_Main -->|"get,list,watch"| KS_IG
    CR_Main -->|"get,list,watch"| KS_LLMCfg
    CR_Main -->|"CRUD + watch"| GW
    CR_Main -->|"get,list,watch"| HR
    CR_Main -->|"CRUD + watch"| EF
    CR_Main -->|"CRUD + watch"| NP
    CR_Main -->|"CRUD + watch"| AP
    CR_Main -->|"get,list,watch"| KQ
    CR_Main -->|"CRUD + watch"| SM
    CR_Main -->|"CRUD + watch"| PM
    CR_Main -->|"CRUD + watch"| TA
    CR_Main -->|"get,list,watch"| AU
    CR_Main -->|"CRUD + watch"| NIM
    CR_Main -->|"get,list,watch"| DSC
    CR_Main -->|"get,list,watch"| DSCI
    CR_Main -->|"get,list,watch"| OA
    CR_Main -->|"CRUD + watch"| Route
    CR_Main -->|"CRUD + watch"| Tmpl
    CR_Main -->|"CRUD + watch"| RBAC_Res

    %% API server role
    CR_API -->|"list"| GW
    CR_API -->|"get"| Core_NS

