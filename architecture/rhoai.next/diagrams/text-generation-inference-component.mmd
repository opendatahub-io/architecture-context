graph TB
    subgraph "TGIS Container (Single Pod)"
        direction TB

        subgraph "Process: Launcher"
            Launcher["text-generation-launcher<br/>(Rust CLI Binary)<br/>PID 1 / Supervisor"]
        end

        subgraph "Process: Router"
            Router["text-generation-router<br/>(Rust Service Binary)<br/>gRPC :8033 | HTTP :3000"]
            Batcher["Batching Engine<br/>Weight-aware queue"]
            Validator["Request Validator<br/>temp, top_k, top_p, lengths"]
            Router --> Batcher
            Router --> Validator
        end

        subgraph "Process: Shard(s)"
            Shard0["text-generation-server<br/>(Python gRPC - Shard 0)<br/>UDS /tmp/text-generation-server-0"]
            Shard1["text-generation-server<br/>(Python gRPC - Shard N)<br/>UDS /tmp/text-generation-server-N"]
            Shard0 ---|"NCCL/GLOO<br/>29500/TCP"| Shard1
        end

        Launcher -->|"spawns + monitors"| Router
        Launcher -->|"spawns per-GPU"| Shard0
        Launcher -->|"spawns per-GPU"| Shard1
        Batcher -->|"gRPC via UDS<br/>Prefill, NextToken"| Shard0
        Batcher -->|"gRPC via UDS<br/>Prefill, NextToken"| Shard1
    end

    Client[External Client] -->|"gRPC :8033<br/>fmaas.GenerationService<br/>Optional TLS"| Router
    Prometheus[Prometheus] -->|"HTTP GET :3000<br/>/metrics"| Router
    K8sProbes["K8s Probes<br/>liveness/readiness"] -->|"HTTP GET :3000<br/>/health"| Router

    KServe["KServe<br/>ServingRuntime"] -->|"manages lifecycle"| Launcher
    GPU["NVIDIA GPU<br/>CUDA 12.1"] -->|"compute"| Shard0
    GPU -->|"compute"| Shard1
    Shard0 -->|"HTTPS :443<br/>model download"| HFHub["HuggingFace Hub"]
    ModelPVC["Shared PVC<br/>models-pvc"] -->|"volume mount<br/>/shared_model_storage"| Shard0

    style Launcher fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style Router fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Batcher fill:#5dade2,stroke:#333,stroke-width:1px
    style Validator fill:#5dade2,stroke:#333,stroke-width:1px
    style Shard0 fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style Shard1 fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Prometheus fill:#f9f9f9,stroke:#999,stroke-width:2px
    style K8sProbes fill:#f9f9f9,stroke:#999,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style GPU fill:#f5a623,stroke:#333,stroke-width:2px
    style HFHub fill:#f5a623,stroke:#333,stroke-width:2px
    style ModelPVC fill:#f5a623,stroke:#333,stroke-width:2px
