graph TB
    subgraph TGIS["Text Generation Inference Server (TGIS)"]
        direction TB

        subgraph Launcher["text-generation-launcher (Rust)"]
            LauncherProc["Launcher Process<br/>Process supervisor<br/>Signal propagation<br/>Health polling"]
        end

        subgraph Router["text-generation-router (Rust)"]
            direction LR
            GRPCServer["gRPC Server<br/>8033/TCP<br/>fmaas.GenerationService"]
            HTTPServer["HTTP Server<br/>3000/TCP<br/>/health, /metrics"]
            Validation["Request Validation<br/>+ Tokenization"]
            Batcher["Continuous Batcher<br/>Dynamic batch formation<br/>Queue jumping<br/>Prefill weight limits"]
            TLSTermination["TLS Termination<br/>rustls / OpenSSL<br/>Optional mTLS"]
        end

        subgraph Client["text-generation-client (Rust)"]
            GRPCClient["gRPC Client<br/>UDS Communication"]
        end

        subgraph Shards["text-generation-server (Python)"]
            direction LR
            Shard0["Shard 0<br/>GPU 0<br/>UDS: /tmp/tgs-0"]
            Shard1["Shard 1<br/>GPU 1<br/>UDS: /tmp/tgs-1"]
            ShardN["Shard N<br/>GPU N<br/>UDS: /tmp/tgs-N"]
        end
    end

    %% External actors
    Client_Ext["Client<br/>(KServe Route)"]
    Kubelet["Kubernetes Kubelet"]

    %% Launcher relationships
    LauncherProc -->|spawns| Shard0
    LauncherProc -->|spawns| Shard1
    LauncherProc -->|spawns| ShardN
    LauncherProc -->|spawns| GRPCServer

    %% Request flow
    Client_Ext -->|"gRPC 8033/TCP<br/>TLS/mTLS"| GRPCServer
    Kubelet -->|"HTTP 3000/TCP"| HTTPServer

    GRPCServer --> TLSTermination
    TLSTermination --> Validation
    Validation --> Batcher

    %% Router to shards via client
    Batcher -->|"Prefill/NextToken"| GRPCClient
    GRPCClient -->|"gRPC over UDS"| Shard0
    GRPCClient -->|"gRPC over UDS"| Shard1
    GRPCClient -->|"gRPC over UDS"| ShardN

    %% Inter-shard communication
    Shard0 <-->|"NCCL 29500/TCP<br/>Tensor Parallelism"| Shard1
    Shard1 <-->|"NCCL 29500/TCP<br/>Tensor Parallelism"| ShardN

    %% Styling
    style LauncherProc fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style Validation fill:#4a90e2,stroke:#333,color:#fff
    style Batcher fill:#4a90e2,stroke:#333,color:#fff
    style TLSTermination fill:#4a90e2,stroke:#333,color:#fff
    style GRPCClient fill:#4a90e2,stroke:#333,color:#fff
    style Shard0 fill:#7ed321,stroke:#333,color:#fff
    style Shard1 fill:#7ed321,stroke:#333,color:#fff
    style ShardN fill:#7ed321,stroke:#333,color:#fff
    style Client_Ext fill:#f5a623,stroke:#333,color:#fff
    style Kubelet fill:#e8e8e8,stroke:#333
