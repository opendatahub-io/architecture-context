graph TB
    subgraph Container["TGIS Container (Single Pod)"]
        direction TB

        subgraph Launcher["text-generation-launcher (Rust)"]
            LauncherProc["Launcher Process<br/>Entry point / supervisor<br/>Signal propagation<br/>Health polling"]
        end

        subgraph Router["text-generation-router (Rust)"]
            direction LR
            GRPCServer["gRPC Server<br/>8033/TCP<br/>TLS/mTLS configurable"]
            HTTPServer["HTTP Server<br/>3000/TCP<br/>TLS configurable"]
            Validation["Request Validation<br/>+ Tokenization"]
            Batcher["Continuous Batcher<br/>Dynamic batch formation<br/>Queue jumping<br/>Prefill weight limits"]
            GRPCClient["gRPC Client<br/>(UDS)"]
        end

        subgraph Shards["text-generation-server (Python)"]
            direction LR
            Shard0["Shard 0<br/>GPU 0<br/>UDS /tmp/tgs-0"]
            Shard1["Shard 1<br/>GPU 1<br/>UDS /tmp/tgs-1"]
            ShardN["Shard N<br/>GPU N<br/>UDS /tmp/tgs-N"]
        end
    end

    %% External interfaces
    Client[External Client] -->|"gRPC/8033<br/>TLS/mTLS"| GRPCServer
    Kubelet[Kubernetes Kubelet] -->|"HTTP GET /health<br/>3000/TCP"| HTTPServer
    Prometheus[Prometheus] -->|"HTTP GET /metrics<br/>3000/TCP"| HTTPServer

    %% Internal flows
    LauncherProc -->|spawns| Shard0
    LauncherProc -->|spawns| Shard1
    LauncherProc -->|spawns| ShardN
    LauncherProc -->|spawns| GRPCServer

    GRPCServer --> Validation
    Validation --> Batcher
    Batcher --> GRPCClient

    GRPCClient -->|"gRPC over UDS<br/>plaintext"| Shard0
    GRPCClient -->|"gRPC over UDS<br/>plaintext"| Shard1
    GRPCClient -->|"gRPC over UDS<br/>plaintext"| ShardN

    %% Cross-shard communication
    Shard0 <-->|"NCCL allreduce<br/>29500/TCP"| Shard1
    Shard1 <-->|"NCCL allreduce<br/>29500/TCP"| ShardN

    %% External dependencies
    Shard0 -->|"CUDA"| GPU["NVIDIA GPU<br/>(CUDA 12.1)"]
    Shard1 -->|"CUDA"| GPU
    ShardN -->|"CUDA"| GPU

    %% Styling
    style LauncherProc fill:#6c757d,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style Validation fill:#5ba0d0,stroke:#333,color:#fff
    style Batcher fill:#5ba0d0,stroke:#333,color:#fff
    style GRPCClient fill:#5ba0d0,stroke:#333,color:#fff
    style Shard0 fill:#7ed321,stroke:#333,color:#fff
    style Shard1 fill:#7ed321,stroke:#333,color:#fff
    style ShardN fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style Kubelet fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style GPU fill:#76b900,stroke:#333,color:#fff
