graph TB
    subgraph TGIS["Text Generation Inference Server (TGIS)"]
        direction TB

        subgraph Launcher["text-generation-launcher (Rust)"]
            LauncherBin["Launcher Binary<br/>Process supervisor<br/>Signal propagation<br/>Health polling"]
        end

        subgraph Router["text-generation-router (Rust)"]
            direction LR
            GRPCServer["gRPC Server<br/>8033/TCP<br/>fmaas.GenerationService"]
            HTTPServer["HTTP Server<br/>3000/TCP<br/>/health, /metrics"]
            Validation["Request Validation<br/>+ Tokenization"]
            Batcher["Continuous Batcher<br/>Dynamic batch formation<br/>Queue jumping<br/>Prefill weight limits"]
            TLSTermination["TLS/mTLS<br/>Termination"]
        end

        subgraph Client["text-generation-client (Rust)"]
            GRPCClient["gRPC Client<br/>UDS Communication"]
        end

        subgraph Shards["text-generation-server (Python)"]
            direction LR
            Shard0["Shard 0<br/>GPU 0<br/>UDS /tmp/tgs-0"]
            Shard1["Shard 1<br/>GPU 1<br/>UDS /tmp/tgs-1"]
            ShardN["Shard N<br/>GPU N<br/>UDS /tmp/tgs-N"]
        end

        subgraph Engines["Inference Engines"]
            direction LR
            HFTransformers["hf_transformers<br/>(default)"]
            TGISNative["tgis_native<br/>(Flash Attn V2)"]
            IBMFMS["ibm_fms"]
            ONNX["hf_optimum_ort<br/>(ONNX Runtime)"]
        end
    end

    %% External actors
    ExtClient["External Client"] -->|gRPC 8033/TCP<br/>TLS/mTLS| GRPCServer
    Kubelet["Kubernetes Kubelet"] -->|HTTP 3000/TCP<br/>Health probe| HTTPServer
    Prometheus["Prometheus"] -->|HTTP 3000/TCP<br/>Scrape /metrics| HTTPServer

    %% Internal flows
    LauncherBin -->|spawns| Shard0
    LauncherBin -->|spawns| Shard1
    LauncherBin -->|spawns| ShardN
    LauncherBin -->|spawns| GRPCServer

    GRPCServer --> TLSTermination
    TLSTermination --> Validation
    Validation --> Batcher
    Batcher --> GRPCClient

    GRPCClient -->|UDS gRPC| Shard0
    GRPCClient -->|UDS gRPC| Shard1
    GRPCClient -->|UDS gRPC| ShardN

    Shard0 -->|NCCL 29500/TCP| Shard1
    Shard1 -->|NCCL| ShardN

    Shard0 --- HFTransformers
    Shard0 --- TGISNative
    Shard0 --- IBMFMS
    Shard0 --- ONNX

    %% External dependencies
    KServe["KServe<br/>InferenceService"] -.->|manages| TGIS
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"] -.->|model download| Shards
    PVC["PVC<br/>/shared_model_storage"] -.->|volume mount| Shards
    GPU["NVIDIA GPU<br/>CUDA 12.1"] -.->|compute| Shards

    %% Styling
    style TGIS fill:#e8f4fd,stroke:#2196f3,stroke-width:2px
    style Launcher fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    style Router fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    style Client fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px
    style Shards fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style Engines fill:#fff8e1,stroke:#ffc107,stroke-width:1px

    style ExtClient fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Kubelet fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Prometheus fill:#f9f9f9,stroke:#999,stroke-width:2px
    style KServe fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    style HFHub fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style PVC fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style GPU fill:#fff9c4,stroke:#f9a825,stroke-width:2px
