graph TD
    subgraph Note["RBAC Overview"]
        direction TB
        Info["lm-evaluation-harness is a batch job container.<br/>It does NOT define its own RBAC resources.<br/>RBAC is configured by the trustyai-service-operator<br/>when creating the Kubernetes Job."]
    end

    subgraph OperatorRBAC["trustyai-service-operator RBAC (manages this component)"]
        direction TB

        OperatorSA["ServiceAccount<br/>trustyai-service-operator"]
        OperatorCRB["ClusterRoleBinding<br/>trustyai-operator-binding"]
        OperatorCR["ClusterRole<br/>trustyai-operator-role"]
    end

    subgraph JobPodRBAC["Job Pod RBAC (configured per-job by operator)"]
        direction TB

        JobSA["ServiceAccount<br/>(per-namespace, created by operator)"]
    end

    subgraph Secrets["Secrets Used by Job Pod"]
        direction TB

        ModelAuth["model.auth.secret_ref<br/>Type: Opaque<br/>Keys: API key, hf-token, CA cert<br/>Provisioned by: User / Operator<br/>Auto-rotate: No"]
        OCIAuth["OCI Registry Auth<br/>Type: Docker config<br/>Provisioned by: User / Platform<br/>Auto-rotate: No"]
    end

    subgraph EnvVars["Derived Environment Variables"]
        direction TB

        OPENAI_KEY["OPENAI_API_KEY<br/>Bearer token for model API<br/>Source: model auth secret"]
        HF_TOKEN["HF_TOKEN<br/>HuggingFace Hub token<br/>Source: model auth secret (hf-token key)"]
    end

    subgraph AuthEndpoints["Authentication Enforcement Points"]
        direction TB

        ModelAPI["Model Inference API<br/>Method: POST<br/>Auth: Bearer Token (OPENAI_API_KEY)<br/>Enforced by: Inference server"]
        EvalHubAPI["EvalHub Callback API<br/>Method: POST<br/>Auth: Bearer Token<br/>Enforced by: EvalHub service"]
        HFHubAPI["HuggingFace Hub<br/>Method: GET<br/>Auth: Bearer Token (HF_TOKEN)<br/>Enforced by: HuggingFace API"]
        OCIAPI["OCI Registry<br/>Method: Push<br/>Auth: Docker registry auth<br/>Enforced by: Registry server"]
    end

    %% Operator creates job SA
    OperatorSA -->|"bound via"| OperatorCRB
    OperatorCRB -->|"grants"| OperatorCR
    OperatorCR -->|"creates Jobs,<br/>ConfigMaps,<br/>ServiceAccounts"| JobSA

    %% Job SA uses secrets
    JobSA -->|"mounts"| ModelAuth
    JobSA -->|"mounts"| OCIAuth

    %% Secrets derive env vars
    ModelAuth -->|"derives"| OPENAI_KEY
    ModelAuth -->|"derives"| HF_TOKEN

    %% Env vars used for auth
    OPENAI_KEY -->|"authenticates"| ModelAPI
    HF_TOKEN -->|"authenticates"| HFHubAPI
    OCIAuth -->|"authenticates"| OCIAPI

    style Note fill:#f9f9f9,stroke:#ccc,stroke-width:1px
    style Info fill:#fff,stroke:none
    style OperatorRBAC fill:#dae8fc,stroke:#6c8ebf
    style JobPodRBAC fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#fff2cc,stroke:#d6b656
    style EnvVars fill:#f8cecc,stroke:#b85450
    style AuthEndpoints fill:#e1d5e7,stroke:#9673a6
    style OperatorSA fill:#4a90e2,color:#fff
    style JobSA fill:#82b366,color:#fff
