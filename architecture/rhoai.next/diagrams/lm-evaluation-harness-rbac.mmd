graph TD
    subgraph "RBAC Overview"
        Note["lm-evaluation-harness is a batch job container.<br/>RBAC is configured by the trustyai-service-operator,<br/>not by this component directly."]
    end

    subgraph "Operator-Managed RBAC"
        Operator["trustyai-service-operator"]
        LMEvalJobCRD["LMEvalJob CRD<br/>(serving.kserve.io)"]
        JobSA["Job Pod ServiceAccount<br/>(operator-configured)"]
    end

    subgraph "Secrets Access"
        ModelSecret["Model Auth Secret<br/>(model.auth.secret_ref)<br/>Type: Opaque<br/>Keys: api-key, hf-token, ca-cert"]
        OCISecret["OCI Registry Auth<br/>Type: Docker Config<br/>Registry credentials"]
    end

    subgraph "Environment Variables (from Secrets)"
        OPENAI_KEY["OPENAI_API_KEY<br/>Bearer token for model API<br/>Derived from model auth secret"]
        HF_TOKEN["HF_TOKEN<br/>HuggingFace Hub access<br/>Derived from model auth secret"]
    end

    subgraph "Auth Mechanisms Used by Job"
        ModelAuth["Model Inference API<br/>Method: POST<br/>Auth: Bearer Token (OPENAI_API_KEY)<br/>Enforced by: Inference server"]
        EvalHubAuth["EvalHub Callback API<br/>Method: POST<br/>Auth: Bearer Token<br/>Enforced by: EvalHub service"]
        HFAuth["HuggingFace Hub<br/>Method: GET<br/>Auth: Bearer Token (HF_TOKEN)<br/>Enforced by: HuggingFace API"]
        OCIAuth["OCI Registry<br/>Method: Push<br/>Auth: Docker registry auth<br/>Enforced by: Registry server"]
    end

    Operator -->|"creates Job with"| JobSA
    Operator -->|"watches"| LMEvalJobCRD
    JobSA -->|"mounts"| ModelSecret
    JobSA -->|"mounts"| OCISecret
    ModelSecret -->|"derives"| OPENAI_KEY
    ModelSecret -->|"derives"| HF_TOKEN
    OPENAI_KEY -->|"used by"| ModelAuth
    HF_TOKEN -->|"used by"| HFAuth
    OCISecret -->|"used by"| OCIAuth

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style LMEvalJobCRD fill:#f5a623,stroke:#333,color:#fff
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style ModelSecret fill:#e74c3c,stroke:#333,color:#fff
    style OCISecret fill:#e74c3c,stroke:#333,color:#fff
    style OPENAI_KEY fill:#e8e8e8,stroke:#333
    style HF_TOKEN fill:#e8e8e8,stroke:#333
    style ModelAuth fill:#dae8fc,stroke:#6c8ebf
    style EvalHubAuth fill:#dae8fc,stroke:#6c8ebf
    style HFAuth fill:#dae8fc,stroke:#6c8ebf
    style OCIAuth fill:#dae8fc,stroke:#6c8ebf
