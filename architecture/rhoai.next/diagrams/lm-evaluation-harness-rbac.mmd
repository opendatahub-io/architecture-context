graph TD
    subgraph "LMEval Job Pod — RBAC Context"
        direction TB

        subgraph "Note"
            Note["RBAC is managed by the TrustyAI Operator<br/>This component does not define its own<br/>ClusterRoles or RoleBindings"]
        end

        subgraph "TrustyAI Operator (Manages RBAC)"
            OperatorSA["ServiceAccount<br/>trustyai-operator-controller-manager"]
        end

        subgraph "Operator ClusterRole Permissions"
            CR["ClusterRole<br/>(defined by TrustyAI Operator)"]
        end

        subgraph "Job Resources Created"
            Job["batch/v1 Job"]
            ConfigMap["ConfigMap<br/>(job spec at /meta/job.json)"]
            Secrets["Secrets<br/>(model auth, OCI auth, AWS creds)"]
        end

        OperatorSA -->|"bound via ClusterRoleBinding"| CR
        CR -->|"create, get, list, watch, delete"| Job
        CR -->|"create, get"| ConfigMap
        CR -->|"get"| Secrets
    end

    subgraph "Credential Access (Runtime — No K8s RBAC)"
        direction TB
        JobPod["LMEval Job Pod<br/>UID: 65532 (non-root)"]

        ModelSecret["Model Auth Secret<br/>- OPENAI_API_KEY<br/>- HF_TOKEN<br/>- CA certificate"]
        OCIAuth["OCI Auth Config<br/>/tmp/.docker/config.json"]
        AWSCreds["AWS Credentials<br/>- AWS_ACCESS_KEY_ID<br/>- AWS_SECRET_ACCESS_KEY"]

        JobPod -->|"env/volume mount"| ModelSecret
        JobPod -->|"volume mount"| OCIAuth
        JobPod -->|"env vars"| AWSCreds
    end

    subgraph "Security Controls"
        direction TB
        NonRoot["Non-root: UID 65532"]
        CPUOnly["CPU-only execution"]
        PathValidation["CWE-22 path traversal<br/>prevention"]
        CredRedaction["Credential redaction<br/>in error messages"]
        SymlinkCheck["Symlink traversal<br/>prevention for CA certs"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style OperatorSA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style Job fill:#7ed321,stroke:#333
    style ConfigMap fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style JobPod fill:#4a90e2,stroke:#333,color:#fff
    style ModelSecret fill:#f8cecc,stroke:#b85450
    style OCIAuth fill:#f8cecc,stroke:#b85450
    style AWSCreds fill:#f8cecc,stroke:#b85450
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style CPUOnly fill:#d5e8d4,stroke:#82b366
    style PathValidation fill:#d5e8d4,stroke:#82b366
    style CredRedaction fill:#d5e8d4,stroke:#82b366
    style SymlinkCheck fill:#d5e8d4,stroke:#82b366
