graph TD
    subgraph "RBAC Model — LM Evaluation Harness"
        direction TB

        Note["NOTE: This component defines NO RBAC resources.<br/>All RBAC is managed by the TrustyAI LMEval Operator<br/>(trustyai-service-operator) which creates the Job."]

        subgraph "Operator-Managed RBAC (external to this component)"
            OperatorSA["ServiceAccount<br/>(managed by LMEval Operator)"]
            JobSA["Job Pod ServiceAccount<br/>(created per-evaluation)"]
        end

        subgraph "Secrets Access"
            ModelSecret["Model Auth Secret<br/>(Opaque)<br/>Keys: OPENAI_API_KEY,<br/>hf-token, ca-cert"]
            OCISecret["OCI Registry Auth<br/>(docker config.json)<br/>Registry credentials"]
            GitSecret["git-auth<br/>(kubernetes.io/basic-auth)<br/>Tekton pipeline auth"]
        end

        subgraph "ConfigMap Access"
            JobSpec["/meta/job.json<br/>(ConfigMap)<br/>Evaluation job specification"]
        end

        subgraph "Volume Access"
            TestData["/test_data<br/>(Volume)<br/>Offline datasets & tokenizers"]
        end

        OperatorSA -->|"creates Job with"| JobSA
        JobSA -->|"mounts"| ModelSecret
        JobSA -->|"mounts"| OCISecret
        JobSA -->|"mounts"| JobSpec
        JobSA -.->|"mounts (optional)"| TestData
    end

    subgraph "Authentication at Runtime"
        direction TB
        Auth1["Model Endpoint<br/>POST /v1/completions<br/>Auth: Bearer Token<br/>(OPENAI_API_KEY from secret)"]
        Auth2["EvalHub Callback<br/>POST callback_url<br/>Auth: Bearer Token<br/>(managed by eval-hub-sdk)"]
        Auth3["HuggingFace Hub<br/>GET datasets<br/>Auth: HF_TOKEN<br/>(optional, from secret)"]
        Auth4["OCI Registry<br/>Push artifacts<br/>Auth: Docker config.json<br/>(from mounted secret)"]
    end

    JobSA -->|"uses credentials for"| Auth1
    JobSA -->|"uses credentials for"| Auth2
    JobSA -->|"uses credentials for"| Auth3
    JobSA -->|"uses credentials for"| Auth4

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style OperatorSA fill:#4a90e2,color:#fff
    style JobSA fill:#4a90e2,color:#fff
    style ModelSecret fill:#ffcdd2,stroke:#c62828
    style OCISecret fill:#ffcdd2,stroke:#c62828
    style GitSecret fill:#ffcdd2,stroke:#c62828
    style JobSpec fill:#fff9c4,stroke:#f9a825
    style TestData fill:#fff9c4,stroke:#f9a825
    style Auth1 fill:#e8f5e9,stroke:#43a047
    style Auth2 fill:#e8f5e9,stroke:#43a047
    style Auth3 fill:#e8f5e9,stroke:#43a047
    style Auth4 fill:#e8f5e9,stroke:#43a047
