graph TD
    subgraph "LMEval Job RBAC (Managed by TrustyAI Operator)"
        direction TB

        Note["NOTE: This component defines no RBAC.<br/>All RBAC is managed by the TrustyAI LMEval Operator<br/>(trustyai-service-operator) which creates the Job."]

        subgraph "Job Pod Identity"
            SA["ServiceAccount<br/>(created by operator)"]
        end

        subgraph "Secrets Access (mounted by operator)"
            ModelSecret["model.auth.secret_ref<br/>(Opaque)<br/>API Key + HF Token"]
            DockerConfig["/tmp/.docker/config.json<br/>(Docker config)<br/>OCI Registry Auth"]
            S3Creds["AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>(Env vars)<br/>S3 Credentials"]
            CACert["verify_certificate<br/>(TLS CA bundle)<br/>Custom CA Cert"]
        end

        subgraph "ConfigMap Access"
            JobSpec["/meta/job.json<br/>(ConfigMap)<br/>Job Specification"]
        end

        SA -->|"uses"| ModelSecret
        SA -->|"uses"| DockerConfig
        SA -->|"uses"| S3Creds
        SA -->|"uses"| CACert
        SA -->|"reads"| JobSpec
    end

    subgraph "External Auth Mechanisms"
        direction TB
        InferenceAuth["Inference Endpoint<br/>Auth: Bearer Token<br/>(OPENAI_API_KEY)"]
        HFAuth["HuggingFace Hub<br/>Auth: Bearer Token<br/>(HF_TOKEN, optional)"]
        EvalHubAuth["EvalHub Service<br/>Auth: Bearer Token"]
        OCIAuth["OCI Registry<br/>Auth: Docker config<br/>(basic auth / token)"]
        S3Auth["S3 Storage<br/>Auth: AWS IAM<br/>(access key + secret)"]
    end

    ModelSecret -->|"provides key"| InferenceAuth
    ModelSecret -->|"provides token"| HFAuth
    DockerConfig -->|"provides auth"| OCIAuth
    S3Creds -->|"provides creds"| S3Auth

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style ModelSecret fill:#f8cecc,stroke:#b85450
    style DockerConfig fill:#f8cecc,stroke:#b85450
    style S3Creds fill:#f8cecc,stroke:#b85450
    style CACert fill:#f8cecc,stroke:#b85450
    style JobSpec fill:#fff2cc,stroke:#d6b656
    style InferenceAuth fill:#d5e8d4,stroke:#82b366
    style HFAuth fill:#d5e8d4,stroke:#82b366
    style EvalHubAuth fill:#d5e8d4,stroke:#82b366
    style OCIAuth fill:#d5e8d4,stroke:#82b366
    style S3Auth fill:#d5e8d4,stroke:#82b366
