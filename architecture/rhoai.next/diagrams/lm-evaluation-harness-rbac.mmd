graph TD
    subgraph OperatorManaged["RBAC Managed by trustyai-service-operator"]
        direction TB

        subgraph JobPod["lmes-job Pod"]
            SA["ServiceAccount<br/>(configured by operator<br/>from LMEvalJob CR)"]
        end

        subgraph OperatorRBAC["Operator-Defined Permissions"]
            OpSA["trustyai-service-operator SA"]
            OpCR["ClusterRole:<br/>trustyai-operator-manager"]
        end

        OpSA -->|"bound via ClusterRoleBinding"| OpCR
        OpCR -->|"create, get, list, watch,<br/>update, delete"| Jobs["batch/v1<br/>Jobs"]
        OpCR -->|"create, get, list, watch"| ConfigMaps["core/v1<br/>ConfigMaps"]
        OpCR -->|"get, list, watch,<br/>update, patch"| LMEvalJobCRD["trustyai.opendatahub.io<br/>LMEvalJob"]
    end

    subgraph AuthNMechanisms["Authentication Mechanisms (Application-Level)"]
        direction TB

        subgraph ModelAuth["Model Inference Auth"]
            ModelSecret["Secret: model.auth.secret_ref<br/>Type: Opaque"]
            ModelSecret -->|"provides"| OPENAI_KEY["OPENAI_API_KEY<br/>(Bearer Token)"]
            ModelSecret -->|"provides"| HF_TOKEN["HF_TOKEN<br/>(HuggingFace access)"]
            ModelSecret -->|"provides (optional)"| CA_CERT["CA Certificate<br/>(custom trust)"]
        end

        subgraph RegistryAuth["OCI Registry Auth"]
            DockerConfig["Secret: OCI registry auth<br/>Type: kubernetes.io/dockerconfigjson"]
            DockerConfig -->|"provides"| RegCreds["Registry Credentials"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        ModelAPI["Model Inference API<br/>POST /v1/completions<br/>Auth: Bearer Token"]
        EvalHubAPI["EvalHub Callback API<br/>POST status/results<br/>Auth: Bearer Token"]
        HFAPI["HuggingFace Hub API<br/>GET datasets/models<br/>Auth: HF_TOKEN"]
        OCIAPI["OCI Registry<br/>Push artifacts<br/>Auth: Docker config"]
    end

    OPENAI_KEY -->|"authenticates"| ModelAPI
    HF_TOKEN -->|"authenticates"| HFAPI
    RegCreds -->|"authenticates"| OCIAPI
    SA -.->|"no direct K8s API<br/>RBAC needed<br/>(batch job)"| Jobs

    Note["Note: This component is a batch job container.<br/>It does not define its own ClusterRoles or RoleBindings.<br/>All Kubernetes RBAC is configured by the<br/>trustyai-service-operator when creating the Job."]

    style SA fill:#4a90e2,color:#fff
    style OpSA fill:#f5a623,color:#fff
    style OpCR fill:#f5a623,color:#fff
    style Jobs fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style LMEvalJobCRD fill:#7ed321,color:#fff
    style ModelSecret fill:#fff2cc,stroke:#d6b656
    style DockerConfig fill:#fff2cc,stroke:#d6b656
    style OPENAI_KEY fill:#fff2cc,stroke:#d6b656
    style HF_TOKEN fill:#fff2cc,stroke:#d6b656
    style CA_CERT fill:#fff2cc,stroke:#d6b656
    style RegCreds fill:#fff2cc,stroke:#d6b656
    style ModelAPI fill:#f8cecc,stroke:#b85450
    style EvalHubAPI fill:#f8cecc,stroke:#b85450
    style HFAPI fill:#f8cecc,stroke:#b85450
    style OCIAPI fill:#f8cecc,stroke:#b85450
    style Note fill:#fff,stroke:#999,stroke-dasharray: 5 5
