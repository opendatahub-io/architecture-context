graph TD
    subgraph OperatorManaged["RBAC Managed by TrustyAI LMEval Operator"]
        direction TB

        Note["This component has no RBAC definitions.<br/>RBAC is managed by the TrustyAI LMEval Operator<br/>that creates and manages the Kubernetes Job."]

        subgraph JobPod["LMEval Job Pod Security"]
            PodSecurity["Pod Security Context<br/>UID: 65532 (non-root)<br/>GID: 65532 (non-root)"]
        end

        subgraph SecretAccess["Secrets Consumed"]
            ModelAuth["Model Auth Secret<br/>(model.auth.secret_ref)<br/>Type: Opaque<br/>Contains: OPENAI_API_KEY, HF_TOKEN"]
            OCIAuth["OCI Auth Config<br/>(/tmp/.docker/config.json)<br/>Type: Docker config<br/>Contains: Registry credentials"]
            S3Creds["S3 Credentials<br/>(Environment Variables)<br/>Type: Env vars<br/>Contains: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY"]
            CACert["CA Certificates<br/>(verify_certificate path)<br/>Type: TLS CA bundle<br/>Contains: Custom CA cert"]
        end

        subgraph AuthMechanisms["Authentication Mechanisms"]
            InferenceAuth["Inference Endpoint<br/>Method: Bearer Token<br/>Source: OPENAI_API_KEY env var<br/>Enforcement: Inference server"]
            HFAuth["HuggingFace Hub<br/>Method: Bearer Token<br/>Source: HF_TOKEN env var<br/>Enforcement: HuggingFace Hub<br/>Required: Only for gated content"]
            EvalHubAuth["EvalHub Callbacks<br/>Method: Bearer Token<br/>Enforcement: EvalHub service"]
            OCIRegAuth["OCI Registry<br/>Method: Docker auth config<br/>Source: /tmp/.docker/config.json<br/>Enforcement: Registry"]
        end
    end

    PodSecurity -->|runs with| ModelAuth
    PodSecurity -->|runs with| OCIAuth
    PodSecurity -->|runs with| S3Creds
    PodSecurity -->|runs with| CACert

    ModelAuth -->|provides| InferenceAuth
    ModelAuth -->|provides| HFAuth
    OCIAuth -->|provides| OCIRegAuth

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style PodSecurity fill:#4a90e2,stroke:#333,color:#fff
    style ModelAuth fill:#f5a623,stroke:#333,color:#fff
    style OCIAuth fill:#f5a623,stroke:#333,color:#fff
    style S3Creds fill:#f5a623,stroke:#333,color:#fff
    style CACert fill:#f5a623,stroke:#333,color:#fff
    style InferenceAuth fill:#7ed321,stroke:#333,color:#fff
    style HFAuth fill:#7ed321,stroke:#333,color:#fff
    style EvalHubAuth fill:#7ed321,stroke:#333,color:#fff
    style OCIRegAuth fill:#7ed321,stroke:#333,color:#fff
