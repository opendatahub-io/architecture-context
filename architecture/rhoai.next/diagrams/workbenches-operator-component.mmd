graph TB
    subgraph Orchestrator["Platform Orchestrator"]
        RhodsOp["rhods-operator<br/>(Platform Orchestrator)"]
    end

    subgraph WorkbenchesOperator["Workbenches Operator"]
        Controller["Workbenches Controller<br/>(controller-runtime v0.23.3)"]
        MetricsServer["Metrics Server<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
    end

    subgraph KubeAPI["Kubernetes API Server"]
        APIServer["kube-apiserver<br/>443/TCP HTTPS"]
    end

    subgraph ManagedResources["Managed Resources"]
        WorkbenchesCR["Workbenches CR<br/>(Cluster-scoped, singleton 'default')<br/>components.platform.opendatahub.io/v1alpha1"]
        WBNamespace["Workbench Namespace<br/>(opendatahub / rhods-notebooks)"]
    end

    subgraph MonitoredResources["Monitored Resources"]
        NBDeployments["Notebook Controller Deployments<br/>label: app.opendatahub.io/workbenches=true"]
    end

    subgraph FutureScope["Future Scope (GVK References)"]
        NotebookCRD["Kubeflow Notebook CRD<br/>kubeflow.org/v1"]
        ImageStream["OpenShift ImageStream<br/>image.openshift.io/v1"]
        HWProfile["HardwareProfile CRD<br/>infrastructure.platform.opendatahub.io/v1"]
    end

    %% Flows
    RhodsOp -->|"creates/updates"| WorkbenchesCR
    Controller -->|"watches"| WorkbenchesCR
    Controller -->|"creates & labels"| WBNamespace
    Controller -->|"lists & monitors health"| NBDeployments
    Controller -->|"updates status"| WorkbenchesCR
    Controller -->|"all K8s operations"| APIServer

    %% Future references
    Controller -.->|"planned"| NotebookCRD
    Controller -.->|"planned"| ImageStream
    Controller -.->|"planned"| HWProfile

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes"| MetricsServer

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthProbes fill:#4a90e2,stroke:#333,color:#fff
    style WorkbenchesCR fill:#f5a623,stroke:#333,stroke-width:2px
    style WBNamespace fill:#f5a623,stroke:#333
    style NBDeployments fill:#7ed321,stroke:#333
    style RhodsOp fill:#9b59b6,stroke:#333,color:#fff
    style APIServer fill:#e8e8e8,stroke:#333
    style NotebookCRD fill:#ddd,stroke:#999,stroke-dasharray: 5 5
    style ImageStream fill:#ddd,stroke:#999,stroke-dasharray: 5 5
    style HWProfile fill:#ddd,stroke:#999,stroke-dasharray: 5 5
    style Prometheus fill:#e8e8e8,stroke:#333
