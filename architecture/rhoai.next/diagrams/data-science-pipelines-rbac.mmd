graph TD
    subgraph ServiceAccounts["Service Accounts (8)"]
        SA_API["ml-pipeline"]
        SA_PA["ml-pipeline-persistenceagent"]
        SA_SWC["ml-pipeline-scheduledworkflow"]
        SA_UI["ml-pipeline-ui"]
        SA_Cache["kubeflow-pipelines-cache"]
        SA_MW["kubeflow-pipelines-metadata-writer"]
        SA_CD["kubeflow-pipelines-cache-deployer-sa"]
        SA_Runner["pipeline-runner"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-Scoped)"]
        RB_API["ml-pipeline<br/>RoleBinding"]
        RB_PA["ml-pipeline-persistenceagent<br/>RoleBinding"]
        RB_SWC["ml-pipeline-scheduledworkflow<br/>RoleBinding"]
        RB_UI["ml-pipeline-ui<br/>RoleBinding"]
        RB_Cache["kubeflow-pipelines-cache<br/>RoleBinding"]
        RB_MW["kubeflow-pipelines-metadata-writer<br/>RoleBinding"]
        RB_CD["kubeflow-pipelines-cache-deployer<br/>RoleBinding"]
        RB_Runner["pipeline-runner<br/>RoleBinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_CD["kubeflow-pipelines-cache-<br/>deployer-clusterrole"]
        CR_Edit["aggregate-to-kubeflow-<br/>pipelines-edit"]
        CR_View["aggregate-to-kubeflow-<br/>pipelines-view"]
    end

    subgraph Resources_CD["Cache Deployer Resources"]
        Res_CSR["certificates.k8s.io<br/>certificatesigningrequests<br/>csr/approval"]
        Res_Webhook["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations"]
        Res_Signers["certificates.k8s.io<br/>signers"]
    end

    subgraph Resources_Edit["Edit Resources (Aggregated)"]
        Res_Pipelines_E["pipelines.kubeflow.org<br/>pipelines, pipelineversions"]
        Res_Experiments_E["pipelines.kubeflow.org<br/>experiments"]
        Res_Runs_E["pipelines.kubeflow.org<br/>runs"]
        Res_Jobs_E["pipelines.kubeflow.org<br/>jobs"]
        Res_SWF_E["kubeflow.org<br/>scheduledworkflows"]
        Res_Argo_E["argoproj.io<br/>workflows, cronworkflows<br/>workflowtemplates, workflowtaskresults"]
    end

    subgraph Resources_View["View Resources (Aggregated)"]
        Res_Pipelines_V["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>experiments, jobs"]
        Res_Runs_V["pipelines.kubeflow.org<br/>runs"]
        Res_Viewers_V["kubeflow.org<br/>viewers"]
    end

    %% SA → RoleBinding connections
    SA_API -->|"bound via"| RB_API
    SA_PA -->|"bound via"| RB_PA
    SA_SWC -->|"bound via"| RB_SWC
    SA_UI -->|"bound via"| RB_UI
    SA_Cache -->|"bound via"| RB_Cache
    SA_MW -->|"bound via"| RB_MW
    SA_CD -->|"bound via"| RB_CD
    SA_Runner -->|"bound via"| RB_Runner

    %% ClusterRole → Resource connections
    CR_CD -->|"create, delete,<br/>get, update"| Res_CSR
    CR_CD -->|"create, delete,<br/>get, list, patch"| Res_Webhook
    CR_CD -->|"approve"| Res_Signers

    CR_Edit -->|"create, delete, update"| Res_Pipelines_E
    CR_Edit -->|"archive, create,<br/>delete, unarchive"| Res_Experiments_E
    CR_Edit -->|"archive, create, delete,<br/>retry, terminate, unarchive"| Res_Runs_E
    CR_Edit -->|"create, delete,<br/>disable, enable"| Res_Jobs_E
    CR_Edit -->|"*"| Res_SWF_E
    CR_Edit -->|"*"| Res_Argo_E

    CR_View -->|"get, list"| Res_Pipelines_V
    CR_View -->|"get, list, readArtifact"| Res_Runs_V
    CR_View -->|"create, get, delete"| Res_Viewers_V

