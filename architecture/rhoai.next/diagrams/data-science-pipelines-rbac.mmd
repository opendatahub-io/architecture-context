graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Pipeline["ml-pipeline"]
        SA_SW["ml-pipeline-scheduledworkflow"]
        SA_PA["ml-pipeline-persistenceagent"]
        SA_Cache["kubeflow-pipelines-cache"]
        SA_Runner["pipeline-runner"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        CRB_Pipeline["ml-pipeline<br/>(ClusterRoleBinding)"]
        CRB_SW["ml-pipeline-scheduledworkflow-binding"]
        CRB_PA["ml-pipeline-persistenceagent-binding"]
        CRB_Cache["kubeflow-pipelines-cache-binding"]
        CRB_Runner["pipeline-runner-binding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Pipeline["ml-pipeline"]
        CR_SW["ml-pipeline-scheduledworkflow-role"]
        CR_PA["ml-pipeline-persistenceagent-role"]
        CR_Cache["kubeflow-pipelines-cache-role"]
        CR_Runner["pipeline-runner"]
    end

    subgraph Resources_Pipeline["ml-pipeline Resources"]
        R_Pods["core: pods, pods/log<br/>get, list, delete"]
        R_Workflows["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_ScheduledWF["kubeflow.org:<br/>scheduledworkflows<br/>+ finalizers<br/>create, get, list,<br/>update, patch, delete"]
        R_Pipelines["pipelines.kubeflow.org:<br/>pipelines<br/>get, list, watch"]
        R_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        R_TR["authentication.k8s.io:<br/>tokenreviews<br/>create"]
    end

    subgraph Resources_SW["scheduledworkflow Resources"]
        R_SW_Workflows["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SW_SWF["kubeflow.org:<br/>scheduledworkflows<br/>+ finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SW_Runs["pipelines.kubeflow.org:<br/>runs<br/>create"]
        R_SW_Events["core: events<br/>create, patch"]
    end

    subgraph Resources_PA["persistenceagent Resources"]
        R_PA_Workflows["argoproj.io: workflows<br/>get, list, watch"]
        R_PA_SWF["kubeflow.org:<br/>scheduledworkflows<br/>get, list, watch"]
        R_PA_Runs["pipelines.kubeflow.org:<br/>runs<br/>reportMetrics, readArtifact"]
    end

    subgraph Resources_Cache["cache Resources"]
        R_Cache_Pods["core: pods<br/>get, list, watch,<br/>update, patch"]
        R_Cache_CM["core: configmaps<br/>get"]
        R_Cache_WF["argoproj.io: workflows<br/>get, list, watch,<br/>update, patch"]
    end

    subgraph Resources_Runner["pipeline-runner Resources"]
        R_Runner_Secrets["core: secrets<br/>get"]
        R_Runner_CM["core: configmaps<br/>get, watch, list"]
        R_Runner_PV["core: PVs, PVCs<br/>* (full access)"]
        R_Runner_Pods["core: pods, exec, log,<br/>services<br/>* (full access)"]
        R_Runner_Apps["apps: deployments,<br/>replicasets<br/>* (full access)"]
        R_Runner_KF["kubeflow.org: *<br/>* (full access)"]
        R_Runner_Batch["batch: jobs<br/>* (full access)"]
        R_Runner_Argo["argoproj.io: workflows,<br/>workflowtaskresults<br/>get, list, watch,<br/>update, patch, create"]
    end

    %% SA → Binding → Role chains
    SA_Pipeline -->|"bound via"| CRB_Pipeline
    CRB_Pipeline -->|"grants"| CR_Pipeline

    SA_SW -->|"bound via"| CRB_SW
    CRB_SW -->|"grants"| CR_SW

    SA_PA -->|"bound via"| CRB_PA
    CRB_PA -->|"grants"| CR_PA

    SA_Cache -->|"bound via"| CRB_Cache
    CRB_Cache -->|"grants"| CR_Cache

    SA_Runner -->|"bound via"| CRB_Runner
    CRB_Runner -->|"grants"| CR_Runner

    %% Role → Resources
    CR_Pipeline --> R_Pods
    CR_Pipeline --> R_Workflows
    CR_Pipeline --> R_ScheduledWF
    CR_Pipeline --> R_Pipelines
    CR_Pipeline --> R_SAR
    CR_Pipeline --> R_TR

    CR_SW --> R_SW_Workflows
    CR_SW --> R_SW_SWF
    CR_SW --> R_SW_Runs
    CR_SW --> R_SW_Events

    CR_PA --> R_PA_Workflows
    CR_PA --> R_PA_SWF
    CR_PA --> R_PA_Runs

    CR_Cache --> R_Cache_Pods
    CR_Cache --> R_Cache_CM
    CR_Cache --> R_Cache_WF

    CR_Runner --> R_Runner_Secrets
    CR_Runner --> R_Runner_CM
    CR_Runner --> R_Runner_PV
    CR_Runner --> R_Runner_Pods
    CR_Runner --> R_Runner_Apps
    CR_Runner --> R_Runner_KF
    CR_Runner --> R_Runner_Batch
    CR_Runner --> R_Runner_Argo

