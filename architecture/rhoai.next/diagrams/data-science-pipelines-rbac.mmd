graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ml-pipeline"]
        SA_PA["ml-pipeline-<br/>persistenceagent"]
        SA_SWC["ml-pipeline-<br/>scheduledworkflow"]
        SA_UI["ml-pipeline-ui"]
        SA_Viewer["ml-pipeline-viewer-<br/>crd-service-account"]
        SA_Runner["pipeline-runner"]
        SA_Cache["kubeflow-pipelines-<br/>cache"]
        SA_CacheDep["kubeflow-pipelines-<br/>cache-deployer-sa"]
        SA_MetaWriter["kubeflow-pipelines-<br/>metadata-writer"]
    end

    subgraph RoleBindings["Role / ClusterRole Bindings"]
        RB_API["ml-pipeline<br/>(RoleBinding)"]
        RB_PA["ml-pipeline-persistenceagent-<br/>binding (RoleBinding)"]
        RB_SWC["ml-pipeline-scheduledworkflow-<br/>binding (RoleBinding)"]
        RB_UI["ml-pipeline-ui<br/>(RoleBinding)"]
        RB_Viewer["ml-pipeline-viewer-<br/>crd-binding (RoleBinding)"]
        RB_Runner["pipeline-runner-<br/>binding (RoleBinding)"]
        RB_Cache["kubeflow-pipelines-<br/>cache-binding (RoleBinding)"]
        RB_CacheDep["kubeflow-pipelines-cache-<br/>deployer-clusterrolebinding<br/>(ClusterRoleBinding)"]
        RB_MetaWriter["kubeflow-pipelines-<br/>metadata-writer-binding<br/>(RoleBinding)"]
    end

    subgraph Roles["Roles / ClusterRoles"]
        R_API["ml-pipeline<br/>(Role)"]
        R_PA["ml-pipeline-<br/>persistenceagent-role<br/>(Role)"]
        R_SWC["ml-pipeline-<br/>scheduledworkflow-role<br/>(Role)"]
        R_UI["ml-pipeline-ui<br/>(Role)"]
        R_Viewer["ml-pipeline-viewer-<br/>controller-role<br/>(Role)"]
        R_Runner["pipeline-runner<br/>(Role)"]
        R_Cache["kubeflow-pipelines-<br/>cache-role<br/>(Role)"]
        R_CacheDep["kubeflow-pipelines-cache-<br/>deployer-clusterrole<br/>(ClusterRole)"]
        R_MetaWriter["kubeflow-pipelines-<br/>metadata-writer-role<br/>(Role)"]
    end

    subgraph Resources["API Resources"]
        Pods["core: pods,<br/>pods/log, pods/exec"]
        Workflows["argoproj.io:<br/>workflows,<br/>workflowtaskresults"]
        SWFs["kubeflow.org:<br/>scheduledworkflows"]
        Pipelines["pipelines.kubeflow.org:<br/>pipelines"]
        PVs["core:<br/>persistentvolumes,<br/>persistentvolumeclaims"]
        Secrets["core: secrets"]
        Deployments["apps/core:<br/>deployments, services"]
        Viewers["kubeflow.org:<br/>viewers"]
        CSRs["certificates.k8s.io:<br/>certificatesigningrequests"]
        MWHs["admissionregistration:<br/>mutatingwebhook-<br/>configurations"]
        AuthZ["authorization.k8s.io:<br/>subjectaccessreviews"]
        AuthN["authentication.k8s.io:<br/>tokenreviews"]
        Jobs["batch: jobs"]
    end

    %% SA → RoleBinding
    SA_API --> RB_API
    SA_PA --> RB_PA
    SA_SWC --> RB_SWC
    SA_UI --> RB_UI
    SA_Viewer --> RB_Viewer
    SA_Runner --> RB_Runner
    SA_Cache --> RB_Cache
    SA_CacheDep --> RB_CacheDep
    SA_MetaWriter --> RB_MetaWriter

    %% RoleBinding → Role
    RB_API --> R_API
    RB_PA --> R_PA
    RB_SWC --> R_SWC
    RB_UI --> R_UI
    RB_Viewer --> R_Viewer
    RB_Runner --> R_Runner
    RB_Cache --> R_Cache
    RB_CacheDep --> R_CacheDep
    RB_MetaWriter --> R_MetaWriter

    %% Role → Resources
    R_API -->|"get,list,delete"| Pods
    R_API -->|"full CRUD"| Workflows
    R_API -->|"full CRUD"| SWFs
    R_API -->|"get,list,watch"| Pipelines
    R_API -->|"create"| AuthZ
    R_API -->|"create"| AuthN

    R_PA -->|"get,list,watch"| Workflows
    R_PA -->|"get,list,watch"| SWFs

    R_SWC -->|"full CRUD"| Workflows
    R_SWC -->|"full CRUD"| SWFs

    R_UI -->|"get"| Pods
    R_UI -->|"get,list"| Workflows
    R_UI -->|"full CRUD"| Viewers

    R_Viewer -->|"full CRUD"| Deployments
    R_Viewer -->|"full CRUD"| Viewers

    R_Runner -->|"*"| Pods
    R_Runner -->|"get"| Secrets
    R_Runner -->|"*"| PVs
    R_Runner -->|"full CRUD"| Workflows
    R_Runner -->|"*"| Jobs

    R_Cache -->|"get,list,watch,<br/>update,patch"| Pods
    R_Cache -->|"get,list,watch,<br/>update,patch"| Workflows

    R_CacheDep -->|"create,delete,<br/>get,update,approve"| CSRs
    R_CacheDep -->|"full CRUD"| MWHs

    R_MetaWriter -->|"get,list,watch,<br/>update,patch"| Pods
    R_MetaWriter -->|"get,list,watch,<br/>update,patch"| Workflows

