graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Pipeline["ml-pipeline"]
        SA_SW["ml-pipeline-scheduledworkflow"]
        SA_PA["ml-pipeline-persistenceagent"]
        SA_Cache["kubeflow-pipelines-cache"]
        SA_Runner["pipeline-runner"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        CRB_Pipeline["ml-pipeline<br/>binding"]
        CRB_SW["ml-pipeline-scheduledworkflow<br/>-binding"]
        CRB_PA["ml-pipeline-persistenceagent<br/>-binding"]
        CRB_Cache["kubeflow-pipelines-cache<br/>-binding"]
        CRB_Runner["pipeline-runner<br/>-binding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Pipeline["ml-pipeline"]
        CR_SW["ml-pipeline-scheduledworkflow-role"]
        CR_PA["ml-pipeline-persistenceagent-role"]
        CR_Cache["kubeflow-pipelines-cache-role"]
        CR_Runner["pipeline-runner"]
    end

    subgraph Resources_Pipeline["API Resources (ml-pipeline)"]
        R_Pods["core<br/>pods, pods/log"]
        R_Workflows_P["argoproj.io<br/>workflows"]
        R_SW_P["kubeflow.org<br/>scheduledworkflows<br/>scheduledworkflows/finalizers"]
        R_Pipelines_P["pipelines.kubeflow.org<br/>pipelines"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        R_TR["authentication.k8s.io<br/>tokenreviews"]
    end

    subgraph Resources_SW["API Resources (scheduledworkflow)"]
        R_Workflows_SW["argoproj.io<br/>workflows"]
        R_SW_SW["kubeflow.org<br/>scheduledworkflows<br/>scheduledworkflows/finalizers"]
        R_Runs_SW["pipelines.kubeflow.org<br/>runs"]
        R_Events["core<br/>events"]
    end

    subgraph Resources_PA["API Resources (persistenceagent)"]
        R_Workflows_PA["argoproj.io<br/>workflows"]
        R_SW_PA["kubeflow.org<br/>scheduledworkflows"]
        R_Runs_PA["pipelines.kubeflow.org<br/>runs"]
    end

    subgraph Resources_Cache["API Resources (cache)"]
        R_Pods_Cache["core<br/>pods, configmaps"]
        R_Workflows_Cache["argoproj.io<br/>workflows"]
    end

    subgraph Resources_Runner["API Resources (pipeline-runner)"]
        R_Secrets["core<br/>secrets"]
        R_ConfigMaps["core<br/>configmaps"]
        R_PV["core<br/>persistentvolumes<br/>persistentvolumeclaims"]
        R_Pods_Runner["core<br/>pods, pods/exec<br/>pods/log, services"]
        R_Apps["apps, extensions<br/>deployments, replicasets"]
        R_KF["kubeflow.org<br/>* (all)"]
        R_Batch["batch<br/>jobs"]
        R_Argo_Runner["argoproj.io<br/>workflows<br/>workflowtaskresults"]
    end

    %% Bindings
    SA_Pipeline -->|bound via| CRB_Pipeline
    SA_SW -->|bound via| CRB_SW
    SA_PA -->|bound via| CRB_PA
    SA_Cache -->|bound via| CRB_Cache
    SA_Runner -->|bound via| CRB_Runner

    CRB_Pipeline -->|grants| CR_Pipeline
    CRB_SW -->|grants| CR_SW
    CRB_PA -->|grants| CR_PA
    CRB_Cache -->|grants| CR_Cache
    CRB_Runner -->|grants| CR_Runner

    %% ml-pipeline permissions
    CR_Pipeline -->|"get, list, delete"| R_Pods
    CR_Pipeline -->|"create, get, list, watch,<br/>update, patch, delete"| R_Workflows_P
    CR_Pipeline -->|"create, get, list,<br/>update, patch, delete"| R_SW_P
    CR_Pipeline -->|"get, list, watch"| R_Pipelines_P
    CR_Pipeline -->|"create"| R_SAR
    CR_Pipeline -->|"create"| R_TR

    %% scheduledworkflow permissions
    CR_SW -->|"create, get, list, watch,<br/>update, patch, delete"| R_Workflows_SW
    CR_SW -->|"create, get, list, watch,<br/>update, patch, delete"| R_SW_SW
    CR_SW -->|"create"| R_Runs_SW
    CR_SW -->|"create, patch"| R_Events

    %% persistenceagent permissions
    CR_PA -->|"get, list, watch"| R_Workflows_PA
    CR_PA -->|"get, list, watch"| R_SW_PA
    CR_PA -->|"reportMetrics,<br/>readArtifact"| R_Runs_PA

    %% cache permissions
    CR_Cache -->|"get, list, watch,<br/>update, patch"| R_Pods_Cache
    CR_Cache -->|"get, list, watch,<br/>update, patch"| R_Workflows_Cache

    %% pipeline-runner permissions (broad)
    CR_Runner -->|"get"| R_Secrets
    CR_Runner -->|"get, watch, list"| R_ConfigMaps
    CR_Runner -->|"* (all verbs)"| R_PV
    CR_Runner -->|"* (all verbs)"| R_Pods_Runner
    CR_Runner -->|"* (all verbs)"| R_Apps
    CR_Runner -->|"* (all verbs)"| R_KF
    CR_Runner -->|"* (all verbs)"| R_Batch
    CR_Runner -->|"get, list, watch,<br/>update, patch, create"| R_Argo_Runner

    %% Styling
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_SW fill:#4a90e2,stroke:#333,color:#fff
    style SA_PA fill:#4a90e2,stroke:#333,color:#fff
    style SA_Cache fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#e74c3c,stroke:#333,color:#fff

    style CR_Pipeline fill:#f5a623,stroke:#333
    style CR_SW fill:#f5a623,stroke:#333
    style CR_PA fill:#f5a623,stroke:#333
    style CR_Cache fill:#f5a623,stroke:#333
    style CR_Runner fill:#e74c3c,stroke:#333,color:#fff

    style R_Pods fill:#7ed321,stroke:#333
    style R_Workflows_P fill:#7ed321,stroke:#333
    style R_SW_P fill:#7ed321,stroke:#333
    style R_Pipelines_P fill:#7ed321,stroke:#333
    style R_SAR fill:#7ed321,stroke:#333
    style R_TR fill:#7ed321,stroke:#333

    style R_Workflows_SW fill:#7ed321,stroke:#333
    style R_SW_SW fill:#7ed321,stroke:#333
    style R_Runs_SW fill:#7ed321,stroke:#333
    style R_Events fill:#7ed321,stroke:#333

    style R_Workflows_PA fill:#7ed321,stroke:#333
    style R_SW_PA fill:#7ed321,stroke:#333
    style R_Runs_PA fill:#7ed321,stroke:#333

    style R_Pods_Cache fill:#7ed321,stroke:#333
    style R_Workflows_Cache fill:#7ed321,stroke:#333

    style R_Secrets fill:#f8cecc,stroke:#b85450
    style R_ConfigMaps fill:#f8cecc,stroke:#b85450
    style R_PV fill:#f8cecc,stroke:#b85450
    style R_Pods_Runner fill:#f8cecc,stroke:#b85450
    style R_Apps fill:#f8cecc,stroke:#b85450
    style R_KF fill:#f8cecc,stroke:#b85450
    style R_Batch fill:#f8cecc,stroke:#b85450
    style R_Argo_Runner fill:#f8cecc,stroke:#b85450
