graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ml-pipeline"]
        SA_PA["ml-pipeline-<br/>persistenceagent"]
        SA_SWF["ml-pipeline-<br/>scheduledworkflow"]
        SA_Cache["kubeflow-pipelines-<br/>cache"]
        SA_Runner["pipeline-runner"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Cache["cache-deployer-<br/>clusterrolebinding"]
        CRB_API["ml-pipeline-<br/>clusterrolebinding<br/>(multi-user)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Cache["kubeflow-pipelines-<br/>cache-deployer-clusterrole"]
        CR_API["ml-pipeline<br/>(multi-user)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_API["ml-pipeline"]
        RB_PA["ml-pipeline-<br/>persistenceagent-binding"]
        RB_SWF["ml-pipeline-<br/>scheduledworkflow-binding"]
        RB_CacheNS["kubeflow-pipelines-<br/>cache-binding"]
        RB_Runner["pipeline-runner-<br/>binding"]
    end

    subgraph Roles["Namespace Roles"]
        R_API["ml-pipeline"]
        R_PA["ml-pipeline-<br/>persistenceagent-role"]
        R_SWF["ml-pipeline-<br/>scheduledworkflow-role"]
        R_CacheNS["kubeflow-pipelines-<br/>cache-role"]
        R_Runner["pipeline-runner"]
    end

    subgraph ClusterResources["Cluster-Scoped Resources"]
        CSR["certificates.k8s.io<br/>CSR, CSR/approval"]
        MWH["admissionregistration.k8s.io<br/>MutatingWebhookConfigurations"]
        Signers["certificates.k8s.io<br/>signers"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
        TR["authentication.k8s.io<br/>TokenReviews"]
    end

    subgraph NamespacedResources["Namespaced Resources"]
        Pods["core<br/>pods, pods/log"]
        Workflows["argoproj.io<br/>workflows"]
        SWFs["kubeflow.org<br/>scheduledworkflows"]
        Pipelines["pipelines.kubeflow.org<br/>pipelines"]
        PipelineRuns["pipelines.kubeflow.org<br/>runs"]
        Secrets["core<br/>secrets, configmaps"]
        Deployments["apps<br/>deployments, replicasets"]
        Jobs["batch<br/>jobs"]
        Events["core<br/>events"]
        KubeflowAll["kubeflow.org<br/>* (all resources)"]
        WFTaskResults["argoproj.io<br/>workflowtaskresults"]
    end

    %% Cluster-scoped bindings
    SA_Cache -->|"bound via"| CRB_Cache
    CRB_Cache -->|"grants"| CR_Cache
    CR_Cache -->|"create,delete,get,update"| CSR
    CR_Cache -->|"create,delete,get,list,patch"| MWH
    CR_Cache -->|"approve"| Signers

    SA_API -->|"bound via"| CRB_API
    CRB_API -->|"grants"| CR_API
    CR_API -->|"create"| SAR
    CR_API -->|"create"| TR

    %% Namespace-scoped bindings
    SA_API -->|"bound via"| RB_API
    RB_API -->|"grants"| R_API
    R_API -->|"get,list,delete"| Pods
    R_API -->|"create,get,list,watch,update,patch,delete"| Workflows
    R_API -->|"create,get,list,update,patch,delete"| SWFs
    R_API -->|"get,list,watch"| Pipelines

    SA_PA -->|"bound via"| RB_PA
    RB_PA -->|"grants"| R_PA
    R_PA -->|"get,list,watch"| Workflows
    R_PA -->|"get,list,watch"| SWFs

    SA_SWF -->|"bound via"| RB_SWF
    RB_SWF -->|"grants"| R_SWF
    R_SWF -->|"create,get,list,watch,update,patch,delete"| Workflows
    R_SWF -->|"create,get,list,watch,update,patch,delete"| SWFs
    R_SWF -->|"create"| PipelineRuns
    R_SWF -->|"create,patch"| Events

    SA_Cache -->|"bound via"| RB_CacheNS
    RB_CacheNS -->|"grants"| R_CacheNS
    R_CacheNS -->|"get,list,watch,update,patch"| Pods
    R_CacheNS -->|"get,list,watch,update,patch"| Workflows

    SA_Runner -->|"bound via"| RB_Runner
    RB_Runner -->|"grants"| R_Runner
    R_Runner -->|"varies"| Secrets
    R_Runner -->|"get,list,watch,update,patch,create"| Workflows
    R_Runner -->|"get,list,watch,update,patch,create"| WFTaskResults
    R_Runner -->|"*"| Deployments
    R_Runner -->|"*"| KubeflowAll
    R_Runner -->|"*"| Jobs

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PA fill:#4a90e2,stroke:#333,color:#fff
    style SA_SWF fill:#4a90e2,stroke:#333,color:#fff
    style SA_Cache fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,color:#fff
    style CR_Cache fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style R_API fill:#f5a623,stroke:#333
    style R_PA fill:#f5a623,stroke:#333
    style R_SWF fill:#f5a623,stroke:#333
    style R_CacheNS fill:#f5a623,stroke:#333
    style R_Runner fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Workflows fill:#7ed321,stroke:#333
    style SWFs fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333
    style PipelineRuns fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style KubeflowAll fill:#7ed321,stroke:#333
    style WFTaskResults fill:#7ed321,stroke:#333
    style CSR fill:#7ed321,stroke:#333
    style MWH fill:#7ed321,stroke:#333
    style Signers fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style TR fill:#7ed321,stroke:#333
