graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ds-pipeline-*<br/>(API Server)"]
        SA_PA["ds-pipeline-persistenceagent-*<br/>(Persistence Agent)"]
        SA_SWF["ds-pipeline-scheduledworkflow-*<br/>(SWF Controller)"]
        SA_Runner["pipeline-runner<br/>(Pipeline Task Pods)"]
    end

    subgraph Bindings["Role Bindings (managed by DSPO)"]
        RB_API["API Server<br/>RoleBinding"]
        RB_PA["Persistence Agent<br/>RoleBinding"]
        RB_SWF["SWF Controller<br/>RoleBinding"]
        RB_Runner["Pipeline Runner<br/>RoleBinding"]
    end

    subgraph APIServerRole["API Server ClusterRole"]
        direction TB
        API_Argo["argoproj.io<br/>workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        API_SWF["kubeflow.org<br/>scheduledworkflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        API_Pipelines["pipelines.kubeflow.org<br/>pipelines, pipelines/finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
        API_PV["pipelines.kubeflow.org<br/>pipelineversions,<br/>pipelineversions/status,<br/>pipelineversions/finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
        API_Pods["core (&quot;&quot;)<br/>pods, pods/log<br/>get, list"]
        API_Secrets["core (&quot;&quot;)<br/>secrets, configmaps<br/>get, list"]
        API_PVC["core (&quot;&quot;)<br/>persistentvolumeclaims<br/>create, get, delete"]
        API_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        API_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph PersistenceRole["Persistence Agent ClusterRole"]
        PA_Argo["argoproj.io<br/>workflows<br/>get, list, watch"]
        PA_SWF["kubeflow.org<br/>scheduledworkflows<br/>get, list, watch"]
    end

    subgraph SWFRole["SWF Controller ClusterRole"]
        SWF_SWF["kubeflow.org<br/>scheduledworkflows<br/>get, list, watch,<br/>update, patch"]
        SWF_Argo["argoproj.io<br/>workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
    end

    %% Bindings
    SA_API -->|"bound via"| RB_API
    SA_PA -->|"bound via"| RB_PA
    SA_SWF -->|"bound via"| RB_SWF
    SA_Runner -->|"bound via"| RB_Runner

    %% Role grants
    RB_API -->|"grants"| API_Argo
    RB_API -->|"grants"| API_SWF
    RB_API -->|"grants"| API_Pipelines
    RB_API -->|"grants"| API_PV
    RB_API -->|"grants"| API_Pods
    RB_API -->|"grants"| API_Secrets
    RB_API -->|"grants"| API_PVC
    RB_API -->|"grants"| API_TokenReview
    RB_API -->|"grants"| API_SAR

    RB_PA -->|"grants"| PA_Argo
    RB_PA -->|"grants"| PA_SWF

    RB_SWF -->|"grants"| SWF_SWF
    RB_SWF -->|"grants"| SWF_Argo

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PA fill:#4a90e2,stroke:#333,color:#fff
    style SA_SWF fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#50c878,stroke:#333,color:#fff

    style RB_API fill:#b8d4f0,stroke:#333
    style RB_PA fill:#b8d4f0,stroke:#333
    style RB_SWF fill:#b8d4f0,stroke:#333
    style RB_Runner fill:#b8d4f0,stroke:#333

    style API_Argo fill:#f5a623,stroke:#333,color:#fff
    style API_SWF fill:#f5a623,stroke:#333,color:#fff
    style API_Pipelines fill:#f5a623,stroke:#333,color:#fff
    style API_PV fill:#f5a623,stroke:#333,color:#fff
    style API_Pods fill:#7ed321,stroke:#333,color:#fff
    style API_Secrets fill:#7ed321,stroke:#333,color:#fff
    style API_PVC fill:#7ed321,stroke:#333,color:#fff
    style API_TokenReview fill:#e85d75,stroke:#333,color:#fff
    style API_SAR fill:#e85d75,stroke:#333,color:#fff

    style PA_Argo fill:#f5a623,stroke:#333,color:#fff
    style PA_SWF fill:#f5a623,stroke:#333,color:#fff

    style SWF_SWF fill:#f5a623,stroke:#333,color:#fff
    style SWF_Argo fill:#f5a623,stroke:#333,color:#fff
