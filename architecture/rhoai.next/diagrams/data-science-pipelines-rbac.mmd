graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Pipeline["ml-pipeline"]
        SA_PA["ml-pipeline-<br/>persistenceagent"]
        SA_SWF["ml-pipeline-<br/>scheduledworkflow"]
        SA_UI["ml-pipeline-ui"]
        SA_Cache["kubeflow-pipelines-<br/>cache"]
        SA_MW["kubeflow-pipelines-<br/>metadata-writer"]
        SA_CD["kubeflow-pipelines-<br/>cache-deployer-sa"]
        SA_Runner["pipeline-runner"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_CD["cache-deployer<br/>ClusterRoleBinding"]
        CRB_Edit["aggregate-to<br/>kubeflow-pipelines-edit"]
        CRB_View["aggregate-to<br/>kubeflow-pipelines-view"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_CD["kubeflow-pipelines-<br/>cache-deployer-clusterrole"]
        CR_Edit["aggregate-to-kubeflow-<br/>pipelines-edit"]
        CR_View["aggregate-to-kubeflow-<br/>pipelines-view"]
    end

    subgraph RoleBindings["Namespace-Scoped Role Bindings"]
        RB_Pipeline["ml-pipeline<br/>RoleBinding"]
        RB_PA["ml-pipeline-<br/>persistenceagent<br/>RoleBinding"]
        RB_SWF["ml-pipeline-<br/>scheduledworkflow<br/>RoleBinding"]
        RB_UI["ml-pipeline-ui<br/>RoleBinding"]
        RB_Cache["kubeflow-pipelines-<br/>cache RoleBinding"]
        RB_MW["kubeflow-pipelines-<br/>metadata-writer<br/>RoleBinding"]
        RB_CD_NS["cache-deployer<br/>RoleBinding"]
        RB_Runner["pipeline-runner<br/>RoleBinding"]
    end

    subgraph ClusterResources["ClusterRole Resources"]
        CR_CD_R1["certificates.k8s.io<br/>CSRs, CSR/approval<br/>create, delete, get, update"]
        CR_CD_R2["admissionregistration<br/>mutatingwebhookconfigs<br/>create, delete, get, list, patch"]
        CR_CD_R3["certificates.k8s.io<br/>signers<br/>approve"]

        CR_Edit_R1["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>create, delete, update"]
        CR_Edit_R2["pipelines.kubeflow.org<br/>experiments<br/>archive, create, delete, unarchive"]
        CR_Edit_R3["pipelines.kubeflow.org<br/>runs<br/>archive, create, delete, retry,<br/>terminate, unarchive"]
        CR_Edit_R4["kubeflow.org<br/>scheduledworkflows<br/>*"]
        CR_Edit_R5["argoproj.io<br/>workflows, cronworkflows,<br/>workflowtemplates<br/>*"]

        CR_View_R1["pipelines.kubeflow.org<br/>pipelines, pipelineversions,<br/>experiments, jobs<br/>get, list"]
        CR_View_R2["pipelines.kubeflow.org<br/>runs<br/>get, list, readArtifact"]
        CR_View_R3["kubeflow.org<br/>viewers<br/>create, get, delete"]
    end

    %% ClusterRole bindings
    SA_CD -->|"bound via"| CRB_CD
    CRB_CD -->|"grants"| CR_CD
    CR_CD -->|"permissions"| CR_CD_R1
    CR_CD -->|"permissions"| CR_CD_R2
    CR_CD -->|"permissions"| CR_CD_R3

    %% Aggregation ClusterRoles (multi-user)
    CR_Edit -->|"aggregated permissions"| CR_Edit_R1
    CR_Edit -->|"aggregated permissions"| CR_Edit_R2
    CR_Edit -->|"aggregated permissions"| CR_Edit_R3
    CR_Edit -->|"aggregated permissions"| CR_Edit_R4
    CR_Edit -->|"aggregated permissions"| CR_Edit_R5

    CR_View -->|"aggregated permissions"| CR_View_R1
    CR_View -->|"aggregated permissions"| CR_View_R2
    CR_View -->|"aggregated permissions"| CR_View_R3

    %% Namespace-scoped bindings
    SA_Pipeline -->|"bound via"| RB_Pipeline
    SA_PA -->|"bound via"| RB_PA
    SA_SWF -->|"bound via"| RB_SWF
    SA_UI -->|"bound via"| RB_UI
    SA_Cache -->|"bound via"| RB_Cache
    SA_MW -->|"bound via"| RB_MW
    SA_CD -->|"bound via"| RB_CD_NS
    SA_Runner -->|"bound via"| RB_Runner

    %% Styling
    style SA_Pipeline fill:#4a90e2,color:#fff
    style SA_PA fill:#4a90e2,color:#fff
    style SA_SWF fill:#4a90e2,color:#fff
    style SA_UI fill:#4a90e2,color:#fff
    style SA_Cache fill:#4a90e2,color:#fff
    style SA_MW fill:#4a90e2,color:#fff
    style SA_CD fill:#4a90e2,color:#fff
    style SA_Runner fill:#e74c3c,color:#fff

    style CR_CD fill:#f5a623,color:#fff
    style CR_Edit fill:#f5a623,color:#fff
    style CR_View fill:#f5a623,color:#fff

    style CR_CD_R1 fill:#7ed321
    style CR_CD_R2 fill:#7ed321
    style CR_CD_R3 fill:#7ed321
    style CR_Edit_R1 fill:#7ed321
    style CR_Edit_R2 fill:#7ed321
    style CR_Edit_R3 fill:#7ed321
    style CR_Edit_R4 fill:#7ed321
    style CR_Edit_R5 fill:#7ed321
    style CR_View_R1 fill:#7ed321
    style CR_View_R2 fill:#7ed321
    style CR_View_R3 fill:#7ed321

    style SA_Runner fill:#e74c3c,color:#fff
