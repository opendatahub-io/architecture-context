    style CR_CD fill:#f5a623,stroke:#333,color:#fff
    style CR_Edit fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#f5a623,stroke:#333,color:#fff

    style Res_CSR fill:#7ed321,stroke:#333,color:#fff
    style Res_Webhook fill:#7ed321,stroke:#333,color:#fff
