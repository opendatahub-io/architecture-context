graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Pipeline["ml-pipeline"]
        SA_SW["ml-pipeline-<br/>scheduledworkflow"]
        SA_PA["ml-pipeline-<br/>persistenceagent"]
        SA_Cache["kubeflow-pipelines-<br/>cache"]
        SA_Runner["pipeline-runner"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        CRB_Pipeline["ml-pipeline"]
        CRB_SW["ml-pipeline-<br/>scheduledworkflow-binding"]
        CRB_PA["ml-pipeline-<br/>persistenceagent-binding"]
        CRB_Cache["kubeflow-pipelines-<br/>cache-binding"]
        CRB_Runner["pipeline-runner-<br/>binding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Pipeline["ml-pipeline"]
        CR_SW["ml-pipeline-<br/>scheduledworkflow-role"]
        CR_PA["ml-pipeline-<br/>persistenceagent-role"]
        CR_Cache["kubeflow-pipelines-<br/>cache-role"]
        CR_Runner["pipeline-runner"]
    end

    subgraph Resources_Pipeline["ml-pipeline Resources"]
        R_Pods["core<br/>pods, pods/log<br/><i>get, list, delete</i>"]
        R_Workflows["argoproj.io<br/>workflows<br/><i>create, get, list, watch,<br/>update, patch, delete</i>"]
        R_SW_Res["kubeflow.org<br/>scheduledworkflows,<br/>scheduledworkflows/finalizers<br/><i>create, get, list,<br/>update, patch, delete</i>"]
        R_Pipelines["pipelines.kubeflow.org<br/>pipelines<br/><i>get, list, watch</i>"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
        R_TR["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
    end

    subgraph Resources_SW["scheduledworkflow Resources"]
        R_SW_WF["argoproj.io<br/>workflows<br/><i>create, get, list, watch,<br/>update, patch, delete</i>"]
        R_SW_SW["kubeflow.org<br/>scheduledworkflows,<br/>scheduledworkflows/finalizers<br/><i>create, get, list, watch,<br/>update, patch, delete</i>"]
        R_SW_Runs["pipelines.kubeflow.org<br/>runs<br/><i>create</i>"]
        R_SW_Events["core<br/>events<br/><i>create, patch</i>"]
    end

    subgraph Resources_PA["persistenceagent Resources"]
        R_PA_WF["argoproj.io<br/>workflows<br/><i>get, list, watch</i>"]
        R_PA_SW["kubeflow.org<br/>scheduledworkflows<br/><i>get, list, watch</i>"]
        R_PA_Runs["pipelines.kubeflow.org<br/>runs<br/><i>reportMetrics, readArtifact</i>"]
    end

    subgraph Resources_Cache["cache Resources"]
        R_C_Pods["core<br/>pods<br/><i>get, list, watch,<br/>update, patch</i>"]
        R_C_CM["core<br/>configmaps<br/><i>get</i>"]
        R_C_WF["argoproj.io<br/>workflows<br/><i>get, list, watch,<br/>update, patch</i>"]
    end

    subgraph Resources_Runner["pipeline-runner Resources"]
        R_R_Secrets["core<br/>secrets<br/><i>get</i>"]
        R_R_CM["core<br/>configmaps<br/><i>get, watch, list</i>"]
        R_R_PV["core<br/>persistentvolumes,<br/>persistentvolumeclaims<br/><i>*</i>"]
        R_R_Pods["core<br/>pods, pods/exec,<br/>pods/log, services<br/><i>*</i>"]
        R_R_Apps["apps, extensions<br/>deployments, replicasets<br/><i>*</i>"]
        R_R_KF["kubeflow.org<br/>*<br/><i>*</i>"]
        R_R_Batch["batch<br/>jobs<br/><i>*</i>"]
        R_R_Argo["argoproj.io<br/>workflows,<br/>workflowtaskresults<br/><i>get, list, watch,<br/>update, patch, create</i>"]
    end

    %% Bindings
    SA_Pipeline -->|"bound via"| CRB_Pipeline
    SA_SW -->|"bound via"| CRB_SW
    SA_PA -->|"bound via"| CRB_PA
    SA_Cache -->|"bound via"| CRB_Cache
    SA_Runner -->|"bound via"| CRB_Runner

    CRB_Pipeline -->|"grants"| CR_Pipeline
    CRB_SW -->|"grants"| CR_SW
    CRB_PA -->|"grants"| CR_PA
    CRB_Cache -->|"grants"| CR_Cache
    CRB_Runner -->|"grants"| CR_Runner

    %% ml-pipeline permissions
    CR_Pipeline --> R_Pods
    CR_Pipeline --> R_Workflows
    CR_Pipeline --> R_SW_Res
    CR_Pipeline --> R_Pipelines
    CR_Pipeline --> R_SAR
    CR_Pipeline --> R_TR

    %% scheduledworkflow permissions
    CR_SW --> R_SW_WF
    CR_SW --> R_SW_SW
    CR_SW --> R_SW_Runs
    CR_SW --> R_SW_Events

    %% persistenceagent permissions
    CR_PA --> R_PA_WF
    CR_PA --> R_PA_SW
    CR_PA --> R_PA_Runs

    %% cache permissions
    CR_Cache --> R_C_Pods
    CR_Cache --> R_C_CM
    CR_Cache --> R_C_WF

    %% pipeline-runner permissions
    CR_Runner --> R_R_Secrets
    CR_Runner --> R_R_CM
    CR_Runner --> R_R_PV
    CR_Runner --> R_R_Pods
    CR_Runner --> R_R_Apps
    CR_Runner --> R_R_KF
    CR_Runner --> R_R_Batch
    CR_Runner --> R_R_Argo

    %% Styling
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_SW fill:#4a90e2,stroke:#333,color:#fff
    style SA_PA fill:#4a90e2,stroke:#333,color:#fff
    style SA_Cache fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,color:#fff

    style CR_Pipeline fill:#f5a623,stroke:#333,color:#000
    style CR_SW fill:#f5a623,stroke:#333,color:#000
    style CR_PA fill:#f5a623,stroke:#333,color:#000
    style CR_Cache fill:#f5a623,stroke:#333,color:#000
    style CR_Runner fill:#f5a623,stroke:#333,color:#000

    style CRB_Pipeline fill:#e8e8e8,stroke:#333
    style CRB_SW fill:#e8e8e8,stroke:#333
    style CRB_PA fill:#e8e8e8,stroke:#333
    style CRB_Cache fill:#e8e8e8,stroke:#333
    style CRB_Runner fill:#e8e8e8,stroke:#333
