    style SA_SW fill:#4a90e2,color:#fff
    style SA_PA fill:#4a90e2,color:#fff
    style SA_Cache fill:#4a90e2,color:#fff
    style SA_Runner fill:#4a90e2,color:#fff

    style CR_Pipeline fill:#f5a623,color:#fff
    style CR_SW fill:#f5a623,color:#fff
    style CR_PA fill:#f5a623,color:#fff
    style CR_Cache fill:#f5a623,color:#fff
    style CR_Runner fill:#f5a623,color:#fff

