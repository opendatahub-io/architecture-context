graph TD
    subgraph "Service Accounts (Inherited)"
        SA_LLS["Llama Stack Server SA<br/><i>(deployment-specific)</i>"]
        SA_KFP["KFP Pipeline Runner SA<br/><i>(pipeline execution namespace)</i>"]
    end

    subgraph "Required Permissions (No RBAC Manifests Defined)"
        direction TB
        Note["No ClusterRoles or RoleBindings<br/>defined by this component.<br/>RBAC is inherited from the<br/>execution environment."]
    end

    subgraph "Implicit Resource Access"
        direction TB
        CM["ConfigMaps<br/><i>trustyai-service-operator-config</i>"]
        Secrets["Secrets<br/><i>{S3 credentials secret}</i>"]
        Pods["Pods / PipelineRuns<br/><i>KFP execution pods</i>"]
    end

    subgraph "Required Verbs"
        CMVerbs["get, list"]
        SecretVerbs["get (mounted as env)"]
        PodVerbs["create, get, list, watch"]
    end

    subgraph "Target Namespaces"
        NS1["redhat-ods-applications"]
        NS2["opendatahub"]
        NS3["{pipeline execution namespace}"]
    end

    SA_LLS -->|"needs"| CM
    SA_KFP -->|"needs"| Secrets
    SA_KFP -->|"needs"| Pods

    CM --> CMVerbs
    Secrets --> SecretVerbs
    Pods --> PodVerbs

    CM --> NS1
    CM --> NS2
    Secrets --> NS3
    Pods --> NS3

    subgraph "Authentication Mechanisms"
        Auth1["KFP API<br/>Bearer Token<br/>(OpenShift OAuth)<br/><i>Pydantic SecretStr</i>"]
        Auth2["S3 Storage<br/>AWS IAM<br/>(ACCESS_KEY_ID,<br/>SECRET_ACCESS_KEY)"]
        Auth3["Kubernetes API<br/>Bearer Token<br/>(kubeconfig)"]
    end

    SA_LLS -.->|"uses"| Auth1
    SA_LLS -.->|"uses"| Auth3
    SA_KFP -.->|"uses"| Auth2

    style SA_LLS fill:#4a90e2,color:#fff
    style SA_KFP fill:#4a90e2,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style CM fill:#7ed321,color:#fff
    style Secrets fill:#f5a623,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Auth1 fill:#e8e8e8,stroke:#333
    style Auth2 fill:#e8e8e8,stroke:#333
    style Auth3 fill:#e8e8e8,stroke:#333
