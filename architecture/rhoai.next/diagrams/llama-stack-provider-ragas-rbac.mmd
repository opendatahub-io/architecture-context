graph TD
    subgraph NoteBox["Note"]
        RBACNote["⚠ No RBAC ClusterRoles or RoleBindings<br/>defined by this component.<br/>Provider relies on Llama Stack server's<br/>ServiceAccount and user-provided credentials."]
    end

    subgraph "Runtime Identity"
        SA["Llama Stack Server<br/>ServiceAccount<br/>(host process SA)"]
    end

    subgraph "Secrets Used (Manual Provisioning)"
        S3Secret["S3 Credentials<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_DEFAULT_REGION"]
        KFPSecret["kubeflow-pipelines-token<br/>(Opaque)<br/>KFP API Bearer Token"]
        InferSecret["llama-stack-inference-<br/>model-secret (Opaque)<br/>vLLM URL, API token,<br/>TLS verify, model name"]
        AWSSecret["aws-credentials<br/>(Opaque)<br/>AWS creds for<br/>LlamaStack pod"]
    end

    subgraph "Authentication Targets"
        KFPAPI["Kubeflow Pipelines API<br/>POST, GET<br/>Auth: Bearer Token"]
        S3API["S3 Storage<br/>PUT, GET<br/>Auth: AWS IAM"]
        K8sAPI["Kubernetes API<br/>GET<br/>Auth: SA Token / kubeconfig"]
    end

    subgraph "Credential Injection (KFP Pods)"
        KFPPod["KFP Pipeline Pod"]
    end

    %% Identity flows
    SA -->|"runs as"| KFPPod

    %% Secret to target
    KFPSecret -->|"env: KUBEFLOW_PIPELINES_TOKEN<br/>or kubeconfig fallback"| KFPAPI
    S3Secret -->|"injected via<br/>kubernetes.use_secret_as_env()"| KFPPod
    AWSSecret -->|"mounted into pod"| KFPPod
    InferSecret -->|"configures inference<br/>backend connection"| SA

    %% Pod to targets
    KFPPod -->|"Bearer Token"| KFPAPI
    KFPPod -->|"AWS IAM"| S3API
    SA -->|"ServiceAccount token"| K8sAPI

    %% K8s API access details
    K8sAPI -->|"GET ConfigMaps<br/>redhat-ods-applications<br/>or opendatahub namespace"| ConfigMap["trustyai-service-<br/>operator-config<br/>ConfigMap"]

    style RBACNote fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style S3Secret fill:#f8cecc,stroke:#b85450
    style KFPSecret fill:#f8cecc,stroke:#b85450
    style InferSecret fill:#f8cecc,stroke:#b85450
    style AWSSecret fill:#f8cecc,stroke:#b85450
    style KFPAPI fill:#f5a623,stroke:#333,color:#fff
    style S3API fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style KFPPod fill:#d5e8d4,stroke:#82b366
    style ConfigMap fill:#e8e8e8,stroke:#333
