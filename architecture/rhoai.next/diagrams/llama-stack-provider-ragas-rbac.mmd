graph TD
    subgraph NoteBox["RBAC Status"]
        RBACNote["No RBAC roles defined by this component.<br/>Relies on Llama Stack server's ServiceAccount<br/>and user-provided credentials."]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB

        subgraph KFPAuth["Kubeflow Pipelines Auth"]
            KFPToken["KUBEFLOW_PIPELINES_TOKEN<br/>(env var)"]
            Kubeconfig["kubeconfig token<br/>(fallback)"]
            KFPEndpoint["KFP API Server<br/>443/TCP HTTPS"]
            KFPToken -->|"Bearer Token"| KFPEndpoint
            Kubeconfig -->|"Bearer Token<br/>(extracted)"| KFPEndpoint
        end

        subgraph S3Auth["S3 Storage Auth"]
            AWSSecret["Kubernetes Secret<br/>(aws-credentials)"]
            AWSKeys["AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_DEFAULT_REGION"]
            S3Endpoint["S3-compatible Storage<br/>443/TCP HTTPS"]
            AWSSecret -->|"injected via<br/>kubernetes.use_secret_as_env()"| AWSKeys
            AWSKeys -->|"AWS IAM"| S3Endpoint
        end

        subgraph K8sAuth["Kubernetes API Auth"]
            SA["ServiceAccount Token<br/>(or kubeconfig)"]
            K8sEndpoint["Kubernetes API<br/>443/TCP HTTPS"]
            ConfigMap["trustyai-service-operator-config<br/>ConfigMap"]
            SA -->|"Bearer Token"| K8sEndpoint
            K8sEndpoint -->|"GET ConfigMap"| ConfigMap
        end

        subgraph InferenceAuth["Inference Backend Auth"]
            InferenceSecret["llama-stack-inference-model-secret<br/>(Kubernetes Secret)"]
            InferenceKeys["vLLM URL<br/>API Token<br/>TLS verification<br/>Model name"]
            InferenceEndpoint["vLLM / Inference Backend"]
            InferenceSecret -->|"mounted"| InferenceKeys
            InferenceKeys -->|"API Token"| InferenceEndpoint
        end
    end

    subgraph "Secrets Inventory"
        direction TB
        Sec1["(user-provided S3 credentials)<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        Sec2["kubeflow-pipelines-token<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        Sec3["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        Sec4["aws-credentials<br/>Type: Opaque<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    style RBACNote fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KFPToken fill:#4a90e2,stroke:#333,color:#fff
    style Kubeconfig fill:#4a90e2,stroke:#333,color:#fff
    style AWSSecret fill:#4a90e2,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style InferenceSecret fill:#4a90e2,stroke:#333,color:#fff
    style KFPEndpoint fill:#7ed321,stroke:#333,color:#fff
    style S3Endpoint fill:#f5a623,stroke:#333,color:#fff
    style K8sEndpoint fill:#f5a623,stroke:#333,color:#fff
    style InferenceEndpoint fill:#f5a623,stroke:#333,color:#fff
    style ConfigMap fill:#ddd,stroke:#333
    style Sec1 fill:#f8cecc,stroke:#b85450
    style Sec2 fill:#f8cecc,stroke:#b85450
    style Sec3 fill:#f8cecc,stroke:#b85450
    style Sec4 fill:#f8cecc,stroke:#b85450
