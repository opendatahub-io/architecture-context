graph TD
    subgraph "Runtime Identity"
        SA_LLS["Service Account<br/>(Llama Stack Server)<br/><i>inherited from host</i>"]
        SA_KFP["Service Account<br/>(KFP Pipeline Pods)<br/><i>inherited from DSP</i>"]
    end

    subgraph "No RBAC Manifests Defined"
        Note["This component does not define<br/>its own RBAC resources.<br/>Permissions are inherited from<br/>the execution environment."]
    end

    subgraph "Required Permissions (Inherited)"
        direction TB
        ConfigMapRead["ConfigMap Read<br/><i>trustyai-service-operator-config</i>"]
        KubeconfigRead["Kubeconfig Token<br/>Extraction"]
    end

    subgraph "Candidate Namespaces"
        NS1["redhat-ods-applications"]
        NS2["opendatahub"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        KFPAuth["KFP API Auth<br/>Bearer Token (OpenShift OAuth)<br/><i>via KUBEFLOW_PIPELINES_TOKEN</i><br/><i>or kubeconfig extraction</i>"]
        S3Auth["S3 Auth<br/>AWS IAM Credentials<br/><i>from Kubernetes Secret</i><br/><i>mounted as env vars</i>"]
        K8sAuth["K8s API Auth<br/>Bearer Token<br/><i>from kubeconfig</i>"]
    end

    subgraph "Secrets"
        S3Secret["{KUBEFLOW_S3_CREDENTIALS_SECRET_NAME}<br/>Type: Opaque<br/>Keys: ACCESS_KEY_ID,<br/>SECRET_ACCESS_KEY,<br/>DEFAULT_REGION<br/><i>User-created, no auto-rotate</i>"]
        TokenSecret["KUBEFLOW_PIPELINES_TOKEN<br/>Type: SecretStr (env var)<br/><i>Pydantic redaction in logs</i><br/><i>No auto-rotate</i>"]
    end

    SA_LLS -->|"needs"| ConfigMapRead
    SA_LLS -->|"needs"| KubeconfigRead
    SA_KFP -->|"needs"| S3Auth

    ConfigMapRead -->|"in namespace"| NS1
    ConfigMapRead -->|"in namespace"| NS2

    SA_LLS -->|"uses"| KFPAuth
    SA_LLS -->|"uses"| K8sAuth
    SA_KFP -->|"uses"| S3Auth

    KFPAuth -->|"token from"| TokenSecret
    S3Auth -->|"creds from"| S3Secret

    style SA_LLS fill:#4a90e2,color:#fff
    style SA_KFP fill:#4a90e2,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style ConfigMapRead fill:#f5a623
    style KubeconfigRead fill:#f5a623
    style KFPAuth fill:#7ed321,color:#fff
    style S3Auth fill:#7ed321,color:#fff
    style K8sAuth fill:#7ed321,color:#fff
    style S3Secret fill:#e74c3c,color:#fff
    style TokenSecret fill:#e74c3c,color:#fff
    style NS1 fill:#dae8fc,stroke:#6c8ebf
    style NS2 fill:#dae8fc,stroke:#6c8ebf
