graph TD
    subgraph "Service Account (Runtime)"
        SA["ServiceAccount<br/>(KFP Pod / Remote Provider)"]
    end

    subgraph "Runtime RBAC Requirements"
        direction TB
        Note["No RBAC manifests defined<br/>by this component.<br/>Runtime permissions required<br/>via kubeconfig or SA."]
    end

    subgraph "Required API Permissions"
        direction TB
        ConfigMaps["core (v1)<br/>ConfigMaps"]
        Secrets["core (v1)<br/>Secrets"]
    end

    subgraph "ConfigMap Access Details"
        direction TB
        CM1["trustyai-service-operator-config<br/>Namespace: redhat-ods-applications<br/>Key: ragas-provider-image"]
        CM2["trustyai-service-operator-config<br/>Namespace: opendatahub<br/>Key: ragas-provider-image"]
    end

    subgraph "Secret Access Details"
        direction TB
        S1["AWS credentials secret<br/>(configurable name via<br/>KUBEFLOW_S3_CREDENTIALS_SECRET_NAME)<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_DEFAULT_REGION"]
        S2["kubeflow-pipelines-token<br/>Key: KUBEFLOW_PIPELINES_TOKEN"]
        S3["llama-stack-inference-model-secret<br/>Keys: vLLM URL, model name,<br/>API token, TLS verification"]
    end

    subgraph "External Auth Mechanisms"
        direction TB
        KFPAuth["Kubeflow Pipelines API<br/>Auth: Bearer Token<br/>(OpenShift OAuth or<br/>explicit token)<br/>Methods: POST, GET"]
        S3Auth["S3 Storage<br/>Auth: AWS IAM credentials<br/>(from Kubernetes Secret)<br/>Methods: PUT, GET"]
        LSAuth["Llama Stack Inference<br/>Auth: None (configurable)<br/>Network-level access only<br/>Methods: POST"]
    end

    SA -->|"get"| ConfigMaps
    SA -->|"get"| Secrets

    ConfigMaps --> CM1
    ConfigMaps --> CM2

    Secrets --> S1
    Secrets --> S2
    Secrets --> S3

    S2 -.->|"token used for"| KFPAuth
    S1 -.->|"credentials used for"| S3Auth

    style SA fill:#4a90e2,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#333
    style ConfigMaps fill:#f5a623,color:#fff
    style Secrets fill:#e74c3c,color:#fff
    style CM1 fill:#fff2cc,stroke:#d6b656
    style CM2 fill:#fff2cc,stroke:#d6b656
    style S1 fill:#fce4ec,stroke:#c62828
    style S2 fill:#fce4ec,stroke:#c62828
    style S3 fill:#fce4ec,stroke:#c62828
    style KFPAuth fill:#d5e8d4,stroke:#82b366
    style S3Auth fill:#d5e8d4,stroke:#82b366
    style LSAuth fill:#d5e8d4,stroke:#82b366
