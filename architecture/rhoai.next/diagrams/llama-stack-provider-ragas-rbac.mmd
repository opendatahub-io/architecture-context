graph TD
    subgraph "Note: No Explicit RBAC Defined"
        Note["This component does not define its own<br/>RBAC resources (ClusterRoles, RoleBindings).<br/>It inherits permissions from the<br/>Llama Stack server pod's ServiceAccount."]
    end

    subgraph "Inherited Service Account"
        SA["(Llama Stack Pod SA)<br/>ServiceAccount in deployment namespace"]
    end

    subgraph "Required Permissions (Remote Provider)"
        direction TB
        ConfigMapRead["ConfigMap READ<br/>trustyai-service-operator-config"]
        SecretRead["Secret READ<br/>(S3 credentials, KFP token)"]
    end

    subgraph "Target Resources"
        direction TB
        CM_TrustyAI["ConfigMap<br/>trustyai-service-operator-config<br/>Namespace: redhat-ods-applications<br/>or opendatahub<br/>Key: ragas-provider-image"]
        Secret_S3["Secret (Opaque)<br/>S3 credentials<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_DEFAULT_REGION"]
        Secret_KFP["Secret (Opaque)<br/>kubeflow-pipelines-token<br/>KUBEFLOW_PIPELINES_TOKEN<br/>(handled as SecretStr)"]
        Secret_Inference["Secret (Opaque)<br/>llama-stack-inference-model-secret<br/>INFERENCE_MODEL, VLLM_URL<br/>VLLM_TLS_VERIFY, VLLM_API_TOKEN"]
        Secret_AWS["Secret (Opaque)<br/>aws-credentials<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_DEFAULT_REGION"]
    end

    subgraph "External API Access"
        KFP_API["Kubeflow Pipelines API<br/>Auth: Bearer Token<br/>POST, GET"]
        S3_API["S3 Storage API<br/>Auth: AWS IAM<br/>PUT, GET"]
        K8s_API["Kubernetes API<br/>Auth: SA Token / kubeconfig<br/>GET (ConfigMaps)"]
    end

    SA -->|"needs"| ConfigMapRead
    SA -->|"needs"| SecretRead
    ConfigMapRead -->|"reads"| CM_TrustyAI
    SecretRead -->|"mounts"| Secret_S3
    SecretRead -->|"mounts"| Secret_KFP
    SecretRead -->|"mounts"| Secret_Inference
    SecretRead -->|"mounts"| Secret_AWS

    SA -->|"authenticates to"| KFP_API
    SA -->|"authenticates to"| S3_API
    SA -->|"authenticates to"| K8s_API

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style ConfigMapRead fill:#f5a623,stroke:#333
    style SecretRead fill:#f5a623,stroke:#333
    style CM_TrustyAI fill:#7ed321,stroke:#333
    style Secret_S3 fill:#e74c3c,stroke:#333,color:#fff
    style Secret_KFP fill:#e74c3c,stroke:#333,color:#fff
    style Secret_Inference fill:#e74c3c,stroke:#333,color:#fff
    style Secret_AWS fill:#e74c3c,stroke:#333,color:#fff
    style KFP_API fill:#e8e8e8,stroke:#333
    style S3_API fill:#e8e8e8,stroke:#333
    style K8s_API fill:#e8e8e8,stroke:#333
