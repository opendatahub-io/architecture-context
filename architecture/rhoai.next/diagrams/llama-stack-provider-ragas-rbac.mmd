graph TD
    subgraph "Llama Stack Server Pod"
        SA["ServiceAccount<br/>(inherited from LlamaStackDistribution CR)"]
    end

    subgraph "RBAC: No Explicit Roles Defined"
        direction TB
        Note["This component does not define its own RBAC.<br/>It inherits RBAC from the Llama Stack server pod.<br/>Remote mode requires ConfigMap read access."]
    end

    subgraph "Required Permissions (Remote Mode)"
        ConfigMapRead["ConfigMap Read Access<br/>Namespaces: redhat-ods-applications, opendatahub"]
    end

    subgraph "Secrets Accessed"
        S1["kubeflow-pipelines-token<br/>Type: Opaque<br/>Purpose: KFP API Bearer Token<br/>Provisioned: Manual (oc whoami -t)<br/>Auto-Rotate: No"]
        S2["aws-credentials<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_DEFAULT_REGION<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        S3["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Keys: INFERENCE_MODEL, VLLM_URL,<br/>VLLM_TLS_VERIFY, VLLM_API_TOKEN<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        S4["S3 credentials secret<br/>(KUBEFLOW_S3_CREDENTIALS_SECRET_NAME)<br/>Type: Opaque<br/>Purpose: AWS creds for KFP pods<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication Flows"
        A1["Llama Stack eval API<br/>Auth: None (app-level)<br/>Enforcement: Platform ingress"]
        A2["KFP API<br/>Auth: Bearer Token (OpenShift user token)<br/>Enforcement: KFP server"]
        A3["S3 Storage<br/>Auth: AWS IAM credentials<br/>Enforcement: AWS/MinIO IAM"]
        A4["Kubernetes API<br/>Auth: SA Token / kubeconfig<br/>Enforcement: K8s RBAC"]
    end

    SA -->|"inherits pod RBAC"| Note
    SA -.->|"needs for remote mode"| ConfigMapRead
    SA -->|"env vars from"| S1
    SA -->|"env vars from"| S2
    SA -->|"env vars from"| S3
    SA -.->|"mounted into KFP pods"| S4

    SA -->|"serves"| A1
    SA -->|"calls with token"| A2
    SA -->|"calls with creds"| A3
    SA -->|"calls with SA token"| A4

    style SA fill:#4a90e2,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style ConfigMapRead fill:#f5a623,color:#fff
    style S1 fill:#e74c3c,color:#fff
    style S2 fill:#e74c3c,color:#fff
    style S3 fill:#e74c3c,color:#fff
    style S4 fill:#e74c3c,color:#fff
    style A1 fill:#d5e8d4,stroke:#82b366
    style A2 fill:#d5e8d4,stroke:#82b366
    style A3 fill:#d5e8d4,stroke:#82b366
    style A4 fill:#d5e8d4,stroke:#82b366
