graph TD
    subgraph "RBAC Model (Inherited - No Manifests Defined)"
        direction TB

        Note["Note: This component does not define its own RBAC manifests.<br/>RBAC is inherited from the execution environment."]

        subgraph "Llama Stack Server Context"
            SA_LLS["ServiceAccount<br/><i>(Llama Stack Server SA)</i><br/>Inherited from deployment"]
        end

        subgraph "KFP Pipeline Context"
            SA_KFP["ServiceAccount<br/><i>(KFP Pipeline Runner SA)</i><br/>Inherited from DSP"]
        end

        subgraph "Required API Access (ConfigMap)"
            ConfigMap["ConfigMap<br/><i>trustyai-service-operator-config</i><br/>Namespaces: redhat-ods-applications,<br/>opendatahub"]
        end

        subgraph "Required API Access (KFP)"
            KFPAPI["Kubeflow Pipelines API<br/>/apis/v2beta1/*<br/>Methods: GET, POST"]
        end

        subgraph "Secrets Access"
            S3Secret["Secret<br/><i>{KUBEFLOW_S3_CREDENTIALS_SECRET_NAME}</i><br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_DEFAULT_REGION"]
            KFPToken["Token<br/><i>KUBEFLOW_PIPELINES_TOKEN</i><br/>Type: SecretStr (Pydantic)<br/>Redacted in logs"]
        end
    end

    %% Relationships
    SA_LLS -->|"needs read access"| ConfigMap
    SA_LLS -->|"uses for KFP auth"| KFPToken
    SA_KFP -->|"mounted as env vars<br/>via use_secret_as_env()"| S3Secret
    SA_KFP -->|"implicit access via<br/>pipeline runner role"| KFPAPI

    %% Auth flow
    KFPToken -->|"Bearer Token"| KFPAPI

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#000
    style SA_LLS fill:#4a90e2,color:#fff
    style SA_KFP fill:#4a90e2,color:#fff
    style ConfigMap fill:#f5a623,color:#000
    style KFPAPI fill:#f5a623,color:#000
    style S3Secret fill:#e74c3c,color:#fff
    style KFPToken fill:#e74c3c,color:#fff
