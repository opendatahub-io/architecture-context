graph TB
    subgraph GD["Guardrails Detectors"]
        direction TB

        subgraph Common["Common Library"]
            BaseAPI["DetectorBaseAPI<br/>(FastAPI base class)"]
            Schemas["Pydantic Schemas<br/>(request/response)"]
            Instrumented["InstrumentedDetector<br/>(Prometheus metrics)"]
            Logging["Structured Logging"]
        end

        subgraph BuiltIn["Built-in Detector<br/>Port: 8080/TCP"]
            RegexDet["Regex Detectors<br/>(PII detection)"]
            FileTypeDet["File-Type Detectors<br/>(JSON/XML/YAML validation)"]
            CustomDet["Custom Detectors<br/>(user-defined Python)"]
            DetRegistry["Detector Registry"]
            StaticAnalysis["Static Code Analysis<br/>(AST-based security)"]
        end

        subgraph HFDetector["HuggingFace Detector<br/>Port: 8000/TCP"]
            SeqClassifier["AutoModelForSequenceClassification"]
            TokenClassifier["AutoModelForTokenClassification"]
            GraniteLM["GraniteForCausalLM"]
            ModelDispatch["Runtime Model Dispatch"]
        end

        subgraph JudgeDetector["LLM Judge Detector<br/>Port: 8000/TCP"]
            JudgeEval["vllm_judge Evaluator"]
            Metrics["Built-in Metrics<br/>(safety, toxicity, accuracy)"]
        end
    end

    %% Common library relationships
    BaseAPI --> RegexDet
    BaseAPI --> FileTypeDet
    BaseAPI --> CustomDet
    BaseAPI --> ModelDispatch
    BaseAPI --> JudgeEval
    Instrumented --> DetRegistry
    StaticAnalysis -.->|validates| CustomDet

    %% Model dispatch
    ModelDispatch --> SeqClassifier
    ModelDispatch --> TokenClassifier
    ModelDispatch --> GraniteLM

    %% External callers
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltIn
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| HFDetector
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| JudgeDetector

    %% External dependencies
    HFDetector -->|model download<br/>9000/TCP| S3["S3/MinIO<br/>Model Storage"]
    JudgeDetector -->|LLM inference<br/>8080/TCP| vLLM["vLLM Server"]
    Prometheus["Prometheus"] -.->|scrape /metrics| BuiltIn
    Prometheus -.->|scrape /metrics| HFDetector
    Prometheus -.->|scrape /metrics| JudgeDetector

    %% Deployment platform
    KServe["KServe"] -.->|deploys| HFDetector
    KServe -.->|deploys| JudgeDetector
    Istio["Istio Service Mesh"] -.->|mTLS sidecar| HFDetector
    Istio -.->|mTLS sidecar| JudgeDetector

    %% Styling
    style BuiltIn fill:#4a90e2,stroke:#333,color:#fff
    style HFDetector fill:#4a90e2,stroke:#333,color:#fff
    style JudgeDetector fill:#4a90e2,stroke:#333,color:#fff
    style Common fill:#b8d4f0,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style vLLM fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
