graph TB
    subgraph "Guardrails Detectors"
        subgraph "Common Library"
            BaseAPI["DetectorBaseAPI<br/>(FastAPI Base Class)"]
            Schemas["Pydantic Schemas<br/>(Request/Response)"]
            Prometheus["Prometheus Instrumentation<br/>(trustyai_guardrails_*)"]
        end

        subgraph "Built-in Detector (8080/TCP)"
            BuiltInApp["Built-in App<br/>(FastAPI/uvicorn)"]
            RegexRegistry["RegexDetectorRegistry<br/>(PII: email, SSN, CC, phone, IP)"]
            FileTypeRegistry["FileTypeDetectorRegistry<br/>(JSON, XML, YAML validation)"]
            CustomRegistry["CustomDetectorRegistry<br/>(Python custom detectors)"]
            StaticAnalysis["Static Code Analysis Gate<br/>(AST-based sandbox)"]

            BuiltInApp --> RegexRegistry
            BuiltInApp --> FileTypeRegistry
            BuiltInApp --> CustomRegistry
            CustomRegistry -->|validates| StaticAnalysis
        end

        subgraph "HuggingFace Detector (8000/TCP)"
            HFApp["HuggingFace App<br/>(FastAPI/uvicorn + PyTorch)"]
            SeqClassifier["Sequence Classification<br/>(AutoModelForSequenceClassification)"]
            TokenClassifier["Token Classification<br/>(AutoModelForTokenClassification)"]
            CausalLM["Causal LM<br/>(GraniteForCausalLM)"]

            HFApp --> SeqClassifier
            HFApp --> TokenClassifier
            HFApp --> CausalLM
        end

        subgraph "LLM Judge Detector (8000/TCP)"
            JudgeApp["LLM Judge App<br/>(FastAPI/uvicorn)"]
            VLLMJudge["vllm_judge Library<br/>(evaluation framework)"]

            JudgeApp --> VLLMJudge
        end

        BuiltInApp -.->|extends| BaseAPI
        HFApp -.->|extends| BaseAPI
        JudgeApp -.->|extends| BaseAPI
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| JudgeApp

    KServe["KServe"] -->|deploys as<br/>InferenceService| HFApp
    KServe -->|deploys as<br/>InferenceService| JudgeApp

    StorageInit["KServe Storage<br/>Initializer"] -->|downloads models to<br/>/mnt/models| HFApp

    VLLMJudge -->|OpenAI-compatible API<br/>8080/TCP| VLLMServer["vLLM Server"]

    S3["S3/MinIO Storage"] -->|model weights| StorageInit

    PromScraper["Prometheus"] -->|scrapes /metrics| BuiltInApp
    PromScraper -->|scrapes /metrics| HFApp
    PromScraper -->|scrapes /metrics| JudgeApp

    style BuiltInApp fill:#4a90e2,color:#fff
    style HFApp fill:#4a90e2,color:#fff
    style JudgeApp fill:#4a90e2,color:#fff
    style BaseAPI fill:#6c5ce7,color:#fff
    style Schemas fill:#6c5ce7,color:#fff
    style Prometheus fill:#6c5ce7,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style StorageInit fill:#7ed321,stroke:#333
    style VLLMServer fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style PromScraper fill:#999,stroke:#333
    style RegexRegistry fill:#74b9ff
    style FileTypeRegistry fill:#74b9ff
    style CustomRegistry fill:#74b9ff
    style StaticAnalysis fill:#fd79a8
    style SeqClassifier fill:#74b9ff
    style TokenClassifier fill:#74b9ff
    style CausalLM fill:#74b9ff
    style VLLMJudge fill:#74b9ff
