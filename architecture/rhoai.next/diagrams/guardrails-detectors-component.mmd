graph TB
    subgraph GuardrailsDetectors["Guardrails Detectors"]
        direction TB

        subgraph BuiltIn["odh-built-in-detector<br/>Port: 8080/TCP"]
            BI_API["FastAPI/uvicorn"]
            BI_Regex["Regex PII Detectors<br/>(email, CC, SSN, phone, IP)"]
            BI_FileType["File Type Validators<br/>(JSON, XML, YAML)"]
            BI_Custom["Custom Python Detectors<br/>(AST-sandboxed)"]
            BI_API --> BI_Regex
            BI_API --> BI_FileType
            BI_API --> BI_Custom
        end

        subgraph HFRuntime["odh-guardrails-detector-huggingface-runtime<br/>Port: 8000/TCP"]
            HF_API["FastAPI/uvicorn"]
            HF_SeqClass["Sequence Classification"]
            HF_TokClass["Token Classification<br/>(NER-style spans)"]
            HF_CausalLM["Causal LM<br/>(Granite Guardian)"]
            HF_API --> HF_SeqClass
            HF_API --> HF_TokClass
            HF_API --> HF_CausalLM
        end

        subgraph LLMJudge["guardrails-detector-llm-judge<br/>Port: 8000/TCP"]
            LJ_API["FastAPI/uvicorn"]
            LJ_Metrics["Built-in Metrics<br/>(safety, toxicity, accuracy,<br/>helpfulness, clarity)"]
            LJ_Custom["Custom Criteria<br/>(natural language)"]
            LJ_API --> LJ_Metrics
            LJ_API --> LJ_Custom
        end

        Common["Common Base<br/>(DetectorBaseAPI, health,<br/>metrics, registry)"]
        Common -.->|extends| BI_API
        Common -.->|extends| HF_API
        Common -.->|extends| LJ_API
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>mTLS (Istio)"| BI_API
    Orchestrator -->|"POST /api/v1/text/contents<br/>mTLS (Istio)"| HF_API
    Orchestrator -->|"POST /api/v1/text/contents<br/>mTLS (Istio)"| LJ_API

    S3["S3 / MinIO<br/>9000/TCP"] -->|"model weights"| HF_API
    LJ_API -->|"HTTP 8080/TCP<br/>evaluation requests"| vLLM["vLLM Server<br/>(OpenAI-compatible)"]

    KServe["KServe"] -.->|"InferenceService<br/>ServingRuntime"| HFRuntime
    KServe -.->|"InferenceService<br/>ServingRuntime"| LLMJudge
    Istio["Istio Service Mesh"] -.->|"sidecar injection<br/>mTLS"| GuardrailsDetectors

    Prometheus["Prometheus"] -->|"scrape /metrics"| BI_API
    Prometheus -->|"scrape /metrics"| HF_API
    Prometheus -->|"scrape /metrics"| LJ_API

    style BuiltIn fill:#4a90e2,stroke:#333,color:#fff
    style HFRuntime fill:#4a90e2,stroke:#333,color:#fff
    style LLMJudge fill:#4a90e2,stroke:#333,color:#fff
    style Common fill:#6bb3e0,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
