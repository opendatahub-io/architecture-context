graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        OrcApp["Orchestrator<br/>Invokes detectors on<br/>text generation I/O"]
    end

    subgraph GuardrailsDetectors["Guardrails Detectors"]
        subgraph Common["Common Library"]
            BaseAPI["DetectorBaseAPI<br/>(FastAPI)"]
            Schemas["Pydantic Schemas<br/>(IBM Detector API)"]
            Instrumentation["InstrumentedDetector<br/>(Prometheus)"]
        end

        subgraph BuiltIn["Built-in Detector :8080"]
            BIApp["FastAPI App"]
            Registry["BaseDetectorRegistry"]
            RegexDet["Regex PII Detectors"]
            FileTypeDet["File Type Detectors"]
            CustomDet["Custom Python Detectors<br/>(AST-sandboxed)"]
            Registry --> RegexDet
            Registry --> FileTypeDet
            Registry --> CustomDet
        end

        subgraph HF["HuggingFace Detector :8000"]
            HFApp["FastAPI App"]
            AutoModel["AutoModelForSequenceClassification"]
            GraniteLM["GraniteForCausalLM<br/>(Risk Categories)"]
            HFApp --> AutoModel
            HFApp --> GraniteLM
        end

        subgraph LLMJudge["LLM Judge Detector :8000"]
            LJApp["FastAPI App"]
            VLLMJudge["vLLM Judge Library<br/>(31+ metrics)"]
            LJApp --> VLLMJudge
        end

        BIApp --> BaseAPI
        HFApp --> BaseAPI
        LJApp --> BaseAPI
        BaseAPI --> Schemas
        BaseAPI --> Instrumentation
    end

    OrcApp -->|"POST /api/v1/text/contents<br/>HTTP :8080"| BIApp
    OrcApp -->|"POST /api/v1/text/contents<br/>HTTP :8000 (mTLS via Istio)"| HFApp
    OrcApp -->|"POST /api/v1/text/contents<br/>HTTP :8000 (mTLS via Istio)"| LJApp

    S3["S3/MinIO<br/>Model Storage<br/>:9000"]
    vLLM["vLLM / OpenAI-compatible<br/>LLM Server"]
    Prometheus["Prometheus"]

    S3 -->|"Model files<br/>(KServe Storage Initializer)"| HFApp
    VLLMJudge -->|"HTTP evaluation prompts"| vLLM
    Prometheus -->|"GET /metrics"| BIApp
    Prometheus -->|"GET /metrics"| HFApp
    Prometheus -->|"GET /metrics"| LJApp

    KServe["KServe<br/>(InferenceService +<br/>ServingRuntime CRDs)"]
    Istio["Istio Service Mesh<br/>(mTLS sidecar)"]

    KServe -.->|manages| HF
    KServe -.->|manages| LLMJudge
    Istio -.->|sidecar injection| HF
    Istio -.->|sidecar injection| LLMJudge

    style BuiltIn fill:#4a90e2,stroke:#333,color:#fff
    style HF fill:#4a90e2,stroke:#333,color:#fff
    style LLMJudge fill:#4a90e2,stroke:#333,color:#fff
    style Common fill:#b8d4f0,stroke:#333
    style OrcApp fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
