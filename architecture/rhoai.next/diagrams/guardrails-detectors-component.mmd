graph TB
    subgraph "Guardrails Detectors"
        subgraph CommonLib["Common Library"]
            BaseAPI["DetectorBaseAPI<br/>(FastAPI base class)"]
            Schemas["Pydantic Schemas<br/>(request/response)"]
            Instrumentation["InstrumentedDetector<br/>(Prometheus metrics)"]
            Logging["Structured Logging"]
        end

        subgraph BuiltIn["Built-in Detector<br/>Port: 8080/TCP"]
            RegexDetectors["Regex Detectors<br/>(PII detection)"]
            FileTypeDetectors["File-Type Detectors<br/>(JSON/XML/YAML validation)"]
            CustomDetectors["Custom Python Detectors<br/>(dynamic code loading)"]
            DetectorRegistry["Detector Registry<br/>(function registry pattern)"]
        end

        subgraph HFDetector["HuggingFace Detector<br/>Port: 8000/TCP"]
            SeqClassifier["Sequence Classifier<br/>(AutoModelForSequenceClassification)"]
            TokenClassifier["Token Classifier<br/>(AutoModelForTokenClassification)"]
            GraniteCausal["Granite Guardian<br/>(GraniteForCausalLM)"]
            ModelLoader["Model Loader<br/>(auto-detect architecture)"]
        end

        subgraph JudgeDetector["LLM Judge Detector<br/>Port: 8000/TCP"]
            JudgeApp["Judge Application"]
            VLLMJudge["vllm_judge Library"]
            MetricsAPI["Metrics API<br/>(safety, toxicity, accuracy)"]
        end
    end

    %% Common library relationships
    BuiltIn -->|extends| BaseAPI
    HFDetector -->|extends| BaseAPI
    JudgeDetector -->|extends| BaseAPI
    RegexDetectors -->|uses| Instrumentation
    FileTypeDetectors -->|uses| Instrumentation
    CustomDetectors -->|uses| Instrumentation
    ModelLoader -->|dispatches to| SeqClassifier
    ModelLoader -->|dispatches to| TokenClassifier
    ModelLoader -->|dispatches to| GraniteCausal
    JudgeApp -->|uses| VLLMJudge

    %% External interactions
    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents| BuiltIn
    Orchestrator -->|POST /api/v1/text/contents| HFDetector
    Orchestrator -->|POST /api/v1/text/contents| JudgeDetector

    KServe["KServe Platform"] -->|deploys| HFDetector
    KServe -->|deploys| JudgeDetector

    S3["S3/MinIO Storage<br/>9000/TCP"] -.->|model files| HFDetector
    VLLMServer["vLLM Server<br/>8080/TCP"] -.->|LLM inference| JudgeDetector

    Prometheus["Prometheus"] -->|scrapes /metrics| BuiltIn
    Prometheus -->|scrapes /metrics| HFDetector
    Prometheus -->|scrapes /metrics| JudgeDetector

    Istio["Istio Service Mesh"] -.->|mTLS sidecar| HFDetector
    Istio -.->|mTLS sidecar| JudgeDetector

    %% Styling
    style BaseAPI fill:#4a90e2,color:#fff
    style Schemas fill:#4a90e2,color:#fff
    style Instrumentation fill:#4a90e2,color:#fff
    style Logging fill:#4a90e2,color:#fff
    style RegexDetectors fill:#50c878,color:#fff
    style FileTypeDetectors fill:#50c878,color:#fff
    style CustomDetectors fill:#50c878,color:#fff
    style DetectorRegistry fill:#50c878,color:#fff
    style SeqClassifier fill:#9b59b6,color:#fff
    style TokenClassifier fill:#9b59b6,color:#fff
    style GraniteCausal fill:#9b59b6,color:#fff
    style ModelLoader fill:#9b59b6,color:#fff
    style JudgeApp fill:#e67e22,color:#fff
    style VLLMJudge fill:#e67e22,color:#fff
    style MetricsAPI fill:#e67e22,color:#fff
    style Orchestrator fill:#2c3e50,color:#fff
    style KServe fill:#999,color:#fff
    style S3 fill:#f5a623,color:#fff
    style VLLMServer fill:#f5a623,color:#fff
    style Prometheus fill:#e8e8e8,color:#333
    style Istio fill:#e8e8e8,color:#333
