graph TB
    subgraph "Guardrails Detectors"
        subgraph "Common Library"
            BaseAPI["DetectorBaseAPI<br/>(FastAPI Base Class)"]
            Schemas["Pydantic Schemas<br/>(Request/Response)"]
            Instrumented["InstrumentedDetector<br/>(Prometheus Metrics)"]
            Logging["Structured Logging"]
        end

        subgraph "Built-in Detector :8080"
            BuiltInApp["built-in detector<br/>FastAPI/uvicorn<br/>Port: 8080/TCP"]
            RegexRegistry["Regex Detectors<br/>(PII Detection)"]
            FileTypeRegistry["File-Type Detectors<br/>(JSON/XML/YAML)"]
            CustomRegistry["Custom Detectors<br/>(User Python Code)"]
            StaticAnalysis["Static Code Analysis<br/>(AST-based security)"]

            BuiltInApp --> RegexRegistry
            BuiltInApp --> FileTypeRegistry
            BuiltInApp --> CustomRegistry
            CustomRegistry --> StaticAnalysis
        end

        subgraph "HuggingFace Detector :8000"
            HFApp["HuggingFace detector<br/>FastAPI/uvicorn<br/>Port: 8000/TCP"]
            SeqClassifier["AutoModelForSequenceClassification<br/>(Binary/Multi-class)"]
            TokenClassifier["AutoModelForTokenClassification<br/>(NER Span Detection)"]
            GraniteLM["GraniteForCausalLM<br/>(IBM Granite Guardian)"]

            HFApp --> SeqClassifier
            HFApp --> TokenClassifier
            HFApp --> GraniteLM
        end

        subgraph "LLM Judge Detector :8000"
            JudgeApp["LLM Judge detector<br/>FastAPI/uvicorn<br/>Port: 8000/TCP"]
            VllmJudge["vllm_judge Library"]
            Metrics["Built-in Metrics<br/>(safety, toxicity, accuracy)"]

            JudgeApp --> VllmJudge
            VllmJudge --> Metrics
        end

        BuiltInApp -.->|extends| BaseAPI
        HFApp -.->|extends| BaseAPI
        JudgeApp -.->|extends| BaseAPI
        BaseAPI --> Schemas
        BaseAPI --> Instrumented
        BaseAPI --> Logging
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>mTLS via Istio| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>mTLS via Istio| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>mTLS via Istio| JudgeApp

    S3["S3/MinIO Storage<br/>9000/TCP"] -->|model files| HFApp
    VLLMServer["vLLM Server<br/>8080/TCP"] <-->|OpenAI API| JudgeApp
    Prometheus["Prometheus"] -->|scrapes /metrics| BuiltInApp
    Prometheus -->|scrapes /metrics| HFApp
    Prometheus -->|scrapes /metrics| JudgeApp

    KServe["KServe Platform"] -.->|deploys as InferenceService| HFApp
    KServe -.->|deploys as InferenceService| JudgeApp

    style BuiltInApp fill:#4a90e2,stroke:#333,color:#fff
    style HFApp fill:#4a90e2,stroke:#333,color:#fff
    style JudgeApp fill:#4a90e2,stroke:#333,color:#fff
    style BaseAPI fill:#6c5ce7,stroke:#333,color:#fff
    style Schemas fill:#6c5ce7,stroke:#333,color:#fff
    style Instrumented fill:#6c5ce7,stroke:#333,color:#fff
    style Logging fill:#6c5ce7,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style VLLMServer fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
