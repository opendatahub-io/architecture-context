graph TB
    subgraph GuardrailsDetectors["Guardrails Detectors"]
        subgraph CommonLib["Common Library"]
            BaseAPI["DetectorBaseAPI<br/>(FastAPI Base)"]
            Schemas["Pydantic Schemas<br/>(IBM Detector API)"]
            Instrumentation["InstrumentedDetector<br/>(Prometheus)"]
        end

        subgraph BuiltIn["Built-in Detector<br/>Port: 8080/TCP"]
            Registry["BaseDetectorRegistry"]
            RegexDet["Regex PII Detectors"]
            FileTypeDet["File Type Detectors"]
            CustomDet["Custom Python Detectors<br/>(AST-sandboxed)"]
            Registry --> RegexDet
            Registry --> FileTypeDet
            Registry --> CustomDet
        end

        subgraph HFDetector["HuggingFace Detector<br/>Port: 8000/TCP"]
            HFLoader["Model Auto-Detector"]
            SeqClass["AutoModelForSequenceClassification"]
            GraniteLM["GraniteForCausalLM<br/>(Risk Categories)"]
            HFLoader --> SeqClass
            HFLoader --> GraniteLM
        end

        subgraph LLMJudge["LLM Judge Detector<br/>Port: 8000/TCP"]
            JudgeLib["vLLM Judge Library"]
            Metrics31["31+ Built-in Metrics"]
            CustomCriteria["Custom Criteria<br/>(Jinja2 Templates)"]
            JudgeLib --> Metrics31
            JudgeLib --> CustomCriteria
        end

        BaseAPI --> BuiltIn
        BaseAPI --> HFDetector
        BaseAPI --> LLMJudge
        Schemas --> BaseAPI
        Instrumentation --> BaseAPI
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents| BuiltIn
    Orchestrator -->|POST /api/v1/text/contents<br/>mTLS via Istio| HFDetector
    Orchestrator -->|POST /api/v1/text/contents<br/>mTLS via Istio| LLMJudge

    KServe["KServe<br/>(InferenceService)"] -->|manages| HFDetector
    KServe -->|manages| LLMJudge

    S3["S3/MinIO<br/>9000/TCP"] -.->|model files| HFDetector
    vLLM["vLLM / OpenAI-compatible<br/>LLM Server"] -.->|evaluation prompts| LLMJudge

    Prometheus["Prometheus"] -->|scrapes /metrics| BuiltIn
    Prometheus -->|scrapes /metrics| HFDetector
    Prometheus -->|scrapes /metrics| LLMJudge

    style BuiltIn fill:#4a90e2,stroke:#333,color:#fff
    style HFDetector fill:#4a90e2,stroke:#333,color:#fff
    style LLMJudge fill:#4a90e2,stroke:#333,color:#fff
    style CommonLib fill:#b8d4f0,stroke:#333
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
