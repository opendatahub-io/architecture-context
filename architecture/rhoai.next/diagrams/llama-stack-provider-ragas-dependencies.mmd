graph LR
    RagasProvider["llama-stack-provider-ragas<br/><i>Llama Stack Eval Provider</i>"]

    %% Core External Dependencies (Required)
    RagasProvider -->|"core evaluation framework"| Ragas["ragas 0.3.0"]
    RagasProvider -->|"server framework + API"| LlamaStack["llama-stack >0.2.23"]
    RagasProvider -->|"LLM/Embedding base classes"| LangChain["langchain-core<br/>(transitive via ragas)"]
    RagasProvider -->|"dataset handling"| Pandas["pandas <2.3.0"]
    RagasProvider -->|"columnar data format"| PyArrow["pyarrow >=21.0.0"]
    RagasProvider -->|"HF datasets"| Datasets["datasets >=2.16.0"]
    RagasProvider -->|"config models"| Pydantic["pydantic<br/>(SecretStr)"]
    RagasProvider -->|"async internals"| Greenlet["greenlet 3.2.4"]
    RagasProvider -->|"HTTP healthz check"| Requests["requests >=2.32.5"]
    RagasProvider -->|"TLS/crypto support"| Cryptography["cryptography 46.0.2"]

    %% Remote-Mode Dependencies (Optional)
    RagasProvider -.->|"pipeline SDK<br/>(remote extra)"| KFP["kfp >=2.5.0"]
    RagasProvider -.->|"K8s secret mounting<br/>(remote extra)"| KFPKubernetes["kfp-kubernetes >=2.0.0"]
    RagasProvider -.->|"S3 filesystem<br/>(remote extra)"| S3FS["s3fs >=2024.12.0"]
    RagasProvider -.->|"K8s client<br/>(remote extra)"| KubernetesClient["kubernetes >=30.0.0"]
    RagasProvider -.->|"HTTP client<br/>(remote)"| LlamaStackClient["llama-stack-client"]

    %% Internal Platform Dependencies
    RagasProvider ==>|"ConfigMap read<br/>ragas-provider-image"| TrustyAI["TrustyAI Service Operator"]
    RagasProvider ==>|"pipeline submit/monitor<br/>REST API"| DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    RagasProvider ==>|"inference + datasets<br/>REST/in-process API"| LLSServer["Llama Stack Server"]
    RagasProvider ==>|"result storage<br/>S3 API"| S3["S3 Object Storage"]
    RagasProvider ==>|"token extraction<br/>kubeconfig"| OAuthKubeconfig["OpenShift OAuth<br/>kubeconfig"]

    %% Consumers / Integrators
    TrustyAI -.->|"provides base image via ConfigMap"| RagasProvider

    %% Styling
    style RagasProvider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core deps (required)
    style Ragas fill:#e8e8e8,stroke:#333,color:#000
    style LlamaStack fill:#e8e8e8,stroke:#333,color:#000
    style LangChain fill:#e8e8e8,stroke:#333,color:#000
    style Pandas fill:#e8e8e8,stroke:#333,color:#000
    style PyArrow fill:#e8e8e8,stroke:#333,color:#000
    style Datasets fill:#e8e8e8,stroke:#333,color:#000
    style Pydantic fill:#e8e8e8,stroke:#333,color:#000
    style Greenlet fill:#e8e8e8,stroke:#333,color:#000
    style Requests fill:#e8e8e8,stroke:#333,color:#000
    style Cryptography fill:#e8e8e8,stroke:#333,color:#000

    %% Remote deps (optional)
    style KFP fill:#d5e8d4,stroke:#82b366,color:#000
    style KFPKubernetes fill:#d5e8d4,stroke:#82b366,color:#000
    style S3FS fill:#d5e8d4,stroke:#82b366,color:#000
    style KubernetesClient fill:#d5e8d4,stroke:#82b366,color:#000
    style LlamaStackClient fill:#d5e8d4,stroke:#82b366,color:#000

