graph LR
    Provider["Llama Stack<br/>Provider Ragas"]

    %% External Dependencies (required)
    Provider -->|"evaluation framework"| Ragas["ragas 0.3.0"]
    Provider -->|"server framework"| LlamaStack["llama-stack >0.2.23"]
    Provider -->|"LLM/Embed base classes"| LangChain["langchain-core<br/>(transitive)"]
    Provider -->|"data handling"| Pandas["pandas <2.3.0"]
    Provider -->|"columnar format"| PyArrow["pyarrow >=21.0.0"]
    Provider -->|"config models"| Pydantic["pydantic<br/>(SecretStr)"]
    Provider -->|"async internals"| Greenlet["greenlet 3.2.4"]
    Provider -->|"HF datasets"| Datasets["datasets >=2.16.0"]

    %% External Dependencies (remote extras)
    Provider -.->|"pipeline SDK<br/>(remote extra)"| KFP["kfp >=2.5.0"]
    Provider -.->|"K8s extensions<br/>(remote extra)"| KFPKube["kfp-kubernetes >=2.0.0"]
    Provider -.->|"S3 filesystem<br/>(remote extra)"| S3FS["s3fs >=2024.12.0"]
    Provider -.->|"K8s client<br/>(remote extra)"| K8sClient["kubernetes >=30.0.0"]
    Provider -.->|"HTTP client"| Requests["requests >=2.32.5"]
    Provider -.->|"TLS/crypto"| Cryptography["cryptography 46.0.2"]

    %% Internal Platform Dependencies
    Provider ==>|"ConfigMap read<br/>ragas-provider-image"| TrustyAI["TrustyAI Service<br/>Operator"]
    Provider ==>|"pipeline submission<br/>443/TCP HTTPS"| DSP["Data Science Pipelines<br/>(KFP)"]
    Provider ==>|"inference + datasets<br/>8321/TCP HTTP"| LLSServer["Llama Stack<br/>Server"]
    Provider ==>|"result storage<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Object Storage"]
    Provider ==>|"ConfigMap + token<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    Provider ==>|"OAuth token"| OpenShiftOAuth["OpenShift OAuth /<br/>kubeconfig"]

    %% Dev-only dependency
    Provider -.->|"inference backend<br/>11434/TCP HTTP<br/>(dev only)"| Ollama["Ollama Server"]

    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Ragas fill:#e8e8e8,stroke:#333
    style LlamaStack fill:#e8e8e8,stroke:#333
    style LangChain fill:#e8e8e8,stroke:#333
    style Pandas fill:#e8e8e8,stroke:#333
    style PyArrow fill:#e8e8e8,stroke:#333
    style Pydantic fill:#e8e8e8,stroke:#333
    style Greenlet fill:#e8e8e8,stroke:#333
    style Datasets fill:#e8e8e8,stroke:#333

    %% Optional / remote extras
    style KFP fill:#ddd,stroke:#999
    style KFPKube fill:#ddd,stroke:#999
    style S3FS fill:#ddd,stroke:#999
    style K8sClient fill:#ddd,stroke:#999
    style Requests fill:#ddd,stroke:#999
    style Cryptography fill:#ddd,stroke:#999
    style Ollama fill:#ddd,stroke:#999

    %% Internal platform
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style LLSServer fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
