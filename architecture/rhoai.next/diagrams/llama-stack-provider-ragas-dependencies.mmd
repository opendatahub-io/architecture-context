graph LR
    LSPR["llama-stack-provider-ragas<br/>(Ragas Eval Provider)"]

    %% External Dependencies (Required)
    LSPR -->|"core evaluation<br/>framework"| Ragas["ragas 0.3.0"]
    LSPR -->|"server framework<br/>& provider APIs"| LlamaStack["llama-stack >0.2.23"]
    LSPR -->|"LLM/embedding<br/>base classes"| LangChain["langchain-core<br/>(transitive via ragas)"]
    LSPR -->|"data manipulation"| Pandas["pandas <2.3.0"]
    LSPR -->|"columnar data"| PyArrow["pyarrow >=21.0.0"]
    LSPR -->|"HuggingFace datasets"| Datasets["datasets >=2.16.0"]
    LSPR -->|"HTTP client"| Requests["requests >=2.32.5"]
    LSPR -->|"config validation"| Pydantic["pydantic<br/>(transitive)"]
    LSPR -->|"async support"| Greenlet["greenlet 3.2.4"]

    %% External Dependencies (Remote-only)
    LSPR -.->|"pipeline SDK<br/>(remote only)"| KFP["kfp >=2.5.0"]
    LSPR -.->|"K8s extensions<br/>(remote only)"| KFPKube["kfp-kubernetes >=2.0.0"]
    LSPR -.->|"K8s client<br/>(remote only)"| K8sClient["kubernetes >=30.0.0"]
    LSPR -.->|"S3 filesystem<br/>(remote only)"| S3FS["s3fs >=2024.12.0"]
    LSPR -.->|"remote API SDK<br/>(remote only)"| LSClient["llama-stack-client<br/>(transitive)"]

    %% Internal Platform Dependencies
    LSPR ==>|"plugin host<br/>routes eval API"| LSServer["Llama Stack Server"]
    LSPR ==>|"pipeline execution<br/>REST API"| DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    LSPR ==>|"LLM inference &<br/>embeddings"| Ollama["Ollama / vLLM<br/>(via Llama Stack)"]
    LSPR ==>|"base image<br/>ConfigMap"| TrustyAI["trustyai-service-operator"]
    LSPR ==>|"result persistence<br/>S3 API"| S3["S3-Compatible Storage<br/>(MinIO / AWS S3)"]

    %% Integration Points (other components that integrate with this)
    LSServer -->|"hosts provider"| LSPR

    %% Styling
    style LSPR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style Ragas fill:#e74c3c,stroke:#333,color:#fff
    style LlamaStack fill:#e74c3c,stroke:#333,color:#fff
    style LangChain fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style PyArrow fill:#999,stroke:#333,color:#fff
    style Datasets fill:#999,stroke:#333,color:#fff
    style Requests fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style Greenlet fill:#999,stroke:#333,color:#fff

    %% Remote-only external deps
    style KFP fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style KFPKube fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style K8sClient fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style S3FS fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style LSClient fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333

    %% Internal platform deps
    style LSServer fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Ollama fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
