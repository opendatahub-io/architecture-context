graph LR
    RagasProvider["llama-stack-provider-ragas<br/>(Llama Stack Eval Provider)"]

    %% Core Dependencies (Required)
    RagasProvider -->|"evaluation engine<br/>v0.3.0"| Ragas["ragas<br/>0.3.0"]
    RagasProvider -->|"provider framework<br/>>0.2.23"| LlamaStack["llama-stack<br/>>0.2.23"]
    RagasProvider -->|"LLM/embedding base classes<br/>(transitive via ragas)"| LangChain["langchain-core"]
    RagasProvider -->|"DataFrame handling<br/><2.3.0"| Pandas["pandas<br/><2.3.0"]
    RagasProvider -->|"columnar data<br/>>=21.0.0"| PyArrow["pyarrow<br/>>=21.0.0"]
    RagasProvider -->|"data loading<br/>>=2.16.0"| Datasets["datasets<br/>>=2.16.0"]
    RagasProvider -->|"config models<br/>(transitive)"| Pydantic["pydantic"]

    %% Remote-Only Dependencies
    RagasProvider -.->|"pipeline SDK<br/>>=2.5.0<br/>(remote only)"| KFP["kfp<br/>>=2.5.0"]
    RagasProvider -.->|"K8s extensions<br/>>=2.0.0<br/>(remote only)"| KFPKubernetes["kfp-kubernetes<br/>>=2.0.0"]
    RagasProvider -.->|"K8s client<br/>>=30.0.0<br/>(remote only)"| Kubernetes["kubernetes<br/>>=30.0.0"]
    RagasProvider -.->|"S3 filesystem<br/>>=2024.12.0<br/>(remote only)"| S3FS["s3fs<br/>>=2024.12.0"]
    RagasProvider -.->|"sync/async client<br/>(remote only)"| LlamaStackClient["llama-stack-client"]

    %% Internal Platform Dependencies
    RagasProvider ==>|"ConfigMap read<br/>ragas-provider-image"| TrustyAI["trustyai-service-operator"]
    RagasProvider ==>|"pipeline execution<br/>REST API"| DSP["Kubeflow Pipelines<br/>(Data Science Pipelines)"]
    RagasProvider ==>|"plugin host<br/>Python API"| LlamaStackServer["Llama Stack Server"]

    %% Integration Points (consumers and backends)
    LlamaStackServer -->|"inference backend<br/>HTTP 11434/TCP"| Ollama["Ollama"]
    LlamaStackServer -.->|"alt inference<br/>HTTP/HTTPS custom"| VLLM["vLLM"]
    RagasProvider ==>|"result storage<br/>S3 API 443/TCP"| S3["S3 Storage<br/>(AWS/MinIO)"]

    %% Styling
    style RagasProvider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core deps (required)
    style Ragas fill:#e74c3c,stroke:#333,color:#fff
    style LlamaStack fill:#e74c3c,stroke:#333,color:#fff
    style LangChain fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style PyArrow fill:#999,stroke:#333,color:#fff
    style Datasets fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff

    %% Remote-only deps
    style KFP fill:#c0c0c0,stroke:#666,stroke-dasharray: 5 5
    style KFPKubernetes fill:#c0c0c0,stroke:#666,stroke-dasharray: 5 5
    style Kubernetes fill:#c0c0c0,stroke:#666,stroke-dasharray: 5 5
    style S3FS fill:#c0c0c0,stroke:#666,stroke-dasharray: 5 5
    style LlamaStackClient fill:#c0c0c0,stroke:#666,stroke-dasharray: 5 5

    %% Internal platform
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style LlamaStackServer fill:#7ed321,stroke:#333,color:#fff

    %% Integration backends
    style Ollama fill:#f5a623,stroke:#333
    style VLLM fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
