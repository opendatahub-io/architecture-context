graph LR
    Provider["llama-stack-provider-ragas<br/>(Eval Provider Plugin)"]

    %% Core Dependencies (Required)
    Provider -->|"core eval framework<br/>v0.3.0"| Ragas["ragas 0.3.0"]
    Provider -->|"server framework<br/>&gt;0.2.23"| LlamaStack["llama-stack"]
    Provider -->|"BaseRagasLLM /<br/>BaseRagasEmbeddings"| LangchainCore["langchain-core<br/>(transitive via ragas)"]
    Provider -->|"DataFrame ops"| Pandas["pandas &lt;2.3.0"]
    Provider -->|"data serialization"| PyArrow["pyarrow &gt;=21.0.0"]
    Provider -->|"dataset support"| HFDatasets["datasets &gt;=2.16.0"]
    Provider -->|"async support"| Greenlet["greenlet 3.2.4"]

    %% Remote-Only Dependencies
    Provider -->|"pipeline SDK<br/>(remote only)"| KFP["kfp &gt;=2.5.0"]
    Provider -->|"K8s integration<br/>(remote only)"| KFPKubernetes["kfp-kubernetes &gt;=2.0.0"]
    Provider -->|"S3 filesystem<br/>(remote only)"| S3FS["s3fs &gt;=2024.12.0"]
    Provider -->|"K8s client<br/>(remote only)"| K8sClient["kubernetes &gt;=30.0.0"]
    Provider -->|"HTTP client<br/>(remote only)"| LlamaStackClient["llama-stack-client"]
    Provider -->|"health checks"| Requests["requests &gt;=2.32.5"]

    %% Internal Platform Dependencies
    LlamaStackServer["Llama Stack Server"] -->|"hosts plugin"| Provider
    Provider -->|"submit pipeline runs<br/>443/TCP HTTPS"| KubeflowPipelines["Kubeflow Pipelines<br/>(DSP)"]
    Provider -->|"base image config<br/>ConfigMap read"| TrustyAI["TrustyAI Service<br/>Operator"]
    Provider -->|"results storage<br/>443/TCP HTTPS"| S3Storage["S3-compatible<br/>Storage"]

    %% Integration Points (consuming this component)
    LlamaStackServer -->|"inference backend<br/>11434/TCP HTTP"| Ollama["Ollama"]

    %% Optional distribution dependencies
    Provider -.->|"distro extra"| Ollama2["ollama (Python)"]
    Provider -.->|"distro extra"| Uvicorn["uvicorn"]
    Provider -.->|"distro extra"| OTelAPI["opentelemetry-api"]
    Provider -.->|"distro extra"| OTelOTLP["opentelemetry-<br/>exporter-otlp"]

