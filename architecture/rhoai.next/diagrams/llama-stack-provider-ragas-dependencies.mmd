graph LR
    Provider["llama-stack-provider-ragas<br/>(Eval Provider Plugin)"]

    %% Core External Dependencies (Required)
    Provider -->|"core evaluation<br/>framework"| Ragas["ragas 0.3.0"]
    Provider -->|"server framework<br/>& provider API"| LlamaStackLib["llama-stack >0.2.23"]
    Provider -->|"BaseRagasLLM /<br/>BaseRagasEmbeddings"| LangChain["langchain-core<br/>(transitive)"]
    Provider -->|"DataFrame ops"| Pandas["pandas <2.3.0"]
    Provider -->|"data serialization"| PyArrow["pyarrow >=21.0.0"]
    Provider -->|"HTTP health checks"| Requests["requests >=2.32.5"]
    Provider -->|"HuggingFace datasets"| Datasets["datasets >=2.16.0"]
    Provider -->|"inline file ops"| Greenlet["greenlet 3.2.4"]

    %% Remote-only External Dependencies
    Provider -.->|"pipeline SDK<br/>(remote only)"| KFP["kfp >=2.5.0"]
    Provider -.->|"K8s integration<br/>(remote only)"| KFPKubernetes["kfp-kubernetes >=2.0.0"]
    Provider -.->|"S3 filesystem<br/>(remote only)"| S3FS["s3fs >=2024.12.0"]
    Provider -.->|"K8s client<br/>(remote only)"| K8sClient["kubernetes >=30.0.0"]
    Provider -.->|"HTTP client<br/>(remote only)"| LSClient["llama-stack-client"]

    %% Internal Platform Dependencies
    Provider ==>|"provider plugin API"| LlamaStackServer["Llama Stack Server"]
    Provider ==>|"pipeline submission<br/>443/TCP HTTPS"| KubeflowPipelines["Kubeflow Pipelines<br/>(DSP)"]
    Provider ==>|"base image config<br/>ConfigMap"| TrustyAI["TrustyAI Service<br/>Operator"]
    Provider ==>|"result storage<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]

    %% Integration Points (other components that interact)
    LlamaStackServer -->|"hosts provider"| Provider
    Ollama["Ollama<br/>(inference backend)"] -.->|"HTTP/11434"| LlamaStackServer

    %% Styling
    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core dependencies
    style Ragas fill:#e8e8e8,stroke:#333
    style LlamaStackLib fill:#e8e8e8,stroke:#333
    style LangChain fill:#e8e8e8,stroke:#333
    style Pandas fill:#e8e8e8,stroke:#333
    style PyArrow fill:#e8e8e8,stroke:#333
    style Requests fill:#e8e8e8,stroke:#333
    style Datasets fill:#e8e8e8,stroke:#333
    style Greenlet fill:#e8e8e8,stroke:#333

    %% Remote-only dependencies
    style KFP fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style KFPKubernetes fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style S3FS fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style K8sClient fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5
    style LSClient fill:#d4d4d4,stroke:#999,stroke-dasharray: 5 5

    %% Internal platform dependencies
    style LlamaStackServer fill:#7ed321,stroke:#333,color:#fff
    style KubeflowPipelines fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style Ollama fill:#f5a623,stroke:#333,color:#fff
