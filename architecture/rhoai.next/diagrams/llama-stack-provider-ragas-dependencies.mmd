graph LR
    Provider["llama-stack-provider-ragas<br/>Python Library / Container Image"]

    %% Core Python Dependencies
    subgraph CoreDeps["Core Dependencies"]
        Ragas["ragas 0.3.0"]
        LlamaStack["llama-stack >0.2.23"]
        LangChain["langchain-core"]
        Pydantic["pydantic"]
    end

    Provider -->|"evaluation metrics"| Ragas
    Provider -->|"eval/inference/dataset APIs"| LlamaStack
    Provider -->|"LLM/embedding wrappers"| LangChain
    Provider -->|"config validation"| Pydantic

    %% Data Dependencies
    subgraph DataDeps["Data Dependencies"]
        Pandas["pandas <2.3.0"]
        PyArrow["pyarrow >=21.0.0"]
        Datasets["datasets >=2.16.0"]
        Greenlet["greenlet 3.2.4"]
    end

    Provider -->|"DataFrame handling"| Pandas
    Provider -->|"columnar data"| PyArrow
    Provider -->|"HuggingFace datasets"| Datasets
    Provider -->|"file system ops"| Greenlet

    %% Remote-Only Dependencies
    subgraph RemoteDeps["Remote Mode Dependencies (optional)"]
        KFP["kfp >=2.5.0"]
        KFPKube["kfp-kubernetes >=2.0.0"]
        S3FS["s3fs >=2024.12.0"]
        K8sClient["kubernetes >=30.0.0"]
        Requests["requests >=2.32.5"]
        LSClient["llama-stack-client"]
    end

    Provider -.->|"pipeline definition"| KFP
    Provider -.->|"secret mounting"| KFPKube
    Provider -.->|"S3 results access"| S3FS
    Provider -.->|"ConfigMap reading"| K8sClient
    Provider -.->|"KFP healthz check"| Requests
    Provider -.->|"HTTP client for KFP pods"| LSClient

    %% Internal RHOAI Platform Dependencies
    subgraph InternalDeps["Internal RHOAI Platform"]
        LSServer["Llama Stack Server"]
        DSPipelines["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
        TrustyAI["TrustyAI Service Operator<br/>(ConfigMap)"]
        LSOperator["Llama Stack Operator<br/>(LlamaStackDistribution CRD)"]
    end

    Provider -->|"host runtime + APIs"| LSServer
    Provider -.->|"remote pipeline execution"| DSPipelines
    Provider -.->|"base image resolution"| TrustyAI
    LSOperator -->|"deploys"| LSServer

    %% Inference Backends
    subgraph InferenceBackends["Inference Backends"]
        Ollama["Ollama<br/>:11434/TCP"]
        vLLM["vLLM<br/>:8443/TCP"]
    end

    LSServer -->|"dev inference"| Ollama
    LSServer -->|"prod inference"| vLLM

    %% External Services
    subgraph ExtServices["External Services"]
        S3["S3-compatible Storage"]
        K8sAPI["Kubernetes API Server"]
    end

    Provider -.->|"results storage"| S3
    Provider -.->|"ConfigMap + kubeconfig"| K8sAPI

    %% Styling
    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Ragas fill:#e74c3c,stroke:#333,color:#fff
    style LlamaStack fill:#e74c3c,stroke:#333,color:#fff
    style LangChain fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style PyArrow fill:#999,stroke:#333,color:#fff
    style Datasets fill:#999,stroke:#333,color:#fff
    style Greenlet fill:#999,stroke:#333,color:#fff
    style KFP fill:#f5a623,stroke:#333,color:#fff
    style KFPKube fill:#f5a623,stroke:#333,color:#fff
    style S3FS fill:#f5a623,stroke:#333,color:#fff
    style K8sClient fill:#f5a623,stroke:#333,color:#fff
    style Requests fill:#f5a623,stroke:#333,color:#fff
    style LSClient fill:#f5a623,stroke:#333,color:#fff
    style LSServer fill:#7ed321,stroke:#333,color:#fff
    style DSPipelines fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style LSOperator fill:#7ed321,stroke:#333,color:#fff
    style Ollama fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
