graph LR
    Provider["llama-stack-provider-ragas<br/><i>Llama Stack Eval Provider</i>"]

    %% Core External Dependencies
    Provider -->|"core framework<br/>0.3.0"| Ragas["ragas<br/>0.3.0"]
    Provider -->|"API + server<br/>>0.2.23"| LlamaStack["llama-stack<br/>>0.2.23"]
    Provider -->|"LLM/Embedding base<br/>(transitive)"| LangChain["langchain-core"]
    Provider -->|"data handling<br/><2.3.0"| Pandas["pandas<br/><2.3.0"]
    Provider -->|"columnar format<br/>>=21.0.0"| PyArrow["pyarrow"]

    %% Remote Mode Dependencies (optional)
    Provider -.->|"pipeline SDK<br/>>=2.5.0 (remote)"| KFP_SDK["kfp<br/>>=2.5.0"]
    Provider -.->|"K8s extensions<br/>>=2.0.0 (remote)"| KFP_K8s["kfp-kubernetes<br/>>=2.0.0"]
    Provider -.->|"S3 filesystem<br/>>=2024.12 (remote)"| S3FS["s3fs"]
    Provider -.->|"K8s client<br/>>=30.0.0 (remote)"| K8sClient["kubernetes<br/>>=30.0.0"]

    %% Internal Platform Dependencies
    Provider ==>|"ConfigMap read<br/>ragas-provider-image"| TrustyAI["TrustyAI Service<br/>Operator"]
    Provider ==>|"REST API<br/>pipeline submit/status"| DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    Provider ==>|"REST API<br/>inference + datasets"| LlamaServer["Llama Stack<br/>Server"]
    Provider ==>|"S3 API<br/>result storage"| S3["S3 Object<br/>Storage"]
    Provider ==>|"Token extraction<br/>kubeconfig"| OAuthKube["OpenShift OAuth<br/>/ kubeconfig"]

    %% Consumers / Upstream Integrators
    TrustyAI -.->|"manages image config"| Provider
    LlamaServer -.->|"hosts as plugin"| Provider

    %% Styling
    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core deps
    style Ragas fill:#7ed321,stroke:#333,color:#fff
    style LlamaStack fill:#7ed321,stroke:#333,color:#fff
    style LangChain fill:#7ed321,stroke:#333,color:#fff
    style Pandas fill:#7ed321,stroke:#333,color:#fff
    style PyArrow fill:#7ed321,stroke:#333,color:#fff

    %% Remote deps (optional)
    style KFP_SDK fill:#b8e6b8,stroke:#333,stroke-dasharray:5 5
    style KFP_K8s fill:#b8e6b8,stroke:#333,stroke-dasharray:5 5
    style S3FS fill:#b8e6b8,stroke:#333,stroke-dasharray:5 5
    style K8sClient fill:#b8e6b8,stroke:#333,stroke-dasharray:5 5

    %% Internal platform
    style TrustyAI fill:#f5a623,stroke:#333,color:#fff
    style DSP fill:#f5a623,stroke:#333,color:#fff
    style LlamaServer fill:#f5a623,stroke:#333,color:#fff
