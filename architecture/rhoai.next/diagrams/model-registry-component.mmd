graph TB
    subgraph MR["Model Registry Component"]
        direction TB
        Proxy["model-registry (proxy)<br/>Go REST Service<br/>Port: 8080/TCP"]
        Catalog["model-catalog<br/>Go REST Service<br/>Port: 8080/TCP"]
        UI["model-registry-ui<br/>React + Go BFF<br/>Port: 8080/TCP"]
        Controller["inferenceservice-controller<br/>Go Controller<br/>Port: 8081/TCP (probes)"]
        CSI["mr-storage-initializer<br/>Go CLI Tool<br/>KServe Init Container"]
        AsyncJob["async-upload job<br/>Python K8s Job<br/>On-demand"]
    end

    subgraph Databases["Database Layer"]
        MySQL["MySQL 8.3<br/>Port: 3306/TCP"]
        PostgreSQL["PostgreSQL 16+<br/>Port: 5432/TCP"]
        CatalogDB["model-catalog-postgres<br/>Port: 5432/TCP"]
    end

    subgraph ExternalServices["External Services"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
        OCI["OCI Registries<br/>443/TCP HTTPS"]
        Sigstore["Sigstore (Fulcio/Rekor)<br/>443/TCP HTTPS"]
    end

    subgraph Platform["Platform Components"]
        KServe["KServe<br/>InferenceService CRDs"]
        Istio["Istio Service Mesh<br/>VirtualService + mTLS"]
        K8sAPI["Kubernetes API<br/>443/TCP"]
    end

    %% Internal flows
    UI -->|"REST API"| Proxy
    Controller -->|"REST API<br/>Bearer Token"| Proxy
    CSI -->|"REST API<br/>Resolve URIs"| Proxy

    %% Database connections
    Proxy -->|"MySQL protocol"| MySQL
    Proxy -->|"PostgreSQL protocol"| PostgreSQL
    Catalog -->|"PostgreSQL protocol"| CatalogDB

    %% External integrations
    Catalog -->|"HTTPS<br/>API Key"| HFHub
    AsyncJob -->|"HTTPS<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS<br/>Registry creds"| OCI
    AsyncJob -->|"HTTPS<br/>K8s SA Token"| Sigstore
    AsyncJob -->|"REST API<br/>Bearer Token"| Proxy
    CSI -->|"HTTPS<br/>Storage creds"| S3

    %% Platform integrations
    Controller -->|"Watch CRDs"| KServe
    Controller -->|"HTTPS<br/>SA Token"| K8sAPI
    Istio -->|"mTLS routing"| Proxy

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style UI fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style AsyncJob fill:#4a90e2,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style CatalogDB fill:#f5a623,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCI fill:#e8e8e8,stroke:#333
    style Sigstore fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style K8sAPI fill:#7ed321,stroke:#333
