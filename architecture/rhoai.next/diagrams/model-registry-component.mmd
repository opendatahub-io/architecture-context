graph TB
    subgraph MR["Model Registry Component"]
        direction TB
        Proxy["model-registry (proxy)<br/>Go REST API<br/>:8080/TCP"]
        Controller["model-registry-controller<br/>Go Controller<br/>:8081/TCP health, :8443/TCP metrics"]
        BFF["model-registry-ui (BFF)<br/>Go BFF Server<br/>:8080/TCP"]
        CatalogServer["model-catalog-server<br/>Go REST API<br/>:8080/TCP"]
        CSI["storage-initializer (CSI)<br/>Go CLI (KServe Plugin)<br/>Init Container"]
        AsyncUpload["async-upload-job<br/>Python K8s Job"]
        Frontend["model-registry-ui (frontend)<br/>React/TypeScript SPA"]
    end

    %% Internal relationships
    BFF -->|"proxies API requests"| Proxy
    BFF -->|"proxies catalog requests"| CatalogServer
    Frontend -->|"served by"| BFF
    Controller -->|"HTTP :8080<br/>Bearer Token"| Proxy
    CSI -->|"HTTP :8080<br/>resolve URIs"| Proxy
    AsyncUpload -->|"HTTP :8080<br/>register artifacts"| Proxy

    %% External actors
    User["Data Scientist / Dashboard"] -->|"HTTP/HTTPS"| BFF
    User -->|"REST API"| Proxy

    %% Database dependencies
    Proxy -->|"MySQL :3306<br/>Username/password"| MySQL[(MySQL 8.3+)]
    Proxy -->|"PostgreSQL :5432<br/>Username/password"| PostgreSQL[(PostgreSQL 16+)]
    CatalogServer -->|"PostgreSQL :5432"| CatalogDB[(Catalog PostgreSQL)]

    %% Kubernetes API
    Controller -->|"HTTPS :443<br/>ServiceAccount"| K8sAPI["Kubernetes API"]
    BFF -->|"HTTPS :443<br/>User/SA token"| K8sAPI

    %% KServe integration
    Controller -->|"watches"| ISVC["InferenceService CR"]
    ISVC -->|"triggers reconciliation"| Controller
    CSI -->|"delegates download"| KServeStorage["KServe Storage Providers"]

    %% External services
    CatalogServer -->|"HTTPS :443<br/>API key"| HuggingFace["Hugging Face API"]
    AsyncUpload -->|"HTTPS :443"| S3["S3 Storage"]
    AsyncUpload -->|"HTTPS :443"| OCIRegistry["OCI Registry"]

    %% Istio integration
    IstioGW["Istio Gateway<br/>(kubeflow-gateway)"] -->|"VirtualService<br/>mTLS"| Proxy
    IstioGW -->|"VirtualService<br/>mTLS"| BFF
    IstioGW -->|"VirtualService<br/>mTLS"| CatalogServer

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style BFF fill:#4a90e2,stroke:#333,color:#fff
    style CatalogServer fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style AsyncUpload fill:#4a90e2,stroke:#333,color:#fff
    style Frontend fill:#4a90e2,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#333
    style MySQL fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style CatalogDB fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style KServeStorage fill:#e8e8e8,stroke:#333
    style IstioGW fill:#7ed321,stroke:#333,color:#333
    style User fill:#f9f9f9,stroke:#999
