    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style ISVCController fill:#4a90e2,stroke:#333,color:#fff
    style BFF fill:#4a90e2,stroke:#333,color:#fff
    style CatalogServer fill:#4a90e2,stroke:#333,color:#fff
    style Frontend fill:#50c878,stroke:#333,color:#fff
