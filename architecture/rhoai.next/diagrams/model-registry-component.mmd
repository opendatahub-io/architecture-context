graph TB
    subgraph "Model Registry Platform"
        direction TB

        subgraph "REST API Layer"
            Proxy["model-registry proxy<br/>(Go REST Service)<br/>Port: 8080/TCP"]
            Catalog["model-registry catalog<br/>(Go REST Service)<br/>Port: 8080/TCP"]
        end

        subgraph "Controller Layer"
            Controller["model-registry controller<br/>(controller-runtime)<br/>Port: 8081/TCP (health)"]
        end

        subgraph "Utility Components"
            CSI["CSI Storage Initializer<br/>(Go CLI / KServe Provider)<br/>model-registry:// URI"]
            AsyncUpload["async-upload Job<br/>(Python 3.12)<br/>Kubernetes Job"]
        end
    end

    %% External Clients
    Client["Client<br/>(Dashboard / CLI / SDK)"]
    Client -->|"REST API v1alpha3<br/>8080/TCP HTTP"| Proxy

    %% Database Backends
    MySQL[("MySQL 8.3<br/>3306/TCP")]
    PostgreSQL[("PostgreSQL 16+<br/>5432/TCP")]
    CatalogDB[("Catalog PostgreSQL<br/>5432/TCP")]

    Proxy -->|"EmbedMD datastore<br/>MySQL protocol"| MySQL
    Proxy -->|"EmbedMD datastore<br/>PostgreSQL protocol"| PostgreSQL
    Catalog -->|"Catalog metadata<br/>PostgreSQL protocol"| CatalogDB

    %% KServe Integration
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    KServePod["KServe Inference Pod"]

    Controller -->|"watches"| InferenceServiceCR
    Controller -->|"syncs metadata<br/>8080/TCP HTTP"| Proxy
    CSI -->|"resolves artifacts<br/>8080/TCP HTTP"| Proxy
    KServePod -->|"init container"| CSI

    %% Async Upload Dependencies
    S3["S3 Storage<br/>443/TCP HTTPS"]
    OCI["OCI Registry<br/>443/TCP HTTPS"]
    HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS"]
    Sigstore["Sigstore<br/>(Fulcio/Rekor)<br/>443/TCP HTTPS"]

    AsyncUpload -->|"download models"| S3
    AsyncUpload -->|"upload OCI images<br/>via skopeo"| OCI
    AsyncUpload -->|"download models"| HuggingFace
    AsyncUpload -->|"code signing<br/>via cosign"| Sigstore
    AsyncUpload -->|"register artifacts<br/>8080/TCP"| Proxy

    %% Catalog Sources
    Catalog -->|"fetch metadata<br/>443/TCP HTTPS"| HuggingFace

    %% Istio Integration
    IstioGW["Istio Gateway<br/>(kubeflow-gateway)"]
    IstioGW -->|"VirtualService<br/>mTLS"| Proxy

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style AsyncUpload fill:#4a90e2,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style CatalogDB fill:#f5a623,stroke:#333,color:#fff
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style S3 fill:#999,stroke:#333,color:#fff
    style OCI fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#999,stroke:#333,color:#fff
    style Sigstore fill:#999,stroke:#333,color:#fff
    style IstioGW fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style KServePod fill:#e8e8e8,stroke:#333
