graph TB
    subgraph ModelRegistry["Model Registry Component"]
        direction TB

        subgraph ProxyServer["Proxy Server (Go)"]
            Proxy["model-registry proxy<br/>:8080/TCP HTTP"]
            OpenAPI["OpenAPI Handlers<br/>/api/model_registry/v1alpha3/*"]
            EmbedMD["EmbedMD Datastore<br/>GORM ORM"]
            Proxy --> OpenAPI
            OpenAPI --> EmbedMD
        end

        subgraph CatalogServer["Catalog Server (Go)"]
            Catalog["model-registry catalog<br/>:8080/TCP HTTP"]
            ModelCatalogAPI["Model Catalog API<br/>/api/model_catalog/v1alpha1/*"]
            MCPCatalogAPI["MCP Catalog API<br/>/api/mcp_catalog/v1alpha1/*"]
            PluginSystem["Plugin System<br/>Hot-reload config"]
            LeaderElection["Leader Election<br/>pglock"]
            Catalog --> ModelCatalogAPI
            Catalog --> MCPCatalogAPI
            ModelCatalogAPI --> PluginSystem
            MCPCatalogAPI --> PluginSystem
            Catalog --> LeaderElection
        end

        subgraph Controller["Controller (Go)"]
            ISVCController["InferenceService Controller<br/>controller-runtime<br/>:8081/TCP metrics"]
        end

        subgraph CSIDriver["CSI Storage Initializer (Go)"]
            CSI["CSI Driver<br/>model-registry:// URI resolver"]
        end

        subgraph AsyncUpload["Async Upload Job (Python)"]
            UploadJob["async-upload-job<br/>K8s Job (on-demand)"]
        end
    end

    %% External Users
    Client["Client<br/>(UI / CLI / API)"]
    Client -->|"REST API<br/>HTTPS/443 via Istio"| Proxy
    Client -->|"REST API<br/>HTTPS/443 via Istio"| Catalog

    %% CRD Interactions
    ISVC["KServe InferenceService CR<br/>serving.kserve.io/v1beta1"]
    ISVC -->|"watched by"| ISVCController
    ISVCController -->|"syncs metadata"| Proxy

    CSC["KServe ClusterStorageContainer<br/>model-registry:// protocol"]
    CSC -->|"triggers"| CSI
    CSI -->|"resolves URI"| Proxy

    %% Database Dependencies
    MySQLDB[("MySQL 8.3+<br/>:3306/TCP")]
    PostgresDB[("PostgreSQL 16+<br/>:5432/TCP")]
    CatalogPostgres[("Catalog PostgreSQL<br/>:5432/TCP")]

    EmbedMD -->|"GORM<br/>MySQL/PostgreSQL"| MySQLDB
    EmbedMD -->|"GORM<br/>MySQL/PostgreSQL"| PostgresDB
    LeaderElection -->|"pglock"| CatalogPostgres
    PluginSystem -->|"catalog data"| CatalogPostgres

    %% External Services
    HuggingFace["HuggingFace API<br/>huggingface.co:443"]
    S3["AWS S3<br/>:443/TCP HTTPS"]
    OCIRegistry["OCI Registry<br/>:443/TCP HTTPS"]
    Sigstore["Sigstore<br/>(Fulcio/Rekor/TUF)<br/>:443/TCP HTTPS"]

    PluginSystem -->|"fetch models<br/>Bearer token"| HuggingFace
    UploadJob -->|"download models"| S3
    UploadJob -->|"push models<br/>skopeo"| OCIRegistry
    UploadJob -->|"sign models"| Sigstore
    UploadJob -->|"register metadata"| Proxy

    %% Platform Integration
    IstioMesh["Istio Service Mesh<br/>mTLS + AuthorizationPolicy"]
    Operator["rhods-operator<br/>Deploys instances"]

    IstioMesh -.->|"secures"| Proxy
    IstioMesh -.->|"secures"| Catalog
    Operator -.->|"deploys via kustomize"| ProxyServer

    %% UI
    UI["model-registry-ui<br/>BFF :8080/TCP"]
    UI -->|"REST API calls"| Proxy
    UI -->|"REST API calls"| Catalog

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,color:#fff
    style ISVCController fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style UploadJob fill:#4a90e2,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333
    style CSC fill:#f5a623,stroke:#333
    style MySQLDB fill:#e8e8e8,stroke:#333
    style PostgresDB fill:#e8e8e8,stroke:#333
    style CatalogPostgres fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#fff2cc,stroke:#d6b656
    style S3 fill:#fff2cc,stroke:#d6b656
    style OCIRegistry fill:#fff2cc,stroke:#d6b656
    style Sigstore fill:#fff2cc,stroke:#d6b656
    style IstioMesh fill:#d5e8d4,stroke:#82b366
    style Operator fill:#d5e8d4,stroke:#82b366
    style UI fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
