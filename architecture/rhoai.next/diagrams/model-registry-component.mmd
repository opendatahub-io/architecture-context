graph TB
    subgraph ModelRegistry["Model Registry Component"]
        direction TB
        Proxy["model-registry (proxy)<br/>Go REST Service<br/>8080/TCP"]
        Catalog["model-catalog<br/>Go REST Service<br/>8080/TCP"]
        Controller["inferenceservice-controller<br/>Go Controller<br/>8081/TCP (health)"]
        CSI["mr-storage-initializer<br/>Go CLI Tool<br/>(init container)"]
        AsyncJob["async-upload job<br/>Python K8s Job<br/>(batch)"]
        UI["model-registry-ui<br/>React + Go BFF<br/>8080/TCP"]
    end

    subgraph Databases["Database Layer"]
        MySQL["MySQL 8.3<br/>3306/TCP"]
        PostgreSQL["PostgreSQL 16+<br/>5432/TCP"]
        CatalogDB["Catalog PostgreSQL<br/>5432/TCP"]
    end

    subgraph ExternalServices["External Services"]
        S3["S3-compatible Storage<br/>443/TCP"]
        OCI["OCI Registries<br/>443/TCP"]
        HuggingFace["Hugging Face Hub<br/>443/TCP"]
        Sigstore["Sigstore<br/>(Fulcio, Rekor, TSA)<br/>443/TCP"]
    end

    subgraph PlatformComponents["Platform Components"]
        KServe["KServe<br/>InferenceService CRDs"]
        Istio["Istio Service Mesh<br/>VirtualService + mTLS"]
        K8sAPI["Kubernetes API<br/>443/TCP"]
    end

    %% Client interactions
    Client["Client / Data Scientist"] -->|"REST API"| Proxy
    Client -->|"Web UI"| UI

    %% Internal flows
    UI -->|"REST API<br/>8080/TCP"| Proxy
    Catalog -->|"PostgreSQL<br/>5432/TCP"| CatalogDB
    Catalog -->|"HTTPS<br/>443/TCP"| HuggingFace
    Proxy -->|"MySQL protocol<br/>3306/TCP"| MySQL
    Proxy -->|"PostgreSQL protocol<br/>5432/TCP"| PostgreSQL
    Controller -->|"REST API<br/>8080/TCP"| Proxy
    CSI -->|"REST API<br/>8080/TCP"| Proxy
    AsyncJob -->|"REST API<br/>8080/TCP"| Proxy

    %% Controller interactions
    Controller -->|"Watch CRDs"| K8sAPI
    K8sAPI -->|"InferenceService events"| Controller
    Controller -->|"Patch ISVCs"| KServe

    %% CSI interactions
    KServe -->|"init container<br/>model-registry://"| CSI
    CSI -->|"Download models"| S3

    %% Async job interactions
    AsyncJob -->|"Read/Write artifacts"| S3
    AsyncJob -->|"Push/Pull images"| OCI
    AsyncJob -->|"Sign/Verify models"| Sigstore

    %% Istio integration
    Istio -->|"mTLS + AuthzPolicy"| Proxy

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Catalog fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CSI fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style AsyncJob fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style UI fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MySQL fill:#f5a623,stroke:#333,stroke-width:2px
    style PostgreSQL fill:#f5a623,stroke:#333,stroke-width:2px
    style CatalogDB fill:#f5a623,stroke:#333,stroke-width:2px
    style S3 fill:#e8e8e8,stroke:#333
    style OCI fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style Sigstore fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Istio fill:#7ed321,stroke:#333
    style K8sAPI fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#333,stroke-width:2px
