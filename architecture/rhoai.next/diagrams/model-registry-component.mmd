graph TB
    subgraph ModelRegistry["Model Registry Component"]
        direction TB

        subgraph CoreAPI["Core REST API Layer"]
            Proxy["model-registry (proxy)<br/>Go REST API<br/>Port: 8080/TCP"]
        end

        subgraph Controller["Controller Layer"]
            ISVCController["model-registry-controller<br/>Go Controller (controller-runtime)<br/>Port: 8081/TCP (health), 8443/TCP (metrics)"]
        end

        subgraph CatalogLayer["Catalog Layer"]
            CatalogServer["model-catalog-server<br/>Go REST API<br/>Port: 8080/TCP"]
        end

        subgraph UILayer["UI Layer"]
            BFF["model-registry-ui (BFF)<br/>Go BFF Server<br/>Port: 8080/TCP"]
            Frontend["model-registry-ui (frontend)<br/>React/TypeScript SPA"]
            Frontend -->|served by| BFF
        end

        subgraph UtilityLayer["Utility Components"]
            CSI["model-registry-storage-initializer<br/>Go CLI (KServe Plugin)<br/>Init Container"]
            AsyncUpload["async-upload-job<br/>Python K8s Job"]
        end
    end

    %% Internal connections
    BFF -->|"HTTP/8080<br/>Forwarded token"| Proxy
    BFF -->|"HTTP/8080<br/>Forwarded token"| CatalogServer
    ISVCController -->|"HTTP/8080<br/>Bearer Token"| Proxy
    CSI -->|"HTTP/8080<br/>Resolve URIs"| Proxy
    AsyncUpload -->|"HTTP/8080<br/>Bearer Token"| Proxy

    %% External interactions
    User["Data Scientist / Dashboard"] -->|"HTTPS/443<br/>Platform auth"| BFF
    InferenceServiceCR["InferenceService CR<br/>(KServe CRD)"] -->|"watched by"| ISVCController

    %% Database backends
    Proxy -->|"MySQL/3306<br/>or PostgreSQL/5432"| DB["MySQL 8.3+ / PostgreSQL 16+<br/>Metadata Storage"]
    CatalogServer -->|"PostgreSQL/5432"| CatalogDB["PostgreSQL<br/>Catalog Storage"]

    %% External services
    CatalogServer -->|"HTTPS/443<br/>API key"| HuggingFace["Hugging Face API"]
    CSI -->|"HTTPS/443<br/>Storage creds"| ModelStorage["Model Storage<br/>(S3/GCS/OCI)"]
    AsyncUpload -->|"HTTPS/443<br/>Registry creds"| OCIRegistry["OCI Registry"]
    AsyncUpload -->|"HTTPS/443<br/>AWS creds"| S3Storage["S3-compatible Storage"]

    %% Istio mesh
    IstioGW["Istio Gateway"] -->|"mTLS<br/>ISTIO_MUTUAL"| Proxy
    IstioGW -->|"mTLS<br/>ISTIO_MUTUAL"| CatalogServer
    IstioGW -->|"mTLS<br/>ISTIO_MUTUAL"| BFF

    %% K8s API
    ISVCController -->|"HTTPS/443<br/>ServiceAccount"| K8sAPI["Kubernetes API"]
    BFF -->|"HTTPS/443<br/>User/SA token"| K8sAPI

    %% Prometheus
    Prometheus["Prometheus"] -->|"HTTPS/8443<br/>TokenReview"| ISVCController

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style ISVCController fill:#4a90e2,stroke:#333,color:#fff
    style CatalogServer fill:#4a90e2,stroke:#333,color:#fff
    style BFF fill:#4a90e2,stroke:#333,color:#fff
    style Frontend fill:#50c878,stroke:#333,color:#fff
    style CSI fill:#9b59b6,stroke:#333,color:#fff
    style AsyncUpload fill:#9b59b6,stroke:#333,color:#fff
    style DB fill:#f5a623,stroke:#333,color:#fff
    style CatalogDB fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#e8e8e8,stroke:#333
    style ModelStorage fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style S3Storage fill:#e8e8e8,stroke:#333
    style IstioGW fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333,color:#fff
    style User fill:#7ed321,stroke:#333,color:#fff
