graph LR
    LLP["llm-d-latency-predictor<br/>(Training + Prediction Servers)"]

    %% Internal llm-d Dependencies
    LLP -->|"consumes predictions<br/>POST /predict/bulk/strict<br/>8001/TCP HTTP"| GW["llm-d Gateway<br/>(gateway-api-inference-extension)"]
    MetricsPipe["llm-d Metrics Pipeline"] -->|"sends observations<br/>POST /add_training_data_bulk<br/>8000/TCP HTTP"| LLP

    %% Internal Server Dependency
    PredServer["Prediction Server<br/>(10 replicas)"] -->|"model sync<br/>GET /model/{name}/download<br/>8000/TCP HTTP every 10s"| TrainServer["Training Server<br/>(singleton)"]

    %% External Python Dependencies
    subgraph MLLibs["ML Libraries"]
        XGBoost["xgboost 3.2.0"]
        LightGBM["lightgbm 4.6.0"]
        ScikitLearn["scikit-learn 1.9.0"]
    end

    subgraph WebFramework["Web Framework"]
        FastAPI["fastapi 0.137.1"]
        Uvicorn["uvicorn 0.49.0"]
        Pydantic["pydantic 2.13.4"]
    end

    subgraph DataLibs["Data & Compute"]
        NumPy["numpy 2.4.6"]
        Pandas["pandas 3.0.3"]
        SciPy["scipy 1.17.1"]
        Joblib["joblib 1.5.3"]
        OrJSON["orjson 3.11.9"]
    end

    LLP -->|"quantile/mean regression"| MLLibs
    LLP -->|"REST API serving"| WebFramework
    LLP -->|"feature engineering<br/>& serialization"| DataLibs

    %% Infrastructure Dependencies
    LLP -->|"health probes<br/>GET /healthz, /readyz"| K8s["Kubernetes"]
    LLP -->|"metrics scraping<br/>GET /metrics"| Prometheus["Prometheus"]

    %% Styling
    style LLP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PredServer fill:#5ba3f5,stroke:#333,color:#fff
    style TrainServer fill:#5ba3f5,stroke:#333,color:#fff
    style GW fill:#7ed321,stroke:#333
    style MetricsPipe fill:#7ed321,stroke:#333
    style K8s fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
    style XGBoost fill:#999,stroke:#333,color:#fff
    style LightGBM fill:#999,stroke:#333,color:#fff
    style ScikitLearn fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style NumPy fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style SciPy fill:#999,stroke:#333,color:#fff
