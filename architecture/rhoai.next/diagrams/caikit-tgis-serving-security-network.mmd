graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Cert: wildcard-certs"]
        KnativeAct["Knative Activator /<br/>Queue-Proxy<br/>8012/TCP<br/>Autoscaling & Queuing"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph Pod["KServe ServingRuntime Pod<br/>Namespace: {user-namespace}"]
            direction TB
            Sidecar["Istio Sidecar Proxy<br/>PeerAuth: STRICT<br/>(port 8086: PERMISSIVE)"]

            subgraph Transformer["transformer-container"]
                CaikitHTTP["Caikit HTTP API<br/>8080/TCP<br/>text-generation"]
                CaikitGRPC["Caikit gRPC API<br/>8085/TCP (h2c)<br/>NlpService"]
                CaikitMetrics["Caikit Metrics<br/>8086/TCP<br/>Prometheus"]
            end

            subgraph InferenceEngine["kserve-container"]
                TGIS["TGIS Engine<br/>8033/TCP gRPC<br/>LLM Model Loading"]
            end
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>openshift-user-workload-monitoring<br/>NetworkPolicy: allowed"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Secret"]
        PVC["PersistentVolumeClaim<br/>/mnt/models<br/>Filesystem"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress internal
    Gateway -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>Service Identity"| KnativeAct

    %% Ingress to Service Mesh
    KnativeAct -->|"HTTP/8080<br/>mTLS (sidecar)<br/>Service Identity"| CaikitHTTP
    KnativeAct -->|"gRPC(h2c)/8085<br/>mTLS (sidecar)<br/>Service Identity"| CaikitGRPC

    %% Pod-internal
    CaikitHTTP -->|"gRPC/8033<br/>localhost<br/>No encryption"| TGIS
    CaikitGRPC -->|"gRPC/8033<br/>localhost<br/>No encryption"| TGIS

    %% Monitoring
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>No auth"| CaikitMetrics

    %% External services
    TGIS -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    TGIS -->|"Filesystem<br/>Volume Mount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway,KnativeAct ingress
    class CaikitHTTP,CaikitGRPC,CaikitMetrics,TGIS servicemesh
    class Sidecar sidecar
    class Prometheus monitoring
    class S3,PVC externalservice
