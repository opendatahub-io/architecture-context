graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>wildcard-certs<br/>RequestAuthentication"]
        KnativeLocalGW["Knative Local Gateway<br/>8081/TCP HTTP<br/>Internal only"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator<br/>+ Queue-Proxy"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph Pod["KServe ServingRuntime Pod"]
                direction TB
                Caikit["Caikit Runtime<br/>(transformer-container)<br/>HTTP :8080 | gRPC :8085 | Metrics :8086<br/>caikit 0.28.1 + caikit-nlp 0.5.14"]
                TGIS["TGIS Server<br/>(kserve-container)<br/>gRPC :8033<br/>LLM Inference Engine"]
                Sidecar["Istio Sidecar (Envoy)<br/>PeerAuth: STRICT<br/>Port 8086: PERMISSIVE"]
            end
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>openshift-user-workload-monitoring<br/>NetworkPolicy allowed"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Secret"]
        PVC["PersistentVolumeClaim<br/>/mnt/models<br/>Filesystem mount"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| IstioGW

    %% Ingress → Service Mesh
    IstioGW -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>Service Identity"| Activator

    %% Knative → Pod
    Activator -->|"HTTP/8080 or gRPC/8085<br/>mTLS (Istio sidecar)<br/>Service Identity"| Caikit

    %% Pod-internal
    Caikit -->|"gRPC/8033<br/>localhost<br/>No encryption"| TGIS

    %% Monitoring
    Prometheus -->|"HTTP/8086<br/>Plaintext<br/>PERMISSIVE mTLS<br/>No auth"| Caikit

    %% External services
    Pod -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    TGIS -.->|"Volume mount<br/>/mnt/models"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class IstioGW,KnativeLocalGW ingress
    class Activator servicemesh
    class Caikit,TGIS,Sidecar pod
    class Prometheus monitoring
    class S3,PVC externalservice
