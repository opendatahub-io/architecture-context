graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        GatewayExt["knative-ingress-gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.3 (SIMPLE)<br/>wildcard-certs"]
        GatewayInt["knative-local-gateway<br/>8081/TCP<br/>HTTP (plaintext)<br/>Cluster-local only"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator /<br/>Queue Proxy<br/>SA: activator"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            subgraph Pod["Caikit-TGIS Pod (UID: 1001)"]
                direction TB
                Caikit["transformer-container<br/>(Caikit Runtime)<br/>:8080/TCP HTTP<br/>:8085/TCP gRPC (h2c)<br/>:8086/TCP Metrics"]
                TGIS["kserve-container<br/>(TGIS)<br/>:8033/TCP gRPC<br/>GPU-accelerated"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>(User Workload Monitoring)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>(MinIO / AWS S3)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        HFHub["HuggingFace Hub<br/>(optional)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>No Auth (passthrough)"| GatewayExt

    %% Ingress → Service Mesh
    GatewayExt -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>Service Identity"| Activator

    %% Queue Proxy → Caikit (HTTP path)
    Activator -->|"HTTP/8080 or gRPC/8085<br/>mTLS (sidecar)<br/>Service Identity"| Caikit

    %% Caikit → TGIS (intra-pod)
    Caikit -->|"gRPC/8033<br/>plaintext (localhost)<br/>No Auth"| TGIS

    %% Metrics
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>plaintext allowed<br/>NetworkPolicy gated"| Caikit

    %% External services
    TGIS -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class GatewayExt,GatewayInt ingress
    class Activator servicemesh
    class Caikit,TGIS pod
    class Prometheus monitoring
    class S3,HFHub externalservice
