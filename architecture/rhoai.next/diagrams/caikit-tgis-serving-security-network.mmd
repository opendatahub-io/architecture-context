graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        ClientHTTP["HTTP Client"]
        ClientGRPC["gRPC Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>(knative-ingress-gateway)<br/>443/TCP → internal<br/>TLS 1.2+ SIMPLE<br/>wildcard-certs"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator /<br/>Queue Proxy<br/>8012/TCP"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph InferencePod["KServe Inference Pod"]
                direction TB
                Caikit["Caikit transformer-container<br/>8080/TCP HTTP | 8085/TCP gRPC<br/>8086/TCP Metrics<br/>Image: quay.io/rhoai/caikit-tgis-serving"]
                TGISBackend["TGIS kserve-container<br/>8033/TCP gRPC<br/>GPU-accelerated inference"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor: caikit-metrics"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>(AWS S3 / MinIO)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / minio-secret"]
        HuggingFace["HuggingFace Hub<br/>(dev only)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        PVC["PVC<br/>/mnt/models/<br/>Filesystem"]
    end

    %% External → Ingress
    ClientHTTP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| Gateway
    ClientGRPC -->|"HTTPS (h2)/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| Gateway

    %% Ingress → Service Mesh
    Gateway -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>PeerAuthentication"| Activator

    %% Knative → Caikit
    Activator -->|"HTTP/8080 or gRPC/8085<br/>mTLS STRICT<br/>Istio sidecar"| Caikit

    %% Caikit → TGIS (localhost)
    Caikit -->|"gRPC/8033<br/>Plaintext (localhost)<br/>No auth"| TGISBackend

    %% Monitoring
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>NetworkPolicy: allow UWM ns"| Caikit

    %% Egress to external
    TGISBackend -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    TGISBackend -->|"Filesystem<br/>mount"| PVC
    TGISBackend -.->|"HTTPS/443<br/>HF Token (dev)"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class ClientHTTP,ClientGRPC external
    class Gateway ingress
    class Activator,Caikit,TGISBackend servicemesh
    class Prometheus monitoring
    class S3,HuggingFace,PVC externalservice
