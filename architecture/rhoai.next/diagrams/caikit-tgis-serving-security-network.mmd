graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>(knative-ingress-gateway)<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>wildcard-certs"]
        LocalGW["Knative Local Gateway<br/>8081/TCP HTTP<br/>Cluster-internal only"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator /<br/>Queue Proxy"]
        end

        subgraph NS_User["Namespace: user-namespace"]
            subgraph Pod["Inference Pod (Multi-Container)"]
                direction TB
                Caikit["transformer-container<br/>(Caikit Runtime)<br/>HTTP: 8080/TCP<br/>gRPC: 8085/TCP<br/>Metrics: 8086/TCP"]
                TGIS["kserve-container<br/>(TGIS)<br/>gRPC: 8033/TCP<br/>(localhost only)"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Secret"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(dev only)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress → Service Mesh
    Gateway -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>Istio PeerAuth"| Activator

    %% Service Mesh internal
    Activator -->|"HTTP/8080 or gRPC/8085<br/>mTLS STRICT<br/>Istio PeerAuth"| Caikit

    %% Pod-internal (localhost)
    Caikit -->|"gRPC/8033<br/>Plaintext (localhost)<br/>No Auth"| TGIS

    %% Metrics (PERMISSIVE)
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>No Auth"| Caikit

    %% Egress
    TGIS -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    TGIS -.->|"HTTPS/443<br/>TLS 1.2+<br/>(dev only)"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,LocalGW ingress
    class Activator servicemesh
    class Caikit,TGIS pod
    class Prometheus monitoring
    class S3,HuggingFace externalservice
