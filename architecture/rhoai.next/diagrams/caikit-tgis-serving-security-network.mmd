graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["knative-ingress-gateway<br/>Istio Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ (SIMPLE)<br/>wildcard-certs"]
        LocalGW["knative-local-gateway<br/>8081/TCP plaintext<br/>(cluster-local only)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Namespace: knative-serving"]
            Activator["Knative Activator /<br/>Queue Proxy"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph Pod["Multi-Container Inference Pod"]
                direction TB
                Caikit["Caikit transformer-container<br/>8080/TCP HTTP | 8085/TCP gRPC<br/>8086/TCP metrics<br/>Image: caikit-tgis-serving"]
                TGIS["TGIS kserve-container<br/>8033/TCP gRPC (localhost)<br/>GPU-accelerated inference"]
            end
        end

        subgraph NS_Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>(MinIO / AWS S3)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Secret"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(dev only, ALLOW_DOWNLOADS=1)"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress to Service Mesh
    Gateway -->|"HTTP or gRPC/8012<br/>mTLS<br/>Istio PeerAuth"| Activator
    LocalGW -->|"HTTP/8081<br/>plaintext<br/>(cluster-local)"| Activator

    %% Within Service Mesh
    Activator -->|"HTTP/8080 or gRPC/8085<br/>mTLS (sidecar)<br/>PeerAuth STRICT"| Caikit

    %% Pod-internal
    Caikit -->|"gRPC/8033<br/>localhost (no encryption)<br/>No auth"| TGIS

    %% Metrics
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>No auth required"| Caikit

    %% Egress
    TGIS -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    TGIS -.->|"HTTPS/443<br/>TLS 1.2+<br/>(dev only)"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway,LocalGW ingress
    class Activator,Caikit,TGIS servicemesh
    class Prometheus monitoring
    class S3,HuggingFace externalservice
