graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 8080/8085<br/>TLS 1.2+<br/>RequestAuthentication (JWT)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph ServingPod["KServe Serving Pod<br/>Namespace: user-namespace"]
            direction TB

            Sidecar["Istio Sidecar (Envoy)<br/>PeerAuth: STRICT<br/>mTLS termination"]

            subgraph Containers["Pod Containers"]
                direction LR
                Caikit["transformer-container<br/>Caikit Runtime<br/>UID: 1001 (non-root)<br/>Ports: 8080, 8085, 8086<br/>Image: caikit-tgis-serving"]
                TGISContainer["kserve-container<br/>TGIS Inference Engine<br/>Port: 8033/TCP gRPC<br/>GPU inference"]
            end

            SharedVol["/mnt/models<br/>Model Artifacts Volume"]
        end

        subgraph Monitoring["Namespace: openshift-user-workload-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor: caikit-metrics"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Secret"]
    end

    subgraph OptionalAuth["OPTIONAL AUTH"]
        Authorino["Authorino<br/>Bearer Token Validation"]
    end

    %% Flows with security details
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway
    Gateway -->|"HTTP/8080 or gRPC/8085<br/>mTLS STRICT<br/>Istio PeerAuth"| Sidecar
    Sidecar -->|"HTTP/8080 or gRPC/8085<br/>Loopback (no encryption)<br/>Trusted after mTLS"| Caikit
    Caikit -->|"gRPC/8033<br/>Localhost (no encryption)<br/>Pod-internal"| TGISContainer
    TGISContainer --> SharedVol

    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>NetworkPolicy restricted"| Caikit

    S3 -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM credentials<br/>(via KServe storage initializer)"| SharedVol

    Gateway -.->|"token validation<br/>(when enabled)"| Authorino

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Client external
    class Gateway ingress
    class Sidecar,Caikit,TGISContainer,Prometheus servicemesh
    class S3 externalservice
    class Authorino optional
    class SharedVol container
