graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>443/TCP → 8012/TCP<br/>TLS 1.2+ termination<br/>RequestAuthentication"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_Knative["Knative Serving Layer"]
            Activator["Knative Activator /<br/>Queue Proxy<br/>SA: activator"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph ServingPod["KServe ServingRuntime Pod"]
                direction TB
                Caikit["Caikit Transformer Container<br/>HTTP: 8080/TCP<br/>gRPC: 8085/TCP (h2c)<br/>Metrics: 8086/TCP"]
                TGIS["TGIS Container<br/>gRPC: 8033/TCP<br/>(localhost only)"]
            end
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus UWM<br/>NS: openshift-user-workload-monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / S3 keys"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>(dev/test only)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP or gRPC/8012<br/>mTLS STRICT<br/>Istio PeerAuth"| Activator
    Activator -->|"HTTP/8080 or gRPC/8085<br/>plaintext (in-pod)<br/>mesh-enforced"| Caikit
    Caikit -->|"gRPC/8033<br/>plaintext (localhost)<br/>no auth"| TGIS
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS<br/>no auth<br/>NetworkPolicy allowed"| Caikit

    %% Storage initializer (init container)
    ServingPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / S3 keys<br/>(storage initializer)"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef mesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class Activator mesh
    class Caikit,TGIS pod
    class Prometheus monitoring
    class S3,HF extsvc
