graph LR
    MMServing[ModelMesh Serving<br/>Controller]

    %% External Dependencies (Required)
    MMServing -->|"coordination backend<br/>gRPC/2379 TLS"| etcd[etcd v3.5.x<br/>Required]
    MMServing -->|"operator framework"| ControllerRuntime[controller-runtime<br/>v0.16.3<br/>Required]
    MMServing -->|"CRD types"| KServe[KServe v0.12.0<br/>Required]

    %% External Dependencies (Optional)
    MMServing -.->|"webhook TLS certs"| CertManager[cert-manager v1<br/>Optional]
    MMServing -.->|"ServiceMonitor CRD"| PrometheusOp[prometheus-operator<br/>v0.55.0<br/>Optional]

    %% Internal Platform Dependencies
    RhodsOp[rhods-operator] -->|"deploys via kustomize"| MMServing
    MMServing -->|"sidecar in runtime pods"| ModelMeshRT[ModelMesh Runtime<br/>kserve/modelmesh]
    MMServing -->|"sidecar: REST→gRPC"| RESTProxy[REST Proxy<br/>kserve/rest-proxy]
    MMServing -->|"sidecar: model download"| RuntimeAdapter[Runtime Adapter<br/>kserve/modelmesh-runtime-adapter]
    MMServing -->|"sidecar: auth proxy"| OAuthProxy[oauth-proxy<br/>ose-oauth-proxy]

    %% Integration Points (inbound)
    ODHDashboard[ODH Dashboard] -.->|"UI management"| MMServing
    ODHModelCtrl[odh-model-controller] -.->|"webhook interception"| MMServing

    %% External Services
    MMServing -->|"model artifacts<br/>HTTPS/443"| S3[S3 Storage]
    MMServing -->|"model artifacts<br/>HTTPS/443"| GCS[GCS]
    MMServing -->|"model artifacts<br/>HTTPS/443"| Azure[Azure Blob]
    MMServing -->|"CRD watches<br/>HTTPS/443"| K8sAPI[Kubernetes API]
    MMServing -->|"metrics scraping<br/>HTTPS/2112"| Prometheus[Prometheus]

