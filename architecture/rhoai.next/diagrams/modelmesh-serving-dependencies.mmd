graph LR
    MM["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MM -->|"model registry<br/>gRPC :2379"| etcd["etcd v3.5.x<br/>(Required)"]
    MM -->|"CRD definitions"| KServeCRDs["KServe CRDs v0.12.0<br/>(Required)"]
    MM -->|"controller framework"| CR["controller-runtime v0.16.3<br/>(Required)"]
    MM -->|"manifest rendering"| Manifestival["manifestival v0.7.1<br/>(Required)"]

    %% External Dependencies (Optional)
    MM -.->|"ServiceMonitor CRD<br/>(auto-detected)"| PromOp["Prometheus Operator<br/>(Optional)"]
    MM -.->|"webhook TLS certs<br/>(upstream pattern)"| CertMgr["cert-manager<br/>(Optional)"]

    %% Container Image Dependencies
    MM -->|"inference routing<br/>sidecar container"| MMesh["ModelMesh<br/>(kserve/modelmesh)"]
    MM -->|"HTTP-to-gRPC<br/>sidecar container"| RESTProxy["REST Proxy<br/>(kserve/rest-proxy)"]
    MM -->|"model download<br/>sidecar container"| Adapter["Runtime Adapter<br/>(kserve/modelmesh-runtime-adapter)"]
    MM -->|"OAuth auth<br/>sidecar container"| OAuthProxy["oauth-proxy<br/>(ose-oauth-proxy)"]

    %% Platform Integration
    MM -->|"OAuth token<br/>validation"| OSAuth["OpenShift OAuth"]

    %% External Services
    MM -->|"model artifacts<br/>HTTPS :443"| S3["Object Storage<br/>(S3 / MinIO)"]
    MM -->|"resource CRUD<br/>HTTPS :443"| K8sAPI["Kubernetes API"]

    %% Incoming integrations (who depends on ModelMesh)
    Dashboard["ODH Dashboard"] -.->|"UI management"| MM
    DSP["Data Science Pipelines"] -.->|"model deployment"| MM
    ODHModelCtrl["odh-model-controller"] -.->|"InferenceService<br/>webhooks"| MM
    KServe["KServe Controller"] -.->|"ServingRuntime<br/>webhooks"| MM

    %% Platform
    MM -->|"TLS certs<br/>(RHOAI pattern)"| ServCerts["OpenShift<br/>serving-certificates"]
    MM -->|"autoscaling"| HPA["Kubernetes HPA"]

    %% Styling
    style MM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style etcd fill:#999,stroke:#333,color:#fff
    style KServeCRDs fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style PromOp fill:#bbb,stroke:#333,color:#fff
    style CertMgr fill:#bbb,stroke:#333,color:#fff

    %% Container images
    style MMesh fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style Adapter fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff

    %% Platform integrations
    style OSAuth fill:#f5a623,stroke:#333,color:#fff
    style ServCerts fill:#f5a623,stroke:#333,color:#fff
    style HPA fill:#f5a623,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff

    %% Consumers
    style Dashboard fill:#d5e8d4,stroke:#82b366
    style DSP fill:#d5e8d4,stroke:#82b366
    style ODHModelCtrl fill:#d5e8d4,stroke:#82b366
    style KServe fill:#d5e8d4,stroke:#82b366
