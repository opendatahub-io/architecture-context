graph LR
    ModelMesh["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    ModelMesh -->|"state store<br/>gRPC/2379"| etcd["etcd v3.5.x<br/>(Required)"]
    ModelMesh -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.16.3 (Required)"]
    ModelMesh -->|"CRD types"| KServeAPI["kserve API types<br/>v0.12.0 (Required)"]
    ModelMesh -->|"manifest rendering"| Manifestival["manifestival<br/>v0.7.1 (Required)"]
    ModelMesh -->|"leader election"| OperatorLib["operator-lib<br/>v0.10.0 (Required)"]

    %% External Dependencies (Optional)
    ModelMesh -.->|"TLS certs<br/>(optional)"| CertManager["cert-manager"]
    ModelMesh -.->|"ServiceMonitor<br/>(optional)"| PrometheusOp["prometheus-operator<br/>v0.55.0"]

    %% Internal Platform Dependencies (Container Images)
    ModelMesh -->|"data plane<br/>gRPC/8033"| MMDataPlane["ModelMesh<br/>(kserve/modelmesh)<br/>Container Image"]
    ModelMesh -->|"model download<br/>gRPC/8086"| RuntimeAdapter["modelmesh-runtime-adapter<br/>Container Image"]
    ModelMesh -->|"HTTP→gRPC<br/>8008/TCP"| RESTProxy["rest-proxy<br/>(kserve/rest-proxy)<br/>Container Image"]
    ModelMesh -->|"OAuth auth<br/>8443/TCP"| OAuthProxy["oauth-proxy<br/>(ose-oauth-proxy)<br/>Container Image"]

    %% Runtime Container Images
    ModelMesh -.->|"runtime"| Triton["Triton Inference Server<br/>Container Image"]
    ModelMesh -.->|"runtime"| MLServer["MLServer<br/>Container Image"]
    ModelMesh -.->|"runtime"| OVMS["OpenVINO Model Server<br/>Container Image"]
    ModelMesh -.->|"runtime"| TorchServe["TorchServe<br/>Container Image"]

    %% External Services
    ModelMesh -->|"API calls<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    RuntimeAdapter -->|"model storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]
    RuntimeAdapter -->|"model storage<br/>HTTPS/443"| GCS["GCS Storage"]
    RuntimeAdapter -->|"model storage<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]

    %% Peer Components (Integration Points)
    KServeComponent["KServe Component"] -->|"external webhooks<br/>on CRDs"| ModelMesh
    ODHModelCtrl["ODH Model Controller"] -->|"mutating/validating<br/>webhooks"| ModelMesh
    RHODSOp["RHODS Operator"] -->|"connection webhook"| ModelMesh

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style etcd fill:#e74c3c,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style KServeAPI fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style OperatorLib fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style PrometheusOp fill:#bbb,stroke:#333,color:#fff

    %% Internal platform deps (container images)
    style MMDataPlane fill:#7ed321,stroke:#333,color:#fff
    style RuntimeAdapter fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff

    %% Runtime images
    style Triton fill:#27ae60,stroke:#333,color:#fff
    style MLServer fill:#27ae60,stroke:#333,color:#fff
    style OVMS fill:#27ae60,stroke:#333,color:#fff
    style TorchServe fill:#27ae60,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff

    %% Peer components
    style KServeComponent fill:#9b59b6,stroke:#333,color:#fff
    style ODHModelCtrl fill:#9b59b6,stroke:#333,color:#fff
    style RHODSOp fill:#9b59b6,stroke:#333,color:#fff
