graph LR
    MMS["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MMS -->|"model registry state<br/>gRPC/2379"| etcd["etcd v3.5.x<br/>(Required)"]
    MMS -->|"operator framework"| CR["controller-runtime<br/>v0.16.3<br/>(Required)"]
    MMS -->|"CRD types"| KServe["kserve v0.12.0<br/>(Required)"]
    MMS -->|"manifest templating"| Manifestival["manifestival v0.7.1<br/>(Required)"]
    MMS -->|"leader election"| OperatorLib["operator-lib v0.10.0<br/>(Required)"]

    %% External Dependencies (Optional)
    MMS -.->|"ServiceMonitor CRD"| PromOperator["prometheus-operator<br/>v0.55.0<br/>(Optional)"]
    MMS -.->|"webhook TLS certs"| CertManager["cert-manager<br/>(Optional)"]

    %% Internal Platform Dependencies (Container Images)
    MMS -->|"data plane<br/>gRPC inference"| ModelMesh["ModelMesh<br/>(kserve/modelmesh)<br/>Container image"]
    MMS -->|"model download<br/>puller sidecar"| RuntimeAdapter["modelmesh-runtime-adapter<br/>Container image"]
    MMS -->|"REST→gRPC proxy<br/>sidecar"| RESTProxy["rest-proxy<br/>(kserve/rest-proxy)<br/>Container image"]
    MMS -->|"OAuth auth<br/>sidecar"| OAuthProxy["oauth-proxy<br/>(ose-oauth-proxy)<br/>Container image"]

    %% Runtime Container Images
    MMS -.->|"NVIDIA runtime"| Triton["Triton Inference Server<br/>Container image"]
    MMS -.->|"Seldon runtime"| MLServer["MLServer<br/>Container image"]
    MMS -.->|"Intel runtime"| OVMS["OpenVINO Model Server<br/>Container image"]
    MMS -.->|"PyTorch runtime"| TorchServe["TorchServe<br/>Container image"]

    %% Platform Services
    MMS -->|"CRD CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]

    %% External Storage Services
    MMS -->|"model artifacts<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    MMS -->|"model artifacts<br/>HTTPS/443"| GCS["GCS Storage"]
    MMS -->|"model artifacts<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]

    %% Styling
    style MMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style etcd fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style OperatorLib fill:#999,stroke:#333,color:#fff
    style PromOperator fill:#bbb,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,color:#fff

    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style RuntimeAdapter fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff

    style Triton fill:#50c878,stroke:#333,color:#fff
    style MLServer fill:#50c878,stroke:#333,color:#fff
    style OVMS fill:#50c878,stroke:#333,color:#fff
    style TorchServe fill:#50c878,stroke:#333,color:#fff

    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
