graph LR
    MMS["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MMS -->|"model registry<br/>2379/gRPC"| etcd["etcd v3.5.x<br/>(Required)"]
    MMS -->|"operator framework"| CR["controller-runtime<br/>v0.16.3<br/>(Required)"]
    MMS -->|"CRD API types"| KServe["kserve v0.12.0<br/>(Required)"]
    MMS -->|"template rendering"| Manifestival["manifestival v0.7.1<br/>(Required)"]
    MMS -->|"leader election"| OperatorLib["operator-lib v0.10.0<br/>(Required)"]

    %% External Dependencies (Optional)
    MMS -.->|"ServiceMonitor CRD"| PromOp["prometheus-operator<br/>v0.55.0<br/>(Optional)"]
    MMS -.->|"webhook TLS certs"| CertMgr["cert-manager<br/>(Optional)"]

    %% Internal Platform Dependencies (Container images / sidecars)
    MMS -->|"data plane<br/>gRPC client"| ModelMesh["ModelMesh<br/>(kserve/modelmesh)<br/>Container image"]
    MMS -->|"puller sidecar"| RTA["modelmesh-runtime-adapter<br/>Container image"]
    MMS -->|"REST→gRPC proxy"| RestProxy["rest-proxy<br/>(kserve/rest-proxy)<br/>Container image"]
    MMS -->|"OAuth sidecar"| OAuthProxy["oauth-proxy<br/>(ose-oauth-proxy)<br/>Container image"]

    %% Runtime images
    MMS -->|"runtime"| Triton["Triton Inference Server<br/>Container image"]
    MMS -->|"runtime"| MLServer["MLServer<br/>(Seldon)<br/>Container image"]
    MMS -->|"runtime"| OVMS["OpenVINO Model Server<br/>Container image"]
    MMS -->|"runtime"| TorchServe["TorchServe<br/>Container image"]

    %% External services (egress)
    MMS -->|"CRD CRUD<br/>443/HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    RTA -->|"model download<br/>443/HTTPS"| S3["S3-compatible<br/>Storage"]
    RTA -->|"model download<br/>443/HTTPS"| GCS["GCS Storage"]
    RTA -->|"model download<br/>443/HTTPS"| Azure["Azure Blob<br/>Storage"]

    %% Styling
    style MMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style etcd fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style OperatorLib fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style PromOp fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style CertMgr fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Internal platform deps (container images)
    style ModelMesh fill:#7ed321,stroke:#333
    style RTA fill:#7ed321,stroke:#333
    style RestProxy fill:#7ed321,stroke:#333
    style OAuthProxy fill:#7ed321,stroke:#333

    %% Runtimes
    style Triton fill:#50c878,stroke:#333
    style MLServer fill:#50c878,stroke:#333
    style OVMS fill:#50c878,stroke:#333
    style TorchServe fill:#50c878,stroke:#333

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
