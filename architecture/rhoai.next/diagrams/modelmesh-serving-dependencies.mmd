graph LR
    MM["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MM -->|"model state<br/>2379/TCP gRPC"| etcd["etcd v3.5.x<br/>(Required)"]
    MM -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.16.3 (Required)"]
    MM -->|"CRD types"| KServe["KServe v0.12.0<br/>(Required)"]
    MM -->|"manifest templating"| Manifestival["manifestival v0.7.1<br/>(Required)"]

    %% External Dependencies (Optional)
    MM -.->|"webhook TLS certs"| CertManager["cert-manager v1<br/>(Optional)"]
    MM -.->|"ServiceMonitor CRD"| PrometheusOp["prometheus-operator<br/>v0.55.0 (Optional)"]

    %% Internal Platform Dependencies (Sidecars)
    MM -->|"gRPC 8033/TCP<br/>vmodel lifecycle"| ModelMeshJava["ModelMesh<br/>(Java Sidecar)"]
    MM -->|"model download<br/>8086/TCP gRPC"| Puller["modelmesh-runtime-adapter<br/>(puller sidecar)"]
    MM -.->|"HTTP-to-gRPC bridge"| RESTProxy["REST Proxy<br/>(sidecar)"]
    MM -.->|"OAuth auth<br/>8443/TCP HTTPS"| OAuthProxy["oauth-proxy<br/>(RHOAI sidecar)"]

    %% Model Runtimes
    MM -->|"manages"| Triton["NVIDIA Triton"]
    MM -->|"manages"| OVMS["OpenVINO Model Server"]
    MM -->|"manages"| MLServer["MLServer"]
    MM -->|"manages"| TorchServe["TorchServe"]

    %% Integration Points (Incoming)
    Dashboard["ODH Dashboard"] -.->|"UI management"| MM
    Pipelines["Data Science Pipelines"] -.->|"auto deploy models"| MM

    %% External Services
    MM -->|"model artifacts<br/>443/TCP HTTPS"| S3["S3 / GCS / Azure<br/>Model Storage"]
    MM -->|"cluster management<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    MM -.->|"auth enforcement"| OpenShiftOAuth["OpenShift OAuth<br/>(RHOAI)"]
    MM -.->|"restricted SCC"| OpenShiftSCC["OpenShift SCC"]

    %% Styling
    style MM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style etcd fill:#e74c3c,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style PrometheusOp fill:#bbb,stroke:#333,color:#fff

    %% Internal sidecars
    style ModelMeshJava fill:#7ed321,stroke:#333,color:#fff
    style Puller fill:#7ed321,stroke:#333,color:#fff
    style RESTProxy fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#9b59b6,stroke:#333,color:#fff

    %% Model runtimes
    style Triton fill:#e67e22,stroke:#333,color:#fff
    style OVMS fill:#e67e22,stroke:#333,color:#fff
    style MLServer fill:#e67e22,stroke:#333,color:#fff
    style TorchServe fill:#e67e22,stroke:#333,color:#fff

    %% Integration points
    style Dashboard fill:#3498db,stroke:#333,color:#fff
    style Pipelines fill:#3498db,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style OpenShiftOAuth fill:#9b59b6,stroke:#333,color:#fff
    style OpenShiftSCC fill:#9b59b6,stroke:#333,color:#fff
