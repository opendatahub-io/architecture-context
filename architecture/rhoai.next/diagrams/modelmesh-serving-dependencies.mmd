graph LR
    MMServing["ModelMesh Serving<br/>Controller"]

    %% External Dependencies (Required)
    MMServing -->|"model state<br/>gRPC/2379"| etcd["etcd v3.5.x<br/>(Required)"]
    MMServing -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.16.3 (Required)"]
    MMServing -->|"CRD type defs"| KServe["KServe CRDs<br/>v0.12.0 (Required)"]
    MMServing -->|"manifest templating"| Manifestival["manifestival<br/>v0.7.1 (Required)"]

    %% External Dependencies (Optional)
    MMServing -.->|"webhook TLS certs"| CertManager["cert-manager v1<br/>(Optional)"]
    MMServing -.->|"ServiceMonitor CRD"| PrometheusOp["prometheus-operator<br/>v0.55.0 (Optional)"]

    %% Internal Platform Dependencies (Sidecars)
    MMServing -->|"model mgmt engine<br/>gRPC sidecar"| ModelMeshJava["ModelMesh<br/>(Java Runtime)"]
    MMServing -->|"model download<br/>storage helper"| Puller["modelmesh-runtime-adapter<br/>(Puller)"]
    MMServing -->|"HTTP-to-gRPC bridge"| RESTProxy["REST Proxy"]
    MMServing -->|"OAuth auth (RHOAI)<br/>HTTPS/8443"| OAuthProxy["oauth-proxy"]

    %% Model Runtimes
    MMServing -->|"inference engines"| Triton["NVIDIA Triton"]
    MMServing -->|"inference engines"| OVMS["OpenVINO Model Server"]
    MMServing -->|"inference engines"| MLServer["Seldon MLServer"]
    MMServing -->|"inference engines"| TorchServe["TorchServe"]

    %% Integration Points (consumed by others)
    K8sAPI["Kubernetes API"] -->|"CRD CRUD<br/>HTTPS/443"| MMServing
    Prometheus["Prometheus"] -.->|"scrape metrics"| MMServing

    %% External Services
    MMServing -->|"model artifacts<br/>HTTPS/443"| S3["S3 Storage"]
    MMServing -->|"model artifacts<br/>HTTPS/443"| GCS["GCS Storage"]
    MMServing -->|"model artifacts<br/>HTTPS/443"| Azure["Azure Blob"]
    MMServing -->|"model artifacts"| PVC["PersistentVolumeClaim"]

    %% Platform Integration
    OpenShiftOAuth["OpenShift OAuth"] -->|"user auth"| OAuthProxy
    OpenShiftSCC["OpenShift SCC"] -.->|"restricted SCC"| MMServing

    %% Styling
    style MMServing fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style PrometheusOp fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style ModelMeshJava fill:#7b68ee,stroke:#333,color:#fff
    style Puller fill:#7b68ee,stroke:#333,color:#fff
    style RESTProxy fill:#7b68ee,stroke:#333,color:#fff
    style OAuthProxy fill:#7b68ee,stroke:#333,color:#fff
    style Triton fill:#7ed321,stroke:#333
    style OVMS fill:#7ed321,stroke:#333
    style MLServer fill:#7ed321,stroke:#333
    style TorchServe fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#999
    style OpenShiftOAuth fill:#cc0000,stroke:#333,color:#fff
    style OpenShiftSCC fill:#cc0000,stroke:#333,color:#fff
