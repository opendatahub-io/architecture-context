graph TB
    subgraph KubeflowNotebook["Kubeflow Notebook Controller Component"]
        direction TB

        subgraph KFController["kf-notebook-controller"]
            NotebookCtrl["Notebook Controller<br/>Go Operator"]
            CullingCtrl["Culling Controller<br/>Idle Detection"]
        end

        subgraph ODHController["odh-notebook-controller"]
            ODHReconciler["Notebook Reconciler<br/>OpenShift Extensions"]
            MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>8443/TCP"]
            ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>8443/TCP"]
        end
    end

    %% CRDs
    NotebookCR["Notebook CR<br/>kubeflow.org/v1"]

    %% Resources created by kf-notebook-controller
    StatefulSet["StatefulSet<br/>(1 replica)"]
    ClusterIPSvc["ClusterIP Service<br/>80/TCP → 8888"]
    VirtualSvc["VirtualService<br/>(optional, Istio)"]

    %% Resources created by odh-notebook-controller
    HTTPRoute["HTTPRoute<br/>(Gateway API)<br/>controller namespace"]
    NetworkPolicy["NetworkPolicy<br/>Pod isolation"]
    RBACProxy["kube-rbac-proxy<br/>Sidecar (8443/TCP)<br/>TLS + SubjectAccessReview"]
    ReferenceGrant["ReferenceGrant<br/>Cross-namespace"]
    CACertBundle["CA Cert Bundle<br/>ConfigMap mount"]
    PipelineSecret["Elyra Pipeline<br/>Config Secret"]

    %% External actors
    User["User / Dashboard"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    Gateway["data-science-gateway<br/>Gateway API"]

    %% User creates Notebook CR
    User -->|creates| NotebookCR
    NotebookCR -->|intercepted by| MutatingWH
    MutatingWH -->|injects sidecars,<br/>certs, config| NotebookCR
    NotebookCR -->|validated by| ValidatingWH

    %% kf-notebook-controller watches and creates
    NotebookCR -->|watched by| NotebookCtrl
    NotebookCtrl -->|creates| StatefulSet
    NotebookCtrl -->|creates| ClusterIPSvc
    NotebookCtrl -->|creates| VirtualSvc

    %% odh-notebook-controller watches and creates
    NotebookCR -->|watched by| ODHReconciler
    ODHReconciler -->|creates| HTTPRoute
    ODHReconciler -->|creates| NetworkPolicy
    ODHReconciler -->|injects| RBACProxy
    ODHReconciler -->|creates| ReferenceGrant
    ODHReconciler -->|mounts| CACertBundle
    ODHReconciler -->|mounts| PipelineSecret

    %% Culling
    CullingCtrl -->|polls Jupyter API<br/>8888/TCP| StatefulSet

    %% Controller dependencies
    NotebookCtrl -->|CRUD| K8sAPI
    ODHReconciler -->|CRUD| K8sAPI
    HTTPRoute -->|parent ref| Gateway

    %% Styling
    style NotebookCtrl fill:#4a90e2,stroke:#333,color:#fff
    style CullingCtrl fill:#4a90e2,stroke:#333,color:#fff
    style ODHReconciler fill:#4a90e2,stroke:#333,color:#fff
    style MutatingWH fill:#4a90e2,stroke:#333,color:#fff
    style ValidatingWH fill:#4a90e2,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style StatefulSet fill:#7ed321,stroke:#333,color:#fff
    style ClusterIPSvc fill:#7ed321,stroke:#333,color:#fff
    style VirtualSvc fill:#7ed321,stroke:#333,color:#fff
    style HTTPRoute fill:#7ed321,stroke:#333,color:#fff
    style NetworkPolicy fill:#7ed321,stroke:#333,color:#fff
    style RBACProxy fill:#7ed321,stroke:#333,color:#fff
    style ReferenceGrant fill:#7ed321,stroke:#333,color:#fff
    style CACertBundle fill:#7ed321,stroke:#333,color:#fff
    style PipelineSecret fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style User fill:#d5e8d4,stroke:#333
