graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers"]
        direction TB

        subgraph NotebookCtrl["notebook-controller (upstream)"]
            NC_Main[Notebook Controller<br/>Reconciler]
            NC_Culler[Culling Controller<br/>Reconciler]
            NC_Metrics[Metrics Server<br/>:8080]
            NC_Health[Health Probes<br/>:8081]
        end

        subgraph ODHCtrl["odh-notebook-controller (RHOAI)"]
            ODH_Main[ODH Notebook Controller<br/>Reconciler]
            ODH_MutWebhook[Mutating Webhook<br/>:8443/mutate-notebook-v1]
            ODH_ValWebhook[Validating Webhook<br/>:8443/validate-notebook-v1]
            ODH_Metrics[Metrics Server<br/>:8080]
            ODH_Health[Health Probes<br/>:8081]
        end

        subgraph CommonLib["common library"]
            Common[Reconcile Helpers<br/>Deployment, Service,<br/>StatefulSet, VirtualService]
        end

        NC_Main -.->|uses| Common
        ODH_Main -.->|uses| Common
    end

    %% CRD
    User[User / Dashboard] -->|creates/updates| NotebookCR["Notebook CR<br/>kubeflow.org/v1"]

    %% Webhook flow
    NotebookCR -->|admission| ODH_MutWebhook
    NotebookCR -->|admission| ODH_ValWebhook

    %% Controller watches
    NotebookCR -->|watched by| NC_Main
    NotebookCR -->|watched by| ODH_Main
    NotebookCR -->|watched by| NC_Culler

    %% notebook-controller creates
    NC_Main -->|creates| StatefulSet[StatefulSet]
    NC_Main -->|creates| SVC_NB["Service<br/>{notebook-name}"]
    NC_Main -->|creates optional| VS["VirtualService<br/>(Istio mode)"]

    %% odh-notebook-controller creates
    ODH_Main -->|creates| HTTPRoute["HTTPRoute<br/>nb-{ns}-{name}"]
    ODH_Main -->|creates| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    ODH_Main -->|creates| NetPol["NetworkPolicy<br/>(per notebook)"]
    ODH_Main -->|injects| KRBP["kube-rbac-proxy<br/>sidecar (8443)"]
    ODH_Main -->|creates| DSPASecret["ds-pipeline-config<br/>Secret"]

    %% Culling flow
    NC_Culler -->|polls /api/kernels<br/>/api/terminals| SVC_NB

    %% External access
    Gateway["Gateway<br/>data-science-gateway<br/>443/TCP"] -->|routes via| HTTPRoute
    HTTPRoute -->|backend ref| KRBP
    KRBP -->|authenticated| SVC_NB

    %% Styling
    style NC_Main fill:#4a90e2,color:#fff
    style NC_Culler fill:#4a90e2,color:#fff
    style ODH_Main fill:#e86826,color:#fff
    style ODH_MutWebhook fill:#e86826,color:#fff
    style ODH_ValWebhook fill:#e86826,color:#fff
    style Common fill:#7ed321,color:#fff
    style NotebookCR fill:#f5a623,color:#fff
    style StatefulSet fill:#b8d4e3
    style SVC_NB fill:#b8d4e3
    style HTTPRoute fill:#f0c8a8
    style RefGrant fill:#f0c8a8
    style NetPol fill:#f0c8a8
    style KRBP fill:#d35400,color:#fff
    style Gateway fill:#8e44ad,color:#fff
    style User fill:#ecf0f1,stroke:#333
