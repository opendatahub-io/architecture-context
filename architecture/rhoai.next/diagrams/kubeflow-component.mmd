graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers (Dual-Controller Architecture)"]
        direction TB

        subgraph KFController["notebook-controller (Upstream)"]
            KFC[KF Controller<br/>Go Operator<br/>controller-runtime 0.21.0]
            KFMetrics[Metrics Server<br/>8080/TCP]
            KFHealth[Health Probes<br/>8081/TCP]
            CullingReconciler[Culling Reconciler<br/>Idle Detection]
            KFC --- KFMetrics
            KFC --- KFHealth
            KFC --- CullingReconciler
        end

        subgraph ODHController["odh-notebook-controller (RHOAI Extension)"]
            ODHC[ODH Controller<br/>Go Operator<br/>controller-runtime 0.21.0]
            ODHMetrics[Metrics Server<br/>8080/TCP]
            ODHHealth[Health Probes<br/>8081/TCP]
            MutatingWH[Mutating Webhook<br/>8443/TCP HTTPS]
            ValidatingWH[Validating Webhook<br/>8443/TCP HTTPS]
            ODHC --- ODHMetrics
            ODHC --- ODHHealth
            ODHC --- MutatingWH
            ODHC --- ValidatingWH
        end
    end

    %% CRD
    NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>(Namespaced)"]

    %% User interaction
    User[User / Dashboard] -->|creates| NotebookCR
    NotebookCR -->|watched by| KFC
    NotebookCR -->|watched by| ODHC

    %% Webhook flow
    User -->|admission| MutatingWH
    User -->|admission| ValidatingWH

    %% KF Controller creates
    KFC -->|creates| StatefulSet[StatefulSet<br/>Notebook Pod]
    KFC -->|creates| NBService[Service<br/>port 80→8888]
    KFC -->|"creates - optional"| VirtualService[VirtualService<br/>Istio]

    %% ODH Controller creates
    ODHC -->|creates| HTTPRoute[HTTPRoute<br/>Gateway API]
    ODHC -->|creates| RefGrant[ReferenceGrant<br/>Cross-namespace]
    ODHC -->|creates| KRBPService[kube-rbac-proxy<br/>Service 8443/TCP]
    ODHC -->|creates| NetPolicy[NetworkPolicy<br/>Ingress isolation]
    ODHC -->|creates| AuthCRB[ClusterRoleBinding<br/>auth-delegator]

    %% Idle culling
    CullingReconciler -->|polls 8888/TCP| StatefulSet

    %% External dependencies
    HTTPRoute -->|parentRef| DSGateway[data-science-gateway<br/>openshift-ingress]
    KRBPService -->|TLS cert| ServiceCA[OpenShift Service CA]

    %% Styling
    style KFC fill:#4a90e2,color:#fff
    style ODHC fill:#4a90e2,color:#fff
    style MutatingWH fill:#e8524a,color:#fff
    style ValidatingWH fill:#e8524a,color:#fff
    style CullingReconciler fill:#4a90e2,color:#fff
    style NotebookCR fill:#f5a623,color:#fff
    style StatefulSet fill:#7ed321,color:#fff
    style NBService fill:#7ed321,color:#fff
    style HTTPRoute fill:#7ed321,color:#fff
    style RefGrant fill:#7ed321,color:#fff
    style KRBPService fill:#7ed321,color:#fff
    style NetPolicy fill:#7ed321,color:#fff
    style AuthCRB fill:#7ed321,color:#fff
    style VirtualService fill:#999,color:#fff
    style DSGateway fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
