graph TB
    subgraph KubeflowNotebook["Kubeflow Notebook Controllers"]
        direction TB

        subgraph UpstreamCtrl["notebook-controller (upstream Kubeflow)"]
            NotebookCtrl["Notebook Controller<br/>Go Operator<br/>8080/TCP metrics, 8081/TCP health"]
            CullingCtrl["Culling Controller<br/>Polls Jupyter API for idle detection"]
            NotebookCtrl -->|"reconciles"| CullingCtrl
        end

        subgraph ODHCtrl["odh-notebook-controller (RHOAI extensions)"]
            ODHReconciler["ODH Notebook Reconciler<br/>Go Operator<br/>8080/TCP metrics, 8081/TCP health"]
            MutatingWH["Mutating Webhook<br/>8443/TCP HTTPS"]
            ValidatingWH["Validating Webhook<br/>8443/TCP HTTPS"]
            ODHReconciler -->|"serves"| MutatingWH
            ODHReconciler -->|"serves"| ValidatingWH
        end

        subgraph CommonLib["common (shared library)"]
            ReconcileHelpers["Reconciliation Helpers<br/>Deployment, Service,<br/>StatefulSet, VirtualService"]
        end

        NotebookCtrl -->|"uses"| ReconcileHelpers
        ODHReconciler -->|"uses"| ReconcileHelpers
    end

    %% CRD
    User["User / Data Scientist"] -->|"creates/updates"| NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>Namespaced"]

    %% Webhook flow
    NotebookCR -->|"admission"| MutatingWH
    NotebookCR -->|"admission"| ValidatingWH

    %% Core controller creates
    NotebookCR -->|"watched by"| NotebookCtrl
    NotebookCtrl -->|"creates"| StatefulSet["StatefulSet<br/>(notebook pod)"]
    NotebookCtrl -->|"creates"| NotebookSvc["ClusterIP Service<br/>80/TCP → 8888"]
    NotebookCtrl -->|"creates (optional)"| VirtualSvc["Istio VirtualService"]

    %% ODH controller creates
    NotebookCR -->|"watched by"| ODHReconciler
    ODHReconciler -->|"creates"| HTTPRoute["HTTPRoute<br/>/notebook/{ns}/{name}"]
    ODHReconciler -->|"creates"| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    ODHReconciler -->|"creates"| NetPol["NetworkPolicy<br/>(per notebook)"]
    ODHReconciler -->|"injects"| KubeRBACProxy["kube-rbac-proxy<br/>Sidecar (8443/TCP)"]
    ODHReconciler -->|"creates"| DSPASecret["ds-pipeline-config<br/>Secret"]

    %% Culling flow
    CullingCtrl -->|"polls /api/kernels,<br/>/api/terminals"| StatefulSet

    %% External dependencies
    HTTPRoute -->|"parentRef"| Gateway["Gateway<br/>data-science-gateway<br/>443/TCP"]
    KubeRBACProxy -->|"TokenReview +<br/>SubjectAccessReview"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% Platform webhooks
    PlatformWH1["connection-notebook<br/>(rhods-operator)"] -.->|"also mutates"| NotebookCR
    PlatformWH2["hardwareprofile-injector<br/>(rhods-operator)"] -.->|"also mutates"| NotebookCR

    %% Styling
    style NotebookCtrl fill:#4a90e2,color:#fff
    style CullingCtrl fill:#4a90e2,color:#fff
    style ODHReconciler fill:#4a90e2,color:#fff
    style MutatingWH fill:#4a90e2,color:#fff
    style ValidatingWH fill:#4a90e2,color:#fff
    style ReconcileHelpers fill:#4a90e2,color:#fff
    style NotebookCR fill:#f5a623,color:#fff
    style StatefulSet fill:#7ed321,color:#fff
    style NotebookSvc fill:#7ed321,color:#fff
    style HTTPRoute fill:#7ed321,color:#fff
    style RefGrant fill:#7ed321,color:#fff
    style NetPol fill:#7ed321,color:#fff
    style KubeRBACProxy fill:#7ed321,color:#fff
    style DSPASecret fill:#7ed321,color:#fff
    style VirtualSvc fill:#7ed321,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PlatformWH1 fill:#e8e8e8,stroke:#333
    style PlatformWH2 fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#333
