graph TB
    subgraph User["User / Dashboard"]
        UserActor[Data Scientist / Admin]
    end

    subgraph KubeAPI["Kubernetes API Server"]
        APIServer["API Server<br/>443/TCP HTTPS"]
    end

    subgraph Webhooks["Admission Webhooks"]
        MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>8443/TCP HTTPS"]
        ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>8443/TCP HTTPS"]
    end

    subgraph KubeflowControllers["Kubeflow Notebook Controllers"]
        direction TB

        subgraph UpstreamCtrl["odh-kf-notebook-controller"]
            NotebookReconciler["Notebook Reconciler<br/>StatefulSet + Service lifecycle"]
            CullingReconciler["Culling Reconciler<br/>Idle notebook detection"]
            UpstreamMetrics["Metrics :8080"]
            UpstreamHealth["Health :8081"]
        end

        subgraph ODHCtrl["odh-notebook-controller"]
            ODHReconciler["ODH Reconciler<br/>HTTPRoute, NetworkPolicy,<br/>kube-rbac-proxy, CA certs"]
            ODHMetrics["Metrics :8080"]
            ODHHealth["Health :8081"]
        end
    end

    subgraph NotebookPod["Notebook Pod"]
        KubeRBACProxy["kube-rbac-proxy<br/>sidecar :8443"]
        NotebookContainer["Jupyter Notebook<br/>:8888"]
        KubeRBACProxy -->|localhost| NotebookContainer
    end

    subgraph CRDs["Custom Resources"]
        NotebookCR["Notebook CR<br/>kubeflow.org/v1"]
    end

    subgraph NetworkResources["Network Resources"]
        HTTPRoute["HTTPRoute<br/>Gateway API"]
        ReferenceGrant["ReferenceGrant"]
        NetworkPolicy["NetworkPolicy"]
    end

    subgraph Gateway["Ingress"]
        DSGateway["data-science-gateway<br/>443/TCP HTTPS"]
    end

    %% User flows
    UserActor -->|"kubectl create"| APIServer
    APIServer -->|"admission"| MutatingWH
    APIServer -->|"admission"| ValidatingWH

    %% CRD watching
    NotebookCR -->|"watched by"| NotebookReconciler
    NotebookCR -->|"watched by"| ODHReconciler

    %% Upstream controller creates
    NotebookReconciler -->|"creates"| StatefulSet["StatefulSet"]
    NotebookReconciler -->|"creates"| NotebookSvc["Notebook Service :80"]

    %% ODH controller creates
    ODHReconciler -->|"creates"| HTTPRoute
    ODHReconciler -->|"creates"| ReferenceGrant
    ODHReconciler -->|"creates"| NetworkPolicy
    ODHReconciler -->|"creates"| KubeRBACProxySvc["kube-rbac-proxy Service :8443"]
    MutatingWH -->|"injects"| KubeRBACProxy

    %% Culling flow
    CullingReconciler -->|"polls /api/kernels<br/>/api/terminals"| NotebookContainer

    %% Gateway routing
    DSGateway -->|"routes via"| HTTPRoute
    HTTPRoute -->|"backends to"| KubeRBACProxy

    %% Styling
    style NotebookReconciler fill:#4a90e2,stroke:#333,color:#fff
    style CullingReconciler fill:#4a90e2,stroke:#333,color:#fff
    style ODHReconciler fill:#4a90e2,stroke:#333,color:#fff
    style MutatingWH fill:#9b59b6,stroke:#333,color:#fff
    style ValidatingWH fill:#9b59b6,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e74c3c,stroke:#333,color:#fff
    style NotebookContainer fill:#2ecc71,stroke:#333,color:#fff
    style DSGateway fill:#95a5a6,stroke:#333,color:#fff
    style HTTPRoute fill:#3498db,stroke:#333,color:#fff
    style ReferenceGrant fill:#3498db,stroke:#333,color:#fff
    style NetworkPolicy fill:#3498db,stroke:#333,color:#fff
