graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers (Dual-Controller Architecture)"]
        direction TB

        subgraph NotebookController["notebook-controller (Upstream Kubeflow)"]
            NC_Main["Controller Manager<br/>Go Operator"]
            NC_Culling["Culling Controller<br/>Idle Detection"]
            NC_Main --- NC_Culling
        end

        subgraph ODHController["odh-notebook-controller (RHOAI Extension)"]
            ODH_Main["Controller Manager<br/>Go Operator"]
            ODH_MutWebhook["Mutating Webhook<br/>8443/TCP"]
            ODH_ValWebhook["Validating Webhook<br/>8443/TCP"]
            ODH_Main --- ODH_MutWebhook
            ODH_Main --- ODH_ValWebhook
        end

        subgraph CommonLib["common (Shared Library)"]
            Helpers["Reconciliation Helpers<br/>Deployment, Service,<br/>StatefulSet, VirtualService"]
        end

        NotebookController -.->|uses| CommonLib
        ODHController -.->|uses| CommonLib
    end

    %% CRD
    User["Data Scientist / User"] -->|creates| NotebookCR["Notebook CR<br/>kubeflow.org/v1"]

    %% Upstream controller watches
    NotebookCR -->|watched by| NC_Main
    NC_Main -->|creates| StatefulSet["StatefulSet<br/>Notebook Pod"]
    NC_Main -->|creates| Service["ClusterIP Service<br/>80/TCP to 8888"]
    NC_Main -->|"creates (optional)"| VirtualService["Istio VirtualService<br/>when USE_ISTIO=true"]

    %% Culling flow
    NC_Culling -->|polls /api/kernels<br/>/api/terminals| StatefulSet
    NC_Culling -->|sets stop annotation| NotebookCR

    %% ODH controller watches
    NotebookCR -->|watched by| ODH_Main

    %% Webhook intercepts
    NotebookCR -.->|mutated by| ODH_MutWebhook
    NotebookCR -.->|validated by| ODH_ValWebhook

    %% ODH creates resources
    ODH_Main -->|creates| HTTPRoute["HTTPRoute<br/>Gateway API"]
    ODH_Main -->|creates| RefGrant["ReferenceGrant<br/>Cross-Namespace"]
    ODH_Main -->|creates| NetPol["NetworkPolicy<br/>Per Notebook"]
    ODH_Main -->|injects| KubeRBACProxy["kube-rbac-proxy<br/>Sidecar 8443/TCP"]

    %% Integrations
    ODH_MutWebhook -->|injects| DSPASecret["DSPA Pipeline Secret"]
    ODH_MutWebhook -->|injects| MLflowEnv["MLflow Env Vars"]
    ODH_MutWebhook -->|mounts| FeastConfig["Feast ConfigMap"]

    %% External access
    UserBrowser["User Browser"] -->|HTTPS/443| Gateway["data-science-gateway<br/>Gateway API"]
    Gateway -->|8443/TCP| KubeRBACProxy
    KubeRBACProxy -->|8888/TCP| StatefulSet

    %% Styling
    style NC_Main fill:#4a90e2,stroke:#333,color:#fff
    style NC_Culling fill:#4a90e2,stroke:#333,color:#fff
    style ODH_Main fill:#7ed321,stroke:#333,color:#fff
    style ODH_MutWebhook fill:#7ed321,stroke:#333,color:#fff
    style ODH_ValWebhook fill:#7ed321,stroke:#333,color:#fff
    style Helpers fill:#9b9b9b,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style StatefulSet fill:#bd10e0,stroke:#333,color:#fff
    style HTTPRoute fill:#50e3c2,stroke:#333
    style RefGrant fill:#50e3c2,stroke:#333
    style NetPol fill:#50e3c2,stroke:#333
    style KubeRBACProxy fill:#d0021b,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style VirtualService fill:#e8e8e8,stroke:#333
