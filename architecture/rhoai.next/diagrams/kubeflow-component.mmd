graph TB
    subgraph "Kubeflow Notebook Controllers"
        subgraph "notebook-controller (Upstream)"
            KFController["KF Notebook Controller<br/>Go Operator (controller-runtime)<br/>:8080 metrics, :8081 health"]
            KFCuller["Culling Reconciler<br/>Idle detection & auto-stop"]
            KFController --- KFCuller
        end

        subgraph "odh-notebook-controller (RHOAI Extension)"
            ODHController["ODH Notebook Controller<br/>Go Operator (controller-runtime)<br/>:8080 metrics, :8081 health, :8443 webhook"]
            MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>:8443/TCP HTTPS"]
            ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>:8443/TCP HTTPS"]
            ODHController --- MutatingWH
            ODHController --- ValidatingWH
        end
    end

    User["User / ODH Dashboard"] -->|"kubectl create Notebook"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    K8sAPI -->|"admission webhook"| MutatingWH
    K8sAPI -->|"admission webhook"| ValidatingWH

    %% CRDs
    NotebookCR["Notebook CR<br/>kubeflow.org/v1"]
    K8sAPI -->|"stores"| NotebookCR
    NotebookCR -->|"watched by"| KFController
    NotebookCR -->|"watched by"| ODHController

    %% KF Controller creates
    KFController -->|"creates"| StatefulSet["StatefulSet<br/>(notebook pod)"]
    KFController -->|"creates"| SvcNB["Service<br/>{name}:80→8888"]
    KFController -.->|"creates (optional)"| VirtualService["VirtualService<br/>(Istio overlay only)"]

    %% ODH Controller creates
    ODHController -->|"creates"| HTTPRoute["HTTPRoute<br/>nb-{ns}-{name}<br/>Path: /notebook/{ns}/{name}"]
    ODHController -->|"creates"| RefGrant["ReferenceGrant<br/>(cross-namespace auth)"]
    ODHController -->|"creates"| NetPol["NetworkPolicy<br/>(ingress restriction)"]
    ODHController -->|"creates"| KRBPSvc["kube-rbac-proxy Service<br/>{name}-kube-rbac-proxy:8443"]
    ODHController -->|"creates"| CRBSA["ClusterRoleBinding<br/>system:auth-delegator"]

    %% Culler
    KFCuller -->|"polls :8888"| StatefulSet
    KFCuller -->|"scales to 0"| StatefulSet

    %% Reconciliation lock
    MutatingWH -.->|"sets stop-notebook lock"| NotebookCR
    ODHController -.->|"removes lock after init"| NotebookCR

    %% Gateway
    HTTPRoute -->|"parentRef"| Gateway["data-science-gateway<br/>(openshift-ingress)"]

    %% Styles
    style KFController fill:#4a90e2,stroke:#333,color:#fff
    style KFCuller fill:#4a90e2,stroke:#333,color:#fff
    style ODHController fill:#7ed321,stroke:#333,color:#fff
    style MutatingWH fill:#7ed321,stroke:#333,color:#fff
    style ValidatingWH fill:#7ed321,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style StatefulSet fill:#9b59b6,stroke:#333,color:#fff
    style HTTPRoute fill:#e74c3c,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style NetPol fill:#e74c3c,stroke:#333,color:#fff
    style KRBPSvc fill:#e74c3c,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style VirtualService fill:#cccccc,stroke:#999,stroke-dasharray: 5 5
