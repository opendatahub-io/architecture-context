graph LR
    Planner["llm-d Planner<br/>(FastAPI Backend)"]

    %% Internal RHOAI Dependencies
    Planner -->|"HTTPS/8443<br/>SA Bearer Token<br/>Model & benchmark sync"| ModelCatalog["Model Catalog API<br/>(rhoai-model-registries)"]
    Planner -->|"CRD creation<br/>InferenceService"| KServe["KServe"]
    Planner -.->|"ConfigMap injection<br/>CA bundle"| ServiceCA["OpenShift service-ca<br/>Operator"]

    %% External Cloud LLM Providers (conditional)
    Planner -->|"HTTP/11434<br/>No auth<br/>Default provider"| Ollama["Ollama<br/>(in-cluster)"]
    Planner -->|"HTTPS/443<br/>GCP ADC<br/>Vertex provider"| VertexAI["Vertex AI / Anthropic"]
    Planner -->|"HTTPS/443<br/>API Key<br/>OpenAI provider"| OpenAI["OpenAI-compatible API"]

    %% Data Dependencies
    Planner -->|"TCP/5432<br/>Password<br/>Benchmark data"| PostgreSQL["PostgreSQL<br/>(in-cluster)"]
    Planner -->|"HTTPS/443<br/>Bearer Token (opt)<br/>Model metadata"| HuggingFace["HuggingFace Hub API"]
    Planner -.->|"In-process<br/>Roofline model"| BentoML["BentoML llm-optimizer"]

    %% Platform Dependencies
    Planner -->|"HTTPS/6443<br/>SA Token<br/>GPU detect + deploy"| K8sAPI["Kubernetes API"]
    Planner -.->|"Routes<br/>Edge TLS"| OpenShiftRouter["OpenShift Router"]

    %% UI depends on Backend
    StreamlitUI["Streamlit UI<br/>(Frontend)"] -->|"HTTP/8000<br/>All API calls"| Planner

    %% Integration Partners (depend on Planner)
    %% (none documented - Planner is a leaf service)

    %% Styling
    style Planner fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style StreamlitUI fill:#4a90e2,stroke:#333,color:#fff

    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff

    style Ollama fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#4a90e2,stroke:#333,color:#fff

    style VertexAI fill:#f5a623,stroke:#333,color:#fff
    style OpenAI fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OpenShiftRouter fill:#999,stroke:#333,color:#fff
    style BentoML fill:#999,stroke:#333
