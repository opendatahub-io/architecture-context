graph LR
    Planner["llm-d Planner<br/>(Backend API)"]

    %% Infrastructure Dependencies (in-cluster, same namespace)
    subgraph InCluster["In-Cluster Infrastructure (planner namespace)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Password Auth"]
        Ollama["Ollama LLM<br/>11434/TCP HTTP<br/>granite3.3:2b / qwen2.5:7b"]
    end

    Planner -->|"benchmark queries<br/>PostgreSQL/5432<br/>Password"| PostgreSQL
    Planner -->|"intent extraction<br/>HTTP/11434<br/>No Auth"| Ollama

    %% Internal RHOAI Platform Dependencies
    subgraph RHOAIPlatform["Internal RHOAI Platform"]
        ModelCatalog["RHOAI Model Catalog<br/>8443/TCP HTTPS<br/>Bearer / SA Token"]
        KServe["KServe<br/>InferenceService CRD"]
        vLLM["vLLM Runtime<br/>Container Image"]
        Prometheus["Prometheus<br/>ServiceMonitor CRD"]
        Grafana["Grafana<br/>Dashboard ConfigMap"]
    end

    Planner -->|"model + artifact sync<br/>HTTPS/8443 TLS<br/>Bearer Token"| ModelCatalog
    Planner -.->|"generates manifests"| KServe
    Planner -.->|"generates ServiceMonitor"| Prometheus
    Planner -.->|"generates Dashboard"| Grafana
    KServe -.->|"runs"| vLLM

    %% External Service Dependencies
    subgraph ExternalServices["External Services"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer (optional)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    Planner -->|"model metadata<br/>HTTPS/443 TLS 1.2+"| HFHub
    Planner -->|"GPU detection<br/>InferenceService CRUD<br/>HTTPS/6443"| K8sAPI

    %% Library Dependencies (in-process)
    subgraph Libraries["In-Process Libraries"]
        BentoML["BentoML llm-optimizer<br/>(roofline model)"]
        Jinja2["Jinja2<br/>(YAML templates)"]
    end

    Planner -->|"performance estimation<br/>(in-process)"| BentoML
    Planner -->|"manifest rendering<br/>(in-process)"| Jinja2

    %% Platform Infrastructure
    subgraph Platform["OpenShift Platform"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS Edge"]
        ServiceCA["service-ca operator<br/>CA cert injection"]
    end

    Router -->|"TLS termination<br/>→ 8000/8501 HTTP"| Planner
    ServiceCA -.->|"injects CA cert<br/>ConfigMap annotation"| Planner

    %% Components that integrate WITH the planner
    subgraph Consumers["Consumers (use Planner output)"]
        DataScientist["Data Scientist<br/>(Browser)"]
        MLOps["MLOps Engineer<br/>(CLI)"]
    end

    DataScientist -->|"HTTPS/443<br/>via Route"| Router
    MLOps -->|"CLI commands<br/>planner plan / estimate"| Planner

    %% Styles
    style Planner fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Ollama fill:#333,stroke:#666,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Grafana fill:#7ed321,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style BentoML fill:#f5a623,stroke:#333
    style Jinja2 fill:#f5a623,stroke:#333
    style Router fill:#326ce5,stroke:#333,color:#fff
    style ServiceCA fill:#326ce5,stroke:#333,color:#fff
    style DataScientist fill:#08427b,stroke:#333,color:#fff
    style MLOps fill:#08427b,stroke:#333,color:#fff
