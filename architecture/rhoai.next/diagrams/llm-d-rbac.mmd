graph TD
    subgraph ModelServerSA["Model Server ServiceAccounts"]
        ModelSA["Model Server SA<br/>(per-deployment)<br/>automountServiceAccountToken: false"]
    end

    subgraph EPPSA["EPP ServiceAccount (Helm-managed)"]
        EPPSA_node["EPP ServiceAccount<br/>(chart-defined)<br/>llm-d-inference-scheduler"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (Helm-managed)"]
        CRB["ClusterRoleBinding<br/>(chart-defined)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions (Helm-managed)"]
        CR["EPP ClusterRole<br/>(chart-defined)"]
    end

    subgraph APIResources["Kubernetes API Resources"]
        InferencePool["inference.networking.x-k8s.io<br/>InferencePool"]
        InferenceObjective["inference.networking.x-k8s.io<br/>InferenceObjective"]
        Pods["core ('')<br/>Pods"]
        Endpoints["core ('')<br/>Endpoints"]
    end

    subgraph Secrets["Secrets"]
        HFToken["hf-token<br/>Type: Opaque<br/>Purpose: HuggingFace API token<br/>Provisioned: Manual (user)<br/>Auto-Rotate: No"]
        WVAToken["controller-manager-token<br/>Type: Opaque<br/>Purpose: WVA metrics auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph SecurityContext["Security Context"]
        subgraph StandardPods["Standard Model Server Pods"]
            StandardSC["Non-root (configurable)<br/>Read-only FS (OpenShift)<br/>Drop ALL capabilities (OpenShift)<br/>automountServiceAccountToken: false"]
        end

        subgraph WideEPPods["Wide-EP LWS Pods"]
            ElevatedSC["ROOT (UID 0)<br/>Capabilities: IPC_LOCK, SYS_RAWIO<br/>Required for RDMA/NVSHMEM<br/>Security trade-off"]
        end
    end

    %% Bindings
    EPPSA_node -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Permissions
    CR -->|"get, list, watch"| InferencePool
    CR -->|"get, list, watch"| InferenceObjective
    CR -->|"get, list, watch"| Pods
    CR -->|"get, list, watch"| Endpoints

    %% Model server SA is minimal
    ModelSA -.->|"no API access<br/>(token not mounted)"| APIResources

    %% Secret usage
    ModelSA -.->|"mounts for<br/>model downloads"| HFToken
    EPPSA_node -.->|"optional<br/>WVA auth"| WVAToken

    %% Security context assignment
    ModelSA -.->|"applied to"| StandardSC
    ModelSA -.->|"applied to<br/>(wide-EP only)"| ElevatedSC

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef role fill:#f5a623,stroke:#d79b00,stroke-width:2px,color:#fff
    classDef resource fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    classDef secret fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef secure fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef elevated fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class ModelSA,EPPSA_node sa
    class CRB binding
    class CR role
    class InferencePool,InferenceObjective,Pods,Endpoints resource
    class HFToken,WVAToken secret
    class StandardSC secure
    class ElevatedSC elevated
