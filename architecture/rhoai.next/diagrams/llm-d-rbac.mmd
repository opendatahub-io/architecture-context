graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Interactive["interactive-pod<br/>(benchmark/debug pod)"]
        SA_ModelServer["model-server SA<br/>automountServiceAccountToken=false"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Interactive["interactive-pod-editor-binding<br/>Namespace: {guide-namespace}"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR_Interactive["interactive-pod-editor<br/>(VERY BROAD - debug/benchmark use)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/log"]
        Secrets["core<br/>secrets"]
        ConfigMaps["core<br/>configmaps"]
        Services["core<br/>services, endpoints"]
        ServiceAccounts["core<br/>serviceaccounts"]
        Events["core<br/>events, namespaces, logs"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>deployments"]
        StatefulSets["apps<br/>statefulsets"]
        ReplicaSets["apps<br/>replicasets"]
    end

    subgraph GatewayResources["Gateway API Resources"]
        Gateways["gateway.networking.k8s.io<br/>gateways"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        GatewayParams["gateway.kgateway.dev<br/>gatewayparameters"]
    end

    subgraph InferenceResources["Inference API Resources"]
        InferencePool["inference.networking.k8s.io<br/>* (all resources)"]
        LlmdAI["llm-d.ai<br/>* (all resources)"]
        KServe["serving.kserve.io<br/>* (all resources)"]
    end

    subgraph RBACResources["RBAC API Resources"]
        Roles["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        ClusterRolesRes["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings"]
    end

    subgraph DiscoveryResources["Discovery API Resources"]
        EndpointSlices["discovery.k8s.io<br/>endpointslices"]
    end

    subgraph OtherResources["Other API Resources"]
        LWS["*<br/>leaderworkersets"]
        Telemetry["telemetry.istio.io<br/>telemetries"]
        Monitoring["monitoring.coreos.com<br/>servicemonitors, podmonitors"]
    end

    %% Bindings
    SA_Interactive -->|"bound via"| CRB_Interactive
    CRB_Interactive -->|"grants"| CR_Interactive

    %% Permissions - Full CRUD
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Pods
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Secrets
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ConfigMaps
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Services
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Events
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Deployments
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| StatefulSets
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ReplicaSets
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Gateways
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| HTTPRoutes
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| GatewayParams
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| InferencePool
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| LlmdAI
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| KServe
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| LWS
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Telemetry
    CR_Interactive -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Monitoring

    %% Limited permissions
    CR_Interactive -->|"get,list,watch,<br/>create,update,patch<br/>(NO delete)"| Roles
    CR_Interactive -->|"get,list,watch,<br/>create,update,patch<br/>(NO delete)"| ClusterRolesRes
    CR_Interactive -->|"get,list,watch<br/>(READ-ONLY)"| EndpointSlices

    %% Model server SA (minimal)
    SA_ModelServer -.->|"no API access<br/>automountToken=false"| CoreResources

    %% Styling
    style SA_Interactive fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelServer fill:#95a5a6,stroke:#333,color:#fff
    style CRB_Interactive fill:#e67e22,stroke:#333,color:#fff
    style CR_Interactive fill:#e74c3c,stroke:#333,color:#fff

    style Pods fill:#7ed321,stroke:#333,color:#000
    style Secrets fill:#e74c3c,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style Events fill:#7ed321,stroke:#333,color:#000
    style Deployments fill:#7ed321,stroke:#333,color:#000
    style StatefulSets fill:#7ed321,stroke:#333,color:#000
    style ReplicaSets fill:#7ed321,stroke:#333,color:#000
    style Gateways fill:#3498db,stroke:#333,color:#fff
    style HTTPRoutes fill:#3498db,stroke:#333,color:#fff
    style GatewayParams fill:#3498db,stroke:#333,color:#fff
    style InferencePool fill:#9b59b6,stroke:#333,color:#fff
    style LlmdAI fill:#9b59b6,stroke:#333,color:#fff
    style KServe fill:#9b59b6,stroke:#333,color:#fff
    style Roles fill:#e74c3c,stroke:#333,color:#fff
    style ClusterRolesRes fill:#e74c3c,stroke:#333,color:#fff
    style EndpointSlices fill:#7ed321,stroke:#333,color:#000
    style LWS fill:#9b59b6,stroke:#333,color:#fff
    style Telemetry fill:#3498db,stroke:#333,color:#fff
    style Monitoring fill:#e67e22,stroke:#333,color:#fff
