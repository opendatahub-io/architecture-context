graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_ModelServer["sa<br/>(Model Server SA)<br/>Per-namespace"]
        SA_EPP["EPP ServiceAccount<br/>(Endpoint Picker)<br/>Scheduler namespace"]
    end

    subgraph InferencePoolScope["InferencePool Scope (Namespace-scoped)"]
        Pool["InferencePool CRD<br/>gateway.networking.k8s.io<br/>Namespace-scoped for<br/>security isolation"]
    end

    subgraph EPP_RBAC["EPP RBAC Requirements"]
        EPP_CR["EPP ClusterRole / Role"]
    end

    subgraph ModelServer_Resources["Model Server Pod Configuration"]
        PodSpec["Pod Spec<br/>uid: 2000 (non-root)<br/>user: vllm<br/>OpenShift compatible"]
    end

    subgraph K8s_API_Resources["Kubernetes API Resources"]
        Pods["core/v1<br/>Pods"]
        Services["core/v1<br/>Services"]
        Endpoints["core/v1<br/>Endpoints"]
        InferencePoolCRD["gateway.networking.k8s.io<br/>InferencePool"]
        GatewayCRD["gateway.networking.k8s.io/v1<br/>Gateway"]
        HTTPRouteCRD["gateway.networking.k8s.io/v1<br/>HTTPRoute"]
        LWS_CRD["leaderworkerset.x-k8s.io<br/>LeaderWorkerSet"]
        Deployments["apps/v1<br/>Deployments"]
    end

    subgraph EPP_Permissions["EPP Required Permissions"]
        WatchPods["watch, list Pods<br/>(endpoint discovery)"]
        WatchCRDs["watch, list InferencePool<br/>(pool configuration)"]
        ReadMetrics["get Prometheus endpoints<br/>(metrics polling)"]
    end

    subgraph Labels_Selectors["Labels & Selectors"]
        LabelInference["llm-d.ai/inference-serving: true<br/>(InferencePool selector)"]
        LabelRole["llm-d.ai/role:<br/>decode | prefill | prefill-decode"]
        LabelModel["llm-d.ai/model:<br/>(model name)"]
        LabelGuide["llm-d.ai/guide:<br/>(deployment guide)"]
        LabelAccel["llm-d.ai/accelerator-variant:<br/>gpu | cpu | hpu | xpu | tpu"]
        LabelVendor["llm-d.ai/accelerator-vendor:<br/>nvidia | amd | intel | google"]
    end

    subgraph ContainerSecurity["Container Security"]
        NonRoot["Non-root execution<br/>uid: 2000<br/>user: vllm"]
        MultiStage["Multi-stage builds<br/>Runtime image only<br/>Minimal attack surface"]
        TrivyScan["Trivy scanning<br/>CRITICAL/HIGH/MEDIUM<br/>SARIF → GitHub Security"]
        PinnedDeps["Pinned dependencies<br/>docker/common-versions<br/>Commit SHA for vLLM"]
    end

    subgraph CISecurityPolicies["CI/CD Security Policies"]
        DCO["DCO Sign-off<br/>Required on all commits"]
        ForkGate["Fork Gate<br/>Prevents unauthorized<br/>external PR builds"]
        SignedCommits["Signed Commits<br/>ci-signed-commits.yaml"]
    end

    %% Service Account bindings
    SA_ModelServer -->|"runs as"| PodSpec
    SA_ModelServer -->|"labeled with"| LabelInference
    SA_ModelServer -->|"labeled with"| LabelRole

    SA_EPP -->|"granted"| EPP_CR
    EPP_CR -->|"allows"| WatchPods
    EPP_CR -->|"allows"| WatchCRDs
    EPP_CR -->|"allows"| ReadMetrics

    WatchPods -->|"watches"| Pods
    WatchCRDs -->|"watches"| InferencePoolCRD
    ReadMetrics -->|"reads"| Services

    %% InferencePool scoping
    Pool -->|"selector"| LabelInference
    Pool -->|"discovers"| Pods
    Pool -->|"namespace-scoped<br/>isolation"| InferencePoolCRD

    %% Container security
    PodSpec --> NonRoot
    PodSpec --> MultiStage
    PodSpec --> PinnedDeps
    MultiStage --> TrivyScan

