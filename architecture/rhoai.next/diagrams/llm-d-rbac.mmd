graph TD
    subgraph "Service Account"
        SA["interactive-pod<br/>(development only)"]
    end

    subgraph "Role Binding"
        RB["interactive-pod-editor-binding<br/>Namespace: deployment namespace"]
    end

    subgraph "Namespace Role"
        K8sRole["interactive-pod-editor<br/>(namespace-scoped Role)"]
    end

    subgraph "Core API Resources"
        CoreRW["Core (read/write)<br/>pods, secrets, configmaps,<br/>services, endpoints,<br/>serviceaccounts, events,<br/>namespaces, logs, pods/log"]
    end

    subgraph "Apps API Resources"
        AppsRW["Apps (read/write)<br/>deployments, statefulsets,<br/>replicasets"]
    end

    subgraph "Gateway API Resources"
        GatewayRW["gateway.networking.k8s.io<br/>gateways, httproutes"]
    end

    subgraph "Inference API Resources"
        InferenceRW["inference.networking.k8s.io<br/>inference.networking.x-k8s.io<br/>serving.kserve.io<br/>* (all resources)"]
    end

    subgraph "Monitoring Resources"
        MonitoringRW["monitoring.coreos.com<br/>servicemonitors, podmonitors"]
    end

    subgraph "RBAC Resources"
        RBACPartial["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>(no delete)"]
    end

    subgraph "Discovery Resources"
        DiscoveryRO["discovery.k8s.io<br/>endpointslices<br/>(read-only)"]
    end

    subgraph "Other Resources"
        LWSRW["leaderworkersets<br/>(all verbs)"]
        KgatewayRW["gateway.kgateway.dev<br/>gatewayparameters"]
        IstioRW["telemetry.istio.io<br/>telemetries"]
    end

    subgraph "Production Security"
        ProdSA["Model Server ServiceAccount<br/>automountServiceAccountToken: false"]
        ProdUser["Container User<br/>UID: 2000, GID: 0<br/>(non-root, OpenShift-compatible)"]
        ProdNote["NOTE: No ClusterRoles<br/>in production deployments.<br/>Security layered by RHOAI platform."]
    end

    %% Bindings
    SA -->|"bound via"| RB
    RB -->|"grants"| K8sRole

    %% Role permissions
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| CoreRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| AppsRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| GatewayRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| InferenceRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| MonitoringRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch"| RBACPartial
    K8sRole -->|"get,list,watch"| DiscoveryRO
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| LWSRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| KgatewayRW
    K8sRole -->|"get,list,watch,create,<br/>update,patch,delete"| IstioRW

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#dae8fc,stroke:#6c8ebf
    style K8sRole fill:#f5a623,stroke:#333,color:#000

    style CoreRW fill:#7ed321,stroke:#333,color:#000
    style AppsRW fill:#7ed321,stroke:#333,color:#000
    style GatewayRW fill:#7ed321,stroke:#333,color:#000
    style InferenceRW fill:#7ed321,stroke:#333,color:#000
    style MonitoringRW fill:#7ed321,stroke:#333,color:#000
    style LWSRW fill:#7ed321,stroke:#333,color:#000
    style KgatewayRW fill:#7ed321,stroke:#333,color:#000
    style IstioRW fill:#7ed321,stroke:#333,color:#000

    style RBACPartial fill:#f9d71c,stroke:#333,color:#000
    style DiscoveryRO fill:#bdc3c7,stroke:#333,color:#000

    style ProdSA fill:#e8e8e8,stroke:#666
    style ProdUser fill:#e8e8e8,stroke:#666
    style ProdNote fill:#ffe6e6,stroke:#c0392b,color:#000
