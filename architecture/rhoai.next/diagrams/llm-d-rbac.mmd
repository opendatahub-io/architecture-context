graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_MS["sa<br/>(Model Server SA)<br/>Per-namespace"]
        SA_EPP["EPP ServiceAccount<br/>(Guide-specific)<br/>Per-namespace"]
    end

    subgraph Permissions_MS["Model Server Permissions"]
        direction TB
        MS_Access["Pod Runtime"]
        MS_Port8000["Serve: 8000/TCP<br/>vLLM OpenAI API"]
        MS_Port8200["Serve: 8200/TCP<br/>Decode (P/D disagg)"]
        MS_Port5600["NIXL: 5600/TCP<br/>KV Cache Transfer"]
        MS_Health["Health Probes<br/>GET /health<br/>GET /v1/models"]
        MS_Metrics["Prometheus Metrics<br/>9002/TCP"]
    end

    subgraph Permissions_EPP["EPP Permissions"]
        direction TB
        EPP_K8s["Kubernetes API Access"]
        EPP_Pods["Watch/List Pods<br/>(endpoint discovery)"]
        EPP_CRDs["Watch InferencePool CRD<br/>(gateway.networking.k8s.io)"]
        EPP_ExtProc["ext-proc gRPC Server<br/>(receives from proxy)"]
        EPP_Metrics["Prometheus Metrics<br/>9002/TCP, 9090/TCP"]
    end

    subgraph CRDs["Custom Resource Definitions"]
        InfPool["InferencePool<br/>gateway.networking.k8s.io<br/>Namespace-scoped"]
        GatewayCR["Gateway<br/>gateway.networking.k8s.io/v1<br/>Cluster-scoped"]
        HTTPRoute["HTTPRoute<br/>gateway.networking.k8s.io/v1<br/>Namespace-scoped"]
        LWS_CRD["LeaderWorkerSet<br/>(Wide EP only)<br/>Namespace-scoped"]
    end

    subgraph SecurityContext["Container Security Context"]
        NonRoot["Non-Root User<br/>uid: 2000 (vllm)<br/>OpenShift arbitrary UID"]
        ImageSec["Image Security<br/>Trivy scanning<br/>CRITICAL/HIGH/MEDIUM"]
        DCO["Code Signing<br/>DCO sign-off required<br/>Fork gate for PRs"]
    end

    subgraph NetworkAccess["Network Access Patterns"]
        direction TB
        IngressHTTP["Ingress: 80/TCP HTTP<br/>Gateway listener"]
        InternalHTTP["Internal: 8000/TCP<br/>Model server API"]
        InternalDecode["Internal: 8200/TCP<br/>Decode (disagg)"]
        RDMANet["RDMA: 5600/TCP<br/>NIXL KV transfer<br/>NVLink/RoCE/InfiniBand"]
        ZMQNet["ZMQ: 5556/TCP<br/>Prefix cache events<br/>(optional)"]
        MetricsNet["Metrics: 9002/9090 TCP<br/>Prometheus scrape"]
    end

    subgraph LabelSelectors["Label-Based Access Control"]
        LabelServing["llm-d.ai/inference-serving: true<br/>→ InferencePool membership"]
        LabelRole["llm-d.ai/role: decode|prefill<br/>→ Scheduling role assignment"]
        LabelModel["llm-d.ai/model: <name><br/>→ Model identification"]
        LabelGuide["llm-d.ai/guide: <name><br/>→ Guide tracking"]
    end

    %% SA relationships
    SA_MS -->|"runs as"| MS_Access
    MS_Access --> MS_Port8000
    MS_Access --> MS_Port8200
    MS_Access --> MS_Port5600
    MS_Access --> MS_Health
    MS_Access --> MS_Metrics

    SA_EPP -->|"runs as"| EPP_K8s
    EPP_K8s --> EPP_Pods
    EPP_K8s --> EPP_CRDs
    EPP_K8s --> EPP_ExtProc
    EPP_K8s --> EPP_Metrics

    %% CRD relationships
    EPP_CRDs -->|"watches"| InfPool
    InfPool -->|"selects pods via"| LabelServing
    InfPool -->|"references"| GatewayCR

    %% Security context
    SA_MS -->|"constrained by"| NonRoot
    SA_EPP -->|"constrained by"| NonRoot

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,color:#fff
    classDef perm fill:#27ae60,stroke:#333,color:#fff
    classDef crd fill:#f5a623,stroke:#333,color:#fff
    classDef security fill:#e74c3c,stroke:#333,color:#fff
    classDef network fill:#9b59b6,stroke:#333,color:#fff
    classDef label fill:#3498db,stroke:#333,color:#fff

    class SA_MS,SA_EPP sa
    class MS_Access,MS_Port8000,MS_Port8200,MS_Port5600,MS_Health,MS_Metrics perm
    class EPP_K8s,EPP_Pods,EPP_CRDs,EPP_ExtProc,EPP_Metrics perm
    class InfPool,GatewayCR,HTTPRoute,LWS_CRD crd
    class NonRoot,ImageSec,DCO security
    class IngressHTTP,InternalHTTP,InternalDecode,RDMANet,ZMQNet,MetricsNet network
    class LabelServing,LabelRole,LabelModel,LabelGuide label
