graph TD
    subgraph ProductionNote["Production Deployment"]
        direction TB
        ProdNote["llm-d does NOT install ClusterRoles<br/>in production deployments.<br/><br/>Security relies on:<br/>- Network-level isolation<br/>- Gateway-provider auth policies<br/>- Platform controls (RHOAI adds<br/>  kube-rbac-proxy, mTLS, etc.)<br/><br/>automountServiceAccountToken: false<br/>Non-root: UID 2000, GID 0"]
    end

    subgraph DevRBAC["Development / Interactive Pod RBAC"]
        direction TB

        subgraph ServiceAccounts["Service Account"]
            SA["interactive-pod<br/>(deployment namespace)"]
        end

        subgraph RoleBindings["RoleBinding"]
            RB["interactive-pod-editor-binding<br/>(namespace-scoped)"]
        end

        subgraph Roles["Role (namespace-scoped)"]
            Role["interactive-pod-editor"]
        end

        subgraph CoreAPI["Core API Resources"]
            Pods["core<br/>pods, pods/log"]
            Secrets["core<br/>secrets"]
            ConfigMaps["core<br/>configmaps"]
            Services["core<br/>services, endpoints"]
            SAs["core<br/>serviceaccounts"]
            Events["core<br/>events, namespaces, logs"]
        end

        subgraph AppsAPI["Apps API Resources"]
            Deployments["apps<br/>deployments"]
            StatefulSets["apps<br/>statefulsets"]
            ReplicaSets["apps<br/>replicasets"]
        end

        subgraph GatewayResources["Gateway API Resources"]
            Gateways["gateway.networking.k8s.io<br/>gateways"]
            HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
            GatewayParams["gateway.kgateway.dev<br/>gatewayparameters"]
        end

        subgraph InferenceResources["Inference Resources"]
            InferenceAll["inference.networking.k8s.io<br/>inference.networking.x-k8s.io<br/>serving.kserve.io<br/>(all resources)"]
            LWSRes["leaderworkerset.x-k8s.io<br/>leaderworkersets"]
        end

        subgraph MonitoringResources["Monitoring Resources"]
            ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
            PodMonitors["monitoring.coreos.com<br/>podmonitors"]
            Telemetries["telemetry.istio.io<br/>telemetries"]
        end

        subgraph RBACResources["RBAC Resources"]
            RBACRoles["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
            EndpointSlices["discovery.k8s.io<br/>endpointslices"]
        end
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| Role

    Role -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Pods
    Role -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Secrets
