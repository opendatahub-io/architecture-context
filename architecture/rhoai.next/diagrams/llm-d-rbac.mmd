graph TD
    subgraph "llm-d RBAC Model (Minimal by Design)"
        direction TB

        subgraph SA["Service Accounts"]
            ModelServerSA["Model Server SA<br/>(per-deployment)<br/>automountServiceAccountToken: false"]
        end

        subgraph SecurityContext["Container Security Context"]
            NonRoot["Non-root execution<br/>UID: 2000"]
            NoTokenMount["No API server token mounted<br/>(automountServiceAccountToken: false)"]
        end

        subgraph Secrets["Secrets"]
            HFSecret["hf-secret<br/>Type: Opaque<br/>Content: HuggingFace API token<br/>Provisioned: Manual (kubectl)<br/>Auto-Rotate: No"]
            SCCacheSecret["AWS sccache credentials<br/>Type: Docker build secret<br/>Content: S3 bucket access<br/>Provisioned: AWS IAM<br/>Scope: Build-time only"]
        end

        subgraph AuthDelegation["Authentication Delegation"]
            direction LR
            GatewayAuth["Gateway Layer<br/>Auth: Configurable per GatewayClass<br/>(Istio RequestAuthentication,<br/>GKE IAP, etc.)"]
            EPPAuth["EPP Layer<br/>RBAC: Managed in sibling repo<br/>(llm-d-inference-scheduler)"]
            GAIEAuth["GAIE Controller<br/>RBAC: Managed in sibling repo<br/>(Gateway API Inference Extension)"]
        end

        subgraph Endpoints["Endpoint Auth Matrix"]
            V1API["/v1/* endpoints<br/>Auth: None<br/>Enforcement: Gateway/EPP proxy"]
            HealthEP["/health endpoint<br/>Auth: None<br/>Purpose: Liveness probe"]
            MetricsEP["/metrics endpoint<br/>Auth: None<br/>Access: Cluster-internal<br/>Policy: NetworkPolicy (if configured)"]
        end

        ModelServerSA --- NonRoot
        ModelServerSA --- NoTokenMount
        ModelServerSA -->|"mounts"| HFSecret

        GatewayAuth -->|"protects"| V1API
        EPPAuth -->|"routes"| V1API
    end

    subgraph RHOAIGaps["RHOAI Distribution Gaps"]
        NoKubeRBAC["No kube-rbac-proxy sidecar<br/>(other RHOAI components use this)"]
        NoAIPCC["No AIPCC base images<br/>(required for product security)"]
        NoKonflux["No Konflux Dockerfiles<br/>(required for hermetic builds)"]
        NoLockFiles["No comprehensive lock files<br/>(partial constraints.txt only)"]
    end

    %% Styling
    style ModelServerSA fill:#4a90e2,stroke:#333,color:#fff
    style NonRoot fill:#27ae60,stroke:#333,color:#fff
    style NoTokenMount fill:#27ae60,stroke:#333,color:#fff
    style HFSecret fill:#f39c12,stroke:#333,color:#fff
    style SCCacheSecret fill:#f39c12,stroke:#333,color:#fff
    style GatewayAuth fill:#3498db,stroke:#333,color:#fff
    style EPPAuth fill:#3498db,stroke:#333,color:#fff
    style GAIEAuth fill:#3498db,stroke:#333,color:#fff
    style V1API fill:#95a5a6,stroke:#333,color:#fff
    style HealthEP fill:#95a5a6,stroke:#333,color:#fff
    style MetricsEP fill:#95a5a6,stroke:#333,color:#fff
    style NoKubeRBAC fill:#e74c3c,stroke:#333,color:#fff
    style NoAIPCC fill:#e74c3c,stroke:#333,color:#fff
    style NoKonflux fill:#e74c3c,stroke:#333,color:#fff
    style NoLockFiles fill:#e74c3c,stroke:#333,color:#fff
