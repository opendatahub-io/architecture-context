graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        RegexDetector["regex-detector<br/>(Rust / Axum 0.7.9)<br/>Port 8080/TCP"]

        subgraph "Built-in Detectors"
            EmailDetector["Email Detector<br/>RFC 5322 regex"]
            SSNDetector["SSN Detector<br/>XXX-XX-XXXX regex"]
            CreditCardDetector["Credit Card Detector<br/>Luhn-pattern regex"]
        end

        subgraph "Custom Detection"
            CustomRegex["Custom Regex Engine<br/>On-the-fly compilation<br/>User-supplied patterns"]
        end

        RegexDetector --> EmailDetector
        RegexDetector --> SSNDetector
        RegexDetector --> CreditCardDetector
        RegexDetector --> CustomRegex
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>8080/TCP HTTP"| RegexDetector

    K8s["Kubernetes"] -->|"GET /health<br/>8080/TCP HTTP"| RegexDetector

    RegexDetector -->|"Detection Results<br/>JSON [[...]]"| Orchestrator

    style RegexDetector fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style EmailDetector fill:#50c878,stroke:#333,color:#fff
    style SSNDetector fill:#50c878,stroke:#333,color:#fff
    style CreditCardDetector fill:#50c878,stroke:#333,color:#fff
    style CustomRegex fill:#f5a623,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style K8s fill:#e8e8e8,stroke:#333
