graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        Main["main.rs<br/>Axum Router & TCP Listener"]
        Detectors["detectors.rs<br/>Detection Logic"]
        BuiltinRegistry["Built-in Pattern Registry<br/>(HashMap)"]
        RegexMatch["regex_match()<br/>Pattern Matching Engine"]

        Main -->|routes requests to| Detectors
        Detectors -->|looks up| BuiltinRegistry
        Detectors -->|delegates to| RegexMatch
    end

    subgraph "Built-in PII Patterns"
        Email["email<br/>Email Address Detection"]
        SSN["ssn<br/>Social Security Number"]
        CreditCard["credit-card<br/>Credit Card Number"]
    end

    BuiltinRegistry --- Email
    BuiltinRegistry --- SSN
    BuiltinRegistry --- CreditCard

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP HTTP| Main
    HealthCheck["Health Probes"] -->|GET /health<br/>8080/TCP HTTP| Main

    Orchestrator -.->|"Custom regex patterns<br/>(compiled per-request)"| Detectors

    style Main fill:#4a90e2,stroke:#333,color:#fff
    style Detectors fill:#4a90e2,stroke:#333,color:#fff
    style BuiltinRegistry fill:#f5a623,stroke:#333,color:#fff
    style RegexMatch fill:#4a90e2,stroke:#333,color:#fff
    style Email fill:#7ed321,stroke:#333,color:#fff
    style SSN fill:#7ed321,stroke:#333,color:#fff
    style CreditCard fill:#7ed321,stroke:#333,color:#fff
    style Orchestrator fill:#e8e8e8,stroke:#333
    style HealthCheck fill:#e8e8e8,stroke:#333
