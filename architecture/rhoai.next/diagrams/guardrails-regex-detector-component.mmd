graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        Server["Axum HTTP Server<br/>0.0.0.0:8080"]
        HealthEP["/health<br/>GET"]
        DetectEP["/api/v1/text/contents<br/>POST"]

        subgraph "Built-in Detectors"
            EmailDet["Email Detector<br/>RFC 5322 regex"]
            SSNDet["SSN Detector<br/>###-##-#### regex"]
            CCDet["Credit Card Detector<br/>Luhn-pattern regex"]
        end

        CustomRegex["Custom Regex Engine<br/>Arbitrary patterns via detector_params"]

        Server --> HealthEP
        Server --> DetectEP
        DetectEP --> EmailDet
        DetectEP --> SSNDet
        DetectEP --> CCDet
        DetectEP --> CustomRegex
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| Server

    Server -->|"DetectionResponse<br/>(start, end, text, type, score)"| Orchestrator

    subgraph "Runtime"
        Tokio["Tokio Async Runtime<br/>Multi-threaded"]
        Tracing["tower-http Tracing<br/>Request Logging"]
    end

    Server -.->|"runs on"| Tokio
    Server -.->|"middleware"| Tracing

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style HealthEP fill:#7ed321,stroke:#333
    style DetectEP fill:#7ed321,stroke:#333
    style EmailDet fill:#f5a623,stroke:#333
    style SSNDet fill:#f5a623,stroke:#333
    style CCDet fill:#f5a623,stroke:#333
    style CustomRegex fill:#f5a623,stroke:#333
    style Orchestrator fill:#e8e8e8,stroke:#333
    style Tokio fill:#d5e8d4,stroke:#82b366
    style Tracing fill:#d5e8d4,stroke:#82b366
