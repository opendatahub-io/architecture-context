graph TB
    subgraph "Guardrails Regex Detector Service"
        direction TB
        Main["main.rs<br/>Axum Router & TCP Listener"]
        Detectors["detectors.rs<br/>Detection Engine"]
        BuiltinRegistry["Builtin Regex Registry<br/>(HashMap)"]

        Main -->|routes requests to| Detectors
        Detectors -->|looks up| BuiltinRegistry
    end

    subgraph "Builtin PII Patterns"
        Email["email<br/>Email Address Detection"]
        SSN["ssn<br/>Social Security Number"]
        CreditCard["credit-card<br/>Credit Card Number"]
    end

    BuiltinRegistry --- Email
    BuiltinRegistry --- SSN
    BuiltinRegistry --- CreditCard

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP HTTP| Main
    HealthCheck["Health Probe"] -->|GET /health<br/>8080/TCP HTTP| Main

    Main -->|"RegexDetection results<br/>(detection_type: pii | custom)"| Orchestrator

    style Main fill:#4a90e2,stroke:#333,color:#fff
    style Detectors fill:#4a90e2,stroke:#333,color:#fff
    style BuiltinRegistry fill:#4a90e2,stroke:#333,color:#fff
    style Email fill:#7ed321,stroke:#333
    style SSN fill:#7ed321,stroke:#333
    style CreditCard fill:#7ed321,stroke:#333
    style Orchestrator fill:#f5a623,stroke:#333,color:#fff
    style HealthCheck fill:#e8e8e8,stroke:#333
