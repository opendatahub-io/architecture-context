graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>ServiceAccount<br/>Namespace: ${pool-namespace}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Metrics["epp-metrics-auth<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_PodReader["epp-pod-reader<br/>(RoleBinding)<br/>Namespace: pool namespace"]
        RB_InferenceCR["epp-inference-cr-reader<br/>(RoleBinding)<br/>Namespace: pool namespace"]
        RB_LeaderElection["epp-leader-election<br/>(RoleBinding)<br/>Namespace: pool namespace"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Metrics["epp-metrics-auth<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_PodReader["pod-reader<br/>(Role)"]
        R_InferenceCR["inference-cr-reader<br/>(Role)"]
        R_LeaderElection["leader-election<br/>(Role)"]
    end

    subgraph ClusterResources["ClusterRole Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
        MetricsNonResource["/metrics<br/>(non-resource URL)<br/><i>get</i>"]
    end

    subgraph NamespacedResources["Role Resources (inferred)"]
        Pods["core<br/>pods<br/><i>get, list, watch</i>"]
        InferencePoolRes["inference.networking.x-k8s.io<br/>inferencepools<br/><i>get, list, watch</i>"]
        InferenceObjRes["llm-d.ai<br/>inferenceobjectives<br/><i>get, list, watch</i>"]
        InferenceRewriteRes["llm-d.ai<br/>inferencemodelrewrites<br/><i>get, list, watch</i>"]
        Leases["coordination.k8s.io<br/>leases<br/><i>get, create, update</i>"]
        Events["core<br/>events<br/><i>create, patch</i>"]
    end

    %% ServiceAccount to Bindings
    SA_EPP -->|"bound via"| CRB_Metrics
    SA_EPP -->|"bound via"| RB_PodReader
    SA_EPP -->|"bound via"| RB_InferenceCR
    SA_EPP -->|"bound via"| RB_LeaderElection

    %% Bindings to Roles
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_PodReader -->|"grants"| R_PodReader
    RB_InferenceCR -->|"grants"| R_InferenceCR
    RB_LeaderElection -->|"grants"| R_LeaderElection

    %% ClusterRole to Resources
    CR_Metrics -->|"create"| TokenReviews
    CR_Metrics -->|"create"| SubjectAccessReviews
    CR_Metrics -->|"get"| MetricsNonResource

    %% Roles to Resources
    R_PodReader -->|"get, list, watch"| Pods
    R_InferenceCR -->|"get, list, watch"| InferencePoolRes
    R_InferenceCR -->|"get, list, watch"| InferenceObjRes
    R_InferenceCR -->|"get, list, watch"| InferenceRewriteRes
    R_LeaderElection -->|"get, create, update"| Leases
    R_LeaderElection -->|"create, patch"| Events

    %% Secrets
    subgraph Secrets["Secrets"]
        TLSSecret["TLS cert/key<br/>(kubernetes.io/tls)<br/>Self-signed or mounted<br/>File watcher auto-reload"]
        MetricsSecret["inference-gateway-sa-<br/>metrics-reader-secret<br/>(kubernetes.io/service-account-token)<br/>Helm provisioned"]
    end

    SA_EPP -.->|"mounts"| TLSSecret
    SA_EPP -.->|"uses"| MetricsSecret

    %% Styling
    style SA_EPP fill:#4a90e2,color:#fff
    style CR_Metrics fill:#f5a623,color:#fff
    style R_PodReader fill:#f5a623,color:#fff
    style R_InferenceCR fill:#f5a623,color:#fff
    style R_LeaderElection fill:#f5a623,color:#fff
    style CRB_Metrics fill:#e8e8e8
    style RB_PodReader fill:#e8e8e8
    style RB_InferenceCR fill:#e8e8e8
    style RB_LeaderElection fill:#e8e8e8
    style TokenReviews fill:#7ed321,color:#fff
    style SubjectAccessReviews fill:#7ed321,color:#fff
    style MetricsNonResource fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style InferencePoolRes fill:#7ed321,color:#fff
    style InferenceObjRes fill:#7ed321,color:#fff
    style InferenceRewriteRes fill:#7ed321,color:#fff
    style Leases fill:#7ed321,color:#fff
    style Events fill:#7ed321,color:#fff
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style MetricsSecret fill:#f8cecc,stroke:#b85450
