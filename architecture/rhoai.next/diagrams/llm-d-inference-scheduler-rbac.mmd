graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["${EPP_NAME}-binding"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["${EPP_NAME}"]
    end

    subgraph GIE_Resources["inference.networking.x-k8s.io"]
        InferencePoolXK8s["InferencePool<br/>(x-k8s.io)"]
        InferenceObjective["InferenceObjective"]
        InferenceModelRewrite["InferenceModelRewrite"]
    end

    subgraph GIE_GA_Resources["inference.networking.k8s.io"]
        InferencePoolGA["InferencePool<br/>(k8s.io GA)"]
    end

    subgraph CoreResources["Core API ('')"]
        Pods["Pods"]
    end

    subgraph AuthResources["authentication.k8s.io"]
        TokenReviews["TokenReviews"]
    end

    subgraph AuthzResources["authorization.k8s.io"]
        SAR["SubjectAccessReviews"]
    end

    %% Binding chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% GIE x-k8s.io permissions
    CR -->|"get, watch, list"| InferencePoolXK8s
    CR -->|"get, watch, list"| InferenceObjective
    CR -->|"get, watch, list"| InferenceModelRewrite

    %% GIE GA permissions
    CR -->|"get, watch, list"| InferencePoolGA

    %% Core permissions
    CR -->|"get, watch, list"| Pods

    %% Auth permissions (for metrics endpoint protection)
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style InferencePoolXK8s fill:#7ed321,stroke:#333
    style InferenceObjective fill:#7ed321,stroke:#333
    style InferenceModelRewrite fill:#7ed321,stroke:#333
    style InferencePoolGA fill:#7ed321,stroke:#333
    style Pods fill:#3498db,stroke:#333,color:#fff
    style TokenReviews fill:#e74c3c,stroke:#333,color:#fff
    style SAR fill:#e74c3c,stroke:#333,color:#fff
