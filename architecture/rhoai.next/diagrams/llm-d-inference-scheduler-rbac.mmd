graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["ServiceAccount<br/>${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["RoleBinding<br/>${EPP_NAME}-binding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role_EPP["Role<br/>${EPP_NAME}"]
    end

    subgraph APIResources["API Resources"]
        subgraph GIE_Resources["inference.networking.x-k8s.io"]
            InferencePool["InferencePool"]
            InferenceObjective["InferenceObjective"]
            InferenceModelRewrite["InferenceModelRewrite"]
        end

        subgraph Legacy_Resources["inference.networking.k8s.io"]
            InferencePoolLegacy["InferencePool<br/>(legacy API group)"]
        end

        subgraph Core_Resources["core ('')"]
            Pods["Pods"]
        end

        subgraph Auth_Resources["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph Authz_Resources["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    subgraph SecurityFeatures["Security Features"]
        MetricsAuth["Metrics Endpoint Auth<br/>(--metrics-endpoint-auth flag)<br/>Uses TokenReview + SAR"]
        SSRFProtection["SSRF Allowlist<br/>(Sidecar)<br/>Validates targets against<br/>InferencePool pod list"]
        TLSCerts["TLS Certificates<br/>ext_proc: manual/cert-manager<br/>Sidecar: self-signed/manual<br/>fsnotify reload (250ms debounce)"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB
    RB -->|"grants"| Role_EPP

    %% GIE API permissions
    Role_EPP -->|"get, watch, list"| InferencePool
    Role_EPP -->|"get, watch, list"| InferenceObjective
    Role_EPP -->|"get, watch, list"| InferenceModelRewrite

    %% Legacy API permissions
    Role_EPP -->|"get, watch, list"| InferencePoolLegacy

    %% Core permissions
    Role_EPP -->|"get, watch, list"| Pods

    %% Auth permissions (for metrics auth)
    Role_EPP -->|"create"| TokenReviews
    Role_EPP -->|"create"| SubjectAccessReviews

    %% Security feature connections
    TokenReviews -.->|"used by"| MetricsAuth
    SubjectAccessReviews -.->|"used by"| MetricsAuth
    InferencePool -.->|"pod selector for"| SSRFProtection

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#6c5ce7,stroke:#333,color:#fff
    style Role_EPP fill:#f5a623,stroke:#333,color:#fff

    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style InferenceObjective fill:#7ed321,stroke:#333,color:#fff
    style InferenceModelRewrite fill:#7ed321,stroke:#333,color:#fff
    style InferencePoolLegacy fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style TokenReviews fill:#e17055,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e17055,stroke:#333,color:#fff

    style MetricsAuth fill:#fdcb6e,stroke:#333
    style SSRFProtection fill:#fdcb6e,stroke:#333
    style TLSCerts fill:#fdcb6e,stroke:#333
