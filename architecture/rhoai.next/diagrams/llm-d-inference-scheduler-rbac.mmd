graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["${EPP_NAME}-binding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["${EPP_NAME}"]
    end

    subgraph APIResources["API Resources"]
        subgraph GIE_Resources["inference.networking.x-k8s.io"]
            InferencePool_X["InferencePool<br/>(x-k8s.io)"]
            InferenceObjective["InferenceObjective"]
            InferenceModelRewrite["InferenceModelRewrite"]
        end

        subgraph GIE_GA_Resources["inference.networking.k8s.io"]
            InferencePool_GA["InferencePool<br/>(k8s.io GA)"]
        end

        subgraph Core_Resources["core ('')"]
            Pods["Pods"]
        end

        subgraph Auth_Resources["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph Authz_Resources["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    subgraph AuthEndpoints["Authentication Enforcement"]
        MetricsEndpoint["/metrics endpoint<br/>9090/TCP<br/>--metrics-endpoint-auth=true"]
        SSRFEndpoint["PD Sidecar endpoints<br/>/v1/chat/completions<br/>--enable-ssrf-protection=true"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Read permissions
    CR -->|"get, watch, list"| InferencePool_X
    CR -->|"get, watch, list"| InferenceObjective
    CR -->|"get, watch, list"| InferenceModelRewrite
    CR -->|"get, watch, list"| InferencePool_GA
    CR -->|"get, watch, list"| Pods

    %% Write permissions (for auth delegation)
    CR -->|"create"| TokenReviews
    CR -->|"create"| SubjectAccessReviews

    %% Auth flow
    TokenReviews -.->|"validates bearer<br/>tokens for"| MetricsEndpoint
    SubjectAccessReviews -.->|"checks RBAC<br/>permissions for"| MetricsEndpoint

    %% SSRF protection
    InferencePool_X -.->|"pod IPs used as<br/>SSRF allowlist for"| SSRFEndpoint
    InferencePool_GA -.->|"pod IPs used as<br/>SSRF allowlist for"| SSRFEndpoint

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#e8a838,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff

    style InferencePool_X fill:#7ed321,stroke:#333
    style InferenceObjective fill:#7ed321,stroke:#333
    style InferenceModelRewrite fill:#7ed321,stroke:#333
    style InferencePool_GA fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333

    style TokenReviews fill:#ff6b6b,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#ff6b6b,stroke:#333,color:#fff

    style MetricsEndpoint fill:#dae8fc,stroke:#6c8ebf
    style SSRFEndpoint fill:#dae8fc,stroke:#6c8ebf
