graph TD
    subgraph "Service Account"
        SA["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "ClusterRole Binding"
        CRB["${EPP_NAME}-binding"]
    end

    subgraph "ClusterRole: ${EPP_NAME}"
        CR["${EPP_NAME}"]
    end

    subgraph "API Resources - GIE (x-k8s.io)"
        InferencePoolXK8s["inference.networking.x-k8s.io<br/>InferencePool"]
        InferenceObjective["inference.networking.x-k8s.io<br/>InferenceObjective"]
        InferenceModelRewrite["inference.networking.x-k8s.io<br/>InferenceModelRewrite"]
    end

    subgraph "API Resources - GIE (k8s.io)"
        InferencePoolK8s["inference.networking.k8s.io<br/>InferencePool"]
    end

    subgraph "API Resources - Core"
        Pods["core ('')<br/>Pods"]
    end

    subgraph "API Resources - Auth"
        TokenReviews["authentication.k8s.io<br/>TokenReview"]
        SubjectAccessReviews["authorization.k8s.io<br/>SubjectAccessReview"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    CR -->|"get, watch, list"| InferencePoolXK8s
    CR -->|"get, watch, list"| InferenceObjective
    CR -->|"get, watch, list"| InferenceModelRewrite
    CR -->|"get, watch, list"| InferencePoolK8s
    CR -->|"get, watch, list"| Pods
    CR -->|"create"| TokenReviews
    CR -->|"create"| SubjectAccessReviews

    subgraph "Authentication Endpoints"
        MetricsAuth["EPP /metrics (9090/TCP)<br/>TokenReview + SubjectAccessReview<br/>when --metrics-endpoint-auth=true"]
        SSRFAuth["PD Sidecar /v1/* (8000/TCP)<br/>SSRF allowlist (InferencePool pod IPs)<br/>when --enable-ssrf-protection=true"]
        ExtProcAuth["EPP ext-proc (9002/TCP)<br/>No auth (Envoy-internal trust)"]
        HealthAuth["EPP Health (9003/TCP)<br/>No auth (open)"]
    end

    SA -.->|"validates requests"| MetricsAuth
    SA -.->|"watches pod list"| SSRFAuth

    style SA fill:#4a90e2,color:#fff
    style CRB fill:#9b59b6,color:#fff
    style CR fill:#f5a623,color:#fff
    style InferencePoolXK8s fill:#7ed321,color:#fff
    style InferenceObjective fill:#7ed321,color:#fff
    style InferenceModelRewrite fill:#7ed321,color:#fff
    style InferencePoolK8s fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style TokenReviews fill:#e74c3c,color:#fff
    style SubjectAccessReviews fill:#e74c3c,color:#fff
    style MetricsAuth fill:#dae8fc,stroke:#6c8ebf
    style SSRFAuth fill:#dae8fc,stroke:#6c8ebf
    style ExtProcAuth fill:#f8cecc,stroke:#b85450
    style HealthAuth fill:#f8cecc,stroke:#b85450
