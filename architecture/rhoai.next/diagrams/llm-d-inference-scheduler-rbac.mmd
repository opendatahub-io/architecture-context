graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>Namespace: pool-namespace"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["${EPP_NAME}-binding<br/>Namespace: pool-namespace"]
    end

    subgraph NamespacedRole["Namespace-Scoped Role: ${EPP_NAME}"]
        Role_EPP["${EPP_NAME}<br/>(Role)"]
    end

    subgraph ClusterRoles["Cluster-Scoped Roles (Helm)"]
        CR_Auth["Cluster RBAC<br/>(ClusterRole)"]
    end

    subgraph API_GIE_xk8s["API Group: inference.networking.x-k8s.io"]
        InferencePoolsX["inferencepools"]
        InferenceObjectivesX["inferenceobjectives"]
        InferenceModelRewritesX["inferencemodelrewrites"]
    end

    subgraph API_GIE_k8s["API Group: inference.networking.k8s.io"]
        InferencePoolsK["inferencepools"]
    end

    subgraph API_LLMd["API Group: llm-d.ai"]
        InferenceObjectivesL["inferenceobjectives"]
        InferenceModelRewritesL["inferencemodelrewrites"]
    end

    subgraph API_Core["API Group: core"]
        Pods["pods"]
    end

    subgraph API_AuthN["API Group: authentication.k8s.io"]
        TokenReviews["tokenreviews"]
    end

    subgraph API_AuthZ["API Group: authorization.k8s.io"]
        SubjectAccessReviews["subjectaccessreviews"]
    end

    subgraph API_NonResource["Non-Resource URLs"]
        MetricsURL["/metrics"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB_EPP
    RB_EPP -->|"grants"| Role_EPP

    %% Role permissions
    Role_EPP -->|"get, watch, list"| InferencePoolsX
    Role_EPP -->|"get, watch, list"| InferenceObjectivesX
    Role_EPP -->|"get, watch, list"| InferenceModelRewritesX
    Role_EPP -->|"get, watch, list"| InferencePoolsK
    Role_EPP -->|"get, watch, list"| InferenceObjectivesL
    Role_EPP -->|"get, watch, list"| InferenceModelRewritesL
    Role_EPP -->|"get, watch, list"| Pods
    Role_EPP -->|"create"| TokenReviews
    Role_EPP -->|"create"| SubjectAccessReviews

    %% ClusterRole permissions
    CR_Auth -->|"create"| TokenReviews
    CR_Auth -->|"create"| SubjectAccessReviews
    CR_Auth -->|"get"| MetricsURL

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#8e44ad,stroke:#333,stroke-width:1px,color:#fff
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    classDef clusterrole fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#27ae60,stroke:#333,stroke-width:1px,color:#fff
    classDef authresource fill:#e74c3c,stroke:#333,stroke-width:1px,color:#fff
    classDef nonresource fill:#95a5a6,stroke:#333,stroke-width:1px,color:#fff

    class SA_EPP sa
    class RB_EPP binding
    class Role_EPP role
    class CR_Auth clusterrole
    class InferencePoolsX,InferenceObjectivesX,InferenceModelRewritesX,InferencePoolsK,InferenceObjectivesL,InferenceModelRewritesL,Pods resource
    class TokenReviews,SubjectAccessReviews authresource
    class MetricsURL nonresource
