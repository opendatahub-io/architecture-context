graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>ServiceAccount<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["${EPP_NAME}-binding<br/>RoleBinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role["${EPP_NAME}<br/>Role"]
    end

    subgraph APIResources["API Resources"]
        subgraph GIE_x_k8s["inference.networking.x-k8s.io"]
            InferencePool_xk8s["InferencePool"]
            InferenceObjective["InferenceObjective"]
            InferenceModelRewrite["InferenceModelRewrite"]
        end

        subgraph GIE_k8s["inference.networking.k8s.io"]
            InferencePool_k8s["InferencePool"]
        end

        subgraph Core["core ('')"]
            Pods["Pods"]
        end

        subgraph AuthN["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph AuthZ["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB
    RB -->|"grants"| Role

    %% Permissions
    Role -->|"get, watch, list"| InferencePool_xk8s
    Role -->|"get, watch, list"| InferenceObjective
    Role -->|"get, watch, list"| InferenceModelRewrite
    Role -->|"get, watch, list"| InferencePool_k8s
    Role -->|"get, watch, list"| Pods
    Role -->|"create"| TokenReviews
    Role -->|"create"| SubjectAccessReviews

    %% Purpose annotations
    InferencePool_xk8s -.-|"Pod selector &<br/>target port config"| PurposePool["Endpoint Discovery"]
    InferenceObjective -.-|"Priority & SLO<br/>parameters"| PurposeObj["Admission Control"]
    InferenceModelRewrite -.-|"Model aliasing &<br/>weighted routing"| PurposeRewrite["Request Routing"]
    Pods -.-|"Endpoint inventory<br/>matching pool selector"| PurposePods["Pod Tracking"]
    TokenReviews -.-|"Validate bearer tokens<br/>on /metrics endpoint"| PurposeAuth["Metrics Auth"]
    SubjectAccessReviews -.-|"Check subject permissions<br/>on /metrics endpoint"| PurposeSAR["Metrics AuthZ"]

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style InferencePool_xk8s fill:#7ed321,stroke:#333,color:#fff
    style InferenceObjective fill:#7ed321,stroke:#333,color:#fff
    style InferenceModelRewrite fill:#7ed321,stroke:#333,color:#fff
    style InferencePool_k8s fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style TokenReviews fill:#e74c3c,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e74c3c,stroke:#333,color:#fff
    style PurposePool fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
    style PurposeObj fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
    style PurposeRewrite fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
    style PurposePods fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
    style PurposeAuth fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
    style PurposeSAR fill:#f0f0f0,stroke:#ccc,stroke-dasharray:5 5
