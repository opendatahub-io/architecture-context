graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["${EPP_NAME}-binding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role["${EPP_NAME}<br/>(Role - namespace-scoped)"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph GIE_x_k8s["inference.networking.x-k8s.io"]
            InferencePool_x["InferencePool"]
            InferenceObjective["InferenceObjective"]
            InferenceModelRewrite["InferenceModelRewrite"]
        end

        subgraph GIE_k8s["inference.networking.k8s.io"]
            InferencePool_k["InferencePool"]
        end

        subgraph Core["core ('')"]
            Pods["Pods"]
        end

        subgraph AuthN["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph AuthZ["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB
    RB -->|"grants"| Role

    %% Permissions - Read-only resources
    Role -->|"get, watch, list"| InferencePool_x
    Role -->|"get, watch, list"| InferenceObjective
    Role -->|"get, watch, list"| InferenceModelRewrite
    Role -->|"get, watch, list"| InferencePool_k
    Role -->|"get, watch, list"| Pods

    %% Permissions - Auth resources (create only)
    Role -->|"create"| TokenReviews
    Role -->|"create"| SubjectAccessReviews

    %% Authentication & Authorization endpoints
    subgraph AuthEndpoints["Authentication & Authorization Endpoints"]
        MetricsAuth["/metrics endpoint<br/>Optional TokenReview + SAR<br/>(--metrics-endpoint-auth flag)"]
        ExtProcAuth["ext_proc gRPC<br/>No auth<br/>(Envoy-internal, network isolation)"]
        SidecarAuth["/v1/* (Sidecar)<br/>No auth<br/>SSRF allowlist via InferencePool"]
    end

    TokenReviews -.->|"validates tokens for"| MetricsAuth
    SubjectAccessReviews -.->|"checks access for"| MetricsAuth

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333

    style InferencePool_x fill:#7ed321,stroke:#333
    style InferenceObjective fill:#7ed321,stroke:#333
    style InferenceModelRewrite fill:#7ed321,stroke:#333
    style InferencePool_k fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style TokenReviews fill:#e74c3c,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e74c3c,stroke:#333,color:#fff

    style MetricsAuth fill:#f8cecc,stroke:#b85450
    style ExtProcAuth fill:#d5e8d4,stroke:#82b366
    style SidecarAuth fill:#fff2cc,stroke:#d6b656
