graph TB
    subgraph CaikitRuntime["Caikit Runtime"]
        direction TB

        subgraph Servers["Dual-Protocol Servers"]
            GRPCServer["gRPC Server<br/>8085/TCP<br/>Optional TLS/mTLS"]
            HTTPServer["HTTP Server (FastAPI/Uvicorn)<br/>8080/TCP<br/>Optional TLS/mTLS"]
            MetricsServer["Prometheus Metrics<br/>8086/TCP<br/>HTTP"]
        end

        subgraph Servicers["Servicer Layer (Shared)"]
            GlobalPredictServicer["GlobalPredictServicer<br/>Task-specific inference"]
            GlobalTrainServicer["GlobalTrainServicer<br/>Model training"]
            InfoServicer["InfoServicer<br/>Runtime & model info"]
            ModelMgmtServicer["ModelManagementServicer<br/>Deploy/undeploy"]
            TrainingMgmtServicer["TrainingManagementServicer<br/>Training status"]
            ModelRuntimeServicer["ModelRuntimeServicer<br/>ModelMesh sidecar API"]
        end

        subgraph ModelMgmt["Model Management"]
            ModelManager["ModelManager<br/>Model lifecycle"]
            Batcher["Batcher<br/>Request batching"]
            ModelLoader["CoreModelLoader<br/>Model loading"]
            ModelSizer["ModelSizer<br/>Model sizing"]
        end

        subgraph PluginSystem["Plugin System (Factories)"]
            Finders["Model Finders<br/>(Local, Remote, Multi)"]
            Initializers["Model Initializers<br/>(Local, Remote, Multi)"]
            Trainers["Model Trainers<br/>(Local)"]
        end

        ThreadPool["Shared Thread Pool"]
    end

    subgraph CaikitCore["Caikit Core"]
        direction TB

        subgraph TaskModule["Task/Module Framework"]
            TaskBase["TaskBase<br/>@task decorator"]
            ModuleBase["ModuleBase<br/>@module decorator"]
            Registries["Module & Task Registries"]
        end

        subgraph DataModel["Data Model Framework"]
            DataBase["DataBase Metaclass<br/>Proto generation"]
            DataObject["@dataobject Decorator<br/>Dataclass-backed models"]
            Backends["Backends<br/>(Pandas, PySpark, PIL)"]
        end

        subgraph ServiceGen["Service Generation"]
            ServiceFactory["ServiceFactory<br/>Auto-generates gRPC/HTTP"]
            PyToProto["py-to-proto<br/>Python → Protobuf"]
        end

        CoreModelManager["Core ModelManager<br/>Pluggable model management"]
    end

    subgraph CaikitInterfaces["Caikit Interfaces"]
        NLP["NLP<br/>Classification, TextGen,<br/>Embedding, Reranking"]
        TimeSeries["Time Series<br/>Forecasting, Evaluation"]
        Vision["Vision<br/>Image processing"]
        Common["Common<br/>Vectors, Streams, Files"]
    end

    HealthProbe["caikit_health_probe<br/>CLI Utility<br/>gRPC & HTTP probing"]

    %% Server to Servicer connections
    GRPCServer -->|routes RPCs| GlobalPredictServicer
    GRPCServer -->|routes RPCs| GlobalTrainServicer
    GRPCServer -->|routes RPCs| InfoServicer
    GRPCServer -->|routes RPCs| ModelMgmtServicer
    HTTPServer -->|translates HTTP| GlobalPredictServicer
    HTTPServer -->|translates HTTP| GlobalTrainServicer
    HTTPServer -->|translates HTTP| InfoServicer

    %% Servicer to Model Management
    GlobalPredictServicer -->|inference| ModelManager
    GlobalTrainServicer -->|training| ModelManager
    ModelMgmtServicer -->|deploy/undeploy| ModelManager
    ModelRuntimeServicer -->|load/unload| ModelManager
    ModelManager --> ModelLoader
    ModelManager --> Batcher
    ModelManager --> ModelSizer

    %% Plugin connections
    ModelManager -->|uses| Finders
    ModelManager -->|uses| Initializers
    ModelManager -->|uses| Trainers
    ModelLoader -->|loads| ModuleBase

    %% Core connections
    ServiceFactory -->|generates from| TaskBase
    ServiceFactory -->|uses| PyToProto
    ModuleBase -->|implements| TaskBase
    ModuleBase -->|registered in| Registries
    DataObject -->|extends| DataBase
    DataBase -->|uses| Backends

    %% Interface connections
    NLP -->|defines tasks/models| TaskBase
    TimeSeries -->|defines tasks/models| TaskBase
    Vision -->|defines tasks/models| TaskBase
    Common -->|base types| DataBase

    %% External connections
    HealthProbe -.->|probes| GRPCServer
    HealthProbe -.->|probes| HTTPServer

    %% Thread pool
    GRPCServer -->|shares| ThreadPool
    HTTPServer -->|shares| ThreadPool

    %% Styling
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style GlobalPredictServicer fill:#5b9bd5,stroke:#333,color:#fff
    style GlobalTrainServicer fill:#5b9bd5,stroke:#333,color:#fff
    style ModelRuntimeServicer fill:#5b9bd5,stroke:#333,color:#fff
    style ModelManager fill:#f5a623,stroke:#333
    style TaskBase fill:#7ed321,stroke:#333
    style ModuleBase fill:#7ed321,stroke:#333
    style DataBase fill:#7ed321,stroke:#333
    style HealthProbe fill:#e8e8e8,stroke:#333
    style NLP fill:#d5a6e6,stroke:#333
    style TimeSeries fill:#d5a6e6,stroke:#333
    style Vision fill:#d5a6e6,stroke:#333
