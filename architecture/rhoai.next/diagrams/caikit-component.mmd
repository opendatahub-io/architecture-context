graph TB
    subgraph CaikitFramework["Caikit Framework (Python Library)"]
        direction TB

        subgraph Runtime["caikit.runtime"]
            direction LR
            GRPCServer["gRPC Server<br/>8085/TCP"]
            HTTPServer["HTTP Server (FastAPI/Uvicorn)<br/>8080/TCP"]
            MetricsServer["Prometheus Metrics<br/>8086/TCP"]

            subgraph Servicers["Servicers"]
                GlobalPredict["GlobalPredictServicer"]
                GlobalTrain["GlobalTrainServicer"]
                InfoServicer["InfoServicer"]
                ModelMgmt["ModelManagementServicer"]
                TrainMgmt["TrainingManagementServicer"]
                ModelRuntimeSvc["ModelRuntimeServicer"]
            end

            subgraph ServiceGen["Service Generation"]
                ServiceFactory["ServiceFactory"]
                TaskPredictRPC["TaskPredictRPC"]
                ModuleTrainRPC["ModuleClassTrainRPC"]
                PydanticWrapper["PydanticWrapper"]
            end

            subgraph ModelMgmtLayer["Model Management"]
                ModelManager["ModelManager"]
                CoreModelLoader["CoreModelLoader"]
                Batcher["Batcher"]
                LoadedModel["LoadedModel"]
            end

            GRPCServer --> Servicers
            HTTPServer --> PydanticWrapper
            PydanticWrapper --> GlobalPredict
            ServiceFactory --> TaskPredictRPC
            ServiceFactory --> ModuleTrainRPC
            GlobalPredict --> ModelManager
            GlobalTrain --> ModelManager
            ModelManager --> CoreModelLoader
            ModelManager --> Batcher
            CoreModelLoader --> LoadedModel
        end

        subgraph Core["caikit.core"]
            direction LR
            TaskDef["Task Definitions"]
            ModuleBase["Module Base"]
            DataModel["DataBase / DataObject"]
            DataStreams["DataStream (lazy)"]
            ModuleBackends["Module Backends"]
            Registry["Module Registry"]
            LocalBackend["LocalBackend"]

            ModuleBase -->|registers with| Registry
            ModuleBase -->|implements| TaskDef
            ModuleBase -->|uses| DataModel
            DataModel -->|serializes via| DataStreams
            ModuleBackends --> LocalBackend
        end

        subgraph Interfaces["caikit.interfaces"]
            direction LR
            NLP["NLP<br/>(TextGeneration, Embedding,<br/>Reranking, Classification)"]
            TimeSeries["Time Series<br/>(Forecasting, Anomaly)"]
            Vision["Vision<br/>(Object Detection)"]
            RuntimeIF["Runtime<br/>(Info, ModelMgmt, TrainMgmt)"]
        end

        subgraph Config["caikit.config"]
            ConfigYAML["config.yml<br/>(hierarchical YAML)"]
            ConfigPy["config.py<br/>(env var overrides)"]
        end
    end

    HealthProbe["caikit_health_probe<br/>(standalone binary)"]

    %% Internal connections
    Runtime -->|uses modules from| Core
    Runtime -->|exposes APIs for| Interfaces
    Interfaces -->|defines tasks & data models in| Core
    Runtime -->|reads| Config

    %% Health probe connections
    HealthProbe -->|HTTP /health| HTTPServer
    HealthProbe -->|gRPC Health.Check()| GRPCServer

    %% External consumers
    CaikitNLP["caikit-nlp<br/>(registers NLP modules)"]
    CaikitTGIS["caikit-tgis-serving<br/>(TGIS backend)"]
    ModelMesh["Model Mesh<br/>(modelmesh-serving)"]
    KServe["KServe<br/>(InferenceService)"]
    Client["Client Application"]

    CaikitNLP -->|imports & registers modules| Core
    CaikitTGIS -->|imports & wraps| Runtime
    ModelMesh -->|gRPC Unix socket<br/>/tmp/mmesh/grpc.sock| ModelRuntimeSvc
    KServe -->|runs as container| Runtime
    Client -->|HTTP 8080 / gRPC 8085| Runtime

    %% Styling
    style CaikitFramework fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Core fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Interfaces fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Config fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style HealthProbe fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style CaikitNLP fill:#7ed321,stroke:#333
    style CaikitTGIS fill:#7ed321,stroke:#333
    style ModelMesh fill:#f5a623,stroke:#333
    style KServe fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
