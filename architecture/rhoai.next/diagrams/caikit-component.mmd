graph TB
    subgraph CaikitFramework["Caikit Framework (Python SDK/Runtime)"]
        direction TB

        subgraph Core["caikit.core"]
            TaskDef["Task Definitions<br/>(TextGeneration, Embedding,<br/>Classification, etc.)"]
            ModuleBase["Module Base<br/>(@module decorator)"]
            DataModel["DataModel / @dataobject<br/>(auto-generates protobuf)"]
            Registries["Module & Task Registries"]
            ModuleLoader["Module Loader / Saver"]
            Factory["Backend Factory"]
        end

        subgraph Runtime["caikit.runtime"]
            direction TB

            subgraph Servers["Dual-Protocol Servers"]
                GRPCServer["gRPC Server<br/>Port 8085/TCP<br/>Optional TLS/mTLS"]
                HTTPServer["HTTP Server (FastAPI)<br/>Port 8080/TCP<br/>Optional TLS/mTLS"]
            end

            subgraph ServiceGen["Dynamic Service Generation"]
                ServiceFactory["ServicePackageFactory<br/>(scans modules at startup)"]
                RPCGen["RPC Generator<br/>(py-to-proto)"]
            end

            subgraph Servicers["Shared Servicers"]
                PredictServicer["GlobalPredictServicer"]
                TrainServicer["GlobalTrainServicer"]
                InfoServicer["InfoServicer"]
                ModelMgmtServicer["ModelManagementServicer"]
                TrainingMgmtServicer["TrainingManagementServicer"]
                ModelRuntimeServicer["ModelRuntimeServicer<br/>(Model Mesh API)"]
            end

            subgraph ModelMgmt["Model Management"]
                ModelManager["ModelManager"]
                LoadedModel["LoadedModel"]
                CoreModelLoader["CoreModelLoader"]
            end

            MetricsPort["Prometheus Metrics<br/>Port 8086/TCP"]
        end

        subgraph Interfaces["caikit.interfaces"]
            NLP["NLP Tasks<br/>(TextGeneration, Embedding,<br/>Classification, Reranking,<br/>Summarization)"]
            Vision["Vision Tasks<br/>(Image data models)"]
            TimeSeries["Time Series Tasks<br/>(Forecasting)"]
        end

        subgraph HealthProbe["caikit_health_probe"]
            Probe["Health Probe Binary<br/>(external process)"]
        end
    end

    %% Internal flows
    TaskDef -->|defines contracts| ModuleBase
    ModuleBase -->|registers in| Registries
    DataModel -->|generates proto via| RPCGen
    Registries -->|scanned by| ServiceFactory
    ServiceFactory -->|generates RPCs for| GRPCServer
    ServiceFactory -->|generates routes for| HTTPServer

    GRPCServer -->|delegates to| PredictServicer
    GRPCServer -->|delegates to| TrainServicer
    HTTPServer -->|delegates to| PredictServicer
    HTTPServer -->|delegates to| TrainServicer
    PredictServicer -->|looks up model| ModelManager
    ModelManager -->|retrieves| LoadedModel
    LoadedModel -->|calls Module.run| ModuleBase

    NLP -->|registers tasks| Registries
    Vision -->|registers tasks| Registries
    TimeSeries -->|registers tasks| Registries

    %% External interactions
    Client["Client<br/>(Data Scientist / Application)"]
    Client -->|"POST inference<br/>8080/TCP HTTP"| HTTPServer
    Client -->|"RPC inference<br/>8085/TCP gRPC"| GRPCServer

    ModelMeshCtrl["Model Mesh Controller<br/>(sidecar)"]
    ModelMeshCtrl -->|"loadModel/unloadModel<br/>Unix socket or 8085/TCP"| ModelRuntimeServicer
    ModelRuntimeServicer -->|manages| ModelManager
    CoreModelLoader -->|"loads from"| Storage["Filesystem / S3 Storage"]

    Probe -->|"health check<br/>8080/TCP + 8085/TCP"| GRPCServer
    Probe -->|"health check<br/>8080/TCP + 8085/TCP"| HTTPServer

    KServe["KServe<br/>InferenceService Pod"]
    KServe -.->|"hosts caikit as<br/>model server"| Runtime

    %% Downstream consumers
    Downstream["Downstream Libraries<br/>(caikit-nlp, caikit-tgis-serving)"]
    Downstream -->|"Python import<br/>registers modules"| Core

    %% Styling
    style CaikitFramework fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dcedc8,stroke:#689f38,stroke-width:2px
    style Runtime fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style Interfaces fill:#f3e5f5,stroke:#8e24aa,stroke-width:2px
    style HealthProbe fill:#e0f7fa,stroke:#00838f,stroke-width:2px
    style Servers fill:#fff8e1,stroke:#f9a825
    style ServiceGen fill:#fff8e1,stroke:#f9a825
    style Servicers fill:#fff8e1,stroke:#f9a825
    style ModelMgmt fill:#fff8e1,stroke:#f9a825
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style ModelMeshCtrl fill:#e8e8e8,stroke:#666
    style KServe fill:#e8e8e8,stroke:#666
    style Storage fill:#f5a623,stroke:#333
    style Downstream fill:#e8e8e8,stroke:#666
