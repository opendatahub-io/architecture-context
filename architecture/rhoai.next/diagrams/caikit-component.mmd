graph TB
    subgraph CaikitRuntime["Caikit Runtime (Python Service)"]
        direction TB
        GRPCServer["gRPC Server<br/>8085/TCP"]
        HTTPServer["HTTP Server (FastAPI)<br/>8080/TCP"]
        MetricsServer["Metrics Server<br/>8086/TCP"]
        ServerWrapper["CaikitRuntimeServerWrapper<br/>RPC Interceptor"]

        subgraph Servicers["Servicers"]
            GlobalPredict["GlobalPredictServicer<br/>Inference routing"]
            GlobalTrain["GlobalTrainServicer<br/>Training routing"]
            ModelRuntimeSvc["ModelRuntimeServicer<br/>ModelMesh sidecar API"]
            InfoSvc["InfoServicer<br/>Version & model info"]
            ModelMgmtSvc["ModelManagementServicer<br/>Deploy/undeploy"]
            TrainingMgmtSvc["TrainingManagementServicer<br/>Training lifecycle"]
        end

        ServiceFactory["ServicePackageFactory<br/>Dynamic service generation"]
    end

    subgraph CaikitCore["Caikit Core (Python Library)"]
        direction TB
        ModuleFramework["Module Framework<br/>@module decorator"]
        TaskDefs["Task Definitions<br/>@task decorator"]
        DataModel["Data Model<br/>@dataobject decorator"]
        ModelManager["Model Manager<br/>Load/save/find"]
        BackendSystem["Module Backend System<br/>LocalBackend + extensible"]
        Registries["Global Registries<br/>MODULE_REGISTRY<br/>MODULE_BACKEND_REGISTRY"]
    end

    subgraph CaikitInterfaces["Caikit Interfaces (Python Library)"]
        NLP["NLP Tasks<br/>TextGeneration, Embedding,<br/>Classification, Reranking"]
        TimeSeries["Time Series Tasks<br/>Forecasting, Anomaly Detection"]
        Vision["Vision Tasks<br/>Image Classification"]
    end

    subgraph HealthProbe["caikit_health_probe (CLI)"]
        Probe["Health Probe<br/>Liveness & readiness checks"]
    end

    subgraph ClientLib["caikit.runtime.client (Library)"]
        RemoteModule["RemoteModuleBase<br/>Distributed inference proxy"]
        RemoteFinder["RemoteModelFinder<br/>Model discovery"]
    end

    %% Internal connections
    GRPCServer --> ServerWrapper
    ServerWrapper --> GlobalPredict
    ServerWrapper --> GlobalTrain
    HTTPServer --> GlobalPredict
    HTTPServer --> GlobalTrain
    ServiceFactory -->|generates endpoints from| Registries
    GlobalPredict --> ModelManager
    GlobalTrain --> ModelManager
    ModelManager --> ModuleFramework
    ModuleFramework --> BackendSystem
    ModuleFramework --> TaskDefs
    TaskDefs --> DataModel
    NLP -->|registers tasks| Registries
    TimeSeries -->|registers tasks| Registries
    Vision -->|registers tasks| Registries

    %% Health probe connections
    Probe -->|HTTP /health| HTTPServer
    Probe -->|gRPC Health| GRPCServer

    %% External interactions
    Kubelet["Kubernetes kubelet"] -->|liveness/readiness| Probe

    ModelMesh["ModelMesh Controller"] -->|loadModel/unloadModel<br/>unix:///tmp/mmesh/grpc.sock| ModelRuntimeSvc
    ModelRuntimeSvc --> ModelManager

    RemoteModule -->|gRPC/HTTP| GRPCServer
    RemoteFinder -->|discovers models| GRPCServer

    Prometheus["Prometheus"] -->|scrapes| MetricsServer
    OTELCollector["OpenTelemetry Collector"] <-->|OTLP traces<br/>4317/4318| CaikitRuntime
    S3["S3-compatible Storage"] <-->|model artifacts<br/>443/TCP HTTPS| ModelManager

    DownstreamLibs["caikit-nlp / caikit-tgis-serving"] -->|register modules via<br/>@module decorator| Registries

    %% Styling
    style CaikitRuntime fill:#4a90e2,stroke:#2c5d8f,color:#fff
    style CaikitCore fill:#7ed321,stroke:#5a9e18,color:#fff
    style CaikitInterfaces fill:#50c8e8,stroke:#3a9ab0,color:#fff
    style HealthProbe fill:#f5a623,stroke:#c4841a,color:#fff
    style ClientLib fill:#b8a9e8,stroke:#8a7ab8,color:#fff
    style ModelMesh fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
    style OTELCollector fill:#e8e8e8,stroke:#999
    style S3 fill:#e8e8e8,stroke:#999
    style Kubelet fill:#e8e8e8,stroke:#999
    style DownstreamLibs fill:#e8e8e8,stroke:#999
