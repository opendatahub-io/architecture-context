graph TB
    subgraph CaikitFramework["Caikit Framework"]
        direction TB

        subgraph Core["caikit.core"]
            ModuleSystem["Module System<br/>@module decorator"]
            TaskSystem["Task System<br/>@task decorator"]
            DataModel["Data Model<br/>dataobject, streams"]
            ModelMgr["Model Manager<br/>load, save, train"]
            Backends["Backend System<br/>pluggable backends"]
            Registries["Registries<br/>module & task registry"]

            TaskSystem -->|defines contracts for| ModuleSystem
            ModuleSystem -->|registers in| Registries
            ModuleSystem -->|uses| DataModel
            ModuleSystem -->|managed by| ModelMgr
            ModelMgr -->|delegates to| Backends
        end

        subgraph Runtime["caikit.runtime"]
            direction TB
            GRPCServer["gRPC Server<br/>configurable port/TCP"]
            HTTPServer["HTTP Server<br/>FastAPI + uvicorn"]
            MetricsServer["Metrics Server<br/>Prometheus"]

            subgraph Servicers["Shared Servicers"]
                PredictServicer["GlobalPredictServicer"]
                TrainServicer["GlobalTrainServicer"]
                ModelMgmtServicer["ModelManagementServicer"]
                ModelRuntimeServicer["ModelRuntimeServicer<br/>(ModelMesh sidecar)"]
                InfoServicer["InfoServicer"]
                TrainingMgmtServicer["TrainingManagementServicer"]
            end

            ServiceFactory["ServiceFactory<br/>dynamic service generation"]
            RuntimeModelMgr["Runtime ModelManager"]
            Batcher["Request Batcher"]

            GRPCServer --> PredictServicer
            GRPCServer --> TrainServicer
            GRPCServer --> ModelMgmtServicer
            GRPCServer --> ModelRuntimeServicer
            GRPCServer --> InfoServicer
            HTTPServer --> PredictServicer
            HTTPServer --> TrainServicer
            HTTPServer --> ModelMgmtServicer
            HTTPServer --> TrainingMgmtServicer
            PredictServicer --> RuntimeModelMgr
            TrainServicer --> RuntimeModelMgr
            RuntimeModelMgr --> Batcher
            ServiceFactory -->|generates| GRPCServer
            ServiceFactory -->|generates| HTTPServer
        end

        subgraph Interfaces["caikit.interfaces"]
            NLP["NLP<br/>text gen, embedding,<br/>classification, reranking"]
            TimeSeries["Time Series<br/>forecasting, anomaly<br/>detection, evaluation"]
            Vision["Vision<br/>image processing"]
            Common["Common<br/>vectors, files,<br/>streams, remote"]
            RuntimeIF["Runtime<br/>model mgmt, training<br/>mgmt, runtime info"]
        end

        HealthProbe["caikit_health_probe<br/>CLI utility"]
    end

    %% External integrations
    Client["Client"] -->|gRPC / HTTP| GRPCServer
    Client -->|HTTP / HTTPS| HTTPServer

    ModelMesh["ModelMesh"] -->|ModelRuntime gRPC<br/>Unix socket / TCP| ModelRuntimeServicer
    KServe["KServe<br/>ServingRuntime"] -.->|container colocation| CaikitFramework

    RuntimeModelMgr -->|loads models| LocalFS["Local Filesystem"]
    RuntimeModelMgr -->|loads models| S3["S3 Storage"]

    HealthProbe -->|probes| GRPCServer
    HealthProbe -->|probes| HTTPServer

    Prometheus["Prometheus"] -->|scrapes| MetricsServer
    OTel["OTel Collector"] <-->|OTLP traces| Runtime

    %% Core provides to Runtime
    Core -->|module/task abstractions| ServiceFactory

    %% Interfaces define tasks for Core
    NLP -->|task definitions| TaskSystem
    TimeSeries -->|task definitions| TaskSystem
    Vision -->|data models| DataModel

    %% Styling
    style CaikitFramework fill:#f0f4ff,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style Runtime fill:#d1fae5,stroke:#10b981,stroke-width:2px
    style Interfaces fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    style Servicers fill:#e0e7ff,stroke:#6366f1,stroke-width:1px

    style GRPCServer fill:#4a90e2,color:#fff
    style HTTPServer fill:#4a90e2,color:#fff
    style MetricsServer fill:#4a90e2,color:#fff

    style ModelMesh fill:#e8e8e8,stroke:#666
    style KServe fill:#e8e8e8,stroke:#666
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#666
    style OTel fill:#e8e8e8,stroke:#666
    style Client fill:#f9f9f9,stroke:#999
    style HealthProbe fill:#7ed321,color:#fff
