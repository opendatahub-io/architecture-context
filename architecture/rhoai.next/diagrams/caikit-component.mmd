graph TB
    subgraph CaikitRuntime["Caikit Runtime"]
        direction TB
        subgraph Core["caikit.core"]
            ModuleFramework["Module Framework<br/>@module decorator"]
            TaskRegistry["Task Registry<br/>@task decorator"]
            DataModel["Data Model<br/>@dataobject decorator"]
            ModelManager["Model Manager<br/>load/save/run/train"]
            BackendSystem["Module Backends<br/>LocalBackend + plugins"]
            Registries["Global Registries<br/>MODULE_REGISTRY<br/>MODULE_BACKEND_REGISTRY"]
            ModuleFramework --> Registries
            TaskRegistry --> Registries
            DataModel --> Registries
            ModelManager --> BackendSystem
        end

        subgraph Interfaces["caikit.interfaces"]
            NLP["NLP Tasks<br/>TextGeneration, Embedding,<br/>Classification, Reranking"]
            TimeSeries["Time Series Tasks<br/>Forecasting, Detection"]
            Vision["Vision Tasks<br/>Image Processing"]
        end

        subgraph Runtime["caikit.runtime"]
            gRPCServer["gRPC Server<br/>Port 8085/TCP"]
            HTTPServer["HTTP Server (FastAPI)<br/>Port 8080/TCP"]
            MetricsServer["Metrics Server<br/>Port 8086/TCP"]
            ServiceFactory["ServicePackageFactory<br/>Dynamic endpoint generation"]
            GlobalPredict["GlobalPredictServicer"]
            GlobalTrain["GlobalTrainServicer"]
            ModelRuntimeSvc["ModelRuntimeServicer<br/>ModelMesh sidecar API"]
            ClientModule["Remote Client Module<br/>RemoteModuleBase"]

            ServiceFactory -->|generates endpoints| gRPCServer
            ServiceFactory -->|generates endpoints| HTTPServer
            gRPCServer --> GlobalPredict
            gRPCServer --> GlobalTrain
            gRPCServer --> ModelRuntimeSvc
            HTTPServer --> GlobalPredict
            HTTPServer --> GlobalTrain
            GlobalPredict --> MetricsServer
        end

        subgraph HealthProbe["caikit_health_probe"]
            Probe["Health Probe CLI<br/>Liveness + Readiness"]
        end

        Interfaces -->|registers tasks| Registries
        ServiceFactory -->|introspects| Registries
        GlobalPredict --> ModelManager
        GlobalTrain --> ModelManager
        ModelRuntimeSvc --> ModelManager
        Probe -->|checks| gRPCServer
        Probe -->|checks| HTTPServer
    end

    %% External Interactions
    Kubelet["Kubernetes kubelet"] -->|liveness/readiness| Probe
    ModelMesh["ModelMesh Controller"] -->|loadModel/unloadModel<br/>unix:///tmp/mmesh/grpc.sock| ModelRuntimeSvc
    KServe["KServe"] -->|container orchestration| CaikitRuntime
    Client["Client<br/>(Application / Pipeline)"] -->|inference/training| gRPCServer
    Client -->|inference/training| HTTPServer
    Prometheus["Prometheus"] -->|scrape :8086| MetricsServer
    OTELCollector["OpenTelemetry Collector"] ---|trace export<br/>OTLP 4317/4318| Runtime
    S3["S3-compatible Storage"] ---|model artifacts<br/>HTTPS/443| ModelManager
    ClientModule -->|distributed inference<br/>gRPC/HTTP| RemoteRuntime["Remote Caikit Runtime"]

    %% Downstream consumers
    CaikitNLP["caikit-nlp /<br/>caikit-tgis-serving"] -->|module registration| Registries

    %% Styling
    style Core fill:#4a90e2,stroke:#333,color:#fff
    style Interfaces fill:#7ed321,stroke:#333,color:#fff
    style Runtime fill:#f5a623,stroke:#333,color:#fff
    style HealthProbe fill:#bd10e0,stroke:#333,color:#fff
    style ModelMesh fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTELCollector fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style RemoteRuntime fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#50e3c2,stroke:#333
