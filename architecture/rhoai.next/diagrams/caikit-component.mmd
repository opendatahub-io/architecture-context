graph TB
    subgraph CaikitFramework["Caikit Framework (Python SDK)"]
        direction TB

        subgraph Core["caikit.core"]
            TaskDef["Task Definitions<br/>(TextGeneration, Embedding, etc.)"]
            ModuleBase["Module Base<br/>(@module decorator)"]
            DataModel["DataModel / @dataobject<br/>(auto-generates protobuf)"]
            Registries["Module & Task Registries"]
            ModelMgr["Core ModelManager<br/>(load/save modules)"]
            Factory["Plugin Factory"]

            TaskDef -->|defines contracts| ModuleBase
            ModuleBase -->|uses| DataModel
            ModuleBase -->|registers in| Registries
            DataModel -->|py-to-proto| Registries
            Factory -->|creates| ModuleBase
        end

        subgraph Interfaces["caikit.interfaces"]
            NLP["NLP Tasks<br/>(TextGeneration, Classification,<br/>Embedding, Reranking, etc.)"]
            Vision["Vision Tasks<br/>(Image processing)"]
            TimeSeries["Time Series Tasks<br/>(Forecasting)"]
            CommonDM["Common Data Models<br/>(Vectors, Streams, Remote)"]
        end

        subgraph Runtime["caikit.runtime"]
            direction TB

            subgraph Servers["Dual-Protocol Servers"]
                GRPCServer["gRPC Server<br/>Port 8085/TCP<br/>Optional TLS/mTLS"]
                HTTPServer["HTTP Server (FastAPI)<br/>Port 8080/TCP<br/>Optional TLS/mTLS"]
                MetricsServer["Metrics Server<br/>Port 8086/TCP<br/>Prometheus"]
            end

            subgraph Servicers["Shared Servicers"]
                PredictServicer["GlobalPredictServicer"]
                TrainServicer["GlobalTrainServicer"]
                InfoServicer["InfoServicer"]
                ModelMgmtServicer["ModelManagementServicer"]
                TrainingMgmtServicer["TrainingManagementServicer"]
                ModelRuntimeServicer["ModelRuntimeServicer<br/>(Model Mesh API)"]
            end

            subgraph ServiceGen["Dynamic Service Generation"]
                ServiceFactory["ServicePackageFactory"]
                RPCGen["RPC Generator<br/>(auto gRPC + HTTP routes)"]
            end

            subgraph ModelMgmt["Model Management"]
                RuntimeModelMgr["Runtime ModelManager"]
                LoadedModel["LoadedModel"]
                CoreLoader["CoreModelLoader"]
            end

            ServerWrapper["CaikitRuntimeServerWrapper<br/>(gRPC interceptor)"]

            GRPCServer --> ServerWrapper
            ServerWrapper --> PredictServicer
            HTTPServer --> PredictServicer
            HTTPServer --> TrainServicer
            GRPCServer --> ModelRuntimeServicer
            PredictServicer --> RuntimeModelMgr
            TrainServicer --> RuntimeModelMgr
            RuntimeModelMgr --> LoadedModel
            RuntimeModelMgr --> CoreLoader
            ServiceFactory --> RPCGen
        end

        subgraph Config["caikit.config"]
            ConfigYAML["config.yml<br/>(hierarchical YAML)"]
            ConfigPy["config.py<br/>(env var overrides)"]
        end

        subgraph HealthProbe["caikit_health_probe"]
            Probe["Health Probe Binary<br/>(external process)"]
            LivenessCheck["Liveness: psutil process check"]
            ReadinessCheck["Readiness: gRPC health +<br/>HTTP GET with TLS"]
            Probe --> LivenessCheck
            Probe --> ReadinessCheck
        end
    end

    %% External interactions
    Client["Client<br/>(Data Scientist / Application)"]
    ModelMesh["Model Mesh<br/>(Sidecar)"]
    K8sKubelet["Kubernetes Kubelet"]

    Client -->|"HTTP POST /api/v1/{task}"| HTTPServer
    Client -->|"gRPC {TaskName}Service"| GRPCServer
    ModelMesh -->|"gRPC loadModel/unloadModel<br/>Unix socket or 8085/TCP"| ModelRuntimeServicer
    K8sKubelet -->|"exec caikit-health-probe"| Probe
    ReadinessCheck -->|"gRPC health check"| GRPCServer
    ReadinessCheck -->|"HTTP GET /health"| HTTPServer

    Interfaces --> Core
    Runtime --> Core
    Runtime --> Interfaces

    %% Styling
    style CaikitFramework fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Interfaces fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Config fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style HealthProbe fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style Client fill:#f5f5f5,stroke:#666,stroke-width:2px
    style ModelMesh fill:#f5f5f5,stroke:#666,stroke-width:2px
    style K8sKubelet fill:#f5f5f5,stroke:#666,stroke-width:2px
    style GRPCServer fill:#4a90e2,color:#fff
    style HTTPServer fill:#4a90e2,color:#fff
    style MetricsServer fill:#4a90e2,color:#fff
