    style HTTPLayer fill:#fce7f3,stroke:#db2777,stroke-width:1px
    style Servicers fill:#e0e7ff,stroke:#4338ca,stroke-width:1px
    style ModelMgmt fill:#ccfbf1,stroke:#0d9488,stroke-width:1px
    style HealthProbe fill:#fef9c3,stroke:#ca8a04,stroke-width:1px
    style Config fill:#f3e8ff,stroke:#7c3aed,stroke-width:1px
    style Client fill:#f9fafb,stroke:#6b7280,stroke-width:2px
    style ModelMesh fill:#e5e7eb,stroke:#374151,stroke-width:2px
