graph TB
    subgraph CaikitFramework["Caikit Framework (Python SDK/Runtime)"]
        direction TB

        subgraph Core["caikit.core - Module/Task/DataModel Framework"]
            Task["Task Definitions<br/>(@task decorator)"]
            Module["Module Base<br/>(@module decorator)"]
            DataModel["DataModel / DataObject<br/>(@dataobject decorator)"]
            Registry["Module & Task Registry"]
            ModelManager_Core["Core Model Manager"]
            Loader["Model Loader / Saver"]
            Factory["Backend Factory"]

            Task --> Registry
            Module --> Registry
            DataModel --> Registry
            Registry --> ModelManager_Core
            ModelManager_Core --> Loader
        end

        subgraph Interfaces["caikit.interfaces - Domain Task Definitions"]
            NLP["NLP Tasks<br/>(TextGeneration, Embedding,<br/>Classification, Reranking,<br/>SentenceSimilarity)"]
            Vision["Vision Tasks<br/>(ObjectDetection,<br/>ImageClassification)"]
            TimeSeries["Time Series Tasks<br/>(Forecasting,<br/>AnomalyDetection)"]
            CommonDM["Common Data Models<br/>(Vectors, StreamSources,<br/>Remote Config)"]
        end

        subgraph Runtime["caikit.runtime - Dual-Protocol Serving"]
            direction TB
            ServiceFactory["ServicePackageFactory<br/>(Dynamic Service Generation)"]

            subgraph gRPCLayer["gRPC Server (Port 8085)"]
                gRPCServer["gRPC Server<br/>(grpcio)"]
                ServerWrapper["CaikitRuntimeServerWrapper<br/>(Dynamic RPC routing)"]
                gRPCInterceptors["Metrics Interceptors<br/>(py-grpc-prometheus)"]
            end

            subgraph HTTPLayer["HTTP Server (Port 8080)"]
                HTTPServer["FastAPI Server<br/>(uvicorn)"]
                PydanticWrapper["Pydantic Wrapper<br/>(Request validation)"]
                SSE["SSE Streaming<br/>(sse-starlette)"]
            end

            subgraph Servicers["Shared Servicers"]
                PredictServicer["GlobalPredictServicer"]
                TrainServicer["GlobalTrainServicer"]
                InfoServicer["InfoServicer"]
                ModelMgmtServicer["ModelManagementServicer"]
                TrainingMgmtServicer["TrainingManagementServicer"]
                ModelRuntimeServicer["ModelRuntimeServicer<br/>(Model Mesh API)"]
            end

            subgraph ModelMgmt["Model Management"]
                RuntimeModelManager["Runtime ModelManager"]
                LoadedModel["LoadedModel"]
                CoreModelLoader["CoreModelLoader"]
            end

            ServiceFactory --> gRPCServer
            ServiceFactory --> HTTPServer
            gRPCServer --> ServerWrapper
            ServerWrapper --> PredictServicer
            ServerWrapper --> TrainServicer
            HTTPServer --> PredictServicer
            HTTPServer --> TrainServicer
            PredictServicer --> RuntimeModelManager
            TrainServicer --> RuntimeModelManager
            RuntimeModelManager --> LoadedModel
            RuntimeModelManager --> CoreModelLoader
        end

        subgraph HealthProbe["caikit_health_probe (CLI)"]
            Probe["Health Probe Binary<br/>(liveness + readiness)"]
        end

        subgraph Config["caikit.config"]
            ConfigSystem["Hierarchical YAML Config<br/>(alchemy-config)"]
        end
    end

    %% External interactions
    Client[Client / Application] -->|"POST /api/v1/{task}/..."| HTTPServer
    Client -->|"gRPC {TaskName}Service"| gRPCServer

    ModelMesh["Model Mesh Sidecar"] -->|"gRPC mmesh.ModelRuntime<br/>Unix socket / 8085"| ModelRuntimeServicer
    ModelRuntimeServicer --> RuntimeModelManager

    Probe -->|"gRPC Health Check<br/>8085/TCP"| gRPCServer
    Probe -->|"HTTP GET /health<br/>8080/TCP"| HTTPServer

    K8s["Kubernetes<br/>(liveness/readiness)"] -->|"exec probe"| Probe

    Prometheus["Prometheus"] -->|"scrape :8086"| gRPCInterceptors

    %% Core to Interfaces relationship
    NLP --> Task
    Vision --> Task
    TimeSeries --> Task
    CommonDM --> DataModel

