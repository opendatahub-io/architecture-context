    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Caikit fill:#dae8fc,stroke:#6c8ebf
    style CaikitNLP fill:#dae8fc,stroke:#6c8ebf
    style CaikitTGISBackend fill:#dae8fc,stroke:#6c8ebf
    style Python fill:#dae8fc,stroke:#6c8ebf
    style TGIS fill:#e67e22,stroke:#333,color:#fff
    style KServe fill:#27ae60,stroke:#333,color:#fff
    style Istio fill:#27ae60,stroke:#333,color:#fff
    style Knative fill:#27ae60,stroke:#333,color:#fff
    style Authorino fill:#27ae60,stroke:#333,color:#fff
    style Prometheus fill:#27ae60,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style Poetry fill:#bdc3c7,stroke:#333
    style UBI9 fill:#bdc3c7,stroke:#333
