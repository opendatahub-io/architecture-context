graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(Container Image)"]

    %% Python Library Dependencies
    subgraph PythonDeps["Python Dependencies (build-time)"]
        Caikit["caikit 0.28.1"]
        CaikitNLP["caikit-nlp 0.5.14"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39"]
        Python["Python ~3.11"]
        Poetry["poetry (build tool)"]
    end

    CaikitTGIS -->|"runtime library"| Caikit
    CaikitTGIS -->|"NLP tasks"| CaikitNLP
    CaikitTGIS -->|"TGIS connector"| CaikitTGISBackend
    CaikitTGIS -->|"runtime"| Python
    CaikitTGIS -.->|"build-time"| Poetry

    %% Internal Platform Dependencies
    subgraph PlatformDeps["Internal Platform Dependencies (RHOAI)"]
        KServe["KServe<br/>(ServingRuntime / InferenceService CRDs)"]
        TGIS["TGIS<br/>(co-located container)"]
        Knative["Knative Serving"]
        Istio["Istio Service Mesh"]
        OSMesh["OpenShift Service Mesh<br/>(Maistra)"]
    end

    CaikitTGIS -->|"CRD orchestration"| KServe
    CaikitTGIS -->|"gRPC localhost:8033"| TGIS
    CaikitTGIS -->|"autoscaling & routing"| Knative
    CaikitTGIS -->|"mTLS sidecar"| Istio
    Istio -->|"managed by"| OSMesh

    %% External Service Dependencies
    subgraph ExternalDeps["External Services"]
        S3["S3-compatible Storage<br/>(AWS S3 / MinIO)"]
        HuggingFace["HuggingFace Hub<br/>(dev only)"]
        PVC["PVC / Filesystem"]
    end

    CaikitTGIS -->|"model artifacts<br/>HTTPS/443"| S3
    CaikitTGIS -.->|"model weights<br/>HTTPS/443 (dev)"| HuggingFace
    CaikitTGIS -->|"model mount<br/>/mnt/models/"| PVC

    %% Integration Points (who consumes this)
    subgraph Consumers["Consumers / Integrations"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
        Authorino["Authorino<br/>(optional auth)"]
    end

    Prometheus -->|"scrapes metrics<br/>HTTP/8086"| CaikitTGIS
    Authorino -.->|"token auth<br/>(optional)"| CaikitTGIS

    %% Styling
    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    classDef pythondep fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef consumer fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Caikit,CaikitNLP,CaikitTGISBackend,Python,Poetry pythondep
    class KServe,TGIS,Knative,Istio,OSMesh platform
    class S3,HuggingFace,PVC external
    class Prometheus,Authorino consumer
