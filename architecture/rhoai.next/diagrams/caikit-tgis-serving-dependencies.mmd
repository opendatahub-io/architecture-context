graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(Container Image)"]

    %% Python Library Dependencies
    subgraph PythonDeps["Python Dependencies"]
        Caikit["caikit 0.28.1"]
        CaikitNLP["caikit-nlp 0.5.14"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39"]
        Python["Python ~3.11"]
    end

    CaikitTGIS -->|"core runtime"| Caikit
    CaikitTGIS -->|"NLP tasks"| CaikitNLP
    CaikitTGIS -->|"TGIS connector"| CaikitTGISBackend
    CaikitTGIS -->|"runtime language"| Python

    %% Internal RHOAI Platform Dependencies
    subgraph RHOAIPlatform["Internal RHOAI Platform"]
        KServe["KServe<br/>(ServingRuntime/InferenceService CRDs)"]
        TGIS["TGIS<br/>(co-located container)"]
        Knative["Knative Serving"]
        Istio["Istio Service Mesh"]
        OSSM["OpenShift Service Mesh<br/>(Maistra)"]
        Authorino["Authorino<br/>(optional)"]
    end

    CaikitTGIS -->|"orchestration"| KServe
    CaikitTGIS -->|"gRPC inference<br/>localhost:8033"| TGIS
    CaikitTGIS -->|"serverless scaling"| Knative
    CaikitTGIS -->|"mTLS, ingress"| Istio
    Istio -->|"managed by"| OSSM
    CaikitTGIS -.->|"token auth<br/>(optional)"| Authorino

    %% Monitoring
    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    end

    Prometheus -->|"scrapes metrics<br/>HTTP/8086"| CaikitTGIS

    %% External Services
    subgraph ExtServices["External Services"]
        S3["S3-compatible Storage<br/>(AWS S3 / MinIO)"]
        HuggingFace["HuggingFace Hub<br/>(dev only)"]
        K8sAPI["Kubernetes API"]
    end

    CaikitTGIS -->|"model storage<br/>HTTPS/443"| S3
    CaikitTGIS -.->|"model download<br/>HTTPS/443 (dev)"| HuggingFace
    KServe -->|"API server"| K8sAPI

    %% Storage
    subgraph Storage["Storage"]
        PVC["PersistentVolumeClaim<br/>/mnt/models/"]
    end

    CaikitTGIS -->|"model artifacts"| PVC

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        Poetry["poetry (latest)"]
        UBI9["UBI 9 Minimal<br/>(base image)"]
    end

    CaikitTGIS -->|"dep management"| Poetry
    CaikitTGIS -->|"base image"| UBI9

