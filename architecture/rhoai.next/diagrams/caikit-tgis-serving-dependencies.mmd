graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(transformer-container)"]

    %% Python Package Dependencies
    subgraph PythonDeps["Python Dependencies (via Poetry)"]
        Caikit["caikit 0.28.1<br/>AI toolkit runtime"]
        CaikitNLP["caikit-nlp 0.5.14<br/>NLP module"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39<br/>TGIS gRPC connector"]
        Python["Python 3.11<br/>Runtime interpreter"]
    end

    CaikitTGIS -->|"runtime dep"| Caikit
    CaikitTGIS -->|"runtime dep"| CaikitNLP
    CaikitTGIS -->|"runtime dep"| CaikitTGISBackend
    CaikitTGIS -->|"runtime"| Python

    %% Internal Platform Dependencies
    subgraph PlatformDeps["Internal Platform Dependencies"]
        TGIS["TGIS<br/>(Text Generation Inference)<br/>gRPC 8033"]
        KServe["KServe<br/>ServingRuntime / InferenceService"]
        Istio["Istio Service Mesh<br/>mTLS, traffic mgmt"]
        Knative["Knative Serving<br/>Autoscaling / scale-to-zero"]
        Authorino["Authorino<br/>Bearer token validation"]
    end

    CaikitTGIS -->|"gRPC 8033<br/>localhost"| TGIS
    KServe -->|"manages lifecycle"| CaikitTGIS
    Istio -->|"sidecar injection<br/>mTLS STRICT"| CaikitTGIS
    Knative -->|"pod autoscaling"| CaikitTGIS
    Authorino -.->|"optional token<br/>validation"| CaikitTGIS

    %% External Services
    subgraph ExternalSvc["External Services"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
    end

    CaikitTGIS -.->|"model artifacts<br/>(via storage initializer)"| S3

    %% Monitoring Integration
    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus UWM<br/>ServiceMonitor"]
    end

    Prometheus -->|"HTTP 8086<br/>metrics scraping"| CaikitTGIS

    %% Build Dependencies
    subgraph BuildDeps["Build-Time Only"]
        Poetry["Poetry<br/>Dependency mgmt"]
        UBI9["UBI9 Minimal<br/>Base image"]
    end

    CaikitTGIS -.->|"build-time"| Poetry
    CaikitTGIS -.->|"base image"| UBI9

