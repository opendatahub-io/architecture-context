graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(KServe ServingRuntime)"]

    %% Python Library Dependencies (bundled in image)
    subgraph PythonLibs["Python Libraries (bundled)"]
        Caikit["caikit<br/>v0.28.1"]
        CaikitNLP["caikit-nlp<br/>v0.5.14"]
        CaikitTGISBackend["caikit-tgis-backend<br/>v0.1.39"]
        Python["Python 3.11"]
    end

    CaikitTGIS -->|"core runtime"| Caikit
    CaikitTGIS -->|"NLP tasks"| CaikitNLP
    CaikitTGIS -->|"TGIS connector"| CaikitTGISBackend
    CaikitTGIS -->|"interpreter"| Python

    %% Internal Platform Dependencies (co-located / same cluster)
    subgraph InternalPlatform["Internal Platform Dependencies"]
        TGIS["TGIS<br/>(text-generation-inference)<br/>gRPC localhost:8033"]
        KServe["KServe<br/>ServingRuntime / InferenceService CRDs"]
        Knative["Knative Serving<br/>Serverless scaling"]
        Istio["Istio Service Mesh<br/>mTLS + AuthZ"]
        PrometheusUWM["OpenShift UWM<br/>Prometheus metrics"]
    end

    CaikitTGIS -->|"gRPC/8033<br/>inference delegation"| TGIS
    CaikitTGIS -->|"CRD orchestration"| KServe
    CaikitTGIS -->|"autoscaling<br/>scale-to-zero"| Knative
    CaikitTGIS -->|"mTLS sidecar<br/>traffic mgmt"| Istio
    CaikitTGIS -.->|"metrics scrape<br/>HTTP/8086"| PrometheusUWM

    %% External Service Dependencies
    subgraph ExternalServices["External Services"]
        S3["S3-Compatible Storage<br/>HTTPS/443"]
        HuggingFace["HuggingFace Hub<br/>HTTPS/443<br/>(dev/test only)"]
    end

    CaikitTGIS -->|"model artifacts<br/>via storage initializer"| S3
    CaikitTGIS -.->|"model download<br/>(convert.py)"| HuggingFace

    %% Build-time Dependencies
    subgraph BuildDeps["Build-time Only"]
        Poetry["Poetry<br/>(dep resolution)"]
        UBI["UBI 9 Minimal<br/>(base image)"]
    end

    CaikitTGIS -.->|"build"| Poetry
    CaikitTGIS -.->|"base image"| UBI

    %% Integration Points (consumers of this component)
    subgraph Consumers["Consumers"]
        Dashboard["ODH Dashboard<br/>(UI management)"]
        DSPipelines["Data Science Pipelines<br/>(auto deploy)"]
    end

    Dashboard -.->|"manages via KServe"| CaikitTGIS
    DSPipelines -.->|"deploys models"| CaikitTGIS

    %% Styling
    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#e8744f,stroke:#333,color:#fff
    style KServe fill:#438dd5,stroke:#333,color:#fff
    style Knative fill:#438dd5,stroke:#333,color:#fff
    style Istio fill:#438dd5,stroke:#333,color:#fff
    style PrometheusUWM fill:#438dd5,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style Caikit fill:#7ed321,stroke:#333
    style CaikitNLP fill:#7ed321,stroke:#333
    style CaikitTGISBackend fill:#7ed321,stroke:#333
    style Python fill:#7ed321,stroke:#333
    style Poetry fill:#999,stroke:#333,color:#fff
    style UBI fill:#999,stroke:#333,color:#fff
    style Dashboard fill:#b8d4e3,stroke:#333
    style DSPipelines fill:#b8d4e3,stroke:#333
