graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(ServingRuntime Image)"]

    %% Core Python Dependencies (bundled in image)
    subgraph PythonDeps["Bundled Python Libraries"]
        Caikit["caikit 0.28.1<br/>(Core AI Runtime)"]
        CaikitNLP["caikit-nlp 0.5.14<br/>(NLP Module)"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39<br/>(TGIS Connector)"]
        Python["Python 3.11"]
    end

    CaikitTGIS -->|"bundles"| Caikit
    CaikitTGIS -->|"bundles"| CaikitNLP
    CaikitTGIS -->|"bundles"| CaikitTGISBackend
    CaikitTGIS -->|"runtime"| Python

    %% Base Image
    UBI["ubi9/ubi-minimal<br/>(Base Image)"]
    CaikitTGIS -->|"FROM"| UBI

    %% Co-located Runtime Dependency
    TGIS["TGIS Inference Server<br/>(kserve-container)"]
    CaikitTGIS -->|"gRPC localhost:8033"| TGIS

    %% Internal Platform Dependencies
    KServe["KServe<br/>(ServingRuntime CRD)"]
    Knative["Knative Serving<br/>(Autoscaling)"]
    Istio["Istio Service Mesh<br/>(mTLS, Ingress)"]

    CaikitTGIS -->|"deployed by"| KServe
    CaikitTGIS -->|"scaled by"| Knative
    CaikitTGIS -->|"traffic mgmt"| Istio

    %% Monitoring
    Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    Prometheus -->|"scrapes :8086"| CaikitTGIS

    %% External Services
    S3["S3-Compatible Storage<br/>(Model Artifacts)"]
    CaikitTGIS -.->|"HTTPS/443<br/>model download"| S3

    %% Build Dependencies
    Poetry["Poetry<br/>(build-time only)"]
    Konflux["Konflux CI/CD<br/>(Tekton Pipelines)"]
    CaikitTGIS -.->|"built with"| Poetry
    Konflux -.->|"builds image"| CaikitTGIS

    %% Platform Integration (consumed by)
    RHODSOp["rhods-operator<br/>(Platform Operator)"]
    RHODSOp -->|"registers runtime"| CaikitTGIS

    %% Styling
    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Caikit fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitNLP fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#5b9bd5,stroke:#333,color:#fff
    style Python fill:#5b9bd5,stroke:#333,color:#fff
    style UBI fill:#cc0000,stroke:#333,color:#fff
    style TGIS fill:#e67e22,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Knative fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#f39c12,stroke:#333,color:#fff
    style S3 fill:#95a5a6,stroke:#333,color:#fff
    style Poetry fill:#bdc3c7,stroke:#333
    style Konflux fill:#bdc3c7,stroke:#333
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
