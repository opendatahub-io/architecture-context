graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(Container Image)"]

    %% Python Library Dependencies (bundled in image)
    subgraph PythonLibs["Python Libraries (Bundled)"]
        Caikit["caikit 0.28.1"]
        CaikitNLP["caikit-nlp 0.5.14"]
        CaikitBackend["caikit-tgis-backend 0.1.39"]
        Python["Python 3.11"]
    end

    CaikitTGIS -->|"bundles"| Caikit
    CaikitTGIS -->|"bundles"| CaikitNLP
    CaikitTGIS -->|"bundles"| CaikitBackend
    CaikitTGIS -->|"runtime"| Python

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        UBI9["ubi9/ubi-minimal<br/>(base image)"]
        Poetry["poetry<br/>(dependency mgmt)"]
    end

    CaikitTGIS -->|"base image"| UBI9
    CaikitTGIS -->|"build-time"| Poetry

    %% Internal Platform Dependencies
    subgraph InternalDeps["Internal Platform (RHOAI)"]
        TGIS["TGIS<br/>(co-located container)"]
        KServe["KServe<br/>(ServingRuntime CRD)"]
        Knative["Knative Serving<br/>(autoscaling)"]
        Istio["Istio Service Mesh<br/>(mTLS + ingress)"]
    end

    CaikitTGIS -->|"gRPC localhost:8033"| TGIS
    CaikitTGIS -->|"CRD lifecycle"| KServe
    CaikitTGIS -->|"serverless scaling"| Knative
    CaikitTGIS -->|"sidecar mTLS"| Istio

    %% External Service Dependencies
    subgraph ExternalSvcs["External Services"]
        S3["S3 Storage<br/>(model artifacts)"]
        PVC["PVC<br/>(model mount)"]
    end

    CaikitTGIS -->|"HTTPS/443<br/>AWS IAM"| S3
    CaikitTGIS -->|"volume mount<br/>/mnt/models"| PVC

    %% Monitoring Integration
    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>(UWM)"]
        ServiceMonitor["ServiceMonitor"]
    end

    Prometheus -->|"HTTP/8086<br/>scrape"| CaikitTGIS
    ServiceMonitor -->|"configures"| Prometheus

    %% CI/CD
    subgraph CICD["CI/CD"]
        Konflux["Konflux<br/>(Tekton)"]
    end

    Konflux -->|"builds multi-arch image"| CaikitTGIS

    %% Platform Operator
    subgraph Operator["Platform Operator"]
        RHODS["rhods-operator"]
    end

    RHODS -->|"registers ServingRuntime"| KServe

    %% Styling
    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Knative fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style RHODS fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style Prometheus fill:#9b59b6,stroke:#333,color:#fff
    style ServiceMonitor fill:#9b59b6,stroke:#333,color:#fff
    style Konflux fill:#ee0000,stroke:#333,color:#fff
    style Caikit fill:#85c1e9,stroke:#333
    style CaikitNLP fill:#85c1e9,stroke:#333
    style CaikitBackend fill:#85c1e9,stroke:#333
    style Python fill:#85c1e9,stroke:#333
    style UBI9 fill:#999,stroke:#333,color:#fff
    style Poetry fill:#999,stroke:#333,color:#fff
