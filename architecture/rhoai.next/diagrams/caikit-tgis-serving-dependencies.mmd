graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(ServingRuntime)"]

    %% Python Library Dependencies
    subgraph PythonDeps["Python Dependencies"]
        Caikit["caikit 0.28.1"]
        CaikitNLP["caikit-nlp 0.5.14"]
        CaikitTGISBackend["caikit-tgis-backend 0.1.39"]
        Python["Python ~3.11"]
    end
    CaikitTGIS -->|"runtime library"| Caikit
    CaikitTGIS -->|"NLP module"| CaikitNLP
    CaikitTGIS -->|"TGIS connector"| CaikitTGISBackend
    CaikitTGIS -->|"interpreter"| Python

    %% Co-located Container Dependency
    TGIS["TGIS<br/>(text-generation-inference)"]
    CaikitTGIS -->|"gRPC/8033<br/>inference backend"| TGIS

    %% Internal Platform Dependencies
    KServe["KServe"]
    KServe -->|"orchestrates via CRDs<br/>ServingRuntime, InferenceService"| CaikitTGIS

    KnativeServing["Knative Serving"]
    CaikitTGIS -->|"autoscaling<br/>revision mgmt"| KnativeServing

    Istio["Istio Service Mesh"]
    CaikitTGIS -->|"mTLS sidecar<br/>PeerAuthentication"| Istio

    UWM["OpenShift User<br/>Workload Monitoring"]
    UWM -->|"Prometheus scrape<br/>HTTP/8086"| CaikitTGIS

    %% External Service Dependencies
    S3["S3-compatible Storage<br/>(MinIO / AWS S3)"]
    CaikitTGIS -->|"model artifacts<br/>HTTPS/443"| S3

    K8sAPI["Kubernetes API"]
    KServe -->|"manages resources"| K8sAPI

    HFHub["HuggingFace Hub<br/>(optional)"]
    CaikitTGIS -.->|"model download<br/>via convert.py"| HFHub

    %% Styling
    style CaikitTGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    style Caikit fill:#85c1e9,stroke:#333
    style CaikitNLP fill:#85c1e9,stroke:#333
    style CaikitTGISBackend fill:#85c1e9,stroke:#333
    style Python fill:#85c1e9,stroke:#333
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KnativeServing fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style UWM fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
