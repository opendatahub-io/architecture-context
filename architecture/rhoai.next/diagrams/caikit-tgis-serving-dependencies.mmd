graph LR
    CaikitTGIS["Caikit-TGIS-Serving<br/>(Container Image)"]

    %% Python Library Dependencies (bundled in image)
    subgraph PythonDeps["Python Dependencies (bundled)"]
        Caikit["caikit<br/>v0.28.1"]
        CaikitNLP["caikit-nlp<br/>v0.5.14"]
        CaikitTGISBackend["caikit-tgis-backend<br/>v0.1.39"]
    end

    CaikitTGIS -->|"runtime framework"| Caikit
    CaikitTGIS -->|"NLP tasks"| CaikitNLP
    CaikitTGIS -->|"TGIS connector"| CaikitTGISBackend

    %% Internal RHOAI Platform Dependencies
    CaikitTGIS -->|"CRD lifecycle mgmt"| KServe["KServe<br/>(ServingRuntime +<br/>InferenceService CRDs)"]
    CaikitTGIS -->|"co-located container"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    CaikitTGIS -->|"autoscaling & routing"| Knative["Knative Serving"]
    CaikitTGIS -->|"mTLS sidecar"| Istio["Istio Service Mesh"]
    CaikitTGIS -.->|"control plane"| Maistra["OpenShift Service Mesh<br/>(Maistra)"]
    CaikitTGIS -.->|"token auth (optional)"| Authorino["Authorino"]

    %% Observability
    Prometheus["Prometheus<br/>(User Workload Monitoring)"] -->|"scrapes metrics<br/>:8086"| CaikitTGIS

    %% External Services
    CaikitTGIS -->|"model storage<br/>HTTPS/443"| S3["S3-compatible Storage<br/>(MinIO / AWS S3)"]
    CaikitTGIS -->|"model mount<br/>/mnt/models/"| PVC["PersistentVolumeClaim"]
    CaikitTGIS -.->|"model download (dev)<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        Python["Python ~3.11"]
        Poetry["poetry (latest)"]
        UBI["UBI 9 Minimal<br/>(base image)"]
    end

    CaikitTGIS -.->|"build-time"| BuildDeps

