graph LR
    KubeflowCtrl["Kubeflow Notebook<br/>Controllers"]

    %% External Dependencies (Required)
    KubeflowCtrl -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.x"]
    KubeflowCtrl -->|"HTTPRoute, Gateway,<br/>ReferenceGrant CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    KubeflowCtrl -->|"Route, ImageStream,<br/>OAuthClient, Proxy CRDs"| OpenShiftAPI["OpenShift API<br/>v4.x"]
    KubeflowCtrl -->|"auth sidecar<br/>(runtime injection)"| KubeRBACProxy["kube-rbac-proxy<br/>(container image)"]
    KubeflowCtrl -->|"TLS cert provisioning<br/>(annotation-based)"| ServiceCA["OpenShift<br/>Service CA"]

    %% External Dependencies (Optional)
    KubeflowCtrl -.->|"VirtualService<br/>(USE_ISTIO=true)"| Istio["Istio<br/>networking v1alpha3"]

    %% Internal RHOAI Dependencies
    KubeflowCtrl -->|"HTTPRoute parentRef<br/>(ingress entry point)"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    KubeflowCtrl -->|"CRD Watch + Secret Read<br/>(Elyra pipeline config)"| DSPA["DSPA<br/>(Data Science Pipelines)"]
    KubeflowCtrl -->|"ClusterRole ref +<br/>RoleBinding creation"| MLflow["MLflow Operator"]
    KubeflowCtrl -->|"ConfigMap mount<br/>(feature store config)"| Feast["Feast"]
    KubeflowCtrl -->|"ImageStream API<br/>(image resolution)"| ImageRegistry["OpenShift<br/>Image Registry"]
    KubeflowCtrl -->|"CRD Read<br/>(proxy settings injection)"| ClusterProxy["OpenShift<br/>Cluster Proxy"]

    %% Components that integrate with Kubeflow
    Dashboard["ODH Dashboard"] -->|"creates Notebook CRs<br/>(UI management)"| KubeflowCtrl
    RHODSOp["rhods-operator"] -->|"platform webhooks<br/>(connection, hwprofile)"| KubeflowCtrl

    %% Runtime dependencies
    KubeflowCtrl -->|"CR, resource, RBAC<br/>management"| K8sAPI["Kubernetes<br/>API Server"]

    %% CA Certificate ConfigMaps
    KubeflowCtrl -.->|"CA bundle mounts"| CACerts["CA ConfigMaps<br/>(odh-trusted-ca-bundle,<br/>kube-root-ca.crt,<br/>openshift-service-ca.crt)"]

    %% Styling
    style KubeflowCtrl fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style KubeRBACProxy fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
