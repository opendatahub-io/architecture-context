    style OSCtrlCommon fill:#999,stroke:#333,color:#fff
    style DSPAPI fill:#999,stroke:#333,color:#fff

    %% Internal platform deps
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff

    %% Consumers
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff
