    KubeflowNB -->|"TLS cert provisioning<br/>(annotation-based)"| ServiceCA["OpenShift<br/>Service CA"]

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard"] -->|"UI management"| KubeflowNB
    Pipelines["Data Science Pipelines"] -->|"auto deploy"| KubeflowNB

    %% Shared CRD
    KubeflowNB -->|"VirtualService<br/>(Kubeflow overlay only)"| Istio["Istio Control Plane<br/>(optional)"]

    %% CA Bundle integration
    KubeflowNB -->|"CA bundle merging"| CABundles["CA Bundle ConfigMaps<br/>odh-trusted-ca-bundle<br/>kube-root-ca.crt<br/>openshift-service-ca.crt"]

    %% Feast integration
    KubeflowNB -.->|"label-driven<br/>ConfigMap mount"| Feast["Feast Integration"]

    %% Prometheus scrape
    Prometheus["Prometheus"] -->|"metrics scrape<br/>8080/TCP"| KubeflowNB

