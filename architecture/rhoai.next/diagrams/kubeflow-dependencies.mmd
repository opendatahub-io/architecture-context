graph LR
    Kubeflow["Kubeflow Notebook<br/>Controllers<br/>(dual-controller)"]

    %% External Dependencies (Required)
    Kubeflow -->|"core platform<br/>6443/TCP HTTPS"| K8s["Kubernetes 1.33+<br/>(OpenShift 4.19)"]
    Kubeflow -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.21.0"]
    Kubeflow -->|"HTTPRoute, ReferenceGrant,<br/>Gateway CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    Kubeflow -->|"ImageStream, Route,<br/>OAuthClient, Proxy APIs"| OpenShiftAPI["OpenShift API<br/>release-4.19"]

    %% External Dependencies (Optional)
    Kubeflow -.->|"pipeline integration<br/>(optional)"| DSPAOperator["data-science-pipelines-<br/>operator v1.1.1+"]

    %% Internal Platform Dependencies
    Kubeflow -->|"Gateway CR hostname<br/>for HTTPRoute parentRef"| GatewayCtrl["rhods-operator /<br/>Gateway Controller"]
    Kubeflow -->|"DSPA CR watch<br/>S3 config + secret sync"| DSPA["Data Science<br/>Pipelines (DSPA)"]
    Kubeflow -->|"ClusterRole binding<br/>mlflow-integration"| MLflow["MLflow Operator"]
    Kubeflow -.->|"ConfigMap mount<br/>feast-config"| Feast["Feast"]
    Kubeflow -->|"image resolution<br/>runtime metadata"| ImageStreams["OpenShift<br/>ImageStreams"]
    Kubeflow -->|"webhook + proxy<br/>TLS certificates"| ServiceCA["OpenShift<br/>Service CA"]

    %% Integration Points (components that depend on Kubeflow)
    Dashboard["RHOAI Dashboard"] -->|"UI notebook mgmt"| Kubeflow
    RhodsOp["rhods-operator"] -->|"connection-notebook<br/>+ hardwareprofile webhooks"| Kubeflow

    %% Per-Notebook Runtime Dependencies
    Kubeflow -->|"user auth<br/>TokenReview + SAR"| KubeRBACProxy["kube-rbac-proxy<br/>(injected sidecar)"]
    Kubeflow -->|"notebook ingress<br/>443/TCP HTTPS"| Gateway["data-science-gateway<br/>(Gateway API)"]
    Kubeflow -->|"culling: polls<br/>/api/kernels, /api/terminals"| JupyterAPI["Notebook Jupyter API<br/>8888/TCP HTTP"]

    %% Optional Istio
    Kubeflow -.->|"VirtualService<br/>(when USE_ISTIO=true)"| Istio["Istio<br/>(optional)"]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Required
    style K8s fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff

    %% External Optional
    style DSPAOperator fill:#bbb,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Istio fill:#bbb,stroke:#333,color:#fff,stroke-dasharray: 5 5

    %% Internal Platform
    style GatewayCtrl fill:#7ed321,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Feast fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff

    %% Runtime
    style KubeRBACProxy fill:#f5a623,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style JupyterAPI fill:#f5a623,stroke:#333,color:#fff
