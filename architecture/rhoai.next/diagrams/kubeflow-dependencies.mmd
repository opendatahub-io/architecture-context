graph LR
    Kubeflow["Kubeflow Notebook Controller<br/>(notebook-controller +<br/>odh-notebook-controller)"]

    %% External Dependencies (libraries / frameworks)
    subgraph ExtDeps["External Dependencies"]
        ControllerRuntime["controller-runtime<br/>v0.23.3"]
        K8sAPI["k8s.io/api<br/>v0.35.x"]
        GatewayAPI["gateway-api<br/>v1.2.1"]
        OpenshiftAPI["openshift/api<br/>release-4.19"]
        CtrlRuntimeCommon["openshift/<br/>controller-runtime-common"]
        DSPAAPI["data-science-pipelines-operator/api<br/>v1.1.1"]
        Prometheus["prometheus/client_golang<br/>v1.23.2"]
    end

    Kubeflow -->|"controller framework"| ControllerRuntime
    Kubeflow -->|"K8s types"| K8sAPI
    Kubeflow -->|"HTTPRoute, ReferenceGrant,<br/>Gateway types"| GatewayAPI
    Kubeflow -->|"Route, ImageStream,<br/>OAuthClient, Config types"| OpenshiftAPI
    Kubeflow -->|"TLS security profile"| CtrlRuntimeCommon
    Kubeflow -->|"DSPA CRD types"| DSPAAPI
    Kubeflow -->|"metrics"| Prometheus

    %% Internal Platform Dependencies
    subgraph IntDeps["Internal RHOAI Dependencies"]
        RhodsOperator["rhods-operator /<br/>opendatahub-operator"]
        DSGateway["data-science-gateway<br/>(Gateway CR)"]
        DSPA["DataSciencePipelinesApplication<br/>(DSPA)"]
        MLflowOp["MLflow Operator"]
        FeastComp["Feast"]
        ImageStreams["OpenShift ImageStreams"]
        TrustedCA["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    end

    RhodsOperator -->|"deploys &<br/>configures"| Kubeflow
    Kubeflow -->|"HTTPRoute parent ref;<br/>hostname extraction"| DSGateway
    Kubeflow -->|"Elyra pipeline config<br/>extraction"| DSPA
    Kubeflow -->|"ClusterRole check;<br/>RoleBinding creation"| MLflowOp
    Kubeflow -->|"ConfigMap mount<br/>per notebook"| FeastComp
    Kubeflow -->|"image tag →<br/>docker digest"| ImageStreams
    Kubeflow -->|"CA cert aggregation<br/>into workbench bundle"| TrustedCA

    %% Cluster Services
    subgraph ClusterSvc["Cluster Services"]
        K8sAPIServer["Kubernetes API Server"]
        ServiceCA["OpenShift Service CA"]
        ImgRegistry["OpenShift Image Registry"]
    end

    Kubeflow -->|"CRUD resources<br/>HTTPS/443"| K8sAPIServer
    Kubeflow -->|"resolve images<br/>HTTPS/5000"| ImgRegistry
    ServiceCA -.->|"auto-provision<br/>TLS certs"| Kubeflow

    %% Components that integrate WITH kubeflow
    subgraph Consumers["Consumers / Integrators"]
        Dashboard["ODH Dashboard"]
        PlatformWebhooks["Platform Webhooks<br/>(connection-notebook,<br/>hardwareprofile-injector)"]
    end

    Dashboard -->|"UI notebook<br/>management"| Kubeflow
    PlatformWebhooks -.->|"additional mutation<br/>on Notebook CRs"| Kubeflow

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OpenshiftAPI fill:#999,stroke:#333,color:#fff
    style CtrlRuntimeCommon fill:#999,stroke:#333,color:#fff
    style DSPAAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style MLflowOp fill:#7ed321,stroke:#333,color:#fff
    style FeastComp fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style K8sAPIServer fill:#f5a623,stroke:#333,color:#fff
    style ServiceCA fill:#f5a623,stroke:#333,color:#fff
    style ImgRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#3498db,stroke:#333,color:#fff
    style PlatformWebhooks fill:#3498db,stroke:#333,color:#fff
