graph LR
    Kubeflow["Kubeflow Notebook<br/>Controllers<br/>(Dual-Controller)"]

    %% External Dependencies
    Kubeflow -->|"core platform<br/>6443/TCP HTTPS"| K8s["Kubernetes 1.33+<br/>(OpenShift 4.19)"]
    Kubeflow -->|"controller framework"| CR["controller-runtime<br/>v0.21.0"]
    Kubeflow -->|"HTTPRoute, ReferenceGrant,<br/>Gateway CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    Kubeflow -->|"ImageStream, Route,<br/>Proxy APIs"| OpenShiftAPI["OpenShift API<br/>release-4.19"]

    %% Internal RHOAI Dependencies
    Kubeflow -->|"reads Gateway CR<br/>hostname for HTTPRoutes"| RhodsOperator["rhods-operator /<br/>Gateway Controller"]
    Kubeflow -->|"reads DSPA CR,<br/>creates pipeline secret"| DSPA["data-science-pipelines-<br/>operator v1.1.1+"]
    Kubeflow -->|"ClusterRole bind<br/>per notebook"| MLflow["MLflow Operator"]
    Kubeflow -->|"ConfigMap mount<br/>/opt/app-root/src/feast-config"| Feast["Feast"]
    Kubeflow -->|"image resolution<br/>from ImageStream tags"| ImageStreams["OpenShift<br/>ImageStreams"]
    Kubeflow -->|"TLS cert injection<br/>webhook + kube-rbac-proxy"| ServiceCA["OpenShift<br/>Service CA"]

    %% Components that integrate WITH Kubeflow
    Dashboard["RHOAI Dashboard"] -->|"creates/manages<br/>Notebook CRs"| Kubeflow
    Pipelines["Data Science<br/>Pipelines"] -->|"pipeline-enabled<br/>notebooks"| Kubeflow

    %% Auth sidecar
    Kubeflow -->|"sidecar injection<br/>TokenReview + SAR"| KubeRBACProxy["kube-rbac-proxy<br/>(auth sidecar)"]
    KubeRBACProxy -->|"auth verification<br/>6443/TCP HTTPS"| K8s

    %% External Services
    Kubeflow -->|"API server<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]

