graph LR
    Kubeflow["Kubeflow Notebook<br/>Controller"]

    %% External Dependencies (required)
    Kubeflow -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    Kubeflow -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.35.x"]
    Kubeflow -->|"HTTPRoute, ReferenceGrant"| GatewayAPI["gateway-api<br/>v1.2.1"]
    Kubeflow -->|"Route, Image, OAuth,<br/>Config API types"| OpenShiftAPI["openshift/api<br/>release-4.19"]
    Kubeflow -->|"TLS security profile<br/>watcher"| OSCtrlCommon["openshift/controller-<br/>runtime-common"]

    %% External Dependencies (optional)
    Kubeflow -.->|"DSPA CRD types<br/>(optional)"| DSPAPI["data-science-pipelines-<br/>operator API v1.1.1"]

    %% Internal Platform Dependencies
    Kubeflow -->|"deploys this component<br/>via kustomize"| PlatformOp["rhods-operator /<br/>opendatahub-operator"]
    Kubeflow -->|"parent gateway for<br/>HTTPRoutes"| Gateway["data-science-gateway<br/>(Gateway API)"]
    Kubeflow -->|"pipeline API endpoint<br/>& S3 config"| DSPA["Data Science Pipelines<br/>Operator"]
    Kubeflow -.->|"MLflow ClusterRole<br/>binding"| MLflow["MLflow Operator"]
    Kubeflow -->|"TLS cert generation<br/>for kube-rbac-proxy"| ServiceCA["OpenShift<br/>Service CA"]
    Kubeflow -->|"custom CA certs<br/>for trust chain"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    Kubeflow -->|"image resolution &<br/>runtime metadata"| ImageStreams["OpenShift<br/>ImageStreams"]
    Kubeflow -->|"auth/authz sidecar<br/>injection"| KubeRBACProxy["kube-rbac-proxy<br/>(sidecar image)"]

    %% Integration Points (consumed by others)
    Dashboard["ODH Dashboard"] -->|"reads update-pending<br/>annotation"| Kubeflow
    Pipelines["Data Science<br/>Pipelines"] -.->|"pipeline secret<br/>mounted by"| Kubeflow
    FeastOp["Feast Operator"] -.->|"config mounted<br/>by"| Kubeflow

    %% External Services
    Kubeflow -->|"all CRUD operations<br/>6443/TCP"| K8sAPIServer["Kubernetes API<br/>Server"]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
