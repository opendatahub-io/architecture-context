graph LR
    Kubeflow["Kubeflow Notebook<br/>Controllers"]

    %% External Dependencies
    Kubeflow -->|"API server<br/>HTTPS/443"| K8sAPI["Kubernetes 1.33+"]
    Kubeflow -->|"controller framework"| CR["controller-runtime 0.21.0"]
    Kubeflow -->|"Route, ImageStream,<br/>Proxy, OAuth APIs"| OpenShiftAPI["OpenShift API<br/>release-4.19"]
    Kubeflow -->|"HTTPRoute, ReferenceGrant,<br/>Gateway CRDs"| GatewayAPI["Gateway API 1.2.1"]
    Kubeflow -->|"metrics export<br/>HTTP/8080"| PromClient["Prometheus<br/>client_golang 1.23.2"]
    Kubeflow -.->|"tracing (optional)"| OTel["OpenTelemetry 1.40.0"]

    %% Internal Platform Dependencies
    Kubeflow -->|"deployed via<br/>component manifests"| Operator["rhods-operator /<br/>opendatahub-operator"]
    Kubeflow -->|"HTTPRoute parentRef<br/>ingress routing"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    Kubeflow -->|"traffic forwarding<br/>data plane"| Envoy["Envoy proxy"]
    Kubeflow -->|"ClusterRole reference<br/>notebook SA binding"| MLflow["MLflow Operator"]
    Kubeflow -->|"CRD watch +<br/>Secret sync"| DSP["Data Science<br/>Pipelines Operator"]
    Kubeflow -->|"ImageStream tag→digest<br/>resolution"| ImageReg["OpenShift<br/>Image Registry"]
    Kubeflow -->|"TLS cert provisioning<br/>annotation-based"| ServiceCA["OpenShift<br/>Service CA"]

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard"] -->|"creates Notebook CRs<br/>via K8s API"| Kubeflow
    Pipelines["Data Science Pipelines"] -.->|"Elyra runtime config"| Kubeflow
    Feast["Feast"] -.->|"label-driven<br/>ConfigMap mount"| Kubeflow
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP/8080"| Kubeflow

    %% Optional
    Kubeflow -.->|"VirtualService CRUD<br/>(Kubeflow overlay only)"| Istio["Istio Control Plane"]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style OTel fill:#cccccc,stroke:#999,stroke-dasharray: 5 5

    %% Internal RHOAI deps
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style Envoy fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style ImageReg fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff

    %% Inbound integrations
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Feast fill:#7ed321,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Prometheus fill:#f5a623,stroke:#333,color:#fff

    %% Optional
    style Istio fill:#cccccc,stroke:#999,stroke-dasharray: 5 5
