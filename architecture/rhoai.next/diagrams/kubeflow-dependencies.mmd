graph LR
    Kubeflow["Kubeflow Notebook<br/>Controllers"]

    %% External Dependencies (Required)
    Kubeflow -->|"core platform<br/>6443/TCP HTTPS"| K8s["Kubernetes 1.33+<br/>(OpenShift 4.19)"]
    Kubeflow -->|"controller framework"| CR["controller-runtime<br/>v0.21.0"]
    Kubeflow -->|"HTTPRoute, ReferenceGrant,<br/>Gateway CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    Kubeflow -->|"ImageStream, Route,<br/>OAuthClient, Proxy"| OpenShift["OpenShift API<br/>release-4.19"]

    %% External Dependencies (Optional)
    Kubeflow -.->|"pipeline integration<br/>(optional)"| DSPAAPI["DSPA CRD<br/>v1.1.1+"]

    %% Internal Platform Dependencies
    Kubeflow -->|"reads Gateway CR hostname<br/>for HTTPRoute parentRef"| RhodsGW["rhods-operator /<br/>Gateway Controller"]
    Kubeflow -->|"reads DSPA CR,<br/>creates Elyra secret"| DSPA["Data Science<br/>Pipelines Operator"]
    Kubeflow -->|"binds mlflow-integration<br/>ClusterRole"| MLflow["MLflow Operator"]
    Kubeflow -.->|"mounts feast-config<br/>ConfigMap"| Feast["Feast"]
    Kubeflow -->|"resolves notebook images,<br/>runtime metadata"| ImageStreams["OpenShift<br/>ImageStreams"]
    Kubeflow -->|"TLS certs for webhook<br/>and kube-rbac-proxy"| ServiceCA["OpenShift<br/>Service CA"]

    %% Components that integrate WITH Kubeflow
    Dashboard["ODH Dashboard"] -->|"UI management<br/>of notebooks"| Kubeflow
    Pipelines["Data Science<br/>Pipelines"] -.->|"Elyra pipeline<br/>runtime config"| Kubeflow

    %% External Services
    Kubeflow -->|"all CRUD ops<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    Kubeflow -->|"TokenReview, SAR<br/>(via kube-rbac-proxy)"| AuthAPI["K8s Auth<br/>API"]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8s fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff
    style DSPAAPI fill:#bbb,stroke:#333,color:#333,stroke-dasharray: 5 5

    %% Internal ODH
    style RhodsGW fill:#7ed321,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Feast fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff

    %% Integrators
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style AuthAPI fill:#f5a623,stroke:#333,color:#fff
