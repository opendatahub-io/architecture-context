    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Feast fill:#7ed321,stroke:#333,color:#fff
    style ImageRegistry fill:#7ed321,stroke:#333,color:#fff
    style ClusterProxy fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
