graph LR
    MLMD["ML Metadata<br/>gRPC Server"]

    %% External Build/Runtime Dependencies
    MLMD -->|"gRPC framework"| gRPC["gRPC C++ 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protocol Buffers 3.21.12"]
    MLMD -->|"utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL"]

    %% Database Backends
    MLMD -->|"primary storage<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"alt storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 12.17+"]
    MLMD -.->|"embedded (optional)"| SQLite["SQLite 3.39.2"]

    %% Internal Platform Consumers (depend on MLMD)
    KFP["Kubeflow Pipelines<br/>ml-pipeline-api-server"] -->|"gRPC client<br/>8080/TCP"| MLMD
    KFPSDK["KFP SDK<br/>(Python)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    DSP["Data Science Pipelines<br/>(RHOAI)"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Build Dependencies
    MLMD -.->|"build system"| Bazel["Bazel 5.3.0+"]
    MLMD -.->|"CLI flags"| gflags["gflags"]
    MLMD -.->|"logging"| glog["glog"]

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Abseil fill:#999,stroke:#333,color:#fff
    style ZetaSQL fill:#999,stroke:#333,color:#fff
    style BoringSSL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#e8e8e8,stroke:#333
    style KFP fill:#7ed321,stroke:#333,color:#fff
    style KFPSDK fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Bazel fill:#e8e8e8,stroke:#333,stroke-dasharray:5 5
    style gflags fill:#e8e8e8,stroke:#333,stroke-dasharray:5 5
    style glog fill:#e8e8e8,stroke:#333,stroke-dasharray:5 5
