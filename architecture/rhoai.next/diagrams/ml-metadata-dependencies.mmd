graph LR
    MLMD["ML Metadata<br/>(MLMD gRPC Server)"]

    %% External Build/Runtime Dependencies
    MLMD -->|"gRPC framework"| gRPC["gRPC C++ 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protocol Buffers 3.21.12"]
    MLMD -->|"utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL"]

    %% Database Backend Dependencies
    MLMD -->|"primary backend<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"alternative backend<br/>5432/TCP"| PostgreSQL["PostgreSQL 12.17+"]
    MLMD -.->|"embedded backend"| SQLite["SQLite 3.39.2"]

    %% Internal RHOAI Consumers
    KFP["Kubeflow Pipelines<br/>(ml-pipeline-api-server)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    KFPSDK["KFP SDK (Python)"] -->|"gRPC via ml-metadata lib<br/>8080/TCP"| MLMD
    DSP["Data Science Pipelines<br/>(RHOAI)"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Deployment Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys & configures"| MLMD

    %% Build Dependencies
    MLMD -.->|"build system"| Bazel["Bazel 5.3.0+"]
    MLMD -.->|"CLI flags"| gflags["gflags"]
    MLMD -.->|"logging"| glog["glog"]

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style gRPC fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333
    style Abseil fill:#999,stroke:#333
    style ZetaSQL fill:#999,stroke:#333
    style BoringSSL fill:#999,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333
    style KFP fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style RHODSOp fill:#7ed321,stroke:#333
    style Bazel fill:#ccc,stroke:#333
    style gflags fill:#ccc,stroke:#333
    style glog fill:#ccc,stroke:#333
