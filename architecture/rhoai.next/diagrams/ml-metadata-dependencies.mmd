graph LR
    MLMD["ML Metadata<br/>(MLMD gRPC Server)"]

    %% Core C++ Dependencies
    MLMD -->|"server framework"| gRPC["gRPC (C++) 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protobuf 3.21.12"]
    MLMD -->|"utilities"| Abseil["Abseil (C++)"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL<br/>(NOT FIPS mode)"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL"]

    %% Database Backends
    MLMD -->|"metadata storage<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 12.17"]
    MLMD -->|"embedded dev DB"| SQLite["SQLite 3.39.2"]

    %% Build & Runtime
    MLMD -->|"CLI flags"| gflags["gflags"]
    MLMD -->|"logging"| glog["glog"]

    %% Internal RHOAI Platform Dependencies (consumers)
    KFP["Kubeflow Pipelines<br/>Backend"] -->|"gRPC client<br/>8080/TCP"| MLMD
    DSP["Data Science<br/>Pipelines"] -->|"gRPC client<br/>8080/TCP"| MLMD
    DSPOperator["DSP Operator"] -.->|"deploys &<br/>configures"| MLMD

    %% Python Client Dependencies
    subgraph PythonClient["Python Client (ml_metadata)"]
        pybind11["pybind11 2.10.1"]
        grpcio["grpcio (Python)"]
        abslpy["absl-py"]
        protobufpy["protobuf (Python)"]
    end

    MLMD -.->|"Python bindings"| PythonClient

    %% External consumers
    KFPSDK["KFP Python SDK"] -->|"gRPC/pybind11<br/>8080/TCP"| MLMD
    TFX["TFX<br/>(TensorFlow Extended)"] -->|"gRPC/pybind11<br/>8080/TCP"| MLMD

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style gRPC fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333
    style Abseil fill:#999,stroke:#333
    style BoringSSL fill:#999,stroke:#333
    style ZetaSQL fill:#999,stroke:#333
    style gflags fill:#999,stroke:#333
    style glog fill:#999,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333
    style KFP fill:#7ed321,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style DSPOperator fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style TFX fill:#b8e986,stroke:#333
    style pybind11 fill:#6baed6,stroke:#333
    style grpcio fill:#6baed6,stroke:#333
    style abslpy fill:#6baed6,stroke:#333
    style protobufpy fill:#6baed6,stroke:#333
