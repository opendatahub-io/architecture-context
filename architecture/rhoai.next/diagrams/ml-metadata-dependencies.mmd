graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% Build-time Dependencies
    MLMD -->|"build system"| Bazel["Bazel 5.x"]
    MLMD -->|"gRPC framework"| gRPC["gRPC C++<br/>(bundled via Bazel)"]
    MLMD -->|"serialization"| Protobuf["Protocol Buffers<br/>(bundled via Bazel)"]
    MLMD -->|"utility libs"| Abseil["Abseil C++<br/>(bundled via Bazel)"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL<br/>(bundled via Bazel)"]

    %% Runtime Database Dependencies
    MLMD -->|"metadata storage<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"metadata storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLMD -.->|"dev/test only<br/>in-process"| SQLite["SQLite"]

    %% Internal ODH/RHOAI Dependencies
    DSP["Data Science Pipelines<br/>(DSP)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    PipelinesUI["Kubeflow Pipelines UI"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Platform Dependencies
    Operator["Platform Operator<br/>(rhods-operator /<br/>opendatahub-operator)"] -->|"deploys &<br/>configures"| MLMD
    CertManager["cert-manager"] -.->|"optional TLS certs"| MLMD

    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Bazel fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Abseil fill:#999,stroke:#333,color:#fff
    style ZetaSQL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#e8e8e8,stroke:#333
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style PipelinesUI fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#9b59b6,stroke:#333,color:#fff
    style CertManager fill:#9b59b6,stroke:#333,color:#fff
