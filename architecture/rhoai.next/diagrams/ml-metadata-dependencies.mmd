graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% Build-Time Dependencies
    MLMD -->|build system| Bazel["Bazel 5.x<br/>(Build-Time)"]
    MLMD -->|server framework| gRPC["gRPC C++<br/>(bundled via Bazel)"]
    MLMD -->|serialization| Protobuf["Protocol Buffers<br/>(bundled via Bazel)"]
    MLMD -->|utilities| Abseil["Abseil C++<br/>(bundled via Bazel)"]
    MLMD -->|CLI flags| gflags["gflags<br/>(bundled via Bazel)"]
    MLMD -->|logging| glog["glog<br/>(bundled via Bazel)"]
    MLMD -->|SQL parsing| ZetaSQL["ZetaSQL<br/>(bundled via Bazel)"]

    %% Runtime Database Dependencies
    MLMD -->|"primary backend<br/>3306/TCP"| MySQL["MySQL / MariaDB<br/>(libmysqlclient)"]
    MLMD -->|"alt backend<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>(libpq)"]
    MLMD -->|"dev/testing<br/>in-process"| SQLite["SQLite"]

    %% Internal RHOAI Consumers (depend on MLMD)
    DSP["Data Science Pipelines<br/>(gRPC client)"] -->|"metadata CRUD<br/>gRPC/8080"| MLMD
    KFUI["Kubeflow Pipelines UI<br/>(gRPC client)"] -->|"lineage queries<br/>gRPC/8080"| MLMD

    %% Platform Deployer
    Operator["Platform Operator<br/>(rhods-operator)"] -.->|deploys & configures| MLMD

    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Bazel fill:#999,stroke:#333
    style gRPC fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333
    style Abseil fill:#999,stroke:#333
    style gflags fill:#999,stroke:#333
    style glog fill:#999,stroke:#333
    style ZetaSQL fill:#999,stroke:#333
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style KFUI fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
