graph LR
    MLMD["ML Metadata<br/>(MLMD gRPC Server)"]

    %% Build Dependencies
    MLMD -->|"RPC framework"| gRPC["gRPC 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protocol Buffers 3.21.12"]
    MLMD -->|"C++ utilities"| Abseil["Abseil C++ 20230802.0"]
    MLMD -->|"SQL filter parsing"| ZetaSQL["ZetaSQL<br/>(patched f764f4e)"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL 648cbaf"]
    MLMD -->|"CLI flags"| gflags["gflags"]
    MLMD -->|"logging"| glog["glog"]

    %% Database Backends
    MLMD -->|"production storage<br/>3306/TCP"| MySQL["MySQL / MariaDB<br/>(libmysqlclient)"]
    MLMD -->|"alt production storage"| PostgreSQL["PostgreSQL 12.17<br/>(libpq)"]
    MLMD -->|"dev/test storage"| SQLite["SQLite 3.39.2"]

    %% Internal RHOAI Dependencies
    DSP["Data Science Pipelines<br/>(DSP)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    TFX["TFX / Kubeflow Pipelines"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Build System
    MLMD -.->|"build system"| Bazel["Bazel 5.3.0"]

