graph LR
    MLMD["MLMD gRPC Server<br/>(metadata_store_server)"]

    %% Internal RHOAI Dependencies (consumers)
    DSP["Data Science Pipelines<br/>(DSP)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    KFUI["Kubeflow Pipelines UI"] -->|"gRPC client<br/>8080/TCP"| MLMD

    %% Database Backends
    MLMD -->|"MySQL protocol<br/>3306/TCP"| MySQL["MySQL / MariaDB"]
    MLMD -->|"PG protocol<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    MLMD -->|"in-process"| SQLite["SQLite<br/>(dev/test)"]

    %% Platform Dependencies
    PlatformOp["Platform Operator<br/>(rhods-operator /<br/>opendatahub-operator)"] -->|"deploys &<br/>manages"| MLMD

    %% Build-Time Dependencies
    subgraph BuildDeps["Build-Time Dependencies (Bazel)"]
        direction TB
        gRPCLib["gRPC C++"]
        Protobuf["Protocol Buffers"]
        Abseil["Abseil C++"]
        ZetaSQL["ZetaSQL"]
        gflags["gflags"]
        glog["glog"]
    end

    MLMD -.->|"build-time<br/>(Bazel WORKSPACE)"| BuildDeps

    %% Client Library
    MLMD -.->|"provides API for"| PythonLib["ml-metadata<br/>Python Library<br/>(PyPI)"]

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style KFUI fill:#7ed321,stroke:#333,color:#fff
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style SQLite fill:#f5a623,stroke:#333,color:#fff
    style PythonLib fill:#50e3c2,stroke:#333,color:#333
    style gRPCLib fill:#e8e8e8,stroke:#666
    style Protobuf fill:#e8e8e8,stroke:#666
    style Abseil fill:#e8e8e8,stroke:#666
    style ZetaSQL fill:#e8e8e8,stroke:#666
    style gflags fill:#e8e8e8,stroke:#666
    style glog fill:#e8e8e8,stroke:#666
