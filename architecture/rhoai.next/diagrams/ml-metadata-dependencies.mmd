graph LR
    MLMD["ML Metadata<br/>(MLMD gRPC Server)"]

    %% Internal RHOAI Dependencies
    MLMD -->|"gRPC client<br/>8080/TCP"| DSP["Data Science Pipelines<br/>(DSP)"]

    %% Core Build/Runtime Dependencies
    MLMD -->|"RPC framework"| gRPC["gRPC 1.46.3"]
