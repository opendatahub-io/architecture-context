graph LR
    AIGO["ai-gateway-operator<br/>(Module Operator)"]

    %% Platform Dependencies (Internal ODH)
    AIGO -->|"module handler<br/>deploys this operator"| ODHOp["opendatahub-operator<br/>v2.8.1"]
    AIGO -->|"shared reconciler<br/>framework"| ODHPkg["opendatahub-operator/v2<br/>pkg/controller/actions"]

    %% Sub-Components (Internal, Deployed by this operator)
    AIGO -->|"deploys when<br/>batchGateway=Managed"| BatchOp["llm-d-batch-gateway<br/>-operator"]
    BatchOp -->|"deploys"| BatchAPI["llm-d-batch-gateway<br/>-apiserver"]
    BatchOp -->|"deploys"| BatchProc["llm-d-batch-gateway<br/>-processor"]
    BatchOp -->|"deploys"| BatchGC["llm-d-batch-gateway<br/>-gc"]

    %% External Dependencies (Go modules)
    AIGO -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.24.1"]
    AIGO -->|"CLI framework"| Cobra["spf13/cobra<br/>v1.10.2"]
    AIGO -->|"config loading"| Viper["spf13/viper<br/>v1.21.0"]
    AIGO -->|"version parsing"| Semver["blang/semver/v4<br/>v4.0.0"]
    AIGO -->|"OLM types"| OFApi["operator-framework/api<br/>v0.42.0"]

    %% Indirect Dependencies
    BatchOp -.->|"indirect"| GatewayAPI["gateway-api<br/>v1.3.0"]
    BatchOp -.->|"indirect"| ManifestKit["k8s-manifest-kit<br/>v0.2.1+"]
    BatchOp -.->|"indirect"| Helm["helm/v4<br/>v4.1.1"]

    %% Runtime Infrastructure Dependencies
    AIGO -->|"CRD CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    BatchOp -->|"CRD interaction"| CertManager["cert-manager"]
    BatchOp -->|"HTTPRoute CRs"| GwAPI2["Gateway API<br/>(runtime)"]
    BatchOp -->|"monitoring CRs"| Prometheus["Prometheus /<br/>monitoring.coreos.com"]

