graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Console User"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP → 9091/TCP<br/>Reencrypt TLS<br/>OAuth Proxy"]
        AlertRoute["Alertmanager Route<br/>443/TCP → 10443/TCP<br/>Reencrypt TLS<br/>OAuth Proxy"]
        DashRoute["RHODS Dashboard Route<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS<br/>OpenShift OAuth"]
    end

    subgraph NS_Monitoring["Namespace: redhat-ods-monitoring"]
        direction TB
        Prom["Prometheus<br/>9091/TCP HTTPS<br/>SA: prometheus<br/>OAuth Proxy sidecar<br/>TLS: service-ca cert"]
        AlertMgr["Alertmanager<br/>443→10443/TCP HTTPS<br/>OAuth Proxy sidecar<br/>TLS: service-ca cert"]
        Blackbox["Blackbox Exporter<br/>9114/TCP HTTPS<br/>OAuth Proxy sidecar<br/>insecure_skip_verify: true"]
    end

    subgraph NS_Apps["Namespace: redhat-ods-applications"]
        direction TB
        Dashboard["rhods-dashboard<br/>8443/TCP HTTPS TLS"]
        NBC["odh-notebook-controller<br/>8080/TCP HTTP"]
        KFNBC["notebook-controller (KF)<br/>8080/TCP HTTP"]
        ModelCtrl["odh-model-controller<br/>8080/TCP HTTP"]
        ModelMesh["modelmesh-controller<br/>8080/TCP HTTP"]
        DSPOSvc["data-science-pipelines-operator<br/>8080/TCP HTTP"]
        DSPipeline["ds-pipeline-*<br/>8888/TCP HTTP"]
    end

    subgraph NS_Operator["Namespace: redhat-ods-operator"]
        OperatorMetrics["rhods-operator-metrics<br/>8383/TCP HTTP"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["OpenShift API Server<br/>443/TCP HTTPS TLS<br/>SA Token Auth"]
        ClusterProm["OpenShift Prometheus<br/>openshift-monitoring<br/>9091/TCP HTTPS TLS<br/>Bearer Token Auth"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Managed Only)"]
        PagerDuty["PagerDuty API<br/>443/TCP HTTPS TLS<br/>Service Key Auth"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS TLS<br/>URL Token Auth"]
        SMTP["SMTP Server<br/>Configured/TCP<br/>STARTTLS<br/>Username/Password"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| PromRoute
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| AlertRoute
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| DashRoute

    %% Ingress to Services
    PromRoute -->|"HTTPS/9091<br/>TLS reencrypt"| Prom
    AlertRoute -->|"HTTPS/10443<br/>TLS reencrypt"| AlertMgr
    DashRoute -->|"HTTPS/8443<br/>TLS reencrypt"| Dashboard

    %% Prometheus scraping flows
    Prom -->|"HTTPS/9091<br/>TLS<br/>Bearer Token (SA)"| ClusterProm
    Prom -->|"HTTP/8080<br/>No encryption"| NBC
    Prom -->|"HTTP/8080<br/>No encryption"| KFNBC
    Prom -->|"HTTP/8080<br/>No encryption"| ModelCtrl
    Prom -->|"HTTP/8080<br/>No encryption"| ModelMesh
    Prom -->|"HTTP/8080<br/>No encryption"| DSPOSvc
    Prom -->|"HTTP/8888<br/>No encryption"| DSPipeline
    Prom -->|"HTTP/8383<br/>No encryption"| OperatorMetrics
    Prom -->|"HTTP/9115<br/>Probe targets"| Blackbox

    %% Blackbox probing
    Blackbox -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| Dashboard

    %% Alertmanager egress
    AlertMgr -->|"HTTPS/443<br/>TLS<br/>Service Key"| PagerDuty
    AlertMgr -->|"HTTPS/443<br/>TLS<br/>URL Token"| DMS
    AlertMgr -->|"SMTP<br/>STARTTLS<br/>User/Pass"| SMTP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef apps fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class PromRoute,AlertRoute,DashRoute ingress
    class Prom,AlertMgr,Blackbox monitoring
    class Dashboard,NBC,KFNBC,ModelCtrl,ModelMesh,DSPOSvc,DSPipeline apps
    class OperatorMetrics operator
    class K8sAPI,ClusterProm cluster
    class PagerDuty,DMS,SMTP externalsvc
