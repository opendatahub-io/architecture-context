graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Admin / SRE User"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP → 9091/TCP<br/>reencrypt TLS<br/>OAuth + SAR"]
        AMRoute["Alertmanager Route<br/>443/TCP → 10443/TCP<br/>reencrypt TLS<br/>OAuth + SAR"]
        DashRoute["Dashboard Route<br/>443/TCP → 8443/TCP<br/>reencrypt TLS<br/>Probe Target"]
    end

    subgraph Deployer["DEPLOYMENT INITIATOR"]
        DeployPod["deploy.sh Container<br/>UBI8-minimal + oc CLI<br/>SA Token Auth"]
    end

    subgraph NSMonitoring["NAMESPACE: redhat-ods-monitoring<br/>Network Policy: opendatahub.io/generated-namespace=true"]
        direction TB

        subgraph PromStack["Prometheus Stack"]
            OAuthProm["OAuth Proxy<br/>9091/TCP HTTPS<br/>TLS serving cert<br/>SAR enforcement"]
            Prom["Prometheus<br/>9090/TCP HTTP<br/>UID:1000 GID:2000<br/>/metrics unauthenticated"]
            OAuthProm -->|"localhost"| Prom
        end

        subgraph AMStack["Alertmanager Stack"]
            OAuthAM["OAuth Proxy<br/>10443/TCP HTTPS<br/>TLS serving cert<br/>SAR enforcement"]
            AM["Alertmanager<br/>9093/TCP HTTP"]
            OAuthAM -->|"localhost"| AM
        end

        BB["Blackbox Exporter<br/>9114/TCP HTTPS<br/>Bearer Token"]

        Prom -->|"9093/TCP HTTP<br/>loopback"| AM
        Prom -->|"9114/TCP HTTPS<br/>Bearer Token"| BB
    end

    subgraph NSApps["NAMESPACE: redhat-ods-applications<br/>Network Policy: opendatahub.io/generated-namespace=true<br/>SCC: anyuid granted"]
        Dashboard["RHODS Dashboard<br/>8443/TCP HTTPS"]
        NBC["ODH Notebook Controller<br/>8080/TCP HTTP"]
        KFNBC["KF Notebook Controller<br/>8080/TCP HTTP"]
        ModelCtrl["ODH Model Controller<br/>8080/TCP HTTP"]
        MMesh["ModelMesh Controller<br/>8080/TCP HTTP"]
        DSPO["DSPO<br/>8080/TCP HTTP"]
    end

    subgraph NSOperator["NAMESPACE: redhat-ods-operator<br/>Network Policy Protected"]
        Operator["RHODS Operator<br/>8383/TCP HTTP"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        ClusterProm["OpenShift Cluster Prometheus<br/>openshift-monitoring<br/>9091/TCP HTTPS<br/>TLS (service CA)"]
        K8sAPI["OpenShift API Server<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Managed Only)"]
        PD["PagerDuty API<br/>443/TCP HTTPS TLS 1.2+<br/>Service Key"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS TLS 1.2+<br/>URL Token"]
        SMTP["SMTP Server<br/>STARTTLS<br/>Username/Password"]
    end

    %% Deployment flow
    DeployPod -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS reencrypt<br/>OAuth"| PromRoute
    User -->|"HTTPS/443<br/>TLS reencrypt<br/>OAuth"| AMRoute
    PromRoute -->|"9091/TCP HTTPS"| OAuthProm
    AMRoute -->|"10443/TCP HTTPS"| OAuthAM

    %% Prometheus scrapes
    Prom -->|"9091/TCP HTTPS<br/>TLS (service CA)<br/>Bearer Token (SA)"| ClusterProm
    Prom -->|"8080/TCP HTTP<br/>No Auth"| NBC
    Prom -->|"8080/TCP HTTP<br/>No Auth"| KFNBC
    Prom -->|"8080/TCP HTTP<br/>No Auth"| ModelCtrl
    Prom -->|"8080/TCP HTTP<br/>No Auth"| MMesh
    Prom -->|"8080/TCP HTTP<br/>No Auth"| DSPO
    Prom -->|"8383/TCP HTTP<br/>No Auth"| Operator
    BB -->|"8443/TCP HTTPS<br/>Bearer Token (SA)"| Dashboard

    %% Alert notifications (managed only)
    AM -.->|"443/TCP HTTPS<br/>TLS 1.2+<br/>Service Key"| PD
    AM -.->|"443/TCP HTTPS<br/>TLS 1.2+<br/>URL Token"| DMS
    AM -.->|"SMTP<br/>STARTTLS<br/>User/Pass"| SMTP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef deployer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef apps fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class PromRoute,AMRoute,DashRoute ingress
    class DeployPod deployer
    class OAuthProm,Prom,OAuthAM,AM,BB monitoring
    class Dashboard,NBC,KFNBC,ModelCtrl,MMesh,DSPO apps
    class Operator operator
    class ClusterProm,K8sAPI cluster
    class PD,DMS,SMTP externalservice
