graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Users / SRE"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        DashRoute["rhods-dashboard Route<br/>443→8443/TCP<br/>TLS Reencrypt"]
        PromRoute["prometheus Route<br/>443→9091/TCP<br/>TLS Reencrypt"]
        AMRoute["alertmanager Route<br/>443→10443/TCP<br/>TLS Reencrypt"]
    end

    subgraph InitContainer["INIT CONTAINER (One-shot)"]
        DeploySH["deploy.sh<br/>Image: odh-deployer<br/>Base: ubi8/ubi-minimal<br/>Tools: oc CLI, openssl"]
    end

    subgraph NS_Monitoring["NAMESPACE: redhat-ods-monitoring"]
        direction TB

        Prometheus["Prometheus<br/>SA: prometheus<br/>Ext: 9091/TCP HTTPS (OAuth)<br/>Int: 9090/TCP HTTP (/metrics skip-auth)"]
        Alertmanager["Alertmanager<br/>Ext: 443→10443/TCP HTTPS (OAuth)<br/>Int: 9093/TCP HTTP (health)"]
        Blackbox["Blackbox Exporter<br/>Ext: 9114/TCP HTTPS (OAuth)<br/>Int: 9115/TCP HTTP (health)"]
    end

    subgraph NS_Apps["NAMESPACE: redhat-ods-applications"]
        direction TB

        Dashboard["rhods-dashboard<br/>8443/TCP HTTPS"]
        NBC["notebook-controller-service<br/>8080/TCP HTTP"]
        OdhNBC["odh-notebook-controller-service<br/>8080/TCP HTTP"]
        ModelCtrl["odh-model-controller-metrics<br/>8080/TCP HTTP"]
        MMCtrl["modelmesh-controller<br/>8080/TCP HTTP"]
        DSPO["data-science-pipelines-operator<br/>8080/TCP HTTP"]
    end

    subgraph NS_Operator["NAMESPACE: redhat-ods-operator"]
        Operator["rhods-operator-metrics<br/>8383/TCP HTTP"]
    end

    subgraph ClusterMonitoring["NAMESPACE: openshift-monitoring"]
        ClusterProm["prometheus-k8s<br/>9091/TCP HTTPS<br/>TLS (service CA)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Managed Only)"]
        PagerDuty["PagerDuty API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service key"]
        SMTP["SMTP Server<br/>Configurable port<br/>SMTP/TLS<br/>Auth: SMTP credentials"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (URL)"]
    end

    K8sAPI["OpenShift API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]

    %% User flows via Routes
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OpenShift OAuth"| DashRoute
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OpenShift OAuth"| PromRoute
    User -->|"HTTPS/443<br/>TLS Reencrypt<br/>OpenShift OAuth"| AMRoute

    DashRoute -->|"8443/TCP HTTPS"| Dashboard
    PromRoute -->|"9091/TCP HTTPS<br/>OAuth proxy SAR"| Prometheus
    AMRoute -->|"10443/TCP HTTPS<br/>OAuth proxy SAR"| Alertmanager

    %% deploy.sh flows
    DeploySH -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Prometheus scraping
    Prometheus -->|"HTTPS/9091<br/>TLS (svc CA)<br/>Bearer token (SA)"| ClusterProm
    Prometheus -->|"HTTP/8080<br/>No TLS, No auth"| NBC
    Prometheus -->|"HTTP/8080<br/>No TLS, No auth"| OdhNBC
    Prometheus -->|"HTTP/8080<br/>No TLS, No auth"| ModelCtrl
    Prometheus -->|"HTTP/8080<br/>No TLS, No auth"| MMCtrl
    Prometheus -->|"HTTP/8080<br/>No TLS, No auth"| DSPO
    Prometheus -->|"HTTP/8383<br/>No TLS, No auth"| Operator

    %% Blackbox probing
    Blackbox -->|"HTTPS/8443<br/>TLS<br/>Bearer token (SA)"| Dashboard

    %% Alertmanager egress
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>Service key"| PagerDuty
    Alertmanager -->|"SMTP/TLS<br/>SMTP credentials"| SMTP
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>None"| DMS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef apps fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef initcontainer fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef clusterinfra fill:#e8e8e8,stroke:#666,stroke-width:2px

    class User external
    class DashRoute,PromRoute,AMRoute ingress
    class Prometheus,Alertmanager,Blackbox monitoring
    class Dashboard,NBC,OdhNBC,ModelCtrl,MMCtrl,DSPO apps
    class Operator operator
    class PagerDuty,SMTP,DMS externalservice
    class DeploySH initcontainer
    class K8sAPI,ClusterProm clusterinfra
