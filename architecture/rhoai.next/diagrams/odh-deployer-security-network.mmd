graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Console User"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP HTTPS<br/>TLS reencrypt"]
        AMRoute["Alertmanager Route<br/>443/TCP HTTPS<br/>TLS reencrypt"]
    end

    subgraph Monitoring["NAMESPACE: redhat-ods-monitoring<br/>Network Policy: ingress from opendatahub.io/generated-namespace=true"]
        direction TB

        subgraph PromStack["Prometheus Stack"]
            PromOAuth["OAuth Proxy<br/>9091/TCP HTTPS<br/>TLS (serving cert)<br/>SAR: get namespaces"]
            Prom["Prometheus<br/>9090/TCP HTTP<br/>UID:1000 GID:2000<br/>SA: prometheus"]
        end

        subgraph AMStack["Alertmanager Stack"]
            AMOAuth["OAuth Proxy<br/>10443/TCP HTTPS<br/>TLS (serving cert)<br/>SAR: get namespaces"]
            AM["Alertmanager<br/>9093/TCP HTTP"]
        end

        BBE["Blackbox Exporter<br/>9114/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token"]
    end

    subgraph Applications["NAMESPACE: redhat-ods-applications<br/>Network Policy: ingress from opendatahub.io/generated-namespace=true"]
        Dashboard["RHODS Dashboard<br/>SA: rhods-dashboard<br/>8443/TCP HTTPS"]
        NBC["ODH Notebook Controller<br/>SA: notebook-controller-service-account<br/>8080/TCP HTTP"]
        KFNBC["Kubeflow Notebook Controller<br/>8080/TCP HTTP"]
        ModelCtrl["ODH Model Controller<br/>SA: odh-model-controller<br/>8080/TCP HTTP"]
        ModelMesh["ModelMesh Controller<br/>SA: modelmesh-controller<br/>8080/TCP HTTP"]
        DSPO["DSPO<br/>8080/TCP HTTP"]
    end

    subgraph Operator["NAMESPACE: redhat-ods-operator"]
        RHODSOp["RHODS Operator<br/>8383/TCP HTTP"]
    end

    subgraph ClusterMonitoring["NAMESPACE: openshift-monitoring"]
        ClusterProm["Cluster Prometheus<br/>9091/TCP HTTPS<br/>TLS (service CA)"]
    end

    subgraph ExternalAlerts["EXTERNAL ALERTING (Managed Only)"]
        PD["PagerDuty API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service Key"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: URL Token"]
        SMTP["SMTP Server<br/>STARTTLS<br/>Auth: Username/Pwd"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>OAuth + SAR"| PromRoute
    User -->|"HTTPS/443<br/>OAuth + SAR"| AMRoute

    %% Ingress to services
    PromRoute -->|"HTTPS/9091<br/>TLS serving cert"| PromOAuth
    AMRoute -->|"HTTPS/10443<br/>TLS serving cert"| AMOAuth

    %% OAuth to backends
    PromOAuth -->|"HTTP/9090<br/>loopback"| Prom
    AMOAuth -->|"HTTP/9093<br/>loopback"| AM

    %% Prometheus scraping
    Prom -->|"HTTPS/9091<br/>TLS service CA<br/>Bearer Token (SA)"| ClusterProm
    Prom -->|"HTTPS/9114<br/>TLS<br/>Bearer Token"| BBE
    Prom -->|"HTTP/8080<br/>no auth"| NBC
    Prom -->|"HTTP/8080<br/>no auth"| KFNBC
    Prom -->|"HTTP/8080<br/>no auth"| ModelCtrl
    Prom -->|"HTTP/8080<br/>no auth"| ModelMesh
    Prom -->|"HTTP/8080<br/>no auth"| DSPO
    Prom -->|"HTTP/8383<br/>no auth"| RHODSOp

    %% Blackbox probing
    BBE -->|"HTTPS/8443<br/>Bearer Token (SA)"| Dashboard

    %% Alert flows
    Prom -->|"HTTP/9093<br/>loopback"| AM
    AM -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Key"| PD
    AM -->|"STARTTLS<br/>Username/Pwd"| SMTP
    AM -->|"HTTPS/443<br/>TLS 1.2+<br/>URL Token"| DMS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef applications fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterinfra fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class PromRoute,AMRoute ingress
    class PromOAuth,Prom,AMOAuth,AM,BBE monitoring
    class Dashboard,NBC,KFNBC,ModelCtrl,ModelMesh,DSPO applications
    class RHODSOp,ClusterProm clusterinfra
    class PD,DMS,SMTP externalservice
