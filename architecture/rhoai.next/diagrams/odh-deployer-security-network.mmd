graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Console User"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP → 9091/TCP<br/>TLS reencrypt"]
        AMRoute["Alertmanager Route<br/>443/TCP → 10443/TCP<br/>TLS reencrypt"]
        DashRoute["RHODS Dashboard Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt<br/>(monitoring probe target)"]
        ConsoleLink["rhodslink ConsoleLink<br/>App Launcher"]
    end

    subgraph NSMonitoring["NAMESPACE: redhat-ods-monitoring<br/>Network Policy: ingress from opendatahub.io/generated-namespace"]
        direction TB
        OAuthProm["OAuth Proxy (Prometheus)<br/>9091/TCP HTTPS<br/>TLS (prometheus-tls)<br/>Auth: OAuth + SAR"]
        Prometheus["Prometheus<br/>9090/TCP HTTP<br/>UID:1000 GID:2000<br/>SA: prometheus"]
        OAuthAM["OAuth Proxy (Alertmanager)<br/>10443/TCP HTTPS<br/>TLS (alertmanager-tls)<br/>Auth: OAuth + SAR"]
        Alertmanager["Alertmanager<br/>9093/TCP HTTP"]
        Blackbox["Blackbox Exporter<br/>9114/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token"]

        OAuthProm -->|"HTTP/9090<br/>localhost"| Prometheus
        OAuthAM -->|"HTTP/9093<br/>localhost"| Alertmanager
        Prometheus -->|"HTTP/9093<br/>localhost"| Alertmanager
        Prometheus -->|"HTTPS/9114<br/>TLS, Bearer Token"| Blackbox
    end

    subgraph NSApps["NAMESPACE: redhat-ods-applications<br/>Network Policy: ingress from opendatahub.io/generated-namespace"]
        direction TB
        Dashboard["RHODS Dashboard<br/>8443/TCP HTTPS"]
        ODHNBC["ODH Notebook Controller<br/>8080/TCP HTTP"]
        KFNBC["KF Notebook Controller<br/>8080/TCP HTTP"]
        ModelCtrl["ODH Model Controller<br/>8080/TCP HTTP"]
        ModelMesh["ModelMesh Controller<br/>8080/TCP HTTP"]
        DSPO["DSPO<br/>8080/TCP HTTP"]
    end

    subgraph NSOperator["NAMESPACE: redhat-ods-operator<br/>Network Policy: ingress from opendatahub.io/generated-namespace"]
        RHODSOp["RHODS Operator<br/>8383/TCP HTTP"]
    end

    subgraph NSClusterMon["NAMESPACE: openshift-monitoring"]
        ClusterProm["Cluster Prometheus<br/>9091/TCP HTTPS<br/>TLS (service CA)<br/>Auth: Bearer Token (SA)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Managed Only)"]
        PagerDuty["PagerDuty API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Service Key"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: URL Token"]
        SMTP["SMTP Server<br/>STARTTLS<br/>Auth: User/Pass"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS<br/>OAuth"| PromRoute
    User -->|"HTTPS/443<br/>TLS<br/>OAuth"| AMRoute

    %% Ingress to Services
    PromRoute -->|"HTTPS/9091<br/>TLS reencrypt"| OAuthProm
    AMRoute -->|"HTTPS/10443<br/>TLS reencrypt"| OAuthAM

    %% Prometheus scraping
    Prometheus -->|"HTTPS/9091<br/>TLS (svc CA)<br/>Bearer Token"| ClusterProm
    Prometheus -->|"HTTP/8080<br/>No Auth"| ODHNBC
    Prometheus -->|"HTTP/8080<br/>No Auth"| KFNBC
    Prometheus -->|"HTTP/8080<br/>No Auth"| ModelCtrl
    Prometheus -->|"HTTP/8080<br/>No Auth"| ModelMesh
    Prometheus -->|"HTTP/8080<br/>No Auth"| DSPO
    Prometheus -->|"HTTP/8383<br/>No Auth"| RHODSOp
    Blackbox -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| Dashboard

    %% Alertmanager egress
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Key"| PagerDuty
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>URL Token"| DMS
    Alertmanager -->|"SMTP<br/>STARTTLS<br/>User/Pass"| SMTP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef apps fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clusterns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class PromRoute,AMRoute,DashRoute,ConsoleLink ingress
    class OAuthProm,Prometheus,OAuthAM,Alertmanager,Blackbox monitoring
    class Dashboard,ODHNBC,KFNBC,ModelCtrl,ModelMesh,DSPO apps
    class RHODSOp operator
    class ClusterProm clusterns
    class PagerDuty,DMS,SMTP extsvc
