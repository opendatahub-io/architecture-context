graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Users /<br/>Administrators"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP → 9091/TCP<br/>TLS Reencrypt<br/>OAuth Proxy"]
        AMRoute["Alertmanager Route<br/>443/TCP → 10443/TCP<br/>TLS Reencrypt<br/>OAuth Proxy"]
        DashRoute["RHODS Dashboard Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt<br/>OAuth"]
    end

    subgraph MonitoringNS["NAMESPACE: redhat-ods-monitoring<br/>NetworkPolicy: opendatahub.io/generated-namespace=true<br/>Ports: 443, 9115, 8443, 9091, 10443/TCP"]
        direction TB

        Prometheus["Prometheus<br/>SA: prometheus<br/>9091/TCP HTTPS<br/>OAuth Proxy sidecar<br/>/metrics: no auth"]
        Alertmanager["Alertmanager<br/>10443/TCP HTTPS<br/>OAuth Proxy sidecar"]
        Blackbox["Blackbox Exporter<br/>9114/TCP HTTPS<br/>OAuth Proxy sidecar<br/>/metrics: no auth<br/>WARNING: insecure_skip_verify"]
    end

    subgraph ApplicationsNS["NAMESPACE: redhat-ods-applications<br/>NetworkPolicy: opendatahub.io/generated-namespace=true<br/>Ports: 8443, 8080, 8081, 5432, 8082, 8099, 8181/TCP"]
        Dashboard["rhods-dashboard<br/>8443/TCP HTTPS"]
        NBCtrl["odh-notebook-controller<br/>8080/TCP HTTP"]
        KFCtrl["notebook-controller (KF)<br/>8080/TCP HTTP"]
        ModelCtrl["odh-model-controller<br/>8080/TCP HTTP"]
        MMCtrl["modelmesh-controller<br/>8080/TCP HTTP"]
        DSPOSvc["DSPO service<br/>8080/TCP HTTP"]
    end

    subgraph OperatorNS["NAMESPACE: redhat-ods-operator<br/>NetworkPolicy: opendatahub.io/generated-namespace=true"]
        Operator["rhods-operator<br/>8383/TCP HTTP"]
    end

    subgraph OcpMonitoring["NAMESPACE: openshift-monitoring"]
        OcpProm["OpenShift Prometheus<br/>9091/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Managed Service Only)"]
        PagerDuty["PagerDuty API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Key"]
        SMTPSrv["SMTP Server<br/>TLS STARTTLS<br/>SMTP Credentials"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>URL Secret"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| PromRoute
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| AMRoute
    User -->|"HTTPS/443<br/>TLS<br/>OpenShift OAuth"| DashRoute

    %% Ingress to Services
    PromRoute -->|"HTTPS/9091<br/>TLS reencrypt"| Prometheus
    AMRoute -->|"HTTPS/10443<br/>TLS reencrypt"| Alertmanager
    DashRoute -->|"HTTPS/8443<br/>TLS reencrypt"| Dashboard

    %% Prometheus Federation
    Prometheus -->|"HTTPS/9091<br/>TLS<br/>Bearer Token (SA)"| OcpProm

    %% Prometheus Scrapes (plaintext HTTP)
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>no auth"| NBCtrl
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>no auth"| KFCtrl
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>no auth"| ModelCtrl
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>no auth"| MMCtrl
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>no auth"| DSPOSvc
    Prometheus -->|"HTTP/8383<br/>plaintext<br/>no auth"| Operator

    %% Blackbox probes
    Blackbox -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| Dashboard

    %% Prometheus to Alertmanager
    Prometheus -->|"HTTP/9093<br/>plaintext<br/>localhost"| Alertmanager

    %% External alerting
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Key"| PagerDuty
    Alertmanager -->|"SMTP<br/>TLS STARTTLS<br/>SMTP creds"| SMTPSrv
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>URL secret"| DMS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef applications fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef ocpmonitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class PromRoute,AMRoute,DashRoute ingress
    class Prometheus,Alertmanager,Blackbox monitoring
    class Dashboard,NBCtrl,KFCtrl,ModelCtrl,MMCtrl,DSPOSvc applications
    class Operator operator
    class OcpProm ocpmonitoring
    class PagerDuty,SMTPSrv,DMS externalservice
