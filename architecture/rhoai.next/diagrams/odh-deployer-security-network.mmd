graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["OpenShift Console User"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        PromRoute["Prometheus Route<br/>443/TCP → 9091/TCP<br/>Reencrypt TLS"]
        AMRoute["Alertmanager Route<br/>443/TCP → 10443/TCP<br/>Reencrypt TLS"]
        DashRoute["Dashboard Route<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS"]
    end

    subgraph Monitoring["NAMESPACE: redhat-ods-monitoring<br/>Network Policy: ports 443, 9115, 8443, 9091, 10443"]
        direction TB

        subgraph PromStack["Prometheus Stack"]
            Prometheus["Prometheus<br/>SA: prometheus<br/>UID: 1000, GID: 2000<br/>9091/TCP HTTPS"]
            PromProxy["OAuth Proxy<br/>SAR: get ns"]
            Prometheus --- PromProxy
        end

        subgraph AMStack["Alertmanager Stack"]
            Alertmanager["Alertmanager<br/>443/TCP → 10443/TCP<br/>HTTPS"]
            AMProxy["OAuth Proxy<br/>SAR: get ns"]
            Alertmanager --- AMProxy
        end

        subgraph BBStack["Blackbox Exporter"]
            Blackbox["Blackbox Exporter<br/>9114/TCP HTTPS<br/>WARNING: external variant<br/>insecure_skip_verify=true"]
            BBProxy["OAuth Proxy<br/>SAR: get ns"]
            Blackbox --- BBProxy
        end
    end

    subgraph Applications["NAMESPACE: redhat-ods-applications<br/>Network Policy: ports 8443, 8080, 8081, 5432, 8082, 8099, 8181"]
        Dashboard["odh-dashboard<br/>8443/TCP HTTPS"]
        NBC["odh-notebook-controller<br/>8080/TCP HTTP"]
        ModelCtrl["odh-model-controller<br/>8080/TCP HTTP"]
        MMCtrl["modelmesh-controller<br/>8080/TCP HTTP"]
        DSPO["DSPO<br/>8080/TCP HTTP"]
    end

    subgraph OperatorNS["NAMESPACE: redhat-ods-operator<br/>Network Policy: label-restricted"]
        Operator["rhods-operator<br/>8383/TCP HTTP"]
    end

    subgraph Bootstrap["DEPLOYER (Init Container - One-time)"]
        Deployer["deploy.sh<br/>UBI8-minimal + oc CLI"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Managed Service Only)"]
        PagerDuty["PagerDuty API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service Key"]
        DMS["Dead Man's Snitch<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: URL token"]
        SMTPRelay["SMTP Relay<br/>SMTP/TLS<br/>Auth: Credentials"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["OpenShift API Server<br/>443/TCP HTTPS"]
        OSProm["OpenShift Prometheus<br/>9091/TCP HTTPS<br/>TLS (service CA)"]
    end

    %% External access flows
    User -->|"HTTPS/443<br/>OpenShift OAuth"| PromRoute
    User -->|"HTTPS/443<br/>OpenShift OAuth"| AMRoute
    User -->|"HTTPS/443<br/>OpenShift OAuth"| DashRoute
    PromRoute -->|"Reencrypt"| PromProxy
    AMRoute -->|"Reencrypt"| AMProxy
    DashRoute -->|"Reencrypt"| Dashboard

    %% Prometheus scraping (egress)
    Prometheus -->|"HTTPS/9091<br/>TLS (service CA)<br/>Bearer Token (SA)"| OSProm
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| NBC
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| ModelCtrl
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| MMCtrl
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| DSPO
    Prometheus -->|"HTTP/8383<br/>No encryption<br/>No auth"| Operator

    %% Blackbox probes
    Blackbox -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| Dashboard

    %% Alertmanager egress
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Key"| PagerDuty
    Alertmanager -->|"HTTPS/443<br/>TLS 1.2+<br/>URL token"| DMS
    Alertmanager -->|"SMTP/TLS<br/>Credentials"| SMTPRelay

    %% Deployer bootstrap
    Deployer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e8d5f5,stroke:#9673a6,stroke-width:2px
    classDef applications fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef bootstrap fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef clusterservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class PromRoute,AMRoute,DashRoute ingress
    class Prometheus,PromProxy,Alertmanager,AMProxy,Blackbox,BBProxy monitoring
    class Dashboard,NBC,ModelCtrl,MMCtrl,DSPO applications
    class Operator operator
    class Deployer bootstrap
    class PagerDuty,DMS,SMTPRelay externalservice
    class K8sAPI,OSProm clusterservice
