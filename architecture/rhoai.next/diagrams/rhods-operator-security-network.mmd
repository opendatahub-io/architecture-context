graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External User / Client"]
    end

    subgraph Ingress["INGRESS — Gateway API Data Plane"]
        direction TB
        Gateway["data-science-gateway<br/>(Gateway CR — Envoy)<br/>443/TCP → Envoy<br/>TLS 1.2+ Terminate<br/>Hostname: rh-ai.{domain}"]
        EnvoyFilter["data-science-authn-filter<br/>(EnvoyFilter)<br/>ext_authz + Lua<br/>Strips cookies, injects Bearer"]
        Gateway --> EnvoyFilter
    end

    subgraph AuthZone["AUTH PROXY ZONE (NetworkPolicy protected)"]
        AuthProxy["kube-auth-proxy<br/>(OAuth2 Proxy)<br/>NS: openshift-ingress<br/>SA: kube-auth-proxy<br/>8443/TCP HTTPS (service-ca)<br/>9000/TCP HTTP (metrics)<br/>NetworkPolicy: only Gateway pods"]
    end

    subgraph ExternalAuth["EXTERNAL AUTH (Identity Provider)"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuthClient credentials"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>Client credentials"]
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE (redhat-ods-operator NS)"]
        direction TB
        Manager["rhods-operator (manager)<br/>Image: quay.io/rhoai/odh-rhel8-operator<br/>SA: opendatahub-operator<br/>FIPS: strictfipsruntime"]
        WebhookSvc["Webhook Service<br/>443 → 9443/TCP HTTPS<br/>TLS: cert-manager<br/>Auth: K8s API mTLS<br/>14 webhooks"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        Metrics["Metrics<br/>8080/TCP HTTP<br/>/metrics (Prometheus)"]
    end

    subgraph ComponentBackends["COMPONENT BACKENDS (redhat-ods-applications NS)"]
        direction TB
        Dashboard["Dashboard"]
        KServe["KServe"]
        Workbenches["Workbenches"]
        DSP["DataSciencePipelines"]
        OtherComps["+ 12 more components"]
    end

    subgraph MonitoringZone["MONITORING (redhat-ods-monitoring NS)"]
        Collector["data-science-collector-prometheus<br/>8889/TCP HTTPS (service-ca)<br/>Bearer Token"]
        OTel["OpenTelemetry Collector"]
        Prometheus["Prometheus<br/>(MonitoringStack)"]
        Thanos["Thanos Querier<br/>10902/TCP HTTP"]
        Perses["Perses Dashboard<br/>9091/9092 HTTPS<br/>TLS (CA ConfigMap)<br/>Bearer Token"]
    end

    subgraph CloudMgr["CLOUD MANAGER (Non-OpenShift only)"]
        CloudManager["cloudmanager binary<br/>Same image, different entrypoint<br/>AWS / Azure / CoreWeave"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        Quay["quay.io/rhoai/*<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
        HelmOCI["Helm OCI Registries<br/>443/TCP HTTPS<br/>Pull Secret"]
    end

    subgraph LegacyRedirects["LEGACY REDIRECTS"]
        RedirectRoute["rhods-dashboard Route<br/>443/TCP HTTPS edge<br/>301 → Gateway hostname"]
        DashRedirect["dashboard-redirect<br/>8080/TCP HTTP<br/>nginx redirect service"]
    end

    %% Flows - External to Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>(no auth yet)"| Gateway
    EnvoyFilter -->|"HTTPS/8443<br/>TLS (service-ca)<br/>OAuth2 proxy"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuthClient creds"| OAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client creds"| OIDC
    EnvoyFilter -->|"HTTP(S)/varies<br/>Bearer Token<br/>(injected by Lua)"| ComponentBackends

    %% Operator flows
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (cert-manager)<br/>K8s API mTLS"| WebhookSvc
    Manager --> HealthProbes
    Manager --> Metrics

    %% Monitoring flows
    OTel -->|"OTLP<br/>TLS (webTLSConfig)<br/>Bearer Token"| Prometheus
    Prometheus --> Thanos
    Perses -->|"HTTPS/9091-9092<br/>TLS (CA)<br/>Bearer Token"| Thanos
    Collector --> OTel

    %% Cloud Manager flows
    CloudManager -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    CloudManager -->|"HTTPS/443<br/>Pull Secret"| HelmOCI

    %% Image pull
    Manager -->|"HTTPS/443<br/>Pull Secret"| Quay

    %% Legacy
    Client -.->|"301 redirect"| RedirectRoute
    RedirectRoute -.-> DashRedirect

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authzone fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef components fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef cloud fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    classDef legacy fill:#e8e8e8,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Gateway,EnvoyFilter ingress
    class AuthProxy authzone
    class OAuth,OIDC external
    class Manager,WebhookSvc,HealthProbes,Metrics operator
    class Dashboard,KServe,Workbenches,DSP,OtherComps components
    class Collector,OTel,Prometheus,Thanos,Perses monitoring
    class K8sAPI,Quay,HelmOCI externalsvc
    class CloudManager cloud
    class RedirectRoute,DashRedirect legacy
