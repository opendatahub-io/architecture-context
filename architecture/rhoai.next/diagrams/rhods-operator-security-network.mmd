graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router / LB<br/>443/TCP<br/>TLS Passthrough"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP<br/>TLS 1.2+ Terminate"]
        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS<br/>OAuth2/OIDC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub-operator-system)"]
        Manager["manager (RHODS Operator)<br/>SA: opendatahub-operator-controller-manager<br/>Image: quay.io/opendatahub/opendatahub-operator"]
        WebhookSvc["Webhook Service<br/>443→9443/TCP HTTPS<br/>TLS (self-signed/cert-manager)"]
        MetricsSvc["Metrics<br/>8080/TCP HTTP<br/>kube-rbac-proxy (Bearer)"]
        HealthSvc["Health/Readiness<br/>8081/TCP HTTP<br/>No Auth"]
    end

    subgraph AppNS["APPLICATION NAMESPACE"]
        direction TB

        subgraph MonitoringStack["Monitoring Stack"]
            Prometheus["MonitoringStack (Prometheus)<br/>9090/TCP HTTPS<br/>service-CA TLS"]
            NSProxy["Namespace Proxy<br/>8443/TCP HTTPS<br/>kube-rbac-proxy (SAR)"]
            ClusterProxy["Cluster Proxy<br/>8443/TCP HTTPS<br/>kube-rbac-proxy (SAR)"]
            ThanosQ["ThanosQuerier<br/>10901/TCP gRPC TLS"]
            OTel["OpenTelemetry Collector<br/>4318/TCP OTLP TLS<br/>9411/TCP HTTPS"]
            TempoSvc["Tempo<br/>Tracing Backend"]
            PersesSvc["Perses<br/>Visualization"]
        end

        DashRedirect["Dashboard Redirect (nginx)<br/>8080/TCP HTTP<br/>Behind Route TLS Edge"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth2 client credentials"]
        OIDCProvider["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>OIDC client credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA Bearer Token"]
    end

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No initial auth"| Router
    Router -->|"HTTPS/443<br/>TLS Passthrough"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>ext_authz Bearer check"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDCProvider
    AuthProxy -->|"HTTPS/443<br/>TokenReview<br/>SA Bearer Token"| K8sAPI

    %% Operator flows
    Manager -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>mTLS (API server cert)<br/>Admission webhooks"| WebhookSvc

    %% Monitoring flows
    NSProxy -->|"HTTPS/9090<br/>service-CA TLS"| Prometheus
    ClusterProxy -->|"HTTPS/9090<br/>service-CA TLS"| Prometheus
    ThanosQ -->|"gRPC/10901<br/>TLS<br/>Federated query"| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef appns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class Router,Gateway,AuthProxy ingress
    class Manager,WebhookSvc,MetricsSvc,HealthSvc operatorns
    class Prometheus,NSProxy,ClusterProxy,ThanosQ,OTel,TempoSvc,PersesSvc monitoring
    class DashRedirect appns
    class OAuthServer,OIDCProvider,K8sAPI externalservice
