graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / User"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Router["OpenShift Router / LB<br/>443/TCP<br/>TLS Passthrough/Edge"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP → 443/TCP<br/>TLS 1.2+ Terminate"]
        EF["EnvoyFilter (ext_authz)<br/>Auth enforcement"]
    end

    subgraph AuthZone["AUTHENTICATION"]
        direction TB
        AuthProxy["kube-auth-proxy<br/>SA: kube-auth-proxy<br/>NS: openshift-ingress<br/>8443/TCP HTTPS | 9000/TCP metrics"]
    end

    subgraph OperatorZone["OPERATOR CONTROL PLANE"]
        direction TB
        Manager["RHODS Operator (manager)<br/>SA: opendatahub-operator-controller-manager<br/>9443/TCP webhook (mTLS)<br/>8080/TCP metrics (kube-rbac-proxy)<br/>8081/TCP health (no auth)"]
    end

    subgraph MonitoringZone["MONITORING STACK"]
        direction TB
        OTelCol["OTel Collector<br/>+ TargetAllocator<br/>4318/TCP OTLP"]
        Prom["MonitoringStack (Prometheus)<br/>9090/TCP HTTPS (service-CA)"]
        Thanos["ThanosQuerier<br/>10901/TCP gRPC TLS"]
        NSProxy["Namespace Proxy<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
        ClProxy["Cluster Proxy<br/>8443/TCP HTTPS<br/>kube-rbac-proxy"]
        Tempo["Tempo<br/>Distributed Tracing"]
        Perses["Perses<br/>Visualization"]
    end

    subgraph UpstreamComponents["UPSTREAM COMPONENTS (via HTTPRoute)"]
        Dashboard["Dashboard"]
        KServe["KServe"]
        Workbenches["Workbenches"]
        OtherComp["Other Components<br/>(16 total)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth2 client credentials"]
        OIDCProvider["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>OIDC client credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph LegacyRedirect["LEGACY REDIRECTS (Conditional)"]
        NginxRedirect["dashboard-redirect (nginx)<br/>8080/TCP HTTP<br/>Behind Route (Edge TLS)<br/>301 redirect to new hostname"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No initial auth"| Router
    Router -->|"HTTPS/443<br/>TLS Passthrough"| Gateway
    Gateway -->|"ext_authz"| EF
    EF -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| AuthProxy

    %% Auth flows
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client creds"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDCProvider
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>TokenReview"| K8sAPI

    %% Authorized traffic to upstream
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Forwarded auth headers"| Dashboard
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Forwarded auth headers"| KServe
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Forwarded auth headers"| Workbenches
    Gateway -->|"HTTP(S) via HTTPRoute<br/>Forwarded auth headers"| OtherComp

    %% Operator → K8s API
    Manager -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% K8s API → Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>mTLS (API server cert)"| Manager

    %% Monitoring flows
    OTelCol -->|"OTLP HTTP/4318<br/>TLS"| Prom
    Thanos -->|"gRPC/10901<br/>TLS"| Prom
    Client -->|"HTTPS/8443<br/>Bearer Token"| NSProxy
    Client -->|"HTTPS/8443<br/>Bearer Token"| ClProxy
    NSProxy -->|"HTTPS/9090<br/>TLS (service-CA)"| Prom
    ClProxy -->|"HTTPS/9090<br/>TLS (service-CA)"| Prom

    %% Legacy
    Client -.->|"HTTPS/443<br/>Edge TLS (Route)"| NginxRedirect

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef upstream fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef legacy fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Router,Gateway,EF ingress
    class AuthProxy auth
    class Manager operator
    class OTelCol,Prom,Thanos,NSProxy,ClProxy,Tempo,Perses monitoring
    class Dashboard,KServe,Workbenches,OtherComp upstream
    class OAuthServer,OIDCProvider,K8sAPI extsvc
    class NginxRedirect legacy
