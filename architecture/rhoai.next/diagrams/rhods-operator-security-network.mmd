graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Browser /<br/>API Consumer"]
    end

    subgraph Ingress["INGRESS (Edge / DMZ)"]
        direction TB
        OCPRoute["OpenShift Route<br/>443/TCP<br/>TLS re-encrypt"]
        Gateway["data-science-gateway<br/>(Envoy via Gateway API)<br/>443/TCP HTTPS<br/>TLS 1.2+ (configurable)"]
        EnvoyFilter["EnvoyFilter: data-science-authn-filter<br/>ext_authz chain"]
        OCPRoute --> Gateway
        Gateway --> EnvoyFilter
    end

    subgraph AuthZone["AUTHENTICATION ZONE"]
        direction TB
        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS<br/>TLS (service CA)<br/>SA: kube-auth-proxy<br/>OAuth2 or OIDC mode"]
        LuaFilter["Envoy Lua Filter<br/>Cookie strip + token forward"]
    end

    subgraph AuthProviders["AUTH PROVIDERS"]
        direction TB
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuthClient: data-science"]
        OIDCProvider["External OIDC Provider<br/>443/TCP HTTPS TLS 1.2+<br/>(when configured)"]
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE"]
        direction TB
        Manager["rhods-operator manager<br/>SA: redhat-ods-operator<br/>8443/TCP (webhooks, HTTPS)<br/>8080/TCP (liveness, HTTP)<br/>8081/TCP (readiness, HTTP)"]
        CloudMgr["cloudmanager<br/>(AWS/Azure/CoreWeave)<br/>Helm-based dep mgmt"]
    end

    subgraph Backends["APPLICATION BACKENDS (Cluster-Internal)"]
        direction LR
        DashboardApp["Dashboard<br/>8080/TCP"]
        KServeApp["KServe<br/>8080/TCP"]
        ModelRegApp["Model Registry<br/>8080/TCP"]
        DSPApp["DSP<br/>8080/TCP"]
        OtherApps["Other Components<br/>8080/TCP"]
    end

    subgraph Monitoring["MONITORING STACK"]
        direction TB
        Prometheus["Prometheus<br/>(MonitoringStack)<br/>8080/TCP HTTPS TLS"]
        OTelCol["OTel Collector<br/>4317/TCP gRPC"]
        Tempo["Tempo<br/>4317/TCP gRPC"]
        Thanos["Thanos Querier<br/>10902/TCP HTTP"]
        Perses["Perses<br/>Dashboard viz"]
        OTelCol --> Tempo
        Thanos --> Prometheus
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        OSConfig["OpenShift API<br/>(config.openshift.io)<br/>6443/TCP HTTPS"]
    end

    subgraph PlatformDeps["PLATFORM DEPENDENCIES"]
        direction LR
        CertMgr["cert-manager<br/>Certificate issuance"]
        Istio["Istio / Sail Operator<br/>EnvoyFilter, DestinationRule"]
        OLM["OLM<br/>CSV, Subscription mgmt"]
        ServiceCA["OpenShift Service CA<br/>Auto TLS cert injection"]
    end

    subgraph Legacy["LEGACY COMPATIBILITY"]
        DashRedirect["dashboard-redirect (nginx)<br/>8080/TCP HTTP<br/>301 redirect"]
        LegacyRoute["Legacy Dashboard Route<br/>443/TCP HTTPS edge<br/>301 redirect"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| OCPRoute

    %% Ingress → Auth
    EnvoyFilter -->|"HTTPS/8443<br/>TLS (service CA)<br/>Cookie/Bearer"| AuthProxy

    %% Auth → Providers
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuthClient creds"| OAuthServer
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC creds"| OIDCProvider
    AuthProxy -->|"HTTPS/6443<br/>TokenReview"| K8sAPI

    %% Auth → Backends (via Lua filter)
    EnvoyFilter -.->|"post-auth"| LuaFilter
    LuaFilter -->|"HTTP/8080<br/>Bearer token fwd<br/>cluster-internal"| DashboardApp
    LuaFilter -->|"HTTP/8080<br/>Bearer token fwd"| KServeApp
    LuaFilter -->|"HTTP/8080<br/>Bearer token fwd"| ModelRegApp
    LuaFilter -->|"HTTP/8080<br/>Bearer token fwd"| DSPApp
    LuaFilter -->|"HTTP/8080<br/>Bearer token fwd"| OtherApps

    %% Operator → K8s
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Manager -->|"HTTPS/6443<br/>SA token"| OSConfig
    CloudMgr -->|"HTTPS/6443<br/>SA token"| K8sAPI

    %% Operator → Platform deps
    Manager -->|"K8s API<br/>Certificate CRDs"| CertMgr
    Manager -->|"K8s API<br/>EnvoyFilter CRDs"| Istio
    Manager -->|"K8s API<br/>CSV mgmt"| OLM

    %% Monitoring flows
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>SA token"| DashboardApp
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>SA token"| KServeApp

    %% Legacy
    Client -.->|"HTTPS/443<br/>edge TLS"| LegacyRoute
    LegacyRoute -.->|"301 redirect"| OCPRoute

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef authprovider fill:#ffebee,stroke:#b71c1c,stroke-width:1px
    classDef operator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platdep fill:#e0e0e0,stroke:#616161,stroke-width:1px
    classDef legacy fill:#f5f5f5,stroke:#bdbdbd,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class OCPRoute,Gateway,EnvoyFilter ingress
    class AuthProxy,LuaFilter auth
    class OAuthServer,OIDCProvider authprovider
    class Manager,CloudMgr operator
    class DashboardApp,KServeApp,ModelRegApp,DSPApp,OtherApps backend
    class Prometheus,OTelCol,Tempo,Thanos,Perses monitoring
    class K8sAPI,OSConfig k8s
    class CertMgr,Istio,OLM,ServiceCA platdep
    class DashRedirect,LegacyRoute legacy
