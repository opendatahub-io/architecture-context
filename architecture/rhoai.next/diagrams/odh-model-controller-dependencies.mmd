graph LR
    ODMCtrl["odh-model-controller<br/>Operator"]
    MSAPI["model-serving-api<br/>REST Server"]

    %% Required External Dependencies
    ODMCtrl -->|"CRD watches<br/>(Required)"| KServe["KServe v0.17.0-rc1"]

    %% Conditional External Dependencies
    ODMCtrl -->|"AuthPolicy CRD<br/>(conditional)"| Kuadrant["Kuadrant v1.4.2"]
    ODMCtrl -->|"TLS detection<br/>(conditional)"| Authorino["Authorino v0.22.0"]
    ODMCtrl -->|"EnvoyFilter CRD<br/>(conditional)"| Istio["Istio v1.27.1"]
    ODMCtrl -->|"TriggerAuth CRD<br/>(conditional)"| KEDA["KEDA v2.17.3"]
    ODMCtrl -->|"ServiceMonitor CRD<br/>(conditional)"| PromOp["Prometheus Operator<br/>v0.89.0"]
    ODMCtrl -.->|"webhook certs<br/>(optional)"| CertManager["cert-manager"]
    ODMCtrl -->|"model metadata<br/>(conditional)"| ModelRegistry["Kubeflow Model<br/>Registry v0.2.19"]

    %% Internal Platform Dependencies
    ODMCtrl -->|"platform config<br/>(DSC, DSCI)"| RhodsOp["rhods-operator"]
    ODMCtrl -->|"ISVC watches"| KServeCtrl["KServe Controller"]
    ODMCtrl -->|"Route creation"| OSRouter["OpenShift Router"]
    ODMCtrl -->|"monitoring RBAC"| OSMonitoring["OpenShift Monitoring"]
    ODMCtrl -->|"Gateway reads"| GWAPICtrl["Gateway API Controller"]

    %% Integration Points (consumers of odh-model-controller)
    Dashboard["RHOAI Dashboard"] -->|"Gateway discovery<br/>REST API"| MSAPI

    %% External Services (NIM)
    ODMCtrl -->|"API key validation<br/>model catalog"| NVIDIA["NVIDIA NGC API"]
    ODMCtrl -->|"image manifest<br/>verification"| NVCR["nvcr.io Registry"]

    %% Infrastructure
    ODMCtrl -->|"CRD CRUD<br/>RBAC checks"| K8sAPI["Kubernetes API"]
    MSAPI -->|"Gateway list<br/>SSAR checks"| K8sAPI

    %% Styling
    style ODMCtrl fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MSAPI fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    style KServe fill:#e74c3c,stroke:#333,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style ModelRegistry fill:#999,stroke:#333,color:#fff

    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style OSRouter fill:#7ed321,stroke:#333,color:#fff
    style OSMonitoring fill:#7ed321,stroke:#333,color:#fff
    style GWAPICtrl fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    style NVIDIA fill:#f5a623,stroke:#333
    style NVCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
