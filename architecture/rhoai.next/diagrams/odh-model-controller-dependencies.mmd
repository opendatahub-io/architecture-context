graph LR
    OMC["odh-model-controller<br/>Operator + API Server"]

    %% Required External Dependencies
    OMC -->|"CRD Watch<br/>(InferenceService, ServingRuntime,<br/>LLMInferenceService, InferenceGraph)"| KServe["KServe<br/>v0.17.0-rc1 ODH fork"]
    OMC -->|"AuthPolicy CRDs<br/>authentication/authorization"| Kuadrant["Kuadrant Operator<br/>v1.4.2"]
    OMC -->|"Auth decisions<br/>gRPC/50051 mTLS"| Authorino["Authorino Operator<br/>v0.22.0"]
    OMC -->|"EnvoyFilter CRDs<br/>TLS bootstrap"| Istio["Istio Client<br/>v1.27.8"]
    OMC -->|"Gateway, HTTPRoute<br/>ingress management"| GatewayAPI["Gateway API<br/>v1.2.1"]
    OMC -->|"ServiceMonitor,<br/>PodMonitor CRDs"| Prometheus["Prometheus Operator<br/>v0.89.0"]
    OMC -->|"Routes, Templates,<br/>Auth, Config APIs"| OpenShift["OpenShift API<br/>latest"]
    OMC -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.19.7"]

    %% Optional External Dependencies
    OMC -.->|"TriggerAuthentication<br/>Prometheus autoscaling"| KEDA["KEDA<br/>v2.18.3"]
    OMC -.->|"Knative Service<br/>validation"| Knative["Knative Serving<br/>v0.48.1"]
    OMC -.->|"model catalog<br/>API key validation"| NGC["NVIDIA NGC API"]

    %% Internal Platform Dependencies
    rhodsOperator["rhods-operator"] -->|"deploys via<br/>kustomize manifests"| OMC
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>HTTPS/443"| OMC
    OMC -.->|"metadata registration<br/>HTTPS"| ModelRegistry["Model Registry"]
    OMC -->|"reads config<br/>(namespace, air-gapped)"| DSC["DataScienceCluster"]
    OMC -->|"reads platform<br/>initialization"| DSCI["DSCInitialization"]
    OMC -->|"discovers installation<br/>namespace"| KuadrantCR["Kuadrant CR"]
    OMC -->|"detects TLS<br/>configuration"| AuthorinoCR["Authorino CR"]

    %% Platform Gateway
    OMC -->|"EnvoyFilters +<br/>AuthPolicies targeting"| PlatformGateway["Platform Gateway<br/>(Gateway API)"]

    %% Styling
    style OMC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external (gray)
    style KServe fill:#999,stroke:#333,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff

    %% Optional external (lighter gray, dashed)
    style KEDA fill:#bbb,stroke:#333,stroke-dasharray:5,color:#333
    style Knative fill:#bbb,stroke:#333,stroke-dasharray:5,color:#333
    style NGC fill:#f5a623,stroke:#333,color:#fff

    %% Internal ODH (green)
    style rhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-dasharray:5,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333,color:#fff
    style KuadrantCR fill:#7ed321,stroke:#333,color:#fff
    style AuthorinoCR fill:#7ed321,stroke:#333,color:#fff
    style PlatformGateway fill:#7ed321,stroke:#333,color:#fff
