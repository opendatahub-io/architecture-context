graph LR
    ODH["odh-model-controller<br/>(Operator)"]

    %% Required External Dependencies
    ODH -->|"CRD watch<br/>(required)"| KServe["KServe v0.17.0-rc1<br/>InferenceService,<br/>LLMInferenceService,<br/>ServingRuntime,<br/>InferenceGraph"]

    %% Conditional External Dependencies
    ODH -->|"CRD create<br/>(conditional)"| Kuadrant["Kuadrant v1.4.2<br/>AuthPolicy"]
    ODH -->|"CRD watch<br/>(conditional)"| Authorino["Authorino v0.22.0<br/>TLS detection"]
    ODH -->|"CRD create<br/>(conditional)"| Istio["Istio v1.27.1<br/>EnvoyFilter"]
    ODH -->|"CRD create<br/>(conditional)"| KEDA["KEDA v2.17.3<br/>TriggerAuth"]
    ODH -->|"CRD create<br/>(conditional)"| PrometheusOp["Prometheus Operator<br/>v0.89.0<br/>ServiceMonitor"]
    ODH -->|"CRD create<br/>(conditional)"| ModelRegistry["Kubeflow Model<br/>Registry v0.2.19"]
    ODH -.->|"optional"| CertManager["cert-manager<br/>(webhook certs)"]

    %% Internal Platform Dependencies
    ODH -->|"CRD read"| RhodsOp["rhods-operator /<br/>opendatahub-operator<br/>DataScienceCluster,<br/>DSCInitialization"]
    ODH -->|"CRD create"| OSRouter["OpenShift Router<br/>Routes"]
    ODH -->|"CRD create"| OSTemplates["OpenShift Templates<br/>NIM runtimes"]
    ODH -->|"CRD read"| GatewayAPI["Gateway API<br/>Controller<br/>Gateway, HTTPRoute"]
    ODH -->|"RBAC create"| OSMonitoring["OpenShift Monitoring<br/>RoleBindings"]

    %% External Services
    ODH -->|"HTTPS/443<br/>NIM validation"| NVIDIA["NVIDIA NGC API<br/>authn.nvidia.com<br/>api.ngc.nvidia.com"]
    ODH -->|"HTTPS/443<br/>image manifest"| NVCR["nvcr.io<br/>container registry"]
    ODH -->|"HTTPS/443<br/>resource mgmt"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumers)
    Dashboard["RHOAI Dashboard"] -->|"HTTPS/8443<br/>Gateway discovery"| ODH

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required
    style KServe fill:#e74c3c,stroke:#333,color:#fff

    %% Conditional
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PrometheusOp fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ModelRegistry fill:#999,stroke:#333,color:#fff

    %% Internal ODH
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style OSRouter fill:#7ed321,stroke:#333,color:#fff
    style OSTemplates fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style OSMonitoring fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style NVIDIA fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
