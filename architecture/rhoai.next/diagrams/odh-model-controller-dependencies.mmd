graph LR
    OMC["odh-model-controller<br/>Operator + API Server"]

    %% Required External Dependencies
    OMC -->|"CRD source<br/>(InferenceService,<br/>ServingRuntime,<br/>LLMInferenceService)"| KServe["KServe<br/>v0.15.1 (ODH fork)"]
    OMC -->|"Routes, Templates,<br/>Authentication config"| OpenShift["OpenShift API<br/>v0.0.0-20260306"]

    %% Optional External Dependencies
    OMC -->|"AuthPolicy CRD<br/>(Gateway API auth)"| Kuadrant["Kuadrant Operator<br/>v1.4.2"]
    OMC -->|"TLS bootstrap<br/>(EnvoyFilter config)"| Authorino["Authorino Operator<br/>v0.22.0"]
    OMC -->|"EnvoyFilter CRD<br/>(proxy config)"| Istio["Istio / Service Mesh<br/>v1.27.1"]
    OMC -->|"TriggerAuthentication<br/>(Prometheus autoscaling)"| KEDA["KEDA<br/>v2.17.3"]
    OMC -->|"ServiceMonitor,<br/>PodMonitor CRDs"| Prometheus["Prometheus Operator<br/>v0.89.0"]
    OMC -->|"Gateway, HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    OMC -->|"Knative Service<br/>(serverless)"| Knative["Knative Serving<br/>v0.48.1"]

    %% Internal ODH Dependencies
    RHODSOp["rhods-operator"] -.->|"DSC, DSCI<br/>platform config"| OMC
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>HTTPS/443"| OMC
    OMC -->|"sync ISVC metadata<br/>HTTP(S)"| ModelRegistry["Model Registry<br/>v0.2.19"]

    %% External Services
    OMC -->|"API key validation,<br/>model catalog<br/>HTTPS/443"| NGC["NVIDIA NGC API"]
    OMC -->|"pull token<br/>HTTPS/443"| NVCR["nvcr.io Registry"]
    OMC -->|"token exchange<br/>HTTPS/443"| AuthnNV["authn.nvidia.com"]

    %% Kubernetes
    OMC -->|"all CRUD ops<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

    %% Styling
    style OMC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required (solid borders)
    style KServe fill:#e57373,stroke:#c62828,stroke-width:2px,color:#fff
    style OpenShift fill:#e57373,stroke:#c62828,stroke-width:2px,color:#fff

    %% Optional (lighter)
    style Kuadrant fill:#999,stroke:#333
    style Authorino fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style KEDA fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style GatewayAPI fill:#999,stroke:#333
    style Knative fill:#999,stroke:#333

    %% Internal ODH
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style NGC fill:#f5a623,stroke:#333
    style NVCR fill:#f5a623,stroke:#333
