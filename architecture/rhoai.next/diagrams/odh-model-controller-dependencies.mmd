    style PromOp fill:#666,stroke:#333,color:#fff
    style CertManager fill:#666,stroke:#333,color:#fff
    style OpenShift fill:#666,stroke:#333,color:#fff

    %% Optional external (light gray)
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style GatewayInf fill:#999,stroke:#333,color:#fff
    style KFHub fill:#999,stroke:#333,color:#fff

    %% Internal ODH (green)
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

