graph LR
    OMC["odh-model-controller<br/>Operator + API Server"]

    %% External Dependencies (Required)
    OMC -->|"CRD Watch<br/>(InferenceService,<br/>ServingRuntime,<br/>LLMInferenceService,<br/>InferenceGraph)"| KServe["KServe v0.17.0-rc1<br/>(Required)"]
    OMC -->|"CRD Watch/Create<br/>(Gateway, HTTPRoute)"| GatewayAPI["Gateway API v1.4.2<br/>(Required)"]

    %% External Dependencies (Conditional)
    OMC -->|"CRD Watch + Create<br/>(AuthPolicy)"| Kuadrant["Kuadrant v1.4.2<br/>(Conditional)"]
    OMC -->|"CRD Watch<br/>(Authorino TLS status)"| Authorino["Authorino v0.22.0<br/>(Conditional)"]
    OMC -->|"CRD Create<br/>(EnvoyFilter)"| Istio["Istio v1.27.1<br/>(Conditional)"]
    OMC -->|"CRD Create<br/>(TriggerAuthentication)"| KEDA["KEDA v2.17.3<br/>(Conditional)"]
    OMC -->|"CRD Create<br/>(ServiceMonitor,<br/>PodMonitor)"| PromOp["Prometheus Operator<br/>v0.89.0<br/>(Conditional)"]

    %% Internal Platform Dependencies
    OMC -->|"CRD Watch<br/>(DataScienceCluster,<br/>DSCInitialization)"| RhodsOp["rhods-operator<br/>(Internal ODH)"]
    OMC -->|"REST API<br/>ISVC metadata sync"| ModelReg["Model Registry<br/>(Internal ODH)"]
    OMC -->|"CRD Watch<br/>(Authentication)"| OSAuth["OpenShift Auth<br/>(Internal ODH)"]
    OMC -->|"CRD Create<br/>(Template)"| OSTemplates["OpenShift Templates<br/>(Internal ODH)"]

    %% External Services
    OMC -->|"REST API<br/>model catalog +<br/>API key validation"| NGC["NVIDIA NGC API<br/>(External)"]
    OMC -->|"OCI Registry API<br/>manifest validation +<br/>pull secrets"| NVCR["nvcr.io Registry<br/>(External)"]

    %% Integration Points (other components → OMC)
    Dashboard["ODH Dashboard"] -->|"HTTPS/443<br/>Gateway discovery"| OMC
    CLI["CLI Tools"] -->|"HTTPS/443<br/>Gateway discovery"| OMC

    %% Infrastructure
    OMC -->|"Watch/CRUD<br/>all resources"| K8sAPI["Kubernetes API<br/>(Infrastructure)"]
    OMC -->|"CRD Create<br/>(Route)"| OSRouter["OpenShift Router<br/>(Infrastructure)"]

    %% Styling
    style OMC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style KServe fill:#b85450,stroke:#333,color:#fff
    style GatewayAPI fill:#b85450,stroke:#333,color:#fff

    %% Conditional external
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff

    %% Internal ODH
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style OSAuth fill:#7ed321,stroke:#333,color:#fff
    style OSTemplates fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style NGC fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff

    %% Consumers
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style CLI fill:#7ed321,stroke:#333,color:#fff

    %% Infrastructure
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style OSRouter fill:#dae8fc,stroke:#6c8ebf
