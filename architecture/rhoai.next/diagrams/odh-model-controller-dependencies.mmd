graph LR
    ODH["odh-model-controller<br/>Operator + API Server"]

    %% Required External Dependencies
    ODH -->|"CRD Watch<br/>InferenceService, ServingRuntime,<br/>LLMInferenceService"| KServe["KServe v0.15.1<br/>(ODH fork)"]
    ODH -->|"Routes, Templates,<br/>Authentication config"| OpenShift["OpenShift API<br/>v0.0.0-20260306"]

    %% Optional External Dependencies
    ODH -->|"AuthPolicy CRD<br/>(Gateway API auth)"| Kuadrant["Kuadrant Operator<br/>v1.4.2"]
    ODH -->|"TLS bootstrap<br/>(EnvoyFilter config)"| Authorino["Authorino Operator<br/>v0.22.0"]
    ODH -->|"EnvoyFilter CRD<br/>(proxy config)"| Istio["Istio / Service Mesh<br/>v1.27.1"]
    ODH -->|"TriggerAuth CRD<br/>(Prometheus autoscale)"| KEDA["KEDA v2.17.3"]
    ODH -->|"ServiceMonitor CRD<br/>(metrics scraping)"| PromOp["Prometheus Operator<br/>v0.89.0"]
    ODH -->|"Gateway, HTTPRoute<br/>(inference routing)"| GatewayAPI["Gateway API v1.2.1"]
    ODH -->|"Knative Service<br/>(serverless inference)"| Knative["Knative Serving<br/>v0.48.1"]

    %% Internal ODH Platform Dependencies
    ODH -->|"reads platform config<br/>(DSC, DSCI)"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    ODH -->|"model metadata sync"| ModelReg["Model Registry<br/>v0.2.19"]

    %% Integration Points (consumers)
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>(gateway discovery)"| ODH
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>(8080, 9090)"| ODH
    KServeCtrl["KServe Controller"] -->|"creates ISVCs<br/>(triggers reconciliation)"| ODH

    %% External Egress
    ODH -->|"API key validation<br/>model catalog"| NGC["NVIDIA NGC API"]
    ODH -->|"pull token<br/>acquisition"| NVCR["nvcr.io Registry"]

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required (solid border)
    style KServe fill:#2d6a4f,stroke:#333,stroke-width:2px,color:#fff
    style OpenShift fill:#2d6a4f,stroke:#333,stroke-width:2px,color:#fff

    %% Optional (lighter)
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff

    %% Internal ODH
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style NGC fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff
