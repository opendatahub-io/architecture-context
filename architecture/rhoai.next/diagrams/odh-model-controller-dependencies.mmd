graph LR
    OMC["odh-model-controller<br/>Operator + API Server"]

    %% External Dependencies (Required)
    OMC -->|"CRDs: InferenceService,<br/>ServingRuntime,<br/>LLMInferenceService"| KServe["KServe<br/>v0.15.1 (ODH fork)<br/><i>Required</i>"]
    OMC -->|"Routes, Templates,<br/>Authentication"| OpenShift["OpenShift API<br/>v0.0.0-20260306<br/><i>Required</i>"]

    %% External Dependencies (Optional)
    OMC -->|"AuthPolicy CRD"| Kuadrant["Kuadrant Operator<br/>v1.4.2<br/><i>Optional</i>"]
    OMC -->|"Authorino TLS<br/>bootstrap"| Authorino["Authorino Operator<br/>v0.22.0<br/><i>Optional</i>"]
    OMC -->|"EnvoyFilter CRD"| Istio["Istio / Service Mesh<br/>v1.27.1<br/><i>Optional</i>"]
    OMC -->|"TriggerAuthentication<br/>CRD"| KEDA["KEDA<br/>v2.17.3<br/><i>Optional</i>"]
    OMC -->|"ServiceMonitor,<br/>PodMonitor CRDs"| Prometheus["Prometheus Operator<br/>v0.89.0<br/><i>Optional</i>"]
    OMC -->|"Gateway, HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API<br/>v1.2.1<br/><i>Optional</i>"]
    OMC -->|"ISVC metadata sync"| ModelRegistry["Model Registry<br/>v0.2.19<br/><i>Optional</i>"]
    OMC -->|"Knative Service"| Knative["Knative Serving<br/>v0.48.1<br/><i>Optional</i>"]

    %% External Services
    OMC -->|"API key validation,<br/>model data"| NGC["NVIDIA NGC API<br/><i>Optional</i>"]
    OMC -->|"Pull token"| NVCR["nvcr.io Registry<br/><i>Optional</i>"]

    %% Internal Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"platform config"| OMC
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways"| OMC

    %% Peer Components (interact via K8s API)
    OMC -.->|"reads config"| RHODSOp
    KServeCtrl["KServe Controller"] -.->|"creates ISVCs"| OMC
    KuadrantCtrl["Kuadrant Controller"] -.->|"enforces auth"| OMC

    %% Styling
    style OMC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style KServe fill:#e74c3c,stroke:#333,color:#fff
    style OpenShift fill:#e74c3c,stroke:#333,color:#fff

    %% Optional external
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff

    %% Internal ODH
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style KuadrantCtrl fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style NGC fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff
