graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_REG["{name}<br/>(per-registry namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_MGR["manager-rolebinding"]
        CRB_AUTH["{name}-auth-delegator<br/>(per registry)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_LEADER["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_MGR["manager-role"]
        CR_AUTH["system:auth-delegator"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_LEADER["leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>configmaps<br/>CRUD"]
        PVCs["core<br/>persistentvolumeclaims<br/>CRUD"]
        Secrets["core<br/>secrets<br/>CRUD"]
        SvcAccounts["core<br/>serviceaccounts<br/>CRUD"]
        Services["core<br/>services<br/>CRUD"]
        Endpoints["core<br/>endpoints<br/>read-only"]
        Pods["core<br/>pods, pods/log<br/>read-only"]
        Events["core, events.k8s.io<br/>events<br/>create, patch"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>deployments<br/>CRUD"]
    end

    subgraph AuthResources["Auth API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph CRDResources["CRD / Custom Resources"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>read-only"]
        ModelRegistries["modelregistry.opendatahub.io<br/>modelregistries<br/>CRUD + finalizers + status"]
        SVM["migration.k8s.io<br/>storageversionmigrations<br/>CRUD"]
    end

    subgraph NetworkResources["Network Resources"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies<br/>CRUD"]
    end

    subgraph RBACResources["RBAC Resources"]
        CRBindings["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>CRUD"]
        RoleBindingsRes["rbac.authorization.k8s.io<br/>rolebindings, roles<br/>CRUD"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        Routes["route.openshift.io<br/>routes, routes/custom-host<br/>CRUD"]
        Groups["user.openshift.io<br/>groups<br/>CRUD"]
        Ingresses["config.openshift.io<br/>ingresses<br/>read-only"]
    end

    subgraph PlatformResources["Platform Resources (read-only)"]
        PlatformMR["components.platform<br/>.opendatahub.io<br/>modelregistries<br/>read-only"]
        PlatformAuth["services.platform<br/>.opendatahub.io<br/>auths<br/>read-only"]
    end

    %% Operator SA bindings
    SA_CM -->|"bound via"| CRB_MGR
    CRB_MGR -->|"grants"| CR_MGR
    SA_CM -->|"bound via"| RB_LEADER
    RB_LEADER -->|"grants"| R_LEADER

    %% Per-registry SA bindings
    SA_REG -->|"bound via"| CRB_AUTH
    CRB_AUTH -->|"grants"| CR_AUTH

    %% manager-role permissions
    CR_MGR -->|"CRUD"| ConfigMaps
    CR_MGR -->|"CRUD"| PVCs
    CR_MGR -->|"CRUD"| Secrets
    CR_MGR -->|"CRUD"| SvcAccounts
    CR_MGR -->|"CRUD"| Services
    CR_MGR -->|"read"| Endpoints
    CR_MGR -->|"read"| Pods
    CR_MGR -->|"create,patch"| Events
    CR_MGR -->|"CRUD"| Deployments
    CR_MGR -->|"create"| TokenReviews
    CR_MGR -->|"create"| SAR
    CR_MGR -->|"read"| CRDs
    CR_MGR -->|"CRUD"| ModelRegistries
    CR_MGR -->|"CRUD"| SVM
    CR_MGR -->|"CRUD"| NetworkPolicies
    CR_MGR -->|"CRUD"| CRBindings
    CR_MGR -->|"CRUD"| RoleBindingsRes
    CR_MGR -->|"CRUD"| Routes
    CR_MGR -->|"CRUD"| Groups
    CR_MGR -->|"read"| Ingresses
    CR_MGR -->|"read"| PlatformMR
    CR_MGR -->|"read"| PlatformAuth

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_REG fill:#4a90e2,color:#fff
    style CR_MGR fill:#f5a623,color:#fff
    style CR_AUTH fill:#f5a623,color:#fff
    style R_LEADER fill:#f5a623,color:#fff
    style CRB_MGR fill:#bd10e0,color:#fff
    style CRB_AUTH fill:#bd10e0,color:#fff
    style RB_LEADER fill:#bd10e0,color:#fff
    style ModelRegistries fill:#7ed321,color:#fff
    style PlatformMR fill:#7ed321,color:#fff
    style PlatformAuth fill:#7ed321,color:#fff
    style TokenReviews fill:#d0021b,color:#fff
    style SAR fill:#d0021b,color:#fff
