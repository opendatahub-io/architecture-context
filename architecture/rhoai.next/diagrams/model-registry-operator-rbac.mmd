graph TD
    subgraph ServiceAccounts["Service Accounts"]
        ControllerSA["controller-manager<br/>(Operator SA)"]
        RegistrySA["{name}<br/>(Per-Registry SA)"]
        CatalogSA["model-catalog<br/>(Catalog SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        ManagerCRB["manager-rolebinding"]
        AuthDelegatorCRB["{name}-auth-delegator"]
        CatalogAuthCRB["model-catalog-auth-delegator"]
        LeaderCRB["leader-election-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        ManagerCR["manager-role"]
        AuthDelegatorCR["system:auth-delegator"]
        LeaderCR["leader-election-role"]
    end

    subgraph PerInstanceRBAC["Per-Instance RBAC"]
        RegistryRole["{name} Role<br/>(per-registry namespace)"]
        RegistryRB["{name}-rolebinding"]
        UsersGroup["{name}-users Group<br/>(OpenShift)"]
    end

    subgraph ModelRegistryCRD["modelregistry.opendatahub.io"]
        MR_Resources["modelregistries<br/>modelregistries/status<br/>modelregistries/finalizers"]
    end

    subgraph CoreResources["Core API Resources"]
        Core_RW["services, serviceaccounts<br/>configmaps, secrets<br/>persistentvolumeclaims<br/>events"]
        Core_RO["pods, pods/log<br/>endpoints"]
    end

    subgraph AppsResources["Apps API Resources"]
        Apps_RW["deployments"]
    end

    subgraph OpenShiftResources["OpenShift API Resources"]
        OS_Routes["route.openshift.io<br/>routes, routes/custom-host"]
        OS_Groups["user.openshift.io<br/>groups"]
        OS_Config["config.openshift.io<br/>ingresses, apiservers"]
    end

    subgraph RBACResources["RBAC API Resources"]
        RBAC_RW["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterrolebindings"]
    end

    subgraph AuthResources["Auth API Resources"]
        Auth_Create["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph NetworkResources["Network API Resources"]
        Net_RW["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph GatewayResources["Gateway API Resources"]
        GW_RW["gateway.networking.k8s.io<br/>httproutes<br/>referencegrants"]
    end

    subgraph PlatformResources["Platform API Resources"]
        Platform_RO["components.platform.opendatahub.io<br/>modelregistries<br/>services.platform.opendatahub.io<br/>auths"]
    end

    subgraph MigrationResources["Migration API Resources"]
        Migration_RW["migration.k8s.io<br/>storageversionmigrations"]
        CRD_RO["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    %% Controller Manager bindings
    ControllerSA -->|bound via| ManagerCRB
    ManagerCRB -->|grants| ManagerCR
    ControllerSA -->|bound via| LeaderCRB
    LeaderCRB -->|grants| LeaderCR

    %% Manager role permissions
    ManagerCR -->|"get, list, watch<br/>create, update, patch, delete"| MR_Resources
    ManagerCR -->|"CRUD"| Core_RW
    ManagerCR -->|"get, list, watch"| Core_RO
    ManagerCR -->|"CRUD"| Apps_RW
    ManagerCR -->|"CRUD"| OS_Routes
    ManagerCR -->|"CRUD"| OS_Groups
    ManagerCR -->|"get, list, watch"| OS_Config
    ManagerCR -->|"CRUD"| RBAC_RW
    ManagerCR -->|"create"| Auth_Create
    ManagerCR -->|"CRUD"| Net_RW
    ManagerCR -->|"CRUD"| GW_RW
    ManagerCR -->|"get, list, watch"| Platform_RO
    ManagerCR -->|"CRUD"| Migration_RW
    ManagerCR -->|"get, list, watch"| CRD_RO

    %% Auth delegator bindings
    RegistrySA -->|bound via| AuthDelegatorCRB
    AuthDelegatorCRB -->|grants| AuthDelegatorCR
    CatalogSA -->|bound via| CatalogAuthCRB
    CatalogAuthCRB -->|grants| AuthDelegatorCR

    %% Per-instance RBAC
    UsersGroup -->|bound via| RegistryRB
    RegistryRB -->|grants| RegistryRole

    %% Styling
    style ControllerSA fill:#4a90e2,stroke:#333,color:#fff
    style RegistrySA fill:#4a90e2,stroke:#333,color:#fff
    style CatalogSA fill:#4a90e2,stroke:#333,color:#fff
    style ManagerCR fill:#f5a623,stroke:#333
    style AuthDelegatorCR fill:#f5a623,stroke:#333
    style LeaderCR fill:#f5a623,stroke:#333
    style RegistryRole fill:#f5a623,stroke:#333
    style MR_Resources fill:#7ed321,stroke:#333
    style Core_RW fill:#7ed321,stroke:#333
    style Core_RO fill:#7ed321,stroke:#333
    style Apps_RW fill:#7ed321,stroke:#333
    style OS_Routes fill:#7ed321,stroke:#333
    style OS_Groups fill:#7ed321,stroke:#333
    style OS_Config fill:#7ed321,stroke:#333
    style RBAC_RW fill:#7ed321,stroke:#333
    style Auth_Create fill:#7ed321,stroke:#333
    style Net_RW fill:#7ed321,stroke:#333
    style GW_RW fill:#7ed321,stroke:#333
    style Platform_RO fill:#7ed321,stroke:#333
    style Migration_RW fill:#7ed321,stroke:#333
    style CRD_RO fill:#7ed321,stroke:#333
    style UsersGroup fill:#9b59b6,stroke:#333,color:#fff
