graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Reg["{registry-name}<br/>(per-registry SA)"]
        SA_Cat["model-catalog<br/>(catalog SA)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Mgr["manager-rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_RegAuth["{registry-name}-auth-delegator"]
        CRB_CatAuth["model-catalog-kube-rbac-proxy"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Users["{registry-name}-users<br/>({namespace})"]
        RB_CatAdmin["model-catalog-admin<br/>({namespace})"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Mgr["manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_AuthDel["system:auth-delegator"]
        CR_Admin["modelregistry-admin-role"]
        CR_Editor["modelregistry-editor-role"]
        CR_Viewer["modelregistry-viewer-role"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role"]
        R_User["registry-user-{name}"]
        R_CatAdmin2["model-catalog-admin"]
    end

    subgraph MgrResources["manager-role Resources"]
        MR_CRD["modelregistry.opendatahub.io<br/>modelregistries<br/>+ status + finalizers"]
        MR_Apps["apps<br/>deployments"]
        MR_Core["core<br/>services, serviceaccounts<br/>configmaps, secrets, PVCs<br/>pods, pods/log, endpoints, events"]
        MR_Route["route.openshift.io<br/>routes, routes/custom-host"]
        MR_User["user.openshift.io<br/>groups"]
        MR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterrolebindings"]
        MR_Net["networking.k8s.io<br/>networkpolicies"]
        MR_Auth["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
        MR_OCP["config.openshift.io<br/>ingresses"]
        MR_Mig["migration.k8s.io<br/>storageversionmigrations"]
        MR_CRDDef["apiextensions.k8s.io<br/>customresourcedefinitions"]
        MR_Platform["components.platform.opendatahub.io<br/>modelregistries<br/>services.platform.opendatahub.io<br/>auths"]
    end

    subgraph UserResources["Per-Registry User Resources"]
        UR_Svc["core<br/>services (resourceName: {name})"]
        UR_Ep["core<br/>endpoints (resourceName: {name})"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        LR_CM["core<br/>configmaps"]
        LR_Lease["coordination.k8s.io<br/>leases"]
    end

    %% SA → CRB/RB
    SA_CM -->|"bound via"| CRB_Mgr
    SA_CM -->|"bound via"| CRB_Proxy
    SA_CM -->|"bound via"| RB_Leader
    SA_Reg -->|"bound via"| CRB_RegAuth
    SA_Cat -->|"bound via"| CRB_CatAuth

    %% CRB → CR
    CRB_Mgr -->|"grants"| CR_Mgr
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_RegAuth -->|"grants"| CR_AuthDel
    CRB_CatAuth -->|"grants"| CR_AuthDel

    %% RB → R
    RB_Leader -->|"grants"| R_Leader
    RB_Users -->|"grants to Group:<br/>{registry-name}-users"| R_User
    RB_CatAdmin -->|"grants to<br/>admin groups from Auth CR"| R_CatAdmin2

    %% CR → Resources
    CR_Mgr -->|"full CRUD"| MR_CRD
    CR_Mgr -->|"full CRUD"| MR_Apps
    CR_Mgr -->|"full CRUD"| MR_Core
    CR_Mgr -->|"full CRUD"| MR_Route
    CR_Mgr -->|"full CRUD"| MR_User
    CR_Mgr -->|"full CRUD"| MR_RBAC
    CR_Mgr -->|"full CRUD"| MR_Net
    CR_Mgr -->|"create"| MR_Auth
    CR_Mgr -->|"read only"| MR_OCP
    CR_Mgr -->|"full CRUD"| MR_Mig
    CR_Mgr -->|"read only"| MR_CRDDef
    CR_Mgr -->|"read only"| MR_Platform

    CR_Proxy -->|"create"| MR_Auth

    %% R → Resources
    R_User -->|"get"| UR_Svc
    R_User -->|"get"| UR_Ep
    R_Leader -->|"full CRUD"| LR_CM
    R_Leader -->|"full CRUD"| LR_Lease

    %% User-facing roles
    CR_Admin -.->|"all verbs"| MR_CRD
    CR_Editor -.->|"CRUD"| MR_CRD
    CR_Viewer -.->|"read only"| MR_CRD
    CR_Metrics -.->|"get /metrics"| MetricsURL["/metrics<br/>(non-resource URL)"]

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Reg fill:#4a90e2,stroke:#333,color:#fff
    style SA_Cat fill:#4a90e2,stroke:#333,color:#fff

    style CR_Mgr fill:#f5a623,stroke:#333,color:#000
    style CR_Proxy fill:#f5a623,stroke:#333,color:#000
    style CR_Metrics fill:#f5a623,stroke:#333,color:#000
    style CR_AuthDel fill:#f5a623,stroke:#333,color:#000
    style CR_Admin fill:#f5a623,stroke:#333,color:#000
    style CR_Editor fill:#f5a623,stroke:#333,color:#000
    style CR_Viewer fill:#f5a623,stroke:#333,color:#000

    style R_Leader fill:#ffcc80,stroke:#333,color:#000
    style R_User fill:#ffcc80,stroke:#333,color:#000
    style R_CatAdmin2 fill:#ffcc80,stroke:#333,color:#000

    style MR_CRD fill:#7ed321,stroke:#333,color:#000
    style MR_Apps fill:#7ed321,stroke:#333,color:#000
    style MR_Core fill:#7ed321,stroke:#333,color:#000
    style MR_Route fill:#7ed321,stroke:#333,color:#000
    style MR_User fill:#7ed321,stroke:#333,color:#000
    style MR_RBAC fill:#7ed321,stroke:#333,color:#000
    style MR_Net fill:#7ed321,stroke:#333,color:#000
    style MR_Auth fill:#7ed321,stroke:#333,color:#000
    style MR_OCP fill:#7ed321,stroke:#333,color:#000
    style MR_Mig fill:#7ed321,stroke:#333,color:#000
    style MR_CRDDef fill:#7ed321,stroke:#333,color:#000
    style MR_Platform fill:#7ed321,stroke:#333,color:#000

    style UR_Svc fill:#a8e6cf,stroke:#333,color:#000
    style UR_Ep fill:#a8e6cf,stroke:#333,color:#000
    style LR_CM fill:#a8e6cf,stroke:#333,color:#000
    style LR_Lease fill:#a8e6cf,stroke:#333,color:#000
    style MetricsURL fill:#a8e6cf,stroke:#333,color:#000
