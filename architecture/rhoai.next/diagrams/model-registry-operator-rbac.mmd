graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Registry["{registry-name}<br/>(registry namespace)"]
        SA_Catalog["model-catalog<br/>(registry namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_AuthDeleg["{registry-name}-auth-delegator"]
        CRB_CatalogAuth["model-catalog-kube-rbac-proxy"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Users["{registry-name}-users<br/>(registry namespace)"]
        RB_CatalogAdmin["model-catalog-admin<br/>(registry namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_Admin["modelregistry-admin-role"]
        CR_Editor["modelregistry-editor-role"]
        CR_Viewer["modelregistry-viewer-role"]
        CR_AuthDeleg["system:auth-delegator"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role"]
        R_User["registry-user-{name}"]
        R_CatalogAdmin["model-catalog-admin"]
    end

    subgraph ManagerResources["manager-role Permissions"]
        MR_CRD["modelregistry.opendatahub.io<br/>modelregistries<br/>+ /status + /finalizers"]
        MR_Apps["apps<br/>deployments"]
        MR_Core["core<br/>services, serviceaccounts<br/>configmaps, secrets, PVCs"]
        MR_CoreRO["core<br/>pods, pods/log, endpoints<br/>(read-only)"]
        MR_Events["events.k8s.io<br/>events"]
        MR_Routes["route.openshift.io<br/>routes, routes/custom-host"]
        MR_Users["user.openshift.io<br/>groups"]
        MR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>clusterrolebindings"]
        MR_NetPol["networking.k8s.io<br/>networkpolicies"]
        MR_Auth["authentication.k8s.io<br/>tokenreviews"]
        MR_Authz["authorization.k8s.io<br/>subjectaccessreviews"]
        MR_Ingress["config.openshift.io<br/>ingresses (read-only)"]
        MR_Migration["migration.k8s.io<br/>storageversionmigrations"]
        MR_CRDDefs["apiextensions.k8s.io<br/>CRDs (read-only)"]
        MR_Platform["components.platform +<br/>services.platform<br/>(read-only)"]
    end

    subgraph ProxyResources["proxy-role Permissions"]
        PR_Auth["authentication.k8s.io<br/>tokenreviews (create)"]
        PR_Authz["authorization.k8s.io<br/>subjectaccessreviews (create)"]
    end

    subgraph UserResources["Per-Registry User Permissions"]
        UR_Svc["core<br/>services/{name} (get)"]
        UR_Ep["core<br/>endpoints/{name} (get)"]
    end

    subgraph LeaderResources["Leader Election Permissions"]
        LR_CM["core<br/>configmaps"]
        LR_Leases["coordination.k8s.io<br/>leases"]
    end

    %% Service Account → Bindings
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Proxy
    SA_CM -->|"bound via"| RB_Leader
    SA_Registry -->|"bound via"| CRB_AuthDeleg
    SA_Catalog -->|"bound via"| CRB_CatalogAuth

    %% Bindings → Roles
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_AuthDeleg -->|"grants"| CR_AuthDeleg
    CRB_CatalogAuth -->|"grants"| CR_AuthDeleg
    RB_Leader -->|"grants"| R_Leader
    RB_Users -->|"grants to Group:<br/>{registry-name}-users"| R_User
    RB_CatalogAdmin -->|"grants to<br/>admin groups from Auth CR"| R_CatalogAdmin

    %% ClusterRoles → Resources
    CR_Manager -->|"full CRUD"| MR_CRD
    CR_Manager -->|"full CRUD"| MR_Apps
    CR_Manager -->|"full CRUD"| MR_Core
    CR_Manager -->|"get, list, watch"| MR_CoreRO
    CR_Manager -->|"create, patch"| MR_Events
    CR_Manager -->|"full CRUD"| MR_Routes
    CR_Manager -->|"full CRUD"| MR_Users
    CR_Manager -->|"full CRUD"| MR_RBAC
    CR_Manager -->|"full CRUD"| MR_NetPol
    CR_Manager -->|"create"| MR_Auth
    CR_Manager -->|"create"| MR_Authz
    CR_Manager -->|"get, list, watch"| MR_Ingress
    CR_Manager -->|"full CRUD"| MR_Migration
    CR_Manager -->|"get, list, watch"| MR_CRDDefs
    CR_Manager -->|"get, list, watch"| MR_Platform

    CR_Proxy -->|"create"| PR_Auth
    CR_Proxy -->|"create"| PR_Authz

    R_User -->|"get"| UR_Svc
    R_User -->|"get"| UR_Ep

    R_Leader -->|"full CRUD"| LR_CM
    R_Leader -->|"full CRUD"| LR_Leases

