graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_MR["&lt;registry-name&gt;<br/>(registry namespace)"]
        SA_MC["model-catalog<br/>(registry namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Proxy["proxy-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_MR_Auth["&lt;registry&gt;-auth-delegator<br/>(ClusterRoleBinding)"]
        CRB_MC_Auth["model-catalog-auth-delegator<br/>(ClusterRoleBinding)"]
    end

    subgraph NSRoleBindings["Namespace Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding, operator NS)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Proxy["proxy-role<br/>(ClusterRole)"]
        CR_AuthDelegator["system:auth-delegator<br/>(ClusterRole, built-in)"]
        CR_Admin["modelregistry-admin-role<br/>(ClusterRole)"]
        CR_Editor["modelregistry-editor-role<br/>(ClusterRole)"]
        CR_Viewer["modelregistry-viewer-role<br/>(ClusterRole)"]
    end

    subgraph NSRoles["Namespace Roles"]
        R_Leader["leader-election-role<br/>(Role, operator NS)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction LR
        Core["core API<br/>configmaps, pvcs,<br/>secrets, serviceaccounts,<br/>services<br/>→ CRUD"]
        CoreRO["core API<br/>endpoints, pods,<br/>pods/log<br/>→ read-only"]
        Events["core, events.k8s.io<br/>events<br/>→ create, patch"]
        Apps["apps<br/>deployments<br/>→ CRUD"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>→ read-only"]
        MRResources["modelregistry<br/>.opendatahub.io<br/>modelregistries<br/>+ finalizers + status<br/>→ CRUD"]
        NetPol["networking.k8s.io<br/>networkpolicies<br/>→ CRUD"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/>→ CRUD"]
        Routes["route.openshift.io<br/>routes,<br/>routes/custom-host<br/>→ CRUD"]
        Groups["user.openshift.io<br/>groups<br/>→ CRUD"]
        Migration["migration.k8s.io<br/>storageversionmigrations<br/>→ CRUD"]
        Platform["components.platform /<br/>services.platform<br/>.opendatahub.io<br/>→ read-only"]
        OSConfig["config.openshift.io<br/>ingresses<br/>→ read-only"]
    end

    subgraph ProxyResources["proxy-role Resources"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>→ create"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        LeaderCM["core<br/>configmaps, events<br/>→ CRUD"]
        Leases["coordination.k8s.io<br/>leases<br/>→ CRUD"]
    end

    subgraph UserFacingResources["User-Facing Role Resources"]
        AdminRes["modelregistry.opendatahub.io<br/>modelregistries<br/>→ * (all verbs)"]
        EditorRes["modelregistry.opendatahub.io<br/>modelregistries<br/>→ CRUD"]
        ViewerRes["modelregistry.opendatahub.io<br/>modelregistries<br/>→ read-only"]
    end

    %% SA to Bindings
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Proxy
    SA_CM -->|"bound via"| RB_Leader
    SA_MR -->|"bound via"| CRB_MR_Auth
    SA_MC -->|"bound via"| CRB_MC_Auth

    %% Bindings to Roles
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_MR_Auth -->|"grants"| CR_AuthDelegator
    CRB_MC_Auth -->|"grants"| CR_AuthDelegator
    RB_Leader -->|"grants"| R_Leader

    %% Roles to Resources
    CR_Manager -->|"permits"| Core
    CR_Manager -->|"permits"| CoreRO
    CR_Manager -->|"permits"| Events
    CR_Manager -->|"permits"| Apps
    CR_Manager -->|"permits"| CRDs
    CR_Manager -->|"permits"| MRResources
    CR_Manager -->|"permits"| NetPol
    CR_Manager -->|"permits"| RBAC_Res
    CR_Manager -->|"permits"| Routes
    CR_Manager -->|"permits"| Groups
    CR_Manager -->|"permits"| Migration
    CR_Manager -->|"permits"| Platform
    CR_Manager -->|"permits"| OSConfig

    CR_Proxy -->|"permits"| TokenReview
    CR_Proxy -->|"permits"| SAR

    R_Leader -->|"permits"| LeaderCM
    R_Leader -->|"permits"| Leases

    CR_Admin -->|"permits"| AdminRes
    CR_Editor -->|"permits"| EditorRes
    CR_Viewer -->|"permits"| ViewerRes

