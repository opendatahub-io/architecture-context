graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_REG["{registry-name}<br/>(registry namespace)"]
        SA_CAT["model-catalog<br/>(target namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_MGR["manager-rolebinding"]
        CRB_REG_AUTH["{registry-name}-auth-delegator"]
        CRB_CAT_AUTH["model-catalog-auth-delegator"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_MGR["manager-role"]
        CR_AUTH["system:auth-delegator"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_LEADER["leader-election-rolebinding<br/>(operator namespace)"]
        RB_REG["{registry-name}<br/>(registry namespace)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_LEADER["leader-election-role"]
        R_REG["{registry-name}"]
    end

    subgraph Groups["OpenShift Groups"]
        GRP_REG["{registry-name}-users"]
    end

    %% Manager role permissions
    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB
        subgraph ModelRegistryCRDs["modelregistry.opendatahub.io"]
            MR_RES["modelregistries<br/>modelregistries/status<br/>modelregistries/finalizers"]
        end
        subgraph CoreResources["core API"]
            CORE_RW["configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>(CRUD)"]
            CORE_RO["endpoints, pods, pods/log<br/>(get, list, watch)"]
        end
        subgraph AppsResources["apps"]
            APPS_RES["deployments<br/>(CRUD)"]
        end
        subgraph OpenShiftResources["OpenShift APIs"]
            OS_ROUTE["route.openshift.io<br/>routes, routes/custom-host<br/>(CRUD)"]
            OS_USER["user.openshift.io<br/>groups (CRUD)"]
        end
        subgraph RBACResources["rbac.authorization.k8s.io"]
            RBAC_RES["roles, rolebindings,<br/>clusterrolebindings<br/>(CRUD)"]
        end
        subgraph AuthResources["Auth APIs"]
            AUTH_TOKEN["authentication.k8s.io<br/>tokenreviews (create)"]
            AUTH_SAR["authorization.k8s.io<br/>subjectaccessreviews (create)"]
        end
        subgraph NetworkResources["Networking"]
            NET_POL["networking.k8s.io<br/>networkpolicies (CRUD)"]
            GW_ROUTE["gateway.networking.k8s.io<br/>httproutes (CRUD)<br/>referencegrants (create, get, list, watch)"]
        end
        subgraph MigrationResources["Migration"]
            MIG_RES["migration.k8s.io<br/>storageversionmigrations (CRUD)"]
        end
        subgraph PlatformResources["Platform (read-only)"]
            PLAT_MR["components.platform.opendatahub.io<br/>modelregistries (get, list, watch)"]
            PLAT_AUTH["services.platform.opendatahub.io<br/>auths (get, list, watch)"]
            PLAT_CFG["config.openshift.io<br/>ingresses, apiservers<br/>(get, list, watch)"]
            PLAT_CRD["apiextensions.k8s.io<br/>customresourcedefinitions<br/>(get, list, watch)"]
        end
    end

    %% Bindings
    SA_CM -->|bound via| CRB_MGR
    CRB_MGR -->|grants| CR_MGR
    CR_MGR -->|permissions| ManagerPermissions

    SA_CM -->|bound via| RB_LEADER
    RB_LEADER -->|grants| R_LEADER

    SA_REG -->|bound via| CRB_REG_AUTH
    CRB_REG_AUTH -->|grants| CR_AUTH

    SA_CAT -->|bound via| CRB_CAT_AUTH
    CRB_CAT_AUTH -->|grants| CR_AUTH

    GRP_REG -->|bound via| RB_REG
    RB_REG -->|grants| R_REG

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_REG fill:#4a90e2,color:#fff
    style SA_CAT fill:#4a90e2,color:#fff
    style CR_MGR fill:#f5a623,color:#fff
    style CR_AUTH fill:#f5a623,color:#fff
    style R_LEADER fill:#f5a623,color:#fff
    style R_REG fill:#f5a623,color:#fff
    style CRB_MGR fill:#e8e8e8,color:#333
    style CRB_REG_AUTH fill:#e8e8e8,color:#333
    style CRB_CAT_AUTH fill:#e8e8e8,color:#333
    style RB_LEADER fill:#e8e8e8,color:#333
    style RB_REG fill:#e8e8e8,color:#333
    style GRP_REG fill:#7ed321,color:#fff
    style MR_RES fill:#d5e8d4,color:#333
    style CORE_RW fill:#d5e8d4,color:#333
    style CORE_RO fill:#d5e8d4,color:#333
    style APPS_RES fill:#d5e8d4,color:#333
    style OS_ROUTE fill:#d5e8d4,color:#333
    style OS_USER fill:#d5e8d4,color:#333
    style RBAC_RES fill:#d5e8d4,color:#333
    style AUTH_TOKEN fill:#d5e8d4,color:#333
    style AUTH_SAR fill:#d5e8d4,color:#333
    style NET_POL fill:#d5e8d4,color:#333
    style GW_ROUTE fill:#d5e8d4,color:#333
    style MIG_RES fill:#d5e8d4,color:#333
    style PLAT_MR fill:#fff2cc,color:#333
    style PLAT_AUTH fill:#fff2cc,color:#333
    style PLAT_CFG fill:#fff2cc,color:#333
    style PLAT_CRD fill:#fff2cc,color:#333
