graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_MR["&lt;registry-name&gt;<br/>(registry namespace)"]
        SA_MC["model-catalog<br/>(registry namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_MGR["manager-rolebinding"]
        CRB_PROXY["proxy-rolebinding"]
        CRB_MR_AUTH["&lt;registry-name&gt;-auth-delegator"]
        CRB_MC_AUTH["model-catalog-auth-delegator"]
    end

    subgraph RoleBindings["Role Bindings (namespaced)"]
        RB_LEADER["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_MGR["manager-role"]
        CR_PROXY["proxy-role"]
        CR_AUTHDELEG["system:auth-delegator"]
        CR_ADMIN["modelregistry-admin-role"]
        CR_EDITOR["modelregistry-editor-role"]
        CR_VIEWER["modelregistry-viewer-role"]
    end

    subgraph Roles["Roles (namespaced)"]
        R_LEADER["leader-election-role"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction LR
        RES_CORE["core<br/>configmaps, PVCs,<br/>secrets, SAs, services,<br/>endpoints, pods, pods/log,<br/>events"]
        RES_APPS["apps<br/>deployments"]
        RES_MR["modelregistry.<br/>opendatahub.io<br/>modelregistries,<br/>modelregistries/finalizers,<br/>modelregistries/status"]
        RES_NET["networking.k8s.io<br/>networkpolicies"]
        RES_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles"]
        RES_ROUTE["route.openshift.io<br/>routes, routes/custom-host"]
        RES_AUTH_K8S["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
        RES_PLATFORM["components.platform.<br/>opendatahub.io<br/>modelregistries<br/>services.platform.<br/>opendatahub.io<br/>auths"]
        RES_MIGRATION["migration.k8s.io<br/>storageversionmigrations"]
        RES_OS["config.openshift.io<br/>ingresses<br/>user.openshift.io<br/>groups"]
        RES_CRD["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph ProxyResources["proxy-role Resources"]
        RES_PROXY_AUTH["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        RES_LEADER["core<br/>configmaps, events<br/>coordination.k8s.io<br/>leases"]
    end

    subgraph UserFacingResources["User-Facing Role Resources"]
        RES_USER["modelregistry.<br/>opendatahub.io<br/>modelregistries"]
    end

    %% SA → Bindings
    SA_CM -->|"bound via"| CRB_MGR
    SA_CM -->|"bound via"| CRB_PROXY
    SA_CM -->|"bound via"| RB_LEADER
    SA_MR -->|"bound via"| CRB_MR_AUTH
    SA_MC -->|"bound via"| CRB_MC_AUTH

    %% Bindings → Roles
    CRB_MGR -->|"grants"| CR_MGR
    CRB_PROXY -->|"grants"| CR_PROXY
    CRB_MR_AUTH -->|"grants"| CR_AUTHDELEG
    CRB_MC_AUTH -->|"grants"| CR_AUTHDELEG
    RB_LEADER -->|"grants"| R_LEADER

    %% Roles → Resources
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_CORE
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_APPS
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_MR
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_NET
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_RBAC
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_ROUTE
    CR_MGR -->|"create"| RES_AUTH_K8S
    CR_MGR -->|"get, list, watch"| RES_PLATFORM
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_MIGRATION
    CR_MGR -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_OS
    CR_MGR -->|"get, list, watch"| RES_CRD

    CR_PROXY -->|"create"| RES_PROXY_AUTH

    R_LEADER -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RES_LEADER

    CR_ADMIN -->|"* (all verbs)"| RES_USER
    CR_EDITOR -->|"create, delete,<br/>get, list, patch,<br/>update, watch"| RES_USER
    CR_VIEWER -->|"get, list, watch"| RES_USER

