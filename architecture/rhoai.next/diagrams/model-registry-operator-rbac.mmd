graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Registry["{registry-name}<br/>(per-registry SA)"]
        SA_Catalog["model-catalog<br/>(catalog SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_AuthDeleg_Registry["{registry-name}-auth-delegator"]
        CRB_AuthDeleg_Catalog["model-catalog-kube-rbac-proxy"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_MetricsReader["metrics-reader"]
        CR_Admin["modelregistry-admin-role"]
        CR_Editor["modelregistry-editor-role"]
        CR_Viewer["modelregistry-viewer-role"]
    end

    subgraph NamespaceRoles["Namespace-Scoped Roles"]
        R_LeaderElection["leader-election-role"]
        R_RegistryUser["registry-user-{name}<br/>(per-registry)"]
        R_CatalogAdmin["model-catalog-admin"]
    end

    subgraph NamespaceBindings["Namespace-Scoped RoleBindings"]
        RB_LeaderElection["leader-election-rolebinding"]
        RB_RegistryUsers["{registry-name}-users"]
        RB_CatalogAdmin["model-catalog-admin"]
    end

    subgraph Resources_Platform["Platform API Resources"]
        Res_MR["modelregistry.opendatahub.io<br/>modelregistries<br/>+ status, finalizers"]
        Res_PlatformMR["components.platform.opendatahub.io<br/>modelregistries"]
        Res_PlatformAuth["services.platform.opendatahub.io<br/>auths"]
    end

    subgraph Resources_K8s["Kubernetes Core Resources"]
        Res_Deployments["apps<br/>deployments"]
        Res_Services["core<br/>services, serviceaccounts"]
        Res_ConfigSecrets["core<br/>configmaps, secrets, PVCs"]
        Res_Pods["core<br/>pods, pods/log, endpoints"]
        Res_Events["core, events.k8s.io<br/>events"]
    end

    subgraph Resources_OpenShift["OpenShift Resources"]
        Res_Routes["route.openshift.io<br/>routes, routes/custom-host"]
        Res_Groups["user.openshift.io<br/>groups"]
        Res_Ingresses["config.openshift.io<br/>ingresses"]
    end

    subgraph Resources_RBAC["RBAC & Auth Resources"]
        Res_RolesBindings["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterrolebindings"]
        Res_NetPol["networking.k8s.io<br/>networkpolicies"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph Resources_Migration["Migration Resources"]
        Res_SVM["migration.k8s.io<br/>storageversionmigrations"]
        Res_CRD["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph Resources_LeaderElection["Leader Election Resources"]
        Res_CM_LE["core<br/>configmaps"]
        Res_Leases["coordination.k8s.io<br/>leases"]
    end

    %% Controller-manager bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_Proxy
    SA_Controller -->|"bound via"| RB_LeaderElection

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Proxy -->|"grants"| CR_Proxy
    RB_LeaderElection -->|"grants"| R_LeaderElection

    %% Manager-role permissions
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_MR
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_Deployments
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_Services
    CR_Manager -->|"create,get,list,watch,<br/>patch,update,delete"| Res_ConfigSecrets
    CR_Manager -->|"get,list,watch"| Res_Pods
    CR_Manager -->|"create,patch"| Res_Events
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_Routes
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_Groups
    CR_Manager -->|"get,list,watch"| Res_Ingresses
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_RolesBindings
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_NetPol
    CR_Manager -->|"create"| Res_TokenReview
    CR_Manager -->|"create"| Res_SAR
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| Res_SVM
    CR_Manager -->|"get,list,watch"| Res_CRD
    CR_Manager -->|"get,list,watch"| Res_PlatformMR
    CR_Manager -->|"get,list,watch"| Res_PlatformAuth

    %% Proxy-role permissions
    CR_Proxy -->|"create"| Res_TokenReview
    CR_Proxy -->|"create"| Res_SAR

    %% Leader election permissions
    R_LeaderElection -->|"get,list,watch,create,<br/>update,patch,delete"| Res_CM_LE
    R_LeaderElection -->|"get,list,watch,create,<br/>update,patch,delete"| Res_Leases

    %% Per-registry SA bindings
    SA_Registry -->|"bound via"| CRB_AuthDeleg_Registry
    CRB_AuthDeleg_Registry -->|"grants"| CR_AuthDeleg

    %% Per-registry user access
    RB_RegistryUsers -->|"grants"| R_RegistryUser
    R_RegistryUser -->|"get (resourceName: {name})"| Res_Services

    %% Catalog SA bindings
    SA_Catalog -->|"bound via"| CRB_AuthDeleg_Catalog
    CRB_AuthDeleg_Catalog -->|"grants"| CR_AuthDeleg
    RB_CatalogAdmin -->|"grants"| R_CatalogAdmin

    %% User-facing roles
    CR_Admin -->|"* (all verbs)"| Res_MR
    CR_Editor -->|"create,delete,get,list,<br/>watch,patch,update"| Res_MR
    CR_Viewer -->|"get,list,watch"| Res_MR

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Registry fill:#4a90e2,stroke:#333,color:#fff
    style SA_Catalog fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Proxy fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDeleg fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#fff
    style CR_Admin fill:#f5a623,stroke:#333,color:#fff
    style CR_Editor fill:#f5a623,stroke:#333,color:#fff
    style CR_Viewer fill:#f5a623,stroke:#333,color:#fff

    style R_LeaderElection fill:#e6b800,stroke:#333,color:#fff
    style R_RegistryUser fill:#e6b800,stroke:#333,color:#fff
    style R_CatalogAdmin fill:#e6b800,stroke:#333,color:#fff

    style Res_MR fill:#7ed321,stroke:#333,color:#fff
    style Res_PlatformMR fill:#7ed321,stroke:#333,color:#fff
    style Res_PlatformAuth fill:#7ed321,stroke:#333,color:#fff
    style Res_Deployments fill:#7ed321,stroke:#333,color:#fff
    style Res_Services fill:#7ed321,stroke:#333,color:#fff
    style Res_ConfigSecrets fill:#7ed321,stroke:#333,color:#fff
    style Res_Pods fill:#7ed321,stroke:#333,color:#fff
    style Res_Events fill:#7ed321,stroke:#333,color:#fff
    style Res_Routes fill:#7ed321,stroke:#333,color:#fff
    style Res_Groups fill:#7ed321,stroke:#333,color:#fff
    style Res_Ingresses fill:#7ed321,stroke:#333,color:#fff
    style Res_RolesBindings fill:#7ed321,stroke:#333,color:#fff
    style Res_NetPol fill:#7ed321,stroke:#333,color:#fff
    style Res_TokenReview fill:#7ed321,stroke:#333,color:#fff
    style Res_SAR fill:#7ed321,stroke:#333,color:#fff
    style Res_SVM fill:#7ed321,stroke:#333,color:#fff
    style Res_CRD fill:#7ed321,stroke:#333,color:#fff
    style Res_CM_LE fill:#7ed321,stroke:#333,color:#fff
    style Res_Leases fill:#7ed321,stroke:#333,color:#fff
