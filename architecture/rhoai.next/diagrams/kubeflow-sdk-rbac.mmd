graph TD
    subgraph UserAuth["User Authentication"]
        Kubeconfig["kubeconfig<br/>(User workstation)"]
        InClusterSA["In-cluster Service Account<br/>(Notebook/Pipeline pod)"]
    end

    subgraph RequiredRBAC["Required RBAC Permissions<br/>(Not defined by SDK — relies on user's SA/kubeconfig)"]
        direction TB

        subgraph TrainerPerms["Kubeflow Trainer Resources"]
            TrainJobs["trainer.kubeflow.org<br/>trainjobs"]
            ClusterRuntimes["trainer.kubeflow.org<br/>clustertrainingruntimes"]
            NamespacedRuntimes["trainer.kubeflow.org<br/>trainingruntimes"]
        end

        subgraph CorePerms["Kubernetes Core Resources"]
            Pods["core ('')<br/>pods"]
            PodLogs["core ('')<br/>pods/log"]
            Events["core ('')<br/>events"]
            ConfigMaps["core ('')<br/>configmaps"]
            Secrets["core ('')<br/>secrets"]
        end
    end

    subgraph Verbs["Required Verbs"]
        FullCRUD["create, get, list,<br/>watch, delete"]
        ReadOnly["get, list"]
        GetOnly["get"]
        ListOnly["list"]
    end

    subgraph SDKModules["SDK Modules Using Permissions"]
        TrainerClient["TrainerClient<br/>kubeflow.trainer"]
        OptimizerClient["OptimizerClient<br/>kubeflow.optimizer"]
        SparkClient["SparkClient<br/>kubeflow.spark"]
        KubeBackend["KubernetesBackend"]
    end

    %% Auth to SDK
    Kubeconfig -->|"Bearer Token"| TrainerClient
    InClusterSA -->|"SA Token"| TrainerClient
    Kubeconfig -->|"Bearer Token"| OptimizerClient
    Kubeconfig -->|"Bearer Token"| SparkClient

    %% SDK to resources
    TrainerClient -->|"CRUD"| TrainJobs
    TrainerClient -->|"Read"| ClusterRuntimes
    TrainerClient -->|"Read"| NamespacedRuntimes
    TrainerClient -->|"Read"| Pods
    TrainerClient -->|"Read"| PodLogs
    TrainerClient -->|"List"| Events
    KubeBackend -->|"Read"| ConfigMaps
    KubeBackend -->|"Read"| Secrets

    %% Verbs
    TrainJobs --- FullCRUD
    ClusterRuntimes --- ReadOnly
    NamespacedRuntimes --- ReadOnly
    Pods --- ReadOnly
    PodLogs --- GetOnly
    Events --- ListOnly
    ConfigMaps --- GetOnly
    Secrets --- GetOnly

    subgraph SecretsAccessed["Secrets Accessed"]
        DataConnection["Data Connection Secret<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT<br/>Provisioned by: User/RHOAI Dashboard<br/>Auto-rotate: No"]
        HFToken["HuggingFace Access Token<br/>(Opaque, env injection)<br/>access_token parameter<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    Secrets -->|"get"| DataConnection
    Secrets -->|"get"| HFToken

    subgraph AuthEndpoints["Authentication Endpoints"]
        K8sAPIAuth["Kubernetes API<br/>Bearer Token / kubeconfig / SA<br/>Enforcement: kube-apiserver RBAC"]
        MetricsAuth["In-pod Metrics Server (28080)<br/>⚠ No auth<br/>⚠ Unrestricted (0.0.0.0 bind)"]
        ModelRegAuth["Model Registry<br/>Bearer Token (optional)<br/>Custom CA supported<br/>Enforcement: Server-side"]
    end

    %% Styling
    style UserAuth fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style RequiredRBAC fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style TrainerPerms fill:#fdebd0,stroke:#f39c12
    style CorePerms fill:#fdebd0,stroke:#f39c12
    style Verbs fill:#d5f5e3,stroke:#27ae60
    style SDKModules fill:#d4e6f1,stroke:#2980b9
    style SecretsAccessed fill:#fce4ec,stroke:#c0392b
    style AuthEndpoints fill:#f3e5f5,stroke:#7b1fa2
    style FullCRUD fill:#c8e6c9,stroke:#388e3c
    style ReadOnly fill:#fff9c4,stroke:#f9a825
    style GetOnly fill:#fff9c4,stroke:#f9a825
    style ListOnly fill:#fff9c4,stroke:#f9a825
    style DataConnection fill:#ffcdd2,stroke:#c62828
    style HFToken fill:#ffcdd2,stroke:#c62828
    style MetricsAuth fill:#ffcdd2,stroke:#c62828
