graph TD
    subgraph "User-Provided Identity"
        SA["ServiceAccount / kubeconfig User<br/>(user-provisioned)"]
    end

    subgraph "Role Binding (user-provisioned)"
        RB["ClusterRoleBinding or RoleBinding<br/>(user must create)"]
    end

    subgraph "Required Permissions (ClusterRole / Role)"
        CR["Required Role<br/>(user-provisioned)"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| CR

    subgraph "Trainer API Resources"
        TrainJobs["trainer.kubeflow.org<br/>trainjobs"]
        TrainingRuntimes["trainer.kubeflow.org<br/>trainingruntimes"]
        ClusterTrainingRuntimes["trainer.kubeflow.org<br/>clustertrainingruntimes"]
    end

    subgraph "Katib API Resources"
        Experiments["kubeflow.org<br/>experiments"]
        Trials["kubeflow.org<br/>trials"]
    end

    subgraph "Spark API Resources"
        SparkConnects["sparkoperator.k8s.io<br/>sparkconnects"]
    end

    subgraph "Core API Resources"
        Pods["core ('')<br/>pods"]
        PodLogs["core ('')<br/>pods/log"]
        Events["core ('')<br/>events"]
        ConfigMaps["core ('')<br/>configmaps"]
        Secrets["core ('')<br/>secrets"]
    end

    %% Trainer permissions
    CR -->|"create, get, list, delete"| TrainJobs
    CR -->|"get, list"| TrainingRuntimes
    CR -->|"get, list"| ClusterTrainingRuntimes

    %% Katib permissions
    CR -->|"create, get, list, delete"| Experiments
    CR -->|"get, list"| Trials

    %% Spark permissions
    CR -->|"create, get, list, delete"| SparkConnects

    %% Core permissions
    CR -->|"get, list"| Pods
    CR -->|"get"| PodLogs
    CR -->|"list"| Events
    CR -->|"get"| ConfigMaps
    CR -->|"get"| Secrets

    %% Notes
    Note["Note: The SDK does not install any RBAC resources.<br/>All permissions must be provisioned by the user<br/>or cluster administrator."]

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style RB fill:#6c8ebf,color:#fff
    style CR fill:#f5a623,color:#fff

    style TrainJobs fill:#7ed321,color:#fff
    style TrainingRuntimes fill:#7ed321,color:#fff
    style ClusterTrainingRuntimes fill:#7ed321,color:#fff

    style Experiments fill:#7ed321,color:#fff
    style Trials fill:#7ed321,color:#fff

    style SparkConnects fill:#7ed321,color:#fff

    style Pods fill:#d5e8d4,stroke:#82b366
    style PodLogs fill:#d5e8d4,stroke:#82b366
    style Events fill:#d5e8d4,stroke:#82b366
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366

    style Note fill:#fff2cc,stroke:#d6b656,stroke-dasharray: 5 5
