graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Permitted Operations"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"access to"| ConfigMaps

    ConfigMaps --> Create
    ConfigMaps --> Delete
    ConfigMaps --> Get
    ConfigMaps --> List
    ConfigMaps --> Patch
    ConfigMaps --> Update
    ConfigMaps --> Watch

    subgraph AuthProxy["Authentication (Operator-Injected Sidecar)"]
        direction LR
        KubeRBAC["kube-rbac-proxy<br/>(RHOAI 3.x)<br/>Token validation"]
        OAuthProxy["oauth-proxy<br/>(RHOAI 2.x)<br/>OAuth flow"]
    end

    subgraph MetricsScrape["Prometheus Scraping Auth"]
        BearerToken["bearerTokenFile<br/>ServiceAccount Token<br/>GET /q/metrics"]
    end

    subgraph NoAuth["No Built-in Auth"]
        AllEndpoints["All REST endpoints<br/>No authentication<br/>No authorization<br/>Relies on auth proxy sidecar<br/>+ network isolation"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#d5e8d4,stroke:#82b366
    style Delete fill:#f8cecc,stroke:#b85450
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Patch fill:#fff2cc,stroke:#d6b656
    style Update fill:#fff2cc,stroke:#d6b656
    style Watch fill:#d5e8d4,stroke:#82b366

    style KubeRBAC fill:#f8cecc,stroke:#b85450
    style OAuthProxy fill:#f8cecc,stroke:#b85450
    style BearerToken fill:#ffe6cc,stroke:#d79b00
    style AllEndpoints fill:#f9f9f9,stroke:#999
