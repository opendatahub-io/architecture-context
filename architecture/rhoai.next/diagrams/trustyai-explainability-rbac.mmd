graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["trustyai-role"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Allowed Verbs"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permits access to"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph OperatorManaged["Operator-Managed Security (runtime)"]
        direction TB
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>(injected by trustyai-service-operator)"]
        ProxiedEndpoints["Protected Endpoints:<br/>/metrics/*, /info/*"]
        AuthN["Authentication:<br/>Bearer token / client cert"]
        AuthZ["Authorization:<br/>Kubernetes SubjectAccessReview"]

        KubeRBACProxy -->|"enforces"| AuthN
        KubeRBACProxy -->|"enforces"| AuthZ
        KubeRBACProxy -->|"protects"| ProxiedEndpoints
    end

    subgraph PrometheusAccess["Prometheus Scrape Access"]
        ServiceMonitor["ServiceMonitor<br/>(trustyai-metrics)"]
        PromSA["Prometheus ServiceAccount"]
        BearerToken["Auth: Bearer SA token"]
        MetricsEndpoint["/q/metrics endpoint<br/>Metrics: trustyai_spd, trustyai_dir"]

        ServiceMonitor -->|"configures"| PromSA
        PromSA -->|"authenticates via"| BearerToken
        BearerToken -->|"scrapes"| MetricsEndpoint
    end

    subgraph UnprotectedEndpoints["Unprotected Endpoints (base manifests)"]
        ConsumerEP["/consumer/kserve/v2<br/>In-cluster trust only"]
        HealthEP["/q/health/*<br/>Liveness + Readiness probes"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#d5e8d4,stroke:#82b366
    style Delete fill:#f8cecc,stroke:#b85450
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Patch fill:#fff2cc,stroke:#d6b656
    style Update fill:#fff2cc,stroke:#d6b656
    style Watch fill:#d5e8d4,stroke:#82b366

    style KubeRBACProxy fill:#f8cecc,stroke:#b85450,color:#fff
    style ConsumerEP fill:#ffe6cc,stroke:#d79b00
    style HealthEP fill:#ffe6cc,stroke:#d79b00
