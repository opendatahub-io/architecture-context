graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Allowed Operations"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"access to"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph AuthProxy["Authentication Proxy (Operator-Managed)"]
        direction LR
        KubeRBAC["kube-rbac-proxy<br/>(sidecar)"]
        OAuthProxy["oauth-proxy<br/>(sidecar)"]
    end

    subgraph MetricsAuth["Prometheus Metrics Authentication"]
        ServiceMonitor["ServiceMonitor"]
        BearerToken["bearerTokenFile:<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token"]
    end

    subgraph Secrets["Secrets"]
        TLSSecret["TLS Certificate<br/>kubernetes.io/tls<br/>tls.crt, tls.key<br/>Provisioned by: operator"]
        DBSecret["Database Credentials<br/>Opaque<br/>QUARKUS_DATASOURCE_USERNAME<br/>QUARKUS_DATASOURCE_PASSWORD<br/>Provisioned by: platform admin"]
        MinIOSecret["MinIO Credentials<br/>Opaque<br/>minio.access-key<br/>minio.secret-key<br/>Provisioned by: platform admin"]
    end

    SA -.->|"uses"| TLSSecret
    SA -.->|"uses"| DBSecret
    SA -.->|"uses"| MinIOSecret
    ServiceMonitor -->|"authenticates via"| BearerToken

    %% Note: Base manifests have no auth; operator injects proxy sidecars
    AuthProxy -.->|"injected by TrustyAI Operator<br/>(not in base manifests)"| SA

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style TLSSecret fill:#e74c3c,stroke:#333,color:#fff
    style DBSecret fill:#e74c3c,stroke:#333,color:#fff
    style MinIOSecret fill:#e74c3c,stroke:#333,color:#fff
    style KubeRBAC fill:#95a5a6,stroke:#333,color:#fff
    style OAuthProxy fill:#95a5a6,stroke:#333,color:#fff
    style ServiceMonitor fill:#3498db,stroke:#333,color:#fff
    style BearerToken fill:#3498db,stroke:#333,color:#fff
