graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide scope)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>ConfigMaps"]
    end

    subgraph Verbs["Permitted Operations"]
        direction LR
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"applies to"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph AuthMechanisms["Authentication & Authorization"]
        direction TB
        RESTAuth["REST Endpoints<br/>Auth: None (proxy-delegated)<br/>Enforcement: kube-rbac-proxy"]
        MetricsAuth["/q/metrics<br/>Auth: Bearer Token (SA)<br/>Enforcement: ServiceMonitor bearerTokenFile"]
        EgressAuth["Outbound to MinIO/S3<br/>Auth: Access Key / Secret Key"]
        DBAuth["Outbound to Database<br/>Auth: Username / Password"]
    end

    subgraph Secrets["Managed Secrets"]
        direction TB
        ConfigMapSecret["trustyai-config (ConfigMap)<br/>storage format, batch size, schedule<br/>Provisioned: Kustomize<br/>Rotate: No"]
        TLSSecret["TLS Certificate (optional)<br/>kubernetes.io/tls<br/>/etc/tls/internal/{tls.crt,tls.key}<br/>Provisioned: Operator/cert-manager<br/>Rotate: Varies"]
        MinIOSecret["MinIO Credentials (optional)<br/>Opaque<br/>Access Key / Secret Key<br/>Provisioned: Manual/Operator<br/>Rotate: No"]
        DBSecret["Database Credentials (optional)<br/>Opaque<br/>JDBC username/password<br/>Provisioned: Manual/Operator<br/>Rotate: No"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#e1d5e7,stroke:#9673a6
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333

    style Create fill:#d5e8d4,stroke:#82b366
    style Delete fill:#f8cecc,stroke:#b85450
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Patch fill:#fff2cc,stroke:#d6b656
    style Update fill:#fff2cc,stroke:#d6b656
    style Watch fill:#d5e8d4,stroke:#82b366

    style RESTAuth fill:#f9f9f9,stroke:#999
    style MetricsAuth fill:#f9f9f9,stroke:#999
    style EgressAuth fill:#f9f9f9,stroke:#999
    style DBAuth fill:#f9f9f9,stroke:#999

    style ConfigMapSecret fill:#fff2cc,stroke:#d6b656
    style TLSSecret fill:#fff2cc,stroke:#d6b656
    style MinIOSecret fill:#fff2cc,stroke:#d6b656
    style DBSecret fill:#fff2cc,stroke:#d6b656
