graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount<br/>Namespace: {data-science-project}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>Scope: cluster-wide"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["API Group: core ('')<br/>Resource: configmaps"]
    end

    subgraph Verbs["Permitted Verbs"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"applies to"| ConfigMaps

    ConfigMaps --> Create
    ConfigMaps --> Delete
    ConfigMaps --> Get
    ConfigMaps --> List
    ConfigMaps --> Patch
    ConfigMaps --> Update
    ConfigMaps --> Watch

    subgraph Secrets["Secrets Accessed"]
        TLSSecret["TLS cert/key<br/>kubernetes.io/tls<br/>Mount: /etc/tls/internal/<br/>Provisioned: operator/cert-manager"]
        DBSecret["Database credentials<br/>Opaque<br/>MariaDB/MySQL auth<br/>Provisioned: Manual/operator"]
        MinIOSecret["MinIO credentials<br/>Opaque<br/>access-key, secret-key<br/>Provisioned: Manual/operator"]
    end

    SA -.->|"mounts"| TLSSecret
    SA -.->|"reads"| DBSecret
    SA -.->|"reads"| MinIOSecret

    subgraph AuthMechanisms["Authentication Mechanisms"]
        NoAuth["REST Endpoints<br/>No application-level auth<br/>Security delegated to<br/>network policies +<br/>external proxy<br/>(kube-rbac-proxy /<br/>oauth-proxy)"]
        BearerAuth["/q/metrics endpoint<br/>Bearer Token<br/>ServiceAccount token<br/>from mounted SA secret"]
    end

    SA -.->|"provides token for"| BearerAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#ff9800,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#000
    style ConfigMaps fill:#7ed321,stroke:#333,color:#000
    style TLSSecret fill:#e91e63,stroke:#333,color:#fff
    style DBSecret fill:#e91e63,stroke:#333,color:#fff
    style MinIOSecret fill:#e91e63,stroke:#333,color:#fff
    style NoAuth fill:#9e9e9e,stroke:#333,color:#fff
    style BearerAuth fill:#673ab7,stroke:#333,color:#fff
    style Create fill:#c8e6c9,stroke:#333
    style Delete fill:#ffcdd2,stroke:#333
    style Get fill:#c8e6c9,stroke:#333
    style List fill:#c8e6c9,stroke:#333
    style Patch fill:#fff9c4,stroke:#333
    style Update fill:#fff9c4,stroke:#333
    style Watch fill:#c8e6c9,stroke:#333
