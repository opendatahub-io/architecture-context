graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["Core API Group (v1)<br/>configmaps"]
    end

    subgraph Verbs["Allowed Verbs"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"full CRUD + watch"| ConfigMaps

    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph AuthPatterns["Authentication Patterns"]
        direction TB
        NoAuth["REST Endpoints<br/>No built-in auth<br/>Relies on sidecar proxy"]
        BearerAuth["/q/metrics<br/>Bearer token (SA token)<br/>ServiceMonitor bearerTokenFile"]
    end

    subgraph SidecarAuth["Sidecar Auth Proxy (injected by Operator)"]
        RBAC3x["RHOAI 3.x: kube-rbac-proxy<br/>Validates Bearer tokens"]
        RBAC2x["RHOAI 2.x: oauth-proxy<br/>Validates OAuth tokens"]
    end

    subgraph Secrets["Secrets"]
        TLSCert["TLS Certificate<br/>kubernetes.io/tls<br/>Mounted: /etc/tls/internal/<br/>Enables HTTPS on 4443/TCP<br/>Auto-Rotate: No"]
        DBCreds["Database Credentials<br/>Opaque (env vars)<br/>MariaDB/MySQL user/pass<br/>Auto-Rotate: No"]
        MinioCreds["MinIO Credentials<br/>Opaque (env vars)<br/>S3 access key / secret key<br/>Auto-Rotate: No"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#f5a623,stroke:#333
    style CR fill:#f5a623,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333

    style Create fill:#e8f5e9,stroke:#4caf50
    style Delete fill:#ffebee,stroke:#f44336
    style Get fill:#e8f5e9,stroke:#4caf50
    style List fill:#e8f5e9,stroke:#4caf50
    style Patch fill:#fff3e0,stroke:#ff9800
    style Update fill:#fff3e0,stroke:#ff9800
    style Watch fill:#e3f2fd,stroke:#2196f3

    style NoAuth fill:#ffebee,stroke:#f44336
    style BearerAuth fill:#e8f5e9,stroke:#4caf50
    style RBAC3x fill:#e1d5e7,stroke:#9673a6
    style RBAC2x fill:#e1d5e7,stroke:#9673a6

    style TLSCert fill:#fff9c4,stroke:#f9a825
    style DBCreds fill:#fff9c4,stroke:#f9a825
    style MinioCreds fill:#fff9c4,stroke:#f9a825
