graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount<br/>Namespace: {data-science-project}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>Scope: cluster-wide"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["Core API Group<br/>configmaps"]
    end

    subgraph Verbs["Allowed Operations"]
        AllVerbs["create, delete, get,<br/>list, patch, update, watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permissions on"| ConfigMaps
    ConfigMaps -->|"with verbs"| AllVerbs

    subgraph AuthN["Authentication & Authorization"]
        direction TB
        NoAuth["REST Endpoints<br/>No application-level auth<br/>Security delegated to:<br/>- Network policies<br/>- kube-rbac-proxy (injected by operator)<br/>- oauth-proxy (injected by operator)"]
        MetricsAuth["GET /q/metrics<br/>Auth: Bearer Token<br/>Source: SA token file<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token<br/>Enforced: ServiceMonitor bearerTokenFile"]
    end

    subgraph Secrets["Secrets"]
        direction TB
        TLSSecret["TLS cert/key<br/>Type: kubernetes.io/tls<br/>Mount: /etc/tls/internal/<br/>Provisioned by: operator/cert-manager<br/>Rotation: Unknown"]
        DBSecret["Database credentials<br/>Type: Opaque<br/>Purpose: MariaDB/MySQL auth<br/>Provisioned by: Manual/operator<br/>Rotation: No"]
        MinIOSecret["MinIO credentials<br/>Type: Opaque<br/>Keys: access-key, secret-key<br/>Provisioned by: Manual/operator<br/>Rotation: No"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#e8a838,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style AllVerbs fill:#d5e8d4,stroke:#82b366

    style NoAuth fill:#f8cecc,stroke:#b85450
    style MetricsAuth fill:#d5e8d4,stroke:#82b366

    style TLSSecret fill:#dae8fc,stroke:#6c8ebf
    style DBSecret fill:#fff2cc,stroke:#d6b656
    style MinIOSecret fill:#fff2cc,stroke:#d6b656
