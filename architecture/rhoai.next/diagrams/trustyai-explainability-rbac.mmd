graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide scope)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph Verbs["Granted Verbs"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"applies to"| ConfigMaps

    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph Secrets["Secrets Referenced"]
        TLSSecret["TLS cert/key<br/>kubernetes.io/tls<br/>Mount: /etc/tls/internal/<br/>Provisioner: operator/cert-manager"]
        DBSecret["Database credentials<br/>Opaque<br/>MariaDB/MySQL auth<br/>Provisioner: Manual/operator"]
        MinIOSecret["MinIO credentials<br/>Opaque<br/>Keys: access-key, secret-key<br/>Provisioner: Manual/operator"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        NoAuth["REST Endpoints<br/>No app-level auth<br/>Security via network policies<br/>+ external proxy"]
        BearerAuth["/q/metrics<br/>Bearer Token<br/>SA token at<br/>/var/run/secrets/.../token"]
    end

    SA -.->|"mounts"| TLSSecret
    SA -.->|"accesses"| DBSecret
    SA -.->|"accesses"| MinIOSecret

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#f5a623,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#e8f5e9,stroke:#4caf50
    style Delete fill:#ffebee,stroke:#f44336
    style Get fill:#e8f5e9,stroke:#4caf50
    style List fill:#e8f5e9,stroke:#4caf50
    style Patch fill:#fff3e0,stroke:#ff9800
    style Update fill:#fff3e0,stroke:#ff9800
    style Watch fill:#e8f5e9,stroke:#4caf50

    style TLSSecret fill:#ffcdd2,stroke:#e53935
    style DBSecret fill:#ffcdd2,stroke:#e53935
    style MinIOSecret fill:#ffcdd2,stroke:#e53935

    style NoAuth fill:#fff9c4,stroke:#f9a825
    style BearerAuth fill:#c8e6c9,stroke:#388e3c
