graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_NB["notebook-controller-<br/>service-account"]
        SA_ODH["odh-notebook-controller-<br/>manager"]
        SA_Notebook["{notebook}<br/>ServiceAccount<br/>(per notebook)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_NB["notebook-controller-<br/>role-binding"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB_AuthDeleg["{notebook}-auth-delegator<br/>(per notebook, dynamic)"]
    end

    subgraph RoleBindings["Role Bindings (per namespace)"]
        RB_MLflow["{notebook}-mlflow-rolebinding<br/>(when MLflow enabled)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_NB["notebook-controller-role"]
        CR_ODH["odh-notebook-controller-<br/>manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_MLflow["mlflow-operator-<br/>mlflow-integration"]
    end

    subgraph AggregatedRoles["Aggregated User Roles"]
        CR_Admin["notebooks-admin<br/>(→ admin)"]
        CR_Edit["notebooks-edit<br/>(→ edit)"]
        CR_View["notebooks-view<br/>(→ view)"]
    end

    subgraph NB_Resources["notebook-controller Resources"]
        NB_Pods["core<br/>pods<br/>get,list,watch,delete"]
        NB_Events["core<br/>events<br/>get,list,watch,create,patch"]
        NB_Services["core<br/>services<br/>*"]
        NB_STS["apps<br/>statefulsets<br/>*"]
        NB_Notebooks["kubeflow.org<br/>notebooks,<br/>notebooks/status,<br/>notebooks/finalizers<br/>*"]
        NB_VS["networking.istio.io<br/>virtualservices<br/>*"]
    end

    subgraph ODH_Resources["odh-notebook-controller Resources"]
        ODH_Core["core<br/>configmaps, secrets,<br/>serviceaccounts, services<br/>create,get,list,patch,<br/>update,watch"]
        ODH_Events["core<br/>events<br/>create,patch"]
        ODH_Auth["authentication.k8s.io<br/>tokenreviews<br/>create"]
        ODH_Authz["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        ODH_GW["gateway.networking.k8s.io<br/>gateways: get,list,watch<br/>httproutes: CRUD+watch<br/>referencegrants: CRUD+watch"]
        ODH_NB["kubeflow.org<br/>notebooks: get,list,patch,<br/>update,watch<br/>notebooks/finalizers: patch,update<br/>notebooks/status: get"]
        ODH_NetPol["networking.k8s.io<br/>networkpolicies: CRUD+watch<br/>networkpolicies/finalizers"]
        ODH_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings: CRUD+watch<br/>rolebindings: CRUD+watch<br/>clusterroles: get<br/>roles: CRUD+watch"]
        ODH_OCP["OpenShift APIs<br/>imagestreams: get,list,watch<br/>routes: get,list,watch<br/>oauthclients: CRUD+watch<br/>proxies: get,list,watch"]
        ODH_DSPA["DSPA APIs<br/>datasciencepipelines-<br/>applications: get,list,watch<br/>dspa/api: CRUD"]
    end

    subgraph UserResources["User-Facing Resources"]
        User_NB["kubeflow.org<br/>notebooks,<br/>notebooks/status"]
    end

    %% Bindings
    SA_NB -->|bound via| CRB_NB
    CRB_NB -->|grants| CR_NB

    SA_ODH -->|bound via| CRB_ODH
    CRB_ODH -->|grants| CR_ODH

    SA_Notebook -->|bound via| CRB_AuthDeleg
    CRB_AuthDeleg -->|grants| CR_AuthDeleg

    SA_Notebook -->|bound via| RB_MLflow
    RB_MLflow -->|grants| CR_MLflow

    %% Role → Resource mappings
    CR_NB -->|access| NB_Pods
    CR_NB -->|access| NB_Events
    CR_NB -->|access| NB_Services
    CR_NB -->|access| NB_STS
    CR_NB -->|access| NB_Notebooks
    CR_NB -->|access| NB_VS

    CR_ODH -->|access| ODH_Core
    CR_ODH -->|access| ODH_Events
    CR_ODH -->|access| ODH_Auth
    CR_ODH -->|access| ODH_Authz
    CR_ODH -->|access| ODH_GW
    CR_ODH -->|access| ODH_NB
    CR_ODH -->|access| ODH_NetPol
    CR_ODH -->|access| ODH_RBAC
    CR_ODH -->|access| ODH_OCP
    CR_ODH -->|access| ODH_DSPA

    %% Aggregated roles
    CR_Admin -->|"* (all verbs)"| User_NB
    CR_Edit -->|"CRUD + watch"| User_NB
    CR_View -->|"get, list, watch"| User_NB

    %% Styling
    style SA_NB fill:#4a90e2,color:#fff
    style SA_ODH fill:#e86826,color:#fff
    style SA_Notebook fill:#8e44ad,color:#fff

    style CR_NB fill:#f5a623,color:#fff
    style CR_ODH fill:#f5a623,color:#fff
    style CR_AuthDeleg fill:#f5a623,color:#fff
    style CR_MLflow fill:#f5a623,color:#fff

    style CR_Admin fill:#27ae60,color:#fff
    style CR_Edit fill:#27ae60,color:#fff
    style CR_View fill:#27ae60,color:#fff

    style NB_Notebooks fill:#7ed321,color:#fff
    style ODH_NB fill:#7ed321,color:#fff
    style ODH_GW fill:#7ed321,color:#fff
    style ODH_Auth fill:#e74c3c,color:#fff
    style ODH_Authz fill:#e74c3c,color:#fff
    style User_NB fill:#7ed321,color:#fff
