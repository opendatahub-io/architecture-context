graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KF["notebook-controller-<br/>service-account"]
        SA_ODH["odh-notebook-controller-<br/>manager"]
        SA_Notebook["Notebook SA<br/>(per notebook, dynamic)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KF["notebook-controller-<br/>role-binding"]
        CRB_Proxy["notebook-controller-<br/>proxy-rolebinding"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB_AuthDel["{name}-rbac-{ns}-<br/>auth-delegator<br/>(dynamic, per notebook)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_KFLeader["notebook-controller-<br/>leader-election-rolebinding<br/>(ns: notebook-controller-system)"]
        RB_ODHLeader["odh-notebook-controller-<br/>leader-election-rolebinding<br/>(ns: opendatahub)"]
        RB_Elyra["elyra-pipelines-{name}<br/>(dynamic, user ns)"]
        RB_MLflow["{name}-mlflow<br/>(dynamic, user ns)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_KF["notebook-controller-role"]
        CR_Proxy["notebook-controller-proxy-role"]
        CR_ODH["odh-notebook-controller-<br/>manager-role"]
        CR_AuthDel["system:auth-delegator"]
        CR_MLflow["mlflow-operator-<br/>mlflow-integration"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_KFLeader["notebook-controller-<br/>leader-election-role"]
        R_ODHLeader["odh-notebook-controller-<br/>leader-election-role"]
        R_DSPA["ds-pipeline-user-<br/>access-dspa"]
    end

    subgraph UserRoles["User-Facing Aggregated Roles"]
        CR_Edit["kubeflow-notebooks-edit<br/>notebooks-edit"]
        CR_View["kubeflow-notebooks-view<br/>notebooks-view"]
    end

    subgraph KFResources["KF Controller Resources"]
        KF_Events["core / events<br/>create, get, list, patch, watch"]
        KF_Pods["core / pods<br/>delete, get, list, watch"]
        KF_Services["core / services<br/>* (all verbs)"]
        KF_STS["apps / statefulsets<br/>* (all verbs)"]
        KF_Notebooks["kubeflow.org / notebooks,<br/>notebooks/finalizers,<br/>notebooks/status<br/>* (all verbs)"]
        KF_VS["networking.istio.io /<br/>virtualservices<br/>* (all verbs)"]
    end

    subgraph ODHResources["ODH Controller Resources"]
        ODH_Core["core / configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch,<br/>update, watch"]
        ODH_Auth["authentication.k8s.io /<br/>tokenreviews<br/>create"]
        ODH_Authz["authorization.k8s.io /<br/>subjectaccessreviews<br/>create"]
        ODH_Proxy["config.openshift.io /<br/>proxies<br/>get, list, watch"]
        ODH_DSPA["datasciencepipelines<br/>applications.odh.io /<br/>dspa, dspa/api<br/>get, list, watch, create,<br/>delete, patch, update"]
        ODH_GW["gateway.networking.k8s.io /<br/>gateways<br/>get, list, watch"]
        ODH_Route["gateway.networking.k8s.io /<br/>httproutes, referencegrants<br/>create, delete, get, list,<br/>patch, update, watch"]
        ODH_IS["image.openshift.io /<br/>imagestreams<br/>get, list, watch"]
        ODH_NB["kubeflow.org / notebooks,<br/>notebooks/finalizers,<br/>notebooks/status<br/>get, list, patch, update, watch"]
        ODH_NP["networking.k8s.io /<br/>networkpolicies<br/>create, get, list, patch,<br/>update, watch"]
        ODH_OAuth["oauth.openshift.io /<br/>oauthclients<br/>delete, get, list, patch,<br/>update, watch"]
        ODH_RBAC["rbac.authorization.k8s.io /<br/>clusterroles, clusterrole-<br/>bindings, roles, rolebindings<br/>create, delete, get, list,<br/>patch, update, watch"]
        ODH_Routes["route.openshift.io /<br/>routes<br/>get, list, watch"]
    end

    subgraph UserResources["User-Facing Resources"]
        User_NB["kubeflow.org / notebooks,<br/>notebooks/status"]
    end

    %% KF Controller bindings
    SA_KF -->|bound via| CRB_KF
    SA_KF -->|bound via| CRB_Proxy
    SA_KF -->|bound via| RB_KFLeader
    CRB_KF -->|grants| CR_KF
    CRB_Proxy -->|grants| CR_Proxy
    RB_KFLeader -->|grants| R_KFLeader

    %% KF ClusterRole → Resources
    CR_KF -->|permits| KF_Events
    CR_KF -->|permits| KF_Pods
    CR_KF -->|permits| KF_Services
    CR_KF -->|permits| KF_STS
    CR_KF -->|permits| KF_Notebooks
    CR_KF -->|permits| KF_VS

    %% Proxy role → Resources
    CR_Proxy -->|permits| ODH_Auth
    CR_Proxy -->|permits| ODH_Authz

    %% ODH Controller bindings
    SA_ODH -->|bound via| CRB_ODH
    SA_ODH -->|bound via| RB_ODHLeader
    CRB_ODH -->|grants| CR_ODH
    RB_ODHLeader -->|grants| R_ODHLeader

    %% ODH ClusterRole → Resources
    CR_ODH -->|permits| ODH_Core
    CR_ODH -->|permits| ODH_Auth
    CR_ODH -->|permits| ODH_Authz
    CR_ODH -->|permits| ODH_Proxy
    CR_ODH -->|permits| ODH_DSPA
    CR_ODH -->|permits| ODH_GW
    CR_ODH -->|permits| ODH_Route
    CR_ODH -->|permits| ODH_IS
    CR_ODH -->|permits| ODH_NB
    CR_ODH -->|permits| ODH_NP
    CR_ODH -->|permits| ODH_OAuth
    CR_ODH -->|permits| ODH_RBAC
    CR_ODH -->|permits| ODH_Routes

    %% Dynamic per-notebook bindings
    SA_Notebook -->|bound via| CRB_AuthDel
    SA_Notebook -->|bound via| RB_Elyra
    SA_Notebook -->|bound via| RB_MLflow
    CRB_AuthDel -->|grants| CR_AuthDel
    RB_Elyra -->|grants| R_DSPA
    RB_MLflow -->|grants| CR_MLflow

    %% User-facing roles
    CR_Edit -->|"get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"| User_NB
    CR_View -->|"get, list, watch"| User_NB

