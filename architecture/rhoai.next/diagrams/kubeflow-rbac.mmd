graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KF["notebook-controller<br/>(upstream controller SA)"]
        SA_ODH["odh-notebook-controller<br/>(ODH controller SA)"]
        SA_NB["{notebook} SA<br/>(per-notebook SA<br/>in user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KF["notebook-controller-binding"]
        CRB_ODH["odh-notebook-controller-binding"]
        CRB_AuthDeleg["{notebook}-rbac-{namespace}<br/>-auth-delegator<br/>(per-notebook, cluster-scoped)"]
        CRB_MLflow["{notebook}-mlflow<br/>(per-notebook)"]
    end

    subgraph RoleBindings["Role Bindings (per namespace)"]
        RB_Elyra["elyra-pipelines-{notebook}<br/>(notebook namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_KF["notebook-controller"]
        CR_ODH["odh-notebook-controller"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_MLflow["mlflow-operator-mlflow-integration"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Pipeline["ds-pipeline-user-access-dspa"]
    end

    subgraph KFResources["notebook-controller Resources"]
        KF_Pods["core / pods<br/>get, list, watch, delete"]
        KF_Events["core / events<br/>get, list, watch, create, patch"]
        KF_Services["core / services<br/>*"]
        KF_StatefulSets["apps / statefulsets<br/>*"]
        KF_Notebooks["kubeflow.org / notebooks,<br/>notebooks/status,<br/>notebooks/finalizers<br/>*"]
        KF_VirtualSvc["networking.istio.io /<br/>virtualservices<br/>*"]
    end

    subgraph ODHResources["odh-notebook-controller Resources"]
        ODH_TokenReview["authentication.k8s.io /<br/>tokenreviews<br/>create"]
        ODH_SAR["authorization.k8s.io /<br/>subjectaccessreviews<br/>create"]
        ODH_Notebooks["kubeflow.org / notebooks<br/>get, list, watch, patch, update"]
        ODH_Gateway["gateway.networking.k8s.io /<br/>httproutes, referencegrants<br/>get, list, watch, create,<br/>update, patch, delete"]
        ODH_GatewayRead["gateway.networking.k8s.io /<br/>gateways<br/>get, list, watch"]
        ODH_Core["core / services, serviceaccounts,<br/>secrets, configmaps<br/>get, list, watch, create,<br/>update, patch"]
        ODH_NetPol["networking.k8s.io /<br/>networkpolicies<br/>get, list, watch, create,<br/>update, patch"]
        ODH_OAuth["oauth.openshift.io /<br/>oauthclients<br/>get, list, watch, update,<br/>patch, delete"]
        ODH_RBAC["rbac.authorization.k8s.io /<br/>roles, rolebindings,<br/>clusterrolebindings<br/>get, list, watch, create,<br/>update, patch, delete"]
        ODH_OpenShift["config.openshift.io /<br/>proxies, apiservers<br/>get, list, watch"]
        ODH_Images["image.openshift.io /<br/>imagestreams<br/>list, get, watch"]
        ODH_Routes["route.openshift.io /<br/>routes<br/>get, list, watch"]
        ODH_DSPA["datasciencepipelinesapplications.<br/>opendatahub.io / dspa, dspa/api<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph PerNotebookResources["Per-Notebook Resources"]
        PN_AuthDeleg["TokenReview +<br/>SubjectAccessReview<br/>(system:auth-delegator)"]
        PN_Pipeline["DSPA pipeline access<br/>(ds-pipeline-user-access-dspa)"]
        PN_MLflow["MLflow integration<br/>(mlflow-operator-<br/>mlflow-integration)"]
    end

    %% Upstream controller bindings
    SA_KF -->|"bound via"| CRB_KF
    CRB_KF -->|"grants"| CR_KF
    CR_KF -->|"permits"| KF_Pods
    CR_KF -->|"permits"| KF_Events
    CR_KF -->|"permits"| KF_Services
    CR_KF -->|"permits"| KF_StatefulSets
    CR_KF -->|"permits"| KF_Notebooks
    CR_KF -->|"permits"| KF_VirtualSvc

    %% ODH controller bindings
    SA_ODH -->|"bound via"| CRB_ODH
    CRB_ODH -->|"grants"| CR_ODH
    CR_ODH -->|"permits"| ODH_TokenReview
    CR_ODH -->|"permits"| ODH_SAR
    CR_ODH -->|"permits"| ODH_Notebooks
    CR_ODH -->|"permits"| ODH_Gateway
    CR_ODH -->|"permits"| ODH_GatewayRead
    CR_ODH -->|"permits"| ODH_Core
    CR_ODH -->|"permits"| ODH_NetPol
    CR_ODH -->|"permits"| ODH_OAuth
    CR_ODH -->|"permits"| ODH_RBAC
    CR_ODH -->|"permits"| ODH_OpenShift
    CR_ODH -->|"permits"| ODH_Images
    CR_ODH -->|"permits"| ODH_Routes
    CR_ODH -->|"permits"| ODH_DSPA

    %% Per-notebook bindings
    SA_NB -->|"bound via"| CRB_AuthDeleg
    CRB_AuthDeleg -->|"grants"| CR_AuthDeleg
    CR_AuthDeleg -->|"permits"| PN_AuthDeleg

    SA_NB -->|"bound via"| RB_Elyra
    RB_Elyra -->|"grants"| R_Pipeline
    R_Pipeline -->|"permits"| PN_Pipeline

    SA_NB -->|"bound via"| CRB_MLflow
    CRB_MLflow -->|"grants"| CR_MLflow
    CR_MLflow -->|"permits"| PN_MLflow

