graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KFC["notebook-controller<br/>-service-account"]
        SA_ODH["odh-notebook-controller<br/>-manager"]
        SA_NB["{notebook-name}<br/>(per notebook)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KFC["notebook-controller<br/>-role-binding"]
        CRB_ODH["odh-notebook-controller<br/>-manager-rolebinding"]
        CRB_AUTH["{notebook-name}-rbac<br/>-{namespace}-auth-delegator<br/>(per notebook, auth mode)"]
        CRB_MLF["{notebook-name}-mlflow<br/>(per notebook, MLflow)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_LEADER["notebook-controller<br/>-leader-election<br/>-role-binding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_KFC["notebook-controller-role"]
        CR_ODH["odh-notebook-controller<br/>-manager-role"]
        CR_AUTH["system:auth-delegator"]
        CR_MLF["mlflow-operator<br/>-mlflow-integration"]
        CR_EDIT["kubeflow-notebooks-edit<br/>notebooks-edit"]
        CR_VIEW["kubeflow-notebooks-view<br/>notebooks-view"]
    end

    subgraph Roles["Namespace Roles"]
        R_LEADER["leader-election-role"]
    end

    %% Bindings
    SA_KFC -->|"bound via"| CRB_KFC
    SA_KFC -->|"bound via"| RB_LEADER
    SA_ODH -->|"bound via"| CRB_ODH
    SA_NB -->|"bound via"| CRB_AUTH
    SA_NB -->|"bound via"| CRB_MLF

    CRB_KFC -->|"grants"| CR_KFC
    CRB_ODH -->|"grants"| CR_ODH
    CRB_AUTH -->|"grants"| CR_AUTH
    CRB_MLF -->|"grants"| CR_MLF
    RB_LEADER -->|"grants"| R_LEADER

    subgraph KFC_Resources["notebook-controller-role Resources"]
        direction LR
        KFC_R1["core<br/>pods<br/>delete,get,list,watch"]
        KFC_R2["core<br/>events<br/>create,get,list,patch,watch"]
        KFC_R3["core<br/>services<br/>*"]
        KFC_R4["apps<br/>statefulsets<br/>*"]
        KFC_R5["kubeflow.org<br/>notebooks,<br/>notebooks/finalizers,<br/>notebooks/status<br/>*"]
        KFC_R6["networking.istio.io<br/>virtualservices<br/>*"]
    end

    subgraph ODH_Resources["odh-notebook-controller-manager-role Resources"]
        direction LR
        ODH_R1["core<br/>configmaps, secrets,<br/>serviceaccounts, services<br/>create,get,list,patch,<br/>update,watch"]
        ODH_R2["authentication.k8s.io<br/>tokenreviews<br/>create"]
        ODH_R3["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        ODH_R4["gateway.networking.k8s.io<br/>gateways: get,list,watch<br/>httproutes, referencegrants:<br/>create,delete,get,list,<br/>patch,update,watch"]
        ODH_R5["kubeflow.org<br/>notebooks: get,list,<br/>patch,update,watch<br/>notebooks/finalizers:<br/>patch,update"]
        ODH_R6["networking.k8s.io<br/>networkpolicies<br/>create,get,list,patch,<br/>update,watch"]
        ODH_R7["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings:<br/>create,delete,get,list,<br/>patch,update,watch<br/>clusterroles: get<br/>roles: create,get,list,<br/>patch,update,watch"]
        ODH_R8["image.openshift.io<br/>imagestreams<br/>get,list,watch"]
        ODH_R9["config.openshift.io<br/>proxies<br/>get,list,watch"]
        ODH_R10["oauth.openshift.io<br/>oauthclients<br/>delete,get,list,patch,<br/>update,watch"]
    end

    subgraph UserRoles["User-Facing Roles"]
        direction LR
        UR_EDIT["kubeflow-notebooks-edit<br/>notebooks-edit<br/>kubeflow.org notebooks,<br/>notebooks/status<br/>get,list,watch,create,<br/>delete,deletecollection,<br/>patch,update"]
        UR_VIEW["kubeflow-notebooks-view<br/>notebooks-view<br/>kubeflow.org notebooks,<br/>notebooks/status<br/>get,list,watch"]
    end

    CR_KFC -->|"permissions"| KFC_Resources
    CR_ODH -->|"permissions"| ODH_Resources
    CR_EDIT -->|"permissions"| UR_EDIT
    CR_VIEW -->|"permissions"| UR_VIEW

    %% Styling
    style SA_KFC fill:#4a90e2,color:#fff
    style SA_ODH fill:#4a90e2,color:#fff
    style SA_NB fill:#4a90e2,color:#fff
    style CR_KFC fill:#f5a623,color:#fff
    style CR_ODH fill:#f5a623,color:#fff
    style CR_AUTH fill:#f5a623,color:#fff
    style CR_MLF fill:#f5a623,color:#fff
    style CR_EDIT fill:#f5a623,color:#fff
    style CR_VIEW fill:#f5a623,color:#fff
    style R_LEADER fill:#f5a623,color:#fff
    style CRB_KFC fill:#7ed321,color:#fff
    style CRB_ODH fill:#7ed321,color:#fff
    style CRB_AUTH fill:#7ed321,color:#fff
    style CRB_MLF fill:#7ed321,color:#fff
    style RB_LEADER fill:#7ed321,color:#fff
