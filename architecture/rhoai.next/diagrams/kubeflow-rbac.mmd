graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KF["notebook-controller-<br/>service-account"]
        SA_ODH["odh-notebook-controller-<br/>manager"]
        SA_NB["{notebook-name}<br/>(per-notebook SA)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KF["notebook-controller-<br/>role-binding"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB_AUTH["{notebook-name}-rbac-<br/>{namespace}-auth-delegator<br/>(dynamic, per notebook)"]
    end

    subgraph RoleBindings["Role Bindings (per namespace)"]
        RB_ELYRA["elyra-pipelines-<br/>{notebook-name}"]
        RB_MLFLOW["{notebook-name}-mlflow"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KF["notebook-controller-role"]
        CR_ODH["odh-notebook-controller-<br/>manager-role"]
        CR_AUTH["system:auth-delegator"]
        CR_MLFLOW["mlflow-operator-<br/>mlflow-integration"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_DSPA["ds-pipeline-user-<br/>access-dspa"]
    end

    subgraph AggregatedRoles["Aggregated ClusterRoles (User-Facing)"]
        CR_EDIT["kubeflow-notebooks-edit<br/>notebooks-edit"]
        CR_VIEW["kubeflow-notebooks-view<br/>notebooks-view"]
    end

    subgraph KFResources["notebook-controller-role Resources"]
        KF_Pods["core/pods<br/>get, list, watch, delete"]
        KF_Events["core/events<br/>get, list, watch, create, patch"]
        KF_Services["core/services<br/>*"]
        KF_StatefulSets["apps/statefulsets<br/>*"]
        KF_Notebooks["kubeflow.org/notebooks<br/>notebooks/status, finalizers<br/>*"]
        KF_VS["networking.istio.io/<br/>virtualservices<br/>*"]
    end

    subgraph ODHResources["odh-notebook-controller-manager-role Resources"]
        ODH_Core["core/configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch,<br/>update, watch"]
        ODH_Auth["authentication.k8s.io/<br/>tokenreviews<br/>authorization.k8s.io/<br/>subjectaccessreviews<br/>create"]
        ODH_OCP["config.openshift.io/<br/>apiservers, proxies<br/>get, list, watch"]
        ODH_GW["gateway.networking.k8s.io/<br/>gateways (get,list,watch)<br/>httproutes, referencegrants<br/>(full CRUD)"]
        ODH_Image["image.openshift.io/<br/>imagestreams<br/>get, list, watch"]
        ODH_NB["kubeflow.org/notebooks<br/>get, list, patch, update, watch<br/>notebooks/finalizers<br/>patch, update"]
        ODH_Net["networking.k8s.io/<br/>networkpolicies<br/>full CRUD"]
        ODH_OAuth["oauth.openshift.io/<br/>oauthclients<br/>delete, get, list, patch,<br/>update, watch"]
        ODH_RBAC["rbac.authorization.k8s.io/<br/>clusterrolebindings, rolebindings<br/>full CRUD<br/>clusterroles (get)<br/>roles (full CRUD)"]
        ODH_Route["route.openshift.io/<br/>routes<br/>get, list, watch"]
        ODH_DSPA["opendatahub.io/<br/>datasciencepipelines-<br/>applications (get,list,watch)<br/>api (full CRUD)"]
    end

    subgraph UserResources["User-Facing Permissions"]
        User_Edit["kubeflow.org/notebooks<br/>notebooks/status<br/>get, list, watch, create,<br/>delete, deletecollection,<br/>patch, update"]
        User_View["kubeflow.org/notebooks<br/>notebooks/status<br/>get, list, watch"]
    end

    %% Service Account → Binding
    SA_KF -->|bound via| CRB_KF
    SA_ODH -->|bound via| CRB_ODH
    SA_NB -->|bound via| CRB_AUTH
    SA_NB -->|bound via| RB_ELYRA
    SA_NB -->|bound via| RB_MLFLOW

    %% Binding → Role
    CRB_KF -->|grants| CR_KF
    CRB_ODH -->|grants| CR_ODH
    CRB_AUTH -->|grants| CR_AUTH
    RB_ELYRA -->|grants| R_DSPA
    RB_MLFLOW -->|grants| CR_MLFLOW

    %% Role → Resources
    CR_KF -->|permits| KF_Pods
    CR_KF -->|permits| KF_Events
    CR_KF -->|permits| KF_Services
    CR_KF -->|permits| KF_StatefulSets
    CR_KF -->|permits| KF_Notebooks
    CR_KF -->|permits| KF_VS

    CR_ODH -->|permits| ODH_Core
    CR_ODH -->|permits| ODH_Auth
    CR_ODH -->|permits| ODH_OCP
    CR_ODH -->|permits| ODH_GW
    CR_ODH -->|permits| ODH_Image
    CR_ODH -->|permits| ODH_NB
    CR_ODH -->|permits| ODH_Net
    CR_ODH -->|permits| ODH_OAuth
    CR_ODH -->|permits| ODH_RBAC
    CR_ODH -->|permits| ODH_Route
    CR_ODH -->|permits| ODH_DSPA

    %% Aggregated roles
    CR_EDIT -->|permits| User_Edit
    CR_VIEW -->|permits| User_View

