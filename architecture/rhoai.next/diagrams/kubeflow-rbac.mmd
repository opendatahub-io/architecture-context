graph TD
    subgraph SA_Upstream["Service Accounts"]
        SA1["notebook-controller-<br/>service-account"]
        SA2["odh-notebook-controller-<br/>manager"]
        SA3["{notebook} SA<br/>(per notebook)"]
    end

    subgraph CRB["ClusterRole Bindings"]
        CRB1["notebook-controller-<br/>role-binding"]
        CRB2["odh-notebook-controller-<br/>manager-rolebinding"]
        CRB3["{notebook}-auth-delegator<br/>(per notebook, cluster-wide)"]
        CRB4["{notebook}-mlflow-rolebinding<br/>(per notebook, namespace-scoped)"]
    end

    subgraph CR_Upstream["ClusterRole: notebook-controller-role"]
        R1_Pods["core/pods<br/>get, list, watch, delete"]
        R1_Events["core/events<br/>get, list, watch, create, patch"]
        R1_Services["core/services<br/>* (full)"]
        R1_SS["apps/statefulsets<br/>* (full)"]
        R1_NB["kubeflow.org/notebooks<br/>notebooks/status<br/>notebooks/finalizers<br/>* (full)"]
        R1_VS["networking.istio.io/<br/>virtualservices<br/>* (full)"]
    end

    subgraph CR_ODH["ClusterRole: odh-notebook-controller-manager-role"]
        R2_Core["core/configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch,<br/>update, watch"]
        R2_Events["core/events<br/>create, patch"]
        R2_Auth["authentication.k8s.io/<br/>tokenreviews<br/>create"]
        R2_AuthZ["authorization.k8s.io/<br/>subjectaccessreviews<br/>create"]
        R2_Proxy["config.openshift.io/<br/>proxies<br/>get, list, watch"]
        R2_DSPA["datasciencepipelines<br/>applications<br/>get, list, watch<br/>+ api: full CRUD"]
        R2_GW["gateway.networking.k8s.io/<br/>gateways<br/>get, list, watch"]
        R2_Routes["gateway.networking.k8s.io/<br/>httproutes, referencegrants<br/>full CRUD"]
        R2_IS["image.openshift.io/<br/>imagestreams<br/>get, list, watch"]
        R2_NB["kubeflow.org/notebooks<br/>get, list, patch, update, watch<br/>+ finalizers: patch, update<br/>+ status: get"]
        R2_NP["networking.k8s.io/<br/>networkpolicies<br/>full CRUD"]
        R2_OAuth["oauth.openshift.io/<br/>oauthclients<br/>delete, get, list,<br/>patch, update, watch"]
        R2_RBAC["rbac.authorization.k8s.io/<br/>clusterrolebindings,<br/>rolebindings<br/>full CRUD"]
        R2_Roles["rbac.authorization.k8s.io/<br/>clusterroles: get<br/>roles: full CRUD"]
        R2_OCP["route.openshift.io/<br/>routes<br/>get, list, watch"]
    end

    subgraph AggRoles["Aggregated Roles (User-Facing)"]
        NB_Admin["notebooks-admin<br/>kubeflow.org/notebooks<br/>notebooks/status<br/>* (full)<br/>aggregated to: admin"]
        NB_Edit["notebooks-edit<br/>kubeflow.org/notebooks<br/>notebooks/status<br/>create, delete, get, list,<br/>patch, update, watch<br/>aggregated to: edit"]
        NB_View["notebooks-view<br/>kubeflow.org/notebooks<br/>notebooks/status<br/>get, list, watch<br/>aggregated to: view"]
    end

    subgraph PerNB_Roles["Per-Notebook Roles"]
        AuthDelegator["system:auth-delegator<br/>(ClusterRole)<br/>tokenreviews: create<br/>subjectaccessreviews: create"]
        MLflowRole["mlflow-operator-<br/>mlflow-integration<br/>(ClusterRole)"]
    end

    %% Bindings
    SA1 -->|"bound via"| CRB1
    CRB1 -->|"grants"| CR_Upstream

    SA2 -->|"bound via"| CRB2
    CRB2 -->|"grants"| CR_ODH

    SA3 -->|"bound via"| CRB3
    CRB3 -->|"grants"| AuthDelegator

    SA3 -->|"bound via"| CRB4
    CRB4 -->|"grants"| MLflowRole

