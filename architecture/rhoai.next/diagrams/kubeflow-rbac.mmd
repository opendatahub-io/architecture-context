graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KF["notebook-controller-<br/>service-account"]
        SA_ODH["odh-notebook-controller-<br/>manager"]
        SA_NB["{notebook} SA<br/>(per notebook)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KF["notebook-controller-<br/>role-binding<br/>(cluster-wide)"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding<br/>(cluster-wide)"]
        CRB_AuthDeleg["{notebook}-auth-delegator<br/>(cluster-wide, per notebook)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_MLflow["{notebook}-mlflow-rolebinding<br/>(per notebook, notebook namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_KF["notebook-controller-role"]
        CR_ODH["odh-notebook-controller-<br/>manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_MLflow["mlflow-operator-<br/>mlflow-integration"]
    end

    subgraph AggregatedRoles["Aggregated User Roles"]
        CR_Admin["notebooks-admin<br/>(aggregated to admin)"]
        CR_Edit["notebooks-edit<br/>(aggregated to edit)"]
        CR_View["notebooks-view<br/>(aggregated to view)"]
    end

    subgraph KF_Resources["notebook-controller Resources"]
        KF_Pods["core<br/>pods<br/>get,list,watch,delete"]
        KF_Events["core<br/>events<br/>get,list,watch,create,patch"]
        KF_Services["core<br/>services<br/>*"]
        KF_StatefulSets["apps<br/>statefulsets<br/>*"]
        KF_Notebooks["kubeflow.org<br/>notebooks, status, finalizers<br/>*"]
        KF_VirtualServices["networking.istio.io<br/>virtualservices<br/>*"]
    end

    subgraph ODH_Resources["odh-notebook-controller Resources"]
        ODH_Core["core<br/>configmaps, secrets,<br/>serviceaccounts, services<br/>create,get,list,patch,update,watch"]
        ODH_Events["core<br/>events<br/>create,patch"]
        ODH_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        ODH_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        ODH_Proxy["config.openshift.io<br/>proxies<br/>get,list,watch"]
        ODH_DSPA["datasciencepipelines...<br/>datasciencepipelinesapplications<br/>get,list,watch"]
        ODH_DSPA_API["datasciencepipelines...<br/>.../api<br/>create,delete,get,patch,update"]
        ODH_Gateway["gateway.networking.k8s.io<br/>gateways<br/>get,list,watch"]
        ODH_HTTPRoute["gateway.networking.k8s.io<br/>httproutes, referencegrants<br/>create,delete,get,list,<br/>patch,update,watch"]
        ODH_ImageStreams["image.openshift.io<br/>imagestreams<br/>get,list,watch"]
        ODH_Notebooks["kubeflow.org<br/>notebooks<br/>get,list,patch,update,watch"]
        ODH_NetPol["networking.k8s.io<br/>networkpolicies<br/>create,get,list,patch,update,watch"]
        ODH_OAuth["oauth.openshift.io<br/>oauthclients<br/>delete,get,list,patch,update,watch"]
        ODH_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings, rolebindings,<br/>roles<br/>create,delete,get,list,<br/>patch,update,watch"]
        ODH_Routes["route.openshift.io<br/>routes<br/>get,list,watch"]
    end

    subgraph User_Resources["User-Facing Resources"]
        User_NB["kubeflow.org<br/>notebooks, notebooks/status"]
    end

    %% Service Account → Binding
    SA_KF -->|bound via| CRB_KF
    SA_ODH -->|bound via| CRB_ODH
    SA_NB -->|bound via| CRB_AuthDeleg
    SA_NB -->|bound via| RB_MLflow

    %% Binding → Role
    CRB_KF -->|grants| CR_KF
    CRB_ODH -->|grants| CR_ODH
    CRB_AuthDeleg -->|grants| CR_AuthDeleg
    RB_MLflow -->|grants| CR_MLflow

    %% Role → Resources
    CR_KF -->|access| KF_Pods
    CR_KF -->|access| KF_Events
    CR_KF -->|access| KF_Services
    CR_KF -->|access| KF_StatefulSets
    CR_KF -->|access| KF_Notebooks
    CR_KF -->|access| KF_VirtualServices

    CR_ODH -->|access| ODH_Core
    CR_ODH -->|access| ODH_Events
    CR_ODH -->|access| ODH_TokenReview
    CR_ODH -->|access| ODH_SAR
    CR_ODH -->|access| ODH_Proxy
    CR_ODH -->|access| ODH_DSPA
    CR_ODH -->|access| ODH_DSPA_API
    CR_ODH -->|access| ODH_Gateway
    CR_ODH -->|access| ODH_HTTPRoute
    CR_ODH -->|access| ODH_ImageStreams
    CR_ODH -->|access| ODH_Notebooks
    CR_ODH -->|access| ODH_NetPol
    CR_ODH -->|access| ODH_OAuth
    CR_ODH -->|access| ODH_RBAC
    CR_ODH -->|access| ODH_Routes

    %% Aggregated roles
    CR_Admin -->|"* (all verbs)"| User_NB
    CR_Edit -->|"create,delete,get,list,<br/>patch,update,watch"| User_NB
    CR_View -->|"get,list,watch"| User_NB

    %% Styling
    style SA_KF fill:#4a90e2,stroke:#333,color:#fff
    style SA_ODH fill:#4a90e2,stroke:#333,color:#fff
    style SA_NB fill:#4a90e2,stroke:#333,color:#fff
    style CR_KF fill:#f5a623,stroke:#333,color:#fff
    style CR_ODH fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDeleg fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style CR_Admin fill:#9b59b6,stroke:#333,color:#fff
    style CR_Edit fill:#9b59b6,stroke:#333,color:#fff
    style CR_View fill:#9b59b6,stroke:#333,color:#fff
    style KF_Notebooks fill:#7ed321,stroke:#333,color:#fff
    style ODH_Notebooks fill:#7ed321,stroke:#333,color:#fff
    style User_NB fill:#7ed321,stroke:#333,color:#fff
