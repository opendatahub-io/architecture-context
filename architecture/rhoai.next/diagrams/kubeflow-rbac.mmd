graph TD
    subgraph "Service Accounts"
        SA_KF["notebook-controller-service-account"]
        SA_ODH["odh-notebook-controller-manager"]
        SA_NB["{notebook-name}<br/>(per notebook, auth mode)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_KF["notebook-controller-role-binding"]
        CRB_ODH["odh-notebook-controller-manager-rolebinding"]
        CRB_NB["{notebook-name}-rbac-{ns}-auth-delegator<br/>(per notebook)"]
        CRB_MLflow["{notebook-name}-mlflow<br/>(per notebook, MLflow mode)"]
    end

    subgraph "ClusterRoles"
        CR_KF["notebook-controller-role"]
        CR_ODH["odh-notebook-controller-manager-role"]
        CR_AuthDel["system:auth-delegator"]
        CR_MLflow["mlflow-operator-mlflow-integration"]
        CR_Edit["kubeflow-notebooks-edit / notebooks-edit"]
        CR_View["kubeflow-notebooks-view / notebooks-view"]
    end

    subgraph "notebook-controller-role Resources"
        KF_Pods["core: pods<br/>delete, get, list, watch"]
        KF_Events["core: events<br/>create, get, list, patch, watch"]
        KF_Services["core: services<br/>*"]
        KF_StatefulSets["apps: statefulsets<br/>*"]
        KF_Notebooks["kubeflow.org: notebooks,<br/>notebooks/finalizers,<br/>notebooks/status<br/>*"]
        KF_VS["networking.istio.io:<br/>virtualservices<br/>*"]
    end

    subgraph "odh-notebook-controller-manager-role Resources"
        ODH_Core["core: configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch, update, watch"]
        ODH_Events["core: events<br/>create, patch"]
        ODH_TokenReview["authentication.k8s.io:<br/>tokenreviews<br/>create"]
        ODH_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        ODH_Proxy["config.openshift.io:<br/>proxies<br/>get, list, watch"]
        ODH_DSPA["datasciencepipelinesapplications<br/>.opendatahub.io: DSPA<br/>get, list, watch; DSPA/api: CRUD"]
        ODH_Gateway["gateway.networking.k8s.io:<br/>gateways: get, list, watch<br/>httproutes, referencegrants: CRUD"]
        ODH_Image["image.openshift.io:<br/>imagestreams<br/>get, list, watch"]
        ODH_NB["kubeflow.org: notebooks<br/>get, list, patch, update, watch<br/>notebooks/finalizers: patch, update"]
        ODH_NetPol["networking.k8s.io:<br/>networkpolicies<br/>create, get, list, patch, update, watch"]
        ODH_OAuth["oauth.openshift.io:<br/>oauthclients<br/>delete, get, list, patch, update, watch"]
        ODH_RBAC["rbac.authorization.k8s.io:<br/>clusterrolebindings, rolebindings<br/>CRUD + clusterroles: get<br/>roles: CRUD"]
        ODH_Routes["route.openshift.io:<br/>routes<br/>get, list, watch"]
    end

    subgraph "User-facing Roles"
        Edit_Res["kubeflow.org: notebooks,<br/>notebooks/status<br/>get, list, watch, create, delete,<br/>deletecollection, patch, update"]
        View_Res["kubeflow.org: notebooks,<br/>notebooks/status<br/>get, list, watch"]
    end

    %% Bindings
    SA_KF -->|"bound via"| CRB_KF
    SA_ODH -->|"bound via"| CRB_ODH
    SA_NB -->|"bound via"| CRB_NB
    SA_NB -->|"bound via (MLflow)"| CRB_MLflow

    CRB_KF -->|"grants"| CR_KF
    CRB_ODH -->|"grants"| CR_ODH
    CRB_NB -->|"grants"| CR_AuthDel
    CRB_MLflow -->|"grants"| CR_MLflow

    %% KF role → resources
    CR_KF -->|"permits"| KF_Pods
    CR_KF -->|"permits"| KF_Events
    CR_KF -->|"permits"| KF_Services
    CR_KF -->|"permits"| KF_StatefulSets
    CR_KF -->|"permits"| KF_Notebooks
    CR_KF -->|"permits"| KF_VS

    %% ODH role → resources
    CR_ODH -->|"permits"| ODH_Core
    CR_ODH -->|"permits"| ODH_Events
    CR_ODH -->|"permits"| ODH_TokenReview
    CR_ODH -->|"permits"| ODH_SAR
    CR_ODH -->|"permits"| ODH_Proxy
    CR_ODH -->|"permits"| ODH_DSPA
    CR_ODH -->|"permits"| ODH_Gateway
    CR_ODH -->|"permits"| ODH_Image
    CR_ODH -->|"permits"| ODH_NB
    CR_ODH -->|"permits"| ODH_NetPol
    CR_ODH -->|"permits"| ODH_OAuth
    CR_ODH -->|"permits"| ODH_RBAC
    CR_ODH -->|"permits"| ODH_Routes

    %% User roles → resources
    CR_Edit -->|"permits"| Edit_Res
    CR_View -->|"permits"| View_Res

