    style SA_KF fill:#4a90e2,stroke:#333,color:#fff
    style SA_ODH fill:#4a90e2,stroke:#333,color:#fff
    style SA_NB fill:#4a90e2,stroke:#333,color:#fff
    style CR_KF fill:#f5a623,stroke:#333,color:#fff
    style CR_ODH fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDeleg fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style R_Pipeline fill:#f5a623,stroke:#333,color:#fff
    style KF_Notebooks fill:#7ed321,stroke:#333,color:#fff
    style ODH_Notebooks fill:#7ed321,stroke:#333,color:#fff
    style ODH_Gateway fill:#7ed321,stroke:#333,color:#fff
    style ODH_TokenReview fill:#e74c3c,stroke:#333,color:#fff
