graph TB
    subgraph ModuleOperator["MCP Lifecycle Module Operator"]
        direction TB
        Reconciler["MCPLifecycleOperator<br/>Reconciler<br/><i>controller-runtime</i>"]
        KustomizeProvider["KustomizeProvider<br/><i>Manifest rendering</i>"]
        ConditionsMgr["ConditionsManager<br/><i>Status management</i>"]
        EmbeddedManifests[("Embedded Operand<br/>Manifests<br/><i>mcp-lifecycle-operator.yaml</i>")]

        Reconciler -->|"loads manifests"| KustomizeProvider
        KustomizeProvider -->|"reads"| EmbeddedManifests
        Reconciler -->|"updates status"| ConditionsMgr
    end

    PlatformOp["ODH Platform Operator<br/><i>rhods-operator</i>"] -->|"creates CR"| MCPLifecycleOpCR

    MCPLifecycleOpCR["MCPLifecycleOperator CR<br/><i>components.platform.opendatahub.io/v1alpha1</i><br/>Cluster-scoped, name=default"]
    MCPLifecycleOpCR -->|"watched by"| Reconciler

    Reconciler -->|"SSA apply"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    subgraph OperandResources["Deployed Operand Resources"]
        direction LR
        OperandDeploy["MCP Lifecycle Operator<br/>Deployment"]
        OperandSA["ServiceAccount"]
        OperandRBAC["ClusterRoles &<br/>ClusterRoleBindings"]
        OperandCRD["MCPServer CRD<br/><i>mcp.x-k8s.io</i>"]
        OperandMetrics["Metrics Service<br/>8443/TCP HTTPS"]
    end

    K8sAPI -->|"creates/manages"| OperandResources

    Reconciler -->|"garbage collects<br/>stale resources"| K8sAPI
    Reconciler -->|"checks readiness"| OperandDeploy

    %% Environment Configuration
    EnvVars["Environment Variables<br/>RELATED_IMAGE_ODH_MCP_LIFECYCLE_OPERATOR_IMAGE<br/>SYSTEM_NAMESPACE (Downward API)<br/>OPERATOR_VERSION"]
    EnvVars -.->|"configures"| KustomizeProvider

    %% Health probes
    Probes["/healthz & /readyz<br/>8081/TCP HTTP"] -.-> Reconciler

    %% Styling
    style ModuleOperator fill:#4a90e2,stroke:#2c6fad,color:#fff
    style Reconciler fill:#3a7bd5,stroke:#2c6fad,color:#fff
    style KustomizeProvider fill:#3a7bd5,stroke:#2c6fad,color:#fff
    style ConditionsMgr fill:#3a7bd5,stroke:#2c6fad,color:#fff
    style EmbeddedManifests fill:#5b9bd5,stroke:#2c6fad,color:#fff
    style MCPLifecycleOpCR fill:#f5a623,stroke:#d4891a,color:#333
    style PlatformOp fill:#7ed321,stroke:#5da318,color:#333
    style K8sAPI fill:#e8e8e8,stroke:#999,color:#333
    style OperandResources fill:#d5e8d4,stroke:#82b366
    style OperandDeploy fill:#c8e6c9,stroke:#82b366,color:#333
    style OperandSA fill:#c8e6c9,stroke:#82b366,color:#333
    style OperandRBAC fill:#c8e6c9,stroke:#82b366,color:#333
    style OperandCRD fill:#c8e6c9,stroke:#82b366,color:#333
    style OperandMetrics fill:#c8e6c9,stroke:#82b366,color:#333
    style EnvVars fill:#fff2cc,stroke:#d6b656,color:#333
    style Probes fill:#e1d5e7,stroke:#9673a6,color:#333
