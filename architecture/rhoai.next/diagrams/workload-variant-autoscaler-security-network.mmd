graph TB
    subgraph MetricsConsumers["METRICS CONSUMERS (Internal Trusted)"]
        HPA["HPA / KEDA"]
    end

    subgraph WVANamespace["WVA CONTROLLER<br/>(workload-variant-autoscaler-system)"]
        direction TB

        subgraph WVAPod["WVA Controller Manager Pod"]
            direction TB
            MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS (self-signed/cert-manager)<br/>Bearer Token auth"]
            HealthEndpoint["Health Endpoint<br/>8081/TCP HTTP<br/>No auth"]

            subgraph EnginesInternal["Scaling Engines"]
                SatEngine["Saturation Engine<br/>(30s loop)"]
                SFZEngine["Scale-from-Zero Engine<br/>(100ms loop)"]
            end

            subgraph ControllersInternal["Controllers"]
                VAReconciler["VA Reconciler"]
                CMReconciler["ConfigMap Reconciler"]
                IPReconciler["InferencePool Reconciler"]
            end

            DecisionCache["Decision Cache"]
            DirectAct["DirectActuator"]
        end

        Service["controller-manager-metrics-service<br/>ClusterIP 8443/TCP"]
        NetworkPolicy["NetworkPolicy: allow-metrics-traffic<br/>Ingress: namespaces with<br/>networking/allow-metrics-scraping=true"]
    end

    subgraph ExternalServices["PLATFORM SERVICES"]
        Prometheus["Prometheus / Thanos Querier<br/>9090/TCP or 9091/TCP<br/>HTTPS TLS 1.2+<br/>Bearer Token (SA token)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        EPP["EPP Pods<br/>(Gateway API Inference Ext.)<br/>configurable/TCP HTTPS<br/>TLS<br/>Bearer Token (epp-metrics-token)"]
    end

    subgraph ScaleTargets["SCALE TARGETS"]
        Deployments["Deployments"]
        LWS["LeaderWorkerSets"]
    end

    %% Ingress flows
    HPA -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>(metrics-reader RBAC)"| Service
    Service --> MetricsEndpoint

    %% Egress flows
    SatEngine -->|"HTTPS/9090<br/>TLS 1.2+<br/>Bearer Token<br/>(SA token)"| Prometheus
    SFZEngine -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token<br/>(epp-metrics-token)"| EPP
    VAReconciler -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>(watch/patch CRs)"| K8sAPI
    DirectAct -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>(scale subresource)"| K8sAPI

    %% Scale target flows
    HPA -->|"HTTPS/443<br/>scale subresource"| Deployments
    HPA -->|"HTTPS/443<br/>scale subresource"| LWS
    DirectAct -.->|"scale-from-zero<br/>direct scaling"| Deployments
    DirectAct -.->|"scale-from-zero<br/>direct scaling"| LWS

    %% Styling
    classDef consumer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef wva fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef target fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef endpoint fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class HPA consumer
    class SatEngine,SFZEngine,VAReconciler,CMReconciler,IPReconciler,DecisionCache,DirectAct wva
    class MetricsEndpoint,HealthEndpoint endpoint
    class Prometheus,K8sAPI,EPP external
    class Deployments,LWS target
