graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph WVANamespace["WVA Controller Namespace"]
            direction TB
            WVA["WVA Controller Manager<br/>SA: controller-manager<br/>Image: llm-d-workload-variant-autoscaler:v0.6.0"]

            subgraph Endpoints["Exposed Endpoints"]
                Metrics["/metrics<br/>8443/TCP HTTPS<br/>TLS (self-signed/cert-mgr)<br/>Bearer Token + TokenReview/SAR"]
                Health["/healthz + /readyz<br/>8081/TCP HTTP<br/>No Auth"]
            end

            subgraph Secrets["Secrets"]
                PromCert["prometheus-client-cert<br/>(kubernetes.io/tls)<br/>Manual/cert-manager"]
                EPPToken["epp-metrics-token<br/>(Opaque)<br/>Manual/SA token"]
            end

            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS + Bearer Token"]
        end

        subgraph MonitoringNS["Namespace: openshift-monitoring"]
            Prometheus["Prometheus / Thanos Querier<br/>9091/TCP HTTPS<br/>TLS 1.2+"]
        end

        subgraph UserNS["User Namespaces"]
            EPPPods["EPP Pods<br/>(Endpoint Picker)<br/>configurable/TCP HTTPS"]
            vLLMPods["vLLM Inference Servers<br/>(metrics source)"]
        end

        subgraph K8sControl["Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        end

        subgraph ExternalAutoscalers["Autoscaler Namespace"]
            HPAKEDA["HPA / KEDA<br/>(external autoscalers)"]
        end
    end

    %% Egress from WVA
    WVA -->|"HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA)"| Prometheus
    WVA -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token (EPP token)"| EPPPods
    WVA -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% vLLM → Prometheus (indirect)
    vLLMPods -.->|"scraped by<br/>Prometheus"| Prometheus

    %% Prometheus scraping WVA metrics
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token + SAR"| MetricsSvc

    %% HPA/KEDA flow
    HPAKEDA -->|"reads wva_desired_ratio<br/>HTTPS/9091"| Prometheus
    HPAKEDA -->|"scales pods<br/>HTTPS/443"| K8sAPI

    %% NetworkPolicy annotation
    NP["NetworkPolicy:<br/>allow-metrics-traffic<br/>Restricts /metrics to<br/>labeled namespaces"]

    %% Styling
    classDef wvaStyle fill:#4a90e2,stroke:#2c5282,stroke-width:2px,color:#fff
    classDef serviceStyle fill:#63b3ed,stroke:#2b6cb0,stroke-width:1px,color:#fff
    classDef endpointStyle fill:#bee3f8,stroke:#2b6cb0,stroke-width:1px
    classDef secretStyle fill:#fed7d7,stroke:#c53030,stroke-width:1px
    classDef externalStyle fill:#e2e8f0,stroke:#718096,stroke-width:2px
    classDef autoscalerStyle fill:#c6f6d5,stroke:#276749,stroke-width:1px
    classDef npStyle fill:#fefcbf,stroke:#d69e2e,stroke-width:1px

    class WVA wvaStyle
    class MetricsSvc serviceStyle
    class Metrics,Health endpointStyle
    class PromCert,EPPToken secretStyle
    class Prometheus,EPPPods,vLLMPods,K8sAPI externalStyle
    class HPAKEDA autoscalerStyle
    class NP npStyle
