graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / MLOps<br/>kubectl"]
    end

    subgraph K8sAPI["KUBERNETES API SERVER"]
        APIServer["kube-apiserver<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph WVAController["WVA CONTROLLER (Trusted)"]
        direction TB

        subgraph WVAPod["WVA Controller Manager Pod<br/>SA: controller-manager<br/>NS: system"]
            MetricsEndpoint["/metrics<br/>8443/TCP HTTPS<br/>TLS (self-signed/CM)<br/>Bearer Token + authn/authz"]
            HealthEndpoint["/healthz /readyz<br/>8081/TCP HTTP<br/>No auth (probes)"]
            SatEngine["Saturation Engine"]
            SFZEngine["Scale-From-Zero Engine"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        direction TB

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus / Thanos Querier<br/>thanos-querier.openshift-monitoring.svc<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (cluster-monitoring-view)"]
        end

        subgraph NS_EPP["Namespace: varies"]
            EPP["EPP Pods (Endpoint Picker)<br/>configurable/TCP HTTPS<br/>TLS<br/>Bearer Token (epp-metrics-token)"]
        end
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACES"]
        Deployments["Deployments / LWS<br/>(vLLM inference servers)"]
        ConfigMaps["ConfigMaps<br/>saturation-scaling-config<br/>model-scale-to-zero-config"]
        InferencePool["InferencePool CR<br/>(Gateway API)"]
        VACR["VariantAutoscaling CR<br/>llmd.ai/v1alpha1"]
    end

    subgraph MetricsConsumers["METRICS CONSUMERS"]
        PromScraper["Prometheus Scraper<br/>(via ServiceMonitor)"]
        HPAKEDA["HPA / KEDA<br/>Scales workloads via K8s API"]
    end

    %% External → K8s
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig auth"| APIServer

    %% K8s ↔ WVA
    APIServer -->|"Watch events<br/>TLS 1.2+<br/>SA token"| WVAPod

    %% WVA → Prometheus
    SatEngine -->|"HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA)<br/>PromQL queries"| Prometheus

    %% WVA → EPP
    SFZEngine -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token<br/>(epp-metrics-token)"| EPP

    %% WVA → K8s API
    WVAPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CR status, scale, leases"| APIServer

    %% WVA → Workloads (scale-from-zero)
    SFZEngine -.->|"Scale 0→1<br/>via K8s API<br/>/scale subresource"| Deployments

    %% Metrics flow
    PromScraper -->|"HTTPS/8443<br/>TLS<br/>Bearer Token + authn/authz"| MetricsEndpoint
    PromScraper -->|"wva_desired_replicas<br/>wva_desired_ratio"| HPAKEDA
    HPAKEDA -->|"HTTPS/443<br/>Scale Deployment/LWS"| APIServer

    %% K8s watches
    APIServer -.->|"Watch"| VACR
    APIServer -.->|"Watch"| ConfigMaps
    APIServer -.->|"Watch"| InferencePool

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef apiserver fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef consumer fill:#e8d5f5,stroke:#7c3aed,stroke-width:2px

    class User external
    class APIServer apiserver
    class MetricsEndpoint,HealthEndpoint,SatEngine,SFZEngine controller
    class Prometheus,EPP clusterservice
    class Deployments,ConfigMaps,InferencePool,VACR workload
    class PromScraper,HPAKEDA consumer
