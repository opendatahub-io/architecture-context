graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HPAKEDA["HPA / KEDA<br/>Metrics Scraper"]
    end

    subgraph WVANamespace["WVA CONTROLLER NAMESPACE<br/>(workload-variant-autoscaler-system)"]
        direction TB

        subgraph NetworkPolicyZone["NetworkPolicy: allow-metrics-traffic<br/>Ingress: labeled namespaces only, port 8443"]
            MetricsService["controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS, TLS (self-signed/cert-manager)<br/>Auth: Bearer Token (authn/authz)"]

            WVAPod["WVA Controller Manager Pod<br/>SA: controller-manager<br/>Image: ghcr.io/llm-d/llm-d-workload-variant-autoscaler:v0.5.1<br/>Ports: 8443/TCP (HTTPS), 8081/TCP (HTTP probes)"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        Prometheus["Prometheus / Thanos Querier<br/>9090/TCP or 9091/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Bearer Token (SA)"]

        EPP["EPP Pods<br/>(Gateway API Inference Extension)<br/>configurable/TCP<br/>HTTPS TLS<br/>Auth: Bearer Token (epp-metrics-token)"]
    end

    subgraph InferenceLayer["INFERENCE LAYER (Indirect)"]
        vLLM["vLLM Inference Servers<br/>(metrics scraped by Prometheus)<br/>kv_cache, queue_depth, tokens"]
    end

    %% Ingress flows
    HPAKEDA -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>(metrics-reader ClusterRole)"| MetricsService
    MetricsService -->|"internal"| WVAPod

    %% Egress flows
    WVAPod -->|"HTTPS/9090-9091<br/>TLS 1.2+<br/>Bearer Token (SA token)<br/>PromQL queries"| Prometheus
    WVAPod -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Watch/Update CRs, Deployments, Nodes"| K8sAPI
    WVAPod -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token (epp-metrics-token)<br/>flow_control_queue_size"| EPP

    %% Indirect
    Prometheus -.->|"scrapes vLLM metrics"| vLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef wvazone fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inference fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class HPAKEDA external
    class MetricsService,WVAPod wvazone
    class K8sAPI controlplane
    class Prometheus,EPP platform
    class vLLM inference
