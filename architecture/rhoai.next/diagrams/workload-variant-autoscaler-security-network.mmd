graph TB
    subgraph Cluster["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_WVA["Namespace: wva-system"]
            WVA["WVA Controller Manager<br/>SA: controller-manager<br/>Ports: 8443/TCP (metrics), 8081/TCP (health)"]
            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS TLS self-signed<br/>Auth: TokenReview + SAR"]
            WVA --- MetricsSvc
        end

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus / Thanos Querier<br/>9090/TCP or 9091/TCP<br/>HTTPS TLS 1.2+"]
        end

        subgraph NS_User["User Namespace(s)"]
            vLLM["vLLM Model Server Pods<br/>8080/TCP HTTP<br/>Metrics: KV cache, queue, latency"]
            EPP["EPP / Inference Scheduler<br/>Metric: flow_control_queue_size"]
            Deploy["Deployment / LWS<br/>Scale Target"]
            HPAObj["HPA / KEDA ScaledObject<br/>llm-d.ai/managed=true"]
        end

        subgraph ControlPlane["Kubernetes Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        end
    end

    %% Egress: WVA → Prometheus
    WVA -->|"HTTPS/9090-9091<br/>TLS 1.2+ (CA cert on OCP)<br/>Bearer Token (SA token)<br/>PromQL queries"| Prometheus

    %% Egress: WVA → K8s API
    WVA -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SA token)<br/>Watch/Patch CRDs, HPAs,<br/>Deployments, ConfigMaps"| K8sAPI

    %% Ingress: Prometheus → WVA metrics
    Prometheus -->|"HTTPS/8443<br/>TLS self-signed<br/>Bearer Token (TokenReview)<br/>Scrape wva_desired_replicas"| MetricsSvc

    %% vLLM → Prometheus (scraped)
    vLLM -.->|"HTTP/8080<br/>No encryption<br/>ServiceMonitor scrape"| Prometheus

    %% EPP → Prometheus
    EPP -.->|"Metrics exposed<br/>via Prometheus"| Prometheus

    %% HPA reads metric from Prometheus/API
    HPAObj -.->|"External metric<br/>wva_desired_replicas<br/>via prometheus-adapter"| K8sAPI

    %% HPA scales deployment
    HPAObj -->|"Scale subresource<br/>HTTPS/443"| Deploy

    %% Scale-from-zero direct patch
    WVA -->|"PATCH scale 0→1<br/>HTTPS/443 TLS 1.2+<br/>(scale-from-zero)"| Deploy

    %% NetworkPolicy
    subgraph NetPol["NetworkPolicy (OpenShift)"]
        NP["allow-metrics-traffic<br/>Ingress 8443/TCP<br/>from openshift-monitoring"]
    end

    NP -.->|protects| MetricsSvc

    %% Styling
    classDef wva fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef monitoring fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef user fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class WVA,MetricsSvc wva
    class Prometheus monitoring
    class vLLM,EPP,Deploy,HPAObj user
    class K8sAPI controlplane
    class NP netpol
