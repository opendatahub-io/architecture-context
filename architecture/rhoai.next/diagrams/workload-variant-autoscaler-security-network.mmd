graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        direction TB
        Note1["No external ingress<br/>WVA is internal-only"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_WVA["Namespace: workload-variant-autoscaler-system"]
            CM["controller-manager<br/>SA: controller-manager<br/>Ports: 8443/TCP (metrics), 8081/TCP (probes)"]
            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS / TLS<br/>NetworkPolicy: restricted"]
            CM --- MetricsSvc
        end

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prom["Prometheus (Thanos Querier)<br/>9091/TCP HTTPS<br/>TLS 1.2+"]
        end

        subgraph NS_Model["Namespace: {model-namespace}"]
            EPP["EPP Pods<br/>configurable/TCP HTTP<br/>Plaintext"]
            Deploy["Deployment / LWS<br/>(Scale Target)"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        HPA["HPA / KEDA<br/>(External Autoscaler)"]
    end

    %% Egress from WVA
    CM -->|"HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA token)<br/>PromQL queries"| Prom
    CM -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch/CRUD CRs"| K8sAPI
    CM -->|"HTTP/configurable<br/>Plaintext ⚠️<br/>Bearer Token (EPP token)<br/>Flow control queue size"| EPP

    %% Ingress to WVA
    Prom -->|"HTTPS/8443<br/>TLS<br/>Bearer Token (prometheus SA)<br/>Scrape WVA metrics"| MetricsSvc
    HPA -->|"HTTPS/8443<br/>TLS<br/>Bearer Token (metrics-reader)<br/>Custom scaling metrics"| MetricsSvc

    %% HPA/KEDA to targets
    HPA -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Scale Deployment"| K8sAPI
    K8sAPI -.->|"update replicas"| Deploy

    %% Styling
    classDef wva fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef monitoring fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px

    class CM,MetricsSvc wva
    class Prom monitoring
    class EPP,Deploy internal
    class K8sAPI,HPA k8s
    class Note1 external
