graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist /<br/>Platform Admin"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    subgraph WVANamespace["WVA CONTROLLER NAMESPACE"]
        direction TB

        subgraph WVAController["WVA Controller Manager<br/>SA: controller-manager"]
            direction LR
            MetricsEP["/metrics<br/>8443/TCP HTTPS<br/>TLS (self-signed/cert-mgr)<br/>Bearer Token + authn/authz"]
            HealthEP["/healthz, /readyz<br/>8081/TCP HTTP<br/>No Auth"]
        end

        MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP<br/>Internal Only"]
    end

    subgraph Monitoring["MONITORING NAMESPACE<br/>(openshift-monitoring)"]
        Prometheus["Prometheus / Thanos Querier<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA token)"]
        vLLM["vLLM Inference Servers<br/>Scraped by Prometheus"]
    end

    subgraph UserNamespaces["USER NAMESPACES"]
        EPP["EPP Pods<br/>Endpoint Picker<br/>configurable/TCP HTTPS<br/>Bearer Token (EPP token)"]
        Deployments["Deployments / LWS<br/>Scale targets"]
    end

    subgraph AutoscalerLayer["EXTERNAL AUTOSCALERS"]
        HPA["HPA / KEDA<br/>Reads wva_desired_ratio<br/>from Prometheus"]
    end

    %% User to K8s
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig"| K8sAPI

    %% K8s to WVA (watch events)
    K8sAPI -->|"Watch: VA, ConfigMap,<br/>Deployment, InferencePool<br/>TLS 1.2+ / SA Token"| WVAController

    %% WVA to Prometheus
    WVAController -->|"HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA)<br/>PromQL queries"| Prometheus

    %% Prometheus scrapes vLLM
    Prometheus -->|"Scrape vLLM metrics"| vLLM

    %% WVA to EPP
    WVAController -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token (EPP token)<br/>flow_control_queue_size"| EPP

    %% WVA to K8s API
    WVAController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>VA status, scale sub"| K8sAPI

    %% WVA scale-from-zero direct
    WVAController -->|"HTTPS/443<br/>Scale 0→1<br/>SA Token"| Deployments

    %% Prometheus scrapes WVA
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>metrics-reader-role"| MetricsSvc
    MetricsSvc -->|"proxy"| MetricsEP

    %% HPA reads from Prometheus, scales via K8s
    HPA -->|"HTTPS/9091<br/>Read wva_desired_ratio"| Prometheus
    HPA -->|"HTTPS/443<br/>Scale Deployment/LWS"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef wva fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef autoscaler fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class WVAController,MetricsSvc,MetricsEP,HealthEP wva
    class Prometheus,vLLM monitoring
    class EPP,Deployments userns
    class HPA autoscaler
