graph TB
    subgraph Image["kube-auth-proxy Container Image"]
        Entrypoint["entrypoint<br/>(Go binary dispatcher)<br/>Selects mode via PROXY_MODE env"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>(OAuth2/OIDC Proxy)<br/>Port: 4180/HTTP, 4443/HTTPS"]
            MiddlewareChain["Authentication Chain<br/>(alice middleware)"]
            K8sTokenValidator["K8s Token Validator"]
            OAuthBearer["OAuth Bearer Validator"]
            JWTBearer["JWT Bearer Validator"]
            BasicAuth["Basic Auth (htpasswd)"]
            StoredSession["Stored Session (Cookie/Redis)"]
            CSRFProtection["CSRF Protection<br/>(PKCE + Nonce + Signed Cookie)"]

            AuthProxy --> MiddlewareChain
            MiddlewareChain --> K8sTokenValidator
            K8sTokenValidator -->|pass| OAuthBearer
            OAuthBearer -->|pass| JWTBearer
            JWTBearer -->|pass| BasicAuth
            BasicAuth -->|pass| StoredSession
            AuthProxy --> CSRFProtection
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            RBACProxy["kube-rbac-proxy<br/>(K8s RBAC Proxy)<br/>Port: 8443/HTTPS"]
            DelegatingAuthn["Delegating Authenticator<br/>(TokenReview / OIDC / x509)"]
            AuthzChain["Authorization Chain"]
            HardcodedAuthz["Hardcoded Metrics Authorizer<br/>(auto-allow Prometheus SA)"]
            StaticAuthz["Static YAML Authorizer"]
            SARAuthz["SubjectAccessReview Authorizer<br/>(5min allow / 30s deny cache)"]

            RBACProxy --> DelegatingAuthn
            DelegatingAuthn --> AuthzChain
            AuthzChain --> HardcodedAuthz
            HardcodedAuthz -->|not metrics| StaticAuthz
            StaticAuthz -->|no match| SARAuthz
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac"| RBACProxy
    end

    %% External actors
    Browser["Browser User"] -->|"HTTPS/4443<br/>OAuth2 session"| AuthProxy
    APIClient["API Client"] -->|"HTTPS/8443<br/>Bearer token"| RBACProxy

    %% External dependencies
    AuthProxy -->|"HTTPS/443<br/>OIDC discovery + tokens"| OIDCProvider["OIDC / OpenShift<br/>OAuth Server"]
    AuthProxy -->|"TCP/6379<br/>Session storage"| Redis["Redis<br/>(optional)"]
    AuthProxy -->|"HTTPS/443<br/>TokenReview"| K8sAPI["Kubernetes<br/>API Server"]
    RBACProxy -->|"HTTPS/443<br/>TokenReview + SAR"| K8sAPI

    %% Upstream
    AuthProxy -->|"HTTP/HTTPS<br/>Proxied request"| Upstream["Upstream<br/>Application"]
    RBACProxy -->|"HTTP/HTTPS/h2c<br/>Proxied request"| Upstream

    %% Operator
    Operator["rhods-operator"] -.->|"Injects sidecar<br/>Sets PROXY_MODE + flags"| Image

    %% Prometheus
    Prometheus["OpenShift Prometheus"] -->|"HTTPS/8443<br/>/metrics scrape"| RBACProxy

    %% Styling
    style Entrypoint fill:#9b59b6,stroke:#333,color:#fff
    style AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style RBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style MiddlewareChain fill:#5dade2,stroke:#333,color:#fff
    style AuthzChain fill:#5dade2,stroke:#333,color:#fff
    style OIDCProvider fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style Upstream fill:#7ed321,stroke:#333
    style Operator fill:#f5a623,stroke:#333
    style Browser fill:#f9f9f9,stroke:#333
    style APIClient fill:#f9f9f9,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
