graph TB
    subgraph "kube-auth-proxy"
        direction TB

        subgraph "Middleware Chain"
            direction LR
            PreAuth["Pre-Auth<br/>(HTTPS redirect,<br/>health checks,<br/>metrics)"]
            SessionLoaders["Session Loaders<br/>(K8s TokenReview,<br/>OAuth/JWT Bearer,<br/>Basic Auth,<br/>Cookie Session)"]
            Headers["Header Injection<br/>(X-Forwarded-User,<br/>X-Forwarded-Email,<br/>X-Forwarded-Groups)"]
            PreAuth --> SessionLoaders --> Headers
        end

        subgraph "Auth Endpoints"
            SignIn["/oauth2/sign_in<br/>Sign-in page"]
            Start["/oauth2/start<br/>Initiate OAuth2 flow"]
            Callback["/oauth2/callback<br/>OAuth2 callback"]
            SignOut["/oauth2/sign_out<br/>Logout + token deletion"]
            UserInfo["/oauth2/userinfo<br/>User info JSON"]
            AuthEndpoint["/oauth2/auth<br/>ext_authz subrequest"]
        end

        subgraph "Health & Observability"
            Ping["/ping<br/>Liveness"]
            Ready["/ready<br/>Readiness"]
            Metrics["/metrics<br/>Prometheus"]
        end

        ReverseProxy["Reverse Proxy Handler<br/>/* catch-all"]
    end

    Browser[Browser Client] -->|"HTTPS/443<br/>OAuth2 flow"| SignIn
    Browser -->|"HTTPS/443<br/>OAuth2 flow"| Start
    Browser -->|"HTTPS/443<br/>Callback"| Callback
    Browser -->|"HTTPS/443<br/>Logout"| SignOut

    APIClient[API Client] -->|"HTTPS/443<br/>Bearer token"| ReverseProxy
    APIClient -->|"HTTPS/443<br/>Bearer token"| UserInfo

    Envoy[Envoy Gateway] -->|"HTTP/HTTPS<br/>ext_authz subrequest"| AuthEndpoint

    K8sClient[K8s Service Account<br/>Client] -->|"HTTPS/443<br/>SA token"| ReverseProxy

    MLflowSDK[MLflow Python SDK] -->|"HTTPS/443<br/>Bearer token"| ReverseProxy

    Headers --> ReverseProxy
    ReverseProxy -->|"HTTP/HTTPS/Unix<br/>Authenticated request"| Upstream[Upstream Application]

    SessionLoaders -->|"HTTPS/443<br/>TokenReview"| K8sAPI[Kubernetes API Server]
    SessionLoaders -->|"HTTPS/443<br/>Token validation"| OIDC[OIDC Provider]
    SessionLoaders -->|"HTTPS/443<br/>Token validation"| OShiftOAuth[OpenShift OAuth Server]
    SessionLoaders -->|"TCP/TLS 6379"| Redis[Redis Session Store]

    Prometheus[Prometheus] -->|"HTTP scrape"| Metrics

