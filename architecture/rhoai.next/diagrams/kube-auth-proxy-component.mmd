graph TB
    subgraph Container["kube-auth-proxy Container Image"]
        direction TB
        Entrypoint["entrypoint<br/>(multiplexer)<br/>Selects binary via PROXY_MODE"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>Go Service<br/>Port: 4180/TCP (HTTP)<br/>Port: 443/TCP (HTTPS)"]
            MiddlewareChain["Middleware Chain<br/>(alice)"]
            SessionMgr["Session Manager<br/>(Cookie / Redis)"]
            AuthProxy --> MiddlewareChain
            MiddlewareChain --> SessionMgr
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>Go Service<br/>Port: 8443/TCP (HTTPS)"]
            UnionAuth["Union Authorizer"]
            HardcodedAuth["Hardcoded Authorizer<br/>(Prometheus metrics)"]
            StaticAuth["Static Authorizer<br/>(YAML rules)"]
            SARAuth["SAR Authorizer<br/>(SubjectAccessReview)"]
            RBACProxy --> UnionAuth
            UnionAuth --> HardcodedAuth
            UnionAuth --> StaticAuth
            UnionAuth --> SARAuth
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac"| RBACProxy
    end

    %% External Interactions - Auth Mode
    User["User Browser"] -->|"OIDC/OAuth Login"| AuthProxy
    AuthProxy -->|"Token Exchange"| OIDCProvider["OIDC Provider<br/>443/TCP HTTPS"]
    AuthProxy -->|"OAuth2 Flow"| OSAuth["OpenShift OAuth<br/>443/TCP HTTPS"]
    AuthProxy -->|"TokenReview"| K8sAPI1["Kubernetes API<br/>443/TCP HTTPS"]
    AuthProxy -->|"Session Storage"| Redis["Redis (optional)<br/>6379/TCP"]
    AuthProxy -->|"Proxy Request"| Upstream1["Upstream App"]

    %% External Interactions - RBAC Mode
    Client["Client / Service"] -->|"Bearer Token"| RBACProxy
    RBACProxy -->|"TokenReview"| K8sAPI2["Kubernetes API<br/>443/TCP HTTPS"]
    SARAuth -->|"SubjectAccessReview"| K8sAPI2
    RBACProxy -->|"Proxy Request"| Upstream2["Upstream App"]

    %% Envoy Integration
    Envoy["Envoy Proxy<br/>(Gateway API)"] -->|"ext_authz<br/>/oauth2/auth"| AuthProxy

    %% Platform Operator
    Operator["rhods-operator"] -.->|"Deploys as sidecar"| Container

    %% Styling
    style Container fill:#e8f4fd,stroke:#2196F3,stroke-width:2px
    style AuthMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RBACMode fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Entrypoint fill:#4a90e2,color:#fff
    style AuthProxy fill:#4a90e2,color:#fff
    style RBACProxy fill:#4a90e2,color:#fff
    style OIDCProvider fill:#e8e8e8,stroke:#333
    style OSAuth fill:#e8e8e8,stroke:#333
    style K8sAPI1 fill:#e8e8e8,stroke:#333
    style K8sAPI2 fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#333
    style Envoy fill:#f5a623,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style User fill:#f9f9f9,stroke:#999
    style Client fill:#f9f9f9,stroke:#999
    style Upstream1 fill:#dcedc8,stroke:#689f38
    style Upstream2 fill:#dcedc8,stroke:#689f38
