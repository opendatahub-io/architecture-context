graph TB
    subgraph KAP["kube-auth-proxy"]
        direction TB

        subgraph Middleware["Middleware Chain (justinas/alice)"]
            direction LR
            Logging["Logging"]
            HealthCheck["Health Check<br/>/ping, /ready"]
            MetricsMW["Metrics<br/>Prometheus"]
            HTTPSRedirect["HTTPS Redirect"]
        end

        subgraph SessionLoading["Session Loading Pipeline"]
            direction LR
            K8sTokenLoader["K8s Token<br/>Session Loader"]
            JWTLoader["JWT/OAuth<br/>Session Loader"]
            BasicAuthLoader["Basic Auth<br/>(htpasswd)"]
            StoredSessionLoader["Stored Session<br/>Loader (Cookie)"]
        end

        subgraph Providers["Authentication Providers"]
            direction LR
            OIDCProvider["OIDC Provider<br/>pkg/providers/oidc/"]
            OpenShiftProvider["OpenShift OAuth<br/>Provider"]
        end

        subgraph SessionStores["Session Stores"]
            direction LR
            CookieStore["Cookie Store<br/>AES-GCM + HMAC"]
            RedisStore["Redis Store<br/>Standalone/Sentinel/Cluster"]
        end

        subgraph Handlers["Request Handlers"]
            direction LR
            AuthEndpoint["/oauth2/auth<br/>ext_authz (202/401)"]
            SignIn["/oauth2/sign_in"]
            Callback["/oauth2/callback"]
            SignOut["/oauth2/sign_out"]
            UserInfo["/oauth2/userinfo"]
            MLflowHandler["MLflow Auth<br/>Denied Handler"]
        end

        UpstreamProxy["Upstream Proxy<br/>HTTP/HTTPS/Unix/WebSocket"]
        MetricsServer["Metrics Server<br/>Prometheus endpoint"]
    end

    %% External actors
    Browser["Browser / Client"]
    K8sClient["K8s Client<br/>(SA Token)"]
    Envoy["Envoy<br/>(ext_authz)"]
    MLflow["MLflow<br/>Python SDK"]

    %% External services
    OIDCIdP["OIDC Identity Provider<br/>443/TCP HTTPS"]
    OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Redis["Redis<br/>6379/TCP"]
    Upstream["Upstream Application"]
    Prometheus["Prometheus"]

    %% Incoming flows
    Browser -->|"4180/TCP"| Middleware
    K8sClient -->|"4180/TCP<br/>Bearer SA Token"| Middleware
    Envoy -->|"4180/TCP<br/>/oauth2/auth"| AuthEndpoint
    MLflow -->|"4180/TCP<br/>User-Agent detection"| MLflowHandler

    %% Internal flows
    Middleware --> SessionLoading
    SessionLoading --> Handlers
    Handlers --> Providers
    Providers --> SessionStores
    Handlers --> UpstreamProxy

    %% Outbound flows
    OIDCProvider -->|"OIDC Discovery<br/>Token Exchange"| OIDCIdP
    OpenShiftProvider -->|"OAuth Discovery<br/>Token Exchange"| OSAuth
    K8sTokenLoader -->|"TokenReview API"| K8sAPI
    OpenShiftProvider -->|"User Info<br/>Token Cleanup"| K8sAPI
    RedisStore -->|"Session R/W"| Redis
    UpstreamProxy -->|"Proxied Requests<br/>+ Identity Headers"| Upstream
    MetricsServer -->|"Scrape"| Prometheus

    %% Styling
    style KAP fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Browser fill:#f9f9f9,stroke:#999
    style K8sClient fill:#f9f9f9,stroke:#999
    style Envoy fill:#f9f9f9,stroke:#999
    style MLflow fill:#f9f9f9,stroke:#999
    style OIDCIdP fill:#fff2cc,stroke:#d6b656
    style OSAuth fill:#fff2cc,stroke:#d6b656
    style K8sAPI fill:#fff2cc,stroke:#d6b656
    style Redis fill:#fff2cc,stroke:#d6b656
    style Upstream fill:#d5e8d4,stroke:#82b366
    style Prometheus fill:#f9f9f9,stroke:#999
    style OIDCProvider fill:#4a90e2,color:#fff
    style OpenShiftProvider fill:#4a90e2,color:#fff
    style AuthEndpoint fill:#f5a623,color:#fff
    style UpstreamProxy fill:#7ed321,color:#fff
