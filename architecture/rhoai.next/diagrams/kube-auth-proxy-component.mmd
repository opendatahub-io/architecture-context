graph TB
    subgraph Container["kube-auth-proxy Container Image"]
        direction TB
        Entrypoint["entrypoint<br/>(multiplexer)<br/>Selects binary via PROXY_MODE"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>Port: 4180/TCP HTTP<br/>Port: 443/TCP HTTPS"]
            SignIn["/oauth2/sign_in"]
            Start["/oauth2/start"]
            Callback["/oauth2/callback"]
            AuthCheck["/oauth2/auth<br/>(ext_authz)"]
            UserInfo["/oauth2/userinfo"]
            SignOut["/oauth2/sign_out"]
            Ping["/ping"]
            Ready["/ready"]

            AuthProxy --- SignIn
            AuthProxy --- Start
            AuthProxy --- Callback
            AuthProxy --- AuthCheck
            AuthProxy --- UserInfo
            AuthProxy --- SignOut
            AuthProxy --- Ping
            AuthProxy --- Ready
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS"]
            Healthz["/healthz"]
            Metrics["/metrics"]

            RBACProxy --- Healthz
            RBACProxy --- Metrics
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac<br/>(default)"| RBACProxy
    end

    User["User Browser"] -->|"HTTPS/HTTP"| AuthProxy
    EnvoyGW["Envoy Gateway<br/>(Gateway API)"] -->|"HTTP ext_authz<br/>4180/TCP"| AuthCheck
    Client["K8s Client /<br/>Prometheus"] -->|"HTTPS<br/>8443/TCP"| RBACProxy

    AuthProxy -->|"Proxy authenticated<br/>requests"| Upstream["Upstream Application"]
    RBACProxy -->|"Proxy authorized<br/>requests"| Upstream

    AuthProxy -->|"HTTPS/443"| OIDCProvider["OIDC Provider"]
    AuthProxy -->|"HTTPS/443"| OSAuth["OpenShift OAuth Server"]
    AuthProxy -->|"Redis/6379"| Redis["Redis<br/>(optional session store)"]

    RBACProxy -->|"HTTPS/443<br/>TokenReview"| K8sAPI["Kubernetes API Server"]
    RBACProxy -->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI
    AuthProxy -->|"HTTPS/443<br/>TokenReview"| K8sAPI

    RHODSOp["rhods-operator"] -.->|"deploys as<br/>sidecar"| Container

    style Container fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style AuthMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RBACMode fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Entrypoint fill:#4a90e2,color:#fff
    style AuthProxy fill:#4a90e2,color:#fff
    style RBACProxy fill:#4a90e2,color:#fff
    style OIDCProvider fill:#e8e8e8,stroke:#999
    style OSAuth fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Redis fill:#e8e8e8,stroke:#999
    style Upstream fill:#7ed321,color:#fff
    style EnvoyGW fill:#f5a623,color:#fff
    style RHODSOp fill:#7ed321,color:#fff
