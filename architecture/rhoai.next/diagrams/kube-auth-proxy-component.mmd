graph TB
    subgraph Image["Container Image: quay.io/rhoai/odh-kube-auth-proxy"]
        direction TB
        Entrypoint["entrypoint<br/>(Go CLI)<br/>Mode Dispatcher"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>OAuth2/OIDC Proxy<br/>Port: 4180/TCP HTTP"]
            SessionMgmt["Session Management<br/>Cookie / Redis"]
            AuthChain["Auth Middleware Chain<br/>1. K8s SA Token<br/>2. JWT Bearer / OAuth<br/>3. Basic Auth<br/>4. Session Cookie"]
            AuthProxy --- SessionMgmt
            AuthProxy --- AuthChain
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>RBAC Authorization Proxy<br/>Port: 8443/TCP HTTPS"]
            DelegatedAuth["Delegated Auth<br/>TokenReview + SAR"]
            UnionAuthz["Union Authorizer<br/>Metrics + Static + SAR"]
            RBACProxy --- DelegatedAuth
            RBACProxy --- UnionAuthz
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac<br/>(default)"| RBACProxy
    end

    %% External Actors
    Browser["Browser User"]
    ServiceClient["Service Account Client"]

    %% Upstream
    UpstreamApp["Upstream Application<br/>(Protected Service)"]

    %% External Services
    OIDCProvider["OIDC Provider<br/>(Keycloak / DEX)<br/>443/TCP HTTPS"]
    OpenShiftOAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Redis["Redis<br/>6379/TCP<br/>(Optional)"]

    %% Deployer
    Operator["rhods-operator<br/>Sidecar Injection"]

    %% Flows
    Browser -->|"OAuth2 flow<br/>4180/TCP"| AuthProxy
    ServiceClient -->|"Bearer token<br/>8443/TCP HTTPS"| RBACProxy
    ServiceClient -->|"SA token<br/>4180/TCP"| AuthProxy

    AuthProxy -->|"proxied requests"| UpstreamApp
    RBACProxy -->|"proxied requests<br/>+ identity headers"| UpstreamApp

    AuthProxy -->|"OIDC discovery<br/>+ token exchange"| OIDCProvider
    AuthProxy -->|"OAuth2 flow"| OpenShiftOAuth
    AuthProxy -->|"TokenReview"| K8sAPI
    AuthProxy -.->|"session storage"| Redis

    RBACProxy -->|"TokenReview<br/>+ SubjectAccessReview"| K8sAPI

    Operator -.->|"deploys as sidecar"| Image

    %% Styling
    style Entrypoint fill:#4a90e2,stroke:#333,color:#fff
    style AuthProxy fill:#7ed321,stroke:#333,color:#fff
    style RBACProxy fill:#7ed321,stroke:#333,color:#fff
    style SessionMgmt fill:#b8e6b8,stroke:#333
    style AuthChain fill:#b8e6b8,stroke:#333
    style DelegatedAuth fill:#b8e6b8,stroke:#333
    style UnionAuthz fill:#b8e6b8,stroke:#333
    style OIDCProvider fill:#999,stroke:#333,color:#fff
    style OpenShiftOAuth fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style UpstreamApp fill:#f5a623,stroke:#333
    style Operator fill:#e8e8e8,stroke:#333
    style Browser fill:#f9f9f9,stroke:#333
    style ServiceClient fill:#f9f9f9,stroke:#333
