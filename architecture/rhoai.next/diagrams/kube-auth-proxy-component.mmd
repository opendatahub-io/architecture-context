graph TB
    subgraph Container["kube-auth-proxy Container Image"]
        direction TB
        Entrypoint["entrypoint<br/>(multiplexer)<br/>Selects binary via PROXY_MODE"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP | 443/TCP HTTPS"]
            MiddlewareChain["Middleware Chain<br/>(alice)"]
            ScopeInject["Scope Injection<br/>Request ID, Reverse Proxy"]
            HealthReady["Health/Readiness<br/>/ping, /ready"]
            Metrics["Metrics Middleware<br/>oauth2_proxy_requests_total"]
            SessionLoader["Session Loader<br/>K8s Token → OAuth → JWT → Basic → Stored"]
            HeaderInjector["Header Injection<br/>X-Forwarded-User/Email/Groups"]
            UpstreamProxy["Upstream Proxy<br/>Reverse proxy to application"]

            AuthProxy --> MiddlewareChain
            MiddlewareChain --> ScopeInject
            ScopeInject --> HealthReady
            HealthReady --> Metrics
            Metrics --> SessionLoader
            SessionLoader --> HeaderInjector
            HeaderInjector --> UpstreamProxy
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            DelegatingAuth["Delegating Authenticator<br/>TokenReview / OIDC JWT / X509"]
            UnionAuthz["Union Authorizer"]
            HardcodedAuthz["Hardcoded Authorizer<br/>Prometheus metrics access"]
            StaticAuthz["Static Authorizer<br/>YAML pattern rules"]
            SARAuthz["SAR Authorizer<br/>SubjectAccessReview"]
            AuthzCache["Authorization Cache<br/>5m positive / 30s negative"]

            RBACProxy --> DelegatingAuth
            DelegatingAuth --> UnionAuthz
            UnionAuthz --> HardcodedAuthz
            UnionAuthz --> StaticAuthz
            UnionAuthz --> SARAuthz
            SARAuthz --> AuthzCache
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac (default)"| RBACProxy
    end

    subgraph SessionStore["Session Storage"]
        CookieStore["Cookie Store<br/>AES-CFB + HMAC-SHA256<br/>Auto-splitting >4KB"]
        RedisStore["Redis Store<br/>AES-GCM per-session<br/>Ticket-based lookup<br/>Distributed locking"]
    end

    SessionLoader -->|"cookie mode (default)"| CookieStore
    SessionLoader -->|"redis mode"| RedisStore

    %% External interactions
    User["User Browser"] -->|"HTTPS/HTTP"| Entrypoint
    EnvoyGW["Envoy Gateway<br/>(ext_authz)"] -->|"HTTP /oauth2/auth"| AuthProxy
    UpstreamProxy -->|"HTTP/HTTPS/h2c"| UpstreamApp["Upstream Application"]

    %% Styling
    style Container fill:#e8f4fd,stroke:#2196F3,stroke-width:2px
    style AuthMode fill:#e3f2fd,stroke:#1976D2,stroke-width:2px
    style RBACMode fill:#e8eaf6,stroke:#3F51B5,stroke-width:2px
    style SessionStore fill:#fff3e0,stroke:#FF9800,stroke-width:2px
    style Entrypoint fill:#4a90e2,stroke:#333,color:#fff
    style AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style RBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style User fill:#f5f5f5,stroke:#999
    style EnvoyGW fill:#f5f5f5,stroke:#999
    style UpstreamApp fill:#f5f5f5,stroke:#999
    style CookieStore fill:#fff8e1,stroke:#FFC107
    style RedisStore fill:#fff8e1,stroke:#FFC107
