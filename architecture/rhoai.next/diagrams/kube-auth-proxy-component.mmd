graph TB
    subgraph Image["Container Image: quay.io/rhoai/odh-kube-auth-proxy"]
        direction TB
        Entrypoint["entrypoint<br/>(Go CLI)<br/>Mode Dispatcher"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>Port: 4180/TCP HTTP<br/>OAuth2/OIDC Proxy"]
            SessionMgmt["Session Management<br/>Cookie / Redis"]
            K8sTokenAuth["K8s SA Token<br/>Validator"]
            AuthProxy --> SessionMgmt
            AuthProxy --> K8sTokenAuth
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS<br/>RBAC Authorization"]
            DelegatedAuth["Delegated AuthN<br/>(TokenReview)"]
            SARAuthz["SubjectAccessReview<br/>Authorization"]
            RBACProxy --> DelegatedAuth
            RBACProxy --> SARAuthz
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac<br/>(default)"| RBACProxy
    end

    %% External actors
    Browser["Browser User"]
    ServiceClient["Service Account Client"]

    %% Auth mode flows
    Browser -->|"OAuth2/OIDC flow<br/>4180/TCP"| AuthProxy
    ServiceClient -->|"Bearer SA token<br/>4180/TCP"| AuthProxy

    %% RBAC mode flows
    ServiceClient -->|"Bearer token<br/>8443/TCP HTTPS"| RBACProxy

    %% External dependencies
    OIDCProvider["OIDC Provider<br/>(Keycloak, DEX)"]
    OSAuth["OpenShift OAuth Server"]
    K8sAPI["Kubernetes API Server"]
    Redis["Redis<br/>(Optional)"]
    Upstream["Upstream Application<br/>(Protected Service)"]

    AuthProxy -->|"OAuth2 token exchange<br/>443/TCP HTTPS"| OIDCProvider
    AuthProxy -->|"OAuth2 flow<br/>443/TCP HTTPS"| OSAuth
    AuthProxy -->|"TokenReview<br/>443/TCP HTTPS"| K8sAPI
    AuthProxy -->|"Session storage<br/>6379/TCP"| Redis
    AuthProxy -->|"Proxied requests<br/>HTTP/HTTPS"| Upstream

    RBACProxy -->|"TokenReview +<br/>SubjectAccessReview<br/>443/TCP HTTPS"| K8sAPI
    RBACProxy -->|"Proxied requests<br/>HTTP/HTTPS"| Upstream

    %% Operator
    Operator["rhods-operator"] -.->|"Deploys as<br/>sidecar container"| Image

    %% Styling
    style Entrypoint fill:#4a90e2,stroke:#333,color:#fff
    style AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style RBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style SessionMgmt fill:#6baed6,stroke:#333,color:#fff
    style K8sTokenAuth fill:#6baed6,stroke:#333,color:#fff
    style DelegatedAuth fill:#6baed6,stroke:#333,color:#fff
    style SARAuthz fill:#6baed6,stroke:#333,color:#fff
    style OIDCProvider fill:#999,stroke:#333,color:#fff
    style OSAuth fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style Upstream fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#f5a623,stroke:#333,color:#fff
    style Browser fill:#f9f9f9,stroke:#999,stroke-width:2px
    style ServiceClient fill:#f9f9f9,stroke:#999,stroke-width:2px
