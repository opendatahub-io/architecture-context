graph TB
    subgraph "models-perf-benchmark-data"
        direction TB

        subgraph Shipped["Shipped Product"]
            DataContainer["Data Container Image<br/>(Init Container)<br/>UBI9-minimal<br/>/app/benchmarks"]
        end

        subgraph DevTools["Development Tools (Not Shipped)"]
            KafkaProc["kafka-processor<br/>Python 3.12 CLI<br/>Kafka Consumer"]
            APIClient["api-client<br/>Python 3.12 CLI<br/>REST Client"]
            ColdStart["cold-start-vram-data<br/>Python Script<br/>Metadata Enrichment"]
        end

        subgraph DataDir["data/ Directory (Git-tracked)"]
            JSONFiles["JSON/NDJSON Files<br/>provider/model hierarchy"]
        end
    end

    %% Dev tool data flows
    KafkaBroker["Kafka Broker<br/>dev.aihub-public-* topics"]
    ValidationHub["model-validation-hub<br/>REST API v1"]

    KafkaBroker -->|"SASL_SSL<br/>SCRAM-SHA-512<br/>9096/TCP"| KafkaProc
    ValidationHub -->|"HTTPS/443<br/>TLS (custom CA)"| APIClient

    KafkaProc -->|"writes JSON/NDJSON"| JSONFiles
    APIClient -->|"writes JSON/NDJSON"| JSONFiles
    ColdStart -->|"enriches metadata.json"| JSONFiles

    %% Build flow
    JSONFiles -->|"Konflux build<br/>COPY data/ into image"| DataContainer

    %% Runtime deployment
    DataContainer -->|"init container<br/>shared emptyDir volume"| ModelCatalog["model-catalog<br/>Service"]

    ModelRegOp["model-registry-operator"] -->|"manages Deployment spec"| ModelCatalog

    %% Styling
    style DataContainer fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style KafkaProc fill:#7ed321,stroke:#333
    style APIClient fill:#7ed321,stroke:#333
    style ColdStart fill:#7ed321,stroke:#333
    style JSONFiles fill:#f5a623,stroke:#333
    style KafkaBroker fill:#e8e8e8,stroke:#333
    style ValidationHub fill:#e8e8e8,stroke:#333
    style ModelCatalog fill:#b8d4f0,stroke:#333
    style ModelRegOp fill:#b8d4f0,stroke:#333
