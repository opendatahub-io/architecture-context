graph TB
    subgraph Production["Production Artifact"]
        direction TB
        DataContainer["odh-model-performance-data<br/>(UBI9-minimal Data Container)<br/>Image: odh-model-performance-data-rhel9"]
        BenchmarkData["/app/benchmarks/<br/>JSON + NDJSON files<br/>provider/model hierarchy"]
        DataContainer -->|contains| BenchmarkData
    end

    subgraph DevTooling["Development Tooling (not shipped)"]
        direction TB
        KafkaProcessor["kafka-processor<br/>(Python 3.12 CLI)"]
        Pipeline["Pipeline Engine<br/>Entity Detection + Transforms"]
        Transforms["Post-Processing Transforms<br/>OverallAccuracyTransform<br/>HardwareConfigurationTransform"]
        KafkaProcessor -->|runs| Pipeline
        Pipeline -->|applies| Transforms
    end

    subgraph K8sDeployment["Kubernetes Deployment (odh-model-registries)"]
        direction TB
        ModelCatalogDeploy["model-catalog Deployment"]
        InitContainer["Init Container<br/>(odh-model-performance-data)"]
        SharedVolume["Shared Volume<br/>(emptyDir)"]
        ModelCatalogSvc["model-catalog Container"]
        ModelCatalogDeploy -->|includes| InitContainer
        InitContainer -->|copies data to| SharedVolume
        SharedVolume -->|mounted by| ModelCatalogSvc
    end

    KafkaBroker["Kafka Broker<br/>CDC Topics<br/>9092/TCP SASL_SSL"]
    ModelRegistryOp["model-registry-operator"]
    LocalFS["Local Filesystem<br/>data/ directory"]

    KafkaBroker -->|CDC messages| KafkaProcessor
    KafkaProcessor -->|writes structured files| LocalFS
    LocalFS -->|packaged into| DataContainer
    DataContainer -->|image ref| InitContainer
    ModelRegistryOp -->|manages deployment| ModelCatalogDeploy

    style DataContainer fill:#4a90e2,stroke:#333,stroke-width:2px
    style BenchmarkData fill:#d5e8d4,stroke:#82b366
    style KafkaProcessor fill:#f5a623,stroke:#333,stroke-width:2px
    style Pipeline fill:#f5a623,stroke:#333
    style Transforms fill:#f5a623,stroke:#333
    style InitContainer fill:#4a90e2,stroke:#333
    style SharedVolume fill:#ffe6cc,stroke:#d79b00
    style ModelCatalogSvc fill:#7ed321,stroke:#333
    style KafkaBroker fill:#999,stroke:#333
    style ModelRegistryOp fill:#7ed321,stroke:#333
    style LocalFS fill:#e8e8e8,stroke:#333
    style ModelCatalogDeploy fill:#d5e8d4,stroke:#82b366
