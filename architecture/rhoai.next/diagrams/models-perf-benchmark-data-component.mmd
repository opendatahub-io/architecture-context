graph TB
    subgraph Platform["RHOAI Platform (odh-model-registries namespace)"]
        subgraph ModelCatalogPod["model-catalog Pod"]
            InitContainer["odh-model-performance-data<br/>(Init Container)<br/>UBI9-minimal<br/>sleep infinity"]
            SharedVolume[("/app/benchmarks<br/>Shared Volume")]
            ModelCatalog["model-catalog<br/>(Main Container)"]
            InitContainer -->|"copies data to"| SharedVolume
            SharedVolume -->|"serves data from"| ModelCatalog
        end
    end

    subgraph DataIngestion["Data Ingestion Layer (CI/Dev - Not Shipped)"]
        subgraph KafkaProc["kafka-processor"]
            KPConsumer["Kafka Consumer<br/>Python 3.12<br/>confluent-kafka"]
            KPTransforms["Transform Pipeline<br/>OverallAccuracyTransform<br/>HardwareConfigurationTransform"]
            KPConsumer -->|"raw CDC messages"| KPTransforms
        end

        subgraph APIClient["api-client"]
            APIPipeline["REST Pipeline<br/>Python 3.12<br/>requests"]
            APIPostProc["Post-Processor"]
            APIPipeline -->|"raw API data"| APIPostProc
        end

        subgraph Enrichment["enrich_models.py"]
            EnrichScript["Enrichment Script<br/>cold-start, VRAM, image-size"]
        end

        DataDir[("data/ directory<br/>JSON/NDJSON files<br/>provider/model hierarchy")]
        KPTransforms -->|"writes"| DataDir
        APIPostProc -->|"writes"| DataDir
        EnrichScript -->|"merges into"| DataDir
    end

    subgraph ExternalSystems["External Data Sources"]
        Kafka["Kafka Brokers<br/>dev.aihub-public-* topics<br/>9092/TCP"]
        ValidationHub["model-validation-hub<br/>REST API<br/>443/TCP"]
        ColdStartData["cold-start-vram-data/<br/>Static JSON files"]
    end

    Kafka -->|"SASL_SSL<br/>SCRAM-SHA-512"| KPConsumer
    ValidationHub -->|"HTTPS/TLS<br/>Custom CA cert"| APIPipeline
    ColdStartData -->|"File I/O"| EnrichScript

    DataDir -->|"Dockerfile.konflux<br/>COPY"| InitContainer

    ModelRegistryOp["model-registry-operator"]
    ModelRegistryOp -->|"manages deployment<br/>image reference"| ModelCatalogPod

    Dashboard["RHOAI Dashboard"]
    Dashboard -->|"queries"| ModelCatalog

    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style ModelCatalog fill:#4a90e2,stroke:#333,color:#fff
    style KPConsumer fill:#7ed321,stroke:#333
    style KPTransforms fill:#7ed321,stroke:#333
    style APIPipeline fill:#7ed321,stroke:#333
    style APIPostProc fill:#7ed321,stroke:#333
    style EnrichScript fill:#7ed321,stroke:#333
    style Kafka fill:#f5a623,stroke:#333
    style ValidationHub fill:#f5a623,stroke:#333
    style ColdStartData fill:#f5a623,stroke:#333
    style DataDir fill:#e8e8e8,stroke:#333
    style SharedVolume fill:#e8e8e8,stroke:#333
    style ModelRegistryOp fill:#9b59b6,stroke:#333,color:#fff
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
