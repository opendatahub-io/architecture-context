graph TB
    subgraph External["EXTERNAL MONITORING"]
        Prometheus["Prometheus"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (workbenches-operator-system)"]
        direction TB

        subgraph Pod["workbenches-operator Pod<br/>UID: 65532 (non-root)<br/>readOnlyRootFilesystem: true<br/>capabilities: drop ALL<br/>seccomp: RuntimeDefault"]
            MetricsPort["Metrics Endpoint<br/>/metrics<br/>8443/TCP HTTPS<br/>TLS (controller-runtime)<br/>Auth: SubjectAccessReview"]
            ProbePort["Health Probes<br/>/healthz /readyz<br/>8081/TCP HTTP<br/>No encryption<br/>No auth"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph UpstreamDeps["UPSTREAM (Platform Orchestrator)"]
        Orchestrator["rhods-operator<br/>(creates Workbenches CR)"]
    end

    subgraph MonitoredNS["WORKBENCH NAMESPACE"]
        NBDeployments["Notebook Controller<br/>Deployments<br/>label: app.opendatahub.io/<br/>workbenches=true"]
    end

    %% Flows
    Prometheus -->|"HTTPS/8443<br/>TLS (cr-managed)<br/>SubjectAccessReview"| MetricsPort
    Pod -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Bearer"| K8sAPI
    Orchestrator -->|"via K8s API<br/>Creates Workbenches CR"| K8sAPI
    K8sAPI -.->|"Watch events<br/>Workbenches CR"| Pod
    Pod -->|"via K8s API<br/>List/Watch Deployments"| NBDeployments

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef upstream fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitored fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef port fill:#4a90e2,stroke:#333,color:#fff
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Prometheus external
    class MetricsPort,ProbePort port
    class K8sAPI clusterservice
    class Orchestrator upstream
    class NBDeployments monitored
