graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies
    Sidecar -->|"reverse proxy<br/>HTTP(S)/8001"| Decoder["vLLM Decoder<br/>(co-located)"]
    Sidecar -->|"reverse proxy<br/>HTTP(S)/dynamic"| Prefiller["vLLM Prefiller(s)<br/>(remote workers)"]
    Sidecar -->|"CRD watch<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -->|"API watch<br/>HTTPS/443"| PodAPI["Kubernetes Pod API<br/>v1/pods"]

    %% External Dependencies (Libraries)
    Sidecar -->|"build"| Go["Go 1.24.2"]
    Sidecar -->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"K8s types"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"LRU cache"| LRU["hashicorp/golang-lru<br/>v2.0.7"]
    Sidecar -->|"UUID gen"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"logging"| Logr["go-logr/logr<br/>v1.4.2"]

    %% Platform Dependencies
    Sidecar -.->|"ingress"| Route["OpenShift Route<br/>Edge TLS"]
    Sidecar -.->|"CRD definition"| GAIE["Gateway API<br/>Inference Extension"]

    %% Integration Points (other components that use this)
    EPP["Endpoint Picker (EPP)<br/>Gateway API<br/>Inference Extension"] -.->|"routes to"| Sidecar
    Router["llm-d Router"] -.->|"sets x-prefiller-host-port"| Sidecar

    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#7ed321,stroke:#333,color:#fff
