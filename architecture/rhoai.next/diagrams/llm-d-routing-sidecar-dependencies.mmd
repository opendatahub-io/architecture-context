graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies (co-located)
    Sidecar -->|"decode requests<br/>8001/TCP HTTP/HTTPS"| Decoder["vLLM Decoder<br/>(co-located in pod)"]

    %% Internal Platform Dependencies (remote)
    Sidecar -->|"prefill requests<br/>variable port HTTP/HTTPS"| Prefiller["vLLM Prefiller<br/>(remote pods)"]

    %% Kubernetes Dependencies
    Sidecar -.->|"watch CRs<br/>443/TCP HTTPS"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -.->|"watch pods<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% External Go Dependencies
    Sidecar -->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"K8s types"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"proxy cache"| LRU["hashicorp/golang-lru/v2<br/>v2.0.7"]
    Sidecar -->|"request IDs"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"logging"| Logr["go-logr/logr<br/>v1.4.2"]
    Sidecar -->|"K8s logging"| Klog["k8s.io/klog/v2<br/>v2.130.1"]
    Sidecar -->|"CPU tuning"| AutoMaxProcs["uber.go/automaxprocs<br/>v1.6.0"]

    %% Ingress
    Route["OpenShift Route<br/>TLS Edge"] -->|"ingress traffic<br/>443/TCP HTTPS"| Sidecar

    %% Gateway API
    GatewayAPI["Gateway API<br/>Inference Extension"] -.->|"defines pool spec"| InferencePool

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#7ed321,stroke:#333,color:#fff
    style Prefiller fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Route fill:#e67e22,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style ClientGo fill:#ddd,stroke:#333
    style APIMachinery fill:#ddd,stroke:#333
    style LRU fill:#ddd,stroke:#333
    style UUID fill:#ddd,stroke:#333
    style Logr fill:#ddd,stroke:#333
    style Klog fill:#ddd,stroke:#333
    style AutoMaxProcs fill:#ddd,stroke:#333
