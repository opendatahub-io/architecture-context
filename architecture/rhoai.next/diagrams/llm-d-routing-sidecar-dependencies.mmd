graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies
    Sidecar -->|"HTTP(S)/8001<br/>reverse proxy<br/>localhost"| DecoderVLLM["vLLM Decoder<br/>(co-located in pod)"]
    Sidecar -->|"HTTP(S)/varies<br/>reverse proxy<br/>remote pods"| PrefillerVLLM["vLLM Prefiller<br/>(remote pods)"]
    Sidecar -.->|"HTTP header<br/>x-prefiller-host-port"| EPP["llm-d-inference-scheduler<br/>(EPP)"]
    Sidecar -.->|"CRD watch<br/>SSRF allowlist"| InferencePool["InferencePool CRD<br/>(Gateway API Inference Ext)"]

    %% Kubernetes API
    Sidecar -->|"HTTPS/443<br/>SA token auth"| K8sAPI["Kubernetes API Server"]

    %% External Go Dependencies
    Sidecar -->|"LRU cache"| GoLRU["hashicorp/golang-lru v2<br/>2.0.7"]
    Sidecar -->|"request UUIDs"| GoUUID["google/uuid<br/>1.6.0"]
    Sidecar -.->|"K8s API client<br/>(SSRF only)"| ClientGo["k8s.io/client-go<br/>0.31.3"]
    Sidecar -.->|"K8s API types<br/>(SSRF only)"| APIMachinery["k8s.io/apimachinery<br/>0.31.3"]

    %% Build Dependencies
    Sidecar -->|"build toolchain"| Go["Go 1.24.2"]

    %% Integration Points (what depends on sidecar)
    EPP -->|"routes traffic<br/>through sidecar"| Sidecar

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DecoderVLLM fill:#9b59b6,stroke:#333,color:#fff
    style PrefillerVLLM fill:#9b59b6,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style GoLRU fill:#e8e8e8,stroke:#333,color:#333
    style GoUUID fill:#e8e8e8,stroke:#333,color:#333
    style ClientGo fill:#e8e8e8,stroke:#333,color:#333
    style APIMachinery fill:#e8e8e8,stroke:#333,color:#333
    style Go fill:#e8e8e8,stroke:#333,color:#333
