graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies (same pod)
    Sidecar -->|"reverse proxy<br/>HTTP/HTTPS 8001/TCP"| Decoder["vLLM Decoder<br/>(local, same pod)"]

    %% Internal Platform Dependencies (remote)
    Sidecar -->|"reverse proxy<br/>HTTP/HTTPS varies"| Prefiller["vLLM Prefiller Pods<br/>(remote GPU workers)"]

    %% Kubernetes Dependencies (SSRF protection)
    Sidecar -->|"CRD watch<br/>dynamic informer"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -->|"watch/list pods<br/>dynamic informer"| PodAPI["Kubernetes Pod API"]

    %% Architectural Dependency
    InferencePool -.->|"CRD defined by"| GatewayAPI["Gateway API<br/>Inference Extension"]

    %% Go Library Dependencies
    subgraph GoLibraries["Go Libraries"]
        ClientGo["k8s.io/client-go v0.31.3<br/>(optional - SSRF only)"]
        APIMachinery["k8s.io/apimachinery v0.31.3<br/>(optional - SSRF only)"]
        LRU["hashicorp/golang-lru/v2<br/>v2.0.7"]
        UUID["google/uuid v1.6.0"]
        Logr["go-logr/logr v1.4.2"]
        Klog["k8s.io/klog/v2 v2.130.1"]
    end

    Sidecar -->|"K8s dynamic client"| ClientGo
    Sidecar -->|"K8s API types"| APIMachinery
    Sidecar -->|"proxy handler cache"| LRU
    Sidecar -->|"NIXL request correlation"| UUID
    Sidecar -->|"structured logging"| Logr
    Sidecar -->|"logging backend"| Klog

    %% Integration Points (incoming)
    EPP["Gateway API EPP<br/>(Endpoint Picker)"] -.->|"sets x-prefiller-host-port<br/>header"| Sidecar

    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#e74c3c,stroke:#333,color:#fff
    style Prefiller fill:#e74c3c,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style PodAPI fill:#999,stroke:#333
    style GatewayAPI fill:#7ed321,stroke:#333
    style EPP fill:#7ed321,stroke:#333
    style ClientGo fill:#e8e8e8,stroke:#333
    style APIMachinery fill:#e8e8e8,stroke:#333
    style LRU fill:#e8e8e8,stroke:#333
    style UUID fill:#e8e8e8,stroke:#333
    style Logr fill:#e8e8e8,stroke:#333
    style Klog fill:#e8e8e8,stroke:#333
