graph LR
    Sidecar["llm-d-routing-sidecar<br/>Go HTTP Reverse Proxy"]

    %% Internal Platform Dependencies (co-located)
    Sidecar -->|"decode requests<br/>HTTP/HTTPS :8001"| Decoder["vLLM Decoder<br/>(co-located, same pod)"]

    %% Internal Platform Dependencies (remote)
    Sidecar -->|"prefill requests<br/>HTTP/HTTPS variable port"| Prefiller["vLLM Prefiller<br/>(remote pods)"]

    %% Kubernetes Dependencies
    Sidecar -->|"CRD watch<br/>SSRF allowlist"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -->|"pod watch<br/>SSRF allowlist"| K8sAPI["Kubernetes API<br/>:443/TCP HTTPS"]

    %% External Go Dependencies
    Sidecar -.->|"K8s client<br/>(SSRF only)"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -.->|"K8s types<br/>(SSRF only)"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -.->|"LRU cache<br/>proxy handlers"| LRU["golang-lru/v2<br/>v2.0.7"]
    Sidecar -.->|"request UUIDs"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -.->|"structured logging"| Logr["go-logr/logr<br/>v1.4.2"]
    Sidecar -.->|"K8s logging"| KLog["klog/v2<br/>v2.130.1"]

    %% Ingress
    Route["OpenShift Route<br/>TLS Edge :443"] -->|"external traffic"| Sidecar

    %% Integration Points
    GatewayAPI["Gateway API<br/>Inference Extension"] -.->|"defines"| InferencePool

    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#7ed321,stroke:#333,color:#fff
    style Prefiller fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style ClientGo fill:#999,stroke:#333,color:#fff
    style APIMachinery fill:#999,stroke:#333,color:#fff
    style LRU fill:#999,stroke:#333,color:#fff
    style UUID fill:#999,stroke:#333,color:#fff
    style Logr fill:#999,stroke:#333,color:#fff
    style KLog fill:#999,stroke:#333,color:#fff
    style Route fill:#e8e8e8,stroke:#333
    style GatewayAPI fill:#e8e8e8,stroke:#333
