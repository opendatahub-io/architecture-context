graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go HTTP Reverse Proxy)"]

    %% Internal Platform Dependencies
    Sidecar -->|"HTTP(S) reverse proxy<br/>localhost:8001"| DecoderVLLM["vLLM Decoder<br/>(co-located in pod)"]
    Sidecar -->|"HTTP(S) reverse proxy<br/>remote pods, varies port"| PrefillerVLLM["vLLM Prefiller<br/>(remote pods)"]
    Sidecar -.->|"reads x-prefiller-host-port<br/>header (set upstream)"| EPP["llm-d-inference-scheduler<br/>(EPP)"]

    %% CRD Dependencies
    Sidecar -->|"CRD Watch<br/>HTTPS/443"| InferencePool["InferencePool CRD<br/>inference.networking.x-k8s.io/v1alpha2"]

    %% Kubernetes Dependencies
    Sidecar -->|"Watch API<br/>HTTPS/443<br/>ServiceAccount token"| K8sAPI["Kubernetes API Server"]

    %% Go Module Dependencies
    Sidecar -.->|"LRU cache<br/>prefiller proxy pool"| LRU["hashicorp/golang-lru/v2<br/>2.0.7"]
    Sidecar -.->|"K8s client<br/>(SSRF protection)"| ClientGo["k8s.io/client-go<br/>0.31.3"]
    Sidecar -.->|"K8s types<br/>(SSRF protection)"| APIMachinery["k8s.io/apimachinery<br/>0.31.3"]
    Sidecar -.->|"request UUID<br/>generation"| UUID["google/uuid<br/>1.6.0"]

    %% Infrastructure Dependencies
    Sidecar -.->|"TLS certificates<br/>(optional)"| CertManager["cert-manager<br/>(external provisioning)"]

    %% Integration Points (reverse - who depends on sidecar)
    GatewayAPI["Gateway API<br/>Inference Extension"] -.->|"defines CRD schema"| InferencePool

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DecoderVLLM fill:#7ed321,stroke:#333,color:#fff
    style PrefillerVLLM fill:#7ed321,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style LRU fill:#999,stroke:#333,color:#fff
    style ClientGo fill:#999,stroke:#333,color:#fff
    style APIMachinery fill:#999,stroke:#333,color:#fff
    style UUID fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#e8e8e8,stroke:#333
