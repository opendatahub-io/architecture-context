graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go Reverse Proxy)"]

    %% Internal Platform Dependencies (co-located / runtime)
    Sidecar -->|"decode requests<br/>HTTP(S)/8001<br/>localhost"| Decoder["vLLM Decoder<br/>(co-located)"]
    Sidecar -->|"prefill requests<br/>HTTP(S)/{dynamic}<br/>cross-pod"| Prefiller["vLLM Prefiller<br/>(remote workers)"]
    Sidecar -->|"CRD watch<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -->|"pod watch<br/>HTTPS/443"| Pods["Pods<br/>(InferencePool members)"]

    %% Platform Dependencies
    Sidecar -.->|"header routing"| EPP["llm-d EPP<br/>(sets x-prefiller-host-port)"]
    Sidecar -.->|"CRD definition"| GatewayAPI["Gateway API<br/>Inference Extension"]
    Sidecar -.->|"external access<br/>TLS edge"| Route["OpenShift Route"]

    %% External Library Dependencies
    Sidecar -->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"K8s types"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"proxy caching"| LRU["golang-lru/v2<br/>v2.0.7"]
    Sidecar -->|"request IDs"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"logging"| Logr["go-logr/logr<br/>v1.4.2"]

    %% Integration Points (consumers)
    Dashboard["llm-d Deployment<br/>(StatefulSet)"] -->|"deploys as sidecar"| Sidecar

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Decoder fill:#85BBF0,stroke:#333
    style Prefiller fill:#85BBF0,stroke:#333
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#85BBF0,stroke:#333
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Route fill:#999,stroke:#333,color:#fff
    style ClientGo fill:#e8e8e8,stroke:#333
    style APIMachinery fill:#e8e8e8,stroke:#333
    style LRU fill:#e8e8e8,stroke:#333
    style UUID fill:#e8e8e8,stroke:#333
    style Logr fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
