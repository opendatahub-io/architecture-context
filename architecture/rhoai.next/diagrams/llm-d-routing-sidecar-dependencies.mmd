graph LR
    Sidecar["llm-d-routing-sidecar<br/>Go HTTP Reverse Proxy"]

    %% Internal Platform Dependencies
    Sidecar -->|"reverse proxy<br/>HTTP(S)/8001<br/>localhost"| Decoder["vLLM Decoder<br/>(co-located)"]
    Sidecar -->|"reverse proxy<br/>HTTP(S)/variable<br/>P/D prefill requests"| Prefiller["vLLM Prefiller<br/>(remote pods)"]
    Sidecar -->|"CRD watch<br/>dynamic client"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io<br/>/v1alpha2"]

    %% External Dependencies (Go modules)
    Sidecar -->|"K8s dynamic client<br/>(SSRF mode only)"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"K8s API types<br/>(SSRF mode only)"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"prefiller proxy<br/>handler cache"| LRUCache["golang-lru/v2<br/>v2.0.7"]
    Sidecar -->|"request<br/>correlation"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"structured logging"| Logr["go-logr/logr<br/>v1.4.2"]
    Sidecar -->|"K8s logging"| Klog["k8s.io/klog/v2<br/>v2.130.1"]
    Sidecar -->|"container<br/>CPU tuning"| AutoMaxProcs["automaxprocs<br/>v1.6.0"]

    %% Infrastructure Dependencies
    Sidecar -->|"API server watch<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    Sidecar -->|"TLS certificates"| CertManager["cert-manager<br/>(optional)"]

    %% Consuming Components
    Gateway["Inference Gateway<br/>(llm-d gateway)"] -->|"routes requests<br/>with P/D headers"| Sidecar
    Route["OpenShift Route<br/>TLS edge"] -->|"external access<br/>443→8080"| Sidecar

