graph TD
    subgraph "Service Account"
        SA["operator-controller-manager<br/>Namespace: ${NAMESPACE}<br/>(default: hc4ai-operator)"]
    end

    subgraph "Role Bindings"
        RB["exec-rbac-rolebinding<br/>Type: RoleBinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "Roles"
        Role["exec-rbac-role<br/>Type: Role<br/>Source: deploy/rbac/"]
    end

    subgraph "API Resources & Permissions"
        Pods["API Group: '' (core)<br/>Resource: pods<br/>Verbs: list, get"]
        PodsExec["API Group: '' (core)<br/>Resource: pods/exec<br/>Verbs: create"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| Role
    Role -->|"list, get"| Pods
    Role -->|"create"| PodsExec

    subgraph "Secrets"
        Secret1["vllm-p2p-secrets<br/>Type: Opaque<br/>Purpose: HuggingFace API token<br/>Provisioned: Manual (Helm --set)<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication Mechanisms"
        Auth1["TokenizationService gRPC<br/>Auth: None<br/>Secured by: UDS filesystem<br/>permissions (0o700)<br/>Access: Pod-local only"]
        Auth2["ZMQ Event Stream<br/>Auth: None ⚠️<br/>Secured by: Network policy<br/>⚠️ No encryption"]
        Auth3["/healthz endpoint<br/>Auth: None<br/>Access: Public within cluster"]
        Auth4["Redis/Valkey (optional)<br/>Auth: None<br/>Encryption: Optional TLS<br/>(rediss:// URI)"]
        Auth5["Kubernetes API<br/>Auth: ServiceAccount Bearer<br/>Encryption: TLS 1.2+"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#3498db,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Secret1 fill:#e74c3c,stroke:#333,color:#fff
    style Auth1 fill:#27ae60,stroke:#333,color:#fff
    style Auth2 fill:#e74c3c,stroke:#333,color:#fff
    style Auth3 fill:#95a5a6,stroke:#333,color:#fff
    style Auth4 fill:#f39c12,stroke:#333,color:#fff
    style Auth5 fill:#27ae60,stroke:#333,color:#fff
