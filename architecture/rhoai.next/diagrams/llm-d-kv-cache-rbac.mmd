graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["exec-rbac-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles (deploy/rbac)"]
        Role["exec-rbac-role"]
    end

    subgraph APIResources["API Resources"]
        Pods["core (v1)<br/>pods"]
        PodsExec["core (v1)<br/>pods/exec"]
    end

    subgraph Authentication["Authentication & Authorization"]
        direction TB
        UDSAuth["TokenizationService gRPC<br/>Auth: None<br/>Enforcement: UDS filesystem<br/>permissions (0o700)<br/>Policy: Pod-local access only"]
        ZMQAuth["ZMQ Event Stream<br/>Auth: None ⚠️<br/>Enforcement: Network-level<br/>(pod-to-pod)<br/>Policy: No authentication"]
        HealthAuth["/healthz Endpoint<br/>Auth: None<br/>Policy: Public within cluster"]
    end

    subgraph Secrets["Secrets"]
        HFSecret["vllm-p2p-secrets<br/>Type: Opaque (Helm)<br/>Contents: HuggingFace API token<br/>Provisioned: Manual (Helm --set)<br/>Auto-Rotate: No"]
    end

    %% RBAC Flow
    SA -->|"bound via"| RB
    RB -->|"grants"| Role
    Role -->|"list, get"| Pods
    Role -->|"create"| PodsExec

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style UDSAuth fill:#d5e8d4,stroke:#82b366
    style ZMQAuth fill:#fff2cc,stroke:#d6b656
    style HealthAuth fill:#d5e8d4,stroke:#82b366
    style HFSecret fill:#f8cecc,stroke:#b85450
