graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/><i>Namespace: ${NAMESPACE}</i>"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["kv-cache-manager<br/><i>Namespace: ${NAMESPACE}</i>"]
    end

    subgraph Roles["Roles"]
        Role["kv-cache-manager<br/><i>Role (namespace-scoped)</i>"]
    end

    subgraph APIResources["API Resources"]
        Pods["core (v1)<br/><b>pods</b>"]
    end

    subgraph Verbs["Permitted Operations"]
        Get["get"]
        List["list"]
        Watch["watch"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| Role
    Role -->|"allows"| Pods
    Pods --- Get
    Pods --- List
    Pods --- Watch

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction LR
        K8sAuth["Kubernetes API<br/>ServiceAccount bearer token<br/>RBAC enforced"]
        UDSAuth["gRPC TokenizationService<br/>UDS filesystem permissions 0o700<br/>Same-pod only"]
        ZMQAuth["ZMQ Event Stream<br/>No auth<br/>Network policy recommended"]
        RedisAuth["Redis/Valkey Backend<br/>Optional redis:// URL auth<br/>Configurable per deployment"]
        HFAuth["HuggingFace Hub<br/>Bearer Token (HF_TOKEN)<br/>Secret: vllm-p2p-secrets"]
    end

    subgraph Secrets["Secrets"]
        HFSecret["vllm-p2p-secrets<br/><i>Type: Opaque</i><br/>Contains: HF_TOKEN<br/>Provisioned: Manual / Helm<br/>Auto-Rotate: No"]
    end

    HFAuth -->|"reads from"| HFSecret

