graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/><i>Namespace: ${NAMESPACE}</i>"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["exec-rbac-rolebinding<br/><i>Namespace: ${NAMESPACE}</i>"]
    end

    subgraph Roles["Roles"]
        ExecRole["exec-rbac-role<br/><i>Namespaced Role</i>"]
        PodWatchRole["Pod Reconciler<br/><i>(controller-runtime implicit)</i>"]
    end

    subgraph Resources["API Resources"]
        direction LR
        PodsExec["Core API (v1)<br/><b>pods/exec</b>"]
        Pods["Core API (v1)<br/><b>pods</b>"]
    end

    subgraph Verbs["Permitted Verbs"]
        direction LR
        ExecVerbs["create"]
        WatchVerbs["get, list, watch"]
    end

    %% Bindings
    SA -->|"bound via"| RB
    RB -->|"grants"| ExecRole

    %% Permissions
    ExecRole -->|"allows"| ExecVerbs
    ExecVerbs -->|"on"| PodsExec

    PodWatchRole -->|"allows"| WatchVerbs
    WatchVerbs -->|"on"| Pods

    %% Secrets
    subgraph Secrets["Secrets"]
        HFSecret["vllm-p2p-secrets<br/><i>Type: Opaque</i><br/>HuggingFace API token<br/>Provisioned: Manual/Helm<br/>Auto-Rotate: No"]
    end

    subgraph AuthSummary["Authentication & Authorization"]
        direction TB
        UDSAuth["UDS gRPC Socket<br/>Auth: None<br/>Trust: pod-local emptyDir"]
        HealthAuth["HTTP /healthz<br/>Auth: None<br/>For: kubelet probes"]
        ZMQAuth["ZMQ Subscriber<br/>Auth: None<br/>Trust: cluster-internal"]
        HTTPAuth["HTTP Scoring Endpoints<br/>Auth: None<br/>Trust: cluster-internal"]
        GRPCAuth["gRPC IndexerService<br/>Auth: None<br/>Trust: cluster-internal"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#b8d4e3,stroke:#333
    style ExecRole fill:#f5a623,stroke:#333,color:#fff
    style PodWatchRole fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style ExecVerbs fill:#ddd,stroke:#333
    style WatchVerbs fill:#ddd,stroke:#333
    style HFSecret fill:#f8cecc,stroke:#b85450
    style UDSAuth fill:#e8e8e8,stroke:#999
    style HealthAuth fill:#e8e8e8,stroke:#999
    style ZMQAuth fill:#e8e8e8,stroke:#999
    style HTTPAuth fill:#e8e8e8,stroke:#999
    style GRPCAuth fill:#e8e8e8,stroke:#999
