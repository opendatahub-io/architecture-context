graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/>ServiceAccount"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB["kv-cache-manager<br/>ClusterRoleBinding<br/>Namespace: Configurable"]
    end

    subgraph Roles["ClusterRoles"]
        CR["kv-cache-manager<br/>ClusterRole"]
    end

    subgraph APIResources["API Resources"]
        Pods["core (v1)<br/>pods"]
    end

    subgraph Verbs["Permitted Operations"]
        Get["get"]
        List["list"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"resources"| Pods
    Pods -->|"verbs"| Get
    Pods -->|"verbs"| List
    Pods -->|"verbs"| Watch

    subgraph Secrets["Secrets"]
        HFSecret["vllm-p2p-secrets<br/>Type: Opaque<br/>HuggingFace API token<br/>Manual provisioning<br/>No auto-rotation"]
        S3Secret["S3 credentials<br/>Type: Opaque<br/>access_key / secret_key<br/>Manual provisioning<br/>No auto-rotation"]
    end

    subgraph AuthEndpoints["Authentication & Authorization"]
        UDSAuth["gRPC TokenizationService<br/>Auth: None<br/>Enforcement: UDS kernel perms<br/>Access: Pod-local only"]
        IndexerAuth["gRPC IndexerService<br/>Auth: None<br/>Enforcement: NetworkPolicy (N/A)<br/>Access: In-cluster"]
        ZMQAuth["ZMQ Event Socket<br/>Auth: None<br/>Enforcement: NetworkPolicy (N/A)<br/>Access: In-cluster"]
        HealthAuth["/healthz Endpoint<br/>Auth: None<br/>Enforcement: None<br/>Access: Open"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#f5a623,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Watch fill:#d5e8d4,stroke:#82b366
    style HFSecret fill:#f8cecc,stroke:#b85450
    style S3Secret fill:#f8cecc,stroke:#b85450
    style UDSAuth fill:#dae8fc,stroke:#6c8ebf
    style IndexerAuth fill:#dae8fc,stroke:#6c8ebf
    style ZMQAuth fill:#dae8fc,stroke:#6c8ebf
    style HealthAuth fill:#dae8fc,stroke:#6c8ebf
