graph TD
    subgraph SA_Group["Service Account"]
        SA["operator-controller-manager<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RB_Group["Role Binding"]
        RB["exec-rbac-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Role_Group["Cluster Role"]
        RoleNode["exec-rbac-role<br/>(deploy/rbac)"]
    end

    subgraph Resources_Group["API Resources & Verbs"]
        Pods["Core API Group<br/>Resource: pods"]
        PodsExec["Core API Group<br/>Resource: pods/exec"]

        PodsVerbs["Verbs:<br/>list, get"]
        PodsExecVerbs["Verbs:<br/>create"]
    end

    subgraph Auth_Group["Authentication & Authorization"]
        UDS["TokenizationService gRPC<br/>Auth: None<br/>Enforcement: UDS filesystem<br/>permissions (0o700)<br/>Access: Pod-local only"]
        ZMQAuth["ZMQ Event Stream<br/>Auth: None<br/>Enforcement: Network-level<br/>(pod-to-pod only)"]
        Health["/healthz Endpoint<br/>Auth: None<br/>Access: Public within cluster"]
        RedisAuth["Redis / Valkey<br/>Auth: None<br/>Encryption: Optional TLS<br/>(rediss:// URI)"]
    end

    subgraph Secrets_Group["Secrets"]
        Secret1["vllm-p2p-secrets (Helm)<br/>Type: Opaque<br/>Content: HF API Token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| RoleNode
    RoleNode -->|"list, get"| Pods
    RoleNode -->|"create"| PodsExec

    Pods --- PodsVerbs
    PodsExec --- PodsExecVerbs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#e8a838,stroke:#333,color:#fff
    style RoleNode fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style PodsVerbs fill:#d5e8d4,stroke:#82b366
    style PodsExecVerbs fill:#d5e8d4,stroke:#82b366
    style UDS fill:#dae8fc,stroke:#6c8ebf
    style ZMQAuth fill:#f8cecc,stroke:#b85450
    style Health fill:#dae8fc,stroke:#6c8ebf
    style RedisAuth fill:#ffe6cc,stroke:#d79b00
    style Secret1 fill:#e1d5e7,stroke:#9673a6
