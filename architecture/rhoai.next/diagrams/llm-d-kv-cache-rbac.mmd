graph TD
    subgraph "Service Accounts"
        SA["operator-controller-manager<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "Role Bindings"
        RB["exec-rbac-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "Roles"
        R1["exec-rbac-role<br/>(Role)"]
        R2["Pod Reconciler<br/>(implicit - controller-runtime)"]
    end

    subgraph "API Resources"
        direction TB
        PodsExec["Core API (v1)<br/>pods/exec"]
        Pods["Core API (v1)<br/>pods"]
    end

    subgraph "Permissions"
        direction TB
        P1["create"]
        P2["get, list, watch"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| R1
    R1 -->|"allows"| P1
    P1 -->|"on"| PodsExec

    SA -->|"implicit binding"| R2
    R2 -->|"allows"| P2
    P2 -->|"on"| Pods

    subgraph "Secrets"
        direction TB
        S1["vllm-p2p-secrets<br/>Type: Opaque<br/>Contents: HuggingFace API token<br/>Provisioned: Manual / Helm<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication Endpoints"
        direction TB
        E1["UDS gRPC Socket<br/>Auth: None<br/>Trust: Pod-local (emptyDir)"]
        E2["HTTP /healthz<br/>Auth: None<br/>Purpose: kubelet probes"]
        E3["ZMQ Subscriber<br/>Auth: None<br/>Trust: Cluster-internal"]
        E4["HTTP Scoring<br/>Auth: None<br/>Trust: Cluster-internal"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style R1 fill:#f5a623,stroke:#333,color:#fff
    style R2 fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style P1 fill:#e74c3c,stroke:#333,color:#fff
    style P2 fill:#e74c3c,stroke:#333,color:#fff
    style S1 fill:#e67e22,stroke:#333,color:#fff
    style E1 fill:#95a5a6,stroke:#333,color:#fff
    style E2 fill:#95a5a6,stroke:#333,color:#fff
    style E3 fill:#95a5a6,stroke:#333,color:#fff
    style E4 fill:#95a5a6,stroke:#333,color:#fff
