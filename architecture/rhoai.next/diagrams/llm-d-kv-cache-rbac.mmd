graph TD
    subgraph "Service Accounts"
        SA["operator-controller-manager<br/>(Note: production should use<br/>component-specific SA)"]
    end

    subgraph "Role Bindings"
        RB["kv-cache-manager<br/>Namespace: (configurable)"]
    end

    subgraph "Roles"
        Role["kv-cache-manager<br/>(Role or ClusterRole)<br/>Scope: Namespace when podNamespace set,<br/>otherwise ClusterRole"]
    end

    subgraph "API Resources"
        Pods["core (v1)<br/>pods"]
    end

    subgraph "Permitted Verbs"
        Get["get"]
        List["list"]
        Watch["watch"]
    end

    SA -->|bound via| RB
    RB -->|grants| Role
    Role -->|access to| Pods
    Pods --> Get
    Pods --> List
    Pods --> Watch

    subgraph "Condition"
        Condition["Required ONLY when<br/>discoverPods: true<br/>(pod auto-discovery mode)"]
    end

    Role -.->|conditional| Condition

    subgraph "Secrets (Optional)"
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Purpose: Private model access<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        RedisPassword["Redis Password<br/>Type: Opaque<br/>Purpose: Redis/Valkey auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication Endpoints"
        UDS_EP["UDS gRPC Socket<br/>Auth: None<br/>Isolation: Socket mode 0700"]
        Health_EP["Health /healthz<br/>Auth: None<br/>Public within cluster"]
        ZMQ_EP["ZMQ Subscribers<br/>Auth: None ⚠️<br/>No authentication"]
        Redis_EP["Redis Index<br/>Auth: Password in URL<br/>TLS: Optional (rediss://)"]
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#e67e22,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Get fill:#27ae60,stroke:#333,color:#fff
    style List fill:#27ae60,stroke:#333,color:#fff
    style Watch fill:#27ae60,stroke:#333,color:#fff
    style Condition fill:#f8cecc,stroke:#b85450
    style HFToken fill:#e1d5e7,stroke:#9673a6
    style RedisPassword fill:#e1d5e7,stroke:#9673a6
    style UDS_EP fill:#d5e8d4,stroke:#82b366
    style Health_EP fill:#d5e8d4,stroke:#82b366
    style ZMQ_EP fill:#f8cecc,stroke:#b85450
    style Redis_EP fill:#fff2cc,stroke:#d6b656
