    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#e67e22,stroke:#333,color:#fff
    style Role fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Get fill:#d5e8d4,stroke:#82b366
    style List fill:#d5e8d4,stroke:#82b366
    style Watch fill:#d5e8d4,stroke:#82b366
    style K8sAuth fill:#dae8fc,stroke:#6c8ebf
    style UDSAuth fill:#dae8fc,stroke:#6c8ebf
    style ZMQAuth fill:#fff2cc,stroke:#d6b656
    style RedisAuth fill:#fff2cc,stroke:#d6b656
    style HFAuth fill:#dae8fc,stroke:#6c8ebf
    style HFSecret fill:#f8cecc,stroke:#b85450
