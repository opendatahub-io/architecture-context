graph LR
    VllmSpyre["vLLM Spyre<br/>(odh-vllm-spyre-rhel9)"]

    %% External Dependencies (Required)
    VllmSpyre -->|"hardware acceleration<br/>(required)"| SpyreHW["IBM Spyre<br/>Hardware"]
    VllmSpyre -->|"base image<br/>(required)"| RHAIIS["RHAIIS<br/>vllm-spyre-rhel9:3.2.2"]
    VllmSpyre -->|"gRPC bridge<br/>(bundled in base)"| TGISAdapter["vllm-tgis-adapter"]

    %% Internal Platform Dependencies
    VllmSpyre -->|"runtime container"| KServe["KServe"]
    VllmSpyre -.->|"image reference"| ServingRuntime["ServingRuntime CR"]

    %% Platform Components That Manage This
    RhodsOp["rhods-operator"] -->|"manages lifecycle"| ServingRuntime
    ServingRuntime -->|"references"| VllmSpyre

    %% External Services (Egress)
    VllmSpyre -->|"model download<br/>HTTPS/443"| S3["S3 Storage"]
    VllmSpyre -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    VllmSpyre -->|"model loading<br/>filesystem"| PVC["PVC Storage"]

    %% Platform Ingress
    KServeRouter["KServe Router /<br/>Platform Ingress"] -->|"HTTP/8000<br/>gRPC/8033"| VllmSpyre

