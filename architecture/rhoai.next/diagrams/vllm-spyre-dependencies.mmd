graph LR
    VllmSpyre["vllm-spyre<br/>(odh-vllm-spyre-rhel9)"]

    %% External Dependencies (Required)
    VllmSpyre -->|"base image<br/>FROM directive"| RHAIISBase["RHAIIS Base Image<br/>rhaiis/vllm-spyre-rhel9:3.2.2"]
    VllmSpyre -->|"PCIe device<br/>hardware required"| SpyreHW["IBM Spyre Accelerator<br/>Hardware"]

    %% Internal Platform Dependencies
    VllmSpyre -->|"pod lifecycle<br/>8000/TCP, 8033/TCP"| KServe["KServe<br/>(Inference Orchestration)"]
    VllmSpyre -->|"model weights<br/>volume mount / HTTPS"| ModelStorage["Model Storage<br/>(S3 / PVC)"]

    %% Integration Points (inbound)
    RHOAIGateway["RHOAI Gateway"] -->|"HTTPS/443<br/>TLS termination"| VllmSpyre
    ServingRuntime["ServingRuntime CR"] -->|"image reference"| VllmSpyre
    Prometheus["Prometheus"] -->|"HTTP/8000<br/>scrape /metrics"| VllmSpyre
    KServeXformer["KServe Transformer"] -->|"gRPC/8033<br/>TGIS protocol"| VllmSpyre

    %% External Services (outbound)
    VllmSpyre -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace["Hugging Face Hub<br/>(optional)"]

