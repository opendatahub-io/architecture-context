    style TGISAdapter fill:#6c5ce7,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333,color:#fff
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style KServeRouter fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style PVC fill:#999,stroke:#333,color:#fff
