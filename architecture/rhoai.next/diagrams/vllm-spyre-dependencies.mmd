graph LR
    VLLMSpyre["vllm-spyre<br/>(odh-vllm-spyre-rhel9)"]

    %% External Dependencies (Required)
    VLLMSpyre -->|"base image<br/>FROM directive"| BaseImage["rhaiis/vllm-spyre-rhel9<br/>v3.2.2"]
    VLLMSpyre -->|"VFIO passthrough<br/>hardware accelerator"| SpyreHW["IBM Spyre<br/>AI Accelerator"]
    VLLMSpyre -->|"volume mount<br/>HF_HUB_OFFLINE=1"| ModelWeights["HuggingFace<br/>Model Artifacts"]

    %% Internal Platform Dependencies
    VLLMSpyre -->|"ServingRuntime<br/>container spec"| KServe["KServe"]
    VLLMSpyre -->|"auth sidecar<br/>8443/TCP HTTPS"| KubeRBACProxy["kube-rbac-proxy"]

    %% Integration Points (components that interact with vllm-spyre)
    ModelMesh["ModelMesh"] -->|"gRPC/TGIS<br/>inference routing"| VLLMSpyre
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(indirect via KServe)"| KServe

    %% Build Pipeline
    Konflux["Konflux Pipeline"] -->|"supply chain<br/>attestation"| VLLMSpyre

    %% What the base image contains
    subgraph BaseImageContents["Pre-built in Base Image"]
        vLLM["vLLM Engine"]
        SpyrePlugin["vllm-spyre Plugin"]
        TGISAdapter["vllm-tgis-adapter"]
        FMSLibs["FMS Libraries"]
    end
    BaseImage -.->|"contains"| BaseImageContents

    style VLLMSpyre fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style BaseImage fill:#999,stroke:#333,color:#fff
    style SpyreHW fill:#e74c3c,stroke:#333,color:#fff
    style ModelWeights fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style vLLM fill:#ddd,stroke:#999
    style SpyrePlugin fill:#ddd,stroke:#999
    style TGISAdapter fill:#ddd,stroke:#999
    style FMSLibs fill:#ddd,stroke:#999
