graph LR
    VllmSpyre["vLLM Spyre<br/>(odh-vllm-spyre-rhel9)"]

    %% External Dependencies (Required)
    VllmSpyre -->|"hardware acceleration"| SpyreHW["IBM Spyre<br/>Accelerator"]
    VllmSpyre -->|"base image layer"| RHAIIS["RHAIIS<br/>vllm-spyre-rhel9:3.2.2"]
    VllmSpyre -->|"gRPC bridge (bundled)"| TGISAdapter["vllm-tgis-adapter"]

    %% Internal Platform Dependencies
    VllmSpyre -->|"runtime container"| KServe["KServe"]
    VllmSpyre -->|"image reference"| ServingRuntime["ServingRuntime /<br/>ClusterServingRuntime CR"]

    %% Platform Management (manages vllm-spyre)
    RhodsOperator["rhods-operator /<br/>opendatahub-operator"] -->|"manages image version"| VllmSpyre

    %% External Services (Egress)
    VllmSpyre -->|"model download<br/>HTTPS/443, TLS 1.2+"| S3["S3 Storage"]
    VllmSpyre -->|"model download<br/>HTTPS/443, TLS 1.2+"| HuggingFace["Hugging Face Hub"]
    VllmSpyre -->|"model weights<br/>filesystem"| PVC["PVC / Local Storage"]

    %% Platform ingress (authenticates for vllm-spyre)
    PlatformIngress["Platform Ingress<br/>(kube-rbac-proxy /<br/>Gateway API)"] -->|"auth enforcement<br/>HTTP/8000, gRPC/8033"| VllmSpyre

    %% Styling
    style VllmSpyre fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style SpyreHW fill:#e74c3c,stroke:#333,color:#fff
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style TGISAdapter fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style RhodsOperator fill:#7ed321,stroke:#333
    style PlatformIngress fill:#7ed321,stroke:#333

    %% External services
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
