graph LR
    VllmSpyre["vllm-spyre<br/>Container Image"]

    %% Base Image Chain (Build-Time)
    VllmSpyre -->|"FROM (base image)"| RHAIIS["RHAIIS vllm-spyre-rhel9<br/>v3.2.2"]
    RHAIIS -->|"built on"| AIPCC["AIPCC Spyre Base Image<br/>quay.io/aipcc/base-images/spyre"]
    AIPCC -->|"based on"| UBI9["UBI9 / RHEL9"]

    %% Hardware Dependency
    VllmSpyre -->|"accelerator"| SpyreHW["IBM Spyre Accelerator<br/>(hardware)"]

    %% Internal RHOAI Dependencies (Runtime)
    KServe["KServe"] -->|"deploys via<br/>ServingRuntime CR"| VllmSpyre
    KubeRBAC["kube-rbac-proxy"] -->|"auth sidecar<br/>8443→8000/8033"| VllmSpyre

    %% Integration Points (consumers)
    KServe -->|"triggers via"| InferenceService["InferenceService CR"]
    RHOAIOp["RHOAI Operator"] -->|"injects"| KubeRBAC

    %% External Services (Egress)
    VllmSpyre -->|"model storage<br/>HTTPS/443"| S3["S3 / Object Storage"]
    VllmSpyre -->|"model storage<br/>volume mount"| PVC["PVC Volume"]
    VllmSpyre -.->|"model download<br/>HTTPS/443 (optional)"| HF["Hugging Face Hub"]

    %% Styling
    style VllmSpyre fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style AIPCC fill:#999,stroke:#333,color:#fff
    style UBI9 fill:#999,stroke:#333,color:#fff
    style SpyreHW fill:#666,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style InferenceService fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style HF fill:#f5a623,stroke:#333,color:#fff
