graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Client"]
    end

    subgraph AppBoundary["LLAMA STACK SERVER (Application Boundary)"]
        direction TB
        LLSServer["Llama Stack Distribution<br/>8321/TCP HTTP<br/>SA: llamastack-garak-distribution-sa<br/>NS: tai-garak-lls"]
        Provider["trustyai-garak Provider<br/>(Python library, no exposed ports)<br/>Image: odh-trustyai-garak-lls-provider-dsp"]
        LLSServer -->|"Local Python API<br/>(in-process)"| Provider
    end

    subgraph EvalHubPath["EVAL-HUB PATH (Alternative Entry)"]
        direction TB
        EvalHub["Eval-Hub Service"]
        AdapterPod["GarakAdapter Job Pod<br/>Image: odh-trustyai-garak-lls-provider-dsp<br/>Vol: /mnt/model-auth (optional)"]
        Sidecar["Eval-Hub Sidecar<br/>local HTTP, no encryption"]
        EvalHub -->|"ConfigMap mount<br/>(JobSpec)"| AdapterPod
        AdapterPod -->|"HTTP (local)<br/>No auth"| Sidecar
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (Internal)"]
        KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>TLS"]
        KFPPod["KFP Pipeline Pods<br/>Image: odh-trustyai-garak-lls-provider-dsp<br/>Secrets as env vars<br/>/mnt/model-auth (optional)"]
        KFPAPI -->|"Schedules"| KFPPod
    end

    subgraph ModelInference["TARGET MODEL INFERENCE (Egress)"]
        vLLM["vLLM / Model Serving<br/>443 or 8080/TCP<br/>HTTPS/HTTP<br/>API Key auth"]
        SDGModel["SDG Model Endpoint<br/>443 or 8080/TCP<br/>API Key (SDG_API_KEY)"]
        JudgeModels["Judge/Attacker/Evaluator<br/>443 or 8080/TCP<br/>Per-role API Keys<br/>from /mnt/model-auth"]
    end

    subgraph StorageServices["STORAGE & ARTIFACT SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS<br/>AWS IAM Credentials"]
        OCI["OCI Registry<br/>443/TCP HTTPS TLS<br/>OCI auth"]
        MLflow["MLflow Tracking<br/>HTTP/HTTPS<br/>Configurable auth"]
    end

    subgraph ClusterInternal["KUBERNETES CLUSTER SERVICES"]
        FilesAPI["Llama Stack Files API<br/>8321/TCP HTTP<br/>No auth (in-cluster)"]
        ConfigMap["trustyai-service-operator-config<br/>ConfigMap<br/>Key: garak-provider-image"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Indirect (via LLS Distribution)"]
    end

    %% External flows
    User -->|"HTTP/8321<br/>Configurable TLS<br/>Llama Stack auth"| LLSServer

    %% Provider to KFP
    Provider -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA)"| KFPAPI
    AdapterPod -->|"HTTPS/443<br/>TLS<br/>SA Token"| KFPAPI

    %% To target models
    Provider -->|"HTTPS/443<br/>API Key"| vLLM
    KFPPod -->|"HTTPS/443<br/>API Key (Secret)"| vLLM
    KFPPod -->|"HTTPS/443<br/>API Key"| SDGModel
    KFPPod -->|"HTTPS/443<br/>Per-role API Key"| JudgeModels

    %% To storage
    KFPPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    AdapterPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    AdapterPod -->|"HTTPS/443<br/>TLS<br/>OCI auth"| OCI
    AdapterPod -->|"HTTP/HTTPS<br/>Configurable"| MLflow

    %% Cluster internal
    KFPPod -->|"HTTP/8321<br/>No auth"| FilesAPI
    Provider -->|"K8s API<br/>ConfigMap read"| ConfigMap

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef appboundary fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef evalhub fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef kfp fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef model fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class User external
    class LLSServer,Provider appboundary
    class EvalHub,AdapterPod,Sidecar evalhub
    class KFPAPI,KFPPod kfp
    class vLLM,SDGModel,JudgeModels model
    class S3,OCI,MLflow storage
    class FilesAPI,ConfigMap,PostgreSQL cluster
