graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Client"]
    end

    subgraph LlamaStackZone["LLAMA STACK SERVER (In-Cluster)"]
        direction TB
        LSD["Llama Stack Distribution<br/>8321/TCP HTTP<br/>SA: {lsd-name}-sa"]

        subgraph Providers["Garak Providers (plugins)"]
            InlineProvider["inline::trustyai_garak<br/>subprocess execution"]
            RemoteProvider["remote::trustyai_garak<br/>KFP pipeline submission"]
        end

        LSD --> InlineProvider
        LSD --> RemoteProvider
    end

    subgraph KFPZone["KUBEFLOW PIPELINES (In-Cluster)"]
        direction TB
        DSPA["DSPA API Server<br/>443/TCP HTTPS<br/>Auth: Bearer Token (SA)"]
        KFPPod["KFP Pipeline Step Pods<br/>Image: odh-trustyai-garak-<br/>lls-provider-dsp-rhel9<br/>Secrets: /mnt/model-auth"]
        DSPA --> KFPPod
    end

    subgraph EvalHubZone["EVAL-HUB (In-Cluster)"]
        direction TB
        EvalHubSvc["Eval-Hub Service<br/>K8s Job orchestration"]
        GarakPod["GarakAdapter K8s Job Pod<br/>ConfigMap: /meta/job.json<br/>Modes: simple | kfp"]
        Sidecar["Eval-Hub Sidecar<br/>localhost HTTP<br/>No auth (pod-local)"]
        EvalHubSvc -->|K8s Job| GarakPod
        GarakPod -->|status events| Sidecar
    end

    subgraph ModelEndpoints["MODEL ENDPOINTS"]
        TargetLLM["Target LLM (vLLM)<br/>443/8080 TCP HTTPS/HTTP<br/>TLS configurable<br/>Auth: Bearer Token"]
        SDGModel["SDG Model<br/>443/8080 TCP HTTPS/HTTP<br/>Auth: SDG_API_KEY"]
        JudgeModels["Judge/Attacker/Evaluator<br/>443/8080 TCP HTTPS/HTTP<br/>Auth: per-role API keys"]
        ShieldModels["Shield Models<br/>(via LSD Safety API)<br/>8321/TCP HTTP<br/>No auth (in-cluster)"]
    end

    subgraph StorageServices["STORAGE & INFRASTRUCTURE"]
        S3["S3 Object Storage<br/>443/TCP HTTPS TLS<br/>Auth: AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS TLS<br/>Auth: Registry creds"]
        MLflow["MLflow Tracking<br/>443/5000 TCP HTTPS/HTTP<br/>Auth: Configurable"]
        PostgreSQL["PostgreSQL (via LSD)<br/>5432/TCP<br/>No encryption (in-cluster)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>mTLS ServiceAccount"]
    end

    %% External flows
    User -->|"HTTP/8321<br/>No TLS<br/>No auth"| LSD

    %% Provider to KFP
    RemoteProvider -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA)"| DSPA
    GarakPod -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA)"| DSPA

    %% To model endpoints
    InlineProvider -->|"subprocess → garak"| TargetLLM
    KFPPod -->|"HTTPS/443<br/>TLS (configurable)<br/>Bearer Token"| TargetLLM
    GarakPod -->|"subprocess → garak"| TargetLLM
    KFPPod -->|"HTTPS/443<br/>Bearer: SDG_API_KEY"| SDGModel
    KFPPod -->|"HTTPS/443<br/>per-role API keys"| JudgeModels
    InlineProvider -->|"HTTP/8321<br/>in-cluster"| ShieldModels

    %% To storage
    KFPPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    GarakPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    GarakPod -->|"HTTPS/443<br/>TLS<br/>Registry creds"| OCI
    GarakPod -->|"HTTPS/443<br/>TLS"| MLflow
    LSD -->|"PostgreSQL/5432"| PostgreSQL

    %% K8s API access
    LSD -->|"HTTPS/443<br/>mTLS<br/>SA Token"| K8sAPI
    GarakPod -->|"HTTPS/443<br/>mTLS<br/>SA Token"| K8sAPI
    KFPPod -->|"HTTPS/443<br/>mTLS<br/>SA Token"| K8sAPI

    %% KFP Pod back to LSD
    KFPPod -->|"HTTP/8321<br/>No TLS"| LSD

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kfp fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef evalhub fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef model fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class LSD,InlineProvider,RemoteProvider llamastack
    class DSPA,KFPPod kfp
    class EvalHubSvc,GarakPod,Sidecar evalhub
    class TargetLLM,SDGModel,JudgeModels,ShieldModels model
    class S3,OCI,MLflow,PostgreSQL,K8sAPI storage
