graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / API Client"]
    end

    subgraph LlamaStackZone["LLAMA STACK SERVER (Host Process)"]
        direction TB
        LSD["Llama Stack Distribution<br/>8321/TCP HTTP<br/>Plugin Host"]

        subgraph InlineProvider["inline::trustyai_garak"]
            InlineEval["GarakInlineEvalAdapter<br/>Subprocess spawn (os.setsid)<br/>Semaphore concurrency"]
        end

        subgraph RemoteProvider["remote::trustyai_garak"]
            RemoteEval["GarakRemoteEvalAdapter<br/>KFP pipeline submission"]
        end

        FilesAPI["Llama Stack Files API<br/>In-process"]
        SafetyAPI["Llama Stack Safety API<br/>In-process"]
    end

    subgraph EvalHubZone["EVAL-HUB INTEGRATION"]
        direction TB
        EvalHubSvc["Eval-Hub Service<br/>K8s Job orchestration"]

        subgraph AdapterPod["GarakAdapter Pod (K8s Job)"]
            Adapter["GarakAdapter<br/>Image: odh-trustyai-garak-lls-provider-dsp-rhel9<br/>Reads: /meta/job.json<br/>Reads: /mnt/model-auth/*"]
        end

        Sidecar["Eval-Hub Sidecar<br/>localhost HTTP<br/>No encryption<br/>Pod namespace isolation"]
    end

    subgraph KFPZone["KFP PIPELINE PODS (Ephemeral)"]
        KFPPod["KFP Step Pod<br/>Image: odh-trustyai-garak-lls-provider-dsp-rhel9<br/>Secrets: /mnt/model-auth/*<br/>6-step pipeline"]
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        direction TB
        TargetLLM["Target LLM (vLLM)<br/>443/TCP or 8080/TCP<br/>HTTPS/HTTP<br/>TLS configurable (GARAK_TLS_VERIFY)<br/>Auth: Bearer Token"]
        SDGModel["SDG Model Endpoint<br/>443/TCP or 8080/TCP<br/>HTTPS/HTTP<br/>Auth: SDG_API_KEY"]
        JudgeModels["Judge/Attacker/Evaluator Models<br/>443/TCP or 8080/TCP<br/>HTTPS/HTTP<br/>Auth: Per-role API keys"]
        KFPAPI["KFP API (DSPA)<br/>443/TCP HTTPS<br/>TLS (configurable verify_ssl)<br/>Auth: SA Bearer Token"]
        S3["S3 Object Storage<br/>443/TCP HTTPS TLS<br/>Auth: AWS IAM"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS TLS<br/>Auth: Registry credentials"]
        MLflowSvc["MLflow Tracking<br/>443/TCP or 5000/TCP<br/>HTTPS/HTTP<br/>Auth: Configurable"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS mTLS<br/>Auth: SA Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>No encryption (in-cluster)<br/>Auth: Username/Password"]
    end

    %% Entry flows
    User -->|"HTTP 8321/TCP<br/>No encryption (in-cluster)<br/>No auth (delegated to LSD)"| LSD
    LSD --> InlineEval
    LSD --> RemoteEval
    EvalHubSvc -->|"K8s Job creation<br/>ConfigMap mount"| Adapter
    Adapter -->|"HTTP localhost<br/>No auth"| Sidecar

    %% Inline provider flows
    InlineEval -->|"subprocess<br/>local"| TargetLLM
    InlineEval --> FilesAPI
    InlineEval --> SafetyAPI

    %% Remote provider flows
    RemoteEval -->|"HTTPS 443/TCP<br/>TLS<br/>SA Bearer Token"| KFPAPI
    RemoteEval --> FilesAPI

    %% KFP pod flows
    KFPAPI -->|"schedules"| KFPPod
    KFPPod -->|"HTTPS 443/TCP<br/>TLS<br/>Bearer Token"| TargetLLM
    KFPPod -->|"HTTPS 443/TCP<br/>TLS<br/>SDG_API_KEY"| SDGModel
    KFPPod -->|"HTTPS 443/TCP<br/>TLS<br/>Per-role keys"| JudgeModels
    KFPPod -->|"HTTPS 443/TCP<br/>TLS<br/>AWS IAM"| S3
    KFPPod -->|"HTTP 8321/TCP"| FilesAPI

    %% Eval-hub adapter flows
    Adapter -->|"HTTPS 443/TCP<br/>TLS<br/>SA Token"| KFPAPI
    Adapter -->|"subprocess<br/>local"| TargetLLM
    Adapter -->|"HTTPS 443/TCP<br/>TLS<br/>AWS IAM"| S3
    Adapter -->|"HTTPS 443/TCP<br/>TLS<br/>Registry creds"| OCIReg
    Adapter -->|"HTTPS 443/TCP<br/>TLS"| MLflowSvc
    Adapter -->|"HTTPS 443/TCP<br/>mTLS<br/>SA Token"| K8sAPI

    %% LSD state storage
    LSD -->|"PostgreSQL 5432/TCP<br/>No encryption<br/>Username/Password"| PostgreSQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#dbeafe,stroke:#1d4ed8,stroke-width:2px
    classDef evalhub fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kfp fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef egressSecure fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    classDef egressInsecure fill:#fff3e0,stroke:#e65100,stroke-width:1px

    class User external
    class LSD,InlineEval,RemoteEval,FilesAPI,SafetyAPI llamastack
    class EvalHubSvc,Adapter,Sidecar evalhub
    class KFPPod kfp
    class TargetLLM,SDGModel,JudgeModels,KFPAPI,S3,OCIReg,MLflowSvc,K8sAPI egress
    class PostgreSQL egressInsecure
