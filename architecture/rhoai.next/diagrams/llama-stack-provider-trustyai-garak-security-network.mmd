graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (Namespace: tai-garak-lls)"]
        direction TB

        subgraph LLSPod["Llama Stack Server Pod"]
            LLServer["Llama Stack Server<br/>SA: llamastack-garak-distribution-sa"]
            GarakProvider["Garak Provider<br/>(this component)<br/>Inline: in-process<br/>Remote: KFP client"]
            GarakSub["Garak Subprocess<br/>os.setsid() isolation<br/>SIGTERM → 5s → SIGKILL"]
            LLServer --- GarakProvider
            GarakProvider -->|"subprocess spawn"| GarakSub
        end

        LLSService["llamastack-garak-distribution-service<br/>ClusterIP 8321/TCP<br/>HTTP plaintext<br/>Auth: None"]
        LLSService -->|"8321/TCP"| LLServer

        PostgresService["postgres<br/>ClusterIP 5432/TCP<br/>PostgreSQL plaintext<br/>Auth: Password<br/>(postgres-secret)"]
        LLServer -.->|"5432/TCP<br/>Password auth"| PostgresService
    end

    subgraph CrossNamespace["CLUSTER INTERNAL (Cross-namespace)"]
        direction TB

        KFPServer["Data Science Pipelines<br/>KFP API Server<br/>443/TCP HTTPS TLS<br/>Auth: Bearer Token / SA<br/>RBAC: lsd-garak-dspa-api-access"]

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount Token<br/>ConfigMap + Secret reads"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        vLLM["vLLM Model Serving<br/>Configurable port<br/>HTTP/HTTPS<br/>Auth: Bearer Token<br/>(VLLM_API_TOKEN from Secret)"]

        S3["S3 / MinIO<br/>443/TCP HTTPS TLS<br/>Auth: AWS IAM<br/>(Data Connection Secret)"]

        SDGModel["SDG / Judge / Attacker /<br/>Evaluator Model Endpoints<br/>Configurable port<br/>HTTP/HTTPS<br/>Auth: API Key<br/>(/mnt/model-auth Secret)"]

        OCI["OCI Registry<br/>443/TCP HTTPS TLS<br/>Auth: Registry auth"]

        MLflow["MLflow<br/>Configurable port<br/>HTTP/HTTPS<br/>Auth: Configurable"]
    end

    %% Outbound flows from Garak Provider
    GarakProvider -->|"HTTP/8321<br/>plaintext<br/>Files/Safety/Shields API"| LLSService
    GarakProvider -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| KFPServer
    GarakProvider -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    GarakSub -->|"HTTP(S)<br/>Bearer Token"| vLLM
    GarakProvider -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    GarakProvider -->|"HTTP(S)<br/>API Key"| SDGModel
    GarakProvider -->|"HTTPS/443<br/>TLS<br/>Registry auth"| OCI
    GarakProvider -->|"HTTP(S)<br/>Configurable"| MLflow

    %% NetworkPolicy
    KFPPod["KFP Pipeline Pods"] -->|"NetworkPolicy:<br/>allow-kfp-to-llamastack<br/>8321/TCP"| LLSService
    KFPPod -->|"HTTP(S)<br/>Bearer Token"| vLLM
    KFPPod -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef crossns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef component fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px
    classDef service fill:#f5f5f5,stroke:#666,stroke-width:1px

    class LLServer,GarakProvider,GarakSub component
    class LLSService,PostgresService service
    class KFPServer,K8sAPI crossns
    class vLLM,S3,SDGModel,OCI,MLflow external
    class KFPPod crossns
