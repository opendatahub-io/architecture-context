graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Client"]
    end

    subgraph LlamaStackRuntime["LLAMA STACK RUNTIME (In-Cluster)"]
        direction TB

        subgraph NS_LSD["Namespace: {user-namespace}"]
            LSD["Llama Stack Server<br/>8321/TCP HTTP<br/>SA: {lsd-name}-sa"]
            InlineProvider["GarakInlineEvalAdapter<br/>subprocess spawn (os.setsid)<br/>Semaphore concurrency"]
            RemoteProvider["GarakRemoteEvalAdapter<br/>KFP pipeline submission"]
        end
    end

    subgraph EvalHubRuntime["EVAL-HUB RUNTIME (In-Cluster)"]
        direction TB

        subgraph NS_EvalHub["Namespace: {eval-namespace}"]
            EvalHubSvc["Eval-Hub Service"]
            EvalPod["Eval-Hub Job Pod<br/>ConfigMap: /meta/job.json<br/>Mode: simple | kfp"]
            Sidecar["Eval-Hub Sidecar<br/>(localhost, HTTP, no auth)"]
        end
    end

    subgraph KFPRuntime["KFP RUNTIME (In-Cluster)"]
        direction TB

        subgraph NS_KFP["Namespace: {namespace}"]
            KFPAPI["KFP API (DSPA)<br/>443/TCP HTTPS<br/>RBAC: lsd-garak-dspa-api-access"]
            KFPPod["KFP Pipeline Pods<br/>Image: quay.io/rhoai/<br/>odh-trustyai-garak-lls-provider-dsp-rhel9<br/>Mount: /mnt/model-auth"]
        end
    end

    subgraph ModelEndpoints["MODEL ENDPOINTS"]
        TargetLLM["Target LLM (vLLM)<br/>443/8080 TCP<br/>HTTPS/HTTP<br/>TLS: Configurable<br/>Auth: Bearer Token"]
        SDGModel["SDG Model<br/>443/8080 TCP<br/>HTTPS/HTTP<br/>Auth: SDG_API_KEY"]
        JudgeModel["Judge/Attacker/Evaluator<br/>443/8080 TCP<br/>HTTPS/HTTP<br/>Auth: Per-role API keys"]
        ShieldModels["Shield Models<br/>(Llama Guard, Prompt Guard)<br/>8321/TCP HTTP<br/>via Llama Stack Safety API"]
    end

    subgraph StorageServices["STORAGE & TRACKING SERVICES"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS<br/>Auth: AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS<br/>Auth: Registry creds"]
        MLflow["MLflow Tracking<br/>443/5000 TCP<br/>HTTPS/HTTP<br/>Auth: Configurable"]
        PostgreSQL["PostgreSQL (via LSD)<br/>5432/TCP<br/>No encryption (in-cluster)<br/>Auth: DB credentials"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>mTLS (ServiceAccount)<br/>Auth: SA Token"]
    end

    %% External to Llama Stack
    User -->|"HTTP/8321<br/>No encryption<br/>No auth"| LSD

    %% Llama Stack internal
    LSD --> InlineProvider
    LSD --> RemoteProvider

    %% Inline mode egress
    InlineProvider -->|"HTTPS/443<br/>TLS (configurable)<br/>Bearer Token"| TargetLLM

    %% Remote mode to KFP
    RemoteProvider -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA)"| KFPAPI
    KFPAPI --> KFPPod

    %% KFP Pod egress
    KFPPod -->|"HTTPS/443<br/>TLS (configurable)<br/>Bearer Token"| TargetLLM
    KFPPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    KFPPod -->|"HTTP/8321<br/>No encryption"| LSD

    %% Eval-Hub flows
    EvalHubSvc -->|"K8s Job creation"| EvalPod
    EvalPod -->|"HTTP localhost<br/>No auth"| Sidecar
    EvalPod -->|"HTTPS/443<br/>TLS (configurable)<br/>Bearer Token"| TargetLLM
    EvalPod -->|"HTTPS/443<br/>TLS<br/>Bearer Token (SA)"| KFPAPI
    EvalPod -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    EvalPod -->|"HTTPS/443<br/>TLS<br/>Registry creds"| OCI
    EvalPod -->|"HTTPS/443<br/>Configurable"| MLflow

    %% Intents benchmark model endpoints
    KFPPod -->|"HTTPS/443<br/>Bearer Token"| SDGModel
    KFPPod -->|"HTTPS/443<br/>Per-role API keys"| JudgeModel

    %% Shield scan
    InlineProvider -->|"HTTP/8321<br/>No encryption<br/>In-cluster"| ShieldModels

    %% K8s API access
    LSD -->|"HTTPS/443<br/>mTLS<br/>SA Token"| K8sAPI
    EvalPod -->|"HTTPS/443<br/>mTLS<br/>SA Token"| K8sAPI

    %% PostgreSQL
    LSD -->|"PostgreSQL/5432<br/>No encryption<br/>DB creds"| PostgreSQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef llamastack fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef evalhub fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    classDef kfp fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    classDef models fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef k8s fill:#e0e0e0,stroke:#616161,stroke-width:2px

    class User external
    class LSD,InlineProvider,RemoteProvider llamastack
    class EvalHubSvc,EvalPod,Sidecar evalhub
    class KFPAPI,KFPPod kfp
    class TargetLLM,SDGModel,JudgeModel,ShieldModels models
    class S3,OCI,MLflow,PostgreSQL storage
    class K8sAPI k8s
