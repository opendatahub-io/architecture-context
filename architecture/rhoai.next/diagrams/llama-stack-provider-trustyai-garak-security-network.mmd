graph TB
    subgraph Orchestration["ORCHESTRATION (Internal Platform)"]
        EvalHub["eval-hub Service<br/>Creates K8s Job"]
    end

    subgraph JobPod["JOB POD"]
        direction TB

        subgraph AdapterContainer["Garak Adapter Container"]
            Adapter["Garak Adapter<br/>SA: Job service account<br/>Mounts: /mnt/model-auth (optional)<br/>Env: Data Connection creds"]
        end

        subgraph SidecarContainer["eval-hub Sidecar"]
            Sidecar["Sidecar<br/>Status callbacks<br/>Result reporting"]
        end

        Adapter -->|"localhost HTTP<br/>plaintext<br/>No Auth"| Sidecar
    end

    subgraph ModelEndpoints["MODEL ENDPOINTS (OpenAI-compatible /v1)"]
        direction TB
        TargetModel["Target Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / None"]
        JudgeModel["Judge Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        AttackerModel["Attacker Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        EvaluatorModel["Evaluator Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        SDGModel["SDG Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        TranslationModel["Translation Model<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer / None"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        direction TB
        KFP["KFP API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        MLflow["MLflow Tracking<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    subgraph ExternalStorage["EXTERNAL STORAGE / REGISTRY"]
        direction TB
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry creds"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>None / HF Token"]
    end

    subgraph KFPPods["KFP PIPELINE PODS (KFP mode only)"]
        direction TB
        Validate["validate"]
        ResolveTax["resolve_taxonomy"]
        SDGGen["sdg_generate"]
        PrepPrompts["prepare_prompts"]
        GarakScan["garak_scan"]
        WriteOutputs["write_kfp_outputs"]
    end

    %% Orchestration flow
    EvalHub -->|"K8s Job creation<br/>RBAC"| Adapter

    %% Adapter egress to models
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| TargetModel
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| JudgeModel
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| AttackerModel
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| SDGModel

    %% Adapter egress to platform
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| KFP
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| MLflow

    %% Adapter egress to storage
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| OCI

    %% KFP pods
    KFP -.->|"spawns"| KFPPods
    GarakScan -->|"HTTPS/443<br/>Bearer Token"| TargetModel
    SDGGen -->|"HTTPS/443<br/>Bearer Token"| SDGModel
    Validate -->|"HTTPS/443<br/>AWS IAM"| S3
    PrepPrompts -->|"HTTPS/443<br/>AWS IAM"| S3
    GarakScan -->|"HTTPS/443<br/>AWS IAM"| S3
    WriteOutputs -->|"HTTPS/443<br/>AWS IAM"| S3

    %% HF downloads
    Adapter -.->|"HTTPS/443<br/>TLS 1.2+<br/>None / HF Token"| HF

    %% Styling
    classDef orchestration fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef models fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef kfppods fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class EvalHub orchestration
    class Adapter,Sidecar jobpod
    class TargetModel,JudgeModel,AttackerModel,EvaluatorModel,SDGModel,TranslationModel models
    class KFP,MLflow platform
    class S3,OCI,HF storage
    class Validate,ResolveTax,SDGGen,PrepPrompts,GarakScan,WriteOutputs kfppods
