graph TB
    subgraph External["EXTERNAL SERVICES"]
        direction TB
        SDGModel["SDG Model Endpoint<br/>HTTP/HTTPS<br/>API Key (__FROM_ENV__)"]
        JudgeModel["Judge Model Endpoint<br/>HTTP/HTTPS<br/>API Key (__FROM_ENV__)"]
        AttackerModel["Attacker Model Endpoint<br/>HTTP/HTTPS<br/>API Key (__FROM_ENV__)"]
        EvaluatorModel["Evaluator Model Endpoint<br/>HTTP/HTTPS<br/>API Key (__FROM_ENV__)"]
        OCIRegistry["OCI Registry<br/>443/TCP HTTPS TLS<br/>Registry Auth"]
        MLflow["MLflow<br/>HTTP/HTTPS<br/>Configurable Auth"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (tai-garak-lls namespace)"]
        direction TB

        subgraph ComponentPod["Llama Stack Server Pod"]
            direction TB
            LLSContainer["Llama Stack Server<br/>+ Garak Provider (in-process)<br/>SA: llamastack-garak-distribution-sa"]
        end

        subgraph Services["Cluster Services"]
            LLSService["llamastack-garak-distribution-service<br/>ClusterIP 8321/TCP<br/>HTTP plaintext<br/>Auth: None"]
            PostgresService["postgres<br/>ClusterIP 5432/TCP<br/>PostgreSQL plaintext<br/>Auth: Password"]
        end

        subgraph KFPPods["KFP Pipeline Pods"]
            KFPStep["KFP Pipeline Steps<br/>(6-step pipeline)<br/>Image: odh-trustyai-garak-lls-provider-dsp"]
        end

        LLSContainer --- LLSService
    end

    subgraph PlatformServices["PLATFORM SERVICES (cluster-internal)"]
        direction TB
        KFPServer["Data Science Pipelines<br/>(KFP API Server)<br/>443/TCP HTTPS TLS<br/>Auth: Bearer Token / SA"]
        vLLM["vLLM / Model Serving<br/>HTTP/HTTPS configurable<br/>Auth: Bearer Token<br/>(VLLM_API_TOKEN)"]
        S3["S3 / MinIO<br/>443/TCP HTTPS TLS<br/>Auth: AWS IAM<br/>(Data Connection Secret)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount Token"]
    end

    %% Inbound - NetworkPolicy controlled
    KFPStep -->|"HTTP/8321<br/>plaintext<br/>NetworkPolicy: allow-kfp-to-llamastack"| LLSService

    %% Outbound from component
    LLSContainer -->|"PostgreSQL/5432<br/>plaintext<br/>Password auth"| PostgresService
    LLSContainer -->|"HTTPS/443<br/>TLS<br/>Bearer Token / SA"| KFPServer
    LLSContainer -->|"HTTP(S)<br/>configurable TLS<br/>Bearer Token"| vLLM
    LLSContainer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% KFP pod egress
    KFPStep -->|"HTTP(S)<br/>configurable<br/>Bearer Token"| vLLM
    KFPStep -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    KFPStep -->|"HTTP(S)<br/>configurable<br/>API Key"| SDGModel

    %% External egress
    LLSContainer -->|"HTTP(S)<br/>configurable<br/>API Key"| SDGModel
    LLSContainer -->|"HTTP(S)<br/>configurable<br/>API Key"| JudgeModel
    LLSContainer -->|"HTTP(S)<br/>configurable<br/>API Key"| AttackerModel
    LLSContainer -->|"HTTP(S)<br/>configurable<br/>API Key"| EvaluatorModel
    LLSContainer -->|"HTTPS/443<br/>TLS<br/>Registry Auth"| OCIRegistry
    LLSContainer -->|"HTTP(S)<br/>configurable"| MLflow

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef component fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef service fill:#e8e8e8,stroke:#666,stroke-width:1px

    class SDGModel,JudgeModel,AttackerModel,EvaluatorModel,OCIRegistry,MLflow external
    class KFPStep clusterinternal
    class LLSContainer component
    class KFPServer,vLLM,S3,K8sAPI platform
    class LLSService,PostgresService service
