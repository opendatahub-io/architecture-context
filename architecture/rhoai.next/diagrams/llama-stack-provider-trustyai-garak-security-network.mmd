graph TB
    subgraph Cluster["KUBERNETES CLUSTER (Trusted)"]
        direction TB

        subgraph JobPod["Batch Job Pod"]
            direction TB
            Adapter["GarakAdapter<br/>SA: eval-hub job SA<br/>Image: garak-provider (AIPCC CPU)"]
            GarakCLI["Garak CLI Subprocess<br/>os.setsid process group"]
            Adapter -->|spawns| GarakCLI
        end

        subgraph Mounts["Volume Mounts"]
            ModelAuth["/mnt/model-auth<br/>Secret: model-auth"]
            SAToken["/var/run/secrets/.../token<br/>ServiceAccount token"]
            ConfigMount["ConfigMap mount<br/>JobSpec"]
        end

        subgraph InternalSvc["Internal Cluster Services"]
            EvalHubSidecar["eval-hub Sidecar<br/>(in-process callback)"]
            K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token"]
            OperatorConfig["trustyai-service-operator-config<br/>ConfigMap<br/>NS: redhat-ods-applications"]
        end

        subgraph KFPCluster["KFP (KFP Mode Only)"]
            KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>SA Token"]
            KFPPods["KFP Pipeline Pods<br/>(6-step pipeline)"]
        end

        ConfigMount -.->|mounts| Adapter
        ModelAuth -.->|mounts| Adapter
        Adapter -->|callback| EvalHubSidecar
        Adapter -->|read secrets/configmaps| K8sAPI
        K8sAPI -->|reads| OperatorConfig
        Adapter -->|submit pipeline| KFPAPI
        KFPAPI -->|orchestrates| KFPPods
    end

    subgraph External["EXTERNAL SERVICES (Untrusted)"]
        direction TB

        subgraph LLMEndpoints["LLM Endpoints (OpenAI-compatible)"]
            TargetLLM["Target LLM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (api-key)"]
            JudgeLLM["Judge LLM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (JUDGE_API_KEY)"]
            AttackerLLM["Attacker LLM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (ATTACKER_API_KEY)"]
            EvaluatorLLM["Evaluator LLM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (EVALUATOR_API_KEY)"]
            SDGLLM["SDG LLM<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token (SDG_API_KEY)"]
        end

        subgraph Storage["Storage Services"]
            S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM (Data Connection)"]
            OCIReg["OCI Registry<br/>443/TCP HTTPS TLS 1.2+<br/>Registry credentials"]
        end

        subgraph Tracking["Tracking Services"]
            MLflow["MLflow Tracking<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        end

        subgraph ModelHub["Model Hub"]
            HFHub["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>None or HF Token"]
        end
    end

    %% Egress flows from Job Pod
    GarakCLI -->|"POST /v1/chat/completions<br/>HTTPS/443 TLS 1.2+<br/>Bearer Token"| TargetLLM
    GarakCLI -->|"POST /v1/chat/completions<br/>HTTPS/443 TLS 1.2+<br/>JUDGE_API_KEY"| JudgeLLM
    GarakCLI -->|"POST /v1/chat/completions<br/>HTTPS/443 TLS 1.2+<br/>ATTACKER_API_KEY"| AttackerLLM
    GarakCLI -->|"POST /v1/chat/completions<br/>HTTPS/443 TLS 1.2+<br/>EVALUATOR_API_KEY"| EvaluatorLLM
    Adapter -->|"POST /v1/chat/completions<br/>HTTPS/443 TLS 1.2+<br/>SDG_API_KEY"| SDGLLM
    Adapter -->|"S3 API<br/>HTTPS/443 TLS 1.2+<br/>AWS IAM"| S3
    KFPPods -->|"S3 API<br/>HTTPS/443 TLS 1.2+<br/>AWS IAM"| S3
    Adapter -->|"OCI push<br/>HTTPS/443 TLS 1.2+<br/>Registry creds"| OCIReg
    Adapter -->|"MLflow API<br/>HTTPS/443 TLS 1.2+<br/>Bearer Token"| MLflow
    GarakCLI -->|"Model download<br/>HTTPS/443 TLS 1.2+"| HFHub

    %% Styling
    classDef jobpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef llm fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tracking fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef modelhub fill:#f5f5f5,stroke:#666666,stroke-width:2px

    class Adapter,GarakCLI jobpod
    class EvalHubSidecar,K8sAPI,OperatorConfig,KFPAPI,KFPPods internal
    class TargetLLM,JudgeLLM,AttackerLLM,EvaluatorLLM,SDGLLM llm
    class S3,OCIReg storage
    class MLflow tracking
    class HFHub modelhub
