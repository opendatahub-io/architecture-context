graph LR
    LS["Llama Stack<br/>Distribution"]

    %% Internal RHOAI Dependencies
    LS -->|"inference + embedding<br/>HTTP/HTTPS, Bearer Token"| vLLM["vLLM<br/>v0.5.0+"]
    LS -->|"safety guardrails<br/>HTTPS, custom cert"| TrustyAIFMS["TrustyAI FMS<br/>Orchestrator"]
    LS -->|"model evaluation<br/>HTTP / K8s API"| TrustyAILMEval["TrustyAI<br/>LM Eval"]
    LS -->|"eval pipelines<br/>HTTP/HTTPS, Bearer Token"| KFP["Kubeflow<br/>Pipelines"]
    LS -->|"vector search<br/>HTTP/HTTPS, Token + mTLS"| Milvus["Milvus<br/>(remote)"]

    %% Cloud Inference Providers
    LS -->|"inference<br/>HTTPS/443, Bearer Token"| Bedrock["AWS Bedrock"]
    LS -->|"inference<br/>HTTPS/443, API Key"| Watsonx["IBM watsonx"]
    LS -->|"inference<br/>HTTPS/443, API Key"| Azure["Azure OpenAI"]
    LS -->|"inference<br/>HTTPS/443, Google ADC"| Vertex["Google Vertex AI"]
    LS -->|"inference<br/>HTTPS/443, API Key"| OpenAI["OpenAI API"]

    %% Persistence
    LS -->|"KV + SQL storage<br/>PostgreSQL/5432, Password"| PG["PostgreSQL"]

    %% Vector Databases
    LS -->|"vector DB<br/>PostgreSQL, Password"| Pgvector["pgvector"]
    LS -->|"vector DB<br/>HTTP/gRPC 6333-6334, API Key"| Qdrant["Qdrant"]

