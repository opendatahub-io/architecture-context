    LlamaStack -.->|"vector DB<br/>6333-6334/TCP"| Qdrant["Qdrant"]
    LlamaStack -.->|"inline vector DB"| FAISS["FAISS"]

    %% External Services (Optional)
    LlamaStack -.->|"file storage<br/>443/TCP HTTPS"| S3["S3 Storage"]
    LlamaStack -.->|"datasets/models<br/>443/TCP HTTPS"| HuggingFace["HuggingFace Hub"]
