    LLS -->|"HTTP framework"| FastAPI["FastAPI"]
    LLS -->|"ASGI server"| Uvicorn["uvicorn"]
    LLS -->|"LLM routing"| LiteLLM["litellm"]
    LLS -->|"AWS SDK<br/>v1.35.88"| Boto3["boto3"]
    LLS -->|"inline embeddings"| SentenceTransformers["sentence-transformers"]
    LLS -->|"tensor ops"| PyTorch["PyTorch (CPU)<br/>torchao ≥0.12.0"]
    LLS -->|"async HTTP"| HTTPX["httpx"]
    LLS -->|"cache/session"| Redis["redis"]

    %% External Data Sources
    LLS -->|"datasets + models<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Platform Infrastructure
    LLS -->|"LMEval Jobs<br/>HTTPS/443"| K8sAPI["Kubernetes API"]
    LLS -.->|"traces + metrics<br/>OTLP"| OTELCollector["OTEL Collector"]

