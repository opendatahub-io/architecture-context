graph LR
    LS["Llama Stack<br/>Distribution"]

    %% Internal RHOAI Dependencies (Required)
    LS -->|"inference + embedding<br/>HTTP/HTTPS, Bearer Token"| vLLM["vLLM Server"]
    LS -->|"persistent storage<br/>PostgreSQL/5432"| PG["PostgreSQL 17+<br/>(Required)"]

    %% Internal RHOAI Dependencies (Safety & Eval)
    LS -->|"safety shields<br/>HTTP/HTTPS"| FMS["TrustyAI FMS<br/>Orchestrator"]
    LS -->|"model evaluation<br/>HTTP + K8s Jobs"| LMEval["TrustyAI LMEval"]
    LS -->|"RAGAS + Garak<br/>HTTPS, Bearer Token"| KFP["Kubeflow<br/>Pipelines"]

    %% Vector Databases
    LS -->|"vector search<br/>HTTP/gRPC, mTLS"| MilvusR["Milvus (remote)"]
    LS -->|"embedded vector<br/>local file I/O"| MilvusL["Milvus Lite<br/>(inline)"]
    LS -->|"vector search<br/>PostgreSQL"| PGVec["pgvector"]
    LS -->|"vector search<br/>HTTP/gRPC, API Key"| Qdrant["Qdrant"]
    LS -->|"in-memory vector<br/>local"| FAISS["FAISS<br/>(inline)"]

    %% Cloud Inference Providers
    LS -->|"remote inference<br/>HTTPS, Bearer Token"| Bedrock["AWS Bedrock"]
    LS -->|"remote inference<br/>HTTPS, ADC"| Vertex["Google<br/>Vertex AI"]
    LS -->|"remote inference<br/>HTTPS, API Key"| Azure["Azure OpenAI"]
    LS -->|"remote inference<br/>HTTPS, API Key"| WatsonX["IBM WatsonX"]
    LS -->|"remote inference<br/>HTTPS, API Key"| OpenAI["OpenAI API"]

    %% External Services
    LS -->|"file storage<br/>HTTPS, AWS IAM"| S3["S3 / S3-compatible"]
    LS -->|"dataset/model download<br/>HTTPS"| HF["HuggingFace Hub"]
    LS -->|"web search<br/>HTTPS, API Key"| Brave["Brave Search"]
    LS -->|"web search<br/>HTTPS, API Key"| Tavily["Tavily Search"]
    LS -->|"tool servers<br/>HTTP/HTTPS, SSE"| MCP["MCP Servers"]

    %% Platform Dependencies
    LS -->|"create eval Jobs<br/>HTTPS, SA Token"| K8s["Kubernetes API"]
    LS -.->|"traces + metrics<br/>OTLP (optional)"| OTEL["OTEL Collector"]

    %% Core Framework
    LlamaStackFW["llama-stack<br/>v0.5.0+rhai0<br/>(opendatahub-io fork)"] -->|"core framework"| LS

    %% Integration Points (incoming)
    Dashboard["ODH Dashboard"] -.->|"UI management"| LS
    Operator["Platform Operator<br/>(rhods-operator)"] -.->|"deploys + configures"| LS

