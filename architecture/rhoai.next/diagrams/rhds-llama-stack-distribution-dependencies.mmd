graph LR
    LS["Llama Stack Distribution<br/>(rhds-llama-stack-distribution)"]

    %% Core Required Dependencies
    subgraph Required["Required Dependencies"]
        LlamaStackFW["llama-stack<br/>v0.5.0+rhai0<br/>(opendatahub-io fork)"]
        LlamaStackClient["llama-stack-client<br/>v0.5.0"]
        PostgreSQLDep["PostgreSQL<br/>17+"]
        GraniteEmbed["ibm-granite/<br/>granite-embedding-125m-english"]
    end

    LS -->|"core framework"| LlamaStackFW
    LS -->|"client library"| LlamaStackClient
    LS -->|"mandatory storage<br/>5432/TCP"| PostgreSQLDep
    LS -->|"pre-downloaded<br/>embedding model"| GraniteEmbed

    %% Internal RHOAI Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        vLLMDep["vLLM Serving Runtime<br/>REST API"]
        TrustyAIDep["TrustyAI<br/>Safety + Evaluation"]
        KubeflowDep["Kubeflow Pipelines<br/>Eval orchestration"]
    end

    LS -->|"primary inference<br/>HTTP(S)/8000"| vLLMDep
    LS -->|"safety shields,<br/>lmeval, RAGAS, Garak"| TrustyAIDep
    LS -->|"remote eval jobs<br/>HTTPS"| KubeflowDep

    %% Cloud Inference Providers (Optional)
    subgraph CloudInference["Cloud Inference Providers (Optional)"]
        BedrockDep["AWS Bedrock"]
        WatsonxDep["IBM Watsonx"]
        AzureDep["Azure AI"]
        VertexDep["Google Vertex AI"]
        OpenAIDep["OpenAI"]
    end

    LS -->|"HTTPS/443<br/>Bearer token"| BedrockDep
    LS -->|"HTTPS/443<br/>API key"| WatsonxDep
    LS -->|"HTTPS/443<br/>API key"| AzureDep
    LS -->|"HTTPS/443<br/>OAuth2"| VertexDep
    LS -->|"HTTPS/443<br/>API key"| OpenAIDep

    %% Vector Stores (Optional)
    subgraph VectorDBs["Vector Stores (Optional)"]
        MilvusDep["Milvus<br/>(lite=default, remote)"]
        FAISSDep["FAISS<br/>(inline)"]
        PgVectorDep["pgvector"]
        QdrantDep["Qdrant"]
    end

    LS -->|"gRPC/HTTP<br/>TLS + token"| MilvusDep
    LS -->|"inline"| FAISSDep
    LS -->|"PostgreSQL/5432"| PgVectorDep
    LS -->|"HTTP-gRPC<br/>6333-6334"| QdrantDep

    %% External Services (Optional)
    subgraph ExternalSvcs["External Services (Optional)"]
        S3Dep["AWS S3 /<br/>S3-compatible"]
        HFDep["HuggingFace Hub"]
        BraveDep["Brave Search"]
        TavilyDep["Tavily Search"]
        SentenceTDep["sentence-transformers"]
        MCPDep["MCP Servers"]
        OTelDep["OpenTelemetry<br/>Collector"]
    end

    LS -->|"HTTPS/443<br/>AWS IAM"| S3Dep
    LS -->|"HTTPS/443"| HFDep
    LS -->|"HTTPS/443<br/>API key"| BraveDep
    LS -->|"HTTPS/443<br/>API key"| TavilyDep
    LS -->|"inline (in-process)"| SentenceTDep
    LS -->|"HTTP<br/>MCP protocol"| MCPDep
    LS -->|"HTTP OTLP"| OTelDep

    %% Build Dependencies
    subgraph BuildDeps["Build Infrastructure"]
        AIPCCBase["AIPCC CPU Base Image<br/>UBI9/RHEL 9.6"]
        WheelRegistry["Internal GitLab<br/>Wheel Registry"]
        Konflux["Konflux / Tekton<br/>CI/CD"]
    end

    LS -.->|"base image"| AIPCCBase
    LS -.->|"wheel releases<br/>install-wheel-release.sh"| WheelRegistry
    LS -.->|"build pipeline"| Konflux

    %% Styling
    style LS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Required fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style InternalRHOAI fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CloudInference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style VectorDBs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style ExternalSvcs fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style BuildDeps fill:#f5f5f5,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    style LlamaStackFW fill:#f5a623,stroke:#333
    style PostgreSQLDep fill:#f5a623,stroke:#333
    style GraniteEmbed fill:#f5a623,stroke:#333
    style vLLMDep fill:#7ed321,stroke:#333
    style TrustyAIDep fill:#7ed321,stroke:#333
    style KubeflowDep fill:#7ed321,stroke:#333
