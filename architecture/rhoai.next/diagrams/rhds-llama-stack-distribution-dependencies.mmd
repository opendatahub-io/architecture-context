graph LR
    LS["Llama Stack<br/>Distribution"]

    %% Internal Platform Dependencies (Green)
    LS -->|"inference & embeddings<br/>HTTPS, Bearer token"| vLLM["vLLM"]
    LS -->|"safety shields<br/>HTTPS, custom cert"| TrustyFMS["TrustyAI FMS<br/>Orchestrator"]
    LS -->|"model evaluation<br/>HTTP/HTTPS"| TrustyLMEval["TrustyAI LM-Eval"]
    LS -->|"eval pipelines<br/>HTTPS, Bearer token"| Kubeflow["Kubeflow<br/>Pipelines"]
    LS -->|"vector storage<br/>HTTPS, Token"| Milvus["Milvus<br/>(remote)"]
    LS -->|"vector storage<br/>PostgreSQL/5432"| PgVector["PgVector"]
    LS -->|"vector storage<br/>REST-gRPC/6333-6334"| Qdrant["Qdrant"]

    %% External Cloud Inference Providers (Orange)
    LS -->|"remote inference<br/>HTTPS/443"| AWSBedrock["AWS Bedrock"]
    LS -->|"remote inference<br/>HTTPS/443"| GoogleVertex["Google Vertex AI"]
    LS -->|"remote inference<br/>HTTPS/443"| AzureOpenAI["Azure OpenAI"]
    LS -->|"remote inference<br/>HTTPS/443"| IBMWatsonx["IBM watsonx"]
    LS -->|"remote inference<br/>HTTPS/443"| OpenAI["OpenAI API"]

    %% Persistence (Purple)
    LS -->|"KV + SQL store<br/>PostgreSQL/5432"| PostgreSQL["PostgreSQL"]
    LS -->|"file storage<br/>HTTPS/443, AWS IAM"| S3["S3-Compatible<br/>Storage"]

    %% Tool Runtime APIs (Yellow)
    LS -->|"web search tool<br/>HTTPS/443, API key"| BraveSearch["Brave Search"]
    LS -->|"web search tool<br/>HTTPS/443, API key"| TavilySearch["Tavily Search"]
    LS -->|"datasets & models<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]
    LS -.->|"tool execution<br/>configurable"| MCPServers["MCP Servers"]

    %% Observability (Gray dashed)
    LS -.->|"traces & metrics<br/>OTLP/HTTPS"| OTELCollector["OTEL Collector"]

    %% Platform Auth (incoming)
    RHOAIOp["RHOAI Operator"] -->|"injects sidecar"| KubeRBAC["kube-rbac-proxy"]
    KubeRBAC -->|"auth proxy<br/>HTTP/8321"| LS

    %% Core Framework Dependencies
    subgraph CoreFramework["Core Framework"]
        LlamaStackFW["llama-stack<br/>v0.5.0+rhai0"]
        LlamaClient["llama-stack-client<br/>v0.5.0"]
        Torch["PyTorch<br/>(CPU)"]
        SentenceT["sentence-transformers"]
        GraniteEmb["granite-embedding<br/>-125m-english"]
    end

    LS -->|"core framework"| LlamaStackFW
    LS -->|"client library"| LlamaClient
    LS -->|"model execution"| Torch
    LS -->|"inline embeddings"| SentenceT
    LS -->|"pre-downloaded model"| GraniteEmb

