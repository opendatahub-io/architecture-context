graph LR
    LlamaStack["Llama Stack<br/>Distribution<br/>(API Gateway)"]

    %% Core Framework
    LlamaStack -->|"pip install<br/>v0.5.0+rhai0"| LlamaStackCore["llama-stack<br/>(opendatahub-io fork)<br/>v0.5.0+rhai0"]

    %% Internal RHOAI Dependencies
    LlamaStack -->|"REST API<br/>HTTP/HTTPS<br/>Bearer Token"| vLLM["vLLM Server<br/>(primary inference)"]
    LlamaStack -->|"REST API<br/>HTTP/HTTPS"| FMS["TrustyAI FMS<br/>Orchestrator<br/>(safety shields)"]
    LlamaStack -->|"REST API +<br/>K8s Job"| LMEval["TrustyAI LMEval<br/>(model evaluation)"]
    LlamaStack -->|"REST API<br/>HTTPS"| KFP["Kubeflow Pipelines<br/>(RAGAS/Garak eval)"]

    %% Critical Runtime Dependencies
    LlamaStack -->|"PostgreSQL/5432<br/>persistent state"| PostgreSQL["PostgreSQL 17+<br/>(kvstore, SQL)"]
    LlamaStack -->|"HTTP/gRPC<br/>vector search"| Milvus["Milvus<br/>(inline + remote)"]

    %% Cloud Inference Providers
    LlamaStack -->|"HTTPS/443"| Bedrock["AWS Bedrock"]
    LlamaStack -->|"HTTPS/443"| VertexAI["Google Vertex AI"]
    LlamaStack -->|"HTTPS/443"| AzureOAI["Azure OpenAI"]
    LlamaStack -->|"HTTPS/443"| WatsonX["IBM WatsonX"]
    LlamaStack -->|"HTTPS/443"| OpenAI["OpenAI API"]

    %% Additional Vector DBs
    LlamaStack -->|"PostgreSQL"| PGVector["pgvector"]
    LlamaStack -->|"HTTP/gRPC"| Qdrant["Qdrant"]

    %% Storage
    LlamaStack -->|"HTTPS/443<br/>AWS IAM"| S3["S3 / S3-compatible<br/>Storage"]

    %% Tool Services
    LlamaStack -->|"HTTPS/443"| Brave["Brave Search API"]
    LlamaStack -->|"HTTPS/443"| Tavily["Tavily Search API"]
    LlamaStack -->|"HTTP/HTTPS"| MCP["MCP Servers"]

    %% Data Sources
    LlamaStack -->|"HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Build/Runtime Dependencies
    LlamaStack -.->|"Python runtime"| FastAPI["FastAPI + uvicorn"]
    LlamaStack -.->|"ML ops"| PyTorch["PyTorch (CPU)<br/>torchao >=0.12.0"]
    LlamaStack -.->|"multi-provider"| LiteLLM["litellm"]
    LlamaStack -.->|"optional"| OTEL["OpenTelemetry"]
    LlamaStack -.->|"eval providers"| TrustyAIProviders["TrustyAI Providers<br/>lmeval 0.5.0<br/>ragas 0.6.0<br/>fms 0.4.0<br/>garak 0.2.0"]

    %% Infrastructure
    LlamaStack -->|"HTTPS/443<br/>SA Token"| K8sAPI["Kubernetes API"]

