graph LR
    LlamaStack["Llama Stack<br/>Distribution"]

    %% Core Runtime Dependencies (Required)
    LlamaStack -->|"core framework<br/>v0.5.0+rhai0"| LlamaStackFork["llama-stack<br/>(opendatahub-io fork)"]
    LlamaStack -->|"runtime<br/>3.12"| Python["Python 3.12"]
    LlamaStack -->|"HTTP framework"| FastAPI["FastAPI"]
    LlamaStack -->|"ASGI server"| Uvicorn["Uvicorn"]
    LlamaStack -->|"persistent storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 17+"]

    %% Internal RHOAI Dependencies
    LlamaStack -->|"inference<br/>8000/TCP HTTP(S)"| vLLM["vLLM Serving Runtime"]
    LlamaStack -->|"safety shields<br/>HTTP(S)"| TrustyAIFMS["TrustyAI FMS<br/>Orchestrator"]
    LlamaStack -->|"LLM eval<br/>K8s Jobs"| TrustyAILMEval["TrustyAI LMEval"]
    LlamaStack -->|"eval pipelines<br/>HTTP"| KubeflowPipelines["Kubeflow Pipelines"]

    %% TrustyAI Provider Plugins (Required)
    LlamaStack -->|"eval plugin<br/>v0.5.0"| LMEvalPlugin["llama_stack_provider_lmeval"]
    LlamaStack -->|"eval plugin<br/>v0.6.0"| RAGASPlugin["llama_stack_provider_ragas"]
    LlamaStack -->|"safety plugin<br/>v0.4.0"| FMSPlugin["llama_stack_provider_trustyai_fms"]
    LlamaStack -->|"eval plugin<br/>v0.2.0"| GarakPlugin["llama_stack_provider_trustyai_garak"]

    %% Cloud Inference Backends (Optional)
    LlamaStack -.->|"cloud inference<br/>443/TCP HTTPS"| AWSBedrock["AWS Bedrock"]
    LlamaStack -.->|"cloud inference<br/>443/TCP HTTPS"| WatsonX["IBM WatsonX"]
    LlamaStack -.->|"cloud inference<br/>443/TCP HTTPS"| AzureOpenAI["Azure OpenAI"]
    LlamaStack -.->|"cloud inference<br/>443/TCP HTTPS"| VertexAI["Google Vertex AI"]
    LlamaStack -.->|"cloud inference<br/>443/TCP HTTPS"| OpenAI["OpenAI API"]

    %% Vector Database Backends (Optional)
    LlamaStack -.->|"inline vector DB"| MilvusLite["Milvus Lite"]
