graph LR
    LS["Llama Stack<br/>Distribution"]

    %% Core Required Dependencies
    subgraph CoreDeps["Core Dependencies (Required)"]
        LlamaStackFork["llama-stack<br/>(opendatahub-io fork)<br/>v0.5.0+rhai0"]
        LlamaStackClient["llama-stack-client<br/>v0.5.0"]
        Python312["Python 3.12<br/>UBI9 base"]
        FastAPI["FastAPI<br/>HTTP Framework"]
        Uvicorn["Uvicorn<br/>ASGI Server"]
    end

    %% Primary Internal Platform Dependencies
    subgraph InternalPlatform["Internal Platform (RHOAI)"]
        vLLM["vLLM Serving Runtime<br/>REST API (OpenAI-compat)<br/>8000/TCP"]
        PostgreSQL["PostgreSQL 17+<br/>KV + SQL Store<br/>5432/TCP"]
        TrustyAIFMS["TrustyAI FMS Orchestrator<br/>Safety Shields<br/>HTTP/HTTPS"]
        TrustyAILMEval["TrustyAI LMEval<br/>Evaluation Jobs<br/>K8s API"]
        KubeflowPipelines["Kubeflow Pipelines<br/>Remote Eval<br/>HTTP"]
        RHODSOperator["rhods-operator<br/>Deployment Management"]
    end

    %% TrustyAI Provider Plugins
    subgraph TrustyAIPlugins["TrustyAI Provider Plugins"]
        LMEvalPlugin["llama_stack_provider_lmeval<br/>v0.5.0"]
        RAGASInline["llama_stack_provider_ragas<br/>(inline) v0.6.0"]
        RAGASRemote["llama_stack_provider_ragas<br/>(remote) v0.6.0"]
        FMSPlugin["llama_stack_provider_trustyai_fms<br/>v0.4.0"]
        GarakPlugin["llama_stack_provider_trustyai_garak<br/>v0.2.0"]
    end

    %% Cloud Inference Backends
    subgraph CloudInference["Cloud Inference Backends (Optional)"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS"]
    end

    %% Vector Databases
    subgraph VectorDBs["Vector Databases (Optional)"]
        MilvusLite["Milvus Lite<br/>(inline, default)"]
        MilvusRemote["Milvus Remote<br/>REST/gRPC"]
        PgVector["pgvector<br/>5432/TCP"]
        Qdrant["Qdrant<br/>6333/6334 TCP"]
        FAISS["FAISS<br/>(inline, CPU)"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS"]
        Tavily["Tavily Search<br/>443/TCP HTTPS"]
        OTel["OpenTelemetry Collector<br/>4318/TCP HTTP"]
    end

    %% Optional Libraries
    subgraph OptionalLibs["Optional Libraries"]
        PyTorch["PyTorch (CPU)"]
        SentenceTransformers["sentence-transformers"]
        Boto3["boto3 1.35.88"]
        LiteLLM["litellm"]
        GoogleAI["google-cloud-aiplatform"]
        KFPClient["kfp-kubernetes 2.14.6"]
        OTelSDK["OpenTelemetry SDK"]
    end

    %% Core dependency connections
    LS -->|"runtime framework"| LlamaStackFork
    LS -->|"CLI/client"| LlamaStackClient
    LS -->|"runtime"| Python312
    LS -->|"HTTP framework"| FastAPI
    LS -->|"ASGI server"| Uvicorn

    %% Internal platform connections
    LS -->|"inference"| vLLM
    LS -->|"persistence"| PostgreSQL
    LS -->|"safety shields"| TrustyAIFMS
    LS -->|"eval jobs"| TrustyAILMEval
    LS -->|"remote eval"| KubeflowPipelines
    LS -.->|"deployed by"| RHODSOperator

    %% TrustyAI plugin connections
    LS -->|"eval provider"| LMEvalPlugin
    LS -->|"inline eval"| RAGASInline
    LS -->|"remote eval"| RAGASRemote
    LS -->|"safety provider"| FMSPlugin
    LS -->|"security eval"| GarakPlugin

    %% Cloud inference connections
    LS -.->|"remote inference"| Bedrock
    LS -.->|"remote inference"| WatsonX
    LS -.->|"remote inference"| Azure
    LS -.->|"remote inference"| Vertex
    LS -.->|"remote inference"| OpenAI

    %% Vector DB connections
    LS -->|"default vector DB"| MilvusLite
    LS -.->|"remote vectors"| MilvusRemote
    LS -.->|"remote vectors"| PgVector
    LS -.->|"remote vectors"| Qdrant
    LS -.->|"inline vectors"| FAISS

    %% External service connections
    LS -.->|"file storage"| S3
    LS -.->|"datasets/models"| HuggingFace
    LS -.->|"web search"| BraveSearch
    LS -.->|"web search"| Tavily
    LS -.->|"observability"| OTel

    %% Optional library connections
    LS -.->|"CPU tensors"| PyTorch
    LS -.->|"embeddings"| SentenceTransformers
    LS -.->|"AWS SDK"| Boto3
    LS -.->|"LLM proxy"| LiteLLM
    LS -.->|"Vertex SDK"| GoogleAI
    LS -.->|"KFP client"| KFPClient
    LS -.->|"tracing"| OTelSDK

