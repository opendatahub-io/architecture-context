    LS -->|"safety plugin"| TrustyAIPlugin["llama_stack_provider<br/>_trustyai_fms 0.4.0"]
    LS -->|"security eval"| GarakPlugin["llama_stack_provider<br/>_trustyai_garak 0.2.0"]

