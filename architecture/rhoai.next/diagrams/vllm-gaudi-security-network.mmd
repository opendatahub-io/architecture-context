graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (KServe Gateway — DMZ)"]
        Gateway["KServe Gateway<br/>HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>JWT Validation"]
    end

    subgraph Pod["APPLICATION POD"]
        direction TB

        subgraph AuthSidecar["Auth Sidecar"]
            RBAC["kube-rbac-proxy<br/>8443/TCP → 8000/TCP<br/>TLS termination<br/>RBAC enforcement"]
        end

        subgraph AppContainer["vLLM Container (odh-vllm-gaudi-rhel9)"]
            API["vLLM API Server<br/>8000/TCP HTTP (plaintext)<br/>OpenAI-compatible endpoints<br/>UBI 9 base / FIPS DISABLED"]
            Worker["HPUWorker<br/>In-process execution"]
            Gaudi["Intel Gaudi 2/3<br/>SynapseAI v1.23.0"]
        end
    end

    subgraph IntraCluster["INTRA-CLUSTER (Plaintext)"]
        direction TB
        HCCL["HCCL Peer Workers<br/>Dynamic ports<br/>Plaintext, no auth<br/>Tensor/Pipeline parallelism"]
        NIXL["NIXL Side Channel<br/>NIXL_PORT + dp_rank<br/>HTTP plaintext, no auth<br/>KV cache coordination"]
        RDMA["NIXL RDMA Transfer<br/>Dynamic ports<br/>No encryption, no auth<br/>Direct HPU memory transfer"]
        RayHead["Ray Head Node<br/>6379/TCP<br/>No encryption, no auth<br/>Distributed orchestration"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 / MinIO<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        HF["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (JWT)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>ServiceAccount Token"| RBAC
    RBAC -->|"HTTP/8000<br/>Plaintext (localhost)<br/>No auth (trusted)"| API

    %% Internal flows
    API -->|"In-process"| Worker
    Worker -->|"SynapseAI HAL"| Gaudi

    %% Intra-cluster flows
    Worker -->|"HCCL<br/>Dynamic port<br/>Plaintext"| HCCL
    Worker -->|"HTTP<br/>Plaintext"| NIXL
    Worker -->|"RDMA<br/>No encryption"| RDMA
    Worker -->|"Ray protocol<br/>6379/TCP"| RayHead

    %% Egress flows
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / Access Key"| S3
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authsidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef intracluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class RBAC authsidecar
    class API,Worker warning
    class Gaudi app
    class HCCL,NIXL,RDMA,RayHead intracluster
    class S3,HF externalservice
