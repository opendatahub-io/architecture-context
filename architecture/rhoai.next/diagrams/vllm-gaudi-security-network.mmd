graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe/RHOAI-managed)"]
        Gateway["KServe Router / Istio Gateway<br/>TLS termination<br/>kube-rbac-proxy sidecar<br/>RequestAuthentication"]
    end

    subgraph InferencePod["INFERENCE POD (vllm-gaudi)"]
        direction TB
        APIServer["vLLM OpenAI API Server<br/>8000/TCP HTTP (no TLS)<br/>UID 2000 (non-root)<br/>FIPS: DISABLED"]
        Plugin["vllm-gaudi Plugin<br/>HPUModelRunner<br/>Attention Backends<br/>Custom Ops"]
        SynapseAI["Habana Synapse AI 1.23.0<br/>Device Driver"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (No Encryption)"]
        direction TB
        PeerWorkers["Peer Gaudi Workers<br/>HCCL/RDMA<br/>all-reduce, all-gather"]
        RayCluster["Ray Cluster<br/>6379/TCP<br/>Ray protocol"]
        NixlTransfer["NIXL KV Transfer<br/>RDMA/TCP<br/>Prefill → Decode"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        S3["S3 Model Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
        HabanaArtifactory["Habana Artifactory<br/>443/TCP HTTPS<br/>BUILD TIME ONLY"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway

    %% Ingress → Pod
    Gateway -->|"HTTP/8000<br/>No encryption*<br/>No auth (vLLM)<br/>*service mesh may add mTLS"| APIServer

    %% Internal pod flows
    APIServer -->|"In-process<br/>Python call"| Plugin
    Plugin -->|"Device driver<br/>Synapse API"| SynapseAI

    %% Distributed communication
    Plugin -->|"HCCL/RDMA<br/>No encryption<br/>No auth"| PeerWorkers
    Plugin -->|"Ray/6379<br/>No encryption<br/>No auth"| RayCluster
    Plugin -.->|"NIXL/RDMA<br/>No encryption<br/>No auth"| NixlTransfer

    %% Egress
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / SA"| S3
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class APIServer warning
    class Plugin,SynapseAI pod
    class PeerWorkers,RayCluster,NixlTransfer cluster
    class S3,HuggingFace,HabanaArtifactory externalservice
