graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway / HTTPRoute<br/>443/TCP<br/>TLS 1.3<br/>Bearer Token Auth"]
        KRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP &rarr; 8000/TCP<br/>TLS termination<br/>RBAC enforcement"]
    end

    subgraph Application["APPLICATION (Pod-Internal)"]
        direction TB

        subgraph PodBoundary["Pod: vllm-gaudi"]
            VLLM["vLLM OpenAI API Server<br/>8000/TCP HTTP<br/>No TLS (localhost)<br/>No Auth (delegated)"]
            Runner["HPUModelRunner<br/>In-process Python<br/>Bucketing + Graph Compilation"]
        end

        HPU["Intel Gaudi 2/3 HPU<br/>PCIe/RDMA<br/>Synapse AI 1.23.0<br/>BFloat16 compute"]
    end

    subgraph Distributed["DISTRIBUTED (Unencrypted)"]
        direction TB
        Ray["Ray Cluster<br/>6379/TCP, 10001/TCP<br/>No encryption<br/>Ray internal auth"]
        HCCL["HCCL Collectives<br/>Dynamic ports<br/>No encryption<br/>all-reduce/all-gather"]
        NIXLNode["NIXL KV Transfer<br/>UCX/TCP Dynamic ports<br/>No encryption<br/>Disaggregated prefill/decode"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        HabanaArtifactory["vault.habana.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Public (build-time only)"]
    end

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>RBAC validation"| KRBAC
    KRBAC -->|"HTTP/8000<br/>localhost<br/>No encryption"| VLLM

    %% Internal flows
    VLLM -->|"In-process<br/>Python"| Runner
    Runner -->|"PCIe/RDMA<br/>HPU driver"| HPU

    %% Distributed flows
    Runner -->|"TCP/6379,10001<br/>Ray protocol<br/>No encryption"| Ray
    Runner -->|"HCCL/TCP<br/>Dynamic ports<br/>No encryption"| HCCL
    Runner -.->|"UCX/TCP<br/>Dynamic ports<br/>No encryption"| NIXLNode

    %% Egress flows
    VLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef distributed fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,KRBAC ingress
    class VLLM,Runner application
    class HPU hardware
    class Ray,HCCL,NIXLNode distributed
    class HFHub,HabanaArtifactory externalservice
