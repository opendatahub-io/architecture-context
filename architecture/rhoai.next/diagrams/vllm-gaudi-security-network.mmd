graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AuthEnforcement["INGRESS (Auth Enforcement)"]
        Proxy["kube-rbac-proxy Sidecar<br/>8443/TCP → 8000/TCP<br/>TLS 1.3 Termination<br/>Bearer Token → K8s RBAC"]
    end

    subgraph Pod["APPLICATION POD (UID 2000, non-root)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["vLLM OpenAI API Server<br/>8000/TCP HTTP<br/>No auth (pre-authenticated)<br/>Endpoints: /v1/completions,<br/>/v1/chat/completions, /v1/models,<br/>/v1/embeddings, /health, /metrics"]
        end

        subgraph InferenceEngine["Inference Engine"]
            ModelRunner["HPUModelRunner<br/>Model execution, KV cache,<br/>graph compilation"]
            Worker["HPUWorker<br/>Device init, memory profiling,<br/>distributed communication"]
            Worker -->|manages| ModelRunner
        end

        subgraph Runtime["Hardware Runtime (in-process)"]
            SynapseAI["SynapseAI v1.23.0<br/>(Graph compiler, kernels)"]
            PyTorchHPU["PyTorch HPU v2.9.0<br/>(Tensor operations)"]
            HPUDevice["Intel Gaudi HPU<br/>(Gaudi2/Gaudi3)"]
        end
    end

    subgraph DistributedIntra["DISTRIBUTED (Intra-Cluster, Plaintext)"]
        Ray["Ray Cluster<br/>6379/TCP + dynamic<br/>TCP, No encryption"]
        HCCL["HCCL Peers<br/>Dynamic ports<br/>RDMA/TCP, No encryption"]
        NIXL["NIXL Peers<br/>Dynamic ports<br/>RDMA/TCP, No encryption"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (TLS)"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN Bearer"]
        S3["Model Storage (S3)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    subgraph Platform["PLATFORM"]
        KServe["KServe / ServingRuntime<br/>Deploys container, injects proxy"]
        Dashboard["RHOAI Dashboard<br/>Runtime selection UI"]
        Registry["Model Registry<br/>Image references"]
    end

    %% Client flow
    Client -->|"HTTPS/8443<br/>TLS 1.3<br/>Bearer Token"| Proxy
    Proxy -->|"HTTP/8000<br/>localhost<br/>pre-authenticated"| APIServer
    APIServer -->|in-process| ModelRunner
    ModelRunner -->|in-process| SynapseAI
    ModelRunner -->|in-process| PyTorchHPU
    SynapseAI -->|device driver| HPUDevice

    %% Distributed
    Worker -->|"TCP/6379<br/>plaintext"| Ray
    Worker -->|"RDMA/TCP<br/>plaintext"| HCCL
    Worker -->|"RDMA/TCP<br/>plaintext"| NIXL

    %% External downloads
    ModelRunner -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    ModelRunner -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Platform
    KServe -.->|deploys & manages| Pod
    Dashboard -.->|references| KServe
    Registry -.->|image ref| KServe

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef distributed fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Proxy ingress
    class APIServer,ModelRunner,Worker,SynapseAI,PyTorchHPU,HPUDevice app
    class Ray,HCCL,NIXL danger
    class HF,S3 externalservice
    class KServe,Dashboard,Registry platform
