graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["KServe Ingress / RHOAI Gateway<br/>443/TCP<br/>TLS 1.3 Termination<br/>HTTPRoute"]
        KRBAC["kube-rbac-proxy Sidecar<br/>JWT Validation<br/>Kubernetes RBAC Enforcement"]
    end

    subgraph AppPod["APPLICATION POD (Inference Runtime)"]
        direction TB

        VLLM["vLLM API Server<br/>odh-vllm-gaudi-rhel9<br/>8000/TCP HTTP (plaintext)<br/>Endpoints: /v1/*, /health, /metrics"]

        subgraph HPUStack["HPU Execution Stack"]
            Runner["HPUModelRunner<br/>vllm_gaudi plugin"]
            HPU["Intel Gaudi 2/3 HPU<br/>SynapseAI v1.23.0"]
        end

        subgraph Distributed["Distributed Communication"]
            HCCLComm["HCCL<br/>Collective Ops<br/>RDMA/TCP plaintext"]
            NIXLConn["NIXL Connector<br/>UCX/RDMA/GDR<br/>plaintext (optional)"]
        end
    end

    subgraph PeerPods["PEER PODS (Multi-Card)"]
        PeerWorker["Peer HPUWorkers<br/>Tensor Parallel / Data Parallel"]
        DecodeWorker["Remote Decode HPUWorker<br/>KV Cache Target (optional)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token (HF_TOKEN)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        Ray["Ray Head Node<br/>6379/TCP gRPC<br/>No encryption"]
    end

    %% Flows - Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token (JWT)"| Gateway
    Gateway -->|"Internal forward"| KRBAC
    KRBAC -->|"HTTP/8000<br/>plaintext (localhost)<br/>No auth (trusted)"| VLLM

    %% Flows - Internal
    VLLM -->|"Python in-process"| Runner
    Runner -->|"PCIe / SynapseAI"| HPU

    %% Flows - Distributed
    HPU -->|"HCCL<br/>RDMA/TCP<br/>plaintext"| HCCLComm
    HCCLComm -->|"Dynamic ports<br/>plaintext<br/>No auth"| PeerWorker
    Runner -.->|"Python in-process"| NIXLConn
    NIXLConn -.->|"UCX RDMA/GDR<br/>plaintext<br/>No auth"| DecodeWorker

    %% Flows - Egress
    VLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    VLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    VLLM -.->|"gRPC/6379<br/>No encryption"| Ray

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef peer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,KRBAC ingress
    class VLLM,Runner,HPU,HCCLComm,NIXLConn app
    class PeerWorker,DecodeWorker peer
    class HF,S3,Ray externalservice
