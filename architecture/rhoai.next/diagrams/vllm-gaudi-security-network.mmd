graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist"]
    end

    subgraph AuthProxy["INGRESS (Pod-level Auth Proxy)"]
        KRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.3 Termination<br/>Bearer Token Validation"]
    end

    subgraph Application["APPLICATION (Pod-internal)"]
        direction TB
        vLLM["vLLM OpenAI API Server<br/>8000/TCP HTTP (plaintext)<br/>UID 2000 (non-root)<br/>Container: odh-vllm-gaudi-rhel9"]

        subgraph PluginLayer["vllm-gaudi Plugin"]
            Runner["HPUModelRunner<br/>Forward Pass, KV Cache,<br/>Graph Compilation"]
            Worker["HPUWorker<br/>Device Init, Memory Profiling"]
        end

        HPU["Intel Gaudi HPU<br/>(Gaudi2 / Gaudi3)"]
    end

    subgraph Distributed["CLUSTER-INTERNAL (Plaintext, Intra-cluster)"]
        Ray["Ray Cluster<br/>6379/TCP<br/>TCP Plaintext"]
        HCCL["HCCL Peer HPUs<br/>RDMA/TCP Plaintext<br/>All-reduce, All-gather"]
        NIXL["NIXL Peer Nodes<br/>RDMA/TCP Plaintext<br/>KV Cache Transfer"]
        Peers["HPUWorker Peers<br/>Rank 1..N<br/>TCP Dynamic Ports"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN Bearer"]
        S3["Model Storage (S3)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
    end

    %% Ingress Flow
    Client -->|"HTTPS/8443<br/>TLS 1.3<br/>Bearer Token"| KRBAC
    KRBAC -->|"HTTP/8000<br/>localhost (plaintext)<br/>Pre-authenticated"| vLLM

    %% Internal Flow
    vLLM -->|"Plugin entry points"| Runner
    Runner -->|"In-process"| HPU
    Worker -->|"In-process"| HPU

    %% Distributed Flow
    Worker -->|"TCP/6379<br/>Plaintext"| Ray
    Ray -->|"TCP/Dynamic<br/>Plaintext"| Peers
    Worker -->|"RDMA/TCP<br/>Plaintext"| HCCL
    Worker -.->|"RDMA/TCP<br/>Plaintext (optional)"| NIXL

    %% Egress Flow
    Runner -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    Runner -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authproxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef distributed fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KRBAC authproxy
    class vLLM,Runner,Worker application
    class HPU hardware
    class Ray,HCCL,NIXL,Peers distributed
    class HF,S3 externalservice
