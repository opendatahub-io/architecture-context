graph LR
    GarakProvider["TrustyAI Garak<br/>LLS Provider"]

    %% Internal RHOAI Dependencies
    GarakProvider -->|"plugin host<br/>in-process"| LlamaStack["Llama Stack<br/>Distribution (LSD)"]
    GarakProvider -->|"KFP pipeline<br/>submission"| DSPA["Data Science Pipelines<br/>(KFP/DSPA)"]
    GarakProvider -->|"K8s Job +<br/>ConfigMap"| EvalHub["Eval-Hub Service"]
    GarakProvider -->|"ConfigMap read<br/>garak-provider-image"| TrustyAIOp["TrustyAI Service<br/>Operator"]

    %% Internal RHOAI - reverse dependencies (components that use this)
    EvalHub -->|"orchestrates"| GarakProvider
    LlamaStack -->|"loads plugin"| GarakProvider

    %% External Library Dependencies
    GarakProvider -->|"red-teaming engine<br/>subprocess"| Garak["garak (NVIDIA)<br/>0.14.1+rhaiv.7"]
    GarakProvider -->|"client API"| LlamaStackClient["llama-stack-client<br/>>=0.5.0"]
    GarakProvider -->|"pipeline SDK"| KFP["kfp + kfp-kubernetes<br/>>=2.14.6"]
    GarakProvider -->|"S3 client"| Boto3["boto3<br/>>=1.35.88"]
    GarakProvider -->|"adapter SDK"| EvalHubSDK["eval-hub-sdk<br/>0.1.4"]
    GarakProvider -->|"synthetic data gen"| SDGHub["sdg-hub<br/>>=0.8.8"]

    %% External Services
    GarakProvider -->|"probe target<br/>HTTPS/443"| TargetLLM["Target LLM<br/>(vLLM)"]
    GarakProvider -->|"SDG prompts<br/>HTTPS/443"| SDGModel["SDG Model<br/>Endpoint"]
    GarakProvider -->|"TAP + judge<br/>HTTPS/443"| JudgeModels["Judge/Attacker/<br/>Evaluator Models"]
    GarakProvider -->|"guardrail test<br/>HTTP/8321"| ShieldModels["Shield Models<br/>(Llama Guard)"]
    GarakProvider -->|"artifacts<br/>HTTPS/443"| S3["S3 Object<br/>Storage"]
    GarakProvider -->|"artifact bundles<br/>HTTPS/443"| OCI["OCI Registry"]
    GarakProvider -->|"metrics + artifacts<br/>HTTPS/443"| MLflow["MLflow"]
    LlamaStack -->|"state storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    GarakProvider -->|"secrets + config<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

