    end

    EvalHub -->|"K8s Job container"| Garak
    LLSOperator -->|"provider plugin"| Garak

    %% External Services
    subgraph ExtServices["External Services"]
        SDGEndpoint["SDG Model Endpoint"]
        JudgeEndpoint["Judge Model Endpoint"]
        AttackerEndpoint["Attacker Model Endpoint"]
        EvalEndpoint["Evaluator Model Endpoint"]
        OCIReg["OCI Registry"]
        MLflowSvc["MLflow"]
    end

    Garak -->|"synthetic data gen"| SDGEndpoint
    Garak -->|"intent judging"| JudgeEndpoint
    Garak -->|"adversarial prompts"| AttackerEndpoint
    Garak -->|"intent classification"| EvalEndpoint
    Garak -.->|"artifact persist"| OCIReg
    Garak -.->|"metrics save"| MLflowSvc

