graph LR
    Provider["TrustyAI Garak<br/>Provider"]

    %% Internal RHOAI Dependencies
    Provider -->|"plugin registration<br/>+ provider API"| LSD["Llama Stack<br/>Distribution (LSD)"]
    Provider -->|"pipeline submission<br/>HTTPS/443"| KFP["Data Science Pipelines<br/>(KFP/DSPA)"]
    Provider -->|"K8s Job adapter<br/>ConfigMap mount"| EvalHub["Eval-Hub Service"]
    Provider -->|"ConfigMap read<br/>garak-provider-image"| TrustyAIOp["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Frameworks)
    Provider -->|"subprocess spawn<br/>red-teaming engine"| Garak["NVIDIA Garak<br/>0.14.1+rhaiv.7"]
    Provider -->|"Python import<br/>SDG generation"| SDGHub["sdg-hub >=0.8.8"]
    Provider -->|"framework adapter<br/>SDK"| EvalHubSDK["eval-hub-sdk 0.1.4"]
    Provider -->|"pipeline SDK<br/>HTTPS/443"| KFPSDK["kfp >=2.14.6<br/>+ kfp-kubernetes"]

    %% Model Endpoints
    Provider -->|"OpenAI-compatible<br/>HTTPS/443<br/>Bearer Token"| TargetLLM["Target LLM<br/>(vLLM)"]
    Provider -->|"Safety API<br/>HTTP/8321"| ShieldModels["Shield Models<br/>(Llama Guard,<br/>Prompt Guard)"]
    Provider -->|"SDG generation<br/>HTTPS/443"| SDGModel["SDG Model<br/>Endpoint"]
    Provider -->|"TAP/judge/eval<br/>HTTPS/443"| JudgeModels["Judge/Attacker/<br/>Evaluator Models"]

    %% Storage & Tracking
    Provider -->|"artifact transfer<br/>HTTPS/443<br/>AWS IAM"| S3["S3 Object<br/>Storage"]
    Provider -->|"OCI push<br/>HTTPS/443"| OCI["OCI Registry"]
    Provider -->|"experiment tracking<br/>HTTPS/443"| MLflow["MLflow"]
    Provider -.->|"state storage<br/>(indirect via LSD)<br/>5432/TCP"| PostgreSQL["PostgreSQL"]

    %% Kubernetes
    Provider -->|"secrets + configmaps<br/>HTTPS/443<br/>mTLS (SA)"| K8sAPI["Kubernetes<br/>API Server"]

    %% Integration Points (other components using this)
    LSD -->|"dispatches eval<br/>requests"| Provider

    %% Python library dependencies
    Provider -.->|"HTTP client"| HTTPX["httpx"]
    Provider -.->|"S3 client"| Boto3["boto3 >=1.35.88"]
    Provider -.->|"config models"| Pydantic["pydantic"]
    Provider -.->|"data processing"| Pandas["pandas >=2.3.3"]
    Provider -.->|"HTML reports"| Jinja2["Jinja2 >=3.1.6"]
    Provider -.->|"API types"| LlamaStackAPI["llama-stack-api<br/>>=0.5.0"]

