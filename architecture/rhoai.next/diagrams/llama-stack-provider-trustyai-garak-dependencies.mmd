    %% Internal Platform Dependencies
    subgraph IntDeps["Internal Platform Dependencies (RHOAI)"]
        LLServer["Llama Stack Server<br/><i>8321/TCP HTTP</i>"]
        DSP["Data Science Pipelines<br/>(KFP)<br/><i>443/TCP HTTPS</i>"]
        S3MinIO["S3 / MinIO<br/><i>443/TCP HTTPS</i>"]
        vLLM["vLLM / Model Serving<br/><i>OpenAI-compatible</i>"]
        TrustyAIOp["TrustyAI Service<br/>Operator<br/><i>ConfigMap</i>"]
    end

    Garak -->|"provider registration<br/>Files/Safety/Shields/Inference API"| LLServer
    Garak -->|"pipeline submission<br/>run monitoring"| DSP
    Garak -->|"artifact storage<br/>(eval-hub mode)"| S3MinIO
    Garak -->|"target model inference<br/>vulnerability scans"| vLLM
    Garak -.->|"container image<br/>override config"| TrustyAIOp

    %% Integration Points (consumers of this component)
    subgraph Consumers["Components That Use This"]
        EvalHub["Eval-Hub<br/><i>Runs GarakAdapter<br/>in K8s jobs</i>"]
