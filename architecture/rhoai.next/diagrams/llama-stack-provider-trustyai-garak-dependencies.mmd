graph LR
    GarakAdapter["Garak Adapter<br/>(llama-stack-provider-<br/>trustyai-garak)"]

    %% Core External Dependencies
    GarakAdapter -->|"red-teaming engine"| Garak["garak<br/>0.15.0+rhaiv.2"]
    GarakAdapter -->|"FrameworkAdapter base"| EvalHubSDK["eval-hub-sdk<br/>>=0.1.7"]
    GarakAdapter -->|"pipeline SDK"| KFP["kfp<br/>>=2.14.6"]
    GarakAdapter -->|"K8s extensions"| KFPKube["kfp-kubernetes<br/>>=2.14.6"]
    GarakAdapter -->|"S3 client"| Boto3["boto3<br/>>=1.35.88"]
    GarakAdapter -.->|"SDG (optional)"| SDGHub["sdg-hub<br/>>=0.8.8"]
    GarakAdapter -->|"DataFrame ops"| Pandas["pandas<br/>>=2.3.3"]
    GarakAdapter -->|"HTML reports"| Jinja2["Jinja2<br/>>=3.1.6"]

    %% Transitive Dependencies
    Garak -.->|"multi-provider LLM API"| LiteLLM["litellm<br/>(transitive)"]
    Garak -.->|"HTTP client"| HTTPX["httpx<br/>(transitive)"]

    %% Internal Platform Dependencies
    GarakAdapter -->|"Job orchestration<br/>JobSpec + Callbacks"| EvalHub["eval-hub<br/>Service"]
    GarakAdapter -->|"pipeline execution<br/>(KFP mode)"| KFPServer["Kubeflow<br/>Pipelines"]
    GarakAdapter -->|"ConfigMap read<br/>garak-provider-image"| TrustyAIOp["trustyai-service-<br/>operator"]
    GarakAdapter -->|"experiment tracking<br/>metrics & artifacts"| MLflow["MLflow"]

    %% Integration Points (other components using this)
    EvalHub -->|"creates Job"| GarakAdapter

    %% External Services
    GarakAdapter -->|"model scanning<br/>HTTPS/443"| TargetModels["Model Inference<br/>Endpoints<br/>(OpenAI-compatible)"]
    GarakAdapter -->|"artifact storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]
    GarakAdapter -->|"artifact persistence<br/>HTTPS/443"| OCI["OCI Registry"]
    GarakAdapter -.->|"translation models<br/>HTTPS/443"| HF["HuggingFace Hub"]

    %% Styling
    style GarakAdapter fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External lib dependencies
    style Garak fill:#999,stroke:#333,color:#fff
    style EvalHubSDK fill:#999,stroke:#333,color:#fff
    style KFP fill:#999,stroke:#333,color:#fff
    style KFPKube fill:#999,stroke:#333,color:#fff
    style Boto3 fill:#999,stroke:#333,color:#fff
    style SDGHub fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style Jinja2 fill:#999,stroke:#333,color:#fff
    style LiteLLM fill:#ccc,stroke:#999
    style HTTPX fill:#ccc,stroke:#999

    %% Internal platform
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style KFPServer fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style TargetModels fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OCI fill:#f5a623,stroke:#333
    style HF fill:#f5a623,stroke:#333
