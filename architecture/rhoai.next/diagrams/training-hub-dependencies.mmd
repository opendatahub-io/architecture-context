graph LR
    TrainingHub["training-hub<br/>Python SDK<br/>v0.8.0"]

    %% Core Required Dependencies
    subgraph CoreDeps["Core Dependencies (Required)"]
        torch["torch >=2.6.0<br/><i>DDP/FSDP, model execution</i>"]
        transformers["transformers >=4.57.6<br/><i>Model loading, tokenization</i>"]
        peft["peft >=0.15<br/><i>LoRA config, adapters</i>"]
        accelerate["accelerate >=0.34.2<br/><i>Distributed training setup</i>"]
        datasets["datasets >=4.0.0<br/><i>Data loading/processing</i>"]
        pydantic["pydantic >=2.7.0<br/><i>Parameter validation</i>"]
        pandas["pandas >=2.2<br/><i>Metrics processing, EMA</i>"]
        matplotlib["matplotlib >=3.9<br/><i>Loss visualization</i>"]
        numpy["numpy >=1.26.4<br/><i>Numerical operations</i>"]
        numba["numba >=0.61.2<br/><i>JIT compilation</i>"]
        rich["rich >=14.1.0<br/><i>Console formatting</i>"]
        timm["timm >=1.0<br/><i>Vision model architectures</i>"]
    end

    %% Internal Platform Dependencies
    subgraph InternalDeps["Internal Platform Dependencies"]
        instructlab["instructlab-training >=0.14.0<br/><i>SFT backend</i>"]
        minitrainer["rhai-innovation-mini-trainer >=0.6.0<br/><i>OSFT backend</i>"]
    end

    %% Optional: CUDA extras
    subgraph CUDAExtras["Optional: [cuda]"]
        flashattn["flash-attn >=2.8<br/><i>Flash Attention 2</i>"]
        bitsandbytes["bitsandbytes >=0.47.0<br/><i>QLoRA quantization</i>"]
        liger["liger-kernel >=0.5.10<br/><i>Triton kernels</i>"]
        mamba["mamba-ssm >=2.2.5<br/><i>Mamba SSM support</i>"]
        einops["einops >=0.8<br/><i>Tensor operations</i>"]
    end

    %% Optional: LoRA extras
    subgraph LoRAExtras["Optional: [lora]"]
        unsloth["unsloth >=2026.1.1<br/><i>Optimized LoRA backend</i>"]
        trl["trl >=0.18.0<br/><i>SFTTrainer/SFTConfig</i>"]
        xformers["xformers >=0.0.33<br/><i>Memory-efficient attention</i>"]
    end

    %% Optional: GRPO extras
    subgraph GRPOExtras["Optional: [grpo]"]
        art["openpipe-art<br/><i>Single-GPU GRPO backend</i>"]
        verl["verl >=0.7<br/><i>Multi-GPU GRPO (FSDP)</i>"]
        litellm["litellm >=1.82.0,<1.82.7<br/><i>LLM inference abstraction</i><br/>⚠️ 1.82.7-8 compromised"]
    end

    %% External Services (Runtime)
    subgraph ExternalServices["External Services (Runtime)"]
        hfhub["HuggingFace Hub<br/><i>Model downloads</i><br/>443/TCP HTTPS"]
        wandb["WandB<br/><i>Experiment tracking</i><br/>443/TCP HTTPS"]
        mlflow["MLflow<br/><i>Experiment tracking</i><br/>HTTPS"]
    end

    %% Core connections
    TrainingHub -->|requires| torch
    TrainingHub -->|requires| transformers
    TrainingHub -->|requires| peft
    TrainingHub -->|requires| accelerate
    TrainingHub -->|requires| datasets
    TrainingHub -->|requires| pydantic
    TrainingHub -->|requires| pandas
    TrainingHub -->|requires| matplotlib
    TrainingHub -->|requires| numpy
    TrainingHub -->|requires| numba
    TrainingHub -->|requires| rich
    TrainingHub -->|requires| timm

    %% Internal platform
    TrainingHub -->|"SFT backend"| instructlab
    TrainingHub -->|"OSFT backend"| minitrainer

    %% Optional extras
    TrainingHub -.->|"[cuda]"| flashattn
    TrainingHub -.->|"[cuda]"| bitsandbytes
    TrainingHub -.->|"[cuda]"| liger
    TrainingHub -.->|"[cuda]"| mamba
    TrainingHub -.->|"[cuda]"| einops
    TrainingHub -.->|"[lora]"| unsloth
    TrainingHub -.->|"[lora]"| trl
    TrainingHub -.->|"[lora]"| xformers
    TrainingHub -.->|"[grpo]"| art
    TrainingHub -.->|"[grpo]"| verl
    TrainingHub -.->|"[grpo]"| litellm

    %% Runtime services
    TrainingHub -->|"model download"| hfhub
    TrainingHub -.->|"optional metrics"| wandb
    TrainingHub -.->|"optional metrics"| mlflow

