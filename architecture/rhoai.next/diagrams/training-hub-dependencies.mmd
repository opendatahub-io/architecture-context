    TH -.->|"experiment tracking<br/>(auto-detected)"| WandB["Weights & Biases"]
    TH -.->|"experiment tracking<br/>(auto-detected)"| MLflow["MLflow"]
    TH -.->|"experiment tracking<br/>(auto-detected)"| TensorBoard["TensorBoard"]

    %% External services (runtime)
    TH -->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Consumers
    DataScientist["Data Scientists /<br/>ML Engineers"] -->|"pip install<br/>training-hub"| TH
