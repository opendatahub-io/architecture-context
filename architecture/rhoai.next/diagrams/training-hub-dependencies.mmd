graph LR
    TrainingHub["training-hub<br/>Python SDK"]

    %% Core Required Dependencies
    subgraph CoreDeps["Core Dependencies (Required)"]
        direction TB
        PyTorch["PyTorch >=2.6.0"]
        Transformers["transformers >=4.57.6"]
        PEFT["peft >=0.15"]
        Datasets["datasets >=4.0.0"]
        Accelerate["accelerate >=0.34.2"]
        Pandas["pandas >=2.2"]
        Pydantic["pydantic >=2.7.0"]
        NumPy["numpy >=1.26.4"]
        Numba["numba >=0.61.2"]
    end

    %% Training Backend Libraries
    subgraph BackendDeps["Training Backends (Required)"]
        direction TB
        ILabTraining["instructlab-training >=0.14.0"]
        MiniTrainer["rhai-innovation-mini-trainer >=0.6.0"]
    end

    %% CUDA Optional Dependencies
    subgraph CUDADeps["CUDA Extras (Optional)"]
        direction TB
        FlashAttn["flash-attn >=2.8"]
        BitsAndBytes["bitsandbytes >=0.47.0"]
        LigerKernel["liger-kernel >=0.5.10"]
        MambaSSM["mamba-ssm >=2.2.5"]
        Kernels["kernels >=0.9.0"]
    end

    %% LoRA Optional Dependencies
    subgraph LoRADeps["LoRA Extras (Optional)"]
        direction TB
        Unsloth["unsloth >=2026.1.1"]
        TRL["trl >=0.18.0"]
        XFormers["xformers >=0.0.33.post1"]
    end

    %% GRPO Optional Dependencies
    subgraph GRPODeps["GRPO Extras (Optional)"]
        direction TB
        OpenPipeART["openpipe-art (latest)"]
        VeRL["verl >=0.7"]
        LiteLLM["litellm >=1.82.0,<1.82.7<br/>⚠️ Pinned: supply chain attack"]
    end

    %% Utility Dependencies
    subgraph UtilDeps["Utility Dependencies (Required)"]
        direction TB
        Matplotlib["matplotlib >=3.9"]
        Rich["rich >=14.1.0"]
        Aiohttp["aiohttp >=3.12"]
        Psutil["psutil >=6.0"]
        Timm["timm >=1.0"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        direction TB
        HFHub["HuggingFace Hub<br/>HTTPS/443"]
        WandB["Weights & Biases<br/>HTTPS/443 (Optional)"]
        MLflow["MLflow<br/>HTTP/HTTPS (Optional)"]
    end

    %% Internal Platform
    subgraph InternalPlatform["RHOAI Platform (Consumers)"]
        direction TB
        Consumer1["RHOAI Components<br/>(consume training-hub<br/>as Python dependency)"]
    end

    %% Connections - Required
    TrainingHub -->|core ML| PyTorch
    TrainingHub -->|model loading| Transformers
    TrainingHub -->|LoRA/QLoRA| PEFT
    TrainingHub -->|data loading| Datasets
    TrainingHub -->|distributed| Accelerate
    TrainingHub -->|data processing| Pandas
    TrainingHub -->|validation| Pydantic
    TrainingHub -->|numerics| NumPy
    TrainingHub -->|JIT compilation| Numba

    %% Connections - Backends
    TrainingHub -->|SFT training| ILabTraining
    TrainingHub -->|OSFT training| MiniTrainer

    %% Connections - LoRA extras
    TrainingHub -.->|optimized LoRA| Unsloth
    TrainingHub -.->|RL training| TRL
    TrainingHub -.->|memory-efficient attn| XFormers

    %% Connections - CUDA extras
    TrainingHub -.->|GPU acceleration| FlashAttn
    TrainingHub -.->|quantization| BitsAndBytes
    TrainingHub -.->|kernel optimization| LigerKernel
    TrainingHub -.->|SSM kernels| MambaSSM
    TrainingHub -.->|GPU kernels| Kernels

    %% Connections - GRPO extras
    TrainingHub -.->|single-GPU GRPO| OpenPipeART
    TrainingHub -.->|multi-GPU GRPO| VeRL
    TrainingHub -.->|LLM API| LiteLLM

    %% Connections - Utilities
    TrainingHub -->|visualization| Matplotlib
    TrainingHub -->|console output| Rich
    TrainingHub -->|async HTTP| Aiohttp
    TrainingHub -->|system monitoring| Psutil
    TrainingHub -->|vision models| Timm

    %% Connections - External Services
    TrainingHub -->|model downloads| HFHub
    TrainingHub -.->|experiment tracking| WandB
    TrainingHub -.->|experiment tracking| MLflow

    %% Connections - Platform
    Consumer1 -.->|pip install| TrainingHub

    %% Styling
    style TrainingHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CoreDeps fill:#d5e8d4,stroke:#82b366
    style BackendDeps fill:#dae8fc,stroke:#6c8ebf
    style CUDADeps fill:#e1d5e7,stroke:#9673a6
    style LoRADeps fill:#fff2cc,stroke:#d6b656
    style GRPODeps fill:#f8cecc,stroke:#b85450
    style UtilDeps fill:#d5e8d4,stroke:#82b366
    style ExternalSvc fill:#f5a623,stroke:#333
    style InternalPlatform fill:#7ed321,stroke:#333

    style LiteLLM fill:#ff6b6b,stroke:#c0392b,color:#fff
