graph LR
    %% ===== RHOAI COMPONENTS =====

    %% Gateway Layer
    AIGateway["ai-gateway-payload-<br/>processing<br/>(Go, ext-proc)"]
    GWExt["gateway-api-inference-<br/>extension<br/>(Go, EPP+BBR)"]
    BatchGW["batch-gateway<br/>(Go, OpenAI Batch API)"]

    %% Inference
    CaikitTGIS["caikit-tgis-serving<br/>(Python, ServingRuntime)"]
    GuardrailsDet["guardrails-detectors<br/>(Python, KServe)"]

    %% Orchestration
    GuardrailsOrch["fms-guardrails-<br/>orchestrator<br/>(Rust)"]
    ArgoWF["argo-workflows<br/>(Go, Controller)"]
    DSPipelines["data-science-<br/>pipelines<br/>(Go, 7 sub-comp)"]

    %% Operators
    CFOperator["codeflare-operator<br/>(Go, Operator)"]
    DSPOperator["data-science-pipelines-<br/>operator<br/>(Go, Operator)"]
    FeastOp["feast-operator<br/>(Go, Operator)"]

    %% Serving
    FeastSrv["feast-feature-server<br/>(Python)"]
    EvalHub["eval-hub<br/>(Go, REST+MCP)"]

    %% Training
    FMSTuning["fms-hf-tuning<br/>(Python, CUDA)"]

    %% Libraries
    Caikit["caikit<br/>(Python SDK)"]
    CaikitNLP["caikit-nlp<br/>(Python lib)"]
    CFSDK["codeflare-sdk<br/>(Python SDK)"]
    AI4RAG["ai4rag<br/>(Python lib)"]

    %% ===== EXTERNAL DEPENDENCIES =====

    %% Infrastructure
    K8sAPI["Kubernetes API"]
    Envoy["Envoy Proxy"]
    Istio["Istio Service Mesh"]
    KServe["KServe"]
    KubeRay["KubeRay"]
    Kueue["Kueue"]
    CertManager["cert-manager"]
    ServiceCA["OpenShift service-ca"]

    %% Data Stores
    PostgreSQL["PostgreSQL/MariaDB"]
    S3["S3/Minio"]
    Redis["Redis/Valkey"]
    OnlineStores["Online Stores<br/>(20+ backends)"]
    OfflineStores["Offline Stores<br/>(9+ backends)"]

    %% External Services
    HFHub["HuggingFace Hub"]
    ModelProviders["Model Providers<br/>(OpenAI, NeMo, etc.)"]
    NeMoGuardrails["NeMo Guardrails"]
    TGIS["TGIS Server"]
    vLLM["vLLM"]
    ExpTrackers["Experiment Trackers<br/>(Aim, MLflow, ClearML)"]

    %% ===== INTERNAL DEPENDENCIES =====

    %% Operator -> managed components
    DSPOperator -->|manages| DSPipelines
    FeastOp -->|manages| FeastSrv
    CFOperator -->|provisions| KubeRay

    %% Pipeline orchestration
    DSPipelines -->|orchestrates| ArgoWF

    %% Guardrails chain
    GuardrailsOrch -->|generation| CaikitTGIS
    GuardrailsOrch -->|screening| GuardrailsDet
    GuardrailsOrch -->|chunking/detection| TGIS

    %% Library dependencies
    CaikitTGIS -->|runtime| Caikit
    CaikitTGIS -->|NLP modules| CaikitNLP
    CaikitNLP -->|backend| TGIS

    %% Gateway -> infrastructure
    AIGateway -->|ext-proc| Envoy
    GWExt -->|ext-proc| Envoy

    %% ===== EXTERNAL DEPENDENCIES =====

    %% K8s API users
    CFOperator -->|RBAC| K8sAPI
    DSPOperator -->|RBAC| K8sAPI
    FeastOp -->|RBAC| K8sAPI
    ArgoWF -->|informers| K8sAPI
    EvalHub -->|TokenReview/SAR| K8sAPI
    CFSDK -.->|client| K8sAPI

    %% KServe dependencies
    CaikitTGIS -->|ServingRuntime| KServe
    GuardrailsDet -->|InferenceService| KServe

    %% Service mesh
    CaikitTGIS -->|mTLS| Istio

    %% Kueue integration
    CFOperator -->|queue mgmt| Kueue

    %% TLS
    BatchGW -.->|TLS certs| CertManager
    DSPOperator -->|TLS| ServiceCA

    %% Database dependencies
    DSPipelines -->|metadata| PostgreSQL
    BatchGW -->|batch jobs| PostgreSQL
    EvalHub -->|evaluations| PostgreSQL
    BatchGW -->|job queue| Redis

    %% Object storage
    ArgoWF -->|artifacts| S3
    DSPipelines -->|artifacts| S3
    BatchGW -->|input/output| S3

    %% Feature store backends
    FeastSrv -->|features| OnlineStores
    FeastSrv -->|features| OfflineStores

    %% External services
    AIGateway -->|routing| ModelProviders
    AIGateway -->|guardrails| NeMoGuardrails
    FMSTuning -->|models| HFHub
    CaikitNLP -->|models| HFHub
    GuardrailsDet -->|models| HFHub
    GuardrailsDet -->|LLM Judge| vLLM
    FMSTuning -->|metrics| ExpTrackers

