graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        Client["Inference Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        KubeAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        subgraph OperatorPod["ogx-k8s-operator Pod<br/>SA: controller-manager<br/>FIPS: strictfipsruntime"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TokenReview + SAR"]
            Manager["controller-manager<br/>8080/TCP metrics (localhost)<br/>8081/TCP healthz (HTTP)<br/>9443/TCP webhook (HTTPS)"]
        end

        MetricsSvc["metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS, Bearer Token"]
        WebhookSvc["webhook-service<br/>ClusterIP 443→9443<br/>HTTPS, TLS serving cert"]
    end

    subgraph UserNS["USER NAMESPACE (per OGXServer)"]
        direction TB

        subgraph OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid"]
            OGXServer["OGX Server Container<br/>Port: 8321/TCP (default)<br/>Config: config.yaml"]
        end

        InstanceSvc["{instance}-service<br/>ClusterIP {port}/TCP<br/>HTTP or HTTPS (configurable)"]
        InstanceIng["{instance}-ingress<br/>80/TCP HTTP<br/>(optional external access)"]
        NetPol["NetworkPolicy<br/>Auto kube-dns egress<br/>Same-NS + operator-NS peers"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+, API Key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+, API Key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+, AWS IAM"]
        VertexAI["Google VertexAI<br/>443/TCP HTTPS<br/>TLS 1.2+, SA JSON"]
        Watsonx["IBM Watsonx<br/>443/TCP HTTPS<br/>TLS 1.2+, API Key"]
        vLLM["vLLM Endpoints<br/>Configurable port<br/>HTTP/HTTPS"]
        VectorDB["PGVector / Milvus / Qdrant<br/>Configurable TCP<br/>Password / Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+, AWS Creds"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    subgraph CertProv["TLS PROVISIONING"]
        CertMgr["cert-manager /<br/>OpenShift service-ca<br/>Auto-rotate: Yes"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig"| KubeAPI

    %% Control Plane → Operator
    KubeAPI -->|"Watch events<br/>HTTPS/443<br/>SA token"| Manager
    KubeAPI -->|"Webhook call<br/>HTTPS/9443<br/>TLS serving cert<br/>FailurePolicy: Fail"| WebhookSvc

    %% Operator → Control Plane
    Manager -->|"CRUD resources<br/>HTTPS/443<br/>SA token"| KubeAPI

    %% Operator → OGX Pods
    Manager -->|"Health check<br/>HTTP/8321<br/>/v1/providers, /v1/version"| OGXServer

    %% Client → OGX Server
    Client -->|"Inference request<br/>HTTP(S)/{port}<br/>App-level auth"| InstanceSvc
    InstanceSvc --> OGXServer
    Client -.->|"External access<br/>HTTP/80"| InstanceIng
    InstanceIng --> InstanceSvc

    %% OGX Server → External Services
    OGXServer -->|"HTTPS/443<br/>API Key"| OpenAI
    OGXServer -->|"HTTPS/443<br/>API Key"| Azure
    OGXServer -->|"HTTPS/443<br/>AWS IAM"| Bedrock
    OGXServer -->|"HTTPS/443<br/>SA JSON"| VertexAI
    OGXServer -->|"HTTPS/443<br/>API Key"| Watsonx
    OGXServer -->|"HTTP(S)<br/>Configurable"| vLLM
    OGXServer -->|"TCP<br/>Password/Token"| VectorDB
    OGXServer -->|"HTTPS/443<br/>AWS Creds"| S3

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>Bearer Token<br/>TokenReview"| MetricsSvc
    MetricsSvc --> RBACProxy
    RBACProxy --> Manager

    %% Cert provisioning
    CertMgr -.->|"Provisions TLS cert"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef certprov fill:#e8e8e8,stroke:#666,stroke-width:1px

    class User,Client external
    class KubeAPI controlplane
    class RBACProxy,Manager,MetricsSvc,WebhookSvc operator
    class OGXServer,InstanceSvc,InstanceIng,NetPol userns
    class OpenAI,Azure,Bedrock,VertexAI,Watsonx,vLLM,VectorDB,S3 extsvc
    class Prometheus monitoring
    class CertMgr certprov
