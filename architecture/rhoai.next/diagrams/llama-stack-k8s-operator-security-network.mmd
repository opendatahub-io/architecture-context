graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (when exposeRoute=true)"]
        IngressCtrl["OpenShift Ingress Controller<br/>80/TCP → 8321/TCP<br/>HTTP (no TLS)<br/>No Auth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["llama-stack-k8s-operator<br/>SA: controller-manager<br/>Probes: /healthz :8081, /readyz :8081"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Bearer Token Auth"]
        end

        subgraph NS_Instance["Namespace: {instance-namespace}"]
            LlamaServer["Llama Stack Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid<br/>CA: /etc/ssl/certs/ca-bundle/"]
            InstanceSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP, No Auth"]
            NP["NetworkPolicy<br/>Allow: same-ns + operator-ns"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>(ServiceMonitor)"]
    end

    %% External flows
    Client -->|"HTTP/80<br/>No Encryption<br/>No Auth"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>No Encryption<br/>No Auth"| InstanceSvc

    %% Operator to managed server
    Operator -->|"HTTP/8321<br/>No Encryption<br/>No Auth<br/>GET /v1/health,providers,version"| InstanceSvc
    InstanceSvc --> LlamaServer
    NP -.->|"protects"| LlamaServer

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>CR CRUD, leader election"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef networkpolicy fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class IngressCtrl ingress
    class Operator,LlamaServer,InstanceSvc,MetricsSvc clusterinternal
    class K8sAPI controlplane
    class Prometheus monitoring
    class NP networkpolicy
