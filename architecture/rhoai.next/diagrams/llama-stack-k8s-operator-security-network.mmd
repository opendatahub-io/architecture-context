graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Cluster Edge)"]
        IngressCtrl["OpenShift Ingress Controller<br/>80/TCP → 8321/TCP<br/>HTTP, No TLS"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Enforced)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["llama-stack-k8s-operator<br/>SA: controller-manager<br/>Ports: 8081 (health), 8443 (metrics)"]
            MetricsSvc["controller-manager-metrics-service<br/>8443/TCP HTTPS<br/>Bearer Token + kube-rbac-proxy"]
        end

        subgraph NS_Instance["Namespace: {user-namespace}"]
            LlamaStack["Llama Stack Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid<br/>8321/TCP HTTP"]
            InstanceSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP, No Auth"]
            NetPol["NetworkPolicy<br/>Allow: same-ns + operator-ns"]
            CABundle["{instance}-ca-bundle<br/>ConfigMap<br/>mounted at /etc/ssl/certs/"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
        Prometheus["Prometheus<br/>(optional)"]
    end

    subgraph ConfigSources["CONFIG SOURCES"]
        ODHBundle["odh-trusted-ca-bundle<br/>ConfigMap"]
        UserCABundle["User CA Bundle<br/>ConfigMap"]
        OperatorConfig["llama-stack-operator-config<br/>ConfigMap"]
    end

    %% External access flow
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth<br/>(when exposeRoute=true)"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>No TLS<br/>No Auth"| InstanceSvc

    %% Operator to managed server
    Operator -->|"HTTP/8321<br/>No TLS, No Auth<br/>/v1/health, /v1/providers,<br/>/v1/version"| LlamaStack

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>CR CRUD, leader election"| K8sAPI

    %% Prometheus scraping
    Prometheus -.->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc

    %% Config reads
    Operator -.->|"directGet<br/>via K8s API"| ODHBundle
    Operator -.->|"directGet<br/>via K8s API"| UserCABundle
    Operator -.->|"directGet<br/>via K8s API"| OperatorConfig

    %% CA bundle flow
    ODHBundle -.->|"aggregated into"| CABundle
    UserCABundle -.->|"aggregated into"| CABundle
    CABundle -.->|"volume mount"| LlamaStack

    %% Service routing
    InstanceSvc -->|"8321/TCP"| LlamaStack

    %% NetworkPolicy enforcement
    NetPol -.->|"protects"| LlamaStack

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class Operator,LlamaStack,InstanceSvc,MetricsSvc,CABundle internal
    class K8sAPI,Prometheus platform
    class ODHBundle,UserCABundle,OperatorConfig config
    class NetPol security
