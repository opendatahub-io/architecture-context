graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        Client["External Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client certs / Bearer tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        Webhook["Validating Webhook<br/>9443/TCP HTTPS<br/>TLS (serving cert)<br/>K8s API server mTLS<br/>FailurePolicy: Fail"]

        subgraph OperatorPod["Operator Pod"]
            Operator["OGX K8s Operator<br/>SA: controller-manager"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token auth<br/>TokenReview + SAR"]
            Probes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
            Metrics["Metrics<br/>127.0.0.1:8080/TCP<br/>/metrics"]
        end

        RBACProxy -->|proxies| Metrics
    end

    subgraph InstanceNS["INSTANCE NAMESPACE (per OGXServer)"]
        direction TB

        OGXPod["OGX Server Pod<br/>SA: {name}-sa<br/>SCC: anyuid<br/>Port: 8321/TCP (default)<br/>HTTP or HTTPS (configurable)"]
        InstanceSvc["Instance Service<br/>ClusterIP<br/>{port}/TCP"]
        InstanceIngress["Ingress (optional)<br/>80/TCP HTTP<br/>externalAccess.enabled"]
        InstanceNP["NetworkPolicy<br/>kube-dns egress auto-inject<br/>same-ns + operator-ns peers"]
    end

    subgraph ExternalProviders["EXTERNAL SERVICES (from OGX server)"]
        vLLM["vLLM<br/>Configurable<br/>HTTP/HTTPS"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        VertexAI["Google VertexAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA JSON"]
        Watsonx["IBM Watsonx<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        VectorDBs["PGVector / Milvus / Qdrant<br/>Configurable TCP<br/>Password / Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
    end

    subgraph Monitoring["MONITORING & TLS"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        CertProvider["cert-manager /<br/>OpenShift service-ca"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig"| K8sAPI
    Client -->|"HTTP or HTTPS/{port}<br/>Application-level auth"| InstanceIngress

    %% Control plane flows
    K8sAPI -->|"HTTPS/9443<br/>TLS (serving cert)<br/>mTLS"| Webhook
    K8sAPI -->|"Watch events<br/>HTTPS/443<br/>SA token"| Operator
    Operator -->|"CRUD resources<br/>HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator to instance
    Operator -->|"Health check<br/>HTTP/8321<br/>No auth"| OGXPod

    %% Instance networking
    InstanceIngress -->|"forwards"| InstanceSvc
    InstanceSvc -->|"routes to"| OGXPod

    %% OGX server to external providers
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| OpenAI
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Azure
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| Bedrock
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA JSON"| VertexAI
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| Watsonx
    OGXPod -->|"HTTP/HTTPS<br/>Configurable"| vLLM
    OGXPod -->|"TCP<br/>Password/Token"| VectorDBs
    OGXPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| RBACProxy
    CertProvider -->|"provisions TLS<br/>webhook-cert"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef instancens fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Client external
    class K8sAPI controlplane
    class Operator,Webhook,RBACProxy,Probes,Metrics operatorns
    class OGXPod,InstanceSvc,InstanceIngress,InstanceNP instancens
    class vLLM,OpenAI,Azure,Bedrock,VertexAI,Watsonx,VectorDBs,S3 externalservice
    class Prometheus,CertProvider monitoring
