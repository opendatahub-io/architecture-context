graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Optional)"]
        IngressCtrl["Ingress Controller<br/>80/TCP → 8321/TCP<br/>HTTP<br/>No encryption<br/>Only when exposeRoute=true"]
    end

    subgraph Cluster["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["Llama Stack Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS TLS<br/>Auth: Bearer Token"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            LLSDPod["Llama Stack Server Pod<br/>SA: {instance-name}-sa<br/>SCC: anyuid (FSGroup 1001)<br/>Port: 8321/TCP HTTP"]
            Service["{instance-name}-service<br/>ClusterIP 8321/TCP<br/>HTTP, No encryption"]
            NetPol["NetworkPolicy<br/>(when enableNetworkPolicy=true)<br/>Ingress: same-ns, operator-ns,<br/>allowed namespaces, router-ns"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]

        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    %% External flows
    Client -->|"HTTP/80<br/>No encryption<br/>No auth"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>No encryption<br/>No auth"| Service

    %% Internal flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRUD resources"| K8sAPI
    Operator -->|"HTTP/8321<br/>No encryption<br/>No auth<br/>/v1/health, /v1/providers,<br/>/v1/version"| LLSDPod
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>Metrics scrape"| RBACProxy
    Service -->|"HTTP/8321<br/>No encryption"| LLSDPod
    NetPol -.->|"controls ingress to"| Service

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef infra fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class IngressCtrl ingress
    class Operator,RBACProxy operator
    class LLSDPod,Service managed
    class K8sAPI,Prometheus infra
    class NetPol netpol
