graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Optional"]
        IngressCtrl["Ingress Controller<br/>80/TCP → 8321/TCP<br/>HTTP, No Encryption<br/>Only when exposeRoute=true"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Enforced)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            OperatorPod["Llama Stack K8s Operator<br/>SA: controller-manager<br/>Probes: 8081/TCP HTTP"]
            MetricsProxy["kube-rbac-proxy<br/>8443/TCP HTTPS TLS<br/>Auth: Bearer Token"]
        end

        subgraph NS_Instance["Namespace: {instance-namespace}"]
            ServerPod["Llama Stack Server Pod<br/>SA: {instance-name}-sa<br/>8321/TCP HTTP<br/>FSGroup: 1001 (anyuid SCC)<br/>CA: /etc/ssl/certs/ca-bundle/ca-bundle.crt"]
            InstanceSvc["{instance-name}-service<br/>ClusterIP 8321/TCP<br/>HTTP, No Encryption"]
            CABundleCM["{instance}-ca-bundle<br/>ConfigMap (operator-managed)"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph PlatformIntegration["PLATFORM INTEGRATION"]
        ODHCABundle["odh-trusted-ca-bundle<br/>ConfigMap (auto-detected)"]
        OperatorConfig["llama-stack-operator-config<br/>ConfigMap (feature flags)"]
        Prometheus["Prometheus<br/>ServiceMonitor"]
        SCC["OpenShift SCC<br/>anyuid"]
    end

    %% External flows
    Client -->|"HTTP/80<br/>No Encryption<br/>No Auth"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>No Encryption<br/>NetworkPolicy"| InstanceSvc

    %% Operator flows
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    OperatorPod -->|"HTTP/8321<br/>No Encryption<br/>Status probes"| ServerPod

    %% Service flow
    InstanceSvc -->|"HTTP/8321"| ServerPod

    %% Platform integration
    ODHCABundle -.->|"auto-detected"| OperatorPod
    OperatorConfig -.->|"feature flags"| OperatorPod
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsProxy
    SCC -.->|"RoleBinding<br/>anyuid"| ServerPod
    CABundleCM -.->|"mounted at<br/>/etc/ssl/certs/"| ServerPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef apiserver fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class OperatorPod,MetricsProxy,ServerPod,InstanceSvc,CABundleCM cluster
    class ODHCABundle,OperatorConfig,Prometheus,SCC platform
    class K8sAPI apiserver
