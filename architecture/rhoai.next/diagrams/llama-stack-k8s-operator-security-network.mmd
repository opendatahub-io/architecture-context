graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS"]
        IngressCtrl["OpenShift Ingress Controller<br/>80/TCP → 8321/TCP<br/>HTTP, No TLS<br/>No Auth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_Instance["Namespace: instance-namespace"]
            LlamaServer["Llama Stack Server Pod<br/>SA: instance-sa<br/>SCC: anyuid<br/>Port: 8321/TCP HTTP"]
            InstanceSvc["instance-service<br/>ClusterIP 8321/TCP"]
            NetPol["NetworkPolicy<br/>Allow: same-ns + operator-ns"]
            PVC["PVC: /app/.llama<br/>(optional, RWO)"]
            CABundleCM["CA Bundle ConfigMap<br/>/etc/ssl/certs/ca-bundle/"]
        end

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["llama-stack-k8s-operator<br/>SA: controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8080/TCP"]
            MetricsSvc["metrics-service<br/>ClusterIP 8443/TCP<br/>HTTPS, Bearer Token<br/>kube-rbac-proxy"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
        ODHCACfg["odh-trusted-ca-bundle<br/>ConfigMap<br/>(auto-detected)"]
        SCCSystem["OpenShift SCC<br/>system:openshift:scc:anyuid"]
        Prometheus["Prometheus<br/>(optional)<br/>ServiceMonitor"]
    end

    %% External flows
    Client -->|HTTP/80<br/>No TLS<br/>No Auth<br/>when exposeRoute=true| IngressCtrl
    IngressCtrl -->|HTTP/8321<br/>No TLS<br/>No Auth| InstanceSvc

    %% Operator flows
    Operator -->|HTTP/8321<br/>No TLS<br/>No Auth<br/>/v1/health, /v1/providers,<br/>/v1/version| LlamaServer
    Operator -->|HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CR reconciliation, CRUD| K8sAPI
    Operator -->|K8s API<br/>DirectClient<br/>uncached read| ODHCACfg

    %% Metrics
    Prometheus -->|HTTPS/8443<br/>TLS<br/>Bearer Token| MetricsSvc

    %% SCC binding
    SCCSystem -.->|"RoleBinding<br/>instance-rb"| LlamaServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef managed fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef security fill:#f5a623,stroke:#333,stroke-width:1px

    class Client external
    class IngressCtrl ingress
    class LlamaServer,InstanceSvc,PVC,CABundleCM managed
    class NetPol security
    class Operator,MetricsSvc operator
    class K8sAPI,ODHCACfg,SCCSystem,Prometheus platform
