graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist / Admin"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>AuthN: Certs / Tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        Webhook["Validating Webhook<br/>9443/TCP HTTPS<br/>TLS (serving cert)<br/>FailurePolicy: Fail"]

        subgraph OperatorPod["Controller Manager Pod"]
            Operator["OGX K8s Operator<br/>SA: controller-manager<br/>Leader: Lease 54e06e98.ogx.io"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]
            Metrics["Metrics<br/>8080/TCP HTTP<br/>127.0.0.1 only"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token Auth<br/>TokenReview + SAR"]
        end

        Metrics --> RBACProxy
    end

    subgraph UserNS["USER NAMESPACE (per OGXServer)"]
        direction TB

        OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid"]
        OGXService["ClusterIP Service<br/>{port}/TCP (default 8321)<br/>HTTP or HTTPS<br/>App-level Auth"]
        OGXIngress["Ingress (optional)<br/>80/TCP HTTP<br/>External Access"]
        NetPol["NetworkPolicy<br/>Auto: kube-dns egress<br/>Peers: same-ns + operator-ns"]

        OGXService --> OGXPod
        OGXIngress --> OGXService
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        subgraph InferenceProviders["Inference Providers (443/TCP HTTPS TLS 1.2+)"]
            OpenAI["OpenAI API<br/>Auth: API key"]
            Azure["Azure OpenAI<br/>Auth: API key"]
            Bedrock["AWS Bedrock<br/>Auth: IAM creds"]
            VertexAI["Google VertexAI<br/>Auth: SA JSON"]
            Watsonx["IBM Watsonx<br/>Auth: API key"]
        end

        vLLM["vLLM Endpoints<br/>Configurable port<br/>HTTP/HTTPS"]

        subgraph VectorDBs["Vector Databases (Configurable TCP)"]
            PGVector["PGVector<br/>Auth: Password"]
            Milvus["Milvus<br/>Auth: Token"]
            Qdrant["Qdrant<br/>Auth: Token"]
        end

        S3["S3 Storage<br/>443/TCP HTTPS<br/>Auth: AWS creds"]
        Registry["OGX Distribution Registries<br/>443/TCP HTTPS<br/>docker.io / quay.io"]
    end

    subgraph CertServices["CERTIFICATE SERVICES"]
        CertMgr["cert-manager /<br/>OpenShift service-ca<br/>Auto-rotate webhook TLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor discovery"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>kubeconfig auth"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>mTLS"| Webhook
    K8sAPI -->|"Watch events<br/>HTTPS TLS 1.2+<br/>SA token"| Operator
    Operator -->|"CRUD resources<br/>HTTPS/443<br/>SA token"| K8sAPI
    Operator -->|"Health/version check<br/>HTTP/8321"| OGXPod
    RBACProxy -->|"HTTPS/8443<br/>Bearer Token"| Prometheus
    CertMgr -->|"TLS cert<br/>provisioning"| Webhook

    OGXPod -->|"HTTPS/443<br/>API key / IAM"| InferenceProviders
    OGXPod -->|"HTTP/HTTPS<br/>Configurable"| vLLM
    OGXPod -->|"TCP<br/>Password/Token"| VectorDBs
    OGXPod -->|"HTTPS/443<br/>AWS creds"| S3
    Operator -.->|"Image pull<br/>HTTPS/443"| Registry

    %% External access
    Client -->|"HTTP/80<br/>via Ingress"| OGXIngress

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorms fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef certservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class K8sAPI controlplane
    class Webhook,Operator,HealthProbes,Metrics,RBACProxy operatorms
    class OGXPod,OGXService,OGXIngress,NetPol userns
    class OpenAI,Azure,Bedrock,VertexAI,Watsonx,vLLM,PGVector,Milvus,Qdrant,S3,Registry externalservice
    class CertMgr certservice
    class Prometheus monitoring
