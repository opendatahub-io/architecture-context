graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) — Managed by KServe Controller"]
        IngressLayer["KServe Ingress Layer<br/>(kube-rbac-proxy / Istio / OCP Route)<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ termination<br/>AuthN: Platform-dependent"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod Network)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            subgraph ServerPod["autogluon-server Pod<br/>Image: odh-kserve-autogluon-server-rhel9<br/>Base: UBI9 (FIPS OpenSSL)<br/>User: non-root"]
                RESTPort["FastAPI REST<br/>8080/TCP HTTP<br/>No TLS, No Auth"]
                GRPCPort["gRPC Server<br/>8081/TCP HTTP/2<br/>No TLS, No Auth"]
                Metrics["/metrics endpoint<br/>8080/TCP HTTP"]
            end
        end

        KServeRouter["KServe Router<br/>(inference traffic routing)"]
        Prometheus["Prometheus<br/>(metrics scraping)"]
    end

    subgraph ExternalServices["EGRESS — External Services"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        GCS["GCS / Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA / SAS token"]
    end

    %% Inbound flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer / OAuth"| IngressLayer
    IngressLayer -->|"HTTP/8080 (REST)<br/>Plaintext<br/>No Auth (delegated)"| RESTPort
    IngressLayer -->|"gRPC/8081<br/>Plaintext<br/>No Auth (delegated)"| GRPCPort

    %% Internal flows
    KServeRouter -->|"HTTP/8080, gRPC/8081<br/>Plaintext (or mTLS via sidecar)<br/>No Auth at server"| ServerPod
    Prometheus -->|"HTTP/8080<br/>GET /metrics<br/>Plaintext, No Auth"| Metrics

    %% Egress flows
    ServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM / storage-config"| S3
    ServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HuggingFace
    ServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA / SAS token"| GCS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef serverpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class IngressLayer ingress
    class RESTPort,GRPCPort,Metrics serverpod
    class KServeRouter clusterinternal
    class Prometheus monitoring
    class S3,HuggingFace,GCS externalservice
