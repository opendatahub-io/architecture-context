graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Router"]
        Prom["Prometheus"]
    end

    subgraph IngressLayer["KSERVE INGRESS LAYER (Trust Boundary)"]
        Ingress["KServe Ingress<br/>Istio Gateway / kube-rbac-proxy / OCP Route<br/>TLS 1.2+ termination<br/>AuthN: Bearer / mTLS<br/>AuthZ: AuthorizationPolicy / RBAC proxy"]
    end

    subgraph Pod["POD: AutoGluon Server<br/>Namespace: {user-namespace}<br/>SA: configured by InferenceService<br/>Image: odh-kserve-autogluon-server-rhel9<br/>Base: UBI9 (FIPS OpenSSL)"]
        direction TB

        REST["REST Server (FastAPI/Uvicorn)<br/>0.0.0.0:8080/TCP<br/>HTTP plaintext<br/>v1: /v1/models/{n}:predict, :explain<br/>v2: /v2/models/{n}/infer<br/>Health: /v2/health/live, /ready<br/>Metrics: /metrics"]

        GRPC["gRPC Server<br/>0.0.0.0:8081/TCP<br/>gRPC/HTTP2 plaintext<br/>Open Inference Protocol"]

        ModelEngine["AutoGluon Predictor<br/>TabularPredictor / TimeSeriesPredictor<br/>(in-process, no network)"]

        StorageClient["kserve-storage<br/>Storage.download()<br/>Model download at startup"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM / access key"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token (optional)"]
        GCS["GCS / Azure Blob<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: SA / SAS token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / mTLS"| Ingress

    %% Ingress to Pod (plaintext within mesh)
    Ingress -->|"HTTP/8080 plaintext<br/>Auth already validated"| REST
    Ingress -->|"gRPC/8081 plaintext<br/>Auth already validated"| GRPC

    %% Prometheus scrape
    Prom -->|"HTTP/8080 plaintext<br/>GET /metrics<br/>No auth"| REST

    %% Internal pod processing
    REST --> ModelEngine
    GRPC --> ModelEngine

    %% Egress to storage
    StorageClient -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (storage-config)"| S3
    StorageClient -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    StorageClient -->|"HTTPS/443<br/>TLS 1.2+<br/>SA / SAS token"| GCS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Ingress ingress
    class REST,GRPC,ModelEngine,StorageClient pod
    class S3,HF,GCS externalservice
    class Prom monitoring
