graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Router"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        IngressLayer["KServe Ingress Layer<br/>kube-rbac-proxy / Istio / Route<br/>TLS 1.2+ Termination<br/>AuthN/AuthZ: Platform-configured"]
    end

    subgraph Pod["POD: AutoGluon Server"]
        direction TB

        subgraph REST["REST Server (FastAPI)"]
            REST_Port["Port 8080/TCP<br/>HTTP (plaintext)<br/>No Auth at server"]
        end

        subgraph GRPC["gRPC Server"]
            GRPC_Port["Port 8081/TCP<br/>gRPC/HTTP2 (plaintext)<br/>No Auth at server"]
        end

        subgraph ModelStorage["Storage Client"]
            StorageDownload["kserve-storage<br/>Storage.download()"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        GCS["GCS / Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA / SAS token"]
    end

    subgraph Monitoring["MONITORING"]
        Prom["Prometheus<br/>(inbound scrape)"]
    end

    %% Client to ingress
    Client -->|"HTTP or gRPC<br/>TLS terminated at ingress<br/>Auth at ingress layer"| IngressLayer

    %% Ingress to pod
    IngressLayer -->|"HTTP/8080<br/>Plaintext (pod-internal)<br/>No Auth (validated at ingress)"| REST_Port
    IngressLayer -->|"gRPC/8081<br/>Plaintext (pod-internal)<br/>No Auth (validated at ingress)"| GRPC_Port

    %% Model storage egress
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM credentials"| S3
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+<br/>SA / SAS token"| GCS

    %% Prometheus scrape
    Prom -->|"HTTP/8080<br/>GET /metrics<br/>No Auth"| REST_Port

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class IngressLayer ingress
    class REST_Port,GRPC_Port,StorageDownload pod
    class S3,HF,GCS externalservice
    class Prom monitoring
