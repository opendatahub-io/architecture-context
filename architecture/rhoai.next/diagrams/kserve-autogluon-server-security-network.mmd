graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["KServe Gateway / Istio Gateway<br/>443/TCP &rarr; internal<br/>TLS 1.2+ termination<br/>JWT validation (delegated)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph PodBoundary["Pod: AutoGluon InferenceService"]
            IstioSidecar["Istio Sidecar (Envoy)<br/>15006/TCP inbound<br/>mTLS STRICT<br/>SPIFFE identity"]
            AutoGluonContainer["AutoGluon Server Container<br/>UID: 1001 (non-root)<br/>8080/TCP HTTP (v1+v2 REST)<br/>8081/TCP gRPC (v2 OIP)<br/>No K8s API access<br/>Read-only rootfs"]
        end

        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        GCS["GCS Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA credentials"]
        GenericURI["HTTP/HTTPS URI<br/>443 or 80/TCP<br/>TLS 1.2+ or plaintext<br/>Bearer Token (optional)"]
        HuggingFace["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token or mTLS"| Gateway

    %% Ingress to Service Mesh
    Gateway -->|"HTTP<br/>mTLS STRICT<br/>Service Identity (SPIFFE)"| IstioSidecar

    %% Sidecar to Container (same pod)
    IstioSidecar -->|"HTTP/8080 + gRPC/8081<br/>plaintext (localhost)<br/>No auth (same pod)"| AutoGluonContainer

    %% Egress flows
    AutoGluonContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AutoGluonContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    AutoGluonContainer -->|"HTTPS/443 or HTTP/80<br/>TLS 1.2+ or plaintext"| GenericURI
    AutoGluonContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HuggingFace

    %% Prometheus scrape
    Prometheus -->|"HTTP/8080<br/>plaintext (within mesh)<br/>Metrics scrape"| AutoGluonContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef container fill:#b3d9ff,stroke:#4a86c8,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e6d5f7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class IstioSidecar servicemesh
    class AutoGluonContainer container
    class S3,GCS,GenericURI,HuggingFace externalservice
    class Prometheus monitoring
