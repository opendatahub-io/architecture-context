graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PodBoundary["INFERENCESERVICE POD"]
        direction TB

        subgraph SidecarZone["Auth Sidecar (TLS Termination)"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.3<br/>Bearer Token Auth"]
        end

        subgraph AppZone["Application Container (UID 1001, non-root)"]
            AGServer["autogluonserver<br/>8080/TCP HTTP (plaintext)<br/>8081/TCP gRPC (plaintext)<br/>No K8s API access<br/>No RBAC roles"]
        end
    end

    subgraph ClusterInternal["INTERNAL CLUSTER (Control Plane)"]
        KServeCtrl["KServe Controller<br/>Manages InferenceService CR"]
        CSR["ClusterServingRuntime<br/>modelFormat: autogluon"]
        Prometheus["Prometheus<br/>Metrics Scrape"]
    end

    subgraph CloudStorage["EXTERNAL SERVICES (Egress - Startup Only)"]
        S3["S3 Storage<br/>*.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>GCP SA"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Azure Identity/SAS"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token (optional)"]
    end

    %% External to Pod
    Client -->|"HTTPS/8443<br/>TLS 1.3<br/>Bearer Token"| KRBP

    %% Sidecar to App (same pod, localhost)
    KRBP -->|"HTTP/8080<br/>plaintext (localhost)<br/>pre-authenticated"| AGServer

    %% Control Plane
    KServeCtrl -.->|"manages lifecycle<br/>InferenceService CR"| PodBoundary
    CSR -.->|"defines image + ports"| PodBoundary
    Prometheus -->|"HTTP/8080<br/>/metrics scrape<br/>internal network"| AGServer

    %% Egress (startup only)
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Identity"| Azure
    AGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KRBP sidecar
    class AGServer app
    class KServeCtrl,CSR,Prometheus controlplane
    class S3,GCS,Azure,HFHub externalservice
