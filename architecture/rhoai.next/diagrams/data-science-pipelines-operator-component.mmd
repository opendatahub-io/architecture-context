    style ArgoController fill:#7ed321,stroke:#333
    style PersistenceAgent fill:#7ed321,stroke:#333
    style ScheduledWorkflow fill:#7ed321,stroke:#333
    style MLMDgRPC fill:#7ed321,stroke:#333
    style MLMDEnvoy fill:#9b59b6,stroke:#333,color:#fff
    style MariaDB fill:#e74c3c,stroke:#333,color:#fff
    style MinIO fill:#e74c3c,stroke:#333,color:#fff
