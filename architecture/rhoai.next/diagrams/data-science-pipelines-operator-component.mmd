graph TB
    subgraph DSPO["Data Science Pipelines Operator"]
        Controller["DSPO Controller Manager<br/>(Go Operator)"]
        Webhook["Pipeline Version Webhook<br/>8443/TCP HTTPS"]
        Controller -->|deploys & reconciles| ManagedComponents
        Controller -->|registers| Webhook
    end

    subgraph ManagedComponents["Managed Components (per DSPA instance)"]
        APIServer["DS Pipelines API Server<br/>8888/TCP REST, 8887/TCP gRPC<br/>8443/TCP HTTPS (kube-rbac-proxy)"]
        PersistenceAgent["Persistence Agent<br/>Syncs Argo → KFP"]
        ScheduledWF["Scheduled Workflow Controller<br/>Cron-triggered runs"]
        ArgoController["Argo Workflows Controller<br/>Pipeline step orchestration"]
        MLMD["MLMD gRPC Server<br/>8080/TCP gRPC"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>8443/TCP HTTPS (kube-rbac-proxy)"]
    end

    subgraph OptionalComponents["Optional Components (per DSPA)"]
        MariaDB["MariaDB<br/>3306/TCP MySQL"]
        MinIO["MinIO<br/>9000/TCP S3"]
    end

    %% CRDs
    User[User / Dashboard] -->|creates| DSPACR["DataSciencePipelinesApplication CR"]
    DSPACR -->|watched by| Controller

    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"] -->|validated by| Webhook
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"] -->|validated/mutated by| Webhook

    %% Runtime flow
    User -->|pipeline operations| APIServer
    APIServer -->|creates Workflow CRs| ArgoController
    ArgoController -->|executes| PipelinePod["Pipeline Step Pods"]
    PipelinePod -->|artifact lineage| MLMD
    MLMD -->|proxied via| MLMDEnvoy
    PersistenceAgent -->|syncs state| APIServer

    %% Storage
    APIServer -->|metadata| MariaDB
    APIServer -->|artifacts| MinIO
    PipelinePod -->|artifacts| MinIO

    %% Health checks
    Controller -->|health check| MariaDB
    Controller -->|health check| MinIO

    %% External
    Controller -->|fetches bundles| OCIRegistry["OCI Registry"]
    Route["OpenShift Route<br/>443/TCP HTTPS Reencrypt"] -->|proxies| APIServer
    RouteMLMD["OpenShift Route<br/>443/TCP HTTPS Reencrypt"] -->|proxies| MLMDEnvoy

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#50c878,stroke:#333,color:#fff
    style PersistenceAgent fill:#50c878,stroke:#333,color:#fff
    style ScheduledWF fill:#50c878,stroke:#333,color:#fff
    style ArgoController fill:#50c878,stroke:#333,color:#fff
    style MLMD fill:#50c878,stroke:#333,color:#fff
    style MLMDEnvoy fill:#50c878,stroke:#333,color:#fff
    style MariaDB fill:#f5a623,stroke:#333,color:#fff
    style MinIO fill:#f5a623,stroke:#333,color:#fff
    style DSPACR fill:#e8c44a,stroke:#333
    style PipelineCR fill:#e8c44a,stroke:#333
    style PipelineVersionCR fill:#e8c44a,stroke:#333
    style Route fill:#999,stroke:#333,color:#fff
    style RouteMLMD fill:#999,stroke:#333,color:#fff
    style OCIRegistry fill:#999,stroke:#333,color:#fff
