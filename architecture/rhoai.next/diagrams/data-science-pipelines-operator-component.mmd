graph TB
    subgraph DSPO["DSPO Controller Manager"]
        Controller["DSPO Controller<br/>(controller-runtime)"]
        HealthCheck["Health Check<br/>8081/TCP"]
        Metrics["Metrics<br/>8080/TCP"]
        ManagedPipelines["Managed Pipelines<br/>Fetcher"]
    end

    subgraph DSPStack["DSP Stack (per DSPA instance)"]
        subgraph APILayer["API Layer"]
            APIServer["DS Pipeline<br/>API Server<br/>8888/TCP REST<br/>8887/TCP gRPC"]
            KubeRBACProxy1["kube-rbac-proxy<br/>8443/TCP HTTPS"]
            Webhook["PipelineVersion<br/>Webhook<br/>8443/TCP"]
        end

        subgraph ExecutionLayer["Execution Layer"]
            ArgoController["Argo Workflow<br/>Controller"]
            PersistenceAgent["Persistence<br/>Agent"]
            ScheduledWF["Scheduled Workflow<br/>Controller"]
        end

        subgraph MetadataLayer["Metadata Layer"]
            MLMDGRPC["MLMD GRPC<br/>Server<br/>8080/TCP"]
            MLMDEnvoy["MLMD Envoy<br/>Proxy<br/>9090/TCP"]
            KubeRBACProxy2["kube-rbac-proxy<br/>8443/TCP HTTPS"]
        end

        subgraph StorageLayer["Storage Layer"]
            MariaDB["MariaDB<br/>3306/TCP"]
            MinIO["MinIO<br/>9000/TCP"]
        end
    end

    %% User interactions
    User["User / Dashboard"] -->|"HTTPS 443<br/>via Route"| KubeRBACProxy1
    KubeRBACProxy1 -->|"SubjectAccessReview"| APIServer
    User -->|"HTTPS 443<br/>via Route"| KubeRBACProxy2
    KubeRBACProxy2 -->|proxy| MLMDEnvoy

    %% CRD flow
    DSPACR["DSPA CR"] -->|"watched by"| Controller
    Controller -->|"reconciles<br/>(template-driven)"| DSPStack

    %% Internal flows
    APIServer -->|"creates Workflow CRs"| ArgoController
    ArgoController -->|"creates pipeline<br/>step pods"| PipelinePods["Pipeline Step Pods"]
    PersistenceAgent -->|"syncs state<br/>8888/TCP"| APIServer
    ScheduledWF -->|"triggers runs"| APIServer
    PipelinePods -->|"gRPC 8080"| MLMDGRPC
    MLMDEnvoy -->|"gRPC 8080"| MLMDGRPC

    %% Storage flows
    APIServer -->|"MySQL 3306"| MariaDB
    MLMDGRPC -->|"MySQL 3306"| MariaDB
    PipelinePods -->|"S3 9000"| MinIO

    %% Managed pipelines
    ManagedPipelines -->|"fetch OCI manifests"| OCIRegistry["OCI Registry"]
    ManagedPipelines -->|"inject init container"| APIServer

    %% Webhook
    K8sAPI["Kubernetes API"] -->|"admission review"| Webhook

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style HealthCheck fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style ManagedPipelines fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#7ed321,stroke:#333,color:#fff
    style ArgoController fill:#7ed321,stroke:#333,color:#fff
    style PersistenceAgent fill:#7ed321,stroke:#333,color:#fff
    style ScheduledWF fill:#7ed321,stroke:#333,color:#fff
    style MLMDGRPC fill:#9b59b6,stroke:#333,color:#fff
    style MLMDEnvoy fill:#9b59b6,stroke:#333,color:#fff
    style MariaDB fill:#e67e22,stroke:#333,color:#fff
    style MinIO fill:#e67e22,stroke:#333,color:#fff
    style KubeRBACProxy1 fill:#e74c3c,stroke:#333,color:#fff
    style KubeRBACProxy2 fill:#e74c3c,stroke:#333,color:#fff
    style Webhook fill:#e74c3c,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333,color:#fff
    style User fill:#f9f9f9,stroke:#999
    style PipelinePods fill:#95a5a6,stroke:#333,color:#fff
    style OCIRegistry fill:#95a5a6,stroke:#333
    style K8sAPI fill:#95a5a6,stroke:#333
