graph TB
    subgraph DSPO["Data Science Pipelines Operator"]
        Controller["DSPO Controller Manager<br/>(controller-runtime)"]
    end

    subgraph ManagedStack["Managed DSP Stack (per DSPA CR)"]
        direction TB

        subgraph APILayer["API & Access Layer"]
            APIServer["DS Pipeline API Server<br/>KFP v2 REST/gRPC<br/>8888/TCP, 8887/TCP"]
            RBACProxy1["kube-rbac-proxy<br/>(API Server sidecar)<br/>8443/TCP"]
            Webhook["DS Pipelines Webhook<br/>(conditional)<br/>8443/TCP"]
        end

        subgraph ExecutionLayer["Pipeline Execution"]
            WorkflowCtrl["Argo Workflow Controller<br/>Pipeline orchestration"]
            PersistenceAgent["Persistence Agent<br/>Syncs workflow status"]
            ScheduledWF["Scheduled Workflow<br/>Cron-scheduled runs"]
        end

        subgraph MetadataLayer["Metadata & Lineage"]
            MLMDgRPC["MLMD gRPC Server<br/>8080/TCP"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP"]
            RBACProxy2["kube-rbac-proxy<br/>(MLMD sidecar)<br/>8443/TCP"]
        end

        subgraph InfraLayer["Backing Infrastructure (optional)"]
            MariaDB["MariaDB<br/>3306/TCP<br/>(or external DB)"]
            Minio["Minio<br/>9000/TCP<br/>(or external S3)"]
        end
    end

    %% User interaction
    User[User / Dashboard] -->|"creates"| DSPACR["DSPA CR"]
    DSPACR -->|"watched by"| Controller

    %% Controller deploys everything
    Controller -->|"deploys via<br/>manifestival templates"| APIServer
    Controller -->|"deploys"| WorkflowCtrl
    Controller -->|"deploys"| PersistenceAgent
    Controller -->|"deploys"| ScheduledWF
    Controller -->|"deploys"| MLMDgRPC
    Controller -->|"deploys"| MLMDEnvoy
    Controller -->|"deploys"| MariaDB
    Controller -->|"deploys"| Minio
    Controller -->|"deploys (conditional)"| Webhook

    %% Internal data flows
    RBACProxy1 -->|"proxies"| APIServer
    APIServer -->|"stores metadata"| MariaDB
    APIServer -->|"stores artifacts"| Minio
    PersistenceAgent -->|"syncs status"| APIServer
    MLMDEnvoy -->|"fronts"| MLMDgRPC
    RBACProxy2 -->|"proxies"| MLMDEnvoy
    MLMDgRPC -->|"stores lineage"| MariaDB

    %% Pipeline execution
    PipelinePods["Pipeline Step Pods<br/>(Argo executor)"] -->|"reports metadata"| MLMDgRPC
    PipelinePods -->|"reports status"| APIServer
    WorkflowCtrl -->|"orchestrates"| PipelinePods

    %% External dependencies
    Controller -->|"depends on"| ServiceCA["OpenShift service-ca"]
    Controller -->|"creates"| Routes["OpenShift Routes"]
    Controller -->|"watches"| CABundle["odh-trusted-ca-bundle"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style APIServer fill:#50b5e9,stroke:#333,color:#fff
    style WorkflowCtrl fill:#50b5e9,stroke:#333,color:#fff
    style PersistenceAgent fill:#50b5e9,stroke:#333,color:#fff
    style ScheduledWF fill:#50b5e9,stroke:#333,color:#fff
    style MLMDgRPC fill:#50b5e9,stroke:#333,color:#fff
    style MLMDEnvoy fill:#50b5e9,stroke:#333,color:#fff
    style MariaDB fill:#9b59b6,stroke:#333,color:#fff
    style Minio fill:#9b59b6,stroke:#333,color:#fff
    style RBACProxy1 fill:#e67e22,stroke:#333,color:#fff
    style RBACProxy2 fill:#e67e22,stroke:#333,color:#fff
    style Webhook fill:#e67e22,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333
    style PipelinePods fill:#27ae60,stroke:#333,color:#fff
    style ServiceCA fill:#bdc3c7,stroke:#333
    style Routes fill:#bdc3c7,stroke:#333
    style CABundle fill:#bdc3c7,stroke:#333
    style User fill:#ecf0f1,stroke:#333
