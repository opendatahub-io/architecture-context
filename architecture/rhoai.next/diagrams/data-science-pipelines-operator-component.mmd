graph TB
    subgraph DSPO["Data Science Pipelines Operator"]
        Controller["DSPO Controller Manager<br/>(controller-runtime)<br/>Port: 8080 metrics, 8081 probes"]
    end

    subgraph DSPStack["DSP Stack (per DSPA instance)"]
        direction TB
        APIServer["DS Pipeline API Server<br/>KFP v2 REST + gRPC<br/>Ports: 8888/HTTP, 8887/gRPC, 8443/HTTPS"]
        PersistenceAgent["Persistence Agent<br/>Syncs Argo → KFP DB"]
        ScheduledWorkflow["Scheduled Workflow<br/>Cron-scheduled runs"]
        WorkflowController["Argo Workflow Controller<br/>Pipeline execution"]
        MLMD["MLMD gRPC Server<br/>Port: 8080/gRPC"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>+ kube-rbac-proxy<br/>Port: 9090/HTTP, 8443/HTTPS"]
        Webhook["DS Pipelines Webhook<br/>(conditional)<br/>Port: 8443/HTTPS"]
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar on API Server)"]
    end

    subgraph Infrastructure["Infrastructure (managed or external)"]
        MariaDB["MariaDB 10.5<br/>Port: 3306/TCP<br/>(optional - can use external DB)"]
        Minio["Minio<br/>Port: 9000/TCP<br/>(optional - can use external S3)"]
    end

    %% User interaction
    User[User / Dashboard] -->|"creates"| DSPACR["DSPA CR<br/>(DataSciencePipelinesApplication)"]
    DSPACR -->|"watched by"| Controller

    %% Controller deploys everything
    Controller -->|"deploys via manifestival"| APIServer
    Controller -->|"deploys"| PersistenceAgent
    Controller -->|"deploys"| ScheduledWorkflow
    Controller -->|"deploys"| WorkflowController
    Controller -->|"deploys"| MLMD
    Controller -->|"deploys"| MLMDEnvoy
    Controller -->|"deploys (conditional)"| Webhook
    Controller -->|"deploys"| MariaDB
    Controller -->|"deploys"| Minio

    %% Internal flows
    KubeRBACProxy -->|"proxies auth"| APIServer
    APIServer -->|"stores metadata"| MariaDB
    APIServer -->|"stores artifacts"| Minio
    PersistenceAgent -->|"syncs status"| APIServer
    WorkflowController -->|"creates Workflows"| K8sAPI["Kubernetes API"]
    MLMD -->|"stores lineage"| MariaDB
    MLMDEnvoy -->|"proxies gRPC"| MLMD
    Webhook -->|"validates"| PipelineVersionCR["PipelineVersion CR"]

    %% External dependencies
    Controller -->|"depends on"| ServiceCA["OpenShift service-ca"]
    Controller -->|"creates"| Routes["OpenShift Routes"]
    Controller -->|"publishes metrics"| Prometheus["Prometheus"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style ScheduledWorkflow fill:#4a90e2,stroke:#333,color:#fff
    style WorkflowController fill:#4a90e2,stroke:#333,color:#fff
    style MLMD fill:#4a90e2,stroke:#333,color:#fff
    style MLMDEnvoy fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e8744f,stroke:#333,color:#fff
    style MariaDB fill:#7ed321,stroke:#333,color:#fff
    style Minio fill:#7ed321,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333,color:#fff
    style PipelineVersionCR fill:#f5a623,stroke:#333,color:#fff
    style ServiceCA fill:#e8e8e8,stroke:#333
    style Routes fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
