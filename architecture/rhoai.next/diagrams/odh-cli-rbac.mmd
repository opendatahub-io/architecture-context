graph TD
    subgraph UserContext["User's Kubeconfig Context"]
        User["Platform Admin<br/>(kubeconfig credentials)"]
        AuthMethods["Authentication Methods"]
        Bearer["Bearer Token"]
        ClientCert["Client Certificate"]
        OIDC["OIDC Token"]
        AuthMethods --- Bearer
        AuthMethods --- ClientCert
        AuthMethods --- OIDC
        User --> AuthMethods
    end

    subgraph ReadAccess["READ Access Required (lint, get, deps, backup, components list)"]
        direction TB

        subgraph ODHPlatform["ODH/RHOAI Platform CRDs"]
            DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/><i>get, list</i>"]
            DSCI["dscinitialization.opendatahub.io<br/>dscinitializations<br/><i>get, list</i>"]
            ComponentCRs["components.platform.opendatahub.io<br/>* (13 component CRs)<br/><i>get, list</i>"]
        end

        subgraph OLMResources["OLM Resources"]
            Subs["operators.coreos.com<br/>subscriptions, csvs, installplans<br/><i>get, list</i>"]
            Pkgs["packages.operators.coreos.com<br/>packagemanifests<br/><i>get, list</i>"]
        end

        subgraph WorkloadCRDs["Workload CRDs"]
            Notebooks["kubeflow.org<br/>notebooks, pytorchjobs<br/><i>get, list</i>"]
            KServe["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>llminferenceservices<br/><i>get, list</i>"]
            RayRes["ray.io<br/>rayclusters, rayjobs<br/><i>get, list</i>"]
            KueueRes["kueue.x-k8s.io<br/>clusterqueues, localqueues<br/><i>get, list</i>"]
            DSPRes["datasciencepipelinesapplications<br/>.opendatahub.io/dspa<br/><i>get, list</i>"]
        end

        subgraph DashboardCRDs["Dashboard CRDs"]
            AccProf["dashboard.opendatahub.io<br/>acceleratorprofiles, hardwareprofiles<br/><i>get, list</i>"]
            InfraHW["infrastructure.opendatahub.io<br/>hardwareprofiles<br/><i>get, list</i>"]
        end

        subgraph AdditionalCRDs["Additional CRDs"]
            TrustyAI["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/><i>get, list</i>"]
            CodeFlare["workload.codeflare.dev<br/>appwrappers<br/><i>get, list</i>"]
            LlamaStack["llamastack.io<br/>llamastackdistributions<br/><i>get, list</i>"]
            KuadrantRes["kuadrant.io/kuadrants<br/>operator.authorino.kuadrant.io/authorinos<br/><i>get, list</i>"]
        end

        subgraph OpenShiftAPIs["OpenShift APIs"]
            CV["config.openshift.io<br/>clusterversions<br/><i>get</i>"]
            IS["image.openshift.io<br/>imagestreams, imagestreamtags<br/><i>get, list</i>"]
        end

        subgraph CoreAPIs["Core Kubernetes APIs"]
            CoreRes["core ('')<br/>configmaps, secrets, pvcs,<br/>namespaces, pods, services<br/><i>get, list</i>"]
            AppsRes["apps<br/>deployments, statefulsets,<br/>daemonsets, replicasets<br/><i>get, list</i>"]
            CRDRes["apiextensions.k8s.io<br/>customresourcedefinitions<br/><i>get, list</i>"]
        end
    end

    subgraph WriteAccess["WRITE Access Required (migrate, components enable/disable)"]
        direction LR
        DSCPatch["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/><i>patch</i>"]
        OLMCreate["operators.coreos.com<br/>subscriptions<br/><i>create</i>"]
    end

    AuthMethods -->|"kube-apiserver<br/>RBAC enforcement"| ReadAccess
    AuthMethods -->|"kube-apiserver<br/>RBAC enforcement"| WriteAccess

    style UserContext fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style User fill:#4a90e2,stroke:#1565c0,color:#fff

    style ReadAccess fill:#e8f5e9,stroke:#2e7d32
    style ODHPlatform fill:#c8e6c9,stroke:#388e3c
    style OLMResources fill:#c8e6c9,stroke:#388e3c
    style WorkloadCRDs fill:#c8e6c9,stroke:#388e3c
    style DashboardCRDs fill:#c8e6c9,stroke:#388e3c
    style AdditionalCRDs fill:#c8e6c9,stroke:#388e3c
    style OpenShiftAPIs fill:#c8e6c9,stroke:#388e3c
    style CoreAPIs fill:#c8e6c9,stroke:#388e3c

    style WriteAccess fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    style DSCPatch fill:#ef9a9a,stroke:#c62828
    style OLMCreate fill:#ef9a9a,stroke:#c62828
