    style R_NS fill:#c8e6c9,stroke:#2e7d32
    style R_Routes fill:#c8e6c9,stroke:#2e7d32
    style R_CV fill:#c8e6c9,stroke:#2e7d32

    style W_IS fill:#ffcdd2,stroke:#c62828
    style W_SR fill:#ffcdd2,stroke:#c62828
    style W_NB fill:#ffcdd2,stroke:#c62828
    style W_DSPA fill:#ffcdd2,stroke:#c62828
    style W_RC fill:#ffcdd2,stroke:#c62828
    style W_CM fill:#ffcdd2,stroke:#c62828
    style W_Role fill:#ffcdd2,stroke:#c62828
    style W_DSC fill:#ffcdd2,stroke:#c62828
    style W_Sub fill:#ffcdd2,stroke:#c62828
    style W_IP fill:#ffcdd2,stroke:#c62828
    style W_SA fill:#fff3e0,stroke:#e65100
    style W_RB fill:#fff3e0,stroke:#e65100

    style CatalogAllowlist fill:#e8eaf6,stroke:#283593,stroke-width:2px
