graph TD
    subgraph UserAuth["Authentication (User-Provided)"]
        Kubeconfig["kubeconfig<br/>(Bearer Token / Client Cert / OIDC)"]
    end

    subgraph CLITool["odh-cli (No RBAC Installed)"]
        direction TB
        CLI["kubectl-odh<br/>Uses user's existing credentials<br/>No ClusterRoles installed<br/>No RoleBindings installed"]
    end

    subgraph ReadOnlyOps["READ Operations (lint, get, deps, components, backup)"]
        direction TB

        subgraph ODHPlatform["ODH/RHOAI Platform"]
            DSC_R["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list"]
            DSCI_R["dscinitialization.opendatahub.io<br/>dscinitializations<br/>get, list"]
            CompPlatform_R["components.platform.opendatahub.io<br/>* (all)<br/>get, list"]
            DashAccel_R["dashboard.opendatahub.io<br/>acceleratorprofiles, hardwareprofiles<br/>get, list"]
            InfraHW_R["infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get, list"]
        end

        subgraph Workloads["Workload Resources"]
            Notebooks_R["kubeflow.org<br/>notebooks, pytorchjobs<br/>get, list"]
            KServe_R["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>llminferenceservices<br/>get, list"]
            DSPA_R["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications<br/>get, list"]
            Ray_R["ray.io<br/>rayclusters, rayjobs<br/>get, list"]
            Kueue_R["kueue.x-k8s.io<br/>clusterqueues, localqueues<br/>get, list"]
            Trustyai_R["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>get, list"]
        end

        subgraph OLMRead["OLM (Read)"]
            OLMSub_R["operators.coreos.com<br/>subscriptions, csvs, installplans<br/>get, list"]
            OLMPkg_R["packages.operators.coreos.com<br/>packagemanifests<br/>get, list"]
        end

        subgraph CoreRead["Core & Extensions (Read)"]
            Core_R["core (&quot;&quot;)<br/>configmaps, secrets, pvcs, namespaces<br/>get, list"]
            Apps_R["apps<br/>deployments<br/>get, list"]
            CRDs_R["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get, list"]
            OCP_R["config.openshift.io<br/>clusterversions<br/>get"]
        end
    end

    subgraph WriteOps["WRITE Operations (migrate command ONLY)"]
        direction TB
        DSC_W["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>patch"]
        OLMSub_W["operators.coreos.com<br/>subscriptions, installplans<br/>create"]
        Core_W["core (&quot;&quot;)<br/>configmaps<br/>patch (annotation)"]
    end

    %% Connections
    Kubeconfig -->|"authenticates"| CLI
    CLI -->|"read-only commands"| ReadOnlyOps
    CLI -->|"migrate command"| WriteOps

    %% Styling
    style UserAuth fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CLITool fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style Kubeconfig fill:#bbdefb,stroke:#1565c0
    style CLI fill:#ffe0b2,stroke:#e65100

    style ODHPlatform fill:#c8e6c9,stroke:#388e3c
    style Workloads fill:#c8e6c9,stroke:#388e3c
