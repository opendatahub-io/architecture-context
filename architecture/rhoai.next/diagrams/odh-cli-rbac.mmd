graph TD
    subgraph "User Authentication"
        User["Platform Administrator<br/>(kubeconfig credentials)"]
    end

    subgraph "Authentication Methods"
        Bearer["Bearer Token"]
        ClientCert["Client Certificate"]
        OIDC["OIDC"]
    end

    subgraph "Enforcement"
        RBAC["kube-apiserver RBAC<br/>(user's existing permissions)"]
    end

    subgraph "Required Permissions: ODH/RHOAI Platform"
        DSC_Perm["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list, patch"]
        DSCI_Perm["dscinitialization.opendatahub.io<br/>dscinitializations<br/>get, list"]
        Comp_Perm["components.platform.opendatahub.io<br/>* (all resources)<br/>get, list"]
        DashAccel_Perm["dashboard.opendatahub.io<br/>acceleratorprofiles, hardwareprofiles<br/>get, list"]
        InfraHW_Perm["infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get, list"]
    end

    subgraph "Required Permissions: Workload CRDs"
        KF_Perm["kubeflow.org<br/>notebooks, pytorchjobs<br/>get, list"]
        KServe_Perm["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>llminferenceservices<br/>get, list"]
        DSPA_Perm["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications<br/>get, list"]
        Ray_Perm["ray.io<br/>rayclusters, rayjobs<br/>get, list"]
        Kueue_Perm["kueue.x-k8s.io<br/>clusterqueues, localqueues<br/>get, list"]
        Trusty_Perm["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>get, list"]
    end

    subgraph "Required Permissions: OLM"
        OLM_Perm["operators.coreos.com<br/>subscriptions, clusterserviceversions,<br/>installplans<br/>get, list, create"]
        Pkg_Perm["packages.operators.coreos.com<br/>packagemanifests<br/>get, list"]
    end

    subgraph "Required Permissions: Core Kubernetes"
        Core_Perm["core (empty API group)<br/>configmaps, secrets,<br/>persistentvolumeclaims, namespaces<br/>get, list"]
        Apps_Perm["apps<br/>deployments<br/>get, list"]
        CRD_Perm["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get, list"]
        OCP_Perm["config.openshift.io<br/>clusterversions<br/>get"]
    end

    User -->|authenticates via| Bearer
    User -->|authenticates via| ClientCert
    User -->|authenticates via| OIDC
    Bearer --> RBAC
    ClientCert --> RBAC
    OIDC --> RBAC

    RBAC -->|"READ + PATCH<br/>(migrate only)"| DSC_Perm
    RBAC -->|READ| DSCI_Perm
    RBAC -->|READ| Comp_Perm
    RBAC -->|READ| DashAccel_Perm
    RBAC -->|READ| InfraHW_Perm
    RBAC -->|READ| KF_Perm
    RBAC -->|READ| KServe_Perm
    RBAC -->|READ| DSPA_Perm
    RBAC -->|READ| Ray_Perm
    RBAC -->|READ| Kueue_Perm
    RBAC -->|READ| Trusty_Perm
    RBAC -->|"READ + CREATE<br/>(migrate only)"| OLM_Perm
    RBAC -->|READ| Pkg_Perm
    RBAC -->|READ| Core_Perm
    RBAC -->|READ| Apps_Perm
    RBAC -->|READ| CRD_Perm
    RBAC -->|READ| OCP_Perm

