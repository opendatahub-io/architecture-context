graph TD
    subgraph UserAuth["User Authentication"]
        Kubeconfig["User Kubeconfig<br/>(~/.kube/config)<br/>Bearer Token / Client Cert / OIDC"]
    end

    subgraph CLITool["odh-cli (kubectl-odh)"]
        CLI["kubectl-odh<br/>client-go QPS=50 Burst=100"]
    end

    subgraph RequiredPermissions["Required Permissions (No Installed RBAC)"]
        direction TB

        subgraph PlatformAPIs["ODH/RHOAI Platform APIs"]
            DSC_Perm["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list, patch"]
            DSCI_Perm["dscinitialization.opendatahub.io<br/>dscinitializations<br/>get, list"]
            Comp_Perm["components.platform.opendatahub.io<br/>*<br/>get, list"]
            AccProf_Perm["dashboard.opendatahub.io<br/>acceleratorprofiles, hardwareprofiles<br/>get, list"]
            InfraProf_Perm["infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get, list"]
        end

        subgraph WorkloadAPIs["Workload APIs"]
            NB_Perm["kubeflow.org<br/>notebooks, pytorchjobs<br/>get, list"]
            KServe_Perm["serving.kserve.io<br/>inferenceservices, servingruntimes,<br/>llminferenceservices<br/>get, list"]
            DSPA_Perm["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>get, list"]
            Ray_Perm["ray.io<br/>rayclusters, rayjobs<br/>get, list"]
            Kueue_Perm["kueue.x-k8s.io<br/>clusterqueues, localqueues<br/>get, list"]
            Trusty_Perm["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>get, list"]
        end

        subgraph OLMAPIs["OLM APIs"]
            OLM_Perm["operators.coreos.com<br/>subscriptions, clusterserviceversions,<br/>installplans<br/>get, list, create"]
            Pkg_Perm["packages.operators.coreos.com<br/>packagemanifests<br/>get, list"]
        end

        subgraph CoreAPIs["Core / OpenShift APIs"]
            Core_Perm["core ('')<br/>configmaps, secrets,<br/>persistentvolumeclaims, namespaces<br/>get, list"]
            Apps_Perm["apps<br/>deployments<br/>get, list"]
            APIExt_Perm["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get, list"]
            OCP_Perm["config.openshift.io<br/>clusterversions<br/>get"]
        end
    end

    subgraph Operations["CLI Operations → Required Verbs"]
        LintOp["lint<br/>Requires: GET, LIST<br/>(read-only across all APIs)"]
        BackupOp["backup<br/>Requires: GET, LIST<br/>(read workloads + deps)"]
        MigrateOp["migrate<br/>Requires: GET, LIST, PATCH, CREATE<br/>(DSC patch, OLM Subscription create)"]
        GetOp["get / deps / components<br/>Requires: GET, LIST<br/>(read-only)"]
    end

    %% Auth flow
    Kubeconfig -->|"provides credentials"| CLI

    %% CLI to operations
    CLI --> LintOp
    CLI --> BackupOp
    CLI --> MigrateOp
    CLI --> GetOp

    %% Operations to permissions
    LintOp -->|"read-only"| PlatformAPIs
    LintOp -->|"read-only"| WorkloadAPIs
    LintOp -->|"read-only"| OLMAPIs
    LintOp -->|"read-only"| CoreAPIs

    BackupOp -->|"read-only"| WorkloadAPIs
    BackupOp -->|"read-only"| CoreAPIs

    MigrateOp -->|"read + patch"| DSC_Perm
    MigrateOp -->|"read + create"| OLM_Perm
    MigrateOp -->|"read-only"| Kueue_Perm

    GetOp -->|"read-only"| PlatformAPIs
    GetOp -->|"read-only"| WorkloadAPIs

    %% Styling
    style Kubeconfig fill:#4a90e2,stroke:#333,color:#fff
    style CLI fill:#1565c0,stroke:#333,color:#fff,stroke-width:3px

    style DSC_Perm fill:#f5a623,stroke:#333,color:#fff
    style DSCI_Perm fill:#f5a623,stroke:#333,color:#fff
    style Comp_Perm fill:#f5a623,stroke:#333,color:#fff
    style AccProf_Perm fill:#f5a623,stroke:#333,color:#fff
    style InfraProf_Perm fill:#f5a623,stroke:#333,color:#fff

    style NB_Perm fill:#7ed321,stroke:#333,color:#fff
    style KServe_Perm fill:#7ed321,stroke:#333,color:#fff
    style DSPA_Perm fill:#7ed321,stroke:#333,color:#fff
    style Ray_Perm fill:#7ed321,stroke:#333,color:#fff
    style Kueue_Perm fill:#7ed321,stroke:#333,color:#fff
    style Trusty_Perm fill:#7ed321,stroke:#333,color:#fff

    style OLM_Perm fill:#e65100,stroke:#333,color:#fff
    style Pkg_Perm fill:#e65100,stroke:#333,color:#fff

    style Core_Perm fill:#9e9e9e,stroke:#333,color:#fff
    style Apps_Perm fill:#9e9e9e,stroke:#333,color:#fff
    style APIExt_Perm fill:#9e9e9e,stroke:#333,color:#fff
    style OCP_Perm fill:#9e9e9e,stroke:#333,color:#fff

    style LintOp fill:#c8e6c9,stroke:#2e7d32
    style BackupOp fill:#fff9c4,stroke:#f9a825
    style MigrateOp fill:#f3e5f5,stroke:#7b1fa2
    style GetOp fill:#e3f2fd,stroke:#1565c0
