graph TD
    subgraph "Authentication Source"
        Kubeconfig["kubeconfig File<br/>(Bearer Token / Client Cert)"]
    end

    subgraph "CLI Permission Model"
        CLI["kubectl-odh<br/>(inherits user permissions)"]
        SSAR["SelfSubjectAccessReview<br/>Pre-validates RBAC<br/>before migration execution"]
    end

    subgraph "Required Read Permissions (lint/status/get/events/logs)"
        direction TB

        subgraph ReadPlatform["Platform Resources"]
            R_DSC["opendatahub.io<br/>DataScienceCluster<br/>get, list"]
            R_DSCI["opendatahub.io<br/>DSCInitialization<br/>get, list"]
            R_Components["opendatahub.io<br/>Component CRs<br/>get, list"]
        end

        subgraph ReadOLM["OLM Resources"]
            R_Sub["operators.coreos.com<br/>Subscription<br/>get, list"]
            R_CSV["operators.coreos.com<br/>CSV<br/>get, list"]
            R_PkgManifest["packages.operators.coreos.com<br/>PackageManifest<br/>get, list"]
        end

        subgraph ReadWorkloads["Workload Resources"]
            R_IS["serving.kserve.io<br/>InferenceService<br/>get, list"]
            R_SR["serving.kserve.io<br/>ServingRuntime<br/>get, list"]
            R_NB["kubeflow.org<br/>Notebook<br/>get, list"]
            R_DSPA["datasciencepipelinesapplications.opendatahub.io<br/>DSPA<br/>get, list"]
            R_RC["ray.io<br/>RayCluster<br/>get, list"]
            R_TAI["trustyai.opendatahub.io<br/>TrustyAIService<br/>get, list"]
            R_Train["kubeflow.org<br/>PyTorchJob, TFJob, MPIJob,<br/>XGBoostJob, TrainJob<br/>get, list"]
        end

        subgraph ReadCore["Core Kubernetes"]
            R_Pods["core<br/>Pods<br/>get, list, log"]
            R_Events["core<br/>Events<br/>get, list, watch"]
            R_CM["core<br/>ConfigMaps<br/>get, list"]
            R_NS["core<br/>Namespaces<br/>get, list"]
            R_Routes["route.openshift.io<br/>Routes<br/>get, list"]
            R_CV["config.openshift.io<br/>ClusterVersion<br/>get"]
        end
    end

    subgraph "Required Write Permissions (migrate/components/deps)"
        direction TB

        subgraph WriteMigrate["Migration Write Access"]
            W_IS["serving.kserve.io<br/>InferenceService<br/>patch, update"]
            W_SR["serving.kserve.io<br/>ServingRuntime<br/>patch, update"]
            W_NB["kubeflow.org<br/>Notebook<br/>patch, update"]
            W_DSPA["datasciencepipelinesapplications.opendatahub.io<br/>DSPA<br/>create, patch, update, delete"]
            W_RC["ray.io<br/>RayCluster<br/>patch, update"]
            W_CM["core<br/>ConfigMaps<br/>patch, update"]
            W_Role["rbac.authorization.k8s.io<br/>Role<br/>patch, update"]
        end

        subgraph WriteComponents["Component Management"]
            W_DSC["opendatahub.io<br/>DataScienceCluster<br/>patch, update"]
        end

        subgraph WriteOLM["Operator Installation"]
            W_Sub["operators.coreos.com<br/>Subscription<br/>create"]
            W_IP["operators.coreos.com<br/>InstallPlan<br/>update (approve)"]
        end

        subgraph WriteRBAC["Migration-Created RBAC"]
            W_SA["core<br/>ServiceAccount<br/>create (per-namespace)"]
            W_RB["rbac.authorization.k8s.io<br/>RoleBinding<br/>create (per-namespace)"]
        end
    end

    subgraph "Supply Chain Security"
        CatalogAllowlist["OLM Catalog Source Allowlist:<br/>redhat-operators<br/>community-operators<br/>certified-operators<br/>redhat-marketplace"]
    end

    %% Flows
    Kubeconfig -->|"auth credentials"| CLI
    CLI -->|"pre-validates"| SSAR
    SSAR -.->|"checks against"| ReadPlatform
    SSAR -.->|"checks against"| WriteMigrate

    CLI -->|"requires"| ReadPlatform
    CLI -->|"requires"| ReadOLM
    CLI -->|"requires"| ReadWorkloads
    CLI -->|"requires"| ReadCore
    CLI -->|"requires (migration)"| WriteMigrate
    CLI -->|"requires (components cmd)"| WriteComponents
    CLI -->|"requires (deps cmd)"| WriteOLM
    CLI -->|"creates during migration"| WriteRBAC

    WriteOLM -.->|"validates against"| CatalogAllowlist

    %% Styling
    style CLI fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style SSAR fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style Kubeconfig fill:#e0e0e0,stroke:#616161,stroke-width:2px

    style R_DSC fill:#c8e6c9,stroke:#2e7d32
    style R_DSCI fill:#c8e6c9,stroke:#2e7d32
    style R_Components fill:#c8e6c9,stroke:#2e7d32
