graph TD
    subgraph UserContext["User's Kubeconfig Context"]
        User["Platform Admin<br/>(kubeconfig credentials)"]
    end

    subgraph AuthMethods["Authentication Methods"]
        BearerToken["Bearer Token"]
        ClientCert["Client Certificate"]
        OIDC["OIDC"]
    end

    subgraph RBAC_Enforcement["Kubernetes RBAC Enforcement (kube-apiserver)"]
        RBACCheck["RBAC Authorization<br/>(user's existing roles)"]
    end

    subgraph ReadPermissions["READ Permissions (get, list) - All Commands"]
        direction LR

        subgraph ODH_Platform["ODH Platform CRDs"]
            DSC_R["datasciencecluster.opendatahub.io<br/>datascienceclusters"]
            DSCI_R["dscinitialization.opendatahub.io<br/>dscinitializations"]
            CompCRs_R["components.platform.opendatahub.io<br/>* (13 component CRs)"]
        end

        subgraph OLM_Resources["OLM Resources"]
            Subs_R["operators.coreos.com<br/>subscriptions"]
            CSVs_R["operators.coreos.com<br/>clusterserviceversions"]
            IPs_R["operators.coreos.com<br/>installplans"]
            PkgMan_R["packages.operators.coreos.com<br/>packagemanifests"]
        end

        subgraph Workload_CRDs_R["Workload CRDs"]
            Notebooks_R["kubeflow.org<br/>notebooks, pytorchjobs"]
            KServe_R["serving.kserve.io<br/>inferenceservices,<br/>servingruntimes,<br/>llminferenceservices"]
            Ray_R["ray.io<br/>rayclusters, rayjobs"]
            Kueue_R["kueue.x-k8s.io<br/>clusterqueues, localqueues"]
            DSPA_R["datasciencepipelines...<br/>datasciencepipelines<br/>applications"]
        end

        subgraph Component_CRDs_R["Component CRDs"]
            Dashboard_R["dashboard.opendatahub.io<br/>acceleratorprofiles,<br/>hardwareprofiles"]
            Infra_R["infrastructure.opendatahub.io<br/>hardwareprofiles"]
            TrustyAI_R["trustyai.opendatahub.io<br/>guardrailsorchestrators"]
            CodeFlare_R["workload.codeflare.dev<br/>appwrappers"]
            LlamaStack_R["llamastack.io<br/>llamastackdistributions"]
            Kuadrant_R["kuadrant.io<br/>kuadrants"]
            Authorino_R["operator.authorino.kuadrant.io<br/>authorinos"]
        end

        subgraph OpenShift_R["OpenShift APIs"]
            CV_R["config.openshift.io<br/>clusterversions"]
            IS_R["image.openshift.io<br/>imagestreams,<br/>imagestreamtags"]
        end

        subgraph Core_R["Core Kubernetes APIs"]
            CRDs_R["apiextensions.k8s.io<br/>customresource<br/>definitions"]
            Core_API_R["core ('')<br/>configmaps, secrets,<br/>pvcs, namespaces,<br/>pods, services"]
            Apps_R["apps<br/>deployments,<br/>statefulsets,<br/>daemonsets, replicasets"]
        end
    end

    subgraph WritePermissions["WRITE Permissions - Migration/Components Only"]
        DSC_W["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>(patch - MergePatch)"]
        OLM_W["operators.coreos.com<br/>subscriptions<br/>(create - RHBOK migration)"]
    end

    %% Flows
    User --> BearerToken
    User --> ClientCert
    User --> OIDC

    BearerToken --> RBACCheck
    ClientCert --> RBACCheck
    OIDC --> RBACCheck

    RBACCheck -->|"get, list"| ReadPermissions
    RBACCheck -->|"patch, create<br/>(migrate/components<br/>commands only)"| WritePermissions

