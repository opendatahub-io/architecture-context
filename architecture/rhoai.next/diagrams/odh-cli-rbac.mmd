graph TD
    subgraph UserAuth["Authentication (kubeconfig)"]
        User["User / ServiceAccount<br/>(via kubeconfig)"]
        Token["--token flag<br/>(direct Bearer Token)"]
        Cert["--certificate-authority<br/>(custom CA)"]
    end

    subgraph CLICommands["CLI Commands (RBAC Requirements)"]
        direction TB

        subgraph ReadOnly["Read-Only Commands (client.Reader)"]
            Lint["lint<br/>(37 checks)"]
            Status["status"]
            Get["get"]
            Logs["logs"]
            Backup["backup"]
        end

        subgraph ReadWrite["Read-Write Commands"]
            Components["components<br/>enable/disable"]
            DepsInstall["deps install"]
            Migrate["migrate"]
        end
    end

    subgraph PlatformAPIs["datasciencecluster.opendatahub.io"]
        DSC_R["datascienceclusters<br/>get, list"]
        DSC_RW["datascienceclusters<br/>get, list, patch"]
    end

    subgraph InitAPIs["dscinitialization.opendatahub.io"]
        DSCI_R["dscinitializations<br/>get, list"]
    end

    subgraph ComponentAPIs["components.platform.opendatahub.io"]
        CompCRs["dashboards, kserves,<br/>rays, etc.<br/>list"]
    end

    subgraph ServingAPIs["serving.kserve.io"]
        InferSvc["inferenceservices<br/>list, get"]
        ServRt["servingruntimes<br/>list, get"]
    end

    subgraph KubeflowAPIs["kubeflow.org"]
        NB["notebooks<br/>list, get"]
        PTJ["pytorchjobs<br/>list"]
    end

    subgraph RayAPIs["ray.io"]
        RC["rayclusters<br/>list, get"]
        RJ["rayjobs<br/>list, get"]
    end

    subgraph OLMAPIs["operators.coreos.com"]
        Subs_R["subscriptions<br/>list, get"]
        Subs_RW["subscriptions<br/>create, list, get"]
        CSVs["clusterserviceversions<br/>list, get"]
        OG["operatorgroups<br/>create, list"]
    end

    subgraph CoreAPIs["Core API (v1)"]
        Pods["pods, pods/log<br/>list, get"]
        Nodes["nodes, events,<br/>resourcequotas<br/>list"]
        CM_R["configmaps<br/>get, list"]
        CM_RW["configmaps<br/>get, list, patch"]
        Secrets["secrets<br/>get, list"]
        NS["namespaces<br/>create, list"]
        Deploy["deployments<br/>get, list"]
        PVC["persistentvolumeclaims<br/>get, list"]
    end

    subgraph OtherAPIs["Other APIs"]
        CV["config.openshift.io<br/>clusterversions — get"]
        CRDs["apiextensions.k8s.io<br/>CRDs — get"]
        Kuadrant["kuadrant.io<br/>kuadrants — get"]
        Authorino["authorino.kuadrant.io<br/>authorinos — get"]
        Llama["stack.llama.io<br/>llamastackdistributions — get"]
        AW["workload.codeflare.dev<br/>appwrappers — list"]
    end

    %% Auth to commands
    User --> ReadOnly
    User --> ReadWrite
    Token -.-> User
    Cert -.-> User

    %% Read-only command permissions
    Lint --> DSC_R
    Lint --> DSCI_R
    Lint --> InferSvc
    Lint --> ServRt
    Lint --> NB
    Lint --> PTJ
    Lint --> RC
    Lint --> RJ
    Lint --> AW
    Lint --> Kuadrant
    Lint --> Authorino
    Lint --> Llama
    Lint --> CM_R
    Lint --> Secrets
    Lint --> Subs_R
    Lint --> CSVs

    Status --> DSC_R
    Status --> DSCI_R
    Status --> Subs_R
    Status --> CSVs
    Status --> Deploy
    Status --> Nodes
    Status --> Pods
    Status --> CompCRs

    Get --> InferSvc
    Get --> ServRt
    Get --> NB

    Logs --> Pods

    Backup --> NB
    Backup --> CM_R
    Backup --> Secrets
    Backup --> PVC

    %% Read-write command permissions
    Components --> DSC_RW
    Components --> CompCRs

    DepsInstall --> Subs_RW
    DepsInstall --> OG
    DepsInstall --> NS
    DepsInstall --> CSVs

    Migrate --> DSC_RW
    Migrate --> CM_RW
    Migrate --> Subs_RW

    %% Version detection
    Lint --> CV
    Status --> CV
    Lint --> CRDs

    %% Styling
    style User fill:#4a90e2,stroke:#333,color:#fff
    style Token fill:#90caf9,stroke:#333
    style Cert fill:#90caf9,stroke:#333

    style Lint fill:#c8e6c9,stroke:#388e3c
    style Status fill:#c8e6c9,stroke:#388e3c
    style Get fill:#c8e6c9,stroke:#388e3c
    style Logs fill:#c8e6c9,stroke:#388e3c
    style Backup fill:#c8e6c9,stroke:#388e3c

    style Components fill:#ffcdd2,stroke:#c62828
    style DepsInstall fill:#ffcdd2,stroke:#c62828
    style Migrate fill:#ffcdd2,stroke:#c62828

    style DSC_R fill:#e8f5e9,stroke:#388e3c
    style DSC_RW fill:#ffebee,stroke:#c62828
    style DSCI_R fill:#e8f5e9,stroke:#388e3c
    style CompCRs fill:#e8f5e9,stroke:#388e3c
    style Subs_R fill:#e8f5e9,stroke:#388e3c
    style Subs_RW fill:#ffebee,stroke:#c62828
    style CSVs fill:#e8f5e9,stroke:#388e3c
    style OG fill:#ffebee,stroke:#c62828
