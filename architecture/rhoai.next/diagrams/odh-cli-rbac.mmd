graph TD
    subgraph AuthChain["Authentication Chain"]
        direction TB
        Kubeconfig["kubeconfig File<br/>~/.kube/config"]
        CLIFlags["CLI Auth Flags<br/>--token<br/>--kubeconfig<br/>--server<br/>--certificate-authority<br/>--client-certificate<br/>--client-key"]
        ConfigFlags["kubectl ConfigFlags<br/>(Standard K8s auth chain)"]
    end

    subgraph PreFlight["Pre-Flight RBAC Check"]
        SSAR["SelfSubjectAccessReview<br/>Checks caller permissions<br/>before mutating operations"]
    end

    subgraph InterfaceSplit["Reader/Writer Interface Split (Safety Mechanism)"]
        direction LR

        subgraph ReaderOnly["Reader Interface (Read-Only)"]
            LintChecks["Lint Checks (38)<br/>dependency group<br/>service group<br/>platform group<br/>component group<br/>workload group"]
            StatusCmd["status command"]
            GetCmd["get command"]
            ComponentsCmd["components command"]
            EventsCmd["events command"]
            LogsCmd["logs command"]
            BackupRead["backup (read phase)"]
        end

        subgraph ReaderWriter["Full Client Interface (Read + Write)"]
            MigrateActions["Migration Actions (19)<br/>AI Pipelines migration<br/>KServe serverless→raw<br/>KServe modelmesh→raw<br/>RayCluster migration<br/>TrustyAI migration<br/>Kueue RHBOK install<br/>DSPA v1alpha1→v1<br/>LlamaStack backup<br/>Workbench migration"]
        end
    end

    subgraph APIAccess["Kubernetes API Access (Caller's Permissions)"]
        direction TB

        subgraph ReadOps["Read Operations"]
            List["list"]
            Get["get"]
            Watch["watch"]
        end

        subgraph WriteOps["Write Operations (Migration Only)"]
            Create["create"]
            Patch["patch"]
            Update["update"]
            Delete["delete"]
        end
    end

    subgraph Resources["API Resources Accessed"]
        direction TB

        subgraph PlatformRes["Platform Resources"]
            DSC["DataScienceCluster<br/>opendatahub.io"]
            DSCI["DSCInitialization<br/>opendatahub.io"]
            CSV["ClusterServiceVersion<br/>operators.coreos.com"]
            Sub["Subscription<br/>operators.coreos.com"]
        end

        subgraph ComponentRes["Component Resources"]
            IS["InferenceService<br/>serving.kserve.io"]
            SR["ServingRuntime<br/>serving.kserve.io"]
            NB["Notebook<br/>kubeflow.org"]
            DSPA["DSPA<br/>opendatahub.io"]
            RC["RayCluster<br/>ray.io"]
            TAS["TrustyAIService<br/>trustyai.opendatahub.io"]
            CQ["ClusterQueue<br/>kueue.x-k8s.io"]
        end
    end

    %% Connections
    Kubeconfig -->|provides credentials| ConfigFlags
    CLIFlags -->|overrides| ConfigFlags
    ConfigFlags -->|authenticates| SSAR

    SSAR -->|"passes → proceed"| InterfaceSplit
    SSAR -->|"fails → error + exit"| Denied["⛔ Permission Denied<br/>(graceful error)"]

    LintChecks -->|read-only calls| ReadOps
    StatusCmd -->|read-only calls| ReadOps
    GetCmd -->|read-only calls| ReadOps
    MigrateActions -->|read calls| ReadOps
    MigrateActions -->|"write calls<br/>(requires --yes)"| WriteOps

    ReadOps --> Resources
    WriteOps --> Resources

    %% Styling
    style AuthChain fill:#dbeafe,stroke:#2563eb
    style PreFlight fill:#fef3c7,stroke:#d97706
    style ReaderOnly fill:#d1fae5,stroke:#059669
    style ReaderWriter fill:#fecaca,stroke:#dc2626
    style ReadOps fill:#d1fae5,stroke:#059669
    style WriteOps fill:#fecaca,stroke:#dc2626
    style Denied fill:#fee2e2,stroke:#dc2626
    style SSAR fill:#fbbf24
    style ConfigFlags fill:#93c5fd
