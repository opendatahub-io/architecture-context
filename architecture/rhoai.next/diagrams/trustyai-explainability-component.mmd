graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus)"]
            direction LR
            ConsumerEndpoint["ConsumerEndpoint<br/>/consumer/kserve/v2"]
            DataUpload["DataEndpoint<br/>/data/upload, /data/download"]
            FairnessEndpoints["FairnessEndpoints<br/>/metrics/group/fairness/spd,dir"]
            DriftEndpoints["DriftEndpoints<br/>/metrics/drift/kstest,fouriermmd,meanshift"]
            ExplainerEndpoints["ExplainerEndpoints<br/>/explainers/local/lime,shap,cf<br/>(disabled in RHOAI)"]
            InfoEndpoint["InfoEndpoint<br/>/info, /info/tags, /info/names"]
            HealthEndpoints["Health & Metrics<br/>/q/health/*, /q/metrics"]
            PrometheusScheduler["PrometheusScheduler<br/>(@Scheduled, default 5s)"]
            CloudEventConsumer["CloudEventConsumer<br/>(Knative Trigger)"]
        end

        subgraph StorageLayer["Storage Backends"]
            direction LR
            PVCStorage["PVC Filesystem<br/>/inputs/data.csv"]
            HibernateStorage["Hibernate ORM<br/>MariaDB/MySQL"]
            MinIOStorage["MinIO<br/>S3-compatible"]
            MemoryStorage["In-Memory<br/>(test only)"]
        end

        subgraph CoreLib["explainability-core (Library)"]
            direction LR
            FairnessMetrics["Fairness Metrics<br/>SPD, DIR"]
            DriftMetrics["Drift Detection<br/>KS, Fourier MMD, Meanshift"]
            LocalExplainers["Local Explainers<br/>LIME, SHAP, Counterfactual"]
            GlobalExplainers["Global Explainers<br/>PDP, Aggregated LIME"]
        end

        subgraph Connectors["explainability-connectors (Library)"]
            KServeV2Client["KServe v2 gRPC Client<br/>Protobuf"]
            KServeV1Client["KServe v1 REST Client"]
        end

        subgraph ArrowLib["explainability-arrow (Library)"]
            ArrowSerde["Apache Arrow<br/>Serialization"]
        end
    end

    %% External inputs
    KServeInference["KServe InferenceService"] -->|CloudEvent<br/>inference req/resp| CloudEventConsumer
    ModelMesh["ModelMesh Serving"] -->|HTTP POST<br/>8080/TCP| ConsumerEndpoint
    User["User / ODH Dashboard"] -->|HTTP POST<br/>8080/TCP| FairnessEndpoints
    User -->|HTTP POST<br/>8080/TCP| DriftEndpoints
    User -->|HTTP POST<br/>8080/TCP| ExplainerEndpoints
    User -->|HTTP POST<br/>8080/TCP| DataUpload

    %% Internal flows
    CloudEventConsumer --> StorageLayer
    ConsumerEndpoint --> StorageLayer
    DataUpload --> StorageLayer
    FairnessEndpoints --> FairnessMetrics
    DriftEndpoints --> DriftMetrics
    ExplainerEndpoints --> LocalExplainers
    ExplainerEndpoints --> GlobalExplainers
    FairnessMetrics --> StorageLayer
    DriftMetrics --> StorageLayer
    LocalExplainers --> KServeV2Client
    GlobalExplainers --> KServeV2Client
    PrometheusScheduler --> FairnessMetrics
    PrometheusScheduler --> DriftMetrics
    ArrowSerde -.->|batch data| StorageLayer

    %% External outputs
    KServeV2Client -->|gRPC<br/>KServe v2| KServeModel["KServe Model Server"]
    PrometheusScheduler -->|trustyai_* gauges| PrometheusMetrics["/q/metrics"]
    Prometheus["Prometheus / OpenShift Monitoring"] -->|HTTP GET<br/>8080/TCP| PrometheusMetrics

    %% Storage backends external deps
    HibernateStorage -->|JDBC<br/>3306/TCP| MariaDB["MariaDB / MySQL"]
    MinIOStorage -->|S3 API<br/>9000/TCP| MinIOServer["MinIO Server"]
    PVCStorage -->|Filesystem I/O| PVC["PersistentVolumeClaim"]

    %% Operator
    Operator["TrustyAI Service Operator"] -.->|deploys & manages<br/>TLS, storage config| TrustyAI

    %% Styling
    style TrustyAI fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style ServiceLayer fill:#bbdefb,stroke:#1565c0
    style StorageLayer fill:#c8e6c9,stroke:#2e7d32
    style CoreLib fill:#fff3e0,stroke:#e65100
    style Connectors fill:#f3e5f5,stroke:#6a1b9a
    style ArrowLib fill:#fce4ec,stroke:#b71c1c
    style KServeInference fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#e8e8e8,stroke:#333
    style User fill:#f5f5f5,stroke:#333
    style KServeModel fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style MariaDB fill:#fff9c4,stroke:#f57f17
    style MinIOServer fill:#fff9c4,stroke:#f57f17
    style PVC fill:#fff9c4,stroke:#f57f17
    style Operator fill:#e8eaf6,stroke:#283593
