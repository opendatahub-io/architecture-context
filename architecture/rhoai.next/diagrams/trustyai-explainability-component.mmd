graph TB
    subgraph TrustyAI["TrustyAI Explainability"]
        direction TB

        subgraph CoreLib["explainability-core (Java Library)"]
            LIME["LIME Explainer"]
            SHAP["SHAP Kernel Explainer"]
            CF["Counterfactual Explainer<br/>(OptaPlanner)"]
            PDP["Partial Dependence<br/>Plot Explainer"]
            AggLIME["Aggregated LIME<br/>Explainer"]
            PredProvider["PredictionProvider<br/>Interface"]
        end

        subgraph Connectors["explainability-connectors (Java Library)"]
            HTTPv1["KServe v1 HTTP<br/>Prediction Provider"]
            HTTPv2["KServe v2 HTTP<br/>Prediction Provider"]
            GRPCv2["KServe v2 gRPC<br/>Prediction Provider"]
            Proto["grpc_predict_v2.proto"]
        end

        subgraph ArrowLib["explainability-arrow (Java Library)"]
            ArrowConv["Arrow Converters"]
        end

        subgraph Service["explainability-service (Quarkus 3.8.5)"]
            direction TB

            subgraph Endpoints["REST Endpoints (8080/TCP)"]
                ConsumerEP["Consumer Endpoint<br/>/consumer/kserve/v2"]
                CloudEventEP["CloudEvent Consumer<br/>(Knative Funqy)"]
                FairnessEP["Fairness Metrics<br/>/metrics/group/fairness/*"]
                DriftEP["Drift Metrics<br/>/metrics/drift/*"]
                ExplainerEP["Explainer Endpoints<br/>/explainers/* (ODH only)"]
                DataEP["Data Upload/Download<br/>/data/*"]
                InfoEP["Service Info<br/>/info/*"]
                HealthEP["Health & Metrics<br/>/q/health/* /q/metrics"]
            end

            subgraph DataLayer["Data Layer"]
                Reconciler["KServe Inference<br/>Payload Reconciler"]
                PVCStore["PVC Storage"]
                HibernateStore["Hibernate Storage<br/>(MariaDB/MySQL)"]
                MinioStore["MinIO Storage"]
                MemStore["Memory Storage"]
            end

            subgraph MetricsEngine["Metrics Engine"]
                PromScheduler["Prometheus Scheduler<br/>(@Scheduled 5s)"]
                PromPublisher["Prometheus Publisher<br/>(Micrometer)"]
            end
        end
    end

    %% External interactions
    User["Data Scientist /<br/>Dashboard Client"]
    ModelMesh["KServe / ModelMesh<br/>Model Servers"]
    KServeIS["KServe InferenceService<br/>(CloudEvents)"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"]
    MariaDB["MariaDB / MySQL<br/>3306/TCP"]
    MinIO["MinIO<br/>S3 API"]
    PVC["PersistentVolumeClaim<br/>/inputs"]
    Operator["trustyai-service-operator"]
    Route["OpenShift Route<br/>80/TCP"]

    %% User flows
    User -->|"REST API"| Route
    Route -->|"HTTP/80"| Endpoints

    %% ModelMesh ingestion
    ModelMesh -->|"POST /consumer/kserve/v2<br/>8080/TCP HTTP"| ConsumerEP
    KServeIS -->|"CloudEvents<br/>8080/TCP HTTP"| CloudEventEP
    ConsumerEP --> Reconciler
    CloudEventEP --> Reconciler

    %% Storage
    Reconciler --> PVCStore
    Reconciler --> HibernateStore
    Reconciler --> MinioStore
    PVCStore --> PVC
    HibernateStore -->|"JDBC/3306"| MariaDB
    MinioStore -->|"S3 API"| MinIO

    %% Explainability flow
    ExplainerEP --> PredProvider
    PredProvider --> HTTPv1
    PredProvider --> HTTPv2
    PredProvider --> GRPCv2
    HTTPv1 -->|"HTTP/8080"| ModelMesh
    HTTPv2 -->|"HTTP/8080"| ModelMesh
    GRPCv2 -->|"gRPC plaintext"| ModelMesh

    %% Metrics flow
    FairnessEP --> PromScheduler
    DriftEP --> PromScheduler
    PromScheduler --> PromPublisher
    Prometheus -->|"GET /q/metrics<br/>Bearer Token"| HealthEP

    %% Operator
    Operator -->|"manages lifecycle"| Service

    %% Arrow
    ArrowConv -.->|"columnar data"| DataLayer

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style CoreLib fill:#dcedc8,stroke:#689f38,stroke-width:1px
    style Connectors fill:#fff3e0,stroke:#f57c00,stroke-width:1px
    style ArrowLib fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style Service fill:#e3f2fd,stroke:#1565c0,stroke-width:1px
    style Endpoints fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style DataLayer fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px
    style MetricsEngine fill:#fff8e1,stroke:#f9a825,stroke-width:1px
    style ModelMesh fill:#e0e0e0,stroke:#616161
    style KServeIS fill:#e0e0e0,stroke:#616161
    style Prometheus fill:#e0e0e0,stroke:#616161
    style MariaDB fill:#e0e0e0,stroke:#616161
    style MinIO fill:#e0e0e0,stroke:#616161
    style Operator fill:#c8e6c9,stroke:#2e7d32
    style Route fill:#ffecb3,stroke:#ff8f00
