graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus 3.8.5)"]
            REST["REST API<br/>8080/TCP HTTP<br/>4443/TCP HTTPS"]
            Consumer["Payload Consumer<br/>/consumer/kserve/v2"]
            MetricsEngine["Fairness & Drift Metrics<br/>SPD, DIR, KS, MMD, Meanshift"]
            Explainers["Explainer Endpoints<br/>SHAP, LIME, CF, TSSaliency<br/>(ODH only)"]
            Scheduler["Quarkus Scheduler<br/>Periodic Metric Calculation"]
            PromPublisher["Prometheus Publisher<br/>Micrometer Gauges"]
            StorageIF["Storage Interface<br/>PVC / DB / MinIO / Memory"]
        end

        subgraph CoreLib["explainability-core (Library)"]
            Algorithms["XAI Algorithms<br/>SHAP, LIME, CF, PDP"]
            FairnessMetrics["Fairness Metrics<br/>DIR, SPD"]
            DriftDetection["Drift Detection<br/>KS, Fourier MMD, Meanshift"]
            DataModel["Data Model<br/>Feature, Prediction, Dataframe"]
        end

        subgraph Connectors["explainability-connectors (Library)"]
            GRPC["gRPC Client<br/>KServe V2 Protocol"]
            HTTPClient["HTTP Client<br/>KServe V1/V2"]
            Proto["Protobuf Stubs<br/>grpc_predict_v2.proto"]
        end

        subgraph Arrow["explainability-arrow (Library)"]
            ArrowIPC["Apache Arrow IPC<br/>Java-Python Interop"]
        end
    end

    %% Internal flows
    REST --> MetricsEngine
    REST --> Explainers
    Consumer --> StorageIF
    Scheduler --> MetricsEngine
    MetricsEngine --> PromPublisher
    MetricsEngine --> CoreLib
    Explainers --> CoreLib
    Explainers --> Connectors
    CoreLib --> DataModel
    Connectors --> Proto

    %% External interactions
    ModelMesh["ModelMesh Serving"] -->|POST inference payloads| Consumer
    Client["Client / Dashboard"] -->|REST API requests| REST
    Prometheus["Prometheus"] -->|GET /q/metrics| PromPublisher

    Connectors -->|gRPC / HTTP| KServeModels["KServe Model Servers"]
    StorageIF -->|File I/O| PVC["PVC (CSV/Parquet)"]
    StorageIF -->|JDBC 3306/TCP| MariaDB["MariaDB / MySQL"]
    StorageIF -->|S3 API 9000/TCP| MinIO["MinIO"]

    Operator["TrustyAI Service Operator"] -.->|manages lifecycle| TrustyAI
    AuthProxy["kube-rbac-proxy / oauth-proxy"] -.->|sidecar auth| REST

