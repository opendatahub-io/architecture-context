graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph CoreLib["explainability-core (Java Library)"]
            LIME["LIME Explainer"]
            SHAP["SHAP Explainer"]
            CF["Counterfactual Explainer<br/>(OptaPlanner)"]
            PDP["PDP Explainer"]
            PredProvider["PredictionProvider<br/>Interface"]
        end

        subgraph Connectors["explainability-connectors (Java Library)"]
            KServeV1HTTP["KServe V1 HTTP<br/>Connector"]
            KServeV2HTTP["KServe V2 HTTP<br/>Connector"]
            KServeV2GRPC["KServe V2 gRPC<br/>Connector"]
        end

        subgraph ArrowLib["explainability-arrow (Java Library)"]
            ArrowConv["Arrow Converters<br/>(Columnar Data)"]
        end

        subgraph Service["explainability-service (Quarkus 3.8.5)"]
            direction TB

            subgraph Endpoints["REST Endpoints (8080/TCP)"]
                FairnessEP["Fairness Metrics<br/>/metrics/group/fairness/*<br/>(SPD, DIR)"]
                DriftEP["Drift Metrics<br/>/metrics/drift/*<br/>(KS, FourierMMD, Meanshift)"]
                ExplainerEP["Explainer Endpoints<br/>/explainers/*<br/>(ODH only)"]
                DataEP["Data Endpoints<br/>/data/upload, /data/download"]
                InfoEP["Service Info<br/>/info, /info/tags, /info/names"]
                HealthEP["Health & Metrics<br/>/q/health/*, /q/metrics"]
            end

            subgraph Consumers["Payload Consumers"]
                ConsumerEP["ConsumerEndpoint<br/>/consumer/kserve/v2"]
                CloudEventCE["CloudEventConsumer<br/>(Knative Funqy)"]
            end

            subgraph Core["Core Services"]
                PayloadReconciler["KServeInferencePayload<br/>Reconciler"]
                PromScheduler["PrometheusScheduler<br/>(@Scheduled 5s)"]
                PromPublisher["PrometheusPublisher<br/>(Micrometer Gauges)"]
            end

            subgraph Storage["Storage Backends (pluggable)"]
                PVCStorage["PVC Storage<br/>/inputs"]
                HibernateStorage["Hibernate Storage<br/>(MariaDB/MySQL)"]
                MinIOStorage["MinIO Storage<br/>(S3 API)"]
                MemStorage["Memory Storage"]
            end
        end
    end

    %% Internal flows
    ConsumerEP -->|inference payloads| PayloadReconciler
    CloudEventCE -->|CloudEvents| PayloadReconciler
    PayloadReconciler -->|persists observations| Storage

    FairnessEP -->|reads data| Storage
    DriftEP -->|reads data| Storage
    ExplainerEP -->|reads data| Storage
    ExplainerEP -->|invokes models| Connectors

    Connectors -->|implements| PredProvider
    CoreLib -->|uses| PredProvider

    PromScheduler -->|computes metrics| FairnessEP
    PromScheduler -->|computes metrics| DriftEP
    PromScheduler -->|publishes| PromPublisher

    %% External interactions
    ModelMesh["ModelMesh<br/>Serving Runtime"] -->|POST /consumer/kserve/v2<br/>8080/TCP HTTP| ConsumerEP
    KServeIS["KServe<br/>InferenceService"] -->|CloudEvents<br/>8080/TCP HTTP| CloudEventCE

    KServeV1HTTP -->|HTTP 8080| ModelServer["KServe/ModelMesh<br/>Model Server"]
    KServeV2HTTP -->|HTTP 8080| ModelServer
    KServeV2GRPC -->|gRPC plaintext| ModelServer

    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|scrapes /q/metrics<br/>8080/TCP HTTP| HealthEP

    Operator["trustyai-service-operator"] -.->|deploys & manages| Service

    Client["Client / Dashboard"] -->|REST API<br/>8080/TCP HTTP| Endpoints

    Route["OpenShift Route<br/>80/TCP HTTP"] -->|forwards| Service

    %% Storage external deps
    HibernateStorage -->|JDBC 3306/TCP| MariaDB["MariaDB/MySQL"]
    MinIOStorage -->|S3 HTTP API| MinIO["MinIO"]
    PVCStorage -->|filesystem| PVC["PersistentVolumeClaim<br/>/inputs"]

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style CoreLib fill:#dcedc8,stroke:#689f38,stroke-width:1px
    style Connectors fill:#dcedc8,stroke:#689f38,stroke-width:1px
    style ArrowLib fill:#dcedc8,stroke:#689f38,stroke-width:1px
    style Service fill:#fff3e0,stroke:#ef6c00,stroke-width:1px
    style Endpoints fill:#e3f2fd,stroke:#1565c0,stroke-width:1px
    style Consumers fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style Core fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px
    style Storage fill:#fff8e1,stroke:#f9a825,stroke-width:1px

    style ModelMesh fill:#e8e8e8,stroke:#333
    style KServeIS fill:#e8e8e8,stroke:#333
    style ModelServer fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Route fill:#e8e8e8,stroke:#333
    style MariaDB fill:#f5a623,stroke:#333
    style MinIO fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
