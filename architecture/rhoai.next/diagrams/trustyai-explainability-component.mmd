graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus REST)"]
            direction LR
            FairnessAPI["Fairness Endpoints<br/>/metrics/group/fairness/*<br/>SPD, DIR"]
            DriftAPI["Drift Endpoints<br/>/metrics/drift/*<br/>KS, MMD, Meanshift"]
            ExplainerAPI["Explainer Endpoints<br/>/explainers/*<br/>LIME, SHAP, CF, TSSaliency, PDP"]
            DataAPI["Data Endpoints<br/>/data/upload, /data/download"]
            ConsumerAPI["Consumer Endpoints<br/>/consumer/kserve/v2"]
            InfoAPI["Info Endpoints<br/>/info, /info/tags, /info/names"]
            HealthAPI["Health & Metrics<br/>/q/health/*, /q/metrics"]
        end

        subgraph StorageLayer["Storage Backends (pluggable)"]
            direction LR
            PVCStorage["PVC Storage<br/>(default, CSV at /inputs)"]
            MinIOStorage["MinIO/S3 Storage<br/>(optional)"]
            DBStorage["Hibernate/DB Storage<br/>(MariaDB/MySQL, optional)"]
            MemoryStorage["In-Memory Storage<br/>(optional)"]
        end

        subgraph CoreLib["explainability-core (Library)"]
            direction LR
            FairnessCalc["Fairness Metrics<br/>SPD, DIR"]
            DriftCalc["Drift Detection<br/>KS, Fourier MMD, Meanshift"]
            Explainers["Explainers<br/>LIME, SHAP, CF, TSSaliency, PDP"]
        end

        subgraph Connectors["explainability-connectors (Library)"]
            direction LR
            KServeV1["KServe v1 HTTP<br/>Connector"]
            KServeV2["KServe v2 HTTP<br/>Connector"]
            KServeGRPC["KServe v2 gRPC<br/>Connector"]
        end

        subgraph Reconciler["Inference Reconciliation"]
            PayloadStorage["PayloadStorage<br/>(partial payloads)"]
            PayloadReconciler["PayloadReconciler<br/>(match input+output by ID)"]
            PayloadStorage --> PayloadReconciler
        end

        PrometheusScheduler["PrometheusScheduler<br/>(cron-triggered metric computation)"]
    end

    %% Internal flows
    FairnessAPI --> FairnessCalc
    DriftAPI --> DriftCalc
    ExplainerAPI --> Explainers
    ConsumerAPI --> PayloadStorage
    PayloadReconciler --> StorageLayer
    PrometheusScheduler --> StorageLayer
    PrometheusScheduler --> FairnessCalc
    PrometheusScheduler --> DriftCalc
    Explainers --> Connectors
    DataAPI --> StorageLayer

    %% External actors
    User["User / Dashboard"] -->|REST 8080/TCP| FairnessAPI
    User -->|REST 8080/TCP| DriftAPI
    User -->|REST 8080/TCP| ExplainerAPI
    User -->|REST 8080/TCP| DataAPI

    KServeIS["KServe InferenceService<br/>(payload processor)"] -->|POST /consumer/kserve/v2<br/>8080/TCP| ConsumerAPI
    ModelMesh["ModelMesh Serving"] -->|POST /consumer/kserve/v2<br/>8080/TCP| ConsumerAPI
    CloudEvents["Kubeflow CloudEvents<br/>Broker"] -->|CloudEvent<br/>8080/TCP| ConsumerAPI

    Connectors -->|gRPC 8033/TCP<br/>or HTTP| KServeModel["KServe Model Endpoint"]

    Prometheus["Prometheus"] -->|GET /q/metrics<br/>8080/TCP| HealthAPI

    TrustyAIOp["TrustyAI Operator"] -.->|manages| TrustyAI

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ServiceLayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style StorageLayer fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style CoreLib fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Connectors fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Reconciler fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    style User fill:#f9f9f9,stroke:#999
    style KServeIS fill:#f9f9f9,stroke:#999
    style ModelMesh fill:#f9f9f9,stroke:#999
    style CloudEvents fill:#f9f9f9,stroke:#999
    style KServeModel fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
    style TrustyAIOp fill:#7ed321,stroke:#333
