graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["Quarkus REST Service (explainability-service)"]
            ConsumerEndpoint["Consumer Endpoint<br/>/consumer/kserve/v2"]
            CloudEventConsumer["CloudEvent Consumer<br/>Knative Triggers"]
            MetricsEndpoints["Metrics Endpoints<br/>/metrics/group/fairness/*<br/>/metrics/drift/*<br/>/metrics/identity/*"]
            ExplainerEndpoints["Explainer Endpoints<br/>/explainers/local/*<br/>/explainers/global/*<br/>(disabled in RHOAI)"]
            DataEndpoints["Data Endpoints<br/>/data/upload<br/>/info/*"]
            HealthEndpoints["Health & Metrics<br/>/q/health/*<br/>/q/metrics"]
        end

        subgraph ReconcilerLayer["Payload Reconciliation"]
            KServeReconciler["KServe Inference<br/>Payload Reconciler"]
            ModelMeshReconciler["ModelMesh Inference<br/>Payload Reconciler"]
        end

        subgraph SchedulerLayer["Metrics Scheduling"]
            PrometheusScheduler["Prometheus Scheduler<br/>(cron: every 5s)"]
            PrometheusPublisher["Prometheus Publisher<br/>(Micrometer gauges)"]
        end

        subgraph CoreLayer["explainability-core"]
            FairnessCalc["Fairness Calculators<br/>SPD, DIR"]
            DriftCalc["Drift Detectors<br/>Meanshift, Fourier MMD"]
            ExplainerAlgos["Explainability Algorithms<br/>LIME, SHAP, Counterfactual,<br/>Time Series Saliency, PDP"]
        end

        subgraph ConnectorsLayer["explainability-connectors"]
            KServeV1HTTP["KServe v1 HTTP<br/>Prediction Provider"]
            KServeV2HTTP["KServe v2 HTTP<br/>Prediction Provider"]
            KServeV2GRPC["KServe v2 gRPC<br/>Prediction Provider"]
        end

        subgraph StorageLayer["Pluggable Storage"]
            PVCStorage["PVC Storage<br/>(CSV files at /inputs)"]
            MinioStorage["MinIO Storage<br/>(S3-compatible)"]
            HibernateStorage["Hibernate Storage<br/>(MariaDB/MySQL)"]
            MemoryStorage["Memory Storage<br/>(test only)"]
        end

        subgraph InitContainer["Init Container"]
            ConfigOverrider["config-map-overrider<br/>(ose-cli shell script)"]
        end
    end

    %% External actors
    KServeIS["KServe InferenceService<br/>(CloudEvents)"]
    ModelMesh["ModelMesh Serving<br/>(REST payloads)"]
    KServeServers["KServe Inference Servers"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"]
    User["User / Dashboard"]
    K8sAPI["Kubernetes API Server"]
    MinIOServer["MinIO Server"]
    Database["MariaDB / MySQL"]

    %% Ingestion flows
    KServeIS -->|CloudEvents<br/>8080/TCP| CloudEventConsumer
    ModelMesh -->|POST /consumer/kserve/v2<br/>8080/TCP| ConsumerEndpoint
    CloudEventConsumer --> KServeReconciler
    ConsumerEndpoint --> ModelMeshReconciler
    KServeReconciler --> StorageLayer
    ModelMeshReconciler --> StorageLayer

    %% Metrics flow
    PrometheusScheduler -->|reads data| StorageLayer
    PrometheusScheduler --> FairnessCalc
    PrometheusScheduler --> DriftCalc
    PrometheusScheduler --> PrometheusPublisher
    Prometheus -->|scrapes /q/metrics<br/>8080/TCP| HealthEndpoints

    %% Explainability flow
    User -->|POST /explainers/*<br/>8080/TCP| ExplainerEndpoints
    ExplainerEndpoints --> ExplainerAlgos
    ExplainerEndpoints --> ConnectorsLayer
    KServeV1HTTP -->|HTTP| KServeServers
    KServeV2HTTP -->|HTTP| KServeServers
    KServeV2GRPC -->|gRPC| KServeServers

    %% Metrics API
    User -->|POST /metrics/*<br/>8080/TCP| MetricsEndpoints
    MetricsEndpoints --> FairnessCalc
    MetricsEndpoints --> DriftCalc

    %% Storage backends
    PVCStorage -.->|volume mount| PVC["PVC Volume<br/>/inputs"]
    MinioStorage -->|S3 API| MinIOServer
    HibernateStorage -->|JDBC 3306/TCP| Database

    %% Init container
    ConfigOverrider -->|oc apply<br/>443/TCP HTTPS| K8sAPI

    %% Styling
    style TrustyAI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ServiceLayer fill:#dceefb,stroke:#4a90e2
    style ReconcilerLayer fill:#dceefb,stroke:#4a90e2
    style SchedulerLayer fill:#dceefb,stroke:#4a90e2
    style CoreLayer fill:#d5e8d4,stroke:#82b366
    style ConnectorsLayer fill:#d5e8d4,stroke:#82b366
    style StorageLayer fill:#fff2cc,stroke:#d6b656
    style InitContainer fill:#f8cecc,stroke:#b85450

    style KServeIS fill:#e8e8e8,stroke:#999
    style ModelMesh fill:#e8e8e8,stroke:#999
    style KServeServers fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
    style User fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style MinIOServer fill:#e8e8e8,stroke:#999
    style Database fill:#e8e8e8,stroke:#999
    style PVC fill:#e8e8e8,stroke:#999
