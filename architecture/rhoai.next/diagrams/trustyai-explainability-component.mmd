graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB
        subgraph ServiceLayer["explainability-service (Quarkus 3.8.5)"]
            RestAPI["REST API<br/>8080/TCP HTTP<br/>4443/TCP HTTPS"]
            Scheduler["Quarkus Scheduler<br/>Scheduled Metric Calculation"]
            Consumer["Payload Consumer<br/>/consumer/kserve/v2"]
            MetricsEndpoint["Prometheus Endpoint<br/>/q/metrics"]
            HealthChecks["Health Checks<br/>/q/health/*"]
        end

        subgraph CoreLib["explainability-core"]
            Fairness["Fairness Metrics<br/>SPD, DIR"]
            Drift["Drift Detection<br/>KS, MMD, Meanshift"]
            Explainers["Explainers<br/>SHAP, LIME, CF, PDP"]
            DataModel["Data Model<br/>Feature, Prediction, Dataframe"]
        end

        subgraph Connectors["explainability-connectors"]
            GRPC["gRPC Client<br/>KServe V2 Protocol"]
            HTTPClient["HTTP Client<br/>KServe V1/V2"]
            Proto["Protobuf Stubs<br/>grpc_predict_v2.proto"]
        end

        subgraph ArrowMod["explainability-arrow"]
            Arrow["Arrow IPC<br/>Java-Python Interop"]
        end

        RestAPI --> Fairness
        RestAPI --> Drift
        RestAPI --> Explainers
        Scheduler --> Fairness
        Scheduler --> Drift
        Explainers --> GRPC
        Explainers --> HTTPClient
        Consumer --> DataModel
        GRPC --> Proto
        Explainers --> DataModel
        Arrow -.-> DataModel
    end

    %% External Actors
    Client["Client / Dashboard"]
    ModelMesh["ModelMesh Serving"]
    KServeModels["KServe Model Servers"]
    Prometheus["Prometheus"]
    Operator["TrustyAI Service Operator"]

    %% Storage Backends
    subgraph Storage["Storage Backends (pluggable)"]
        PVC["PVC (CSV/Parquet)<br/>Default - 1Gi RWO"]
        DB["MariaDB / MySQL<br/>3306/TCP JDBC"]
        MinIO["MinIO<br/>9000/TCP S3 API"]
    end

    %% Flows
    Client -->|"REST API<br/>80/TCP HTTP"| RestAPI
    ModelMesh -->|"POST /consumer/kserve/v2<br/>80/TCP HTTP"| Consumer
    GRPC -->|"gRPC/HTTP2<br/>V2 Inference"| KServeModels
    HTTPClient -->|"HTTP<br/>V1/V2 Inference"| KServeModels
    Prometheus -->|"GET /q/metrics<br/>80/TCP HTTP<br/>Bearer Token"| MetricsEndpoint
    Operator -.->|"CRD-managed<br/>lifecycle"| TrustyAI

    RestAPI --> PVC
    RestAPI --> DB
    RestAPI --> MinIO
    Consumer --> PVC
    Consumer --> DB
    Consumer --> MinIO

    %% Styles
    style TrustyAI fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style ServiceLayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CoreLib fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Connectors fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style ArrowMod fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Storage fill:#f5f5f5,stroke:#999,stroke-width:2px

    style RestAPI fill:#4a90e2,color:#fff
    style Scheduler fill:#4a90e2,color:#fff
    style Consumer fill:#4a90e2,color:#fff
    style MetricsEndpoint fill:#4a90e2,color:#fff
    style HealthChecks fill:#4a90e2,color:#fff

    style Fairness fill:#f5a623,color:#fff
    style Drift fill:#f5a623,color:#fff
    style Explainers fill:#f5a623,color:#fff
    style DataModel fill:#f5a623,color:#fff

    style Client fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style KServeModels fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Operator fill:#7ed321,stroke:#333

    style PVC fill:#ddd,stroke:#666
    style DB fill:#ddd,stroke:#666
    style MinIO fill:#ddd,stroke:#666
