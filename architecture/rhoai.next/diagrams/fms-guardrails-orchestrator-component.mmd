graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        direction TB
        subgraph GuardrailsServer["Guardrails Server (8033/TCP)"]
            AxumRouter["Axum Router<br/>(axum + tokio)"]
            V1Handlers["V1 Handlers<br/>classification-with-gen<br/>streaming-classification"]
            V2Handlers["V2 Handlers<br/>content detection<br/>chat detection<br/>context detection<br/>generation-detection<br/>completions-detection"]
            OpenAIHandlers["OpenAI-Compatible Handlers<br/>chat/completions-detection<br/>text/completions-detection"]
            OrchestratorCore["Orchestrator Core<br/>Pipeline coordination<br/>Detection batching"]
        end

        subgraph HealthServer["Health Server (8034/TCP)"]
            HealthEndpoint["/health - Liveness"]
            InfoEndpoint["/info - Readiness"]
        end

        subgraph Clients["Client Modules"]
            GenClient["GenerationClient<br/>(TGIS / NLP abstraction)"]
            DetectorClient["DetectorClient<br/>(HTTP REST)"]
            ChunkerClient["ChunkerClient<br/>(gRPC)"]
            OpenAIClient["OpenAIClient<br/>(HTTP REST)"]
        end

        subgraph TLS["TLS Layer"]
            RustlsTLS["rustls + ring<br/>Optional TLS/mTLS"]
        end
    end

    Client[External Client] -->|"POST /api/v1/* or /api/v2/*<br/>8033/TCP HTTP/HTTPS"| AxumRouter
    AxumRouter --> V1Handlers
    AxumRouter --> V2Handlers
    AxumRouter --> OpenAIHandlers
    V1Handlers --> OrchestratorCore
    V2Handlers --> OrchestratorCore
    OpenAIHandlers --> OrchestratorCore

    OrchestratorCore --> GenClient
    OrchestratorCore --> DetectorClient
    OrchestratorCore --> ChunkerClient
    OrchestratorCore --> OpenAIClient

    GenClient -->|"gRPC 8033/TCP"| TGIS["TGIS<br/>Generation Server"]
    GenClient -->|"gRPC 8085/TCP"| CaikitNLP["Caikit NLP<br/>Generation Server"]
    ChunkerClient -->|"gRPC 8085/TCP"| CaikitChunker["Caikit Chunker<br/>Service"]
    DetectorClient -->|"HTTP 8080/TCP"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    OpenAIClient -->|"HTTP 8080/TCP"| vLLM["OpenAI-compatible<br/>/ vLLM"]

    K8sProbes["Kubernetes Probes"] -->|"GET /health, /info<br/>8034/TCP"| HealthEndpoint
    K8sProbes --> InfoEndpoint

    OrchestratorCore -.->|"gRPC/HTTP 4317-4318/TCP"| OTLP["OTLP Collector"]

    style Orchestrator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style GuardrailsServer fill:#d5e8d4,stroke:#82b366
    style HealthServer fill:#d5e8d4,stroke:#82b366
    style Clients fill:#fff2cc,stroke:#d6b656
    style TLS fill:#f8cecc,stroke:#b85450
    style Client fill:#f9f9f9,stroke:#999
    style TGIS fill:#e8e8e8,stroke:#666
    style CaikitNLP fill:#e8e8e8,stroke:#666
    style CaikitChunker fill:#e8e8e8,stroke:#666
    style Detectors fill:#e8e8e8,stroke:#666
    style vLLM fill:#e8e8e8,stroke:#666
    style OTLP fill:#e8e8e8,stroke:#666
    style K8sProbes fill:#f9f9f9,stroke:#999
