graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        direction TB
        subgraph Servers["Dual Server Architecture"]
            APIServer["API Server<br/>Port 8033/TCP<br/>Axum + Hyper"]
            HealthServer["Health Server<br/>Port 8034/TCP<br/>Axum + Hyper"]
        end

        subgraph Core["Orchestration Engine"]
            Router["Route Handler<br/>(v1 + v2 API)"]
            OrchestratorEngine["Orchestrator Engine<br/>(Tokio async)"]
            DetectionBatcher["Detection Batcher<br/>(Actor Pattern)"]
        end

        subgraph Clients["Downstream Clients"]
            TGISClient["TGIS Client<br/>(tonic gRPC)"]
            NLPClient["Caikit NLP Client<br/>(tonic gRPC)"]
            ChunkerClient["Chunker Client<br/>(tonic gRPC)"]
            DetectorClient["Detector Client<br/>(reqwest HTTP)"]
            OpenAIClient["OpenAI Client<br/>(reqwest HTTP)"]
        end

        subgraph Observability["Observability"]
            OTelTracing["OpenTelemetry<br/>Tracing + Metrics"]
        end

        APIServer --> Router
        Router --> OrchestratorEngine
        OrchestratorEngine --> DetectionBatcher
        OrchestratorEngine --> TGISClient
        OrchestratorEngine --> NLPClient
        OrchestratorEngine --> ChunkerClient
        OrchestratorEngine --> DetectorClient
        OrchestratorEngine --> OpenAIClient
        OrchestratorEngine --> OTelTracing
    end

    Client["Client<br/>(API Consumer)"] -->|"POST /api/v1/* /api/v2/*<br/>HTTP 8033/TCP"| APIServer
    K8s["Kubernetes<br/>(Health Probes)"] -->|"GET /health /info<br/>HTTP 8034/TCP"| HealthServer

    TGISClient -->|"gRPC 8033/TCP<br/>mTLS optional"| TGIS["TGIS Server<br/>(Text Generation)"]
    NLPClient -->|"gRPC 8085/TCP<br/>mTLS optional"| CaikitNLP["Caikit NLP<br/>(Text Generation)"]
    ChunkerClient -->|"gRPC 8085/TCP<br/>mTLS optional"| Chunker["Chunker Service<br/>(Text Tokenization)"]
    DetectorClient -->|"HTTP 8080/TCP<br/>TLS optional"| Detector["Detector Service(s)<br/>(Content Safety)"]
    OpenAIClient -->|"HTTP 8080/TCP<br/>TLS optional"| vLLM["OpenAI-compatible API<br/>(vLLM)"]
    OTelTracing -->|"gRPC 4317/TCP<br/>HTTP 4318/TCP"| OTelCollector["OTLP Collector"]

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#4a90e2,stroke:#333,color:#fff
    style Router fill:#5b9bd5,stroke:#333,color:#fff
    style OrchestratorEngine fill:#5b9bd5,stroke:#333,color:#fff
    style DetectionBatcher fill:#5b9bd5,stroke:#333,color:#fff
    style TGISClient fill:#7fb3e0,stroke:#333
    style NLPClient fill:#7fb3e0,stroke:#333
    style ChunkerClient fill:#7fb3e0,stroke:#333
    style DetectorClient fill:#7fb3e0,stroke:#333
    style OpenAIClient fill:#7fb3e0,stroke:#333
    style OTelTracing fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333
    style K8s fill:#f5a623,stroke:#333
    style TGIS fill:#7ed321,stroke:#333
    style CaikitNLP fill:#7ed321,stroke:#333
    style Chunker fill:#7ed321,stroke:#333
    style Detector fill:#7ed321,stroke:#333
