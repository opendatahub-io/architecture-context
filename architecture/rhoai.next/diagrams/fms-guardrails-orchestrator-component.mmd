graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph "Guardrails API Server (8033/TCP)"
            Router["axum Router<br/>HTTP/HTTPS + Optional TLS/mTLS"]

            subgraph "v1 Endpoints"
                V1Classify["/api/v1/task/classification-with-text-generation"]
                V1Stream["/api/v1/task/server-streaming-classification-with-text-generation"]
            end

            subgraph "v2 Endpoints"
                V2Content["/api/v2/text/detection/content"]
                V2Chat["/api/v2/text/detection/chat"]
                V2Context["/api/v2/text/detection/context"]
                V2Generated["/api/v2/text/detection/generated"]
                V2GenDetect["/api/v2/text/generation-detection"]
                V2StreamContent["/api/v2/text/detection/stream-content"]
                V2ChatComp["/api/v2/chat/completions-detection"]
                V2TextComp["/api/v2/text/completions-detection"]
            end

            Router --> V1Classify
            Router --> V1Stream
            Router --> V2Content
            Router --> V2Chat
            Router --> V2Context
            Router --> V2Generated
            Router --> V2GenDetect
            Router --> V2StreamContent
            Router --> V2ChatComp
            Router --> V2TextComp
        end

        subgraph "Health Server (8034/TCP)"
            HealthEndpoint["/health<br/>Plaintext HTTP"]
            InfoEndpoint["/info<br/>Downstream health status"]
        end

        subgraph "Client Layer"
            GenClient["GenerationClient<br/>(TGIS | caikit-nlp)"]
            DetectorClient["Detector HTTP Client"]
            ChunkerClient["Chunker gRPC Client"]
            OpenAIClient["OpenAI HTTP Client"]
            ClientMap["ClientMap<br/>Type-erased container"]
        end

        subgraph "Infrastructure"
            TLS["rustls + ring<br/>TLS 1.2+ / mTLS"]
            OTel["OpenTelemetry<br/>Traces + Metrics"]
            Tokio["tokio Async Runtime"]
        end

        Router --> ClientMap
        ClientMap --> GenClient
        ClientMap --> DetectorClient
        ClientMap --> ChunkerClient
        ClientMap --> OpenAIClient
    end

    Client[Client / API Consumer] -->|"POST /api/v*/**<br/>8033/TCP"| Router
    Monitor[Kubernetes Probes] -->|"GET /health<br/>8034/TCP"| HealthEndpoint

    GenClient -->|"gRPC/HTTP2<br/>8033/TCP"| TGIS["TGIS<br/>Generation Server"]
    GenClient -->|"gRPC/HTTP2<br/>8085/TCP"| CaikitNLP["caikit-nlp<br/>Generation Server"]
    ChunkerClient -->|"gRPC/HTTP2<br/>8085/TCP"| Chunkers["caikit Chunkers"]
    DetectorClient -->|"HTTP/HTTPS<br/>8080/TCP"| Detectors["Detector Services"]
    OpenAIClient -->|"HTTP/HTTPS<br/>8080/TCP"| OpenAISrv["OpenAI-compatible<br/>Server (vLLM)"]
    OTel -->|"gRPC 4317 / HTTP 4318"| OTLPCol["OTLP Collector"]

    style Router fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#7ed321,stroke:#333,color:#fff
    style InfoEndpoint fill:#7ed321,stroke:#333,color:#fff
    style GenClient fill:#f5a623,stroke:#333,color:#fff
    style DetectorClient fill:#f5a623,stroke:#333,color:#fff
    style ChunkerClient fill:#f5a623,stroke:#333,color:#fff
    style OpenAIClient fill:#f5a623,stroke:#333,color:#fff
    style ClientMap fill:#f5a623,stroke:#333,color:#fff
    style TLS fill:#bd10e0,stroke:#333,color:#fff
    style OTel fill:#bd10e0,stroke:#333,color:#fff
    style Tokio fill:#bd10e0,stroke:#333,color:#fff
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
    style Chunkers fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
    style OpenAISrv fill:#e8e8e8,stroke:#333
    style OTLPCol fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style Monitor fill:#f9f9f9,stroke:#333
