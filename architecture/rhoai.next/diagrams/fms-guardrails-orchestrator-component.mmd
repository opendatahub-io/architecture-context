graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph "Guardrails Server :8033"
            Router[Axum Router]
            V1Handler["V1 Handlers<br/>(classification-with-gen)"]
            V2DetHandler["V2 Detection Handlers<br/>(content, chat, context, generated)"]
            V2GenHandler["V2 Generation-Detection Handlers<br/>(generation-detection, completions)"]
            StreamHandler["Streaming Handlers<br/>(SSE, ND-JSON)"]
            DetectionBatcher["DetectionBatcherManager<br/>(actor pattern)"]
            CompletionState["CompletionState<br/>(DashMap, lock-free)"]

            Router --> V1Handler
            Router --> V2DetHandler
            Router --> V2GenHandler
            Router --> StreamHandler
            StreamHandler --> DetectionBatcher
            StreamHandler --> CompletionState
        end

        subgraph "Health Server :8034"
            HealthEndpoint["/health endpoint"]
            InfoEndpoint["/info endpoint"]
        end

        subgraph "Client Layer"
            GenClient["GenerationClient<br/>(unified TGIS/NLP abstraction)"]
            ChunkerClient["ChunkerClient<br/>(gRPC via ginepro)"]
            DetectorClient["DetectorClient<br/>(HTTP via reqwest)"]
            OpenAIClient["OpenAIClient<br/>(HTTP via reqwest)"]
        end

        subgraph "TLS Layer"
            TLSConfig["rustls ServerConfig<br/>(ring crypto backend)"]
            mTLS["WebPkiClientVerifier<br/>(optional mTLS)"]
        end

        V1Handler --> GenClient
        V1Handler --> ChunkerClient
        V1Handler --> DetectorClient
        V2DetHandler --> ChunkerClient
        V2DetHandler --> DetectorClient
        V2GenHandler --> GenClient
        V2GenHandler --> DetectorClient
        V2GenHandler --> OpenAIClient
        InfoEndpoint -->|health checks| GenClient
        InfoEndpoint -->|health checks| DetectorClient
    end

    Client[External Client] -->|"POST /api/v1/* or /api/v2/*<br/>8033/TCP"| Router
    K8sProbe[Kubernetes Probes] -->|"GET /health, /info<br/>8034/TCP"| HealthEndpoint

    GenClient -->|gRPC| TGIS["TGIS<br/>8033/TCP"]
    GenClient -->|gRPC| CaikitNLP["Caikit NLP<br/>8085/TCP"]
    ChunkerClient -->|gRPC| Chunkers["Caikit Chunkers<br/>8085/TCP"]
    DetectorClient -->|HTTP/HTTPS| Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>8080/TCP"]
    OpenAIClient -->|HTTP/HTTPS| vLLM["OpenAI / vLLM<br/>8080/TCP"]

    subgraph "Observability"
        OTLP["OTLP Collector<br/>4317/TCP (gRPC)<br/>4318/TCP (HTTP)"]
    end

    Router -.->|traces & metrics| OTLP

    style Router fill:#4a90e2,stroke:#333
    style V1Handler fill:#4a90e2,stroke:#333
    style V2DetHandler fill:#4a90e2,stroke:#333
    style V2GenHandler fill:#4a90e2,stroke:#333
    style StreamHandler fill:#4a90e2,stroke:#333
    style DetectionBatcher fill:#4a90e2,stroke:#333
    style CompletionState fill:#4a90e2,stroke:#333
    style HealthEndpoint fill:#4a90e2,stroke:#333
    style InfoEndpoint fill:#4a90e2,stroke:#333
    style GenClient fill:#6baed6,stroke:#333
    style ChunkerClient fill:#6baed6,stroke:#333
    style DetectorClient fill:#6baed6,stroke:#333
    style OpenAIClient fill:#6baed6,stroke:#333
    style TLSConfig fill:#9ecae1,stroke:#333
    style mTLS fill:#9ecae1,stroke:#333
    style Client fill:#f5a623,stroke:#333
    style K8sProbe fill:#f5a623,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
    style Chunkers fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style OTLP fill:#d5e8d4,stroke:#333
