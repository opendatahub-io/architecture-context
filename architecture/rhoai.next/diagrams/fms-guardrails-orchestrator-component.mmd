graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph "API Server (Port 8033)"
            V1ClassifyGen["/api/v1 Classification<br/>with Generation"]
            V2Detection["/api/v2 Detection<br/>(content, chat, context,<br/>generated, stream)"]
            V2GenDetect["/api/v2 Generation<br/>Detection"]
            V2ChatComp["/api/v2 Chat<br/>Completions Detection"]
            V2TextComp["/api/v2 Text<br/>Completions Detection"]
        end

        subgraph "Health Server (Port 8034)"
            Health["/health<br/>Liveness"]
            Info["/info<br/>Readiness"]
        end

        subgraph "Orchestration Engine"
            OrchestratorCore["Orchestrator Core<br/>(Tokio async runtime)"]
            InputDetection["Input Detection<br/>Pipeline"]
            OutputDetection["Output Detection<br/>Pipeline"]
            DetectionBatcher["Detection Batch<br/>Stream Manager"]
        end

        subgraph "Client Modules"
            TGISClient["TGIS gRPC Client"]
            NLPClient["Caikit NLP gRPC Client"]
            ChunkerClient["Chunker gRPC Client"]
            DetectorClient["Detector HTTP Client"]
            OpenAIClient["OpenAI HTTP Client"]
        end

        subgraph "TLS & Observability"
            TLSManager["TLS Manager<br/>(rustls)"]
            OTelTracing["OpenTelemetry<br/>Tracing & Metrics"]
        end
    end

    Client[External Client] -->|"HTTP/8033<br/>TLS optional"| V1ClassifyGen
    Client -->|"HTTP/8033<br/>TLS optional"| V2Detection
    Client -->|"HTTP/8033<br/>TLS optional"| V2GenDetect
    Client -->|"HTTP/8033<br/>TLS optional"| V2ChatComp
    Client -->|"HTTP/8033<br/>TLS optional"| V2TextComp
    K8s[Kubernetes] -->|"HTTP/8034"| Health
    K8s -->|"HTTP/8034"| Info

    V1ClassifyGen --> OrchestratorCore
    V2Detection --> OrchestratorCore
    V2GenDetect --> OrchestratorCore
    V2ChatComp --> OrchestratorCore
    V2TextComp --> OrchestratorCore

    OrchestratorCore --> InputDetection
    OrchestratorCore --> OutputDetection
    InputDetection --> DetectionBatcher
    OutputDetection --> DetectionBatcher

    OrchestratorCore --> TGISClient
    OrchestratorCore --> NLPClient
    OrchestratorCore --> ChunkerClient
    OrchestratorCore --> DetectorClient
    OrchestratorCore --> OpenAIClient

    TGISClient -->|"gRPC/8033<br/>mTLS optional"| TGIS["TGIS Server"]
    NLPClient -->|"gRPC/8085<br/>mTLS optional"| CaikitNLP["Caikit NLP Server"]
    ChunkerClient -->|"gRPC/8085<br/>mTLS optional"| Chunker["Chunker Server"]
    DetectorClient -->|"HTTP/8080<br/>TLS optional"| Detectors["Detector Services<br/>(HAP, toxicity, etc.)"]
    OpenAIClient -->|"HTTP/8080<br/>TLS optional"| OpenAI["OpenAI-compatible API<br/>(vLLM)"]

    OTelTracing -->|"gRPC/4317 or<br/>HTTP/4318"| OTELCollector["OpenTelemetry<br/>Collector"]

    style OrchestratorCore fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style InputDetection fill:#4a90e2,stroke:#333,color:#fff
    style OutputDetection fill:#4a90e2,stroke:#333,color:#fff
    style DetectionBatcher fill:#4a90e2,stroke:#333,color:#fff
    style TGISClient fill:#6baed6,stroke:#333
    style NLPClient fill:#6baed6,stroke:#333
    style ChunkerClient fill:#6baed6,stroke:#333
    style DetectorClient fill:#6baed6,stroke:#333
    style OpenAIClient fill:#6baed6,stroke:#333
    style TLSManager fill:#9ecae1,stroke:#333
    style OTelTracing fill:#9ecae1,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
    style Chunker fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
    style OpenAI fill:#e8e8e8,stroke:#333
    style OTELCollector fill:#e8e8e8,stroke:#333
    style Client fill:#f5a623,stroke:#333
    style K8s fill:#f5a623,stroke:#333
