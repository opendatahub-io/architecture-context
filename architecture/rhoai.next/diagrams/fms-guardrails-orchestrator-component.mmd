graph TB
    subgraph "FMS Guardrails Orchestrator"
        direction TB
        subgraph MainServer["Guardrails API Server (8033/TCP)"]
            Router[Axum Router]
            V1Handler["V1 Handlers<br/>/api/v1/task/*"]
            V2Handler["V2 Handlers<br/>/api/v2/text/*"]
            OpenAIHandler["OpenAI Handlers<br/>/api/v2/chat/completions-detection<br/>/api/v2/text/completions-detection"]
            TLSLayer["TLS/mTLS Layer<br/>(rustls + ring)"]
            Router --> V1Handler
            Router --> V2Handler
            Router --> OpenAIHandler
            TLSLayer --> Router
        end

        subgraph HealthServer["Health Server (8034/TCP, plaintext)"]
            HealthEndpoint["/health"]
            InfoEndpoint["/info"]
        end

        subgraph Orchestration["Orchestration Engine"]
            TaskHandler["Task Handlers<br/>(Handle&lt;Task&gt; trait)"]
            ClassTask["ClassificationWithGenTask"]
            StreamClassTask["StreamingClassificationTask"]
            ChatDetTask["ChatCompletionsDetectionTask"]
            ContentDetTask["ContentDetectionTask"]
            TaskHandler --> ClassTask
            TaskHandler --> StreamClassTask
            TaskHandler --> ChatDetTask
            TaskHandler --> ContentDetTask
        end

        subgraph Clients["Client Layer"]
            GenClient["GenerationClient<br/>(TgisClient | NlpClient)"]
            OpenAIClient["OpenAiClient<br/>(HTTP)"]
            ChunkerClient["ChunkerClient<br/>(gRPC)"]
            DetectorClient["DetectorClient<br/>(HTTP)"]
        end

        V1Handler --> TaskHandler
        V2Handler --> TaskHandler
        OpenAIHandler --> TaskHandler
        TaskHandler --> GenClient
        TaskHandler --> OpenAIClient
        TaskHandler --> ChunkerClient
        TaskHandler --> DetectorClient
        InfoEndpoint --> Clients
    end

    Client[External Client] -->|HTTP/HTTPS| TLSLayer
    Client -->|HTTP| HealthEndpoint

    GenClient -->|gRPC/HTTP2| TGIS["TGIS Server<br/>8033/TCP"]
    GenClient -->|gRPC/HTTP2| CaikitNLP["Caikit NLP<br/>8085/TCP"]
    OpenAIClient -->|HTTP/HTTPS| vLLM["OpenAI-compatible Server<br/>(e.g., vLLM) 8080/TCP"]
    ChunkerClient -->|gRPC/HTTP2| Chunkers["Caikit Chunkers<br/>8085/TCP"]
    DetectorClient -->|HTTP/HTTPS| Detectors["Detector Services<br/>8080/TCP"]

    style MainServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#7ed321,stroke:#333,color:#fff
    style Orchestration fill:#f5a623,stroke:#333,color:#000
    style Clients fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style Chunkers fill:#e8e8e8,stroke:#333
    style Detectors fill:#e8e8e8,stroke:#333
