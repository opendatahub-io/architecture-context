graph TB
    subgraph External["External Clients"]
        Client[AI Application Client]
    end

    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        direction TB
        APIServer["REST API Server<br/>(axum)<br/>Port 8033/TCP"]
        HealthServer["Health Server<br/>Port 8034/TCP"]

        subgraph Handlers["Request Handlers"]
            ClassGen["Classification +<br/>Text Generation"]
            StreamClassGen["Streaming Classification +<br/>Text Generation"]
            ContentDetect["Content Detection"]
            StreamContentDetect["Streaming Content<br/>Detection"]
            GenDetect["Generation +<br/>Detection"]
            ChatDetect["Chat Detection"]
            ContextDetect["Context/Doc Detection"]
            GenOnDetect["Detection on<br/>Generated Text"]
            ChatCompletions["Chat Completions<br/>Detection (OpenAI)"]
            TextCompletions["Text Completions<br/>Detection (OpenAI)"]
        end

        subgraph ClientLayer["Client Abstraction Layer"]
            DetectorClient["Detector Client<br/>(reqwest HTTP)"]
            ChunkerClient["Chunker Client<br/>(tonic gRPC)"]
            TGISClient["TGIS Client<br/>(tonic gRPC)"]
            NLPClient["NLP Client<br/>(tonic gRPC)"]
            OpenAIClient["OpenAI Client<br/>(reqwest HTTP)"]
        end

        subgraph Streaming["Streaming Infrastructure"]
            DetectionBatcher["Detection Batcher"]
            CompletionBatcher["Completion Batcher"]
            BatchStream["Detection Batch Stream"]
        end

        APIServer --> Handlers
        Handlers --> ClientLayer
        Handlers --> Streaming
        Streaming --> ClientLayer
    end

    subgraph Downstream["Downstream Services"]
        Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>8080/TCP REST"]
        Chunkers["Chunker Services<br/>(caikit-based)<br/>8085/TCP gRPC"]
        TGIS["TGIS<br/>8033/TCP gRPC"]
        CaikitNLP["caikit-nlp<br/>8085/TCP gRPC"]
        OpenAISvc["OpenAI-compatible<br/>(vLLM, etc.)<br/>8080/TCP REST"]
    end

    subgraph Observability["Observability"]
        OTelCollector["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>4318/TCP HTTP"]
    end

    Client -->|"HTTP/HTTPS<br/>TLS 1.2+ (optional)"| APIServer
    Client -->|"HTTP (plaintext)"| HealthServer

    DetectorClient -->|"HTTP/HTTPS<br/>TLS (optional)"| Detectors
    ChunkerClient -->|"gRPC<br/>TLS (optional)"| Chunkers
    TGISClient -->|"gRPC<br/>TLS (optional)"| TGIS
    NLPClient -->|"gRPC<br/>TLS (optional)"| CaikitNLP
    OpenAIClient -->|"HTTP/HTTPS<br/>TLS (optional)"| OpenAISvc

    APIServer -.->|"OTLP export"| OTelCollector

    style APIServer fill:#4a90e2,color:#fff
    style HealthServer fill:#4a90e2,color:#fff
    style DetectorClient fill:#6c5ce7,color:#fff
    style ChunkerClient fill:#6c5ce7,color:#fff
    style TGISClient fill:#6c5ce7,color:#fff
    style NLPClient fill:#6c5ce7,color:#fff
    style OpenAIClient fill:#6c5ce7,color:#fff
    style Detectors fill:#e17055,color:#fff
    style Chunkers fill:#e17055,color:#fff
    style TGIS fill:#e17055,color:#fff
    style CaikitNLP fill:#e17055,color:#fff
    style OpenAISvc fill:#e17055,color:#fff
    style OTelCollector fill:#fdcb6e,color:#333
    style DetectionBatcher fill:#00b894,color:#fff
    style CompletionBatcher fill:#00b894,color:#fff
    style BatchStream fill:#00b894,color:#fff
    style Client fill:#dfe6e9,color:#333
