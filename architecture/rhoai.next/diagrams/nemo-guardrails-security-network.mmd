graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform Component"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Internal)"]
        direction TB

        subgraph GuardrailsService["NeMo Guardrails Service<br/>ClusterIP: 8000/TCP HTTP<br/>No built-in auth"]
            direction TB
            Server["FastAPI Server<br/>Port: 8000/TCP<br/>Image: odh-nemo-guardrails (UBI9)"]
            LLMRails["LLMRails Engine"]
            InputRails["Input Rails<br/>(content safety, injection,<br/>topic control, PII)"]
            OutputRails["Output Rails<br/>(hallucination, factcheck,<br/>sensitive data)"]
            EmbeddingEngine["Embedding Providers<br/>(FastEmbed all-MiniLM-L6-v2<br/>ONNX Runtime, baked-in)"]
        end

        ConfigMap["ConfigMap<br/>(config.yaml + rails.co)<br/>Mounted: /app/config/"]
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        direction TB
        vLLM["vLLM (Primary RHOAI)<br/>443/TCP or custom<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (OPENAI_API_KEY)"]
        AzureOpenAI["Azure OpenAI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>api-key header"]
        NIM["NVIDIA NIM<br/>443/TCP or custom<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        Cohere["Cohere API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (COHERE_API_KEY)"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTELCollector["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS 1.2+ (configurable)<br/>No Auth"]
    end

    %% Inbound flow
    Client -->|"HTTP/8000<br/>No TLS (terminated externally)<br/>Header forwarding (X-* headers)<br/>POST /v1/chat/completions<br/>POST /v1/guardrail/checks"| Server

    %% Internal
    ConfigMap -.->|"Volume mount"| Server
    Server --> LLMRails
    LLMRails --> InputRails
    LLMRails --> OutputRails
    LLMRails --> EmbeddingEngine

    %% Egress flows
    LLMRails -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| vLLM
    LLMRails -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| OpenAI
    LLMRails -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| AzureOpenAI
    LLMRails -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NIM
    LLMRails -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Cohere

    %% Observability
    Server -->|"OTLP gRPC/4317 or HTTP/4318<br/>TLS 1.2+ (configurable)<br/>Conditional: OTEL_EXPORTER_OTLP_ENDPOINT"| OTELCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef config fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Server,LLMRails,InputRails,OutputRails,EmbeddingEngine service
    class ConfigMap config
    class vLLM,OpenAI,AzureOpenAI,NIM,Cohere egress
    class OTELCollector observability
