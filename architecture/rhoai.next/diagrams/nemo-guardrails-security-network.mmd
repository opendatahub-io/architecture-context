graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform Component"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (Trust Boundary)"]
        Ingress["Platform Ingress<br/>(HTTPRoute / Gateway API / Route)<br/>Provisioned by rhods-operator<br/>Auth: kube-rbac-proxy / Gateway API"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (ClusterIP)"]
        direction TB

        subgraph ServiceLayer["Service: nemo-guardrails"]
            Service["ClusterIP Service<br/>8000/TCP → 8000/TCP<br/>HTTP, No Encryption<br/>No built-in auth"]
        end

        subgraph PodLayer["Pod: nemo-guardrails-server"]
            Server["FastAPI/Uvicorn Server<br/>Image: UBI9/python-312<br/>Port 8000/TCP (main)<br/>Port 8001/TCP (actions, optional)"]

            subgraph Endpoints["Endpoints"]
                ChatAPI["/v1/chat/completions POST"]
                GuardrailAPI["/v1/guardrail/checks POST"]
                ConfigsAPI["/v1/rails/configs GET"]
                ModelsAPI["/v1/models GET"]
                HealthAPI["/ GET (health)"]
            end

            subgraph InProcess["In-Process Libraries"]
                Presidio["Presidio<br/>(PII detection)"]
                SpaCy["spaCy<br/>(NLP/NER)"]
                FastEmbed["FastEmbed<br/>(local embeddings)"]
            end
        end
    end

    subgraph LLMProviders["EXTERNAL LLM PROVIDERS (Untrusted)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        NIM["NVIDIA NIM<br/>integrate.api.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        AnthropicAPI["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key"]
        AzureOAI["Azure OpenAI<br/>*.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key"]
        CohereAPI["Cohere API<br/>api.cohere.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP credentials"]
    end

    subgraph InfraServices["INFRASTRUCTURE SERVICES (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Auth: username/password"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC (OTLP)<br/>Optional TLS<br/>Auth: None"]
    end

    %% Flows
    Client -->|"HTTP/8000<br/>Authorization header<br/>No encryption (platform terminates TLS)"| Ingress
    Ingress -->|"HTTP/8000<br/>Internal cluster network<br/>Auth enforced at platform level"| Service
    Service --> Server

    Server -->|"HTTPS/443 TLS 1.2+<br/>Bearer Token (forwarded or env var)"| OpenAI
    Server -->|"HTTPS/443 TLS 1.2+<br/>Bearer Token"| NIM
    Server -->|"HTTPS/443 TLS 1.2+<br/>x-api-key header"| AnthropicAPI
    Server -->|"HTTPS/443 TLS 1.2+<br/>api-key header"| AzureOAI
    Server -->|"HTTPS/443 TLS 1.2+<br/>Bearer Token"| CohereAPI
    Server -->|"HTTPS/443 TLS 1.2+<br/>GCP credentials"| VertexAI

    Server -.->|"Redis/6379<br/>Optional TLS<br/>username/password"| Redis
    Server -.->|"gRPC OTLP/4317<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmprovider fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef infra fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inprocess fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class Client external
    class Ingress ingress
    class Service,Server internal
    class ChatAPI,GuardrailAPI,ConfigsAPI,ModelsAPI,HealthAPI internal
    class OpenAI,NIM,AnthropicAPI,AzureOAI,CohereAPI,VertexAI llmprovider
    class Redis,OTel infra
    class Presidio,SpaCy,FastEmbed inprocess
