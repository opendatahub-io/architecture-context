graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>No built-in auth required"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Platform Managed)"]
        direction TB

        subgraph NemoNS["Namespace: {platform-namespace}"]
            Server["NeMo Guardrails Server<br/>Service: nemo-guardrails (ClusterIP)<br/>Port: 8000/TCP HTTP<br/>Image: odh-nemo-guardrails (UBI9)<br/>No built-in auth/authz"]
            ConfigMap["ConfigMap<br/>config.yaml + rails.co<br/>Mounted at /app/config/"]
            Secrets["Secrets (Opaque)<br/>OPENAI_API_KEY<br/>ANTHROPIC_API_KEY<br/>AZURE_OPENAI_API_KEY<br/>COHERE_API_KEY"]
        end
    end

    subgraph LLMProviders["EGRESS - LLM PROVIDERS (Encrypted)"]
        direction TB
        vLLM["vLLM Runtime (RHOAI Primary)<br/>443/TCP or custom<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        AzureOAI["Azure OpenAI<br/>{resource}.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>api-key header"]
        NIM["NVIDIA NIM<br/>443/TCP or custom<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
        AnthropicAPI["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        CohereAPI["Cohere API<br/>api.cohere.com<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
    end

    subgraph Observability["EGRESS - OBSERVABILITY (Configurable)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS 1.2+ (configurable)<br/>No auth<br/>Conditional: OTEL_EXPORTER_OTLP_ENDPOINT"]
    end

    %% Flows
    Client -->|"HTTP/8000<br/>No encryption (TLS terminated externally)<br/>Header forwarding: X-*, Authorization"| Server
    ConfigMap -.->|"Volume mount"| Server
    Secrets -.->|"Env vars"| Server

    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>X-* headers forwarded<br/>(auth tokens redacted)"| vLLM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| OpenAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| AzureOAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NIM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| AnthropicAPI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| CohereAPI

    Server -->|"OTLP gRPC/4317<br/>or HTTP/4318<br/>TLS configurable"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef llmprovider fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Server server
    class ConfigMap config
    class Secrets secret
    class vLLM,OpenAI,AzureOAI,NIM,AnthropicAPI,CohereAPI llmprovider
    class OTEL observability
