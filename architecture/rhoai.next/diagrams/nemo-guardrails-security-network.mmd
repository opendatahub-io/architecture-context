graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform User"]
    end

    subgraph Ingress["PLATFORM INGRESS (TLS Termination)"]
        Gateway["Platform Gateway<br/>kube-rbac-proxy / Gateway API<br/>TLS Termination<br/>Platform AuthN/AuthZ"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Service Network)"]
        direction TB

        subgraph NGService["NeMo Guardrails Service"]
            NGServer["NeMo Guardrails Server<br/>ClusterIP: 8000/TCP HTTP<br/>No built-in auth/TLS<br/>Auth header passthrough"]
        end

        subgraph ActionsOpt["Optional"]
            ActionsServer["Actions Server<br/>8001/TCP HTTP"]
        end

        subgraph LocalProcessing["In-Process Libraries"]
            Presidio["Presidio<br/>(PII Detection)"]
            SpaCy["spaCy + en_core_web_lg<br/>(NLP/NER)"]
            FastEmbed["FastEmbed/ONNX<br/>(Local Embeddings)"]
            LangChain["LangChain<br/>(LLM Abstraction)"]
        end
    end

    subgraph ExternalLLM["EXTERNAL LLM PROVIDERS (Egress)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        NIM["NVIDIA NIM<br/>integrate.api.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key"]
        AzureOAI["Azure OpenAI<br/>*.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key"]
        Cohere["Cohere API<br/>api.cohere.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP credentials"]
    end

    subgraph OptionalServices["OPTIONAL EXTERNAL SERVICES"]
        Redis["Redis<br/>6379/TCP<br/>Redis Protocol<br/>Optional TLS<br/>Auth: user/pass"]
        OTelCollector["OTel Collector<br/>4317/TCP gRPC OTLP<br/>Optional TLS<br/>Auth: None"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS (platform)<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8000<br/>Plaintext (cluster-internal)<br/>Auth header forwarded"| NGServer

    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (forwarded)"| OpenAI
    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NIM
    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key"| Anthropic
    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key"| AzureOAI
    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Cohere
    NGServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| VertexAI

    NGServer -.->|"Redis/6379<br/>Optional TLS<br/>user/pass"| Redis
    NGServer -.->|"gRPC/4317 OTLP<br/>Optional TLS"| OTelCollector

    NGServer --- Presidio
    NGServer --- SpaCy
    NGServer --- FastEmbed
    NGServer --- LangChain

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef locallib fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class Client external
    class Gateway ingress
    class NGServer,ActionsServer internal
    class OpenAI,NIM,Anthropic,AzureOAI,Cohere,VertexAI llmprovider
    class Redis,OTelCollector optional
    class Presidio,SpaCy,FastEmbed,LangChain locallib
