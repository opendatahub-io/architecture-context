graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform User"]
    end

    subgraph Ingress["PLATFORM INGRESS (DMZ)"]
        IngressCtrl["Platform Ingress Controller<br/>Gateway API / OpenShift Route<br/>TLS Termination<br/>kube-rbac-proxy / AuthPolicy"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NemoService["NeMo Guardrails Service"]
            Server["nemo-guardrails-server<br/>ClusterIP 8000/TCP HTTP<br/>No built-in auth<br/>FastAPI/Uvicorn on UBI9"]

            subgraph RailsPipelines["Rails Pipelines"]
                InputRails["Input Rails<br/>(content safety, jailbreak,<br/>topic, PII/SDD)"]
                OutputRails["Output Rails<br/>(content safety, hallucination,<br/>SDD, topic)"]
            end

            subgraph LocalLibs["In-Process Libraries"]
                Presidio["Presidio<br/>(PII Detection)"]
                SpaCy["spaCy + en_core_web_lg<br/>(NLP/NER)"]
                FastEmbed["FastEmbed<br/>(Local Embeddings)"]
                AnnoyIdx["Annoy Index<br/>(ANN Search)"]
            end
        end

        ActionsServer["Actions Server (optional)<br/>8001/TCP HTTP<br/>No auth"]
    end

    subgraph LLMProviders["EGRESS - LLM PROVIDERS (Encrypted)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        NIM["NVIDIA NIM<br/>integrate.api.nvidia.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key"]
        Azure["Azure OpenAI<br/>*.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key header"]
        Cohere["Cohere API<br/>api.cohere.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCP credentials"]
    end

    subgraph InfraServices["EGRESS - INFRASTRUCTURE (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Auth: user/pass"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>Optional TLS<br/>Auth: None"]
    end

    %% External → Ingress
    Client -->|"HTTPS<br/>TLS (platform-managed)<br/>Bearer Token"| IngressCtrl

    %% Ingress → Service
    IngressCtrl -->|"HTTP/8000<br/>No encryption (cluster-internal)<br/>Auth header forwarded"| Server

    %% Internal flows
    Server --> InputRails
    Server --> OutputRails
    InputRails --> LocalLibs
    OutputRails --> LocalLibs

    %% Egress to LLM providers
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (forwarded or env var)"| OpenAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NIM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key"| Anthropic
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| Azure
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Cohere
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| Vertex

    %% Egress to infrastructure
    Server -.->|"6379/TCP<br/>Redis protocol<br/>Optional TLS"| Redis
    Server -.->|"4317/TCP<br/>gRPC OTLP<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infra fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef locallib fill:#e8e8e8,stroke:#999

    class Client external
    class IngressCtrl ingress
    class Server,InputRails,OutputRails,ActionsServer internal
    class Presidio,SpaCy,FastEmbed,AnnoyIdx locallib
    class OpenAI,NIM,Anthropic,Azure,Cohere,Vertex llmprovider
    class Redis,OTel infra
