graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(User / Platform Service)"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        PlatformIngress["Platform Ingress / Route<br/>TLS Termination (platform-managed)<br/>No in-repo ingress definition"]
    end

    subgraph Application["APPLICATION (Stateless Service)"]
        direction TB

        subgraph NS_Guardrails["Namespace: {deployment-namespace}"]
            Server["NeMo Guardrails Server<br/>Service: nemo-guardrails (ClusterIP)<br/>Port: 8000/TCP HTTP<br/>Image: UBI9 Python 3.12<br/>No K8s API access"]
        end

        subgraph AuthHandling["Auth Header Isolation"]
            AuthNote["Authorization header: BLOCKED<br/>(K8s/proxy auth — not forwarded)<br/>X-Authorization: FORWARDED<br/>(as Authorization to LLM provider)<br/>Tokens REDACTED in logs"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        LLMProvider["LLM Provider API<br/>(OpenAI / NIM / Azure /<br/>Anthropic / Cohere / vLLM)<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        OTELCollector["OpenTelemetry Collector<br/>Port: Configurable<br/>gRPC/HTTP TLS<br/>Auth: None<br/>(Optional)"]
    end

    subgraph BuildTimeOnly["BUILD-TIME ONLY (not runtime)"]
        HuggingFace["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token (optional)<br/>Models baked into image"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS (platform)<br/>Bearer Token"| PlatformIngress
    PlatformIngress -->|"HTTP/8000<br/>No encryption (internal)<br/>X-Authorization: Bearer"| Server
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>(from X-Authorization)"| LLMProvider
    Server -.->|"gRPC/HTTP<br/>TLS (configurable)<br/>No auth"| OTELCollector

    Server --- AuthNote

    %% Build-time only (dashed)
    Server -.->|"BUILD-TIME ONLY<br/>HTTPS/443 TLS 1.2+"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#f0f0f0,stroke:#aaa,stroke-width:1px,stroke-dasharray: 5 5
    classDef authinfo fill:#e6e0f8,stroke:#9673a6,stroke-width:1px

    class Client external
    class PlatformIngress ingress
    class Server application
    class LLMProvider,OTELCollector externalservice
    class HuggingFace buildtime
    class AuthNote authinfo
