graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["OpenShift Route / HTTPRoute<br/>TLS Termination<br/>(not defined in repo)"]
    end

    subgraph Internal["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph GuardrailsSvc["nemo-guardrails-server (ClusterIP)"]
            Server["NeMo Guardrails Server<br/>:8000/TCP HTTP (plaintext)<br/>Auth: Bearer passthrough<br/>Image: UBI9/python-312"]

            subgraph ServerEndpoints["Endpoints"]
                EP1["POST /v1/chat/completions<br/>(Bearer passthrough)"]
                EP2["POST /v1/guardrail/checks<br/>(Bearer passthrough)"]
                EP3["GET /v1/rails/configs<br/>(No auth)"]
                EP4["GET /v1/models<br/>(Bearer passthrough)"]
                EP5["GET / (Health, no auth)"]
            end

            subgraph MLModels["Embedded ML Models (in-process)"]
                SpaCy["spaCy en_core_web_lg"]
                ST["Sentence Transformers"]
                FE["FastEmbed (ONNX)"]
                NLTK["NLTK punkt"]
            end
        end

        subgraph ActionsSvc["actions-server (ClusterIP, optional)"]
            Actions["Actions Server<br/>:8001/TCP HTTP (plaintext)<br/>Auth: None"]
        end
    end

    subgraph OptionalInternal["OPTIONAL INTERNAL SERVICES"]
        Redis["Redis<br/>:6379/TCP Redis protocol<br/>Encryption: None<br/>Auth: user/pass (optional)"]
        OTel["OpenTelemetry Collector<br/>:4317/TCP gRPC or :4318/TCP HTTP<br/>Encryption: Configurable<br/>Auth: None"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>:443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        Azure["Azure OpenAI<br/>{endpoint}.openai.azure.com<br/>:443/TCP HTTPS TLS 1.2+<br/>Auth: API Key (api-key)"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>:443/TCP HTTPS TLS 1.2+<br/>Auth: API Key (x-api-key)"]
        Cohere["Cohere API<br/>api.cohere.com<br/>:443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        NIM["NVIDIA NIM<br/>(configurable)<br/>:443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        VLLM["vLLM Server<br/>(configurable)<br/>HTTP/HTTPS<br/>Auth: Bearer Token"]
    end

    %% Flows
    Client -->|"HTTP :8000<br/>plaintext<br/>Bearer Token"| Route
    Route -->|"HTTP :8000<br/>plaintext (internal)"| Server
    Server -->|"HTTP :8001<br/>plaintext<br/>No auth"| Actions

    Server -.->|"Redis :6379<br/>No TLS<br/>user/pass optional"| Redis
    Server -.->|"OTLP :4317/:4318<br/>gRPC or HTTP"| OTel

    Server -->|"HTTPS :443<br/>TLS 1.2+<br/>Bearer Token fwd"| OpenAI
    Server -->|"HTTPS :443<br/>TLS 1.2+<br/>API Key fwd"| Azure
    Server -->|"HTTPS :443<br/>TLS 1.2+<br/>API Key fwd"| Anthropic
    Server -->|"HTTPS :443<br/>TLS 1.2+<br/>Bearer Token fwd"| Cohere
    Server -->|"HTTPS :443<br/>TLS 1.2+<br/>Bearer Token fwd"| NIM
    Server -->|"HTTP/HTTPS<br/>Bearer Token fwd"| VLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,stroke-dasharray:5
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class Server,Actions internal
    class Redis,OTel optional
    class OpenAI,Azure,Anthropic,Cohere,NIM,VLLM externalservice
