graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (TLS Termination)"]
        Gateway["Platform Gateway<br/>HTTPRoute (RHOAI 3.x) / Route (RHOAI 2.x)<br/>TLS Termination<br/>kube-rbac-proxy / Gateway API Auth"]
    end

    subgraph Application["APPLICATION (Internal Cluster Network)"]
        direction TB

        subgraph NS_Deploy["Namespace: {deployment-namespace}"]
            Server["NeMo Guardrails Server<br/>Service: nemo-guardrails-server (ClusterIP)<br/>Port: 8000/TCP HTTP (plaintext)<br/>Runtime: Python 3.12 (UBI9)<br/>No built-in auth / No built-in TLS"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES (Optional)"]
        LLM["LLM Inference Service<br/>(vLLM / NIM / OpenAI-compatible)<br/>443/TCP HTTPS<br/>Bearer Token (forwarded)"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS 1.2+"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress — All Optional)"]
        direction TB
        ActiveFence["ActiveFence<br/>443/TCP HTTPS<br/>API Key"]
        CiscoAI["Cisco AI Defense<br/>443/TCP HTTPS<br/>API Key"]
        CrowdStrike["CrowdStrike AIDR<br/>443/TCP HTTPS<br/>Bearer Token"]
        Pangea["Pangea AI Guard<br/>443/TCP HTTPS<br/>Bearer Token"]
        Patronus["Patronus<br/>443/TCP HTTPS<br/>API Key"]
        MoreProviders["+ 11 more providers<br/>443/TCP HTTPS<br/>API Key / Bearer Token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"HTTP/8000<br/>Plaintext<br/>No Auth (platform-handled)"| Server
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (forwarded)"| LLM
    Server -.->|"OTLP/4317 or 4318<br/>TLS 1.2+"| OTel
    Server -.->|"Redis/6379<br/>Optional TLS<br/>Password"| Redis
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| ActiveFence
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| CiscoAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| CrowdStrike
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Pangea
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Patronus
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Various Auth"| MoreProviders

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Server application
    class LLM,OTel,Redis internal
    class ActiveFence,CiscoAI,CrowdStrike,Pangea,Patronus,MoreProviders externalservice
