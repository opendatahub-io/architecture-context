graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["planner-gpu-reader<br/>(ClusterRoleBinding)<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["planner-gpu-reader<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core (v1)<br/>nodes"]
    end

    subgraph Verbs["Allowed Verbs"]
        NodeVerbs["list"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"list"| Nodes
    Nodes --- NodeVerbs

    subgraph ImplicitPermissions["Implicit Permissions (SA Token)"]
        direction TB
        K8sDeploy["Kubernetes API<br/>kubectl apply/get/delete<br/>InferenceService CRs"]
        K8sNodes["Kubernetes API<br/>Node GPU detection<br/>(nvidia.com/gpu.product labels)"]
    end

    SA -->|"SA token auth<br/>HTTPS/6443"| K8sDeploy
    SA -->|"via ClusterRole"| K8sNodes

    subgraph Secrets["Secrets Used"]
        PlannerSecrets["planner-secrets (Opaque)<br/>├─ postgres-password<br/>└─ model-catalog-token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph ConfigMaps["ConfigMaps"]
        PlannerConfig["planner-config<br/>├─ PLANNER_BENCHMARK_SOURCE<br/>├─ MODEL_CATALOG_URL<br/>└─ MODEL_CATALOG_SOURCE_ID"]
        ServiceCA["planner-service-ca<br/>OpenShift Service CA injection<br/>/etc/pki/service-ca"]
    end

    SA -.->|"mounts"| PlannerSecrets
    SA -.->|"mounts"| PlannerConfig
    SA -.->|"mounts"| ServiceCA

    subgraph AuthEndpoints["Endpoint Authentication"]
        direction TB
        NoAuth["⚠ /api/v1/* (all 29 endpoints)<br/>Auth: NONE<br/>All publicly accessible"]
        RouteAuth["OpenShift Routes<br/>TLS edge termination only<br/>No AuthN/AuthZ"]
        MCatAuth["Model Catalog API<br/>Auth: Bearer token<br/>(from planner-secrets)"]
        PGAuth["PostgreSQL<br/>Auth: Password<br/>(from planner-secrets)"]
        HFAuth["HuggingFace Hub<br/>Auth: Bearer HF_TOKEN<br/>(optional, for gated models)"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Nodes fill:#7ed321,stroke:#333,color:#fff
    style NodeVerbs fill:#d5e8d4,stroke:#82b366

    style K8sDeploy fill:#e1d5e7,stroke:#9673a6
    style K8sNodes fill:#e1d5e7,stroke:#9673a6

    style PlannerSecrets fill:#f8cecc,stroke:#b85450
    style PlannerConfig fill:#fff2cc,stroke:#d6b656
    style ServiceCA fill:#fff2cc,stroke:#d6b656

    style NoAuth fill:#f8cecc,stroke:#b85450,stroke-width:3px
    style RouteAuth fill:#ffe6cc,stroke:#d79b00
    style MCatAuth fill:#d5e8d4,stroke:#82b366
    style PGAuth fill:#d5e8d4,stroke:#82b366
    style HFAuth fill:#d5e8d4,stroke:#82b366
