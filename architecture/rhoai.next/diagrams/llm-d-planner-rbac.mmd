graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["planner-gpu-reader<br/>(Cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        CR["planner-gpu-reader"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core (v1)<br/>nodes"]
    end

    subgraph AllowedVerbs["Allowed Operations"]
        List["list"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"list"| Nodes
    Nodes --- List

    subgraph AuthEndpoints["Application-Level Auth (HMAC)"]
        direction LR
        UploadBenchmarks["/api/v1/db/upload-benchmarks<br/>POST<br/>x-admin-password header"]
        ResetDB["/api/v1/db/reset<br/>POST<br/>x-admin-password header"]
        VerifyAdmin["/api/v1/db/verify-admin<br/>POST<br/>x-admin-password header"]
    end

    subgraph UnauthEndpoints["Unauthenticated Endpoints"]
        direction LR
        AllOther["All other /api/v1/* endpoints<br/>No authentication<br/>Relies on network isolation"]
    end

    subgraph Secrets["Secrets Referenced"]
        PlannerSecrets["planner-secrets (Opaque)<br/>Keys: postgres-password, hf-token,<br/>model-catalog-token, vertex-project-id,<br/>vertex-region, gcp-credentials-json,<br/>openai-api-key, openai-base-url,<br/>db-admin-password<br/>Provisioned: Manual (deploy-all.sh)<br/>Auto-Rotate: No"]
        ServiceCAConfig["planner-service-ca (ConfigMap)<br/>OpenShift service-serving CA bundle<br/>Provisioned: service-ca operator<br/>Auto-Rotate: Yes (auto-injected)"]
    end

    SA -.->|"mounts"| PlannerSecrets
    SA -.->|"mounts"| ServiceCAConfig

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Nodes fill:#7ed321,stroke:#333,color:#fff
    style List fill:#d5e8d4,stroke:#82b366

    style UploadBenchmarks fill:#ffe6cc,stroke:#d79b00
    style ResetDB fill:#ffe6cc,stroke:#d79b00
    style VerifyAdmin fill:#ffe6cc,stroke:#d79b00
    style AllOther fill:#f8cecc,stroke:#b85450

    style PlannerSecrets fill:#e1d5e7,stroke:#9673a6
    style ServiceCAConfig fill:#e1d5e7,stroke:#9673a6
