graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["planner-gpu-reader<br/>(ClusterRoleBinding)<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["planner-gpu-reader<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core (v1)<br/>nodes"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"list"| Nodes

    subgraph SecretsAccess["Secrets & Credentials"]
        PlannerSecrets["planner-secrets (Opaque)<br/>- POSTGRES_PASSWORD<br/>- MODEL_CATALOG_TOKEN<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        ServiceCA["planner-service-ca (ConfigMap)<br/>- service-ca.crt<br/>Provisioned: OpenShift service-ca operator<br/>Auto-Rotate: Yes"]
    end

    SA -.->|"mounts"| PlannerSecrets
    SA -.->|"mounts"| ServiceCA

    subgraph MissingRBAC["RBAC Gap (Not Defined in Manifests)"]
        direction TB
        Note["WARNING: Backend performs kubectl apply/delete<br/>for the following resources but no RBAC<br/>is defined in repository manifests:"]
        KServeCRD["serving.kserve.io<br/>inferenceservices<br/>Needed: create, get, list, delete"]
        HPACRD["autoscaling<br/>horizontalpodautoscalers<br/>Needed: create, get, list, delete"]
        SMon["monitoring.coreos.com<br/>servicemonitors<br/>Needed: create, get, list, delete"]
        CM["core (v1)<br/>configmaps<br/>Needed: create, get, list, delete"]
    end

    SA -.->|"needs but<br/>not defined"| KServeCRD
    SA -.->|"needs but<br/>not defined"| HPACRD
    SA -.->|"needs but<br/>not defined"| SMon
    SA -.->|"needs but<br/>not defined"| CM

    subgraph AuthEndpoints["Endpoint Authentication"]
        NoAuth["ALL 27 /api/v1/* endpoints<br/>Auth: NONE<br/>Including destructive:<br/>- POST /api/v1/db/reset<br/>- POST /api/v1/deploy-to-cluster<br/>- DELETE /api/v1/deployments/{id}<br/>- POST /api/v1/db/upload-benchmarks"]
    end

    %% Styles
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#5b9bd5,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style Nodes fill:#7ed321,stroke:#333
    style PlannerSecrets fill:#e6b8af,stroke:#333
    style ServiceCA fill:#d5e8d4,stroke:#333
    style Note fill:#f8cecc,stroke:#b85450,color:#333
    style KServeCRD fill:#f8cecc,stroke:#b85450
    style HPACRD fill:#f8cecc,stroke:#b85450
    style SMon fill:#f8cecc,stroke:#b85450
    style CM fill:#f8cecc,stroke:#b85450
    style NoAuth fill:#f8cecc,stroke:#b85450,stroke-width:3px
