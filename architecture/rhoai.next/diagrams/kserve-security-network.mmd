graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS LAYER"]
        Gateway["Gateway / Ingress Controller<br/>443/TCP → 80 or 8443/TCP<br/>TLS 1.2+<br/>HTTPRoute / VirtualService / Ingress"]
        OSRoute["OpenShift Route<br/>443/TCP HTTPS<br/>TLS Reencrypt<br/>InferenceGraph access"]
    end

    subgraph ServiceLayer["SERVICE LAYER (Kubernetes Internal)"]
        direction TB

        subgraph ISVCPod["InferenceService Pod"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS TLS<br/>Auth: SubjectAccessReview"]
            ModelServer["Model Server<br/>8080/TCP REST V1/V2/OpenAI<br/>8081/TCP gRPC V2<br/>HTTP (pod-local, no auth)"]
            AgentSidecar["kserve-agent<br/>9081/TCP proxy<br/>Request logger + batcher"]
            StorageInit["storage-initializer<br/>(init container)<br/>Model download at start"]
        end

        subgraph LLMStack["LLMInferenceService Stack"]
            SchedulerEPP["Scheduler EPP<br/>gRPC + metrics + zmq<br/>TLS (self-signed)<br/>Auth: Bearer tokenReview"]
            vLLMPod["vLLM Workload<br/>8000/TCP HTTPS<br/>TLS (self-signed)"]
            RoutingSidecar["Routing Sidecar<br/>Disaggregated P/D"]
            InfPool["InferencePool CRD<br/>Gateway API ext"]
        end

        subgraph IGRouter["InferenceGraph"]
            Router["kserve-router<br/>8080/TCP HTTP (opt TLS)<br/>Auth: Optional bearer<br/>TokenReview + SAR"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE (opendatahub namespace)"]
        KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>8080/TCP metrics<br/>9443/TCP webhook (TLS)"]
        LLMCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>8443/TCP secure metrics (HTTPS)<br/>9443/TCP webhook (TLS)"]
        LMCtrl["localmodel-controller<br/>SA: kserve-localmodel-ctrl<br/>9443/TCP webhook (TLS)"]
        LMAgent["localmodelnode-agent<br/>DaemonSet on worker nodes<br/>Creates download Jobs"]

        WebhookSvcs["Webhook Services<br/>443/TCP → 9443/TCP<br/>TLS: OpenShift serving certs<br/>Auth: K8s API server mTLS"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>Auth: kube-rbac-proxy"]
    end

    subgraph K8sControl["KUBERNETES API"]
        K8sAPI["kube-apiserver<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount tokens"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCS SA JSON"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Azure creds / Managed ID"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF_TOKEN (optional)"]
        HDFS["HDFS Namenode<br/>8020/TCP RPC<br/>Auth: Kerberos keytab"]
    end

    subgraph PlatformDeps["PLATFORM DEPENDENCIES"]
        Knative["Knative Serving<br/>443/TCP HTTPS"]
        Istio["Istio<br/>443/TCP HTTPS<br/>VirtualService, DestinationRule"]
        GatewayAPIDep["Gateway API<br/>443/TCP HTTPS<br/>HTTPRoute, Gateway"]
        KEDADep["KEDA<br/>443/TCP HTTPS<br/>ScaledObject"]
        LWS["LeaderWorkerSet<br/>443/TCP HTTPS"]
        PromOp["Prometheus Operator<br/>443/TCP HTTPS<br/>PodMonitor, ServiceMonitor"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer/OAuth"| Gateway
    Client -->|"HTTPS/443<br/>TLS Reencrypt"| OSRoute

    %% Ingress → Service Layer
    Gateway -->|"HTTP/80 or HTTPS/8443<br/>None or TLS"| RBACProxy
    Gateway -->|"gRPC/TLS<br/>Bearer token"| SchedulerEPP
    OSRoute -->|"HTTP/8080 or HTTPS<br/>Optional TLS"| Router

    %% InferenceService Pod internal
    RBACProxy -->|"HTTP/8080<br/>pod-local, no auth"| ModelServer
    SchedulerEPP -->|"HTTPS/8000<br/>TLS self-signed"| vLLMPod

    %% Router → InferenceServices
    Router -->|"HTTP/80<br/>in-mesh mTLS"| ModelServer

    %% Storage egress
    StorageInit -->|"HTTPS/443<br/>Provider creds"| S3
    StorageInit -->|"HTTPS/443<br/>GCS SA JSON"| GCS
    StorageInit -->|"HTTPS/443<br/>Azure creds"| Azure
    StorageInit -->|"HTTPS/443<br/>HF_TOKEN"| HFHub
    StorageInit -->|"RPC/8020<br/>Kerberos"| HDFS
    vLLMPod -->|"HTTPS/443<br/>Provider creds"| S3

    %% Control Plane → K8s API
    KServeCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    LLMCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    LMCtrl -->|"HTTPS/443<br/>SA token"| K8sAPI
    LMAgent -->|"HTTPS/443<br/>SA token"| K8sAPI

    %% Control Plane → Platform Dependencies
    KServeCtrl -.->|"HTTPS/443"| Knative
    KServeCtrl -.->|"HTTPS/443"| Istio
    KServeCtrl -.->|"HTTPS/443"| KEDADep
    LLMCtrl -.->|"HTTPS/443"| GatewayAPIDep
    LLMCtrl -.->|"HTTPS/443"| Istio
    LLMCtrl -.->|"HTTPS/443"| LWS
    LLMCtrl -.->|"HTTPS/443"| PromOp

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,OSRoute ingress
    class RBACProxy,ModelServer,AgentSidecar,StorageInit,SchedulerEPP,vLLMPod,RoutingSidecar,InfPool,Router service
    class KServeCtrl,LLMCtrl,LMCtrl,LMAgent,WebhookSvcs,MetricsSvc controlplane
    class K8sAPI k8s
    class S3,GCS,Azure,HFHub,HDFS extsvc
    class Knative,Istio,GatewayAPIDep,KEDADep,LWS,PromOp platform
