graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / OpenShift Router<br/>443/TCP → 80/TCP<br/>TLS 1.2+ (SIMPLE)<br/>VirtualService / HTTPRoute / Route"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph ISVCPath["InferenceService Path"]
            OAuthProxy["oauth-proxy / kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift OAuth / RBAC SAR"]
            PredictorPod["Predictor Pod<br/>8080/TCP HTTP (localhost)<br/>+ kserve-agent sidecar (9081)<br/>+ storage-initializer (init)"]
            TransformerPod["Transformer Pod (optional)<br/>8080/TCP HTTP"]
            ExplainerPod["Explainer Pod (optional)<br/>8080/TCP HTTP"]
        end

        subgraph LLMPath["LLMInferenceService Path"]
            Scheduler["InferencePool Scheduler<br/>gRPC + metrics + zmq<br/>TLS<br/>Auth: Bearer (metrics)"]
            LLMWorkload["LLM Workload Pod (vLLM)<br/>8000/TCP HTTPS (self-signed)<br/>+ routing sidecar (P/D)<br/>+ tokenizer sidecar (UDS)"]
            LLMMultiNode["LeaderWorkerSet (multi-node)<br/>8000/TCP HTTPS (self-signed)<br/>Pipeline/Data parallelism"]
        end

        subgraph IGPath["InferenceGraph Path"]
            IGRouter["kserve-router<br/>8080/TCP HTTP/HTTPS<br/>Auth: Bearer → TokenReview"]
            ISvcEndpoints["InferenceService endpoints<br/>80/TCP HTTP, mTLS<br/>DAG: splitter/switch/ensemble/sequence"]
        end

        subgraph ControlPlane["Control Plane (opendatahub namespace)"]
            KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>8080 metrics, 9443 webhook, 8081 health"]
            LLMISVCCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>8080 metrics, 9443 webhook, 8081 health"]
            LocalModelCtrl["kserve-localmodel-controller<br/>SA: kserve-localmodel-controller<br/>8080 metrics, 9443 webhook, 8081 health"]
            LocalModelAgent["kserve-localmodelnode-agent<br/>SA: kserve-localmodelnode-agent<br/>No network ports"]
        end

        subgraph WebhookSvcs["Webhook Services"]
            WebhookSvc["kserve-webhook-server-service<br/>ClusterIP 443→9443<br/>TLS (service-ca on OCP)"]
            LLMWebhookSvc["llmisvc-webhook-server-service<br/>ClusterIP 443→9443<br/>TLS (service-ca on OCP)"]
        end
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS, TLS 1.2+<br/>AWS IAM / Access Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS, TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS, TLS 1.2+<br/>Azure AD / SAS Token"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS, TLS 1.2+<br/>HF Token"]
        OCI["OCI Registries<br/>443/TCP HTTPS, TLS 1.2+<br/>Registry credentials"]
        LogEndpoint["Log Endpoints<br/>configurable HTTP/HTTPS<br/>TLS optional"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress → Service Mesh paths
    Gateway -->|"HTTP/80<br/>mTLS STRICT"| OAuthProxy
    Gateway -->|"gRPC<br/>TLS"| Scheduler
    Gateway -->|"HTTP(S)/8080<br/>TLS optional"| IGRouter

    %% InferenceService path
    OAuthProxy -->|"HTTP/8080<br/>localhost (no TLS)"| PredictorPod

    %% LLM path
    Scheduler -->|"HTTPS/8000<br/>TLS (self-signed)"| LLMWorkload
    Scheduler -->|"HTTPS/8000<br/>TLS (self-signed)"| LLMMultiNode

    %% InferenceGraph path
    IGRouter -->|"HTTPS/6443<br/>TokenReview"| K8sAPI
    IGRouter -->|"HTTP/80<br/>mTLS"| ISvcEndpoints

    %% Controllers → K8s API
    KServeCtrl -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    LLMISVCCtrl -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    LocalModelCtrl -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    LocalModelAgent -->|"HTTPS/6443<br/>SA Token"| K8sAPI

    %% Webhook services
    K8sAPI -->|"HTTPS/443<br/>AdmissionReview"| WebhookSvc
    K8sAPI -->|"HTTPS/443<br/>AdmissionReview"| LLMWebhookSvc

    %% Egress (storage-initializer)
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| GCS
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| Azure
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| OCI
    PredictorPod -.->|"HTTP(S)<br/>TLS optional"| LogEndpoint

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef webhook fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class OAuthProxy,PredictorPod,TransformerPod,ExplainerPod servicemesh
    class Scheduler,LLMWorkload,LLMMultiNode servicemesh
    class IGRouter,ISvcEndpoints servicemesh
    class KServeCtrl,LLMISVCCtrl,LocalModelCtrl,LocalModelAgent controlplane
    class WebhookSvc,LLMWebhookSvc webhook
    class K8sAPI k8s
    class S3,GCS,Azure,HuggingFace,OCI,LogEndpoint externalservice
