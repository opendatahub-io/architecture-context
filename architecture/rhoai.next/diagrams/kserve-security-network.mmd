graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS LAYER (DMZ)"]
        Gateway["Istio Gateway / OpenShift Router<br/>443/TCP → 80/TCP<br/>TLS 1.2+ termination<br/>RequestAuthentication (JWT)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>8080 (metrics) | 9443 (webhook) | 8081 (health)"]
            LLMISVCCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>8080 (metrics) | 9443 (webhook) | 8081 (health)"]
            LocalModelCtrl["localmodel-controller<br/>SA: kserve-localmodel-controller<br/>8080 (metrics) | 9443 (webhook) | 8081 (health)"]
            LocalModelAgent["localmodelnode-agent<br/>SA: kserve-localmodelnode-agent<br/>(no network ports)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OAuthProxy["oauth-proxy / kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift OAuth / SAR"]
            Predictor["Predictor Pod<br/>8080/TCP HTTP<br/>+ storage-initializer init<br/>+ kserve-agent sidecar (9081)"]
            Transformer["Transformer Pod<br/>8080/TCP HTTP"]
            Explainer["Explainer Pod<br/>8080/TCP HTTP"]
            LLMWorkload["LLM Workload Pod(s)<br/>8000/TCP HTTPS (self-signed)<br/>+ routing sidecar<br/>+ tokenizer sidecar (UDS)"]
            LLMScheduler["LLM Scheduler (EPP)<br/>gRPC + metrics<br/>TLS<br/>Bearer Token (metrics)"]
            IGRouter["InferenceGraph Router<br/>8080/TCP HTTP/HTTPS<br/>Bearer Token → TokenReview"]
        end

        subgraph Webhooks["Webhook Services"]
            WebhookSvc["kserve-webhook-server-service<br/>443→9443/TCP HTTPS<br/>TLS (service-ca)"]
            LLMWebhookSvc["llmisvc-webhook-server-service<br/>443→9443/TCP HTTPS<br/>TLS (service-ca)"]
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token"]
        Istio["Istio / OSSM<br/>mTLS STRICT<br/>VirtualService + DestinationRule"]
        Knative["Knative Serving<br/>Serverless autoscaling"]
        ServiceCA["OpenShift service-ca<br/>Certificate injection"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM / Access Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Azure AD / SAS Token"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token"]
        OCI["OCI Registries<br/>443/TCP HTTPS TLS 1.2+<br/>Registry credentials"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| Gateway

    %% Ingress → Service Mesh
    Gateway -->|"HTTP/80 or HTTPS/443<br/>mTLS STRICT<br/>Service Identity"| OAuthProxy
    Gateway -->|"HTTPS/443<br/>HTTPRoute<br/>TLS"| LLMScheduler
    Gateway -->|"HTTP(S)/8080<br/>Route (OCP)"| IGRouter

    %% Auth proxy → Inference
    OAuthProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| Predictor

    %% LLM flow
    LLMScheduler -->|"HTTPS/8000<br/>Self-signed TLS"| LLMWorkload

    %% InferenceGraph routing
    IGRouter -->|"HTTP/80<br/>mTLS (mesh)"| Predictor

    %% Controllers → K8s API
    KServeCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LLMISVCCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LocalModelCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LocalModelAgent -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% K8s API → Webhooks
    K8sAPI -->|"HTTPS/443<br/>TLS (service-ca)<br/>Client cert"| WebhookSvc
    K8sAPI -->|"HTTPS/443<br/>TLS (service-ca)<br/>Client cert"| LLMWebhookSvc

    %% Model download (egress)
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| GCS
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure creds"| Azure
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HuggingFace
    Predictor -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef webhook fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class KServeCtrl,LLMISVCCtrl,LocalModelCtrl,LocalModelAgent,OAuthProxy,Predictor,Transformer,Explainer,LLMWorkload,LLMScheduler,IGRouter servicemesh
    class K8sAPI,Istio,Knative,ServiceCA cluster
    class S3,GCS,Azure,HuggingFace,OCI externalservice
    class WebhookSvc,LLMWebhookSvc webhook
