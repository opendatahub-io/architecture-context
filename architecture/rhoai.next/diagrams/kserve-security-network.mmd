graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway / Route Layer)"]
        direction TB
        HTTPRoute["HTTPRoute / Gateway API<br/>443/TCP → internal<br/>TLS 1.2+ (Gateway-terminated)<br/>Used by: ISVC, LLMISVC"]
        VirtualService["Istio VirtualService<br/>443/TCP → internal<br/>TLS 1.2+ (Istio-terminated)<br/>Used by: ISVC"]
        OSRoute["OpenShift Route<br/>443/TCP<br/>TLS Reencrypt<br/>Used by: InferenceGraph"]
        K8sIngress["Kubernetes Ingress<br/>80|443/TCP<br/>Ingress controller TLS<br/>Used by: ISVC"]
    end

    subgraph AuthLayer["AUTH PROXY LAYER (ODH)"]
        AuthProxy["kube-rbac-proxy / OAuth proxy<br/>8443/TCP HTTPS<br/>OpenShift Serving Cert<br/>SubjectAccessReview"]
    end

    subgraph Controllers["CONTROLLER NAMESPACE (opendatahub/kserve)"]
        direction TB

        ControllerMgr["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>9443/TCP webhook (HTTPS)<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)<br/>FIPS: Yes"]

        LLMCtrl["llmisvc-controller<br/>SA: llmisvc-controller-manager<br/>8443/TCP metrics (HTTPS TLS)<br/>9443/TCP webhook (HTTPS)<br/>8081/TCP health (HTTP)<br/>FIPS: Yes"]

        LocalModelCtrl["localmodel-controller<br/>SA: kserve-localmodel-controller-manager<br/>8080/TCP, 9443/TCP, 8081/TCP<br/>FIPS: Yes"]

        ModuleCtrl["kserve-module-controller<br/>SA: kserve-module-controller-manager<br/>8081/TCP health (HTTP)<br/>FIPS: NO (CGO_ENABLED=0)"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        ISVCPod["InferenceService Pod<br/>Inference: 8080/TCP HTTP<br/>Agent: 9081/TCP, 9083/TCP<br/>Auth Proxy: 8443/TCP HTTPS (ODH)"]

        LLMPod["LLMInferenceService Pod<br/>vLLM: 8000/TCP<br/>Multi-node: LeaderWorkerSet<br/>GPU: DRA ResourceClaims"]

        EPPPod["EPP Scheduler Pod<br/>9002/TCP gRPC (EPP)<br/>9003/TCP gRPC (health)<br/>5557/TCP ZMQ"]

        IGRouter["InferenceGraph Router<br/>8080/TCP HTTP<br/>Auth: TokenReview + SAR"]
    end

    subgraph NodeLevel["NODE LEVEL (DaemonSet)"]
        NodeAgent["localmodelnode-agent<br/>SA: kserve-localmodelnode-agent<br/>8080/TCP metrics, 8081/TCP health<br/>Creates download Jobs<br/>SELinux/MCS (ODH)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure Identity"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Creds"]
        LogSink["Logger Sink<br/>Configurable<br/>HTTP/HTTPS<br/>Bearer Token"]
        OTLP["OTLP Collector<br/>Configurable<br/>gRPC/HTTP"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| HTTPRoute
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| VirtualService
    Client -->|"HTTPS/443<br/>TLS Reencrypt<br/>Bearer Token (opt)"| OSRoute
    Client -->|"HTTP(S)/80|443<br/>Bearer Token (opt)"| K8sIngress

    %% Ingress → Auth / Workloads
    HTTPRoute -->|"HTTPS/8443<br/>OCP Serving Cert"| AuthProxy
    VirtualService -->|"HTTPS/8443<br/>OCP Serving Cert"| AuthProxy
    AuthProxy -->|"HTTP/8080<br/>localhost (trusted)"| ISVCPod

    HTTPRoute -->|"gRPC/9002<br/>Configurable"| EPPPod
    EPPPod -->|"HTTP/8000<br/>Configurable"| LLMPod

    OSRoute -->|"HTTP/8080<br/>TokenReview+SAR"| IGRouter
    IGRouter -->|"HTTP/8080<br/>Istio mTLS (mesh)"| ISVCPod

    %% Controllers → K8s API
    ControllerMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LLMCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    LocalModelCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    ModuleCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    NodeAgent -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Egress to storage
    ISVCPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>Provider Creds"| S3
    ISVCPod -.->|"HTTPS/443<br/>TLS 1.2+"| GCS
    ISVCPod -.->|"HTTPS/443<br/>TLS 1.2+"| Azure
    ISVCPod -.->|"HTTPS/443<br/>TLS 1.2+"| HF
    ISVCPod -.->|"HTTPS/443<br/>TLS 1.2+"| OCI
    ISVCPod -.->|"Configurable"| LogSink
    ISVCPod -.->|"Configurable"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef auth fill:#ffcccc,stroke:#cc3333,stroke-width:2px,color:#333
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef nodeagent fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef fipsgap fill:#ffcccc,stroke:#cc0000,stroke-width:3px,color:#333

    class Client external
    class HTTPRoute,VirtualService,OSRoute,K8sIngress ingress
    class AuthProxy auth
    class ControllerMgr,LLMCtrl,LocalModelCtrl controller
    class ModuleCtrl fipsgap
    class ISVCPod,LLMPod,EPPPod,IGRouter workload
    class NodeAgent nodeagent
    class K8sAPI,S3,GCS,Azure,HF,OCI,LogSink,OTLP externalservice
