graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / OpenShift Router<br/>443/TCP external<br/>TLS 1.2+<br/>VirtualService / HTTPRoute / Route"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS - Istio/OSSM)"]
        direction TB

        subgraph ControlPlane["Control Plane (opendatahub namespace)"]
            KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>8080/TCP metrics, 9443/TCP webhook<br/>TLS: service-ca"]
            LLMISVCCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>8080/TCP metrics, 9443/TCP webhook<br/>TLS: service-ca, HTTP/2 disabled"]
            LocalModelCtrl["kserve-localmodel-controller<br/>SA: kserve-localmodel-controller<br/>8080/TCP metrics, 9443/TCP webhook"]
            LocalModelAgent["kserve-localmodelnode-agent<br/>SA: kserve-localmodelnode-agent<br/>(per-node, no ports exposed)"]
        end

        subgraph WebhookSvcs["Webhook Services"]
            KServeWebhook["kserve-webhook-server-service<br/>ClusterIP 443→9443/TCP HTTPS<br/>TLS: service-ca cert"]
            LLMISVCWebhook["llmisvc-webhook-server-service<br/>ClusterIP 443→9443/TCP HTTPS<br/>TLS: service-ca cert"]
        end

        subgraph ISVCPath["InferenceService Data Path"]
            AuthProxy["oauth-proxy / kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Auth: OpenShift OAuth / RBAC SAR"]
            PredictorPod["Predictor Pod<br/>8080/TCP HTTP<br/>+ kserve-agent sidecar 9081/TCP"]
        end

        subgraph LLMPath["LLMInferenceService Data Path"]
            Scheduler["InferencePool Scheduler<br/>gRPC + metrics + ZMQ<br/>TLS<br/>Auth: Bearer (metrics)"]
            PrefillPod["Prefill Workload Pod<br/>8000/TCP HTTPS<br/>TLS: self-signed<br/>SCC: openshift-ai-llminferenceservice-scc"]
            DecodePod["Decode Workload Pod<br/>8000/TCP HTTPS<br/>TLS: self-signed<br/>+ routing-sidecar, tokenizer"]
        end

        subgraph IGPath["InferenceGraph Data Path"]
            IGRouter["kserve-router<br/>8080/TCP HTTP/HTTPS<br/>Auth: Bearer → K8s TokenReview"]
            ISvcEndpoints["InferenceService Endpoints<br/>80/TCP HTTP mTLS"]
        end
    end

    subgraph K8sAPI["KUBERNETES API"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: GCP SA"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Azure AD / SAS"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF Token"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Registry creds"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| Gateway

    %% Ingress to Data Paths
    Gateway -->|"HTTP/80<br/>mTLS (Istio)<br/>VirtualService/HTTPRoute"| AuthProxy
    Gateway -->|"gRPC<br/>TLS<br/>HTTPRoute"| Scheduler
    Gateway -->|"HTTP(S)/8080<br/>TLS (opt)<br/>Route (OpenShift)"| IGRouter

    %% InferenceService path
    AuthProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| PredictorPod

    %% LLMInferenceService path
    Scheduler -->|"HTTPS/8000<br/>TLS self-signed"| PrefillPod
    PrefillPod -->|"HTTPS/8000<br/>TLS self-signed<br/>routing-sidecar"| DecodePod

    %% InferenceGraph path
    IGRouter -->|"HTTP/80<br/>mTLS (mesh)"| ISvcEndpoints

    %% Controller to K8s API
    KServeCtrl -->|"HTTPS/6443<br/>SA Token"| APIServer
    LLMISVCCtrl -->|"HTTPS/6443<br/>SA Token"| APIServer
    LocalModelCtrl -->|"HTTPS/6443<br/>SA Token"| APIServer
    LocalModelAgent -->|"HTTPS/6443<br/>SA Token"| APIServer

    %% Webhook connections
    KServeCtrl ---|webhook| KServeWebhook
    LLMISVCCtrl ---|webhook| LLMISVCWebhook

    %% TokenReview
    IGRouter -->|"HTTPS/6443<br/>TokenReview"| APIServer

    %% Data path to external storage
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| GCS
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| Azure
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace
    PredictorPod -->|"HTTPS/443<br/>TLS 1.2+"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef webhook fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef datapath fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8sapi fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class KServeCtrl,LLMISVCCtrl,LocalModelCtrl,LocalModelAgent controlplane
    class KServeWebhook,LLMISVCWebhook webhook
    class AuthProxy,PredictorPod,Scheduler,PrefillPod,DecodePod,IGRouter,ISvcEndpoints datapath
    class S3,GCS,Azure,HuggingFace,OCI externalservice
    class APIServer k8sapi
