graph TD
    subgraph "Service Account"
        SA["controller-manager<br/>(mcp-lifecycle-operator-system)"]
    end

    subgraph "ClusterRole Bindings"
        CRB1["manager-rolebinding<br/>(ClusterScoped)"]
        CRB2["metrics-auth-rolebinding<br/>(ClusterScoped)"]
        RB1["leader-election-rolebinding<br/>(Namespace: mcp-lifecycle-operator-system)"]
    end

    subgraph "Operator Roles"
        CR1["ClusterRole:<br/>manager-role"]
        CR2["ClusterRole:<br/>metrics-auth-role"]
        R1["Role:<br/>leader-election-role"]
    end

    subgraph "User-Facing Roles (Aggregated)"
        CR3["ClusterRole:<br/>mcpserver-admin-role"]
        CR4["ClusterRole:<br/>mcpserver-editor-role"]
        CR5["ClusterRole:<br/>mcpserver-viewer-role"]
    end

    subgraph "API Resources - manager-role"
        MCPServers["mcp.x-k8s.io<br/>MCPServers<br/>get, list, watch"]
        MCPServersStatus["mcp.x-k8s.io<br/>MCPServers/status<br/>get, patch"]
        Deployments["apps<br/>Deployments<br/>get, list, watch,<br/>create, update"]
        Services["core<br/>Services<br/>get, list, watch,<br/>create, update"]
        ConfigMaps["core<br/>ConfigMaps, Secrets<br/>get, list, watch"]
        Pods["core<br/>Pods<br/>get, list"]
        Events["core, events.k8s.io<br/>Events<br/>create, patch"]
    end

    subgraph "API Resources - metrics-auth-role"
        TokenReviews["authentication.k8s.io<br/>TokenReviews<br/>create"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews<br/>create"]
    end

    subgraph "API Resources - leader-election-role"
        LEConfigMaps["core<br/>ConfigMaps<br/>get, list, watch,<br/>create, update, patch, delete"]
        Leases["coordination.k8s.io<br/>Leases<br/>get, list, watch,<br/>create, update, patch, delete"]
        LEEvents["core<br/>Events<br/>create, patch"]
    end

    subgraph "API Resources - User Roles"
        AdminMCPServers["mcp.x-k8s.io<br/>MCPServers<br/>get, list, watch, create,<br/>update, patch, delete,<br/>deletecollection"]
        EditorMCPServers["mcp.x-k8s.io<br/>MCPServers<br/>get, list, watch, create,<br/>update, patch, delete"]
        ViewerMCPServers["mcp.x-k8s.io<br/>MCPServers<br/>get, list, watch"]
    end

    %% Bindings
    SA -->|"bound via"| CRB1
    SA -->|"bound via"| CRB2
    SA -->|"bound via"| RB1

    CRB1 -->|"grants"| CR1
    CRB2 -->|"grants"| CR2
    RB1 -->|"grants"| R1

    %% manager-role permissions
    CR1 --> MCPServers
    CR1 --> MCPServersStatus
    CR1 --> Deployments
    CR1 --> Services
    CR1 --> ConfigMaps
    CR1 --> Pods
    CR1 --> Events

    %% metrics-auth-role permissions
    CR2 --> TokenReviews
    CR2 --> SAR

    %% leader-election-role permissions
    R1 --> LEConfigMaps
    R1 --> Leases
    R1 --> LEEvents

    %% User-facing roles
    CR3 --> AdminMCPServers
    CR4 --> EditorMCPServers
    CR5 --> ViewerMCPServers

