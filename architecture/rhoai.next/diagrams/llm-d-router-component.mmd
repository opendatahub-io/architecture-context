graph TB
    subgraph LLMDRouter["llm-d-router"]
        direction TB

        subgraph EPP["Endpoint Picker (EPP)"]
            direction TB
            ExtProc["ext_proc gRPC Server<br/>9002/TCP TLS"]
            HealthGRPC["Health gRPC<br/>9003/TCP"]
            MetricsHTTP["Metrics HTTP<br/>9090/TCP"]
            ZMQ["ZMQ KV-Events<br/>5557/TCP"]

            subgraph PluginFramework["Plugin Framework (60+ plugins)"]
                direction LR
                Scheduling["Scheduling<br/>Filters | Scorers | Pickers"]
                FlowControl["Flow Control<br/>Fairness | Saturation | Eviction"]
                RequestControl["Request Control<br/>Admission | Data Production"]
                DataLayer["Data Layer<br/>Polling | Extractors | Discovery"]
                RequestHandling["Request Handling<br/>OpenAI | Anthropic | vLLM | VertexAI"]
            end

            Controllers["controller-runtime<br/>Reconcilers"]
            Datastore["In-Memory Datastore"]

            Controllers -->|reconciles| Datastore
            Datastore -->|feeds| PluginFramework
            PluginFramework -->|routing decision| ExtProc
        end

        subgraph Sidecar["Disaggregation Sidecar (pd-sidecar)"]
            direction TB
            SidecarProxy["HTTP/HTTPS Proxy<br/>8000/TCP TLS"]
            SidecarHealth["Health<br/>/health"]

            subgraph Connectors["KV-Cache Connectors"]
                direction LR
                NIXL["nixlv2"]
                SharedStorage["shared-storage"]
                SGLang["sglang"]
                Mooncake["mooncake"]
            end

            SidecarProxy -->|orchestrates| Connectors
        end
    end

    %% External Resources watched by EPP
    InferencePoolCR["InferencePool CR<br/>(Gateway API Inference Extension)"]
    InferenceObjectiveCR["InferenceObjective CR<br/>(llm-d.ai/v1alpha2)"]
    InferenceModelRewriteCR["InferenceModelRewrite CR<br/>(llm-d.ai/v1alpha2)"]
    PodsCR["Pods<br/>(endpoint discovery)"]

    InferencePoolCR -->|watched by| Controllers
    InferenceObjectiveCR -->|watched by| Controllers
    InferenceModelRewriteCR -->|watched by| Controllers
    PodsCR -->|watched by| Controllers

    %% L7 Proxy Integration
    Client["Client"] -->|HTTP request| EnvoyProxy
    EnvoyProxy["Envoy / AgentGateway<br/>L7 Proxy<br/>8081/TCP"] -->|ext_proc gRPC| ExtProc
    ExtProc -->|header mutation<br/>llm-d-destination-endpoint| EnvoyProxy
    EnvoyProxy -->|routed request| ModelServer

    %% Model Server Metrics
    ModelServer["Model Servers<br/>(vLLM / SGLang)<br/>8000/TCP"]
    ModelServer -->|Prometheus metrics| DataLayer

    %% Sidecar Flows
    EnvoyProxy -->|inference request| SidecarProxy
    SidecarProxy -->|prefill stage| PrefillWorker["Prefill Workers"]
    SidecarProxy -->|decode stage| LocalDecoder["Local Decoder<br/>(vLLM) 8001/TCP"]
    PrefillWorker -->|KV-cache transfer| Connectors

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"] -->|watches| Controllers
    OTel["OpenTelemetry Collector<br/>4317/TCP gRPC"]
    Prometheus["Prometheus<br/>scrapes 9090/TCP"]

    EPP -.->|traces| OTel
    Prometheus -.->|scrapes| MetricsHTTP

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#50a0c0,stroke:#333,color:#fff
    style PluginFramework fill:#5ba0d2,stroke:#333,color:#fff
    style Connectors fill:#60b0d0,stroke:#333,color:#fff
    style ExtProc fill:#357abd,stroke:#333,color:#fff
    style HealthGRPC fill:#357abd,stroke:#333,color:#fff
    style MetricsHTTP fill:#357abd,stroke:#333,color:#fff
    style ZMQ fill:#357abd,stroke:#333,color:#fff
    style SidecarProxy fill:#408fb0,stroke:#333,color:#fff
    style Controllers fill:#357abd,stroke:#333,color:#fff
    style Datastore fill:#357abd,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjectiveCR fill:#f5a623,stroke:#333
    style InferenceModelRewriteCR fill:#f5a623,stroke:#333
    style PodsCR fill:#f5a623,stroke:#333
    style EnvoyProxy fill:#e8e8e8,stroke:#333
    style ModelServer fill:#7ed321,stroke:#333
    style PrefillWorker fill:#7ed321,stroke:#333
    style LocalDecoder fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OTel fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
