graph LR
    WVA["Workload Variant<br/>Autoscaler"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"metrics source<br/>(via Prometheus)"| vLLM["vLLM Inference<br/>Servers"]
    WVA -->|"emits scaling metrics<br/>(wva_desired_ratio)"| HPA["HPA / KEDA"]
    WVA -->|"controller framework"| CR["controller-runtime<br/>v0.22.5"]
    WVA -->|"InferencePool CRD<br/>scale-from-zero"| GatewayExt["Gateway API<br/>Inference Extension<br/>v1.2.1"]

    %% External Dependencies (Optional)
    WVA -.->|"optional: multi-worker<br/>GPU topology"| LWS["LeaderWorkerSet<br/>v0.8.0"]
    WVA -.->|"optional: ServiceMonitor<br/>CRD"| PromOp["Prometheus<br/>Operator"]

    %% Internal Platform Interactions
    WVA -->|"PromQL API<br/>9091/TCP HTTPS<br/>Bearer Token"| PromCluster["Prometheus<br/>(cluster)"]
    WVA -->|"CRD Watch<br/>v1 + v1alpha2"| InferencePool["InferencePool<br/>(Gateway API)"]
    WVA -->|"HTTP pod scraping<br/>HTTPS Bearer Token"| EPP["EPP Pods<br/>(Endpoint Picker)"]

    %% Kubernetes API Interactions
    WVA -->|"CRUD VA status<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    WVA -->|"watch + scale<br/>443/TCP HTTPS"| Deploys["Deployments /<br/>StatefulSets"]
    WVA -->|"watch ConfigMaps<br/>443/TCP HTTPS"| ConfigMaps["ConfigMaps<br/>(dynamic config)"]
    WVA -->|"read node labels<br/>GPU inventory"| Nodes["Kubernetes<br/>Nodes"]

    %% Reverse Dependencies (things that depend on WVA)
    HPA -->|"scales"| Deploys

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Prometheus fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style HPA fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style GatewayExt fill:#999,stroke:#333,color:#fff

    %% Optional external
    style LWS fill:#bbb,stroke:#333,color:#fff
    style PromOp fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style PromCluster fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff

    %% Kubernetes resources
    style K8sAPI fill:#f5a623,stroke:#333,color:#000
    style Deploys fill:#f5a623,stroke:#333,color:#000
    style ConfigMaps fill:#f5a623,stroke:#333,color:#000
    style Nodes fill:#f5a623,stroke:#333,color:#000
