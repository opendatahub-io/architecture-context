graph LR
    WVA["WVA Controller<br/>(Workload Variant Autoscaler)"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>HTTPS/9090-9091"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"metrics source<br/>(required)"| vLLM["vLLM Model Servers"]

    %% External Dependencies (Optional)
    WVA -.->|"ScaledObject support<br/>(optional, v2.18+)"| KEDA["KEDA"]
    WVA -.->|"queue metrics<br/>(optional)"| EPP["EPP / Inference<br/>Scheduler"]
    WVA -.->|"LWS scaling<br/>(optional, v0.8+)"| LWS["LeaderWorkerSet"]
    WVA -.->|"InferencePool CRD<br/>(optional, v1.2+)"| GatewayAPI["Gateway API<br/>Inference Extension"]
    WVA -.->|"ServiceMonitor CRD<br/>(optional)"| PromOperator["Prometheus Operator"]

    %% Internal Platform Dependencies
    WVA -->|"emits wva_desired_replicas<br/>(external metric)"| HPA["HorizontalPodAutoscaler"]
    WVA -->|"emits wva_desired_replicas<br/>(external metric)"| ScaledObj["KEDA ScaledObject"]
    WVA -->|"CRD watch<br/>(deprecated)"| VACRD["VariantAutoscaling CRD"]
    WVA -->|"patch scale 0→1"| Deploy["Deployment"]
    WVA -->|"patch scale 0→1"| LWSTarget["LeaderWorkerSet"]
    WVA -->|"watch + read"| CMConfig["ConfigMap<br/>(manager-config)"]
    WVA -->|"watch + read"| CMSat["ConfigMap<br/>(saturation-scaling-config)"]
    WVA -->|"watch + read"| CMLocal["ConfigMap<br/>(namespace-local)"]
    WVA -->|"CRD watch<br/>(predicate filter)"| SvcMon["ServiceMonitor"]
    WVA -->|"watch + list"| Nodes["Nodes"]
    WVA -->|"get + list"| RQ["ResourceQuota"]

    %% Integration Points (consumers of WVA)
    HPA -->|"scales"| Deploy
    ScaledObj -->|"scales"| Deploy

    %% Kubernetes API
    WVA -->|"watch/patch<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Prometheus fill:#e6550d,stroke:#333,color:#fff
    style vLLM fill:#e6550d,stroke:#333,color:#fff

    %% Optional external
    style KEDA fill:#999,stroke:#333,color:#fff
    style EPP fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style PromOperator fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style HPA fill:#7ed321,stroke:#333
    style ScaledObj fill:#7ed321,stroke:#333
    style VACRD fill:#7ed321,stroke:#333
    style Deploy fill:#7ed321,stroke:#333
    style LWSTarget fill:#7ed321,stroke:#333
    style CMConfig fill:#7ed321,stroke:#333
    style CMSat fill:#7ed321,stroke:#333
    style CMLocal fill:#7ed321,stroke:#333
    style SvcMon fill:#7ed321,stroke:#333
    style Nodes fill:#7ed321,stroke:#333
    style RQ fill:#7ed321,stroke:#333

    %% Kubernetes
    style K8sAPI fill:#f5a623,stroke:#333
