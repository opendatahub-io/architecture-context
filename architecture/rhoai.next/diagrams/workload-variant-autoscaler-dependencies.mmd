graph LR
    WVA["Workload Variant<br/>Autoscaler (WVA)"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>HTTPS/9090"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"metrics source<br/>(indirect via Prometheus)"| vLLM["vLLM Inference<br/>Servers"]
    WVA -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.5"]
    WVA -->|"InferencePool CRD<br/>types"| GatewayInference["gateway-api-inference<br/>-extension v1.2.1"]

    %% External Dependencies (Optional)
    WVA -.->|"multi-pod scaling<br/>(optional)"| LWS["LeaderWorkerSet<br/>(lws) v0.8.0"]
    WVA -.->|"ServiceMonitor CRD<br/>(optional)"| PromOperator["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    WVA -->|"flow control queue<br/>HTTPS"| EPP["Gateway API<br/>Inference Extension<br/>EPP"]
    WVA -->|"emits wva_desired_*<br/>HTTPS/8443"| HPAKEDA["HPA / KEDA"]
    WVA -->|"scale subresource<br/>HTTPS/443"| Deployments["Deployments /<br/>StatefulSets /<br/>LeaderWorkerSets"]
    WVA -->|"node labels<br/>GPU discovery"| GPUOperator["GPU Operator<br/>(NVIDIA, AMD, Intel)"]

    %% Integration Points (consumed by others)
    HPAKEDA -->|"scales"| Deployments

    %% Kubernetes API (central)
    WVA -->|"watch/patch CRs<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required External
    style Prometheus fill:#e06666,stroke:#333,color:#fff
    style vLLM fill:#e06666,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GatewayInference fill:#999,stroke:#333,color:#fff

    %% Optional External
    style LWS fill:#b4a7d6,stroke:#333,color:#fff
    style PromOperator fill:#b4a7d6,stroke:#333,color:#fff

    %% Internal Platform
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style HPAKEDA fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style GPUOperator fill:#7ed321,stroke:#333,color:#fff

    %% Infrastructure
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
