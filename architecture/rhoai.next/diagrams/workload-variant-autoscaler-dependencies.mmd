graph LR
    WVA["Workload Variant<br/>Autoscaler"]

    %% Required External Dependencies
    WVA -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus<br/>(Thanos Querier)"]
    WVA -->|"metrics source<br/>(indirect via Prometheus)"| vLLM["vLLM Inference<br/>Servers"]

    %% Optional External Dependencies
    WVA -.->|"metrics consumer<br/>8443/TCP HTTPS"| KEDA["KEDA v2.18.0<br/>(optional)"]
    WVA -.->|"metrics consumer<br/>8443/TCP HTTPS"| HPA["HPA<br/>(optional)"]
    WVA -.->|"ServiceMonitor CRD<br/>watch"| PromOperator["Prometheus Operator<br/>v0.89.0 (optional)"]
    WVA -.->|"InferencePool CRD<br/>watch"| GatewayAPIIE["Gateway API<br/>Inference Extension<br/>v1.2.1 (optional)"]
    WVA -.->|"LeaderWorkerSet<br/>scale target"| LWS["LeaderWorkerSet<br/>v0.8.0 (optional)"]

    %% Internal Platform Dependencies
    WVA -->|"CRD Watch<br/>6443/TCP HTTPS"| InferencePool["InferencePool CR"]
    WVA -->|"HTTP scraping<br/>flow_control_queue_size"| EPP["EPP (Endpoint<br/>Picker) Pods"]

    %% Core Infrastructure
    WVA -->|"Watch/CRUD CRs<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% Configuration Dependencies
    WVA -->|"dynamic config<br/>watch + parse"| ConfigMaps["ConfigMaps<br/>(saturation, scale-to-zero,<br/>queueing model)"]
    WVA -.->|"GPU node labels<br/>limited mode"| GPUOperator["GPU Operator<br/>(node labels)"]

    %% Framework
    WVA -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.5"]
    WVA -.->|"Kalman filter<br/>online learning"| KalmanLib["Kalman Filter<br/>Library v0.1.2"]

    %% Integration Points (things that depend on WVA)
    HPA -->|"scales based on<br/>WVA metrics"| Deployments["Deployments /<br/>LeaderWorkerSets"]
    KEDA -->|"scales based on<br/>WVA metrics"| Deployments

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style KEDA fill:#999,stroke:#333,stroke-dasharray:5 5
    style HPA fill:#999,stroke:#333,stroke-dasharray:5 5
    style PromOperator fill:#999,stroke:#333,stroke-dasharray:5 5
    style GatewayAPIIE fill:#999,stroke:#333,stroke-dasharray:5 5
    style LWS fill:#999,stroke:#333,stroke-dasharray:5 5
    style InferencePool fill:#7ed321,stroke:#333
    style EPP fill:#7ed321,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
    style GPUOperator fill:#999,stroke:#333,stroke-dasharray:5 5
    style ControllerRuntime fill:#e8e8e8,stroke:#333
    style KalmanLib fill:#999,stroke:#333,stroke-dasharray:5 5
    style Deployments fill:#e8e8e8,stroke:#333
