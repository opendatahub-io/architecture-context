graph LR
    WVA["WVA<br/>Workload Variant Autoscaler"]

    %% Required External Dependencies
    WVA -->|"queries metrics<br/>HTTPS/9090-9091"| Prometheus["Prometheus<br/>(Required)"]
    WVA -->|"reads inference metrics<br/>(indirect via Prometheus)"| vLLM["vLLM<br/>(Required)"]

    %% Optional External Dependencies
    WVA -.->|"consumes wva_desired_replicas<br/>external metric"| KEDA["KEDA v2.18+<br/>(Optional)"]
    WVA -.->|"consumes wva_desired_replicas<br/>external metric"| HPA["Kubernetes HPA<br/>autoscaling/v2<br/>(Optional)"]
    WVA -.->|"queue_size for<br/>scale-from-zero"| EPP["Gateway API<br/>Inference Extension<br/>EPP v1.2.1+<br/>(Optional)"]
    WVA -.->|"distributed inference<br/>scale target"| LWS["LeaderWorkerSet<br/>v0.8+<br/>(Optional)"]
    WVA -.->|"TLS cert mgmt"| CertManager["cert-manager<br/>(Optional)"]
    WVA -.->|"ServiceMonitor CRD"| PromOperator["Prometheus Operator<br/>(Optional)"]
    WVA -.->|"SLO parameter<br/>tuning (in-process)"| Kalman["llm-d Kalman Filter<br/>v0.1.2<br/>(Optional)"]

    %% Internal Platform Dependencies
    WVA -->|"cross-namespace<br/>metric aggregation<br/>HTTPS/9091"| Thanos["Thanos Querier<br/>(OpenShift)"]
    WVA -->|"discovers model<br/>endpoint pools<br/>CRD Watch"| InferencePool["InferencePool<br/>(Gateway API<br/>Inference Extension)"]

    %% Core Platform
    WVA -->|"watch CRDs, scale<br/>HTTPS/6443"| K8sAPI["Kubernetes API<br/>Server"]

    %% Integration Points - Components that integrate WITH WVA
    HPA -->|"reads external metric<br/>scales deployments"| K8sAPI
    KEDA -->|"reads external metric<br/>scales deployments"| K8sAPI
    vLLM -->|"exposes metrics"| Prometheus

    %% ConfigMap-based configuration
    ConfigMaps["ConfigMaps<br/>wva-manager-config<br/>wva-saturation-scaling-config<br/>wva-model-scale-to-zero-config<br/>wva-qm-analyzer-config"] -->|"runtime config<br/>(watch, no restart)"| WVA

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Prometheus fill:#e65100,stroke:#333,color:#fff
    style vLLM fill:#e65100,stroke:#333,color:#fff
    style K8sAPI fill:#e65100,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style HPA fill:#999,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style PromOperator fill:#999,stroke:#333,color:#fff
    style Kalman fill:#999,stroke:#333,color:#fff
    style Thanos fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#f5a623,stroke:#333
