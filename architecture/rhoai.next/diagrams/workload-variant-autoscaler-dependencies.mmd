graph LR
    WVA["WVA Controller<br/>Manager"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>9090/TCP HTTPS"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"metrics source<br/>(indirect via Prom)"| vLLM["vLLM Inference<br/>Servers"]
    WVA -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.5"]
    WVA -->|"InferencePool CRD<br/>scale-from-zero"| GatewayAPIInf["gateway-api-inference<br/>-extension v1.2.1"]

    %% External Dependencies (Optional)
    WVA -.->|"multi-pod scaling<br/>(tensor parallelism)"| LWS["LeaderWorkerSet<br/>v0.8.0"]
    WVA -.->|"ServiceMonitor CRD"| PromOperator["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    WVA -->|"emits scaling metrics<br/>8443/TCP HTTPS"| HPAKEDA["HPA / KEDA"]
    WVA -->|"scale subresource<br/>443/TCP HTTPS"| Deployments["Deployment /<br/>StatefulSet /<br/>LeaderWorkerSet"]
    WVA -->|"EPP queue metrics<br/>HTTPS"| EPP["Gateway API<br/>Inference Extension<br/>EPP"]
    WVA -->|"GPU inventory<br/>node labels"| GPUOperator["GPU Operator<br/>(NVIDIA, AMD, Intel)"]

    %% Kubernetes API
    WVA -->|"CRs, ConfigMaps,<br/>Nodes, Namespaces<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% Consumers of WVA
    HPAKEDA -->|"scales pods"| Deployments

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style Prometheus fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPIInf fill:#999,stroke:#333,color:#fff

    %% External optional
    style LWS fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff

    %% Internal platform
    style HPAKEDA fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style GPUOperator fill:#7ed321,stroke:#333,color:#fff

    %% Infrastructure
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
