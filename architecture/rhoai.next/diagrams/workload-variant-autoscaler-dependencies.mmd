graph LR
    WVA["Workload Variant<br/>Autoscaler"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"metrics source<br/>(via Prometheus)"| vLLM["vLLM Inference<br/>Servers"]
    WVA -->|"metrics consumed by<br/>(wva_desired_ratio)"| HPAKEDA["HPA / KEDA"]
    WVA -->|"controller framework<br/>v0.22.5"| ControllerRuntime["controller-runtime"]
    WVA -->|"InferencePool CRD<br/>v1.2.1"| GatewayAPIExt["gateway-api-inference<br/>-extension"]

    %% External Dependencies (Optional)
    WVA -.->|"multi-worker GPU<br/>v0.8.0 (optional)"| LWS["LeaderWorkerSet"]
    WVA -.->|"ServiceMonitor CRD<br/>(optional)"| PromOperator["Prometheus Operator"]

    %% Internal Platform Dependencies
    WVA -->|"EPP pod scraping<br/>HTTPS"| EPPPods["EPP Pods<br/>(Endpoint Picker)"]
    WVA -->|"CRD watch<br/>K8s API"| InferencePool["InferencePool CR"]

    %% Infrastructure
    WVA -->|"CR CRUD, scale,<br/>leader election<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Consumers of WVA
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(potential)"| WVA
    Pipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>(potential)"| WVA

    %% Secondary dependencies
    HPAKEDA -->|"reads metrics"| Prometheus
    HPAKEDA -->|"scales workloads<br/>443/TCP"| K8sAPI
    vLLM -->|"metrics scraped"| Prometheus
    GatewayAPIExt -->|"provides CRD"| InferencePool

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style HPAKEDA fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPIExt fill:#999,stroke:#333,color:#fff
    style LWS fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style EPPPods fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
    style Pipelines fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#333
