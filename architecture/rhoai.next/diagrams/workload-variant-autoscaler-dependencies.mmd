graph LR
    WVA["WVA Controller<br/>(Workload Variant Autoscaler)"]

    %% Required External Dependencies
    WVA -->|"PromQL queries<br/>HTTPS/9091"| Prometheus["Prometheus /<br/>Thanos Querier<br/>(Required)"]
    WVA -->|"metrics source<br/>(indirect via Prometheus)"| vLLM["vLLM Inference<br/>Servers<br/>(Required)"]
    WVA -->|"consumes wva metrics<br/>(indirect via Prometheus)"| HPAKEDA["HPA / KEDA<br/>(Required)"]
    WVA -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.5<br/>(Required)"]
    WVA -->|"InferencePool CRD +<br/>EPP pod scraping"| GatewayAPIExt["gateway-api-inference-<br/>extension v1.2.1<br/>(Required)"]

    %% Optional External Dependencies
    WVA -.->|"multi-worker GPU<br/>topologies"| LWS["LeaderWorkerSet<br/>v0.8.0<br/>(Optional)"]
    WVA -.->|"ServiceMonitor CRD<br/>for metrics scraping"| PromOperator["Prometheus Operator<br/>(Optional)"]

    %% Internal Platform Dependencies
    WVA -->|"REST API PromQL<br/>HTTPS + Bearer Token"| PromCluster["Prometheus (cluster)<br/>Internal Platform"]
    WVA -->|"CRD Watch"| InferencePool["InferencePool<br/>(Gateway API)<br/>Internal Platform"]
    WVA -->|"HTTP pod scraping<br/>Bearer Token"| EPPPods["EPP Pods<br/>(Endpoint Picker)<br/>Internal Platform"]

    %% Kubernetes API interactions
    WVA -->|"CRUD VA, watch<br/>Deployments/LWS/<br/>ConfigMaps/Nodes"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% Integration Points (consumers of WVA)
    vLLM -.->|"metrics scraped"| Prometheus
    HPAKEDA -->|"reads wva metrics"| Prometheus
    HPAKEDA -->|"scales pods"| K8sAPI

    %% Styles
    style WVA fill:#4a90e2,stroke:#2c5282,stroke-width:4px,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style HPAKEDA fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPIExt fill:#999,stroke:#333,color:#fff
    style LWS fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style PromOperator fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style PromCluster fill:#7ed321,stroke:#333,color:#fff
    style InferencePool fill:#7ed321,stroke:#333,color:#fff
    style EPPPods fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
