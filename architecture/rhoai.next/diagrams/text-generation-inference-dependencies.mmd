graph LR
    TGIS["Text Generation<br/>Inference Server<br/>(TGIS)"]

    %% External Dependencies (Required)
    TGIS -->|"GPU compute<br/>runtime"| CUDA["CUDA Toolkit<br/>12.1.0"]
    TGIS -->|"deep learning<br/>framework"| PyTorch["PyTorch<br/>2.2.1"]
    TGIS -->|"model architectures<br/>+ tokenizers"| HFTransformers["HuggingFace<br/>Transformers 4.40.2"]
    TGIS -->|"multi-GPU collective<br/>communication"| NCCL["NCCL<br/>2.18.3"]
    TGIS -->|"TLS/crypto<br/>operations"| OpenSSL["OpenSSL<br/>>=0.10.64 (Rust)"]
    TGIS -->|"gRPC protocol<br/>serialization"| Protobuf["Protobuf<br/>>=4.25.3"]

    %% External Dependencies (Optional)
    TGIS -.->|"optimized attention<br/>(A100/A10 GPUs)"| FlashAttn["Flash Attention V2<br/>2.5.6"]
    TGIS -.->|"GPTQ quantization"| AutoGPTQ["Auto-GPTQ<br/>0.7.1"]
    TGIS -.->|"ONNX inference<br/>acceleration"| ONNXRuntime["ONNX Runtime GPU<br/>1.18.0"]
    TGIS -.->|"IBM Foundation<br/>Model Stack"| IBMFMS["IBM FMS<br/>>=0.0"]

    %% Internal Platform Dependencies
    TGIS -->|"deployed as<br/>serving runtime"| KServe["KServe<br/>InferenceService"]
    TGIS -->|"model weight<br/>download"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    TGIS -->|"persistent model<br/>storage"| PVC["PVC<br/>models-pvc"]

    %% Integration Points (things that connect TO TGIS)
    Kubelet["Kubernetes<br/>Kubelet"] -->|"HTTP probes<br/>3000/TCP"| TGIS
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"HTTP scrape<br/>3000/TCP /metrics"| TGIS
    TGIS -->|"gRPC tracing<br/>export"| OTel["OpenTelemetry<br/>Collector"]
    TGIS -->|"device driver<br/>compute"| GPU["NVIDIA GPU<br/>(CUDA 12.1)"]

    %% Styling
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

