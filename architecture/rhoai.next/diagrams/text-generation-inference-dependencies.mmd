graph LR
    TGIS["TGIS<br/>Text Generation<br/>Inference Server"]

    %% Internal Platform Dependencies
    TGIS -->|"ServingRuntime<br/>container lifecycle"| KServe["KServe<br/>InferenceService"]
    TGIS -->|"GPU resources<br/>CUDA drivers"| GPUOp["NVIDIA GPU<br/>Operator"]
    TGIS -->|"volume mount<br/>pre-cached models"| ModelPVC["Shared PVC<br/>models-pvc"]

    %% Core External Dependencies (Required)
    TGIS -->|"inference framework"| PyTorch["PyTorch 2.2.1<br/>+cu121"]
    TGIS -->|"GPU compute"| CUDA["CUDA 12.1.0"]
    TGIS -->|"model loading<br/>tokenizer"| Transformers["Transformers<br/>4.40.2 (pinned)"]
    TGIS -->|"gRPC serialization"| Protobuf["protobuf ^4.25.3"]
    TGIS -->|"safe weight loading"| Safetensors["safetensors ^0.4.3"]

    %% Optional External Dependencies
    TGIS -.->|"multi-GPU<br/>tensor parallelism"| NCCL["NCCL 2.18.3"]
    TGIS -.->|"optimized attention<br/>compute >= 8.0"| FlashAttn["Flash Attention<br/>v2 2.5.6"]
    TGIS -.->|"GPTQ quantization"| AutoGPTQ["AutoGPTQ 0.7.1"]
    TGIS -.->|"8-bit quantization"| BitsBytes["bitsandbytes<br/>^0.42.0"]
    TGIS -.->|"ONNX runtime"| ONNX["Optimum + ONNX<br/>Runtime 1.18.0"]
    TGIS -.->|"IBM Megatron"| IBMFMS["IBM FMS ^0.0"]

    %% External Services
    TGIS -->|"model download<br/>HTTPS :443"| HFHub["HuggingFace Hub<br/>huggingface.co"]

    %% Integration Points (other components depending on TGIS)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP :3000"| TGIS
    K8sProbes["K8s Probes"] -->|"/health<br/>HTTP :3000"| TGIS

    %% Styling
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform - green
    style KServe fill:#7ed321,stroke:#333
    style GPUOp fill:#7ed321,stroke:#333
    style ModelPVC fill:#7ed321,stroke:#333

    %% Required external - grey
    style PyTorch fill:#999,stroke:#333,color:#fff
    style CUDA fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Safetensors fill:#999,stroke:#333,color:#fff

    %% Optional external - light grey
    style NCCL fill:#bbb,stroke:#333
    style FlashAttn fill:#bbb,stroke:#333
    style AutoGPTQ fill:#bbb,stroke:#333
    style BitsBytes fill:#bbb,stroke:#333
    style ONNX fill:#bbb,stroke:#333
    style IBMFMS fill:#bbb,stroke:#333

    %% External services - orange
    style HFHub fill:#f5a623,stroke:#333

    %% Consumers - light blue
    style Prometheus fill:#dae8fc,stroke:#6c8ebf
    style K8sProbes fill:#dae8fc,stroke:#6c8ebf
