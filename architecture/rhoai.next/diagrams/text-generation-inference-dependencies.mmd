graph LR
    TGIS["Text Generation<br/>Inference Server<br/>(TGIS)"]

    %% Internal RHOAI Dependencies
    TGIS -->|"container runtime"| KServe["KServe<br/>InferenceService"]

    %% External Runtime Dependencies
    TGIS -->|"GPU compute"| CUDA["CUDA Toolkit<br/>12.1.0"]
    TGIS -->|"tensor parallelism"| NCCL["NCCL<br/>2.18.3"]
    TGIS -->|"model inference"| PyTorch["PyTorch<br/>2.2.1"]
    TGIS -->|"model architectures<br/>& tokenizers"| HFTransformers["HuggingFace<br/>Transformers 4.40.2"]
    TGIS -->|"TLS/crypto"| OpenSSL["OpenSSL<br/>(UBI 9.5)"]
    TGIS -->|"gRPC serialization"| Protobuf["Protobuf<br/>4.25.3+"]

    %% Optional Dependencies
    TGIS -.->|"optimized attention<br/>(A100/A10 GPUs)"| FlashAttn["Flash Attention V2<br/>2.5.6"]
    TGIS -.->|"GPTQ quantization"| AutoGPTQ["Auto-GPTQ<br/>0.7.1"]
    TGIS -.->|"ONNX acceleration"| ONNXRT["ONNX Runtime GPU<br/>1.18.0"]
    TGIS -.->|"IBM FMS backend"| IBMFMS["IBM Foundation<br/>Model Stack"]

    %% External Services
    TGIS -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    TGIS -->|"model storage<br/>volume mount"| PVC["PVC<br/>(models-pvc)"]

    %% Integration Points (consumed by)
    Kubelet["Kubernetes<br/>Kubelet"] -->|"health probes<br/>HTTP/3000"| TGIS
    Prometheus["Prometheus /<br/>OCP Monitoring"] -->|"metrics scrape<br/>HTTP/3000"| TGIS
    OTel["OpenTelemetry<br/>Collector"] -.->|"traces<br/>gRPC"| TGIS

    %% Styling
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff

    %% Required external dependencies
    style CUDA fill:#76b900,stroke:#333,color:#fff
    style NCCL fill:#76b900,stroke:#333,color:#fff
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style HFTransformers fill:#ff9d00,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff

    %% Optional dependencies
    style FlashAttn fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style AutoGPTQ fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style ONNXRT fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style IBMFMS fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5

    %% External services
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#dae8fc,stroke:#6c8ebf

    %% Consumers
    style Kubelet fill:#326ce5,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style OTel fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
