graph LR
    TGIS["Text Generation<br/>Inference Server<br/>(TGIS)"]

    %% Internal Platform Dependencies
    TGIS -->|"ServingRuntime container"| KServe["KServe<br/>InferenceService"]
    TGIS -->|"GPU resources<br/>CUDA drivers"| GPUOp["NVIDIA GPU<br/>Operator"]
    TGIS -->|"model weights<br/>volume mount"| ModelPVC["Shared Model<br/>PVC"]

    %% Core Runtime Dependencies (Required)
    TGIS -->|"inference framework"| PyTorch["PyTorch<br/>2.2.1+cu121"]
    TGIS -->|"GPU compute"| CUDA["CUDA<br/>12.1.0"]
    TGIS -->|"multi-GPU comms"| NCCL["NCCL<br/>2.18.3"]
    TGIS -->|"model loading<br/>tokenizer"| Transformers["Transformers<br/>4.40.2"]
    TGIS -->|"weight files"| Safetensors["safetensors<br/>0.4.3"]
    TGIS -->|"gRPC framework"| grpcio["grpcio<br/>1.62.2"]

    %% Optional Dependencies
    TGIS -.->|"optimized attention<br/>(optional)"| FlashAttn["Flash Attention v2<br/>2.5.6"]
    TGIS -.->|"GPTQ quantization<br/>(optional)"| AutoGPTQ["AutoGPTQ<br/>0.7.1"]
    TGIS -.->|"8-bit quantization<br/>(optional)"| BNB["bitsandbytes<br/>0.42.0"]
    TGIS -.->|"ONNX inference<br/>(optional)"| ONNX["Optimum + ONNX RT<br/>1.20.0 / 1.18.0"]
    TGIS -.->|"Megatron models<br/>(optional)"| IBMFMS["IBM FMS<br/>0.0+"]

    %% External Services
    TGIS -.->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>huggingface.co"]

    %% Integration Points (things that connect TO TGIS)
    Prometheus["Prometheus"] -->|"HTTP scrape<br/>3000/TCP"| TGIS
    K8sProbes["Kubernetes<br/>Probes"] -->|"HTTP GET /health<br/>3000/TCP"| TGIS

    %% Styling
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI (green)
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style GPUOp fill:#7ed321,stroke:#333,color:#fff
    style ModelPVC fill:#7ed321,stroke:#333,color:#fff

    %% Required external deps (gray)
    style PyTorch fill:#999,stroke:#333,color:#fff
    style CUDA fill:#999,stroke:#333,color:#fff
    style NCCL fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style Safetensors fill:#999,stroke:#333,color:#fff
    style grpcio fill:#999,stroke:#333,color:#fff

    %% Optional deps (lighter gray, dashed)
    style FlashAttn fill:#bbb,stroke:#666,color:#333
    style AutoGPTQ fill:#bbb,stroke:#666,color:#333
    style BNB fill:#bbb,stroke:#666,color:#333
    style ONNX fill:#bbb,stroke:#666,color:#333
    style IBMFMS fill:#bbb,stroke:#666,color:#333

    %% External services (orange)
    style HFHub fill:#f5a623,stroke:#333,color:#fff

    %% Integrators (light blue)
    style Prometheus fill:#85bbf0,stroke:#333,color:#fff
    style K8sProbes fill:#85bbf0,stroke:#333,color:#fff
