    style ONNXRuntime fill:#bbb,stroke:#666,stroke-dasharray: 5 5,color:#333
    style IBMFMS fill:#bbb,stroke:#666,stroke-dasharray: 5 5,color:#333

    %% Internal ODH/RHOAI (green)
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style HFHub fill:#7ed321,stroke:#333,color:#fff
