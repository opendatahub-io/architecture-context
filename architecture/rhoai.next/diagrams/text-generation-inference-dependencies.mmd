graph LR
    TGIS["Text Generation<br/>Inference Server<br/>(TGIS)"]

    %% Internal RHOAI Dependencies
    TGIS -->|"serving runtime<br/>container lifecycle"| KServe["KServe<br/>(InferenceService)"]

    %% External Dependencies - Required
    TGIS -->|"GPU compute<br/>inference"| CUDA["CUDA Toolkit<br/>12.1.0"]
    TGIS -->|"multi-GPU<br/>tensor parallelism"| NCCL["NCCL 2.18.3"]
    TGIS -->|"deep learning<br/>framework"| PyTorch["PyTorch 2.2.1"]
    TGIS -->|"model architectures<br/>tokenizers"| HFTransformers["HuggingFace<br/>Transformers 4.40.2"]
    TGIS -->|"TLS/crypto"| OpenSSL["OpenSSL<br/>>=0.10.64"]
    TGIS -->|"gRPC serialization"| Protobuf["Protobuf<br/>>=4.25.3"]

    %% External Dependencies - Optional
    TGIS -.->|"optimized attention<br/>(A100/A10)"| FlashAttn["Flash Attention<br/>V2 2.5.6"]
    TGIS -.->|"GPTQ quantization"| AutoGPTQ["Auto-GPTQ<br/>0.7.1"]
    TGIS -.->|"ONNX acceleration"| ONNXRT["ONNX Runtime<br/>GPU 1.18.0"]
    TGIS -.->|"IBM megatron<br/>models"| IBMFMS["IBM FMS<br/>>=0.0"]

    %% External Services
    TGIS -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    TGIS -->|"model weights<br/>volume mount"| PVC["PVC<br/>models-pvc"]

    %% Integration Points (other components that interact with TGIS)
    Kubelet["Kubernetes<br/>Kubelet"] -->|"health probes<br/>HTTP/3000"| TGIS
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"metrics scrape<br/>HTTP/3000"| TGIS
    OTel["OpenTelemetry<br/>Collector"] <--|"tracing export<br/>gRPC"| TGIS

    %% Styling
    style TGIS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff

    %% Required external
    style CUDA fill:#76b900,stroke:#333,color:#fff
    style NCCL fill:#76b900,stroke:#333,color:#fff
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style HFTransformers fill:#ffd21e,stroke:#333
    style OpenSSL fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff

    %% Optional external
    style FlashAttn fill:#ccc,stroke:#666
    style AutoGPTQ fill:#ccc,stroke:#666
    style ONNXRT fill:#ccc,stroke:#666
    style IBMFMS fill:#ccc,stroke:#666

    %% External services
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff

    %% Integration
    style Kubelet fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTel fill:#e8e8e8,stroke:#333
