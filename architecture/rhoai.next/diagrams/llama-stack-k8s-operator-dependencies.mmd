    style GoContainerReg fill:#999,stroke:#333,color:#fff
    style ODHTrustedCA fill:#7ed321,stroke:#333,color:#fff
    style UserConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style OperatorConfigCM fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftSCC fill:#7ed321,stroke:#333,color:#fff
    style LlamaServer fill:#50c878,stroke:#333,color:#fff
