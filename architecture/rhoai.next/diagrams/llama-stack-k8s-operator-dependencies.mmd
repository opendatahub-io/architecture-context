graph LR
    OGXOperator["OGX K8s Operator<br/>(llama-stack-k8s-operator)"]

    %% External Framework Dependencies
    OGXOperator -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    OGXOperator -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.34.3"]
    OGXOperator -->|"API machinery"| APIMachinery["k8s.io/apimachinery<br/>v0.34.3"]
    OGXOperator -->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.34.3"]
    OGXOperator -->|"manifest rendering"| Kustomize["kustomize/api<br/>v0.21.0"]
    OGXOperator -->|"image validation"| ContainerReg["go-containerregistry<br/>v0.20.7"]
    OGXOperator -->|"metrics"| PromClient["prometheus/client_golang<br/>v1.22.0"]

    %% Infrastructure Dependencies
    OGXOperator -->|"webhook TLS certs"| CertManager["cert-manager<br/>(vanilla K8s)"]
    OGXOperator -->|"webhook TLS certs"| ServiceCA["OpenShift service-ca<br/>(OpenShift)"]

    %% Internal Platform Dependencies
    OGXOperator -->|"deploys containers from"| DistroImages["OGX Distribution Images<br/>(starter, remote-vllm,<br/>meta-reference-gpu, custom)"]
    OGXOperator -.->|"CA trust bundle"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap (optional)"]

    %% Integration Points - Inbound
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTPS/8443"| OGXOperator
    K8sAPIServer["Kubernetes API Server"] -->|"webhook calls<br/>HTTPS/9443"| OGXOperator
    K8sAPIServer -->|"watch events<br/>HTTPS/443"| OGXOperator

    %% Integration Points - Outbound (OGX Server)
    subgraph ManagedOGXServer["Managed OGX Server Connections"]
        direction TB
        InferenceProviders["Remote Inference Providers<br/>(vLLM, OpenAI, Azure,<br/>Bedrock, VertexAI, Watsonx)"]
        VectorDBs["Vector Databases<br/>(PGVector, Milvus, Qdrant)"]
        S3["S3-compatible Storage"]
    end

    OGXOperator -->|"manages pods that connect to"| ManagedOGXServer

    %% Runtime Dependencies
    OGXOperator -->|"leader election"| LeaderElection["coordination.k8s.io<br/>Lease: 54e06e98.ogx.io"]
    OGXOperator -->|"SCC binding"| OpenShiftSCC["OpenShift SCC<br/>anyuid"]
    OGXOperator -->|"user config"| UserConfigMaps["User ConfigMaps<br/>(ogx.io/watch=true)"]

    %% Styling
    style OGXOperator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

