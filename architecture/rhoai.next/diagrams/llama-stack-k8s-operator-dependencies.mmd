graph LR
    OGXOp["OGX K8s Operator<br/>(ogx-k8s-operator)"]

    %% External Dependencies (required frameworks/libraries)
    OGXOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    OGXOp -->|"API types"| K8sAPI["k8s.io/api<br/>v0.34.3"]
    OGXOp -->|"manifest rendering"| Kustomize["kustomize/api<br/>v0.21.0"]
    OGXOp -->|"image validation"| GoContainerReg["go-containerregistry<br/>v0.20.7"]

    %% Infrastructure Dependencies
    OGXOp -->|"resource CRUD<br/>HTTPS/443"| KubeAPIServer["Kubernetes API Server"]
    OGXOp -->|"webhook TLS certs"| CertManager["cert-manager 1.13+<br/><i>or OpenShift service-ca</i>"]

    %% Internal Platform Dependencies
    OGXOp -.->|"CA bundle<br/>(optional, auto-detect)"| ODHCABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    OGXOp -->|"container images"| OGXImages["OGX Distribution Images<br/>starter, remote-vllm,<br/>meta-reference-gpu, custom"]
    OGXOp -->|"SCC anyuid<br/>(per-instance RoleBinding)"| OpenShiftSCC["OpenShift SCC"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTPS/8443"| OGXOp

    %% Integration Points - components that consume OGX Operator
    ODHDashboard["ODH Dashboard"] -.->|"manages OGXServer CRs"| OGXOp
    UserWorkloads["User Workloads"] -->|"inference requests<br/>HTTP(S)/8321"| OGXOp

    %% Managed OGX Server outbound dependencies
    subgraph ManagedEgress["Managed OGX Server Egress"]
        direction TB
        vLLM["vLLM<br/>HTTP(S)"]
        OpenAI["OpenAI API<br/>HTTPS/443"]
        Azure["Azure OpenAI<br/>HTTPS/443"]
        Bedrock["AWS Bedrock<br/>HTTPS/443"]
        VertexAI["Google VertexAI<br/>HTTPS/443"]
        Watsonx["IBM Watsonx<br/>HTTPS/443"]
        PGVector["PGVector<br/>TCP"]
        Milvus["Milvus<br/>TCP"]
        Qdrant["Qdrant<br/>TCP"]
        S3["S3 Storage<br/>HTTPS/443"]
    end

    OGXOp -->|"provider connectivity<br/>(from managed pods)"| ManagedEgress

    %% Legacy migration dependency
    OGXOp -.->|"legacy migration<br/>(v1alpha1 → v1beta1)"| LegacyLSD["LlamaStackDistribution<br/>CRDs (legacy)"]

    %% Styling
    style OGXOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Kustomize fill:#999,stroke:#333,color:#fff
    style GoContainerReg fill:#999,stroke:#333,color:#fff
    style KubeAPIServer fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ODHCABundle fill:#7ed321,stroke:#333
    style OGXImages fill:#7ed321,stroke:#333
    style OpenShiftSCC fill:#7ed321,stroke:#333
    style ODHDashboard fill:#7ed321,stroke:#333
    style UserWorkloads fill:#f5a623,stroke:#333
    style LegacyLSD fill:#f5a623,stroke:#333,stroke-dasharray: 5 5
    style vLLM fill:#fff2cc,stroke:#d6b656
    style OpenAI fill:#fff2cc,stroke:#d6b656
    style Azure fill:#fff2cc,stroke:#d6b656
    style Bedrock fill:#fff2cc,stroke:#d6b656
    style VertexAI fill:#fff2cc,stroke:#d6b656
    style Watsonx fill:#fff2cc,stroke:#d6b656
    style PGVector fill:#fff2cc,stroke:#d6b656
    style Milvus fill:#fff2cc,stroke:#d6b656
    style Qdrant fill:#fff2cc,stroke:#d6b656
    style S3 fill:#fff2cc,stroke:#d6b656
