    style UserConfigMaps fill:#f5a623,stroke:#333
    style OpenShiftSCC fill:#f5a623,stroke:#333
    style Registries fill:#f5a623,stroke:#333
    style vLLM fill:#fff2cc,stroke:#d6b656
    style OpenAI fill:#fff2cc,stroke:#d6b656
    style Azure fill:#fff2cc,stroke:#d6b656
