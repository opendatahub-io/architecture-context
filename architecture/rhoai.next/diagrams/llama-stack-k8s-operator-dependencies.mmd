graph LR
    OGX["OGX K8s Operator<br/>(ogx-k8s-operator)"]

    %% External Dependencies (required)
    OGX -->|"operator framework<br/>v0.22.4"| CR["controller-runtime"]
    OGX -->|"K8s API types<br/>v0.34.3"| K8sAPI["k8s.io/api"]
    OGX -->|"API machinery<br/>v0.34.3"| APIMach["k8s.io/apimachinery"]
    OGX -->|"K8s client<br/>v0.34.3"| ClientGo["k8s.io/client-go"]
    OGX -->|"manifest rendering<br/>v0.21.0"| Kustomize["kustomize/api"]
    OGX -->|"image parsing<br/>v0.20.7"| ContainerReg["go-containerregistry"]
    OGX -->|"metrics<br/>v1.22.0"| PromClient["prometheus/client_golang"]
    OGX -->|"webhook TLS<br/>(one of)"| CertManager["cert-manager /<br/>OpenShift service-ca"]

    %% Internal Platform Dependencies
    OGX -->|"distribution images<br/>(container pull)"| OGXImages["OGX Distribution<br/>Images<br/>(starter, remote-vllm,<br/>meta-reference-gpu,<br/>postgres-demo, custom)"]
    OGX -.->|"CA bundle<br/>(optional read)"| ODHCaBundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Integration Points - Incoming
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTPS/8443"| OGX
    K8sAPIServer["Kubernetes API<br/>Server"] -->|"watch events<br/>HTTPS/443"| OGX
    LeaderElection["Leader Election<br/>(coordination.k8s.io)"] -.->|"Lease resource<br/>54e06e98.ogx.io"| OGX
    UserConfigMaps["User ConfigMaps<br/>(ogx.io/watch=true)"] -.->|"watched for<br/>config changes"| OGX

    %% Integration Points - Outgoing (from managed OGX server)
    subgraph "Remote Providers (from managed OGX server)"
        vLLM["vLLM"]
        OpenAI["OpenAI API"]
        Azure["Azure OpenAI"]
        Bedrock["AWS Bedrock"]
        VertexAI["Google VertexAI"]
        Watsonx["IBM Watsonx"]
        VectorDBs["PGVector / Milvus /<br/>Qdrant"]
        S3["S3 Storage"]
    end

    OGX -->|"manages servers<br/>connecting to"| vLLM
    OGX -->|"manages servers<br/>connecting to"| OpenAI
    OGX -->|"manages servers<br/>connecting to"| Azure
    OGX -->|"manages servers<br/>connecting to"| Bedrock
    OGX -->|"manages servers<br/>connecting to"| VertexAI
    OGX -->|"manages servers<br/>connecting to"| Watsonx
    OGX -->|"manages servers<br/>connecting to"| VectorDBs
    OGX -->|"manages servers<br/>connecting to"| S3

    %% OpenShift Integration
    OGX -->|"SCC anyuid<br/>(use verb)"| OpenShiftSCC["OpenShift SCC"]
    OGX -->|"CRUD resources<br/>HTTPS/443"| K8sAPIServer

    %% Container Registries
    OGX -->|"image pull<br/>HTTPS/443"| Registries["Container Registries<br/>(docker.io, quay.io)"]

    %% Styling
    style OGX fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CR fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style APIMach fill:#999,stroke:#333
