graph LR
    Operator["llama-stack-k8s-operator<br/>(Go Operator)"]

    %% External Dependencies (libraries)
    Operator -->|"controller framework<br/>v0.22.4"| ControllerRuntime["controller-runtime"]
    Operator -->|"manifest rendering<br/>v0.21.0"| KustomizeAPI["kustomize/api"]
    Operator -->|"image validation<br/>v0.20.7"| GoContainerReg["go-containerregistry"]

    %% Internal Platform Dependencies
    Operator -->|"reads CA certs"| ODHTrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    Operator -->|"reads user config"| UserConfigMaps["User ConfigMaps<br/>(caBundle, userConfig)"]
    Operator -->|"reads feature flags"| OperatorConfigCM["llama-stack-operator-config<br/>ConfigMap"]
    Operator -->|"binds anyuid SCC"| OpenShiftSCC["OpenShift SCC<br/>(security.openshift.io)"]

    %% Managed Component
    Operator -->|"deploys & probes<br/>HTTP/8321"| LlamaServer["Llama Stack Server<br/>(managed pods)"]

    %% Infrastructure Dependencies
    Operator -->|"resource CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Optional Dependencies
    Operator -.->|"external access<br/>HTTP/80"| IngressCtrl["OpenShift Ingress<br/>Controller"]
    Prometheus["Prometheus"] -.->|"scrapes metrics<br/>HTTPS/8443"| Operator

