graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / API Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: rhoai/odh-trainer-rhel9"]

        subgraph ControllerPorts["Controller Ports"]
            WebhookPort["9443/TCP Webhook<br/>HTTPS TLS<br/>API Server Client Cert"]
            MetricsPort["8443/TCP Metrics<br/>HTTPS TLS<br/>No Auth"]
            HealthPort["8081/TCP Health<br/>HTTP<br/>No Auth"]
        end

        Controller --- WebhookPort
        Controller --- MetricsPort
        Controller --- HealthPort
    end

    subgraph TrainingNS["TRAINING NAMESPACE (user-namespace)"]
        subgraph NetworkPolicyZone["NetworkPolicy (per TrainJob)"]
            Rank0["Training Pod (rank-0)<br/>28080/TCP Metrics HTTP<br/>29500/TCP PyTorch Master TCP<br/>2222/TCP SSH (MPI)"]
            Workers["Training Worker Pods<br/>29500/TCP PyTorch TCP<br/>2222/TCP SSH (MPI)<br/>Dynamic NCCL ports"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>(PodMonitor)"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / Client Cert"| K8sAPI

    %% Control plane to operator
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-managed)<br/>API Server TLS Client Cert<br/>failurePolicy=Fail"| WebhookPort

    %% Operator to control plane (bidirectional)
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRD watches, CRUD, status"| K8sAPI

    %% Operator to training pods
    Controller -->|"HTTP/28080<br/>plaintext<br/>No Auth<br/>NetworkPolicy enforced<br/>RHAI Progression"| Rank0

    %% Training pod communication
    Workers -->|"TCP/29500<br/>plaintext<br/>PyTorch rendezvous"| Rank0
    Rank0 <-->|"TCP Dynamic<br/>plaintext NCCL<br/>NetworkPolicy: same-job"| Workers
    Rank0 -->|"SSH/2222<br/>ECDSA P521 key<br/>MPI launch"| Workers

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>PodMonitor scrape"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef training fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef networkpolicy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,stroke-dasharray: 5 5

    class User external
    class K8sAPI controlplane
    class Controller,WebhookPort,MetricsPort,HealthPort operator
    class Rank0,Workers training
    class Prometheus monitoring
