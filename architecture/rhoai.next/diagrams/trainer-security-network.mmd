graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / OIDC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub (Trusted)"]
        direction TB

        subgraph ControllerPod["trainer-controller-manager Pod"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS auto-rotated"]
            MetricsSrv["Metrics Server<br/>8443/TCP HTTPS<br/>TLS 1.2+"]
            HealthSrv["Health Probes<br/>8081/TCP HTTP"]
            Reconciler["TrainJob Reconciler"]
            ProgressionTracker["RHAI Progression Tracker"]
        end

        Service["Service: kubeflow-trainer-controller-manager<br/>ClusterIP<br/>443→9443 (webhook), 8443→8443 (metrics)"]
    end

    subgraph UserNS["USER NAMESPACES (Training Workloads)"]
        direction TB

        subgraph TrainingJobPods["Training Job Pods"]
            TrainPod["Training Pod (rank 0)<br/>28080/TCP HTTP<br/>Prometheus metrics"]
            MPILauncher["MPI Launcher Pod"]
            MPIWorkers["MPI Worker Pods<br/>2222/TCP SSH"]
        end

        NetPol["NetworkPolicy<br/>(dynamically created)<br/>Restricts 28080 to controller only"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>PodMonitor<br/>insecureSkipVerify"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OIDC"| K8sAPI

    %% Control Plane → Operator
    K8sAPI -->|"HTTPS/9443<br/>TLS auto-rotated<br/>API server client cert"| Service

    %% Operator → Control Plane
    Reconciler -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| K8sAPI

    %% Operator → Training Pods
    ProgressionTracker -->|"⚠️ HTTP/28080<br/>PLAINTEXT<br/>No Auth<br/>(NetworkPolicy restricted)"| TrainPod

    %% MPI Communication
    MPILauncher -->|"SSH/2222<br/>SSH encryption<br/>RSA key pair"| MPIWorkers

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>insecureSkipVerify"| MetricsSrv

    %% NetworkPolicy enforcement
    NetPol -.->|"enforces"| TrainPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class WebhookSrv,MetricsSrv,HealthSrv,Reconciler,ProgressionTracker,Service operator
    class TrainPod,MPILauncher,MPIWorkers,NetPol userns
    class Prometheus monitoring
