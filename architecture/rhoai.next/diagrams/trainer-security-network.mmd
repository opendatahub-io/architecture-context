graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / OIDC / Client Certs"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB
        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: rhoai/odh-trainer-rhel9<br/>FIPS: strictfipsruntime + UBI9"]

        subgraph Ports["Exposed Ports"]
            WebhookPort["Webhook: 9443/TCP<br/>HTTPS, TLS auto-rotated<br/>Auth: API server client cert"]
            MetricsPort["Metrics: 8443/TCP<br/>HTTPS, TLS 1.2+<br/>Auth: None"]
            HealthPort["Health: 8081/TCP<br/>HTTP, plaintext<br/>Auth: None"]
        end

        Controller --- WebhookPort
        Controller --- MetricsPort
        Controller --- HealthPort

        CertCtrl["cert-controller (OPA)<br/>Auto cert rotation<br/>Secret: kubeflow-trainer-webhook-cert"]
        CertCtrl -.->|"rotates"| WebhookPort
    end

    subgraph UserNS["USER NAMESPACE (Per-TrainJob)"]
        direction TB
        TrainingPod["Training Pod (rank 0)<br/>28080/TCP HTTP<br/>NetworkPolicy restricted"]
        MPIWorkers["MPI Worker Pods<br/>2222/TCP SSH<br/>RSA key pair auth"]
        NetPol["NetworkPolicy<br/>Restricts ingress to:<br/>- same-job pods<br/>- controller namespace"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OIDC"| K8sAPI

    %% Control Plane → Operator (webhooks)
    K8sAPI -->|"HTTPS/9443<br/>TLS auto-rotated<br/>API server client cert"| WebhookPort

    %% Operator → Control Plane
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>CRUD: CRDs, JobSets, Pods,<br/>Secrets, ConfigMaps, NetworkPolicies"| K8sAPI

    %% Operator → Training Pods (plaintext!)
    Controller -->|"⚠️ HTTP/28080<br/>PLAINTEXT<br/>No auth<br/>Progression metrics polling"| TrainingPod

    %% MPI internal
    TrainingPod -->|"SSH/2222<br/>SSH encryption<br/>RSA key pair"| MPIWorkers

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>insecureSkipVerify"| MetricsPort

    %% NetworkPolicy enforcement
    NetPol -.->|"enforces"| TrainingPod
    NetPol -.->|"enforces"| MPIWorkers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef security fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookPort,MetricsPort,HealthPort,CertCtrl operator
    class TrainingPod,MPIWorkers warning
    class NetPol security
    class Prometheus monitoring
