graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard Client"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE (TLS 1.2+)"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / mTLS"]
    end

    subgraph ControllerNamespace["CONTROLLER NAMESPACE (Internal)"]
        direction TB

        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/trainer:odh-3.5-ea1"]

        WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-signed cert)<br/>Auth: API server client cert"]

        MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS<br/>TLS (secure serving)<br/>Auth: None (insecureSkipVerify)"]

        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz<br/>Auth: None"]

        WebhookCert["kubeflow-trainer-webhook-cert<br/>Opaque (TLS)<br/>cert-controller managed<br/>Auto-rotate: Yes"]
    end

    subgraph UserNamespace["USER NAMESPACE (Training Workloads)"]
        direction TB

        TrainingPod["Training Pod<br/>Metrics: 2113/TCP HTTP<br/>No Encryption<br/>Auth: NetworkPolicy"]

        MPILauncher["MPI Launcher Pod<br/>SSH Client"]

        MPINodes["MPI Node Pods<br/>2222/TCP SSH<br/>ECDSA encryption<br/>Auth: SSH public key"]

        SSHSecret["SSH Secret<br/>{trainjob}-mpi-ssh-auth<br/>ECDSA keypair<br/>Generated per TrainJob"]

        NetPolicy["NetworkPolicy<br/>Restricts 2113/TCP ingress<br/>to controller pods only"]
    end

    subgraph ExternalControllers["PLATFORM CONTROLLERS"]
        JobSetCtrl["JobSet Controller<br/>jobset.x-k8s.io"]
        KueueCtrl["Kueue / scheduler-plugins<br/>scheduling.x-k8s.io<br/>(optional)"]
        VolcanoCtrl["Volcano<br/>scheduling.volcano.sh<br/>(optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["PodMonitor<br/>Scrapes 8443/TCP<br/>insecureSkipVerify: true"]
    end

    %% External → API
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OIDC)"| APIServer

    %% API ↔ Webhook
    APIServer -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert"| WebhookServer

    %% Controller ↔ API
    Controller <-->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| APIServer

    %% Controller → Training Pod metrics
    Controller -->|"HTTP/2113<br/>No encryption<br/>NetworkPolicy restricted"| TrainingPod

    %% MPI SSH
    MPILauncher -->|"SSH/2222<br/>ECDSA encryption<br/>Public key auth"| MPINodes

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>insecureSkipVerify"| MetricsEndpoint

    %% Platform controllers via API
    JobSetCtrl <-->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| APIServer
    KueueCtrl <-->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| APIServer
    VolcanoCtrl <-->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px

    class User external
    class APIServer controlplane
    class Controller,WebhookServer,MetricsEndpoint,HealthProbes controller
    class TrainingPod,MPILauncher,MPINodes workload
    class JobSetCtrl,KueueCtrl,VolcanoCtrl platform
    class WebhookCert,SSHSecret,NetPolicy security
    class Prometheus monitoring
