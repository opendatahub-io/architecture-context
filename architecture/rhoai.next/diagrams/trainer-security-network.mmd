graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist<br/>(kubectl / RHOAI Dashboard)"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE (Trusted)"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph OperatorNS["NAMESPACE: opendatahub (Operator)"]
        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/trainer:odh-3.5-ea1"]

        subgraph ControllerPorts["Controller Ports"]
            WebhookPort["Webhook: 9443/TCP<br/>HTTPS (self-managed TLS)<br/>Auth: K8s API mTLS"]
            MetricsPort["Metrics: 8443/TCP<br/>HTTPS (TLS)<br/>Auth: None (PodMonitor)"]
            HealthPort["Health: 8081/TCP<br/>HTTP (plaintext)<br/>Auth: None"]
        end
    end

    subgraph UserNS["NAMESPACE: {user-namespace} (Training Workloads)"]
        direction TB

        subgraph TrainingPods["Training Pods (JobSet managed)"]
            Rank0["Rank-0 Pod (Master)<br/>29500/TCP PyTorch c10d<br/>28080/TCP RHAI Metrics"]
            WorkerPods["Worker Pods (1..N)<br/>29500/TCP PyTorch c10d<br/>Dynamic ports NCCL/Gloo"]
        end

        subgraph NetworkPolicies["NetworkPolicy Enforcement (RHAI)"]
            NP["Per-TrainJob NetworkPolicy<br/>Ingress: controller labels + same-job pods<br/>Egress: restricted"]
        end

        subgraph Secrets["Secrets"]
            WebhookCert["kubeflow-trainer-webhook-cert<br/>kubernetes.io/tls<br/>Provisioned: cert-controller<br/>Auto-Rotate: Yes"]
            MPISecret["{trainjob}-mpi-ssh-auth<br/>Opaque (ECDSA P521)<br/>Provisioned: Controller<br/>Auto-Rotate: No (lifecycle-bound)"]
        end

        subgraph InitContainers["Init Containers"]
            DatasetInit["dataset-initializer"]
            ModelInit["model-initializer"]
        end

        subgraph DataCachePods["Data Cache (Optional, LWS managed)"]
            DCHead["Data Cache Head<br/>gRPC Arrow Flight<br/>No TLS, No Auth"]
            DCWorkers["Data Cache Workers<br/>gRPC Arrow Flight<br/>No TLS, No Auth"]
        end
    end

    subgraph Monitoring["OPENSHIFT MONITORING"]
        Prometheus["Prometheus<br/>(PodMonitor scrape)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        IcebergStore["Iceberg Metadata Store<br/>HTTP/S3<br/>Varies Auth"]
    end

    %% Control plane flows
    User -->|"kubectl apply TrainJob<br/>HTTPS/443 TLS 1.2+<br/>Bearer Token"| APIServer
    APIServer -->|"Webhook validation<br/>HTTPS/9443<br/>mTLS (API server cert)"| WebhookPort
    APIServer -->|"Watch events<br/>HTTPS/443 TLS 1.2+<br/>SA Bearer Token"| Controller
    Controller -->|"CRUD operations<br/>HTTPS/443 TLS 1.2+<br/>SA Bearer Token"| APIServer

    %% RHAI metrics flow
    Controller -->|"Poll metrics<br/>HTTP/28080<br/>No TLS, No Auth<br/>NetworkPolicy restricted"| Rank0

    %% Training pod inter-communication
    WorkerPods -->|"c10d rendezvous<br/>TCP/29500<br/>No TLS, No Auth<br/>NetworkPolicy: same-job"| Rank0
    Rank0 <-->|"NCCL/Gloo collectives<br/>Dynamic ports TCP/UDP<br/>No TLS<br/>NetworkPolicy: same-job"| WorkerPods

    %% Monitoring
    Prometheus -->|"Scrape metrics<br/>HTTPS/8443 TLS<br/>insecureSkipVerify"| MetricsPort

    %% Data cache flows
    Rank0 -.->|"Arrow Flight gRPC<br/>No TLS, No Auth"| DCHead
    DCHead -.->|"Arrow Flight do_put<br/>No TLS, No Auth"| DCWorkers
    Rank0 -.->|"Arrow Flight do_get<br/>No TLS, No Auth"| DCWorkers
    DCHead -.->|"Read metadata<br/>HTTP/S3<br/>Varies"| IcebergStore

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef security fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class User external
    class APIServer controlplane
    class Controller,WebhookPort,MetricsPort,HealthPort operator
    class Rank0,WorkerPods,DatasetInit,ModelInit workload
    class DCHead,DCWorkers workload
    class Prometheus monitoring
    class IcebergStore externalservice
    class NP,WebhookCert,MPISecret security
