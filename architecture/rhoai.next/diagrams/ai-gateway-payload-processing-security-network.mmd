graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (AI Gateway)"]
        Gateway["AI Gateway (Istio Envoy)<br/>443/TCP → 9004/TCP<br/>TLS 1.2+ termination<br/>HTTPRoute per ExternalModel"]
    end

    subgraph ServiceMesh["SERVICE MESH (Internal)"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            direction TB
            PP["AI Gateway Payload Processing<br/>SA: {name}-{release}<br/>Ports: 9004/TCP (gRPC), 9005/TCP (health)<br/>FIPS: strictfipsruntime"]

            subgraph Pipeline["Plugin Pipeline"]
                direction LR
                P1["maas-headers-guard"]
                P2["model-provider-resolver"]
                P3["api-translation"]
                P4["apikey-injection"]
                P5["nemo-guards"]
                P1 --> P2 --> P3 --> P4 --> P5
            end

            subgraph Ctrl["Controllers"]
                direction LR
                C1["ExternalModel"]
                C2["ExternalProvider"]
                C3["Legacy Migration"]
            end
        end

        NeMo["NeMo Guardrails<br/>POST /v1/guardrail/checks<br/>HTTP (no mTLS)<br/>Auth: None"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>mTLS (in-cluster)<br/>SA token auth"]
    end

    subgraph IstioEgress["EGRESS (Istio TLS Origination)"]
        direction TB
        ExtNameSvc["ExternalName Service<br/>+ ServiceEntry (MESH_EXTERNAL)<br/>+ DestinationRule (TLS SIMPLE)"]
    end

    subgraph ExternalProviders["EXTERNAL LLM PROVIDERS"]
        OpenAI["api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer Token"]
        Anthropic["api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key header"]
        Azure["{resource}.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key header"]
        Bedrock["bedrock-runtime.{region}<br/>.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS SigV4"]
        Vertex["{endpoint}.aiplatform<br/>.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer (OAuth2)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (user)"| Gateway
    Gateway -->|"gRPC/9004<br/>plaintext (mesh-internal)<br/>No auth"| PP
    PP -->|"HTTP<br/>configurable encryption<br/>No auth"| NeMo
    PP -->|"HTTPS/443<br/>mTLS (in-cluster)<br/>SA token"| K8sAPI

    PP -->|"Mutated request<br/>via Envoy"| ExtNameSvc
    ExtNameSvc -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>Bearer Token"| OpenAI
    ExtNameSvc -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>x-api-key"| Anthropic
    ExtNameSvc -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>api-key"| Azure
    ExtNameSvc -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>SigV4"| Bedrock
    ExtNameSvc -->|"HTTPS/443<br/>TLS 1.2+ (SIMPLE)<br/>Bearer/OAuth2"| Vertex

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef provider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef plugin fill:#4a90e2,stroke:#333,color:#fff
    classDef controller fill:#7ed321,stroke:#333,color:#fff

    class Client external
    class Gateway ingress
    class PP,NeMo,K8sAPI servicemesh
    class ExtNameSvc egress
    class OpenAI,Anthropic,Azure,Bedrock,Vertex provider
    class P1,P2,P3,P4,P5 plugin
    class C1,C2,C3 controller
