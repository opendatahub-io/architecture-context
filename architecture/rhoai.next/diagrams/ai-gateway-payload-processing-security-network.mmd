graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(inference consumer)"]
    end

    subgraph Ingress["INGRESS (Gateway API Data Plane)"]
        Gateway["Gateway API Gateway (Envoy Proxy)<br/>443/TCP → internal routing<br/>TLS 1.2+ termination<br/>Client token authentication"]
        EnvoyFilter["Istio EnvoyFilter<br/>Attaches ExtProc to Gateway"]
        Gateway --- EnvoyFilter
    end

    subgraph ServiceInternal["SERVICE MESH (Internal - Same Namespace)"]
        direction TB

        subgraph PayloadProc["Payload Processing Pod"]
            ExtProc["ai-gateway-payload-processing<br/>9004/TCP gRPC (plaintext)<br/>SA: payload-processing-{release}<br/>Image: quay.io/opendatahub/<br/>odh-ai-gateway-payload-processing"]
            HealthCheck["Health Check<br/>9005/TCP HTTP (plaintext)<br/>Liveness/Readiness probes"]
        end
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph ExternalProviders["EXTERNAL LLM PROVIDERS (Untrusted)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key header"]
        AzureOAI["Azure OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key header"]
        Bedrock["AWS Bedrock API<br/>bedrock.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        VertexAI["Google Vertex AI API<br/>aiplatform.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster)"]
        NemoSvc["NeMo Guardrails Service<br/>configurable port<br/>HTTP plaintext<br/>Auth: None"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Client token"| Gateway
    Gateway -->|"gRPC/9004<br/>plaintext<br/>No auth (pod-local)"| ExtProc
    ExtProc -->|"gRPC/9004<br/>plaintext<br/>Mutated request/response"| Gateway

    ExtProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer token<br/>(watch ExternalModel, Secrets)"| K8sAPI

    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| AzureOAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Bedrock
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| VertexAI

    ExtProc -->|"HTTP/configurable<br/>plaintext<br/>No auth<br/>POST /v1/guardrail/checks"| NemoSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,EnvoyFilter ingress
    class ExtProc,HealthCheck servicemesh
    class K8sAPI controlplane
    class OpenAI,Anthropic,AzureOAI,Bedrock,VertexAI externalservice
    class NemoSvc warning
