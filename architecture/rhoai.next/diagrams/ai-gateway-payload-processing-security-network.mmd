graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Gateway / Envoy Proxy<br/>443/TCP → internal<br/>TLS 1.2+<br/>Per-Gateway Auth"]
    end

    subgraph Internal["INTERNAL (Same Namespace as Gateway)"]
        direction TB

        subgraph BBRService["AI Gateway Payload Processing"]
            ExtProc["ext_proc gRPC Server<br/>9004/TCP plaintext<br/>No Auth (Envoy-internal)"]
            HealthCheck["Health Check<br/>9005/TCP HTTP plaintext"]

            subgraph PluginChain["Plugin Chain (Request Order)"]
                direction LR
                P1["body-field-to-header"]
                P2["model-provider-resolver"]
                P3["api-translation"]
                P4["apikey-injection"]
            end

            subgraph OptionalPlugins["Optional Plugins"]
                NReq["nemo-request-guard"]
                NResp["nemo-response-guard"]
            end
        end

        BBRService --- SA["SA: payload-processing-release<br/>Image: rhoai/odh-ai-gateway-payload-processing-rhel9<br/>FIPS: strictfipsruntime"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
        ExternalModelCRD["ExternalModel CRD<br/>maas.opendatahub.io/v1alpha1"]
        ManagedSecrets["Secrets<br/>label: bbr-managed=true"]
    end

    subgraph OptionalService["OPTIONAL INTERNAL SERVICE"]
        NeMo["NeMo Guardrails<br/>configurable port<br/>HTTP/HTTPS<br/>No Auth<br/>POST /v1/guardrail/checks"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (via Gateway)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS<br/>Bearer Token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS<br/>x-api-key header"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>api-key header"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>Bearer Token"]
        Vertex["Google Vertex AI<br/>443/TCP HTTPS<br/>Bearer Token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"gRPC ext_proc/9004<br/>plaintext<br/>No Auth (network isolation)"| ExtProc
    ExtProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    K8sAPI --- ExternalModelCRD
    K8sAPI --- ManagedSecrets
    NReq -->|"HTTP POST<br/>configurable<br/>No Auth"| NeMo
    NResp -->|"HTTP POST<br/>configurable<br/>No Auth"| NeMo
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>API key injected"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key injected"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key injected"| Azure
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>API key injected"| Bedrock
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>API key injected"| Vertex

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sainfo fill:#f5f5f5,stroke:#ccc,stroke-width:1px,stroke-dasharray:5 5

    class Client external
    class Gateway ingress
    class ExtProc,HealthCheck,P1,P2,P3,P4,NReq,NResp internal
    class K8sAPI,ExternalModelCRD,ManagedSecrets k8scontrol
    class NeMo optional
    class OpenAI,Anthropic,Azure,Bedrock,Vertex externalservice
    class SA sainfo
