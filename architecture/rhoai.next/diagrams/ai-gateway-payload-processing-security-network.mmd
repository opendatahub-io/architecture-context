graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph GatewayPlane["GATEWAY API DATA PLANE"]
        Gateway["Gateway API Gateway<br/>(Envoy Proxy)<br/>443/TCP → internal<br/>TLS 1.2+ termination"]
        EnvoyFilter["Istio EnvoyFilter<br/>Attaches ExtProc to Gateway"]
        EnvoyFilter -.->|configures| Gateway
    end

    subgraph PayloadProcessing["PAYLOAD PROCESSING SERVICE"]
        direction TB
        ExtProc["ai-gateway-payload-processing<br/>SA: payload-processing-{release}<br/>Image: quay.io/opendatahub/odh-ai-gateway-payload-processing"]

        subgraph Ports["Exposed Ports"]
            GRPC["9004/TCP gRPC ExtProc<br/>plaintext, no auth<br/>(pod-local only)"]
            Health["9005/TCP HTTP health<br/>plaintext, no auth<br/>(kubelet probes)"]
        end

        subgraph Plugins["Plugin Pipeline"]
            P1["body-field-to-header"]
            P2["model-provider-resolver"]
            P3["api-translation"]
            P4["apikey-injection"]
            P5["nemo-request-guard<br/>(optional)"]
            P6["nemo-response-guard<br/>(optional)"]
        end
    end

    subgraph K8sServices["KUBERNETES SERVICES (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer token"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        NemoSvc["NeMo Guardrails Service<br/>configurable port<br/>HTTP plaintext ⚠<br/>No auth"]
    end

    subgraph ExternalProviders["EXTERNAL LLM PROVIDERS"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key header"]
        Azure["Azure OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key header"]
        Bedrock["AWS Bedrock API<br/>bedrock.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        Vertex["Google Vertex AI API<br/>aiplatform.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Client token"| Gateway
    Gateway -->|"gRPC/9004<br/>plaintext<br/>No auth (pod-local)"| GRPC
    ExtProc -->|"mutated request<br/>gRPC/9004"| Gateway

    P2 -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer token<br/>Watch ExternalModel CRDs"| K8sAPI
    P4 -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer token<br/>Watch labeled Secrets"| K8sAPI

    P5 -->|"HTTP configurable<br/>plaintext ⚠<br/>No auth<br/>POST /v1/guardrail/checks"| NemoSvc
    P6 -->|"HTTP configurable<br/>plaintext ⚠<br/>No auth<br/>POST /v1/guardrail/checks"| NemoSvc

    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected Bearer"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected x-api-key"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected api-key"| Azure
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected Bearer"| Bedrock
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected Bearer"| Vertex

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef processing fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef provider fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#ffcccc,stroke:#cc0000,stroke-width:2px

    class Client external
    class Gateway,EnvoyFilter gateway
    class ExtProc,GRPC,Health,P1,P2,P3,P4,P5,P6 processing
    class K8sAPI k8s
    class NemoSvc warning
    class OpenAI,Anthropic,Azure,Bedrock,Vertex provider
