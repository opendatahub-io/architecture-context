graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["Istio Gateway (Envoy Proxy)<br/>443/TCP → internal routing<br/>TLS 1.2+ termination<br/>AuthN: per Gateway config"]
    end

    subgraph Internal["SERVICE (Network Isolated - Same Namespace as Gateway)"]
        direction TB

        subgraph PayloadProc["AI Gateway Payload Processing"]
            direction TB
            ExtProc["ext_proc gRPC Server<br/>9004/TCP plaintext<br/>Auth: None (Envoy-internal)<br/>SA: payload-processing-{release}"]
            Health["Health Check<br/>9005/TCP HTTP plaintext"]

            subgraph Plugins["Plugin Chain"]
                direction LR
                P1["body-field-to-header"]
                P2["model-provider-resolver"]
                P3["nemo-request-guard<br/>(optional)"]
                P4["api-translation"]
                P5["apikey-injection"]
            end

            subgraph Stores["In-Memory Stores"]
                ModelStore["modelInfoStore<br/>(ExternalModel cache)"]
                SecretStoreBox["secretStore<br/>(API keys cache)<br/>⚠ Sensitive"]
            end
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA bearer token auth"]
    end

    subgraph OptionalServices["OPTIONAL SERVICES"]
        NemoSvc["NeMo Guardrails Service<br/>configurable port<br/>HTTP/HTTPS (configurable)<br/>Auth: None"]
    end

    subgraph ProviderEgress["EXTERNAL CLOUD PROVIDERS (via Gateway)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: x-api-key"]
        Azure["Azure OpenAI<br/>{resource}.openai.azure.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: api-key"]
        Bedrock["AWS Bedrock<br/>{region}.bedrock.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
        Vertex["Google Vertex AI<br/>{region}-aiplatform.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Client auth"| Gateway
    Gateway -->|"gRPC ext_proc/9004<br/>plaintext<br/>No auth (network isolation)"| ExtProc
    ExtProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA bearer token"| K8sAPI
    ExtProc -->|"HTTP(S)/configurable<br/>No auth<br/>POST /v1/guardrail/checks"| NemoSvc
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>API key (injected)"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key (injected)"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key (injected)"| Azure
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (injected)"| Bedrock
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (injected)"| Vertex

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef provider fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef sensitive fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class ExtProc,Health,P1,P2,P3,P4,P5 internal
    class ModelStore sensitive
    class SecretStoreBox sensitive
    class K8sAPI k8s
    class NemoSvc optional
    class OpenAI,Anthropic,Azure,Bedrock,Vertex provider
