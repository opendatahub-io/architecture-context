graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(Namespace: system)"]
        SA_MR["model-registry<br/>(Namespace: model-registry)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["model-registry-manager-rolebinding"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["model-registry-manager-role"]
    end

    subgraph CoreAPIResources["API Group: core ('')"]
        Services["services"]
    end

    subgraph KServeAPIResources["API Group: serving.kserve.io"]
        ISVC["inferenceservices"]
        ISVCFinalizers["inferenceservices/finalizers"]
    end

    subgraph IstioAuthz["Istio AuthorizationPolicy"]
        AuthzPolicy["model-registry<br/>Action: ALLOW<br/>All authenticated mesh traffic"]
    end

    subgraph DatabaseAuth["Database Authentication"]
        MySQLAuth["MySQL Auth<br/>Source: mysql-secret<br/>Type: Username/Password"]
        PGAuth["PostgreSQL Auth<br/>Source: model-registry-db-secrets<br/>Type: Username/Password"]
        CatalogPGAuth["Catalog PG Auth<br/>Source: model-catalog-postgres<br/>Type: Username/Password"]
    end

    subgraph ExternalAuth["External Service Auth"]
        HFAuth["Hugging Face API<br/>Source: model-catalog-hf-api-key<br/>Type: API Key (optional)"]
        BearerAuth["Controller → MR API<br/>Type: Bearer Token<br/>Source: SA Token"]
        SigstoreAuth["Sigstore Auth<br/>Type: K8s SA Token (OIDC)"]
    end

    %% RBAC flow
    SA_Controller -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, patch,<br/>update, watch"| ISVC
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| ISVCFinalizers

    %% Istio AuthZ
    SA_MR -.->|"protected by"| AuthzPolicy
    AuthzPolicy -.->|"enforces mTLS on"| Services

    %% Database Auth flows
    SA_MR -.->|"accesses via"| MySQLAuth
    SA_MR -.->|"accesses via"| PGAuth

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_MR fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style ISVCFinalizers fill:#7ed321,stroke:#333
    style AuthzPolicy fill:#ffe6cc,stroke:#d79b00
    style MySQLAuth fill:#f8cecc,stroke:#b85450
    style PGAuth fill:#f8cecc,stroke:#b85450
    style CatalogPGAuth fill:#f8cecc,stroke:#b85450
    style HFAuth fill:#f8cecc,stroke:#b85450
    style BearerAuth fill:#f8cecc,stroke:#b85450
    style SigstoreAuth fill:#f8cecc,stroke:#b85450
