graph TD
    subgraph "Service Accounts"
        SA_Controller["controller-manager<br/>(system namespace)"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager["model-registry-manager-rolebinding<br/>(cluster-wide)"]
        RB_Leader["model-registry-leader-election-rolebinding<br/>(namespace: system)"]
    end

    subgraph "Roles"
        CR_Manager["ClusterRole:<br/>model-registry-manager-role"]
        R_Leader["Role:<br/>model-registry-leader-election-role<br/>(namespace: system)"]
    end

    subgraph "API Resources - Manager Role"
        CoreServices["core (v1)<br/>services<br/>▸ get, list, watch"]
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>▸ get, list, watch, update, patch"]
        ISFinalizers["serving.kserve.io<br/>inferenceservices/finalizers<br/>▸ get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph "API Resources - Leader Election Role"
        ConfigMaps["core (v1)<br/>configmaps<br/>▸ get, list, watch, create,<br/>update, patch, delete"]
        Leases["coordination.k8s.io<br/>leases<br/>▸ get, list, watch, create,<br/>update, patch, delete"]
        Events["core (v1)<br/>events<br/>▸ create, patch"]
    end

    subgraph "Istio Authorization"
        AuthPolicy["AuthorizationPolicy:<br/>model-registry"]
        IstioGWSA["Allowed Principal:<br/>istio-ingressgateway SA"]
        InternalAuth["Allowed: requests with<br/>Authorization header<br/>(no kubeflow-userid header)"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    RB_Leader -->|"grants"| R_Leader

    %% Manager Role → Resources
    CR_Manager -->|"read-only"| CoreServices
    CR_Manager -->|"read + write"| InferenceServices
    CR_Manager -->|"full CRUD"| ISFinalizers

    %% Leader Election Role → Resources
    R_Leader -->|"full CRUD"| ConfigMaps
    R_Leader -->|"full CRUD"| Leases
    R_Leader -->|"create + patch"| Events

    %% Istio Auth
    AuthPolicy -->|"allows"| IstioGWSA
    AuthPolicy -->|"allows"| InternalAuth

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style CRB_Manager fill:#b8e986,stroke:#333
    style RB_Leader fill:#b8e986,stroke:#333
    style CoreServices fill:#7ed321,stroke:#333,color:#fff
    style InferenceServices fill:#7ed321,stroke:#333,color:#fff
    style ISFinalizers fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#50e3c2,stroke:#333
    style Leases fill:#50e3c2,stroke:#333
    style Events fill:#50e3c2,stroke:#333
    style AuthPolicy fill:#e8e8e8,stroke:#333
    style IstioGWSA fill:#e8e8e8,stroke:#333
    style InternalAuth fill:#e8e8e8,stroke:#333
