graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(ServiceAccount)"]
        SA_Registry["model-registry<br/>(ServiceAccount)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["model-registry-manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics_Auth["metrics-auth-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics_Reader["metrics-reader-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace: system)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["model-registry-manager-role<br/>(ClusterRole)"]
        CR_Metrics_Auth["metrics-auth-role<br/>(ClusterRole)"]
        CR_Metrics_Reader["metrics-reader-role<br/>(ClusterRole)"]
    end

    subgraph Roles["Roles (namespace: system)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph APIResources_KServe["API Resources: serving.kserve.io"]
        InferenceServices["InferenceServices<br/>get, list, watch,<br/>update, patch"]
        InferenceServicesFinalizers["InferenceServices/finalizers<br/>get, list, watch, create,<br/>delete, update, patch"]
    end

    subgraph APIResources_Core["API Resources: core ('')"]
        Services["Services<br/>get, list, watch"]
        ConfigMaps["ConfigMaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        Events["Events<br/>create, patch"]
    end

    subgraph APIResources_Coordination["API Resources: coordination.k8s.io"]
        Leases["Leases<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph APIResources_Auth["API Resources: authentication/authorization"]
        TokenReviews["TokenReviews<br/>(authentication.k8s.io)<br/>create"]
        SubjectAccessReviews["SubjectAccessReviews<br/>(authorization.k8s.io)<br/>create"]
    end

    subgraph NonResourceURLs["Non-Resource URLs"]
        Metrics["/metrics<br/>get"]
    end

    %% Service Account → Bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_Metrics_Auth
    SA_Controller -->|"bound via"| CRB_Metrics_Reader
    SA_Controller -->|"bound via"| RB_Leader

    %% Bindings → Roles
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics_Auth -->|"grants"| CR_Metrics_Auth
    CRB_Metrics_Reader -->|"grants"| CR_Metrics_Reader
    RB_Leader -->|"grants"| R_Leader

    %% Roles → Resources
    CR_Manager -->|"serving.kserve.io"| InferenceServices
    CR_Manager -->|"serving.kserve.io"| InferenceServicesFinalizers
    CR_Manager -->|"core"| Services

    R_Leader -->|"core"| ConfigMaps
    R_Leader -->|"core"| Events
    R_Leader -->|"coordination.k8s.io"| Leases

    CR_Metrics_Auth -->|"authentication.k8s.io"| TokenReviews
    CR_Metrics_Auth -->|"authorization.k8s.io"| SubjectAccessReviews

    CR_Metrics_Reader -->|"nonResourceURLs"| Metrics

