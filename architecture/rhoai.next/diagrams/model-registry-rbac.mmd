graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["model-registry-<br/>manager-rolebinding"]
        CRB_Metrics["metrics-auth-<br/>rolebinding"]
        CRB_UIServices["model-registry-ui-<br/>services-reader-binding"]
        CRB_UICR["model-registry-<br/>clusterrolebindings-binding"]
        CRB_UINS["model-registry-ui-<br/>namespaces-reader-binding"]
        CRB_UISAR["model-registry-<br/>create-sars-binding"]
    end

    subgraph RoleBindings["Role Bindings (Namespace)"]
        RB_Leader["leader-election-<br/>rolebinding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["model-registry-<br/>manager-role"]
        CR_MetricsReader["metrics-reader"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_UIServices["model-registry-ui-<br/>services-reader"]
        CR_UICR["model-registry-retrieve-<br/>clusterrolebindings"]
        CR_UINS["model-registry-ui-<br/>namespaces-reader"]
        CR_UISAR["model-registry-<br/>create-sars"]
    end

    subgraph Roles["Roles (Namespace)"]
        R_Leader["leader-election-role"]
    end

    subgraph APIResources_Controller["API Resources (Controller)"]
        Res_Services["core: services<br/>get, list, watch"]
        Res_ISVC["serving.kserve.io:<br/>inferenceservices<br/>get, list, watch, patch, update"]
        Res_ISVCFin["serving.kserve.io:<br/>inferenceservices/finalizers<br/>get, list, watch, create,<br/>delete, patch, update"]
        Res_TokenReview["authentication.k8s.io:<br/>tokenreviews<br/>create"]
        Res_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        Res_Metrics["nonResourceURLs:<br/>/metrics<br/>get"]
        Res_ConfigMaps["core: configmaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        Res_Leases["coordination.k8s.io: leases<br/>get, list, watch, create,<br/>update, patch, delete"]
        Res_Events["core: events<br/>create, patch"]
    end

    subgraph APIResources_UI["API Resources (UI)"]
        Res_UIServices["core: services<br/>get, list, watch"]
        Res_UICR["rbac.authorization.k8s.io:<br/>clusterrolebindings<br/>get, list, watch"]
        Res_UINS["core: namespaces<br/>get, list, watch"]
        Res_UISAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
    end

    %% Controller SA bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_Metrics
    SA_Controller -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    RB_Leader -->|grants| R_Leader

    %% Controller role → resources
    CR_Manager -->|permits| Res_Services
    CR_Manager -->|permits| Res_ISVC
    CR_Manager -->|permits| Res_ISVCFin
    CR_MetricsReader -->|permits| Res_Metrics
    CR_MetricsAuth -->|permits| Res_TokenReview
    CR_MetricsAuth -->|permits| Res_SAR
    R_Leader -->|permits| Res_ConfigMaps
    R_Leader -->|permits| Res_Leases
    R_Leader -->|permits| Res_Events

    %% UI SA bindings
    SA_UI -->|bound via| CRB_UIServices
    SA_UI -->|bound via| CRB_UICR
    SA_UI -->|bound via| CRB_UINS
    SA_UI -->|bound via| CRB_UISAR

    CRB_UIServices -->|grants| CR_UIServices
    CRB_UICR -->|grants| CR_UICR
    CRB_UINS -->|grants| CR_UINS
    CRB_UISAR -->|grants| CR_UISAR

    %% UI role → resources
    CR_UIServices -->|permits| Res_UIServices
    CR_UICR -->|permits| Res_UICR
    CR_UINS -->|permits| Res_UINS
    CR_UISAR -->|permits| Res_UISAR

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff
