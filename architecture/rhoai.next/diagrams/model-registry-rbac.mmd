graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-manager-rolebinding<br/>(Cluster)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(Cluster)"]
        CRB_UIServices["model-registry-ui-services-reader-binding<br/>(Cluster)"]
        CRB_UIClusterRB["model-registry-clusterrolebindings-binding<br/>(Cluster)"]
        CRB_UINS["model-registry-ui-namespaces-reader-binding<br/>(Cluster)"]
        CRB_UISAR["model-registry-create-sars-binding<br/>(Cluster)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(controller namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-manager-role"]
        CR_MetricsReader["metrics-reader"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_UIServices["model-registry-ui-services-reader"]
        CR_UICRB["model-registry-retrieve-clusterrolebindings"]
        CR_UINS["model-registry-ui-namespaces-reader"]
        CR_UISAR["model-registry-create-sars"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph APIResources["API Resources"]
        Res_Services["core<br/>services"]
        Res_ISVC["serving.kserve.io<br/>inferenceservices"]
        Res_ISVCFin["serving.kserve.io<br/>inferenceservices/finalizers"]
        Res_ConfigMaps["core<br/>configmaps"]
        Res_Leases["coordination.k8s.io<br/>leases"]
        Res_Events["core<br/>events"]
        Res_Metrics["/metrics<br/>(nonResourceURL)"]
        Res_TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        Res_CRBs["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        Res_Namespaces["core<br/>namespaces"]
    end

    %% Controller SA bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_Metrics
    SA_Controller -->|"bound via"| RB_Leader

    %% UI SA bindings
    SA_UI -->|"bound via"| CRB_UIServices
    SA_UI -->|"bound via"| CRB_UIClusterRB
    SA_UI -->|"bound via"| CRB_UINS
    SA_UI -->|"bound via"| CRB_UISAR

    %% Binding → Role grants
    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    RB_Leader -->|"grants"| R_Leader

    CRB_UIServices -->|"grants"| CR_UIServices
    CRB_UIClusterRB -->|"grants"| CR_UICRB
    CRB_UINS -->|"grants"| CR_UINS
    CRB_UISAR -->|"grants"| CR_UISAR

    %% ClusterRole → Resource permissions
    CR_Manager -->|"get,list,watch"| Res_Services
    CR_Manager -->|"get,list,watch,<br/>patch,update"| Res_ISVC
    CR_Manager -->|"get,list,watch,create,<br/>delete,patch,update"| Res_ISVCFin

    R_Leader -->|"full CRUD"| Res_ConfigMaps
    R_Leader -->|"full CRUD"| Res_Leases
    R_Leader -->|"create,patch"| Res_Events

    CR_MetricsReader -->|"get"| Res_Metrics
    CR_MetricsAuth -->|"create"| Res_TokenReviews
    CR_MetricsAuth -->|"create"| Res_SAR

    CR_UIServices -->|"get,list,watch"| Res_Services
    CR_UICRB -->|"get,list,watch"| Res_CRBs
    CR_UINS -->|"get,list,watch"| Res_Namespaces
    CR_UISAR -->|"create"| Res_SAR

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#333
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#333
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#333
    style CR_UIServices fill:#f5a623,stroke:#333,color:#333
    style CR_UICRB fill:#f5a623,stroke:#333,color:#333
    style CR_UINS fill:#f5a623,stroke:#333,color:#333
    style CR_UISAR fill:#f5a623,stroke:#333,color:#333
    style R_Leader fill:#f5a623,stroke:#333,color:#333

    style Res_Services fill:#7ed321,stroke:#333,color:#333
    style Res_ISVC fill:#7ed321,stroke:#333,color:#333
    style Res_ISVCFin fill:#7ed321,stroke:#333,color:#333
    style Res_ConfigMaps fill:#7ed321,stroke:#333,color:#333
    style Res_Leases fill:#7ed321,stroke:#333,color:#333
    style Res_Events fill:#7ed321,stroke:#333,color:#333
    style Res_Metrics fill:#7ed321,stroke:#333,color:#333
    style Res_TokenReviews fill:#7ed321,stroke:#333,color:#333
    style Res_SAR fill:#7ed321,stroke:#333,color:#333
    style Res_CRBs fill:#7ed321,stroke:#333,color:#333
    style Res_Namespaces fill:#7ed321,stroke:#333,color:#333
