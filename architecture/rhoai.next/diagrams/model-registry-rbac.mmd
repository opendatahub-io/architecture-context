graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>Namespace: system"]
        SA_Registry["model-registry-sa<br/>Namespace: model-registry"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["model-registry-manager-rolebinding<br/>Namespace: system"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["model-registry-manager-role"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            Services["services"]
        end

        subgraph KServeAPI["API Group: serving.kserve.io"]
            ISVC["inferenceservices"]
            ISVCFinalizers["inferenceservices/finalizers"]
        end
    end

    subgraph IstioAuth["Istio Authorization"]
        AuthPolicy["AuthorizationPolicy<br/>model-registry<br/>Action: ALLOW"]
        MeshTraffic["All authenticated<br/>mesh traffic"]
    end

    subgraph Secrets["Secrets (No Auto-Rotation)"]
        MySQLSecret["mysql-secret<br/>(Opaque)<br/>username, password"]
        DBSecrets["model-registry-db-secrets<br/>(Opaque)<br/>root password, user creds"]
        CatalogPGSecret["model-catalog-postgres<br/>(Opaque)<br/>user, password, database"]
        HFSecret["model-catalog-hf-api-key<br/>(Opaque)<br/>Hugging Face API key"]
    end

    %% RBAC bindings
    SA_Controller -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| Services
    CR -->|"get, list, patch,<br/>update, watch"| ISVC
    CR -->|"create, delete, get, list,<br/>patch, update, watch"| ISVCFinalizers

    %% Istio auth
    AuthPolicy -->|"permits"| MeshTraffic

    %% Secret usage
    MySQLSecret -.->|"used by"| SA_Registry
    DBSecrets -.->|"used by"| SA_Registry
    CatalogPGSecret -.->|"used by model-catalog"| SA_Registry
    HFSecret -.->|"used by model-catalog"| SA_Registry

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Registry fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style ISVCFinalizers fill:#7ed321,stroke:#333
    style AuthPolicy fill:#e74c3c,stroke:#333,color:#fff
    style MeshTraffic fill:#e8e8e8,stroke:#333
    style MySQLSecret fill:#fff2cc,stroke:#d6b656
    style DBSecrets fill:#fff2cc,stroke:#d6b656
    style CatalogPGSecret fill:#fff2cc,stroke:#d6b656
    style HFSecret fill:#fff2cc,stroke:#d6b656
