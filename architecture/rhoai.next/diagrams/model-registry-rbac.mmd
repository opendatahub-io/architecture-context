graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-<br/>manager-rolebinding<br/>(Cluster)"]
        CRB_Metrics["metrics-auth-<br/>rolebinding<br/>(Cluster)"]
        CRB_UIServices["model-registry-ui-<br/>services-reader-binding<br/>(Cluster)"]
        CRB_UICR["model-registry-<br/>clusterrolebindings-binding<br/>(Cluster)"]
        CRB_UINS["model-registry-ui-<br/>namespaces-reader-binding<br/>(Cluster)"]
        CRB_UISAR["model-registry-<br/>create-sars-binding<br/>(Cluster)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-<br/>rolebinding<br/>(controller namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-<br/>manager-role"]
        CR_MetricsReader["metrics-reader"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_UIServices["model-registry-ui-<br/>services-reader"]
        CR_UICR["model-registry-retrieve-<br/>clusterrolebindings"]
        CR_UINS["model-registry-ui-<br/>namespaces-reader"]
        CR_UISAR["model-registry-<br/>create-sars"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph APIResources["API Resources"]
        Res_Services["core<br/>services"]
        Res_ISVC["serving.kserve.io<br/>inferenceservices"]
        Res_ISVCFin["serving.kserve.io<br/>inferenceservices/finalizers"]
        Res_ConfigMaps["core<br/>configmaps"]
        Res_Leases["coordination.k8s.io<br/>leases"]
        Res_Events["core<br/>events"]
        Res_Metrics["/metrics<br/>(nonResourceURL)"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        Res_CRB["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        Res_Namespaces["core<br/>namespaces"]
    end

    %% Controller SA bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    SA_Controller -->|bound via| CRB_Metrics

    %% UI SA bindings
    SA_UI -->|bound via| CRB_UIServices
    SA_UI -->|bound via| CRB_UICR
    SA_UI -->|bound via| CRB_UINS
    SA_UI -->|bound via| CRB_UISAR

    %% Bindings → Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    RB_Leader -->|grants| R_Leader
    CRB_UIServices -->|grants| CR_UIServices
    CRB_UICR -->|grants| CR_UICR
    CRB_UINS -->|grants| CR_UINS
    CRB_UISAR -->|grants| CR_UISAR

    %% ClusterRole → Resources (Controller)
    CR_Manager -->|"get, list, watch"| Res_Services
    CR_Manager -->|"get, list, watch,<br/>patch, update"| Res_ISVC
    CR_Manager -->|"get, list, watch, create,<br/>delete, patch, update"| Res_ISVCFin
    CR_MetricsAuth -->|"create"| Res_TokenReview
    CR_MetricsAuth -->|"create"| Res_SAR
    CR_MetricsReader -->|"get"| Res_Metrics

    %% Role → Resources (Leader Election)
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Res_ConfigMaps
    R_Leader -->|"get, list, watch, create,<br/>update, patch, delete"| Res_Leases
    R_Leader -->|"create, patch"| Res_Events

    %% ClusterRole → Resources (UI)
    CR_UIServices -->|"get, list, watch"| Res_Services
    CR_UICR -->|"get, list, watch"| Res_CRB
    CR_UINS -->|"get, list, watch"| Res_Namespaces
    CR_UISAR -->|"create"| Res_SAR

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style CR_UIServices fill:#f5a623,stroke:#333,color:#fff
    style CR_UICR fill:#f5a623,stroke:#333,color:#fff
    style CR_UINS fill:#f5a623,stroke:#333,color:#fff
    style CR_UISAR fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#e8a838,stroke:#333,color:#fff

    style Res_Services fill:#7ed321,stroke:#333,color:#fff
    style Res_ISVC fill:#7ed321,stroke:#333,color:#fff
    style Res_ISVCFin fill:#7ed321,stroke:#333,color:#fff
    style Res_ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Res_Leases fill:#7ed321,stroke:#333,color:#fff
    style Res_Events fill:#7ed321,stroke:#333,color:#fff
    style Res_Metrics fill:#7ed321,stroke:#333,color:#fff
    style Res_TokenReview fill:#7ed321,stroke:#333,color:#fff
    style Res_SAR fill:#7ed321,stroke:#333,color:#fff
    style Res_CRB fill:#7ed321,stroke:#333,color:#fff
    style Res_Namespaces fill:#7ed321,stroke:#333,color:#fff
