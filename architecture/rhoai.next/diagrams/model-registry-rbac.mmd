graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(system namespace)"]
        SA_MR["model-registry<br/>(model-registry namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["model-registry-manager-rolebinding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["model-registry-manager-role"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph CoreAPI["API Group: core ('')"]
            Services["Services"]
        end

        subgraph KServeAPI["API Group: serving.kserve.io"]
            InferenceServices["inferenceservices"]
            InferenceServicesFinalizers["inferenceservices/finalizers"]
        end
    end

    subgraph IstioAuthz["Istio Authorization"]
        direction TB
        AuthzPolicy["AuthorizationPolicy<br/>(model-registry)"]

        subgraph Rule1["Rule 1: Ingress Gateway"]
            IGW_Source["Source: istio-ingressgateway SA<br/>(istio-system namespace)"]
        end

        subgraph Rule2["Rule 2: Internal Cluster"]
            Internal_Source["Source: Valid Kubernetes JWT<br/>Condition: blocks kubeflow-userid<br/>header spoofing"]
        end
    end

    subgraph Secrets_Section["Secrets"]
        direction TB
        S1["mysql-secret<br/>Type: Opaque<br/>DB username/password"]
        S2["model-registry-db-secrets<br/>Type: Opaque<br/>DB credentials (kustomize)"]
        S3["model-catalog-postgres<br/>Type: Opaque<br/>PostgreSQL credentials"]
        S4["model-catalog-hf-api-key<br/>Type: Opaque<br/>HuggingFace API key"]
    end

    %% RBAC Flow
    SA_Controller -->|"bound via"| CRB
    CRB -->|"grants"| CR

    CR -->|"get, list, watch"| Services
    CR -->|"get, list, patch,<br/>update, watch"| InferenceServices
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| InferenceServicesFinalizers

    %% Istio AuthZ Flow
    SA_MR -.->|"protected by"| AuthzPolicy
    AuthzPolicy --- Rule1
    AuthzPolicy --- Rule2

    %% Secret consumption
    SA_MR -.->|"reads"| S1
    SA_MR -.->|"reads"| S2

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_MR fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#000
    style Services fill:#7ed321,stroke:#333,color:#000
    style InferenceServices fill:#7ed321,stroke:#333,color:#000
    style InferenceServicesFinalizers fill:#7ed321,stroke:#333,color:#000
    style AuthzPolicy fill:#e74c3c,stroke:#333,color:#fff
    style IGW_Source fill:#f1c40f,stroke:#333,color:#000
    style Internal_Source fill:#f1c40f,stroke:#333,color:#000
    style S1 fill:#e8e8e8,stroke:#333
    style S2 fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style S4 fill:#e8e8e8,stroke:#333
