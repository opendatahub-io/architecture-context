graph LR
    LLMDRouter["llm-d Router<br/>(EPP + pd-sidecar)"]

    %% External Dependencies (Required)
    LLMDRouter -->|"ext_proc gRPC<br/>9002/TCP"| Envoy["Envoy / AgentGateway<br/>(L7 Proxy)"]
    LLMDRouter -->|"CRD watches<br/>HTTPS/443"| K8s["Kubernetes 1.29+"]
    LLMDRouter -->|"InferencePool CRD"| GIE["Gateway API Inference<br/>Extension v1.5.0"]
    LLMDRouter -->|"Go library<br/>prefix cache scoring"| KVCache["llm-d-kv-cache v0.9.0-rc.1"]
    LLMDRouter -->|"controller framework"| CtrlRuntime["controller-runtime v0.23.3"]
    LLMDRouter -->|"ext_proc protobuf"| GoControlPlane["go-control-plane v1.37.0"]
    LLMDRouter -->|"request parsing"| OpenAISDK["OpenAI Go SDK v1.12.0"]

    %% External Dependencies (Optional)
    LLMDRouter -.->|"HTTPRoute/Gateway"| GatewayAPI["Gateway API v1.5.1"]
    LLMDRouter -.->|"VertexAI format"| VertexAI["Google Cloud AI<br/>Platform v1.124.0"]

    %% Internal Platform Dependencies
    LLMDRouter -->|"metrics scraping<br/>HTTP/8000"| ModelServers["Model Servers<br/>(vLLM / SGLang)"]
    LLMDRouter -->|"prefill stage<br/>HTTP(S)/Dynamic"| PrefillWorkers["Prefill Workers"]
    LLMDRouter -->|"encode stage<br/>HTTP(S)/Dynamic"| EncodeWorkers["Encode Workers"]
    LLMDRouter -->|"decode stage<br/>HTTP(S)/8001"| LocalDecoder["Local Decoder<br/>(vLLM)"]
    LLMDRouter -.->|"TTFT/TPOT predictions<br/>HTTP/8001"| LatencyPredictor["Latency Predictor"]

    %% Observability
    LLMDRouter -.->|"traces<br/>gRPC/4317"| OTel["OpenTelemetry<br/>Collector"]
    Prometheus["Prometheus"] -.->|"metrics scraping<br/>HTTP/9090"| LLMDRouter

    %% Consumers / Integration Points
    Envoy -->|"routed requests<br/>HTTP/8000"| ModelServers

    %% Styling
    style LLMDRouter fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Required
    style Envoy fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GIE fill:#999,stroke:#333,color:#fff
    style KVCache fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style GoControlPlane fill:#999,stroke:#333,color:#fff
    style OpenAISDK fill:#999,stroke:#333,color:#fff

    %% External Optional
    style GatewayAPI fill:#bbb,stroke:#333,color:#fff
    style VertexAI fill:#bbb,stroke:#333,color:#fff

    %% Internal Platform
    style ModelServers fill:#7ed321,stroke:#333,color:#fff
    style PrefillWorkers fill:#7ed321,stroke:#333,color:#fff
    style EncodeWorkers fill:#7ed321,stroke:#333,color:#fff
    style LocalDecoder fill:#7ed321,stroke:#333,color:#fff
    style LatencyPredictor fill:#7ed321,stroke:#333,color:#fff

    %% Observability
    style OTel fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
