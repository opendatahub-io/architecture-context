graph TD
    subgraph MLMDServer["MLMD gRPC Server"]
        Server["metadata_store_server<br/>(C++ binary, UID 65534)"]
    end

    subgraph KubernetesRBAC["Kubernetes RBAC"]
        NoRBAC["No RBAC Defined<br/>in this repository"]
    end

    subgraph ManagedBy["RBAC Managed By"]
        Operator["Platform Operator<br/>(rhods-operator /<br/>opendatahub-operator)"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        TLSAuth["gRPC TLS<br/>(SSLConfig proto)"]
        mTLSAuth["Optional mTLS<br/>(client_verify=true)"]
        NoAuth["InsecureServerCredentials<br/>(default — no TLS, no auth)"]
    end

    subgraph DatabaseAuth["Database Authentication"]
        direction TB
        DBCreds["Database Credentials<br/>(Opaque Secret)<br/>Username/Password"]
        TLSCerts["TLS Certificates<br/>(kubernetes.io/tls Secret)<br/>Server Key, Cert, CA"]
    end

    Server -->|"no K8s API<br/>interaction"| NoRBAC
    Operator -->|"manages all<br/>RBAC & deployment"| Server
    Operator -->|"provisions"| DBCreds
    Operator -->|"provisions<br/>(or cert-manager)"| TLSCerts

    Server -->|"when SSLConfig<br/>provided"| TLSAuth
    TLSAuth -->|"optionally<br/>enables"| mTLSAuth
    Server -->|"when no SSLConfig<br/>(default)"| NoAuth

    Server -->|"authenticates to DB"| DBCreds
    Server -->|"optional TLS<br/>for gRPC"| TLSCerts

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#e8e8e8,stroke:#999,color:#666
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style TLSAuth fill:#d5e8d4,stroke:#82b366
    style mTLSAuth fill:#d5e8d4,stroke:#82b366
    style NoAuth fill:#f8cecc,stroke:#b85450
    style DBCreds fill:#fff2cc,stroke:#d6b656
    style TLSCerts fill:#fff2cc,stroke:#d6b656
