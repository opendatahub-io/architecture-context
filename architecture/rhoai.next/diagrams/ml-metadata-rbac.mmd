graph TD
    subgraph "Authentication Model"
        direction TB
        Note["ML Metadata has NO Kubernetes RBAC.<br/>Access control is entirely network-level."]
    end

    subgraph "Access Control Layers"
        direction TB

        subgraph "Layer 1: Network Isolation"
            ClusterIP["ClusterIP Service<br/>Only reachable within cluster"]
            NetPol["NetworkPolicy<br/>(managed by platform operator)"]
        end

        subgraph "Layer 2: Optional mTLS (gRPC Server)"
            TLSConfig["SSLConfig"]
            ServerKey["server_key<br/>(TLS private key)"]
            ServerCert["server_cert<br/>(TLS certificate)"]
            CustomCA["custom_ca<br/>(CA for client verification)"]
            ClientVerify["client_verify flag"]

            TLSConfig --> ServerKey
            TLSConfig --> ServerCert
            TLSConfig --> CustomCA
            TLSConfig --> ClientVerify
        end

        subgraph "Layer 3: Upstream Proxy (RHOAI)"
            KRBP["kube-rbac-proxy<br/>(deployed by platform operator)<br/>Provides K8s RBAC enforcement"]
        end
    end

    subgraph "Authorization Model"
        NoAuthz["NO per-RPC authorization<br/>Any authenticated client can:<br/>• Create/Update/Delete all entity types<br/>• Create/Update/Delete all entities<br/>• Modify schema (PutTypes)<br/>• Query all lineage data"]
    end

    subgraph "Database Authentication"
        DBAuth["Database Credentials"]
        MySQLAuth["MySQL: username/password<br/>(mysql_config_password)"]
        PGAuth["PostgreSQL: username/password<br/>(postgres_config_password / passfile)"]
        DBAuth --> MySQLAuth
        DBAuth --> PGAuth
    end

    ClusterIP -->|"network boundary"| TLSConfig
    ClientVerify -->|"when true, requires<br/>valid client cert"| CustomCA
    KRBP -->|"proxies to"| ClusterIP

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style NoAuthz fill:#f8d7da,stroke:#721c24,stroke-width:2px
    style ClusterIP fill:#d5e8d4,stroke:#82b366
    style NetPol fill:#d5e8d4,stroke:#82b366
    style TLSConfig fill:#dae8fc,stroke:#6c8ebf
    style ServerKey fill:#dae8fc,stroke:#6c8ebf
    style ServerCert fill:#dae8fc,stroke:#6c8ebf
    style CustomCA fill:#dae8fc,stroke:#6c8ebf
    style ClientVerify fill:#dae8fc,stroke:#6c8ebf
    style KRBP fill:#e2d5f1,stroke:#7c4dff
    style DBAuth fill:#fff2cc,stroke:#d6b656
    style MySQLAuth fill:#fff2cc,stroke:#d6b656
    style PGAuth fill:#fff2cc,stroke:#d6b656
