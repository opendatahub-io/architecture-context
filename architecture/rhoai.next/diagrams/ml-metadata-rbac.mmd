graph TD
    subgraph "Container Security"
        Container["MLMD gRPC Server Container<br/>UID: 65534 / GID: 65534<br/>(non-root, nobody)"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No RBAC defined in this repository<br/>RBAC managed externally by<br/>rhods-operator / opendatahub-operator"]
    end

    subgraph "gRPC Authentication"
        SSLConfig["SSLConfig (BoringSSL)"]
        ServerKey["server_key<br/>(TLS private key)"]
        ServerCert["server_cert<br/>(TLS certificate)"]
        CustomCA["custom_ca<br/>(CA certificate)"]
        ClientVerify["client_verify<br/>(mTLS enforcement flag)"]

        SSLConfig --> ServerKey
        SSLConfig --> ServerCert
        SSLConfig --> CustomCA
        SSLConfig --> ClientVerify
    end

    subgraph "Secrets (Provisioned by Platform Operator)"
        ConfigSecret["metadata-store-server-config<br/>Type: Opaque<br/>MetadataStoreServerConfig protobuf<br/>DB connection + TLS config<br/>Auto-Rotate: No"]
        DBCreds["mysql/postgres credentials<br/>Type: Opaque<br/>Database username/password<br/>Auto-Rotate: No"]
        TLSSecret["grpc-tls<br/>Type: kubernetes.io/tls<br/>server_key, server_cert, custom_ca<br/>Auto-Rotate: Depends on provisioner"]
    end

    subgraph "Database Authentication"
        MySQLAuth["MySQL/MariaDB Auth<br/>Username/Password<br/>Optional TLS: cert, key, ca,<br/>capath, cipher, verify_server_cert"]
        PGAuth["PostgreSQL Auth<br/>Username/Password<br/>Optional TLS: sslmode, sslcert,<br/>sslkey, sslpassword, sslrootcert"]
    end

    Container -->|"uses"| SSLConfig
    TLSSecret -.->|"provides certs"| SSLConfig
    ConfigSecret -.->|"configures"| Container
    DBCreds -.->|"provides credentials"| MySQLAuth
    DBCreds -.->|"provides credentials"| PGAuth

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style SSLConfig fill:#f5a623,stroke:#333
    style ServerKey fill:#f5a623,stroke:#333
    style ServerCert fill:#f5a623,stroke:#333
    style CustomCA fill:#f5a623,stroke:#333
    style ClientVerify fill:#f5a623,stroke:#333
    style ConfigSecret fill:#f8cecc,stroke:#b85450
    style DBCreds fill:#f8cecc,stroke:#b85450
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style MySQLAuth fill:#fff2cc,stroke:#d6b656
    style PGAuth fill:#fff2cc,stroke:#d6b656
