graph TD
    subgraph "Container Security"
        Container["metadata_store_server Container<br/>UBI9-minimal"]
        UID["Non-Root User<br/>UID 65534:65534"]

        Container -->|"runs as"| UID
    end

    subgraph "RBAC (Managed Externally)"
        Note["No Kubernetes RBAC defined in this repository<br/>RBAC is managed by the deploying operator:<br/>rhods-operator or opendatahub-operator"]
    end

    subgraph "Authentication"
        gRPCAuth["gRPC mTLS Authentication<br/>(Optional)"]
        SSLConfig["SSLConfig Parameters"]

        SSLConfig -->|"server_key"| gRPCAuth
        SSLConfig -->|"server_cert"| gRPCAuth
        SSLConfig -->|"custom_ca"| gRPCAuth
        SSLConfig -->|"client_verify=true"| gRPCAuth
    end

    subgraph "Secrets"
        ServerConfig["metadata-store-server-config<br/>(Opaque)<br/>DB connection + TLS config<br/>Provisioned by: Platform operator"]
        DBCreds["mysql/postgres credentials<br/>(Opaque)<br/>Username/Password<br/>Provisioned by: Platform operator"]
        TLSCert["grpc-tls<br/>(kubernetes.io/tls)<br/>server_key, server_cert, custom_ca<br/>Provisioned by: Platform operator / cert-manager"]
    end

    subgraph "Database Auth"
        MySQLAuth["MySQL/MariaDB Auth<br/>Username/Password<br/>Optional TLS (SSLOptions)"]
        PostgreSQLAuth["PostgreSQL Auth<br/>Username/Password<br/>Optional TLS (sslmode, sslcert, sslkey)"]
    end

    %% Connections
    Container -->|"uses"| gRPCAuth
    TLSCert -.->|"provides certs"| gRPCAuth
    ServerConfig -.->|"configures"| Container
    DBCreds -.->|"credentials for"| MySQLAuth
    DBCreds -.->|"credentials for"| PostgreSQLAuth
    Container -->|"connects via"| MySQLAuth
    Container -->|"connects via"| PostgreSQLAuth

    %% Styling
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style UID fill:#7ed321,stroke:#333,color:#fff
    style Note fill:#fff2cc,stroke:#d6b656
    style gRPCAuth fill:#f5a623,stroke:#333,color:#fff
    style SSLConfig fill:#f5a623,stroke:#333,color:#fff
    style ServerConfig fill:#f8cecc,stroke:#b85450
    style DBCreds fill:#f8cecc,stroke:#b85450
    style TLSCert fill:#f8cecc,stroke:#b85450
    style MySQLAuth fill:#dae8fc,stroke:#6c8ebf
    style PostgreSQLAuth fill:#dae8fc,stroke:#6c8ebf
