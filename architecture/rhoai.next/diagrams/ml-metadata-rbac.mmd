graph TD
    subgraph Note["MLMD RBAC Model"]
        direction TB
        Info["ML Metadata is a standalone gRPC service<br/>with NO Kubernetes RBAC resources.<br/>Access control is external."]
    end

    subgraph AccessControl["Access Control Layers"]
        direction TB

        subgraph Layer1["Layer 1: Network Isolation"]
            ClusterIP["ClusterIP Service<br/><i>No external exposure</i><br/><i>Internal cluster traffic only</i>"]
        end

        subgraph Layer2["Layer 2: Upstream Proxy (RHOAI)"]
            KubeRBAC["kube-rbac-proxy<br/><i>Platform-managed</i><br/><i>Kubernetes RBAC enforcement</i>"]
        end

        subgraph Layer3["Layer 3: Optional mTLS"]
            mTLS["gRPC SslServerCredentials<br/><i>BoringSSL</i>"]
            ServerCert["Server cert/key<br/>(ssl_config.server_cert/key)"]
            CustomCA["Custom CA<br/>(ssl_config.custom_ca)"]
            ClientVerify["client_verify flag<br/><i>Enables mTLS</i>"]
            mTLS --- ServerCert
            mTLS --- CustomCA
            mTLS --- ClientVerify
        end

        subgraph Layer4["Layer 4: gRPC Service (NO per-RPC authz)"]
            AllRPCs["MetadataStoreService<br/><i>All 40+ RPC methods</i>"]
            PutOps["Put* operations<br/><i>Create/Update entities</i>"]
            GetOps["Get* operations<br/><i>Read entities & lineage</i>"]
            AllRPCs --- PutOps
            AllRPCs --- GetOps
        end
    end

    subgraph Secrets["Secrets (No Auto-Rotation)"]
        DBCreds["DB credentials<br/>mysql_config_password /<br/>postgres_config_password<br/><i>Opaque, Manual</i>"]
        SSLKey["SSL server key<br/>ssl_config.server_key<br/><i>TLS key, Manual/cert-manager</i>"]
        SSLCert["SSL server cert<br/>ssl_config.server_cert<br/><i>TLS cert, Manual/cert-manager</i>"]
        SSLCA["SSL custom CA<br/>ssl_config.custom_ca<br/><i>CA cert, Manual</i>"]
        DBSSLCerts["DB SSL certs<br/>MySQL/PG sslcert, sslkey,<br/>sslrootcert<br/><i>TLS, Manual</i>"]
    end

    ClusterIP -->|"allows cluster-internal traffic"| KubeRBAC
    KubeRBAC -->|"authenticated requests"| mTLS
    mTLS -->|"verified client"| AllRPCs

    SSLKey -.->|"used by"| mTLS
    SSLCert -.->|"used by"| mTLS
    SSLCA -.->|"used by"| mTLS

    %% Warning
    subgraph Warning["⚠ Security Note"]
        WarningText["No built-in per-RPC authorization.<br/>Any client with network access and valid TLS creds<br/>can perform ANY operation including bulk deletes<br/>and schema modifications."]
    end

    style Info fill:#f0f0f0,stroke:#999,color:#333
    style ClusterIP fill:#d5e8d4,stroke:#82b366
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style mTLS fill:#dae8fc,stroke:#6c8ebf
    style ServerCert fill:#e1d5e7,stroke:#9673a6
    style CustomCA fill:#e1d5e7,stroke:#9673a6
    style ClientVerify fill:#e1d5e7,stroke:#9673a6
    style AllRPCs fill:#4a90e2,stroke:#333,color:#fff
    style PutOps fill:#4a90e2,stroke:#333,color:#fff
    style GetOps fill:#4a90e2,stroke:#333,color:#fff
    style DBCreds fill:#fff2cc,stroke:#d6b656
    style SSLKey fill:#fff2cc,stroke:#d6b656
    style SSLCert fill:#fff2cc,stroke:#d6b656
    style SSLCA fill:#fff2cc,stroke:#d6b656
    style DBSSLCerts fill:#fff2cc,stroke:#d6b656
    style WarningText fill:#f8cecc,stroke:#b85450,color:#333
