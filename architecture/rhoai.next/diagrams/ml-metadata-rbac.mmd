graph TD
    subgraph "MLMD RBAC Model"
        direction TB
        Note["NOTE: No Kubernetes RBAC defined by this component.<br/>MLMD server does not interact with Kubernetes API.<br/>All RBAC is managed by the deploying platform operator."]
    end

    subgraph "Platform Operator RBAC (External)"
        direction TB
        OperatorSA["ServiceAccount<br/>rhods-operator / odh-operator"]
        OperatorCRB["ClusterRoleBinding<br/>(managed by OLM)"]
        OperatorCR["ClusterRole<br/>(operator permissions)"]
        OperatorSA -->|bound via| OperatorCRB
        OperatorCRB -->|grants| OperatorCR
    end

    subgraph "Resources Managed by Operator"
        direction TB
        MLMDDeployment["apps/Deployment<br/>metadata_store_server"]
        MLMDService["core/Service<br/>ClusterIP 8080/TCP"]
        MLMDSecret["core/Secret<br/>Database credentials"]
        MLMDTLSSecret["core/Secret<br/>TLS certificates (optional)"]
    end

    OperatorCR -->|"create, update, delete"| MLMDDeployment
    OperatorCR -->|"create, update, delete"| MLMDService
    OperatorCR -->|"create, update, delete"| MLMDSecret
    OperatorCR -->|"create, update, delete"| MLMDTLSSecret

    subgraph "Application-Level Auth"
        direction TB
        gRPCAuth["gRPC mTLS (Optional)<br/>client_verify=true in SSLConfig<br/>Enforced by: grpc::SslServerCredentials"]
        DBAuth["Database Auth<br/>Username/Password<br/>from Secret"]
    end

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style OperatorSA fill:#4a90e2,stroke:#333,color:#fff
    style OperatorCR fill:#f5a623,stroke:#333,color:#fff
    style OperatorCRB fill:#e8e8e8,stroke:#333
    style MLMDDeployment fill:#d5e8d4,stroke:#82b366
    style MLMDService fill:#d5e8d4,stroke:#82b366
    style MLMDSecret fill:#f8cecc,stroke:#b85450
    style MLMDTLSSecret fill:#f8cecc,stroke:#b85450
    style gRPCAuth fill:#dae8fc,stroke:#6c8ebf
    style DBAuth fill:#dae8fc,stroke:#6c8ebf
