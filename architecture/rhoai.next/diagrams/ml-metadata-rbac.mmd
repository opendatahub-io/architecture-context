graph TD
    subgraph MLMDService["ML Metadata Service"]
        Server["metadata_store_server<br/>(C++ gRPC Binary)<br/>UID: 65534 (non-root)"]
    end

    subgraph NoK8sRBAC["No Kubernetes RBAC"]
        direction TB
        Note1["MLMD does not interact with<br/>the Kubernetes API server"]
        Note2["No ClusterRoles, Roles,<br/>or RoleBindings defined"]
        Note3["RBAC for the MLMD pod is<br/>managed by the deploying<br/>Data Science Pipelines Operator"]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB
        DefaultAuth["Default: InsecureServerCredentials<br/>(no authentication)"]
        OptionalTLS["Optional: SSLConfig protobuf"]
        ServerCert["server_key + server_cert<br/>(Server-side TLS)"]
        ClientVerify["client_verify = true<br/>(mTLS enforcement)"]
        CustomCA["custom_ca<br/>(Client cert CA validation)"]

        OptionalTLS --> ServerCert
        OptionalTLS --> ClientVerify
        OptionalTLS --> CustomCA
    end

    subgraph AccessControl["Access Control (External)"]
        direction TB
        DSPOperator["DSP Operator<br/>Controls deployment<br/>& network config"]
        K8sNetPol["Kubernetes<br/>Network Policies<br/>(if configured)"]
        ServiceMesh["Service Mesh<br/>mTLS & AuthZ<br/>(if deployed)"]
    end

    Server -->|"no built-in<br/>K8s RBAC"| NoK8sRBAC
    Server -->|"auth config"| AuthModel
    DSPOperator -.->|"manages access"| Server
    K8sNetPol -.->|"restricts traffic"| Server
    ServiceMesh -.->|"enforces mTLS"| Server

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#fff3cd,stroke:#856404
    style Note2 fill:#fff3cd,stroke:#856404
    style Note3 fill:#fff3cd,stroke:#856404
    style DefaultAuth fill:#f8d7da,stroke:#721c24
    style OptionalTLS fill:#d4edda,stroke:#155724
    style ServerCert fill:#d4edda,stroke:#155724
    style ClientVerify fill:#d4edda,stroke:#155724
    style CustomCA fill:#d4edda,stroke:#155724
    style DSPOperator fill:#7ed321,stroke:#333
    style K8sNetPol fill:#e1d5e7,stroke:#9673a6
    style ServiceMesh fill:#e1d5e7,stroke:#9673a6
