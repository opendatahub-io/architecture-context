graph TD
    subgraph "MLMD RBAC Model"
        direction TB
        Note["Note: MLMD does not define its own<br/>Kubernetes RBAC resources.<br/>The server does not interact with<br/>the Kubernetes API directly."]
    end

    subgraph "Platform Operator Managed RBAC"
        direction TB
        Operator["Platform Operator<br/>(rhods-operator / opendatahub-operator)"]
        OperatorSA["ServiceAccount<br/>(operator-managed)"]
        OperatorRB["RoleBinding<br/>(operator-managed)"]
    end

    subgraph "MLMD Application-Level Auth"
        direction TB
        SSLConfig["SSLConfig (protobuf)"]
        ServerCreds["grpc::SslServerCredentials"]
        ClientVerify["client_verify = true<br/>(optional mTLS)"]
        InsecureCreds["InsecureServerCredentials()<br/>(default — no auth)"]
    end

    subgraph "Database Auth"
        direction TB
        DBCreds["Database Credentials Secret<br/>(Opaque)"]
        MySQLAuth["MySQL Auth<br/>Username/Password"]
        PGAuth["PostgreSQL Auth<br/>Username/Password"]
    end

    Operator -->|"deploys & manages RBAC for"| OperatorSA
    OperatorSA -->|"bound via"| OperatorRB

    SSLConfig -->|"configures"| ServerCreds
    SSLConfig -->|"enables"| ClientVerify
    SSLConfig -.->|"if not provided"| InsecureCreds

    DBCreds -->|"provides"| MySQLAuth
    DBCreds -->|"provides"| PGAuth

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style Operator fill:#9b59b6,stroke:#333,color:#fff
    style OperatorSA fill:#9b59b6,stroke:#333,color:#fff
    style OperatorRB fill:#9b59b6,stroke:#333,color:#fff
    style SSLConfig fill:#4a90e2,stroke:#333,color:#fff
    style ServerCreds fill:#4a90e2,stroke:#333,color:#fff
    style ClientVerify fill:#27ae60,stroke:#333,color:#fff
    style InsecureCreds fill:#e74c3c,stroke:#333,color:#fff
    style DBCreds fill:#f5a623,stroke:#333,color:#fff
    style MySQLAuth fill:#f5a623,stroke:#333,color:#fff
    style PGAuth fill:#f5a623,stroke:#333,color:#fff
