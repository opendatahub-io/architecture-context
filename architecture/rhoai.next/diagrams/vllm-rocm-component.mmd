graph TB
    subgraph "vLLM ROCm Container Image"
        direction TB
        subgraph "Application Layer"
            Adapter["vllm-tgis-adapter<br/>Entrypoint"]
            VLLMEngine["vLLM Inference Engine"]
            Adapter -->|wraps| VLLMEngine
        end

        subgraph "API Layer"
            HTTPAPI["OpenAI-compatible HTTP API<br/>Port 8000/TCP"]
            GRPCAPI["TGIS gRPC API<br/>Port 8033/TCP"]
        end

        subgraph "Hardware Acceleration"
            ROCmLib["ROCm 7.1.1 Libraries<br/>HIP Runtime"]
            GPU["AMD ROCm GPU"]
            ROCmLib -->|HIP/ROCm| GPU
        end

        Adapter --> HTTPAPI
        Adapter --> GRPCAPI
        VLLMEngine --> ROCmLib
    end

    subgraph "KServe Pod"
        direction TB
        RBAC["kube-rbac-proxy sidecar<br/>Port 8443/TCP<br/>TLS termination + Auth"]
    end

    Client["External Client"] -->|HTTPS/8443<br/>Bearer Token| RBAC
    RBAC -->|HTTP/8000<br/>localhost| HTTPAPI

    KServeRouter["KServe Router"] -->|HTTPS/8443| RBAC
    ModelMesh["ModelMesh"] -->|gRPC/8033| GRPCAPI

    VLLMEngine -->|HTTPS/443| HFHub["HuggingFace Hub<br/>Model Weights"]
    VLLMEngine -->|HTTPS/443| S3["S3-compatible Storage<br/>Model Weights"]

    BaseImage["AIPCC Base Image<br/>rhaiis/vllm-rocm-rhel9:3.2.1"] -.->|provides runtime| VLLMEngine

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style HTTPAPI fill:#7ed321,stroke:#333
    style GRPCAPI fill:#7ed321,stroke:#333
    style ROCmLib fill:#9b59b6,stroke:#333,color:#fff
    style GPU fill:#9b59b6,stroke:#333,color:#fff
    style RBAC fill:#f5a623,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style BaseImage fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style Client fill:#f9f9f9,stroke:#999
    style KServeRouter fill:#f9f9f9,stroke:#999
    style ModelMesh fill:#f9f9f9,stroke:#999
