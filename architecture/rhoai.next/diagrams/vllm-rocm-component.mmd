    style TGISAPI fill:#50c878,stroke:#333,color:#fff
    style RHAIISBase fill:#9b59b6,stroke:#333,color:#fff
    style ROCmLibs fill:#9b59b6,stroke:#333,color:#fff
    style Python fill:#9b59b6,stroke:#333,color:#fff
    style GPU fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#f5a623,stroke:#333,color:#fff
    style ModelStorage fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style GRPCClient fill:#f9f9f9,stroke:#999
