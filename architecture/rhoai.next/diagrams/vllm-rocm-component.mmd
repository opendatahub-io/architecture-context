graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        Adapter["vllm_tgis_adapter<br/>(Entrypoint Module)"]
        VLLMEngine["vLLM Engine<br/>(PagedAttention, Continuous Batching)"]
        ROCmLibs["ROCm Libraries<br/>(HIP Runtime, GPU Kernels)"]
        HTTPServer["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        GRPCServer["TGIS gRPC API<br/>Port 8033/TCP"]

        Adapter --> HTTPServer
        Adapter --> GRPCServer
        Adapter --> VLLMEngine
        VLLMEngine --> ROCmLibs
    end

    subgraph "Base Image Layer"
        RHAIIS["RHAIIS vllm-rocm-rhel9:3.2.1<br/>(Pre-built Base Image)"]
    end

    RHAIIS -.->|provides| VLLMEngine
    RHAIIS -.->|provides| ROCmLibs
    RHAIIS -.->|provides| Adapter

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"| HTTPServer
    TGISClient["TGIS Client / KServe"] -->|"gRPC Inference<br/>Request"| GRPCServer

    subgraph "KServe Orchestration"
        ServingRuntime["ServingRuntime CR"]
        InferenceService["InferenceService CR"]
        ServingRuntime -->|"references image"| Adapter
        InferenceService -->|"triggers pod"| ServingRuntime
    end

    ROCmLibs -->|"HIP/ROCm"| GPU["AMD ROCm GPU<br/>(Host Node)"]
    VLLMEngine -->|"read model weights"| ModelStorage["Model Storage<br/>(PVC / S3)"]

    style Adapter fill:#4a90e2,color:#fff
    style VLLMEngine fill:#4a90e2,color:#fff
    style ROCmLibs fill:#4a90e2,color:#fff
    style HTTPServer fill:#50c878,color:#fff
    style GRPCServer fill:#50c878,color:#fff
    style RHAIIS fill:#e8e8e8,stroke:#999
    style GPU fill:#f5a623,color:#fff
    style ModelStorage fill:#f5a623,color:#fff
    style ServingRuntime fill:#7ed321,color:#fff
    style InferenceService fill:#7ed321,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style TGISClient fill:#f9f9f9,stroke:#999
