graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        TGISAdapter["vllm_tgis_adapter<br/>(Python entrypoint)"]
        VLLMEngine["vLLM Engine<br/>(LLM inference runtime)"]
        OpenAIAPI["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        TGISAPI["TGIS gRPC Service<br/>Port 8033/TCP"]

        TGISAdapter -->|wraps| VLLMEngine
        TGISAdapter -->|exposes| OpenAIAPI
        TGISAdapter -->|exposes| TGISAPI
    end

    subgraph "Base Image"
        RHAIISBase["RHAIIS vLLM ROCm<br/>registry.redhat.io/rhaiis/vllm-rocm-rhel9<br/>v3.2.1"]
        ROCmLibs["ROCm Libraries"]
        Python["Python Runtime"]
    end

    VLLMEngine -->|built on| RHAIISBase
    RHAIISBase -->|includes| ROCmLibs
    RHAIISBase -->|includes| Python

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"| OpenAIAPI
    GRPCClient["gRPC Client / KServe Router"] -->|"GenerationService RPC"| TGISAPI

    VLLMEngine -->|"PCIe/ROCm"| GPU["AMD ROCm GPU"]

    KServe["KServe Controller"] -->|"deploys as<br/>ServingRuntime"| TGISAdapter

    VLLMEngine -->|"model download<br/>HTTPS/443"| ModelStorage["Model Storage<br/>(S3 / PVC)"]
    VLLMEngine -.->|"optional download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]

    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
