graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        TGIS["vllm_tgis_adapter<br/>(Entrypoint Module)"]
        vLLM["vLLM Engine<br/>(LLM Inference)"]
        OpenAI_API["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        TGIS_API["TGIS gRPC Service<br/>Port 8033/TCP"]
        Health["Health Check<br/>/health"]

        TGIS -->|wraps| vLLM
        TGIS -->|exposes| OpenAI_API
        TGIS -->|exposes| TGIS_API
        TGIS -->|exposes| Health
    end

    subgraph "RHAIIS Base Image"
        BaseImage["registry.redhat.io/rhaiis/<br/>vllm-rocm-rhel9:3.2.1"]
        ROCmLibs["ROCm Libraries"]
        Python["Python Runtime"]
        Adapter["vllm_tgis_adapter Module"]

        BaseImage --- ROCmLibs
        BaseImage --- Python
        BaseImage --- Adapter
    end

    Client["Client / KServe Router"] -->|POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models| OpenAI_API
    Client -->|gRPC GenerationService| TGIS_API

    vLLM -->|PCIe/ROCm| GPU["AMD ROCm GPU<br/>(Device Plugin)"]
    vLLM -->|loads model| ModelStorage["Model Storage<br/>(PVC / S3)"]

    KServe["KServe<br/>(ServingRuntime)"] -->|deploys & routes| TGIS

    BaseImage -.->|base layer| TGIS

    style TGIS fill:#4a90e2,stroke:#333,color:#fff
    style vLLM fill:#4a90e2,stroke:#333,color:#fff
    style OpenAI_API fill:#7ed321,stroke:#333,color:#fff
    style TGIS_API fill:#7ed321,stroke:#333,color:#fff
    style Health fill:#7ed321,stroke:#333,color:#fff
    style BaseImage fill:#e8e8e8,stroke:#666
    style ROCmLibs fill:#e8e8e8,stroke:#666
    style Python fill:#e8e8e8,stroke:#666
    style Adapter fill:#e8e8e8,stroke:#666
    style GPU fill:#f5a623,stroke:#333,color:#fff
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
