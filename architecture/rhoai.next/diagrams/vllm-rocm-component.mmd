graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        subgraph "RHAIIS Base Image (rhaiis/vllm-rocm-rhel9)"
            vLLM["vLLM Runtime<br/>LLM Inference Engine"]
            TGISAdapter["vllm_tgis_adapter<br/>TGIS gRPC Bridge"]
            ROCmLibs["ROCm Libraries<br/>HIP, MIOpen, RCCL, hipBLAS"]
            PythonEnv["Python Environment<br/>RHEL 9 UBI"]
        end
        subgraph "Thin Wrapper Layer (this repo)"
            Entrypoint["Entrypoint<br/>python3 -m vllm_tgis_adapter"]
            EnvVars["Env Config<br/>PORT=8000, GRPC_PORT=8033"]
            UserConfig["USER 2000<br/>Non-root execution"]
        end
        Entrypoint -->|launches| TGISAdapter
        TGISAdapter -->|wraps| vLLM
        vLLM -->|uses| ROCmLibs
        ROCmLibs -->|runs on| PythonEnv
    end

    Client[External Client] -->|POST /v1/completions<br/>POST /v1/chat/completions| PlatformIngress
    PlatformIngress["Platform Ingress<br/>Gateway/HTTPRoute<br/>443/TCP HTTPS"] -->|HTTPS/8443| KubeRBACProxy
    KubeRBACProxy["kube-rbac-proxy<br/>Auth Sidecar<br/>8443/TCP"] -->|HTTP/8000| vLLM
    KubeRBACProxy -->|gRPC/8033| TGISAdapter

    subgraph "Deployment Infrastructure"
        KServe["KServe<br/>ServingRuntime CRD"]
        InferenceService["InferenceService CR"]
    end

    KServe -->|deploys & manages| vLLM
    InferenceService -->|routes requests to| PlatformIngress

    subgraph "GPU Hardware"
        AMDGPU["AMD Instinct GPU<br/>MI200/MI300 Series"]
    end

    ROCmLibs -->|HIP API| AMDGPU

    subgraph "Model Storage"
        PVC["PVC / Local Storage"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
    end

    vLLM -->|loads model| PVC
    vLLM -->|fetches artifacts| S3
    vLLM -->|downloads weights| HFHub

    style vLLM fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style ROCmLibs fill:#4a90e2,stroke:#333,color:#fff
    style PythonEnv fill:#4a90e2,stroke:#333,color:#fff
    style Entrypoint fill:#50c878,stroke:#333,color:#fff
    style EnvVars fill:#50c878,stroke:#333,color:#fff
    style UserConfig fill:#50c878,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style InferenceService fill:#f5a623,stroke:#333,color:#fff
    style PlatformIngress fill:#ffe6cc,stroke:#d79b00
    style KubeRBACProxy fill:#ffe6cc,stroke:#d79b00
    style AMDGPU fill:#e8e8e8,stroke:#333
    style PVC fill:#fff2cc,stroke:#d6b656
    style S3 fill:#fff2cc,stroke:#d6b656
    style HFHub fill:#fff2cc,stroke:#d6b656
    style Client fill:#f9f9f9,stroke:#999
