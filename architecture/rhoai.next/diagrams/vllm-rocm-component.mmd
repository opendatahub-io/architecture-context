graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        TGISAdapter["vllm_tgis_adapter<br/>(Python entrypoint)"]
        VLLMEngine["vLLM Engine<br/>(LLM inference)"]
        ROCmRuntime["ROCm Runtime<br/>(AMD GPU libraries)"]

        TGISAdapter -->|wraps| VLLMEngine
        VLLMEngine -->|uses| ROCmRuntime
    end

    subgraph "APIs Exposed"
        OpenAIAPI["OpenAI-compatible HTTP API<br/>Port 8000/TCP"]
        TGISAPI["TGIS gRPC API<br/>Port 8033/TCP"]
    end

    TGISAdapter -->|serves| OpenAIAPI
    TGISAdapter -->|serves| TGISAPI

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"| OpenAIAPI
    Client -->|"gRPC GenerationService"| TGISAPI

    KServe["KServe Controller"] -->|"deploys as<br/>ServingRuntime"| TGISAdapter
    ModelStorage["Model Storage<br/>(PVC / S3)"] -->|"model weights"| VLLMEngine
    GPU["AMD ROCm GPU<br/>(Host Device)"] ---|"PCIe/ROCm<br/>compute"| ROCmRuntime

    RHAIIS["RHAIIS Base Image<br/>registry.redhat.io/rhaiis/<br/>vllm-rocm-rhel9:3.2.1"] -.->|"base layer"| TGISAdapter

    style TGISAdapter fill:#4a90e2,color:#fff
    style VLLMEngine fill:#4a90e2,color:#fff
    style ROCmRuntime fill:#4a90e2,color:#fff
    style OpenAIAPI fill:#f5a623,color:#fff
    style TGISAPI fill:#f5a623,color:#fff
    style KServe fill:#7ed321,color:#fff
    style ModelStorage fill:#e8e8e8,stroke:#333
    style GPU fill:#e74c3c,color:#fff
    style Client fill:#9b59b6,color:#fff
    style RHAIIS fill:#999,color:#fff
