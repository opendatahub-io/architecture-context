graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        Adapter["vllm_tgis_adapter<br/>(Entrypoint Module)"]
        VLLMEngine["vLLM Engine<br/>(PagedAttention, Continuous Batching)"]
        ROCmLibs["ROCm Libraries<br/>(HIP Runtime, GPU Kernels)"]
        HTTPServer["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        GRPCServer["TGIS gRPC API<br/>Port 8033/TCP"]

        Adapter --> HTTPServer
        Adapter --> GRPCServer
        Adapter --> VLLMEngine
        VLLMEngine --> ROCmLibs
    end

    subgraph "Base Image Layer"
        RHAIIS["RHAIIS vllm-rocm-rhel9:3.2.1<br/>(Pre-built Base Image)"]
    end

    RHAIIS -.->|provides| VLLMEngine
    RHAIIS -.->|provides| ROCmLibs
    RHAIIS -.->|provides| Adapter

    Client[Client / KServe Router] -->|POST /v1/completions<br/>POST /v1/chat/completions| HTTPServer
    Client -->|gRPC GenerateStream| GRPCServer

    KServeSR["KServe ServingRuntime CR"] -->|deploys| Adapter
    KServeIS["KServe InferenceService CR"] -->|triggers pod| Adapter

    VLLMEngine -->|HIP/ROCm| GPU["AMD ROCm GPU"]
    VLLMEngine -->|load weights| ModelStorage["Model Storage<br/>(PVC / S3)"]

    PlatformIngress["Platform Ingress<br/>(Gateway API /<br/>kube-rbac-proxy)"] -->|routes traffic| HTTPServer
    PlatformIngress -->|routes traffic| GRPCServer

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style ROCmLibs fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#50c878,stroke:#333,color:#fff
    style GRPCServer fill:#50c878,stroke:#333,color:#fff
    style RHAIIS fill:#e8e8e8,stroke:#333
    style GPU fill:#f5a623,stroke:#333,color:#fff
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style KServeSR fill:#7ed321,stroke:#333,color:#fff
    style KServeIS fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
