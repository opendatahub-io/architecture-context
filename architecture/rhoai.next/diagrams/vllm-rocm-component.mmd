graph TB
    subgraph "vllm-rocm Container Image"
        direction TB
        subgraph "Application Layer"
            TGISAdapter["vllm_tgis_adapter<br/>(Python Module)"]
            VLLMEngine["vLLM Inference Engine"]
            TGISAdapter -->|wraps| VLLMEngine
        end

        subgraph "API Layer"
            HTTPEndpoint["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
            GRPCEndpoint["TGIS gRPC Service<br/>Port 8033/TCP"]
        end

        subgraph "GPU Runtime"
            ROCmStack["ROCm GPU Libraries<br/>(HIP Runtime)"]
        end

        TGISAdapter --> HTTPEndpoint
        TGISAdapter --> GRPCEndpoint
        VLLMEngine -->|tensor ops| ROCmStack
    end

    subgraph "Base Image"
        BaseImage["rhaiis/vllm-rocm-rhel9:3.2.1<br/>(UBI9 + Python + ROCm + vLLM)"]
    end

    Client["Client<br/>(via KServe Gateway)"] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models"| HTTPEndpoint
    KServeGRPC["Client<br/>(via KServe)"] -->|"gRPC GenerateStream"| GRPCEndpoint

    ROCmStack -->|"PCIe/Device API"| GPU["AMD ROCm GPU<br/>(Host Device)"]

    VLLMEngine -->|"Load model weights"| ModelStorage["Model Storage<br/>(S3/PVC)"]

    BaseImage -.->|provides all runtime deps| TGISAdapter

    KServe["KServe Controller"] -->|"manages lifecycle<br/>scaling, routing"| TGISAdapter

    style TGISAdapter fill:#4a90e2,stroke:#333
    style VLLMEngine fill:#4a90e2,stroke:#333
    style HTTPEndpoint fill:#7ed321,stroke:#333
    style GRPCEndpoint fill:#7ed321,stroke:#333
    style ROCmStack fill:#9b59b6,stroke:#333
    style BaseImage fill:#e8e8e8,stroke:#333
    style GPU fill:#f5a623,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style KServeGRPC fill:#f9f9f9,stroke:#999
