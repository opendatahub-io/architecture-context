graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        KFTO["Kubeflow Training Operator<br/>Manages PyTorchJob CR<br/>ServiceAccount RBAC"]
    end

    subgraph TrainingPods["TRAINING JOB PODS (Internal - Pod Mesh)"]
        direction TB

        subgraph Worker0["Worker 0 (Master)"]
            Container0["FMS HF Tuning Container<br/>Image: quay.io/modh/fms-hf-tuning<br/>Base: UBI 9<br/>CUDA 12.1, cuDNN 9.6<br/>Entry: accelerate_launch.py"]
        end

        subgraph WorkerN["Worker 1..N"]
            ContainerN["FMS HF Tuning Container<br/>FSDP Distributed Workers<br/>Same image & config"]
        end
    end

    subgraph Storage["STORAGE (Internal - Volume Mounts)"]
        PVC["PersistentVolumeClaim<br/>/data/input (read)<br/>/data/output (write)<br/>/data/models (cache)<br/>POSIX permissions"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        MLflow["MLflow Server<br/>configurable port<br/>HTTP/HTTPS<br/>URI-based auth"]
        Aim["Aim Server<br/>configurable port<br/>HTTP/HTTPS<br/>No auth"]
        ClearML["ClearML Server<br/>configurable port<br/>HTTPS TLS 1.2+<br/>API key auth"]
    end

    subgraph QueueMgmt["QUEUE MANAGEMENT"]
        Kueue["Kueue<br/>Job scheduling<br/>kueue.x-k8s.io/queue-name"]
    end

    %% Control plane flows
    KFTO -->|"Kubernetes API<br/>TLS 1.2+<br/>ServiceAccount token"| Container0
    KFTO -->|"Kubernetes API<br/>TLS 1.2+<br/>ServiceAccount token"| ContainerN
    Kueue -.->|"Kubernetes API<br/>Queue scheduling"| KFTO

    %% Inter-worker FSDP (SECURITY RISK)
    Container0 <-->|"29500/TCP<br/>c10d static rendezvous<br/>⚠️ PLAINTEXT<br/>Gradient sync (all-reduce)<br/>Requires NetworkPolicy"| ContainerN

    %% Storage access
    Container0 -->|"Filesystem<br/>POSIX permissions"| PVC
    ContainerN -->|"Filesystem<br/>POSIX permissions"| PVC

    %% External egress
    Container0 -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Container0 -->|"HTTP/HTTPS<br/>configurable<br/>URI-based"| MLflow
    Container0 -->|"HTTP/HTTPS<br/>configurable<br/>No auth"| Aim
    Container0 -->|"HTTPS<br/>TLS 1.2+<br/>API key"| ClearML

    %% Styling
    classDef controlplane fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef training fill:#d1fae5,stroke:#10b981,stroke-width:2px
    classDef storage fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef external fill:#fee2e2,stroke:#ef4444,stroke-width:2px
    classDef queue fill:#e0e7ff,stroke:#6366f1,stroke-width:2px

    class KFTO controlplane
    class Container0,ContainerN training
    class PVC storage
    class HFHub,MLflow,Aim,ClearML external
    class Kueue queue
