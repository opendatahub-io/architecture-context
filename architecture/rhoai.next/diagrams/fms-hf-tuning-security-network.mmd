graph TB
    subgraph ControlPlane["CONTROL PLANE"]
        KFTO["Kubeflow Training Operator<br/>Namespace: kubeflow<br/>Creates PyTorchJob"]
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACE (user-namespace)"]
        direction TB

        subgraph Pod["fms-hf-tuning Pod"]
            direction TB
            EntryPt["accelerate_launch.py<br/>User: tuning (UID 1000)<br/>Image: UBI 9 + CUDA 12.1"]
            SFT["tuning.sft_trainer"]
            DataPipe["tuning.data"]
            TrackerMod["tuning.trackers"]
            AccelPlugins["fms-acceleration<br/>(optional plugins)"]
            EntryPt --> SFT
            SFT --> DataPipe
            SFT --> TrackerMod
            SFT --> AccelPlugins
        end

        PVC["PVC<br/>Persistent Volume<br/>Model input/output<br/>Training data"]
        Workers["Worker Pods 1..N<br/>(Multi-GPU FSDP)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>TLS 1.2+<br/>HF Token (optional)"]
        AimStack["AimStack Server<br/>HTTP<br/>No encryption<br/>No auth"]
        MLflow["MLflow Server<br/>HTTP/HTTPS<br/>Configurable"]
        ClearML["ClearML Server<br/>HTTPS<br/>API Key auth"]
    end

    subgraph BuildOnly["BUILD-TIME ONLY"]
        NVIDIA["NVIDIA CUDA repos<br/>developer.download.nvidia.com<br/>HTTPS/443, TLS 1.2+"]
        PyPI["PyPI<br/>pypi.org<br/>HTTPS/443, TLS 1.2+"]
    end

    %% Control plane to workload
    KFTO -->|"Create Pod<br/>Config: env var (base64 JSON)<br/>or ConfigMap mount"| Pod

    %% Internal flows
    SFT -->|"Filesystem<br/>Read/Write"| PVC
    SFT -->|"NCCL/Gloo<br/>29500/TCP<br/>No encryption"| Workers

    %% Egress flows
    SFT -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token (optional)"| HFHub
    TrackerMod -->|"HTTP<br/>configurable port<br/>No encryption"| AimStack
    TrackerMod -->|"HTTP/HTTPS<br/>configurable port"| MLflow
    TrackerMod -->|"HTTPS<br/>configurable port<br/>API Key"| ClearML

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildonly fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef pod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class KFTO controlplane
    class EntryPt,SFT,DataPipe,TrackerMod,AccelPlugins pod
    class PVC,Workers workload
    class HFHub,AimStack,MLflow,ClearML external
    class NVIDIA,PyPI buildonly
