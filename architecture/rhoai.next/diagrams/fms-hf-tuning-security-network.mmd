graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        KFTO["Kubeflow Training Operator<br/>Namespace: kubeflow<br/>Creates PyTorchJob resources"]
        Kueue["Kueue Queue Manager<br/>Queue-based job scheduling"]
    end

    subgraph BatchZone["BATCH WORKLOAD ZONE (Training Pods)"]
        direction TB

        subgraph TrainingPod["Training Pod - PyTorchJob Worker<br/>Namespace: user-namespace<br/>Image: fms-hf-tuning (UBI9 + CUDA 12.1)"]
            direction TB

            AccelLaunch["accelerate_launch.py<br/>Container Entrypoint"]
            SFTTrainer["sft_trainer.py<br/>Core Training Engine"]
            AccelLaunch -->|"subprocess"| SFTTrainer
        end

        subgraph Storage["LOCAL STORAGE (No Network)"]
            PVC_M["PVC: Model Weights<br/>(ReadOnly)"]
            PVC_D["PVC: Training Data<br/>(ReadOnly)"]
            PVC_O["PVC: Output/Checkpoints<br/>(ReadWrite)"]
            ConfigMap["ConfigMap<br/>/etc/config/config.json"]
        end

        subgraph GPUAccess["GPU ACCESS (No Network)"]
            GPU["NVIDIA GPU<br/>CUDA 12.1<br/>PCIe/NVLink"]
        end

        subgraph FSDP["MULTI-GPU COMMS"]
            Rank0["Rank 0"] <-->|"NCCL/Gloo<br/>29500/TCP<br/>PLAINTEXT<br/>No Auth"| RankN["Rank 1..N"]
        end
    end

    subgraph ExternalServices["EGRESS TO EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]

        AimStack["AimStack Server<br/>(optional)<br/>HTTP/HTTPS<br/>No Auth"]

        MLflow["MLflow Server<br/>(optional)<br/>HTTP/HTTPS<br/>Auth: configurable"]

        ClearML["ClearML Server<br/>(optional)<br/>HTTP/HTTPS<br/>Auth: API key"]
    end

    %% Control Plane Flows
    KFTO -->|"K8s API / 6443/TCP<br/>TLS 1.3<br/>ServiceAccount Token"| TrainingPod
    Kueue -.->|"Scheduling decisions"| KFTO

    %% Storage Flows (local, no network)
    SFTTrainer ---|"local mount"| PVC_M
    SFTTrainer ---|"local mount"| PVC_D
    SFTTrainer ---|"local mount"| PVC_O
    AccelLaunch ---|"local mount"| ConfigMap

    %% GPU Flow
    SFTTrainer ---|"PCIe/NVLink"| GPU

    %% Egress Flows
    SFTTrainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    SFTTrainer -.->|"HTTP/HTTPS<br/>configurable"| AimStack
    SFTTrainer -.->|"HTTP/HTTPS<br/>configurable"| MLflow
    SFTTrainer -.->|"HTTP/HTTPS<br/>configurable"| ClearML

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef batchzone fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef gpu fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class KFTO,Kueue controlplane
    class AccelLaunch,SFTTrainer batchzone
    class PVC_M,PVC_D,PVC_O,ConfigMap storage
    class GPU gpu
    class HFHub,AimStack,MLflow,ClearML external
    class Rank0,RankN warning
