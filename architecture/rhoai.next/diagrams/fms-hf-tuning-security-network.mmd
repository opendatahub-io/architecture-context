graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        KFTO["Kubeflow Training Operator<br/>Kubernetes API<br/>TLS 1.2+<br/>ServiceAccount Auth"]
    end

    subgraph TrainingNS["TRAINING JOB NAMESPACE (Batch Pods)"]
        direction TB

        subgraph FSDPCluster["FSDP Distributed Training"]
            Worker0["PyTorchJob Worker 0<br/>Image: quay.io/modh/fms-hf-tuning<br/>SA: PyTorchJob SA<br/>GPU: CUDA 12.1 / cuDNN 9.6"]
            WorkerN["PyTorchJob Worker N<br/>Image: quay.io/modh/fms-hf-tuning<br/>SA: PyTorchJob SA<br/>GPU: CUDA 12.1 / cuDNN 9.6"]
        end

        subgraph Storage["Persistent Storage"]
            PVCInput["PVC /data/input<br/>Training Data"]
            PVCOutput["PVC /data/output<br/>Model Checkpoints"]
            PVCModels["PVC /data/models<br/>Cached Models"]
        end

        Kueue["Kueue (optional)<br/>Queue Label<br/>GPU Scheduling"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        MLflow["MLflow Server<br/>(optional)<br/>HTTP/HTTPS<br/>URI-based Auth"]
        Aim["Aim Server<br/>(optional)<br/>HTTP/HTTPS<br/>No Auth"]
        ClearML["ClearML Server<br/>(optional)<br/>HTTPS TLS 1.2+<br/>API Key Auth"]
    end

    %% Control plane flows
    KFTO -->|"Kubernetes API<br/>TLS 1.2+<br/>ServiceAccount"| Worker0
    KFTO -->|"Kubernetes API<br/>TLS 1.2+<br/>ServiceAccount"| WorkerN

    %% FSDP inter-worker (PLAINTEXT WARNING)
    Worker0 <-->|"⚠️ 29500/TCP<br/>c10d rendezvous<br/>PLAINTEXT<br/>No Auth"| WorkerN

    %% Storage access
    Worker0 -->|"Filesystem<br/>POSIX perms"| PVCInput
    Worker0 -->|"Filesystem<br/>POSIX perms"| PVCOutput
    Worker0 -->|"Filesystem<br/>POSIX perms"| PVCModels

    %% Egress flows
    Worker0 -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Worker0 -.->|"HTTP/HTTPS<br/>configurable<br/>URI-based"| MLflow
    Worker0 -.->|"HTTP/HTTPS<br/>configurable<br/>None"| Aim
    Worker0 -.->|"HTTPS<br/>TLS 1.2+<br/>API Key"| ClearML

    %% Kueue
    Kueue -.->|"Queue scheduling"| Worker0

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef training fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class KFTO controlplane
    class Worker0,WorkerN training
    class PVCInput,PVCOutput,PVCModels storage
    class HFHub external
    class MLflow,Aim,ClearML optional
    class Kueue optional
