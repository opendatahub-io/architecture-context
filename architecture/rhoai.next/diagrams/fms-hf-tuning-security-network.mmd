graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        KFTO["Kubeflow Training Operator<br/>Creates PyTorchJob CRs"]
    end

    subgraph TrainingPods["TRAINING JOB PODS (Namespace-scoped)"]
        direction TB

        subgraph Master["PyTorchJob Pod - Master (Worker 0)"]
            AccLaunch["accelerate_launch.py<br/>Image: quay.io/modh/fms-hf-tuning<br/>GPU: NVIDIA CUDA 12.1<br/>Env: HF_TOKEN (Bearer)"]
        end

        subgraph WorkerN["PyTorchJob Pod - Worker 1..N"]
            Worker["Same image & config<br/>Port 29500/TCP rendezvous"]
        end
    end

    subgraph Storage["STORAGE (PVC - Internal)"]
        PVCIn["/data/input (ReadOnly)<br/>Training datasets<br/>JSON, JSONL, Parquet, Arrow"]
        PVCOut["/data/output (ReadWrite)<br/>Model checkpoints<br/>safetensors format"]
        PVCModels["/data/models (ReadWrite)<br/>Cached model weights"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
        MLflow["MLflow Server<br/>(optional)<br/>HTTP/HTTPS configurable<br/>Auth: URI-based"]
        Aim["Aim Server<br/>(optional)<br/>HTTP/HTTPS configurable<br/>Auth: None"]
        ClearML["ClearML Server<br/>(optional)<br/>HTTPS TLS 1.2+<br/>Auth: API key"]
    end

    %% Control plane flows
    KFTO -->|"Kubernetes API<br/>TLS 1.2+<br/>Auth: ServiceAccount"| AccLaunch

    %% Inter-worker communication
    AccLaunch <-->|"⚠️ 29500/TCP<br/>c10d static rendezvous<br/>PLAINTEXT<br/>Auth: None<br/>FSDP gradient sync"| Worker

    %% Storage flows
    AccLaunch -->|"Filesystem<br/>POSIX permissions"| PVCIn
    AccLaunch -->|"Filesystem<br/>POSIX permissions"| PVCOut
    AccLaunch -->|"Filesystem<br/>POSIX permissions"| PVCModels

    %% External egress
    AccLaunch -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"| HFHub
    AccLaunch -.->|"HTTP/HTTPS<br/>configurable<br/>URI-based auth"| MLflow
    AccLaunch -.->|"HTTP/HTTPS<br/>configurable"| Aim
    AccLaunch -.->|"HTTPS<br/>TLS 1.2+<br/>API key"| ClearML

    %% Styling
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef trainingpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class KFTO controlplane
    class AccLaunch,Worker trainingpod
    class PVCIn,PVCOut,PVCModels storage
    class HFHub,MLflow,Aim,ClearML external
