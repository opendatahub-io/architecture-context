graph TB
    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        KFTO["KFTO PyTorchJob Controller<br/>SA: kubeflow-training-operator<br/>Kubernetes API / TLS 1.3"]
    end

    subgraph TrainingNS["TRAINING NAMESPACE (User Project)"]
        direction TB

        subgraph TrainingPod["Training Pod"]
            AccLaunch["accelerate_launch.py<br/>Image: quay.io/modh/fms-hf-tuning<br/>Config: /etc/config/config.json"]
            SFTTrainer["sft_trainer.py<br/>SFTTrainer + PEFT + Acceleration"]
            AccLaunch -->|"subprocess"| SFTTrainer
        end

        subgraph Storage["Local Storage (PVC Mounts)"]
            PVC_Model["PVC: Model Weights<br/>Mount: RWX"]
            PVC_Data["PVC: Training Data<br/>Mount: ROX"]
            PVC_Output["PVC: Output/Checkpoints<br/>Mount: RWX"]
        end

        GPU["NVIDIA GPU<br/>PCIe/NVLink<br/>No network"]
    end

    subgraph InterPod["INTER-POD (Multi-GPU/Multi-Node)"]
        direction LR
        Rank0["Rank 0"]
        Rank1["Rank 1"]
        RankN["Rank N"]
        Rank0 <-->|"NCCL<br/>⚠️ PLAINTEXT"| Rank1
        Rank1 <-->|"NCCL<br/>⚠️ PLAINTEXT"| RankN
    end

    subgraph ExternalServices["EGRESS - EXTERNAL SERVICES"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        Aim["AimStack Server<br/>HTTP/HTTPS<br/>configurable"]
        MLflow["MLflow Server<br/>HTTP/HTTPS<br/>configurable"]
        ClearML["ClearML Server<br/>HTTP/HTTPS<br/>API key"]
    end

    %% Flows
    KFTO -->|"Creates PyTorchJob<br/>K8s API / TLS 1.3<br/>ServiceAccount"| TrainingPod
    SFTTrainer -->|"Local FS"| PVC_Model
    SFTTrainer -->|"Local FS"| PVC_Data
    SFTTrainer -->|"Local FS"| PVC_Output
    SFTTrainer -->|"PCIe/NVLink"| GPU
    SFTTrainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    SFTTrainer -.->|"HTTP(S)<br/>configurable"| Aim
    SFTTrainer -.->|"HTTP(S)<br/>configurable"| MLflow
    SFTTrainer -.->|"HTTP(S)<br/>configurable"| ClearML
    TrainingPod -->|"TCP/29500<br/>⚠️ PLAINTEXT<br/>No Auth"| InterPod

    %% Styling
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef trainingns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef interpod fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef gpu fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d6b656,stroke-width:3px,stroke-dasharray: 5 5

    class KFTO controlplane
    class AccLaunch,SFTTrainer trainingns
    class PVC_Model,PVC_Data,PVC_Output storage
    class GPU gpu
    class Rank0,Rank1,RankN warning
    class HF,Aim,MLflow,ClearML external
