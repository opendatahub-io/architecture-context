graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Admin"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>RBAC"]
    end

    subgraph KueueServices["KUEUE SERVICES (Namespace: opendatahub)"]
        direction TB

        subgraph ControllerPod["kueue-controller-manager Pod"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]
            MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS TLS<br/>Bearer Token Auth"]
            WebhookEndpoint["Webhook Server<br/>9443/TCP HTTPS TLS<br/>mTLS (API Server)"]
        end

        WebhookSvc["kueue-webhook-service<br/>ClusterIP 443→9443"]
        MetricsSvc["kueue-metrics-service<br/>ClusterIP 8443→8443"]
        NetworkPolicy["NetworkPolicy<br/>webhook_network_policy"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>OpenShift Monitoring<br/>ServiceMonitor"]
    end

    subgraph IntegratedWorkloads["WORKLOAD NAMESPACES"]
        direction TB
        Jobs["batch/v1 Jobs"]
        KubeflowJobs["Kubeflow Training Jobs<br/>(PyTorch, TF, MPI, Paddle, XGBoost)"]
        RayWorkloads["Ray Jobs & Clusters"]
        OtherWorkloads["JobSets, AppWrappers,<br/>LeaderWorkerSets, Pods"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Disabled in RHOAI)"]
        MultiKueueWorker["MultiKueue Worker Clusters<br/>443/TCP HTTPS TLS 1.2+<br/>KubeConfig Auth<br/>(DISABLED)"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User credentials"| K8sAPI

    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>mTLS (API server cert)"| WebhookSvc
    WebhookSvc --> WebhookEndpoint

    WebhookEndpoint -->|"Intercepts workload<br/>create/update"| K8sAPI

    ControllerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    K8sAPI -.->|"Webhook calls on<br/>workload creation"| Jobs
    K8sAPI -.->|"Webhook calls on<br/>workload creation"| KubeflowJobs
    K8sAPI -.->|"Webhook calls on<br/>workload creation"| RayWorkloads
    K8sAPI -.->|"Webhook calls on<br/>workload creation"| OtherWorkloads

    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token (SA)"| MetricsSvc
    MetricsSvc --> MetricsEndpoint

    ControllerPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>KubeConfig (DISABLED)"| MultiKueueWorker

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kueueservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workloads fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class User external
    class K8sAPI controlplane
    class HealthProbe,MetricsEndpoint,WebhookEndpoint,WebhookSvc,MetricsSvc,NetworkPolicy kueueservice
    class Prometheus monitoring
    class Jobs,KubeflowJobs,RayWorkloads,OtherWorkloads workloads
    class MultiKueueWorker externalservice
