graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Certs, Tokens, OIDC<br/>AuthZ: RBAC"]
    end

    subgraph KueueNS["KUEUE NAMESPACE (kueue-system / opendatahub)"]
        direction TB

        subgraph KueuePod["kueue-controller-manager Pod"]
            direction TB
            WebhookSvr["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (cert-manager/internal)<br/>Auth: API Server client cert<br/>POST /mutate-*, /validate-*"]
            MetricsSvr["Metrics Server<br/>8443/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token<br/>GET /metrics"]
            HealthSvr["Health Probes<br/>8081/TCP HTTP<br/>No encryption<br/>No auth<br/>GET /healthz, /readyz"]
        end

        WebhookSvc["Service: kueue-webhook-service<br/>ClusterIP 443→9443<br/>NetworkPolicy: ingress 9443 only (RHOAI)"]
        MetricsSvc["Service: kueue-metrics-service<br/>ClusterIP 8443→8443"]

        WebhookSvc --> WebhookSvr
        MetricsSvc --> MetricsSvr
    end

    subgraph RemoteClusters["REMOTE CLUSTERS (MultiKueue - Optional)"]
        RemoteAPI["Remote K8s API Servers<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: kubeconfig (Secret)"]
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>Auth: Bearer Token"]
    end

    %% External flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| APIServer

    %% API Server to Webhook (admission reviews)
    APIServer -->|"HTTPS/9443<br/>TLS (cert-manager)<br/>API Server client cert"| WebhookSvc

    %% Controller to API Server (all operations)
    KueuePod -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token"| APIServer

    %% MultiKueue egress
    KueuePod -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig credentials"| RemoteAPI

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#e1d5e7,stroke:#9673a6
    classDef endpoint fill:#f8cecc,stroke:#b85450

    class User external
    class APIServer controlplane
    class WebhookSvr,MetricsSvr,HealthSvr endpoint
    class WebhookSvc,MetricsSvc service
    class RemoteAPI remote
    class Prometheus monitoring
