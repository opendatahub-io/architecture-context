graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist<br/>kubectl / kueuectl"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>User credentials / SA tokens"]
    end

    subgraph KueueNamespace["NAMESPACE: opendatahub (RHOAI)"]
        direction TB

        subgraph ControllerPod["Kueue Controller Manager Pod"]
            direction TB
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (internal cert mgmt)<br/>Auth: API server webhook auth"]
            MetricsServer["Metrics Server<br/>8443/TCP HTTPS<br/>TLS (cert-watcher)<br/>Auth: Bearer Token + TokenReview"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>No TLS / No Auth"]
            SchedulerLoop["Scheduler Loop<br/>(in-process)"]
            Controllers["Core Controllers<br/>(in-process)"]
        end

        WebhookSvc["kueue-webhook-service<br/>ClusterIP 443→9443/TCP"]
        MetricsSvc["kueue-metrics-service<br/>ClusterIP 8443/TCP"]
        NetPolicy["NetworkPolicy<br/>Allows ingress to 9443/TCP"]

        WebhookSvc --> WebhookServer
        MetricsSvc --> MetricsServer
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor + PrometheusRule"]
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        RemoteCluster["Remote Cluster API<br/>(MultiKueue - disabled)<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: Kubeconfig"]
        CertManager["cert-manager<br/>(optional)<br/>Certificate management"]
    end

    %% Flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User creds (OIDC/certs)"| APIServer

    APIServer -->|"HTTPS/443→9443<br/>TLS (internal certs)<br/>API server webhook auth"| WebhookSvc

    Controllers -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token"| APIServer

    SchedulerLoop -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount token"| APIServer

    Prometheus -->|"HTTPS/8443<br/>TLS (cert-watcher)<br/>Bearer Token (SA token)<br/>TokenReview + SubjectAccessReview"| MetricsSvc

    Controllers -.->|"HTTPS/6443<br/>TLS 1.2+<br/>Kubeconfig auth<br/>(disabled in RHOAI)"| RemoteCluster

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,stroke-dasharray: 5 5
    classDef service fill:#ffe6cc,stroke:#d79b00
    classDef netpol fill:#f8cecc,stroke:#b85450

    class User external
    class APIServer controlplane
    class WebhookServer,MetricsServer,HealthProbe,SchedulerLoop,Controllers kueuens
    class Prometheus monitoring
    class RemoteCluster,CertManager optional
    class WebhookSvc,MetricsSvc service
    class NetPolicy netpol
