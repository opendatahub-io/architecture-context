graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token / Client Cert / OIDC"]
    end

    subgraph KueueNS["KUEUE NAMESPACE: opendatahub"]
        direction TB

        subgraph Controller["kueue-controller-manager"]
            direction LR
            WebhookPort["Webhook<br/>9443/TCP HTTPS<br/>TLS (cert-mgmt)<br/>mTLS (API server)"]
            MetricsPort["Metrics<br/>8443/TCP HTTPS<br/>TLS<br/>Bearer Token"]
            HealthPort["Health<br/>8081/TCP HTTP<br/>No Auth"]
        end

        subgraph Services["ClusterIP Services"]
            WebhookSvc["kueue-webhook-service<br/>443 → 9443/TCP<br/>HTTPS/TLS"]
            MetricsSvc["kueue-metrics-service<br/>8443/TCP<br/>HTTPS/TLS<br/>Bearer Token"]
        end

        NetPol["NetworkPolicy<br/>Ingress: port 9443 only"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (optional)"]
        RemoteKueue["Remote Kueue Clusters<br/>(MultiKueue - disabled in RHOAI)<br/>443/TCP HTTPS TLS 1.2+<br/>kubeconfig from Secret"]
        ClusterAS["Cluster Autoscaler<br/>(ProvisioningRequest)<br/>Indirect via K8s API"]
    end

    subgraph SecurityContext["CONTAINER SECURITY"]
        SecCtx["UID: 65532 (non-root)<br/>runAsNonRoot: true<br/>Seccomp: RuntimeDefault<br/>Capabilities: ALL dropped<br/>FIPS: strictfipsruntime"]
    end

    %% External → API Server
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / Client Cert"| K8sAPI

    %% API Server → Webhook (admission reviews)
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>mTLS (API server cert)<br/>36 webhooks"| WebhookSvc
    WebhookSvc --> WebhookPort
    NetPol -.->|restricts| WebhookPort

    %% Controller → API Server (egress)
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRD watches, status updates"| K8sAPI

    %% Prometheus → Metrics
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>metrics-reader ClusterRole"| MetricsSvc
    MetricsSvc --> MetricsPort

    %% MultiKueue (optional)
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig Secret<br/>(disabled: MultiKueue=false)"| RemoteKueue

    %% ProvisioningRequest (indirect)
    Controller -.->|"Creates ProvisioningRequest CR<br/>via K8s API"| ClusterAS

    %% Security context association
    SecCtx -.->|applied to| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    classDef kueue fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef security fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef netpol fill:#ffe6cc,stroke:#d79b00,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class K8sAPI k8s
    class Controller,WebhookPort,MetricsPort,HealthPort kueue
    class WebhookSvc,MetricsSvc service
    class Prometheus monitoring
    class RemoteKueue,ClusterAS extsvc
    class SecCtx security
    class NetPol netpol
