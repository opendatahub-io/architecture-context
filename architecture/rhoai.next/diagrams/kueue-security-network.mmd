graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Client certs, Bearer tokens"]
    end

    subgraph KueueNS["KUEUE NAMESPACE (opendatahub)"]
        direction TB

        subgraph Manager["kueue-controller-manager"]
            direction LR
            WebhookPort["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (cert-manager)<br/>API Server client cert"]
            MetricsPort["Metrics Server<br/>8443/TCP HTTPS<br/>TLS<br/>Bearer Token"]
            HealthPort["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]
        end

        subgraph Services["Kubernetes Services"]
            WebhookSvc["kueue-webhook-service<br/>ClusterIP 443→9443"]
            MetricsSvc["kueue-metrics-service<br/>ClusterIP 8443→8443"]
        end

        NetworkPolicy["NetworkPolicy<br/>(RHOAI: restrict<br/>webhook ingress)"]
    end

    subgraph MultiCluster["MULTI-CLUSTER (MultiKueue)"]
        RemoteAPI1["Remote K8s API Server 1<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>kubeconfig credentials"]
        RemoteAPI2["Remote K8s API Server N<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>kubeconfig credentials"]
    end

    subgraph ExternalIntegrations["EXTERNAL INTEGRATIONS"]
        Autoscaler["Cluster Autoscaler<br/>ProvisioningRequest CRD<br/>via K8s API"]
        CertManager["cert-manager<br/>Certificate CRD<br/>TLS provisioning"]
        Prometheus["Prometheus<br/>8443/TCP HTTPS<br/>Bearer Token<br/>ServiceMonitor"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| APIServer

    %% Control Plane → Kueue (webhooks)
    APIServer -->|"HTTPS/9443<br/>TLS (cert-mgr)<br/>API Server client cert"| WebhookSvc
    WebhookSvc --> WebhookPort
    NetworkPolicy -.->|"restricts ingress"| WebhookSvc

    %% Kueue → Control Plane (controller operations)
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>CRD CRUD, Job mgmt"| APIServer

    %% MultiKueue
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig (Secret)"| RemoteAPI1
    Manager -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig (Secret)"| RemoteAPI2

    %% Prometheus scraping
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc
    MetricsSvc --> MetricsPort

    %% External integrations via API Server
    Autoscaler -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| APIServer
    CertManager -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kueuens fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef multicluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class User external
    class APIServer controlplane
    class WebhookPort,MetricsPort,HealthPort,WebhookSvc,MetricsSvc kueuens
    class RemoteAPI1,RemoteAPI2 multicluster
    class Autoscaler,CertManager,Prometheus integration
    class NetworkPolicy netpol
