graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph K8sControl["KUBERNETES API SERVER"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph KueueNS["KUEUE CONTROLLER MANAGER<br/>Namespace: opendatahub<br/>SA: kueue-controller-manager"]
        direction TB

        Webhook["Webhook Server<br/>Service: kueue-webhook-service<br/>443→9443/TCP HTTPS<br/>TLS internal cert mgmt<br/>Cert: kueue-webhook-server-cert"]

        Metrics["Metrics Server<br/>Service: kueue-metrics-service<br/>8443/TCP HTTPS<br/>TLS cert-watcher<br/>Auth: Bearer Token<br/>/metrics"]

        Health["Health Probe<br/>8081/TCP HTTP<br/>No Auth<br/>/healthz /readyz"]

        subgraph Controllers["Controllers & Scheduler"]
            CoreCtrl["Core Controllers<br/>ClusterQueue, LocalQueue,<br/>Workload, ResourceFlavor"]
            SchedLoop["Scheduler Loop<br/>Admission decisions"]
            JobFW["Job Framework<br/>batch, kubeflow, ray,<br/>jobset, appwrapper"]
        end
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>+ ServiceMonitor<br/>+ PrometheusRule"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        RemoteK8s["Remote Kubernetes Cluster(s)<br/>MultiKueue Federation<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Kubeconfig Auth"]
        CloudAPI["Cloud Provider API<br/>Provisioning<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Cloud Credentials"]
    end

    %% Flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| K8sAPI

    K8sAPI -->|"HTTPS/9443<br/>TLS internal certs<br/>API server webhook auth"| Webhook

    Controllers -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA bearer token<br/>CRD CRUD, reconciliation"| K8sAPI

    Prometheus -->|"HTTPS/8443<br/>TLS cert-watcher<br/>Bearer Token<br/>(SA metrics-token)"| Metrics

    Controllers -.->|"HTTPS/6443<br/>TLS 1.2+<br/>Kubeconfig auth<br/>(MultiKueue)"| RemoteK8s

    K8sAPI -.->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials<br/>(via autoscaler)"| CloudAPI

    %% NetworkPolicy
    K8sAPI -->|"NetworkPolicy allows<br/>ingress to 9443/TCP"| Webhook

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef kueue fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#fce7f3,stroke:#ec4899,stroke-width:2px

    class User external
    class K8sAPI k8sapi
    class Webhook,Metrics,Health,CoreCtrl,SchedLoop,JobFW kueue
    class Prometheus monitoring
    class RemoteK8s,CloudAPI externalservice
