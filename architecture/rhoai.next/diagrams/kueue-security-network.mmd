graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / CI Pipeline"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["kube-apiserver<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph KueueNS["KUEUE (Namespace: opendatahub)"]
        direction TB

        subgraph WebhookZone["Webhook Zone (NetworkPolicy protected)"]
            WebhookSvc["kueue-webhook-service<br/>ClusterIP 443→9443/TCP<br/>TLS (internal certs)<br/>API server auth"]
        end

        subgraph MetricsZone["Metrics Zone"]
            MetricsSvc["kueue-metrics-service<br/>ClusterIP 8443/TCP<br/>TLS (cert-watcher)<br/>Bearer Token auth"]
        end

        subgraph HealthZone["Health Probes"]
            Health["Health Endpoints<br/>8081/TCP HTTP<br/>No encryption<br/>No auth"]
        end

        subgraph ControllerMgr["kueue-controller-manager Pod<br/>SA: kueue-controller-manager"]
            Controller["Controllers + Scheduler<br/>+ Job Framework<br/>+ MultiKueue<br/>+ TAS + Provisioning"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor<br/>PrometheusRule alerts"]
    end

    subgraph MultiKueueZone["MULTIKUEUE (disabled in RHOAI)"]
        RemoteCluster["Remote Worker Cluster<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Kubeconfig auth"]
    end

    subgraph ProvisioningZone["PROVISIONING"]
        Autoscaler["Cluster Autoscaler"]
        CloudAPI["Cloud Provider API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Cloud credentials"]
    end

    %% External → API Server
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| APIServer

    %% API Server → Webhook
    APIServer -->|"HTTPS/9443<br/>TLS (internal certs)<br/>API server webhook auth"| WebhookSvc

    %% Controller → API Server (all reconciliation)
    Controller -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA bearer token<br/>Watch: Jobs, CRDs, Pods,<br/>Nodes, Secrets"| APIServer

    %% Prometheus → Metrics
    Prometheus -->|"HTTPS/8443<br/>TLS (cert-watcher)<br/>Bearer Token<br/>(TokenReview + SAR)"| MetricsSvc

    %% MultiKueue (disabled but shown)
    Controller -.->|"HTTPS/6443<br/>TLS 1.2+<br/>Kubeconfig auth<br/>(disabled in RHOAI)"| RemoteCluster

    %% Provisioning
    Controller -->|"HTTPS/6443<br/>Creates ProvisioningRequest CR"| APIServer
    Autoscaler -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials"| CloudAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8scontrol fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef kueue fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef monitoring fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef multikueue fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,stroke-dasharray: 5 5
    classDef provisioning fill:#fff8e1,stroke:#f57f17,stroke-width:2px

    class User external
    class APIServer k8scontrol
    class WebhookSvc,MetricsSvc,Health,Controller kueue
    class Prometheus monitoring
    class RemoteCluster multikueue
    class Autoscaler,CloudAPI provisioning
