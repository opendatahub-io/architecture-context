graph LR
    Caikit["Caikit<br/>AI Toolkit & Runtime"]

    %% Internal RHOAI Dependencies
    Caikit -->|"ModelRuntime sidecar<br/>gRPC (Unix socket/TCP)"| ModelMesh["ModelMesh"]
    Caikit -->|"container colocation<br/>ServingRuntime"| KServe["KServe"]

    %% Core Python Dependencies (Required)
    subgraph CoreDeps["Core Dependencies (Required)"]
        grpcio["grpcio<br/>≥1.35,<2.0"]
        protobuf["protobuf<br/>≥3.19,<6"]
        pyyaml["PyYAML<br/>≥6.0,<7.0"]
        numpy["numpy<br/>≥1.22,<2"]
        aconfig["alchemy-config<br/>≥1.1.1,<2.0"]
        alog["alchemy-logging<br/>≥1.3.2,<2.0"]
        pyToProto["py-to-proto<br/>≥0.5.0,<0.6"]
        werkzeug["werkzeug<br/>≥2.3.7,<4.0"]
    end
    Caikit -->|"core framework"| CoreDeps

    %% Optional Runtime Dependencies
    subgraph RuntimeHTTP["HTTP Runtime (Optional)"]
        fastapi["FastAPI<br/>≥0.100,<1"]
        pydantic["Pydantic<br/>≥2.8,<3"]
        sseStarlette["sse-starlette<br/>≥1.6.1,<3"]
    end
    Caikit -.->|"HTTP server"| RuntimeHTTP

    subgraph RuntimeGRPC["gRPC Runtime (Optional)"]
        grpcHealth["grpcio-health<br/>≥1.35,<2.0"]
        grpcReflection["grpcio-reflection<br/>≥1.35,<2.0"]
        promClient["prometheus_client<br/>≥0.12,<1.0"]
        grpcProm["py-grpc-prometheus<br/>≥0.7,<0.9"]
    end
    Caikit -.->|"gRPC server"| RuntimeGRPC

    subgraph Tracing["Tracing (Optional)"]
        otelSDK["opentelemetry-sdk<br/>≥1.24,<2"]
        otelOTLP["opentelemetry-exporter-otlp<br/>≥1.24,<2"]
    end
    Caikit -.->|"distributed tracing"| Tracing

    %% External Services
    Caikit -->|"model storage<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    Caikit -.->|"trace export<br/>OTLP"| OTel["OTel Collector"]
    Caikit -.->|"remote proxy<br/>gRPC/HTTP"| RemoteRuntime["Remote Caikit<br/>Runtime"]

    %% Monitoring (inbound)
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP"| Caikit

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    Pipelines["Data Science<br/>Pipelines"] -.->|"auto deploy"| KServe

    %% Downstream consumers
    subgraph Downstream["Downstream Libraries"]
        caikitNLP["caikit-nlp"]
        caikitTGIS["caikit-tgis-serving"]
    end
    Downstream -->|"implements modules<br/>Python import"| Caikit

    %% Styling
    style Caikit fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OTel fill:#e8e8e8,stroke:#666
    style Prometheus fill:#e8e8e8,stroke:#666
    style RemoteRuntime fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Pipelines fill:#7ed321,stroke:#333

    style CoreDeps fill:#dbeafe,stroke:#3b82f6
    style RuntimeHTTP fill:#fef3c7,stroke:#f59e0b
    style RuntimeGRPC fill:#fef3c7,stroke:#f59e0b
    style Tracing fill:#fef3c7,stroke:#f59e0b
    style Downstream fill:#d1fae5,stroke:#10b981
