graph LR
    Caikit["Caikit<br/>Python AI Toolkit & Runtime"]

    %% Internal RHOAI Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        KServe["KServe<br/>Model serving platform"]
        ModelMesh["ModelMesh<br/>Model lifecycle mgmt"]
        CaikitNLP["caikit-nlp<br/>NLP modules"]
        CaikitTGIS["caikit-tgis-serving<br/>TGIS text gen"]
        ModelTrainDWF["Model-Train DWF<br/>Training workflow"]
    end

    %% External Infrastructure
    subgraph ExternalInfra["External Infrastructure"]
        OTelCollector["OpenTelemetry Collector<br/>4317/4318/TCP"]
        Prometheus["Prometheus<br/>8086/TCP"]
        ModelStorage["Model Storage<br/>Filesystem / Volume"]
    end

    %% Core Python Dependencies
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        grpcio["grpcio >=1.35,<2.0"]
        protobuf["protobuf >=3.19,<6"]
        alchemyConfig["alchemy-config >=1.1.1,<2.0"]
        alog["alchemy-logging >=1.3.2,<2.0"]
        pyToProto["py-to-proto >=0.5.0,<0.6"]
        numpy["numpy >=1.22.2,<2"]
        pyyaml["PyYAML >=6.0,<7.0"]
        semver["semver >=2.13,<4.0"]
        werkzeug["werkzeug >=2.3.7,<4.0"]
        ijson["ijson >=3.1.4,<3.3"]
    end

    %% Optional Dependencies
    subgraph OptionalDeps["Optional Dependencies (Extras)"]
        FastAPI["FastAPI >=0.100,<1<br/>(runtime-http)"]
        uvicorn["uvicorn<br/>(runtime-http)"]
        pydantic["pydantic >=2.8,<3<br/>(runtime-http)"]
        sseStarlette["sse-starlette >=1.6.1,<3<br/>(runtime-http)"]
        grpcHealthCheck["grpcio-health-checking<br/>(runtime-grpc)"]
        grpcReflection["grpcio-reflection<br/>(runtime-grpc)"]
        promClient["prometheus_client >=0.12,<1<br/>(runtime-grpc)"]
        otelSDK["opentelemetry-sdk >=1.24,<2<br/>(runtime-trace)"]
        otelExporter["opentelemetry-exporter-otlp<br/>(runtime-trace)"]
        requests["requests >=2.28.2,<3<br/>(runtime-client)"]
        pillow["pillow >=6.2.1,<11<br/>(interfaces-vision)"]
        pandas["pandas >=1.4.3,<2<br/>(interfaces-ts)"]
        pyspark["pyspark >=3.3,<3.6<br/>(interfaces-ts-pyspark)"]
    end

    %% Caikit → Internal Platform
    KServe -->|"hosts as serving container"| Caikit
    ModelMesh -->|"gRPC Unix socket<br/>mmesh.ModelRuntime"| Caikit
    CaikitNLP -->|"Python import<br/>extends framework"| Caikit
    CaikitTGIS -->|"Python import + runtime<br/>TGIS backend"| Caikit
    ModelTrainDWF -->|"gRPC/8085<br/>processproto.Process"| Caikit

    %% Caikit → External
    Caikit -->|"OTLP trace export<br/>gRPC/HTTP"| OTelCollector
    Prometheus -->|"HTTP scrape<br/>8086/TCP"| Caikit
    Caikit -->|"File I/O<br/>load/save models"| ModelStorage

    %% Caikit → Core deps
    Caikit -->|"gRPC server/client"| grpcio
    Caikit -->|"serialization"| protobuf
    Caikit -->|"configuration"| alchemyConfig
    Caikit -->|"logging"| alog
    Caikit -->|"proto generation"| pyToProto
    Caikit -->|"array ops"| numpy

    %% Caikit → Optional deps
    Caikit -.->|"HTTP server"| FastAPI
    Caikit -.->|"ASGI server"| uvicorn
    Caikit -.->|"HTTP validation"| pydantic
    Caikit -.->|"SSE streaming"| sseStarlette
    Caikit -.->|"health checks"| grpcHealthCheck
    Caikit -.->|"reflection"| grpcReflection
    Caikit -.->|"metrics"| promClient
    Caikit -.->|"tracing SDK"| otelSDK
    Caikit -.->|"trace export"| otelExporter
    Caikit -.->|"HTTP client"| requests
    Caikit -.->|"image processing"| pillow
    Caikit -.->|"time series"| pandas

