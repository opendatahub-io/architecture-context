graph LR
    Caikit["Caikit Runtime<br/>Python AI Toolkit"]

    %% Internal RHOAI Dependencies
    Caikit -->|"ModelRuntime sidecar API<br/>gRPC / unix socket"| ModelMesh["KServe / ModelMesh"]
    Caikit -->|"container runtime<br/>serving runtime container"| KServe["KServe"]

    %% Internal RHOAI Integrations (inbound)
    CaikitNLP["caikit-nlp /<br/>caikit-tgis-serving"] -->|"@module decorator<br/>Python import"| Caikit
    RemoteCaikit["Remote Caikit Runtime"] <-->|"distributed inference<br/>gRPC/8085 HTTP/8080"| Caikit

    %% External Service Dependencies
    Caikit -->|"model artifacts<br/>HTTPS/443 TLS 1.2+<br/>AWS IAM"| S3["S3-compatible<br/>Storage"]
    Caikit -->|"trace export<br/>gRPC/4317 or HTTP/4318<br/>OTLP"| OTEL["OpenTelemetry<br/>Collector"]

    %% Monitoring (inbound)
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP/8086 plaintext"| Caikit

    %% Core Python Dependencies
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        grpcio["grpcio >=1.35"]
        protobuf["protobuf >=3.19"]
        aconfig["alchemy-config >=1.1.1"]
        alog["alchemy-logging >=1.3.2"]
        pyToProto["py-to-proto >=0.5.0"]
        numpy["numpy >=1.22.2"]
        pyyaml["PyYAML >=6.0"]
        semver["semver >=2.13.0"]
        werkzeug["werkzeug >=2.3.7"]
        psutil["psutil >=5"]
    end

    Caikit -.->|"core deps"| CoreDeps

    %% Optional Runtime Dependencies
    subgraph OptionalDeps["Optional Dependencies"]
        direction TB
        subgraph GRPCOpt["runtime-grpc"]
            healthChecking["grpcio-health-checking"]
            reflection["grpcio-reflection"]
            promClient["prometheus_client"]
            grpcProm["py-grpc-prometheus"]
        end
        subgraph HTTPOpt["runtime-http"]
            fastapi["fastapi >=0.100"]
            pydantic["pydantic >=2.8"]
            sseStarlette["sse-starlette"]
            requests["requests >=2.28"]
        end
        subgraph TraceOpt["runtime-trace"]
            otelSDK["opentelemetry-sdk"]
            otelExporter["opentelemetry-exporter-otlp"]
        end
        subgraph InterfaceOpt["interfaces"]
            pillow["pillow (vision)"]
            pandas["pandas (time series)"]
            pyspark["pyspark (distributed TS)"]
        end
    end

    Caikit -.->|"optional deps"| OptionalDeps

    %% Styling
    style Caikit fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style RemoteCaikit fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OTEL fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style CoreDeps fill:#e8f4f8,stroke:#4a90e2
    style OptionalDeps fill:#f5f5f5,stroke:#999
    style GRPCOpt fill:#e8f0e8,stroke:#82b366
    style HTTPOpt fill:#e8f0e8,stroke:#82b366
    style TraceOpt fill:#e8f0e8,stroke:#82b366
    style InterfaceOpt fill:#e8f0e8,stroke:#82b366
