graph LR
    Caikit["Caikit Runtime<br/>Python AI Toolkit"]

    %% Internal Platform Dependencies
    Caikit -->|ModelRuntime sidecar API<br/>unix socket gRPC| ModelMesh["ModelMesh<br/>Model lifecycle mgmt"]
    Caikit -->|container runtime| KServe["KServe<br/>Model serving platform"]
    Caikit -->|OTLP export<br/>gRPC/4317 or HTTP/4318| OTELCollector["OpenTelemetry Collector<br/>Distributed tracing"]
    Caikit -->|metrics scrape<br/>HTTP/8086| Prometheus["Prometheus<br/>Metrics collection"]
    Caikit -->|S3 API<br/>HTTPS/443| S3["S3-compatible Storage<br/>Model artifacts + training data"]

    %% Downstream consumers (depend on Caikit)
    CaikitNLP["caikit-nlp"] -->|module registration<br/>Python import| Caikit
    CaikitTGIS["caikit-tgis-serving"] -->|module registration<br/>Python import| Caikit

    %% Platform components that integrate
    Dashboard["ODH Dashboard"] -.->|UI management<br/>via KServe| KServe
    Pipelines["Data Science Pipelines"] -.->|model deployment<br/>via KServe| KServe

    %% Remote inference
    Caikit -->|distributed inference<br/>gRPC/HTTP TLS/mTLS| RemoteCaikit["Remote Caikit Runtime"]

    %% Core Python Dependencies (key ones)
    subgraph CoreDeps["Core Python Dependencies"]
        grpcio["grpcio >=1.35,<2.0"]
        protobuf["protobuf >=3.19,<6"]
        aconfig["alchemy-config >=1.1.1"]
        alog["alchemy-logging >=1.3.2"]
        pyToProto["py-to-proto >=0.5.0"]
        numpy["numpy >=1.22.2,<2"]
        fastapi["fastapi >=0.100,<1"]
        pydantic["pydantic >=2.8.0,<3"]
    end

    Caikit -->|core framework| grpcio
    Caikit -->|serialization| protobuf
    Caikit -->|config mgmt| aconfig
    Caikit -->|logging| alog
    Caikit -->|proto generation| pyToProto
    Caikit -->|numeric ops| numpy
    Caikit -->|HTTP server| fastapi
    Caikit -->|validation| pydantic

    %% Optional Dependencies
    subgraph OptionalDeps["Optional Dependencies"]
        otelSDK["opentelemetry-sdk >=1.24"]
        promClient["prometheus_client >=0.12"]
        sseStarlette["sse-starlette >=1.6.1"]
        pillow["pillow >=6.2.1"]
        pandas["pandas >=1.4.3"]
    end

    Caikit -.->|tracing| otelSDK
    Caikit -.->|metrics| promClient
    Caikit -.->|SSE streaming| sseStarlette
    Caikit -.->|vision| pillow
    Caikit -.->|time series| pandas

