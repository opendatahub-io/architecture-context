graph LR
    Caikit["Caikit<br/>AI Toolkit & Runtime Framework"]

    %% Internal RHOAI Dependencies (consume caikit)
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        KServe["KServe<br/>(hosts caikit as model server)"]
        ModelMesh["Model Mesh<br/>(multi-model orchestration)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(auth sidecar in RHOAI)"]
    end

    %% Downstream consumers (depend on caikit as SDK)
    subgraph Downstream["Downstream Module Libraries"]
        CaikitNLP["caikit-nlp<br/>(NLP modules)"]
        CaikitTGIS["caikit-tgis-serving<br/>(TGIS integration)"]
    end

    %% Observability
    subgraph Observability["Observability Stack"]
        OTEL["OpenTelemetry Collector"]
        Prometheus["Prometheus"]
    end

    %% External Services
    subgraph ExternalSvc["External Services"]
        S3["S3-Compatible Storage<br/>(model artifacts + training data)"]
    end

    %% Core Python Dependencies
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        grpcio["grpcio >=1.35,<2.0"]
        protobuf["protobuf >=3.19,<6"]
        alchemyConfig["alchemy-config >=1.1.1"]
        alog["alchemy-logging (alog) >=1.3.2"]
        pyToProto["py-to-proto >=0.5.0"]
        numpy["numpy >=1.22.2,<2"]
        PyYAML["PyYAML >=6.0"]
    end

    %% Optional Python Dependencies
    subgraph OptionalDeps["Optional Python Dependencies"]
        fastapi["fastapi >=0.100 (HTTP runtime)"]
        pydantic["pydantic >=2.8.0 (HTTP validation)"]
        uvicorn["uvicorn (ASGI server)"]
        sseStarlette["sse-starlette (SSE streaming)"]
        otelSDK["opentelemetry-sdk (tracing)"]
        promClient["prometheus_client (metrics)"]
        pillow["pillow (vision interface)"]
        pandas["pandas (time series)"]
    end

    %% Platform integration relationships
    KServe -->|"container runtime<br/>hosts caikit pods"| Caikit
    ModelMesh -->|"gRPC sidecar<br/>Unix socket / 8085"| Caikit
    KubeRBACProxy -->|"auth proxy<br/>Bearer Token"| Caikit

    %% Downstream relationships
    CaikitNLP -->|"Python import<br/>registers modules"| Caikit
    CaikitTGIS -->|"Python import<br/>registers modules"| Caikit

    %% Egress relationships
    Caikit -->|"traces<br/>gRPC/4317 or HTTP/4318"| OTEL
    Caikit -->|"metrics<br/>HTTP/8086 scrape"| Prometheus
    Caikit -->|"model artifacts<br/>HTTPS/443, IAM"| S3

    %% Core dependency relationships
    Caikit -->|"gRPC server"| grpcio
    Caikit -->|"serialization"| protobuf
    Caikit -->|"configuration"| alchemyConfig
    Caikit -->|"logging"| alog
    Caikit -->|"proto generation"| pyToProto
    Caikit -->|"data types"| numpy
    Caikit -->|"config parsing"| PyYAML

    %% Optional dependency relationships
    Caikit -.->|"HTTP server"| fastapi
    Caikit -.->|"request validation"| pydantic
    Caikit -.->|"ASGI server"| uvicorn
    Caikit -.->|"SSE streaming"| sseStarlette
    Caikit -.->|"tracing"| otelSDK
    Caikit -.->|"metrics export"| promClient
    Caikit -.->|"image processing"| pillow
    Caikit -.->|"time series"| pandas

