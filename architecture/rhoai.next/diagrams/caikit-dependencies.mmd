graph LR
    Caikit["Caikit<br/>AI Toolkit & Runtime"]

    %% Internal RHOAI Dependencies
    Caikit -->|"gRPC sidecar API<br/>Unix socket / 8085/TCP"| ModelMesh["Model Mesh"]
    Caikit -->|"model server container<br/>in InferenceService pods"| KServe["KServe"]
    Caikit -->|"trace push<br/>gRPC/4317 or HTTP/4318"| OTEL["OpenTelemetry<br/>Collector"]
    Caikit -->|"metrics scrape<br/>HTTP/8086"| Prometheus["Prometheus"]

    %% Downstream consumers (depend ON caikit)
    CaikitNLP["caikit-nlp"] -->|"Python import<br/>(downstream)"| Caikit
    CaikitTGIS["caikit-tgis-serving"] -->|"Python import<br/>(downstream)"| Caikit

    %% External service dependencies
    Caikit -->|"model/data storage<br/>HTTPS/443, IAM auth"| S3["S3-Compatible<br/>Storage"]
    Caikit -->|"model artifacts<br/>local I/O"| FS["Local Filesystem"]

    %% Platform integration
    KubeRBACProxy["kube-rbac-proxy<br/>(RHOAI sidecar)"] -->|"authn/authz proxy<br/>HTTP/gRPC"| Caikit

    %% Core Python dependencies
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        grpcio["grpcio >=1.35,<2.0"]
        protobuf["protobuf >=3.19,<6"]
        alchemyConfig["alchemy-config >=1.1.1"]
        alog["alchemy-logging >=1.3.2"]
        pyToProto["py-to-proto >=0.5.0"]
        numpy["numpy >=1.22.2,<2"]
        pyyaml["PyYAML >=6.0"]
        werkzeug["werkzeug >=2.3.7"]
        ijson["ijson >=3.1.4"]
        psutil["psutil >=5,<6"]
    end

    Caikit ---|"core deps"| CoreDeps

    subgraph OptionalDeps["Optional Python Dependencies"]
        direction TB
        subgraph RuntimeGRPC["runtime-grpc"]
            grpcHealthChecking["grpcio-health-checking"]
            grpcReflection["grpcio-reflection"]
            promClient["prometheus_client"]
            pyGrpcProm["py-grpc-prometheus"]
        end
        subgraph RuntimeHTTP["runtime-http"]
            fastapi["fastapi >=0.100"]
            pydantic["pydantic >=2.8.0"]
            uvicorn["uvicorn"]
            sseStarlette["sse-starlette"]
        end
        subgraph RuntimeTrace["runtime-trace"]
            otelSdk["opentelemetry-sdk"]
            otelExporter["opentelemetry-exporter-otlp"]
        end
        subgraph InterfacesOpt["interfaces"]
            pillow["pillow (vision)"]
            pandas["pandas (time series)"]
            pyspark["pyspark (time series)"]
        end
    end

    Caikit -.-|"optional deps"| OptionalDeps

    %% Styling
    style Caikit fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style OTEL fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style CaikitTGIS fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style FS fill:#f5a623,stroke:#333,color:#fff
    style CoreDeps fill:#e8f4fd,stroke:#4a90e2,stroke-width:1px
    style OptionalDeps fill:#fef3c7,stroke:#d97706,stroke-width:1px
    style RuntimeGRPC fill:#c7d2fe,stroke:#6366f1,stroke-width:1px
    style RuntimeHTTP fill:#fce7f3,stroke:#db2777,stroke-width:1px
    style RuntimeTrace fill:#d1fae5,stroke:#059669,stroke-width:1px
    style InterfacesOpt fill:#f3e8ff,stroke:#7c3aed,stroke-width:1px
