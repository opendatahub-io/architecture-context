graph LR
    Caikit["Caikit<br/>AI Runtime Framework"]

    %% Internal Platform Dependencies
    Caikit -->|"gRPC sidecar API<br/>Unix socket or 8085/TCP<br/>Model lifecycle mgmt"| ModelMesh["Model Mesh"]
    Caikit -->|"Container runtime<br/>Runs as model server<br/>in InferenceService pods"| KServe["KServe"]
    Caikit -->|"gRPC 4317 or HTTP 4318<br/>Optional TLS/mTLS<br/>Distributed trace export"| OTEL["OpenTelemetry<br/>Collector"]
    Caikit -->|"HTTP 8086 (scraped)<br/>Plaintext<br/>Runtime metrics"| Prometheus["Prometheus"]

    %% Downstream consumers (depend ON caikit)
    CaikitNLP["caikit-nlp"] -->|"Python dependency<br/>NLP module impls"| Caikit
    CaikitTGIS["caikit-tgis-serving"] -->|"Python dependency<br/>TGIS integration"| Caikit

    %% External Service Dependencies
    Caikit -->|"HTTPS 443<br/>TLS, AWS IAM<br/>Model artifacts + training data"| S3["S3-Compatible<br/>Storage"]
    Caikit -->|"gRPC or HTTP<br/>Optional TLS/mTLS<br/>Remote model inference"| RemoteCaikit["Remote Caikit<br/>Servers"]

    %% Platform auth layer
    KubeRBACProxy["kube-rbac-proxy<br/>(RHOAI sidecar)"] -->|"Bearer Token auth<br/>Forwards to caikit"| Caikit

    %% Core Python Dependencies
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        grpcio["grpcio >=1.35,<2.0"]
        protobuf["protobuf >=3.19,<6"]
        alchemyConfig["alchemy-config >=1.1.1"]
        alog["alog >=1.3.2"]
        pyToProto["py-to-proto >=0.5.0"]
        numpy["numpy >=1.22.2"]
        pyyaml["PyYAML >=6.0"]
    end

    subgraph OptionalDeps["Optional Python Dependencies"]
        fastapi["fastapi >=0.100 (HTTP)"]
        pydantic["pydantic >=2.8 (HTTP)"]
        uvicorn["uvicorn (HTTP)"]
        sseStarlette["sse-starlette (streaming)"]
        otelSDK["opentelemetry-sdk (tracing)"]
        prometheusClient["prometheus_client (metrics)"]
        pillow["pillow (vision)"]
        pandas["pandas (time series)"]
    end

    Caikit --> grpcio
    Caikit --> protobuf
    Caikit --> alchemyConfig
    Caikit --> pyToProto
    Caikit --> fastapi

