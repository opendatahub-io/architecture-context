graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["controller-manager<br/>(workbenches-operator-system)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["manager-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB["leader-election-rolebinding<br/>(RoleBinding in operator namespace)"]
    end

    subgraph ClusterRolePerms["ClusterRole: manager-role"]
        CR["manager-role"]
    end

    subgraph NamespacedRolePerms["Role: leader-election-role"]
        LER["leader-election-role<br/>(namespace-scoped)"]
    end

    subgraph ClusterResources["Cluster-Scoped API Resources"]
        Namespaces["core<br/>namespaces<br/><i>create, get, list,<br/>patch, update, watch</i>"]
        Workbenches["components.platform.<br/>opendatahub.io<br/>workbenches<br/><i>get, list, watch</i>"]
        WBFinalizers["components.platform.<br/>opendatahub.io<br/>workbenches/finalizers<br/><i>update</i>"]
        WBStatus["components.platform.<br/>opendatahub.io<br/>workbenches/status<br/><i>get, patch, update</i>"]
        Deployments["apps<br/>deployments<br/><i>get, list, watch</i>"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    subgraph NamespacedResources["Namespace-Scoped API Resources (Leader Election)"]
        ConfigMaps["core<br/>configmaps<br/><i>get, list, watch,<br/>create, update,<br/>patch, delete</i>"]
        Leases["coordination.k8s.io<br/>leases<br/><i>get, list, watch,<br/>create, update,<br/>patch, delete</i>"]
        Events["core<br/>events<br/><i>create, patch</i>"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB
    CRB -->|"grants"| CR
    RB -->|"grants"| LER

    %% ClusterRole permissions
    CR -->|"manages"| Namespaces
    CR -->|"watches"| Workbenches
    CR -->|"updates"| WBFinalizers
    CR -->|"updates status"| WBStatus
    CR -->|"monitors"| Deployments
    CR -->|"auth checks"| SAR

    %% Leader election role permissions
    LER -->|"leader election"| ConfigMaps
    LER -->|"leader election"| Leases
    LER -->|"emits"| Events

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style LER fill:#f5a623,stroke:#333
    style CRB fill:#e8e8e8,stroke:#333
    style RB fill:#e8e8e8,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style Workbenches fill:#7ed321,stroke:#333
    style WBFinalizers fill:#7ed321,stroke:#333
    style WBStatus fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style ConfigMaps fill:#b8d4e3,stroke:#333
    style Leases fill:#b8d4e3,stroke:#333
    style Events fill:#b8d4e3,stroke:#333
