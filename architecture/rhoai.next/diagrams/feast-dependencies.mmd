    classDef internal fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef runtime fill:#f5a623,stroke:#333,stroke-width:1px,color:#000
    classDef platform fill:#50c878,stroke:#333,stroke-width:1px,color:#fff

    class ControllerRuntime,K8sAPI,FastAPI,Gunicorn,PyArrow,Pandas,Protobuf,ReactJS,ElasticUI,OpenShiftAPI required
