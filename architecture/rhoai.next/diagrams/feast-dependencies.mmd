graph LR
    Feast["Feast<br/>Operator + Feature Server"]

    %% External Dependencies (frameworks/libraries)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.18.4"]
    Feast -->|"REST framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"process manager"| Gunicorn["Gunicorn"]
    Feast -->|"ASGI server"| Uvicorn["Uvicorn<br/>>=0.30.6"]
    Feast -->|"JWT parsing"| PyJWT["PyJWT"]

    %% Optional external dependencies
    Feast -.->|"OpenShift APIs"| OpenShiftAPI["OpenShift API<br/>release-4.17"]
    Feast -.->|"metrics scraping"| PrometheusOperator["Prometheus Operator<br/>v0.75.0"]
    Feast -.->|"metrics export"| PrometheusClient["prometheus_client"]

    %% Internal Platform Dependencies
    Feast -->|"deploys operator"| RHODSOperator["rhods-operator /<br/>opendatahub-operator"]
    Feast -->|"notebook integration"| NotebookCRD["kubeflow.org<br/>Notebook CRD"]
    Feast -->|"TLS provisioning"| ServiceServingCerts["OpenShift<br/>service-serving-certs"]
    Feast -->|"CA trust"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% Integration Points - Inbound
    Dashboard["RHOAI / ODH<br/>Dashboard"] -.->|"UI management"| Feast
    MLApp["ML Applications /<br/>Notebooks"] -->|"feature retrieval"| Feast

    %% External Services (data stores)
    Feast -->|"online store<br/>6379/TCP"| Redis["Redis"]
    Feast -->|"online/offline store<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Feast -->|"offline store<br/>443/TCP"| BigQuery["BigQuery"]
    Feast -->|"offline store<br/>443/TCP"| Snowflake["Snowflake"]
    Feast -->|"online store<br/>443/TCP"| DynamoDB["DynamoDB"]
    Feast -->|"registry storage<br/>443/TCP"| S3GCS["S3 / GCS"]
    Feast -->|"auth<br/>443/TCP"| OIDC["OIDC Provider"]
    Feast -->|"API server<br/>6443/TCP"| K8sAPI["Kubernetes API"]

