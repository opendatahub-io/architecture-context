graph LR
    Feast["Feast<br/>(feast-operator +<br/>feature-server)"]

    %% External Dependencies (Required)
    Feast -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.20+"]
    Feast -->|"REST API framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"ASGI server"| Uvicorn["uvicorn<br/>>=0.30.6"]
    Feast -->|"gRPC serving"| gRPC["grpcio<br/>>=1.56.2"]
    Feast -->|"columnar data"| PyArrow["pyarrow<br/>>=21.0.0"]
    Feast -->|"serialization"| Protobuf["protobuf<br/>>=4.24.0"]

    %% External Dependencies (Optional backends)
    Feast -.->|"online store"| Redis["Redis<br/>client >=4.2.2"]
    Feast -.->|"offline/online store"| Psycopg["psycopg<br/>>=3.2.5"]

    %% Internal ODH/RHOAI Dependencies
    ODHOperator["ODH/RHOAI Operator"] -->|"deploys via<br/>Kustomize manifests"| Feast
    Feast -->|"watches Notebooks<br/>auto-creates ConfigMaps"| ODHNotebooks["OpenDataHub Notebooks<br/>(kubeflow.org/Notebook)"]
    Feast -->|"creates<br/>ServiceMonitor"| PrometheusOp["Prometheus Operator<br/>(monitoring.coreos.com)"]
    Feast -->|"TLS cert<br/>provisioning"| OpenShiftCA["OpenShift Service CA"]
    Feast -->|"external access<br/>Routes"| OpenShiftRoutes["OpenShift Routes<br/>(route.openshift.io)"]

    %% Platform infrastructure
    Feast -->|"resource CRUD<br/>RBAC, TokenReview"| K8sAPI["Kubernetes API"]
    Feast -->|"cluster detection<br/>Route mgmt"| OpenShiftAPI["OpenShift API"]

    %% External services
    Feast -.->|"online store<br/>6379/TCP"| RedisServer["Redis Server"]
    Feast -.->|"offline/online/registry<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Feast -.->|"offline/online/registry<br/>443/TCP"| Snowflake["Snowflake"]
    Feast -.->|"registry storage<br/>443/TCP"| S3["S3/GCS"]
    Feast -.->|"token validation<br/>443/TCP"| OIDC["OIDC Provider"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style PyArrow fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff

    %% Optional deps
    style Redis fill:#bbb,stroke:#333,color:#fff
    style Psycopg fill:#bbb,stroke:#333,color:#fff

    %% Internal ODH/RHOAI
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style ODHNotebooks fill:#7ed321,stroke:#333,color:#fff
    style PrometheusOp fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftCA fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftRoutes fill:#7ed321,stroke:#333,color:#fff

    %% Platform infra
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OpenShiftAPI fill:#f5a623,stroke:#333,color:#fff

    %% External services
    style RedisServer fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style Snowflake fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OIDC fill:#f5a623,stroke:#333,color:#fff
