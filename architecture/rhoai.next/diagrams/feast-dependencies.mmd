graph LR
    Feast["Feast<br/>(Operator + Feature Server)"]

    %% External Dependencies (Required)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.18.4"]
    Feast -->|"REST API framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"process manager"| Gunicorn["Gunicorn<br/>+ Uvicorn >=0.30.6"]
    Feast -->|"JWT parsing"| PyJWT["PyJWT"]

    %% External Dependencies (Optional)
    Feast -.->|"Route & cert support"| OpenShiftAPI["OpenShift API<br/>release-4.17"]
    Feast -.->|"metrics scraping"| PrometheusOp["prometheus-operator<br/>v0.75.0"]
    Feast -.->|"metrics export"| PromClient["prometheus_client"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize"| Feast
    Feast -->|"watch Notebooks,<br/>inject feast config"| NotebookCRD["kubeflow.org<br/>Notebook CRD"]
    Feast -->|"auto TLS certs"| ServiceCerts["OpenShift<br/>service-serving-certs"]
    Feast -->|"CA trust bundle"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% External Services - Data Stores
    Feast -->|"online store<br/>TCP/6379, TLS"| Redis["Redis"]
    Feast -->|"online/offline/registry<br/>TCP/5432, TLS verify-full"| PostgreSQL["PostgreSQL"]
    Feast -->|"offline store<br/>HTTPS/443"| BigQuery["BigQuery"]
    Feast -->|"online/offline/registry<br/>HTTPS/443"| Snowflake["Snowflake"]
    Feast -->|"online store<br/>HTTPS/443"| DynamoDB["DynamoDB"]
    Feast -->|"registry persistence<br/>HTTPS/443"| S3GCS["S3 / GCS"]

    %% External Services - Auth & API
    Feast -->|"token validation,<br/>JWKS, HTTPS/443"| OIDC["OIDC Provider"]
    Feast -->|"CRD reconciliation,<br/>TokenReview, HTTPS/6443"| K8sAPI["Kubernetes API<br/>Server"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Gunicorn fill:#999,stroke:#333,color:#fff
    style PyJWT fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style OpenShiftAPI fill:#bbb,stroke:#333,color:#fff
    style PrometheusOp fill:#bbb,stroke:#333,color:#fff
    style PromClient fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style NotebookCRD fill:#7ed321,stroke:#333,color:#fff
    style ServiceCerts fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style Redis fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style BigQuery fill:#f5a623,stroke:#333
    style Snowflake fill:#f5a623,stroke:#333
    style DynamoDB fill:#f5a623,stroke:#333
    style S3GCS fill:#f5a623,stroke:#333
    style OIDC fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
