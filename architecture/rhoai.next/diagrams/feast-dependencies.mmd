graph LR
    Feast["Feast Feature Store<br/>(Operator + Servers + UI)"]

    %% External Dependencies (Required)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    Feast -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.33.1"]
    Feast -->|"REST API"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"HTTP server"| Gunicorn["Gunicorn<br/>latest"]
    Feast -->|"data processing"| PyArrow["PyArrow<br/>>=21.0.0"]
    Feast -->|"data manipulation"| Pandas["Pandas<br/>>=1.4.3"]
    Feast -->|"serialization"| Protobuf["Protobuf<br/>>=4.24.0"]
    Feast -->|"UI framework"| ReactJS["React<br/>^18"]
    Feast -->|"UI components"| ElasticUI["Elastic UI<br/>^95.12.0"]

    %% External Dependencies (Optional)
    Feast -->|"Route API"| OpenShiftAPI["openshift/api<br/>release-4.17"]
    Feast -.->|"metrics CRD"| PrometheusOp["prometheus-operator<br/>v0.83.0"]
    Feast -.->|"gRPC serving"| gRPC["gRPC<br/>>=1.56.2"]
    Feast -.->|"Go online store"| GoRedis["go-redis<br/>v9"]

    %% Internal Platform Dependencies
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>Kustomize"| Feast
    Feast -->|"watches Notebooks,<br/>creates ConfigMaps"| KFNotebooks["Kubeflow Notebooks<br/>(kubeflow.org/v1)"]
    Feast -->|"creates Routes"| OSRouteAPI["OpenShift Route API<br/>(route.openshift.io/v1)"]
    Feast -->|"creates ServiceMonitors"| PromOperator["Prometheus Operator<br/>(monitoring.coreos.com/v1)"]
    Feast -->|"TLS cert injection"| OSServiceCA["OpenShift Service CA<br/>(annotation-based)"]
    Feast -->|"OIDC_ISSUER_URL<br/>env var injection"| PlatformOIDC["Platform OIDC<br/>(GatewayConfig)"]

    %% External Services (Runtime)
    Feast -->|"store persistence<br/>TCP/5432"| PostgreSQL["PostgreSQL"]
    Feast -->|"online store<br/>TCP/6379"| Redis["Redis"]
    Feast -.->|"offline/online store<br/>HTTPS/443"| Snowflake["Snowflake"]
    Feast -.->|"online store<br/>HTTPS/443"| DynamoDB["AWS DynamoDB"]
    Feast -.->|"offline store<br/>HTTPS/443"| BigQuery["GCP BigQuery"]
    Feast -.->|"token validation<br/>HTTPS/443"| OIDC["OIDC Provider"]
    Feast -.->|"data lineage"| OpenLineage["OpenLineage<br/>Collector"]
    Feast -.->|"tracing"| OTELCollector["OTEL Collector"]

