    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Elasticsearch fill:#f5a623,stroke:#333,color:#fff
    style Milvus fill:#f5a623,stroke:#333,color:#fff
    style MongoDB fill:#f5a623,stroke:#333,color:#fff
