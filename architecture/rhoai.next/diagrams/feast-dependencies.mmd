graph LR
    Feast["Feast<br/>(Operator + Feature Server)"]

    %% External Dependencies (Required)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    Feast -->|"resource mgmt<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v0.33.0"]
    Feast -->|"REST framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"ASGI server"| Uvicorn["Uvicorn<br/>>=0.30.6"]
    Feast -->|"production server"| Gunicorn["Gunicorn"]
    Feast -->|"JWT validation"| PyJWT["PyJWT"]

    %% External Dependencies (Optional)
    Feast -.->|"Routes, certs<br/>6443/TCP HTTPS"| OpenShiftAPI["OpenShift API<br/>release-4.17"]
    Feast -.->|"ServiceMonitor CRD"| PromOperator["Prometheus Operator<br/>v0.75.0"]
    Feast -.->|"metrics"| PromClient["prometheus_client"]

    %% Internal Platform Dependencies
    Feast -->|"kustomize deployment"| PlatformOperator["ODH / RHOAI Operator"]
    Feast -.->|"ConfigMap injection<br/>for labeled Notebooks"| KubeflowNotebooks["Kubeflow Notebook<br/>Controller"]
    Feast -.->|"service-serving TLS"| ServiceServingCerts["OpenShift<br/>Service-Serving Certs"]
    Feast -.->|"CA bundle"| TrustedCA["OpenShift<br/>Trusted CA Bundle"]
    Feast -.->|"token validation<br/>443/TCP HTTPS"| PlatformOIDC["Platform OIDC<br/>Provider"]

    %% Online Store Backends
    Feast -->|"online store<br/>6379/TCP"| Redis["Redis"]
    Feast -->|"online/offline/registry<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Feast -.->|"online store<br/>443/TCP HTTPS"| DynamoDB["DynamoDB"]
    Feast -.->|"online store<br/>9200/TCP HTTPS"| Elasticsearch["Elasticsearch"]
    Feast -.->|"online store<br/>19530/TCP gRPC"| Milvus["Milvus"]
    Feast -.->|"online store<br/>27017/TCP"| MongoDB["MongoDB"]
    Feast -.->|"online store<br/>9042/TCP"| Cassandra["Cassandra"]
    Feast -.->|"online store<br/>3306/TCP"| MySQL["MySQL"]

    %% Offline Store Backends
    Feast -.->|"offline store<br/>443/TCP HTTPS"| BigQuery["BigQuery"]
    Feast -.->|"online/offline/registry<br/>443/TCP HTTPS"| Snowflake["Snowflake"]

    %% Registry Storage
    Feast -.->|"registry storage<br/>443/TCP HTTPS"| S3["S3"]
    Feast -.->|"registry storage<br/>443/TCP HTTPS"| GCS["GCS"]

    %% Data Lineage
    Feast -.->|"lineage events<br/>HTTP/HTTPS"| OpenLineage["OpenLineage /<br/>Marquez"]

    %% UI Dependencies
    Feast -->|"UI framework"| React["React<br/>^18.3.1"]
    Feast -->|"UI components"| ElasticUI["Elastic UI<br/>^95.12.0"]

    %% Styling - Core component
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style Gunicorn fill:#999,stroke:#333,color:#fff
    style PyJWT fill:#999,stroke:#333,color:#fff
    style React fill:#999,stroke:#333,color:#fff
    style ElasticUI fill:#999,stroke:#333,color:#fff

    %% Optional external
    style OpenShiftAPI fill:#bbb,stroke:#333,color:#fff
    style PromOperator fill:#bbb,stroke:#333,color:#fff
    style PromClient fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style PlatformOperator fill:#7ed321,stroke:#333,color:#fff
    style KubeflowNotebooks fill:#7ed321,stroke:#333,color:#fff
    style ServiceServingCerts fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style PlatformOIDC fill:#7ed321,stroke:#333,color:#fff

    %% Store backends
    style Redis fill:#f5a623,stroke:#333,color:#fff
