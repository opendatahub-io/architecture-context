graph LR
    Feast["Feast Feature Store<br/>(Operator + Feature Server + UI)"]

    %% External Dependencies (Required)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    Feast -->|"resource mgmt<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v0.33.0"]
    Feast -->|"REST framework<br/>6566/TCP"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"ASGI server"| Uvicorn["Uvicorn<br/>>=0.30.6"]
    Feast -->|"production server"| Gunicorn["Gunicorn"]
    Feast -->|"JWT validation"| PyJWT["PyJWT"]
    Feast -->|"UI framework<br/>3000/TCP"| ReactLib["React<br/>^18.3.1"]
    Feast -->|"UI components"| ElasticUI["Elastic UI<br/>^95.12.0"]

    %% External Dependencies (Optional)
    Feast -.->|"Routes, certs<br/>6443/TCP HTTPS"| OpenShiftAPI["OpenShift API<br/>release-4.17"]
    Feast -.->|"ServiceMonitor CRD"| PrometheusOp["prometheus-operator<br/>v0.75.0"]
    Feast -.->|"metrics collection"| PromClient["prometheus_client"]

    %% Internal Platform Dependencies
    ODHOperator["opendatahub-operator /<br/>rhods-operator"] -->|"deploys via kustomize"| Feast
    Feast -->|"ConfigMap injection<br/>6443/TCP"| KubeflowNotebooks["Kubeflow Notebook<br/>Controller"]
    Feast -.->|"TLS certs"| ServiceServingCerts["OpenShift<br/>service-serving-certs"]
    Feast -.->|"CA bundle"| TrustedCA["OpenShift<br/>trusted CA bundle"]
    Feast -.->|"token validation<br/>443/TCP HTTPS"| OIDCProvider["Platform OIDC<br/>Provider"]
    PlatformGW["Platform<br/>GatewayConfig"] -.->|"OIDC_ISSUER_URL"| Feast

    %% Online Store Backends
    Feast -->|"online store<br/>6379/TCP"| Redis["Redis"]
    Feast -->|"online/offline<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Feast -->|"online store<br/>443/TCP HTTPS"| DynamoDB["DynamoDB"]
    Feast -->|"online store<br/>443/TCP HTTPS"| Snowflake["Snowflake"]
    Feast -->|"vector search<br/>9200/TCP"| Elasticsearch["Elasticsearch"]
    Feast -->|"vector search<br/>19530/TCP gRPC"| Milvus["Milvus"]
    Feast -->|"online store<br/>27017/TCP"| MongoDB["MongoDB"]
    Feast -->|"online store<br/>9042/TCP"| Cassandra["Cassandra"]
    Feast -->|"online store<br/>3306/TCP"| MySQL["MySQL"]

    %% Offline Store Backends
    Feast -->|"offline store<br/>443/TCP HTTPS"| BigQuery["BigQuery"]

    %% Registry Backends
    Feast -->|"registry storage<br/>443/TCP HTTPS"| S3["S3 Storage"]
    Feast -->|"registry storage<br/>443/TCP HTTPS"| GCS["GCS"]

    %% Integration Points
    Feast -.->|"data lineage"| OpenLineage["OpenLineage /<br/>Marquez"]

