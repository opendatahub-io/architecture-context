graph LR
    Feast["Feast<br/>(Operator + Feature Server)"]

    %% External Framework Dependencies
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.21.0"]
    Feast -->|"REST framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"ASGI server"| Uvicorn["Uvicorn<br/>>=0.30.6"]
    Feast -->|"WSGI server"| Gunicorn["Gunicorn"]
    Feast -->|"UI framework"| React["React<br/>^18.3.1"]
    Feast -->|"UI components"| ElasticUI["Elastic UI<br/>^95.12.0"]

    %% Platform Dependencies
    Feast -->|"resource mgmt<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v0.33.0"]
    Feast -->|"routes, certs<br/>6443/TCP HTTPS"| OpenShiftAPI["OpenShift API<br/>release-4.17"]
    Feast -->|"metrics scraping"| PrometheusOp["prometheus-operator<br/>v0.75.0"]
    Feast -->|"JWT validation<br/>443/TCP HTTPS"| OIDC["Platform OIDC<br/>Provider"]

    %% Internal ODH Dependencies
    ODHOperator["opendatahub-operator /<br/>rhods-operator"] -->|"deploys via<br/>kustomize"| Feast
    Feast -.->|"CRD Watch<br/>ConfigMap injection"| KubeflowNotebooks["Kubeflow Notebook<br/>Controller"]
    Feast -.->|"annotation-based<br/>TLS provisioning"| ServiceServingCerts["OpenShift<br/>service-serving-certs"]
    Feast -.->|"CA bundle<br/>injection"| TrustedCA["OpenShift<br/>trusted CA bundle"]

    %% Online Store Backends
    Feast -->|"online store<br/>6379/TCP"| Redis["Redis"]
    Feast -->|"online/offline<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Feast -->|"online store<br/>3306/TCP"| MySQL["MySQL"]
    Feast -->|"online store<br/>443/TCP HTTPS"| DynamoDB["DynamoDB"]
    Feast -->|"online store<br/>443/TCP HTTPS"| Snowflake["Snowflake"]
    Feast -->|"online store<br/>27017/TCP"| MongoDB["MongoDB"]
    Feast -->|"online store<br/>9042/TCP"| Cassandra["Cassandra"]

    %% Offline Store Backends
    Feast -->|"offline store<br/>443/TCP HTTPS"| BigQuery["BigQuery"]

    %% Vector Search Backends
    Feast -->|"vector search<br/>9200/TCP HTTPS"| Elasticsearch["Elasticsearch"]
    Feast -->|"vector search<br/>19530/TCP gRPC"| Milvus["Milvus"]

    %% Registry Storage
    Feast -->|"registry storage<br/>443/TCP HTTPS"| S3["S3 Storage"]
    Feast -->|"registry storage<br/>443/TCP HTTPS"| GCS["GCS Storage"]

    %% Lineage
    Feast -.->|"lineage events<br/>HTTP/HTTPS"| OpenLineage["OpenLineage /<br/>Marquez"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

