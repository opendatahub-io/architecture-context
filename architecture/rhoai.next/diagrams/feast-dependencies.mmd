graph LR
    Feast["Feast<br/>(feast-operator +<br/>feature-server)"]

    %% External Dependencies (Required)
    Feast -->|"CRD watch, resource mgmt<br/>HTTPS/6443"| K8sAPI["Kubernetes 1.27+"]
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime v0.19+"]

    %% External Dependencies (Optional)
    Feast -->|"service-serving certs,<br/>Routes"| OpenShift["OpenShift 4.14+"]
    Feast -->|"ServiceMonitor<br/>metrics collection"| PrometheusOp["Prometheus Operator"]

    %% Online Store Backends
    Feast -->|"online features<br/>TCP/6379"| Redis["Redis 4.x-7.x"]
    Feast -->|"online/offline + registry<br/>TCP/5432"| PostgreSQL["PostgreSQL 12+"]
    Feast -->|"online + registry<br/>TCP/3306"| MySQL["MySQL 5.7+"]
    Feast -->|"online features<br/>HTTPS/443"| DynamoDB["AWS DynamoDB"]

    %% Offline Store Backends
    Feast -->|"offline features<br/>HTTPS/443"| BigQuery["Google BigQuery"]
    Feast -->|"online/offline + registry<br/>HTTPS/443"| Snowflake["Snowflake"]

    %% Registry Storage Backends
    Feast -->|"registry storage<br/>HTTPS/443"| S3["AWS S3"]
    Feast -->|"registry storage<br/>HTTPS/443"| GCS["Google Cloud Storage"]

    %% Auth
    Feast -->|"token validation<br/>JWKS, HTTPS/443"| OIDC["OIDC Provider"]

    %% Observability
    Feast -.->|"data lineage events<br/>HTTP/Kafka"| OpenLineage["OpenLineage Collector"]

    %% Internal ODH/RHOAI Dependencies
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| Feast
    Feast -.->|"notebook integration<br/>ConfigMap injection"| Notebooks["ODH Dashboard /<br/>Kubeflow Notebooks"]
    Feast -.->|"OIDC_ISSUER_URL<br/>env injection"| PlatformOIDC["Platform OIDC<br/>(GatewayConfig)"]
    Feast -.->|"CRD watch<br/>kubeflow.org/v1"| KubeflowCRD["Kubeflow Notebook CRD"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external (dark gray)
    style K8sAPI fill:#666,stroke:#333,color:#fff
    style ControllerRuntime fill:#666,stroke:#333,color:#fff

    %% Optional external (light gray)
    style OpenShift fill:#999,stroke:#333,color:#fff
    style PrometheusOp fill:#999,stroke:#333,color:#fff

    %% Data stores (orange)
    style Redis fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style DynamoDB fill:#f5a623,stroke:#333,color:#fff
    style BigQuery fill:#f5a623,stroke:#333,color:#fff
    style Snowflake fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff

    %% Security (purple)
    style OIDC fill:#9b59b6,stroke:#333,color:#fff

    %% Observability (teal)
    style OpenLineage fill:#1abc9c,stroke:#333,color:#fff

    %% Internal platform (green)
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style Notebooks fill:#7ed321,stroke:#333,color:#fff
    style PlatformOIDC fill:#7ed321,stroke:#333,color:#fff
    style KubeflowCRD fill:#7ed321,stroke:#333,color:#fff
