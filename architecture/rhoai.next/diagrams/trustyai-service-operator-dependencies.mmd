graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"controller framework<br/>v0.17.0"| ControllerRuntime["controller-runtime<br/>v0.17.0"]

    %% External Dependencies (Optional)
    TrustyAI -->|"model serving<br/>CRD Watch + Patch"| KServe["KServe<br/>v0.12.1"]
    TrustyAI -->|"job scheduling<br/>CRD Create + Watch"| Kueue["Kueue<br/>v0.6.2"]
    TrustyAI -->|"metrics collection<br/>ServiceMonitor CRD"| PrometheusOp["Prometheus Operator<br/>v0.64.1"]
    TrustyAI -->|"external access<br/>Route CRD"| OpenShiftAPI["OpenShift API<br/>(Route)"]
    TrustyAI -->|"traffic mgmt<br/>(conditional)"| Istio["Istio / Service Mesh"]

    %% Internal Platform Dependencies
    TrustyAI -->|"InferenceService<br/>payload injection"| KServeModelMesh["KServe / ModelMesh<br/>CRD Watch + Patch"]
    TrustyAI -->|"TLS cert provisioning<br/>annotation-based"| ServiceCA["OpenShift Service CA"]
    TrustyAI -->|"custom CA trust<br/>ConfigMap read"| ODHCA["ODH Trusted CA Bundle"]
    TrustyAI -->|"experiment tracking<br/>REST API"| MLFlow["MLFlow (Kubeflow)"]
    TrustyAI -->|"operator deployment<br/>image config"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]

    %% Integration Points (other components that use TrustyAI)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    DSPipelines["Data Science<br/>Pipelines"] -.->|"evaluation<br/>integration"| TrustyAI

    %% External Services
    TrustyAI -->|"model/dataset<br/>download"| S3["S3 Storage<br/>443/TCP HTTPS"]
    TrustyAI -->|"result upload"| OCI["OCI Registry<br/>443/TCP HTTPS"]
    TrustyAI -->|"model download<br/>(if allowOnline)"| HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
    TrustyAI -->|"trace/metrics<br/>export"| OTEL["OpenTelemetry<br/>Collector"]
    TrustyAI -->|"custom tasks<br/>clone"| Git["Git Repositories<br/>443/TCP HTTPS"]
    TrustyAI -->|"CRD reconciliation<br/>resource mgmt"| K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]

