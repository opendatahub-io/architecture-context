graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.5"]

    %% External Dependencies (Optional)
    TrustyAI -->|"InferenceService CRD<br/>payload logging, auto-config"| KServe["KServe<br/>v0.18.0"]
    TrustyAI -->|"workload scheduling"| Kueue["Kueue<br/>v0.16.0-devel"]
    TrustyAI -->|"ServiceMonitor CRD"| PrometheusOp["prometheus-operator<br/>v0.64.1"]
    TrustyAI -->|"Route CRD"| OpenShiftAPI["openshift/api<br/>v0.0.0-20250602"]
    TrustyAI -->|"serverless support<br/>(transitive via KServe)"| Knative["Knative Serving<br/>v0.48.1"]
    TrustyAI -->|"Gateway types<br/>(transitive via KServe)"| GatewayAPI["gateway-api<br/>v1.4.2"]

    %% Internal Platform Dependencies
    TrustyAI -->|"DSCInitialization<br/>config overrides"| ODHOperator["rhods-operator /<br/>opendatahub-operator"]
    TrustyAI -->|"Deployment patching<br/>MM_PAYLOAD_PROCESSORS"| ModelMesh["ModelMesh Serving"]
    TrustyAI -->|"DestinationRule, VirtualService,<br/>EnvoyFilter CRDs"| Istio["Istio /<br/>Service Mesh"]
    TrustyAI -->|"serving certs<br/>(annotation-based)"| CertManager["cert-manager /<br/>OpenShift service CA"]
    TrustyAI -->|"cluster CA bundle"| CABundle["odh-trusted-ca-bundle"]
    TrustyAI -->|"MCP gateway discovery<br/>for EnvoyFilter targeting"| MCPGateway["MCPGatewayExtension<br/>(Kuadrant)"]
    TrustyAI -->|"resource configuration"| HWProfiles["HardwareProfiles"]
    TrustyAI -->|"workspace access<br/>RoleBindings"| MLflow["MLflow"]

    %% Integration Points (components that depend on TrustyAI)
    Dashboard["ODH Dashboard"] -->|"UI management"| TrustyAI
    DSPipelines["Data Science<br/>Pipelines"] -.->|"evaluation integration"| TrustyAI

    %% External Services
    TrustyAI -->|"persistent storage<br/>Conditional TLS"| PostgreSQL["PostgreSQL"]
    TrustyAI -->|"model/dataset storage<br/>HTTPS/443"| S3["S3 Storage"]
    TrustyAI -->|"result upload<br/>HTTPS/443"| OCI["OCI Registries"]
    TrustyAI -->|"telemetry export<br/>gRPC/HTTP"| OTLP["OTLP Collector"]
    TrustyAI -->|"custom tasks<br/>HTTPS/443"| Git["Git Repos"]
    TrustyAI -->|"CRD reconciliation<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

