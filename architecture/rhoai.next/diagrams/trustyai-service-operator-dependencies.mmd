graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"controller framework<br/>v0.17.0"| ControllerRuntime["controller-runtime<br/>v0.17.0"]
    TrustyAI -->|"ISVC/ServingRuntime CRDs<br/>(TAS, GORCH)"| KServe["KServe<br/>v0.12.1"]
    TrustyAI -->|"Route CRD<br/>ingress"| OpenShiftAPI["OpenShift API<br/>Route CRD"]
    TrustyAI -->|"ServiceMonitor CRD<br/>metrics scraping"| PrometheusOp["Prometheus Operator<br/>v0.64.1"]

    %% External Dependencies (Optional)
    TrustyAI -.->|"job scheduling<br/>(optional)"| Kueue["Kueue<br/>v0.6.2"]
    TrustyAI -.->|"transitive via KServe<br/>(indirect)"| Knative["Knative Serving<br/>v0.39.3"]

    %% Internal Platform Dependencies
    TrustyAI -->|"patch ModelMesh/Serverless<br/>auto-discover models"| KServeISVC["KServe<br/>InferenceService"]
    TrustyAI -.->|"DestinationRule<br/>VirtualService<br/>(conditional)"| Istio["Istio<br/>Service Mesh"]
    TrustyAI -->|"Bearer Token auth<br/>FIPS 140-2 TLS"| KubeRbacProxy["kube-rbac-proxy<br/>Sidecar"]
    TrustyAI -->|"auto TLS certs<br/>via annotations"| ServiceCA["OpenShift<br/>Service CA"]

    %% Integration Points - Components that depend on TrustyAI
    Dashboard["RHOAI Dashboard"] -.->|"UI management"| TrustyAI
    DSC["DataScienceCluster"] -->|"config overrides<br/>AllowOnline, AllowCodeExec"| TrustyAI

    %% External Services
    TrustyAI -->|"dataset download<br/>HTTPS/443 AWS IAM"| S3["S3-Compatible<br/>Storage"]
    TrustyAI -->|"result upload<br/>HTTPS/443"| OCI["OCI Registry"]
    TrustyAI -.->|"model download<br/>online mode only"| HFHub["HuggingFace Hub"]
    TrustyAI -->|"persistent storage<br/>TCP/TLS"| Database["Database<br/>MariaDB/PostgreSQL"]
    TrustyAI -.->|"telemetry export<br/>gRPC/HTTP"| OTEL["OTEL Collector"]
    TrustyAI -->|"experiment tracking<br/>HTTPS SA Token"| MLflow["MLflow<br/>Tracking Server"]
    TrustyAI -->|"CRD operations<br/>HTTPS/443 SA Token"| K8sAPI["Kubernetes<br/>API Server"]

