graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"operator framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.17.0"]

    %% External Dependencies (Optional)
    TrustyAI -->|"model serving<br/>integration"| KServe["KServe<br/>v0.12.1"]
    TrustyAI -->|"workload admission<br/>& quotas"| Kueue["Kueue<br/>v0.6.2"]
    TrustyAI -->|"metrics scraping"| PrometheusOp["prometheus-operator<br/>v0.64.1"]
    TrustyAI -->|"routes & serving<br/>certs"| OpenShiftAPI["OpenShift API"]
    TrustyAI -->|"autoscaling<br/>(transitive)"| Knative["Knative Serving<br/>v0.39.3"]

    %% Internal Platform Dependencies
    TrustyAI -->|"DSC config &<br/>permission overrides"| RHOAIOp["rhods-operator /<br/>opendatahub-operator"]
    TrustyAI -->|"payload processing<br/>& auto-config"| KServeIS["KServe<br/>InferenceService"]
    TrustyAI -->|"container port<br/>extraction"| KServeSR["KServe<br/>ServingRuntime"]
    TrustyAI -->|"mTLS traffic<br/>policy"| Istio["Istio Service Mesh"]
    TrustyAI -->|"external access<br/>routes"| OSRouter["OpenShift Router"]
    TrustyAI -->|"metrics collection"| Prometheus["Prometheus"]

    %% External Services
    TrustyAI -->|"database storage<br/>TCP/TLS"| PostgreSQL["PostgreSQL"]
    TrustyAI -->|"offline assets<br/>HTTPS/443"| S3["S3 Storage"]
    TrustyAI -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    TrustyAI -->|"result upload<br/>HTTPS/443"| OCI["OCI Registry"]
    TrustyAI -->|"telemetry export<br/>gRPC/HTTP"| OTLP["OTLP Collector"]

    %% Integration Points (components that depend on TrustyAI)
    TrustedCABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -.->|"CA certs"| TrustyAI
    DSCConfig["trustyai-dsc-config<br/>ConfigMap"] -.->|"permission overrides"| TrustyAI
    OSCertCtrl["OpenShift Serving<br/>Cert Controller"] -.->|"auto TLS certs"| TrustyAI

    %% Auth
    KubeRBACProxy["kube-rbac-proxy<br/>4.19"] -.->|"auth sidecar"| TrustyAI

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ControllerRuntime fill:#333,stroke:#333,color:#fff

    %% Optional external
    style KServe fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff
    style PrometheusOp fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style RHOAIOp fill:#7ed321,stroke:#333,color:#333
    style KServeIS fill:#7ed321,stroke:#333,color:#333
    style KServeSR fill:#7ed321,stroke:#333,color:#333
    style Istio fill:#7ed321,stroke:#333,color:#333
    style OSRouter fill:#7ed321,stroke:#333,color:#333
    style Prometheus fill:#7ed321,stroke:#333,color:#333

    %% External Services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#333
    style S3 fill:#f5a623,stroke:#333,color:#333
    style HFHub fill:#f5a623,stroke:#333,color:#333
    style OCI fill:#f5a623,stroke:#333,color:#333
    style OTLP fill:#f5a623,stroke:#333,color:#333

    %% Config/Infra
