graph LR
    TAO["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TAO -->|"controller framework<br/>(required)"| CR["controller-runtime<br/>v0.17.0"]

    %% External Dependencies (Optional)
    TAO -->|"InferenceService API<br/>(TAS, GORCH)"| KServe["KServe<br/>v0.12.1"]
    TAO -->|"workload scheduling<br/>(JOB_MGR)"| Kueue["Kueue<br/>v0.6.2"]
    TAO -->|"ServiceMonitor CRD"| PromOp["Prometheus Operator<br/>v0.64.1"]
    TAO -->|"Route CRD<br/>(external access)"| OSRoute["OpenShift API<br/>(Route)"]
    TAO -->|"DestinationRule /<br/>VirtualService<br/>(conditional)"| Istio["Istio /<br/>Service Mesh"]

    %% Internal Platform Dependencies
    TAO -->|"CRD Watch + Patch<br/>(payload processors)"| KServeMM["KServe /<br/>ModelMesh"]
    TAO -->|"CRD Watch + Create<br/>(Workloads)"| KueueInt["Kueue<br/>(Workloads)"]
    TAO -->|"TLS cert provisioning<br/>(annotation)"| OSCA["OpenShift<br/>Service CA"]
    TAO -->|"custom CA trust"| ODHCA["ODH Trusted<br/>CA Bundle"]
    TAO -->|"experiment tracking<br/>(REST API)"| MLFlow["MLFlow<br/>(Kubeflow)"]

    %% Integration Points - other components integrating with this
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys + configures"| TAO
    DSC["DSC Config"] -.->|"AllowOnline /<br/>AllowCodeExecution"| TAO

    %% External Services (Egress)
    TAO -->|"offline assets<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    TAO -->|"result upload<br/>HTTPS/443"| OCI["OCI Container<br/>Registry"]
    TAO -->|"model/dataset download<br/>HTTPS/443"| HF["Hugging Face<br/>Hub"]
    TAO -->|"traces + metrics<br/>gRPC/HTTP"| OTel["OpenTelemetry<br/>Collector"]
    TAO -->|"persistent storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    TAO -->|"custom tasks<br/>HTTPS/443"| Git["Git<br/>Repositories"]
    TAO -->|"CRD mgmt<br/>HTTPS/6443"| K8sAPI["Kubernetes<br/>API Server"]

