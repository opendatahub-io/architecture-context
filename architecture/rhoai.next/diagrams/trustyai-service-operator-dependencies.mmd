graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"operator framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.17.0"]

    %% External Dependencies (Optional)
    TrustyAI -->|"InferenceService CRD<br/>payload injection"| KServe["KServe<br/>v0.12.1"]
    TrustyAI -->|"workload admission<br/>resource quotas"| Kueue["Kueue<br/>v0.6.2"]
    TrustyAI -->|"ServiceMonitor CRD<br/>metrics scraping"| PrometheusOp["prometheus-operator<br/>v0.64.1"]
    TrustyAI -->|"Routes, serving certs<br/>cert injection"| OpenShiftAPI["OpenShift API"]
    TrustyAI -.->|"transitive via KServe"| Knative["Knative Serving<br/>v0.39.3"]

    %% Internal Platform Dependencies
    TrustyAI -->|"DSC config, CA bundle<br/>ConfigMap read"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    TrustyAI -->|"payload processing<br/>CRD Watch + Patch"| KServeIS["KServe<br/>InferenceService"]
    TrustyAI -->|"auto-config discovery<br/>CRD List + Read"| KServeRT["KServe<br/>ServingRuntime"]
    TrustyAI -->|"mTLS DestinationRule<br/>HTTP→HTTPS VirtualService"| Istio["Istio<br/>Service Mesh"]
    TrustyAI -->|"external access<br/>Route Create"| OSRouter["OpenShift<br/>Router"]
    TrustyAI -->|"metrics scraping<br/>ServiceMonitor Create"| Prometheus["Prometheus"]

    %% Integration Points (other components → TrustyAI)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    Pipelines["Data Science<br/>Pipelines"] -.->|"model evaluation"| TrustyAI

    %% External Services
    TrustyAI -->|"TAS + EvalHub storage<br/>TCP TLS(opt)"| PostgreSQL["PostgreSQL"]
    TrustyAI -->|"LMES asset download<br/>HTTPS/443 AWS IAM"| S3["S3 Storage"]
    TrustyAI -->|"LMES result upload<br/>HTTPS/443"| OCI["OCI Registry"]
    TrustyAI -->|"LMES model download<br/>HTTPS/443 API Token"| HFHub["Hugging Face Hub"]
    TrustyAI -->|"GORCH + EvalHub telemetry<br/>gRPC/HTTP"| OTLP["OTLP Collector"]

