graph TD
    subgraph Operator["TrustyAI Service Operator (provisions RBAC)"]
        OpNote["Roles and bindings are created<br/>by the operator, not by EvalHub"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub ServiceAccount<br/>(operator-provisioned)"]
        SA_Sidecar["eval-job ServiceAccount<br/>(per-job, operator-provisioned)"]
    end

    subgraph ClusterRoleBindings["Role Bindings (operator-managed)"]
        CRB1["eval-hub-role-binding"]
        CRB2["eval-job-role-binding"]
    end

    subgraph Roles["Roles / ClusterRoles"]
        CR_Main["eval-hub-role<br/>(operator-provisioned)"]
        CR_Job["eval-job-role<br/>(operator-provisioned)"]
    end

    subgraph APIResources["API Resources"]
        subgraph BatchAPI["batch API Group"]
            Jobs["batch/jobs"]
        end

        subgraph CoreAPI["core API Group"]
            ConfigMaps["core/configmaps"]
            Secrets["core/secrets"]
        end

        subgraph InfraAPI["infrastructure.opendatahub.io"]
            HWProfiles["hardwareprofiles"]
        end
    end

    subgraph AuthEnforcement["Authentication Enforcement"]
        RBAC_Proxy["kube-rbac-proxy<br/>(sidecar container)"]
        SAR["SubjectAccessReview<br/>(K8s API)"]
    end

    subgraph InboundAuth["Inbound Authentication"]
        BearerToken["Bearer Token<br/>(Kubernetes SA token)"]
        Headers["Injected Headers:<br/>X-Tenant, X-User"]
    end

    %% Operator provisions everything
    Operator -->|provisions| SA_EvalHub
    Operator -->|provisions| SA_Sidecar
    Operator -->|provisions| CR_Main
    Operator -->|provisions| CR_Job
    Operator -->|provisions| CRB1
    Operator -->|provisions| CRB2

    %% Bindings
    SA_EvalHub -->|bound via| CRB1
    SA_Sidecar -->|bound via| CRB2
    CRB1 -->|grants| CR_Main
    CRB2 -->|grants| CR_Job

    %% Permissions
    CR_Main -->|"create, delete,<br/>list, get, watch"| Jobs
    CR_Main -->|"create, delete,<br/>list, get, watch"| ConfigMaps
    CR_Main -->|"create, delete,<br/>list, get, watch"| Secrets
    CR_Main -->|"get, list"| HWProfiles

    CR_Job -->|"get, list"| ConfigMaps
    CR_Job -->|"get, list"| Secrets

    %% Auth flow
    BearerToken -->|validated by| RBAC_Proxy
    RBAC_Proxy -->|performs| SAR
    SAR -->|on success| Headers
    Headers -->|forwarded to| EvalHubAPI["eval-hub API<br/>(8080/TCP)"]

    %% Secret Types
    subgraph SecretTypes["Secrets Managed"]
        ModelAuth["model-auth (per Job)<br/>Opaque - real model credentials<br/>User-provisioned"]
        RefTokens["internal-model-ref (per Job)<br/>Opaque - ephemeral ref tokens<br/>Auto-created, auto-deleted"]
        TestData["test-data (per Job)<br/>Opaque - S3 credentials<br/>User-provisioned"]
        OCICreds["oci-credentials (per Job)<br/>dockerconfigjson<br/>User-provisioned"]
        MLflowToken["mlflow-token<br/>Opaque - MLflow auth<br/>Platform, SA rotation"]
        ServiceCA["service-ca.crt<br/>ConfigMap - TLS cert<br/>service-ca-operator"]
    end

    CR_Main -->|manages| RefTokens

    %% Styling
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Sidecar fill:#4a90e2,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style CR_Job fill:#f5a623,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style HWProfiles fill:#7ed321,stroke:#333
    style RBAC_Proxy fill:#e74c3c,stroke:#333,color:#fff
    style SAR fill:#e74c3c,stroke:#333,color:#fff
    style OpNote fill:#fff,stroke:#999,stroke-dasharray: 5 5
    style ModelAuth fill:#fff2cc,stroke:#d6b656
    style RefTokens fill:#fff2cc,stroke:#d6b656
    style TestData fill:#fff2cc,stroke:#d6b656
    style OCICreds fill:#fff2cc,stroke:#d6b656
    style MLflowToken fill:#fff2cc,stroke:#d6b656
    style ServiceCA fill:#fff2cc,stroke:#d6b656
