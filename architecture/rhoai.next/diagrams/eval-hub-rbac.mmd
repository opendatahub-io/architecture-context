graph TD
    subgraph Operator["TrustyAI Service Operator (creates RBAC)"]
        TrustyAI["TrustyAI Operator<br/>Manages EvalHub CR"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        SA_Job["{instance}-{namespace}-job<br/>Evaluation Job SA"]
    end

    subgraph RoleBindings["Role Bindings (Tenant Namespace)"]
        RB_Job["RoleBinding<br/>(created by operator)"]
    end

    subgraph Roles["Cluster/Role Permissions"]
        CR_Batch["Role: Job Creator<br/>(created by operator)"]
    end

    subgraph APIResources["API Resources"]
        Jobs["batch<br/>jobs"]
        ConfigMaps["core (&#34;&#34;)<br/>configmaps"]
        Secrets["core (&#34;&#34;)<br/>secrets"]
        HWProfiles["infrastructure.opendatahub.io<br/>hardwareprofiles"]
    end

    subgraph Verbs_Jobs["Verbs"]
        V_Jobs["create, get, list, delete"]
    end
    subgraph Verbs_CM["Verbs"]
        V_CM["create, get, list,<br/>update, delete"]
    end
    subgraph Verbs_Secrets["Verbs"]
        V_Secrets["get, create, update,<br/>delete, list"]
    end
    subgraph Verbs_HW["Verbs"]
        V_HW["get, delete"]
    end

    %% Operator creates RBAC
    TrustyAI -->|creates| SA_Job
    TrustyAI -->|creates| RB_Job
    TrustyAI -->|creates| CR_Batch

    %% Bindings
    SA_Job -->|bound via| RB_Job
    RB_Job -->|grants| CR_Batch

    %% Permissions
    CR_Batch --> Jobs
    CR_Batch --> ConfigMaps
    CR_Batch --> Secrets
    CR_Batch --> HWProfiles

    Jobs --> V_Jobs
    ConfigMaps --> V_CM
    Secrets --> V_Secrets
    HWProfiles --> V_HW

    %% Auth Mechanisms
    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction LR
        KRBACAuth["kube-rbac-proxy<br/>8443/TCP<br/>Bearer Token → X-Tenant + X-User"]
        SAToken["ServiceAccount Token<br/>Projected volume<br/>Auto-rotated"]
        CredInjection["Credential Injection<br/>ref-token → real API key<br/>Adapter never sees real creds"]
    end

    subgraph SecretTypes["Managed Secrets"]
        direction LR
        ServiceCA["{instance}-service-ca<br/>ConfigMap (CA cert)<br/>Auto-rotated by service-ca op"]
        ModelAuth["Model auth secret<br/>Opaque (api-key, hf-token)<br/>User-provided"]
        OCICreds["OCI credentials<br/>dockerconfigjson<br/>User-provided"]
        S3Creds["S3 test-data secret<br/>Opaque (AWS creds)<br/>User-provided"]
        RefToken["{job}-{guid}-model-ref<br/>Opaque (ephemeral)<br/>Auto-created per job"]
    end

    %% Styling
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style SA_Job fill:#4a90e2,stroke:#333,color:#fff
    style RB_Job fill:#f5a623,stroke:#333,color:#fff
    style CR_Batch fill:#f5a623,stroke:#333,color:#fff
    style Jobs fill:#dae8fc,stroke:#6c8ebf
    style ConfigMaps fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#dae8fc,stroke:#6c8ebf
    style HWProfiles fill:#dae8fc,stroke:#6c8ebf
    style KRBACAuth fill:#ffe6cc,stroke:#d79b00
    style SAToken fill:#ffe6cc,stroke:#d79b00
    style CredInjection fill:#ffe6cc,stroke:#d79b00
    style ServiceCA fill:#e1d5e7,stroke:#9673a6
    style ModelAuth fill:#e1d5e7,stroke:#9673a6
    style OCICreds fill:#e1d5e7,stroke:#9673a6
    style S3Creds fill:#e1d5e7,stroke:#9673a6
    style RefToken fill:#e1d5e7,stroke:#9673a6
