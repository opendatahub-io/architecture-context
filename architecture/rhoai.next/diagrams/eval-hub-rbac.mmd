graph TD
    subgraph "Authentication Flow"
        Client["Client Request<br/>Bearer Token"]
        TokenReview["Kubernetes TokenReview<br/>(DelegatingAuthenticator)"]
        Client -->|"Bearer Token in<br/>Authorization header"| TokenReview
        TokenReview -->|"validates token<br/>returns user identity"| AuthResult["Authenticated Identity<br/>User + Groups"]
    end

    subgraph "Authorization Flow (SubjectAccessReview)"
        AuthResult -->|"identity + request"| SAR["Kubernetes SAR<br/>(DelegatingAuthorizer)"]
        SAR -->|"checks RBAC"| Decision["Allow / Deny"]
    end

    subgraph "Tenant Scoping"
        TenantHeader["X-Tenant Header"]
        TenantHeader -->|"maps to"| Namespace["Kubernetes Namespace<br/>(SAR resource namespace)"]
        Namespace -->|"scopes"| SAR
    end

    subgraph "Auth Resource Mappings"
        direction LR

        subgraph "trustyai.opendatahub.io"
            Evaluations["evaluations<br/>/api/v1/evaluations/jobs<br/>Verbs: create, get, list, delete"]
            Collections["collections<br/>/api/v1/evaluations/collections<br/>Verbs: create, get, list, update, patch, delete"]
            Providers["providers<br/>/api/v1/evaluations/providers<br/>Verbs: create, get, list, update, patch, delete"]
            StatusEvents["status-events<br/>/api/v1/.../events<br/>Verbs: create"]
        end

        subgraph "mlflow.kubeflow.org"
            Experiments["experiments<br/>MLflow experiment access<br/>Verbs: create, get"]
        end
    end

    subgraph "Public Endpoints (No Auth)"
        Health["/api/v1/health<br/>GET"]
        Metrics["/metrics<br/>GET"]
        OpenAPI["/openapi.yaml<br/>GET"]
        Docs["/docs<br/>GET"]
    end

    subgraph "Secrets & Credentials"
        TLSCert["TLS cert/key<br/>kubernetes.io/tls<br/>cert-manager<br/>Auto-rotate: Yes"]
        DBCreds["DB credentials<br/>Opaque<br/>Operator-provisioned<br/>Auto-rotate: No"]
        MLflowToken["MLflow token<br/>Projected SA Token<br/>3600s expiry<br/>Auto-rotate: Yes (kubelet)"]
        S3Creds["S3 credentials<br/>Opaque<br/>User-provisioned<br/>Auto-rotate: No"]
        OCICreds["OCI credentials<br/>dockerconfigjson<br/>User-provisioned<br/>Auto-rotate: No"]
        ModelAuth["Model auth<br/>Opaque<br/>User-provisioned<br/>Auto-rotate: No"]
        ServiceCA["Service CA<br/>ConfigMap<br/>service-ca operator<br/>Auto-rotate: Yes"]
    end

    SAR -->|"checks against"| Evaluations
    SAR -->|"checks against"| Collections
    SAR -->|"checks against"| Providers
    SAR -->|"checks against"| StatusEvents
    SAR -->|"checks against<br/>(on job create)"| Experiments

    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style TokenReview fill:#4a90e2,stroke:#333,color:#fff
    style SAR fill:#4a90e2,stroke:#333,color:#fff
    style Decision fill:#7ed321,stroke:#333,color:#fff
    style TenantHeader fill:#f5a623,stroke:#333,color:#fff
    style Namespace fill:#f5a623,stroke:#333,color:#fff
    style Evaluations fill:#d5e8d4,stroke:#82b366
    style Collections fill:#d5e8d4,stroke:#82b366
    style Providers fill:#d5e8d4,stroke:#82b366
    style StatusEvents fill:#d5e8d4,stroke:#82b366
    style Experiments fill:#dae8fc,stroke:#6c8ebf
    style Health fill:#e8e8e8,stroke:#999
    style Metrics fill:#e8e8e8,stroke:#999
    style OpenAPI fill:#e8e8e8,stroke:#999
    style Docs fill:#e8e8e8,stroke:#999
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style DBCreds fill:#fff2cc,stroke:#d6b656
    style MLflowToken fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#fff2cc,stroke:#d6b656
    style OCICreds fill:#fff2cc,stroke:#d6b656
