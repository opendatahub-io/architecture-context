graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub SA<br/>(control plane namespace)"]
        SA_Job["evalhub-instance-ns-job SA<br/>(evaluation namespaces)"]
    end

    subgraph RoleBindings["Role Bindings (operator-managed)"]
        CRB_EvalHub["eval-hub ClusterRoleBinding<br/>(control plane namespace)"]
        RB_Job["Job RoleBinding<br/>(per evaluation namespace)"]
    end

    subgraph ClusterRolePerms["ClusterRole: eval-hub (operator-managed)"]
        direction TB
        CR_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        CR_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        CR_Jobs["batch<br/>jobs"]
        CR_ConfigMaps["core<br/>configmaps"]
    end

    subgraph AuthZRules["Authorization Rules (config/auth.yaml)"]
        direction TB
        Rule_Evals["trustyai.opendatahub.io<br/>evaluations<br/>create, get, list, delete"]
        Rule_Collections["trustyai.opendatahub.io<br/>collections<br/>create, get, list, update, patch, delete"]
        Rule_Providers["trustyai.opendatahub.io<br/>providers<br/>create, get, list, update, patch, delete"]
        Rule_StatusEvents["trustyai.opendatahub.io<br/>status-events<br/>create"]
        Rule_MLflow["mlflow.kubeflow.org<br/>experiments<br/>create, get"]
    end

    subgraph TenantScoping["Multi-Tenant Scoping"]
        XTenant["X-Tenant HTTP Header<br/>→ Namespace extraction<br/>→ SAR namespace field"]
    end

    %% SA to RoleBinding
    SA_EvalHub -->|"bound via"| CRB_EvalHub
    SA_Job -->|"bound via"| RB_Job

    %% RoleBinding to ClusterRole
    CRB_EvalHub -->|"grants"| CR_TokenReview
    CRB_EvalHub -->|"grants"| CR_SAR
    CRB_EvalHub -->|"grants"| CR_Jobs
    CRB_EvalHub -->|"grants"| CR_ConfigMaps

    %% AuthZ rules checked via SAR
    CR_SAR -->|"validates against"| Rule_Evals
    CR_SAR -->|"validates against"| Rule_Collections
    CR_SAR -->|"validates against"| Rule_Providers
    CR_SAR -->|"validates against"| Rule_StatusEvents
    CR_SAR -->|"validates against"| Rule_MLflow

    %% Tenant scoping
    TenantScoping -->|"determines namespace for"| CR_SAR

    %% Verbs
    CR_TokenReview ---|"Verbs: create"| CR_TokenReview
    CR_Jobs ---|"Verbs: create, get, list, delete"| CR_Jobs
    CR_ConfigMaps ---|"Verbs: create, get, list, delete, update"| CR_ConfigMaps

    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Job fill:#4a90e2,stroke:#333,color:#fff
    style CRB_EvalHub fill:#50c878,stroke:#333,color:#fff
    style RB_Job fill:#50c878,stroke:#333,color:#fff
    style CR_TokenReview fill:#f5a623,stroke:#333,color:#fff
    style CR_SAR fill:#f5a623,stroke:#333,color:#fff
    style CR_Jobs fill:#f5a623,stroke:#333,color:#fff
    style CR_ConfigMaps fill:#f5a623,stroke:#333,color:#fff
    style Rule_Evals fill:#e8d4f0,stroke:#9673a6
    style Rule_Collections fill:#e8d4f0,stroke:#9673a6
    style Rule_Providers fill:#e8d4f0,stroke:#9673a6
    style Rule_StatusEvents fill:#e8d4f0,stroke:#9673a6
    style Rule_MLflow fill:#e8d4f0,stroke:#9673a6
    style XTenant fill:#dae8fc,stroke:#6c8ebf
