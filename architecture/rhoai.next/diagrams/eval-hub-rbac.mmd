graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub<br/>(control plane namespace)"]
        SA_Job["&#123;evalhub-instance&#125;-&#123;namespace&#125;-job<br/>(evaluation namespaces)"]
    end

    subgraph RoleBindings["Role Bindings (Operator-Managed)"]
        RB_ControlPlane["RoleBinding<br/>control plane namespace"]
        RB_EvalNS["RoleBinding<br/>evaluation namespaces"]
    end

    subgraph ClusterRoles["Cluster Roles (Implied)"]
        CR_TokenReview["ClusterRole: TokenReview"]
        CR_SAR["ClusterRole: SAR"]
        CR_Jobs["ClusterRole: Job Management"]
        CR_ConfigMaps["ClusterRole: ConfigMap Management"]
    end

    subgraph APIResources["Kubernetes API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SARs["authorization.k8s.io<br/>subjectaccessreviews"]
        Jobs["batch<br/>jobs"]
        ConfigMaps["core<br/>configmaps"]
    end

    subgraph CustomAuthZ["Custom Authorization (SAR-based)"]
        direction TB
        EvalRule["trustyai.opendatahub.io<br/>evaluations<br/>create, get, list, delete"]
        CollRule["trustyai.opendatahub.io<br/>collections<br/>create, get, list, update, delete"]
        ProvRule["trustyai.opendatahub.io<br/>providers<br/>create, get, list, update, delete"]
        EventRule["trustyai.opendatahub.io<br/>status-events<br/>create"]
        MLflowRule["mlflow.kubeflow.org<br/>experiments<br/>create, get"]
    end

    subgraph TenantScoping["Multi-Tenant Scoping"]
        XTenant["X-Tenant HTTP Header<br/>→ Kubernetes Namespace"]
    end

    %% Service Account bindings
    SA_EvalHub -->|"bound via"| RB_ControlPlane
    SA_Job -->|"bound via"| RB_EvalNS

    %% Role binding to cluster roles
    RB_ControlPlane -->|"grants"| CR_TokenReview
    RB_ControlPlane -->|"grants"| CR_SAR
    RB_ControlPlane -->|"grants"| CR_Jobs
    RB_ControlPlane -->|"grants"| CR_ConfigMaps

    %% Cluster roles to API resources
    CR_TokenReview -->|"create"| TokenReviews
    CR_SAR -->|"create"| SARs
    CR_Jobs -->|"create, get, list, delete"| Jobs
    CR_ConfigMaps -->|"create, get, list,<br/>delete, update"| ConfigMaps

    %% Custom AuthZ flow
    XTenant -->|"namespace extraction"| EvalRule
    XTenant -->|"namespace extraction"| CollRule
    XTenant -->|"namespace extraction"| ProvRule
    XTenant -->|"namespace extraction"| EventRule
    XTenant -->|"namespace extraction"| MLflowRule

    %% Styling
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Job fill:#4a90e2,stroke:#333,color:#fff
    style RB_ControlPlane fill:#9b59b6,stroke:#333,color:#fff
    style RB_EvalNS fill:#9b59b6,stroke:#333,color:#fff
    style CR_TokenReview fill:#f5a623,stroke:#333,color:#fff
    style CR_SAR fill:#f5a623,stroke:#333,color:#fff
    style CR_Jobs fill:#f5a623,stroke:#333,color:#fff
    style CR_ConfigMaps fill:#f5a623,stroke:#333,color:#fff
    style TokenReviews fill:#7ed321,stroke:#333,color:#fff
    style SARs fill:#7ed321,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style EvalRule fill:#e74c3c,stroke:#333,color:#fff
    style CollRule fill:#e74c3c,stroke:#333,color:#fff
    style ProvRule fill:#e74c3c,stroke:#333,color:#fff
    style EventRule fill:#e74c3c,stroke:#333,color:#fff
    style MLflowRule fill:#e74c3c,stroke:#333,color:#fff
    style XTenant fill:#3498db,stroke:#333,color:#fff
