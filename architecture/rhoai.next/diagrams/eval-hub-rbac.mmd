graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub<br/>service account<br/>(control plane namespace)"]
        SA_Job["{evalhub-instance}-{ns}-job<br/>service account<br/>(evaluation namespaces)"]
    end

    subgraph ClusterRoleBindings["Role Bindings (operator-managed)"]
        CRB_EvalHub["eval-hub<br/>ClusterRoleBinding"]
        RB_Job["job<br/>RoleBinding<br/>(per evaluation namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_EvalHub["eval-hub ClusterRole"]
    end

    subgraph K8sAPIResources["Kubernetes API Resources"]
        direction TB
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
        Jobs["batch<br/>jobs"]
        ConfigMaps["core<br/>configmaps"]
    end

    subgraph EvalHubAuthZ["Eval Hub Authorization (auth.yaml)"]
        direction TB
        subgraph TrustyAI["API Group: trustyai.opendatahub.io"]
            Evaluations["evaluations<br/>create, get, list, delete"]
            Collections["collections<br/>create, get, list, update, delete"]
            Providers["providers<br/>create, get, list, update, delete"]
            StatusEvents["status-events<br/>create"]
        end
        subgraph MLflowKF["API Group: mlflow.kubeflow.org"]
            Experiments["experiments<br/>create, get"]
        end
    end

    subgraph TenantScoping["Multi-Tenant Scoping"]
        XTenant["X-Tenant HTTP Header<br/>→ namespace extraction<br/>→ SAR namespace"]
    end

    %% Service Account → Bindings
    SA_EvalHub -->|"bound via"| CRB_EvalHub
    SA_Job -->|"bound via"| RB_Job

    %% Bindings → Roles
    CRB_EvalHub -->|"grants"| CR_EvalHub

    %% Role → K8s Resources
    CR_EvalHub -->|"create"| TokenReviews
    CR_EvalHub -->|"create"| SubjectAccessReviews
    CR_EvalHub -->|"create, get, list, delete"| Jobs
    CR_EvalHub -->|"create, get, list, delete, update"| ConfigMaps

    %% Authorization flow
    SA_EvalHub -.->|"enforces via middleware"| TrustyAI
    SA_EvalHub -.->|"enforces via middleware"| MLflowKF
    XTenant -.->|"scopes SAR to"| SubjectAccessReviews

    style SA_EvalHub fill:#4a90e2,color:#fff
    style SA_Job fill:#4a90e2,color:#fff
    style CRB_EvalHub fill:#e1d5e7,stroke:#9673a6
    style RB_Job fill:#e1d5e7,stroke:#9673a6
    style CR_EvalHub fill:#f5a623,color:#fff
    style TokenReviews fill:#7ed321,color:#fff
    style SubjectAccessReviews fill:#7ed321,color:#fff
    style Jobs fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Evaluations fill:#dae8fc,stroke:#6c8ebf
    style Collections fill:#dae8fc,stroke:#6c8ebf
    style Providers fill:#dae8fc,stroke:#6c8ebf
    style StatusEvents fill:#dae8fc,stroke:#6c8ebf
    style Experiments fill:#fff2cc,stroke:#d6b656
    style XTenant fill:#f8cecc,stroke:#b85450
