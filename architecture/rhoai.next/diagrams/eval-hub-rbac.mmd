graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub SA<br/>(eval-hub namespace)"]
        SA_Job["&lt;instance&gt;-&lt;ns&gt;-job SA<br/>(job namespace)"]
    end

    subgraph RoleBindings["Role Bindings (Managed by RHOAI Operator)"]
        RB_EvalHub["eval-hub role binding<br/>(eval-hub namespace)"]
        RB_Job["job role binding<br/>(job namespace)"]
    end

    subgraph Roles["Roles (Managed by RHOAI Operator)"]
        Role_EvalHub["eval-hub role"]
        Role_Job["job role"]
    end

    subgraph APIResources_Batch["API Group: batch"]
        Jobs["Jobs<br/>create, get, list, delete"]
    end

    subgraph APIResources_Core["API Group: core ('')"]
        ConfigMaps["ConfigMaps<br/>create, get, list, delete, update"]
        Secrets["Secrets<br/>get"]
    end

    subgraph APIResources_Auth["API Group: authentication.k8s.io"]
        TokenReviews["TokenReviews<br/>create"]
    end

    subgraph APIResources_Authz["API Group: authorization.k8s.io"]
        SAR["SubjectAccessReviews<br/>create"]
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction LR
        Request["Incoming Request<br/>Bearer Token"] --> TR["TokenReview<br/>(AuthN)"]
        TR --> SARCheck["SubjectAccessReview<br/>(AuthZ)"]
        SARCheck --> Allow["Allow / Deny"]
    end

    %% Bindings
    SA_EvalHub -->|"bound via"| RB_EvalHub
    RB_EvalHub -->|"grants"| Role_EvalHub
    SA_Job -->|"bound via"| RB_Job
    RB_Job -->|"grants"| Role_Job

    %% Role to Resources
    Role_EvalHub -->|"batch"| Jobs
    Role_EvalHub -->|"core"| ConfigMaps
    Role_EvalHub -->|"core"| Secrets
    Role_EvalHub -->|"authentication.k8s.io"| TokenReviews
    Role_EvalHub -->|"authorization.k8s.io"| SAR

    %% Styling
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Job fill:#4a90e2,stroke:#333,color:#fff
    style RB_EvalHub fill:#b8d4f0,stroke:#333
    style RB_Job fill:#b8d4f0,stroke:#333
    style Role_EvalHub fill:#f5a623,stroke:#333,color:#fff
    style Role_Job fill:#f5a623,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style Secrets fill:#ff6b6b,stroke:#333,color:#fff
    style TokenReviews fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style Request fill:#f9f9f9,stroke:#999
    style TR fill:#dbeafe,stroke:#3b82f6
    style SARCheck fill:#dbeafe,stroke:#3b82f6
    style Allow fill:#d5e8d4,stroke:#82b366
