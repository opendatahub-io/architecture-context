graph TD
    subgraph "Authentication Flow"
        Client["Client Request<br/>Bearer Token in Header"]
        TokenReview["Kubernetes API Server<br/>TokenReview"]
        SAR["Kubernetes API Server<br/>SubjectAccessReview"]

        Client -->|"Bearer Token"| TokenReview
        TokenReview -->|"authenticated identity"| SAR
    end

    subgraph "Authorization Policy (SAR Attributes)"
        direction TB

        subgraph "API Group: trustyai.opendatahub.io"
            EvalResource["Resource: evaluations<br/>Verbs: create, get, list, delete"]
            StatusEvents["Resource: status-events<br/>Verbs: create"]
            Collections["Resource: collections<br/>Verbs: create, get, list, update, patch, delete"]
            Providers["Resource: providers<br/>Verbs: create, get, list, update, patch, delete"]
        end

        subgraph "API Group: mlflow.kubeflow.org"
            MLflowExperiments["Resource: experiments<br/>Verbs: create, get"]
        end
    end

    subgraph "Multi-Tenancy"
        TenantHeader["X-Tenant Header<br/>→ Kubernetes Namespace"]
        NamespaceSAR["SAR scoped to<br/>tenant namespace"]

        TenantHeader --> NamespaceSAR
    end

    subgraph "Endpoint → Resource Mapping"
        EP_Jobs_POST["POST /api/v1/evaluations/jobs"]
        EP_Jobs_GET["GET /api/v1/evaluations/jobs"]
        EP_Jobs_ID["GET|DELETE /api/v1/evaluations/jobs/{id}"]
        EP_Events["POST /api/v1/evaluations/jobs/{id}/events"]
        EP_Collections["* /api/v1/evaluations/collections"]
        EP_Providers["* /api/v1/evaluations/providers"]
        EP_Public["GET /health, /metrics, /openapi, /docs"]
    end

    SAR --> EP_Jobs_POST
    SAR --> EP_Jobs_GET
    SAR --> EP_Jobs_ID
    SAR --> EP_Events
    SAR --> EP_Collections
    SAR --> EP_Providers

    EP_Jobs_POST -->|"requires"| EvalResource
    EP_Jobs_POST -->|"requires"| MLflowExperiments
    EP_Jobs_GET -->|"requires"| EvalResource
    EP_Jobs_ID -->|"requires"| EvalResource
    EP_Events -->|"requires"| StatusEvents
    EP_Collections -->|"requires"| Collections
    EP_Providers -->|"requires"| Providers
    EP_Public -.->|"no auth required"| Public["Public Access"]

    SAR --> NamespaceSAR

    subgraph "ServiceAccount Tokens"
        SA_EvalHub["eval-hub SA<br/>K8s API access"]
        SA_Projected["Projected SA Token<br/>MLflow auth (3600s TTL)"]
        SA_Sidecar["Sidecar SA Token<br/>eval-hub callback auth"]
    end

    style Client fill:#e8e8e8,stroke:#333
    style TokenReview fill:#4a90e2,stroke:#333,color:#fff
    style SAR fill:#4a90e2,stroke:#333,color:#fff
    style EvalResource fill:#7ed321,stroke:#333
    style StatusEvents fill:#7ed321,stroke:#333
    style Collections fill:#7ed321,stroke:#333
    style Providers fill:#7ed321,stroke:#333
    style MLflowExperiments fill:#f5a623,stroke:#333
    style TenantHeader fill:#e8a0bf,stroke:#333
    style NamespaceSAR fill:#e8a0bf,stroke:#333
    style Public fill:#d5e8d4,stroke:#333
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Projected fill:#4a90e2,stroke:#333,color:#fff
    style SA_Sidecar fill:#4a90e2,stroke:#333,color:#fff
