sequenceDiagram
    participant User as Data Scientist<br/>(User Code)
    participant Exp as AI4RAGExperiment<br/>(Orchestrator)
    participant SS as SearchSpace<br/>(Parameter Mgmt)
    participant HPO as GAMOptimizer<br/>(Surrogate Model)
    participant Chunker as LangChainChunker<br/>(Text Splitting)
    participant Embed as EmbeddingModel<br/>(LS / OpenAI)
    participant VS as VectorStore<br/>(LS / Chroma)
    participant Ret as Retriever<br/>(Vector/Hybrid)
    participant FM as FoundationModel<br/>(LS / OpenAI)
    participant Eval as UnitxtEvaluator<br/>(Metrics)
    participant LS as Llama Stack Server<br/>(HTTP/HTTPS)
    participant EH as EventHandler<br/>(Local / KFP)

    rect rgb(240, 248, 255)
        Note over User,EH: Flow 1: RAG Optimization Experiment
        User->>Exp: experiment.search(rag_template, search_space, n_trials)

        rect rgb(255, 248, 240)
            Note over Exp,LS: Optional: Models Pre-Selection (MPS)
            Exp->>LS: models.list()<br/>HTTP/HTTPS, API Key
            LS-->>Exp: Available models list
            loop For each model pair
                Exp->>Embed: embed(benchmark_docs)
                Embed->>LS: POST embeddings<br/>HTTP/HTTPS, API Key
                LS-->>Embed: Embedding vectors
                Exp->>FM: chat(benchmark_queries)
                FM->>LS: POST chat/completions<br/>HTTP/HTTPS, API Key
                LS-->>FM: Generated answers
                Exp->>Eval: evaluate(answers, ground_truth)
                Eval-->>Exp: Metrics + confidence intervals
            end
            Exp->>SS: narrow_search_space(top_models)
        end

        rect rgb(240, 255, 240)
            Note over Exp,EH: Main Optimization Loop (n_trials iterations)
            loop For each trial
                Exp->>HPO: suggest_next_params()
                HPO->>SS: sample(constraints)
                SS-->>HPO: Parameter configuration
                HPO-->>Exp: {chunk_size, overlap, model, search_mode, ...}

                Note over Exp,VS: Stage 1: Index Documents
                Exp->>Chunker: chunk(documents, chunk_size, overlap)
                Chunker-->>Exp: Document chunks (in-process)
                Exp->>Embed: embed(chunks)
                Embed->>LS: POST embeddings<br/>HTTP/HTTPS, API Key
                LS-->>Embed: Embedding vectors
                Exp->>VS: insert(chunks, embeddings)
                VS->>LS: POST vector_io/insert<br/>HTTP/HTTPS, API Key
                LS-->>VS: Confirmation

                Note over Exp,FM: Stage 2: Retrieve & Generate
                Exp->>Ret: retrieve(query, top_k)
                Ret->>VS: similarity_search(query_embedding)
                VS->>LS: POST vector_io/query<br/>HTTP/HTTPS, API Key
                LS-->>VS: Relevant chunks
                VS-->>Ret: Context documents
                Ret-->>Exp: Retrieved context
                Exp->>FM: chat(query + context)
                FM->>LS: POST chat/completions<br/>HTTP/HTTPS, API Key
                LS-->>FM: Generated answer
                FM-->>Exp: RAG answer

                Note over Exp,EH: Stage 3: Evaluate & Record
                Exp->>Eval: evaluate(answer, ground_truth, context)
                Eval-->>Exp: {correctness, faithfulness, context_correctness}
                Exp->>HPO: observe(params, score)
                Exp->>EH: emit(PatternPayload, EvaluationRecord)
                EH-->>EH: Write JSON / KFP metadata
            end
        end

        Exp-->>User: Best RAG Pattern<br/>(optimal hyperparameters + scores)
    end
