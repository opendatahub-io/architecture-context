sequenceDiagram
    autonumber

    participant User as User / Pipeline
    participant Exp as AI4RAGExperiment
    participant MPS as ModelsPreSelector
    participant Chroma as ChromaDB<br/>(In-memory)
    participant LS as Llama Stack Server<br/>HTTP/HTTPS<br/>API Key Auth
    participant OAI as OpenAI API<br/>HTTP/HTTPS<br/>API Key Auth
    participant Eval as UnitxtEvaluator
    participant GAM as GAMOptimizer
    participant SS as AI4RAGSearchSpace
    participant RAG as SimpleRAG Pipeline
    participant LSVS as LlamaStack VectorStore<br/>(Milvus/Qdrant)
    participant EH as EventHandler<br/>(Local/KFP)

    rect rgb(230, 245, 255)
        Note over User,EH: Phase 0: Search Space Preparation
        User->>Exp: run(benchmark_data, search_space_config)
        Exp->>LS: models.list()
        LS-->>Exp: Available models
        Exp->>LS: Validate foundation models (chat test)
        LS-->>Exp: Validation results
        Exp->>LS: Validate embedding models (embed_query test)
        LS-->>Exp: Embedding validation + dimension auto-detect
        Exp->>LS: Context length auto-detection (binary search)
        LS-->>Exp: Max context lengths
        Exp->>SS: Build constrained search space
        SS-->>Exp: Pruned parameter combinations
    end

    rect rgb(255, 243, 224)
        Note over User,EH: Phase 1: Models Pre-Selection (MPS)
        Exp->>MPS: run_pre_selection(benchmark_sample)
        loop For each (foundation_model, embedding_model) pair
            MPS->>LS: Generate embeddings for sample docs
            LS-->>MPS: Embedding vectors
            MPS->>Chroma: Create in-memory vector store
            MPS->>Chroma: Insert embedded chunks
            Chroma-->>MPS: Indexed
            MPS->>Chroma: Retrieve relevant chunks
            Chroma-->>MPS: Retrieved context
            MPS->>LS: Chat completion (RAG query)
            LS-->>MPS: Generated answer
            MPS->>Eval: evaluate_metrics(answer, ground_truth)
            Eval-->>MPS: faithfulness, answer_correctness, context_correctness
        end
        MPS-->>Exp: Top-K model pairs ranked by metrics
    end

    rect rgb(232, 245, 233)
        Note over User,EH: Phase 2: GAM-based Hyperparameter Optimization
        Exp->>GAM: optimize(search_space, top_model_pairs)
        loop For each optimization iteration
            GAM->>SS: Select next parameter node (GAM prediction)
            SS-->>GAM: {chunk_size, overlap, embedding_model,<br/>foundation_model, retrieval_method, top_k, search_mode}

            GAM->>RAG: run_single_evaluation(params)

            RAG->>RAG: Chunk documents (RecursiveCharacterTextSplitter)
            RAG->>LS: Generate embeddings for chunks
            LS-->>RAG: Embedding vectors
            RAG->>LSVS: Create/insert into vector store
            LSVS-->>RAG: Indexed

            RAG->>LSVS: Search (vector/keyword/hybrid)
            LSVS-->>RAG: Retrieved documents

            RAG->>LS: Chat completion with context
            LS-->>RAG: Generated answer

            RAG->>Eval: evaluate_metrics(answer, ground_truth)
            Eval-->>RAG: Scores with confidence intervals

            RAG-->>GAM: Evaluation result
            GAM->>GAM: Update GAM model with new observation
            GAM->>EH: on_pattern_creation(pattern_payload)
        end
        GAM-->>Exp: Best parameter configuration + scores
    end

    Exp->>EH: on_experiment_complete(results)
    Exp-->>User: Optimal RAG configuration
