graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance-name}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Instance["{instance-name}-rb"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role"]
    end

    subgraph LlamaStackResources["llamastack.io API Resources"]
        LLSD["llamastackdistributions<br/>get, list, watch, create,<br/>update, patch, delete"]
        LLSDStatus["llamastackdistributions/status<br/>get, update, patch"]
        LLSDFinalizers["llamastackdistributions/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Resources"]
        Services["services<br/>get, list, watch, create,<br/>update, patch, delete"]
        ServiceAccts["serviceaccounts<br/>get, list, watch, create,<br/>update, patch, delete"]
        ConfigMaps["configmaps<br/>get, list, watch, create,<br/>update, patch"]
        PVCs["persistentvolumeclaims<br/>get, list, watch, create"]
    end

    subgraph AppsResources["apps API Resources"]
        Deployments["deployments<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph NetworkingResources["networking.k8s.io Resources"]
        NetworkPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch, delete"]
        Ingresses["ingresses<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph PolicyResources["policy API Resources"]
        PDBs["poddisruptionbudgets<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph AutoscalingResources["autoscaling API Resources"]
        HPAs["horizontalpodautoscalers<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io Resources"]
        RoleBindingsRes["rolebindings<br/>get, list, watch, create,<br/>update, patch, delete"]
        ClusterRoleBindingsRes["clusterrolebindings<br/>get, list, delete"]
        ClusterRolesRes["clusterroles<br/>get, list, watch"]
    end

    subgraph SecurityResources["security.openshift.io Resources"]
        SCCs["securitycontextconstraints<br/>(anyuid)<br/>use"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    SA_Instance -->|bound via| CRB_Instance
    CRB_Instance -->|grants| CR_SCC

    %% manager-role permissions
    CR_Manager -->|manages| LLSD
    CR_Manager -->|manages| LLSDStatus
    CR_Manager -->|manages| LLSDFinalizers
    CR_Manager -->|manages| Services
    CR_Manager -->|manages| ServiceAccts
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| NetworkPolicies
    CR_Manager -->|manages| Ingresses
    CR_Manager -->|manages| PDBs
    CR_Manager -->|manages| HPAs
    CR_Manager -->|manages| RoleBindingsRes
    CR_Manager -->|manages| ClusterRoleBindingsRes
    CR_Manager -->|manages| ClusterRolesRes
    CR_Manager -->|manages| SCCs

    %% SCC binding
    CR_SCC -->|allows| SCCs

    style SA_Controller fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_Instance fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
