graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster/Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding, operator-ns)"]
        RB_Instance["{instance}-rb<br/>(RoleBinding, instance-ns)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_LeaderElection["leader-election-role<br/>(Role, operator-ns)"]
        CR_AnyUID["system:openshift:scc:anyuid<br/>(ClusterRole)"]
    end

    subgraph LlamaStackResources["llamastack.io API Resources"]
        LSD["llamastackdistributions<br/>get,list,watch,create,<br/>update,patch,delete"]
        LSD_Status["llamastackdistributions/status<br/>get,update,patch"]
        LSD_Finalizers["llamastackdistributions/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Resources"]
        Deployments["apps/deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        Services["core/services<br/>get,list,watch,create,<br/>update,patch,delete"]
        ServiceAccts["core/serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
        ConfigMaps["core/configmaps<br/>get,list,watch,create,<br/>update,patch"]
        PVCs["core/persistentvolumeclaims<br/>get,list,watch,create"]
    end

    subgraph NetworkResources["Networking API Resources"]
        NetworkPolicies["networking.k8s.io/networkpolicies<br/>get,list,watch,create,<br/>update,patch,delete"]
        Ingresses["networking.k8s.io/ingresses<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph PolicyResources["Policy & Autoscaling Resources"]
        PDBs["policy/poddisruptionbudgets<br/>get,list,watch,create,<br/>update,patch,delete"]
        HPAs["autoscaling/horizontalpodautoscalers<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph RBACResources["RBAC Resources"]
        RoleBindings["rbac/rolebindings<br/>get,list,watch,create,<br/>update,patch,delete"]
        ClusterRoleBindingsRes["rbac/clusterrolebindings<br/>get,list,delete"]
        ClusterRolesRes["rbac/clusterroles<br/>get,list,watch"]
    end

    subgraph SecurityResources["OpenShift Security Resources"]
        SCCs["security.openshift.io/scc<br/>use (anyuid)"]
    end

    %% Manager SA bindings
    SA_Manager -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    SA_Manager -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| CR_LeaderElection

    %% Instance SA bindings
    SA_Instance -->|"bound via"| RB_Instance
    RB_Instance -->|"grants"| CR_AnyUID

    %% Manager role permissions
    CR_Manager -->|"allows"| LSD
    CR_Manager -->|"allows"| LSD_Status
    CR_Manager -->|"allows"| LSD_Finalizers
    CR_Manager -->|"allows"| Deployments
    CR_Manager -->|"allows"| Services
    CR_Manager -->|"allows"| ServiceAccts
    CR_Manager -->|"allows"| ConfigMaps
    CR_Manager -->|"allows"| PVCs
    CR_Manager -->|"allows"| NetworkPolicies
    CR_Manager -->|"allows"| Ingresses
    CR_Manager -->|"allows"| PDBs
    CR_Manager -->|"allows"| HPAs
    CR_Manager -->|"allows"| RoleBindings
    CR_Manager -->|"allows"| ClusterRoleBindingsRes
    CR_Manager -->|"allows"| ClusterRolesRes
    CR_Manager -->|"allows"| SCCs

    %% AnyUID role permissions
    CR_AnyUID -->|"allows"| SCCs

    %% Styling
    style SA_Manager fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_LeaderElection fill:#f5a623,color:#fff
    style CR_AnyUID fill:#f5a623,color:#fff
    style CRB_Manager fill:#e8e8e8
    style RB_Leader fill:#e8e8e8
    style RB_Instance fill:#e8e8e8
    style LSD fill:#7ed321,color:#fff
    style LSD_Status fill:#7ed321,color:#fff
    style LSD_Finalizers fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ServiceAccts fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style PVCs fill:#7ed321,color:#fff
    style NetworkPolicies fill:#7ed321,color:#fff
    style Ingresses fill:#7ed321,color:#fff
    style PDBs fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style RoleBindings fill:#7ed321,color:#fff
    style ClusterRoleBindingsRes fill:#7ed321,color:#fff
    style ClusterRolesRes fill:#7ed321,color:#fff
    style SCCs fill:#d0021b,color:#fff
