graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance-name}-sa<br/>(user namespace, per OGXServer)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-wide)"]
        CRB_Proxy["proxy-rolebinding<br/>(cluster-wide)"]
        CRB_Instance["{instance-name}-rolebinding<br/>(per OGXServer, user namespace)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(system namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_Editor["ogxserver-editor-role<br/>(aggregated)"]
        CR_Viewer["ogxserver-viewer-role<br/>(aggregated)"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/>(system namespace)"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims"]
        Pods["core<br/>pods"]
        SAs["core<br/>serviceaccounts"]
        Services["core<br/>services"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>deployments"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        HPAs["autoscaling/v2<br/>horizontalpodautoscalers"]
    end

    subgraph NetworkingResources["Networking Resources"]
        Ingresses["networking.k8s.io<br/>ingresses"]
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph OGXResources["OGX API Resources"]
        OGXServers["ogx.io<br/>ogxservers"]
        OGXFinalizers["ogx.io<br/>ogxservers/finalizers"]
        OGXStatus["ogx.io<br/>ogxservers/status"]
    end

    subgraph PolicyResources["Policy Resources"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph RBACResources["RBAC Resources"]
        ClusterRolesRes["rbac.authorization.k8s.io<br/>clusterroles"]
        ClusterRoleBindingsRes["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        RoleBindingsRes["rbac.authorization.k8s.io<br/>rolebindings"]
    end

    subgraph SecurityResources["Security Resources"]
        SCCs["security.openshift.io<br/>securitycontextconstraints"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph NonResourceURLs["Non-Resource URLs"]
        MetricsURL["/metrics"]
    end

    %% SA → Binding → Role chains
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Proxy
    SA_CM -->|"bound via"| RB_Leader
    SA_Instance -->|"bound via"| CRB_Instance

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_Instance -->|"grants"| CR_SCC
    RB_Leader -->|"grants"| R_Leader

    %% manager-role permissions
    CR_Manager -->|"create,get,list,<br/>patch,update,watch"| ConfigMaps
    CR_Manager -->|"create,get,list,<br/>patch,update,watch"| PVCs
    CR_Manager -->|"list"| Pods
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| SAs
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| Services
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| Deployments
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| HPAs
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| Ingresses
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| NetworkPolicies
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| OGXServers
    CR_Manager -->|"update"| OGXFinalizers
    CR_Manager -->|"get,patch,update"| OGXStatus
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| PDBs
    CR_Manager -->|"get,list,watch"| ClusterRolesRes
    CR_Manager -->|"delete,get,list"| ClusterRoleBindingsRes
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| RoleBindingsRes
    CR_Manager -->|"use"| SCCs

    %% proxy-role permissions
    CR_Proxy -->|"create"| TokenReviews
    CR_Proxy -->|"create"| SAR

    %% metrics-reader permissions
    CR_Metrics -->|"get"| MetricsURL

    %% editor/viewer permissions
    CR_Editor -->|"create,delete,get,list,<br/>patch,update,watch"| OGXServers
    CR_Editor -->|"get"| OGXStatus
    CR_Viewer -->|"get,list,watch"| OGXServers
    CR_Viewer -->|"get"| OGXStatus

    %% SCC permissions
    CR_SCC -->|"use"| SCCs

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_Proxy fill:#f5a623,stroke:#333
    style CR_Metrics fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style CR_SCC fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style OGXServers fill:#7ed321,stroke:#333
    style OGXFinalizers fill:#7ed321,stroke:#333
    style OGXStatus fill:#7ed321,stroke:#333
