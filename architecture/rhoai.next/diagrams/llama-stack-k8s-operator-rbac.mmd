graph TD
    subgraph "Service Accounts"
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Inst["{instance-name}-sa<br/>(per managed instance)"]
    end

    subgraph "Bindings"
        CRB_Manager["ClusterRoleBinding<br/>(manager-rolebinding)"]
        RB_Leader["RoleBinding<br/>leader-election-rolebinding<br/>(operator namespace)"]
        RB_SCC["{instance-name}-rb<br/>RoleBinding<br/>(instance namespace)"]
    end

    subgraph "Roles"
        CR_Manager["ClusterRole<br/>manager-role"]
        R_Leader["Role<br/>leader-election-role"]
        CR_SCC["ClusterRole<br/>system:openshift:scc:anyuid"]
    end

    subgraph "LlamaStack CRD Resources"
        LLSDRes["llamastack.io<br/>llamastackdistributions<br/>get,list,watch,create,<br/>update,patch,delete"]
        LLSDStatus["llamastack.io<br/>llamastackdistributions/status<br/>get,update,patch"]
        LLSDFin["llamastack.io<br/>llamastackdistributions/finalizers<br/>update"]
    end

    subgraph "Workload Resources"
        Deploy["apps<br/>deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        Svc["core<br/>services<br/>get,list,watch,create,<br/>update,patch,delete"]
        SvcAcct["core<br/>serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
        PVC["core<br/>persistentvolumeclaims<br/>get,list,watch,create"]
        CM["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch"]
    end

    subgraph "Network Resources"
        NetPol["networking.k8s.io<br/>networkpolicies<br/>get,list,watch,create,<br/>update,patch,delete"]
        Ingress["networking.k8s.io<br/>ingresses<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph "Scaling & Availability"
        PDB["policy<br/>poddisruptionbudgets<br/>get,list,watch,create,<br/>update,patch,delete"]
        HPA["autoscaling<br/>horizontalpodautoscalers<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph "RBAC Resources"
        RBRes["rbac.authorization.k8s.io<br/>rolebindings<br/>get,list,watch,create,<br/>update,patch,delete"]
        CRBRes["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get,list,delete"]
        CRRes["rbac.authorization.k8s.io<br/>clusterroles<br/>get,list,watch"]
    end

    subgraph "OpenShift Resources"
        SCC["security.openshift.io<br/>securitycontextconstraints<br/>use"]
        SCCAnyuid["security.openshift.io<br/>securitycontextconstraints<br/>(anyuid) use"]
    end

    %% Operator SA bindings
    SA_CM -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    SA_CM -->|"bound via"| RB_Leader
    RB_Leader -->|"grants"| R_Leader

    %% Instance SA bindings
    SA_Inst -->|"bound via"| RB_SCC
    RB_SCC -->|"grants"| CR_SCC

    %% ClusterRole permissions
    CR_Manager -->|"permits"| LLSDRes
    CR_Manager -->|"permits"| LLSDStatus
    CR_Manager -->|"permits"| LLSDFin
    CR_Manager -->|"permits"| Deploy
    CR_Manager -->|"permits"| Svc
    CR_Manager -->|"permits"| SvcAcct
    CR_Manager -->|"permits"| PVC
    CR_Manager -->|"permits"| CM
    CR_Manager -->|"permits"| NetPol
    CR_Manager -->|"permits"| Ingress
    CR_Manager -->|"permits"| PDB
    CR_Manager -->|"permits"| HPA
    CR_Manager -->|"permits"| RBRes
    CR_Manager -->|"permits"| CRBRes
    CR_Manager -->|"permits"| CRRes
    CR_Manager -->|"permits"| SCC
    CR_Manager -->|"permits"| SCCAnyuid

    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Inst fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style CR_SCC fill:#f5a623,stroke:#333
    style LLSDRes fill:#7ed321,stroke:#333
    style LLSDStatus fill:#7ed321,stroke:#333
    style LLSDFin fill:#7ed321,stroke:#333
    style Deploy fill:#7ed321,stroke:#333
    style Svc fill:#7ed321,stroke:#333
    style SvcAcct fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style CM fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style Ingress fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style RBRes fill:#7ed321,stroke:#333
    style CRBRes fill:#7ed321,stroke:#333
    style CRRes fill:#7ed321,stroke:#333
    style SCC fill:#e8e8e8,stroke:#333
    style SCCAnyuid fill:#e8e8e8,stroke:#333
