graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance-name}-sa<br/>(per OGXServer, user namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-wide)"]
        CRB_Proxy["proxy-rolebinding<br/>(cluster-wide)"]
        CRB_LE["leader-election-rolebinding<br/>(system namespace, Role)"]
    end

    subgraph RoleBindings["Per-Instance Role Bindings"]
        RB_Instance["{instance-name}-rolebinding<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_Editor["ogxserver-editor-role<br/>(aggregation label)"]
        CR_Viewer["ogxserver-viewer-role<br/>(aggregation label)"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB
        CoreCM["core<br/>configmaps<br/>create,get,list,patch,update,watch"]
        CorePVC["core<br/>persistentvolumeclaims<br/>create,get,list,patch,update,watch"]
        CorePods["core<br/>pods<br/>list"]
        CoreSA["core<br/>serviceaccounts<br/>create,delete,get,list,patch,<br/>update,watch"]
        CoreSvc["core<br/>services<br/>create,delete,get,list,patch,<br/>update,watch"]
        AppsDeploy["apps<br/>deployments<br/>create,delete,get,list,patch,<br/>update,watch"]
        AutoHPA["autoscaling/v2<br/>horizontalpodautoscalers<br/>create,delete,get,list,patch,<br/>update,watch"]
        NetIng["networking.k8s.io<br/>ingresses<br/>create,delete,get,list,patch,<br/>update,watch"]
        NetNP["networking.k8s.io<br/>networkpolicies<br/>create,delete,get,list,patch,<br/>update,watch"]
        OGXRes["ogx.io<br/>ogxservers<br/>create,delete,get,list,patch,<br/>update,watch"]
        OGXFin["ogx.io<br/>ogxservers/finalizers<br/>update"]
        OGXStat["ogx.io<br/>ogxservers/status<br/>get,patch,update"]
        PolicyPDB["policy<br/>poddisruptionbudgets<br/>create,delete,get,list,patch,<br/>update,watch"]
        RBACCR["rbac.authorization.k8s.io<br/>clusterroles<br/>get,list,watch"]
        RBACCRB["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>delete,get,list"]
        RBACRB["rbac.authorization.k8s.io<br/>rolebindings<br/>create,delete,get,list,patch,<br/>update,watch"]
        SCC["security.openshift.io<br/>securitycontextconstraints<br/>use"]
    end

    subgraph ProxyPermissions["proxy-role Permissions"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
    end

    subgraph MetricsPermissions["metrics-reader Permissions"]
        MetricsURL["nonResourceURLs<br/>/metrics<br/>get"]
    end

    subgraph EditorPermissions["ogxserver-editor-role Permissions"]
        EditorOGX["ogx.io<br/>ogxservers<br/>create,delete,get,list,patch,<br/>update,watch"]
        EditorStatus["ogx.io<br/>ogxservers/status<br/>get"]
    end

    subgraph ViewerPermissions["ogxserver-viewer-role Permissions"]
        ViewerOGX["ogx.io<br/>ogxservers<br/>get,list,watch"]
        ViewerStatus["ogx.io<br/>ogxservers/status<br/>get"]
    end

    %% Bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Proxy
    SA_CM -->|bound via| CRB_LE

    SA_Instance -->|bound via| RB_Instance

    CRB_Manager -->|grants| CR_Manager
    CRB_Proxy -->|grants| CR_Proxy
    RB_Instance -->|grants| CR_SCC

    %% Role → Permissions
    CR_Manager -->|permissions| ManagerPermissions
    CR_Proxy -->|permissions| ProxyPermissions
    CR_Metrics -->|permissions| MetricsPermissions
    CR_Editor -->|permissions| EditorPermissions
    CR_Viewer -->|permissions| ViewerPermissions

