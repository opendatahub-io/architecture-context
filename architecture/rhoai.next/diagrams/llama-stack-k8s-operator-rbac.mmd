graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthProxy["auth-proxy-rolebinding"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Instance["{instance}-rb<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_AuthProxy["auth-proxy-role"]
        CR_AnyUID["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/>(operator namespace)"]
    end

    subgraph APIResources_CR["manager-role Permissions"]
        LSD["llamastack.io<br/>llamastackdistributions<br/>get,list,watch,create,<br/>update,patch,delete"]
        LSD_Status["llamastack.io<br/>llamastackdistributions/status<br/>get,update,patch"]
        LSD_Finalizers["llamastack.io<br/>llamastackdistributions/finalizers<br/>update"]
        Deployments["apps<br/>deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        Services["core<br/>services, serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
        ConfigMaps["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch"]
        PVCs["core<br/>persistentvolumeclaims<br/>get,list,watch,create"]
        NetPol["networking.k8s.io<br/>networkpolicies, ingresses<br/>get,list,watch,create,<br/>update,patch,delete"]
        PDBs["policy<br/>poddisruptionbudgets<br/>get,list,watch,create,<br/>update,patch,delete"]
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>get,list,watch,create,<br/>update,patch,delete"]
        RoleBindingsRes["rbac.authorization.k8s.io<br/>rolebindings<br/>get,list,watch,create,<br/>update,patch,delete"]
        CRBRes["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>get,list,delete"]
        CRRes["rbac.authorization.k8s.io<br/>clusterroles<br/>get,list,watch"]
        SCCs["security.openshift.io<br/>securitycontextconstraints<br/>use"]
    end

    %% Operator SA bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_AuthProxy
    SA_CM -->|bound via| RB_Leader

    CRB_Manager -->|grants| CR_Manager
    CRB_AuthProxy -->|grants| CR_AuthProxy
    RB_Leader -->|grants| R_Leader

    %% Instance SA bindings
    SA_Instance -->|bound via| RB_Instance
    RB_Instance -->|grants| CR_AnyUID

    %% manager-role permissions
    CR_Manager -->|manages| LSD
    CR_Manager -->|manages| LSD_Status
    CR_Manager -->|manages| LSD_Finalizers
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| Services
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| NetPol
    CR_Manager -->|manages| PDBs
    CR_Manager -->|manages| HPAs
    CR_Manager -->|manages| RoleBindingsRes
    CR_Manager -->|manages| CRBRes
    CR_Manager -->|manages| CRRes
    CR_Manager -->|manages| SCCs

