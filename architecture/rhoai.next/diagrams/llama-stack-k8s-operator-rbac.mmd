graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance}-sa<br/>(instance namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_Proxy["proxy-rolebinding"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
        RB_Instance["{instance}-rb<br/>(instance namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Proxy["auth_proxy_role"]
        CR_SCC["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role"]
    end

    subgraph LlamaStackResources["llamastack.io API Group"]
        LSD["llamastackdistributions<br/>get, list, watch, create,<br/>update, patch, delete"]
        LSD_Status["llamastackdistributions/status<br/>get, update, patch"]
        LSD_Finalizers["llamastackdistributions/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Group"]
        Deployments["apps / deployments<br/>get, list, watch, create,<br/>update, patch, delete"]
        Services["core / services<br/>get, list, watch, create,<br/>update, patch, delete"]
        SvcAccounts["core / serviceaccounts<br/>get, list, watch, create,<br/>update, patch, delete"]
        ConfigMaps["core / configmaps<br/>get, list, watch, create,<br/>update, patch"]
        PVCs["core / persistentvolumeclaims<br/>get, list, watch, create"]
    end

    subgraph NetworkResources["networking.k8s.io API Group"]
        NetPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch, delete"]
        Ingresses["ingresses<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph PolicyResources["policy API Group"]
        PDBs["poddisruptionbudgets<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph AutoscalingResources["autoscaling API Group"]
        HPAs["horizontalpodautoscalers<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        RoleBindingsRes["rolebindings<br/>get, list, watch, create,<br/>update, patch, delete"]
        ClusterRoleBindingsRes["clusterrolebindings<br/>get, list, delete"]
        ClusterRolesRes["clusterroles<br/>get, list, watch"]
    end

    subgraph SecurityResources["security.openshift.io"]
        SCCs["securitycontextconstraints<br/>use"]
        SCC_Anyuid["securitycontextconstraints (anyuid)<br/>use"]
    end

    %% Controller-manager bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    SA_Controller -->|bound via| CRB_Proxy
    CRB_Proxy -->|grants| CR_Proxy
    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% Instance SA bindings
    SA_Instance -->|bound via| RB_Instance
    RB_Instance -->|grants| CR_SCC

    %% manager-role permissions
    CR_Manager -->|manages| LSD
    CR_Manager -->|manages| LSD_Status
    CR_Manager -->|manages| LSD_Finalizers
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| Services
    CR_Manager -->|manages| SvcAccounts
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| NetPolicies
    CR_Manager -->|manages| Ingresses
    CR_Manager -->|manages| PDBs
    CR_Manager -->|manages| HPAs
    CR_Manager -->|manages| RoleBindingsRes
    CR_Manager -->|manages| ClusterRoleBindingsRes
    CR_Manager -->|manages| ClusterRolesRes
    CR_Manager -->|manages| SCCs

    %% SCC anyuid
    CR_SCC -->|allows| SCC_Anyuid

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_Proxy fill:#f5a623,stroke:#333
    style CR_SCC fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_Proxy fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style RB_Instance fill:#e8e8e8,stroke:#333
    style LSD fill:#7ed321,stroke:#333
    style LSD_Status fill:#7ed321,stroke:#333
    style LSD_Finalizers fill:#7ed321,stroke:#333
