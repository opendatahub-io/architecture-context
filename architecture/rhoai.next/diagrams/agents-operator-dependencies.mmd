graph LR
    Kagenti["Kagenti Operator<br/>(agents-operator)"]

    %% Required External Dependencies
    Kagenti -->|"CRD CRUD, RBAC<br/>6443/TCP HTTPS"| K8s["Kubernetes v1.28+"]
    Kagenti -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.24.1"]

    %% Conditional External Dependencies
    Kagenti -->|"webhook TLS, metrics TLS<br/>TLS Bridge CA, SharedTrust"| CertManager["cert-manager<br/>v1.20.2+"]
    Kagenti -->|"SPIFFE workload identity<br/>mTLS, SVID provisioning<br/>CSI: csi.spiffe.io"| SPIRE["SPIRE"]
    Kagenti -->|"OAuth2 client registration<br/>JWT validation, token exchange<br/>8080/TCP HTTP"| Keycloak["Keycloak"]
    Kagenti -->|"experiment tracking<br/>80/443/TCP HTTP(S)"| MLflow["MLflow"]
    Kagenti -->|"API gateway<br/>rate limiting, auth"| Kuadrant["Kuadrant"]
    Kagenti -->|"ambient mesh enrollment<br/>CA cert sync"| Istio["Istio<br/>(ambient mode)"]
    Kagenti -->|"supply-chain attestation<br/>verification"| Sigstore["Sigstore<br/>(Rekor/Fulcio)"]

    %% Internal Platform Dependencies
    Kagenti -->|"OVN-Kubernetes<br/>routingViaHost validation"| OSNetwork["OpenShift<br/>Network Operator"]
    Kagenti -->|"auto-discover<br/>Keycloak public URL"| OSRoutes["OpenShift<br/>Routes"]
    Kagenti -->|"detect MLflow<br/>component enabled"| DSC["DataScienceCluster<br/>(RHOAI)"]
    Kagenti -->|"pipeline config<br/>for kagenti"| Tekton["Tekton<br/>(TektonConfig)"]
    Kagenti -->|"auto-discover<br/>SPIRE trust domain"| ZTWIM["ZTWIM"]

    %% Integration Points (consumers)
    Kagenti -.->|"SCC management<br/>CSI volume access"| OSSCC["OpenShift SCC"]

    %% Styling
    style Kagenti fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required
    style K8s fill:#2c3e50,stroke:#333,color:#fff
    style CtrlRuntime fill:#2c3e50,stroke:#333,color:#fff

    %% Conditional External
    style CertManager fill:#7f8c8d,stroke:#333,color:#fff
    style SPIRE fill:#7f8c8d,stroke:#333,color:#fff
    style Keycloak fill:#7f8c8d,stroke:#333,color:#fff
    style MLflow fill:#7f8c8d,stroke:#333,color:#fff
    style Kuadrant fill:#7f8c8d,stroke:#333,color:#fff
    style Istio fill:#7f8c8d,stroke:#333,color:#fff
    style Sigstore fill:#7f8c8d,stroke:#333,color:#fff

    %% Internal Platform
    style OSNetwork fill:#7ed321,stroke:#333,color:#fff
    style OSRoutes fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style Tekton fill:#7ed321,stroke:#333,color:#fff
    style ZTWIM fill:#7ed321,stroke:#333,color:#fff
    style OSSCC fill:#7ed321,stroke:#333,color:#fff
