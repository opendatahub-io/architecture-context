graph TB
    subgraph UserEnv["USER ENVIRONMENT (Client-Side)"]
        SDK["CodeFlare SDK<br/>Python 3.9/3.11<br/>Runs in Workbench Pod"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer Token / kubeconfig<br/>AuthZ: RBAC"]
    end

    subgraph OperatorPlane["OPERATOR PLANE"]
        KubeRay["KubeRay Operator<br/>Watches: ray.io/v1 RayCluster"]
        AppWrapperCtrl["AppWrapper Controller<br/>Watches: workload.codeflare.dev/v1beta2"]
        Kueue["Kueue<br/>Manages: LocalQueue"]
    end

    subgraph IngressLayer["INGRESS LAYER"]
        Route["OpenShift Route<br/>ray-dashboard-{name}<br/>443/TCP → 8265/TCP<br/>TLS edge/passthrough<br/>OAuth Proxy"]
        K8sIngress["Kubernetes Ingress<br/>ray-dashboard-{name}<br/>80 or 443/TCP → 8265/TCP<br/>Optional TLS"]
    end

    subgraph DataPlane["DATA PLANE (User Namespace)"]
        subgraph RayCluster["Ray Cluster"]
            RayHead["Ray Head Pod<br/>{name}-head-svc (ClusterIP)"]
            RayWorkers["Ray Worker Pods"]
        end
        subgraph Ports["Head Service Ports"]
            GCS["6379/TCP<br/>GCS<br/>No Encryption"]
            Dashboard["8265/TCP<br/>Dashboard (HTTP)<br/>No Encryption (internal)"]
            ClientPort["10001/TCP<br/>Ray Client<br/>Optional mTLS"]
        end
    end

    subgraph Secrets["SECRETS / CERTIFICATES"]
        CACert["{cluster_name}-ca-secret-*<br/>Type: Opaque<br/>Contents: ca.key, ca.crt<br/>Auto-Rotate: No"]
        CABundle["odh-trusted-ca-bundle<br/>Type: ConfigMap<br/>Mounted in Ray pods"]
    end

    %% Client to Control Plane
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token<br/>CRD CRUD: RayCluster,<br/>AppWrapper, LocalQueue,<br/>Route, Ingress, Secret"| K8sAPI

    %% Client to Data Plane (via Ingress)
    SDK -->|"HTTPS/443<br/>TLS (edge/passthrough)<br/>Bearer Token (OAuth)"| Route
    SDK -->|"HTTP or HTTPS/80,443<br/>Optional TLS"| K8sIngress

    %% Client direct to Ray
    SDK -->|"TCP/10001<br/>mTLS (optional)<br/>Client Cert (RSA 2048)"| ClientPort

    %% Ingress to Ray
    Route -->|"HTTP/8265<br/>Internal"| Dashboard
    K8sIngress -->|"HTTP/8265<br/>Internal"| Dashboard

    %% Control Plane to Operators
    K8sAPI -.->|"CRD Watch"| KubeRay
    K8sAPI -.->|"CRD Watch"| AppWrapperCtrl

    %% Operators to Data Plane
    KubeRay -->|"Creates/Manages"| RayHead
    KubeRay -->|"Creates/Manages"| RayWorkers

    %% Internal Ray connections
    RayHead --- GCS
    RayHead --- Dashboard
    RayHead --- ClientPort
    RayWorkers -->|"TCP/6379<br/>No Encryption"| GCS

    %% Certificate references
    CACert -.->|"Used for mTLS"| ClientPort
    CABundle -.->|"TLS trust chain"| RayHead

    %% Styling
    classDef userenv fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e3a5f
    classDef controlplane fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#78350f
    classDef operatorplane fill:#d1fae5,stroke:#059669,stroke-width:2px,color:#064e3b
    classDef ingress fill:#ffe4e6,stroke:#e11d48,stroke-width:2px,color:#881337
    classDef dataplane fill:#e0e7ff,stroke:#4f46e5,stroke-width:2px,color:#312e81
    classDef secrets fill:#fde68a,stroke:#b45309,stroke-width:2px,color:#78350f

    class SDK userenv
    class K8sAPI controlplane
    class KubeRay,AppWrapperCtrl,Kueue operatorplane
    class Route,K8sIngress ingress
    class RayHead,RayWorkers,GCS,Dashboard,ClientPort dataplane
    class CACert,CABundle secrets
