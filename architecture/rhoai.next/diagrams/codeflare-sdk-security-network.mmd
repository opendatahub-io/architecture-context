graph TB
    subgraph UserEnv["USER ENVIRONMENT (Jupyter Notebook / Workbench)"]
        SDK["CodeFlare SDK<br/>(Python Library)<br/>Runs in user's process<br/>Uses user's K8s credentials"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / RBAC"]
    end

    subgraph Ingress["OPENSHIFT INGRESS"]
        DashRoute["ray-dashboard Route<br/>443/TCP HTTPS<br/>TLS edge/passthrough<br/>OpenShift OAuth"]
        ClientRoute["{name}-ingress Route<br/>10001/TCP<br/>TLS passthrough<br/>mTLS (optional)"]
    end

    subgraph RayCluster["RAY CLUSTER (Namespace: user-namespace)"]
        direction TB

        subgraph HeadSvc["{name}-head-svc - ClusterIP"]
            HeadGCS["Port 6379/TCP<br/>GCS (internal)<br/>No encryption"]
            HeadDash["Port 8265/TCP<br/>Ray Dashboard<br/>HTTP, TLS optional<br/>Bearer Token (OCP)"]
            HeadClient["Port 10001/TCP<br/>Ray Client<br/>TLS optional, mTLS optional"]
        end

        RayHead["Ray Head Pod<br/>ray:2.35.0<br/>Mounts: odh-trusted-ca-bundle"]
        RayWorkers["Ray Worker Pods<br/>ray:2.35.0<br/>Mounts: odh-trusted-ca-bundle"]

        RayHead --- HeadSvc
        RayHead -->|"Ray internal<br/>None / mTLS"| RayWorkers
    end

    subgraph Operators["PLATFORM OPERATORS"]
        KubeRay["KubeRay Operator<br/>Reconciles RayCluster"]
        CFOp["CodeFlare Operator<br/>Reconciles AppWrapper"]
        KueueCtrl["Kueue Controller<br/>Manages LocalQueues"]
    end

    %% Flows
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token<br/>CRD CRUD operations"| K8sAPI
    SDK -->|"HTTPS/443<br/>TLS<br/>Bearer Token<br/>Job submission"| DashRoute
    SDK -.->|"Ray/10001<br/>mTLS (optional)<br/>Client cert<br/>Interactive use"| ClientRoute

    DashRoute -->|"HTTP/8265<br/>Forward"| HeadDash
    ClientRoute -->|"Ray/10001<br/>Passthrough"| HeadClient

    K8sAPI -->|"Reconcile"| KubeRay
    K8sAPI -->|"Reconcile"| CFOp
    K8sAPI -->|"Schedule"| KueueCtrl

    %% Styling
    classDef userenv fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef raycluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operators fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef risk fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class SDK userenv
    class K8sAPI controlplane
    class DashRoute,ClientRoute ingress
    class RayHead,RayWorkers,HeadGCS,HeadDash,HeadClient raycluster
    class KubeRay,CFOp,KueueCtrl operators
