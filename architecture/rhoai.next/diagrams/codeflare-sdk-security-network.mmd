graph TB
    subgraph UserEnv["USER ENVIRONMENT (Trusted - Workbench)"]
        SDK["CodeFlare SDK<br/>(Python Library)<br/>Runs in Jupyter Workbench<br/>Auth: Bearer Token / kubeconfig"]
    end

    subgraph K8sLayer["KUBERNETES API LAYER"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>Bearer Token / kubeconfig"]
    end

    subgraph OperatorLayer["OPERATOR LAYER (Cluster-internal)"]
        direction LR
        CFOperator["CodeFlare Operator<br/>AppWrapper Controller<br/>Watches: AppWrapper CR"]
        KubeRayOp["KubeRay Operator<br/>Watches: RayCluster CR<br/>Creates: Pods, Services, Routes"]
        KueueCtrl["Kueue Controller<br/>Watches: LocalQueue, Workload<br/>Quota + Gang Scheduling"]
    end

    subgraph IngressLayer["INGRESS LAYER"]
        Route["OpenShift Route<br/>ray-dashboard-{cluster}<br/>443/TCP external → 8265/TCP internal<br/>TLS edge/passthrough<br/>Bearer Token (OpenShift OAuth)"]
    end

    subgraph RayCluster["RAY CLUSTER (Service Mesh / Namespace)"]
        direction TB

        subgraph HeadNode["Ray Head Node"]
            Dashboard["Dashboard<br/>8265/TCP HTTP"]
            ClientPort["Client Port<br/>10001/TCP gRPC<br/>Optional mTLS<br/>TLS client certs"]
            GCS["GCS Port<br/>6379/TCP<br/>No encryption"]
        end

        Workers["Ray Worker Nodes<br/>Connect to head via 6379/TCP<br/>Mounts: odh-trusted-ca-bundle"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io/modh/ray<br/>443/TCP HTTPS TLS 1.2+<br/>Public (no auth)"]
    end

    %% Flows
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token<br/>CRD CRUD + Secrets + Routes"| K8sAPI
    SDK -->|"HTTPS/443<br/>TLS<br/>Bearer Token<br/>Job submit + status"| Route
    SDK -->|"gRPC/10001<br/>Optional mTLS<br/>TLS client cert<br/>Interactive Ray session"| ClientPort

    K8sAPI --> CFOperator
    K8sAPI --> KubeRayOp
    K8sAPI --> KueueCtrl

    Route -->|"HTTP/8265<br/>No encryption<br/>(cluster-internal)"| Dashboard

    Workers -->|"TCP/6379<br/>No encryption"| GCS

    KubeRayOp -.->|"creates"| HeadNode
    KubeRayOp -.->|"creates"| Workers

    %% Styling
    classDef userenv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef raycluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px

    class SDK userenv
    class K8sAPI k8s
    class CFOperator,KubeRayOp,KueueCtrl operator
    class Route ingress
    class Dashboard,ClientPort,GCS,Workers raycluster
    class Registry external
