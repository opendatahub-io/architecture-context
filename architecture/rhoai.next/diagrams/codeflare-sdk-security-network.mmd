graph TB
    subgraph UserEnv["USER ENVIRONMENT (Jupyter Workbench)"]
        SDK["CodeFlare SDK<br/>(Python Client Library)<br/>Inherits user SA/Token"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route<br/>ray-dashboard-{cluster}<br/>443/TCP → 8265/TCP<br/>TLS edge/passthrough<br/>Bearer Token"]
        K8sIngress["Kubernetes Ingress<br/>{cluster}-ingress-*<br/>80 or 443/TCP → 8265/TCP<br/>Optional TLS"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph UserNS["Namespace: {user-namespace}"]
            RayHead["Ray Head Pod<br/>{cluster}-head-svc (ClusterIP)<br/>• 6379/TCP GCS (no encryption)<br/>• 8265/TCP Dashboard (HTTP)<br/>• 10001/TCP Client (gRPC, opt. mTLS)"]
            RayWorkers["Ray Worker Pods<br/>Connect to head:6379"]
        end

        subgraph Operators["Platform Operators"]
            KubeRay["KubeRay Operator<br/>Reconciles: RayCluster"]
            CFOp["CodeFlare Operator<br/>Reconciles: AppWrapper"]
            KueueCtrl["Kueue Controller<br/>Manages: LocalQueue quotas"]
        end
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Registry["quay.io/modh/ray<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Image registry"]
    end

    %% SDK to K8s API
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (OAuth)<br/>CRUD: RayCluster, AppWrapper<br/>READ: LocalQueue, Route, Secret, Ingress"| K8sAPI

    %% SDK to Ray Dashboard via Route
    SDK -->|"HTTPS/443 (via Route)<br/>TLS edge/passthrough<br/>Bearer Token<br/>Job submission + status"| Route
    Route -->|"HTTP/8265<br/>Internal"| RayHead

    %% SDK to Ray Client (mTLS)
    SDK -->|"gRPC/10001<br/>Optional mTLS<br/>Client TLS cert<br/>Interactive Ray session"| RayHead

    %% Operators reconciliation
    K8sAPI -.->|"Reconcile"| KubeRay
    K8sAPI -.->|"Reconcile"| CFOp
    K8sAPI -.->|"Manage quotas"| KueueCtrl
    KubeRay -.->|"Creates Pods,<br/>Services"| RayHead
    KubeRay -.->|"Creates"| RayWorkers

    %% Image pull (by kubelet, not SDK)
    RayHead -.->|"Image pull<br/>HTTPS/443"| Registry

    %% Styling
    classDef userenv fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#333
    classDef controlplane fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef operator fill:#e8eaf6,stroke:#283593,stroke-width:2px,color:#333
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class SDK userenv
    class K8sAPI controlplane
    class Route,K8sIngress ingress
    class RayHead,RayWorkers internal
    class KubeRay,CFOp,KueueCtrl operator
    class Registry external
