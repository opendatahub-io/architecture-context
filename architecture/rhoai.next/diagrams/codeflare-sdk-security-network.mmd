graph TB
    subgraph UserEnv["USER ENVIRONMENT (Trusted - Workbench Pod)"]
        SDK["CodeFlare SDK<br/>Python Client Library<br/>Auth: Bearer Token / kubeconfig / SA Token<br/>CA: CF_SDK_CA_CERT_PATH"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC enforced"]
    end

    subgraph Operators["PLATFORM OPERATORS (Internal)"]
        direction TB
        KubeRay["KubeRay Operator<br/>Watches: ray.io/v1 RayCluster"]
        AppWrapperCtrl["AppWrapper Controller<br/>Watches: workload.codeflare.dev/v1beta2"]
        KueueCtrl["Kueue Controller<br/>Manages: LocalQueue queuing"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes / K8s Ingress)"]
        DashRoute["ray-dashboard-{name}<br/>Route: 443/TCP HTTPS<br/>TLS: edge/passthrough"]
        ClientRoute["{name}-ingress-*<br/>Route: 10001/TCP<br/>TLS: Optional"]
    end

    subgraph RayCluster["RAY CLUSTER SERVICES (User Namespace)"]
        direction TB
        HeadSvc["{name}-head-svc<br/>ClusterIP"]
        RayDash["Ray Dashboard<br/>8265/TCP HTTP"]
        RayGCS["Ray GCS Server<br/>6379/TCP TCP"]
        RayClientSvc["Ray Client Server<br/>10001/TCP TCP<br/>Optional mTLS"]

        HeadSvc --- RayDash
        HeadSvc --- RayGCS
        HeadSvc --- RayClientSvc
    end

    %% SDK to K8s API
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token<br/>CRD CRUD: RayCluster,<br/>AppWrapper, LocalQueue,<br/>Route, Secret, Ingress"| K8sAPI

    %% K8s API to Operators
    K8sAPI -->|"Watch events"| KubeRay
    K8sAPI -->|"Watch events"| AppWrapperCtrl
    K8sAPI -->|"Watch events"| KueueCtrl

    %% Operators create Ray cluster
    KubeRay -->|"Creates Ray Pods<br/>SA: kuberay-operator"| RayCluster

    %% SDK to Ray via Routes
    SDK -->|"HTTPS/443<br/>TLS<br/>Bearer Token (OpenShift)"| DashRoute
    DashRoute -->|"HTTP/8265<br/>Internal"| RayDash

    SDK -->|"TCP/10001<br/>mTLS (client cert)<br/>RSA 2048 + SHA-256"| ClientRoute
    ClientRoute -->|"TCP/10001<br/>Internal"| RayClientSvc

    %% Styling
    classDef userenv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operators fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef raycluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class SDK userenv
    class K8sAPI k8scontrol
    class KubeRay,AppWrapperCtrl,KueueCtrl operators
    class DashRoute,ClientRoute ingress
    class HeadSvc,RayDash,RayGCS,RayClientSvc raycluster
