graph TB
    subgraph FMSHFTuning["FMS HF Tuning Container Image"]
        direction TB

        subgraph EntryPoint["Entry Point"]
            AccLaunch["accelerate_launch.py<br/>Container Entry Point<br/>JSON config parsing<br/>Multi-GPU auto-detection"]
        end

        subgraph Core["Core Training"]
            SFTTrainer["sft_trainer.py<br/>Training Orchestration<br/>Model loading, tokenization<br/>SFTTrainer initialization"]
            SumLoss["sum_loss_sft_trainer.py<br/>Custom SFTTrainer<br/>Sum-based loss reduction"]
        end

        subgraph DataPipeline["Data Processing Pipeline"]
            DataConfig["data_config.py<br/>Data Configuration"]
            DataHandlers["data_handlers.py<br/>Handler Chain Pattern"]
            DataProcessors["data_processors.py<br/>DataPreProcessor"]
            Collators["collators.py<br/>VisionDataCollator"]
            TokenizerUtils["tokenizer_utils.py<br/>Tokenizer Management"]
        end

        subgraph Config["Configuration"]
            Configs["configs.py<br/>Model, Data, Training"]
            PeftConfig["peft_config.py<br/>LoRA, QLoRA, Prompt Tuning"]
            AccelConfig["acceleration_configs/<br/>QLoRA, Fused LoRA<br/>Padding-free, ScatterMoE, ODM"]
        end

        subgraph Trackers["Experiment Tracking"]
            TrackerFactory["tracker_factory.py<br/>Pluggable Backend Selection"]
            AimTracker["Aim Tracker"]
            MLflowTracker["MLflow Tracker"]
            ClearMLTracker["ClearML Tracker"]
            FileTracker["File Logger (JSONL)"]
            HFScanner["HFResourceScanner"]
        end

        subgraph TrainerCtrl["Trainer Controller"]
            Controller["callback.py<br/>Rule-driven Loop Control"]
            Patience["patience.py<br/>Debounce Mechanism"]
            Metrics["controllermetrics/<br/>Loss, EvalMetrics<br/>TrainingState"]
        end

        subgraph Recommender["Recommender"]
            FMSRecommender["fms-recommender.py<br/>Config Optimization"]
        end
    end

    %% Internal flows
    AccLaunch -->|"initializes"| SFTTrainer
    AccLaunch -->|"reads"| Configs
    SFTTrainer -->|"uses"| SumLoss
    SFTTrainer -->|"processes data via"| DataProcessors
    DataProcessors -->|"applies"| DataHandlers
    DataProcessors -->|"reads"| DataConfig
    DataHandlers -->|"uses"| TokenizerUtils
    DataHandlers -->|"uses"| Collators
    SFTTrainer -->|"configures"| PeftConfig
    SFTTrainer -->|"loads"| AccelConfig
    SFTTrainer -->|"registers"| TrackerFactory
    TrackerFactory -->|"creates"| AimTracker
    TrackerFactory -->|"creates"| MLflowTracker
    TrackerFactory -->|"creates"| ClearMLTracker
    TrackerFactory -->|"creates"| FileTracker
    TrackerFactory -->|"creates"| HFScanner
    SFTTrainer -->|"registers"| Controller
    Controller -->|"uses"| Patience
    Controller -->|"evaluates"| Metrics
    FMSRecommender -->|"generates config for"| AccLaunch

    %% External interactions
    KFTO["Kubeflow Training Operator<br/>(PyTorchJob CR)"] -->|"creates & manages"| AccLaunch
    Kueue["Kueue<br/>Queue Scheduling"] -.->|"schedules"| KFTO

    SFTTrainer -->|"downloads models"| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    SFTTrainer -->|"reads/writes"| PVC["PersistentVolumeClaim<br/>/data/input, /data/output"]
    SFTTrainer -->|"GPU compute"| CUDA["NVIDIA CUDA/cuDNN<br/>PCIe/NVLink"]
    SFTTrainer -->|"FSDP sync<br/>29500/TCP plaintext"| FSDPWorkers["FSDP Worker Pods"]

    AccLaunch -->|"post-processes"| vLLM["vLLM Adapters<br/>safetensors"]

