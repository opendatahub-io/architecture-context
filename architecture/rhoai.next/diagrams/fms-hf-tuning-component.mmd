graph TB
    subgraph "fms-hf-tuning Component"
        direction TB
        subgraph "Container Entrypoint"
            AccLaunch["accelerate_launch.py<br/>Container CMD<br/>Parses JSON config,<br/>constructs accelerate args"]
        end

        subgraph "Core Training Engine"
            SFTTrainer["sft_trainer.py<br/>SFTTrainer wrapper<br/>PEFT + acceleration +<br/>tracker integrations"]
        end

        subgraph "Data Processing Pipeline"
            DataPreprocessor["Data Preprocessor<br/>Handlers: pretokenized,<br/>single-seq, chat, multi-turn,<br/>vision-language"]
        end

        subgraph "Training Control"
            TrainerController["Trainer Controller<br/>YAML-driven policy engine<br/>Early stopping, loss threshold,<br/>patience-based rules"]
        end

        subgraph "Experiment Tracking"
            TrackerSystem["Tracker System<br/>File, AimStack, MLflow,<br/>ClearML, HF Resource Scanner"]
        end

        subgraph "Acceleration Configs"
            AccelConfigs["fms-acceleration<br/>QLoRA, padding-free,<br/>multipack, ScatterMoE, ODM"]
        end

        subgraph "Utilities"
            Recommender["fms-recommender<br/>Tuning config recommender"]
        end
    end

    %% Internal flows
    AccLaunch -->|"subprocess launch"| SFTTrainer
    SFTTrainer -->|"loads data via"| DataPreprocessor
    SFTTrainer -->|"applies callbacks"| TrainerController
    SFTTrainer -->|"reports metrics"| TrackerSystem
    SFTTrainer -->|"applies optimizations"| AccelConfigs

    %% External inputs
    ConfigJSON["JSON Config<br/>(env var or file)"] -->|"parsed by"| AccLaunch
    PVC_Data["PVC<br/>Training Data"] -->|"mounted"| DataPreprocessor
    PVC_Model["PVC<br/>Model Weights"] -->|"mounted"| SFTTrainer
    GPU["NVIDIA GPU<br/>(CUDA)"] -->|"nvidia.com/gpu"| SFTTrainer

    %% External outputs
    SFTTrainer -->|"saves to"| PVC_Output["PVC<br/>Output/Checkpoints"]
    SFTTrainer -->|"writes"| TermLog["/dev/termination-log"]

    %% Platform integration
    KFTO["Kubeflow Training Operator"] -->|"creates PyTorchJob<br/>running this image"| AccLaunch
    Kueue["Kueue"] -->|"queue scheduling"| KFTO

    %% Styling
    style AccLaunch fill:#4a90e2,stroke:#333,color:#fff
    style SFTTrainer fill:#4a90e2,stroke:#333,color:#fff
    style DataPreprocessor fill:#4a90e2,stroke:#333,color:#fff
    style TrainerController fill:#4a90e2,stroke:#333,color:#fff
    style TrackerSystem fill:#4a90e2,stroke:#333,color:#fff
    style AccelConfigs fill:#4a90e2,stroke:#333,color:#fff
    style Recommender fill:#4a90e2,stroke:#333,color:#fff
    style ConfigJSON fill:#f5a623,stroke:#333
    style PVC_Data fill:#f5a623,stroke:#333
    style PVC_Model fill:#f5a623,stroke:#333
    style PVC_Output fill:#f5a623,stroke:#333
    style GPU fill:#e8e8e8,stroke:#333
    style TermLog fill:#e8e8e8,stroke:#333
    style KFTO fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
