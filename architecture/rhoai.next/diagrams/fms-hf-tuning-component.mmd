graph TB
    subgraph FMS["FMS HF Tuning Container (PyTorchJob Pod)"]
        direction TB

        subgraph EntryPoint["Entry Point"]
            AccLaunch["accelerate_launch.py<br/>CLI Wrapper<br/>JSON config parsing<br/>Multi-GPU auto-detection"]
        end

        subgraph Core["Core Training"]
            SFTTrainer["sft_trainer.py<br/>Training Orchestration<br/>Model loading, tokenization<br/>SFTTrainer init, model saving"]
            SumLoss["sum_loss_sft_trainer.py<br/>Custom SFTTrainer<br/>Sum-based loss reduction"]
        end

        subgraph DataPipeline["Data Processing Pipeline"]
            DataConfig["data_config.py<br/>Data Configuration"]
            DataHandlers["data_handlers.py<br/>Handler Chain Pattern"]
            DataProcessors["data_processors.py<br/>DataPreProcessor"]
            Collators["collators.py<br/>VisionDataCollator"]
            TokenizerUtils["tokenizer_utils.py<br/>Tokenizer Management"]
        end

        subgraph Config["Configuration"]
            Configs["configs.py<br/>Model/Data/Training"]
            PEFTConfig["peft_config.py<br/>LoRA/QLoRA/PromptTuning"]
            AccelConfig["acceleration_configs/<br/>QLoRA, Fused LoRA<br/>Padding-free, ScatterMoE, ODM"]
            TrackerConfig["tracker_configs.py<br/>Tracker Settings"]
        end

        subgraph Trackers["Experiment Tracking"]
            TrackerFactory["tracker_factory.py<br/>Pluggable Backend Selection"]
            AimTracker["aimstack_tracker.py"]
            MLflowTracker["mlflow_tracker.py"]
            ClearMLTracker["clearml_tracker.py"]
            FileLogger["filelogging_tracker.py<br/>JSONL Output"]
            HFScanner["hf_resource_scanner.py<br/>GPU/CPU Monitoring"]
        end

        subgraph TrainerCtrl["Trainer Controller Framework"]
            CtrlCallback["callback.py<br/>Rule Engine"]
            CtrlPatience["patience.py<br/>Debounce Logic"]
            CtrlOps["operations/<br/>Early Stop, Eval, Log"]
            CtrlMetrics["controllermetrics/<br/>Loss, Eval, History"]
        end

        Recommender["fms-recommender.py<br/>Config Optimization"]
    end

    %% Internal flows
    AccLaunch -->|"launches"| SFTTrainer
    SFTTrainer -->|"uses"| SumLoss
    SFTTrainer -->|"reads config"| Configs
    SFTTrainer -->|"loads data"| DataProcessors
    DataProcessors -->|"applies"| DataHandlers
    DataHandlers -->|"uses"| DataConfig
    DataProcessors -->|"tokenizes"| TokenizerUtils
    DataProcessors -->|"collates"| Collators
    SFTTrainer -->|"configures PEFT"| PEFTConfig
    SFTTrainer -->|"initializes"| TrackerFactory
    TrackerFactory --> AimTracker
    TrackerFactory --> MLflowTracker
    TrackerFactory --> ClearMLTracker
    TrackerFactory --> FileLogger
    TrackerFactory --> HFScanner
    SFTTrainer -->|"attaches"| CtrlCallback
    CtrlCallback -->|"evaluates rules"| CtrlMetrics
    CtrlCallback -->|"debounces"| CtrlPatience
    CtrlCallback -->|"triggers"| CtrlOps
    AccLaunch -->|"reads"| AccelConfig
    Recommender -.->|"generates config for"| AccLaunch

    %% External interactions
    KFTO["Kubeflow Training Operator"] -->|"creates PyTorchJob"| AccLaunch
    AccLaunch -->|"downloads models"| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    SFTTrainer -->|"reads"| PVCIn["/data/input (PVC)"]
    SFTTrainer -->|"writes"| PVCOut["/data/output (PVC)"]
    SFTTrainer -->|"FSDP gradient sync<br/>29500/TCP plaintext"| Workers["Other FSDP Workers"]
    AccLaunch -->|"post-processes<br/>vLLM adapters"| PVCOut

    %% Styling
    style FMS fill:#e8f4f8,stroke:#4a90e2,stroke-width:3px
    style EntryPoint fill:#d5e8d4,stroke:#82b366
    style Core fill:#fff2cc,stroke:#d6b656
    style DataPipeline fill:#dae8fc,stroke:#6c8ebf
    style Config fill:#f8cecc,stroke:#b85450
    style Trackers fill:#e1d5e7,stroke:#9673a6
    style TrainerCtrl fill:#ffe6cc,stroke:#d79b00
    style KFTO fill:#999,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style PVCIn fill:#e8e8e8,stroke:#666
    style PVCOut fill:#e8e8e8,stroke:#666
    style Workers fill:#e8e8e8,stroke:#666
