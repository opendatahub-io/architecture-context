graph TB
    subgraph "fms-hf-tuning Component"
        direction TB

        subgraph "Entrypoint"
            AccelLaunch["accelerate_launch.py<br/>Container Entrypoint<br/>Wraps accelerate launch"]
        end

        subgraph "Core Training Engine"
            SFTTrainer["tuning.sft_trainer<br/>SFT Training Engine<br/>Model loading, PEFT, data preprocessing,<br/>SFTTrainer orchestration, model saving"]
            SumLossTrainer["SumLossSFTTrainer<br/>Custom SFTTrainer subclass<br/>Sum-reduction cross-entropy loss"]
        end

        subgraph "Data Pipeline"
            DataModule["tuning.data<br/>Data Preprocessing Pipeline<br/>Format detection, chat templates,<br/>tokenization, multimodal, ODM"]
        end

        subgraph "Configuration"
            Config["tuning.config<br/>Configuration Dataclasses<br/>Model, data, training, PEFT,<br/>quantization parameters"]
            AccelConfig["acceleration_configs<br/>Acceleration Framework Config<br/>Quantized LoRA, fused ops,<br/>padding-free attention, multipack"]
        end

        subgraph "Tracking & Control"
            Trackers["tuning.trackers<br/>Experiment Tracking<br/>File, AimStack, MLflow,<br/>ClearML, HF Resource Scanner"]
            TrainerController["tuning.trainercontroller<br/>Trainer Controller Framework<br/>YAML rules & metrics<br/>for training loop control"]
        end

        subgraph "Utilities"
            Recommender["fms-recommender<br/>Tuning Config Recommender"]
        end

        AccelLaunch -->|"launches"| SFTTrainer
        SFTTrainer -->|"alternative"| SumLossTrainer
        SFTTrainer -->|"preprocesses data"| DataModule
        SFTTrainer -->|"reads config"| Config
        SFTTrainer -->|"optional acceleration"| AccelConfig
        SFTTrainer -->|"reports metrics"| Trackers
        SFTTrainer -->|"training callbacks"| TrainerController
    end

    %% External Orchestration
    KFTO["Kubeflow Training Operator<br/>(PyTorchJob)"] -->|"creates Pod with config"| AccelLaunch
    Kueue["Kueue<br/>(Queue Management)"] -.->|"optional scheduling"| KFTO

    %% External Data Sources
    SFTTrainer -->|"downloads models/datasets<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    DataModule -->|"loads training data"| PVC["PVC<br/>(Persistent Volume)"]
    SFTTrainer -->|"saves model artifacts"| PVC

    %% GPU
    SFTTrainer -->|"CUDA/NCCL"| GPU["GPU(s)<br/>PyTorch FSDP"]

    %% Acceleration Plugins
    AccelConfig -->|"loads plugins"| FMSAccel["fms-acceleration<br/>Plugins"]

    %% Tracking Backends
    Trackers -->|"HTTP"| AimStack["AimStack Server"]
    Trackers -->|"HTTP/HTTPS"| MLflow["MLflow Server"]
    Trackers -->|"HTTPS"| ClearML["ClearML Server"]

    %% Styling
    style AccelLaunch fill:#4a90e2,color:#fff
    style SFTTrainer fill:#4a90e2,color:#fff
    style SumLossTrainer fill:#4a90e2,color:#fff
    style DataModule fill:#4a90e2,color:#fff
    style Config fill:#4a90e2,color:#fff
    style AccelConfig fill:#4a90e2,color:#fff
    style Trackers fill:#4a90e2,color:#fff
    style TrainerController fill:#4a90e2,color:#fff
    style Recommender fill:#4a90e2,color:#fff
    style KFTO fill:#7ed321,color:#fff
    style Kueue fill:#7ed321,color:#fff
    style HFHub fill:#f5a623,color:#fff
    style PVC fill:#f5a623,color:#fff
    style GPU fill:#e8e8e8
    style FMSAccel fill:#7ed321,color:#fff
    style AimStack fill:#999,color:#fff
    style MLflow fill:#999,color:#fff
    style ClearML fill:#999,color:#fff
