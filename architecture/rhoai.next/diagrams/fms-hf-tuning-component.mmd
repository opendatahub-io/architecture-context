graph TB
    subgraph KFTO["Kubeflow Training Operator"]
        PyTorchJob["PyTorchJob CR"]
    end

    subgraph FMSHFTuning["FMS HF Tuning Container"]
        direction TB

        subgraph EntryPoint["Entry Point"]
            AccelerateLaunch["accelerate_launch.py<br/>CLI Wrapper"]
        end

        subgraph Core["Core Training"]
            SFTTrainer["sft_trainer.py<br/>Training Orchestration"]
            SumLossSFT["SumLossSFTTrainer<br/>Custom Loss Reduction"]
        end

        subgraph DataPipeline["Data Pipeline"]
            DataConfig["data_config.py<br/>Data Configuration"]
            DataHandlers["data_handlers.py<br/>Handler Chain"]
            DataProcessors["data_processors.py<br/>Preprocessing"]
            Collators["collators.py<br/>VisionDataCollator"]
        end

        subgraph ConfigMgmt["Configuration"]
            Configs["configs.py<br/>Training Config"]
            PEFTConfig["peft_config.py<br/>LoRA/QLoRA/PromptTuning"]
            AccelConfig["acceleration_configs/<br/>FMS Acceleration"]
        end

        subgraph Tracking["Experiment Tracking"]
            TrackerFactory["tracker_factory.py"]
            AimTracker["Aim Tracker"]
            MLflowTracker["MLflow Tracker"]
            ClearMLTracker["ClearML Tracker"]
            FileLogger["File Logger (JSONL)"]
        end

        subgraph TrainerCtrl["Trainer Controller"]
            ControllerCallback["callback.py<br/>Rule Engine"]
            Patience["patience.py<br/>Debounce"]
            Operations["operations/<br/>HF Controls, Logging"]
            Metrics["controllermetrics/<br/>Loss, EvalMetrics"]
        end
    end

    subgraph External["External Services"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
        PVC_Input["PVC /data/input"]
        PVC_Output["PVC /data/output"]
        GPU["NVIDIA GPU<br/>CUDA 12.1"]
    end

    subgraph FSDPWorkers["FSDP Distributed Training"]
        Worker0["Worker 0"]
        WorkerN["Worker N"]
        Worker0 <-->|29500/TCP<br/>plaintext c10d| WorkerN
    end

    %% Flow
    PyTorchJob -->|launches| AccelerateLaunch
    AccelerateLaunch -->|configures & launches| SFTTrainer
    SFTTrainer -->|uses| SumLossSFT
    SFTTrainer -->|loads data via| DataConfig
    DataConfig --> DataHandlers
    DataHandlers --> DataProcessors
    DataProcessors --> Collators
    SFTTrainer -->|reads config| Configs
    Configs --> PEFTConfig
    Configs --> AccelConfig
    SFTTrainer -->|logs metrics via| TrackerFactory
    TrackerFactory --> AimTracker
    TrackerFactory --> MLflowTracker
    TrackerFactory --> ClearMLTracker
    TrackerFactory --> FileLogger
    SFTTrainer -->|dynamic control| ControllerCallback
    ControllerCallback --> Patience
    ControllerCallback --> Operations
    ControllerCallback --> Metrics

    %% External connections
    SFTTrainer -->|downloads models| HFHub
    SFTTrainer -->|reads training data| PVC_Input
    SFTTrainer -->|saves checkpoints| PVC_Output
    SFTTrainer -->|trains on| GPU
    SFTTrainer -->|distributes via| Worker0

    %% Styling
    style AccelerateLaunch fill:#4a90e2,stroke:#333,color:#fff
    style SFTTrainer fill:#4a90e2,stroke:#333,color:#fff
    style SumLossSFT fill:#4a90e2,stroke:#333,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#e8e8e8,stroke:#333
    style PVC_Input fill:#e8e8e8,stroke:#333
    style PVC_Output fill:#e8e8e8,stroke:#333
    style GPU fill:#e8e8e8,stroke:#333
    style TrackerFactory fill:#7ed321,stroke:#333
    style ControllerCallback fill:#9b59b6,stroke:#333,color:#fff
    style DataConfig fill:#3498db,stroke:#333,color:#fff
