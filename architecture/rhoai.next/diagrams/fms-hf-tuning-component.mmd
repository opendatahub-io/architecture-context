graph TB
    subgraph "fms-hf-tuning Component"
        direction TB

        subgraph Entrypoint["Container Entrypoint"]
            AccelLaunch["accelerate_launch.py<br/>Parses JSON config<br/>Configures Accelerate args<br/>Invokes distributed training"]
        end

        subgraph Core["Core Training Engine"]
            SFTTrainer["sft_trainer.py<br/>Wraps HF SFTTrainer<br/>PEFT integration<br/>Acceleration plugins"]
        end

        subgraph DataPipeline["Data Processing Pipeline"]
            DataPreprocessor["data preprocessor<br/>Handlers: MAP, FILTER,<br/>REMOVE, SELECT, RENAME"]
            DataFormats["Supported Formats:<br/>Pretokenized | Jinja Template<br/>Chat Style | Multi-turn<br/>Vision-Language"]
            DataPreprocessor --> DataFormats
        end

        subgraph TrainerCtrl["Trainer Controller Framework"]
            Controller["YAML-driven policy engine<br/>Early stopping, loss thresholds<br/>Patience-based rules"]
        end

        subgraph Trackers["Experiment Tracking"]
            TrackerFactory["tracker_factory.py"]
            FileLogger["File Logger"]
            AimTracker["AimStack"]
            MLflowTracker["MLflow"]
            ClearMLTracker["ClearML"]
            HFScanner["HF Resource Scanner"]
            TrackerFactory --> FileLogger
            TrackerFactory --> AimTracker
            TrackerFactory --> MLflowTracker
            TrackerFactory --> ClearMLTracker
            TrackerFactory --> HFScanner
        end

        subgraph AccelConfigs["Acceleration Configs"]
            QLoRA["QLoRA<br/>(AutoGPTQ / BnB)"]
            PaddingFree["Padding-Free<br/>Flash Attention"]
            Multipack["Multipack<br/>Distributed Packing"]
            ScatterMoE["ScatterMoE<br/>Parallel MoE"]
            ODM["Online Data<br/>Mixing"]
        end

        subgraph Recommender["fms-recommender CLI"]
            RecommenderCLI["Parses training commands<br/>Suggests optimized settings"]
        end

        AccelLaunch -->|"subprocess"| SFTTrainer
        SFTTrainer --> DataPreprocessor
        SFTTrainer --> Controller
        SFTTrainer --> TrackerFactory
        SFTTrainer -.->|"optional"| AccelConfigs
    end

    %% External Inputs
    ConfigJSON["ConfigMap<br/>/etc/config/config.json"] -->|"JSON config"| AccelLaunch
    PVCModel["PVC<br/>Model Weights"] -->|"mount"| SFTTrainer
    PVCData["PVC<br/>Training Data"] -->|"mount"| DataPreprocessor
    GPU["NVIDIA GPU<br/>(CUDA)"] -->|"PCIe/NVLink"| SFTTrainer

    %% External Outputs
    SFTTrainer -->|"checkpoints"| PVCOutput["PVC<br/>Output/Checkpoints"]
    SFTTrainer -->|"error details"| TermLog["/dev/termination-log"]

    %% Orchestration
    KFTO["Kubeflow Training Operator<br/>(KFTO)"] -->|"creates PyTorchJob"| AccelLaunch
    Kueue["Kueue"] -.->|"queue scheduling"| KFTO

    %% External Services
    SFTTrainer -->|"HTTPS/443<br/>Bearer Token"| HFHub["HuggingFace Hub"]

    %% Styling
    style AccelLaunch fill:#4a90e2,color:#fff
    style SFTTrainer fill:#4a90e2,color:#fff
    style DataPreprocessor fill:#4a90e2,color:#fff
    style Controller fill:#4a90e2,color:#fff
    style TrackerFactory fill:#4a90e2,color:#fff
    style RecommenderCLI fill:#4a90e2,color:#fff
    style KFTO fill:#7ed321,color:#fff
    style Kueue fill:#7ed321,color:#fff
    style GPU fill:#e8e8e8,stroke:#333
    style HFHub fill:#f5a623,color:#fff
    style ConfigJSON fill:#f5a623,color:#fff
    style PVCModel fill:#e8e8e8,stroke:#333
    style PVCData fill:#e8e8e8,stroke:#333
    style PVCOutput fill:#e8e8e8,stroke:#333
    style TermLog fill:#e8e8e8,stroke:#333
    style QLoRA fill:#9b59b6,color:#fff
    style PaddingFree fill:#9b59b6,color:#fff
    style Multipack fill:#9b59b6,color:#fff
    style ScatterMoE fill:#9b59b6,color:#fff
    style ODM fill:#9b59b6,color:#fff
