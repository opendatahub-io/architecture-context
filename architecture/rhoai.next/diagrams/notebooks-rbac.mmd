graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["No RBAC resources defined<br/>in the Notebooks repository.<br/>RBAC is managed externally."]
    end

    subgraph AuthArchitecture["Authentication Architecture (Runtime)"]
        direction TB

        User["Data Scientist / User"]
        OAuth["OAuth Provider<br/>(OpenShift)"]

        subgraph PodAuth["Workbench Pod Authentication"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(Injected by ODH Notebook Controller)"]
            WorkbenchApp["Workbench Application<br/>(JupyterLab / code-server / RStudio)<br/>--auth=none"]
        end

        subgraph ManagedBy["RBAC Managed By"]
            NotebookCtrlRBAC["ODH Notebook Controller<br/>- Injects kube-rbac-proxy sidecar<br/>- Creates HTTPRoute/Route<br/>- Mounts CA bundles"]
            OperatorRBAC["rhods-operator<br/>- Deploys ImageStreams<br/>- Manages namespace RBAC"]
        end
    end

    User -->|"OAuth login<br/>HTTPS/443"| OAuth
    OAuth -->|"Token"| User
    User -->|"OAuth token<br/>HTTPS/8443"| KubeRBACProxy
    KubeRBACProxy -->|"Validates token<br/>against OpenShift API"| OAuth
    KubeRBACProxy -->|"Authorized:<br/>HTTP plaintext<br/>localhost"| WorkbenchApp

    NotebookCtrlRBAC -->|"injects"| KubeRBACProxy
    OperatorRBAC -->|"deploys"| PodAuth

    subgraph BuildSecrets["Build-Time Secrets"]
        RHELSub["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription<br/>for RStudio BuildConfig<br/>Provisioned: Manual (admin)<br/>Auto-Rotate: No"]
    end

    subgraph SupplyChain["Supply Chain Security"]
        Hermetic["Hermetic Builds (Konflux)<br/>- No network during build<br/>- cachi2 prefetched deps<br/>- Hash verification via pylock<br/>- 3-day exclude-newer window"]
        DigestPin["Image Digest Pinning<br/>- All ImageStreams use @sha256:<br/>- Immutable deployments<br/>- Traceable via commit.env"]
    end

    subgraph AccessPolicy["Access Policy"]
        NamespaceAccess["Namespace-Level Access<br/>User must have access to<br/>the namespace to use workbench"]
        MethodsAllowed["Methods: GET, POST, WebSocket<br/>Enforcement: kube-rbac-proxy<br/>Applies to: All workbench UIs"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style AuthArchitecture fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PodAuth fill:#d5e8d4,stroke:#82b366
    style ManagedBy fill:#dae8fc,stroke:#6c8ebf
    style BuildSecrets fill:#f8cecc,stroke:#b85450
    style SupplyChain fill:#e1d5e7,stroke:#9673a6
    style AccessPolicy fill:#fff2cc,stroke:#d6b656
    style User fill:#4a90e2,stroke:#333,color:#fff
    style OAuth fill:#f5a623,stroke:#333
    style KubeRBACProxy fill:#ff6b6b,stroke:#333,color:#fff
    style WorkbenchApp fill:#7ed321,stroke:#333
