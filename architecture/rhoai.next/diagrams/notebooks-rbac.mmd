graph TD
    subgraph RepoScope["Notebooks Repository Scope"]
        direction TB
        Note["This repository defines NO RBAC resources.<br/>RBAC for deployed notebooks is managed by<br/>ODH Notebook Controller and platform operator."]
    end

    subgraph RuntimeRBAC["Runtime RBAC (Managed by ODH Notebook Controller)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts (per notebook)"]
            SA["{notebook-name}<br/>Namespace: {user-namespace}"]
        end

        subgraph AuthEnforcement["Authentication Enforcement"]
            KRBAC["kube-rbac-proxy Sidecar<br/>Port: 8443/TCP HTTPS<br/>Injected by: ODH Notebook Controller"]
        end

        subgraph AuthMechanisms["Auth Mechanisms"]
            OIDC["OAuth2 / OpenID Connect<br/>All endpoints<br/>Policy: User must have<br/>RBAC access to Notebook CR"]
        end

        subgraph ProtectedEndpoints["Protected Endpoints"]
            JLEndpoint["JupyterLab<br/>8888/TCP HTTP<br/>/lab, /api/*"]
            CSEndpoint["code-server<br/>8787/TCP HTTP<br/>/ (via nginx)"]
        end
    end

    subgraph BuildRBAC["Build-Time Security"]
        direction TB

        subgraph BuildSecurity["Build Hermeticity"]
            RPMLock["rpms.lock.yaml<br/>OS package pinning"]
            PyLock["pylock.{flavor}.toml<br/>Python dep pinning (PEP 751)"]
            GoSum["go.sum<br/>Go module pinning"]
            NpmLock["package-lock.json<br/>npm package pinning"]
        end

        subgraph SupplyChain["Supply Chain"]
            Hermetic["Hermetic Builds<br/>--no-index (Python)<br/>GPG-verified RPMs<br/>Cached GOMODCACHE<br/>Offline npm"]
            FIPS["FIPS Compliance<br/>CGO_ENABLED=1<br/>-tags strictfipsruntime<br/>(mongocli Go binary)"]
        end
    end

    %% Auth flow
    OIDC -->|enforced by| KRBAC
    KRBAC -->|protects| JLEndpoint
    KRBAC -->|protects| CSEndpoint
    SA -->|mounted in| JLEndpoint
    SA -->|mounted in| CSEndpoint

    %% Build security
    RPMLock -->|ensures| Hermetic
    PyLock -->|ensures| Hermetic
    GoSum -->|ensures| Hermetic
    NpmLock -->|ensures| Hermetic

    %% Styling
    classDef noteStyle fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    classDef saStyle fill:#4a90e2,stroke:#2c5f8a,stroke-width:2px,color:#fff
    classDef authStyle fill:#ff6b6b,stroke:#cc0000,stroke-width:2px,color:#fff
    classDef endpointStyle fill:#7ed321,stroke:#5a9e18,stroke-width:2px
    classDef lockStyle fill:#e8e8e8,stroke:#666,stroke-width:1px
    classDef securityStyle fill:#f5a623,stroke:#c7851a,stroke-width:2px

    class Note noteStyle
    class SA saStyle
    class KRBAC,OIDC authStyle
    class JLEndpoint,CSEndpoint endpointStyle
    class RPMLock,PyLock,GoSum,NpmLock lockStyle
    class Hermetic,FIPS securityStyle
