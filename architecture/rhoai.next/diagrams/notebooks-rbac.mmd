graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Note: No RBAC resources are defined<br/>in the Notebooks repository itself.<br/>All RBAC is managed by the ODH Notebook Controller<br/>and platform operator."]
    end

    subgraph AuthArchitecture["Authentication & Authorization Architecture"]
        direction TB

        subgraph ExternalAccess["External User Access"]
            Browser["Data Scientist<br/>(Browser)"]
        end

        subgraph OAuthFlow["OAuth Flow (managed by Notebook Controller)"]
            Route["OpenShift Route<br/>443/TCP HTTPS"]
            OAuth["OpenShift OAuth<br/>OIDC Provider"]
        end

        subgraph PodBoundary["Pod Security Boundary"]
            KubeRBAC["kube-rbac-proxy Sidecar<br/>Injected by Notebook Controller<br/>8443/TCP HTTPS"]

            subgraph AuthChecks["Authorization Checks"]
                TokenValidation["1. Validate OAuth Token"]
                NamespaceCheck["2. Check Namespace Access"]
                SubjectReview["3. SubjectAccessReview"]
            end

            subgraph IDEContainers["IDE Containers (No Auth)"]
                Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>--no-auth"]
                CS["code-server<br/>8787/TCP HTTP<br/>--auth=none"]
                RS["RStudio Server<br/>8787/TCP HTTP<br/>no auth"]
            end
        end

        subgraph PlatformRBAC["Platform-Managed RBAC"]
            OperatorSA["rhods-operator SA<br/>ClusterRole: manages ImageStreams"]
            ControllerSA["notebook-controller SA<br/>ClusterRole: manages Notebook CRs,<br/>creates Pods, injects sidecars"]
            CullerSA["notebook-culler SA<br/>Role: GET pods, GET /api/kernels/"]
        end
    end

    subgraph BuildSecrets["Build-Time Secrets"]
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio BuildConfig<br/>Provisioned by: Admin (manual)<br/>Auto-rotate: No"]
    end

    %% Flows
    Browser -->|"HTTPS/443<br/>OAuth redirect"| Route
    Route -->|"OAuth"| OAuth
    OAuth -->|"Bearer Token"| Route
    Route -->|"HTTPS/8443<br/>Bearer Token"| KubeRBAC
    KubeRBAC --> TokenValidation
    TokenValidation --> NamespaceCheck
    NamespaceCheck --> SubjectReview
    SubjectReview -->|"Authorized"| IDEContainers

    OperatorSA -.->|"Deploys ImageStreams"| PodBoundary
    ControllerSA -.->|"Creates Pod,<br/>injects sidecar"| PodBoundary
    CullerSA -.->|"Polls /api/kernels/<br/>via kube-rbac-proxy"| KubeRBAC

    RHELSecret -.->|"Used by BuildConfig<br/>(build-time only)"| PodBoundary

    %% Styling
    style Browser fill:#4a90e2,color:#fff
    style KubeRBAC fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style TokenValidation fill:#d5e8d4,stroke:#82b366
    style NamespaceCheck fill:#d5e8d4,stroke:#82b366
    style SubjectReview fill:#d5e8d4,stroke:#82b366
    style Jupyter fill:#f37626,color:#fff
    style CS fill:#007acc,color:#fff
    style RS fill:#75aadb,color:#fff
    style OperatorSA fill:#7ed321,color:#fff
    style ControllerSA fill:#7ed321,color:#fff
    style CullerSA fill:#7ed321,color:#fff
    style RHELSecret fill:#f5a623,color:#fff
    style Route fill:#ffe6cc,stroke:#d79b00
    style OAuth fill:#ffe6cc,stroke:#d79b00
    style L1 fill:#fff3cd,stroke:#856404,color:#856404
