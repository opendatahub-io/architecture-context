graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Component does NOT define its own RBAC"]
        L2["All RBAC is managed externally"]
    end

    subgraph NotebooksComponent["Notebooks Component (No RBAC Defined)"]
        direction TB
        Note1["This component produces container images only.<br/>It does not define ClusterRoles, Roles, or RoleBindings."]
    end

    subgraph ExternalRBAC["RBAC Managed By External Components"]
        direction TB

        subgraph NBControllerRBAC["odh-notebook-controller"]
            NBCtrlSA["ServiceAccount:<br/>notebook-controller-manager"]
            NBCtrlCR["ClusterRole:<br/>notebook-controller-role"]
            NBCtrlCRB["ClusterRoleBinding:<br/>notebook-controller-rolebinding"]

            NBCtrlSA -->|"bound via"| NBCtrlCRB
            NBCtrlCRB -->|"grants"| NBCtrlCR
        end

        subgraph KRBPAuth["kube-rbac-proxy (Injected Sidecar)"]
            KRBP_SA["ServiceAccount:<br/>(workbench pod SA)"]
            KRBP_Auth["Auth Mechanism:<br/>OAuth + SubjectAccessReview"]
            KRBP_Policy["Policy:<br/>User must have access to<br/>notebook namespace"]

            KRBP_SA -->|"validates via"| KRBP_Auth
            KRBP_Auth -->|"enforces"| KRBP_Policy
        end

        subgraph WorkbenchPodSecurity["Workbench Pod Security Context"]
            PodSA["ServiceAccount:<br/>(per-workbench SA)"]
            SAToken["ServiceAccount Token:<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/"]
            PodSA -->|"mounts"| SAToken
        end
    end

    subgraph SecretsAccess["Secrets Accessed by Workbench Pods"]
        direction TB
        DSPASecret["DSPA Connection Secret<br/>Type: Opaque<br/>Mount: /opt/app-root/runtimes/<br/>Provisioned by: Notebook controller<br/>Auto-Rotate: No"]
        CABundle["CA Certificate Bundle<br/>Type: Opaque<br/>Mount: /etc/pki/tls/custom-certs/<br/>Provisioned by: Notebook controller<br/>Auto-Rotate: No"]
        SATokenSecret["ServiceAccount Token<br/>Type: kubernetes.io/service-account-token<br/>Mount: /var/run/secrets/<br/>Provisioned by: Kubernetes<br/>Auto-Rotate: Yes"]
    end

    subgraph EgressAuth["Egress Authentication"]
        direction TB
        K8sEgress["OpenShift API Server<br/>Auth: ServiceAccount token<br/>Purpose: Elyra pipeline submission"]
        DSPAEgress["DSPA API<br/>Auth: SA token<br/>(KF_PIPELINES_SA_TOKEN_PATH)<br/>Purpose: Pipeline execution"]
        RegistryEgress["Container Registries<br/>Auth: Registry credentials<br/>Purpose: Runtime image pulls"]
    end

    %% Connections
    NBCtrlCR -->|"manages pod spec via<br/>mutating webhook"| WorkbenchPodSecurity
    NBCtrlCR -->|"injects"| KRBPAuth
    PodSA -->|"accesses"| DSPASecret
    PodSA -->|"accesses"| CABundle
    PodSA -->|"accesses"| SATokenSecret
    SAToken -->|"authenticates to"| K8sEgress
    SAToken -->|"authenticates to"| DSPAEgress

    %% Styling
    style NotebooksComponent fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NBControllerRBAC fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style KRBPAuth fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style WorkbenchPodSecurity fill:#e8f4fd,stroke:#4a90e2,stroke-width:1px
    style SecretsAccess fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style EgressAuth fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    style Legend fill:#f0f0f0,stroke:#ccc,stroke-width:1px

    style NBCtrlSA fill:#4a90e2,color:#fff
    style NBCtrlCR fill:#f5a623,color:#fff
    style KRBP_Auth fill:#4a90e2,color:#fff
    style DSPASecret fill:#e74c3c,color:#fff
    style CABundle fill:#e74c3c,color:#fff
    style SATokenSecret fill:#e74c3c,color:#fff
