graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["Notebooks repository does NOT define<br/>its own RBAC resources.<br/><br/>RBAC for workbench pods is managed by:<br/>- kubeflow notebook controller<br/>- rhods-operator / opendatahub-operator"]
    end

    subgraph RuntimeRBAC["Runtime RBAC (Managed by Notebook Controller)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            NotebookSA["Per-Notebook SA<br/>(created by notebook controller<br/>for each Notebook CR)"]
        end

        subgraph SidecarAuth["Sidecar Authentication"]
            KRBP["kube-rbac-proxy Sidecar<br/>Injected by notebook controller webhook"]
        end

        subgraph AuthMechanisms["Authentication Mechanisms"]
            OAuthOIDC["OAuth/OIDC<br/>User authentication via<br/>kube-rbac-proxy (8443/TCP)"]
            SAToken["ServiceAccount Token<br/>Mounted at standard path<br/>for KFP and K8s API access"]
        end
    end

    subgraph Secrets["Secrets Used by Workbenches"]
        direction TB
        SATokenSecret["Notebook SA Token<br/>Type: kubernetes.io/service-account-token<br/>Provisioned: Kubernetes<br/>Auto-Rotate: Yes"]
        DSPASecret["DSPA Connection Secret<br/>Type: Opaque<br/>Provisioned: Notebook Controller<br/>Auto-Rotate: No"]
        CABundle["CA Certificate Bundle<br/>Type: ConfigMap mount<br/>Path: /etc/pki/tls/custom-certs/ca-bundle.crt<br/>Provisioned: Notebook Controller<br/>Auto-Rotate: No"]
    end

    subgraph AccessPatterns["Workbench Access Patterns"]
        direction TB
        UserAccess["User → Gateway → kube-rbac-proxy → Workbench<br/>Auth: OAuth/OIDC Token"]
        PipelineAccess["Elyra → DSPA<br/>Auth: ServiceAccount Token (443/TCP)"]
        K8sAccess["kubectl/oc → K8s API<br/>Auth: ServiceAccount Token (6443/TCP)"]
        CullerAccess["Notebook Controller Culler → kube-rbac-proxy<br/>Auth: ServiceAccount Token (8443/TCP)"]
    end

    %% Relationships
    NotebookSA -->|"token mounted in"| SATokenSecret
    NotebookSA -->|"used by"| PipelineAccess
    NotebookSA -->|"used by"| K8sAccess
    KRBP -->|"enforces"| OAuthOIDC
    KRBP -->|"validates"| SAToken
    OAuthOIDC -->|"protects"| UserAccess
    SAToken -->|"enables"| CullerAccess
    DSPASecret -->|"credentials for"| PipelineAccess
    CABundle -->|"TLS trust for"| PipelineAccess
    CABundle -->|"TLS trust for"| K8sAccess

    %% Styling
    style Note fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style Info fill:#fff3e0,stroke:#f5a623
    style RuntimeRBAC fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    style Secrets fill:#fce4ec,stroke:#e91e63,stroke-width:2px
    style AccessPatterns fill:#e8f5e9,stroke:#4caf50,stroke-width:2px

    style NotebookSA fill:#4a90e2,stroke:#333,color:#fff
    style KRBP fill:#e91e63,stroke:#333,color:#fff
    style OAuthOIDC fill:#f5a623,stroke:#333
    style SAToken fill:#f5a623,stroke:#333
    style SATokenSecret fill:#7ed321,stroke:#333
    style DSPASecret fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333

    style UserAccess fill:#e8e8e8,stroke:#333
    style PipelineAccess fill:#e8e8e8,stroke:#333
    style K8sAccess fill:#e8e8e8,stroke:#333
    style CullerAccess fill:#e8e8e8,stroke:#333
