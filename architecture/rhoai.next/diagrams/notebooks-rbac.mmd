graph TD
    subgraph NotebookImages["Notebooks Component"]
        Note1["This component does NOT define<br/>its own RBAC resources"]
        Note2["RBAC is managed externally by<br/>ODH Notebook Controller<br/>and Platform Operator"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (External to this component)"]
        direction TB

        subgraph AuthChain["Authentication Chain"]
            UserBrowser["User Browser<br/>OAuth/OIDC SSO"]
            Gateway2["Platform Gateway<br/>TLS Termination"]
            KubeRBACProxy["kube-rbac-proxy Sidecar<br/>(injected by Notebook Controller)"]
        end

        subgraph AuthPolicy["Authorization Policies"]
            Policy1["Policy: Namespace Access<br/>User must have access<br/>to the notebook namespace"]
            Policy2["Enforcement: kube-rbac-proxy<br/>validates OAuth/OIDC token<br/>against OpenShift RBAC"]
        end
    end

    subgraph ProtectedEndpoints["Protected Endpoints (All via kube-rbac-proxy)"]
        EP1["JupyterLab UI<br/>8888/TCP<br/>GET, POST, WebSocket"]
        EP2["code-server UI<br/>8888/TCP<br/>GET, POST, WebSocket"]
        EP3["RStudio UI<br/>8888/TCP<br/>GET, POST"]
    end

    subgraph PlatformSAs["Platform Service Accounts (Not defined here)"]
        SA1["rhods-operator SA<br/>Applies kustomize manifests<br/>Creates ImageStreams"]
        SA2["notebook-controller SA<br/>Creates StatefulSets<br/>Injects kube-rbac-proxy"]
        SA3["dashboard SA<br/>Reads ImageStream annotations"]
        SA4["elyra SA<br/>Reads runtime ImageStreams<br/>Creates pipeline Jobs"]
    end

    subgraph UserSecrets["User-Provisioned Secrets"]
        Secret1["S3 Credentials<br/>AWS IAM / Access Keys"]
        Secret2["Git Configuration<br/>SSH keys / tokens"]
        Secret3["Database Credentials<br/>MongoDB, ODBC"]
    end

    %% Auth flow
    UserBrowser -->|"OAuth/OIDC cookie"| Gateway2
    Gateway2 -->|"Bearer token"| KubeRBACProxy
    KubeRBACProxy -->|"validates against"| Policy1
    Policy1 -->|"enforced by"| Policy2

    %% Protected endpoints
    KubeRBACProxy -->|"proxies to"| EP1
    KubeRBACProxy -->|"proxies to"| EP2
    KubeRBACProxy -->|"proxies to"| EP3

    %% SA interactions
    SA1 -->|"6443/TCP HTTPS<br/>SA token"| OpenShiftAPI["OpenShift API Server"]
    SA2 -->|"6443/TCP HTTPS<br/>SA token"| OpenShiftAPI
    SA3 -->|"6443/TCP HTTPS<br/>SA token"| OpenShiftAPI
    SA4 -->|"6443/TCP HTTPS<br/>SA token"| OpenShiftAPI

    %% User secrets
    Secret1 -.->|"mounted by<br/>Notebook Controller"| EP1
    Secret2 -.->|"mounted by<br/>Notebook Controller"| EP1
    Secret3 -.->|"mounted by<br/>Notebook Controller"| EP1

    %% Styling
    style NotebookImages fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Note1 fill:#fff2cc,stroke:#d6b656
    style Note2 fill:#fff2cc,stroke:#d6b656
    style KubeRBACProxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Policy1 fill:#f8cecc,stroke:#b85450
    style Policy2 fill:#f8cecc,stroke:#b85450
    style EP1 fill:#dae8fc,stroke:#6c8ebf
    style EP2 fill:#e1d5e7,stroke:#9673a6
    style EP3 fill:#e1d5e7,stroke:#9673a6
    style SA1 fill:#7ed321,stroke:#333,color:#fff
    style SA2 fill:#7ed321,stroke:#333,color:#fff
    style SA3 fill:#7ed321,stroke:#333,color:#fff
    style SA4 fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftAPI fill:#ee0000,stroke:#333,color:#fff
    style UserBrowser fill:#f9f9f9,stroke:#999
    style Gateway2 fill:#ffe6cc,stroke:#d79b00
    style Secret1 fill:#fff2cc,stroke:#d6b656
    style Secret2 fill:#fff2cc,stroke:#d6b656
    style Secret3 fill:#fff2cc,stroke:#d6b656
