graph TD
    subgraph "Notebooks Component RBAC"
        direction TB
        Note["This component does NOT define<br/>its own RBAC resources"]
    end

    subgraph "Platform-Managed Authentication"
        direction TB
        UserBrowser["User Browser<br/>(OAuth/OIDC SSO)"]
        PlatformGateway["Platform Gateway<br/>(Envoy)"]
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>(Injected by Notebook Controller)"]
    end

    subgraph "Auth Flow"
        direction TB
        AuthCheck{"Validates Bearer Token<br/>against Kubernetes RBAC"}
        NamespaceAccess["Policy: User must have<br/>access to the namespace"]
    end

    subgraph "Workbench Endpoints (No Self-Auth)"
        direction TB
        JupyterUI["JupyterLab UI<br/>8888/TCP<br/>GET, POST, WebSocket"]
        CodeServerUI["code-server UI<br/>8888/TCP<br/>GET, POST, WebSocket"]
        RStudioUI["RStudio UI<br/>8888/TCP<br/>GET, POST"]
    end

    subgraph "Platform Operator RBAC (External to This Component)"
        direction TB
        OperatorSA["ServiceAccount:<br/>rhods-operator"]
        ControllerSA["ServiceAccount:<br/>odh-notebook-controller"]
        DashboardSA["ServiceAccount:<br/>odh-dashboard"]
    end

    subgraph "Platform Operator Permissions"
        direction TB
        ISCreate["ImageStreams<br/>create, update, patch, delete"]
        SSCreate["StatefulSets<br/>create, update, patch, delete"]
        SvcCreate["Services<br/>create, update, patch, delete"]
        ISRead["ImageStreams<br/>get, list, watch"]
    end

    %% Auth flow
    UserBrowser -->|"OAuth/OIDC cookie"| PlatformGateway
    PlatformGateway -->|"Bearer token"| KubeRBACProxy
    KubeRBACProxy --> AuthCheck
    AuthCheck -->|"validates"| NamespaceAccess
    NamespaceAccess -->|"grants access"| JupyterUI
    NamespaceAccess -->|"grants access"| CodeServerUI
    NamespaceAccess -->|"grants access"| RStudioUI

    %% Operator RBAC (for context)
    OperatorSA -->|"manages"| ISCreate
    ControllerSA -->|"manages"| SSCreate
    ControllerSA -->|"manages"| SvcCreate
    DashboardSA -->|"reads"| ISRead

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style UserBrowser fill:#f9f9f9,stroke:#999
    style PlatformGateway fill:#ffe6cc,stroke:#d79b00
    style KubeRBACProxy fill:#fff2cc,stroke:#d6b656
    style AuthCheck fill:#d5e8d4,stroke:#82b366
    style NamespaceAccess fill:#d5e8d4,stroke:#82b366
    style JupyterUI fill:#dae8fc,stroke:#6c8ebf
    style CodeServerUI fill:#dae8fc,stroke:#6c8ebf
    style RStudioUI fill:#dae8fc,stroke:#6c8ebf
    style OperatorSA fill:#e1d5e7,stroke:#9673a6
    style ControllerSA fill:#e1d5e7,stroke:#9673a6
    style DashboardSA fill:#e1d5e7,stroke:#9673a6
    style ISCreate fill:#f5a623,stroke:#333
    style SSCreate fill:#f5a623,stroke:#333
    style SvcCreate fill:#f5a623,stroke:#333
    style ISRead fill:#f5a623,stroke:#333
