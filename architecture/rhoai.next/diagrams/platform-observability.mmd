        subgraph ServiceProbes["Service Health Probes"]
            H_dashboard["odh-dashboard<br/>L: :8080 healthz<br/>R: :8080 readyz"]
            H_modelreg["Model Registry<br/>L: :8080 healthz<br/>R: :8080 readyz"]
            H_guardrails["Guardrails Orchestrator<br/>L: :8080 health<br/>R: :8080 health"]
            H_dspo["DSP API Server<br/>L: :8888 healthz<br/>R: :8888 readyz"]
            H_mlmd["ML Metadata Server<br/>L: gRPC health check<br/>R: gRPC health check"]
        end

        subgraph RuntimeProbes["Runtime Health Probes"]
            H_vllm["vLLM Runtimes<br/>L: :8080 health<br/>R: :8080 health<br/>S: model load check"]
            H_modelmesh["ModelMesh Pods<br/>L: :8089 healthz<br/>R: :8089 readyz"]
            H_llamastack["Llama Stack<br/>L: /v1/health<br/>R: /v1/providers"]
