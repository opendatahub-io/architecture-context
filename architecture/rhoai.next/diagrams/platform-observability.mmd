graph TB
    subgraph Prometheus["Prometheus Scrape Targets (16 endpoints)"]
        direction TB

        subgraph PromOperators["Operator Metrics"]
            P_Rhods["rhods-operator<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_KServe["kserve-controller<br/>:8080/TCP metrics<br/>Auth: None (cluster-internal)"]
            P_LLMISVC["llmisvc-controller<br/>:8443/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_Kueue["kueue<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_Kuberay["kuberay<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_TrainOp["training-operator<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_Trainer["trainer<br/>:28080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_DSPO["ds-pipelines-operator<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_ODHModel["odh-model-controller<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_ModelMesh["modelmesh-serving<br/>:8080/TCP metrics<br/>Auth: None"]
            P_ModelReg["model-registry<br/>:8080/TCP metrics<br/>Auth: kube-rbac-proxy"]
            P_Codeflare["codeflare-operator<br/>:8443/TCP metrics<br/>Auth: kube-rbac-proxy"]
        end

        subgraph PromServices["Service Metrics"]
            P_TrustyAI["trustyai-explainability<br/>:8080/TCP /q/metrics<br/>Auth: None"]
            P_LLMD["llm-d-inference-scheduler<br/>:9090/TCP metrics<br/>Auth: Optional (SAR)"]
            P_vLLM["vLLM (all variants)<br/>:8000/TCP metrics<br/>Auth: None"]
            P_Guardrails["fms-guardrails-orchestrator<br/>:8034/TCP metrics<br/>Auth: None"]
        end
    end

    subgraph Probes["Health Probes (10 components)"]
        direction TB

        subgraph ProbeOperators["Operator Health"]
            H_Rhods["rhods-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_KServe["kserve-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_Kueue["kueue<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_Kuberay["kuberay<br/>L: :8082 healthz<br/>R: :8082 readyz"]
            H_TrainOp["training-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
        end

        subgraph ProbeServices["Service Health"]
            H_Dashboard["odh-dashboard<br/>L: :8080 /api/health<br/>R: :8080 /api/health"]
            H_DSP["data-science-pipelines<br/>L: :8888 /apis/v2beta1/healthz<br/>R: :8888 /apis/v2beta1/healthz"]
            H_vLLM["vLLM<br/>L: :8000 /health<br/>R: :8000 /health"]
            H_Llama["llama-stack<br/>L: :8321 /v1/health<br/>R: :8321 /v1/health"]
            H_Guard["fms-guardrails-orchestrator<br/>L: :8034 /health<br/>R: :8034 /health"]
            H_ModelReg["model-registry<br/>L: :8080 /healthcheck<br/>R: :8080 /healthcheck"]
        end
    end

    subgraph Tracing["Distributed Tracing (5 components)"]
        direction TB

        T_LLMD["llm-d-inference-scheduler<br/>OTLP gRPC<br/>Configurable collector (4317/TCP)"]
        T_Llama["llama-stack<br/>OTLP HTTP<br/>Configurable collector"]
        T_Tempo["rhods-operator (Tempo)<br/>OTLP gRPC/HTTP<br/>Tempo in monitoring namespace"]
        T_Guard["fms-guardrails-orchestrator<br/>OTLP gRPC<br/>Configurable collector"]
        T_DSP["data-science-pipelines<br/>OTLP gRPC<br/>Configurable collector"]

        Collector["OpenTelemetry Collector<br/>(redhat-ods-monitoring)"]
        TempoBackend["Tempo<br/>(redhat-ods-monitoring)"]
    end

    subgraph MonitoringStack["Monitoring Infrastructure"]
        direction TB
        MS_Prometheus["Prometheus<br/>(MonitoringStack)"]
        MS_Thanos["ThanosQuerier<br/>(Aggregation)"]
        MS_Perses["Perses<br/>(Dashboards)"]
        MS_Dashboard["odh-dashboard<br/>(Metrics UI via Thanos)"]
    end

    %% Tracing flows
    T_LLMD -->|OTLP gRPC/4317| Collector
    T_Llama -->|OTLP HTTP| Collector
    T_Guard -->|OTLP gRPC| Collector
    T_DSP -->|OTLP gRPC| Collector
    Collector -->|forward| TempoBackend

    %% Monitoring stack flows
    MS_Prometheus -->|federate| MS_Thanos
    MS_Thanos -->|query| MS_Dashboard
    MS_Thanos -->|visualize| MS_Perses

    %% Styling
    classDef prom fill:#e8d5b7,stroke:#b8860b
    classDef promAuth fill:#f5deb3,stroke:#b8860b,stroke-width:2px
    classDef probe fill:#d5e8d4,stroke:#82b366
    classDef trace fill:#dae8fc,stroke:#6c8ebf
    classDef infra fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class P_Rhods,P_KServe,P_LLMISVC,P_Kueue,P_Kuberay,P_TrainOp,P_Trainer,P_DSPO,P_ODHModel,P_ModelMesh,P_ModelReg,P_Codeflare prom
    class P_TrustyAI,P_LLMD,P_vLLM,P_Guardrails promAuth
    class H_Rhods,H_KServe,H_Kueue,H_Kuberay,H_TrainOp,H_Dashboard,H_DSP,H_vLLM,H_Llama,H_Guard,H_ModelReg probe
    class T_LLMD,T_Llama,T_Tempo,T_Guard,T_DSP,Collector,TempoBackend trace
    class MS_Prometheus,MS_Thanos,MS_Perses,MS_Dashboard infra
