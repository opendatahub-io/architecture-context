        direction TB

        subgraph ControllerProbes["Controller Health Probes"]
            H_rhods["rhods-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_kserve["KServe Controllers<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_kueue["Kueue<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_codeflare["CodeFlare Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_kuberay["KubeRay Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_training["Training Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_trustyai["TrustyAI Service Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_modelregop["Model Registry Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            H_odmctrl["odh-model-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
