    end

    subgraph Alerting["Alerting & Monitoring Infrastructure"]
        direction TB
        MonNS["Namespace: redhat-ods-monitoring<br/>Platform monitoring stack"]
        AlertRules["Alert Rules<br/>Managed by rhods-operator<br/>via DSCInitialization CR"]
        ServiceMonitors["ServiceMonitors<br/>Auto-created by operators<br/>for Prometheus discovery"]
    end

    subgraph Tracing["Distributed Tracing (Where Available)"]
        direction TB
        T_note["Tracing coverage varies by component.<br/>No platform-wide OTLP collector<br/>is mandated in RHOAI rhoai.next."]
        T_kserve["KServe: Request-level tracing<br/>via Istio sidecar (Envoy spans)"]
        T_guardrails["Guardrails Orchestrator:<br/>Chunked streaming pipeline spans<br/>via Rust tracing crate"]
        T_epp["llm-d EPP:<br/>Routing decision traces<br/>via Go OTLP SDK"]
    end

    subgraph KeyMetrics["Key Platform Metrics"]
        direction TB
        KM1["Model Serving:<br/>inference_latency, throughput,<br/>model_load_time, replica_count"]
        KM2["Workload Scheduling:<br/>queue_depth, admission_latency,<br/>quota_utilization, preemptions"]
        KM3["Pipeline Execution:<br/>run_duration, step_failures,<br/>artifact_count, concurrent_runs"]
        KM4["LLM-specific:<br/>kv_cache_utilization, prefix_hit_rate,<br/>time_to_first_token, tokens_per_sec"]
        KM5["Platform Health:<br/>controller_reconcile_duration,<br/>workqueue_depth, webhook_latency,<br/>leader_election_transitions"]
    end

    %% Scraping relationships
    MonNS -->|scrapes| OperatorMetrics
    MonNS -->|scrapes| ServiceMetrics
    MonNS -->|scrapes| RuntimeMetrics
    ServiceMonitors -.->|discovers| OperatorMetrics
    ServiceMonitors -.->|discovers| ServiceMetrics
    AlertRules -.->|evaluates| MonNS

