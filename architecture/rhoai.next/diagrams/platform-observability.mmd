graph TB
    subgraph MonitoringInfra["Monitoring Infrastructure (redhat-ods-monitoring)"]
        direction TB
        Prometheus["Prometheus<br/>Central metric collection<br/>Scrapes all ServiceMonitors"]
        Thanos["Thanos Querier<br/>Multi-tenant metric queries"]
        AlertMgr["AlertManager<br/>Alert routing + notification"]
        Perses["Perses<br/>Platform dashboards"]
        OTel["OpenTelemetry Collector<br/>Distributed tracing<br/>OTLP gRPC receiver"]
    end

    subgraph PrometheusTargets["Prometheus Scrape Targets (via kube-rbac-proxy)"]
        direction TB

        subgraph OperatorMetrics["Operator Metrics (8443/TCP, kube-rbac-proxy auth)"]
            PM1[rhods-operator<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM2[KServe Controllers<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM3[odh-model-controller<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM4[DSPO Controller<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM5[Model Registry Operator<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM6[KubeRay Operator<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM7[Kueue Controller<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM8[TrustyAI Operator<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM9[Spark Operator<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM10[Kubeflow Trainer<br/>8443/TCP metrics<br/>kube-rbac-proxy]
        end

        subgraph ServiceMetrics["Platform Service Metrics"]
            PM11[odh-dashboard<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM12[EvalHub<br/>8443/TCP metrics<br/>kube-rbac-proxy]
            PM13[Notebook Pods<br/>8443/TCP metrics<br/>kube-rbac-proxy sidecar<br/>injected by ODH controller]
        end

        subgraph InferenceMetrics["Inference Metrics"]
            PM14[vLLM Inference Pods<br/>Application metrics<br/>Queue depth, KV-cache,<br/>token throughput, latency]
            PM15[llm-d EPP<br/>Routing decision metrics<br/>Endpoint scoring data]
            PM16[WVA Controller<br/>Saturation detection<br/>Scale-from-zero metrics<br/>Emits HPA/KEDA targets]
            PM17[ModelMesh Serving<br/>Model load/unload metrics<br/>Inference latency]
        end

        subgraph PipelineMetrics["Pipeline & Training Metrics"]
            PM18[DSP API Server<br/>Pipeline run metrics]
            PM19[Argo Workflows<br/>Workflow step metrics]
        end
    end

    subgraph HealthProbes["Health Probes"]
        direction TB

        subgraph ControllerProbes["Controller Health Probes (8081/TCP)"]
            HP1[rhods-operator<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP2[KServe Controllers<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP3[odh-model-controller<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP4[DSPO Controller<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP5[Kueue Controller<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP6[KubeRay Operator<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP7[TrustyAI Operator<br/>L: 8081 healthz<br/>R: 8081 readyz]
            HP8[Model Registry Operator<br/>L: 8081 healthz<br/>R: 8081 readyz]
        end

        subgraph ServiceProbes["Service Health Probes"]
            HP9[odh-dashboard<br/>HTTP readiness probe]
            HP10[vLLM Server<br/>L: model loaded check<br/>R: model ready check<br/>S: weight download progress]
            HP11[DSP API Server<br/>HTTP health endpoint]
            HP12[Model Registry<br/>REST health endpoint]
            HP13[MLflow Server<br/>HTTP health endpoint]
            HP14[EvalHub<br/>HTTP health endpoint]
            HP15[Gateway Envoy<br/>Admin health endpoint]
        end
    end

    subgraph Tracing["Distributed Tracing"]
        direction TB
        T1[KServe Controllers<br/>OTLP gRPC traces<br/>Reconciliation spans]
        T2[DSP API Server<br/>OTLP gRPC traces<br/>Pipeline execution spans]
        T3[llm-d EPP<br/>OTLP gRPC traces<br/>Routing decision spans]
        T4[Envoy Gateway<br/>Request tracing<br/>Trace context propagation]
    end

    subgraph Alerting["Key Alerts"]
        direction TB
        A1[Component Degraded<br/>DSC condition != Ready<br/>Operator-level health]
        A2[Inference Latency<br/>vLLM P99 > threshold<br/>Model serving SLO]
        A3[Pipeline Failures<br/>Argo Workflow error rate<br/>Pipeline SLO]
        A4[Notebook Idle<br/>Culling threshold exceeded<br/>Resource reclamation]
        A5[Resource Exhaustion<br/>Kueue queue depth<br/>Workload admission backlog]
    end

    %% Prometheus scrapes
    Prometheus -->|"scrapes<br/>ServiceMonitor"| OperatorMetrics
    Prometheus -->|"scrapes<br/>ServiceMonitor"| ServiceMetrics
    Prometheus -->|"scrapes<br/>ServiceMonitor"| InferenceMetrics
    Prometheus -->|"scrapes<br/>ServiceMonitor"| PipelineMetrics

    %% Monitoring stack
    Thanos -->|queries| Prometheus
    Perses -->|visualizes| Thanos
    Prometheus -->|fires| AlertMgr
    AlertMgr -->|routes| Alerting

    %% Tracing
    T1 -->|OTLP gRPC| OTel
    T2 -->|OTLP gRPC| OTel
    T3 -->|OTLP gRPC| OTel
    T4 -->|OTLP gRPC| OTel

    %% WVA feedback loop
    PM16 -.->|emits metrics for| PM14

    %% Auth note
    Note1[All kube-rbac-proxy protected<br/>metrics require ServiceAccount<br/>with GET access.<br/>prometheus-k8s SA auto-allowed.]

    %% Styling
    classDef prom fill:#e8d5b7,stroke:#b8860b
    classDef probe fill:#d5e8d4,stroke:#82b366
    classDef trace fill:#dae8fc,stroke:#6c8ebf
    classDef alert fill:#f8cecc,stroke:#b85450
    classDef infra fill:#e1d5e7,stroke:#9673a6

    class PM1,PM2,PM3,PM4,PM5,PM6,PM7,PM8,PM9,PM10 prom
    class PM11,PM12,PM13 prom
    class PM14,PM15,PM16,PM17 prom
    class PM18,PM19 prom
    class HP1,HP2,HP3,HP4,HP5,HP6,HP7,HP8 probe
    class HP9,HP10,HP11,HP12,HP13,HP14,HP15 probe
    class T1,T2,T3,T4 trace
    class A1,A2,A3,A4,A5 alert
    class Prometheus,Thanos,AlertMgr,Perses,OTel infra
    class Note1 prom
