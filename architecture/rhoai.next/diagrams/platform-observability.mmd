        end

        subgraph ServiceMetrics["Service Metrics (Direct / Token)"]
            P_dashboard["odh-dashboard<br/>:8080/TCP metrics<br/>Auth: None (internal)"]
            P_dspo["DSPO API Server<br/>:8888/TCP metrics<br/>Auth: Bearer Token<br/>NS: user namespace"]
            P_modelreg["Model Registry<br/>:8080/TCP metrics<br/>Auth: None (internal)"]
            P_guardrails["FMS Guardrails Orchestrator<br/>:8080/TCP metrics<br/>Auth: None (internal)<br/>NS: user namespace"]
        end

        subgraph RuntimeMetrics["Inference Runtime Metrics"]
            P_vllm["vLLM Runtimes<br/>:8080/TCP Prometheus<br/>Metrics: token throughput, latency,<br/>KV cache utilization, queue depth<br/>Auth: None"]
            P_modelmesh["ModelMesh<br/>:2112/TCP Prometheus<br/>Metrics: model loading, inference<br/>latency, cache stats<br/>Auth: None"]
            P_epp["llm-d Inference Scheduler<br/>:9090/TCP metrics<br/>Metrics: routing decisions,<br/>pod scores, P/D splits<br/>Auth: None"]
        end
    end

