graph TB
    subgraph Prometheus["Prometheus Scrape Targets (22 endpoints)"]
        direction TB

        subgraph PromRBACProxy["Protected by kube-rbac-proxy"]
            P_kserve["KServe Controller<br/>:9443/TCP /metrics<br/>kube-rbac-proxy"]
            P_kubeflow["Kubeflow Controller<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
            P_kuberay["KubeRay Operator<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
            P_kueue["Kueue Controller<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
            P_trustyai_svc["TrustyAI Explainability<br/>:8080/TCP /q/metrics<br/>kube-rbac-proxy"]
            P_modelregop["Model Registry Operator<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
            P_mlflowop["MLflow Operator<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
            P_dashboard["ODH Dashboard<br/>:8443/TCP /metrics<br/>kube-rbac-proxy"]
        end

        subgraph PromBearer["Protected by Bearer Token"]
            P_trainer["Trainer Controller<br/>:8443/TCP /metrics<br/>Bearer Token"]
            P_wva["WVA Controller<br/>:8443/TCP /metrics<br/>Bearer Token"]
        end

        subgraph PromOAuth["Protected by OAuth Proxy"]
            P_prometheus["Prometheus (managed)<br/>:9090/TCP /metrics<br/>OAuth proxy"]
        end

        subgraph PromUnauth["No Authentication"]
            P_rhods["rhods-operator<br/>:8080/TCP /metrics"]
            P_trainingop["Training Operator<br/>:8080/TCP /metrics"]
            P_trustyaiop["TrustyAI Operator<br/>:8080/TCP /metrics"]
            P_modelmesh["ModelMesh<br/>:2112/TCP /metrics<br/>(self-signed TLS)"]
            P_mmadapter["ModelMesh Runtime Adapter<br/>:8084/TCP /metrics"]
            P_mlserver["MLServer<br/>:8082/TCP /metrics"]
            P_llamaop["Llama Stack Operator<br/>:8443/TCP /metrics"]
            P_odmctrl["odh-model-controller<br/>:8080/TCP /metrics"]
            P_sparkop["Spark Operator<br/>:8080/TCP /metrics"]
            P_llmd_epp["llm-d-inference-scheduler<br/>:9090/TCP /metrics"]
            P_vllm["vLLM / vLLM-CPU / vLLM-Gaudi<br/>:8000/TCP /metrics"]
            P_ovms["OpenVINO Model Server<br/>configurable /metrics"]
            P_tgis["text-generation-inference<br/>:3000/TCP /metrics"]
            P_nemo["NeMo-Guardrails<br/>:8000/TCP /metrics"]
            P_dsp["Data Science Pipelines<br/>:8888/TCP /metrics"]
        end
    end

    subgraph Probes["Health Probes (25 components)"]
        direction TB

        subgraph ProbesK8s["Standard K8s Probes (healthz/readyz)"]
            H_kserve["KServe<br/>L: healthz R: readyz"]
            H_kubeflow["Kubeflow<br/>L: healthz R: readyz"]
            H_kuberay["KubeRay<br/>L: healthz R: readyz"]
            H_kueue["Kueue<br/>L: healthz R: readyz"]
            H_rhods["rhods-operator<br/>L: healthz R: readyz"]
            H_trainingop["Training Operator<br/>L: healthz R: readyz"]
            H_trainer["Trainer<br/>L: healthz R: readyz"]
            H_trustyaiop["TrustyAI Operator<br/>L: healthz R: readyz"]
            H_odmctrl["odh-model-controller<br/>L: healthz R: readyz"]
            H_sparkop["Spark Operator<br/>L: healthz R: readyz"]
            H_wva["WVA Controller<br/>L: healthz R: readyz"]
            H_mlflowop["MLflow Operator<br/>L: healthz R: readyz"]
            H_llamaop["Llama Stack Operator<br/>L: healthz R: readyz"]
        end

        subgraph ProbesQuarkus["Quarkus Health"]
            H_trustyai["TrustyAI Explainability<br/>L: /q/health/live<br/>R: /q/health/ready"]
        end

        subgraph ProbesGRPC["gRPC Health"]
            H_llmd["llm-d-inference-scheduler<br/>L: grpc.health.v1.Health :9003<br/>R: grpc.health.v1.Health :9003"]
        end

        subgraph ProbesV2["V2 Inference Protocol"]
            H_ovms["OpenVINO Model Server<br/>L: /v2/health/live<br/>R: /v2/health/ready"]
            H_mlserver["MLServer<br/>L: /v2/health/live<br/>R: /v2/health/ready"]
        end

        subgraph ProbesSimple["Simple Health Endpoint"]
            H_vllm["vLLM / vLLM-CPU / Gaudi<br/>L: /health R: /health"]
            H_llama["Llama Stack<br/>L: /health R: /health"]
            H_nemo["NeMo-Guardrails<br/>L: /health R: /health"]
            H_guardreg["guardrails-regex-detector<br/>L: /health R: /health"]
            H_tgis["text-generation-inference<br/>L: /health R: /health"]
        end

        subgraph ProbesCustom["Custom Health"]
            H_modelmesh["ModelMesh<br/>L: /live :8089<br/>R: /ready :8089"]
        end
    end

    subgraph Tracing["Distributed Tracing (5 components)"]
        direction TB
        T_mlflow["MLflow<br/>OTLP HTTP<br/>traces.otlp.endpoint"]
        T_rhods["rhods-operator<br/>OTLP gRPC<br/>OTel Collector → Tempo"]
        T_guardrails["fms-guardrails-orchestrator<br/>OTLP gRPC<br/>Configurable collector"]
        T_llama["rhds-llama-stack-dist<br/>OTLP HTTP<br/>Configurable (optional)"]
        T_dsp["Data Science Pipelines<br/>OTLP gRPC<br/>Configurable collector"]
        Collector["OpenTelemetry<br/>Collector"]
        Tempo["Tempo<br/>Trace Backend"]
    end

    %% Tracing connections
    T_rhods -->|OTLP gRPC| Collector
    T_guardrails -->|OTLP gRPC| Collector
    T_dsp -->|OTLP gRPC| Collector
    T_mlflow -->|OTLP HTTP| Collector
    T_llama -->|OTLP HTTP| Collector
    Collector -->|forward| Tempo

    %% Styling
    classDef prom fill:#e8d5b7,stroke:#b8860b,stroke-width:2px
    classDef promProtected fill:#f0e0c8,stroke:#b8860b,stroke-width:2px,stroke-dasharray:5 5
    classDef probe fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef probeCustom fill:#c5d8c4,stroke:#72a356,stroke-width:2px
    classDef trace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef collector fill:#b3cde3,stroke:#4a7fb5,stroke-width:3px

    class P_kserve,P_kubeflow,P_kuberay,P_kueue,P_trustyai_svc,P_modelregop,P_mlflowop,P_dashboard promProtected
    class P_trainer,P_wva promProtected
    class P_prometheus promProtected
    class P_rhods,P_trainingop,P_trustyaiop,P_modelmesh,P_mmadapter,P_mlserver,P_llamaop,P_odmctrl,P_sparkop,P_llmd_epp,P_vllm,P_ovms,P_tgis,P_nemo,P_dsp prom

    class H_kserve,H_kubeflow,H_kuberay,H_kueue,H_rhods,H_trainingop,H_trainer,H_trustyaiop,H_odmctrl,H_sparkop,H_wva,H_mlflowop,H_llamaop probe
    class H_trustyai,H_llmd,H_ovms,H_mlserver probeCustom
    class H_vllm,H_llama,H_nemo,H_guardreg,H_tgis,H_modelmesh probe

    class T_mlflow,T_rhods,T_guardrails,T_llama,T_dsp trace
    class Collector,Tempo collector
