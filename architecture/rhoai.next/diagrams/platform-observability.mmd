    subgraph HealthProbes["Health Probes (14 Components)"]
        direction TB

        subgraph ProbeOperators["Operator Health"]
            HP1["rhods-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP2["kserve-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP3["kueue<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP4["data-science-pipelines-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP5["trainer<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP6["training-operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP7["maas-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
        end

        subgraph ProbeServices["Service Health"]
            HS1["odh-dashboard<br/>L: :8080 api/health<br/>R: :8080 api/health"]
            HS2["maas-api<br/>L: :8080 health<br/>R: :8080 health"]
            HS3["trustyai-explainability<br/>L: :8080 q/health/live<br/>R: :8080 q/health/ready"]
            HS4["vLLM variants<br/>L: :8000 health<br/>R: :8000 health"]
            HS5["fms-guardrails-orchestrator<br/>L: :8080 health<br/>R: :8080 health"]
            HS6["NeMo-Guardrails<br/>L: :8000 v1/rails/config<br/>R: :8000 v1/rails/config"]
        end
    end

    subgraph Tracing["Distributed Tracing (5 Components)"]
        direction TB
        T1["rhods-operator<br/>(monitoring controller)<br/>OTLP gRPC"]
        T2["rhds-llama-stack-distribution<br/>OTLP HTTP/gRPC<br/>(configurable)"]
        T3["kserve inference pods<br/>OTLP gRPC<br/>(optional sidecar)"]
        T4["fms-guardrails-orchestrator<br/>OTLP gRPC<br/>(configurable)"]
        T5["data-science-pipelines<br/>OTLP HTTP<br/>(configurable)"]
    end

    subgraph MonStack["Monitoring Stack (redhat-ods-monitoring)"]
        direction TB
        Prometheus["MonitoringStack<br/>(Prometheus)<br/>Metric collection"]
        Thanos["ThanosQuerier<br/>:9092/TCP HTTPS<br/>Federated queries"]
        Tempo["Tempo<br/>Trace storage"]
        OTEL["OpenTelemetry Collector<br/>OTLP gRPC/HTTP<br/>Trace forwarding"]
        Perses["Perses<br/>Observability<br/>Dashboards"]
    end

    %% Prometheus scraping
    Prometheus -.->|ServiceMonitor| PM1
    Prometheus -.->|ServiceMonitor| PM2
    Prometheus -.->|ServiceMonitor| PM3
    Prometheus -.->|ServiceMonitor| PM4
    Prometheus -.->|ServiceMonitor| PM5
    Prometheus -.->|ServiceMonitor| PS1
    Prometheus -.->|ServiceMonitor| PI1
    Prometheus -.->|ServiceMonitor| PI2
    Prometheus -.->|PodMonitor| PL1

    %% Thanos federation
    Prometheus -->|remote-write| Thanos

    %% Tracing pipeline
    T1 -->|OTLP/gRPC| OTEL
    T2 -->|OTLP| OTEL
    T3 -->|OTLP/gRPC| OTEL
    T4 -->|OTLP/gRPC| OTEL
    T5 -->|OTLP/HTTP| OTEL
    OTEL -->|export| Tempo

    %% Dashboard queries
    Dashboard_Query["ODH Dashboard<br/>Metrics UI"]
    Dashboard_Query -->|HTTPS/9092| Thanos
    Perses -->|query| Thanos

    %% Styling
    classDef prom fill:#e8d5b7,stroke:#b8860b,color:#333
    classDef probe fill:#d5e8d4,stroke:#82b366,color:#333
    classDef trace fill:#dae8fc,stroke:#6c8ebf,color:#333
    classDef stack fill:#e1d5e7,stroke:#9673a6,color:#333
    classDef query fill:#fff2cc,stroke:#d6b656,color:#333

    class PM1,PM2,PM3,PM4,PM5,PM6,PM7,PM8,PM9,PM10,PM11 prom
    class PS1,PS2,PS3,PS4,PS5 prom
    class PI1,PI2,PI3 prom
    class PL1,PL2,PL3 prom
    class HP1,HP2,HP3,HP4,HP5,HP6,HP7 probe
    class HS1,HS2,HS3,HS4,HS5,HS6 probe
    class T1,T2,T3,T4,T5 trace
    class Prometheus,Thanos,Tempo,OTEL,Perses stack
    class Dashboard_Query query
