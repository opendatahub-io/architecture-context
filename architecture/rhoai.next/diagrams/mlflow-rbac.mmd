graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["mlflow-server<br/>(managed by MLflow Operator)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["ClusterRoleBinding<br/>(managed by MLflow Operator Helm chart)"]
    end

    subgraph ClusterRolePerms["ClusterRole Permissions"]
        CR["ClusterRole<br/>(managed by MLflow Operator)"]
    end

    subgraph APIResources["API Resources Accessed"]
        MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
        Namespaces["core (v1)<br/>namespaces"]
        SSAR["authorization.k8s.io<br/>selfsubjectaccessreviews"]
    end

    subgraph WorkspaceRBAC["Workspace-Level RBAC (Runtime)"]
        direction TB
        AuthFlow["Per-Request Authorization Flow"]
        BearerToken["Client Bearer Token<br/>(K8s SA token)"]
        SSARCheck["SelfSubjectAccessReview<br/>against mlflow.kubeflow.org<br/>pseudo-resources"]
        PermResult{"Permission<br/>Result"}
        Allow["ALLOW<br/>Access granted"]
        Deny["NO_PERMISSIONS<br/>Default deny"]
    end

    subgraph Secrets["Secrets (Operator-Managed)"]
        KEK["MLFLOW_CRYPTO_KEK_PASSPHRASE<br/>Opaque env var<br/>AES-256-GCM KEK<br/>No auto-rotate"]
        FlaskKey["MLFLOW_FLASK_SERVER_SECRET_KEY<br/>Opaque env var<br/>Flask session signing<br/>No auto-rotate"]
        DBCreds["Database Connection URI<br/>Opaque env var<br/>PostgreSQL credentials<br/>No auto-rotate"]
        S3Creds["S3/Artifact Credentials<br/>Opaque env var<br/>AWS_ACCESS_KEY_ID<br/>No auto-rotate"]
    end

    %% RBAC Chain
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| MLflowConfigs
    CR -->|"get, list, watch"| Namespaces
    CR -->|"create"| SSAR

    %% Runtime Auth Flow
    BearerToken -->|"extracted from<br/>Authorization header"| AuthFlow
    AuthFlow -->|"delegates to K8s API"| SSARCheck
    SSARCheck -->|"evaluates"| PermResult
    PermResult -->|"allowed: true"| Allow
    PermResult -->|"allowed: false<br/>or missing"| Deny

    %% Secret usage
    SA -.->|"mounts"| KEK
    SA -.->|"mounts"| FlaskKey
    SA -.->|"mounts"| DBCreds
    SA -.->|"mounts"| S3Creds

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#90caf9,stroke:#1565c0
    style CR fill:#f5a623,stroke:#333
    style MLflowConfigs fill:#7ed321,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style SSAR fill:#7ed321,stroke:#333
    style BearerToken fill:#fff3e0,stroke:#e65100
    style SSARCheck fill:#ffcc80,stroke:#e65100
    style Allow fill:#c8e6c9,stroke:#2e7d32
    style Deny fill:#ffcdd2,stroke:#c62828
    style KEK fill:#e1bee7,stroke:#6a1b9a
    style FlaskKey fill:#e1bee7,stroke:#6a1b9a
    style DBCreds fill:#e1bee7,stroke:#6a1b9a
    style S3Creds fill:#e1bee7,stroke:#6a1b9a
