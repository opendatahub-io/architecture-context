graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_MLflow["mlflow-server SA<br/>(MLflow Server Pod)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Executor["mlflow-executor<br/>(required for K8s project backend)"]
    end

    subgraph APIResources["API Resources"]
        Jobs["batch<br/>jobs"]
    end

    subgraph Verbs["Permitted Operations"]
        V_Create["create"]
        V_Get["get"]
        V_List["list"]
        V_Watch["watch"]
        V_Delete["delete"]
    end

    SA_MLflow -->|"bound via ClusterRoleBinding"| CR_Executor
    CR_Executor -->|"grants access to"| Jobs
    Jobs --- V_Create
    Jobs --- V_Get
    Jobs --- V_List
    Jobs --- V_Watch
    Jobs --- V_Delete

    subgraph InternalAuth["MLflow Internal Authorization"]
        direction TB
        AuthPlugin["kubernetes-namespaced<br/>Auth Provider"]
        PermSystem["MLflow Permission System"]

        AuthPlugin -->|"resolves"| Workspace["Workspace<br/>(from K8s namespace)"]
        PermSystem -->|"enforces"| PermLevels["Permission Levels"]

        subgraph PermLevels["Permission Levels"]
            READ["READ<br/>(view experiments, runs, models)"]
            USE["USE<br/>(create runs, log metrics)"]
            EDIT["EDIT<br/>(update experiments, models)"]
            MANAGE["MANAGE<br/>(delete, manage permissions)"]
        end

        subgraph ProtectedResources["Protected Resources"]
            Experiments["Experiments"]
            Runs["Runs"]
            RegisteredModels["Registered Models"]
            ModelVersions["Model Versions"]
            Workspaces["Workspaces"]
            GatewayEndpoints["Gateway Endpoints"]
            GatewaySecrets["Gateway Secrets"]
        end
    end

    AuthPlugin -->|"scopes to workspace"| ProtectedResources

    subgraph AuthNChain["Authentication Chain"]
        Step1["1. kube-rbac-proxy<br/>Validates K8s SA Token"]
        Step2["2. kubernetes-namespaced provider<br/>Resolves workspace from namespace"]
        Step3["3. MLflow Auth Middleware<br/>Checks resource permissions"]
        Step1 --> Step2
        Step2 --> Step3
    end

    subgraph SecretsAccess["Secrets (Sensitive Data)"]
        KEK["MLFLOW_CRYPTO_KEK_PASSPHRASE<br/>(envelope encryption key)"]
        FlaskKey["MLFLOW_FLASK_SERVER_SECRET_KEY<br/>(session cookie signing)"]
        DBCreds["Database Credentials<br/>(PostgreSQL connection string)"]
        APIKeys["AI Gateway API Keys<br/>(encrypted in DB with KEK)"]
    end

    %% Styling
    style SA_MLflow fill:#4a90e2,color:#fff
    style CR_Executor fill:#f5a623,color:#fff
    style Jobs fill:#7ed321,color:#fff
    style AuthPlugin fill:#e74c3c,color:#fff
    style PermSystem fill:#e74c3c,color:#fff
    style READ fill:#d5e8d4,stroke:#82b366
    style USE fill:#d5e8d4,stroke:#82b366
    style EDIT fill:#fff2cc,stroke:#d6b656
    style MANAGE fill:#f8cecc,stroke:#b85450
    style Step1 fill:#ffe6cc,stroke:#d79b00
    style Step2 fill:#ffe6cc,stroke:#d79b00
    style Step3 fill:#ffe6cc,stroke:#d79b00
    style KEK fill:#f8cecc,stroke:#b85450
    style FlaskKey fill:#f8cecc,stroke:#b85450
    style DBCreds fill:#f8cecc,stroke:#b85450
    style APIKeys fill:#f8cecc,stroke:#b85450
