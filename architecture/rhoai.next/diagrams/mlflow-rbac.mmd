graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["mlflow-server<br/>(operator namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (Managed by MLflow Operator)"]
        CRB["mlflow-server-binding<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions (Managed by MLflow Operator)"]
        CR["mlflow-server-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph MLflowGroup["mlflow.kubeflow.org"]
            MLflowConfigs["mlflowconfigs"]
        end

        subgraph CoreGroup["core ('')"]
            Namespaces["namespaces"]
        end

        subgraph AuthGroup["authorization.k8s.io"]
            SSAR["selfsubjectaccessreviews"]
        end
    end

    subgraph RuntimeAuth["Runtime Authorization (Per-Request)"]
        direction TB
        AuthFlow["kubernetes-auth Plugin<br/>Per-request RBAC enforcement"]
        PseudoResources["Pseudo-Resources<br/>(mlflow.kubeflow.org group)<br/>experiments, runs, models,<br/>model-versions, workspaces"]
    end

    subgraph Endpoints["Protected Endpoints"]
        direction TB
        TrackingEndpoints["/api/2.0/mlflow/*<br/>Experiment & Run CRUD"]
        RegistryEndpoints["/api/2.0/mlflow/registered-models/*<br/>Model Registry"]
        GatewayEndpoints["/gateway/*<br/>AI Gateway Invocation"]
        TracesEndpoints["/v1/traces<br/>OTLP Trace Ingestion<br/>(+ x-mlflow-experiment-id)"]
        PublicEndpoints["/health, /version, /static-files/*<br/>(No auth required)"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Permissions
    CR -->|"get, list, watch"| MLflowConfigs
    CR -->|"get, list, watch"| Namespaces
    CR -->|"create"| SSAR

    %% Runtime auth flow
    TrackingEndpoints -->|"Bearer Token"| AuthFlow
    RegistryEndpoints -->|"Bearer Token"| AuthFlow
    GatewayEndpoints -->|"Bearer Token"| AuthFlow
    TracesEndpoints -->|"Bearer Token +<br/>x-mlflow-experiment-id"| AuthFlow
    AuthFlow -->|"SelfSubjectAccessReview<br/>against pseudo-resources"| SSAR
    AuthFlow -->|"checks permissions on"| PseudoResources

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#6c8ebf,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style MLflowConfigs fill:#7ed321,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style SSAR fill:#7ed321,stroke:#333
    style AuthFlow fill:#f8cecc,stroke:#b85450
    style PseudoResources fill:#f8cecc,stroke:#b85450
    style PublicEndpoints fill:#d5e8d4,stroke:#82b366
    style TrackingEndpoints fill:#dae8fc,stroke:#6c8ebf
    style RegistryEndpoints fill:#dae8fc,stroke:#6c8ebf
    style GatewayEndpoints fill:#dae8fc,stroke:#6c8ebf
    style TracesEndpoints fill:#dae8fc,stroke:#6c8ebf
