graph TD
    subgraph Users["Users / Clients"]
        MLClient["ML Client<br/>(mlflow-skinny)"]
        WebUser["Web Browser User"]
        AppDev["Application Developer"]
    end

    subgraph AuthFlow["Authentication Flow"]
        direction TB
        SecurityMW["Security Middleware<br/>━━━━━━━━━━━━━━━━━━━<br/>Host Header Validation<br/>(DNS rebinding protection)<br/>CORS Origin Validation<br/>(CSRF prevention)"]
        AuthPlugin["Auth Module<br/>━━━━━━━━━━━━━━━━━━━<br/>--app-name kubernetes-auth<br/>Flask Plugin"]
    end

    subgraph RBAC["RBAC System (kubernetes-auth)"]
        direction TB
        RBACEngine["RBAC Engine<br/>━━━━━━━━━━━━━━━━━━━<br/>Role-based Access Control<br/>Workspace-scoped Permissions"]

        subgraph Roles["Roles"]
            AdminRole["Admin Role<br/>Full access to all resources"]
            UserRole["User Role<br/>Scoped to owned experiments/runs"]
            CustomRole["Custom Roles<br/>(Configurable via Helm<br/>namespace_rbac.extraRules<br/>cluster_rbac.extraRules)"]
        end
    end

    subgraph ServiceAccount["Kubernetes Service Account"]
        SA["mlflow ServiceAccount<br/>━━━━━━━━━━━━━━━━━━━<br/>Namespace: {release-namespace}<br/>Token automount: disabled"]
    end

    subgraph K8sRBAC["Kubernetes RBAC (Helm-managed)"]
        direction TB

        subgraph NSScoped["Namespace-Scoped (when configured)"]
            NSRole["Role<br/>(namespace_rbac.extraRules)"]
            NSBinding["RoleBinding<br/>mlflow SA → Role"]
        end

        subgraph ClusterScoped["Cluster-Scoped (when configured)"]
            ClusterRole["ClusterRole<br/>(cluster_rbac.extraRules)"]
            ClusterBinding["ClusterRoleBinding<br/>mlflow SA → ClusterRole"]
        end
    end

    subgraph Resources["Protected API Resources"]
        direction TB

        subgraph AuthRequired["Auth Required (kubernetes-auth)"]
            Experiments["/api/2.0/mlflow/experiments/*<br/>Experiment CRUD & Search"]
            Runs["/api/2.0/mlflow/runs/*<br/>Run CRUD, Metrics, Params"]
            Models["/api/2.0/mlflow/registered-models/*<br/>Model Registry CRUD"]
            Versions["/api/2.0/mlflow/model-versions/*<br/>Version Management"]
            Gateway["/api/2.0/mlflow/gateway/*<br/>AI Gateway Routes"]
            Traces["/v1/traces<br/>OTLP Trace Ingestion"]
            Jobs["/ajax-api/3.0/jobs/*<br/>Job Execution"]
            AjaxAPI["/ajax-api/2.0/mlflow/*<br/>Frontend API"]
        end

        subgraph NoAuth["No Auth Required"]
            Health["/health<br/>Liveness Probe"]
            VersionEP["/version<br/>Server Version"]
            MetricsEP["/metrics<br/>Prometheus Metrics"]
        end
    end

    subgraph K8sResources["Kubernetes API Resources"]
        Namespaces["Namespaces<br/>(workspace resolution)"]
        Pods["Pods<br/>(pod metadata)"]
    end

    %% Auth flow
    MLClient -->|"Bearer / kubernetes-auth"| SecurityMW
    WebUser -->|"Session / kubernetes-auth"| SecurityMW
    AppDev -->|"Bearer / kubernetes-auth"| SecurityMW
    SecurityMW -->|"passes validation"| AuthPlugin
    AuthPlugin -->|"checks permissions"| RBACEngine

    %% RBAC to resources
    RBACEngine -->|"authorized"| Experiments
    RBACEngine -->|"authorized"| Runs
    RBACEngine -->|"authorized"| Models
    RBACEngine -->|"authorized"| Versions
    RBACEngine -->|"authorized"| Gateway
    RBACEngine -->|"authorized"| Traces
    RBACEngine -->|"authorized"| Jobs
    RBACEngine -->|"authorized"| AjaxAPI

    %% Roles
    AdminRole --> RBACEngine
    UserRole --> RBACEngine
    CustomRole --> RBACEngine

    %% ServiceAccount bindings
    SA -->|"bound via"| NSBinding
    NSBinding -->|"grants"| NSRole
    SA -->|"bound via"| ClusterBinding
    ClusterBinding -->|"grants"| ClusterRole

    %% K8s API access
    SA -->|"HTTPS/6443<br/>SA token"| Namespaces
    SA -->|"HTTPS/6443<br/>SA token"| Pods

    %% No-auth endpoints (direct access)
    MLClient -.->|"no auth"| Health
    MLClient -.->|"no auth"| VersionEP

    %% Styling
    style SecurityMW fill:#b85450,color:#fff
    style AuthPlugin fill:#b85450,color:#fff
    style RBACEngine fill:#f5a623,color:#333
    style AdminRole fill:#e6522c,color:#fff
    style UserRole fill:#4a90e2,color:#fff
    style CustomRole fill:#999,color:#fff
    style SA fill:#326ce5,color:#fff
    style NSRole fill:#7ed321,color:#fff
    style NSBinding fill:#7ed321,color:#fff
    style ClusterRole fill:#d6b656,color:#333
    style ClusterBinding fill:#d6b656,color:#333

    style Experiments fill:#d5e8d4,stroke:#82b366
    style Runs fill:#d5e8d4,stroke:#82b366
    style Models fill:#d5e8d4,stroke:#82b366
    style Versions fill:#d5e8d4,stroke:#82b366
    style Gateway fill:#d5e8d4,stroke:#82b366
    style Traces fill:#d5e8d4,stroke:#82b366
    style Jobs fill:#d5e8d4,stroke:#82b366
    style AjaxAPI fill:#d5e8d4,stroke:#82b366

    style Health fill:#f5f5f5,stroke:#999
    style VersionEP fill:#f5f5f5,stroke:#999
    style MetricsEP fill:#f5f5f5,stroke:#999

    style Namespaces fill:#dae8fc,stroke:#6c8ebf
    style Pods fill:#dae8fc,stroke:#6c8ebf

    style MLClient fill:#f9f9f9,stroke:#333
    style WebUser fill:#f9f9f9,stroke:#333
    style AppDev fill:#f9f9f9,stroke:#333
