graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA[mlflow<br/>Namespace: release-namespace]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB[mlflow<br/>ClusterRoleBinding]
    end

    subgraph ClusterRoles["Cluster Role"]
        CR[mlflow<br/>ClusterRole]
    end

    subgraph APIResources["API Resources & Permissions"]
        subgraph CoreAPI["API Group: core ('')"]
            Namespaces["namespaces"]
        end

        subgraph MLflowAPI["API Group: mlflow.kubeflow.org"]
            MLflowConfigs["mlflowconfigs"]
        end

        subgraph AuthzAPI["API Group: authorization.k8s.io"]
            SSAR["selfsubjectaccessreviews"]
        end

        subgraph BatchAPI["API Group: batch"]
            Jobs["jobs"]
        end
    end

    subgraph AuthPlugins["Authentication & Authorization Plugins"]
        K8sAuthPlugin["kubernetes-auth Plugin<br/>(MLflow App Plugin)"]
        K8sWorkspace["kubernetes Workspace Provider<br/>(MLflow Workspace Plugin)"]
    end

    subgraph PseudoResource["Authorization Target"]
        PseudoRes["mlflow.kubeflow.org<br/>pseudo-resource<br/>(per-workspace RBAC)"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% ClusterRole permissions
    CR -->|"get, list, watch"| Namespaces
    CR -->|"get, list, watch"| MLflowConfigs
    CR -->|"create"| SSAR
    CR -->|"create, get, list,<br/>watch, delete"| Jobs

    %% Auth plugin flow
    K8sAuthPlugin -->|"creates SSAR<br/>for caller's token"| SSAR
    K8sAuthPlugin -->|"checks access to"| PseudoRes
    K8sWorkspace -->|"reads"| Namespaces
    K8sWorkspace -->|"reads"| MLflowConfigs

    %% Auth modes
    subgraph AuthModes["Request Authentication Modes"]
        BearerAuth["Bearer Token<br/>(K8s ServiceAccount)<br/>Primary"]
        BasicAuth["HTTP Basic Auth<br/>(basic_auth.ini)<br/>Fallback"]
    end

    subgraph Permissions["MLflow Permission Levels"]
        READ["READ<br/>View experiments, runs"]
        USE["USE<br/>Log metrics, create runs"]
        EDIT["EDIT<br/>Modify experiments, models"]
        MANAGE["MANAGE<br/>Admin operations"]
    end

    BearerAuth -->|"validated by"| K8sAuthPlugin
    BasicAuth -->|"validated by"| K8sAuthPlugin

    K8sAuthPlugin -->|"maps to"| READ
    K8sAuthPlugin -->|"maps to"| USE
    K8sAuthPlugin -->|"maps to"| EDIT
    K8sAuthPlugin -->|"maps to"| MANAGE

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style MLflowConfigs fill:#7ed321,stroke:#333,color:#fff
    style SSAR fill:#7ed321,stroke:#333,color:#fff
    style Jobs fill:#7ed321,stroke:#333,color:#fff
    style K8sAuthPlugin fill:#e74c3c,stroke:#333,color:#fff
    style K8sWorkspace fill:#e74c3c,stroke:#333,color:#fff
    style PseudoRes fill:#e67e22,stroke:#333,color:#fff
    style BearerAuth fill:#3498db,stroke:#333,color:#fff
    style BasicAuth fill:#95a5a6,stroke:#333,color:#fff
    style READ fill:#2ecc71,stroke:#333,color:#fff
    style USE fill:#2ecc71,stroke:#333,color:#fff
    style EDIT fill:#f39c12,stroke:#333,color:#fff
    style MANAGE fill:#e74c3c,stroke:#333,color:#fff
