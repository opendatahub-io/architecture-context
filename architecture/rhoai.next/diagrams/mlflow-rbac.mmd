graph TD
    subgraph "Service Accounts"
        SA_MLflow["mlflow-server<br/>(MLflow Server Pod)"]
        SA_Workload["ML Workload Pod SA<br/>(User namespace)"]
    end

    subgraph "Kubernetes RBAC"
        subgraph "ClusterRole"
            CR_Executor["mlflow-executor<br/>(Required for K8s project backend)"]
        end
    end

    subgraph "Kubernetes API Resources"
        BatchJobs["batch/jobs<br/>create, get, list, watch, delete"]
    end

    SA_MLflow -->|"bound via ClusterRoleBinding"| CR_Executor
    CR_Executor -->|"grants access to"| BatchJobs

    subgraph "kube-rbac-proxy Authentication"
        TokenValidation["K8s SA Token Validation<br/>8443/TCP HTTPS"]
    end

    SA_Workload -->|"Bearer Token"| TokenValidation
    TokenValidation -->|"validated, forwarded"| MLflowAuth

    subgraph "MLflow Internal Authorization"
        MLflowAuth["kubernetes-namespaced Auth Provider<br/>Resolves SA token → workspace"]

        subgraph "Permission Levels"
            direction LR
            READ["READ<br/>View experiments, runs,<br/>models, artifacts"]
            USE["USE<br/>Create runs,<br/>log metrics"]
            EDIT["EDIT<br/>Update experiments,<br/>modify models"]
            MANAGE["MANAGE<br/>Delete resources,<br/>manage permissions"]
        end

        subgraph "Protected Resource Types"
            Experiments["Experiments<br/>/api/2.0/mlflow/experiments/*"]
            Runs["Runs<br/>/api/2.0/mlflow/runs/*"]
            Models["Registered Models<br/>/api/2.0/mlflow/registered-models/*"]
            ModelVersions["Model Versions<br/>/api/2.0/mlflow/model-versions/*"]
            Workspaces["Workspaces<br/>/api/3.0/mlflow/workspaces/*"]
            GatewayEndpoints["Gateway Endpoints<br/>/api/3.0/mlflow/gateway/*"]
            Jobs["Jobs<br/>/ajax-api/3.0/jobs/*"]
        end

        subgraph "Workspace Isolation"
            WSMapping["K8s Namespace → MLflow Workspace<br/>1:1 mapping via X-MLFLOW-WORKSPACE header"]
            WSComposite["Composite Primary Keys<br/>(workspace column on all tables)"]
            WSDelete["Workspace Deletion Modes:<br/>RESTRICT | CASCADE | SET_DEFAULT"]
        end
    end

    MLflowAuth --> READ
    MLflowAuth --> USE
    MLflowAuth --> EDIT
    MLflowAuth --> MANAGE

    READ --> Experiments
    READ --> Runs
    READ --> Models
    READ --> ModelVersions
    USE --> Experiments
    USE --> Runs
    EDIT --> Experiments
    EDIT --> Runs
    EDIT --> Models
    EDIT --> ModelVersions
    MANAGE --> Workspaces
    MANAGE --> GatewayEndpoints
    MANAGE --> Jobs

    MLflowAuth --> WSMapping
    WSMapping --> WSComposite
    WSComposite --> WSDelete

    subgraph "Secrets Management"
        KEK["MLFLOW_CRYPTO_KEK_PASSPHRASE<br/>Opaque (env var)<br/>KEK for gateway secrets<br/>Manual rotation via mlflow crypto rotate-kek"]
        FlaskKey["MLFLOW_FLASK_SERVER_SECRET_KEY<br/>Opaque (env var)<br/>Session cookie signing"]
        DBCreds["Database Credentials<br/>Opaque (connection string)<br/>PostgreSQL URI"]
        GWKeys["AI Gateway Provider Keys<br/>Opaque (encrypted in DB)<br/>KEK envelope encryption"]
    end

    style SA_MLflow fill:#4a90e2,color:#fff
    style SA_Workload fill:#4a90e2,color:#fff
    style CR_Executor fill:#f5a623,color:#fff
    style BatchJobs fill:#7ed321,color:#fff
