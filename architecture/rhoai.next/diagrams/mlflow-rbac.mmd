graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["mlflow-server<br/>(operator namespace)"]
    end

    subgraph RoleBindings["Role Bindings (Managed by MLflow Operator)"]
        CRB1["ClusterRoleBinding<br/>(mlflowconfig access)"]
        CRB2["ClusterRoleBinding<br/>(namespace access)"]
        CRB3["ClusterRoleBinding<br/>(SSAR access)"]
    end

    subgraph ClusterRoles["Cluster Roles (Managed by MLflow Operator)"]
        CR1["ClusterRole<br/>(mlflowconfig-reader)"]
        CR2["ClusterRole<br/>(namespace-reader)"]
        CR3["ClusterRole<br/>(ssar-creator)"]
    end

    subgraph APIResources["API Resources"]
        MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs"]
        Namespaces["core ('')<br/>namespaces"]
        SSAR["authorization.k8s.io<br/>selfsubjectaccessreviews"]
    end

    subgraph AuthFlow["Authentication Flow (per API request)"]
        direction LR
        Token["Bearer Token<br/>(K8s SA token)"]
        AuthPlugin["kubernetes-auth plugin<br/>before_request handler"]
        SSARCheck["SelfSubjectAccessReview<br/>against mlflow.kubeflow.org<br/>pseudo-resources"]
        Decision["Allow / Deny"]

        Token --> AuthPlugin
        AuthPlugin --> SSARCheck
        SSARCheck --> Decision
    end

    subgraph WorkspaceRBAC["Workspace RBAC Model"]
        direction TB
        WSHeader["X-MLFLOW-WORKSPACE header"]
        NSMapping["Namespace → Workspace mapping"]
        WSFilter["workspace_aware_mixin<br/>Auto-filter SQLAlchemy queries"]
        DefaultPolicy["Default: NO_PERMISSIONS<br/>(when workspace enabled<br/>+ no explicit permission)"]

        WSHeader --> NSMapping
        NSMapping --> WSFilter
        WSFilter --> DefaultPolicy
    end

    subgraph CRD["Custom Resource Definition"]
        MLflowConfigCRD["MLflowConfig<br/>Group: mlflow.kubeflow.org<br/>Version: v1alpha1<br/>Scope: Namespaced<br/>Purpose: Per-namespace artifact<br/>storage overrides"]
    end

    %% Bindings
    SA -->|"bound via"| CRB1
    SA -->|"bound via"| CRB2
    SA -->|"bound via"| CRB3

    CRB1 -->|"grants"| CR1
    CRB2 -->|"grants"| CR2
    CRB3 -->|"grants"| CR3

    CR1 -->|"get, list, watch"| MLflowConfigs
    CR2 -->|"get, list, watch"| Namespaces
    CR3 -->|"create"| SSAR

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB1 fill:#5b9bd5,stroke:#333,color:#fff
    style CRB2 fill:#5b9bd5,stroke:#333,color:#fff
    style CRB3 fill:#5b9bd5,stroke:#333,color:#fff
    style CR1 fill:#f5a623,stroke:#333
    style CR2 fill:#f5a623,stroke:#333
    style CR3 fill:#f5a623,stroke:#333
    style MLflowConfigs fill:#7ed321,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style SSAR fill:#7ed321,stroke:#333
    style Token fill:#d9534f,stroke:#333,color:#fff
    style AuthPlugin fill:#d9534f,stroke:#333,color:#fff
    style SSARCheck fill:#d9534f,stroke:#333,color:#fff
    style Decision fill:#d9534f,stroke:#333,color:#fff
    style WSHeader fill:#9b59b6,stroke:#333,color:#fff
    style NSMapping fill:#9b59b6,stroke:#333,color:#fff
    style WSFilter fill:#9b59b6,stroke:#333,color:#fff
    style DefaultPolicy fill:#9b59b6,stroke:#333,color:#fff
    style MLflowConfigCRD fill:#f5a623,stroke:#333
