graph TB
    subgraph ClientSide["CLIENT-SIDE (User Workstation / Notebook)"]
        SDK["Kubeflow SDK<br/>Python Client Library<br/>pip install kubeflow"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>443/TCP → 6443<br/>TLS 1.2+<br/>Bearer Token / RBAC"]

        subgraph NS_Kubeflow["Namespace: kubeflow-system"]
            TrainerCtrl["Kubeflow Trainer Controller<br/>Watches TrainJob CRs"]
            ConfigMap["kubeflow-trainer-public<br/>ConfigMap"]
        end

        subgraph NS_Katib["Namespace: katib"]
            KatibCtrl["Katib Controller<br/>Watches Experiment CRs"]
        end

        subgraph NS_Spark["Namespace: spark-operator"]
            SparkOp["Spark Operator<br/>Watches SparkApplication CRs"]
        end
    end

    subgraph WorkloadPlane["WORKLOAD PLANE (Training Pods)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            TrainingPod["Training Pod (GPU Worker)<br/>RHAI code injected via heredoc<br/>No SDK deps in image"]
            MetricsServer["In-Pod Metrics Server<br/>28080/TCP HTTP<br/>⚠ NO AUTH<br/>⚠ bind 0.0.0.0"]
        end

        subgraph NS_RHOAI["RHOAI Controller"]
            RHOAICtrl["RHOAI Trainer Controller<br/>Polls progression via annotations<br/>trainer.opendatahub.io/*"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials<br/>⚠ SSL verify can be disabled"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        ModelReg["Model Registry Server<br/>443/TCP or 8080/TCP<br/>HTTP/HTTPS<br/>Bearer Token (optional)<br/>Custom CA supported"]
        PyPI["PyPI / Custom Index<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
    end

    subgraph LocalOnly["LOCAL ONLY (Dev)"]
        Docker["Docker/Podman<br/>Unix socket<br/>HTTP over Unix<br/>No encryption"]
    end

    %% Client to Control Plane
    SDK -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>CRD CRUD: TrainJob,<br/>Experiment, SparkApp"| K8sAPI

    %% Control Plane internal
    K8sAPI -->|"Watch stream<br/>TLS 1.2+"| TrainerCtrl
    K8sAPI -->|"Watch stream<br/>TLS 1.2+"| KatibCtrl
    K8sAPI -->|"Watch stream<br/>TLS 1.2+"| SparkOp
    TrainerCtrl -->|"Creates pods"| TrainingPod

    %% Metrics polling
    TrainingPod --- MetricsServer
    RHOAICtrl -->|"HTTP/28080<br/>No encryption<br/>No auth<br/>Poll metrics"| MetricsServer

    %% Training Pod egress
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| PyPI

    %% SDK direct
    SDK -->|"HTTP/HTTPS<br/>Bearer Token<br/>Custom CA"| ModelReg
    SDK -->|"Unix socket<br/>Local only"| Docker

    %% Styling
    classDef client fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef warning fill:#fce4ec,stroke:#c0392b,stroke-width:2px
    classDef local fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px

    class SDK client
    class K8sAPI,TrainerCtrl,KatibCtrl,SparkOp,ConfigMap controlplane
    class TrainingPod workload
    class MetricsServer warning
    class RHOAICtrl workload
    class S3,HFHub,ModelReg,PyPI external
    class Docker local
