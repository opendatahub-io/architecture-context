graph TD
    subgraph "OpenShift RBAC (inherited from oc adm must-gather)"
        SA_OCP["ServiceAccount<br/>must-gather<br/>(auto-created by framework)"]
        CRB_OCP["ClusterRoleBinding<br/>(managed by must-gather framework)"]
        CR_OCP["ClusterRole<br/>(must-gather framework RBAC)<br/>Broad read access"]

        SA_OCP -->|"bound via"| CRB_OCP
        CRB_OCP -->|"grants"| CR_OCP
    end

    subgraph "xKS RBAC (manually created by user)"
        SA_XKS["ServiceAccount<br/>must-gather-sa<br/>(user-chosen namespace)"]
        CRB_XKS["ClusterRoleBinding<br/>must-gather-reader-binding<br/>(cluster-wide)"]
        CR_XKS["ClusterRole<br/>must-gather-reader"]

        SA_XKS -->|"bound via"| CRB_XKS
        CRB_XKS -->|"grants"| CR_XKS
    end

    subgraph "xKS ClusterRole Permissions"
        AllGroups["API Groups: *<br/>(all API groups)"]
        AllResources["Resources: *<br/>(all resources)"]
    end

    CR_XKS -->|"get, list, watch"| AllGroups
    CR_XKS -->|"get, list, watch"| AllResources

    subgraph "Resources Accessed (Read-Only)"
        direction LR

        subgraph "Platform CRDs"
            DSCI["opendatahub.io<br/>DSCInitialization"]
            DSC["opendatahub.io<br/>DataScienceCluster"]
            PlatformSvc["services.platform.<br/>opendatahub.io/*"]
            PlatformComp["components.platform.<br/>opendatahub.io/*"]
        end

        subgraph "Component CRDs"
            IS["serving.kserve.io<br/>InferenceService"]
            SR["serving.kserve.io<br/>ServingRuntime"]
            DSPA["datasciencepipelines.<br/>opendatahub.io<br/>DSPApplication"]
            NB["kubeflow.org<br/>Notebook"]
            RC["ray.io<br/>RayCluster"]
            CQ["kueue.x-k8s.io<br/>ClusterQueue"]
            PTJ["kubeflow.org<br/>PyTorchJob"]
            MReg["modelregistry.<br/>opendatahub.io<br/>ModelRegistry"]
            TAI["trustyai.opendatahub.io<br/>TrustyAIService"]
        end

        subgraph "Infrastructure CRDs"
            GW["gateway.networking.k8s.io<br/>Gateway, HTTPRoute"]
            VS["networking.istio.io<br/>VirtualService"]
            Cert["cert-manager.io<br/>Certificate, Issuer"]
            SM["monitoring.coreos.com<br/>ServiceMonitor"]
            VAP["admissionregistration.k8s.io<br/>ValidatingAdmissionPolicy"]
        end

        subgraph "Core Resources"
            Pods["core<br/>Pods + Logs"]
            Svcs["core<br/>Services"]
            CMs["core<br/>ConfigMaps"]
            Secrets_res["core<br/>Secrets"]
            Nodes["core<br/>Nodes"]
        end
    end

    CR_OCP -->|"get, list, watch"| DSCI
    CR_OCP -->|"get, list, watch"| DSC
    CR_OCP -->|"get, list, watch"| IS
    CR_OCP -->|"get, list, watch"| Pods
    CR_OCP -->|"get, list, watch"| GW

    subgraph "Secrets Accessed"
        PullSecret["redhat-pull-secret<br/>(xKS only)<br/>kubernetes.io/dockerconfigjson<br/>Image pull for registry.redhat.io<br/>Manual provisioning, No auto-rotate"]
    end

    subgraph "Authentication"
        SAToken["ServiceAccount Bearer Token<br/>→ kube-apiserver (443/TCP HTTPS)<br/>Read-only operations: GET, LIST, WATCH"]
    end

    SA_OCP -->|"authenticates via"| SAToken
    SA_XKS -->|"authenticates via"| SAToken
    SA_XKS -.->|"uses (image pull)"| PullSecret

    style SA_OCP fill:#4a90e2,color:#fff
    style SA_XKS fill:#4a90e2,color:#fff
    style CR_OCP fill:#f5a623,color:#fff
    style CR_XKS fill:#f5a623,color:#fff
    style CRB_OCP fill:#e8e8e8
    style CRB_XKS fill:#e8e8e8
    style AllGroups fill:#7ed321,color:#fff
    style AllResources fill:#7ed321,color:#fff
