graph TD
    subgraph "OpenShift Mode (oc adm must-gather)"
        direction TB

        subgraph "Temporary RBAC (auto-created, auto-cleaned)"
            SA_OCP["ServiceAccount<br/>(auto-generated by must-gather framework)"]
            CRB_OCP["ClusterRoleBinding<br/>(temporary, auto-deleted on pod termination)"]
            CR_OCP["ClusterRole<br/>cluster-admin"]
        end

        subgraph "cluster-admin Permissions"
            AllResources_OCP["ALL API Groups<br/>ALL Resources<br/>ALL Verbs"]
        end

        SA_OCP -->|"bound via (temporary)"| CRB_OCP
        CRB_OCP -->|"grants"| CR_OCP
        CR_OCP -->|"* / * / *"| AllResources_OCP
    end

    subgraph "xKS Job Mode (Kubernetes Job)"
        direction TB

        subgraph "ServiceAccount"
            SA_XKS["must-gather-sa<br/>Namespace: must-gather"]
        end

        subgraph "ClusterRole Binding"
            CRB_XKS["must-gather-reader-binding<br/>Scope: Cluster-wide"]
        end

        subgraph "ClusterRole"
            CR_XKS["must-gather-reader"]
        end

        subgraph "Permissions (Read-Only)"
            AllAPI["API Groups: *<br/>Resources: *"]
        end

        subgraph "Allowed Verbs"
            Get["get"]
            List["list"]
            Watch["watch"]
        end

        SA_XKS -->|"bound via"| CRB_XKS
        CRB_XKS -->|"grants"| CR_XKS
        CR_XKS -->|"read-only access"| AllAPI
        AllAPI --> Get
        AllAPI --> List
        AllAPI --> Watch
    end

    subgraph "Image Pull Secret (xKS only)"
        direction TB
        Secret["redhat-pull-secret<br/>Type: kubernetes.io/dockerconfigjson"]
        Purpose["Purpose: Pull must-gather image<br/>from registry.redhat.io"]
        Provisioning["Provisioned: Manual (user-created)<br/>Auto-Rotate: No"]

        Secret --- Purpose
        Purpose --- Provisioning
    end

    subgraph "Resources Accessed (Both Modes)"
        direction LR
        PlatformCRs["Platform CRs<br/>DSCInitialization<br/>DataScienceCluster"]
        ComponentCRs["Component CRs<br/>InferenceService, DSPA,<br/>Notebook, RayCluster,<br/>ClusterQueue, ModelRegistry,<br/>+ 20 more CRD types"]
        InfraCRs["Infrastructure CRs<br/>Gateway, HTTPRoute,<br/>EnvoyFilter, Certificate,<br/>ServiceMonitor"]
        CoreResources["Core Resources<br/>Pods, Deployments,<br/>Services, ConfigMaps,<br/>Events, Logs"]
        ClusterResources["Cluster Resources<br/>Nodes, api-resources,<br/>ClusterRoles, CRDs"]
    end

    AllResources_OCP -.->|"reads"| PlatformCRs
    AllResources_OCP -.->|"reads"| ComponentCRs
    AllResources_OCP -.->|"reads"| InfraCRs
    AllResources_OCP -.->|"reads"| CoreResources
    AllResources_OCP -.->|"reads"| ClusterResources

    AllAPI -.->|"reads"| PlatformCRs
    AllAPI -.->|"reads"| ComponentCRs
    AllAPI -.->|"reads"| InfraCRs
    AllAPI -.->|"reads"| CoreResources
    AllAPI -.->|"reads"| ClusterResources

    %% Styling
    style SA_OCP fill:#4a90e2,color:#fff
    style SA_XKS fill:#4a90e2,color:#fff
    style CR_OCP fill:#e74c3c,color:#fff
    style CR_XKS fill:#f5a623,color:#fff
    style CRB_OCP fill:#9b59b6,color:#fff
    style CRB_XKS fill:#9b59b6,color:#fff
    style AllResources_OCP fill:#e74c3c,color:#fff
    style AllAPI fill:#f5a623
    style Get fill:#7ed321
    style List fill:#7ed321
    style Watch fill:#7ed321
    style Secret fill:#e8e8e8
    style PlatformCRs fill:#dae8fc,stroke:#6c8ebf
    style ComponentCRs fill:#dae8fc,stroke:#6c8ebf
    style InfraCRs fill:#dae8fc,stroke:#6c8ebf
    style CoreResources fill:#dae8fc,stroke:#6c8ebf
    style ClusterResources fill:#dae8fc,stroke:#6c8ebf
