graph TD
    subgraph OCPPath["OpenShift Path"]
        direction TB

        subgraph OCPInvocation["Invocation"]
            OCPUser["User / SRE<br/>(oc adm must-gather)"]
        end

        subgraph OCPFramework["Must-Gather Framework"]
            OCPPod["Must-Gather Pod<br/>Created by oc adm must-gather"]
        end

        subgraph OCPAuth["RBAC (Inherited)"]
            OCPClusterAdmin["cluster-admin<br/>(ClusterRole)"]
        end

        subgraph OCPScope["Effective Permissions"]
            OCPAllGroups["API Groups: *"]
            OCPAllResources["Resources: *"]
            OCPAllVerbs["Verbs: * (all)"]
            OCPAllNS["Scope: All namespaces"]
        end

        OCPUser -->|"invokes"| OCPPod
        OCPPod -->|"inherits"| OCPClusterAdmin
        OCPClusterAdmin -->|"grants"| OCPAllGroups
        OCPClusterAdmin -->|"grants"| OCPAllResources
        OCPClusterAdmin -->|"grants"| OCPAllVerbs
        OCPClusterAdmin -->|"grants"| OCPAllNS
    end

    subgraph XKSPath["xKS Path (AKS / EKS / CKS)"]
        direction TB

        subgraph XKSInvocation["Invocation"]
            XKSUser["User / SRE<br/>(kubectl apply -f job.yaml)"]
        end

        subgraph XKSServiceAccount["Service Account"]
            SA["must-gather-sa<br/>Namespace: must-gather"]
        end

        subgraph XKSBinding["ClusterRoleBinding"]
            CRB["must-gather-reader-binding<br/>Cluster-scoped"]
        end

        subgraph XKSRole["ClusterRole"]
            CR["must-gather-reader"]
        end

        subgraph XKSPermissions["Permissions"]
            XKSGroups["API Groups: *<br/>(all groups)"]
            XKSResources["Resources: *<br/>(all resources)"]
            XKSVerbs["Verbs: get, list, watch<br/>(read-only)"]
            XKSNS["Scope: All namespaces<br/>(cluster-scoped)"]
        end

        subgraph XKSTargets["Resource Types Accessed"]
            CRDs["CRDs: 50+ types<br/>InferenceService, DSPA,<br/>RayCluster, ModelRegistry,<br/>Gateway, Istio, etc."]
            CoreRes["Core: Pods, Deployments,<br/>Services, Events,<br/>ConfigMaps, Secrets"]
            ClusterRes["Cluster: Nodes, Namespaces,<br/>API Resources,<br/>ClusterRoles"]
            Logs["Pod Logs:<br/>current + previous<br/>containers"]
            HelmRes["Helm Secrets:<br/>helm.sh/release.v1"]
        end

        XKSUser -->|"creates Job"| SA
        SA -->|"bound via"| CRB
        CRB -->|"grants"| CR
        CR -->|"API Groups"| XKSGroups
        CR -->|"Resources"| XKSResources
        CR -->|"Verbs"| XKSVerbs
        CR -->|"Scope"| XKSNS

        XKSVerbs -->|"accesses"| CRDs
        XKSVerbs -->|"accesses"| CoreRes
        XKSVerbs -->|"accesses"| ClusterRes
        XKSVerbs -->|"accesses"| Logs
        XKSVerbs -->|"accesses"| HelmRes
    end

    subgraph Secrets["Secrets Used"]
        SAToken["ServiceAccount Token<br/>Type: Projected volume<br/>Auto-rotated by kubelet<br/>Purpose: API auth"]
        PullSecret["redhat-pull-secret (xKS only)<br/>Type: kubernetes.io/dockerconfigjson<br/>Purpose: Pull from registry.redhat.io<br/>Auto-rotate: No (manual)"]
    end

    OCPPod -.->|"mounts"| SAToken
    SA -.->|"mounts"| SAToken
    SA -.->|"uses"| PullSecret

    %% Styles
    style OCPClusterAdmin fill:#e74c3c,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style OCPUser fill:#4a90e2,stroke:#333,color:#fff
    style XKSUser fill:#4a90e2,stroke:#333,color:#fff
    style OCPPod fill:#6c8ebf,stroke:#333,color:#fff
    style CRDs fill:#7ed321,stroke:#333,color:#fff
    style CoreRes fill:#7ed321,stroke:#333,color:#fff
    style ClusterRes fill:#7ed321,stroke:#333,color:#fff
    style Logs fill:#7ed321,stroke:#333,color:#fff
    style HelmRes fill:#7ed321,stroke:#333,color:#fff
    style SAToken fill:#f0f0f0,stroke:#999
    style PullSecret fill:#f0f0f0,stroke:#999
