graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        Admin["Administrator<br/>(kubectl / helm / ArgoCD)"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        InfGW["inference-gateway<br/>443/TCP HTTPS, 80/TCP HTTP<br/>TLS: cert-manager (rhai-ca-issuer)<br/>TLS Mode: SIMPLE<br/>Cert: inference-gateway-cert<br/>GatewayClass: openshift-ai-inference"]
        MaasGW["maas-default-gateway<br/>HTTPS TLS"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-operator"]
            RHAIOp["RHAI Operator<br/>SA: rhai-operator-controller-manager<br/>9443/TCP webhook (TLS)<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)"]
            WebhookSvc["rhai-operator-webhook-service<br/>ClusterIP 9443/TCP → webhook-server<br/>HTTPS TLS (cert-manager)<br/>Secret: webhook-cert"]
            MetricsSvc["metrics-service<br/>ClusterIP 8080/TCP<br/>HTTP (no encryption)"]
        end

        subgraph NS_CloudMgr["Namespace: rhai-cloudmanager-system (xKS)"]
            AzureMgr["Azure Cloud Manager<br/>SA: azure-cloud-manager-operator<br/>8080/TCP HTTP"]
            CoreWeaveMgr["CoreWeave Cloud Manager<br/>SA: coreweave-cloud-manager-operator<br/>8080/TCP HTTP"]
            AWSMgr["AWS Cloud Manager<br/>SA: aws-cloud-manager-operator<br/>8080/TCP HTTP"]
        end

        subgraph NS_CertMgr["Namespace: cert-manager"]
            CertMgrOp["cert-manager Operator<br/>8443/TCP HTTPS TLS"]
        end

        subgraph NS_ServiceMesh["Namespace: istio-system"]
            SailOp["Sail Operator (Istio)<br/>8443/TCP HTTPS TLS"]
        end
    end

    subgraph OLMLayer["OPERATOR LIFECYCLE (OLM - OpenShift Only)"]
        OLM["OLM<br/>(Operator Lifecycle Manager)"]
        Catalog["CatalogSource<br/>50051/TCP gRPC TLS<br/>openshift-marketplace"]
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        RegistryRH["registry.redhat.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secret"]
        Quay["quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull Secret"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount Token"]
        CloudAPIs["Cloud Provider APIs<br/>(Azure/CoreWeave/AWS)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Cloud Credentials"]
    end

    %% External → Ingress flows
    Client -->|"HTTPS/443<br/>TLS (rhai-ca-issuer)<br/>Bearer Token"| InfGW
    Admin -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig"| K8sAPI

    %% Ingress → Services
    InfGW -->|"HTTP/gRPC<br/>mTLS (Istio)<br/>Authorino / kube-rbac-proxy"| RHAIOp

    %% OLM flows
    OLM -->|"gRPC/50051<br/>TLS<br/>cluster-internal"| Catalog
    OLM -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| RegistryRH
    OLM -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| Quay

    %% Operator → external
    RHAIOp -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull Secret"| RegistryRH
    RHAIOp -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Cloud managers → cloud
    AzureMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure Credentials"| CloudAPIs
    CoreWeaveMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>CoreWeave Credentials"| CloudAPIs
    AWSMgr -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Credentials"| CloudAPIs

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef olm fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,Admin external
    class InfGW,MaasGW ingress
    class RHAIOp,WebhookSvc,MetricsSvc,AzureMgr,CoreWeaveMgr,AWSMgr,CertMgrOp,SailOp cluster
    class OLM,Catalog olm
    class RegistryRH,Quay,K8sAPI,CloudAPIs externalservice
