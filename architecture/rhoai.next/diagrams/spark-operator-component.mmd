graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB
        subgraph ControllerProcess["Controller Manager"]
            Controller["spark-operator-controller<br/>Go Operator (controller-runtime)"]
            SAReconciler["SparkApplication<br/>Reconciler"]
            SSAReconciler["ScheduledSparkApplication<br/>Reconciler"]
            SCReconciler["SparkConnect<br/>Reconciler (alpha)"]
            Controller --> SAReconciler
            Controller --> SSAReconciler
            Controller --> SCReconciler
        end

        subgraph WebhookProcess["Webhook Server"]
            Webhook["spark-operator-webhook<br/>Port 9443/TCP TLS"]
            PodDefaulter["SparkPodDefaulter<br/>Mutates driver/executor pods"]
            SADefaulter["SparkApplication<br/>Defaulter"]
            SAValidator["SparkApplication<br/>Validator"]
            SSADefaulter["ScheduledSparkApplication<br/>Defaulter"]
            SSAValidator["ScheduledSparkApplication<br/>Validator"]
            Webhook --> PodDefaulter
            Webhook --> SADefaulter
            Webhook --> SAValidator
            Webhook --> SSADefaulter
            Webhook --> SSAValidator
        end
    end

    User["User / CI"] -->|"kubectl apply"| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    K8sAPI -->|"Admission webhook<br/>9443/TCP TLS"| Webhook
    K8sAPI -->|"Watch events"| Controller

    SAReconciler -->|"creates"| DriverPod["Spark Driver Pod<br/>via spark-submit"]
    DriverPod -->|"creates"| ExecutorPods["Spark Executor Pods<br/>7078/TCP, 7079/TCP"]

    SSAReconciler -->|"creates on cron schedule"| SparkAppCR["SparkApplication CR"]
    SparkAppCR -->|"reconciled by"| SAReconciler

    SCReconciler -->|"creates"| ConnectPod["SparkConnect Server Pod"]
    SCReconciler -->|"creates"| ConnectSvc["SparkConnect Service<br/>7078, 7079, 4040, 15002"]

    PodDefaulter -->|"injects volumes, env vars,<br/>sidecars, monitoring,<br/>security contexts"| DriverPod
    PodDefaulter -->|"injects volumes, env vars,<br/>sidecars, monitoring,<br/>security contexts"| ExecutorPods

    SAReconciler -->|"creates"| UISvc["{app}-ui-svc<br/>4040/TCP"]
    SAReconciler -->|"creates (optional)"| Ingress["{app}-ing<br/>Ingress"]

    subgraph CRDs["Custom Resource Definitions"]
        SparkApp["SparkApplication<br/>v1beta2"]
        ScheduledSparkApp["ScheduledSparkApplication<br/>v1beta2"]
        SparkConnect["SparkConnect<br/>v1alpha1"]
    end

    User -->|"creates"| SparkApp
    User -->|"creates"| ScheduledSparkApp
    User -->|"creates"| SparkConnect

    SparkApp -->|"watched by"| SAReconciler
    ScheduledSparkApp -->|"watched by"| SSAReconciler
    SparkConnect -->|"watched by"| SCReconciler

    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style PodDefaulter fill:#4a90e2,color:#fff
    style SAReconciler fill:#5ba3d9,color:#fff
    style SSAReconciler fill:#5ba3d9,color:#fff
    style SCReconciler fill:#5ba3d9,color:#fff
    style SparkApp fill:#f5a623,color:#fff
    style ScheduledSparkApp fill:#f5a623,color:#fff
    style SparkConnect fill:#f5a623,color:#fff
    style DriverPod fill:#7ed321,color:#fff
    style ExecutorPods fill:#7ed321,color:#fff
    style ConnectPod fill:#7ed321,color:#fff
    style K8sAPI fill:#e8e8e8,color:#333
    style User fill:#ddd,color:#333
