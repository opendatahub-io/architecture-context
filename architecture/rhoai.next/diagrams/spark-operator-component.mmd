graph TB
    subgraph SparkOperator["Spark Operator (v2.3.0)"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>Go Operator (controller-runtime)<br/>Watches CRs, manages Spark lifecycle"]
            SparkSubmit["spark-submit<br/>(local exec in controller pod)"]
            Controller -->|"executes"| SparkSubmit
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>Admission Webhook Server<br/>9443/TCP HTTPS"]
            MutatingPod["Pod Mutator<br/>(22 mutation steps)"]
            MutatingSA["SparkApplication<br/>Defaulter"]
            MutatingSSA["ScheduledSparkApp<br/>Defaulter"]
            ValidatingSA["SparkApplication<br/>Validator"]
            ValidatingSSA["ScheduledSparkApp<br/>Validator"]
            CertProvider["Certificate Provider<br/>(self-signed TLS)"]
            Webhook --> MutatingPod
            Webhook --> MutatingSA
            Webhook --> MutatingSSA
            Webhook --> ValidatingSA
            Webhook --> ValidatingSSA
            Webhook --> CertProvider
        end
    end

    %% CRDs
    User["User / Data Scientist"] -->|"kubectl apply"| SparkAppCR["SparkApplication CR<br/>(v1beta2)"]
    User -->|"kubectl apply"| ScheduledCR["ScheduledSparkApplication CR<br/>(v1beta2)"]
    User -->|"kubectl apply"| SparkConnectCR["SparkConnect CR<br/>(v1alpha1)"]

    %% Controller watches CRDs
    SparkAppCR -->|"watched by"| Controller
    ScheduledCR -->|"watched by"| Controller
    SparkConnectCR -->|"watched by"| Controller

    %% Controller creates resources
    Controller -->|"creates"| DriverPod["Spark Driver Pod<br/>7078/TCP, 7079/TCP"]
    DriverPod -->|"creates"| ExecutorPods["Spark Executor Pods<br/>7078/TCP, 7079/TCP"]
    Controller -->|"creates"| SparkUISvc["Spark UI Service<br/>4040/TCP"]
    Controller -->|"creates"| SparkConnectSvc["SparkConnect Service<br/>15002/TCP gRPC"]
    Controller -->|"creates (optional)"| SparkIngress["Ingress<br/>(optional, per app)"]

    %% Webhook intercepts
    K8sAPI["Kubernetes API Server"] -->|"admission review<br/>9443/TCP HTTPS"| Webhook
    Webhook -->|"mutated/validated"| K8sAPI

    %% External interactions
    Controller -->|"443/TCP HTTPS"| K8sAPI
    Webhook -->|"reads TLS profile"| OpenShiftAPI["OpenShift APIServer CR<br/>config.openshift.io"]

    %% Workbench access
    Workbench["ODH/RHOAI Workbench"] -->|"15002/TCP gRPC"| SparkConnectSvc
    Browser["Browser"] -->|"4040/TCP HTTP"| SparkUISvc

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333
    style ScheduledCR fill:#f5a623,stroke:#333
    style SparkConnectCR fill:#f5a623,stroke:#333
    style DriverPod fill:#7ed321,stroke:#333
    style ExecutorPods fill:#7ed321,stroke:#333
    style SparkUISvc fill:#b8e986,stroke:#333
    style SparkConnectSvc fill:#b8e986,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OpenShiftAPI fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
    style Workbench fill:#fff,stroke:#333
    style Browser fill:#fff,stroke:#333
