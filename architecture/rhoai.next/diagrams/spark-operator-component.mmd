graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator controller<br/>(Go, controller-runtime)<br/>Port: 8080/metrics, 8081/health"]
            SAController["SparkApplication<br/>Controller<br/>(13+ state machine)"]
            SSAController["ScheduledSparkApplication<br/>Controller<br/>(cron-based)"]
            SCController["SparkConnect<br/>Controller"]
            MWHController["MutatingWebhookConfig<br/>Controller"]
            VWHController["ValidatingWebhookConfig<br/>Controller"]
            CertProvider["Certificate Provider<br/>(self-signed / cert-manager)"]

            Controller --> SAController
            Controller --> SSAController
            Controller --> SCController
            Controller --> MWHController
            Controller --> VWHController
            Controller --> CertProvider
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator webhook<br/>(Go Admission Webhook)<br/>Port: 9443/HTTPS"]
            SADefaulter["SparkApplication<br/>Defaulter"]
            SAValidator["SparkApplication<br/>Validator"]
            SSADefaulter["ScheduledSparkApplication<br/>Defaulter"]
            SSAValidator["ScheduledSparkApplication<br/>Validator"]
            PodMutator["Spark Pod Mutator<br/>(25+ mutation ops)"]

            Webhook --> SADefaulter
            Webhook --> SAValidator
            Webhook --> SSADefaulter
            Webhook --> SSAValidator
            Webhook --> PodMutator
        end

        subgraph BatchSchedulers["Batch Scheduler Registry"]
            VolcanoSched["Volcano Scheduler"]
            KubeSched["kube-scheduler plugins"]
            YunikornSched["Yunikorn Scheduler"]
        end

        Controller --> BatchSchedulers
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| SparkAppCR["SparkApplication CR<br/>(v1beta2)"]
    User -->|creates| SSAppCR["ScheduledSparkApplication CR<br/>(v1beta2)"]
    User -->|creates| SCConnectCR["SparkConnect CR<br/>(v1alpha1)"]

    SparkAppCR -->|watched by| SAController
    SSAppCR -->|watched by| SSAController
    SCConnectCR -->|watched by| SCController

    %% Webhook intercepts
    SparkAppCR -->|admission| Webhook
    SSAppCR -->|admission| Webhook

    %% Controller creates workloads
    SAController -->|spark-submit| SparkSubmit["spark-submit<br/>(local exec)"]
    SparkSubmit -->|creates| DriverPod["Driver Pod<br/>(Java 17 / PySpark 4.0.1)"]
    DriverPod -->|creates| ExecutorPods["Executor Pods"]
    PodMutator -.->|mutates| DriverPod
    PodMutator -.->|mutates| ExecutorPods

    %% Controller creates resources
    SAController -->|creates| WebUISvc["Web UI Service<br/>:4040"]
    SAController -->|creates| Ingress["Ingress<br/>(optional)"]
    SCController -->|creates| ConnectSvc["Connect Service<br/>:15002, :7078, :7079, :4040"]

    %% External dependencies
    Controller -->|6443/HTTPS| K8sAPI["Kubernetes API Server"]
    K8sAPI -->|9443/HTTPS| Webhook

