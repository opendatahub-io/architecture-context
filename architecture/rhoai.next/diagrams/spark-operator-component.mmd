graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator controller<br/>(Go, controller-runtime)<br/>Port: 8080/TCP metrics<br/>Port: 8081/TCP probes"]
            SparkAppCtrl["SparkApplication<br/>Controller<br/>(13+ state machine)"]
            SchedCtrl["ScheduledSparkApplication<br/>Controller<br/>(cron-based)"]
            ConnectCtrl["SparkConnect<br/>Controller"]
            MutWHCtrl["MutatingWebhookConfig<br/>Controller<br/>(CA bundle sync)"]
            ValWHCtrl["ValidatingWebhookConfig<br/>Controller<br/>(CA bundle sync)"]
            Controller --- SparkAppCtrl
            Controller --- SchedCtrl
            Controller --- ConnectCtrl
            Controller --- MutWHCtrl
            Controller --- ValWHCtrl
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator webhook<br/>(Go, Admission Server)<br/>Port: 9443/TCP HTTPS"]
            CertProvider["Certificate Provider<br/>(self-signed or cert-manager)"]
            Webhook --- CertProvider
        end

        subgraph SchedulerRegistry["Batch Scheduler Registry"]
            Volcano["Volcano<br/>Scheduler"]
            KubeSched["kube-scheduler<br/>plugins"]
            Yunikorn["Yunikorn<br/>Scheduler"]
        end
    end

    %% CRDs
    SparkAppCR["SparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    SchedSparkAppCR["ScheduledSparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    SparkConnectCR["SparkConnect CR<br/>sparkoperator.k8s.io/v1alpha1"]

    %% User interaction
    User["User / Data Scientist"] -->|"kubectl apply"| SparkAppCR
    User -->|"kubectl apply"| SchedSparkAppCR
    User -->|"kubectl apply"| SparkConnectCR

    %% CR watching
    SparkAppCR -->|"watched by"| SparkAppCtrl
    SchedSparkAppCR -->|"watched by"| SchedCtrl
    SparkConnectCR -->|"watched by"| ConnectCtrl

    %% Webhook validation
    SparkAppCR -->|"admission"| Webhook
    SchedSparkAppCR -->|"admission"| Webhook

    %% Controller creates resources
    SparkAppCtrl -->|"spark-submit<br/>(local exec)"| SparkSubmit["spark-submit"]
    SparkSubmit -->|"creates via K8s API"| DriverPod["Driver Pod"]
    DriverPod -->|"creates"| ExecutorPods["Executor Pods"]
    SparkAppCtrl -->|"creates"| UISvc["Web UI Service<br/>4040/TCP"]
    SparkAppCtrl -->|"creates"| UIIngress["Web UI Ingress"]

    ConnectCtrl -->|"creates"| ConnectPod["Spark Connect<br/>Server Pod"]
    ConnectCtrl -->|"creates"| ConnectSvc["Connect Service<br/>15002/TCP gRPC"]

    %% Webhook mutates pods
    Webhook -->|"mutates pods<br/>(25+ mutations)"| DriverPod
    Webhook -->|"mutates pods"| ExecutorPods

    %% Scheduler integration
    SparkAppCtrl -->|"creates PodGroup"| Volcano
    SparkAppCtrl -->|"creates PodGroup"| KubeSched
    SparkAppCtrl -->|"injects annotations"| Yunikorn

    %% External
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    Controller -->|"CRUD operations"| K8sAPI
    Webhook -->|"called by"| K8sAPI

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333,color:#fff
    style SchedSparkAppCR fill:#f5a623,stroke:#333,color:#fff
    style SparkConnectCR fill:#f5a623,stroke:#333,color:#fff
    style DriverPod fill:#7ed321,stroke:#333,color:#fff
    style ExecutorPods fill:#7ed321,stroke:#333,color:#fff
    style ConnectPod fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style SparkSubmit fill:#d0d0d0,stroke:#333
    style User fill:#b8e6ff,stroke:#333
