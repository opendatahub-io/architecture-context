graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB

        subgraph ControllerDeployment["Controller Deployment"]
            Controller["spark-operator-controller<br/>(Go Operator)<br/>controller-runtime v0.20.4"]
            MWHController["MutatingWebhookConfig<br/>Controller"]
            VWHController["ValidatingWebhookConfig<br/>Controller"]
        end

        subgraph WebhookDeployment["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>(Admission Webhook)<br/>9443/TCP HTTPS"]
            PodDefaulter["SparkPod Defaulter<br/>(19 mutation functions)"]
            AppDefaulter["SparkApplication Defaulter"]
            AppValidator["SparkApplication Validator"]
            SSADefaulter["ScheduledSparkApplication<br/>Defaulter"]
            SSAValidator["ScheduledSparkApplication<br/>Validator"]
            Webhook --> PodDefaulter
            Webhook --> AppDefaulter
            Webhook --> AppValidator
            Webhook --> SSADefaulter
            Webhook --> SSAValidator
        end
    end

    %% CRDs
    User["User / Data Scientist"] -->|creates| SparkAppCR["SparkApplication CR<br/>(sparkoperator.k8s.io/v1beta2)"]
    User -->|creates| ScheduledCR["ScheduledSparkApplication CR<br/>(sparkoperator.k8s.io/v1beta2)"]
    User -->|creates| SparkConnectCR["SparkConnect CR<br/>(sparkoperator.k8s.io/v1alpha1)"]

    %% Controller watches
    SparkAppCR -->|watched by| Controller
    ScheduledCR -->|watched by| Controller
    SparkConnectCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|creates| DriverPod["Driver Pod<br/>(7078, 7079, 4040/TCP)"]
    Controller -->|creates| UIService["{app}-ui Service<br/>(4040/TCP)"]
    Controller -->|creates| UIIngress["{app}-ui Ingress<br/>(80/TCP)"]
    Controller -->|creates| MonitoringCM["Prometheus ConfigMap"]
    Controller -->|creates| SparkConnectSvc["SparkConnect Service<br/>(7078, 7079, 4040, 15002/TCP)"]

    %% Driver creates executors
    DriverPod -->|creates| ExecutorPods["Executor Pods<br/>(7078, 7079/TCP)"]
    DriverPod -->|Spark RPC| ExecutorPods

    %% Webhook intercepts
    K8sAPI["Kubernetes API Server"] -->|admission review| Webhook
    MWHController -->|syncs CA cert| MWHConfig["MutatingWebhookConfiguration"]
    VWHController -->|syncs CA cert| VWHConfig["ValidatingWebhookConfiguration"]

    %% Certificate management
    WebhookCerts["spark-operator-webhook-certs<br/>(Self-signed RSA-2048 CA)<br/>180-day auto-rotation"]
    WebhookCerts -.->|mounts| Webhook

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style MWHController fill:#6ca8e8,color:#fff
    style VWHController fill:#6ca8e8,color:#fff
    style PodDefaulter fill:#5b9bd5,color:#fff
    style AppDefaulter fill:#5b9bd5,color:#fff
    style AppValidator fill:#5b9bd5,color:#fff
    style SSADefaulter fill:#5b9bd5,color:#fff
    style SSAValidator fill:#5b9bd5,color:#fff
    style SparkAppCR fill:#f5a623,color:#333
    style ScheduledCR fill:#f5a623,color:#333
    style SparkConnectCR fill:#f5a623,color:#333
    style DriverPod fill:#7ed321,color:#333
    style ExecutorPods fill:#7ed321,color:#333
    style UIService fill:#b8e986,color:#333
    style UIIngress fill:#b8e986,color:#333
    style SparkConnectSvc fill:#b8e986,color:#333
    style MonitoringCM fill:#b8e986,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style WebhookCerts fill:#ff6b6b,color:#fff
    style MWHConfig fill:#e8e8e8,color:#333
    style VWHConfig fill:#e8e8e8,color:#333
