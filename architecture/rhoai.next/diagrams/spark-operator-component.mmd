graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB

        subgraph ControllerDeployment["Controller Deployment"]
            Controller["spark-operator controller<br/>Go Operator (controller-runtime)<br/>Ports: 8080/metrics, 8081/health"]
            SparkAppCtrl["SparkApplication Controller<br/>13+ state machine"]
            SchedCtrl["ScheduledSparkApplication Controller<br/>Cron-triggered"]
            ConnectCtrl["SparkConnect Controller<br/>Server lifecycle"]
            MutWebhookCtrl["MutatingWebhookConfig Controller<br/>CA bundle sync"]
            ValWebhookCtrl["ValidatingWebhookConfig Controller<br/>CA bundle sync"]
            Controller --> SparkAppCtrl
            Controller --> SchedCtrl
            Controller --> ConnectCtrl
            Controller --> MutWebhookCtrl
            Controller --> ValWebhookCtrl
        end

        subgraph WebhookDeployment["Webhook Deployment"]
            Webhook["spark-operator webhook<br/>Admission Webhook Server<br/>Port: 9443/HTTPS (TLS)"]
            MutateApp["Mutate SparkApplication<br/>(defaults)"]
            ValidateApp["Validate SparkApplication<br/>(DNS, quotas, selectors)"]
            MutateSched["Mutate ScheduledSparkApplication"]
            ValidateSched["Validate ScheduledSparkApplication"]
            MutatePod["Mutate Spark Pods<br/>(25+ mutations)"]
            Webhook --> MutateApp
            Webhook --> ValidateApp
            Webhook --> MutateSched
            Webhook --> ValidateSched
            Webhook --> MutatePod
        end

        subgraph Support["Support Libraries"]
            CertProvider["Certificate Provider<br/>Self-signed / cert-manager"]
            BatchScheduler["Batch Scheduler Registry<br/>Volcano / Yunikorn / kube-scheduler"]
        end
    end

    %% CRDs
    SparkAppCR["SparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    SchedSparkAppCR["ScheduledSparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    SparkConnectCR["SparkConnect CR<br/>sparkoperator.k8s.io/v1alpha1"]

    %% Users
    User["User / Data Scientist"]

    %% Created Resources
    DriverPod["Spark Driver Pod"]
    ExecutorPods["Spark Executor Pods"]
    UISvc["Spark Web UI Service<br/>4040/TCP"]
    SparkSubmit["spark-submit<br/>(local exec)"]

    %% External
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    Prometheus["Prometheus<br/>PodMonitor"]

    %% Flows
    User -->|creates| SparkAppCR
    User -->|creates| SchedSparkAppCR
    User -->|creates| SparkConnectCR

    SparkAppCR -->|watched by| SparkAppCtrl
    SchedSparkAppCR -->|watched by| SchedCtrl
    SparkConnectCR -->|watched by| ConnectCtrl

    SparkAppCtrl -->|invokes| SparkSubmit
    SparkSubmit -->|creates pods via| K8sAPI
    K8sAPI -->|admission callback| Webhook

    SparkAppCtrl -->|creates| UISvc
    SparkAppCtrl -->|monitors| DriverPod
    DriverPod -->|manages| ExecutorPods

    CertProvider -.->|TLS certs| Webhook
    BatchScheduler -.->|PodGroup mgmt| SparkAppCtrl

    Controller -->|CRUD| K8sAPI
    Prometheus -->|scrapes :8080| Controller

    %% Styles
    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style SparkAppCR fill:#f5a623,color:#fff
    style SchedSparkAppCR fill:#f5a623,color:#fff
    style SparkConnectCR fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8,color:#333
    style Prometheus fill:#e8e8e8,color:#333
    style DriverPod fill:#7ed321,color:#fff
    style ExecutorPods fill:#7ed321,color:#fff
    style SparkSubmit fill:#9b59b6,color:#fff
    style User fill:#3498db,color:#fff
