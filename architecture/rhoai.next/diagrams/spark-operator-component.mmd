graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB
        subgraph ControllerMgr["Controller Manager"]
            SAController[spark-operator-controller<br/>controller-runtime]
            SparkAppCtrl[SparkApplication<br/>Reconciler]
            SchedCtrl[ScheduledSparkApplication<br/>Reconciler]
            ConnCtrl[SparkConnect<br/>Reconciler]
            SAController --> SparkAppCtrl
            SAController --> SchedCtrl
            SAController --> ConnCtrl
        end

        subgraph WebhookServer["Webhook Server"]
            Webhook[spark-operator-webhook<br/>controller-runtime]
            PodDefaulter[SparkPod Defaulter<br/>volumes, env, sidecars,<br/>monitoring, security]
            AppDefaulter[SparkApplication<br/>Defaulter]
            AppValidator[SparkApplication<br/>Validator]
            SchedDefaulter[ScheduledSparkApplication<br/>Defaulter]
            SchedValidator[ScheduledSparkApplication<br/>Validator]
            Webhook --> PodDefaulter
            Webhook --> AppDefaulter
            Webhook --> AppValidator
            Webhook --> SchedDefaulter
            Webhook --> SchedValidator
        end
    end

    User[User / CI] -->|kubectl apply| K8sAPI[Kubernetes API Server]

    K8sAPI -->|admission webhook<br/>9443/TCP TLS| Webhook
    K8sAPI -->|watch/list events| SAController

    SparkAppCtrl -->|creates| SparkAppCR[SparkApplication CR<br/>sparkoperator.k8s.io/v1beta2]
    SparkAppCtrl -->|spark-submit| DriverPod[Driver Pod]
    DriverPod -->|creates| ExecutorPods[Executor Pods]
    DriverPod -->|7078, 7079/TCP| ExecutorPods

    SchedCtrl -->|cron trigger| SchedAppCR[ScheduledSparkApplication CR<br/>sparkoperator.k8s.io/v1beta2]
    SchedCtrl -->|creates child| SparkAppCR

    ConnCtrl -->|manages| ConnCR[SparkConnect CR<br/>sparkoperator.k8s.io/v1alpha1]
    ConnCtrl -->|creates| ConnPod[Connect Server Pod]
    ConnCtrl -->|creates| ConnSvc[Connect Service<br/>7078, 7079, 4040, 15002/TCP]

    SparkAppCtrl -->|creates| UISvc[Spark UI Service<br/>4040/TCP]
    SparkAppCtrl -->|creates| Ingress[Ingress Resource]

    PodDefaulter -->|mutates| DriverPod
    PodDefaulter -->|mutates| ExecutorPods

    %% External dependencies
    SparkAppCtrl -.->|optional| Volcano[Volcano Scheduler]
    SparkAppCtrl -.->|optional| Yunikorn[Yunikorn Scheduler]
    SparkAppCtrl -.->|optional| KubeSchedPlugins[kube-scheduler-plugins]
    Webhook -.->|optional TLS| CertManager[cert-manager]

    SAController -->|metrics 8080/TCP| Prometheus[Prometheus]

    style SAController fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333
    style SchedAppCR fill:#f5a623,stroke:#333
    style ConnCR fill:#f5a623,stroke:#333
    style DriverPod fill:#7ed321,stroke:#333
    style ExecutorPods fill:#7ed321,stroke:#333
    style ConnPod fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Volcano fill:#999,stroke:#333
    style Yunikorn fill:#999,stroke:#333
    style KubeSchedPlugins fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
