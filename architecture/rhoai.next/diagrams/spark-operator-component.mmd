graph TB
    subgraph SparkOperator["Spark Operator"]
        direction TB

        subgraph ControlPlane["Control Plane"]
            Controller["spark-operator controller<br/>(Go Operator)<br/>controller-runtime"]
            CertProvider["Certificate Provider<br/>(Self-signed / cert-manager)"]
        end

        subgraph AdmissionControl["Admission Control Plane"]
            Webhook["spark-operator webhook<br/>(Go Webhook Server)<br/>9443/TCP HTTPS"]
        end

        subgraph SchedulerAbstraction["Scheduler Registry (Pluggable)"]
            Volcano["Volcano Scheduler"]
            Yunikorn["Yunikorn Scheduler"]
            KubeSched["kube-scheduler<br/>PodGroups"]
        end
    end

    %% CRDs
    SparkAppCR["SparkApplication CR<br/>(v1beta2)"]
    ScheduledCR["ScheduledSparkApplication CR<br/>(v1beta2)"]
    SparkConnectCR["SparkConnect CR<br/>(v1alpha1)"]

    %% User interaction
    User["User / Data Scientist"] -->|creates| SparkAppCR
    User -->|creates| ScheduledCR
    User -->|creates| SparkConnectCR

    %% CR to Controller
    SparkAppCR -->|watched by| Controller
    ScheduledCR -->|watched by| Controller
    SparkConnectCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|spark-submit| SparkSubmit["spark-submit<br/>(subprocess)"]
    SparkSubmit -->|creates| DriverPod["Driver Pod"]
    SparkSubmit -->|creates| ExecutorPods["Executor Pods"]

    Controller -->|creates| UISvc["{app}-ui-svc<br/>Service"]
    Controller -->|creates| UIIngress["{app}-ui-ingress<br/>Ingress"]
    Controller -->|creates| MonitorCM["Monitoring ConfigMap<br/>(Prometheus)"]

    %% Webhook mutation
    K8sAPI["Kubernetes API Server"] -->|admission review| Webhook
    Webhook -->|validates| SparkAppCR
    Webhook -->|defaults| SparkAppCR
    Webhook -->|mutates pods| DriverPod
    Webhook -->|mutates pods| ExecutorPods

    %% Certificate management
    CertProvider -->|provisions TLS| Webhook

    %% Scheduler integration
    Controller -->|gang scheduling| SchedulerAbstraction

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style CertProvider fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333,color:#fff
    style ScheduledCR fill:#f5a623,stroke:#333,color:#fff
    style SparkConnectCR fill:#f5a623,stroke:#333,color:#fff
    style DriverPod fill:#7ed321,stroke:#333,color:#fff
    style ExecutorPods fill:#7ed321,stroke:#333,color:#fff
    style SparkSubmit fill:#9b59b6,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Volcano fill:#95a5a6,stroke:#333,color:#fff
    style Yunikorn fill:#95a5a6,stroke:#333,color:#fff
    style KubeSched fill:#95a5a6,stroke:#333,color:#fff
