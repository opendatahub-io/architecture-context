graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            TenantReconciler["Tenant Reconciler<br/>Platform lifecycle mgmt"]
            ModelRefReconciler["MaaSModelRef Reconciler<br/>Model endpoint tracking"]
            AuthPolicyReconciler["MaaSAuthPolicy Reconciler<br/>Access control aggregation"]
            SubscriptionReconciler["MaaSSubscription Reconciler<br/>Rate limit aggregation"]
            ExternalModelReconciler["ExternalModel Reconciler<br/>External provider routing"]
        end

        subgraph API["maas-api (Go HTTP Service - Gin)"]
            APIKeyHandler["API Key Handler<br/>CRUD, validation, revocation"]
            ModelDiscovery["Model Discovery<br/>KServe model probing"]
            SubscriptionSelector["Subscription Selector<br/>Authorino callback"]
            HealthEndpoint["Health Endpoint"]
        end

        subgraph BBR["payload-processing (BBR ext-proc)"]
            ModelToHeader["model-to-header plugin<br/>Extract model from body"]
            ProviderResolver["model-provider-resolver<br/>Resolve ExternalModel"]
            APITranslation["api-translation plugin<br/>Format translation"]
            KeyInjection["apikey-injection plugin<br/>Credential injection"]
        end
    end

    %% CRDs
    TenantCR["Tenant CR<br/>(singleton: default-tenant)"]
    ModelRefCR["MaaSModelRef CR"]
    AuthPolicyCR["MaaSAuthPolicy CR"]
    SubscriptionCR["MaaSSubscription CR"]
    ExternalModelCR["ExternalModel CR"]

    %% User interactions
    User["Data Scientist / Platform Admin"]
    User -->|creates| TenantCR
    User -->|creates| ModelRefCR
    User -->|creates| AuthPolicyCR
    User -->|creates| SubscriptionCR
    User -->|creates| ExternalModelCR

    %% Controller watches
    TenantCR -->|watched by| TenantReconciler
    ModelRefCR -->|watched by| ModelRefReconciler
    AuthPolicyCR -->|watched by| AuthPolicyReconciler
    SubscriptionCR -->|watched by| SubscriptionReconciler
    ExternalModelCR -->|watched by| ExternalModelReconciler

    %% Controller creates
    AuthPolicyReconciler -->|creates aggregated| KuadrantAuthPolicy["Kuadrant AuthPolicy<br/>(1 per model HTTPRoute)"]
    SubscriptionReconciler -->|creates aggregated| KuadrantTRLP["Kuadrant TokenRateLimitPolicy<br/>(1 per model HTTPRoute)"]
    ExternalModelReconciler -->|creates| IstioSE["Istio ServiceEntry"]
    ExternalModelReconciler -->|creates| IstioDR["Istio DestinationRule"]
    ExternalModelReconciler -->|creates| HTTPRoute["Gateway API HTTPRoute"]
    TenantReconciler -->|deploys via kustomize| API
    TenantReconciler -->|deploys via kustomize| BBR

    %% API dependencies
    APIKeyHandler -->|stores keys| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    ModelDiscovery -->|probes| KServeIS["KServe InferenceService"]
    SubscriptionSelector -->|reads| SubscriptionCR

    %% BBR flow
    Gateway["Gateway<br/>(maas-default-gateway)<br/>443/TCP"] -->|ext-proc| ModelToHeader
    ModelToHeader --> ProviderResolver
    ProviderResolver --> APITranslation
    APITranslation --> KeyInjection

    %% External integrations
    Gateway -->|Authorino callback| APIKeyHandler
    Gateway -->|Authorino callback| SubscriptionSelector
    KuadrantAuthPolicy -->|enforced by| Authorino["Authorino"]
    KuadrantTRLP -->|enforced by| Limitador["Limitador"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#50a0d0,stroke:#333,color:#fff
    style BBR fill:#5ab0e0,stroke:#333,color:#fff
    style TenantCR fill:#f5a623,stroke:#333
    style ModelRefCR fill:#f5a623,stroke:#333
    style AuthPolicyCR fill:#f5a623,stroke:#333
    style SubscriptionCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style KuadrantAuthPolicy fill:#7ed321,stroke:#333
    style KuadrantTRLP fill:#7ed321,stroke:#333
    style Authorino fill:#999,stroke:#333
    style Limitador fill:#999,stroke:#333
    style PostgreSQL fill:#999,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style IstioSE fill:#7ed321,stroke:#333
    style IstioDR fill:#7ed321,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style KServeIS fill:#999,stroke:#333
