graph TB
    subgraph MaaS["Models as a Service (MaaS) Platform"]
        direction TB

        subgraph ControlPlane["Control Plane (opendatahub namespace)"]
            Controller["maas-controller<br/>Go Operator (controller-runtime)<br/>:8080 metrics, :8081 health"]
            TenantCR["Tenant CR<br/>(default-tenant)"]
            Controller -->|reconciles| TenantCR
        end

        subgraph DataPlane["Data Plane"]
            subgraph APIServer["API Server (opendatahub namespace)"]
                MaaSAPI["maas-api<br/>Go HTTP (Gin)<br/>:8080/HTTP or :8443/HTTPS"]
            end

            subgraph GatewayNS["Gateway (openshift-ingress namespace)"]
                BBR["payload-processing (BBR)<br/>Go gRPC ext_proc<br/>:9004/gRPC, :9005/metrics"]
            end
        end
    end

    %% CRDs
    subgraph CRDs["MaaS Custom Resources (maas.opendatahub.io/v1alpha1)"]
        ModelRef["MaaSModelRef"]
        AuthPolicy["MaaSAuthPolicy"]
        Subscription["MaaSSubscription"]
        ExtModel["ExternalModel"]
        Tenant["Tenant"]
    end

    %% Controller reconciliation
    Controller -->|"watches & reconciles"| ModelRef
    Controller -->|"watches & reconciles"| AuthPolicy
    Controller -->|"watches & reconciles"| Subscription
    Controller -->|"watches & reconciles"| ExtModel
    Controller -->|"watches & reconciles"| Tenant

    %% Generated resources
    subgraph Generated["Generated Resources"]
        HTTPRoutes["HTTPRoute<br/>(Gateway API)"]
        KuadrantAuth["AuthPolicy<br/>(Kuadrant)"]
        TRLP["TokenRateLimitPolicy<br/>(Kuadrant)"]
        ServiceEntry["ServiceEntry<br/>(Istio)"]
        DestRule["DestinationRule<br/>(Istio)"]
        EnvoyFilter["EnvoyFilter<br/>(Istio)"]
    end

    Controller -->|creates| HTTPRoutes
    Controller -->|creates| KuadrantAuth
    Controller -->|creates| TRLP
    Controller -->|creates| ServiceEntry
    Controller -->|creates| DestRule
    Controller -->|creates| EnvoyFilter

    %% Tenant deploys components
    Controller -->|"deploys via kustomize"| MaaSAPI
    Controller -->|"deploys via kustomize"| BBR

    %% External interactions
    Admin["Administrator"] -->|"creates CRDs"| CRDs
    Client["External Client"] -->|"HTTPS/443"| Gateway["maas-default-gateway<br/>Gateway API"]

    Gateway -->|"routes to"| MaaSAPI
    Gateway -->|"ext_proc"| BBR
    MaaSAPI -->|"informer cache"| CRDs

    %% Backends
    MaaSAPI -->|"5432/TCP"| PostgreSQL["PostgreSQL<br/>API Key Storage"]
    BBR -->|"reads Secrets"| K8sAPI["Kubernetes API"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style MaaSAPI fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style ModelRef fill:#f5a623,stroke:#333
    style AuthPolicy fill:#f5a623,stroke:#333
    style Subscription fill:#f5a623,stroke:#333
    style ExtModel fill:#f5a623,stroke:#333
    style Tenant fill:#f5a623,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style KuadrantAuth fill:#7ed321,stroke:#333
    style TRLP fill:#7ed321,stroke:#333
    style ServiceEntry fill:#7ed321,stroke:#333
    style DestRule fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Gateway fill:#d5e8d4,stroke:#82b366
    style Client fill:#f9f9f9,stroke:#999
    style Admin fill:#f9f9f9,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#333
