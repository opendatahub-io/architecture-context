graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            AITenantReconciler["AITenant<br/>Reconciler"]
            TenantReconciler["Tenant<br/>Reconciler"]
            ModelRefReconciler["MaaSModelRef<br/>Reconciler"]
            SubReconciler["MaaSSubscription<br/>Reconciler"]
            AuthPolicyReconciler["MaaSAuthPolicy<br/>Reconciler"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
            LifecycleReconciler["Lifecycle<br/>Reconciler"]
            WebhookServer["Webhook Server<br/>9443/TCP"]
        end

        subgraph API["maas-api (Go REST Service / Gin)"]
            APIKeyHandler["API Key<br/>Handler"]
            ModelHandler["Model<br/>Handler"]
            SubscriptionHandler["Subscription<br/>Handler"]
            InternalValidate["Internal:<br/>Key Validate"]
            InternalSelect["Internal:<br/>Sub Select"]
        end

        subgraph PayloadProc["Payload Processing (ext_proc)"]
            PreProc["payload-pre-processing<br/>9004/TCP gRPC<br/>Model name extraction"]
            PostProc["payload-processing<br/>9004/TCP gRPC<br/>API translation +<br/>credential injection"]
        end
    end

    %% CRDs
    subgraph CRDs["Custom Resources"]
        AITenantCR["AITenant CR"]
        TenantCR["Tenant CR"]
        ConfigCR["Config CR"]
        ModelRefCR["MaaSModelRef CR"]
        SubscriptionCR["MaaSSubscription CR"]
        AuthPolicyCR["MaaSAuthPolicy CR"]
        ExternalModelCR["ExternalModel CR"]
        ExternalProviderCR["ExternalProvider CR"]
    end

    %% External Dependencies
    subgraph ExtDeps["External Dependencies"]
        Kuadrant["Kuadrant<br/>(Authorino + Limitador)"]
        GatewayAPI["Gateway API<br/>(HTTPRoute)"]
        Istio["Istio Service Mesh<br/>(mTLS, ServiceEntry,<br/>DestinationRule, EnvoyFilter)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        KServe["KServe<br/>(LLMInferenceService)"]
    end

    %% Users
    User["Platform Admin /<br/>Data Scientist"]
    Client["External Client"]

    %% User interactions
    User -->|"creates/manages"| AITenantCR
    User -->|"creates"| ModelRefCR
    User -->|"creates"| SubscriptionCR
    User -->|"creates"| AuthPolicyCR
    Client -->|"inference request<br/>443/TCP HTTPS"| GatewayAPI

    %% Controller watches
    AITenantCR -->|"watched by"| AITenantReconciler
    TenantCR -->|"watched by"| TenantReconciler
    ConfigCR -->|"watched by"| LifecycleReconciler
    ModelRefCR -->|"watched by"| ModelRefReconciler
    SubscriptionCR -->|"watched by"| SubReconciler
    AuthPolicyCR -->|"watched by"| AuthPolicyReconciler
    ExternalModelCR -->|"watched by"| ExternalModelReconciler

    %% Controller creates
    AITenantReconciler -->|"creates namespace,<br/>RBAC, Gateway ref"| TenantCR
    TenantReconciler -->|"deploys via<br/>kustomize + SSA"| API
    TenantReconciler -->|"creates"| GatewayAPI
    ModelRefReconciler -->|"creates HTTPRoute,<br/>AuthPolicy, RateLimitPolicy"| Kuadrant
    ModelRefReconciler -->|"checks governance"| SubscriptionCR
    ModelRefReconciler -->|"checks governance"| AuthPolicyCR
    ExternalModelReconciler -->|"creates ServiceEntry,<br/>DestinationRule, HTTPRoute"| Istio

    %% API dependencies
    APIKeyHandler -->|"hash storage"| PostgreSQL
    InternalValidate -->|"key validation<br/>callback"| Kuadrant
    InternalSelect -->|"subscription selection<br/>callback"| Kuadrant
    ModelHandler -->|"informer cache"| ModelRefCR

    %% Gateway flow
    GatewayAPI -->|"pre-auth ext_proc"| PreProc
    GatewayAPI -->|"auth evaluation"| Kuadrant
    GatewayAPI -->|"post-auth ext_proc"| PostProc

    %% KServe integration
    ModelRefReconciler -->|"discovers endpoints"| KServe

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#50c878,stroke:#333,color:#fff
    style PayloadProc fill:#9b59b6,stroke:#333,color:#fff
    style CRDs fill:#f5a623,stroke:#333,color:#000
    style ExtDeps fill:#e8e8e8,stroke:#333,color:#000
    style User fill:#fff,stroke:#333
    style Client fill:#fff,stroke:#333
    style MaaS fill:#f0f4ff,stroke:#4a90e2,stroke-width:2px
