graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            MaaSModelRefReconciler["MaaSModelRef<br/>Reconciler"]
            MaaSAuthPolicyReconciler["MaaSAuthPolicy<br/>Reconciler"]
            MaaSSubscriptionReconciler["MaaSSubscription<br/>Reconciler"]
            TenantReconciler["Tenant<br/>Reconciler"]
            AITenantReconciler["AITenant<br/>Reconciler"]
            LifecycleReconciler["Lifecycle<br/>Reconciler"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
            Webhook["Webhook Server<br/>443/TCP"]
        end

        subgraph API["maas-api (Go HTTP Service)"]
            ModelDiscovery["/v1/models<br/>OpenAI-compatible"]
            APIKeyMgmt["/v1/api-keys<br/>CRUD + Validation"]
            SubscriptionEP["/v1/subscriptions<br/>Selection"]
            InternalEP["/internal/v1/*<br/>Authorino Callbacks"]
        end

        subgraph PayloadProc["payload-processing (Envoy ext_proc)"]
            PreAuth["Pre-Auth Stage<br/>Model Extraction"]
            PostAuth["Post-Auth Stage<br/>Provider Resolution<br/>API Translation<br/>Key Injection"]
        end
    end

    %% CRDs
    AITenantCR["AITenant CR"]
    TenantCR["Tenant CR"]
    MaaSModelRefCR["MaaSModelRef CR"]
    MaaSAuthPolicyCR["MaaSAuthPolicy CR"]
    MaaSSubscriptionCR["MaaSSubscription CR"]
    ExternalModelCR["ExternalModel CR"]
    ConfigCR["Config CR<br/>(cluster-scoped)"]

    %% Kuadrant Policy CRs (generated)
    AuthPolicyCR["Kuadrant<br/>AuthPolicy CR"]
    TokenRateLimitCR["Kuadrant<br/>TokenRateLimitPolicy CR"]
    TelemetryPolicyCR["Kuadrant<br/>TelemetryPolicy CR"]

    %% Gateway API Resources (generated)
    HTTPRoute["HTTPRoute<br/>(per-model)"]
    Gateway["maas-default-gateway<br/>Gateway"]

    %% Istio Resources (generated)
    EnvoyFilter["EnvoyFilter"]
    DestinationRule["DestinationRule"]
    ServiceEntry["ServiceEntry"]

    %% External Systems
    Client["External Client"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    K8sAPI["Kubernetes API<br/>443/TCP"]
    Authorino["Authorino"]

    %% CR Watches
    AITenantCR -->|watched by| AITenantReconciler
    TenantCR -->|watched by| TenantReconciler
    MaaSModelRefCR -->|watched by| MaaSModelRefReconciler
    MaaSAuthPolicyCR -->|watched by| MaaSAuthPolicyReconciler
    MaaSSubscriptionCR -->|watched by| MaaSSubscriptionReconciler
    ExternalModelCR -->|watched by| ExternalModelReconciler

    %% Controller Creates
    MaaSModelRefReconciler -->|creates| HTTPRoute
    MaaSAuthPolicyReconciler -->|creates| AuthPolicyCR
    MaaSSubscriptionReconciler -->|creates| TokenRateLimitCR
    TenantReconciler -->|deploys| API
    TenantReconciler -->|deploys| PayloadProc
    TenantReconciler -->|creates| EnvoyFilter
    TenantReconciler -->|creates| DestinationRule
    TenantReconciler -->|creates| TelemetryPolicyCR
    AITenantReconciler -->|creates| TenantCR
    LifecycleReconciler -->|creates| ConfigCR
    ExternalModelReconciler -->|creates| ServiceEntry

    %% Request Flow
    Client -->|HTTPS/443| Gateway
    Gateway -->|ext_proc/9004| PreAuth
    Gateway -->|HTTPS/443| Authorino
    Authorino -->|callback/8443| InternalEP
    Gateway -->|ext_proc/9004| PostAuth

    %% API Dependencies
    APIKeyMgmt -->|5432/TCP| PostgreSQL
    ModelDiscovery -->|443/TCP| K8sAPI

    %% Webhook
    Webhook -->|validates| AITenantCR
    Webhook -->|validates| MaaSSubscriptionCR
    Webhook -->|validates| MaaSAuthPolicyCR

    %% Styles
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#50c878,stroke:#333,color:#fff
    style PayloadProc fill:#9b59b6,stroke:#333,color:#fff
    style MaaSModelRefCR fill:#f5a623,stroke:#333
    style MaaSAuthPolicyCR fill:#f5a623,stroke:#333
    style MaaSSubscriptionCR fill:#f5a623,stroke:#333
    style AITenantCR fill:#f5a623,stroke:#333
    style TenantCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style ConfigCR fill:#f5a623,stroke:#333
    style AuthPolicyCR fill:#e67e22,stroke:#333
    style TokenRateLimitCR fill:#e67e22,stroke:#333
    style TelemetryPolicyCR fill:#e67e22,stroke:#333
    style HTTPRoute fill:#3498db,stroke:#333
    style Gateway fill:#3498db,stroke:#333
    style EnvoyFilter fill:#8e44ad,stroke:#333,color:#fff
    style DestinationRule fill:#8e44ad,stroke:#333,color:#fff
    style ServiceEntry fill:#8e44ad,stroke:#333,color:#fff
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Authorino fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
