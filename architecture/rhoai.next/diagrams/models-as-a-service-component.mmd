graph TB
    subgraph MaaS["Models as a Service (MaaS) Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            MaaSModelRefCtrl["MaaSModelRef<br/>Controller"]
            MaaSAuthCtrl["MaaSAuthPolicy<br/>Controller"]
            MaaSSubCtrl["MaaSSubscription<br/>Controller"]
            TenantCtrl["Tenant<br/>Controller"]
            ExtModelCtrl["ExternalModel<br/>Controller"]
        end

        subgraph API["maas-api (Go/Gin HTTP Service)"]
            ModelsHandler["Models Handler<br/>/v1/models"]
            APIKeyHandler["API Key Handler<br/>/v1/api-keys"]
            SubHandler["Subscription Handler<br/>/v1/subscriptions"]
            InternalAPI["Internal API<br/>/internal/v1/*"]
        end

        subgraph BBR["payload-processing (BBR ext_proc)"]
            ModelExtract["Model Extraction<br/>body → X-Gateway-Model-Name"]
            ProviderResolve["Provider Resolution<br/>ExternalModel CRD lookup"]
            APITranslation["API Translation<br/>OpenAI ↔ backend"]
            CredInjection["Credential Injection<br/>Secret → API key header"]
        end
    end

    %% CRDs
    ExternalModelCR["ExternalModel CR"]
    MaaSModelRefCR["MaaSModelRef CR"]
    MaaSAuthPolicyCR["MaaSAuthPolicy CR"]
    MaaSSubscriptionCR["MaaSSubscription CR"]
    TenantCR["Tenant CR<br/>(singleton: default-tenant)"]

    %% Generated Resources
    HTTPRoute["HTTPRoute<br/>(per-model)"]
    AuthPolicy["Kuadrant<br/>AuthPolicy"]
    TRLP["Kuadrant<br/>TokenRateLimitPolicy"]
    ServiceEntry["Istio<br/>ServiceEntry"]
    DestRule["Istio<br/>DestinationRule"]
    EnvoyFilter["Istio<br/>EnvoyFilter"]

    %% External Systems
    Client["External Client"]
    Gateway["maas-default-gateway<br/>(Gateway API)"]
    Authorino["Kuadrant Authorino"]
    Limitador["Kuadrant Limitador"]
    KServe["KServe<br/>LLMInferenceService"]
    PostgreSQL["PostgreSQL"]
    ExtProviders["External Providers<br/>(OpenAI, Anthropic, etc.)"]

    %% CRD → Controller watches
    MaaSModelRefCR -->|watched by| MaaSModelRefCtrl
    MaaSAuthPolicyCR -->|watched by| MaaSAuthCtrl
    MaaSSubscriptionCR -->|watched by| MaaSSubCtrl
    TenantCR -->|watched by| TenantCtrl
    ExternalModelCR -->|watched by| ExtModelCtrl

    %% Controller → Generated Resources
    MaaSModelRefCtrl -->|creates| HTTPRoute
    MaaSAuthCtrl -->|creates/aggregates| AuthPolicy
    MaaSSubCtrl -->|creates/aggregates| TRLP
    ExtModelCtrl -->|creates| ServiceEntry
    ExtModelCtrl -->|creates| DestRule
    TenantCtrl -->|deploys via kustomize| API
    TenantCtrl -->|deploys via kustomize| BBR
    TenantCtrl -->|creates| EnvoyFilter

    %% Client flow
    Client -->|HTTPS/443| Gateway
    Gateway -->|gRPC/5001| Authorino
    Gateway -->|gRPC/9004| BBR
    Gateway -->|gRPC/8081| Limitador
    Gateway -->|HTTPRoute| KServe
    Gateway -->|HTTPRoute| ExtProviders

    %% Authorino → maas-api callbacks
    Authorino -->|validate key| InternalAPI
    Authorino -->|select subscription| InternalAPI

    %% maas-api dependencies
    APIKeyHandler -->|hash store| PostgreSQL
    ModelsHandler -->|probe /v1/models| KServe

    %% BBR dependencies
    ProviderResolve -->|reads| ExternalModelCR
    CredInjection -->|reads Secret| ExtProviders

    %% Styles
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#50c878,stroke:#333,color:#fff
    style BBR fill:#9b59b6,stroke:#333,color:#fff
    style MaaSModelRefCR fill:#f5a623,stroke:#333
    style MaaSAuthPolicyCR fill:#f5a623,stroke:#333
    style MaaSSubscriptionCR fill:#f5a623,stroke:#333
    style TenantCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style HTTPRoute fill:#e8e8e8,stroke:#666
    style AuthPolicy fill:#e8e8e8,stroke:#666
    style TRLP fill:#e8e8e8,stroke:#666
    style ServiceEntry fill:#e8e8e8,stroke:#666
    style DestRule fill:#e8e8e8,stroke:#666
    style EnvoyFilter fill:#e8e8e8,stroke:#666
    style Gateway fill:#ff6b6b,stroke:#333,color:#fff
    style Authorino fill:#e74c3c,stroke:#333,color:#fff
    style Limitador fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#3498db,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style ExtProviders fill:#f39c12,stroke:#333
