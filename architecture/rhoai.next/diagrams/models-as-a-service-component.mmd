graph TB
    subgraph MaaS["Models as a Service (MaaS) Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            TenantRec[TenantReconciler]
            ModelRefRec[MaaSModelRefReconciler]
            SubRec[MaaSSubscriptionReconciler]
            AuthPolicyRec[MaaSAuthPolicyReconciler]
            LifecycleRec[LifecycleReconciler]
            ExtModelRec[ExternalModelReconciler]
            ConflictDet[Conflict Detection]
        end

        subgraph API["maas-api (Go REST Service - Gin)"]
            HealthEP["/health"]
            ModelsEP["/v1/models"]
            APIKeysEP["/v1/api-keys/*"]
            SubsEP["/v1/subscriptions"]
            InternalEP["/internal/v1/*"]
            MetricsEP["/metrics :9090"]
        end

        subgraph PayloadProc["payload-processing (BBR ext_proc)"]
            ModelToHeader["model-to-header plugin"]
            ProviderResolver["model-provider-resolver plugin"]
            APITranslation["api-translation plugin"]
            APIKeyInjection["apikey-injection plugin"]
        end
    end

    %% CRDs
    TenantCR["Tenant CR"]
    ModelRefCR["MaaSModelRef CR"]
    SubCR["MaaSSubscription CR"]
    AuthPolicyCR["MaaSAuthPolicy CR"]
    ExtModelCR["ExternalModel CR"]
    ConfigCR["Config CR"]

    %% CR → Controller relationships
    TenantCR -->|watched by| TenantRec
    ModelRefCR -->|watched by| ModelRefRec
    SubCR -->|watched by| SubRec
    AuthPolicyCR -->|watched by| AuthPolicyRec
    ExtModelCR -->|watched by| ExtModelRec

    %% TenantReconciler deploys operands
    TenantRec -->|deploys via kustomize SSA| API
    TenantRec -->|deploys| PayloadProc
    TenantRec -->|creates| KuadrantPolicies["Kuadrant AuthPolicy\n+ TokenRateLimitPolicy"]
    TenantRec -->|creates| IstioResources["Istio DestinationRule\n+ EnvoyFilter + Telemetry"]
    TenantRec -->|creates| HTTPRoutes["HTTPRoutes"]
    TenantRec -->|creates| NetworkPolicies["NetworkPolicies"]

    %% Sub/Auth aggregation
    SubRec -->|aggregates into| TRLP["TokenRateLimitPolicy\n(per model)"]
    AuthPolicyRec -->|aggregates into| AP["AuthPolicy\n(per model)"]
    AuthPolicyRec -->|uses| ConflictDet

    %% ModelRef coordination
    ModelRefRec -->|tracks governance pairing| ModelRefCR
    SubRec -.->|status| ModelRefRec
    AuthPolicyRec -.->|status| ModelRefRec

    %% ExternalModel creates networking
    ExtModelRec -->|creates| ExtNameSvc["ExternalName Service"]
    ExtModelRec -->|creates| ServiceEntry["Istio ServiceEntry"]
    ExtModelRec -->|creates| ExtHTTPRoute["HTTPRoute"]

    %% Lifecycle
    LifecycleRec -->|creates| ConfigCR

    %% External dependencies
    Gateway["MaaS Gateway\n443/TCP TLS Terminate"]
    PostgreSQL["PostgreSQL\n5432/TCP"]
    K8sAPI["Kubernetes API\n443/TCP"]
    Kuadrant["Kuadrant\n(Authorino + Limitador)"]
    KServe["KServe\n(LLMInferenceService)"]
    Istio["Istio / Envoy"]
    ExtProviders["External Model Providers\n(OpenAI, Anthropic, etc.)"]

    %% API dependencies
    API -->|queries| PostgreSQL
    API -->|informer cache| K8sAPI
    InternalEP -->|callback from| Kuadrant

    %% Payload processing flow
    Gateway -->|ext_proc gRPC :9004| PayloadProc
    PayloadProc -->|reads Secrets| K8sAPI
    APIKeyInjection -->|injects credentials| ExtProviders

    %% Client flow
    Client["Client"] -->|HTTPS :443| Gateway
    Gateway -->|routes to| API
    Gateway -->|routes to| KServe

    %% Controller dependencies
    Controller -->|reconciles via| K8sAPI
    ModelRefRec -->|watches| KServe

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#50c878,stroke:#333,color:#fff
    style PayloadProc fill:#9b59b6,stroke:#333,color:#fff
    style TenantCR fill:#f5a623,stroke:#333
    style ModelRefCR fill:#f5a623,stroke:#333
    style SubCR fill:#f5a623,stroke:#333
    style AuthPolicyCR fill:#f5a623,stroke:#333
    style ExtModelCR fill:#f5a623,stroke:#333
    style ConfigCR fill:#f5a623,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Kuadrant fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#2ecc71,stroke:#333
    style Istio fill:#466bb0,stroke:#333,color:#fff
    style Gateway fill:#e67e22,stroke:#333,color:#fff
    style Client fill:#ecf0f1,stroke:#333
    style ExtProviders fill:#95a5a6,stroke:#333
