graph TB
    subgraph MaaS["Models as a Service Platform"]
        direction TB

        subgraph ControlPlane["Control Plane (opendatahub namespace)"]
            Controller["maas-controller<br/>Go Operator<br/>8080/TCP metrics<br/>8081/TCP health"]
            API["maas-api<br/>Go HTTP Service (Gin)<br/>8080/TCP HTTP | 8443/TCP HTTPS"]
            CronJob["API Key Cleanup<br/>CronJob"]
        end

        subgraph DataPlane["Data Plane (openshift-ingress namespace)"]
            BBR["payload-processing (BBR)<br/>Go gRPC ext-proc<br/>9004/TCP gRPC | 9005/TCP metrics"]
        end
    end

    subgraph CRDs["MaaS Custom Resources (maas.opendatahub.io/v1alpha1)"]
        TenantCR["Tenant CR<br/>(singleton: default-tenant)"]
        ModelRefCR["MaaSModelRef CR"]
        AuthPolicyCR["MaaSAuthPolicy CR"]
        SubscriptionCR["MaaSSubscription CR"]
        ExternalModelCR["ExternalModel CR"]
    end

    subgraph GatewayStack["Gateway Stack"]
        Gateway["maas-default-gateway<br/>Gateway API<br/>443/TCP HTTPS"]
        HTTPRoutes["HTTPRoutes<br/>(per-model routing)"]
    end

    subgraph AuthStack["Auth & Rate Limiting"]
        Authorino["Authorino<br/>(AuthPolicy enforcement)"]
        Limitador["Limitador<br/>(Token rate limiting)"]
    end

    subgraph Storage["Data Storage"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
    end

    %% Controller relationships
    Controller -->|"reconciles"| TenantCR
    Controller -->|"reconciles"| ModelRefCR
    Controller -->|"reconciles"| AuthPolicyCR
    Controller -->|"reconciles"| SubscriptionCR
    Controller -->|"reconciles"| ExternalModelCR

    Controller -->|"deploys via kustomize"| API
    Controller -->|"deploys via kustomize"| BBR
    Controller -->|"deploys via kustomize"| CronJob

    Controller -->|"creates aggregated"| KuadrantAuthPolicy["Kuadrant AuthPolicy"]
    Controller -->|"creates aggregated"| KuadrantTRLP["Kuadrant TokenRateLimitPolicy"]
    Controller -->|"creates"| HTTPRoutes
    Controller -->|"creates Istio resources"| IstioResources["ServiceEntry<br/>DestinationRule<br/>EnvoyFilter"]

    %% API relationships
    API -->|"stores/queries keys"| PostgreSQL
    API -->|"validates access via SAR"| K8sAPI["Kubernetes API"]
    API -->|"probes model access"| KServeModels["KServe Models"]
    CronJob -->|"cleanup expired keys"| API

    %% Auth flow
    Authorino -->|"callback: validate key"| API
    Authorino -->|"callback: select subscription"| API
    KuadrantAuthPolicy -->|"enforced by"| Authorino
    KuadrantTRLP -->|"enforced by"| Limitador

    %% Gateway flow
    Gateway -->|"routes via"| HTTPRoutes
    Gateway -->|"ext-proc filter"| BBR
    BBR -->|"reads ExternalModels, Secrets"| K8sAPI

    %% User interaction
    User["User / Client"] -->|"HTTPS/443"| Gateway

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style API fill:#4a90e2,color:#fff
    style BBR fill:#4a90e2,color:#fff
    style CronJob fill:#4a90e2,color:#fff
    style TenantCR fill:#f5a623,color:#fff
    style ModelRefCR fill:#f5a623,color:#fff
    style AuthPolicyCR fill:#f5a623,color:#fff
    style SubscriptionCR fill:#f5a623,color:#fff
    style ExternalModelCR fill:#f5a623,color:#fff
    style Gateway fill:#7ed321,color:#fff
    style HTTPRoutes fill:#7ed321,color:#fff
    style Authorino fill:#bd10e0,color:#fff
    style Limitador fill:#bd10e0,color:#fff
    style PostgreSQL fill:#e8e8e8,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style KServeModels fill:#e8e8e8,color:#333
    style User fill:#50e3c2,color:#333
    style KuadrantAuthPolicy fill:#bd10e0,color:#fff
    style KuadrantTRLP fill:#bd10e0,color:#fff
    style IstioResources fill:#7ed321,color:#fff
