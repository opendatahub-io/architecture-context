graph TB
    subgraph ODH_Model_Controller["odh-model-controller (Operator)"]
        direction TB

        subgraph Manager["Manager Process"]
            direction TB
            ISReconciler["InferenceService<br/>Reconciler"]
            LLMReconciler["LLMInferenceService<br/>Reconciler"]
            GWReconciler["Gateway<br/>Reconciler"]
            SRReconciler["ServingRuntime<br/>Reconciler"]
            NIMReconciler["NIM Account<br/>Reconciler"]
            CMReconciler["ConfigMap<br/>Reconciler"]
            SecretReconciler["Secret<br/>Reconciler"]
            PodReconciler["Pod<br/>Reconciler"]
        end

        subgraph Webhooks["Webhook Server :9443"]
            PodWebhook["Pod Mutating<br/>Webhook"]
            NIMWebhook["NIM Account<br/>Validating Webhook"]
            IGWebhook["InferenceGraph<br/>Validating Webhook"]
            ISWebhook["InferenceService<br/>Mutating Webhook"]
        end

        subgraph SubReconcilers["Sub-Resource Reconcilers"]
            RouteReconciler["Route<br/>Reconciler"]
            CRBReconciler["ClusterRoleBinding<br/>Reconciler"]
            MetricsSvcReconciler["Metrics Service<br/>Reconciler"]
            SMReconciler["ServiceMonitor<br/>Reconciler"]
            KEDAReconciler["KEDA<br/>Reconciler"]
            MRReconciler["Model Registry<br/>Reconciler"]
        end

        ISReconciler --> RouteReconciler
        ISReconciler --> CRBReconciler
        ISReconciler --> MetricsSvcReconciler
        ISReconciler --> SMReconciler
        ISReconciler --> KEDAReconciler
        ISReconciler --> MRReconciler
    end

    subgraph ModelServingAPI["model-serving-api :8443"]
        GatewayHandler["Gateway Discovery<br/>Handler"]
        AuthMiddleware["Auth Middleware<br/>(Bearer + RBAC)"]
        CertReloader["TLS Cert<br/>Hot-Reloader"]
        GatewayHandler --> AuthMiddleware
    end

    %% CRDs Watched
    ISVC["InferenceService CR"] -->|watched by| ISReconciler
    LLMISVC["LLMInferenceService CR"] -->|watched by| LLMReconciler
    GatewayCR["Gateway CR"] -->|watched by| GWReconciler
    ServingRuntimeCR["ServingRuntime CR"] -->|watched by| SRReconciler
    NIMAccountCR["NIM Account CR"] -->|watched by| NIMReconciler
    ConfigMapCR["ConfigMaps<br/>(CA bundles)"] -->|watched by| CMReconciler
    SecretCR["Secrets<br/>(data connections)"] -->|watched by| SecretReconciler
    PodCR["Pods<br/>(Ray workers)"] -->|watched by| PodReconciler

    %% Resources Created
    ISReconciler -->|creates| Route["OpenShift Route"]
    ISReconciler -->|creates| ServiceMonitor["ServiceMonitor"]
    ISReconciler -->|creates| NetworkPolicy["NetworkPolicy"]
    ISReconciler -->|creates| TriggerAuth["KEDA TriggerAuth"]
    LLMReconciler -->|creates| AuthPolicy["Kuadrant AuthPolicy"]
    GWReconciler -->|creates| EnvoyFilter["Istio EnvoyFilter"]
    GWReconciler -->|creates| AuthPolicy
    NIMReconciler -->|creates| NIMTemplate["OpenShift Template"]
    NIMReconciler -->|creates| PullSecret["Image Pull Secret"]
    CMReconciler -->|creates| KServeCA["KServe CA Bundle"]
    SecretReconciler -->|creates| StorageConfig["storage-config Secret"]
    PodReconciler -->|creates| RayTLS["Ray TLS Certs"]
    SRReconciler -->|creates| RayCA["Ray CA Secret"]

    %% External Dependencies
    NIMReconciler -->|validates| NVIDIA["NVIDIA NGC API"]
    MRReconciler -->|syncs| ModelRegistry["Kubeflow Model Registry"]
    GatewayHandler -->|discovers| K8sAPI["Kubernetes API"]

    %% Dashboard Integration
    Dashboard["RHOAI Dashboard"] -->|queries| GatewayHandler

    %% Styling
    style ODH_Model_Controller fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ModelServingAPI fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
