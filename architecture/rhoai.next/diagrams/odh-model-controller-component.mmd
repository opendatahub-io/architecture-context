graph TB
    subgraph OMC["odh-model-controller (Go Operator)"]
        direction TB
        subgraph Controllers["Controllers"]
            ISVCCtrl["InferenceService<br/>Reconciler"]
            LLMCtrl["LLMInferenceService<br/>Reconciler"]
            GWCtrl["Gateway<br/>Reconciler"]
            SRCtrl["ServingRuntime<br/>Reconciler"]
            CMCtrl["ConfigMap<br/>Reconciler"]
            SecretCtrl["Secret<br/>Reconciler"]
            PodCtrl["Pod<br/>Reconciler"]
            NIMCtrl["NIM Account<br/>Reconciler"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutPod["Mutating: Pod<br/>(Ray TLS injection)"]
            MutIG["Mutating: InferenceGraph<br/>(URL validation)"]
            MutISVC["Mutating: InferenceService<br/>(name validation)"]
            ValAccount["Validating: NIM Account<br/>(singleton enforcement)"]
            ValIG["Validating: InferenceGraph"]
            ValISVC["Validating: InferenceService"]
        end

        Metrics1["Metrics :8080/TCP"]
        Health1["Health :8081/TCP"]
    end

    subgraph MSA["model-serving-api (Go HTTP Server)"]
        GWDiscovery["GET /api/v1/gateways<br/>Bearer Token + SSAR"]
        Health2["Health/Ready :8443/TCP"]
        Metrics2["Metrics :9090/TCP"]
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    LLMISVC_CR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha2)"]
    GW_CR["Gateway CR<br/>(gateway.networking.k8s.io/v1)"]
    SR_CR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    NIM_CR["NIM Account CR<br/>(nim.opendatahub.io/v1)"]
    DSC_CR["DataScienceCluster CR"]

    %% Resources Created
    Route["OpenShift Route<br/>(per-ISVC)"]
    ServiceMon["ServiceMonitor<br/>(per-ISVC)"]
    AuthPolicy["Kuadrant AuthPolicy<br/>(per-HTTPRoute)"]
    EnvoyFilter["Istio EnvoyFilter<br/>(per-Gateway)"]
    KEDA_TA["KEDA TriggerAuth<br/>(per-ISVC)"]
    CRB["ClusterRoleBinding<br/>(per-ISVC SA)"]
    StorageConfig["storage-config Secret"]
    CACert["kserve-custom-cert<br/>ConfigMap"]
    RayTLS["Ray TLS Certs"]
    NIMTemplate["NIM Runtime<br/>Templates"]
    NIMSecret["NIM Pull Secrets"]

    %% External
    Dashboard["RHOAI Dashboard"]
    K8sAPI["Kubernetes API"]
    NGC["NVIDIA NGC API"]

    %% Watches
    ISVC_CR -->|watched by| ISVCCtrl
    LLMISVC_CR -->|watched by| LLMCtrl
    GW_CR -->|watched by| GWCtrl
    SR_CR -->|watched by| SRCtrl
    NIM_CR -->|watched by| NIMCtrl
    DSC_CR -.->|reads config| ISVCCtrl

    %% Creates
    ISVCCtrl -->|creates| Route
    ISVCCtrl -->|creates| ServiceMon
    ISVCCtrl -->|creates| KEDA_TA
    ISVCCtrl -->|creates| CRB
    LLMCtrl -->|creates| AuthPolicy
    GWCtrl -->|creates| EnvoyFilter
    GWCtrl -->|creates| AuthPolicy
    SRCtrl -->|manages| RayTLS
    CMCtrl -->|aggregates| CACert
    SecretCtrl -->|aggregates| StorageConfig
    PodCtrl -->|injects| RayTLS
    NIMCtrl -->|creates| NIMTemplate
    NIMCtrl -->|creates| NIMSecret

    %% External interactions
    NIMCtrl -->|validates keys| NGC
    Dashboard -->|GET /api/v1/gateways| GWDiscovery
    GWDiscovery -->|SSAR + list| K8sAPI

    %% Styling
    style OMC fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style MSA fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Controllers fill:#bbdefb,stroke:#1565c0
    style Webhooks fill:#bbdefb,stroke:#1565c0
    style ISVC_CR fill:#fff3e0,stroke:#e65100
    style LLMISVC_CR fill:#fff3e0,stroke:#e65100
    style GW_CR fill:#fff3e0,stroke:#e65100
    style SR_CR fill:#fff3e0,stroke:#e65100
    style NIM_CR fill:#fff3e0,stroke:#e65100
    style DSC_CR fill:#fff3e0,stroke:#e65100
    style Route fill:#c8e6c9,stroke:#2e7d32
    style ServiceMon fill:#c8e6c9,stroke:#2e7d32
    style AuthPolicy fill:#c8e6c9,stroke:#2e7d32
    style EnvoyFilter fill:#c8e6c9,stroke:#2e7d32
    style KEDA_TA fill:#c8e6c9,stroke:#2e7d32
    style CRB fill:#c8e6c9,stroke:#2e7d32
    style StorageConfig fill:#c8e6c9,stroke:#2e7d32
    style CACert fill:#c8e6c9,stroke:#2e7d32
    style RayTLS fill:#c8e6c9,stroke:#2e7d32
    style NIMTemplate fill:#c8e6c9,stroke:#2e7d32
    style NIMSecret fill:#c8e6c9,stroke:#2e7d32
    style Dashboard fill:#f3e5f5,stroke:#6a1b9a
    style K8sAPI fill:#e0e0e0,stroke:#424242
    style NGC fill:#e0e0e0,stroke:#424242
