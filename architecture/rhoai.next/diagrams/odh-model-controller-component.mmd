    style ISReconciler fill:#4a90e2,color:#fff
    style LLMReconciler fill:#4a90e2,color:#fff
    style GWReconciler fill:#4a90e2,color:#fff
    style SRReconciler fill:#4a90e2,color:#fff
    style NIMReconciler fill:#4a90e2,color:#fff
    style CMReconciler fill:#4a90e2,color:#fff
    style SecretReconciler fill:#4a90e2,color:#fff
    style PodReconciler fill:#4a90e2,color:#fff

    style PodWebhook fill:#f5a623,color:#fff
    style NIMWebhook fill:#f5a623,color:#fff
    style IGWebhook fill:#f5a623,color:#fff
    style ISWebhook fill:#f5a623,color:#fff

