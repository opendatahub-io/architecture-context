graph TB
    subgraph "odh-model-controller Operator"
        direction TB
        Controller["odh-model-controller<br/>Go Operator (controller-runtime)<br/>Ports: 8081/TCP health, 9443/TCP webhooks, 8080/TCP metrics"]

        subgraph "InferenceService Reconcilers"
            ISVCReconciler[InferenceService<br/>Reconciler]
            RouteReconciler[Route<br/>Reconciler]
            MetricsSvcReconciler[Metrics Service<br/>Reconciler]
            MetricsSMReconciler[ServiceMonitor<br/>Reconciler]
            KEDAReconciler[KEDA<br/>Reconciler]
            CRBReconciler[ClusterRoleBinding<br/>Reconciler]
            ISVCReconciler --> RouteReconciler
            ISVCReconciler --> MetricsSvcReconciler
            ISVCReconciler --> MetricsSMReconciler
            ISVCReconciler --> KEDAReconciler
            ISVCReconciler --> CRBReconciler
        end

        subgraph "LLM Controllers"
            LLMISVCController[LLMInferenceService<br/>Controller]
            GatewayController[Gateway<br/>Controller]
            AuthPolicyReconciler[AuthPolicy<br/>Reconciler]
            LLMISVCController --> AuthPolicyReconciler
            GatewayController -->|EnvoyFilter + AuthPolicy| AuthPolicyReconciler
        end

        subgraph "Core Controllers"
            ConfigMapController[ConfigMap<br/>Controller]
            SecretController[Secret<br/>Controller]
            PodController[Pod<br/>Controller]
            ServingRuntimeController[ServingRuntime<br/>Controller]
            InferenceGraphController[InferenceGraph<br/>Controller]
        end

        subgraph "NIM Integration"
            NIMAccountController[NIM Account<br/>Controller]
            APIKeyManager[API Key<br/>Manager]
            PullSecretHandler[Pull Secret<br/>Handler]
            TemplateHandler[Template<br/>Handler]
            NIMAccountController --> APIKeyManager
            NIMAccountController --> PullSecretHandler
            NIMAccountController --> TemplateHandler
        end

        subgraph "Webhooks"
            ISVCWebhook[InferenceService<br/>Webhook]
            IGWebhook[InferenceGraph<br/>Webhook]
            PodWebhook[Pod Webhook<br/>Ray TLS injection]
            NIMWebhook[NIM Account<br/>Webhook]
        end
    end

    subgraph "model-serving-api Server"
        APIServer["model-serving-api<br/>Go HTTP Server<br/>Ports: 8443/TCP API, 8080/TCP metrics"]
        GatewayDiscovery[Gateway Discovery<br/>/api/v1/gateways]
        AuthMiddleware[Auth Middleware<br/>Bearer Token + SSAR]
        APIServer --> AuthMiddleware
        AuthMiddleware --> GatewayDiscovery
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io)"]
    LLMISVC_CR["LLMInferenceService CR<br/>(serving.kserve.io)"]
    ServingRuntime_CR["ServingRuntime CR<br/>(serving.kserve.io)"]
    InferenceGraph_CR["InferenceGraph CR<br/>(serving.kserve.io)"]
    NIMAccount_CR["Account CR<br/>(nim.opendatahub.io)"]
    Gateway_CR["Gateway CR<br/>(gateway.networking.k8s.io)"]

    %% Resources Created
    Route["OpenShift Route"]
    ServiceMonitor["ServiceMonitor"]
    AuthPolicy["Kuadrant AuthPolicy"]
    EnvoyFilter["Istio EnvoyFilter"]
    TriggerAuth["KEDA TriggerAuth"]
    NetworkPolicy["NetworkPolicy"]
    PullSecret["NIM Pull Secret"]
    Template["NIM Runtime Template"]

    %% Watch relationships
    ISVC_CR -->|watched by| ISVCReconciler
    LLMISVC_CR -->|watched by| LLMISVCController
    ServingRuntime_CR -->|watched by| ServingRuntimeController
    InferenceGraph_CR -->|watched by| InferenceGraphController
    NIMAccount_CR -->|watched by| NIMAccountController
    Gateway_CR -->|watched by| GatewayController

    %% Create relationships
    RouteReconciler -->|creates| Route
    MetricsSMReconciler -->|creates| ServiceMonitor
    AuthPolicyReconciler -->|creates| AuthPolicy
    GatewayController -->|creates| EnvoyFilter
    KEDAReconciler -->|creates| TriggerAuth
    ISVCReconciler -->|creates| NetworkPolicy
    PullSecretHandler -->|creates| PullSecret
    TemplateHandler -->|creates| Template

    %% External Dependencies
    K8sAPI["Kubernetes API Server"]
    NVIDIA_NGC["NVIDIA NGC API"]
    Dashboard["RHOAI Dashboard"]

    Controller -->|CRUD operations| K8sAPI
    NIMAccountController -->|API key validation<br/>model catalog| NVIDIA_NGC
    Dashboard -->|/api/v1/gateways| APIServer

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ISVC_CR fill:#f5a623,stroke:#333
    style LLMISVC_CR fill:#f5a623,stroke:#333
    style ServingRuntime_CR fill:#f5a623,stroke:#333
    style InferenceGraph_CR fill:#f5a623,stroke:#333
    style NIMAccount_CR fill:#f5a623,stroke:#333
    style Gateway_CR fill:#f5a623,stroke:#333
    style Route fill:#7ed321,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style TriggerAuth fill:#7ed321,stroke:#333
    style NetworkPolicy fill:#7ed321,stroke:#333
    style PullSecret fill:#7ed321,stroke:#333
    style Template fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style NVIDIA_NGC fill:#e8e8e8,stroke:#333
    style Dashboard fill:#e8e8e8,stroke:#333
