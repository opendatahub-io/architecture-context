graph TB
    subgraph "odh-model-controller Operator"
        direction TB
        Manager["Manager Binary<br/>controller-runtime<br/>8081/TCP health, 8080/TCP metrics"]

        subgraph "KServe Controllers"
            ISReconciler["InferenceService<br/>Reconciler"]
            LLMReconciler["LLMInferenceService<br/>Reconciler"]
            IGReconciler["InferenceGraph<br/>Webhook"]
            SRReconciler["ServingRuntime<br/>Reconciler"]
        end

        subgraph "Gateway Controllers"
            GWReconciler["Gateway<br/>Reconciler"]
        end

        subgraph "NIM Controllers"
            NIMReconciler["Account<br/>Reconciler"]
        end

        subgraph "Core Controllers"
            CMReconciler["ConfigMap<br/>Reconciler"]
            SecretReconciler["Secret<br/>Reconciler"]
            PodReconciler["Pod<br/>Reconciler"]
        end

        Webhook["Webhook Server<br/>9443/TCP"]
    end

    subgraph "model-serving-api"
        APIServer["Gateway Discovery<br/>REST API<br/>8443/TCP HTTPS"]
    end

    %% CRDs Watched
    ISVC["InferenceService CR"]
    LLMISVC["LLMInferenceService CR"]
    SR["ServingRuntime CR"]
    IG["InferenceGraph CR"]
    GW["Gateway CR"]
    NIMAccount["NIM Account CR"]

    %% Resources Created
    Route["OpenShift Route"]
    AuthPolicy["Kuadrant AuthPolicy"]
    EnvoyFilter["Istio EnvoyFilter"]
    ServiceMonitor["ServiceMonitor"]
    NetworkPolicy["NetworkPolicy"]
    TriggerAuth["KEDA TriggerAuth"]
    Template["OpenShift Template"]
    PullSecret["Image Pull Secret"]
    RayCerts["Ray TLS Certs"]

    %% External
    NVIDIA["NVIDIA NGC API"]
    K8sAPI["Kubernetes API"]
    Dashboard["RHOAI Dashboard"]

    %% CRD Watches
    ISVC -->|watched by| ISReconciler
    LLMISVC -->|watched by| LLMReconciler
    SR -->|watched by| SRReconciler
    IG -->|validated by| Webhook
    GW -->|watched by| GWReconciler
    NIMAccount -->|watched by| NIMReconciler

    %% Resource Creation
    ISReconciler -->|creates| Route
    ISReconciler -->|creates| ServiceMonitor
    ISReconciler -->|creates| NetworkPolicy
    ISReconciler -->|creates| TriggerAuth
    LLMReconciler -->|creates| AuthPolicy
    GWReconciler -->|creates| EnvoyFilter
    GWReconciler -->|creates| AuthPolicy
    SRReconciler -->|manages| RayCerts
    NIMReconciler -->|creates| Template
    NIMReconciler -->|creates| PullSecret
    PodReconciler -->|creates| RayCerts
    CMReconciler -->|aggregates| CACerts["CA Bundle ConfigMap"]
    SecretReconciler -->|consolidates| StorageConfig["storage-config Secret"]

    %% External Interactions
    NIMReconciler -->|validates keys| NVIDIA
    APIServer -->|serves| Dashboard
    Manager -->|all watches via| K8sAPI

    %% Styling
    style Manager fill:#4a90e2,color:#fff
    style APIServer fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style ISReconciler fill:#5ba8f7,color:#fff
    style LLMReconciler fill:#5ba8f7,color:#fff
    style IGReconciler fill:#5ba8f7,color:#fff
    style SRReconciler fill:#5ba8f7,color:#fff
    style GWReconciler fill:#5ba8f7,color:#fff
    style NIMReconciler fill:#5ba8f7,color:#fff
    style CMReconciler fill:#5ba8f7,color:#fff
    style SecretReconciler fill:#5ba8f7,color:#fff
    style PodReconciler fill:#5ba8f7,color:#fff
    style ISVC fill:#f5a623
    style LLMISVC fill:#f5a623
    style SR fill:#f5a623
    style IG fill:#f5a623
    style GW fill:#f5a623
    style NIMAccount fill:#f5a623
    style Route fill:#7ed321
    style AuthPolicy fill:#7ed321
    style EnvoyFilter fill:#7ed321
    style ServiceMonitor fill:#7ed321
    style NetworkPolicy fill:#7ed321
    style TriggerAuth fill:#7ed321
    style Template fill:#7ed321
    style PullSecret fill:#7ed321
    style RayCerts fill:#7ed321
    style CACerts fill:#7ed321
    style StorageConfig fill:#7ed321
    style NVIDIA fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Dashboard fill:#e8e8e8,stroke:#999
