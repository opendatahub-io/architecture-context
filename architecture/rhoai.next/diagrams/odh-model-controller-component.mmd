graph TB
    subgraph ODH["odh-model-controller Operator"]
        direction TB

        subgraph Controllers["Controllers"]
            ISVCCtrl["InferenceService<br/>Reconciler"]
            LLMCtrl["LLMInferenceService<br/>Reconciler"]
            GWCtrl["Gateway<br/>Reconciler"]
            SRCtrl["ServingRuntime<br/>Reconciler"]
            CMCtrl["ConfigMap<br/>Reconciler"]
            SecCtrl["Secret<br/>Reconciler"]
            PodCtrl["Pod<br/>Reconciler"]
            NIMCtrl["NIM Account<br/>Reconciler"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutPod["Mutating: Pod<br/>(Ray TLS injection)"]
            MutIG["Mutating: InferenceGraph<br/>(URL validation)"]
            MutISVC["Mutating: InferenceService<br/>(name length check)"]
            ValAcct["Validating: Account<br/>(singleton enforcement)"]
            ValIG["Validating: InferenceGraph"]
            ValISVC["Validating: InferenceService"]
        end

        Metrics1["Metrics :8080/TCP"]
        Health1["Health :8081/TCP"]
    end

    subgraph API["model-serving-api"]
        GWDisc["Gateway Discovery<br/>GET /api/v1/gateways"]
        AuthMW["Auth Middleware<br/>(Bearer + SSAR)"]
        Metrics2["Metrics :9090/TCP"]
        Health2["Health :8443/TCP"]
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    LLMISVC_CR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha2)"]
    GW_CR["Gateway CR<br/>(gateway.networking.k8s.io/v1)"]
    SR_CR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    NIM_CR["Account CR<br/>(nim.opendatahub.io/v1)"]

    %% Resources Created
    Route["OpenShift Route<br/>(per-ISVC)"]
    SvcMon["ServiceMonitor<br/>(per-ISVC)"]
    AuthPolicy["Kuadrant AuthPolicy<br/>(per-HTTPRoute/Gateway)"]
    EnvoyFilter["Istio EnvoyFilter<br/>(Authorino TLS)"]
    TrigAuth["KEDA TriggerAuth<br/>(Prometheus autoscale)"]
    StorageConfig["storage-config Secret<br/>(aggregated)"]
    CACert["kserve-custom-cert CM<br/>(CA aggregation)"]
    RayTLS["Ray TLS Certs<br/>(self-signed)"]
    NIMTemplate["NIM Templates<br/>(ServingRuntime)"]
    NIMSecret["NIM Pull Secret<br/>(nvcr.io)"]

    %% Watches
    ISVC_CR -->|watched by| ISVCCtrl
    LLMISVC_CR -->|watched by| LLMCtrl
    GW_CR -->|watched by| GWCtrl
    SR_CR -->|watched by| SRCtrl
    NIM_CR -->|watched by| NIMCtrl

    %% Creates
    ISVCCtrl -->|creates| Route
    ISVCCtrl -->|creates| SvcMon
    ISVCCtrl -->|creates| TrigAuth
    LLMCtrl -->|creates| AuthPolicy
    GWCtrl -->|creates| EnvoyFilter
    GWCtrl -->|creates| AuthPolicy
    SecCtrl -->|aggregates| StorageConfig
    CMCtrl -->|aggregates| CACert
    PodCtrl -->|injects| RayTLS
    NIMCtrl -->|creates| NIMTemplate
    NIMCtrl -->|creates| NIMSecret

    %% External consumers
    Dashboard["RHOAI Dashboard"] -->|GET /api/v1/gateways| GWDisc
    Prometheus["Prometheus"] -->|scrapes| Metrics1
    Prometheus -->|scrapes| Metrics2

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style API fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Controllers fill:#5b9bd5,stroke:#333,color:#fff
    style Webhooks fill:#5b9bd5,stroke:#333,color:#fff

    style ISVC_CR fill:#f5a623,stroke:#333
    style LLMISVC_CR fill:#f5a623,stroke:#333
    style GW_CR fill:#f5a623,stroke:#333
    style SR_CR fill:#f5a623,stroke:#333
    style NIM_CR fill:#f5a623,stroke:#333

    style Route fill:#7ed321,stroke:#333
    style SvcMon fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style TrigAuth fill:#7ed321,stroke:#333
    style StorageConfig fill:#7ed321,stroke:#333
    style CACert fill:#7ed321,stroke:#333
    style RayTLS fill:#7ed321,stroke:#333
    style NIMTemplate fill:#7ed321,stroke:#333
    style NIMSecret fill:#7ed321,stroke:#333

    style Dashboard fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
