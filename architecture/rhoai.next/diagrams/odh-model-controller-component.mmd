graph TB
    subgraph OMC["odh-model-controller Operator"]
        direction TB
        subgraph Controllers["Controllers"]
            ISVCCtrl["InferenceService<br/>Reconciler"]
            LLMCtrl["LLMInferenceService<br/>Reconciler"]
            GWCtrl["Gateway<br/>Reconciler"]
            SRCtrl["ServingRuntime<br/>Reconciler"]
            CMCtrl["ConfigMap<br/>Reconciler"]
            SecCtrl["Secret<br/>Reconciler"]
            PodCtrl["Pod<br/>Reconciler"]
            NIMCtrl["NIM Account<br/>Reconciler"]
        end

        subgraph Webhooks["Admission Webhooks"]
            MutPod["Mutating: Pod<br/>(Ray TLS injection)"]
            MutISVC["Mutating: InferenceService<br/>(name/namespace validation)"]
            MutIG["Mutating: InferenceGraph<br/>(URL validation)"]
            ValNIM["Validating: NIM Account<br/>(singleton enforcement)"]
        end

        subgraph Processors["Shared Infrastructure"]
            Delta["DeltaProcessor<br/>(create/update/delete)"]
        end
    end

    subgraph MSA["model-serving-api Server"]
        GWAPI["/api/v1/gateways<br/>HTTPS :8443"]
        AuthMW["Auth Middleware<br/>(Bearer + SSAR)"]
        GWAPI --> AuthMW
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    LLMISVC_CR["LLMInferenceService CR<br/>(serving.kserve.io/v1alpha2)"]
    GW_CR["Gateway CR<br/>(gateway.networking.k8s.io/v1)"]
    SR_CR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    NIM_CR["Account CR<br/>(nim.opendatahub.io/v1)"]
    CM_CR["ConfigMap<br/>(v1)"]
    SEC_CR["Secret<br/>(v1)"]

    %% CRD → Controller
    ISVC_CR -->|watched by| ISVCCtrl
    LLMISVC_CR -->|watched by| LLMCtrl
    GW_CR -->|watched by| GWCtrl
    SR_CR -->|watched by| SRCtrl
    NIM_CR -->|watched by| NIMCtrl
    CM_CR -->|watched by| CMCtrl
    SEC_CR -->|watched by| SecCtrl

    %% Resources Created
    ISVCCtrl -->|creates| Route["OpenShift Route"]
    ISVCCtrl -->|creates| SvcMon["ServiceMonitor"]
    ISVCCtrl -->|creates| KEDAAuth["KEDA TriggerAuth"]
    ISVCCtrl -->|creates| CRB["ClusterRoleBinding"]

    LLMCtrl -->|creates| AuthPol["AuthPolicy<br/>(per-HTTPRoute)"]
    GWCtrl -->|creates| EnvoyF["EnvoyFilter"]
    GWCtrl -->|creates| GWAuthPol["AuthPolicy<br/>(per-Gateway)"]

    SRCtrl -->|creates| RayTLS["Ray TLS Certs"]
    SRCtrl -->|creates| MonRB["Monitoring RoleBinding"]

    CMCtrl -->|creates| CACert["kserve-custom-cert<br/>ConfigMap"]
    SecCtrl -->|creates| StorageCfg["storage-config<br/>Secret"]

    NIMCtrl -->|creates| NIMTemplate["OpenShift Template"]
    NIMCtrl -->|creates| NIMPullSec["nvcr.io Pull Secret"]

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"]
    AuthMW -->|SelfSubjectAccessReview| K8sAPI

    %% Dashboard
    Dashboard["RHOAI Dashboard"] -->|GET /api/v1/gateways| MSA

    %% Styling
    style OMC fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style MSA fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Controllers fill:#bbdefb,stroke:#1976d2
    style Webhooks fill:#bbdefb,stroke:#1976d2
    style Processors fill:#bbdefb,stroke:#1976d2

    style ISVC_CR fill:#fff3e0,stroke:#ef6c00
    style LLMISVC_CR fill:#fff3e0,stroke:#ef6c00
    style GW_CR fill:#fff3e0,stroke:#ef6c00
    style SR_CR fill:#fff3e0,stroke:#ef6c00
    style NIM_CR fill:#fff3e0,stroke:#ef6c00
    style CM_CR fill:#fff3e0,stroke:#ef6c00
    style SEC_CR fill:#fff3e0,stroke:#ef6c00

    style Route fill:#c8e6c9,stroke:#388e3c
    style SvcMon fill:#c8e6c9,stroke:#388e3c
    style KEDAAuth fill:#c8e6c9,stroke:#388e3c
    style CRB fill:#c8e6c9,stroke:#388e3c
    style AuthPol fill:#c8e6c9,stroke:#388e3c
    style EnvoyF fill:#c8e6c9,stroke:#388e3c
    style GWAuthPol fill:#c8e6c9,stroke:#388e3c
    style RayTLS fill:#c8e6c9,stroke:#388e3c
    style MonRB fill:#c8e6c9,stroke:#388e3c
    style CACert fill:#c8e6c9,stroke:#388e3c
    style StorageCfg fill:#c8e6c9,stroke:#388e3c
    style NIMTemplate fill:#c8e6c9,stroke:#388e3c
    style NIMPullSec fill:#c8e6c9,stroke:#388e3c

