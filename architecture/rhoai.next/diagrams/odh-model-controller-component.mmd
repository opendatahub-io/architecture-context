graph TB
    subgraph OMC["odh-model-controller Operator"]
        direction TB
        subgraph CoreControllers["Core Controllers"]
            ConfigMapCtrl["ConfigMap Controller"]
            PodCtrl["Pod Controller"]
            SecretCtrl["Secret Controller"]
        end

        subgraph ServingControllers["Serving Controllers"]
            ISVCCtrl["InferenceService Controller"]
            IGCtrl["InferenceGraph Controller"]
            SRCtrl["ServingRuntime Controller"]
        end

        subgraph LLMControllers["LLM Controllers"]
            GWCtrl["Gateway Controller"]
            LLMISVCCtrl["LLMInferenceService Controller"]
        end

        subgraph NIMController["NIM Controller"]
            NIMAcctCtrl["NIM Account Controller"]
            ValidationHandler["Validation Handler"]
            ConfigMapHandler["ConfigMap Handler"]
            TemplateHandler["Template Handler"]
            PullSecretHandler["Pull Secret Handler"]
            NIMAcctCtrl --> ValidationHandler
            ValidationHandler --> ConfigMapHandler
            ConfigMapHandler --> TemplateHandler
            TemplateHandler --> PullSecretHandler
        end

        subgraph ISVCReconcilers["ISVC Sub-Reconcilers"]
            RouteReconciler["Route Reconciler"]
            NetPolReconciler["NetworkPolicy Reconciler"]
            SvcMonReconciler["ServiceMonitor Reconciler"]
            CRBReconciler["ClusterRoleBinding Reconciler"]
            KEDAReconciler["KEDA TriggerAuth Reconciler"]
            DashReconciler["Dashboard Reconciler"]
            SAReconciler["ServiceAccount Reconciler"]
            MRReconciler["Model Registry Reconciler"]
        end

        ISVCCtrl --> RouteReconciler
        ISVCCtrl --> NetPolReconciler
        ISVCCtrl --> SvcMonReconciler
        ISVCCtrl --> CRBReconciler
        ISVCCtrl --> KEDAReconciler
        ISVCCtrl --> DashReconciler
        ISVCCtrl --> SAReconciler
        ISVCCtrl --> MRReconciler

        subgraph Webhooks["Admission Webhooks"]
            PodWH["Pod Webhook<br/>(Ray TLS injection)"]
            ISVCWH["InferenceService Webhook<br/>(name/namespace validation)"]
            IGWH["InferenceGraph Webhook<br/>(cross-namespace check)"]
            NIMAcctWH["NIM Account Webhook<br/>(singleton constraint)"]
        end

        MetricsEP["Metrics :8080/TCP"]
        HealthEP["Health :8081/TCP"]
        WebhookSvr["Webhook Server :9443/TCP"]
    end

    subgraph MSA["model-serving-api Server"]
        direction TB
        GWAPI["GET /api/v1/gateways"]
        AuthMW["Auth Middleware<br/>(Bearer Token)"]
        SSARCheck["SelfSubjectAccessReview"]
        GWDiscovery["Gateway Discovery"]
        AuthMW --> SSARCheck
        SSARCheck --> GWDiscovery
        GWAPI --> AuthMW
        MSAMetrics["Metrics :8080/TCP"]
        MSATLS["HTTPS :8443/TCP<br/>TLS 1.2+ FIPS"]
    end

    %% CRDs Watched
    ISVC_CR["InferenceService CR"]
    LLMISVC_CR["LLMInferenceService CR"]
    IG_CR["InferenceGraph CR"]
    SR_CR["ServingRuntime CR"]
    NIMAcct_CR["NIM Account CR"]
    GW_CR["Gateway CR"]

    ISVC_CR -->|watched by| ISVCCtrl
    LLMISVC_CR -->|watched by| LLMISVCCtrl
    IG_CR -->|watched by| IGCtrl
    SR_CR -->|watched by| SRCtrl
    NIMAcct_CR -->|watched by| NIMAcctCtrl
    GW_CR -->|watched by| GWCtrl

    %% Resources Created
    ISVCCtrl -->|creates| Route["OpenShift Route"]
    ISVCCtrl -->|creates| NetPol["NetworkPolicy"]
    ISVCCtrl -->|creates| SvcMon["ServiceMonitor"]
    GWCtrl -->|creates| EnvoyFilter["Istio EnvoyFilter"]
    GWCtrl -->|creates| AuthPolicyGW["AuthPolicy<br/>(Gateway-level)"]
    LLMISVCCtrl -->|creates| AuthPolicyHR["AuthPolicy<br/>(HTTPRoute-level)"]
    NIMAcctCtrl -->|creates| Template["OpenShift Template"]
    NIMAcctCtrl -->|creates| PullSecret["Docker Pull Secret"]

    %% External Dependencies
    ISVCCtrl -->|depends on| KServe["KServe"]
    GWCtrl -->|depends on| Kuadrant["Kuadrant"]
    GWCtrl -->|depends on| Authorino["Authorino"]
    GWCtrl -->|depends on| Istio["Istio"]
    NIMAcctCtrl -->|calls| NGC["NVIDIA NGC API"]

    %% Styling
    style OMC fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style MSA fill:#e8f4e8,stroke:#7ed321,stroke-width:2px
    style ISVCCtrl fill:#4a90e2,color:#fff
    style GWCtrl fill:#4a90e2,color:#fff
    style LLMISVCCtrl fill:#4a90e2,color:#fff
    style NIMAcctCtrl fill:#4a90e2,color:#fff
    style IGCtrl fill:#4a90e2,color:#fff
    style SRCtrl fill:#4a90e2,color:#fff
    style ConfigMapCtrl fill:#4a90e2,color:#fff
    style PodCtrl fill:#4a90e2,color:#fff
    style SecretCtrl fill:#4a90e2,color:#fff
    style ISVC_CR fill:#f5a623
    style LLMISVC_CR fill:#f5a623
    style IG_CR fill:#f5a623
    style SR_CR fill:#f5a623
    style NIMAcct_CR fill:#f5a623
    style GW_CR fill:#f5a623
    style KServe fill:#e8e8e8,stroke:#999
    style Kuadrant fill:#e8e8e8,stroke:#999
    style Authorino fill:#e8e8e8,stroke:#999
    style Istio fill:#e8e8e8,stroke:#999
    style NGC fill:#e8e8e8,stroke:#999
    style Route fill:#d5e8d4
    style NetPol fill:#d5e8d4
    style SvcMon fill:#d5e8d4
    style EnvoyFilter fill:#d5e8d4
    style AuthPolicyGW fill:#d5e8d4
    style AuthPolicyHR fill:#d5e8d4
    style Template fill:#d5e8d4
    style PullSecret fill:#d5e8d4
