graph TB
    subgraph ODH["odh-model-controller Component"]
        direction TB

        subgraph Controller["odh-model-controller (Go Operator)"]
            direction TB
            ISVCReconciler["InferenceService<br/>Reconciler"]
            LLMISVCReconciler["LLMInferenceService<br/>Reconciler"]
            GatewayReconciler["Gateway<br/>Reconciler"]
            SRReconciler["ServingRuntime<br/>Reconciler"]
            NIMReconciler["NIM Account<br/>Reconciler"]
            SecretController["Secret<br/>Controller"]
            ConfigMapController["ConfigMap<br/>Controller"]
            PodController["Pod Controller<br/>(Ray TLS)"]
        end

        subgraph SubReconcilers["Sub-Reconcilers (Delta Processor Pattern)"]
            RouteReconciler["Route<br/>Reconciler"]
            MonitorReconciler["ServiceMonitor<br/>Reconciler"]
            RBACReconciler["ClusterRoleBinding<br/>Reconciler"]
            KEDAReconciler["KEDA Trigger<br/>Reconciler"]
            AuthPolicyReconciler["AuthPolicy<br/>Reconciler"]
            EnvoyFilterReconciler["EnvoyFilter<br/>Reconciler"]
            ModelRegReconciler["Model Registry<br/>Reconciler"]
        end

        subgraph APIServer["model-serving-api (REST Server)"]
            GatewayDiscovery["Gateway Discovery<br/>Endpoint"]
            RBACEnforcement["Per-User RBAC<br/>Enforcement"]
            CertReloader["TLS Cert<br/>Hot-Reload"]
        end

        subgraph Webhooks["Admission Webhooks"]
            PodMutator["Pod Mutator<br/>(Ray TLS Injection)"]
            ISVCValidator["InferenceService<br/>Validator"]
            IGValidator["InferenceGraph<br/>Validator"]
            NIMValidator["NIM Account<br/>Validator (Singleton)"]
        end
    end

    %% CRDs Watched
    ISVC["InferenceService CR"]
    LLMISVC["LLMInferenceService CR"]
    GatewayCR["Gateway CR"]
    SRCR["ServingRuntime CR"]
    NIMAccount["NIM Account CR"]
    IGraph["InferenceGraph CR"]

    %% Resources Created
    Route["OpenShift Route"]
    ServiceMonitor["ServiceMonitor"]
    CRB["ClusterRoleBinding"]
    TriggerAuth["KEDA TriggerAuth"]
    AuthPolicy["Kuadrant AuthPolicy"]
    EnvoyFilter["Istio EnvoyFilter"]
    PullSecret["NIM Pull Secret"]
    NIMTemplate["NIM Runtime Template"]

    %% CRD Watch flows
    ISVC -->|watched by| ISVCReconciler
    LLMISVC -->|watched by| LLMISVCReconciler
    GatewayCR -->|watched by| GatewayReconciler
    SRCR -->|watched by| SRReconciler
    NIMAccount -->|watched by| NIMReconciler
    IGraph -->|validated by| IGValidator

    %% Reconciler to Sub-Reconciler
    ISVCReconciler --> RouteReconciler
    ISVCReconciler --> MonitorReconciler
    ISVCReconciler --> RBACReconciler
    ISVCReconciler --> KEDAReconciler
    ISVCReconciler --> ModelRegReconciler
    LLMISVCReconciler --> AuthPolicyReconciler
    GatewayReconciler --> EnvoyFilterReconciler
    GatewayReconciler --> AuthPolicyReconciler

    %% Resources Created
    RouteReconciler -->|creates| Route
    MonitorReconciler -->|creates| ServiceMonitor
    RBACReconciler -->|creates| CRB
    KEDAReconciler -->|creates| TriggerAuth
    AuthPolicyReconciler -->|creates| AuthPolicy
    EnvoyFilterReconciler -->|creates| EnvoyFilter
    NIMReconciler -->|creates| PullSecret
    NIMReconciler -->|creates| NIMTemplate

    %% API Server flows
    Dashboard["RHOAI Dashboard"] -->|calls| GatewayDiscovery
    GatewayDiscovery --> RBACEnforcement
    RBACEnforcement -->|SelfSubjectAccessReview| K8sAPI["Kubernetes API"]

    %% External dependencies
    Controller -->|CRUD operations| K8sAPI
    NIMReconciler -->|API calls| NGCAPI["NVIDIA NGC API"]
    EnvoyFilterReconciler -.->|configures auth chain| Authorino["Authorino"]

    %% Styling
    style ODH fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controller fill:#d5e8ff,stroke:#4a90e2,stroke-width:2px
    style SubReconcilers fill:#e8f0e8,stroke:#82b366,stroke-width:2px
    style APIServer fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style Webhooks fill:#fce4ec,stroke:#e57373,stroke-width:2px

    style ISVC fill:#f5a623,stroke:#333
    style LLMISVC fill:#f5a623,stroke:#333
    style GatewayCR fill:#f5a623,stroke:#333
    style SRCR fill:#f5a623,stroke:#333
    style NIMAccount fill:#f5a623,stroke:#333
    style IGraph fill:#f5a623,stroke:#333

    style Route fill:#7ed321,stroke:#333
    style ServiceMonitor fill:#7ed321,stroke:#333
    style CRB fill:#7ed321,stroke:#333
    style TriggerAuth fill:#7ed321,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style EnvoyFilter fill:#7ed321,stroke:#333
    style PullSecret fill:#7ed321,stroke:#333
    style NIMTemplate fill:#7ed321,stroke:#333

    style K8sAPI fill:#e8e8e8,stroke:#333
    style NGCAPI fill:#e8e8e8,stroke:#333
    style Authorino fill:#e8e8e8,stroke:#333
    style Dashboard fill:#b39ddb,stroke:#333
