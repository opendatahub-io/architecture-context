graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        subgraph SharedBase["Shared JobController Base"]
            JobController["JobController<br/>Pod lifecycle, Service mgmt,<br/>Status tracking, Gang scheduling"]
        end

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller<br/>Elastic training, HPA,<br/>Init containers, NetworkPolicy"]
            TFCtrl["TFJob Controller<br/>PS/AllReduce topologies,<br/>Dynamic workers"]
            MPICtrl["MPIJob Controller<br/>Launcher/Worker pattern,<br/>ConfigMaps, RBAC"]
            XGBoostCtrl["XGBoostJob Controller<br/>Master/Worker topology,<br/>LightGBM compatible"]
            PaddleCtrl["PaddleJob Controller<br/>Collective & PS modes"]
            JAXCtrl["JAXJob Controller<br/>Coordinator pattern,<br/>All-to-all comms"]
        end

        WebhookServer["Validating Webhook Server<br/>Port: 9443/TCP (TLS)"]
        CertMgr["OPA Cert Controller<br/>TLS cert rotation"]
        Metrics["Metrics Endpoint<br/>Port: 8080/TCP"]

        JobController --> PyTorchCtrl
        JobController --> TFCtrl
        JobController --> MPICtrl
        JobController --> XGBoostCtrl
        JobController --> PaddleCtrl
        JobController --> JAXCtrl
        CertMgr -->|rotates certs| WebhookServer
    end

    %% CRDs
    User["User / kubectl"] -->|creates| PyTorchJobCR["PyTorchJob CR"]
    User -->|creates| TFJobCR["TFJob CR"]
    User -->|creates| MPIJobCR["MPIJob CR"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR"]
    User -->|creates| PaddleJobCR["PaddleJob CR"]
    User -->|creates| JAXJobCR["JAXJob CR"]

    %% CR to Controller mapping
    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    PaddleJobCR -->|watched by| PaddleCtrl
    JAXJobCR -->|watched by| JAXCtrl

    %% K8s API Server interactions
    K8sAPI["Kubernetes API Server"]
    K8sAPI -->|webhook callback| WebhookServer
    PyTorchCtrl -->|creates| WorkerPods["Worker Pods"]
    PyTorchCtrl -->|creates| HeadlessSvc["Headless Services<br/>(pod DNS discovery)"]
    PyTorchCtrl -->|creates| NetPol["NetworkPolicy<br/>(PyTorch only)"]
    MPICtrl -->|creates| LauncherPod["Launcher Pod"]
    MPICtrl -->|creates| MPIWorkers["MPI Worker Pods"]
    MPICtrl -->|creates| MPIConfigMap["ConfigMap<br/>(hostfile, kubexec.sh)"]
    MPICtrl -->|creates| MPIRBAC["Role/RoleBinding<br/>(per job)"]

    %% Optional integrations
    PyTorchCtrl -.->|optional| Volcano["Volcano PodGroup"]
    PyTorchCtrl -.->|optional| SchedPlugins["scheduler-plugins PodGroup"]
    PyTorchCtrl -.->|optional| HPA["HorizontalPodAutoscaler"]

    %% Monitoring
    OpenShiftMon["OpenShift Monitoring<br/>(PodMonitor)"] -->|scrapes| Metrics

    %% Styles
    style TrainingOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style SharedBase fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Controllers fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style WebhookServer fill:#4a90e2,color:#fff
    style CertMgr fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff
    style JobController fill:#82b366,color:#fff
    style PyTorchCtrl fill:#f5a623,color:#fff
    style TFCtrl fill:#f5a623,color:#fff
    style MPICtrl fill:#f5a623,color:#fff
    style XGBoostCtrl fill:#f5a623,color:#fff
    style PaddleCtrl fill:#f5a623,color:#fff
    style JAXCtrl fill:#f5a623,color:#fff
    style PyTorchJobCR fill:#fff2cc,stroke:#d6b656
    style TFJobCR fill:#fff2cc,stroke:#d6b656
    style MPIJobCR fill:#fff2cc,stroke:#d6b656
    style XGBoostJobCR fill:#fff2cc,stroke:#d6b656
    style PaddleJobCR fill:#fff2cc,stroke:#d6b656
    style JAXJobCR fill:#fff2cc,stroke:#d6b656
    style K8sAPI fill:#999,color:#fff
    style Volcano fill:#e8e8e8,stroke:#999
    style SchedPlugins fill:#e8e8e8,stroke:#999
    style OpenShiftMon fill:#7ed321,color:#fff
