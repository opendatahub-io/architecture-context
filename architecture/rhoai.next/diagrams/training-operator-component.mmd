graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        Controller["training-operator<br/>Go Operator (controller-runtime)"]

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorch Controller<br/>(+elastic, HPA, NetworkPolicy)"]
            TFCtrl["TensorFlow Controller"]
            XGBoostCtrl["XGBoost Controller"]
            MPICtrl["MPI Controller<br/>(launcher/worker pattern)"]
            PaddleCtrl["PaddlePaddle Controller"]
            JAXCtrl["JAX Controller"]
        end

        subgraph CommonFramework["Common Framework (pkg/controller.v1/common)"]
            PodMgmt["Pod Lifecycle Manager"]
            ServiceMgmt["Service Manager"]
            GangSched["Gang Scheduling"]
            StatusMgmt["Status Tracker"]
        end

        subgraph Webhooks["Validating Webhooks (9443/TCP TLS)"]
            PyTorchWH["PyTorchJob Webhook"]
            TFWH["TFJob Webhook"]
            XGBoostWH["XGBoostJob Webhook"]
            PaddleWH["PaddleJob Webhook"]
            JAXWH["JAXJob Webhook"]
        end

        CertRotator["cert-controller<br/>(OPA cert rotator)"]
    end

    %% CRDs
    PyTorchJobCR["PyTorchJob CR<br/>kubeflow.org/v1"]
    TFJobCR["TFJob CR<br/>kubeflow.org/v1"]
    XGBoostJobCR["XGBoostJob CR<br/>kubeflow.org/v1"]
    MPIJobCR["MPIJob CR<br/>kubeflow.org/v1"]
    PaddleJobCR["PaddleJob CR<br/>kubeflow.org/v1"]
    JAXJobCR["JAXJob CR<br/>kubeflow.org/v1"]

    %% User interaction
    User["Data Scientist / ML Engineer"]
    User -->|creates| PyTorchJobCR
    User -->|creates| TFJobCR
    User -->|creates| XGBoostJobCR
    User -->|creates| MPIJobCR
    User -->|creates| PaddleJobCR
    User -->|creates| JAXJobCR

    %% CRDs watched by controllers
    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    MPIJobCR -->|watched by| MPICtrl
    PaddleJobCR -->|watched by| PaddleCtrl
    JAXJobCR -->|watched by| JAXCtrl

    %% Controllers use common framework
    PyTorchCtrl --> PodMgmt
    TFCtrl --> PodMgmt
    XGBoostCtrl --> PodMgmt
    MPICtrl --> PodMgmt
    PaddleCtrl --> PodMgmt
    JAXCtrl --> PodMgmt

    PodMgmt --> ServiceMgmt
    PodMgmt --> GangSched
    PodMgmt --> StatusMgmt

    %% Webhook validates CRDs
    PyTorchJobCR -.->|validated by| PyTorchWH
    TFJobCR -.->|validated by| TFWH
    XGBoostJobCR -.->|validated by| XGBoostWH
    PaddleJobCR -.->|validated by| PaddleWH
    JAXJobCR -.->|validated by| JAXWH

    CertRotator -->|rotates TLS certs| Webhooks

    %% Created resources
    subgraph CreatedResources["Created Resources (user namespace)"]
        WorkerPods["Worker/Master Pods<br/>(with env vars: MASTER_ADDR,<br/>WORLD_SIZE, RANK)"]
        HeadlessSvc["Headless Services<br/>(per-pod DNS discovery)"]
        HPA["HPA<br/>(PyTorch elastic only)"]
        NetPol["NetworkPolicy<br/>(PyTorch only)"]
        MPIResources["ConfigMap + SA + Role<br/>(MPI only)"]
    end

    PodMgmt -->|creates| WorkerPods
    ServiceMgmt -->|creates| HeadlessSvc
    PyTorchCtrl -->|creates| HPA
    PyTorchCtrl -->|creates| NetPol
    MPICtrl -->|creates| MPIResources

    %% External dependencies
    K8sAPI["Kubernetes API Server"]
    Controller -->|watches/CRUD| K8sAPI

