graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        subgraph SharedBase["Shared JobController Base"]
            JobController["JobController<br/>Pod lifecycle, Service mgmt,<br/>Status tracking, Gang scheduling"]
            Expectations["Expectation Controller<br/>Race condition handling"]
            PodControl["Pod Control<br/>Create/Delete pods"]
            ServiceControl["Service Control<br/>Create/Delete headless services"]
            PodGroupControl["PodGroup Control<br/>Create/Delete PodGroups"]
        end

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller<br/>Elastic training, HPA,<br/>Init containers, NetworkPolicy"]
            TFCtrl["TFJob Controller<br/>PS/AllReduce topologies,<br/>Dynamic workers"]
            MPICtrl["MPIJob Controller<br/>Launcher/Worker pattern,<br/>ConfigMap hostfiles, RBAC"]
            XGBoostCtrl["XGBoostJob Controller<br/>Master/Worker topology"]
            PaddleCtrl["PaddleJob Controller<br/>Collective/PS modes"]
            JAXCtrl["JAXJob Controller<br/>Coordinator pattern"]
        end

        subgraph Webhooks["Webhook Server (9443/TCP TLS)"]
            PyTorchWH["PyTorchJob Webhook"]
            TFWH["TFJob Webhook"]
            XGBoostWH["XGBoostJob Webhook"]
            PaddleWH["PaddleJob Webhook"]
            JAXWH["JAXJob Webhook"]
        end

        CertMgr["OPA Cert Controller<br/>TLS cert rotation"]
    end

    %% CRDs
    PyTorchJob["PyTorchJob CR<br/>kubeflow.org/v1"]
    TFJob["TFJob CR<br/>kubeflow.org/v1"]
    MPIJob["MPIJob CR<br/>kubeflow.org/v1"]
    XGBoostJob["XGBoostJob CR<br/>kubeflow.org/v1"]
    PaddleJob["PaddleJob CR<br/>kubeflow.org/v1"]
    JAXJob["JAXJob CR<br/>kubeflow.org/v1"]

    %% User interaction
    User["User / kubectl"]
    User -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| MPIJob
    User -->|creates| XGBoostJob
    User -->|creates| PaddleJob
    User -->|creates| JAXJob

    %% CRD → Controller
    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    MPIJob -->|watched by| MPICtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    PaddleJob -->|watched by| PaddleCtrl
    JAXJob -->|watched by| JAXCtrl

    %% Controllers inherit from base
    PyTorchCtrl --> JobController
    TFCtrl --> JobController
    MPICtrl --> JobController
    XGBoostCtrl --> JobController
    PaddleCtrl --> JobController
    JAXCtrl --> JobController

    JobController --> PodControl
    JobController --> ServiceControl
    JobController --> PodGroupControl
    JobController --> Expectations

    %% Created resources
    PodControl -->|creates| WorkerPods["Worker Pods"]
    ServiceControl -->|creates| HeadlessSvc["Headless Services<br/>(pod DNS discovery)"]
    PodGroupControl -->|creates| PodGroups["PodGroups<br/>(gang scheduling)"]
    PyTorchCtrl -->|creates| NetworkPolicyCR["NetworkPolicy<br/>(PyTorchJob isolation)"]
    PyTorchCtrl -->|creates| HPA["HorizontalPodAutoscaler<br/>(elastic training)"]

    %% Webhook validation
    K8sAPI["K8s API Server"] -->|webhook callback| Webhooks
    CertMgr -->|rotates certs| Webhooks

    %% Metrics
    Prometheus["OpenShift Monitoring<br/>(PodMonitor)"] -->|scrapes /metrics<br/>8080/TCP| TrainingOperator

    %% Styling
    style TrainingOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style SharedBase fill:#d4e6f1,stroke:#2980b9
    style Controllers fill:#d5f5e3,stroke:#27ae60
    style Webhooks fill:#fdebd0,stroke:#f39c12
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style JAXJob fill:#f5a623,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style HeadlessSvc fill:#7ed321,stroke:#333
    style PodGroups fill:#7ed321,stroke:#333
    style NetworkPolicyCR fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style CertMgr fill:#bb8fce,stroke:#333
