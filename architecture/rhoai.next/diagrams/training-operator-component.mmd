graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        Controller["Training Operator Controller<br/>Go Operator (controller-runtime)<br/>Ports: 8080 metrics, 8081 health, 9443 webhook"]

        subgraph Webhooks["Validating Webhooks (9443/TCP HTTPS)"]
            WH_PT["PyTorchJob Webhook"]
            WH_TF["TFJob Webhook"]
            WH_JAX["JAXJob Webhook"]
            WH_XGB["XGBoostJob Webhook"]
            WH_Paddle["PaddleJob Webhook"]
        end

        Controller --> WH_PT
        Controller --> WH_TF
        Controller --> WH_JAX
        Controller --> WH_XGB
        Controller --> WH_Paddle

        CertCtrl["cert-controller<br/>(embedded library)"]
        Controller --> CertCtrl
    end

    subgraph CRDs["Custom Resource Definitions (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob<br/>Master/Worker topology<br/>Elastic training support"]
        TFJob["TFJob<br/>Chief/PS/Worker/Evaluator"]
        MPIJob["MPIJob<br/>Launcher/Worker pattern<br/>kubectl exec communication"]
        JAXJob["JAXJob<br/>Flat worker topology"]
        XGBoostJob["XGBoostJob<br/>Rabit tracker master/worker"]
        PaddleJob["PaddleJob<br/>Collective or PS mode<br/>Elastic support"]
    end

    User["Data Scientist / User"] -->|"kubectl create"| PyTorchJob
    User -->|"kubectl create"| TFJob
    User -->|"kubectl create"| MPIJob
    User -->|"kubectl create"| JAXJob
    User -->|"kubectl create"| XGBoostJob
    User -->|"kubectl create"| PaddleJob

    PyTorchJob -->|"watched by"| Controller
    TFJob -->|"watched by"| Controller
    MPIJob -->|"watched by"| Controller
    JAXJob -->|"watched by"| Controller
    XGBoostJob -->|"watched by"| Controller
    PaddleJob -->|"watched by"| Controller

    subgraph CreatedResources["Created Resources (per job namespace)"]
        Pods["Training Pods<br/>(master + workers)"]
        HeadlessSvc["Headless Services<br/>(pod-to-pod DNS)"]
        MPI_Resources["MPI Resources<br/>(SA, Role, RoleBinding,<br/>ConfigMap, kubectl-delivery)"]
    end

    Controller -->|"creates"| Pods
    Controller -->|"creates"| HeadlessSvc
    Controller -->|"creates (MPI only)"| MPI_Resources

    subgraph OptionalSchedulers["Optional Gang Schedulers"]
        Volcano["Volcano<br/>PodGroup CRD"]
        SchedPlugins["scheduler-plugins<br/>PodGroup CRD"]
    end

    Controller -->|"creates PodGroup"| Volcano
    Controller -->|"creates PodGroup"| SchedPlugins

    K8sAPI["Kubernetes API Server"]
    Controller -->|"CRUD via REST API"| K8sAPI
    Prometheus["Prometheus<br/>(PodMonitor)"] -->|"scrapes :8080/metrics"| Controller

    KubectlDelivery["kubectl-delivery<br/>Init Container Image"]
    KubectlDelivery -.->|"provides kubectl binary"| MPI_Resources

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style WH_PT fill:#4a90e2,stroke:#333,color:#fff
    style WH_TF fill:#4a90e2,stroke:#333,color:#fff
    style WH_JAX fill:#4a90e2,stroke:#333,color:#fff
    style WH_XGB fill:#4a90e2,stroke:#333,color:#fff
    style WH_Paddle fill:#4a90e2,stroke:#333,color:#fff
    style CertCtrl fill:#4a90e2,stroke:#333,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style JAXJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style HeadlessSvc fill:#7ed321,stroke:#333
    style MPI_Resources fill:#7ed321,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style SchedPlugins fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style KubectlDelivery fill:#b8d4f0,stroke:#333
    style User fill:#fff,stroke:#333
