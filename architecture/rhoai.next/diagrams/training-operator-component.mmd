graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        Controller["Training Operator Controller<br/>Go / controller-runtime<br/>Port 8080 (metrics), 8081 (health)"]
        WebhookServer["Webhook Server<br/>Port 9443/HTTPS<br/>TLS (self-signed)"]

        subgraph FrameworkControllers["Framework Controllers"]
            PyTorchCtrl["PyTorch Controller"]
            TFCtrl["TensorFlow Controller"]
            MPICtrl["MPI Controller"]
            JAXCtrl["JAX Controller"]
            XGBoostCtrl["XGBoost Controller"]
            PaddleCtrl["PaddlePaddle Controller"]
        end

        subgraph SharedBase["Shared Base (JobController)"]
            PodMgmt["Pod Lifecycle<br/>Management"]
            ServiceMgmt["Headless Service<br/>Creation"]
            GangSched["Gang Scheduling<br/>Integration"]
            StatusTrack["Status Tracking<br/>& Expectations"]
        end

        Controller --> FrameworkControllers
        FrameworkControllers --> SharedBase
    end

    subgraph CRDs["Custom Resource Definitions (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        MPIJob["MPIJob"]
        JAXJob["JAXJob"]
        XGBoostJob["XGBoostJob"]
        PaddleJob["PaddleJob"]
    end

    User["Data Scientist / User"] -->|"kubectl create"| CRDs
    CRDs -->|"admission"| WebhookServer
    CRDs -->|"watched by"| Controller

    Controller -->|"creates"| Pods["Training Pods<br/>(Master/Worker)"]
    Controller -->|"creates"| HeadlessSvc["Headless Services<br/>(pod-to-pod DNS)"]
    MPICtrl -->|"creates"| MPIResources["MPI Resources<br/>(SA, Role, RoleBinding,<br/>ConfigMap)"]
    MPICtrl -->|"creates"| KubectlInit["kubectl-delivery<br/>Init Container"]

    Controller -->|"API calls"| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style WebhookServer fill:#4a90e2,stroke:#333,color:#fff
