    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style PyTorchCtrl fill:#4a90e2,stroke:#333,color:#fff
    style TFCtrl fill:#4a90e2,stroke:#333,color:#fff
    style XGBoostCtrl fill:#4a90e2,stroke:#333,color:#fff
    style MPICtrl fill:#4a90e2,stroke:#333,color:#fff
    style PaddleCtrl fill:#4a90e2,stroke:#333,color:#fff
    style JAXCtrl fill:#4a90e2,stroke:#333,color:#fff
    style PodMgmt fill:#5b9bd5,stroke:#333,color:#fff
    style ServiceMgmt fill:#5b9bd5,stroke:#333,color:#fff
    style GangSched fill:#5b9bd5,stroke:#333,color:#fff
    style StatusMgmt fill:#5b9bd5,stroke:#333,color:#fff
    style PyTorchWH fill:#e8a838,stroke:#333
    style TFWH fill:#e8a838,stroke:#333
    style XGBoostWH fill:#e8a838,stroke:#333
    style PaddleWH fill:#e8a838,stroke:#333
    style JAXWH fill:#e8a838,stroke:#333
    style CertRotator fill:#9b59b6,stroke:#333,color:#fff
