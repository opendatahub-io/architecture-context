graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller<br/>Master/Worker topology<br/>NetworkPolicy, HPA, InitContainers"]
            TFCtrl["TFJob Controller<br/>Chief/PS/Worker/Evaluator topology<br/>TF_CONFIG injection"]
            XGBoostCtrl["XGBoostJob Controller<br/>Master/Worker topology<br/>Rabit coordination"]
            JAXCtrl["JAXJob Controller<br/>Worker-only topology<br/>Coordinator discovery"]
            MPICtrl["MPIJob Controller<br/>Launcher/Worker topology<br/>kubectl exec, per-job RBAC"]
            PaddleCtrl["PaddleJob Controller<br/>Master/Worker topology<br/>Collective + PS modes"]
        end

        subgraph SharedBase["Shared Infrastructure"]
            JobController["JobController Base<br/>Pod/Service lifecycle<br/>Status tracking, Gang scheduling"]
            Expectations["Expectation Controller<br/>Eventual consistency handling<br/>Prevents redundant reconciliation"]
        end

        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>Validates 5 CRD types"]
        CertMgr["Cert Controller<br/>Auto TLS cert generation<br/>cert-controller library"]
        Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>Prometheus counters"]
    end

    %% CRDs
    PyTorchCR["PyTorchJob CR<br/>kubeflow.org/v1"]
    TFCR["TFJob CR<br/>kubeflow.org/v1"]
    XGBoostCR["XGBoostJob CR<br/>kubeflow.org/v1"]
    JAXCR["JAXJob CR<br/>kubeflow.org/v1"]
    MPICR["MPIJob CR<br/>kubeflow.org/v1"]
    PaddleCR["PaddleJob CR<br/>kubeflow.org/v1"]

    %% External actors
    User["User / Data Scientist"]
    K8sAPI["Kubernetes API Server"]
    Prometheus["Prometheus<br/>OpenShift Monitoring"]

    %% User creates CRDs via API
    User -->|kubectl apply| K8sAPI
    K8sAPI -->|webhook validation| Webhook
    K8sAPI -->|watch events| PyTorchCtrl
    K8sAPI -->|watch events| TFCtrl
    K8sAPI -->|watch events| XGBoostCtrl
    K8sAPI -->|watch events| JAXCtrl
    K8sAPI -->|watch events| MPICtrl
    K8sAPI -->|watch events| PaddleCtrl

    %% CRD associations
    PyTorchCR -->|reconciled by| PyTorchCtrl
    TFCR -->|reconciled by| TFCtrl
    XGBoostCR -->|reconciled by| XGBoostCtrl
    JAXCR -->|reconciled by| JAXCtrl
    MPICR -->|reconciled by| MPICtrl
    PaddleCR -->|reconciled by| PaddleCtrl

    %% Controllers use shared base
    PyTorchCtrl -->|extends| JobController
    TFCtrl -->|extends| JobController
    XGBoostCtrl -->|extends| JobController
    JAXCtrl -->|extends| JobController
    MPICtrl -->|extends| JobController
    PaddleCtrl -->|extends| JobController
    JobController -->|uses| Expectations

    %% Controllers create resources via API
    JobController -->|creates Pods, Services| K8sAPI
    MPICtrl -->|creates ConfigMaps, SA, Roles| K8sAPI

    %% Cert manager manages webhook certs
    CertMgr -->|provisions TLS certs| Webhook

    %% Monitoring
    Prometheus -->|scrapes /metrics| Metrics

    %% Created resources
    subgraph CreatedResources["Created Resources (per job namespace)"]
        TrainingPods["Training Pods<br/>Master + Workers"]
        HeadlessSvc["Headless Services<br/>Pod-to-pod DNS discovery"]
        NetPolicy["NetworkPolicy<br/>(PyTorch only)"]
        HPA["HPA<br/>(PyTorch elastic only)"]
    end

    JobController -->|creates| TrainingPods
    JobController -->|creates| HeadlessSvc
    PyTorchCtrl -->|creates| NetPolicy
    PyTorchCtrl -->|creates| HPA

    %% Styling
    style TrainingOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#f0f4ff,stroke:#4a90e2,stroke-width:1px
    style SharedBase fill:#f0f4ff,stroke:#4a90e2,stroke-width:1px
    style CreatedResources fill:#fff8e1,stroke:#f5a623,stroke-width:1px

    style PyTorchCtrl fill:#4a90e2,color:#fff
    style TFCtrl fill:#4a90e2,color:#fff
    style XGBoostCtrl fill:#4a90e2,color:#fff
    style JAXCtrl fill:#4a90e2,color:#fff
    style MPICtrl fill:#4a90e2,color:#fff
    style PaddleCtrl fill:#4a90e2,color:#fff
    style JobController fill:#2c6fbb,color:#fff
    style Expectations fill:#2c6fbb,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style CertMgr fill:#4a90e2,color:#fff
    style Metrics fill:#4a90e2,color:#fff

    style PyTorchCR fill:#f5a623,color:#fff
    style TFCR fill:#f5a623,color:#fff
    style XGBoostCR fill:#f5a623,color:#fff
    style JAXCR fill:#f5a623,color:#fff
    style MPICR fill:#f5a623,color:#fff
    style PaddleCR fill:#f5a623,color:#fff

    style User fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Prometheus fill:#7ed321,color:#fff

    style TrainingPods fill:#f5a623,color:#fff
    style HeadlessSvc fill:#f5a623,color:#fff
    style NetPolicy fill:#f5a623,color:#fff
    style HPA fill:#f5a623,color:#fff
