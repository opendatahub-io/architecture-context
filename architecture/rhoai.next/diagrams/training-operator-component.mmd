graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        Controller["Training Operator Controller<br/>Go controller-runtime<br/>Port 8080 metrics, 8081 probes"]
        Webhook["Webhook Server<br/>Port 9443/HTTPS<br/>TLS (self-signed)"]
        CertCtrl["cert-controller<br/>Certificate generation & rotation"]

        Controller -->|"validates admissions"| Webhook
        CertCtrl -->|"provisions TLS cert"| Webhook
    end

    subgraph CRDs["Custom Resource Definitions (kubeflow.org/v1)"]
        direction LR
        PyTorchJob["PyTorchJob<br/>master/worker topology<br/>elastic training"]
        TFJob["TFJob<br/>Chief/PS/Worker/Evaluator"]
        MPIJob["MPIJob<br/>launcher/worker pattern<br/>kubectl exec comm"]
        JAXJob["JAXJob<br/>flat worker topology"]
        XGBoostJob["XGBoostJob<br/>Rabit tracker master/worker"]
        PaddleJob["PaddleJob<br/>collective or PS mode<br/>elastic training"]
    end

    subgraph CreatedResources["Resources Created Per Job"]
        direction LR
        Pods["Worker/Master Pods<br/>framework-specific env vars"]
        HeadlessSvc["Headless Services<br/>pod-to-pod DNS discovery"]
        MPI_Resources["MPI: SA, Role, RoleBinding<br/>ConfigMap, kubectl-delivery"]
        HPARes["HPA<br/>(elastic PyTorch/Paddle)"]
    end

    User["Data Scientist / User"] -->|"kubectl create"| CRDs
    CRDs -->|"watched by"| Controller
    Controller -->|"creates & manages"| CreatedResources

    subgraph GangScheduling["Gang Scheduling (optional)"]
        Volcano["Volcano<br/>PodGroup CRD"]
        SchedPlugins["scheduler-plugins<br/>PodGroup CRD"]
    end

    Controller -->|"creates PodGroup"| GangScheduling

    K8sAPI["Kubernetes API Server"] -->|"webhook calls"| Webhook
    Controller -->|"CRUD operations"| K8sAPI

    Prometheus["Prometheus"] -->|"scrapes /metrics"| Controller

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style CertCtrl fill:#4a90e2,stroke:#333,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style JAXJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style HeadlessSvc fill:#7ed321,stroke:#333
    style MPI_Resources fill:#7ed321,stroke:#333
    style HPARes fill:#7ed321,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style SchedPlugins fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
