graph TB
    subgraph TrainingOperator["Training Operator (opendatahub namespace)"]
        direction TB
        Controller["training-operator<br/>(Go Operator / controller-runtime)<br/>Reconciles 6 CRD types"]
        Webhooks["Validating Webhooks<br/>9443/TCP HTTPS<br/>PyTorch, TF, XGBoost, JAX, Paddle"]
        CertMgr["Certificate Manager<br/>(OPA cert-controller)<br/>Self-managed TLS rotation"]
        Metrics["Prometheus Metrics<br/>8080/TCP HTTP<br/>Job lifecycle counters"]

        Controller -->|"serves"| Webhooks
        CertMgr -->|"provisions TLS certs"| Webhooks
        Controller -->|"exposes"| Metrics
    end

    %% CRDs
    subgraph CRDs["Custom Resources (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob<br/>master/worker topology<br/>elastic scaling"]
        TFJob["TFJob<br/>PS/worker/chief/evaluator"]
        XGBoostJob["XGBoostJob<br/>master/worker"]
        MPIJob["MPIJob<br/>launcher/worker<br/>hostfile + kubexec"]
        JAXJob["JAXJob<br/>worker-only"]
        PaddleJob["PaddleJob<br/>master/worker<br/>elastic scaling"]
    end

    User["User / Data Scientist"] -->|"kubectl create"| CRDs
    CRDs -->|"watched by"| Controller

    %% Resources created by operator
    subgraph CreatedResources["Resources Created by Operator"]
        TrainingPods["Training Pods<br/>(framework-specific env vars)"]
        HeadlessServices["Headless Services<br/>(DNS peer discovery)"]
        PodGroups["PodGroups<br/>(gang scheduling)"]
        HPAs["HPA<br/>(PyTorch elastic only)"]
        MPIResources["MPI RBAC<br/>(SA + Role + RoleBinding)"]
    end

    Controller -->|"creates"| TrainingPods
    Controller -->|"creates"| HeadlessServices
    Controller -->|"creates (optional)"| PodGroups
    Controller -->|"creates (elastic)"| HPAs
    Controller -->|"creates (MPI only)"| MPIResources

    %% External dependencies
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    Controller -->|"CRUD operations<br/>ServiceAccount Token"| K8sAPI
    K8sAPI -->|"admission calls"| Webhooks

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhooks fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CertMgr fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333,color:#000
    style TFJob fill:#f5a623,stroke:#333,color:#000
    style XGBoostJob fill:#f5a623,stroke:#333,color:#000
    style MPIJob fill:#f5a623,stroke:#333,color:#000
    style JAXJob fill:#f5a623,stroke:#333,color:#000
    style PaddleJob fill:#f5a623,stroke:#333,color:#000
    style TrainingPods fill:#7ed321,stroke:#333,color:#000
    style HeadlessServices fill:#7ed321,stroke:#333,color:#000
    style PodGroups fill:#7ed321,stroke:#333,color:#000
    style HPAs fill:#7ed321,stroke:#333,color:#000
    style MPIResources fill:#7ed321,stroke:#333,color:#000
    style K8sAPI fill:#e8e8e8,stroke:#333,color:#000
    style User fill:#fff,stroke:#333,color:#000
