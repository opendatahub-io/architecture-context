graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph Clients["gRPC Clients"]
            DSP["Data Science Pipelines<br/>(Primary Client)<br/>Pipeline metadata recording"]
            KFUI["Kubeflow Pipelines UI<br/>(Read-Only Client)<br/>Lineage visualization"]
        end

        subgraph MLMDService["MLMD Service (ClusterIP)"]
            MLMD["metadata_store_server<br/>Port: 8080/TCP<br/>Protocol: gRPC/HTTP2<br/>Encryption: Optional TLS (SSLConfig)<br/>Auth: Optional mTLS (client_verify)<br/>Default: InsecureServerCredentials<br/>Image: odh-mlmd-grpc-server (UBI9)<br/>User: non-root (UID 65534)"]
        end
    end

    subgraph DataStores["DATA STORES"]
        MySQL["MySQL / MariaDB<br/>Port: 3306/TCP<br/>Protocol: MySQL<br/>Encryption: Optional SSL<br/>(MySQLDatabaseConfig.SSLOptions)<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL<br/>Port: 5432/TCP<br/>Protocol: PostgreSQL<br/>Encryption: Optional SSL<br/>(PostgreSQLDatabaseConfig.SSLOptions)<br/>Auth: Username/Password"]
    end

    subgraph Secrets["SECRETS"]
        DBCreds["Database Credentials<br/>(Opaque)<br/>Provisioned by: Platform Operator<br/>Auto-Rotate: No"]
        TLSCerts["TLS Certificates<br/>(kubernetes.io/tls)<br/>Provisioned by: cert-manager<br/>Auto-Rotate: Depends"]
    end

    %% Client to MLMD flows
    DSP -->|"gRPC/HTTP2 : 8080/TCP<br/>Optional TLS (SSLConfig)<br/>Optional mTLS (client_verify)"| MLMD
    KFUI -->|"gRPC/HTTP2 : 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| MLMD

    %% MLMD to database flows
    MLMD -->|"MySQL Protocol : 3306/TCP<br/>Optional SSL<br/>Username/Password<br/>New conn per RPC"| MySQL
    MLMD -->|"PostgreSQL Protocol : 5432/TCP<br/>Optional SSL<br/>Username/Password<br/>New conn per RPC"| PostgreSQL

    %% Secret references
    DBCreds -.->|credentials| MLMD
    TLSCerts -.->|server key, cert, CA| MLMD

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef datastore fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class DSP,KFUI client
    class MLMD service
    class MySQL,PostgreSQL datastore
    class DBCreds,TLSCerts secret
