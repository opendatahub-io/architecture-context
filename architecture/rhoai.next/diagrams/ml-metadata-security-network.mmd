graph TB
    subgraph Clients["INTERNAL CLIENTS (Cluster-Internal)"]
        KFP["Kubeflow Pipelines<br/>(ml-pipeline-api-server)<br/>Records pipeline metadata"]
        KFPSDK["KFP SDK / Python Client<br/>(ml-metadata library)<br/>Retry: exponential backoff"]
        DSP["Data Science Pipelines<br/>(RHOAI)<br/>Artifact & lineage tracking"]
        PipelineUI["Pipeline UI / Client<br/>Lineage queries"]
    end

    subgraph Service["SERVICE (ClusterIP - Internal Only)"]
        direction TB
        SVC["metadata-grpc-service<br/>ClusterIP 8080/TCP"]
        subgraph Container["MLMD gRPC Server Container"]
            Server["metadata_store_server<br/>User: 65534:65534 (non-root)<br/>Env: GRPC_PORT=8080<br/>40+ gRPC RPC methods"]
        end
        SVC --> Server
    end

    subgraph Databases["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL protocol<br/>Optional TLS<br/>(cert, key, ca, cipher,<br/>verify_server_cert)<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL protocol<br/>Optional TLS<br/>(sslmode, sslcert, sslkey,<br/>sslrootcert)<br/>Auth: Username/Password"]
    end

    subgraph Secrets["SECRETS"]
        ConfigSecret["metadata-store-server-config<br/>(Opaque)<br/>DB connection + TLS config"]
        DBCreds["mysql/postgres credentials<br/>(Opaque)<br/>DB username/password"]
        TLSSecret["grpc-tls<br/>(kubernetes.io/tls)<br/>server_key, server_cert, custom_ca"]
    end

    %% Client flows
    KFP -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS (client_verify)"| SVC
    KFPSDK -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC
    DSP -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC
    PipelineUI -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC

    %% Database flows
    Server -->|"MySQL protocol 3306/TCP<br/>Optional TLS (SSLOptions)<br/>Username/Password"| MySQL
    Server -->|"PostgreSQL protocol 5432/TCP<br/>Optional TLS (SSLOptions)<br/>Username/Password"| PostgreSQL

    %% Secret references
    ConfigSecret -.->|"config file"| Server
    DBCreds -.->|"credentials"| Server
    TLSSecret -.->|"TLS certs"| Server

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef container fill:#4a90e2,stroke:#333,color:#fff,stroke-width:2px

    class KFP,KFPSDK,DSP,PipelineUI client
    class SVC service
    class Server container
    class MySQL,PostgreSQL database
    class ConfigSecret,DBCreds,TLSSecret secret
