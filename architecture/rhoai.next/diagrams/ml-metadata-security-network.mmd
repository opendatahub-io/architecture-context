graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        direction TB
        DSP["Data Science Pipelines<br/>(gRPC Client)"]
        PipelinesUI["Kubeflow Pipelines UI<br/>(gRPC Client)"]
    end

    subgraph Internal["INTERNAL CLUSTER (Trusted)"]
        direction TB

        subgraph NS_DSP["Namespace: data-science-pipelines"]
            MLMDServer["MLMD gRPC Server<br/>metadata_store_server<br/>Port: 8080/TCP<br/>Protocol: gRPC/HTTP2<br/>UID: 65534 (non-root)<br/>Image: odh-mlmd-grpc-server (UBI9)"]
        end
    end

    subgraph DatabaseLayer["DATABASE LAYER"]
        direction TB
        MySQL["MySQL / MariaDB<br/>Port: 3306/TCP<br/>Protocol: MySQL<br/>Encryption: Optional SSL<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL<br/>Port: 5432/TCP<br/>Protocol: PostgreSQL<br/>Encryption: Optional SSL (sslmode)<br/>Auth: Username/Password"]
    end

    %% Ingress flows
    DSP -->|"gRPC/HTTP2 / 8080/TCP<br/>Encryption: Optional TLS (SSLConfig)<br/>Auth: Optional mTLS (client_verify)"| MLMDServer
    PipelinesUI -->|"gRPC/HTTP2 / 8080/TCP<br/>Encryption: Optional TLS<br/>Auth: Optional mTLS"| MLMDServer

    %% Egress flows
    MLMDServer -->|"MySQL protocol / 3306/TCP<br/>Encryption: Optional SSL (ssl_options)<br/>Auth: Username/Password"| MySQL
    MLMDServer -->|"PostgreSQL protocol / 5432/TCP<br/>Encryption: Optional SSL (sslmode)<br/>Auth: Username/Password"| PostgreSQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class DSP,PipelinesUI external
    class MLMDServer internal
    class MySQL,PostgreSQL database
