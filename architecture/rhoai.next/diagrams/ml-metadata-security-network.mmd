graph TB
    subgraph InternalClients["INTERNAL CLIENTS (Cluster-Internal, Trusted)"]
        KFP["Kubeflow Pipelines<br/>ml-pipeline-api-server<br/>SA: ml-pipeline"]
        KFPSDK["KFP SDK / Python Client<br/>ml-metadata library<br/>Retry: Exponential Backoff"]
        DSP["Data Science Pipelines<br/>(RHOAI)"]
        PipelineUI["Pipeline UI / Client"]
    end

    subgraph Service["SERVICE (ClusterIP - No External Exposure)"]
        direction TB
        SVC["metadata-grpc-service<br/>ClusterIP<br/>8080/TCP → 8080/TCP"]
        Server["metadata_store_server<br/>C++ gRPC Binary<br/>UBI9-minimal<br/>UID 65534:65534 (non-root)<br/>TLS: BoringSSL"]

        SVC --> Server
    end

    subgraph Databases["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL Protocol<br/>Optional TLS<br/>Username/Password Auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL Protocol<br/>Optional TLS<br/>Username/Password Auth"]
    end

    subgraph Secrets["SECRETS"]
        ConfigSecret["metadata-store-server-config<br/>(Opaque)<br/>DB connection + TLS config"]
        DBCreds["mysql/postgres credentials<br/>(Opaque)<br/>Username/Password"]
        TLSSecret["grpc-tls<br/>(kubernetes.io/tls)<br/>server_key, server_cert, custom_ca"]
    end

    %% Client flows
    KFP -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC
    KFPSDK -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC
    DSP -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC
    PipelineUI -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| SVC

    %% Database flows
    Server -->|"MySQL Protocol 3306/TCP<br/>Optional TLS (SSLOptions)<br/>Username/Password"| MySQL
    Server -->|"PostgreSQL Protocol 5432/TCP<br/>Optional TLS (SSLOptions)<br/>Username/Password"| PostgreSQL

    %% Secret references
    ConfigSecret -.->|"mounted"| Server
    DBCreds -.->|"referenced"| Server
    TLSSecret -.->|"mounted"| Server

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5 5

    class KFP,KFPSDK,DSP,PipelineUI client
    class SVC,Server service
    class MySQL,PostgreSQL database
    class ConfigSecret,DBCreds,TLSSecret secret
