graph TB
    subgraph Clients["INTERNAL CLIENTS (Platform Services)"]
        DSP["Data Science Pipelines<br/>(DSP Driver)"]
        TFX["TFX / Kubeflow Pipelines<br/>(Legacy)"]
    end

    subgraph ProxyLayer["ACCESS CONTROL (Platform-Managed)"]
        Proxy["kube-rbac-proxy<br/><i>Optional upstream proxy</i><br/><i>Managed by RHOAI operator</i>"]
    end

    subgraph MLMDService["MLMD SERVICE (ClusterIP - Internal Only)"]
        direction TB
        Server["odh-mlmd-grpc-server<br/>8080/TCP gRPC/HTTP2<br/>User: 65534:65534 (non-root)<br/>Image: UBI9/ubi-minimal<br/>TLS: Optional (BoringSSL)<br/>Auth: Optional mTLS (client_verify)"]

        subgraph ServerInternals["Server Internals"]
            ServiceImpl["MetadataStoreServiceImpl<br/><i>New DB conn per RPC</i>"]
            MetadataStore["metadata_store core<br/><i>Optimistic concurrency</i>"]
            QueryEngine["query_engine<br/><i>ZetaSQL filter parsing</i>"]
            ServiceImpl --> MetadataStore
            MetadataStore --> QueryEngine
        end

        Server --> ServiceImpl
    end

    subgraph Databases["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL wire protocol<br/>Optional SSL<br/>Auth: Username/password"]
        PostgreSQL["PostgreSQL<br/>Configurable/TCP<br/>PG wire protocol<br/>Optional SSL<br/>Auth: Username/password"]
    end

    %% Client flows
    DSP -->|"gRPC/HTTP2 · 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Proxy
    TFX -->|"gRPC/HTTP2 · 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Proxy
    Proxy -->|"gRPC/HTTP2 · 8080/TCP"| Server

    %% Database flows
    MetadataStore -->|"MySQL wire protocol · 3306/TCP<br/>Optional SSL<br/>Username/password"| MySQL
    MetadataStore -->|"PG wire protocol · configurable/TCP<br/>Optional SSL<br/>Username/password"| PostgreSQL

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef proxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class DSP,TFX client
    class Proxy proxy
    class Server service
    class ServiceImpl,MetadataStore,QueryEngine internal
    class MySQL,PostgreSQL database
