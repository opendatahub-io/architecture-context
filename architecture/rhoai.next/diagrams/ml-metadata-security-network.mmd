graph TB
    subgraph InCluster["INTERNAL CLIENTS (In-Cluster, Trusted)"]
        KFP["KFP Backend /<br/>DSP API Server<br/>Namespace: {dsp-namespace}"]
        SDK["KFP Python SDK /<br/>Pipeline UI<br/>Namespace: {user-namespace}"]
        TFX["TFX<br/>(TensorFlow Extended)"]
    end

    subgraph MLMDService["ML METADATA SERVICE"]
        direction TB
        Server["metadata_store_server<br/>C++ gRPC Binary<br/>Port: 8080/TCP<br/>UID: 65534 (non-root)<br/>Image: odh-mlmd-grpc-server (UBI9)"]
        TLSNote["TLS: Optional SSLConfig<br/>Crypto: BoringSSL (NOT FIPS mode)<br/>Default: InsecureServerCredentials"]
        Server --- TLSNote
    end

    subgraph DatabaseBackends["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>Optional SSL<br/>Username/password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional SSL<br/>Username/password"]
    end

    subgraph Management["DEPLOYMENT MANAGEMENT"]
        DSPOperator["Data Science Pipelines<br/>Operator"]
    end

    %% Ingress flows (in-cluster only)
    KFP -->|"gRPC/HTTP2 · 8080/TCP<br/>Optional TLS (SSLConfig)<br/>No built-in auth"| Server
    SDK -->|"gRPC/HTTP2 · 8080/TCP<br/>Optional TLS (SSLConfig)<br/>No built-in auth"| Server
    TFX -->|"gRPC/HTTP2 · 8080/TCP<br/>Optional TLS (SSLConfig)<br/>No built-in auth"| Server

    %% Egress flows
    Server -->|"MySQL protocol · 3306/TCP<br/>Optional SSL (SSLOptions)<br/>Username/password"| MySQL
    Server -->|"PostgreSQL protocol · 5432/TCP<br/>Optional SSL (SSLOptions)<br/>Username/password"| PostgreSQL

    %% Management
    DSPOperator -.->|"Deploys & configures<br/>Provides DB credentials"| Server

    %% Styling
    classDef incluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef management fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef tlsnote fill:#f8cecc,stroke:#b85450,stroke-width:1px,font-size:10px

    class KFP,SDK,TFX incluster
    class Server service
    class TLSNote tlsnote
    class MySQL,PostgreSQL database
    class DSPOperator management
