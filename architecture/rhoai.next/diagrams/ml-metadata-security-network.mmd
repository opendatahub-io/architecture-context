graph TB
    subgraph InternalClients["INTERNAL CLIENTS (Cluster-Internal)"]
        DSP["Data Science Pipelines<br/>(DSP Driver)<br/>Primary consumer"]
        TFX["TFX / Kubeflow Pipelines<br/>Legacy integration"]
        PipelineUI["ML Pipeline UI / Client<br/>Lineage queries"]
    end

    subgraph MLMDService["MLMD SERVICE (ClusterIP)"]
        Server["metadata_store_server<br/>(odh-mlmd-grpc-server)<br/>Port: 8080/TCP gRPC/HTTP2<br/>User: 65534:65534 (non-root)<br/>Crypto: BoringSSL<br/>TLS: Optional SslServerCredentials<br/>Auth: Optional mTLS (client_verify)"]
    end

    subgraph DatabaseBackends["DATABASE BACKENDS (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL wire protocol<br/>Optional SSL<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL<br/>Configurable/TCP<br/>PG wire protocol<br/>Optional SSL (sslmode)<br/>Auth: Username/Password"]
        SQLite["SQLite (Dev/Test)<br/>Embedded<br/>No network"]
    end

    %% Client → MLMD flows
    DSP -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Server
    TFX -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Server
    PipelineUI -->|"gRPC/HTTP2 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Server

    %% MLMD → Database flows
    Server -->|"MySQL wire protocol<br/>3306/TCP<br/>Optional SSL<br/>Username/Password"| MySQL
    Server -->|"PG wire protocol<br/>Configurable/TCP<br/>Optional SSL<br/>Username/Password"| PostgreSQL
    Server -->|"Embedded SQL<br/>No network"| SQLite

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef devonly fill:#f5f5f5,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5

    class DSP,TFX,PipelineUI client
    class Server service
    class MySQL,PostgreSQL database
    class SQLite devonly
