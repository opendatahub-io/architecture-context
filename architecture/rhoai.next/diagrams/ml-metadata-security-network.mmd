graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph Clients["gRPC Clients"]
            DSP["Data Science Pipelines<br/>(DSP)<br/>Primary consumer"]
            KFUI["Kubeflow Pipelines UI<br/>Reads artifacts/lineage"]
        end

        subgraph MLMDService["MLMD Service (ClusterIP)"]
            Server["MLMD gRPC Server<br/>(metadata_store_server)<br/>Port: 8080/TCP<br/>gRPC/HTTP2<br/>User: UID 65534 (non-root)<br/>Image: odh-mlmd-grpc-server (UBI9)"]
        end
    end

    subgraph DatabaseTier["DATABASE TIER"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL protocol<br/>Optional SSL<br/>Auth: Username/Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL protocol<br/>Optional SSL (sslmode)<br/>Auth: Username/Password"]
        SQLite["SQLite<br/>In-Process<br/>No network<br/>(Dev/Test only)"]
    end

    %% Client flows
    DSP -->|"gRPC/HTTP2 : 8080/TCP<br/>Optional TLS (SSLConfig)<br/>Optional mTLS (client_verify)"| Server
    KFUI -->|"gRPC/HTTP2 : 8080/TCP<br/>Optional TLS<br/>Optional mTLS"| Server

    %% Database flows
    Server -->|"MySQL protocol : 3306/TCP<br/>Optional SSL (SSLOptions)<br/>Username/Password"| MySQL
    Server -->|"PG protocol : 5432/TCP<br/>Optional SSL (sslmode)<br/>Username/Password"| PostgreSQL
    Server -->|"In-process<br/>No network"| SQLite

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef devonly fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class DSP,KFUI client
    class Server service
    class MySQL,PostgreSQL database
    class SQLite devonly
