graph LR
    RHAII["RHAII Cluster<br/>Validation"]

    %% External Dependencies (Required)
    RHAII -->|"node discovery, Job mgmt<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v1.35+"]
    RHAII -->|"GPU checks via nvidia-smi<br/>privileged exec"| NvidiaDriver["NVIDIA GPU Driver<br/>>= 535.0 (OCP)"]
    RHAII -->|"GPU checks via amd-smi<br/>privileged exec"| AMDDriver["AMD GPU Driver"]
    RHAII -->|"TCP bandwidth testing<br/>5201/TCP"| iperf3["iperf3<br/>(tools image)"]
    RHAII -->|"RDMA bandwidth &amp; connectivity<br/>18515/TCP + dynamic"| perftest["perftest<br/>ib_write_bw, ibv_rc_pingpong<br/>v25.10.0"]
    RHAII -->|"GPUDirect RDMA"| CUDA["CUDA Runtime<br/>libcudart 13.0"]
    RHAII -->|"RDMA device access"| IBDrivers["InfiniBand/RoCE<br/>Device Drivers"]

    %% Internal Platform Dependencies (CRD Checks)
    RHAII -.->|"CRD presence check"| GatewayAPI["Gateway API CRDs<br/>gateways, httproutes"]
    RHAII -.->|"CRD presence check"| InferencePool["InferencePool CRDs<br/>inference.networking"]
    RHAII -.->|"CRD presence check"| LWSCRD["LeaderWorkerSet CRDs<br/>leaderworkerset"]
    RHAII -.->|"CRD presence check"| CertMgrCRD["cert-manager CRDs<br/>certificates"]

    %% Internal Platform Dependencies (Health Checks)
    RHAII -.->|"operator health check<br/>pod listing"| CertMgr["cert-manager Operator<br/>cert-manager NS"]
    RHAII -.->|"operator health check<br/>pod listing"| Istio["Istio Service Mesh<br/>istio-system NS"]
    RHAII -.->|"operator health check<br/>pod listing"| LWSOperator["LeaderWorkerSet Operator<br/>openshift-lws-operator NS"]

    %% Internal Platform Dependencies (Node Detection)
    RHAII -.->|"GPU node discovery<br/>nvidia.com/gpu.present label"| NvidiaGPUOp["NVIDIA GPU Operator"]
    RHAII -.->|"GPU node discovery<br/>amd.com/gpu.present label"| AMDGPUOp["AMD GPU Operator"]

    %% Platform Detection
    RHAII -.->|"OpenShift SCC<br/>privileged access"| OCP["OpenShift SCC System"]

