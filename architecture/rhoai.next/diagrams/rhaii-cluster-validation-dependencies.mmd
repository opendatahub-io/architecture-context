graph LR
    RhaiiVal["RHAII Cluster<br/>Validation<br/>(kubectl plugin)"]

    %% Required External Dependencies
    RhaiiVal -->|"Job/Pod orchestration<br/>HTTPS/6443"| K8s["Kubernetes 1.29+"]

    %% Optional External Dependencies (GPU)
    RhaiiVal -->|"GPU node discovery<br/>nvidia.com/gpu.present label"| NVIDIAOp["NVIDIA GPU Operator"]
    RhaiiVal -->|"GPU node discovery<br/>amd.com/gpu.present label"| AMDOp["AMD GPU Operator"]
    RhaiiVal -->|"GPU lib injection<br/>nvidia-smi, libcuda.so.1"| NVIDIAToolkit["NVIDIA Container<br/>Toolkit"]

    %% CRD Dependencies (checked by deps subcommand)
    RhaiiVal -.->|"CRD existence check"| GatewayAPI["Gateway API CRDs"]
    RhaiiVal -.->|"CRD existence check"| InferencePool["InferencePool CRD<br/>(Gateway API Inference<br/>Extension)"]
    RhaiiVal -.->|"CRD + operator health"| LWS["LeaderWorkerSet<br/>CRD + Operator"]
    RhaiiVal -.->|"CRD + operator health"| CertManager["cert-manager<br/>CRD + Operator"]
    RhaiiVal -.->|"operator health check"| Istio["Istio"]

    %% Host OS Access
    RhaiiVal -->|"chroot /host<br/>privileged + hostPID"| HostOS["Host OS<br/>sysfs / procfs /<br/>device files"]

    %% Platform Support
    RhaiiVal ===|"auto-detects"| OCP["OpenShift (OCP)<br/>+ SCC support"]
    RhaiiVal ===|"auto-detects"| AKS["Azure (AKS)"]
    RhaiiVal ===|"auto-detects"| EKS["AWS (EKS)"]
    RhaiiVal ===|"auto-detects"| CoreWeave["CoreWeave"]

    %% No Internal ODH Dependencies (standalone tool)

    %% Styling
    style RhaiiVal fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style NVIDIAOp fill:#76b900,stroke:#333,color:#fff
    style AMDOp fill:#ed1c24,stroke:#333,color:#fff
    style NVIDIAToolkit fill:#76b900,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style InferencePool fill:#999,stroke:#333,color:#fff
    style LWS fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style Istio fill:#466bb0,stroke:#333,color:#fff
    style HostOS fill:#f5a623,stroke:#333
    style OCP fill:#ee0000,stroke:#333,color:#fff
    style AKS fill:#0078d4,stroke:#333,color:#fff
    style EKS fill:#ff9900,stroke:#333,color:#fff
    style CoreWeave fill:#6366f1,stroke:#333,color:#fff
