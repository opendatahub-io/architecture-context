graph TB
    subgraph External["INBOUND (ModelMesh Orchestration)"]
        ModelMesh["ModelMesh Controller<br/>gRPC Client"]
    end

    subgraph PodBoundary["POD BOUNDARY (Trust Zone: Pod-local, Plaintext)"]
        direction TB

        subgraph PullerZone["Puller Sidecar"]
            Puller["model-serving-puller<br/>8084/TCP gRPC<br/>Plaintext, No Auth<br/>SA: inherited from pod"]
            Pullman["pullman Storage Library<br/>Client cache: 1hr TTL"]
        end

        subgraph AdapterZone["Runtime Adapter Sidecar (one active per pod)"]
            TritonAdapt["triton-adapter<br/>8085/TCP gRPC<br/>Plaintext, No Auth"]
            MLServerAdapt["mlserver-adapter<br/>8085/TCP gRPC<br/>Plaintext, No Auth"]
            OVMSAdapt["ovms-adapter<br/>8085/TCP gRPC<br/>Plaintext, No Auth"]
            TSAdapt["torchserve-adapter<br/>8085/TCP gRPC<br/>Plaintext, No Auth"]
        end

        subgraph RuntimeZone["Model Runtime Container"]
            Triton["NVIDIA Triton<br/>8001/TCP gRPC"]
            MLServer["Seldon MLServer<br/>8001/TCP gRPC"]
            OVMS["OpenVINO MS<br/>8001/TCP HTTP REST"]
            TorchServe["TorchServe<br/>7071/TCP gRPC mgmt<br/>7070/TCP gRPC infer"]
        end

        subgraph Volumes["Mounted Volumes"]
            Models["/models<br/>(emptyDir)"]
            StorageConfig["/storage-config<br/>(Secret: storage-config)"]
        end
    end

    subgraph EgressZone["EXTERNAL SERVICES (Egress)"]
        S3["S3 / IBM COS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Static credentials<br/>(access_key_id/secret_access_key)"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service account JSON"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service principal<br/>or connection string"]
        HTTPStore["HTTP(S) Endpoints<br/>Configurable port<br/>Optional TLS + mTLS<br/>Auth: Custom headers<br/>+ optional client cert"]
    end

    %% Inbound flows
    ModelMesh -->|"gRPC/8084<br/>Plaintext<br/>No Auth<br/>Pod-local"| Puller

    %% Puller to adapters
    Puller -->|"gRPC/8085<br/>Plaintext<br/>Pod-local"| TritonAdapt
    Puller -->|"gRPC/8085<br/>Plaintext<br/>Pod-local"| MLServerAdapt
    Puller -->|"gRPC/8085<br/>Plaintext<br/>Pod-local"| OVMSAdapt
    Puller -->|"gRPC/8085<br/>Plaintext<br/>Pod-local"| TSAdapt

    %% Adapter to runtime
    TritonAdapt -->|"gRPC/8001<br/>Plaintext"| Triton
    MLServerAdapt -->|"gRPC/8001<br/>Plaintext"| MLServer
    OVMSAdapt -->|"HTTP/8001<br/>Plaintext"| OVMS
    TSAdapt -->|"gRPC/7071+7070<br/>Plaintext"| TorchServe

    %% Storage egress
    Puller --> Pullman
    Pullman -->|"HTTPS/443<br/>TLS 1.2+<br/>Static creds"| S3
    Pullman -->|"HTTPS/443<br/>TLS 1.2+<br/>SA JSON"| GCS
    Pullman -->|"HTTPS/443<br/>TLS 1.2+<br/>SP creds"| Azure
    Pullman -->|"HTTP(S)<br/>Optional TLS+mTLS<br/>Custom headers"| HTTPStore

    %% Volume access
    Pullman -->|"write"| Models
    Pullman -->|"read creds"| StorageConfig

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef podlocal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef puller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef adapter fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef volume fill:#f8e71c,stroke:#333,stroke-width:1px

    class ModelMesh external
    class Puller,Pullman puller
    class TritonAdapt,MLServerAdapt,OVMSAdapt,TSAdapt adapter
    class Triton,MLServer,OVMS,TorchServe runtime
    class S3,GCS,Azure,HTTPStore egress
    class Models,StorageConfig volume
