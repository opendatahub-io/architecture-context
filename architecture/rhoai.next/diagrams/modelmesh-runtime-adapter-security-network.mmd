graph TB
    subgraph External["EXTERNAL SERVICES (Cloud Provider Networks)"]
        S3["S3 / IBM COS<br/>s3.amazonaws.com<br/>TLS 1.2+<br/>Static Credentials"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>TLS 1.2+<br/>Service Account"]
        Azure["Azure Blob Storage<br/>{account}.blob.core.windows.net<br/>TLS 1.2+<br/>Service Principal"]
        HTTPStore["HTTP/HTTPS Server<br/>Custom URL<br/>TLS 1.2+ / mTLS<br/>Custom Headers or Client Certs"]
    end

    subgraph Inbound["INBOUND (Cluster-Internal)"]
        ModelMesh["ModelMesh<br/>(modelmesh-serving pod)<br/>gRPC client"]
    end

    subgraph Pod["POD BOUNDARY (ModelMesh Serving Pod)<br/>All inter-container: plaintext over localhost"]
        direction TB

        subgraph SidecarContainer["Sidecar: modelmesh-runtime-adapter"]
            direction TB
            Puller["model-serving-puller<br/>gRPC :8084/TCP<br/>plaintext<br/>No auth"]
            Adapter["runtime-adapter<br/>gRPC :8085/TCP<br/>plaintext<br/>No auth"]
        end

        subgraph RuntimeContainer["Runtime Container (one of)"]
            Triton["Triton<br/>gRPC :8001"]
            OVMS["OVMS<br/>HTTP :8001"]
            MLServer["MLServer<br/>gRPC :8001"]
            TorchServe["TorchServe<br/>gRPC :7071 mgmt<br/>gRPC :7070 infer"]
        end

        Secret["/storage-config<br/>Mounted Secret<br/>Cloud credentials"]
    end

    %% Inbound flows
    ModelMesh -->|"gRPC/8084<br/>plaintext<br/>No auth"| Puller
    ModelMesh -->|"gRPC/8085<br/>plaintext<br/>No auth"| Adapter

    %% Pod-internal flows
    Puller -->|"gRPC/8085<br/>plaintext<br/>localhost"| Adapter
    Adapter -->|"gRPC/8001<br/>plaintext<br/>localhost"| Triton
    Adapter -->|"HTTP/8001<br/>plaintext<br/>localhost"| OVMS
    Adapter -->|"gRPC/8001<br/>plaintext<br/>localhost"| MLServer
    Adapter -->|"gRPC/7071+7070<br/>plaintext<br/>localhost"| TorchServe

    Secret -.->|"filesystem<br/>mount"| Puller
    Secret -.->|"filesystem<br/>mount"| Adapter

    %% Egress flows
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Static Credentials"| S3
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Account"| GCS
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Principal"| Azure
    Puller -->|"HTTPS/443<br/>TLS 1.2+ / mTLS<br/>Custom Auth"| HTTPStore

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef inbound fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#b3d9ff,stroke:#4a90e2,stroke-width:2px
    classDef runtime fill:#e6ffe6,stroke:#82b366,stroke-width:2px
    classDef secret fill:#f5f5f5,stroke:#999,stroke-width:1px,stroke-dasharray:5

    class S3,GCS,Azure,HTTPStore external
    class ModelMesh inbound
    class Puller,Adapter sidecar
    class Triton,OVMS,MLServer,TorchServe runtime
    class Secret secret
