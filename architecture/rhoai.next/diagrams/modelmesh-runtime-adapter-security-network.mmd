graph TB
    subgraph PodBoundary["POD BOUNDARY (ModelMesh Serving Pod)<br/>All internal traffic: plaintext localhost"]
        direction TB

        subgraph PullerZone["model-serving-puller"]
            Puller["model-serving-puller<br/>8084/TCP gRPC<br/>Plaintext (localhost)<br/>No Auth<br/><br/>Strips credentials before<br/>forwarding to adapter"]
            PullmanLib["pullman Library<br/>Storage abstraction<br/>FNV-64a cache keys<br/>(no raw creds in cache)"]
            Puller --- PullmanLib
        end

        subgraph AdapterZone["Runtime Adapter (one active per pod)"]
            TritonA["triton-adapter<br/>8085/TCP gRPC<br/>→ Triton 8001/TCP gRPC"]
            MLServerA["mlserver-adapter<br/>8085/TCP gRPC<br/>→ MLServer 8001/TCP gRPC"]
            OVMSA["ovms-adapter<br/>8085/TCP gRPC<br/>→ OVMS 8001/TCP HTTP"]
            TorchServeA["torchserve-adapter<br/>8085/TCP gRPC<br/>→ TorchServe 7071/TCP gRPC"]
        end

        subgraph RuntimeZone["Inference Runtime (one active per pod)"]
            TritonR["NVIDIA Triton<br/>8001/TCP gRPC"]
            MLServerR["SeldonIO MLServer<br/>8001/TCP gRPC"]
            OVMSR["OpenVINO Model Server<br/>8001/TCP HTTP REST"]
            TorchServeR["TorchServe<br/>7071/TCP mgmt gRPC<br/>7070/TCP infer gRPC"]
        end

        subgraph Volumes["Volume Mounts"]
            StorageConfig["/storage-config<br/>K8s Secret<br/>Storage credentials"]
            Models["/models<br/>EmptyDir<br/>Downloaded artifacts"]
            PVCMount["/pvc_mounts<br/>PVC (optional)"]
        end

        Puller -->|"gRPC/8085<br/>Plaintext localhost<br/>No Auth<br/>(credentials stripped)"| TritonA
        Puller -->|"gRPC/8085<br/>Plaintext localhost<br/>No Auth"| MLServerA
        Puller -->|"gRPC/8085<br/>Plaintext localhost<br/>No Auth"| OVMSA
        Puller -->|"gRPC/8085<br/>Plaintext localhost<br/>No Auth"| TorchServeA

        TritonA -->|"gRPC/8001<br/>Plaintext localhost"| TritonR
        MLServerA -->|"gRPC/8001<br/>Plaintext localhost"| MLServerR
        OVMSA -->|"HTTP/8001<br/>Plaintext localhost"| OVMSR
        TorchServeA -->|"gRPC/7071<br/>Plaintext localhost"| TorchServeR

        StorageConfig -.->|"credentials"| PullmanLib
    end

    subgraph Inbound["INBOUND (Pod-Internal)"]
        ModelMesh["ModelMesh Controller<br/>(modelmesh-serving)<br/>Same pod"]
    end

    subgraph Egress["EGRESS (TLS-Encrypted)"]
        S3["AWS S3 / IBM COS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Access Key ID<br/>+ Secret Access Key"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service Account<br/>(JSON credentials)"]
        AzureBlob["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Service Principal<br/>or Connection String"]
        HTTPEndpoint["HTTP/HTTPS Endpoints<br/>Port: configurable<br/>Encryption: Optional TLS<br/>Auth: Optional headers/mTLS"]
    end

    ModelMesh -->|"gRPC/8084<br/>Plaintext localhost<br/>No Auth"| Puller

    PullmanLib -->|"HTTPS/443<br/>TLS 1.2+<br/>Access Key + Secret"| S3
    PullmanLib -->|"HTTPS/443<br/>TLS 1.2+<br/>SA JSON credentials"| GCS
    PullmanLib -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Principal"| AzureBlob
    PullmanLib -->|"HTTP(S)<br/>Optional TLS<br/>Optional headers"| HTTPEndpoint

    %% Styling
    classDef podinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inbound fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Puller,PullmanLib,TritonA,MLServerA,OVMSA,TorchServeA,TritonR,MLServerR,OVMSR,TorchServeR podinternal
    class ModelMesh inbound
    class S3,GCS,AzureBlob,HTTPEndpoint egress
    class StorageConfig secrets
    class Models,PVCMount storage
