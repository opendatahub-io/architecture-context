graph TB
    subgraph PodBoundary["MODELMESH SERVING POD (Trust Boundary)"]
        direction TB

        subgraph MMContainer["ModelMesh Container"]
            ModelMesh["ModelMesh Framework<br/>Orchestrates model placement"]
        end

        subgraph SidecarContainer["Sidecar: modelmesh-runtime-adapter"]
            direction TB
            Puller["model-serving-puller<br/>8084/TCP gRPC<br/>Plaintext / No Auth<br/>SecureJoin path protection"]
            Adapter["Runtime Adapter<br/>8085/TCP gRPC<br/>Plaintext / No Auth<br/>SecureJoin path protection"]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            direction TB
            TritonRT["Triton: 8001/TCP gRPC"]
            OVMSRT["OVMS: 8001/TCP HTTP"]
            MLServerRT["MLServer: 8001/TCP gRPC"]
            TorchServeRT["TorchServe: 7071/TCP gRPC mgmt<br/>7070/TCP gRPC inference"]
        end

        subgraph MountedSecrets["Mounted Volumes"]
            StorageConfig["/storage-config<br/>Secret: storage-config (Opaque)<br/>S3 keys, Azure SP, GCS SA,<br/>HTTP headers, mTLS certs, CA bundles"]
        end
    end

    subgraph ExternalStorage["EXTERNAL SERVICES (Untrusted Network)"]
        S3["S3 / MinIO / IBM COS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM (access_key_id,<br/>secret_access_key)"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Principal (client_id,<br/>client_secret, tenant_id)"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Service Account JSON<br/>(private_key, client_email)"]
        HTTPStore["HTTP/HTTPS Endpoints<br/>Configurable port<br/>Optional TLS + mTLS<br/>Custom headers,<br/>client certificates"]
    end

    subgraph LocalStorage["LOCAL STORAGE"]
        PVC["PVC Volumes<br/>Filesystem symlinks<br/>No network traffic"]
    end

    %% Pod-internal flows (plaintext localhost)
    ModelMesh -->|"gRPC/8084<br/>Plaintext localhost<br/>No Auth"| Puller
    Puller -->|"gRPC/8085<br/>Plaintext localhost<br/>No Auth"| Adapter
    Adapter -->|"gRPC/8001 or HTTP/8001<br/>Plaintext localhost<br/>No Auth"| TritonRT
    Adapter -->|"HTTP/8001<br/>Plaintext localhost<br/>No Auth"| OVMSRT
    Adapter -->|"gRPC/8001<br/>Plaintext localhost<br/>No Auth"| MLServerRT
    Adapter -->|"gRPC/7071+7070<br/>Plaintext localhost<br/>No Auth"| TorchServeRT

    StorageConfig -.->|"credential mount"| Puller

    %% Egress flows (encrypted)
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Principal"| Azure
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Account"| GCS
    Puller -->|"HTTP(S)/configurable<br/>Optional TLS + mTLS<br/>Custom headers + certs"| HTTPStore
    Puller -->|"Filesystem<br/>Symlinks"| PVC

    %% Styling
    classDef podInternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef runtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secret fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef local fill:#e8e8e8,stroke:#666,stroke-width:1px

    class ModelMesh podInternal
    class Puller,Adapter sidecar
    class TritonRT,OVMSRT,MLServerRT,TorchServeRT runtime
    class StorageConfig secret
    class S3,Azure,GCS,HTTPStore external
    class PVC local
