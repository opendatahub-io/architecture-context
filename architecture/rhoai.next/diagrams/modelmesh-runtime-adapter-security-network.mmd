graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL"]
        ModelMesh["ModelMesh Controller<br/>(modelmesh-serving)"]
    end

    subgraph PodBoundary["POD BOUNDARY (ModelMesh Serving Pod)"]
        direction TB

        subgraph SidecarContainer["SIDECAR: modelmesh-runtime-adapter"]
            direction TB
            Puller["model-serving-puller<br/>gRPC :8084<br/>mmesh.ModelRuntime<br/>plaintext | no auth<br/>FIPS: strictfipsruntime"]

            subgraph AdapterGroup["Runtime Adapter (one active)"]
                Adapter["triton / mlserver / ovms / torchserve<br/>gRPC :8085<br/>mmesh.ModelRuntime<br/>plaintext | no auth"]
            end
        end

        subgraph RuntimeContainer["RUNTIME CONTAINER (one active)"]
            direction LR
            Triton["Triton<br/>gRPC :8001"]
            MLServer["MLServer<br/>gRPC :8001"]
            OVMS["OVMS<br/>HTTP :8001"]
            TorchServe["TorchServe<br/>gRPC :7071 mgmt<br/>gRPC :7070 infer"]
        end

        subgraph Volumes["VOLUME MOUNTS"]
            StorageConfig["/storage-config<br/>K8s Secret (Opaque)<br/>Cloud credentials"]
            ModelDir["/models<br/>EmptyDir/PVC<br/>Model artifacts"]
            PVCMounts["/pvc_mounts<br/>PVC volumes<br/>Pre-provisioned models"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Untrusted)"]
        S3["S3 / IBM COS / MinIO<br/>HTTPS :443<br/>TLS 1.2+<br/>AWS IAM credentials"]
        GCS["Google Cloud Storage<br/>HTTPS :443<br/>TLS 1.2+<br/>GCP SA JWT"]
        Azure["Azure Blob Storage<br/>HTTPS :443<br/>TLS 1.2+<br/>Service Principal"]
        HTTPEndpoint["HTTP/HTTPS Endpoints<br/>configurable port<br/>Optional TLS + mTLS<br/>Custom Headers/Certs"]
    end

    %% Ingress flows
    ModelMesh -->|"gRPC :8084<br/>plaintext<br/>no auth<br/>LoadModel/UnloadModel/<br/>RuntimeStatus"| Puller

    %% Intra-sidecar flow
    Puller -->|"gRPC :8085<br/>plaintext<br/>no auth<br/>localhost"| Adapter

    %% Adapter to Runtime flows (all localhost, plaintext)
    Adapter -->|"gRPC :8001 plaintext<br/>RepositoryModelLoad/Unload"| Triton
    Adapter -->|"gRPC :8001 plaintext<br/>RepositoryModelLoad/Unload"| MLServer
    Adapter -->|"HTTP :8001 plaintext<br/>POST /v1/config/reload"| OVMS
    Adapter -->|"gRPC :7071 plaintext<br/>RegisterModel/Unregister"| TorchServe

    %% Egress flows (to cloud storage)
    Puller -->|"HTTPS :443<br/>TLS 1.2+ (FIPS)<br/>AWS IAM"| S3
    Puller -->|"HTTPS :443<br/>TLS 1.2+ (FIPS)<br/>GCP SA JWT"| GCS
    Puller -->|"HTTPS :443<br/>TLS 1.2+ (FIPS)<br/>Service Principal"| Azure
    Puller -->|"HTTP/HTTPS<br/>Optional TLS+mTLS<br/>Custom Headers"| HTTPEndpoint

    %% Volume mounts
    StorageConfig -.->|"credentials"| Puller
    ModelDir -.->|"model files"| Puller
    ModelDir -.->|"adapted layout"| Adapter
    ModelDir -.->|"model data"| Triton
    ModelDir -.->|"model data"| MLServer
    ModelDir -.->|"model data"| OVMS
    ModelDir -.->|"model data"| TorchServe
    PVCMounts -.->|"symlink"| Puller

    %% Styling
    classDef clusterInternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef podBoundary fill:#e8f4f8,stroke:#4a90e2,stroke-width:3px
    classDef sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef externalService fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef volume fill:#ffe6cc,stroke:#d79b00,stroke-width:1px

    class ModelMesh clusterInternal
    class Puller,Adapter sidecar
    class Triton,MLServer,OVMS,TorchServe runtime
    class S3,GCS,Azure,HTTPEndpoint externalService
    class StorageConfig,ModelDir,PVCMounts volume
