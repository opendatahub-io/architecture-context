graph TB
    subgraph External["EXTERNAL CLOUD SERVICES (Untrusted)"]
        S3["S3 / IBM COS<br/>*.s3.amazonaws.com<br/>TLS 1.2+<br/>Static Credentials"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>TLS 1.2+<br/>Service Account"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>TLS 1.2+<br/>Service Principal"]
        HTTP["HTTP/HTTPS Server<br/>Configurable Endpoint<br/>TLS 1.2+ (optional mTLS)<br/>Custom Headers / Client Cert"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL"]
        ModelMesh["ModelMesh<br/>(gRPC Client)"]
        MMController["ModelMesh Controller<br/>(ConfigMap reference only)"]
    end

    subgraph PodBoundary["MODEL SERVER POD (Trusted Pod-Internal, plaintext)"]
        direction TB

        subgraph PullerContainer["Sidecar: model-serving-puller"]
            Puller["model-serving-puller<br/>:8084/TCP gRPC<br/>plaintext, No Auth<br/>pullman storage framework"]
        end

        subgraph AdapterContainer["Sidecar: Runtime Adapter (one of four)"]
            Adapter["Runtime Adapter<br/>:8085/TCP gRPC<br/>plaintext, No Auth<br/>Optional embedded puller"]
        end

        subgraph RuntimeContainer["Container: Model Runtime (one of four)"]
            Triton["Triton<br/>:8001/TCP gRPC"]
            OVMS["OVMS<br/>:8001/TCP HTTP"]
            MLServer["MLServer<br/>:8001/TCP gRPC"]
            TorchServeMgmt["TorchServe Mgmt<br/>:7071/TCP gRPC"]
            TorchServeInfer["TorchServe Infer<br/>:7070/TCP gRPC"]
        end

        Secret["storage-config Secret<br/>Mounted: /storage-config<br/>Cloud credentials (S3/GCS/Azure/HTTP)"]
    end

    %% Cluster-internal flows
    ModelMesh -->|"gRPC :8084<br/>plaintext<br/>No Auth"| Puller
    ModelMesh -->|"gRPC :8085<br/>plaintext<br/>No Auth"| Adapter
    MMController -.->|"ConfigMap ref<br/>storageHelperImage"| PodBoundary

    %% Pod-internal flows
    Puller -->|"gRPC :8085<br/>plaintext<br/>No Auth"| Adapter
    Adapter -->|"gRPC :8001<br/>plaintext"| Triton
    Adapter -->|"HTTP :8001<br/>plaintext"| OVMS
    Adapter -->|"gRPC :8001<br/>plaintext"| MLServer
    Adapter -->|"gRPC :7071<br/>plaintext"| TorchServeMgmt
    Adapter -->|"gRPC :7070<br/>plaintext"| TorchServeInfer
    Secret -.->|"credentials"| Puller

    %% External egress
    Puller -->|"HTTPS :443<br/>TLS 1.2+<br/>Access Key + Secret"| S3
    Puller -->|"HTTPS :443<br/>TLS 1.2+<br/>SA private_key"| GCS
    Puller -->|"HTTPS :443<br/>TLS 1.2+<br/>Client ID + Secret"| Azure
    Puller -->|"HTTP/S :80/443<br/>TLS 1.2+ / mTLS<br/>Custom Headers"| HTTP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef runtime fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class S3,GCS,Azure,HTTP external
    class ModelMesh,MMController cluster
    class Puller,Adapter pod
    class Secret secret
    class Triton,OVMS,MLServer,TorchServeMgmt,TorchServeInfer runtime
