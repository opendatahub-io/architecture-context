    style Introspect fill:#e67e22,color:#fff
    style Claims fill:#f39c12,color:#fff
    style Roles fill:#f1c40f,stroke:#333
    style Teams fill:#f1c40f,stroke:#333
    style Projects fill:#f1c40f,stroke:#333
    style Namespaces fill:#f1c40f,stroke:#333
    style QuotaMW fill:#9b59b6,color:#fff
    style AuthQuota fill:#8e44ad,color:#fff
    style AnonQuota fill:#8e44ad,color:#fff
    style PolicyEngine fill:#2c3e50,color:#fff
    style Forbid fill:#e74c3c,color:#fff
    style Permit fill:#27ae60,color:#fff
    style Default fill:#7f8c8d,color:#fff
