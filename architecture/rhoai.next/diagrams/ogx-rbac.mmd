graph TD
    subgraph ClientRequest["Client Request"]
        Client["Client<br/>Authorization: Bearer {JWT}"]
    end

    subgraph AuthenticationLayer["Authentication Layer (ASGI Middleware)"]
        direction TB
        ExtractToken["Extract Bearer Token<br/>from Authorization header"]
        ValidateToken["Validate Token"]

        subgraph AuthProviders["Auth Provider Options"]
            OAuth2JWKS["OAuth2 JWKS<br/>Fetch public keys from<br/>/.well-known/jwks.json<br/>Validate JWT signature"]
            OAuth2Introspect["OAuth2 Introspection<br/>POST to introspection endpoint<br/>RFC 7662<br/>Basic Auth (client_id/secret)"]
            CustomAuth["Custom Endpoint<br/>Forward token to<br/>external validation URL"]
        end

        ExtractClaims["Extract Claims & Attributes<br/>sub, username, roles,<br/>teams, projects, namespaces"]
    end

    subgraph QuotaLayer["Rate Limiting Layer (Optional)"]
        QuotaCheck["QuotaMiddleware<br/>Per-client rate limits"]
        AuthLimits["Authenticated Client Limits"]
        AnonLimits["Anonymous Client Limits"]
    end

    subgraph AccessControlLayer["Access Control Layer (ABAC)"]
        direction TB
        ABACEngine["ABAC Engine<br/>Cedar-like Policy Language"]

        subgraph PolicyEvaluation["Policy Evaluation"]
            direction LR
            PermitRules["Permit Rules<br/>permit(principal, action, resource)<br/>when { conditions }"]
            ForbidRules["Forbid Rules<br/>forbid(principal, action, resource)<br/>unless { conditions }"]
        end

        subgraph Actions["Actions"]
            Create["create"]
            Read["read"]
            Update["update"]
            Delete["delete"]
        end

        subgraph ResourceTypes["Resource Types"]
            ModelRes["model::*<br/>model::my-llama-model"]
            VectorDBRes["vector_db::*<br/>vector_db::my-rag-db"]
            ShieldRes["shield::*"]
            DatasetRes["dataset::*"]
            BenchmarkRes["benchmark::*"]
            AgentRes["agent::*"]
            ToolGroupRes["toolgroup::*"]
        end

        subgraph Conditions["Conditions"]
            UserAttr["user with {value} in {attr}<br/>(e.g., user with 'admin' in roles)"]
            OwnerCheck["user is owner<br/>(resource owner match)"]
            OwnerAttr["user in owners {attr}<br/>(e.g., user in owners teams)"]
        end

        DefaultPolicy["Default Policy<br/>Owners have full access<br/>(backward compatibility)"]
    end

    subgraph PublicBypass["Public Endpoints (bypass all auth)"]
        HealthEP["/health"]
        VersionEP["/version"]
        DocsEP["/docs"]
        OpenAPIEP["/openapi.json"]
    end

    subgraph ProtectedAPIs["Protected API Endpoints"]
        InferenceEP["/v1/inference/*"]
        AgentsEP["/v1/agents/*"]
        SafetyEP["/v1/safety/*"]
        VectorIOEP["/v1/vector-io/*"]
        ModelsEP["/v1/models"]
        EvalEP["/v1/eval/*"]
        ToolsEP["/v1/tool-runtime/*"]
        OtherAPIs["+ 10 more API groups"]
    end

    %% Flow
    Client -->|"1. HTTP Request"| ExtractToken
    ExtractToken -->|"2. Token"| ValidateToken
    ValidateToken --> OAuth2JWKS
    ValidateToken --> OAuth2Introspect
    ValidateToken --> CustomAuth
    OAuth2JWKS -->|validated| ExtractClaims
    OAuth2Introspect -->|validated| ExtractClaims
    CustomAuth -->|validated| ExtractClaims

    ExtractClaims -->|"3. User context"| QuotaCheck
    QuotaCheck --> AuthLimits
    QuotaCheck --> AnonLimits

    QuotaCheck -->|"4. Rate limit OK"| ABACEngine
    ABACEngine --> PermitRules
    ABACEngine --> ForbidRules
    PermitRules --> Actions
    ForbidRules --> Actions
    Actions --> ResourceTypes
    PermitRules --> Conditions
    ForbidRules --> Conditions
    ABACEngine --> DefaultPolicy

    ABACEngine -->|"5. Authorized"| ProtectedAPIs

    Client -.->|"Direct (no auth)"| PublicBypass

    %% Styling
    style Client fill:#ecf0f1,stroke:#333
    style ExtractToken fill:#f39c12,stroke:#333,color:#fff
    style ValidateToken fill:#f39c12,stroke:#333,color:#fff
    style OAuth2JWKS fill:#e74c3c,stroke:#333,color:#fff
    style OAuth2Introspect fill:#e74c3c,stroke:#333,color:#fff
    style CustomAuth fill:#e74c3c,stroke:#333,color:#fff
    style ExtractClaims fill:#f39c12,stroke:#333,color:#fff
    style QuotaCheck fill:#9b59b6,stroke:#333,color:#fff
    style ABACEngine fill:#e74c3c,stroke:#333,color:#fff
    style PermitRules fill:#27ae60,stroke:#333,color:#fff
    style ForbidRules fill:#c0392b,stroke:#333,color:#fff
    style DefaultPolicy fill:#95a5a6,stroke:#333,color:#fff
    style Create fill:#3498db,stroke:#333,color:#fff
    style Read fill:#3498db,stroke:#333,color:#fff
    style Update fill:#3498db,stroke:#333,color:#fff
    style Delete fill:#3498db,stroke:#333,color:#fff
    style ModelRes fill:#7ed321,stroke:#333
    style VectorDBRes fill:#7ed321,stroke:#333
    style ShieldRes fill:#7ed321,stroke:#333
