graph TD
    subgraph ClientLayer["Client Request"]
        Client["API Client<br/>Bearer Token"]
    end

    subgraph AuthLayer["Authentication Layer"]
        AuthMW["AuthenticationMiddleware<br/>(ASGI Middleware)"]

        subgraph AuthProviders["Auth Providers (pluggable)"]
            OAuth2["OAuth2TokenAuthProvider"]
            CustomProv["CustomAuthProvider"]
        end

        subgraph TokenValidation["Token Validation Methods"]
            JWKS["JWKS Validation<br/>(Public key verification)"]
            Introspect["Token Introspection<br/>(RFC 7662)<br/>Client credentials auth"]
        end
    end

    subgraph ClaimsMapping["Claims → Attributes Mapping"]
        Claims["JWT Claims<br/>(configurable mapping)"]

        subgraph Attributes["User Attributes"]
            Roles["roles"]
            Teams["teams"]
            Projects["projects"]
            Namespaces["namespaces"]
        end
    end

    subgraph RateLimiting["Rate Limiting"]
        QuotaMW["QuotaMiddleware"]
        AuthQuota["Authenticated Quota<br/>(per-client limits)"]
        AnonQuota["Anonymous Quota<br/>(separate limits)"]
    end

    subgraph ABACLayer["Authorization — Cedar-like ABAC"]
        PolicyEngine["Policy Engine"]

        subgraph Policies["Policy Rules"]
            Forbid["Forbid Rules<br/>(evaluated FIRST)"]
            Permit["Permit Rules<br/>(evaluated second)"]
            Default["Default: DENY<br/>(if no rule matches)"]
        end

        subgraph Conditions["Rule Conditions"]
            When["when<br/>(attribute match)"]
            Unless["unless<br/>(attribute exclusion)"]
            Owner["owner-based<br/>(resource ownership)"]
            Wildcard["wildcard<br/>(resource pattern)"]
        end
    end

    subgraph Resources["Protected API Resources"]
        InferenceRes["Inference APIs<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
        AgentRes["Agent APIs<br/>/v1/agents/*"]
        SafetyRes["Safety APIs<br/>/v1/safety/*"]
        VectorRes["Vector IO APIs<br/>/v1/vector-io/*<br/>/v1/vector-dbs/*"]
        EvalRes["Eval APIs<br/>/v1/eval/*<br/>/v1/scoring/*"]
        ToolRes["Tool APIs<br/>/v1/tools/*<br/>/v1/tool-runtime/*"]
        ModelRes["Model/Shield/Dataset<br/>Registration APIs"]
        TelemetryRes["Telemetry APIs<br/>/v1/telemetry/*"]
    end

    subgraph Unauthenticated["Unauthenticated Endpoints (No Auth)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Routes["/v1/inspect/routes"]
        Docs["/docs, /redoc<br/>/openapi.json"]
    end

    %% Flow
    Client -->|"Authorization: Bearer <token>"| AuthMW
    AuthMW -->|"OAuth2 mode"| OAuth2
    AuthMW -->|"Custom mode"| CustomProv
    OAuth2 -->|"JWKS discovery"| JWKS
    OAuth2 -->|"introspection"| Introspect
    CustomProv -->|"external endpoint"| AuthMW

    AuthMW -->|"extract claims"| Claims
    Claims -->|"map to"| Roles
    Claims -->|"map to"| Teams
    Claims -->|"map to"| Projects
    Claims -->|"map to"| Namespaces

    AuthMW -->|"rate check"| QuotaMW
    QuotaMW -->|"authenticated"| AuthQuota
    QuotaMW -->|"anonymous"| AnonQuota

    QuotaMW -->|"user attributes"| PolicyEngine
    PolicyEngine -->|"1st"| Forbid
    PolicyEngine -->|"2nd"| Permit
    PolicyEngine -->|"fallback"| Default

    Forbid -->|"uses"| When
    Forbid -->|"uses"| Unless
    Permit -->|"uses"| When
    Permit -->|"uses"| Owner
    Permit -->|"uses"| Wildcard

    PolicyEngine -->|"grants access to"| Resources

    Client -.->|"no auth required"| Unauthenticated

