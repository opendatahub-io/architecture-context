graph TB
    subgraph KagentiOperator["Kagenti Operator (kagenti-system)"]
        direction TB
        Manager["kagenti-operator<br/>(manager)<br/>Go Operator"]

        subgraph Controllers["Controllers"]
            direction LR
            ARCtrl["AgentRuntime<br/>Controller"]
            ACCtrl["AgentCard<br/>Controller"]
            ACSCtrl["AgentCardSync<br/>Controller"]
            NPCtrl["NetworkPolicy<br/>Controller"]
            CRCtrl["ClientRegistration<br/>Controller"]
            ABCCtrl["AuthBridgeConfig<br/>Controller"]
            MLCtrl["MLflow<br/>Controller"]
            MLOCtrl["MLflow Operand<br/>Controller"]
            STCtrl["SharedTrust<br/>Controller"]
            TLSCtrl["TLSBridgeCA<br/>Controller"]
            KuadCtrl["Kuadrant<br/>Controller"]
            TekCtrl["TektonConfig<br/>Controller"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP TLS)"]
            direction LR
            MutWH["Mutating Webhook<br/>inject.kagenti.io<br/>Pod CREATE"]
            ValACWH["Validating Webhook<br/>AgentCard"]
            ValARWH["Validating Webhook<br/>AgentRuntime"]
        end

        Manager --> Controllers
        Manager --> Webhooks
    end

    subgraph Sidecars["Injected Sidecars (per-agent Pod)"]
        direction TB
        ABProxy["authbridge-proxy<br/>8000/TCP reverse<br/>8081/TCP forward<br/>8082/TCP transparent"]
        ProxyInit["proxy-init<br/>(init container)<br/>iptables REDIRECT"]
        EnvoyProxy["envoy-proxy<br/>15123/TCP outbound<br/>15124/TCP inbound"]
    end

    subgraph BundleSvc["Bundle Service"]
        BundleService["bundle-service<br/>8080/TCP HTTP<br/>OPA Policy Bundles"]
    end

    %% CRDs
    AgentRuntimeCR["AgentRuntime CR"]
    AgentCardCR["AgentCard CR"]
    AuthzPolicyCR["AuthorizationPolicy CR"]

    %% External interactions
    User["User / kubectl"] -->|creates| AgentRuntimeCR
    AgentRuntimeCR -->|watched by| ARCtrl
    AgentCardCR -->|watched by| ACCtrl
    AuthzPolicyCR -->|watched by| BundleService

    ARCtrl -->|labels, config-hash| Deployment["Target Deployment<br/>/ StatefulSet / Sandbox"]
    ACSCtrl -->|auto-creates| AgentCardCR

    MutWH -->|injects sidecars| Sidecars
    ACCtrl -->|fetches agent card| AgentService["Agent Service<br/>Endpoints"]
    ACCtrl -->|verifies JWS| SPIRETrust["SPIRE Trust Bundle"]
    CRCtrl -->|registers clients| Keycloak["Keycloak"]
    MLCtrl -->|creates experiments| MLflow["MLflow"]
    STCtrl -->|syncs CA certs| CertManager["cert-manager"]
    TLSCtrl -->|provisions CA| CertManager
    NPCtrl -->|creates| NetPol["NetworkPolicies"]
    KuadCtrl -->|manages| Kuadrant["Kuadrant"]
    TekCtrl -->|patches| Tekton["TektonConfig"]

    ABProxy -->|JWT validation| Keycloak
    ABProxy -->|mTLS| SPIRE["SPIRE<br/>CSI Driver"]

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style MutWH fill:#e8744f,stroke:#333,color:#fff
    style ValACWH fill:#e8744f,stroke:#333,color:#fff
    style ValARWH fill:#e8744f,stroke:#333,color:#fff
    style ABProxy fill:#9b59b6,stroke:#333,color:#fff
    style ProxyInit fill:#9b59b6,stroke:#333,color:#fff
    style EnvoyProxy fill:#9b59b6,stroke:#333,color:#fff
    style BundleService fill:#2ecc71,stroke:#333,color:#fff
    style AgentRuntimeCR fill:#f5a623,stroke:#333
    style AgentCardCR fill:#f5a623,stroke:#333
    style AuthzPolicyCR fill:#f5a623,stroke:#333
    style Keycloak fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style SPIRE fill:#e8e8e8,stroke:#333
    style Kuadrant fill:#e8e8e8,stroke:#333
    style Tekton fill:#e8e8e8,stroke:#333
