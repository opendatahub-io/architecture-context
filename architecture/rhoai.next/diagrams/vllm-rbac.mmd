graph TD
    subgraph ComponentNote["vLLM RBAC Model"]
        direction TB
        Note["NOTE: vLLM defines NO RBAC resources.<br/>It is a container image, not an operator.<br/>All RBAC is managed by the platform."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (KServe / RHOAI)"]
        direction TB

        subgraph AuthFlow["Authentication Flow"]
            JWT["Bearer Token (JWT)<br/>Presented by client"]
            KRBP_Auth["kube-rbac-proxy Sidecar<br/>(RHOAI 3.x)"]
            Istio_Auth["Istio AuthorizationPolicy<br/>(RHOAI 2.x)"]

            JWT -->|"validated by"| KRBP_Auth
            JWT -->|"validated by"| Istio_Auth
        end

        subgraph Endpoints["Protected Endpoints"]
            HTTP_EP["/v1/* HTTP API<br/>8000/TCP"]
            GRPC_EP["TGIS gRPC<br/>8033/TCP"]
        end

        KRBP_Auth -->|"proxies to"| HTTP_EP
        KRBP_Auth -->|"proxies to"| GRPC_EP
        Istio_Auth -->|"allows traffic to"| HTTP_EP
    end

    subgraph ContainerSecurity["Container Security Context"]
        direction TB
        UID["Runs as UID 2000<br/>(non-root)"]
        NoPriv["No privileged capabilities"]
        ReadOnly["No package installation<br/>(immutable image layers)"]
    end

    subgraph Secrets["Secrets (User-Provisioned)"]
        direction TB
        HFSecret["model-serving secret<br/>Type: Opaque<br/>Contains: HF_TOKEN"]
        S3Secret["model-serving secret<br/>Type: Opaque<br/>Contains: AWS credentials"]

        HFSecret -->|"injected as env var<br/>by KServe"| VLLMPod["vLLM Pod"]
        S3Secret -->|"injected as env var<br/>by KServe"| VLLMPod
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    style JWT fill:#4a90e2,stroke:#333,color:#fff
    style KRBP_Auth fill:#f5a623,stroke:#333
    style Istio_Auth fill:#f5a623,stroke:#333
    style HTTP_EP fill:#7ed321,stroke:#333
    style GRPC_EP fill:#7ed321,stroke:#333
    style UID fill:#d5e8d4,stroke:#82b366
    style NoPriv fill:#d5e8d4,stroke:#82b366
    style ReadOnly fill:#d5e8d4,stroke:#82b366
    style HFSecret fill:#f8cecc,stroke:#b85450
    style S3Secret fill:#f8cecc,stroke:#b85450
