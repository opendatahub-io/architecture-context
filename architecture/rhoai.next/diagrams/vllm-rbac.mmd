graph TD
    subgraph "vLLM CUDA Container Security"
        direction TB

        subgraph "Container Runtime"
            Container["odh-vllm-cuda-rhel9<br/>USER 2000 (non-root)<br/>No privilege escalation"]
        end

        subgraph "Authentication & Authorization (Platform-Managed)"
            direction TB
            AuthNote["All auth enforced externally<br/>by KServe/Istio — not by vLLM process"]

            subgraph "Ingress Auth"
                KServeAuth["KServe Gateway<br/>Bearer Token / OAuth<br/>Request validation"]
            end

            subgraph "Service Mesh Auth"
                IstioMTLS["Istio mTLS<br/>STRICT mode<br/>Service Identity"]
            end
        end

        subgraph "RBAC (KServe-Managed)"
            RBACNote["No RBAC resources defined<br/>by this component"]

            KServeSA["KServe Service Account<br/>(manages pod lifecycle)"]
            InferenceSA["Inference Pod SA<br/>(runtime service account)"]
        end

        subgraph "Secrets (KServe-Injected at Runtime)"
            SecretsNote["No secrets defined<br/>by this repository"]

            StorageCreds["Storage Credentials<br/>(S3 / IAM / SA token)<br/>Injected by KServe"]
            HFToken["HF Hub Token<br/>(optional Bearer token)<br/>Injected via env var"]
        end
    end

    %% Relationships
    KServeAuth -->|"validates tokens"| Container
    IstioMTLS -->|"enforces mTLS"| Container
    KServeSA -->|"creates/manages"| Container
    InferenceSA -->|"runs as"| Container
    StorageCreds -->|"mounted into"| Container
    HFToken -->|"env var"| Container

    %% Styling
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style KServeAuth fill:#f5a623,stroke:#333,color:#fff
    style IstioMTLS fill:#f5a623,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style InferenceSA fill:#7ed321,stroke:#333,color:#fff
    style StorageCreds fill:#e8e8e8,stroke:#333
    style HFToken fill:#e8e8e8,stroke:#333
    style AuthNote fill:#fff,stroke:#ccc,color:#666
    style RBACNote fill:#fff,stroke:#ccc,color:#666
    style SecretsNote fill:#fff,stroke:#ccc,color:#666
