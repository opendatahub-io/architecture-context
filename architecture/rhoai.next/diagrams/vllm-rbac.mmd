graph TD
    subgraph "Container Security"
        Container["vLLM CUDA Container<br/>UID: 2000 (non-root)"]
    end

    subgraph "Authentication Model"
        direction TB
        Note1["No RBAC defined in this repository"]
        Note2["Auth delegated to platform layer"]
    end

    subgraph "Platform Auth Chain"
        direction TB
        Gateway["RHOAI Gateway<br/>Bearer Token / OAuth validation"]
        KRBAC["kube-rbac-proxy Sidecar<br/>TLS termination<br/>ServiceAccount Token auth"]
        KServeCtrl["KServe Controller<br/>Manages RBAC for InferenceService pods"]
    end

    subgraph "Auth Enforcement Points"
        direction TB
        HTTP_EP["/v1/* HTTP Endpoints<br/>Auth: None at container<br/>Enforced by: kube-rbac-proxy + Gateway"]
        GRPC_EP["TGIS gRPC Endpoint<br/>Auth: None at container<br/>Enforced by: kube-rbac-proxy + Gateway"]
    end

    subgraph "Secrets"
        ModelCreds["(model storage credentials)<br/>Type: Opaque<br/>Purpose: S3/storage access<br/>Provisioned by: User/operator<br/>Auto-Rotate: No"]
    end

    Gateway -->|"validates token"| KRBAC
    KRBAC -->|"proxy (localhost)"| HTTP_EP
    KRBAC -->|"proxy (localhost)"| GRPC_EP
    KServeCtrl -->|"manages pod RBAC"| Container
    Container -->|"uses at startup"| ModelCreds

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style KRBAC fill:#f5a623,stroke:#333,color:#fff
    style KServeCtrl fill:#7ed321,stroke:#333
    style HTTP_EP fill:#dae8fc,stroke:#6c8ebf
    style GRPC_EP fill:#dae8fc,stroke:#6c8ebf
    style ModelCreds fill:#fff2cc,stroke:#d6b656
    style Note1 fill:#f9f9f9,stroke:#ccc
    style Note2 fill:#f9f9f9,stroke:#ccc
