graph TD
    subgraph "Container Security"
        Container["vLLM CUDA Container<br/>UID 2000 (non-root)<br/>No added capabilities"]
    end

    subgraph "Auth Enforcement Chain"
        direction TB
        Gateway["RHOAI Gateway<br/>TLS 1.2+ termination<br/>Per-InferenceService routing"]
        RBACProxy["kube-rbac-proxy Sidecar<br/>(injected by platform)<br/>SubjectAccessReview"]
        VLLMPorts["vLLM Ports<br/>8000/TCP HTTP<br/>8033/TCP gRPC<br/>No auth at container level"]

        Gateway -->|"HTTPS/8443<br/>SA Token"| RBACProxy
        RBACProxy -->|"localhost only<br/>No auth needed"| VLLMPorts
    end

    subgraph "RBAC Managed By (External)"
        KServeOp["KServe Operator<br/>Manages InferenceService RBAC"]
        ODHModelCtrl["odh-model-controller<br/>Manages ServingRuntime RBAC"]
    end

    subgraph "Secrets"
        ModelCreds["(model storage credentials)<br/>Type: Opaque<br/>Purpose: S3/storage access<br/>Provisioned by: User / operator<br/>Auto-rotate: No"]
    end

    KServeOp -->|"configures"| RBACProxy
    ODHModelCtrl -->|"injects sidecar"| RBACProxy
    ModelCreds -->|"mounted into"| Container

    Note["NOTE: This component defines no RBAC<br/>resources. All RBAC is managed by<br/>KServe and odh-model-controller.<br/>Auth is enforced at the platform layer."]

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style RBACProxy fill:#e1d5e7,stroke:#9673a6
    style VLLMPorts fill:#d5e8d4,stroke:#82b366
    style KServeOp fill:#7ed321,stroke:#333,color:#fff
    style ODHModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style ModelCreds fill:#fff2cc,stroke:#d6b656
    style Note fill:#f5f5f5,stroke:#ccc,stroke-dasharray: 5 5
