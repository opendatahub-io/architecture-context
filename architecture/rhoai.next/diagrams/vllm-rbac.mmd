graph TD
    subgraph "vLLM RBAC — Delegated to KServe"
        direction TB

        Note["NOTE: vLLM defines no RBAC resources.<br/>This is a container image, not an operator.<br/>All RBAC is managed by KServe."]

        subgraph "KServe-Managed RBAC (External)"
            direction TB

            subgraph "Service Accounts"
                KServeSA["KServe Controller Manager<br/>SA: kserve-controller-manager"]
                InferenceSA["Inference Pod SA<br/>(KServe-generated per InferenceService)"]
            end

            subgraph "Access Control"
                KServeRBAC["KServe RBAC<br/>- Manages ServingRuntime CRs<br/>- Creates/manages inference pods<br/>- Configures networking"]
                IstioAuth["Istio Authorization<br/>- mTLS STRICT enforcement<br/>- Service Identity validation"]
                KServeAuth["KServe Auth<br/>- Bearer Token / OAuth validation<br/>- Endpoint authorization"]
            end

            subgraph "Resources Accessed by vLLM Pod"
                ModelSecret["Model Access Secrets<br/>(storage-config)<br/>Injected by KServe"]
                GPUResource["GPU Resources<br/>nvidia.com/gpu<br/>Allocated by Device Plugin"]
                ModelStorage["Model Storage<br/>PVC mount or S3 access<br/>Configured via InferenceService"]
            end
        end

        KServeSA -->|"creates & manages"| InferenceSA
        InferenceSA -->|"runs"| vLLMPod["vLLM Pod<br/>User: 2000 (non-root)<br/>No privilege escalation"]
        KServeRBAC -->|"governs"| KServeSA
        IstioAuth -->|"enforces mTLS on"| vLLMPod
        KServeAuth -->|"validates requests to"| vLLMPod
        InferenceSA -->|"reads"| ModelSecret
        vLLMPod -->|"uses"| GPUResource
        vLLMPod -->|"reads"| ModelStorage
    end

    subgraph "Container Security Posture"
        Security["Security Controls:<br/>- Non-root user (UID 2000)<br/>- No privilege escalation<br/>- Red Hat signed base image<br/>- Clair vulnerability scan<br/>- ecosystem-cert-preflight-checks<br/>- FIPS: inherited from RHAIIS base"]
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style InferenceSA fill:#7ed321,stroke:#333,color:#fff
    style KServeRBAC fill:#7ed321,stroke:#333,color:#fff
    style IstioAuth fill:#7ed321,stroke:#333,color:#fff
    style KServeAuth fill:#7ed321,stroke:#333,color:#fff
    style ModelSecret fill:#f5a623,stroke:#333,color:#fff
    style GPUResource fill:#e1d5e7,stroke:#9673a6,color:#333
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style vLLMPod fill:#4a90e2,stroke:#333,color:#fff
    style Security fill:#d5e8d4,stroke:#82b366,color:#333
