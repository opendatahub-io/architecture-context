graph TD
    subgraph "Authentication Flow (No RBAC in this repo)"
        direction TB

        Client["External Client<br/>(Data Scientist / App)"]

        subgraph "Gateway Layer"
            GW["Gateway API (HTTPRoute)<br/>TLS 1.2+ termination"]
        end

        subgraph "Authorization Enforcement"
            KRBP["kube-rbac-proxy Sidecar<br/>Port: 8443/TCP HTTPS"]
            JWT["JWT Token Validation"]
            K8sRBAC["Kubernetes RBAC Check"]
            KRBP --> JWT
            JWT --> K8sRBAC
        end

        subgraph "Kubernetes RBAC (managed externally)"
            SA["ServiceAccount<br/>(user's service account)"]
            RB["RoleBinding<br/>(managed by platform operator)"]
            CR["ClusterRole / Role<br/>(managed by KServe / RHOAI)"]
            SA -->|"bound via"| RB
            RB -->|"grants"| CR
        end

        subgraph "vLLM Endpoints (No Auth)"
            OpenAI["OpenAI API<br/>8000/TCP HTTP<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>POST /v1/embeddings"]
            TGISgRPC["TGIS gRPC<br/>8033/TCP<br/>GenerationService"]
            Health["GET /health<br/>GET /metrics<br/>8000/TCP HTTP"]
        end
    end

    subgraph "Secrets (User-Provisioned)"
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Purpose: Model download<br/>Auto-rotate: No"]
        S3Creds["S3 Credentials<br/>Type: Opaque<br/>Purpose: Model storage access<br/>Auto-rotate: No"]
    end

    Client -->|"Bearer Token (JWT)"| GW
    GW -->|"HTTPS 8443"| KRBP
    K8sRBAC -->|"authorized"| OpenAI
    K8sRBAC -->|"authorized"| TGISgRPC

    HFToken -.->|"env: HF_TOKEN"| OpenAI
    S3Creds -.->|"env / volume"| OpenAI

    style Client fill:#f9f9f9,stroke:#333,stroke-width:1px
    style GW fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style KRBP fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style JWT fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style K8sRBAC fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style SA fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style RB fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style CR fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style OpenAI fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style TGISgRPC fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style Health fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style HFToken fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style S3Creds fill:#fff2cc,stroke:#d6b656,stroke-width:1px
