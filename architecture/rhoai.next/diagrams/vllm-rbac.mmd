graph TD
    subgraph "vLLM RBAC Context"
        direction TB

        Note["Note: No RBAC resources defined in this repository.<br/>All RBAC is managed by KServe and RHOAI platform operators."]

        subgraph "Platform-Managed RBAC (KServe)"
            direction TB
            KServeSA["ServiceAccount<br/>(created by KServe per InferenceService)"]
            KServeRole["Role/ClusterRole<br/>(managed by KServe Operator)"]
        end

        subgraph "Authentication (Platform-Managed)"
            direction TB
            ProxySA["kube-rbac-proxy Sidecar"]
            BearerToken["Bearer Token<br/>(Platform Auth Policy)"]
        end

        subgraph "Container Security"
            direction TB
            NonRoot["Non-Root User<br/>UID 2000"]
            NoTLS["No TLS at Container<br/>(Plaintext HTTP/gRPC)"]
            FIPSDelegated["FIPS Compliance<br/>Delegated to RHAIIS Base Image"]
        end

        subgraph "Secrets"
            direction TB
            ModelCreds["(model storage credentials)<br/>Type: Opaque<br/>Purpose: S3/HuggingFace access<br/>Provisioned by: User / RHOAI<br/>Auto-Rotate: No"]
        end
    end

    subgraph "Access Paths"
        direction LR
        ExternalAccess["External Access<br/>/v1/* endpoints"]
        InternalAccess["Internal Access<br/>TGIS gRPC/8033"]
    end

    ExternalAccess -->|"Bearer Token required<br/>Enforced by kube-rbac-proxy"| ProxySA
    InternalAccess -->|"No auth at container<br/>Platform network policy"| KServeSA

    ProxySA -->|"validates against"| BearerToken
    KServeSA -->|"bound via"| KServeRole

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333,color:#fff
    style ProxySA fill:#4a90e2,stroke:#333,color:#fff
    style BearerToken fill:#f5a623,stroke:#333,color:#fff
    style NonRoot fill:#7ed321,stroke:#333,color:#fff
    style NoTLS fill:#e74c3c,stroke:#333,color:#fff
    style FIPSDelegated fill:#9b59b6,stroke:#333,color:#fff
    style ModelCreds fill:#e8e8e8,stroke:#333
    style ExternalAccess fill:#f9f9f9,stroke:#999
    style InternalAccess fill:#f9f9f9,stroke:#999
