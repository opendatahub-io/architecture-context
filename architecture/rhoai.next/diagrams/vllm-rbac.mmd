graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["No RBAC resources defined<br/>by this component"]
        Explanation["vLLM is a container image,<br/>not an operator.<br/>RBAC is managed externally<br/>by KServe."]
        Info --- Explanation
    end

    subgraph SecurityContext["Container Security Context"]
        direction TB
        User["USER 2000<br/>(non-root)"]
        NoPrivEsc["No privilege escalation"]
        User --- NoPrivEsc
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction TB
        ClientReq["Client Request"]
        KServeGW["KServe Gateway<br/>Bearer Token / OAuth<br/>validation"]
        IstioSidecar["Istio Sidecar<br/>mTLS STRICT<br/>Service Identity"]
        vLLMProcess["vLLM Process<br/>No auth enforcement<br/>(delegates to platform)"]

        ClientReq -->|"Bearer Token / OAuth"| KServeGW
        KServeGW -->|"mTLS"| IstioSidecar
        IstioSidecar -->|"localhost (trusted)"| vLLMProcess
    end

    subgraph ExternalRBAC["KServe-Managed RBAC (External)"]
        direction TB
        KServeSA["KServe Service Account"]
        KServeRole["KServe ClusterRole<br/>(manages ServingRuntime,<br/>InferenceService)"]
        PodSA["Pod Service Account<br/>(model storage access)"]

        KServeSA -->|"bound to"| KServeRole
        KServeRole -->|"creates pods with"| PodSA
    end

    style Info fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Explanation fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style User fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NoPrivEsc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ClientReq fill:#f9f9f9,stroke:#999
    style KServeGW fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style IstioSidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style vLLMProcess fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style KServeSA fill:#e8e8e8,stroke:#999
    style KServeRole fill:#e8e8e8,stroke:#999
    style PodSA fill:#e8e8e8,stroke:#999
