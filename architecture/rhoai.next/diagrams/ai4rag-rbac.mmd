graph TD
    subgraph LibraryContext["ai4rag — Python Library (No Kubernetes RBAC)"]
        direction TB

        Note["ai4rag is a Python library, not a Kubernetes operator.<br/>It has NO CRDs, NO ClusterRoles, NO RoleBindings.<br/><br/>When deployed inside a Kubeflow Pipeline,<br/>RBAC is inherited from the KFP pipeline<br/>component's pod ServiceAccount."]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB

        subgraph Credential["Credential: OGX API Key"]
            Secret["OGX API Key<br/>Type: API key string<br/>Provisioned by: User<br/>Auto-Rotate: No"]
        end

        subgraph Usage["Usage"]
            OGXClient["OgxClient Constructor<br/>or Environment Variable"]
        end

        subgraph Target["Target Service"]
            OGXServer["OGX Server<br/>Auth: Bearer Token<br/>in Authorization header"]
        end

        Secret -->|"provided to"| OGXClient
        OGXClient -->|"Bearer token in<br/>HTTPS request"| OGXServer
    end

    subgraph KFPContext["When Running in KFP Pipeline"]
        direction TB

        KFPServiceAccount["KFP Pod ServiceAccount<br/>(inherited, not managed by ai4rag)"]
        KFPPod["Pipeline Component Pod"]
        AI4RAGLib["ai4rag library<br/>(runs in-process)"]

        KFPServiceAccount -->|"mounted in"| KFPPod
        KFPPod -->|"imports"| AI4RAGLib
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style Secret fill:#f5a623,stroke:#333
    style OGXServer fill:#999,stroke:#333,color:#fff
    style OGXClient fill:#4a90e2,stroke:#333,color:#fff
    style KFPServiceAccount fill:#7ed321,stroke:#333,color:#fff
    style KFPPod fill:#7ed321,stroke:#333,color:#fff
    style AI4RAGLib fill:#4a90e2,stroke:#333,color:#fff
