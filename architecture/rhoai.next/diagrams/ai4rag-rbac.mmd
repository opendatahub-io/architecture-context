graph TD
    subgraph Notice["ai4rag RBAC"]
        direction TB
        Info["ai4rag is a Python library<br/><br/>It does NOT create any Kubernetes RBAC resources:<br/>- No ClusterRoles<br/>- No Roles<br/>- No RoleBindings<br/>- No ServiceAccounts<br/><br/>RBAC is inherited from the consuming service<br/>(e.g., KFP pipeline runner ServiceAccount)"]
    end

    subgraph ConsumingService["Consuming Service Responsibility"]
        direction TB
        SA["ServiceAccount<br/><i>(defined by consuming service)</i>"]
        Secret["OGX API Key Secret<br/><i>(managed by consuming service)</i>"]
        SA -->|"mounts"| Secret
    end

    subgraph AuthMechanisms["Authentication (Application-Level)"]
        direction TB
        OGXAuth["OGX Server Auth<br/>Mechanism: API Key (Bearer token)<br/>Passed via: OgxClient(api_key=...)<br/>Enforcement: OGX Server side"]
    end

    SA -->|"runs ai4rag code"| Info
    Info -->|"outbound API calls"| OGXAuth

    %% Styling
    style Notice fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Info fill:#fff,stroke:#999
    style ConsumingService fill:#ffe6cc,stroke:#d79b00
    style AuthMechanisms fill:#f8cecc,stroke:#b85450
    style SA fill:#dae8fc,stroke:#6c8ebf
    style Secret fill:#fff2cc,stroke:#d6b656
    style OGXAuth fill:#f8cecc,stroke:#b85450
