graph TD
    subgraph "ai4rag RBAC & Authentication"
        direction TB

        subgraph "Note"
            Info["ai4rag is a Python library — no Kubernetes RBAC<br/>Authentication is user-provided to external services"]
        end

        subgraph "User-Provided Credentials"
            EnvVars["Environment Variables<br/>or Constructor Parameters"]
        end

        subgraph "Authentication Flows"
            direction TB
            LSAuth["Llama Stack Auth<br/>API Key (Bearer Token)"]
            OAIAuth["OpenAI Auth<br/>API Key (Bearer Token)"]
        end

        subgraph "External Service Authorization"
            direction TB
            LSServer["Llama Stack Server<br/>Enforces: API Key validation<br/>Policy: Server-configured"]
            OAIServer["OpenAI API Server<br/>Enforces: API Key validation<br/>Policy: Provider-configured"]
        end

        subgraph "API Permissions Required"
            direction TB
            LS_Perms["Llama Stack Permissions:<br/>• inference/chat_completion (POST)<br/>• inference/embeddings (POST)<br/>• vector_io/insert (POST)<br/>• vector_io/query (POST)<br/>• models/list (GET)<br/>• vector_stores CRUD (POST/GET/DELETE)"]
            OAI_Perms["OpenAI Permissions:<br/>• v1/chat/completions (POST)<br/>• v1/embeddings (POST)"]
        end
    end

    EnvVars -->|"api_key"| LSAuth
    EnvVars -->|"api_key"| OAIAuth
    LSAuth -->|"Bearer Token"| LSServer
    OAIAuth -->|"Bearer Token"| OAIServer
    LSServer -->|"grants access to"| LS_Perms
    OAIServer -->|"grants access to"| OAI_Perms

    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style EnvVars fill:#d4edda,stroke:#155724,color:#155724
    style LSAuth fill:#cce5ff,stroke:#004085,color:#004085
    style OAIAuth fill:#cce5ff,stroke:#004085,color:#004085
    style LSServer fill:#f5a623,stroke:#333,color:#fff
    style OAIServer fill:#f5a623,stroke:#333,color:#fff
    style LS_Perms fill:#e8e8e8,stroke:#333
    style OAI_Perms fill:#e8e8e8,stroke:#333
