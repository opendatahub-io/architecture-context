graph TD
    subgraph ai4rag_rbac["ai4rag RBAC & Credentials"]
        direction TB

        Note["NOTE: ai4rag is a Python library.<br/>No Kubernetes RBAC roles, bindings,<br/>or service accounts are defined.<br/><br/>Authentication is handled via<br/>environment variables passed to<br/>the host process."]

        subgraph Credentials["Credentials (Environment Variables)"]
            direction TB
            API_KEY["API_KEY<br/>━━━━━━━━━━━━━━━━━━━━━<br/>Type: Environment Variable<br/>Purpose: Llama Stack auth<br/>Provisioned: Manual (.env)<br/>Auto-Rotate: No<br/>Used as: Bearer token"]
            BASE_URL["BASE_URL<br/>━━━━━━━━━━━━━━━━━━━━━<br/>Type: Environment Variable<br/>Purpose: Llama Stack endpoint<br/>Provisioned: Manual (.env)<br/>Auto-Rotate: No<br/>Used by: LlamaStackClient"]
        end

        subgraph AuthFlows["Authentication Flows"]
            direction TB

            subgraph LSAuth["Llama Stack Authentication"]
                LSClient["LlamaStackClient<br/>(llama-stack-client SDK)"]
                LSServer["Llama Stack Server"]
                LSClient -->|"Bearer Token<br/>(API_KEY env var)<br/>HTTP/HTTPS"| LSServer
            end

            subgraph OAIAuth["OpenAI Authentication"]
                OAIClient["OpenAI Client<br/>(openai SDK)"]
                OAIServer["OpenAI-compatible Server"]
                OAIClient -->|"Bearer Token<br/>(user-provided key)<br/>HTTP/HTTPS"| OAIServer
            end
        end

        API_KEY -->|"loaded by"| LSClient
        BASE_URL -->|"configures endpoint"| LSClient
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style API_KEY fill:#f8d7da,stroke:#dc3545
    style BASE_URL fill:#f8d7da,stroke:#dc3545
    style LSClient fill:#4a90e2,color:#fff
    style LSServer fill:#bdc3c7,stroke:#333
    style OAIClient fill:#9b59b6,color:#fff
    style OAIServer fill:#bdc3c7,stroke:#333
