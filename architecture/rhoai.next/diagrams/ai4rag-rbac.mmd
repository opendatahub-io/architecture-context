graph TD
    subgraph Notice["ai4rag — No Kubernetes RBAC"]
        direction TB
        Info["ai4rag is a Python library, NOT a Kubernetes operator.<br/>It has no ClusterRoles, Roles, RoleBindings, or ServiceAccounts.<br/><br/>Authentication to external services is handled by the user<br/>via API keys passed as environment variables or constructor parameters."]
    end

    subgraph AuthModel["Authentication Model (User-Managed)"]
        direction TB
        UserCreds["User-Provided Credentials"]

        subgraph LlamaStackAuth["Llama Stack Authentication"]
            LSURL["LLAMA_STACK_BASE_URL<br/>(environment variable or<br/>constructor parameter)"]
            LSKey["LLAMA_STACK_API_KEY<br/>(environment variable or<br/>constructor parameter)"]
            LSMech["Mechanism: Bearer Token<br/>Enforcement: Llama Stack Server"]
        end

        subgraph OpenAIAuth["OpenAI Authentication"]
            OAIURL["OPENAI_BASE_URL<br/>(environment variable or<br/>constructor parameter)"]
            OAIKey["OPENAI_API_KEY<br/>(environment variable or<br/>constructor parameter)"]
            OAIMech["Mechanism: Bearer Token<br/>Enforcement: OpenAI API Server"]
        end

        UserCreds --> LlamaStackAuth
        UserCreds --> OpenAIAuth
    end

    subgraph SecNotes["Security Notes"]
        Note1["No credentials stored or cached by ai4rag"]
        Note2["No Kubernetes Secrets created"]
        Note3["No RBAC permissions required"]
        Note4["FIPS: Delegates TLS to httpx/openai SDK"]
        Note5["SHA256 used only for document dedup (non-security)"]
    end

    style Notice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthModel fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style SecNotes fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Info fill:#fff,stroke:#999
    style UserCreds fill:#4a90e2,stroke:#333,color:#fff
    style LlamaStackAuth fill:#e8f4fd,stroke:#4a90e2
    style OpenAIAuth fill:#e8f4fd,stroke:#4a90e2
