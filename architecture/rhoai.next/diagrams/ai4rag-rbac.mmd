graph TD
    subgraph Notice["ai4rag RBAC Summary"]
        direction TB
        NoRBAC["ai4rag is a Python library, not a Kubernetes component.<br/>No RBAC resources (ClusterRoles, Roles, RoleBindings)<br/>are created or required by the library itself."]
    end

    subgraph RuntimeAuth["Runtime Authentication (User-Configured)"]
        direction TB

        subgraph LlamaStackAuth["Llama Stack API Access"]
            LSKey["API Key (Bearer Token)<br/>Provided by user via constructor:<br/>LlamaStackClient(base_url=..., api_key=...)"]
            LSEndpoints["Endpoints Accessed:<br/>- /chat/completions<br/>- /embeddings<br/>- /vector_stores (CRUD)<br/>- /vector_io/insert<br/>- /vector_io/query<br/>- /models (list)"]
            LSKey -->|"authenticates"| LSEndpoints
        end

        subgraph OpenAIAuth["OpenAI-Compatible API Access"]
            OAIKey["API Key (Bearer Token)<br/>Provided by user via constructor:<br/>OpenAI(base_url=..., api_key=...)"]
            OAIEndpoints["Endpoints Accessed:<br/>- /v1/chat/completions<br/>- /v1/embeddings"]
            OAIKey -->|"authenticates"| OAIEndpoints
        end
    end

    subgraph HostEnv["Host Environment RBAC (Not Managed by ai4rag)"]
        direction TB
        Note2["When ai4rag runs inside a RHOAI Notebook Pod,<br/>the Pod's ServiceAccount and RBAC are managed by<br/>the notebook controller / RHOAI platform.<br/><br/>ai4rag itself does not interact with the<br/>Kubernetes API server."]
    end

    %% Styling
    style NoRBAC fill:#f0f0f0,stroke:#999,stroke-width:2px
    style LSKey fill:#fff3e0,stroke:#FF9800
    style LSEndpoints fill:#e3f2fd,stroke:#2196F3
    style OAIKey fill:#fff3e0,stroke:#FF9800
    style OAIEndpoints fill:#e3f2fd,stroke:#2196F3
    style Note2 fill:#f0f0f0,stroke:#999,stroke-width:1px
