graph TD
    subgraph "ai4rag RBAC & Secrets"
        direction TB

        subgraph "Note"
            Note["ai4rag is a Python library<br/>with NO Kubernetes RBAC.<br/><br/>RBAC is the responsibility of<br/>the consuming service."]
        end

        subgraph "Secrets (User-Provisioned)"
            APIKey["OGX API Key<br/><i>Type: API Key (string)</i><br/><i>Provisioned: User (.env or K8s Secret)</i><br/><i>Auto-Rotate: No</i>"]
        end

        subgraph "Usage Flow"
            Consumer["Consumer<br/>(e.g., KFP Component Pod)"]
            OGXClientLib["OgxClient(api_key=...)"]
            OGXServer["OGX Server"]
        end
    end

    Consumer -->|"mounts secret<br/>as env var"| APIKey
    APIKey -->|"passed at<br/>construction"| OGXClientLib
    OGXClientLib -->|"Authorization: Bearer<br/>(HTTPS/TLS 1.2+)"| OGXServer

    subgraph "When Deployed in KFP"
        direction TB
        K8sSecret["Kubernetes Secret<br/><i>Namespace: pipeline namespace</i>"]
        PodSA["Pod ServiceAccount<br/><i>Needs: get secrets</i>"]
        K8sSecret -.->|"mounted as env"| Consumer
        PodSA -.->|"bound to pod"| Consumer
    end

    %% Styling
    style Note fill:#f9f9f9,stroke:#ccc,stroke-dasharray: 5 5
    style APIKey fill:#f8cecc,stroke:#b85450
    style Consumer fill:#dae8fc,stroke:#6c8ebf
    style OGXClientLib fill:#fff2cc,stroke:#d6b656
    style OGXServer fill:#d5e8d4,stroke:#82b366
    style K8sSecret fill:#f8cecc,stroke:#b85450
    style PodSA fill:#e1d5e7,stroke:#9673a6
