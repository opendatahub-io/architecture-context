graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% External LLM Provider Dependencies
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API<br/>api.openai.com"]
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| NIM["NVIDIA NIM<br/>integrate.api.nvidia.com"]
    NemoGuardrails -->|"HTTPS/443<br/>x-api-key"| Anthropic["Anthropic API<br/>api.anthropic.com"]
    NemoGuardrails -->|"HTTPS/443<br/>api-key header"| AzureOpenAI["Azure OpenAI<br/>*.openai.azure.com"]
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| Cohere["Cohere API<br/>api.cohere.com"]
    NemoGuardrails -->|"HTTPS/443<br/>GCP creds"| VertexAI["Google Vertex AI"]

    %% Infrastructure Dependencies (optional)
    NemoGuardrails -.->|"TCP/6379<br/>user/pass"| Redis["Redis<br/>(optional)"]
    NemoGuardrails -.->|"gRPC/4317<br/>OTLP"| OTel["OpenTelemetry<br/>Collector (optional)"]

    %% Framework Dependencies
    NemoGuardrails -->|"in-process"| LangChain["LangChain<br/>>=0.2.14"]
    NemoGuardrails -->|"in-process"| FastAPI["FastAPI<br/>>=0.103.0"]
    NemoGuardrails -->|"in-process"| Uvicorn["Uvicorn<br/>>=0.23"]

    %% ML/NLP Dependencies
    NemoGuardrails -->|"in-process"| FastEmbed["FastEmbed<br/>>=0.2.2"]
    NemoGuardrails -->|"in-process"| ONNX["ONNX Runtime<br/>>=1.17.0"]
    NemoGuardrails -->|"in-process"| SpaCy["spaCy<br/>>=3.4.4"]
    NemoGuardrails -.->|"in-process<br/>optional"| Presidio["Presidio<br/>Analyzer/Anonymizer"]
    NemoGuardrails -.->|"in-process<br/>optional"| YARA["YARA-Python<br/>(jailbreak detection)"]

    %% Language/Parser Dependencies
    NemoGuardrails -->|"in-process"| Lark["Lark<br/>(Colang parser)"]
    NemoGuardrails -->|"in-process"| Jinja2["Jinja2<br/>(prompt templates)"]

    %% Platform Integration
    PlatformIngress["Platform Ingress<br/>(Gateway API / Route)"] -->|"HTTP/8000"| NemoGuardrails
    RHODSOperator["rhods-operator"] -->|"provisions ingress"| PlatformIngress

    %% Build-time Dependencies
    NemoGuardrails -.->|"HTTPS/443<br/>build-time only"| HuggingFace["HuggingFace Hub<br/>(model downloads)"]

