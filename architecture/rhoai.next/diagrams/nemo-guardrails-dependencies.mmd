graph LR
    NemoGuardrails["NeMo Guardrails<br/>Service"]

    %% External Dependencies (Required)
    NemoGuardrails -->|"LLM inference<br/>HTTPS/443"| LLMProvider["LLM Provider<br/>(OpenAI / NIM / Azure /<br/>Anthropic / Cohere / vLLM)"]
    NemoGuardrails -->|"LLM abstraction<br/>>=0.2.14"| LangChain["LangChain"]
    NemoGuardrails -->|"HTTP framework<br/>>=0.103.0"| FastAPI["FastAPI"]
    NemoGuardrails -->|"ASGI server<br/>>=0.23"| Uvicorn["uvicorn"]
    NemoGuardrails -->|"API types<br/>>=1.0.0"| OpenAISDK["OpenAI SDK"]

    %% External Dependencies (ML/NLP)
    NemoGuardrails -->|"embeddings<br/>>=2.2.0"| SentenceTransformers["Sentence<br/>Transformers"]
    NemoGuardrails -->|"NLP pipeline<br/>>=3.4.4"| SpaCy["spaCy"]
    NemoGuardrails -->|"PII detection<br/>>=2.2"| Presidio["Presidio<br/>Analyzer/Anonymizer"]
    NemoGuardrails -->|"fast inference<br/>>=1.17.0"| ONNXRuntime["ONNX Runtime"]
    NemoGuardrails -->|"tensor ops<br/>>=2.0.0 CPU"| PyTorch["PyTorch (CPU)"]

    %% External Dependencies (Optional)
    NemoGuardrails -.->|"tracing<br/>>=1.27.0"| OpenTelemetry["OpenTelemetry"]
    NemoGuardrails -.->|"jailbreak detection<br/>>=4.5.1"| YARA["YARA"]

