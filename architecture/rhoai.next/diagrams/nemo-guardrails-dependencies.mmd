graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% Core Framework Dependencies
    NemoGuardrails -->|HTTP server| FastAPI["FastAPI >=0.103.0"]
    NemoGuardrails -->|ASGI server| Uvicorn["Uvicorn >=0.23"]
    NemoGuardrails -->|data validation| Pydantic["Pydantic >=1.10"]

    %% LLM Provider Abstraction
    NemoGuardrails -->|LLM abstraction| LangChain["LangChain >=0.2.14"]
    NemoGuardrails -->|core interfaces| LangChainCore["LangChain-Core >=0.2.14"]
    NemoGuardrails -->|community providers| LangChainComm["LangChain-Community >=0.2.5"]
    NemoGuardrails -->|OpenAI schemas| OpenAISDK["OpenAI SDK >=1.0.0"]

    %% DSL & Parsing
    NemoGuardrails -->|Colang parser| Lark["Lark >=1.1.7"]

    %% Embedding & ML
    NemoGuardrails -->|default embeddings| FastEmbed["FastEmbed >=0.2.2"]
    NemoGuardrails -->|ML inference| ONNXRuntime["ONNX Runtime >=1.17.0"]

    %% Optional Dependencies
    NemoGuardrails -.->|NLP processing| spaCy["spaCy >=3.4.4"]
    NemoGuardrails -.->|PII detection| Presidio["Presidio >=2.2"]
    NemoGuardrails -.->|embeddings| SentenceTransformers["Sentence-Transformers >=2.2.0"]
    NemoGuardrails -.->|ML models| PyTorch["PyTorch >=2.0.0"]
    NemoGuardrails -.->|jailbreak detection| YARA["YARA-Python >=4.5.1"]
    NemoGuardrails -.->|tracing| OTELAPI["OpenTelemetry API >=1.27.0"]
    NemoGuardrails -.->|auto-instrument| OTELDistro["OpenTelemetry Distro >=0.48b0"]
    NemoGuardrails -.->|language detect| FastLangDetect["fast-langdetect >=1.0.0"]

    %% Internal Platform Dependencies (Runtime)
    NemoGuardrails -->|"LLM inference<br/>HTTPS/443"| vLLM["vLLM Serving Runtime<br/>(Primary RHOAI)"]
    NemoGuardrails -.->|"OTLP traces<br/>4317-4318/TCP"| OTELCollector["OpenTelemetry Collector"]

    %% Integration Points
    OpenAIAPI["OpenAI API"] -.->|"HTTPS/443"| NemoGuardrails
    AzureOpenAI["Azure OpenAI"] -.->|"HTTPS/443"| NemoGuardrails
    NVIDINIM["NVIDIA NIM"] -.->|"HTTPS/443"| NemoGuardrails
    AnthropicAPI["Anthropic API"] -.->|"HTTPS/443"| NemoGuardrails
    CohereAPI["Cohere API"] -.->|"HTTPS/443"| NemoGuardrails

