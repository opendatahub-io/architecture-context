    RHOAIPlatform["TrustyAI /<br/>RHOAI Platform"] -->|"deploys"| NemoGuardrails

    %% Build-time Dependencies
    NemoGuardrails -.->|"model downloads<br/>(build-time only)"| HuggingFace["Hugging Face Hub"]

    %% Integration Points (Outbound)
    NemoGuardrails -->|"trace export<br/>gRPC/HTTP"| OTELCollector["OTEL Collector"]

