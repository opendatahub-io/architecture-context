graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% Core Framework Dependencies
    subgraph CoreFramework["Core Framework"]
        FastAPI["FastAPI >=0.103.0"]
        Uvicorn["Uvicorn >=0.23"]
        Pydantic["Pydantic >=1.10"]
    end

    NemoGuardrails -->|"HTTP server"| FastAPI
    NemoGuardrails -->|"ASGI server"| Uvicorn
    NemoGuardrails -->|"data validation"| Pydantic

    %% LLM Abstraction Layer
    subgraph LLMAbstraction["LLM Abstraction (LangChain)"]
        LangChain["LangChain >=0.2.14"]
        LangChainCore["LangChain-Core >=0.2.14"]
        LangChainCommunity["LangChain-Community >=0.2.5"]
        LangChainOpenAI["LangChain-OpenAI >=0.1.0"]
        LangChainNVIDIA["LangChain-NVIDIA >=0.2.0"]
    end

    NemoGuardrails -->|"LLM provider abstraction"| LangChain
    NemoGuardrails -->|"core interfaces"| LangChainCore
    NemoGuardrails -->|"community providers"| LangChainCommunity
    NemoGuardrails -.->|"OpenAI integration"| LangChainOpenAI
    NemoGuardrails -.->|"NVIDIA NIM integration"| LangChainNVIDIA

    %% Embedding & ML Dependencies
    subgraph EmbeddingML["Embedding & ML"]
        FastEmbed["FastEmbed >=0.2.2<br/>(bundled in container)"]
        ONNXRuntime["ONNX Runtime >=1.17.0"]
        SentenceTransformers["Sentence-Transformers >=2.2.0"]
        PyTorch["PyTorch >=2.0.0"]
    end

    NemoGuardrails -->|"default embeddings"| FastEmbed
    NemoGuardrails -->|"model inference"| ONNXRuntime
    NemoGuardrails -.->|"alt embeddings"| SentenceTransformers
    NemoGuardrails -.->|"ML inference"| PyTorch

    %% NLP & Safety Dependencies
    subgraph NLPSafety["NLP & Safety"]
        SpaCy["spaCy >=3.4.4<br/>(bundled in container)"]
        Presidio["Presidio Analyzer/Anonymizer >=2.2"]
        YARA["YARA-Python >=4.5.1"]
        FastLangDetect["fast-langdetect >=1.0.0"]
    end

    NemoGuardrails -.->|"NLP/PII detection"| SpaCy
    NemoGuardrails -.->|"sensitive data"| Presidio
    NemoGuardrails -.->|"jailbreak detection"| YARA
    NemoGuardrails -.->|"language detection"| FastLangDetect

    %% Language & Parsing
    subgraph LanguageParsing["Language & Parsing"]
        Lark["Lark >=1.1.7"]
        OpenAISDK["OpenAI SDK >=1.0.0"]
    end

    NemoGuardrails -->|"Colang parser"| Lark
    NemoGuardrails -->|"API schema types"| OpenAISDK

    %% Observability
    subgraph Observability["Observability"]
        OTelAPI["OpenTelemetry API >=1.27.0"]
        OTelDistro["OpenTelemetry Distro >=0.48b0"]
    end

    NemoGuardrails -.->|"tracing API"| OTelAPI
    NemoGuardrails -.->|"auto-instrumentation"| OTelDistro

    %% Internal Platform Dependencies
    subgraph InternalPlatform["Internal Platform (Runtime)"]
        vLLM["vLLM Serving Runtime<br/>(RHOAI primary)"]
        OTELCollector["OpenTelemetry Collector<br/>4317/4318 TCP"]
    end

    NemoGuardrails -->|"LLM inference<br/>REST/HTTPS/443"| vLLM
    NemoGuardrails -.->|"trace export<br/>OTLP"| OTELCollector

    %% External LLM Providers
    subgraph ExternalLLM["External LLM Providers (Runtime)"]
        OpenAIAPI["OpenAI API"]
        AzureOAI["Azure OpenAI"]
        NVIDIA_NIM["NVIDIA NIM"]
        AnthropicAPI["Anthropic API"]
        CohereAPI["Cohere API"]
    end

    NemoGuardrails -.->|"HTTPS/443"| OpenAIAPI
    NemoGuardrails -.->|"HTTPS/443"| AzureOAI
    NemoGuardrails -.->|"HTTPS/443"| NVIDIA_NIM
    NemoGuardrails -.->|"HTTPS/443"| AnthropicAPI
    NemoGuardrails -.->|"HTTPS/443"| CohereAPI

    %% Configuration
    ConfigMap["Kubernetes ConfigMap<br/>config.yaml + rails.co"]
    ConfigMap -->|"volume mount<br/>/app/config/"| NemoGuardrails

