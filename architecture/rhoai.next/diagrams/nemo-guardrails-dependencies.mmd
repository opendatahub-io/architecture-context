graph LR
    NemoGuardrails["NeMo Guardrails Server<br/>(FastAPI :8000)"]

    %% Core Runtime Dependencies
    NemoGuardrails -->|"web framework"| FastAPI["FastAPI >=0.103.0"]
    NemoGuardrails -->|"ASGI server"| Uvicorn["uvicorn >=0.23"]
    NemoGuardrails -->|"LLM abstraction"| LangChain["LangChain >=0.2.14"]

    %% ML / NLP Dependencies
    NemoGuardrails -->|"PII detection (NER)"| SpaCy["spaCy >=3.4.4<br/>(en_core_web_lg)"]
    NemoGuardrails -->|"PII anonymization"| Presidio["Presidio >=2.2"]
    NemoGuardrails -->|"ML framework"| PyTorch["PyTorch >=2.0"]
    NemoGuardrails -->|"sentence embeddings"| SentenceTransformers["sentence-transformers<br/>>=2.2.0"]
    NemoGuardrails -->|"fast embeddings"| Fastembed["fastembed >=0.2.2"]
    NemoGuardrails -->|"ONNX inference"| ONNX["onnxruntime >=1.17.0"]

    %% Optional Dependencies
    NemoGuardrails -.->|"OpenAI client"| OpenAISDK["OpenAI SDK >=1.0"]
    NemoGuardrails -.->|"NVIDIA NIM"| NIMSDK["NVIDIA NIM SDK<br/>>=0.2.0"]
    NemoGuardrails -.->|"tracing"| OTel["OpenTelemetry >=1.27"]
    NemoGuardrails -.->|"injection detection"| YARA["YARA >=4.5.1"]
    NemoGuardrails -.->|"state persistence"| Redis["Redis (aioredis)"]

    %% Internal Platform Dependencies
    NemoGuardrails -->|"chat completion<br/>safety classification<br/>HTTPS :443"| LLMService["LLM Inference Service<br/>(vLLM / NIM / OpenAI)"]
    NemoGuardrails -->|"deployment context"| TrustyAI["TrustyAI Platform"]

    %% External Guardrail Integrations (all optional)
    subgraph ExternalGuardrails["External Guardrail Providers (all optional, HTTPS :443)"]
        ActiveFence["ActiveFence"]
        CiscoAI["Cisco AI Defense"]
        CrowdStrike["CrowdStrike AIDR"]
        Pangea["Pangea AI Guard"]
        Patronus["Patronus"]
        PolicyAI["PolicyAI"]
        PromptSecurity["Prompt Security"]
        TrendMicro["Trend Micro"]
        PrivateAI["Private AI"]
        GoogleNLP["Google Cloud NLP"]
        AutoAlign["AutoAlign"]
        Cleanlab["Cleanlab TLM"]
        Fiddler["Fiddler"]
        GuardrailsAI["Guardrails AI"]
        GLiNER["GLiNER"]
        Clavata["Clavata"]
    end
    NemoGuardrails -.->|"optional safety checks<br/>HTTPS :443, API Key"| ExternalGuardrails

    %% Platform Integration
    PlatformOperator["rhods-operator"] -->|"deploys & manages"| NemoGuardrails
    ConfigMap["ConfigMap<br/>(config.yaml + rails.co)"] -->|"volume mount"| NemoGuardrails

