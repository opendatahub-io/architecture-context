graph LR
    NG["NeMo Guardrails<br/>Server"]

    %% Core Runtime Dependencies (Required)
    NG -->|"HTTP framework"| FastAPI["FastAPI >=0.103.0"]
    NG -->|"ASGI server"| Uvicorn["Uvicorn >=0.23"]
    NG -->|"LLM abstraction"| LangChain["LangChain >=0.2.14"]
    NG -->|"language parser"| Lark["Lark >=1.1.7<br/>(Colang parser)"]
    NG -->|"data validation"| Pydantic["Pydantic >=1.10"]
    NG -->|"templates"| Jinja2["Jinja2 >=3.1.6"]

    %% Embedding & ML Dependencies
    NG -->|"local embeddings"| FastEmbed["FastEmbed >=0.2.2"]
    NG -->|"ML inference"| ONNX["ONNX Runtime >=1.17.0"]
    NG -->|"ANN index"| Annoy["Annoy >=1.17.3"]

    %% HTTP Client Dependencies
    NG -->|"async HTTP"| aiohttp["aiohttp >=3.10.11"]
    NG -->|"HTTP client"| httpx["httpx >=0.24.1"]

    %% External LLM Providers (Egress)
    NG ==>|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API<br/>api.openai.com"]
    NG ==>|"HTTPS/443<br/>Bearer Token"| NIM["NVIDIA NIM<br/>integrate.api.nvidia.com"]
    NG ==>|"HTTPS/443<br/>x-api-key"| Anthropic["Anthropic API<br/>api.anthropic.com"]
    NG ==>|"HTTPS/443<br/>api-key"| Azure["Azure OpenAI<br/>*.openai.azure.com"]
    NG ==>|"HTTPS/443<br/>Bearer Token"| Cohere["Cohere API<br/>api.cohere.com"]
    NG ==>|"HTTPS/443<br/>GCP creds"| VertexAI["Google Vertex AI"]

    %% Optional Dependencies
    NG -.->|"PII detection"| Presidio["Presidio >=2.2<br/>(optional)"]
    NG -.->|"NLP/NER"| SpaCy["spaCy >=3.4.4<br/>(optional)"]
    NG -.->|"tracing"| OTelSDK["OpenTelemetry >=1.27<br/>(optional)"]
    NG -.->|"state persistence"| Redis["Redis<br/>6379/TCP (optional)"]
    NG -.->|"jailbreak patterns"| YARA["YARA-Python >=4.5.1<br/>(optional)"]
    NG -.->|"deep learning"| PyTorch["PyTorch >=2.0<br/>(optional)"]
    NG -.->|"sentence embeddings"| SentTrans["Sentence-Transformers<br/>(optional)"]

    %% Platform Integration
    Platform["RHOAI Platform<br/>Ingress / Operator"] ==>|"provisions ingress<br/>auth enforcement"| NG
    OTelCollector["OTel Collector<br/>4317/TCP gRPC"] -.->|"trace export"| NG

    %% Build-time Dependencies
    HF["HuggingFace Hub<br/>(build-time only)"] -.->|"model downloads<br/>HTTPS/443"| NG

