graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% LLM Provider Dependencies (External, Egress)
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API<br/>api.openai.com"]
    NemoGuardrails -->|"HTTPS/443<br/>API Key"| AzureOpenAI["Azure OpenAI<br/>{endpoint}.openai.azure.com"]
    NemoGuardrails -->|"HTTPS/443<br/>API Key"| Anthropic["Anthropic API<br/>api.anthropic.com"]
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| Cohere["Cohere API<br/>api.cohere.com"]
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| NIM["NVIDIA NIM<br/>(configurable)"]
    NemoGuardrails -->|"HTTP/HTTPS<br/>Bearer Token"| VLLM["vLLM Server<br/>(configurable)"]

    %% Build-Time Dependencies
    NemoGuardrails -.->|"HTTPS/443<br/>build-time only"| HuggingFace["HuggingFace Hub<br/>huggingface.co"]

    %% Optional Infrastructure
    NemoGuardrails -.->|"Redis/6379<br/>optional"| Redis["Redis"]
    NemoGuardrails -.->|"OTLP/4317-4318<br/>optional"| OTel["OpenTelemetry<br/>Collector"]

    %% Core Framework Dependencies
    NemoGuardrails -->|"core framework"| FastAPI["FastAPI >=0.103.0"]
    NemoGuardrails -->|"LLM abstraction"| LangChain["LangChain >=0.2.14"]
    NemoGuardrails -->|"DSL parsing"| Lark["Lark >=1.1.7"]

    %% Embedded ML Models (In-Process)
    NemoGuardrails -->|"NER<br/>(in-process)"| SpaCy["spaCy >=3.4.4<br/>en_core_web_lg"]
    NemoGuardrails -->|"embeddings<br/>(in-process)"| SentTrans["Sentence<br/>Transformers >=2.2.0"]
    NemoGuardrails -->|"fast embeddings<br/>(in-process)"| FastEmbed["FastEmbed >=0.2.2<br/>(ONNX)"]
    NemoGuardrails -->|"tokenization<br/>(in-process)"| NLTK["NLTK >=3.8"]

    %% Optional Guardrail Dependencies
    NemoGuardrails -.->|"PII detection<br/>(optional)"| Presidio["Presidio<br/>Analyzer/Anonymizer"]
    NemoGuardrails -.->|"jailbreak patterns<br/>(optional)"| Yara["yara-python >=4.5.1"]

    %% Runtime Dependencies
    NemoGuardrails -->|"ML inference"| ONNXRuntime["ONNX Runtime >=1.17.0"]
    NemoGuardrails -->|"ASGI server"| Uvicorn["uvicorn >=0.23"]
    NemoGuardrails -->|"async HTTP"| Aiohttp["aiohttp >=3.10.11"]
    NemoGuardrails -->|"ANN search"| Annoy["Annoy >=1.17.3"]

    %% Styling
    style NemoGuardrails fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External LLM Providers
    style OpenAI fill:#f5a623,stroke:#333
    style AzureOpenAI fill:#f5a623,stroke:#333
    style Anthropic fill:#f5a623,stroke:#333
    style Cohere fill:#f5a623,stroke:#333
    style NIM fill:#f5a623,stroke:#333
    style VLLM fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333

    %% Optional Infrastructure
    style Redis fill:#e1d5e7,stroke:#9673a6
    style OTel fill:#e1d5e7,stroke:#9673a6

    %% Core Frameworks
    style FastAPI fill:#7ed321,stroke:#333
    style LangChain fill:#7ed321,stroke:#333
    style Lark fill:#7ed321,stroke:#333

    %% ML Models
    style SpaCy fill:#d5e8d4,stroke:#82b366
    style SentTrans fill:#d5e8d4,stroke:#82b366
    style FastEmbed fill:#d5e8d4,stroke:#82b366
    style NLTK fill:#d5e8d4,stroke:#82b366

    %% Optional Guardrail Deps
    style Presidio fill:#e1d5e7,stroke:#9673a6
    style Yara fill:#e1d5e7,stroke:#9673a6

    %% Runtime Deps
    style ONNXRuntime fill:#dae8fc,stroke:#6c8ebf
    style Uvicorn fill:#dae8fc,stroke:#6c8ebf
    style Aiohttp fill:#dae8fc,stroke:#6c8ebf
    style Annoy fill:#dae8fc,stroke:#6c8ebf
