graph TD
    subgraph Legend["RBAC Scope Legend"]
        direction LR
        LCluster["ClusterRole<br/>(cluster-wide)"]
        LNamespace["Role/SA<br/>(namespace-scoped)"]
        LNone["No K8s RBAC<br/>(library/SDK)"]
        style LCluster fill:#e74c3c,stroke:#333,color:#fff
        style LNamespace fill:#f5a623,stroke:#333,color:#fff
        style LNone fill:#95a5a6,stroke:#333,color:#fff
    end

    subgraph ClusterWide["ClusterRole (Broad Scope)"]
        direction TB

        subgraph CFOp_RBAC["codeflare-operator"]
            CFOp_SA["SA: codeflare-operator-<br/>controller-manager"]
            CFOp_CR["ClusterRole:<br/>manager-role"]
            CFOp_R1["workload.codeflare.dev<br/>AppWrappers"]
            CFOp_R2["ray.io<br/>RayClusters"]
            CFOp_R3["core<br/>Pods, ConfigMaps,<br/>Secrets"]
            CFOp_R4["networking.k8s.io<br/>NetworkPolicies"]
            CFOp_R5["kueue.x-k8s.io<br/>LocalQueues,<br/>ClusterQueues,<br/>ResourceFlavors,<br/>Workloads"]
            CFOp_SA -->|bound| CFOp_CR
            CFOp_CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CFOp_R1
            CFOp_CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CFOp_R2
            CFOp_CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CFOp_R3
            CFOp_CR -->|"get,list,watch,<br/>create,update"| CFOp_R4
            CFOp_CR -->|"get,list,watch"| CFOp_R5
        end

        subgraph DSPOp_RBAC["data-science-pipelines-operator"]
            DSPOp_SA["SA: dspo-controller-<br/>manager"]
            DSPOp_CR["ClusterRole:<br/>(extensive)"]
            DSPOp_R1["opendatahub.io<br/>DSPAs"]
            DSPOp_R2["apps<br/>Deployments"]
            DSPOp_R3["core<br/>Services, ConfigMaps,<br/>Secrets, Routes"]
            DSPOp_R4["rbac<br/>RoleBindings"]
            DSPOp_R5["networking.k8s.io<br/>NetworkPolicies"]
            DSPOp_R6["monitoring<br/>ServiceMonitors"]
            DSPOp_SA -->|bound| DSPOp_CR
            DSPOp_CR -->|"full CRUD"| DSPOp_R1
            DSPOp_CR -->|"full CRUD"| DSPOp_R2
            DSPOp_CR -->|"full CRUD"| DSPOp_R3
            DSPOp_CR -->|"full CRUD"| DSPOp_R4
            DSPOp_CR -->|"full CRUD"| DSPOp_R5
            DSPOp_CR -->|"full CRUD"| DSPOp_R6
        end

        subgraph Argo_RBAC["argo-workflows"]
            Argo_SA["SA: argo-workflow-<br/>controller"]
            Argo_CR["ClusterRole +<br/>Role"]
            Argo_R1["argoproj.io<br/>Workflows,<br/>CronWorkflows,<br/>WorkflowTemplates"]
            Argo_R2["core<br/>Pods, PVCs,<br/>ConfigMaps"]
            Argo_SA -->|bound| Argo_CR
            Argo_CR -->|"full CRUD"| Argo_R1
            Argo_CR -->|"get,list,watch,<br/>create,delete"| Argo_R2
        end

        subgraph DSP_RBAC["data-science-pipelines"]
            DSP_SA["SA: ds-pipelines"]
            DSP_CR["ClusterRole +<br/>Role"]
            DSP_R1["pipelines.kubeflow.org<br/>Pipelines, Runs,<br/>ScheduledWorkflows"]
            DSP_R2["argoproj.io<br/>Workflows"]
            DSP_R3["core<br/>Pods, ConfigMaps,<br/>Secrets, Events"]
            DSP_SA -->|bound| DSP_CR
            DSP_CR -->|"full CRUD"| DSP_R1
            DSP_CR -->|"create,watch"| DSP_R2
            DSP_CR -->|"get,list,watch,<br/>create"| DSP_R3
        end

        subgraph Feast_RBAC["feast-operator"]
            Feast_SA["SA: feast-operator-<br/>controller-manager"]
            Feast_CR["ClusterRole +<br/>Role"]
            Feast_R1["feast.dev<br/>FeatureStores"]
            Feast_R2["apps<br/>Deployments"]
            Feast_R3["core<br/>Services, ConfigMaps,<br/>ServiceAccounts"]
            Feast_R4["monitoring<br/>ServiceMonitors"]
            Feast_SA -->|bound| Feast_CR
            Feast_CR -->|"full CRUD"| Feast_R1
            Feast_CR -->|"full CRUD"| Feast_R2
            Feast_CR -->|"full CRUD"| Feast_R3
            Feast_CR -->|"full CRUD"| Feast_R4
        end

        subgraph AIGW_RBAC["ai-gateway-payload-processing"]
            AIGW_SA["SA: ai-gateway"]
            AIGW_CR["ClusterRole"]
            AIGW_R1["inference.opendatahub.io<br/>ExternalModel,<br/>ExternalProvider"]
            AIGW_R2["core<br/>Secrets"]
            AIGW_SA -->|bound| AIGW_CR
            AIGW_CR -->|"get,list,watch"| AIGW_R1
            AIGW_CR -->|"get"| AIGW_R2
        end

        subgraph GWExt_RBAC["gateway-api-inference-extension"]
            GWExt_SA["SA: gw-ext"]
            GWExt_CR["ClusterRole"]
            GWExt_R1["inference.networking.x-k8s.io<br/>InferencePool,<br/>InferenceModel"]
            GWExt_R2["core<br/>Pods, EndpointSlices"]
            GWExt_R3["coordination.k8s.io<br/>Leases"]
            GWExt_SA -->|bound| GWExt_CR
            GWExt_CR -->|"get,list,watch"| GWExt_R1
            GWExt_CR -->|"get,list,watch"| GWExt_R2
            GWExt_CR -->|"get,create,update"| GWExt_R3
        end

        subgraph Eval_RBAC["eval-hub"]
            Eval_SA["SA: eval-hub"]
            Eval_CR["ClusterRole"]
            Eval_R1["authentication.k8s.io<br/>TokenReview"]
            Eval_R2["authorization.k8s.io<br/>SubjectAccessReview"]
            Eval_SA -->|bound| Eval_CR
            Eval_CR -->|"create"| Eval_R1
            Eval_CR -->|"create"| Eval_R2
        end
    end

    subgraph NamespaceScoped["Namespace-Scoped / Minimal RBAC"]
        direction LR
        BatchGW_SA["batch-gateway<br/>ServiceAccount<br/>(minimal)"]
        Guardrails_SA["fms-guardrails-orch<br/>ServiceAccount<br/>(minimal)"]
        FMSTuning_SA["fms-hf-tuning<br/>Default pod SA"]
        CaikitTGIS_SA["caikit-tgis-serving<br/>KServe-managed SA"]
        GuardrailsDet_SA["guardrails-detectors<br/>KServe-managed SA"]
    end

    subgraph NoRBAC["No Kubernetes RBAC"]
        direction LR
        AI4RAG_None["ai4rag<br/>(library)"]
        Caikit_None["caikit<br/>(library)"]
        CaikitNLP_None["caikit-nlp<br/>(library)"]
        CFSDK_Client["codeflare-sdk<br/>(user kubeconfig)"]
    end

    %% Styling
    classDef clusterRole fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#3498db,stroke:#333,stroke-width:1px,color:#fff
    classDef sa fill:#2ecc71,stroke:#333,stroke-width:2px,color:#fff
    classDef none fill:#95a5a6,stroke:#333,stroke-width:1px,color:#fff
    classDef minimal fill:#f39c12,stroke:#333,stroke-width:1px,color:#fff

    class CFOp_CR,DSPOp_CR,Argo_CR,DSP_CR,Feast_CR,AIGW_CR,GWExt_CR,Eval_CR clusterRole
    class CFOp_SA,DSPOp_SA,Argo_SA,DSP_SA,Feast_SA,AIGW_SA,GWExt_SA,Eval_SA sa
    class CFOp_R1,CFOp_R2,CFOp_R3,CFOp_R4,CFOp_R5 resource
    class DSPOp_R1,DSPOp_R2,DSPOp_R3,DSPOp_R4,DSPOp_R5,DSPOp_R6 resource
    class Argo_R1,Argo_R2 resource
    class DSP_R1,DSP_R2,DSP_R3 resource
    class Feast_R1,Feast_R2,Feast_R3,Feast_R4 resource
    class AIGW_R1,AIGW_R2 resource
    class GWExt_R1,GWExt_R2,GWExt_R3 resource
    class Eval_R1,Eval_R2 resource
    class BatchGW_SA,Guardrails_SA,FMSTuning_SA,CaikitTGIS_SA,GuardrailsDet_SA minimal
    class AI4RAG_None,Caikit_None,CaikitNLP_None,CFSDK_Client none
