graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_AIGO["ai-gateway-operator<br/>(system)"]
        SA_Batch["llm-d-batch-gateway-operator"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(cluster-wide)"]
        CRB_Batch["llm-d-batch-gateway-operator<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(ns: ai-gateway-system)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
        CR_Admin["components-aigateway<br/>-admin-role"]
        CR_Editor["components-aigateway<br/>-editor-role"]
        CR_Viewer["components-aigateway<br/>-viewer-role"]
        CR_BatchOp["llm-d-batch-gateway<br/>-operator"]
        CR_BatchAdmin["llmbatchgateway-admin"]
        CR_BatchView["llmbatchgateway-view"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role<br/>(ns: ai-gateway-system)"]
    end

    subgraph APIResources["API Resources Managed"]
        Res_AIGateway["components.platform.opendatahub.io<br/>aigateways, /status, /finalizers"]
        Res_Deployments["apps<br/>deployments"]
        Res_Core["core<br/>services, serviceaccounts,<br/>configmaps, secrets"]
        Res_Events["events.k8s.io<br/>events"]
        Res_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
        Res_BatchCRD["batch.llm-d.ai<br/>llmbatchgateways,<br/>/status, /finalizers"]
        Res_CertMgr["cert-manager.io<br/>certificates"]
        Res_GatewayAPI["gateway.networking.k8s.io<br/>httproutes, referencegrants"]
        Res_Monitoring["monitoring.coreos.com<br/>podmonitors, prometheusrules,<br/>servicemonitors"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        Res_Metrics["/metrics<br/>(non-resource URL)"]
    end

    %% SA → CRB → CR bindings
    SA_AIGO -->|"bound via"| CRB_Manager
    SA_AIGO -->|"bound via"| CRB_Metrics
    SA_AIGO -->|"bound via"| RB_Leader
    SA_Batch -->|"bound via"| CRB_Batch

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    RB_Leader -->|"grants"| R_Leader
    CRB_Batch -->|"grants"| CR_BatchOp

    %% CR → Resources
    CR_Manager -->|"full CRUD"| Res_AIGateway
    CR_Manager -->|"full CRUD"| Res_Deployments
    CR_Manager -->|"full CRUD"| Res_Core
    CR_Manager -->|"create, patch"| Res_Events
    CR_Manager -->|"create, list, watch<br/>+ scoped CRUD"| Res_CRDs
    CR_Manager -->|"full CRUD +<br/>deletecollection"| Res_BatchCRD
    CR_Manager -->|"full CRUD"| Res_CertMgr
    CR_Manager -->|"full CRUD"| Res_GatewayAPI
    CR_Manager -->|"full CRUD"| Res_Monitoring
    CR_Manager -->|"create, list, watch<br/>+ scoped CRUD"| Res_RBAC

    CR_MetricsAuth -->|"create"| Res_TokenReview
    CR_MetricsAuth -->|"create"| Res_SAR
    CR_MetricsReader -->|"get"| Res_Metrics

    %% Aggregated roles
    CR_Admin -->|"full CRUD"| Res_AIGateway
    CR_Editor -->|"full CRUD"| Res_AIGateway
    CR_Viewer -->|"read-only"| Res_AIGateway
    CR_BatchAdmin -->|"full CRUD"| Res_BatchCRD
    CR_BatchView -->|"read-only"| Res_BatchCRD

