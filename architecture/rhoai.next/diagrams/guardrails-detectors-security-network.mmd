graph TB
    subgraph Callers["INTERNAL CALLERS (Trusted)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Platform namespace"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS - Istio sidecar)"]
        direction TB

        subgraph BuiltInNS["Built-in Detector"]
            BuiltIn["odh-built-in-detector-rhel9<br/>Port: 8080/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics, /registry<br/>Processing: regex, file-type, custom Python"]
        end

        subgraph HFNS["HuggingFace Detector - KServe ISVC"]
            HF["odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics<br/>Processing: PyTorch inference"]
        end

        subgraph JudgeNS["LLM Judge Detector - KServe ISVC"]
            Judge["guardrails-detector-llm-judge<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/api/v1/text/generation,<br/>/health, /metrics"]
        end

        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    subgraph InternalSvc["INTERNAL SERVICES - Cluster"]
        S3["S3/MinIO Storage<br/>9000/TCP HTTP<br/>AWS IAM credentials"]
        vLLM["vLLM Server<br/>8080/TCP HTTP<br/>OpenAI-compatible API<br/>No auth"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES - Internet"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Model download - example only"]
    end

    %% Caller flows
    Orchestrator -->|"HTTP/8080<br/>mTLS (Istio)<br/>Platform auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| HF
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| Judge

    %% Egress flows
    HF -->|HTTP/9000<br/>No encryption<br/>AWS credentials<br/>Init: model download| S3
    Judge -->|HTTP/8080<br/>No encryption<br/>No auth<br/>LLM inference| vLLM
    HF -.->|HTTPS/443<br/>TLS 1.2+<br/>Example init only| HFHub

    %% Prometheus scraping
    Prometheus -.->|HTTP scrape| BuiltIn
    Prometheus -.->|HTTP scrape| HF
    Prometheus -.->|HTTP scrape| Judge

    %% Styling
    classDef caller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef detector fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Orchestrator caller
    class BuiltIn,HF,Judge detector
    class S3,vLLM internal
    class HFHub external
    class Prometheus monitoring
