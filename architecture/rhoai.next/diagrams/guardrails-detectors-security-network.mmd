graph TB
    subgraph Internal["INTERNAL CLUSTER (Service-to-Service)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Invokes detectors on text I/O"]
    end

    subgraph NoMesh["NO SERVICE MESH (Network Isolation)"]
        BuiltIn["Built-in Detector<br/>ClusterIP :8080/TCP<br/>HTTP plaintext<br/>No Auth (network isolation)<br/>Image: odh-built-in-detector-rhel9"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph KServeHF["KServe InferenceService"]
            HFDetector["HuggingFace Detector<br/>ClusterIP :8000/TCP<br/>HTTP + mTLS (Istio sidecar)<br/>Auth: KServe platform auth<br/>Image: odh-guardrails-detector-hf-runtime-rhel9"]
        end

        subgraph KServeLJ["KServe InferenceService"]
            LLMJudge["LLM Judge Detector<br/>ClusterIP :8000/TCP<br/>HTTP + mTLS (Istio sidecar)<br/>Auth: KServe platform auth<br/>Image: guardrails-detector-llm-judge"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO<br/>:9000/TCP HTTP<br/>Plaintext<br/>Auth: AWS IAM Credentials"]
        vLLM["vLLM / OpenAI LLM Server<br/>configurable port HTTP<br/>Plaintext<br/>Auth: None"]
        HFHub["HuggingFace Hub<br/>:443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (optional)"]
        Prom["Prometheus<br/>Scrapes /metrics<br/>HTTP plaintext"]
    end

    %% Flows
    Orchestrator -->|"HTTP :8080<br/>Plaintext<br/>No Auth"| BuiltIn
    Orchestrator -->|"HTTP :8000<br/>mTLS (Istio)<br/>KServe Auth"| HFDetector
    Orchestrator -->|"HTTP :8000<br/>mTLS (Istio)<br/>KServe Auth"| LLMJudge

    HFDetector -->|"HTTP :9000<br/>Plaintext<br/>AWS IAM Credentials"| S3
    HFDetector -.->|"HTTPS :443<br/>TLS 1.2+<br/>Init container only"| HFHub
    LLMJudge -->|"HTTP configurable<br/>Plaintext<br/>No Auth"| vLLM

    Prom -.->|"GET /metrics :8080"| BuiltIn
    Prom -.->|"GET /metrics :8000"| HFDetector
    Prom -.->|"GET /metrics :8000"| LLMJudge

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef nomesh fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef detector fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    class Orchestrator internal
    class BuiltIn detector
    class HFDetector,LLMJudge detector
    class S3,vLLM,HFHub,Prom externalservice
