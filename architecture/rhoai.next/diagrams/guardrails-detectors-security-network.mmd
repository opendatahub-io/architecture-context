graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>(caller)"]
    end

    subgraph Ingress["INGRESS (Istio - mTLS PASSTHROUGH)"]
        direction TB
        KServeHF["KServe InferenceService<br/>HuggingFace Detector<br/>8000/TCP<br/>Auth: security.opendatahub.io/enable-auth"]
        KServeJudge["KServe InferenceService<br/>LLM Judge Detector<br/>8000/TCP<br/>Auth: security.opendatahub.io/enable-auth"]
    end

    subgraph ServiceMesh["SERVICE MESH (Internal)"]
        direction TB

        subgraph NS_Detectors["Namespace: (deployment ns)"]
            BuiltIn["Built-in Detector<br/>ClusterIP 8080/TCP<br/>HTTP / No TLS (configurable)<br/>Image: rhoai/odh-built-in-detector-rhel9<br/>No auth"]
            HFDetector["HuggingFace Detector<br/>ClusterIP 8000/TCP<br/>HTTP / Istio mTLS<br/>Image: rhoai/odh-guardrails-detector-hf-runtime-rhel9<br/>KServe auth"]
            JudgeDetector["LLM Judge Detector<br/>ClusterIP 8000/TCP<br/>HTTP / Istio mTLS<br/>Image: quay.io/trustyai/guardrails-detector-llm-judge<br/>KServe auth (upstream only)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        vLLM["vLLM Server<br/>configurable port<br/>HTTP / No TLS<br/>No auth"]
        S3["S3/Minio Storage<br/>9000/TCP<br/>HTTP / No TLS<br/>AWS credentials"]
        HFHub["HuggingFace Hub<br/>443/TCP<br/>HTTPS / TLS<br/>Optional token"]
        Prometheus["Prometheus<br/>Scrape: 8080, 8000/TCP<br/>HTTP / No auth"]
    end

    %% Inbound flows
    Orchestrator -->|"HTTP/8080<br/>No TLS (Istio mTLS in mesh)<br/>No app auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS<br/>KServe auth"| KServeHF
    Orchestrator -->|"HTTP/8000<br/>Istio mTLS<br/>KServe auth"| KServeJudge

    KServeHF --> HFDetector
    KServeJudge --> JudgeDetector

    %% Outbound flows
    JudgeDetector -->|"HTTP/configurable<br/>No TLS<br/>No auth"| vLLM
    HFDetector -.->|"HTTP/9000<br/>No TLS<br/>AWS credentials<br/>(KServe storage init)"| S3
    HFDetector -.->|"HTTPS/443<br/>TLS<br/>HF token (init)"| HFHub

    %% Metrics
    Prometheus -.->|"HTTP scrape<br/>/metrics"| BuiltIn
    Prometheus -.->|"HTTP scrape<br/>/metrics"| HFDetector
    Prometheus -.->|"HTTP scrape<br/>/metrics"| JudgeDetector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef upstream fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Orchestrator external
    class KServeHF,KServeJudge ingress
    class BuiltIn,HFDetector servicemesh
    class JudgeDetector upstream
    class vLLM,S3,HFHub,Prometheus externalservice
