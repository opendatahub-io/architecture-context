graph TB
    subgraph External["EXTERNAL / PLATFORM (Orchestrated)"]
        Orchestrator["FMS Guardrails Orchestrator<br/>Content analysis orchestration"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS via Istio Sidecar Injection)"]
        direction TB

        subgraph NS_BuiltIn["Built-in Detector"]
            BuiltIn["Built-in Detector<br/>Image: odh-built-in-detector-rhel9<br/>Port: 8080/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics, /registry"]
        end

        subgraph NS_HF["HuggingFace Detector (KServe ISVC)"]
            HF["HuggingFace Detector<br/>Image: odh-guardrails-detector-hf-runtime-rhel9<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics<br/>Auth: security.opendatahub.io/enable-auth"]
        end

        subgraph NS_Judge["LLM Judge Detector (KServe ISVC)"]
            Judge["LLM Judge Detector<br/>Image: guardrails-detector-llm-judge<br/>Port: 8000/TCP<br/>Endpoints: /api/v1/text/contents,<br/>/api/v1/text/generation,<br/>/health, /metrics<br/>Auth: security.opendatahub.io/enable-auth"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO Storage<br/>9000/TCP HTTP<br/>Auth: AWS IAM credentials<br/>Purpose: Model file storage"]
        VLLM["vLLM Server<br/>8080/TCP HTTP<br/>Auth: None<br/>Purpose: LLM inference backend"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Purpose: Model download (init only)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>trustyai_guardrails_*"]
    end

    %% Flows from Orchestrator
    Orchestrator -->|"HTTP/8080<br/>mTLS (Istio)<br/>Platform auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| HF
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| Judge

    %% Egress flows
    HF -->|"HTTP/9000<br/>No encryption<br/>AWS credentials"| S3
    Judge -->|"HTTP/8080<br/>No encryption<br/>No auth"| VLLM
    HF -.->|"HTTPS/443<br/>TLS 1.2+<br/>(init container only)"| HFHub

    %% Monitoring
    Prometheus -.->|"HTTP/8080, 8000<br/>scrape"| BuiltIn
    Prometheus -.->|"HTTP/8000<br/>scrape"| HF
    Prometheus -.->|"HTTP/8000<br/>scrape"| Judge

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Orchestrator external
    class BuiltIn,HF,Judge servicemesh
    class S3,VLLM,HFHub externalservice
    class Prometheus monitoring
