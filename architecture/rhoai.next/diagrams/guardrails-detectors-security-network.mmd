graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS"]
        Orchestrator["FMS Guardrails Orchestrator<br/>(Internal Caller)<br/>mTLS via Istio"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS via Istio Sidecar)"]
        direction TB

        subgraph BuiltInZone["Built-in Detector"]
            BuiltIn["Built-in Detector<br/>ClusterIP 8080/TCP<br/>Image: odh-built-in-detector-rhel9<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics, /registry"]
        end

        subgraph HFZone["HuggingFace Detector (KServe ISVC)"]
            HFDetector["HuggingFace Detector<br/>ClusterIP 8000/TCP<br/>sidecar.istio.io/inject: true<br/>Image: odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics"]
        end

        subgraph JudgeZone["LLM Judge Detector (KServe ISVC)"]
            JudgeDetector["LLM Judge Detector<br/>ClusterIP 8000/TCP<br/>sidecar.istio.io/inject: true<br/>Image: guardrails-detector-llm-judge<br/>Endpoints: /api/v1/text/contents,<br/>/api/v1/text/generation,<br/>/health, /metrics"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        S3["S3/MinIO Storage<br/>ClusterIP 9000/TCP<br/>HTTP | No encryption<br/>Auth: AWS credentials"]
        VLLM["vLLM Server<br/>8080/TCP<br/>HTTP | No encryption<br/>Auth: None"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>trustyai_guardrails_* counters"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>mTLS (Istio)<br/>Platform auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| HFDetector
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>Platform auth"| JudgeDetector

    HFDetector -->|"HTTP/9000<br/>No encryption<br/>AWS IAM credentials"| S3
    JudgeDetector -->|"HTTP/8080<br/>No encryption<br/>No auth"| VLLM
    HFHub -.->|"HTTPS/443<br/>TLS 1.2+<br/>Init container only"| HFDetector

    Prometheus -.->|"HTTP/8080, 8000<br/>Scrape /metrics"| BuiltIn
    Prometheus -.->|"HTTP/8000<br/>Scrape /metrics"| HFDetector
    Prometheus -.->|"HTTP/8000<br/>Scrape /metrics"| JudgeDetector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#ffcccc,stroke:#cc0000,stroke-width:2px

    class HFHub external
    class Orchestrator ingress
    class BuiltIn,HFDetector,JudgeDetector servicemesh
    class S3,Prometheus internal
    class VLLM warning
