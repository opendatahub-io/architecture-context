graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Cluster["CLUSTER INTERNAL"]
        subgraph OrchestratorZone["ORCHESTRATOR ZONE"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Invokes detectors for<br/>content analysis pipeline"]
        end

        subgraph DetectorZone["DETECTOR ZONE"]
            subgraph DirectDeploy["Direct Deployment (No Istio)"]
                BuiltIn["Built-in Detector<br/>8080/TCP HTTP<br/>Encryption: None<br/>Auth: None<br/>Service: ClusterIP"]
            end

            subgraph KServeMesh["KServe + Istio Service Mesh (mTLS)"]
                HFDet["HuggingFace Detector<br/>8000/TCP HTTP<br/>Encryption: mTLS (Istio)<br/>Auth: KServe<br/>KServe InferenceService"]

                LLMJudgeDet["LLM Judge Detector<br/>8000/TCP HTTP<br/>Encryption: mTLS (Istio)<br/>Auth: KServe<br/>KServe InferenceService"]
            end
        end

        subgraph StorageZone["STORAGE / UPSTREAM SERVICES"]
            MinIO["S3/MinIO<br/>minio-guardrails-guardian<br/>9000/TCP HTTP<br/>Encryption: None<br/>Auth: AWS IAM (Secret)"]

            vLLM["vLLM / OpenAI-compatible<br/>LLM Server<br/>Port: configurable<br/>HTTP Plaintext<br/>Auth: None"]
        end

        subgraph Platform["PLATFORM SERVICES"]
            KServe["KServe Controller<br/>Manages InferenceServices"]
            Istio["Istio Service Mesh<br/>mTLS enforcement"]
            Prom["Prometheus<br/>Scrapes /metrics"]
        end
    end

    %% Orchestrator to Detectors
    Orchestrator -->|"HTTP/8080<br/>Plaintext<br/>No Auth"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>KServe Auth"| HFDet
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>KServe Auth"| LLMJudgeDet

    %% Detector upstream dependencies
    HFDet -->|"HTTP/9000<br/>Plaintext<br/>AWS Credentials"| MinIO
    LLMJudgeDet -->|"HTTP/configurable<br/>Plaintext<br/>No Auth"| vLLM

    %% Optional external
    HFDet -.->|"HTTPS/443<br/>TLS 1.2+<br/>Init container"| HFHub

    %% Platform management
    KServe -.->|manages| HFDet
    KServe -.->|manages| LLMJudgeDet
    Istio -.->|sidecar inject| HFDet
    Istio -.->|sidecar inject| LLMJudgeDet
    Prom -.->|scrape /metrics| BuiltIn
    Prom -.->|scrape /metrics| HFDet
    Prom -.->|scrape /metrics| LLMJudgeDet

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef directDetector fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef meshDetector fill:#2c6fbb,stroke:#333,stroke-width:2px,color:#fff
    classDef storage fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef platform fill:#e8e8e8,stroke:#666,stroke-width:1px

    class HFHub external
    class Orchestrator orchestrator
    class BuiltIn directDetector
    class HFDet,LLMJudgeDet meshDetector
    class MinIO,vLLM storage
    class KServe,Istio,Prom platform
