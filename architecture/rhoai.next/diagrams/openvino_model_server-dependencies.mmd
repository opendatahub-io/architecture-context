graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"inference engine<br/>(required)"| OVRuntime["OpenVINO Runtime<br/>2026.0"]
    OVMS -->|"LLM/audio/image<br/>pipelines (required)"| OVGenAI["OpenVINO GenAI<br/>2026.0"]
    OVMS -->|"tokenization<br/>(required)"| OVTokenizers["OpenVINO Tokenizers<br/>2026.0"]

    %% Build System
    OVMS -->|"build system<br/>(build-time)"| Bazel["Bazel 6.1.1"]

    %% Server Frameworks (Required, Embedded)
    OVMS -->|"HTTP server"| Drogon["Drogon<br/>(embedded)"]
    OVMS -->|"gRPC server"| GRPC["gRPC<br/>(embedded)"]

    %% C++ Libraries (Required)
    OVMS -->|"utilities"| Boost["Boost 1.68.0"]
    OVMS -->|"image processing"| OpenCV["OpenCV<br/>(embedded)"]
    OVMS -->|"JSON parsing"| RapidJSON["RapidJSON<br/>(embedded)"]
    OVMS -->|"XML parsing"| pugixml["pugixml 1.13"]
    OVMS -->|"logging"| spdlog["spdlog<br/>(embedded)"]
    OVMS -->|"REST SDK dep"| cpprestsdk["cpprestsdk 2.10.16"]

    %% Optional Dependencies
    OVMS -.->|"pipeline graphs<br/>(optional)"| MediaPipe["MediaPipe<br/>(embedded)"]
    OVMS -.->|"chat templates<br/>(optional)"| Python["Python 3.12<br/>+ Jinja2 3.1.6"]
    OVMS -.->|"HuggingFace pulls<br/>(optional)"| libgit2["libgit2<br/>(embedded)"]

    %% Cloud Storage SDKs (Optional)
    OVMS -.->|"S3 storage"| AWSSDK["AWS SDK (S3)<br/>(embedded)"]
    OVMS -.->|"GCS storage"| GCSSDK["GCS SDK<br/>(embedded)"]
    OVMS -.->|"Azure storage"| AzureSDK["Azure Storage SDK<br/>7.5.0"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe<br/>(InferenceService)"] -->|"deploys as<br/>inference container"| OVMS
    KubeRBAC["kube-rbac-proxy"] -->|"auth proxy<br/>sidecar"| OVMS
    Istio["Istio / Service Mesh"] -.->|"mTLS + traffic<br/>management"| OVMS

    %% External Services (Runtime)
    OVMS -->|"model storage<br/>HTTPS/443"| S3["Amazon S3"]
    OVMS -->|"model storage<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    OVMS -->|"model storage<br/>HTTPS/443"| Azure["Azure Blob Storage"]
    OVMS -->|"model download<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Monitoring Integration
    Prometheus["Prometheus"] -->|"scrapes /metrics"| OVMS
    Grafana["Grafana"] -->|"dashboards"| Prometheus

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - green
    style OVRuntime fill:#10b981,stroke:#333,color:#fff
    style OVGenAI fill:#10b981,stroke:#333,color:#fff
    style OVTokenizers fill:#10b981,stroke:#333,color:#fff

    %% Build tools - gray
    style Bazel fill:#6b7280,stroke:#333,color:#fff

    %% Embedded libs - light blue
    style Drogon fill:#93c5fd,stroke:#333
    style GRPC fill:#93c5fd,stroke:#333
    style Boost fill:#93c5fd,stroke:#333
    style OpenCV fill:#93c5fd,stroke:#333
    style RapidJSON fill:#93c5fd,stroke:#333
    style pugixml fill:#93c5fd,stroke:#333
    style spdlog fill:#93c5fd,stroke:#333
    style cpprestsdk fill:#93c5fd,stroke:#333
    style MediaPipe fill:#93c5fd,stroke:#333
    style Python fill:#93c5fd,stroke:#333
    style libgit2 fill:#93c5fd,stroke:#333

    %% Cloud SDKs - light orange
    style AWSSDK fill:#fed7aa,stroke:#333
    style GCSSDK fill:#fed7aa,stroke:#333
    style AzureSDK fill:#fed7aa,stroke:#333

    %% Internal RHOAI - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff

    %% External services - yellow/orange
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff

    %% Monitoring - purple
    style Prometheus fill:#9333ea,stroke:#333,color:#fff
    style Grafana fill:#9333ea,stroke:#333,color:#fff
