graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"inference engine<br/>(required)"| OVRuntime["OpenVINO Runtime<br/>2026.1"]
    OVMS -->|"LLM/embed/image/audio<br/>(required)"| OVGenAI["OpenVINO GenAI<br/>2026.1"]
    OVMS -->|"tokenization<br/>(required)"| OVTokenizers["OpenVINO Tokenizers<br/>pinned commit"]

    %% Framework Dependencies (Required)
    OVMS -->|"pipeline composition<br/>(required)"| MediaPipe["MediaPipe<br/>bundled"]
    OVMS -->|"HTTP server<br/>(required)"| Drogon["Drogon<br/>bundled"]
    OVMS -->|"gRPC server<br/>(required)"| gRPC["gRPC<br/>bundled via Bazel"]
    OVMS -->|"TFS proto defs<br/>(required)"| TFProto["TensorFlow<br/>(proto only)"]

    %% Utility Dependencies
    OVMS -->|"XML parsing<br/>(required)"| pugixml["pugixml<br/>1.13"]
    OVMS -->|"JSON parsing<br/>(required)"| RapidJSON["RapidJSON<br/>bundled"]
    OVMS -->|"C++/Python interop<br/>(required)"| pybind11["pybind11<br/>bundled"]
    OVMS -->|"metrics<br/>(required)"| PromClient["Prometheus C++<br/>Client (bundled)"]
    OVMS -->|"image processing<br/>(required)"| OpenCV["OpenCV<br/>pinned"]
    OVMS -->|"Python runtime<br/>(required)"| Python312["Python 3.12"]

    %% Optional Dependencies
    OVMS -.->|"Azure storage<br/>(optional)"| AzureSDK["Azure Storage<br/>C++ SDK 7.5.0"]
    OVMS -.->|"Azure REST<br/>(optional)"| cpprestsdk["cpprestsdk<br/>2.10.16"]
    OVMS -.->|"HF model cloning<br/>(optional)"| libgit2["libgit2<br/>bundled"]
    OVMS -.->|"HF model export<br/>(optional)"| OptimumIntel["optimum-intel<br/>pinned commit"]
    OVMS -.->|"GPU inference<br/>(optional)"| GPUDrivers["Intel GPU Drivers<br/>OpenCL/Level Zero<br/>25.05.32567"]

    %% Build Dependencies
    OVMS -.->|"build system<br/>(build only)"| Bazel["Bazel 6.1.1"]
    OVMS -.->|"C++ libs<br/>(build only)"| Boost["Boost 1.68.0"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>ServingRuntime"] -->|"deploys as container"| OVMS
    RHOAIGateway["RHOAI Gateway<br/>(Envoy)"] -->|"TLS termination<br/>traffic routing"| OVMS
    KubeRBAC["kube-rbac-proxy"] -->|"auth enforcement<br/>sidecar"| OVMS

    %% Integration Points (Inbound)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP 8080"| OVMS

    %% External Services (Outbound)
    OVMS -->|"model storage<br/>HTTPS/443 AWS IAM"| S3["S3-compatible<br/>Storage"]
    OVMS -->|"model storage<br/>HTTPS/443 GCS SA"| GCS["Google Cloud<br/>Storage"]
    OVMS -->|"model storage<br/>HTTPS/443 Conn String"| Azure["Azure Blob/File<br/>Storage"]
    OVMS -->|"model pulling<br/>HTTPS/443 HF_TOKEN"| HFHub["Hugging Face Hub"]

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - orange
    style OVRuntime fill:#ff8f00,stroke:#333,color:#fff
    style OVGenAI fill:#ff8f00,stroke:#333,color:#fff
    style OVTokenizers fill:#ff8f00,stroke:#333,color:#fff

    %% Framework deps - grey
    style MediaPipe fill:#999,stroke:#333,color:#fff
    style Drogon fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style TFProto fill:#999,stroke:#333,color:#fff

    %% Utility deps - light grey
    style pugixml fill:#bbb,stroke:#333
    style RapidJSON fill:#bbb,stroke:#333
    style pybind11 fill:#bbb,stroke:#333
    style PromClient fill:#bbb,stroke:#333
    style OpenCV fill:#bbb,stroke:#333
    style Python312 fill:#bbb,stroke:#333

    %% Optional deps - dashed border
    style AzureSDK fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style cpprestsdk fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style libgit2 fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style OptimumIntel fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style GPUDrivers fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5

    %% Build deps
    style Bazel fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style Boost fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5

    %% Platform deps - green
    style KServe fill:#7ed321,stroke:#333
    style RHOAIGateway fill:#7ed321,stroke:#333
    style KubeRBAC fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333

    %% External services - gold
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
