graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    subgraph CoreRuntime["Core Runtime (Required)"]
        OVRuntime["OpenVINO Runtime<br/>2026.1"]
        OVGenAI["OpenVINO GenAI<br/>2026.1"]
        OVTokenizers["OpenVINO Tokenizers<br/>2026.1"]
    end

    OVMS -->|"inference engine<br/>(CPU/GPU/NPU)"| OVRuntime
    OVMS -->|"LLM pipelines<br/>(continuous batching)"| OVGenAI
    OVMS -->|"tokenization"| OVTokenizers

    %% Bundled Libraries (Required)
    subgraph BundledLibs["Bundled Libraries (Required)"]
        gRPCLib["gRPC<br/>(bundled)"]
        Drogon["Drogon<br/>(HTTP framework)"]
        MediaPipeLib["MediaPipe<br/>(bundled)"]
        OpenCV["OpenCV<br/>(bundled)"]
        libgit2["libgit2<br/>(bundled)"]
        RapidJSON["RapidJSON<br/>(bundled)"]
    end

    OVMS -->|"gRPC server"| gRPCLib
    OVMS -->|"REST server"| Drogon
    OVMS -->|"graph processing"| MediaPipeLib
    OVMS -->|"image preprocessing"| OpenCV
    OVMS -->|"HuggingFace clone"| libgit2
    OVMS -->|"JSON parsing"| RapidJSON

    %% System Libraries
    subgraph SystemLibs["System Libraries (UBI 9)"]
        OpenSSL["OpenSSL<br/>(system)"]
    end

    OVMS -->|"TLS for storage,<br/>HuggingFace downloads"| OpenSSL

    %% Conditional Dependencies
    subgraph ConditionalDeps["Conditional Dependencies"]
        pybind11["pybind11<br/>(bundled)"]
        Jinja2["Jinja2<br/>3.1.6"]
        numpy["numpy<br/><2.0.0"]
    end

    OVMS -.->|"Python embedding<br/>(when enabled)"| pybind11
    OVMS -.->|"chat templates<br/>(LLMs)"| Jinja2
    OVMS -.->|"tensor ops<br/>(Python nodes)"| numpy

    %% Build-Time Dependencies
    subgraph BuildDeps["Build-Time Only"]
        Bazel["Bazel 6.1.1"]
        Boost["Boost 1.68.0<br/>(static)"]
    end

    OVMS -.->|"build system"| Bazel
    OVMS -.->|"Azure SDK,<br/>logging"| Boost

    %% Internal RHOAI Platform Dependencies
    subgraph InternalPlatform["Internal RHOAI Platform"]
        KServe["KServe<br/>(ServingRuntime CR)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"]
    end

    KServe -->|"deploys OVMS<br/>container"| OVMS
    KubeRBACProxy -->|"TLS + AuthN/AuthZ<br/>enforcement"| OVMS

    %% External Cloud Services (Egress)
    subgraph ExternalServices["External Cloud Services"]
        S3["Amazon S3<br/>443/TCP HTTPS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
        AzureBlob["Azure Blob Storage<br/>443/TCP HTTPS"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    end

    OVMS -->|"model storage<br/>(AWS IAM)"| S3
    OVMS -->|"model storage<br/>(OAuth 2.0)"| GCS
    OVMS -->|"model storage<br/>(SAS/MI)"| AzureBlob
    OVMS -->|"model repos<br/>(Bearer Token)"| HFHub

    %% Integration Points (Inbound)
    subgraph IntegrationInbound["Integration Points (Inbound)"]
        Prometheus["Prometheus"]
        K8sProbes["Kubernetes<br/>Probes"]
    end

    Prometheus -->|"HTTP scrape<br/>/metrics"| OVMS
    K8sProbes -->|"HTTP GET<br/>/v2/health/*"| OVMS

    %% Local Storage
    PVC["PVC / NFS<br/>Volume"]
    OVMS -->|"filesystem<br/>mount"| PVC

