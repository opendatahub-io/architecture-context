graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"inference engine"| OpenVINO["OpenVINO Runtime<br/>2026.0"]
    OVMS -->|"LLM pipeline"| GenAI["OpenVINO GenAI<br/>releases/2026/0"]
    OVMS -->|"tokenization"| Tokenizers["OpenVINO Tokenizers<br/>releases/2026/0"]

    %% Framework Dependencies (Required)
    OVMS -->|"HTTP server"| Drogon["Drogon<br/>(Bundled)"]
    OVMS -->|"gRPC server"| gRPC["gRPC<br/>(Bundled)"]
    OVMS -->|"calculator graphs"| MediaPipe["MediaPipe<br/>(Bundled)"]
    OVMS -->|"build system"| Bazel["Bazel<br/>6.1.1"]

    %% Library Dependencies (Required)
    OVMS -->|"C++ utilities"| Boost["Boost<br/>1.68.0"]
    OVMS -->|"image processing"| OpenCV["OpenCV<br/>(Bundled)"]
    OVMS -->|"JSON parsing"| RapidJSON["RapidJSON<br/>(Bundled)"]
    OVMS -->|"serialization"| Protobuf["Protocol Buffers<br/>(Bundled)"]
    OVMS -->|"TLS/crypto"| OpenSSL["OpenSSL<br/>(System)"]
    OVMS -->|"XML parsing"| pugixml["pugixml<br/>1.13"]

    %% Conditional Dependencies
    OVMS -.->|"S3 storage"| AWSSDK["AWS SDK (S3)<br/>(Bundled)"]
    OVMS -.->|"GCS storage"| GCSSDK["GCS SDK<br/>(Bundled)"]
    OVMS -.->|"Azure storage"| AzureSDK["Azure SDK<br/>v2.10.16 / v7.5.0"]
    OVMS -.->|"Python nodes"| pybind11["pybind11<br/>(Bundled)"]
    OVMS -.->|"HF model cloning"| libgit2["libgit2<br/>(Bundled)"]
    OVMS -.->|"HTTP downloads"| libcurl["libcurl<br/>(System)"]
    OVMS -.->|"GPU inference"| IntelGPU["Intel GPU Drivers<br/>24.52.32224"]
    OVMS -.->|"Python execution"| Python["Python 3.12<br/>(System)"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>(Platform)"] -->|"runtime contract"| OVMS
    ServingRuntime["RHOAI ServingRuntime CR<br/>(Platform)"] -->|"configuration"| OVMS
    ModelStorage["Model Storage<br/>(PVC/S3/GCS)"] -->|"data access"| OVMS

    %% External Service Dependencies
    OVMS -->|"model storage"| S3["Amazon S3<br/>443/TCP HTTPS"]
    OVMS -->|"model storage"| GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
    OVMS -->|"model storage"| AzureBlob["Azure Blob Storage<br/>443/TCP HTTPS"]
    OVMS -->|"model repos"| HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS"]

    %% Integration Points
    Prometheus["Prometheus"] -->|"metrics scrape"| OVMS
    NginxMTLS["nginx mTLS sidecar<br/>(optional)"] -->|"reverse proxy"| OVMS

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - dark blue
    style OpenVINO fill:#2c5f8a,stroke:#333,color:#fff
    style GenAI fill:#2c5f8a,stroke:#333,color:#fff
    style Tokenizers fill:#2c5f8a,stroke:#333,color:#fff

    %% Frameworks - medium blue
    style Drogon fill:#5ba8f7,stroke:#333,color:#fff
    style gRPC fill:#5ba8f7,stroke:#333,color:#fff
    style MediaPipe fill:#5ba8f7,stroke:#333,color:#fff
    style Bazel fill:#5ba8f7,stroke:#333,color:#fff

    %% Libraries - light gray
    style Boost fill:#999,stroke:#333,color:#fff
    style OpenCV fill:#999,stroke:#333,color:#fff
    style RapidJSON fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff
    style pugixml fill:#999,stroke:#333,color:#fff

    %% Conditional - orange
    style AWSSDK fill:#f5a623,stroke:#333,color:#fff
    style GCSSDK fill:#f5a623,stroke:#333,color:#fff
    style AzureSDK fill:#f5a623,stroke:#333,color:#fff
    style pybind11 fill:#f5a623,stroke:#333,color:#fff
    style libgit2 fill:#f5a623,stroke:#333,color:#fff
    style libcurl fill:#f5a623,stroke:#333,color:#fff
    style IntelGPU fill:#f5a623,stroke:#333,color:#fff
    style Python fill:#f5a623,stroke:#333,color:#fff

    %% Internal platform - green
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333,color:#fff

    %% External services - yellow
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff

    %% Monitoring / optional
