graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"inference engine<br/>(required)"| OpenVINORT["OpenVINO Runtime<br/>2026.0"]
    OVMS -->|"LLM/audio/image gen<br/>(required)"| OpenVINOGenAI["OpenVINO GenAI<br/>2026.0"]
    OVMS -->|"tokenization<br/>(required)"| OpenVINOTokenizers["OpenVINO Tokenizers<br/>2026.0"]

    %% Build Dependencies
    OVMS -->|"build system"| Bazel["Bazel<br/>6.1.1"]

    %% Server Framework Dependencies (Required)
    OVMS -->|"HTTP server"| Drogon["Drogon<br/>(embedded)"]
    OVMS -->|"RPC server"| GRPC["gRPC<br/>(embedded)"]
    OVMS -->|"C++ utilities"| Boost["Boost<br/>1.68.0"]
    OVMS -->|"image processing"| OpenCV["OpenCV<br/>(embedded)"]
    OVMS -->|"JSON parsing"| RapidJSON["RapidJSON<br/>(embedded)"]
    OVMS -->|"XML parsing"| pugixml["pugixml<br/>1.13"]
    OVMS -->|"logging"| spdlog["spdlog<br/>(embedded)"]

    %% Optional Dependencies
    OVMS -.->|"pipeline graphs<br/>(optional)"| MediaPipe["MediaPipe<br/>(embedded)"]
    OVMS -.->|"chat templates<br/>(optional)"| Python["Python 3.12<br/>+ Jinja2 3.1.6"]

    %% Cloud Storage Dependencies (Optional)
    OVMS -.->|"S3 model loading"| AWSSDK["AWS SDK (S3)<br/>(embedded)"]
    OVMS -.->|"GCS model loading"| GCSSDK["GCS SDK<br/>(embedded)"]
    OVMS -.->|"Azure model loading"| AzureSDK["Azure Storage SDK<br/>7.5.0"]
    AzureSDK -->|"dependency"| cpprestsdk["cpprestsdk<br/>2.10.16"]
    OVMS -.->|"HuggingFace pulls"| libgit2["libgit2<br/>(embedded)"]

    %% Internal Platform Dependencies
    KServe["KServe Operator"] -->|"deploys as<br/>inference container"| OVMS
    KubeRBACProxy["kube-rbac-proxy"] -->|"auth sidecar<br/>(RHOAI)"| OVMS
    Istio["Istio / Service Mesh"] -.->|"mTLS & traffic<br/>management"| OVMS

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrapes /metrics"| OVMS
    Grafana["Grafana"] -->|"dashboards"| Prometheus
    DSPipelines["Data Science Pipelines"] -.->|"auto-deploy models"| KServe

    %% External Services
    OVMS -.->|"model storage"| S3["Amazon S3"]
    OVMS -.->|"model storage"| GCS["Google Cloud Storage"]
    OVMS -.->|"model storage"| AzureBlob["Azure Blob Storage"]
    OVMS -.->|"model download"| HuggingFace["HuggingFace Hub"]

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime (orange)
    style OpenVINORT fill:#ff9800,stroke:#333,color:#fff
    style OpenVINOGenAI fill:#ff9800,stroke:#333,color:#fff
    style OpenVINOTokenizers fill:#ff9800,stroke:#333,color:#fff

    %% Build/framework deps (gray)
    style Bazel fill:#999,stroke:#333,color:#fff
    style Drogon fill:#999,stroke:#333,color:#fff
    style GRPC fill:#999,stroke:#333,color:#fff
    style Boost fill:#999,stroke:#333,color:#fff
    style OpenCV fill:#999,stroke:#333,color:#fff
    style RapidJSON fill:#999,stroke:#333,color:#fff
    style pugixml fill:#999,stroke:#333,color:#fff
    style spdlog fill:#999,stroke:#333,color:#fff
    style MediaPipe fill:#999,stroke:#333,color:#fff
    style Python fill:#999,stroke:#333,color:#fff
    style AWSSDK fill:#999,stroke:#333,color:#fff
    style GCSSDK fill:#999,stroke:#333,color:#fff
    style AzureSDK fill:#999,stroke:#333,color:#fff
    style cpprestsdk fill:#999,stroke:#333,color:#fff
    style libgit2 fill:#999,stroke:#333,color:#fff

    %% Internal platform (green)
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Grafana fill:#7ed321,stroke:#333,color:#fff
    style DSPipelines fill:#7ed321,stroke:#333,color:#fff

    %% External services (yellow)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
