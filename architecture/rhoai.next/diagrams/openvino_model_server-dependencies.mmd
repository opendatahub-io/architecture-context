graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% ═══════════════════════════════════════════
    %% Runtime Libraries (linked, critical)
    %% ═══════════════════════════════════════════
    OVMS -->|"inference engine<br/>(linked library)"| OVRuntime["OpenVINO Runtime<br/>2026.1"]
    OVMS -->|"LLM/VLM pipelines<br/>(linked library)"| OVGenAI["OpenVINO GenAI<br/>2026.1"]
    OVMS -->|"tokenization<br/>(linked library)"| OVTokenizers["OpenVINO Tokenizers<br/>2026.1"]

    %% ═══════════════════════════════════════════
    %% Build Dependencies
    %% ═══════════════════════════════════════════
    OVMS -.->|"build system"| Bazel["Bazel 6.1.1"]

    %% ═══════════════════════════════════════════
    %% Server Framework Dependencies
    %% ═══════════════════════════════════════════
    OVMS -->|"REST server"| Drogon["Drogon<br/>(HTTP framework)"]
    OVMS -->|"gRPC server +<br/>serialization"| GRPC["gRPC / Protobuf"]
    OVMS -->|"metrics"| PromClient["Prometheus<br/>C++ Client"]
    OVMS -->|"C++ utilities"| Boost["Boost 1.68.0"]

    %% ═══════════════════════════════════════════
    %% Storage / Network Client Dependencies
    %% ═══════════════════════════════════════════
    OVMS -->|"Azure model loading"| AzureSDK["Azure Storage<br/>C++ SDK 7.5.0"]
    AzureSDK -->|"HTTP client"| CPPRest["cpprestsdk 2.10.16"]
    OVMS -->|"HTTP client /<br/>model downloads"| Libcurl["libcurl"]
    OVMS -->|"git clone / HF pull"| Libgit2["libgit2"]

    %% ═══════════════════════════════════════════
    %% Processing Dependencies
    %% ═══════════════════════════════════════════
    OVMS -->|"image preprocessing"| OpenCV["OpenCV"]
    OVMS -->|"XML parsing"| Pugixml["pugixml 1.13"]

    %% ═══════════════════════════════════════════
    %% Optional Dependencies
    %% ═══════════════════════════════════════════
    OVMS -.->|"graph pipelines<br/>(optional)"| MediaPipe["MediaPipe"]
    OVMS -.->|"chat templates<br/>(optional)"| Python["Python 3.12 /<br/>Jinja2 3.1.6"]

    %% ═══════════════════════════════════════════
    %% Internal Platform Dependencies
    %% ═══════════════════════════════════════════
    KServe["KServe Controller"] -->|"deploys as<br/>inference container"| OVMS
    KRBP["kube-rbac-proxy"] -->|"auth proxy<br/>sidecar"| OVMS

    %% ═══════════════════════════════════════════
    %% External Service Dependencies (Egress)
    %% ═══════════════════════════════════════════
    OVMS -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    OVMS -->|"model storage<br/>HTTPS/443"| S3["AWS S3"]
    OVMS -->|"model storage<br/>HTTPS/443"| AzureBlob["Azure Blob Storage"]
    OVMS -->|"model storage<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    OVMS -->|"model storage<br/>filesystem"| PVC["PVC / Local Storage"]

    %% ═══════════════════════════════════════════
    %% Platform Integrations (Inbound)
    %% ═══════════════════════════════════════════
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -.->|"scrapes /metrics"| OVMS
    K8s["Kubernetes"] -.->|"health probes"| OVMS

    %% ═══════════════════════════════════════════
    %% Styling
    %% ═══════════════════════════════════════════
    style OVMS fill:#1565c0,stroke:#0d47a1,stroke-width:4px,color:#fff

    %% Intel runtime libraries - blue
    style OVRuntime fill:#0071c5,stroke:#004a80,color:#fff
    style OVGenAI fill:#0071c5,stroke:#004a80,color:#fff
    style OVTokenizers fill:#0071c5,stroke:#004a80,color:#fff

    %% Server framework deps - green
    style Drogon fill:#43a047,stroke:#2e7d32,color:#fff
    style GRPC fill:#43a047,stroke:#2e7d32,color:#fff
    style PromClient fill:#43a047,stroke:#2e7d32,color:#fff
    style Boost fill:#43a047,stroke:#2e7d32,color:#fff

    %% Storage/network client deps - teal
    style AzureSDK fill:#00897b,stroke:#00695c,color:#fff
    style CPPRest fill:#00897b,stroke:#00695c,color:#fff
    style Libcurl fill:#00897b,stroke:#00695c,color:#fff
    style Libgit2 fill:#00897b,stroke:#00695c,color:#fff

    %% Processing deps - amber
    style OpenCV fill:#ff8f00,stroke:#e65100,color:#fff
    style Pugixml fill:#ff8f00,stroke:#e65100,color:#fff

    %% Optional deps - grey dashed
    style MediaPipe fill:#78909c,stroke:#546e7a,color:#fff
    style Python fill:#78909c,stroke:#546e7a,color:#fff

    %% Build deps
    style Bazel fill:#bdbdbd,stroke:#757575,color:#333

    %% Internal platform - purple
    style KServe fill:#7b1fa2,stroke:#4a148c,color:#fff
    style KRBP fill:#c62828,stroke:#b71c1c,color:#fff

    %% External services - orange
    style HFHub fill:#f57c00,stroke:#e65100,color:#fff
    style S3 fill:#f57c00,stroke:#e65100,color:#fff
    style AzureBlob fill:#f57c00,stroke:#e65100,color:#fff
    style GCS fill:#f57c00,stroke:#e65100,color:#fff
    style PVC fill:#e1d5e7,stroke:#9673a6

    %% Monitoring - light blue
    style Prometheus fill:#039be5,stroke:#0277bd,color:#fff
    style K8s fill:#039be5,stroke:#0277bd,color:#fff
