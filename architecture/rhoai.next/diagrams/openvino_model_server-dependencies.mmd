graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (Required)
    OVMS -->|"inference engine<br/>(required)"| OpenVINORT["OpenVINO Runtime<br/>2026.0"]
    OVMS -->|"LLM pipelines<br/>(required)"| OpenVINOGenAI["OpenVINO GenAI<br/>releases/2026/0"]
    OVMS -->|"tokenization<br/>(required)"| OpenVINOTok["OpenVINO Tokenizers<br/>releases/2026/0"]

    %% Framework Dependencies (Required)
    OVMS -->|"HTTP server<br/>(required)"| Drogon["Drogon<br/>(bundled)"]
    OVMS -->|"gRPC framework<br/>(required)"| gRPC["gRPC<br/>(bundled)"]
    OVMS -->|"calculator graphs<br/>(required)"| MediaPipe["MediaPipe<br/>(bundled)"]
    OVMS -->|"serialization<br/>(required)"| ProtoBuf["Protocol Buffers<br/>(bundled)"]

    %% Library Dependencies (Required)
    OVMS -->|"C++ utilities<br/>(required)"| Boost["Boost<br/>1.68.0"]
    OVMS -->|"image preprocessing<br/>(required)"| OpenCV["OpenCV<br/>(bundled)"]
    OVMS -->|"JSON parsing<br/>(required)"| RapidJSON["RapidJSON<br/>(bundled)"]
    OVMS -->|"XML parsing<br/>(required)"| pugixml["pugixml<br/>1.13"]
    OVMS -->|"TLS, checksums<br/>(required)"| OpenSSL["OpenSSL<br/>(system)"]

    %% Conditional Dependencies
    OVMS -.->|"Python nodes<br/>(conditional)"| pybind11["pybind11<br/>(bundled)"]
    OVMS -.->|"Python execution<br/>(conditional)"| Python["Python 3.12<br/>(system)"]
    OVMS -.->|"S3 storage<br/>(conditional)"| AWSSDK["AWS SDK (S3)<br/>(bundled)"]
    OVMS -.->|"GCS storage<br/>(conditional)"| GCSSDK["GCS SDK<br/>(bundled)"]
    OVMS -.->|"Azure storage<br/>(conditional)"| AzureSDK["Azure Storage SDK<br/>cpprestsdk v2.10.16"]
    OVMS -.->|"HF model cloning<br/>(conditional)"| libgit2["libgit2<br/>(bundled)"]
    OVMS -.->|"GGUF downloads<br/>(conditional)"| libcurl["libcurl<br/>(system)"]
    OVMS -.->|"GPU inference<br/>(conditional)"| IntelGPU["Intel GPU Drivers<br/>24.52.32224"]

    %% Internal Platform Dependencies
    KServe["KServe<br/>(InferenceService)"] -->|"deploys as<br/>model runtime"| OVMS
    ServingRuntime["RHOAI<br/>ServingRuntime CR"] -->|"configures"| OVMS

    %% External Service Dependencies
    OVMS -->|"model storage<br/>(s3://)"| S3["Amazon S3"]
    OVMS -->|"model storage<br/>(gs://)"| GCS["Google Cloud Storage"]
    OVMS -->|"model storage<br/>(az://)"| AzureBlob["Azure Blob Storage"]
    OVMS -->|"model storage<br/>(azurefs://)"| AzureFile["Azure File Shares"]
    OVMS -->|"model repos<br/>(git/GGUF)"| HFHub["HuggingFace Hub"]

    %% Integration Points (incoming)
    Prometheus["Prometheus"] -->|"scrapes /metrics"| OVMS
    CustomNodes["Custom Node Libraries<br/>(dlopen/dlsym)"] -.->|"loaded at runtime"| OVMS

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required dependencies
    style OpenVINORT fill:#2d6da3,stroke:#333,color:#fff
    style OpenVINOGenAI fill:#2d6da3,stroke:#333,color:#fff
    style OpenVINOTok fill:#2d6da3,stroke:#333,color:#fff
    style Drogon fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style MediaPipe fill:#999,stroke:#333,color:#fff
    style ProtoBuf fill:#999,stroke:#333,color:#fff
    style Boost fill:#999,stroke:#333,color:#fff
    style OpenCV fill:#999,stroke:#333,color:#fff
    style RapidJSON fill:#999,stroke:#333,color:#fff
    style pugixml fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff

    %% Conditional dependencies
    style pybind11 fill:#ccc,stroke:#666
    style Python fill:#ccc,stroke:#666
    style AWSSDK fill:#ccc,stroke:#666
    style GCSSDK fill:#ccc,stroke:#666
    style AzureSDK fill:#ccc,stroke:#666
    style libgit2 fill:#ccc,stroke:#666
    style libcurl fill:#ccc,stroke:#666
    style IntelGPU fill:#ccc,stroke:#666

    %% Platform
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style AzureFile fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style CustomNodes fill:#e1d5e7,stroke:#9673a6
