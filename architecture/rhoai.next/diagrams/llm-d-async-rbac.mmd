graph TD
    subgraph HelmChart["Helm Chart: async-processor"]
        SA["ServiceAccount<br/>&lt;release&gt;-async-processor"]
    end

    subgraph PodIdentity["Pod Identity Usage"]
        Pod["Async Processor Pod<br/>spec.serviceAccountName"]
    end

    subgraph MetricsAuth["Metrics Endpoint Auth (Optional)"]
        direction TB
        MetricsFlag["--metrics-endpoint-auth flag"]
        ControllerRuntime["controller-runtime<br/>metrics server"]
        TokenReview["Kubernetes TokenReview<br/>API (authn)"]
        SAR["SubjectAccessReview<br/>API (authz)"]

        MetricsFlag -->|enables| ControllerRuntime
        ControllerRuntime -->|validates token via| TokenReview
        ControllerRuntime -->|checks permissions via| SAR
    end

    subgraph SecretsAccess["Secrets (Volume Mounts / Env)"]
        RedisCreds["redis-creds<br/>(Opaque)<br/>Redis connection URL<br/>Manual / pre-existing"]
        RedisAuto["&lt;release&gt;-redis<br/>(Opaque, optional)<br/>Auto-created from ap.redis.url<br/>Helm chart"]
        TLSSecret["TLS Secret<br/>(kubernetes.io/tls, optional)<br/>CA cert, client cert, client key<br/>Manual / cert-manager"]
    end

    subgraph NoRBAC["No Explicit RBAC Defined"]
        NoClusterRole["No ClusterRole"]
        NoRole["No Role"]
        NoRoleBinding["No RoleBinding"]
        NoClusterRoleBinding["No ClusterRoleBinding"]
    end

    SA -->|mounted in| Pod
    Pod -->|uses SA token for| ControllerRuntime
    Pod -->|mounts| RedisCreds
    Pod -->|mounts| RedisAuto
    Pod -->|mounts| TLSSecret

    subgraph AuthEndpoints["Authentication & Authorization Summary"]
        MetricsEndpoint["/metrics (GET)<br/>Auth: K8s TokenReview + SAR<br/>Enforcement: controller-runtime<br/>Policy: Optional (configurable)"]
        IGWEndpoint["IGW Requests (POST)<br/>Auth: None / mTLS client cert<br/>Enforcement: Inference Gateway<br/>Policy: TLS config via --tls-* flags"]
    end

    Pod -->|exposes| MetricsEndpoint
    Pod -->|sends to| IGWEndpoint
    TLSSecret -->|provides certs for| IGWEndpoint

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style RedisCreds fill:#e74c3c,stroke:#333,color:#fff
    style RedisAuto fill:#e74c3c,stroke:#333,color:#fff
    style TLSSecret fill:#e74c3c,stroke:#333,color:#fff
    style NoClusterRole fill:#f5f5f5,stroke:#ccc,color:#999
    style NoRole fill:#f5f5f5,stroke:#ccc,color:#999
    style NoRoleBinding fill:#f5f5f5,stroke:#ccc,color:#999
    style NoClusterRoleBinding fill:#f5f5f5,stroke:#ccc,color:#999
    style MetricsEndpoint fill:#fff2cc,stroke:#d6b656
    style IGWEndpoint fill:#fff2cc,stroke:#d6b656
    style ControllerRuntime fill:#9b59b6,stroke:#333,color:#fff
    style TokenReview fill:#9b59b6,stroke:#333,color:#fff
    style SAR fill:#9b59b6,stroke:#333,color:#fff
