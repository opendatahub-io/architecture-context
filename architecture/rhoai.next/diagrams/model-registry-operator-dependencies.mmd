graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (Required)
    MRO -->|"operator framework"| CR["controller-runtime<br/>v0.23.3"]
    MRO -->|"webhook TLS certs"| CertMgr["cert-manager<br/>v1.0+"]
    MRO -->|"object comparison"| ObjMatch["k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"OpenShift types"| OSAPI["openshift/api<br/>v0.0.0-20260320"]

    %% External Dependencies (Optional)
    MRO -.->|"conditional import"| Istio["istio.io/client-go<br/>v1.29.2"]
    MRO -.->|"auto-provisioned DB"| Postgres["PostgreSQL 16<br/>sclorg/postgresql-16"]

    %% Internal RHOAI Dependencies
    MRO -->|"CRD Watch<br/>(catalog owner ref)"| PlatformMR["ModelRegistry<br/>Component CR<br/>(platform.opendatahub.io)"]
    MRO -->|"CRD Watch<br/>(admin groups)"| AuthCR["Auth CR<br/>(services.platform.opendatahub.io)"]
    MRO -->|"deployed by<br/>kustomize overlay"| PlatformOp["RHOAI Platform<br/>Operator"]

    %% Container Images Deployed
    MRO -->|"deploys (data plane)"| MRImage["model-registry<br/>REST service"]
    MRO -->|"injects (sidecar)"| KRBP["kube-rbac-proxy"]
    MRO -->|"catalog init container"| CatalogData["odh-model-metadata<br/>-collection"]
    MRO -->|"async upload job"| AsyncJob["model-registry-job<br/>-async-upload"]

    %% Integration Points (consume MRO)
    MRO -->|"Route creation"| Routes["OpenShift Router<br/>(route.openshift.io)"]
    MRO -->|"user groups"| Groups["OpenShift Groups<br/>(user.openshift.io)"]
    MRO -->|"cluster domain"| IngressCfg["OpenShift Ingress<br/>(config.openshift.io)"]
    MRO -->|"CRD migration"| SVM["StorageVersionMigration<br/>(migration.k8s.io)"]

    %% Monitoring
    Prometheus["Prometheus<br/>ServiceMonitor"] -->|"scrapes metrics<br/>8443/TCP"| MRO
    MRO -->|"TLS cert provisioning"| ServingCert["OpenShift<br/>serving-cert-signer"]

    %% Database backends
    MRImage -->|"metadata storage<br/>5432/TCP"| PGBackend["PostgreSQL Backend"]
    MRImage -.->|"alt storage<br/>3306/TCP"| MySQLBackend["MySQL Backend"]

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style CR fill:#999,stroke:#333,color:#fff
    style CertMgr fill:#999,stroke:#333,color:#fff
    style ObjMatch fill:#999,stroke:#333,color:#fff
    style OSAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#bbb,stroke:#333,color:#333
    style Postgres fill:#bbb,stroke:#333,color:#333

    style PlatformMR fill:#7ed321,stroke:#333,color:#000
    style AuthCR fill:#7ed321,stroke:#333,color:#000
    style PlatformOp fill:#7ed321,stroke:#333,color:#000

    style MRImage fill:#50c878,stroke:#333,color:#000
    style KRBP fill:#50c878,stroke:#333,color:#000
    style CatalogData fill:#50c878,stroke:#333,color:#000
    style AsyncJob fill:#50c878,stroke:#333,color:#000

    style Routes fill:#f5a623,stroke:#333,color:#000
    style Groups fill:#f5a623,stroke:#333,color:#000
    style IngressCfg fill:#f5a623,stroke:#333,color:#000
    style SVM fill:#f5a623,stroke:#333,color:#000
    style Prometheus fill:#f5a623,stroke:#333,color:#000
    style ServingCert fill:#f5a623,stroke:#333,color:#000

    style PGBackend fill:#dae8fc,stroke:#6c8ebf,color:#000
    style MySQLBackend fill:#dae8fc,stroke:#6c8ebf,color:#000
