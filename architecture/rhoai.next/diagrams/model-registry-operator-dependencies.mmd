graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (Required)
    MRO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"object comparison"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"webhook TLS certs"| CertManager["cert-manager<br/>v1.0+"]
    MRO -->|"OpenShift types<br/>(Route, User, Config)"| OpenshiftAPI["openshift/api<br/>v0.0.0-20260320"]

    %% External Dependencies (Optional)
    MRO -.->|"conditionally imported<br/>(Istio types)"| IstioClient["istio.io/client-go<br/>v1.29.2"]
    MRO -.->|"auto-provisioned DB"| PostgreSQL16["PostgreSQL 16<br/>sclorg/postgresql-16"]

    %% Internal Platform Dependencies
    MRO -->|"catalog owner ref"| PlatformMR["components.platform.<br/>opendatahub.io<br/>ModelRegistry CR"]
    MRO -->|"admin groups"| PlatformAuth["services.platform.<br/>opendatahub.io<br/>Auth CR"]
    MRO -->|"deployed by"| PlatformOp["opendatahub-operator<br/>/ rhods-operator"]

    %% Runtime Dependencies (Container Images)
    MRO -->|"deploys (data plane)"| RegistryImage["model-registry<br/>REST service"]
    MRO -->|"injects sidecar"| KubeRBACProxy["kube-rbac-proxy"]

    %% Infrastructure Dependencies
    MRO -->|"cluster domain"| IngressConfig["config.openshift.io<br/>Ingress"]
    MRO -->|"Route creation"| OpenshiftRouter["OpenShift Router"]
    MRO -->|"proxy TLS certs"| ServingCerts["OpenShift<br/>serving-cert-signer"]
    MRO -->|"reconciliation,<br/>RBAC, CRD watches"| K8sAPI["Kubernetes<br/>API Server"]

    %% Integration Points (consumed by)
    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| MRO
    CatalogCMs["ConfigMaps<br/>(catalog-source labeled)"] -->|"discovered by<br/>label selector"| MRO

    %% External Data Services
    MRO -.->|"metadata storage<br/>5432/TCP"| ExtPostgres["External<br/>PostgreSQL"]
    MRO -.->|"metadata storage<br/>3306/TCP"| ExtMySQL["External<br/>MySQL"]

    %% CRD Version Migration
    MRO -->|"storage migration<br/>v1alpha1 → v1beta1"| StorageVersionMig["migration.k8s.io<br/>StorageVersionMigration"]

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style ObjectMatcher fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OpenshiftAPI fill:#999,stroke:#333,color:#fff

    %% Optional external
    style IstioClient fill:#bbb,stroke:#333,color:#333
    style PostgreSQL16 fill:#bbb,stroke:#333,color:#333

    %% Internal platform
    style PlatformMR fill:#7ed321,stroke:#333,color:#333
    style PlatformAuth fill:#7ed321,stroke:#333,color:#333
    style PlatformOp fill:#7ed321,stroke:#333,color:#333

    %% Runtime images
    style RegistryImage fill:#7ed321,stroke:#333,color:#333
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#333

    %% Infrastructure
    style IngressConfig fill:#e8e8e8,stroke:#333
    style OpenshiftRouter fill:#e8e8e8,stroke:#333
    style ServingCerts fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style StorageVersionMig fill:#e8e8e8,stroke:#333

    %% Integration
    style Prometheus fill:#f5a623,stroke:#333,color:#333
    style CatalogCMs fill:#f5a623,stroke:#333,color:#333

    %% External data
    style ExtPostgres fill:#f8cecc,stroke:#b85450
    style ExtMySQL fill:#f8cecc,stroke:#b85450
