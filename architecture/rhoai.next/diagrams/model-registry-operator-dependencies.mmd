graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies
    MRO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"resource diffing"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"database backend"| PostgreSQL["PostgreSQL 16"]
    MRO -.->|"optional: OpenShift APIs"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260320"]
    MRO -.->|"legacy: being phased out"| IstioClient["istio.io/client-go<br/>v1.29.2"]

