graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies
    MRO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"resource diff"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"database backend"| PostgreSQL["PostgreSQL 16<br/>(auto-provisioned or<br/>user-provided)"]
    MRO -.->|"legacy, phasing out"| IstioClient["istio.io/client-go<br/>v1.29.2"]
    MRO -.->|"optional, runtime detect"| OpenShiftAPI["openshift/api<br/>(Route, User, Ingress)"]

    %% Internal Platform Dependencies
    MRO -->|"deployed by"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    MRO -->|"deploys image"| MRImage["model-registry<br/>REST API image"]
    MRO -->|"injects sidecar"| KRBACProxy["kube-rbac-proxy<br/>image"]
    MRO -->|"deploys image"| PGImage["PostgreSQL<br/>(sclorg) image"]
    MRO -->|"reads admin groups"| PlatformAuth["Platform Auth CR<br/>services.platform.<br/>opendatahub.io"]
    MRO -->|"owner reference"| PlatformMR["Platform ModelRegistry CR<br/>components.platform.<br/>opendatahub.io"]
    MRO -->|"init container"| CatalogData["odh-model-metadata-<br/>collection image"]

    %% Kubernetes APIs consumed
    MRO -->|"CRUD operations"| K8sAPI["Kubernetes<br/>API Server"]
    MRO -->|"storage migration"| MigrationAPI["StorageVersionMigration<br/>API (migration.k8s.io)"]
    MRO -->|"CRD versions"| CRDApi["CRD API<br/>(apiextensions.k8s.io)"]

    %% Integration Points (other components → operator)
    Dashboard["ODH Dashboard"] -.->|"UI management"| MRO
    Pipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| MRO

    %% ConfigMap discovery
    CatalogCMs["Labeled ConfigMaps<br/>opendatahub.io/<br/>catalog-source=true"] -->|"discovered by"| MRO

