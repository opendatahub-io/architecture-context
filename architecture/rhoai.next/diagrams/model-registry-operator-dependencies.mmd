graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (required)
    MRO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"object comparison"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"webhook TLS certs"| CertManager["cert-manager<br/>v1.0+"]
    MRO -->|"OpenShift API types"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260320"]

    %% External Dependencies (optional)
    MRO -.->|"Istio types<br/>(conditionally imported)"| IstioClient["istio.io/client-go<br/>v1.29.2"]
    MRO -.->|"auto-provisioned DB"| PostgreSQL16["PostgreSQL 16<br/>sclorg/postgresql-16"]

    %% Internal RHOAI Platform Dependencies
    MRO -->|"CRD Watch<br/>(catalog owner ref)"| PlatformMR["components.platform<br/>.opendatahub.io<br/>ModelRegistry"]
    MRO -->|"CRD Watch<br/>(admin groups)"| PlatformAuth["services.platform<br/>.opendatahub.io<br/>Auth"]
    MRO -->|"deployed by<br/>(kustomize overlay)"| PlatformOperator["opendatahub-operator<br/>/ rhods-operator"]

    %% Container Images Deployed
    MRO -->|"deploys<br/>(data plane)"| RegistryImage["model-registry<br/>REST service"]
    MRO -->|"injects<br/>(auth sidecar)"| KubeRBACProxy["kube-rbac-proxy"]
    MRO -->|"catalog data<br/>(init container)"| CatalogData["odh-model-metadata<br/>-collection"]

    %% Integration Points (consumed by others)
    Dashboard["ODH Dashboard"] -->|"UI management"| MRO
    Pipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| MRO

    %% External Services
    MRO -->|"reconciliation<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    MRO -->|"Route creation"| OpenShiftRouter["OpenShift<br/>Router"]
    MRO -->|"serving certs<br/>(annotation-driven)"| ServingCerts["OpenShift Serving<br/>Cert Signer"]
    MRO -->|"metrics scraping<br/>8443/TCP HTTPS"| Prometheus["Prometheus<br/>(ServiceMonitor)"]

    %% Database backends
    RegistryImage -->|"metadata storage<br/>5432/TCP"| PostgreSQLExt["PostgreSQL<br/>(external)"]
    RegistryImage -.->|"alternative storage<br/>3306/TCP"| MySQLExt["MySQL<br/>(external)"]

    %% CRD storage migration
    MRO -->|"storage version<br/>migration"| MigrationAPI["migration.k8s.io<br/>StorageVersionMigration"]

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style ObjectMatcher fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style IstioClient fill:#ccc,stroke:#999,color:#333
    style PostgreSQL16 fill:#ccc,stroke:#999,color:#333

    %% Internal RHOAI
    style PlatformMR fill:#7ed321,stroke:#333,color:#fff
    style PlatformAuth fill:#7ed321,stroke:#333,color:#fff
    style PlatformOperator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff

    %% Container images
    style RegistryImage fill:#4a90e2,stroke:#333,color:#fff
    style KubeRBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style CatalogData fill:#4a90e2,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OpenShiftRouter fill:#f5a623,stroke:#333,color:#fff
    style ServingCerts fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQLExt fill:#f5a623,stroke:#333,color:#fff
    style MySQLExt fill:#f5a623,stroke:#333,color:#fff
