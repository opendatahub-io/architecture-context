graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (Go modules / runtime)
    MRO -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"OpenShift types"| OpenshiftAPI["openshift/api<br/>v0.0.0-20260320"]
    MRO -->|"scheme compat"| IstioClient["istio/client-go<br/>v1.29.2"]
    MRO -->|"resource diff"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]
    MRO -.->|"TLS certs (optional)"| CertManager["cert-manager"]

    %% Internal Platform Dependencies
    MRO -->|"owner ref lookup"| PlatformMR["components.platform<br/>.opendatahub.io<br/>ModelRegistry"]
    MRO -->|"admin groups"| PlatformAuth["services.platform<br/>.opendatahub.io<br/>Auth"]
    MRO -->|"deployed by"| PlatformOp["opendatahub-operator<br/>/ rhods-operator"]
    MRO -->|"ingress domain"| OSIngress["OpenShift Ingress<br/>(config.openshift.io)"]

    %% Container Image Dependencies
    MRO -->|"main container"| RESTImage["model-registry<br/>REST image<br/>8080/TCP HTTP"]
    MRO -->|"auth sidecar"| KRBPImage["kube-rbac-proxy<br/>image<br/>8443/TCP HTTPS"]
    MRO -->|"auto-provisioned DB"| PostgresImage["PostgreSQL 16<br/>image<br/>5432/TCP"]
    MRO -->|"catalog init data"| CatalogDataImage["odh-model-metadata<br/>-collection image"]
    MRO -->|"async upload jobs"| AsyncUploadImage["model-registry-job<br/>-async-upload image"]

    %% Integration Points (components consuming this operator)
    Dashboard["ODH Dashboard"] -->|"routing annotations"| MRO
    MRO -->|"creates Routes"| OSRouter["OpenShift Router"]
    MRO -->|"creates Groups"| OSGroups["OpenShift Groups<br/>(user.openshift.io)"]
    MRO -->|"storage migration"| SVM["StorageVersionMigration<br/>(migration.k8s.io)"]

    %% External Services
    MRO -->|"metadata storage"| ExtPostgres["External PostgreSQL<br/>5432/TCP"]
    MRO -->|"alt storage"| ExtMySQL["External MySQL<br/>3306/TCP"]
    MRO -->|"CRUD + auth"| K8sAPI["Kubernetes API<br/>6443/TCP"]
    MRO -->|"label discovery"| CatalogCMs["ConfigMaps<br/>(catalog-source label)"]

    %% Styling
    style MRO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

