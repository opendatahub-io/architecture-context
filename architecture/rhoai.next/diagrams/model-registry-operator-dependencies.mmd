graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (libraries/frameworks)
    MRO -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.24.1"]
    MRO -->|"Gateway API types"| GatewayAPI["gateway-api<br/>v1.5.1"]
    MRO -->|"legacy v1alpha1 types"| IstioClient["istio.io/client-go<br/>v1.30.1"]
    MRO -->|"Route, User, Config types"| OpenShiftAPI["openshift/api"]
    MRO -->|"TLS profile integration"| OpenShiftCRCommon["openshift/controller-<br/>runtime-common"]
    MRO -->|"idempotent patches"| ObjectMatcher["k8s-objectmatcher<br/>v1.8.0"]

    %% Internal Platform Dependencies
    MRO -->|"deploys operator"| RhodsOperator["rhods-operator /<br/>opendatahub-operator"]
    MRO -->|"reads admin groups"| AuthCR["Auth CR<br/>(services.platform.<br/>opendatahub.io)"]
    MRO -->|"reads owner refs"| PlatformMRCR["Platform ModelRegistry<br/>(components.platform.<br/>opendatahub.io)"]

    %% Infrastructure Dependencies
    MRO -->|"cluster domain"| IngressConfig["config.openshift.io<br/>/Ingress"]
    MRO -->|"TLS profile watch"| APIServerConfig["config.openshift.io<br/>/APIServer"]
    MRO -->|"CRD migration"| SVMigration["StorageVersionMigration<br/>(migration.k8s.io)"]

    %% Runtime Dependencies (container images)
    MRO -->|"REST API image"| MRImage["model-registry<br/>quay.io/opendatahub/<br/>model-registry"]
    MRO -->|"auth sidecar image"| KRBPImage["kube-rbac-proxy<br/>quay.io/openshift/<br/>origin-kube-rbac-proxy"]
    MRO -->|"auto-provisioned DB"| PostgresImage["PostgreSQL 16<br/>quay.io/sclorg/<br/>postgresql-16-c10s"]
    MRO -->|"catalog data"| CatalogImage["odh-model-metadata-<br/>collection"]

    %% Ingress Dependencies
    MRO -->|"external Routes"| OSRouter["OpenShift Router"]
    MRO -->|"HTTPRoute parentRef"| DSGateway["Data Science Gateway<br/>(gateway.networking.k8s.io)"]

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -->|"UI management"| MRO
    Pipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| MRO

