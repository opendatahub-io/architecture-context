graph TB
    subgraph NotebooksRepo["Notebooks Repository (Image Build System)"]
        direction TB

        subgraph JupyterImages["Jupyter Workbench Images"]
            MinCPU["Jupyter Minimal<br/>CPU"]
            MinCUDA["Jupyter Minimal<br/>CUDA 13.0"]
            MinROCm["Jupyter Minimal<br/>ROCm 7.1"]
            DS["Jupyter DataScience<br/>CPU"]
            PyTorch["Jupyter PyTorch<br/>CUDA 13.0"]
            PyTorchLLM["Jupyter PyTorch+<br/>LLMCompressor<br/>CUDA 13.0"]
            TF["Jupyter TensorFlow<br/>CUDA 12.9"]
            TrustyAI["Jupyter TrustyAI<br/>CPU"]
            ROCmPT["Jupyter ROCm<br/>PyTorch"]
            ROCmTF["Jupyter ROCm<br/>TensorFlow"]
        end

        subgraph CodeServerImage["Code-Server Image"]
            CS["Code-Server<br/>v4.106.3"]
            Nginx["nginx proxy<br/>80/TCP"]
            HTTPD["httpd CGI<br/>8080/TCP"]
            CGI["access.cgi<br/>(kernel API emulation)"]
            CS --- Nginx
            Nginx --- HTTPD
            HTTPD --- CGI
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            RTMin["Runtime Minimal<br/>CPU"]
            RTDS["Runtime DataScience<br/>CPU"]
            RTPyTorch["Runtime PyTorch<br/>CUDA"]
            RTLLM["Runtime PyTorch+<br/>LLMCompressor<br/>CUDA"]
            RTTF["Runtime TensorFlow<br/>CUDA"]
            RTROCmPT["Runtime ROCm<br/>PyTorch"]
            RTROCmTF["Runtime ROCm<br/>TensorFlow"]
        end

        subgraph BuildStage["Build-Stage Components"]
            MongoCLI["mongocli<br/>(Go, FIPS)"]
            JLAddons["JupyterLab Addons<br/>(TypeScript)"]
        end
    end

    %% Base images
    AIPCC_CPU["AIPCC CPU Base<br/>RHEL 9.6 + Python 3.12"]
    AIPCC_CUDA["AIPCC CUDA Base<br/>RHEL 9.6 + CUDA 13.0"]
    AIPCC_ROCm["AIPCC ROCm Base<br/>RHEL 9.6 + ROCm 7.1"]

    AIPCC_CPU -->|base image| MinCPU
    AIPCC_CPU -->|base image| DS
    AIPCC_CPU -->|base image| TrustyAI
    AIPCC_CPU -->|base image| CS
    AIPCC_CPU -->|base image| RTMin
    AIPCC_CPU -->|base image| RTDS
    AIPCC_CUDA -->|base image| MinCUDA
    AIPCC_CUDA -->|base image| PyTorch
    AIPCC_CUDA -->|base image| PyTorchLLM
    AIPCC_CUDA -->|base image| TF
    AIPCC_CUDA -->|base image| RTPyTorch
    AIPCC_CUDA -->|base image| RTLLM
    AIPCC_CUDA -->|base image| RTTF
    AIPCC_ROCm -->|base image| MinROCm
    AIPCC_ROCm -->|base image| ROCmPT
    AIPCC_ROCm -->|base image| ROCmTF
    AIPCC_ROCm -->|base image| RTROCmPT
    AIPCC_ROCm -->|base image| RTROCmTF

    %% Build outputs
    Konflux["Konflux / Tekton<br/>Build Pipeline"]
    Hermeto["Hermeto / Cachi2<br/>Dependency Prefetch"]
    QuayIO["Quay.io Registry"]

    Hermeto -->|hermetic deps| Konflux
    Konflux -->|builds| NotebooksRepo
    NotebooksRepo -->|pushes images| QuayIO

    %% Downstream consumers
    QuayIO -->|ImageStream import| ISController["OpenShift<br/>ImageStream Controller"]
    ISController -->|populates| ImageStreams["ImageStreams<br/>(18 streams, 4 tags each)"]
    ImageStreams -->|discovered by| Dashboard["ODH Dashboard"]
    ImageStreams -->|deployed by| Operator["rhods-operator"]

    Dashboard -->|user selects workbench| NotebookCR["Notebook CR"]
    NotebookCR -->|watched by| NBController["odh-notebook-controller"]
    NBController -->|creates pod with| WorkbenchPod["Workbench Pod<br/>(image + kube-rbac-proxy sidecar)"]

    %% Styling
    style NotebooksRepo fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterImages fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style CodeServerImage fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style RuntimeImages fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style BuildStage fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style AIPCC_CPU fill:#e8e8e8,stroke:#666
    style AIPCC_CUDA fill:#e8e8e8,stroke:#666
    style AIPCC_ROCm fill:#e8e8e8,stroke:#666
    style Konflux fill:#e8e8e8,stroke:#666
    style Hermeto fill:#e8e8e8,stroke:#666
    style QuayIO fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style NBController fill:#7ed321,stroke:#333
    style WorkbenchPod fill:#4a90e2,stroke:#333,color:#fff
