graph TB
    subgraph BuildSystem["Build System (Konflux CI)"]
        direction TB
        Makefile["Makefile<br/>(build orchestration)"]
        BuildInputs["buildinputs (Go CLI)<br/>Dockerfile → LLB parser"]
        Makefile --> BuildInputs
    end

    subgraph JupyterImages["Jupyter Workbench Images"]
        direction TB
        Minimal["jupyter/minimal<br/>Python 3.12, JupyterLab 4.5<br/>Port: 8888/TCP"]
        DataScience["jupyter/datascience<br/>NumPy, Pandas, Elyra, DB connectors"]
        PyTorch["jupyter/pytorch<br/>PyTorch 2.10 + CUDA 13.0"]
        PyTorchLLM["jupyter/pytorch+llmcompressor<br/>LLM quantization"]
        TensorFlow["jupyter/tensorflow<br/>TensorFlow + CUDA 12.9"]
        TrustyAI["jupyter/trustyai<br/>TrustyAI + Java 17"]
        ROCmPyTorch["jupyter/rocm/pytorch<br/>PyTorch + ROCm 7.1"]
        ROCmTF["jupyter/rocm/tensorflow<br/>TensorFlow + ROCm 7.1"]

        Minimal --> DataScience
        DataScience --> PyTorch
        DataScience --> PyTorchLLM
        DataScience --> TensorFlow
        DataScience --> TrustyAI
        DataScience --> ROCmPyTorch
        DataScience --> ROCmTF
    end

    subgraph NonJupyterImages["Non-Jupyter Workbench Images"]
        direction TB
        CodeServer["codeserver<br/>VS Code (code-server 4.106.3)<br/>Port: 8787/TCP + 80/TCP nginx"]
        RStudioCPU["rstudio (CPU)<br/>RStudio Server, R 4.5.1<br/>Port: 8787/TCP + 80/TCP nginx"]
        RStudioCUDA["rstudio (CUDA)<br/>RStudio + CUDA 12.8<br/>Port: 8787/TCP + 80/TCP nginx"]
    end

    subgraph RuntimeImages["Pipeline Runtime Images"]
        direction TB
        RTMinimal["runtimes/minimal<br/>Lightweight Python"]
        RTDataSci["runtimes/datascience<br/>Data science packages"]
        RTPyTorch["runtimes/pytorch<br/>PyTorch CUDA"]
        RTPyTorchLLM["runtimes/pytorch+llmcompressor"]
        RTTF["runtimes/tensorflow<br/>TensorFlow CUDA"]
        RTROCmPT["runtimes/rocm-pytorch"]
        RTROCmTF["runtimes/rocm-tensorflow"]
    end

    subgraph Manifests["Kustomize Manifests"]
        direction TB
        RHOAIManifests["manifests/rhoai/<br/>ImageStreams + BuildConfig<br/>114 replacement rules"]
        ODHManifests["manifests/odh/<br/>ImageStreams (pre-built)"]
    end

    subgraph IdleCulling["Idle Culling Stack<br/>(Code-Server & RStudio only)"]
        direction TB
        Nginx["nginx (port 80)<br/>Reverse proxy + JSON access log"]
        Httpd["httpd (port 8080)<br/>CGI gateway"]
        CGI["access.cgi<br/>Emulates /api/kernels/"]
        Nginx --> Httpd
        Httpd --> CGI
    end

    %% Build flow
    BuildSystem -->|builds| JupyterImages
    BuildSystem -->|builds| NonJupyterImages
    BuildSystem -->|builds| RuntimeImages

    %% Manifest flow
    Manifests -->|defines ImageStreams for| JupyterImages
    Manifests -->|defines ImageStreams for| NonJupyterImages
    Manifests -->|defines ImageStreams for| RuntimeImages

    %% Idle culling integration
    CodeServer -->|uses| IdleCulling
    RStudioCPU -->|uses| IdleCulling
    RStudioCUDA -->|uses| IdleCulling

    %% External consumers
    Operator["rhods-operator /<br/>opendatahub-operator"]
    Dashboard["ODH Dashboard"]
    NotebookCtrl["ODH Notebook Controller"]
    DSP["Data Science Pipelines"]

    Manifests -->|deployed by| Operator
    Operator -->|creates| ImageStreams["ImageStream CRs"]
    ImageStreams -->|discovered by| Dashboard
    Dashboard -->|user selects image| NotebookCtrl
    NotebookCtrl -->|runs pod from| JupyterImages
    NotebookCtrl -->|runs pod from| NonJupyterImages
    DSP -->|executes pipeline step with| RuntimeImages

