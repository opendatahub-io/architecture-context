graph TB
    subgraph Notebooks["Notebooks Component (Container Image Factory)"]
        direction TB

        subgraph JupyterImages["JupyterLab Workbenches"]
            Minimal["jupyter/minimal<br/>Python 3.12, JupyterLab 4.5<br/>Port: 8888/TCP"]
            DataScience["jupyter/datascience<br/>NumPy, Pandas, Elyra<br/>DB connectors"]
            PyTorch["jupyter/pytorch<br/>PyTorch 2.10 + CUDA 13.0"]
            PyTorchLLM["jupyter/pytorch+llmcompressor<br/>LLM quantization"]
            TensorFlow["jupyter/tensorflow<br/>TensorFlow + CUDA 12.9"]
            TrustyAI["jupyter/trustyai<br/>AI Explainability + Java 17"]
            RocmPyTorch["jupyter/rocm/pytorch<br/>PyTorch + ROCm 7.1"]
            RocmTF["jupyter/rocm/tensorflow<br/>TensorFlow + ROCm 7.1"]
        end

        subgraph AltWorkbenches["Alternative Workbenches"]
            CodeServer["codeserver<br/>VS Code (code-server 4.106.3)<br/>nginx + CGI idle culling<br/>Port: 8787/TCP"]
            RStudioCPU["rstudio (CPU)<br/>RStudio Server, R 4.5<br/>nginx + CGI idle culling<br/>Port: 8787/TCP"]
            RStudioCUDA["rstudio (CUDA)<br/>RStudio + CUDA 12.8<br/>Port: 8787/TCP"]
        end

        subgraph Runtimes["Elyra Pipeline Runtimes"]
            RTMinimal["runtimes/minimal"]
            RTDataScience["runtimes/datascience"]
            RTPyTorch["runtimes/pytorch"]
            RTPyTorchLLM["runtimes/pytorch+llmcompressor"]
            RTTensorFlow["runtimes/tensorflow"]
            RTRocmPT["runtimes/rocm-pytorch"]
            RTRocmTF["runtimes/rocm-tensorflow"]
        end

        subgraph BuildTools["Build Tooling"]
            BuildInputs["scripts/buildinputs<br/>Go CLI: Dockerfile → LLB<br/>dependency extraction"]
            Manifests["manifests/<br/>Kustomize ImageStreams<br/>114 replacement rules"]
        end
    end

    %% Image Hierarchy
    Minimal -->|extends| DataScience
    DataScience -->|extends| PyTorch
    DataScience -->|extends| TensorFlow
    DataScience -->|extends| TrustyAI
    DataScience -->|extends| PyTorchLLM

    %% External consumers
    Operator["rhods-operator /<br/>opendatahub-operator"]
    Dashboard["ODH Dashboard"]
    NotebookCtrl["ODH Notebook Controller"]
    Culler["Notebook Controller Culler"]
    DSP["Data Science Pipelines"]

    Manifests -->|"ImageStream deploy"| Operator
    Operator -->|"creates ImageStreams"| Dashboard
    Dashboard -->|"reads annotations"| JupyterImages
    Dashboard -->|"reads annotations"| AltWorkbenches
    NotebookCtrl -->|"resolves image,<br/>injects sidecar"| JupyterImages
    NotebookCtrl -->|"resolves image,<br/>injects sidecar"| AltWorkbenches
    Culler -->|"GET /api/kernels/"| JupyterImages
    Culler -->|"GET /api/kernels/<br/>(via nginx+CGI)"| AltWorkbenches
    DSP -->|"launches runtime pods"| Runtimes

    %% Build pipeline
    Konflux["Konflux CI<br/>Hermetic Builds"]
    Registry["Container Registry<br/>registry.redhat.io"]

    Konflux -->|"builds images"| Notebooks
    Konflux -->|"pushes"| Registry
    BuildInputs -->|"extracts deps"| Konflux

    %% Styling
    style Notebooks fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style JupyterImages fill:#d5e8d4,stroke:#82b366
    style AltWorkbenches fill:#fff2cc,stroke:#d6b656
    style Runtimes fill:#f8cecc,stroke:#b85450
    style BuildTools fill:#e1d5e7,stroke:#9673a6
    style Operator fill:#dae8fc,stroke:#6c8ebf
    style Dashboard fill:#dae8fc,stroke:#6c8ebf
    style NotebookCtrl fill:#dae8fc,stroke:#6c8ebf
    style Culler fill:#dae8fc,stroke:#6c8ebf
    style DSP fill:#dae8fc,stroke:#6c8ebf
    style Konflux fill:#f5f5f5,stroke:#666
    style Registry fill:#f5f5f5,stroke:#666
