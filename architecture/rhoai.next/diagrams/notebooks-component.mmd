graph TB
    subgraph NotebooksRepo["Notebooks Repository (Container Image Factory)"]
        direction TB

        subgraph BaseImages["Base Images"]
            BaseCPU["Base CPU Image<br/>UBI9 + Python 3.12"]
            BaseCUDA["Base CUDA Image<br/>UBI9 + Python 3.12 + CUDA 12.8"]
            BaseROCm["Base ROCm Image<br/>UBI9 + Python 3.12 + ROCm 6.3+"]
        end

        subgraph JupyterWorkbenches["Jupyter Workbench Images"]
            JupyterMinimal["jupyter-minimal<br/>CPU / CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterDS["jupyter-datascience<br/>CPU<br/>+ mongocli, Elyra"]
            JupyterPyTorch["jupyter-pytorch<br/>CUDA / ROCm"]
            JupyterTF["jupyter-tensorflow<br/>CUDA / ROCm"]
            JupyterTrustyAI["jupyter-trustyai<br/>CPU<br/>+ Java 17"]
            JupyterLLM["jupyter-pytorch-llmcompressor<br/>CUDA"]
        end

        subgraph OtherWorkbenches["Other Workbench Images"]
            CodeServer["code-server<br/>CPU<br/>VS Code + nginx proxy<br/>Port: 8888/TCP"]
            RStudio["rstudio<br/>CPU / CUDA<br/>RStudio Server + nginx<br/>Port: 8888/TCP"]
        end

        subgraph PipelineRuntimes["Pipeline Runtime Images"]
            RTMinimal["runtime-minimal<br/>CPU"]
            RTDatascience["runtime-datascience<br/>CPU"]
            RTPyTorch["runtime-pytorch<br/>CUDA / ROCm"]
            RTTF["runtime-tensorflow<br/>CUDA / ROCm"]
            RTLLM["runtime-pytorch-llmcompressor<br/>CUDA"]
        end

        subgraph BuildSystem["Build System"]
            Konflux["Konflux / Tekton<br/>102 PipelineRuns"]
            Cachi2["cachi2 / Hermeto<br/>Hermetic Prefetch"]
            LockFiles["Lock Files<br/>rpms.lock.yaml<br/>pylock.*.toml<br/>go.sum<br/>package-lock.json"]
        end

        subgraph Manifests["ImageStream Manifests"]
            KustomizeRHOAI["manifests/rhoai/<br/>3 version tags (N, N-1, N-2)"]
            KustomizeODH["manifests/odh/<br/>2 version tags (N, N-1)"]
        end
    end

    %% Image inheritance chain
    BaseCPU --> JupyterMinimal
    BaseCUDA --> JupyterMinimal
    BaseROCm --> JupyterMinimal
    JupyterMinimal --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTF
    JupyterDS --> JupyterTrustyAI
    JupyterPyTorch --> JupyterLLM

    BaseCPU --> RTMinimal
    RTMinimal --> RTDatascience
    BaseCUDA --> RTPyTorch
    BaseCUDA --> RTTF
    BaseCUDA --> RTLLM

    %% Build system connections
    LockFiles -->|prefetched deps| Cachi2
    Cachi2 -->|zero network builds| Konflux
    Konflux -->|builds| JupyterMinimal
    Konflux -->|builds| CodeServer
    Konflux -->|builds| RStudio
    Konflux -->|builds| RTMinimal

    %% External consumers
    Konflux -->|pushes images| Registry["Container Registry<br/>registry.redhat.io<br/>quay.io"]
    KustomizeRHOAI -->|creates| ImageStreams["OpenShift ImageStreams"]
    KustomizeODH -->|creates| ImageStreams

    %% Platform integration
    Operator["rhods-operator /<br/>opendatahub-operator"] -->|applies manifests| KustomizeRHOAI
    Operator -->|applies manifests| KustomizeODH
    Dashboard["ODH Dashboard"] -->|reads annotations| ImageStreams
    NotebookController["ODH Notebook Controller"] -->|creates StatefulSets from| ImageStreams

    %% Styling
    style NotebooksRepo fill:#e8f4f8,stroke:#2196F3,stroke-width:2px
    style BaseImages fill:#fff3e0,stroke:#ff9800,stroke-width:1px
    style JupyterWorkbenches fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style OtherWorkbenches fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    style PipelineRuntimes fill:#fce4ec,stroke:#e91e63,stroke-width:1px
    style BuildSystem fill:#f3e5f5,stroke:#9c27b0,stroke-width:1px
    style Manifests fill:#fff8e1,stroke:#ffc107,stroke-width:1px
    style Registry fill:#e0e0e0,stroke:#616161
    style ImageStreams fill:#ffecb3,stroke:#ffa000
    style Operator fill:#bbdefb,stroke:#1976d2
    style Dashboard fill:#bbdefb,stroke:#1976d2
    style NotebookController fill:#bbdefb,stroke:#1976d2
