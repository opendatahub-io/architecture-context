graph TB
    subgraph "Notebooks Component (Image Factory)"
        direction TB

        subgraph BaseLayer["Base Images"]
            BaseCPU["Base CPU<br/>UBI9 + Python 3.12"]
            BaseCUDA["Base CUDA<br/>UBI9 + Python 3.12 + CUDA 12.8"]
            BaseROCm["Base ROCm<br/>UBI9 + Python 3.12 + ROCm 6.3+"]
        end

        subgraph JupyterWorkbenches["Jupyter Workbench Images"]
            direction TB
            JupyterMinimal["jupyter-minimal<br/>CPU / CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterDS["jupyter-datascience<br/>CPU<br/>Port: 8888/TCP"]
            JupyterPyTorch["jupyter-pytorch<br/>CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterTF["jupyter-tensorflow<br/>CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterTrustyAI["jupyter-trustyai<br/>CPU<br/>Port: 8888/TCP"]
            JupyterLLM["jupyter-pytorch-llmcompressor<br/>CUDA<br/>Port: 8888/TCP"]
        end

        subgraph OtherWorkbenches["Other Workbench Images"]
            CodeServer["code-server<br/>CPU<br/>Port: 8888/TCP (nginx proxy)"]
            RStudio["rstudio<br/>CPU / CUDA<br/>Port: 8888/TCP (nginx proxy)"]
        end

        subgraph PipelineRuntimes["Pipeline Runtime Images"]
            direction TB
            RTMinimal["runtime-minimal<br/>CPU"]
            RTDS["runtime-datascience<br/>CPU"]
            RTPyTorch["runtime-pytorch<br/>CUDA / ROCm"]
            RTTF["runtime-tensorflow<br/>CUDA / ROCm"]
            RTLLM["runtime-pytorch-llmcompressor<br/>CUDA"]
        end

        subgraph Manifests["ImageStream Manifests"]
            KustomizeBase["manifests/rhoai/base/<br/>Kustomize ImageStreams"]
            KustomizeOverlay["manifests/rhoai/overlays/<br/>Labels & Config"]
        end
    end

    %% Inheritance chain
    BaseCPU -->|inherits| JupyterMinimal
    BaseCUDA -->|inherits| JupyterMinimal
    BaseROCm -->|inherits| JupyterMinimal
    JupyterMinimal -->|inherits| JupyterDS
    JupyterDS -->|inherits| JupyterPyTorch
    JupyterDS -->|inherits| JupyterTF
    JupyterDS -->|inherits| JupyterTrustyAI
    JupyterPyTorch -->|inherits| JupyterLLM

    BaseCPU -->|inherits| RTMinimal
    RTMinimal -->|inherits| RTDS
    RTDS -->|inherits| RTPyTorch
    RTDS -->|inherits| RTTF
    RTPyTorch -->|inherits| RTLLM

    BaseCPU -->|inherits| CodeServer
    BaseCPU -->|inherits| RStudio

    %% Manifest relationships
    JupyterWorkbenches -.->|registered in| KustomizeBase
    OtherWorkbenches -.->|registered in| KustomizeBase
    PipelineRuntimes -.->|registered in| KustomizeBase

    %% Platform integration
    Operator["rhods-operator"] -->|applies manifests| KustomizeBase
    KustomizeBase -->|creates| ImageStreams["OpenShift ImageStreams"]
    ImageStreams -->|read by| Dashboard["ODH Dashboard"]
    Dashboard -->|user selects image| NotebookController["ODH Notebook Controller"]
    NotebookController -->|creates StatefulSet from| ImageStreams

    %% Build system
    Konflux["Konflux Build System<br/>102 Tekton PipelineRuns"] -->|hermetic build| BaseLayer
    Konflux -->|hermetic build| JupyterWorkbenches
    Konflux -->|hermetic build| OtherWorkbenches
    Konflux -->|hermetic build| PipelineRuntimes
    Konflux -->|pushes to| Registry["Container Registry<br/>registry.redhat.io"]

    %% Styling
    style BaseCPU fill:#e8e8e8,stroke:#333
    style BaseCUDA fill:#76b900,stroke:#333,color:#fff
    style BaseROCm fill:#ed1c24,stroke:#333,color:#fff
    style JupyterMinimal fill:#4a90e2,stroke:#333,color:#fff
    style JupyterDS fill:#4a90e2,stroke:#333,color:#fff
    style JupyterPyTorch fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTF fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTrustyAI fill:#4a90e2,stroke:#333,color:#fff
    style JupyterLLM fill:#4a90e2,stroke:#333,color:#fff
    style CodeServer fill:#007acc,stroke:#333,color:#fff
    style RStudio fill:#75aadb,stroke:#333,color:#fff
    style RTMinimal fill:#f5a623,stroke:#333
    style RTDS fill:#f5a623,stroke:#333
    style RTPyTorch fill:#f5a623,stroke:#333
    style RTTF fill:#f5a623,stroke:#333
    style RTLLM fill:#f5a623,stroke:#333
    style KustomizeBase fill:#7ed321,stroke:#333
    style KustomizeOverlay fill:#7ed321,stroke:#333
    style Operator fill:#cc0000,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333
    style NotebookController fill:#7ed321,stroke:#333
    style Konflux fill:#9b59b6,stroke:#333,color:#fff
    style Registry fill:#999,stroke:#333,color:#fff
    style ImageStreams fill:#cc0000,stroke:#333,color:#fff
