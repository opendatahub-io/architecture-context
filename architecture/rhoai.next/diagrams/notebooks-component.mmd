graph TB
    subgraph NotebooksRepo["Notebooks Repository (Image Factory)"]
        direction TB

        subgraph BaseImages["Base Images"]
            BaseCPU["Base CPU<br/>UBI9 + Python 3.12"]
            BaseCUDA["Base CUDA<br/>UBI9 + Python 3.12<br/>+ CUDA 12.8"]
            BaseROCm["Base ROCm<br/>UBI9 + Python 3.12<br/>+ ROCm 6.3+"]
        end

        subgraph JupyterWorkbenches["Jupyter Workbench Images"]
            JupyterMinimal["jupyter-minimal<br/>CPU / CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterDS["jupyter-datascience<br/>CPU<br/>+ mongocli (FIPS)"]
            JupyterPyTorch["jupyter-pytorch<br/>CUDA / ROCm"]
            JupyterTF["jupyter-tensorflow<br/>CUDA / ROCm"]
            JupyterTrustyAI["jupyter-trustyai<br/>CPU<br/>+ Java 17"]
            JupyterLLM["jupyter-pytorch-llmcompressor<br/>CUDA"]
        end

        subgraph OtherWorkbenches["Other Workbench Images"]
            CodeServer["code-server<br/>CPU<br/>VS Code + nginx<br/>Port: 8888/TCP"]
            RStudio["rstudio<br/>CPU / CUDA<br/>RStudio Server + nginx<br/>Port: 8888/TCP"]
        end

        subgraph PipelineRuntimes["Pipeline Runtime Images"]
            RTMinimal["runtime-minimal<br/>CPU"]
            RTDataScience["runtime-datascience<br/>CPU"]
            RTPyTorch["runtime-pytorch<br/>CUDA / ROCm"]
            RTTensorFlow["runtime-tensorflow<br/>CUDA / ROCm"]
            RTLLM["runtime-pytorch-llmcompressor<br/>CUDA"]
        end

        subgraph BuildTooling["Build Tooling"]
            Konflux["Konflux Build System<br/>102 Tekton PipelineRuns"]
            Cachi2["Hermeto/cachi2<br/>Dependency Prefetch"]
            LockFiles["Lock Files<br/>rpms.lock.yaml<br/>pylock.*.toml<br/>go.sum<br/>package-lock.json"]
        end

        subgraph Manifests["ImageStream Manifests"]
            KustomizeRHOAI["Kustomize (RHOAI)<br/>manifests/rhoai/"]
            KustomizeODH["Kustomize (ODH)<br/>manifests/odh/"]
        end
    end

    %% Image inheritance chain
    BaseCPU --> JupyterMinimal
    BaseCUDA --> JupyterMinimal
    BaseROCm --> JupyterMinimal
    JupyterMinimal --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTF
    JupyterDS --> JupyterTrustyAI
    JupyterPyTorch --> JupyterLLM

    %% Runtime inheritance (parallel to workbench)
    BaseCPU --> RTMinimal
    RTMinimal --> RTDataScience
    BaseCUDA --> RTPyTorch
    BaseCUDA --> RTTensorFlow
    RTPyTorch --> RTLLM

    %% Build tooling feeds all images
    Konflux -.->|builds| JupyterWorkbenches
    Konflux -.->|builds| OtherWorkbenches
    Konflux -.->|builds| PipelineRuntimes
    Cachi2 -.->|prefetch deps| Konflux
    LockFiles -.->|pins versions| Cachi2

    %% External consumers
    Registry["Container Registry<br/>registry.redhat.io / quay.io"]
    Operator["rhods-operator /<br/>opendatahub-operator"]
    ImageStreams["OpenShift ImageStreams"]
    Dashboard["ODH Dashboard"]
    NotebookController["ODH Notebook Controller"]
    ElyraEngine["Elyra Pipeline Engine"]

    Konflux -->|pushes images| Registry
    KustomizeRHOAI -->|applied by| Operator
    KustomizeODH -->|applied by| Operator
    Operator -->|creates| ImageStreams
    ImageStreams -->|reads annotations| Dashboard
    ImageStreams -->|references images in| Registry
    Dashboard -->|user selects workbench| NotebookController
    NotebookController -->|creates StatefulSet from| ImageStreams
    ElyraEngine -->|selects runtime from| ImageStreams

    %% Styling
    style NotebooksRepo fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style BaseCPU fill:#d5e8d4,stroke:#82b366
    style BaseCUDA fill:#fff2cc,stroke:#d6b656
    style BaseROCm fill:#f8cecc,stroke:#b85450
    style JupyterMinimal fill:#dae8fc,stroke:#6c8ebf
    style JupyterDS fill:#dae8fc,stroke:#6c8ebf
    style JupyterPyTorch fill:#dae8fc,stroke:#6c8ebf
    style JupyterTF fill:#dae8fc,stroke:#6c8ebf
    style JupyterTrustyAI fill:#dae8fc,stroke:#6c8ebf
    style JupyterLLM fill:#dae8fc,stroke:#6c8ebf
    style CodeServer fill:#e1d5e7,stroke:#9673a6
    style RStudio fill:#e1d5e7,stroke:#9673a6
    style RTMinimal fill:#fff2cc,stroke:#d6b656
    style RTDataScience fill:#fff2cc,stroke:#d6b656
    style RTPyTorch fill:#fff2cc,stroke:#d6b656
    style RTTensorFlow fill:#fff2cc,stroke:#d6b656
    style RTLLM fill:#fff2cc,stroke:#d6b656
    style Konflux fill:#f5f5f5,stroke:#666
    style Cachi2 fill:#f5f5f5,stroke:#666
    style LockFiles fill:#f5f5f5,stroke:#666
    style Registry fill:#e8e8e8,stroke:#999
    style Operator fill:#7ed321,stroke:#333
    style ImageStreams fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style NotebookController fill:#7ed321,stroke:#333
    style ElyraEngine fill:#7ed321,stroke:#333
