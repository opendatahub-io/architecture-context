graph TB
    subgraph NotebooksRepo["Notebooks Repository (Container Image Factory)"]
        direction TB

        subgraph BaseImages["Base Images Layer"]
            CPU["base-images/cpu<br/>CentOS Stream 9<br/>Python 3.12 venv<br/>AIPCC packages"]
            CUDA13["base-images/cuda/13.0<br/>CUDA 13.0.2 runtime<br/>cuDNN 9.14.0"]
            CUDA12["base-images/cuda/12.9<br/>CUDA 12.9 runtime"]
            ROCm["base-images/rocm/7.1<br/>ROCm 7.1.1 runtime"]
        end

        subgraph JupyterWorkbenches["Jupyter Workbench Images"]
            JMinCPU["jupyter/minimal<br/>CPU"]
            JMinCUDA["jupyter/minimal<br/>CUDA"]
            JMinROCm["jupyter/minimal<br/>ROCm"]
            JDS["jupyter/datascience<br/>CPU<br/>Elyra + Kale + mongocli"]
            JPT["jupyter/pytorch<br/>CUDA"]
            JPTLLM["jupyter/pytorch<br/>+llmcompressor<br/>CUDA"]
            JTF["jupyter/tensorflow<br/>CUDA"]
            JRPt["jupyter/rocm/pytorch<br/>ROCm"]
            JRTf["jupyter/rocm/tensorflow<br/>ROCm"]
            JTrust["jupyter/trustyai<br/>CPU<br/>Java 17 JRE"]
        end

        subgraph CodeServerWB["Code-Server Workbench"]
            CS["codeserver<br/>VS Code (code-server v4.106.3)<br/>nginx proxy<br/>8787/TCP"]
        end

        subgraph Runtimes["Pipeline Runtime Images"]
            RTMin["runtimes/minimal<br/>CPU<br/>Elyra bootstrapper"]
            RTDS["runtimes/datascience<br/>CPU"]
            RTPt["runtimes/pytorch<br/>CUDA"]
            RTPTLLM["runtimes/pytorch<br/>+llmcompressor<br/>CUDA"]
            RTTf["runtimes/tensorflow<br/>CUDA"]
            RTRPt["runtimes/rocm-pytorch<br/>ROCm"]
            RTRTf["runtimes/rocm-tensorflow<br/>ROCm"]
        end

        subgraph BuildUtils["Build Utilities"]
            Mongocli["mongocli<br/>Go build stage<br/>FIPS-compliant"]
            AIPCC["aipcc.sh<br/>System package installer"]
        end

        Manifests["manifests/<br/>Kustomize ImageStream<br/>definitions"]
    end

    %% Base image inheritance
    CPU -->|FROM| JMinCPU
    CUDA13 -->|FROM| JMinCUDA
    ROCm -->|FROM| JMinROCm
    CPU -->|FROM| CS
    CPU -->|FROM| RTMin

    JMinCPU -->|layers on| JDS
    JDS -->|layers on| JPT
    JPT -->|layers on| JPTLLM
    JDS -->|layers on| JTrust
    JMinCUDA -->|layers on| JTF
    JMinROCm -->|layers on| JRPt
    JMinROCm -->|layers on| JRTf

    RTMin -->|layers on| RTDS
    RTDS -->|layers on| RTPt
    RTPt -->|layers on| RTPTLLM
    RTDS -->|layers on| RTTf
    RTDS -->|layers on| RTRPt
    RTDS -->|layers on| RTRTf

    Mongocli -.->|embedded in| JDS
    Mongocli -.->|embedded in| JPT
    AIPCC -.->|runs in| CPU
    AIPCC -.->|runs in| CUDA13
    AIPCC -.->|runs in| CUDA12
    AIPCC -.->|runs in| ROCm

    %% External consumers
    NotebookCtrl["ODH Notebook Controller<br/>(Image Consumer)"]
    Operator["rhods-operator<br/>(Manifest Consumer)"]
    DSP["Data Science Pipelines<br/>(Runtime Consumer)"]
    Dashboard["RHOAI Dashboard<br/>(UI Integration)"]

    Manifests -->|ImageStreams| Operator
    Operator -->|applies to cluster| NotebookCtrl
    NotebookCtrl -->|launches pods from| JupyterWorkbenches
    NotebookCtrl -->|launches pods from| CodeServerWB
    DSP -->|runs pipeline steps with| Runtimes
    Dashboard -->|reads annotations from| Manifests

    %% Styling
    classDef baseImage fill:#e8d5b7,stroke:#b8860b,stroke-width:2px
    classDef workbench fill:#4a90e2,stroke:#2c5f8a,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#5a9e18,stroke-width:2px
    classDef buildutil fill:#f5a623,stroke:#c7851a,stroke-width:2px
    classDef consumer fill:#e8e8e8,stroke:#999,stroke-width:2px
    classDef manifest fill:#b8a9c9,stroke:#7b6b8a,stroke-width:2px

    class CPU,CUDA13,CUDA12,ROCm baseImage
    class JMinCPU,JMinCUDA,JMinROCm,JDS,JPT,JPTLLM,JTF,JRPt,JRTf,JTrust,CS workbench
    class RTMin,RTDS,RTPt,RTPTLLM,RTTf,RTRPt,RTRTf runtime
    class Mongocli,AIPCC buildutil
    class NotebookCtrl,Operator,DSP,Dashboard consumer
    class Manifests manifest
