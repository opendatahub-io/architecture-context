graph TB
    subgraph NotebooksRepo["Notebooks Repository (Container Image Factory)"]
        direction TB

        subgraph BuildSystem["Build System"]
            Makefile["Makefile Build Orchestration"]
            Buildinputs["buildinputs (Go CLI)<br/>Dockerfile dependency parser"]
            NTB["ntb (Python Library)<br/>Test/CI utilities"]
        end

        subgraph BaseImages["Base Images"]
            BaseCPU["Base CPU<br/>c9s + Python 3.12"]
            BaseCUDA129["Base CUDA 12.9<br/>c9s + CUDA 12.9.1 + cuDNN 9.14"]
            BaseCUDA130["Base CUDA 13.0<br/>c9s + CUDA 13.0.2 + cuDNN 9.14"]
            BaseROCm64["Base ROCm 6.4<br/>c9s + ROCm 6.4.3"]
            BaseROCm71["Base ROCm 7.1<br/>c9s + ROCm 7.1.1"]
        end

        subgraph JupyterImages["Jupyter Workbench Images"]
            Minimal["Jupyter Minimal<br/>JupyterLab + PDF Export<br/>:8888/TCP"]
            DataScience["Jupyter DataScience<br/>NumPy, Pandas, SciPy,<br/>scikit-learn, Elyra"]
            PyTorch["Jupyter PyTorch<br/>PyTorch ML Framework"]
            PyTorchLLM["Jupyter PyTorch+LLMCompressor<br/>Model Optimization"]
            TensorFlow["Jupyter TensorFlow<br/>TensorFlow ML Framework"]
            TrustyAI["Jupyter TrustyAI<br/>Fairness/Explainability<br/>+ Java 17"]
        end

        subgraph CodeServerImage["Code-Server Workbench"]
            CodeServer["Code-Server<br/>VS Code in Browser"]
            Nginx["nginx Proxy<br/>:80/TCP"]
            Httpd["httpd CGI<br/>:8080/TCP"]
            CodeServerProc["code-server Process<br/>:8787/TCP"]
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            RTMinimal["Runtime Minimal<br/>Elyra Bootstrapper"]
            RTDataScience["Runtime DataScience"]
            RTPyTorch["Runtime PyTorch"]
            RTPyTorchLLM["Runtime PyTorch+LLMCompressor"]
            RTTensorFlow["Runtime TensorFlow"]
        end

        subgraph Manifests["ImageStream Manifests"]
            ISManifests["Kustomize ImageStreams<br/>manifests/rhoai/base/<br/>manifests/odh/base/"]
        end
    end

    %% Image inheritance chain
    BaseCPU -->|base| Minimal
    BaseCUDA129 -->|base| PyTorch
    BaseCUDA130 -->|base| PyTorch
    BaseCUDA129 -->|base| TensorFlow
    BaseROCm64 -->|base| PyTorch
    BaseROCm71 -->|base| PyTorch
    BaseROCm64 -->|base| TensorFlow
    BaseROCm71 -->|base| TensorFlow

    Minimal -->|extends| DataScience
    DataScience -->|extends| PyTorch
    DataScience -->|extends| TensorFlow
    DataScience -->|extends| TrustyAI
    PyTorch -->|extends| PyTorchLLM

    Minimal -->|extends| RTMinimal
    DataScience -->|extends| RTDataScience
    PyTorch -->|extends| RTPyTorch
    RTPyTorch -->|extends| RTPyTorchLLM
    TensorFlow -->|extends| RTTensorFlow

    %% Code-Server internal
    Nginx -->|proxy| CodeServerProc
    Httpd -->|CGI healthz| CodeServerProc

    %% Build system
    Makefile -->|builds| BaseImages
    Makefile -->|builds| JupyterImages
    Makefile -->|builds| CodeServerImage
    Makefile -->|builds| RuntimeImages

    %% External consumers
    Operator["rhods-operator /<br/>opendatahub-operator"]
    Dashboard["ODH Dashboard"]
    Registry["Container Registry<br/>(registry.redhat.io / quay.io)"]
    Konflux["Konflux Build System"]

    Konflux -->|builds hermetically| NotebooksRepo
    NotebooksRepo -->|pushes images| Registry
    ISManifests -->|consumed by| Operator
    Operator -->|deploys ImageStreams| Dashboard
    Dashboard -->|displays workbenches| User["Data Scientist"]

    %% Styling
    style NotebooksRepo fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style BuildSystem fill:#f0f0f0,stroke:#666
    style BaseImages fill:#fff3e0,stroke:#f5a623
    style JupyterImages fill:#e8f5e9,stroke:#4caf50
    style CodeServerImage fill:#fce4ec,stroke:#e91e63
    style RuntimeImages fill:#e3f2fd,stroke:#2196f3
    style Manifests fill:#f3e5f5,stroke:#9c27b0
    style Operator fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Registry fill:#f5a623,stroke:#333
    style Konflux fill:#e8e8e8,stroke:#333
    style User fill:#4a90e2,stroke:#333,color:#fff
