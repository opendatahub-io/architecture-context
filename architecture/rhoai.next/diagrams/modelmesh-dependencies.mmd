graph LR
    ModelMesh["ModelMesh<br/>(Distributed LRU Cache Sidecar)"]

    %% External Dependencies (Required)
    ModelMesh -->|"KV store :2379<br/>model registry, leader election"| etcd["etcd v3.5.x"]
    ModelMesh -.->|"alternative KV store"| ZooKeeper["Apache ZooKeeper 3.8.x"]

    %% Runtime Dependencies
    ModelMesh -->|"RPC framework"| gRPC["gRPC 1.63.2"]
    ModelMesh -->|"network transport"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"inter-instance comm"| Thrift["Apache Thrift 0.20.0"]
    ModelMesh -->|"service framework"| litelinks["litelinks 1.7.2"]
    ModelMesh -->|"KV abstraction"| kvutils["kv-utils 0.5.1"]

    %% Optional Dependencies
    ModelMesh -.->|"metrics (optional)"| PromClient["Prometheus Client 0.9.0"]
    ModelMesh -.->|"TLS certs (optional)"| BouncyCastle["BouncyCastle 1.78"]

    %% Internal Platform Dependencies
    Controller["modelmesh-serving<br/>Controller"] -->|"deploys sidecar<br/>register/unregister"| ModelMesh
    ModelMesh -->|"gRPC ModelRuntime API<br/>load/unload/status"| RuntimeAdapter["modelmesh-runtime-adapter"]
    RuntimeAdapter -->|"bridges to"| ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)"]

    %% Integration Points (inbound)
    ModelMesh -->|"peer forwarding<br/>Thrift/gRPC :8033"| OtherInstances["Other ModelMesh<br/>Instances"]

    %% Integration Points (outbound)
    ModelMesh -->|"metrics :2112"| Prometheus["Prometheus"]
    ModelMesh -.->|"metrics :8126/UDP"| StatsD["StatsD Collector"]
    ModelMesh -.->|"payload logging<br/>HTTP/HTTPS"| PayloadProc["Remote Payload<br/>Processor"]

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style etcd fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#999,stroke:#333,color:#fff
    style gRPC fill:#bbb,stroke:#333
    style Netty fill:#bbb,stroke:#333
    style Protobuf fill:#bbb,stroke:#333
    style Thrift fill:#bbb,stroke:#333
    style litelinks fill:#bbb,stroke:#333
    style kvutils fill:#bbb,stroke:#333
    style PromClient fill:#bbb,stroke:#333
    style BouncyCastle fill:#bbb,stroke:#333

    %% Internal platform
    style Controller fill:#7ed321,stroke:#333
    style RuntimeAdapter fill:#7ed321,stroke:#333
    style ModelRuntime fill:#7ed321,stroke:#333

    %% Integration
    style OtherInstances fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333
    style StatsD fill:#f5a623,stroke:#333
    style PayloadProc fill:#f5a623,stroke:#333
