graph LR
    ModelMesh["ModelMesh<br/>Distributed LRU Cache<br/>& Model Router"]

    %% Internal Platform Dependencies (Required)
    ModelMesh -->|"sidecar gRPC<br/>:8085/TCP or UDS"| Runtime["Model Runtime<br/>(Triton, MLServer)"]
    ModelMesh -->|"model registry<br/>leader election<br/>:2379/TCP gRPC"| etcd["etcd v3.5.x"]
    ModelMesh -->|"deployed by<br/>orchestrator"| MMServing["modelmesh-serving<br/>Controller"]

    %% Language & Framework Dependencies
    ModelMesh -->|"runtime"| OpenJDK["OpenJDK 21"]
    ModelMesh -->|"gRPC framework"| gRPC["gRPC-Java 1.63.2"]
    ModelMesh -->|"async networking"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"inter-instance RPC"| Litelinks["Litelinks 1.7.2"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"inter-instance<br/>serialization"| Thrift["Apache Thrift 0.20.0"]
    ModelMesh -->|"KV-store<br/>abstraction"| KVUtils["kv-utils 0.5.1"]
    ModelMesh -->|"etcd client"| EtcdJava["etcd-java 0.0.24"]

    %% Security Dependencies
    ModelMesh -->|"self-signed<br/>TLS certs"| BouncyCastle["BouncyCastle 1.78"]

    %% Monitoring Dependencies
    ModelMesh -->|"metrics collection"| PromClient["Prometheus Client 0.9.0"]

    %% Optional Dependencies
    ModelMesh -.->|"alternative<br/>KV-store :2181"| ZooKeeper["ZooKeeper 3.8.4"]
    ModelMesh -.->|"optional metrics<br/>:8125/UDP"| StatsD["StatsD Client 2.7"]

    %% Integration Points (other components integrating with ModelMesh)
    Prometheus["Prometheus"] -->|"scrapes :2112<br/>HTTPS"| ModelMesh
    K8sAPI["Kubernetes API"] -.->|"ConfigMap watch<br/>Downward API"| ModelMesh

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#7ed321,stroke:#333,color:#fff
    style MMServing fill:#7ed321,stroke:#333,color:#fff
    style OpenJDK fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Netty fill:#999,stroke:#333,color:#fff
    style Litelinks fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Thrift fill:#999,stroke:#333,color:#fff
    style KVUtils fill:#999,stroke:#333,color:#fff
    style EtcdJava fill:#999,stroke:#333,color:#fff
    style BouncyCastle fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style StatsD fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
