graph LR
    ModelMesh["ModelMesh<br/>(Java 21 Sidecar)"]

    %% External Dependencies (Required)
    ModelMesh -->|"KV store: model registry,<br/>leader election, instance state<br/>gRPC/2379 TLS"| etcd["etcd v3.5+"]
    ModelMesh -.->|"Alternative KV store<br/>(legacy support)"| ZooKeeper["ZooKeeper 3.7+"]
    ModelMesh -->|"Client/server comms<br/>framework"| gRPC["gRPC 1.63.2"]
    ModelMesh -->|"NIO transport for<br/>gRPC + HTTP servers"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"gRPC message<br/>serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"Service discovery,<br/>inter-instance Thrift RPC"| Litelinks["Litelinks 1.7.2"]
    ModelMesh -->|"KV store abstraction<br/>(etcd + Curator)"| kvutils["kv-utils 0.5.1"]
    ModelMesh -->|"etcd v3 Java client"| etcdjava["etcd-java 0.0.24"]

    %% External Dependencies (Optional)
    ModelMesh -.->|"Metrics exposition<br/>(optional)"| PromClient["Prometheus Client 0.9.0"]
    ModelMesh -->|"Self-signed cert gen<br/>for Prometheus HTTPS"| BouncyCastle["BouncyCastle 1.78"]

    %% Internal Platform Dependencies
    Controller["modelmesh-serving<br/>(KServe Controller)"] -->|"Deploys as sidecar,<br/>manages ServingRuntimes<br/>& InferenceServices"| ModelMesh
    ModelMesh -->|"gRPC sidecar API<br/>8085/TCP or UDS<br/>loadModel, unloadModel,<br/>inference"| Runtimes["Model Runtime Containers<br/>(Triton / MLServer / Custom)"]
    ModelMesh -->|"Platform-provisioned<br/>model registry storage"| etcdPlatform["etcd<br/>(platform-managed)"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"HTTPS scrape<br/>2112/TCP"| ModelMesh
    StatsD["StatsD Agent"] <-.->|"UDP/8126<br/>metrics emission"| ModelMesh
    K8sDownward["Kubernetes<br/>Downward API"] -->|"Pod name, pod IP,<br/>host IP env vars"| ModelMesh

    %% Runtime external calls
    Runtimes -->|"Model artifacts<br/>HTTPS/varies"| Storage["Model Storage<br/>(S3 / PVC)"]

    %% Styling
