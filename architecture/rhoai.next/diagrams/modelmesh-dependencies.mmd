graph LR
    ModelMesh["ModelMesh<br/>Distributed LRU Cache<br/>& Routing Layer"]

    %% Internal Platform Dependencies
    ModelMesh -->|"deploys sidecar<br/>manages CRDs"| ModelmeshServing["modelmesh-serving<br/>Controller"]
    ModelMesh -->|"gRPC :8085 or UDS<br/>loadModel, unloadModel,<br/>inference"| ModelRuntime["Model Runtime<br/>(Triton, MLServer)"]
    ModelMesh -->|"gRPC :2379<br/>model/instance registry,<br/>leader election"| etcd["etcd<br/>(model-mesh-etcd)"]

    %% External Runtime Dependencies
    ModelMesh -->|"Java 21 runtime"| OpenJDK["OpenJDK 21<br/>(UBI9 base)"]
    ModelMesh -->|"gRPC framework"| gRPC["gRPC-Java 1.63.2"]
    ModelMesh -->|"async networking,<br/>HTTP server"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"inter-instance RPC"| Thrift["Apache Thrift 0.20.0"]
    ModelMesh -->|"service discovery,<br/>Thrift RPC"| Litelinks["Litelinks 1.7.2"]
    ModelMesh -->|"KV-store abstraction"| KVUtils["kv-utils 0.5.1"]
    ModelMesh -->|"etcd v3 Java client"| EtcdJava["etcd-java 0.0.24"]
    ModelMesh -->|"metrics collection"| PromClient["Prometheus Client 0.9.0"]
    ModelMesh -->|"TLS cert generation"| BouncyCastle["BouncyCastle 1.78"]

    %% Optional Dependencies
    ModelMesh -.->|"alternative<br/>KV-store"| ZooKeeper["Apache ZooKeeper<br/>3.8.4"]
    ModelMesh -.->|"optional metrics<br/>UDP :8125"| StatsD["Datadog StatsD<br/>Client 2.7"]

    %% Integration Points (consumers/dependents)
    Prometheus["Prometheus"] -->|"HTTPS :2112<br/>scrape /metrics"| ModelMesh
    K8sAPI["Kubernetes API"] -->|"ConfigMap watch,<br/>Downward API"| ModelMesh
    OtherInstances["Other ModelMesh<br/>Instances"] <-->|"Thrift :8080<br/>inference forwarding"| ModelMesh
    PayloadProc["Remote Payload<br/>Processor"] -.->|"HTTP/HTTPS<br/>optional logging"| ModelMesh

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (green)
    style ModelmeshServing fill:#7ed321,stroke:#333,color:#fff
    style ModelRuntime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#7ed321,stroke:#333,color:#fff

    %% External dependencies (gray)
    style OpenJDK fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Netty fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Thrift fill:#999,stroke:#333,color:#fff
    style Litelinks fill:#999,stroke:#333,color:#fff
    style KVUtils fill:#999,stroke:#333,color:#fff
    style EtcdJava fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style BouncyCastle fill:#999,stroke:#333,color:#fff

    %% Optional dependencies (light gray, dashed)
    style ZooKeeper fill:#bbb,stroke:#333,color:#fff
    style StatsD fill:#bbb,stroke:#333,color:#fff

    %% Integration points (orange)
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OtherInstances fill:#9b59b6,stroke:#333,color:#fff
    style PayloadProc fill:#bbb,stroke:#333,color:#fff
