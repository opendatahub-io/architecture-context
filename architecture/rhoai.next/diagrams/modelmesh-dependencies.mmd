graph LR
    ModelMesh["ModelMesh<br/>(Distributed LRU Cache<br/>Sidecar)"]

    %% External Dependencies (Required)
    ModelMesh -->|"model registry,<br/>leader election<br/>gRPC 2379/TCP"| etcd["etcd 3.5+"]
    ModelMesh -->|"alternative KV store<br/>(legacy)"| ZooKeeper["ZooKeeper 3.7+"]
    ModelMesh -->|"JVM runtime"| OpenJDK["OpenJDK 21"]
    ModelMesh -->|"async networking,<br/>gRPC, metrics server"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"gRPC server + client"| gRPC["gRPC-Java 1.63.2"]
    ModelMesh -->|"inter-pod RPC"| Litelinks["Litelinks 1.7.2"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"self-signed TLS certs"| BouncyCastle["BouncyCastle 1.78"]

    %% Internal Platform Dependencies
    modelmeshServing["modelmesh-serving<br/>(Controller)"] -->|"creates pods with<br/>ModelMesh sidecar"| ModelMesh
    ModelMesh -->|"gRPC: loadModel,<br/>unloadModel, serve<br/>8085/TCP or UDS"| Runtime["Model Runtimes<br/>(Triton, MLServer, Custom)"]
    ModelMesh -->|"model registry,<br/>instance records"| etcdCluster["etcd Cluster<br/>(Platform)"]

    %% Integration Points (Consumers)
    ModelMesh -->|"Litelinks Thrift<br/>8080/TCP"| Peers["Other ModelMesh Pods"]
    Prometheus["Prometheus"] -->|"scrape metrics<br/>HTTPS 2112/TCP"| ModelMesh
    ModelMesh -.->|"StatsD metrics<br/>UDP 8125"| StatsD["StatsD/Datadog Agent"]
    K8s["Kubernetes API<br/>(Downward API)"] -.->|"env vars:<br/>pod name, pod IP"| ModelMesh

    %% Model Storage (accessed by runtime)
    Runtime -->|"model artifacts<br/>HTTPS 443/TCP"| S3["S3 / PVC<br/>(Model Storage)"]

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style etcd fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#999,stroke:#333,color:#fff
    style OpenJDK fill:#999,stroke:#333,color:#fff
    style Netty fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Litelinks fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style BouncyCastle fill:#999,stroke:#333,color:#fff

    %% Internal ODH/RHOAI dependencies
    style modelmeshServing fill:#7ed321,stroke:#333,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style etcdCluster fill:#7ed321,stroke:#333,color:#fff
    style Peers fill:#9b59b6,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
