graph LR
    ModelMesh["ModelMesh<br/>(Distributed LRU Cache Sidecar)"]

    %% Platform Dependencies (Required)
    ModelMesh -->|"model registry<br/>leader election<br/>coordination<br/>gRPC :2379"| etcd["etcd v3.5.x"]
    ModelMesh -->|"alternative KV store<br/>(if not etcd)"| ZooKeeper["Apache ZooKeeper 3.8.x"]

    %% Colocated Dependencies
    ModelMesh -->|"load/unload/status<br/>gRPC :8085 or UDS"| RuntimeAdapter["modelmesh-runtime-adapter"]
    RuntimeAdapter -->|"bridges to"| ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)"]

    %% Internal RHOAI Dependencies
    MMServing["modelmesh-serving<br/>Controller"] -->|"deploys sidecar<br/>registers models<br/>gRPC :8033"| ModelMesh

    %% Peer Communication
    ModelMesh -->|"inference forwarding<br/>Thrift/gRPC :8033<br/>TLS/mTLS"| ModelMeshPeers["Other ModelMesh<br/>Instances"]

    %% Library Dependencies
    ModelMesh -->|"RPC framework"| gRPC["gRPC 1.63.2"]
    ModelMesh -->|"network transport"| Netty["Netty 4.1.132"]
    ModelMesh -->|"inter-instance comm"| Thrift["Apache Thrift 0.20.0"]
    ModelMesh -->|"service framework"| litelinks["litelinks 1.7.2"]
    ModelMesh -->|"KV abstraction"| kvutils["kv-utils 0.5.1"]

    %% Optional Integration Points
    ModelMesh -.->|"metrics scrape<br/>HTTPS :2112"| Prometheus["Prometheus"]
    ModelMesh -.->|"metrics emit<br/>UDP :8126"| StatsD["StatsD Collector"]
    ModelMesh -.->|"payload logging<br/>HTTP(S) POST"| PayloadProc["Remote Payload<br/>Processor"]

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#999,stroke:#333,color:#fff
    style RuntimeAdapter fill:#7ed321,stroke:#333,color:#fff
    style ModelRuntime fill:#7ed321,stroke:#333,color:#fff
    style MMServing fill:#7ed321,stroke:#333,color:#fff
    style ModelMeshPeers fill:#4a90e2,stroke:#333,color:#fff
    style gRPC fill:#e8e8e8,stroke:#333
    style Netty fill:#e8e8e8,stroke:#333
    style Thrift fill:#e8e8e8,stroke:#333
    style litelinks fill:#e8e8e8,stroke:#333
    style kvutils fill:#e8e8e8,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
    style StatsD fill:#f5a623,stroke:#333,color:#fff
    style PayloadProc fill:#f5a623,stroke:#333,color:#fff
