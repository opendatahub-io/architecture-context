graph LR
    ModelMesh["ModelMesh<br/>(Distributed Model Serving)"]

    %% External Dependencies (Required)
    ModelMesh -->|"gRPC 2379/TCP<br/>model registry, state,<br/>leader election"| etcd["etcd v3.5.x"]
    ModelMesh -->|"gRPC 8085/TCP or UDS<br/>load/unload/inference"| Runtime["Model Runtime<br/>(Triton / MLServer / Custom)"]
    ModelMesh -->|"JVM runtime"| Java21["Java 21<br/>(OpenJDK)"]
    ModelMesh -->|"RPC framework"| gRPC["gRPC 1.63.2"]
    ModelMesh -->|"network transport"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"service discovery,<br/>inter-pod Thrift"| Litelinks["Litelinks 1.7.2"]

    %% External Dependencies (Optional)
    ModelMesh -.->|"alternative KV store"| ZooKeeper["ZooKeeper 3.8.x"]
    ModelMesh -.->|"metrics collection"| PromClient["Prometheus Client 0.9.0"]
    ModelMesh -.->|"self-signed certs"| BouncyCastle["BouncyCastle 1.78"]
    ModelMesh -.->|"structured logging"| Log4j2["Log4j2 2.23.1"]

    %% Internal Platform Dependencies
    MMServing["modelmesh-serving<br/>Controller"] -->|"deploys as sidecar<br/>creates Deployments/Services<br/>configures env vars"| ModelMesh

    %% Peer Communication
    ModelMesh <-->|"Thrift 8080/TCP<br/>Litelinks peer-to-peer<br/>cache miss forwarding"| PeerPods["Other ModelMesh Pods<br/>(Same Deployment)"]

    %% Integration Points (consumers)
    ModelMesh -.->|"HTTP(S) 2112/TCP<br/>metrics scraping"| Prometheus["Prometheus"]
    ModelMesh -.->|"UDP 8126<br/>metrics push"| StatsD["StatsD / Sysdig"]
    ModelMesh -.->|"HTTP(S)<br/>payload forwarding"| RemotePayload["Remote Payload<br/>Processor"]

    %% Styling
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style Runtime fill:#f5a623,stroke:#333,color:#fff
    style Java21 fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Netty fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style Litelinks fill:#999,stroke:#333,color:#fff
    style ZooKeeper fill:#ccc,stroke:#333
    style PromClient fill:#ccc,stroke:#333
    style BouncyCastle fill:#ccc,stroke:#333
    style Log4j2 fill:#ccc,stroke:#333
    style MMServing fill:#7ed321,stroke:#333,color:#fff
    style PeerPods fill:#b8d4f0,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style StatsD fill:#e8e8e8,stroke:#333
    style RemotePayload fill:#e8e8e8,stroke:#333
