graph LR
    ModelMesh["ModelMesh<br/>(Distributed LRU Cache<br/>Sidecar)"]

    %% External Dependencies (Required)
    ModelMesh -->|"model registry<br/>leader election<br/>gRPC/2379"| etcd["etcd v3.5.x"]
    ModelMesh -->|"alternative KV store<br/>gRPC"| ZooKeeper["ZooKeeper 3.8.x"]
    ModelMesh -->|"RPC framework<br/>external + internal"| gRPC["gRPC 1.63.2"]
    ModelMesh -->|"network transport"| Netty["Netty 4.1.132.Final"]
    ModelMesh -->|"serialization"| Protobuf["Protobuf 3.25.5"]
    ModelMesh -->|"inter-instance<br/>communication"| Thrift["Apache Thrift 0.20.0"]
    ModelMesh -->|"service framework<br/>litelinks"| litelinks["litelinks 1.7.2"]
    ModelMesh -->|"KV abstraction"| kvutils["kv-utils 0.5.1"]

    %% External Dependencies (Optional)
    ModelMesh -.->|"metrics collection"| PromClient["Prometheus Client 0.9.0"]
    ModelMesh -.->|"TLS self-signed<br/>cert generation"| BouncyCastle["BouncyCastle 1.78"]

    %% Internal Platform Dependencies
    Controller["modelmesh-serving<br/>Controller"] -->|"deploys sidecar<br/>register/unregister models"| ModelMesh
    ModelMesh -->|"gRPC ModelRuntime API<br/>8085/TCP or UDS"| RuntimeAdapter["modelmesh-runtime-<br/>adapter"]
    RuntimeAdapter -->|"translates API"| ModelRuntime["Model Runtime<br/>(Triton / MLServer /<br/>Custom)"]

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -.->|"UI management"| Controller
    Pipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| Controller

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrapes metrics<br/>HTTPS/2112"| ModelMesh
    ModelMesh -.->|"UDP/8126<br/>StatsD"| StatsD["StatsD Collector"]
    ModelMesh -.->|"HTTP/HTTPS<br/>payload logging"| PayloadProc["Remote Payload<br/>Processor"]

