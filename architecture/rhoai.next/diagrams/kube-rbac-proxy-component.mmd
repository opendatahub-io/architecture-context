graph TB
    subgraph "kube-rbac-proxy Sidecar Container"
        direction TB

        subgraph "Authentication Layer"
            DelegatingAuthn["Delegating Authn<br/>(TokenReview)"]
            OIDCAuthn["OIDC Authn<br/>(JWT Validation)"]
            X509Authn["x509 Authn<br/>(Client Certs)"]
        end

        subgraph "Authorization Layer"
            HardcodedAuthz["Hardcoded Authorizer<br/>(Prometheus /metrics)"]
            StaticAuthz["Static Authorizer<br/>(Config Rules)"]
            SARAuthz["SAR Authorizer<br/>(SubjectAccessReview)"]
        end

        subgraph "HTTP Pipeline"
            Filters["Filters<br/>(Auth Middleware Chain)"]
            Proxy["Proxy<br/>(Attribute Builder)"]
            TLSReloader["TLS Reloader<br/>(Hot-reload Certs)"]
            Sanitizer["Sanitizing Filter<br/>(Token Masking in Logs)"]
        end

        Filters -->|authenticates via| DelegatingAuthn
        Filters -->|authenticates via| OIDCAuthn
        Filters -->|authenticates via| X509Authn
        Filters -->|authorizes via| HardcodedAuthz
        Filters -->|authorizes via| StaticAuthz
        Filters -->|authorizes via| SARAuthz
        Filters -->|builds attrs| Proxy
        TLSReloader -->|reloads certs| Filters
    end

    Client["Client<br/>(Browser / API / SDK)"] -->|HTTPS 8443/TCP<br/>Bearer / x509 / OIDC| Filters
    DelegatingAuthn -->|TokenReview| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    SARAuthz -->|SubjectAccessReview| K8sAPI
    Proxy -->|Forward authorized<br/>requests| Upstream["Upstream Application<br/>(localhost)"]
    Prometheus["prometheus-k8s<br/>(OpenShift Monitoring)"] -->|GET /metrics<br/>HTTPS 8443/TCP| Filters

    style DelegatingAuthn fill:#4a90e2,color:#fff
    style OIDCAuthn fill:#4a90e2,color:#fff
    style X509Authn fill:#4a90e2,color:#fff
    style HardcodedAuthz fill:#f5a623,color:#fff
    style StaticAuthz fill:#f5a623,color:#fff
    style SARAuthz fill:#f5a623,color:#fff
    style Filters fill:#7ed321,color:#fff
    style Proxy fill:#7ed321,color:#fff
    style TLSReloader fill:#7ed321,color:#fff
    style Sanitizer fill:#7ed321,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Upstream fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style Prometheus fill:#f9f9f9,stroke:#333
