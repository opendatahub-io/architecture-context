graph TB
    subgraph "kube-rbac-proxy Sidecar Container"
        direction TB
        subgraph "Middleware Chain"
            PathFilter["Path Filter<br/>(pkg/filters/path)"]
            AuthNFilter["Authentication Filter<br/>(pkg/filters/auth)"]
            AuthZFilter["Authorization Filter<br/>(pkg/filters/auth)"]
            HeaderInjection["Auth Header Injection<br/>(pkg/filters/auth)"]
        end

        subgraph "Authentication Module (pkg/authn)"
            DelegatingAuthn["Delegating Authenticator<br/>(TokenReview)"]
            OIDCAuthn["OIDC Authenticator<br/>(JWT Verification)"]
            X509Authn["x509 Authenticator<br/>(Client Certificates)"]
        end

        subgraph "Authorization Module (pkg/authz)"
            HardcodedAuthz["Hardcoded Authorizer<br/>(Prometheus SA Allow)"]
            StaticAuthz["Static Authorizer<br/>(config-file)"]
            SARAuthz["SAR Authorizer<br/>(SubjectAccessReview)"]
        end

        TLSReloader["TLS Certificate Reloader<br/>(pkg/tls)"]
        ReverseProxy["Reverse Proxy<br/>(pkg/proxy)"]
        Sanitizer["Sanitizing Filter<br/>(Token Masking in Logs)"]
    end

    Client["External Client<br/>(In-Cluster Service)"] -->|"HTTPS 8443/TCP<br/>Bearer / mTLS / OIDC"| PathFilter
    PathFilter -->|"path allowed"| AuthNFilter
    PathFilter -->|"ignore-paths match"| ReverseProxy

    AuthNFilter --> DelegatingAuthn
    AuthNFilter --> OIDCAuthn
    AuthNFilter --> X509Authn

    AuthNFilter -->|"authenticated"| AuthZFilter
    AuthZFilter --> HardcodedAuthz
    AuthZFilter --> StaticAuthz
    AuthZFilter --> SARAuthz

    AuthZFilter -->|"authorized"| HeaderInjection
    HeaderInjection -->|"headers injected"| ReverseProxy

    DelegatingAuthn -->|"TokenReview API"| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    SARAuthz -->|"SubjectAccessReview API"| K8sAPI
    OIDCAuthn -->|"OIDC Discovery + JWKS"| OIDCIssuer["OIDC Identity Provider<br/>443/TCP HTTPS"]
    TLSReloader -->|"hot-reload certs<br/>(1 min interval)"| TLSCerts["TLS Certificates<br/>(mounted files)"]

    ReverseProxy -->|"HTTP/HTTPS/h2c<br/>(localhost)"| Upstream["Upstream Application<br/>(Protected Container)"]

    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"HTTPS 8443/TCP<br/>Bearer Token"| PathFilter

    RHODSOperator["rhods-operator"] -.->|"injects sidecar"| PathFilter

    style PathFilter fill:#4a90e2,color:#fff
    style AuthNFilter fill:#4a90e2,color:#fff
    style AuthZFilter fill:#4a90e2,color:#fff
    style HeaderInjection fill:#4a90e2,color:#fff
    style DelegatingAuthn fill:#6bb5e0
    style OIDCAuthn fill:#6bb5e0
    style X509Authn fill:#6bb5e0
    style HardcodedAuthz fill:#f5a623
    style StaticAuthz fill:#f5a623
    style SARAuthz fill:#f5a623
    style TLSReloader fill:#7ed321,color:#fff
    style ReverseProxy fill:#4a90e2,color:#fff
    style Sanitizer fill:#e8e8e8
    style K8sAPI fill:#999,color:#fff
    style OIDCIssuer fill:#999,color:#fff
    style Upstream fill:#7ed321,color:#fff
    style Prometheus fill:#e8e8e8
    style RHODSOperator fill:#e8e8e8
    style Client fill:#f9f9f9
    style TLSCerts fill:#e8e8e8
