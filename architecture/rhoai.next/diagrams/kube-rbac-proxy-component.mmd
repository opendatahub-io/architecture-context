graph TB
    subgraph External["External Clients"]
        Client[Client<br/>curl / browser / API caller]
        Prometheus["Prometheus<br/>(openshift-monitoring)"]
    end

    subgraph PlatformGateway["Platform Gateway"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    end

    subgraph ComponentPod["Component Pod (Sidecar Pattern)"]
        subgraph KubeRBACProxy["kube-rbac-proxy Sidecar"]
            direction TB
            SecureListener["Secure Listener<br/>8443/TCP HTTPS TLS 1.2+"]
            HealthEndpoint["/healthz Endpoint<br/>(unauthenticated)"]

            subgraph AuthNLayer["Authentication Layer"]
                DelegatingAuth["Delegating Authenticator<br/>(Kubernetes TokenReview)"]
                OIDCAuth["OIDC Authenticator<br/>(JWT Validation)"]
                X509Auth["X.509 Client Cert<br/>(mTLS)"]
            end

            subgraph AuthZLayer["Authorization Layer (Union Chain)"]
                HardcodedAuthz["Hardcoded Metrics Authorizer<br/>(auto-allow prometheus-k8s)"]
                StaticAuthz["Static Authorizer<br/>(config file rules)"]
                SARAuthz["SAR Authorizer<br/>(SubjectAccessReview)"]
            end

            TokenSanitizer["Token Sanitization Filter<br/>(masks bearer tokens in logs)"]
            TLSReloader["TLS Certificate Reloader<br/>(hot-reload, 1min poll)"]
            ReverseProxy["httputil.ReverseProxy<br/>(forwards to upstream)"]
        end

        UpstreamApp["Upstream Application<br/>(metrics, APIs, dashboards)"]
    end

    subgraph K8sControlPlane["Kubernetes Control Plane"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    end

    subgraph Operators["Platform Operators"]
        RhodsOperator["rhods-operator<br/>(sidecar injection)"]
        CertManager["cert-manager<br/>(TLS provisioning)"]
    end

    %% External flows
    Client -->|HTTPS/8443<br/>Bearer Token / mTLS / OIDC JWT| HTTPRoute
    HTTPRoute -->|HTTPS/8443| SecureListener
    Prometheus -->|HTTPS/8443<br/>Bearer Token| SecureListener

    %% Internal auth pipeline
    SecureListener --> DelegatingAuth
    SecureListener --> OIDCAuth
    SecureListener --> X509Auth
    DelegatingAuth -->|TokenReview| K8sAPI
    OIDCAuth -.->|JWKS fetch| OIDCIssuer["OIDC Issuer<br/>443/TCP HTTPS"]

    DelegatingAuth --> HardcodedAuthz
    OIDCAuth --> HardcodedAuthz
    X509Auth --> HardcodedAuthz
    HardcodedAuthz --> StaticAuthz
    StaticAuthz --> SARAuthz
    SARAuthz -->|SubjectAccessReview| K8sAPI

    %% Proxy to upstream
    SARAuthz --> ReverseProxy
    HardcodedAuthz -->|prometheus-k8s auto-allow| ReverseProxy
    ReverseProxy -->|HTTP/HTTPS/h2c| UpstreamApp

    %% Operator flows
    RhodsOperator -.->|injects sidecar| KubeRBACProxy
    CertManager -.->|provisions TLS certs| TLSReloader

    %% Styling
    style KubeRBACProxy fill:#4a90e2,stroke:#2c5ea0,stroke-width:2px,color:#fff
    style SecureListener fill:#3a7bd5,stroke:#2c5ea0,color:#fff
    style DelegatingAuth fill:#5ba3e6,stroke:#2c5ea0,color:#fff
    style OIDCAuth fill:#5ba3e6,stroke:#2c5ea0,color:#fff
    style X509Auth fill:#5ba3e6,stroke:#2c5ea0,color:#fff
    style HardcodedAuthz fill:#f5a623,stroke:#d4881b,color:#fff
    style StaticAuthz fill:#f5a623,stroke:#d4881b,color:#fff
    style SARAuthz fill:#f5a623,stroke:#d4881b,color:#fff
    style ReverseProxy fill:#3a7bd5,stroke:#2c5ea0,color:#fff
    style UpstreamApp fill:#7ed321,stroke:#5ea016
    style K8sAPI fill:#e8e8e8,stroke:#999
    style RhodsOperator fill:#9b59b6,stroke:#7d3c98,color:#fff
    style CertManager fill:#9b59b6,stroke:#7d3c98,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e6522c,stroke:#c0392b,color:#fff
    style TokenSanitizer fill:#5ba3e6,stroke:#2c5ea0,color:#fff
    style TLSReloader fill:#5ba3e6,stroke:#2c5ea0,color:#fff
    style HealthEndpoint fill:#5ba3e6,stroke:#2c5ea0,color:#fff
