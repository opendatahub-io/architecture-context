graph TB
    subgraph "kube-rbac-proxy Sidecar Container"
        direction TB

        subgraph "HTTP Middleware Chain"
            PathFilter["Path Allow-List Filter<br/>(pkg/filters/path)"]
            AuthNFilter["Authentication Filter<br/>(pkg/filters/auth)"]
            AuthZFilter["Authorization Filter<br/>(pkg/filters/auth)"]
            HeaderInjection["Auth Header Injection<br/>(pkg/filters/auth)"]
            ReverseProxy["Reverse Proxy<br/>(pkg/proxy)"]
        end

        subgraph "Authentication (pkg/authn)"
            DelegatingAuthn["Delegating Authenticator<br/>TokenReview API"]
            OIDCAuthn["OIDC Authenticator<br/>JWT Validation"]
            X509Authn["x509 Authenticator<br/>Client Certificates"]
        end

        subgraph "Authorization (pkg/authz)"
            HardcodedAuthz["Hardcoded Authorizer<br/>(Prometheus /metrics)"]
            StaticAuthz["Static Authorizer<br/>(config-file)"]
            SARAuthz["SubjectAccessReview<br/>Authorizer"]
        end

        subgraph "TLS (pkg/tls)"
            CertReloader["CertReloader<br/>Hot-reload interval"]
            SanitizingFilter["SanitizingFilter<br/>Token Masking in Logs"]
        end

        PathFilter --> AuthNFilter
        AuthNFilter --> AuthZFilter
        AuthZFilter --> HeaderInjection
        HeaderInjection --> ReverseProxy

        AuthNFilter -.->|delegates to| DelegatingAuthn
        AuthNFilter -.->|delegates to| OIDCAuthn
        AuthNFilter -.->|delegates to| X509Authn

        AuthZFilter -.->|1. check| HardcodedAuthz
        AuthZFilter -.->|2. check| StaticAuthz
        AuthZFilter -.->|3. check| SARAuthz
    end

    Client["External Client<br/>(in-cluster service)"] -->|"HTTPS :8443<br/>Bearer / mTLS / OIDC JWT"| PathFilter

    DelegatingAuthn -->|"TokenReview API"| K8sAPI["Kubernetes API Server"]
    SARAuthz -->|"SubjectAccessReview API"| K8sAPI

    OIDCAuthn -->|"OIDC Discovery + JWKS"| OIDC["OIDC Identity Provider"]

    ReverseProxy -->|"HTTP/HTTPS/h2c<br/>(localhost)"| Upstream["Upstream Application<br/>Container"]

    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"HTTPS :8443<br/>GET /metrics"| PathFilter
    HardcodedAuthz -.->|"hardcoded allow<br/>prometheus-k8s SA"| Prometheus

    CertReloader -.->|"hot-reload certs"| PathFilter

    Operator["rhods-operator"] -.->|"injects sidecar"| ReverseProxy

    style PathFilter fill:#4a90e2,color:#fff
    style AuthNFilter fill:#4a90e2,color:#fff
    style AuthZFilter fill:#4a90e2,color:#fff
    style HeaderInjection fill:#4a90e2,color:#fff
    style ReverseProxy fill:#4a90e2,color:#fff
    style DelegatingAuthn fill:#5ba0d9,color:#fff
    style OIDCAuthn fill:#5ba0d9,color:#fff
    style X509Authn fill:#5ba0d9,color:#fff
    style HardcodedAuthz fill:#f5a623,color:#fff
    style StaticAuthz fill:#f5a623,color:#fff
    style SARAuthz fill:#f5a623,color:#fff
    style CertReloader fill:#7ed321,color:#fff
    style SanitizingFilter fill:#7ed321,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OIDC fill:#e8e8e8,stroke:#333
    style Upstream fill:#d5e8d4,stroke:#82b366
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
    style Operator fill:#f9f9f9,stroke:#999
