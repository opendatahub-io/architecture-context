graph TB
    subgraph External["External Clients"]
        Client["Client<br/>(browser, SDK, curl)"]
        Prometheus["prometheus-k8s SA<br/>(openshift-monitoring)"]
    end

    subgraph Pod["Component Pod (e.g., Notebook, Model Server)"]
        subgraph KRP["kube-rbac-proxy Sidecar"]
            direction TB
            TLSTermination["TLS Termination<br/>8443/TCP HTTPS<br/>TLS 1.2+"]

            subgraph AuthnLayer["Authentication Layer"]
                DelegatingAuthn["Delegating Authenticator<br/>(TokenReview via K8s API)"]
                OIDCAuthn["OIDC Authenticator<br/>(JWT validation)"]
                X509Authn["X.509 Client Cert<br/>(CA validation)"]
            end

            subgraph AuthzLayer["Authorization Layer"]
                HardcodedAuthz["Hardcoded Metrics Authorizer<br/>(prometheus-k8s → /metrics)"]
                StaticAuthz["Static Authorizer<br/>(pre-configured rules)"]
                SARAuthz["SAR Authorizer<br/>(SubjectAccessReview)"]
            end

            subgraph Support["Support Components"]
                CertReloader["TLS Certificate Reloader<br/>(hot-reload from disk)"]
                LogSanitizer["Log Sanitizer<br/>(masks bearer tokens)"]
            end

            ReverseProxy["HTTP Reverse Proxy"]
        end

        Upstream["Upstream Application<br/>(localhost:8081)"]
    end

    subgraph K8sControl["Kubernetes Control Plane"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS"]
    end

    subgraph ExternalIdP["External Identity (Optional)"]
        OIDCIssuer["OIDC Identity Provider<br/>443/TCP HTTPS"]
    end

    %% Request flow
    Client -->|"HTTPS/8443<br/>Bearer Token / OIDC JWT / X.509"| TLSTermination
    Prometheus -->|"HTTPS/8443<br/>SA Token"| TLSTermination

    TLSTermination --> DelegatingAuthn
    TLSTermination --> OIDCAuthn
    TLSTermination --> X509Authn

    DelegatingAuthn -->|"TokenReview"| APIServer
    OIDCAuthn -->|"JWKS fetch"| OIDCIssuer

    DelegatingAuthn --> HardcodedAuthz
    OIDCAuthn --> HardcodedAuthz
    X509Authn --> HardcodedAuthz

    HardcodedAuthz --> StaticAuthz
    StaticAuthz --> SARAuthz
    SARAuthz -->|"SubjectAccessReview"| APIServer

    SARAuthz --> ReverseProxy
    HardcodedAuthz -->|"fast-path<br/>(prometheus-k8s)"| ReverseProxy

    ReverseProxy -->|"HTTP/8081<br/>plaintext (localhost)"| Upstream

    CertReloader -.->|"reloads certs"| TLSTermination

    %% Styling
    style TLSTermination fill:#4a90e2,stroke:#333,color:#fff
    style DelegatingAuthn fill:#e8a838,stroke:#333
    style OIDCAuthn fill:#e8a838,stroke:#333
    style X509Authn fill:#e8a838,stroke:#333
    style HardcodedAuthz fill:#d94f4f,stroke:#333,color:#fff
    style StaticAuthz fill:#d94f4f,stroke:#333,color:#fff
    style SARAuthz fill:#d94f4f,stroke:#333,color:#fff
    style ReverseProxy fill:#4a90e2,stroke:#333,color:#fff
    style Upstream fill:#7ed321,stroke:#333
    style APIServer fill:#999,stroke:#333,color:#fff
    style OIDCIssuer fill:#999,stroke:#333,color:#fff
    style CertReloader fill:#9b59b6,stroke:#333,color:#fff
    style LogSanitizer fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
