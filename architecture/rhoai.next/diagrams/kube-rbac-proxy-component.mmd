graph TB
    subgraph "kube-rbac-proxy Sidecar Container"
        direction TB

        subgraph "Request Pipeline"
            AllowPaths["WithAllowPaths Filter<br/>--ignore-paths bypass"]
            AuthN["WithAuthentication Filter"]
            AuthZ["WithAuthorization Filter"]
            AuthHeaders["WithAuthHeaders Filter"]
            ReverseProxy["httputil.ReverseProxy"]

            AllowPaths -->|"passes non-ignored paths"| AuthN
            AuthN -->|"authenticated request"| AuthZ
            AuthZ -->|"authorized request"| AuthHeaders
            AuthHeaders -->|"headers injected"| ReverseProxy
        end

        subgraph "Authentication (pkg/authn)"
            DelegatingAuth["Delegating Authenticator<br/>Kubernetes TokenReview<br/>2-min cache TTL"]
            OIDCAuth["OIDC Authenticator<br/>JWT validation via JWKS<br/>Claims mapping"]
            ClientCertAuth["X.509 Client Cert Auth<br/>CN-based identity"]
        end

        subgraph "Authorization (pkg/authz)"
            HardcodedAuth["Hardcoded Metrics Authorizer<br/>Auto-allows prometheus-k8s SA<br/>GET /metrics"]
            StaticAuth["Static Authorizer<br/>Config file-based rules"]
            SARAuth["SAR Authorizer<br/>SubjectAccessReview<br/>Allow cache: 5m / Deny cache: 30s"]
        end

        subgraph "Infrastructure"
            TLSReloader["TLS Certificate Reloader<br/>Hot-reload via polling<br/>Atomic swap (RWMutex)"]
            TokenSanitizer["Token Sanitization Filter<br/>Masks bearer tokens in logs"]
            HealthEndpoint["/healthz Endpoint<br/>Unauthenticated"]
        end

        AuthN --- DelegatingAuth
        AuthN --- OIDCAuth
        AuthN --- ClientCertAuth
        AuthZ --- HardcodedAuth
        AuthZ --- StaticAuth
        AuthZ --- SARAuth
    end

    %% External entities
    Client["Client<br/>(curl, browser, service)"]
    Gateway["Gateway API HTTPRoute<br/>(platform Gateway)"]
    K8sAPI["Kubernetes API Server"]
    Upstream["Upstream Application<br/>Container"]
    Prometheus["OpenShift Monitoring<br/>Prometheus"]
    OIDCProvider["OIDC Provider"]
    CertManager["cert-manager /<br/>Platform Operator"]
    RhodsOperator["rhods-operator"]

    %% Flows
    Client -->|"HTTPS/8443<br/>Bearer / mTLS / OIDC JWT"| Gateway
    Gateway -->|"HTTPS/8443"| AllowPaths
    ReverseProxy -->|"HTTP/HTTPS/h2c<br/>to upstream port"| Upstream
    DelegatingAuth -->|"TokenReview<br/>HTTPS/443"| K8sAPI
    SARAuth -->|"SubjectAccessReview<br/>HTTPS/443"| K8sAPI
    OIDCAuth -->|"JWKS/discovery<br/>HTTPS/443"| OIDCProvider
    Prometheus -->|"GET /metrics<br/>HTTPS/8443"| AllowPaths
    CertManager -.->|"TLS certs<br/>mounted as files"| TLSReloader
    RhodsOperator -.->|"injects sidecar<br/>into pod spec"| AllowPaths

    %% Styling
    style AllowPaths fill:#4a90e2,color:#fff
    style AuthN fill:#4a90e2,color:#fff
    style AuthZ fill:#4a90e2,color:#fff
    style AuthHeaders fill:#4a90e2,color:#fff
    style ReverseProxy fill:#4a90e2,color:#fff
    style DelegatingAuth fill:#6baed6
    style OIDCAuth fill:#6baed6
    style ClientCertAuth fill:#6baed6
    style HardcodedAuth fill:#f5a623
    style StaticAuth fill:#f5a623
    style SARAuth fill:#f5a623
    style TLSReloader fill:#7ed321
    style TokenSanitizer fill:#7ed321
    style HealthEndpoint fill:#7ed321
    style K8sAPI fill:#e8e8e8
    style Upstream fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style OIDCProvider fill:#e8e8e8
    style Gateway fill:#e8e8e8
    style CertManager fill:#e8e8e8
    style RhodsOperator fill:#e8e8e8
    style Client fill:#f9f9f9
