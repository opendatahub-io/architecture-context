graph TB
    subgraph "kube-rbac-proxy Sidecar Container"
        direction TB

        subgraph "HTTP Handler Pipeline"
            PathFilter["Path Filter<br/>(pkg/filters/path)"]
            AuthNFilter["Authentication Filter<br/>(pkg/filters/auth)"]
            AuthZFilter["Authorization Filter<br/>(pkg/filters/auth)"]
            HeaderInjection["Auth Header Injection<br/>(pkg/filters/auth)"]
            ReverseProxy["Reverse Proxy<br/>(pkg/proxy)"]

            PathFilter -->|"pass"| AuthNFilter
            AuthNFilter -->|"authenticated"| AuthZFilter
            AuthZFilter -->|"authorized"| HeaderInjection
            HeaderInjection -->|"headers set"| ReverseProxy
        end

        subgraph "Authentication (pkg/authn)"
            DelegatingAuth["Delegating Authenticator<br/>(TokenReview)"]
            OIDCAuth["OIDC Authenticator<br/>(JWT verification)"]
            X509Auth["x509 Authenticator<br/>(Client certificates)"]
        end

        subgraph "Authorization (pkg/authz)"
            HardcodedAuthz["Hardcoded Authorizer<br/>(Prometheus SA allow)"]
            StaticAuthz["Static Authorizer<br/>(config-file driven)"]
            SARAuthz["SAR Authorizer<br/>(SubjectAccessReview)"]
        end

        subgraph "TLS (pkg/tls)"
            CertReloader["CertReloader<br/>(hot-reload at interval)"]
        end

        AuthNFilter -.->|"delegates to"| DelegatingAuth
        AuthNFilter -.->|"or"| OIDCAuth
        AuthNFilter -.->|"or"| X509Auth

        AuthZFilter -.->|"1st: check"| HardcodedAuthz
        AuthZFilter -.->|"2nd: check"| StaticAuthz
        AuthZFilter -.->|"3rd: check"| SARAuthz
    end

    %% External actors
    Client["External Client<br/>(Service / User)"]
    Prometheus["Prometheus<br/>(openshift-monitoring)"]
    K8sAPI["Kubernetes API Server"]
    Upstream["Upstream Application<br/>(localhost)"]

    %% Flows
    Client -->|"HTTPS/8443<br/>Bearer/mTLS/OIDC"| PathFilter
    Prometheus -->|"HTTPS/8443<br/>GET /metrics"| PathFilter

    DelegatingAuth -->|"TokenReview API"| K8sAPI
    SARAuthz -->|"SubjectAccessReview API"| K8sAPI
    OIDCAuth -->|"OIDC Discovery + JWKS"| OIDCIssuer["OIDC Issuer"]

    ReverseProxy -->|"HTTP/HTTPS/h2c<br/>(localhost)"| Upstream
    CertReloader -.->|"reloads TLS certs"| PathFilter

    %% Styling
    style Client fill:#f9f9f9,stroke:#666,stroke-width:2px
    style Prometheus fill:#e8d5b7,stroke:#b8860b,stroke-width:2px
    style K8sAPI fill:#dce8f5,stroke:#4a90e2,stroke-width:2px
    style Upstream fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style OIDCIssuer fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style PathFilter fill:#4a90e2,color:#fff
    style AuthNFilter fill:#4a90e2,color:#fff
    style AuthZFilter fill:#4a90e2,color:#fff
    style HeaderInjection fill:#4a90e2,color:#fff
    style ReverseProxy fill:#4a90e2,color:#fff
    style DelegatingAuth fill:#7b68ee,color:#fff
    style OIDCAuth fill:#7b68ee,color:#fff
    style X509Auth fill:#7b68ee,color:#fff
    style HardcodedAuthz fill:#f5a623,color:#fff
    style StaticAuthz fill:#f5a623,color:#fff
    style SARAuthz fill:#f5a623,color:#fff
    style CertReloader fill:#82b366,color:#fff
