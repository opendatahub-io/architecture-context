graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>Dashboard / CLI"]
    end

    subgraph EvalHubService["EVAL-HUB SERVICE (Internal - ClusterIP)"]
        direction TB

        subgraph NS_EvalHub["Namespace: operator-managed"]
            EvalHub["eval-hub API Server<br/>8080/TCP HTTP/HTTPS<br/>TLS 1.2+<br/>AuthN: K8s TokenReview<br/>AuthZ: K8s SAR<br/>Image: rhoai/odh-eval-hub-rhel9"]
        end
    end

    subgraph EvalJobPod["EVALUATION JOB POD (batch/v1)"]
        direction TB

        subgraph InitPhase["Init Phase (optional)"]
            InitContainer["eval-runtime-init<br/>S3 Data Download<br/>Secrets: /var/run/secrets/test-data/"]
        end

        subgraph RuntimePhase["Runtime Phase"]
            Adapter["Adapter Container<br/>LM Eval / Garak /<br/>Lighteval / GuideLLM /<br/>IBM CLEAR"]
            Sidecar["eval-runtime-sidecar<br/>Native Sidecar (KEP-753)<br/>8080/TCP HTTP localhost<br/>Token cache: 5min TTL"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>TokenReview, SAR, batch/v1"]
        PostgreSQL["PostgreSQL Database<br/>5432/TCP pgx<br/>TLS configurable<br/>Username/Password"]
        MLflow["MLflow Tracking Server<br/>HTTPS<br/>TLS 1.2+<br/>Projected SA Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Registry Token"]
    end

    %% External to Service
    Client -->|"HTTPS/8080<br/>TLS 1.2+<br/>Bearer Token (K8s SAR)"| EvalHub

    %% Eval-hub to Platform
    EvalHub -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    EvalHub -->|"pgx/5432<br/>TLS configurable<br/>Username/Password"| PostgreSQL
    EvalHub -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| MLflow

    %% Eval-hub creates Job
    EvalHub -.->|"creates via K8s API"| EvalJobPod

    %% Init container
    InitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Adapter to Sidecar (pod-local)
    Adapter -->|"HTTP/8080<br/>plaintext localhost<br/>No auth (pod-local)"| Sidecar

    %% Sidecar egress
    Sidecar -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Token"| EvalHub
    Sidecar -->|"HTTPS<br/>TLS 1.2+<br/>Projected SA Token"| MLflow
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker Registry Token"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef evalhub fill:#4a90e2,stroke:#2c5f8a,stroke-width:2px,color:#fff
    classDef jobpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class EvalHub evalhub
    class InitContainer,Adapter,Sidecar jobpod
    class K8sAPI,PostgreSQL,MLflow platform
    class S3,OCI externalservice
