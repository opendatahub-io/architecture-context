graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Dashboard / API User)"]
    end

    subgraph ControlPlane["CONTROL PLANE (RHOAI Namespace)"]
        direction TB
        EvalHubSvc["eval-hub API Server<br/>Service: eval-hub (ClusterIP)<br/>8080/TCP<br/>TLS 1.2-1.3 (FIPS)<br/>AuthN: K8s TokenReview (2min cache)<br/>AuthZ: K8s SAR (5min/30s cache)<br/>SA: eval-hub<br/>Image: rhoai/odh-eval-hub-rhel9"]
    end

    subgraph EvalNamespace["EVALUATION NAMESPACE (User Workload)"]
        direction TB

        subgraph JobPod["Batch Job Pod"]
            direction TB
            Init["eval-runtime-init<br/>(Init Container)<br/>S3 data downloader"]
            AdapterC["Evaluation Adapter<br/>(Lighteval / lm-eval /<br/>Garak / GuideLLM / IBM CLEAR)"]
            SidecarC["eval-runtime-sidecar<br/>(Native Sidecar, KEP-753)<br/>RestartPolicy: Always<br/>8080/TCP localhost<br/>SA: evalhub-instance-ns-job"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>plaintext (in-cluster)<br/>Connection String Auth"]
        MLflow["MLflow Tracking Server<br/>HTTPS (configurable port)<br/>TLS 1.2+ (custom CA)<br/>Bearer Token (projected SA)"]
        S3["S3 Object Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (Docker config)"]
        OTEL["OTEL Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>configurable encryption<br/>No Auth"]
    end

    %% Client to eval-hub
    Client -->|"HTTPS/8080<br/>TLS 1.2-1.3 (FIPS)<br/>Bearer Token + X-Tenant"| EvalHubSvc

    %% eval-hub to K8s API
    EvalHubSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR"| K8sAPI

    %% eval-hub to PostgreSQL
    EvalHubSvc -->|"TCP/5432<br/>plaintext<br/>Connection String"| PostgreSQL

    %% eval-hub to OTEL
    EvalHubSvc -.->|"gRPC/4317 or HTTP/4318<br/>OTLP<br/>No Auth"| OTEL

    %% eval-hub creates Job
    EvalHubSvc -->|"HTTPS/443<br/>Create Batch Job + ConfigMap<br/>SA Token"| K8sAPI

    %% Init container to S3
    Init -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (from Secret)"| S3

    %% Adapter to Sidecar (pod-local)
    AdapterC -->|"HTTP/8080<br/>plaintext (localhost)<br/>No Auth"| SidecarC

    %% Sidecar to eval-hub
    SidecarC -->|"HTTPS/8080<br/>TLS 1.2+ (service-ca.crt)<br/>SA Token"| EvalHubSvc

    %% Sidecar to MLflow
    SidecarC -->|"HTTPS<br/>TLS 1.2+ (custom CA)<br/>Projected SA Token"| MLflow

    %% Sidecar to OCI
    SidecarC -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (challenge-response)"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef evalnamespace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef jobpod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class EvalHubSvc controlplane
    class Init,AdapterC,SidecarC jobpod
    class K8sAPI,PostgreSQL,MLflow,S3,OCI,OTEL externalservice
