graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Dashboard / CLI)"]
    end

    subgraph Platform["PLATFORM SERVICES (Internal ClusterIP)"]
        direction TB
        EvalHub["eval-hub API Server<br/>8080/TCP HTTP/HTTPS<br/>TLS 1.2+ (configurable)<br/>AuthN: K8s TokenReview<br/>AuthZ: K8s SubjectAccessReview<br/>Tenant: X-Tenant → namespace"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>TokenReview + SAR<br/>batch/v1 Jobs + ConfigMaps"]
    end

    subgraph EvalJob["EVALUATION JOB POD (batch/v1)"]
        direction TB

        subgraph InitPhase["Init Phase (optional)"]
            Init["eval-runtime-init<br/>Go Init Container<br/>No port<br/>AWS IAM auth"]
        end

        subgraph RuntimePhase["Runtime Phase"]
            Sidecar["eval-runtime-sidecar<br/>8080/TCP localhost<br/>HTTP plaintext<br/>Native sidecar (KEP-753)<br/>No auth (trusted localhost)"]
            Adapter["Adapter Container<br/>LM Eval / Garak /<br/>Lighteval / GuideLLM /<br/>IBM CLEAR"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP pgx<br/>TLS configurable<br/>Username/Password"]
        MLflow["MLflow Tracking<br/>Configurable port<br/>HTTPS TLS 1.2+<br/>Projected SA Token (3600s)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker Registry Token"]
    end

    %% External to Platform
    Client -->|"HTTPS 8080/TCP<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| EvalHub

    %% Platform to K8s
    EvalHub -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR + Jobs"| K8sAPI

    %% Platform to External Services
    EvalHub -->|"pgx 5432/TCP<br/>TLS configurable<br/>Username/Password"| PostgreSQL
    EvalHub -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| MLflow

    %% K8s creates Job
    K8sAPI -.->|"schedules"| EvalJob

    %% Init to S3
    Init -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Adapter to Sidecar (localhost)
    Adapter -->|"HTTP 8080/TCP<br/>plaintext<br/>localhost only"| Sidecar

    %% Sidecar egress
    Sidecar -->|"HTTPS 8443/TCP<br/>TLS 1.2+<br/>SA Token"| EvalHub
    Sidecar -->|"HTTPS<br/>TLS 1.2+<br/>Projected SA Token"| MLflow
    Sidecar -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Registry Token"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef evaljob fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class EvalHub platform
    class K8sAPI k8s
    class Init,Sidecar,Adapter evaljob
    class PostgreSQL,MLflow,S3,OCI extservice
