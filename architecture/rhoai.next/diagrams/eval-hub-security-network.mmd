graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / API Client"]
        AIAssistant["AI Assistant<br/>(Cursor, VS Code, Claude Code)"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER (kube-rbac-proxy)"]
        direction TB
        RBACProxy1["kube-rbac-proxy (eval-hub)<br/>8443/TCP → 8080/TCP<br/>TLS 1.2+<br/>SubjectAccessReview"]
        RBACProxy2["kube-rbac-proxy (MCP)<br/>8443/TCP → 3001/TCP<br/>TLS 1.2+<br/>SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER (Internal Services)"]
        direction TB

        subgraph APIPodNS["eval-hub Pod"]
            API["eval-hub API<br/>SA: operator-provisioned<br/>8080/TCP (API), 8081/TCP (metrics)<br/>FIPS: strictfipsruntime"]
        end

        subgraph MCPPodNS["evalhub-mcp Pod"]
            MCP["evalhub-mcp<br/>3001/TCP<br/>stdio / HTTP / SSE"]
        end
    end

    subgraph EvalLayer["EVALUATION JOB LAYER (Ephemeral Pods)"]
        direction TB
        InitC["eval-runtime-init<br/>(init container)<br/>No listener port"]
        AdapterC["Benchmark Adapter<br/>(untrusted code)<br/>NO real credentials"]
        SidecarC["eval-runtime-sidecar<br/>(native sidecar)<br/>8080/TCP pod-local<br/>Credential injection"]
    end

    subgraph ExtServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Connection string"]
        MLflow["MLflow Tracking<br/>HTTPS TLS 1.2+<br/>Bearer token (file)"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS<br/>Docker config OAuth2"]
        ModelEP["Model Endpoints<br/>HTTPS<br/>Bearer token (injected)"]
        OTELCol["OTEL Collector<br/>4317/TCP gRPC<br/>Optional TLS"]
    end

    %% External to Auth Layer
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (SA)"| RBACProxy1
    AIAssistant -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (SA)"| RBACProxy2

    %% Auth Layer to App Layer
    RBACProxy1 -->|"HTTP/8080<br/>No encryption (pod-local)<br/>X-Tenant + X-User"| API
    RBACProxy2 -->|"HTTP/3001<br/>No encryption (pod-local)<br/>X-Tenant + X-User"| MCP

    %% MCP to API
    MCP -->|"HTTP or HTTPS<br/>8080 or 8443<br/>Bearer token"| API

    %% App Layer to External Services
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    API -->|"TCP/5432<br/>Optional TLS<br/>Conn string"| PostgreSQL
    API -->|"HTTPS<br/>TLS 1.2+<br/>Bearer token"| MLflow
    API -->|"gRPC/4317<br/>Optional TLS<br/>None"| OTELCol

    %% Eval Layer flows
    InitC -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (Secret)"| S3
    AdapterC -->|"HTTP/8080<br/>No encryption (pod-local)<br/>ref tokens only"| SidecarC
    SidecarC -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA token (cached 5m)"| RBACProxy1
    SidecarC -->|"HTTPS<br/>TLS 1.2+<br/>Bearer token (injected)"| ModelEP
    SidecarC -->|"HTTPS<br/>TLS 1.2+<br/>Bearer token (cached 5m)"| MLflow
    SidecarC -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker OAuth2"| OCIReg

    %% Prometheus scrape
    Prometheus["Prometheus"] -.->|"HTTP/8081<br/>No auth<br/>Cluster-internal"| API

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authlayer fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef applayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef evallayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client,AIAssistant external
    class RBACProxy1,RBACProxy2 authlayer
    class API,MCP applayer
    class InitC,AdapterC,SidecarC evallayer
    class K8sAPI,PostgreSQL,MLflow,S3,OCIReg,ModelEP,OTELCol extservice
    class Prometheus monitoring
