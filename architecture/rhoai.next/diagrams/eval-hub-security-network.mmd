graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Dashboard / CLI / MCP Agent)"]
    end

    subgraph EvalHubService["EVAL HUB SERVICE (Internal ClusterIP)"]
        direction TB

        subgraph NS_EvalHub["Namespace: eval-hub (operator-managed)"]
            API["Eval Hub API Server<br/>SA: eval-hub<br/>Image: odh-eval-hub-rhel9<br/>FIPS: strictfipsruntime"]
            MCP["evalhub-mcp Server<br/>3001/TCP HTTP<br/>(Optional)"]
        end
    end

    subgraph EvalJobPods["EVALUATION JOB PODS (Ephemeral)"]
        direction TB

        subgraph NS_Job["Namespace: {job-namespace}"]
            Init["eval-runtime-init<br/>SA: instance-name-ns-job<br/>CLI (no listener)"]
            Sidecar["eval-runtime-sidecar<br/>Native Sidecar (KEP-753)<br/>localhost:8080 HTTP<br/>CA: service-ca.crt"]
            Adapter["Eval Adapter<br/>(lm-eval / lighteval /<br/>garak / guideLLM)"]
        end
    end

    subgraph Platform["PLATFORM SERVICES (Internal)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Password"]
        OTEL["OTEL Collector<br/>4317 gRPC / 4318 HTTP<br/>TLS (configurable)"]
        Prometheus["Prometheus<br/>scrapes /metrics"]
        ServiceCA["OpenShift Service CA<br/>ConfigMap mount"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        MLflow["MLflow Tracking Server<br/>HTTPS TLS 1.2+<br/>Bearer / Projected SA token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS static credentials"]
        OCI["OCI Registry (Quay)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker config.json"]
    end

    %% Client to API
    Client -->|"HTTPS/8080<br/>TLS 1.2+<br/>Bearer Token<br/>→ TokenReview + SAR"| API

    %% MCP
    Client -->|"HTTP/3001<br/>Bearer Token"| MCP
    MCP -->|"HTTPS/8080<br/>Bearer Token"| API

    %% API egress
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Jobs, TokenReview, SAR"| K8sAPI
    API -->|"SQL/5432<br/>TLS (configurable)<br/>Password"| PostgreSQL
    API -->|"HTTPS<br/>TLS 1.2+<br/>Bearer token"| MLflow
    API -->|"OTLP/4317-4318<br/>TLS (configurable)"| OTEL

    %% Prometheus scrape
    Prometheus -.->|"HTTP(S)/8080<br/>no auth"| API

    %% Service CA
    ServiceCA -.->|"ConfigMap mount"| API
    ServiceCA -.->|"ConfigMap mount"| Sidecar

    %% Job pod internal
    Adapter -->|"HTTP/8080<br/>plaintext<br/>localhost only<br/>no auth"| Sidecar

    %% Init container
    Init -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS credentials"| S3

    %% Sidecar egress
    Sidecar -->|"HTTPS/8080<br/>TLS 1.2+<br/>SA token"| API
    Sidecar -->|"HTTPS<br/>TLS 1.2+<br/>Projected SA token (1h)"| MLflow
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker config.json"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef evalhub fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef jobpod fill:#fef3c7,stroke:#f59e0b,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class API,MCP evalhub
    class Init,Sidecar,Adapter jobpod
    class K8sAPI,PostgreSQL,OTEL,Prometheus,ServiceCA platform
    class MLflow,S3,OCI externalservice
