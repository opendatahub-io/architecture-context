graph TD
    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph UserAccess["User Access Path"]
            User["Data Scientist<br/>(Browser)"]
        end

        subgraph PlatformAuth["Platform Authentication Layer<br/>(NOT defined by this component)"]
            direction TB
            IngressTLS["Ingress TLS Termination<br/>443/TCP → HTTP<br/>TLS 1.2+"]

            subgraph RHOAI3x["RHOAI 3.x"]
                KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)<br/>Injected by Notebook Controller"]
            end

            subgraph RHOAI2x["RHOAI 2.x"]
                OAuthProxy["oauth-proxy<br/>(Sidecar)<br/>Injected by Notebook Controller"]
            end
        end

        subgraph WorkbenchAuth["Workbench Auth Status<br/>(This Component)"]
            direction TB
            JupyterAuth["JupyterLab<br/>8888/TCP<br/>Auth: DISABLED<br/>--ServerApp.token=''"]
            RStudioAuth["RStudio Server<br/>8787/TCP<br/>Auth: DISABLED"]
            CodeServerAuth["code-server<br/>8787/TCP<br/>Auth: DISABLED"]
        end
    end

    subgraph ContainerSecurity["Container Security Model"]
        direction TB
        NonRoot["Non-Root Execution<br/>UID: 1001<br/>GID: 0 (root group)<br/>Supports OpenShift random UID"]
        BaseImage["Base Image: UBI 9<br/>FIPS via system OpenSSL<br/>System trust store"]
        NoTLS["No Custom TLS<br/>Plaintext HTTP servers<br/>TLS terminated at platform ingress"]
    end

    subgraph Secrets["Secrets (Build-Time Only)"]
        direction TB
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio RHEL9 entitled builds<br/>Provisioned: Manual<br/>Rotation: None"]
        GitSecret["git_auth_secret<br/>Type: kubernetes.io/basic-auth<br/>Purpose: Git auth for Konflux<br/>Tekton pipelines<br/>Provisioned: Konflux/PaC<br/>Rotation: Auto"]
    end

    subgraph PlatformRBAC["Platform RBAC (Managed by Notebook Controller)"]
        direction TB
        NCRole["Notebook Controller<br/>manages pod RBAC"]
        SAToken["ServiceAccount Token<br/>for oc CLI access<br/>from workbenches"]
    end

    %% User flow
    User -->|"OAuth2/OIDC"| IngressTLS
    IngressTLS --> KubeRBACProxy
    IngressTLS --> OAuthProxy
    KubeRBACProxy -->|"HTTP (no auth)<br/>localhost"| JupyterAuth
    KubeRBACProxy -->|"HTTP (no auth)<br/>localhost"| RStudioAuth
    KubeRBACProxy -->|"HTTP (no auth)<br/>localhost"| CodeServerAuth
    OAuthProxy -->|"HTTP (no auth)<br/>localhost"| JupyterAuth
    OAuthProxy -->|"HTTP (no auth)<br/>localhost"| RStudioAuth
    OAuthProxy -->|"HTTP (no auth)<br/>localhost"| CodeServerAuth

    %% Styling
    style User fill:#4a90e2,color:#fff
    style IngressTLS fill:#ffe6cc,stroke:#d79b00
    style KubeRBACProxy fill:#fff2cc,stroke:#d6b656
    style OAuthProxy fill:#fff2cc,stroke:#d6b656
    style JupyterAuth fill:#f8cecc,stroke:#b85450
    style RStudioAuth fill:#f8cecc,stroke:#b85450
    style CodeServerAuth fill:#f8cecc,stroke:#b85450
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style NoTLS fill:#d5e8d4,stroke:#82b366
    style RHELSecret fill:#e1d5e7,stroke:#9673a6
    style GitSecret fill:#e1d5e7,stroke:#9673a6
    style NCRole fill:#dae8fc,stroke:#6c8ebf
    style SAToken fill:#dae8fc,stroke:#6c8ebf
