graph TD
    subgraph Note["RBAC Architecture Note"]
        direction TB
        Info["notebooks-downstream produces container images, NOT operators.<br/>No RBAC definitions exist in this repository.<br/>All RBAC is managed externally by the deploying platform."]
    end

    subgraph PlatformRBAC["Platform-Level RBAC (managed by odh-notebook-controller)"]
        direction TB

        subgraph AuthFlow["Authentication & Authorization Flow"]
            direction TB
            UserBrowser["User Browser<br/>(OAuth-authenticated)"]
            Gateway["RHOAI Gateway<br/>OAuth Token Validation"]
            KubeRBACProxy["kube-rbac-proxy Sidecar<br/>Injected per-workbench pod"]
            WorkbenchContainer["Workbench Container<br/>(no auth - relies on sidecar)"]
        end

        UserBrowser -->|"OAuth Token<br/>HTTPS/443"| Gateway
        Gateway -->|"Bearer Token<br/>HTTPS/8443"| KubeRBACProxy
        KubeRBACProxy -->|"Authorized<br/>HTTP (localhost)"| WorkbenchContainer
    end

    subgraph NamespaceIsolation["Per-User Namespace Isolation"]
        direction TB
        NS1["User Namespace A<br/>user-a-project"]
        NS2["User Namespace B<br/>user-b-project"]
        NS3["User Namespace C<br/>user-c-project"]

        WB1["Workbench Pod A<br/>+ kube-rbac-proxy"]
        WB2["Workbench Pod B<br/>+ kube-rbac-proxy"]
        WB3["Workbench Pod C<br/>+ kube-rbac-proxy"]

        NS1 --- WB1
        NS2 --- WB2
        NS3 --- WB3
    end

    subgraph Secrets["Secrets (in this repository)"]
        direction TB
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL entitlement certs<br/>Provisioned: Manual<br/>Auto-rotate: No"]
        GitSecret["git-auth-secret<br/>Type: Opaque<br/>Purpose: Git creds for CI pipelines<br/>Provisioned: Pipelines as Code<br/>Auto-rotate: Yes"]
    end

    subgraph WorkbenchEndpoints["Workbench Endpoints (all behind kube-rbac-proxy)"]
        direction TB
        Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>Auth: OAuth + kube-rbac-proxy<br/>Policy: Per-user namespace"]
        CodeServerEP["Code Server<br/>8585/TCP HTTP<br/>Auth: OAuth + kube-rbac-proxy<br/>Policy: Per-user namespace"]
        RStudioEP["RStudio Server<br/>8787/TCP HTTP<br/>Auth: OAuth + kube-rbac-proxy<br/>Policy: Per-user namespace"]
    end

    KubeRBACProxy -.->|"enforces access to"| Jupyter
    KubeRBACProxy -.->|"enforces access to"| CodeServerEP
    KubeRBACProxy -.->|"enforces access to"| RStudioEP

    subgraph FIPSNote["FIPS Compliance"]
        FIPS["mongocli: CGO_ENABLED=1, -tags strictfipsruntime<br/>Python: UBI9 OpenSSL, FIPS when host enabled<br/>TLS: Terminated at platform ingress, not workbench"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style PlatformRBAC fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NamespaceIsolation fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style WorkbenchEndpoints fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style FIPSNote fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    style UserBrowser fill:#f9f9f9,stroke:#999
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KubeRBACProxy fill:#f5a623,stroke:#333,color:#fff
    style WorkbenchContainer fill:#4a90e2,stroke:#333,color:#fff
    style RHELSecret fill:#f8cecc,stroke:#b85450
    style GitSecret fill:#f8cecc,stroke:#b85450
    style Jupyter fill:#4a90e2,stroke:#333,color:#fff
    style CodeServerEP fill:#4a90e2,stroke:#333,color:#fff
    style RStudioEP fill:#4a90e2,stroke:#333,color:#fff
    style FIPS fill:#e1d5e7,stroke:#9673a6
