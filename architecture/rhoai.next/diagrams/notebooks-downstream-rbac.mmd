graph TD
    subgraph NotebooksDownstream["notebooks-downstream (Container Images)"]
        Note1["No RBAC resources defined<br/>These are container images, not operators"]
    end

    subgraph ExternalRBAC["RBAC Managed by Other Components"]
        direction TB

        subgraph ControllerRBAC["odh-notebook-controller (manages notebook RBAC)"]
            SA_Notebook["ServiceAccount<br/>{notebook-name}<br/>(per workbench)"]
            RB_Notebook["RoleBinding<br/>(per namespace)"]
            Role_Notebook["Role<br/>notebook-access"]
        end

        subgraph SidecarRBAC["kube-rbac-proxy (auth sidecar)"]
            SA_KRBAC["ServiceAccount<br/>(from controller)"]
            TokenReview["TokenReview<br/>→ OpenShift API"]
            SAR["SubjectAccessReview<br/>→ OpenShift API"]
        end

        subgraph PlatformRBAC["Platform Operator RBAC"]
            SA_Operator["ServiceAccount<br/>rhods-operator"]
            CR_Operator["ClusterRole<br/>rhods-operator-role"]
            CRB_Operator["ClusterRoleBinding<br/>rhods-operator-binding"]
        end
    end

    subgraph AuthFlow["Authentication Flow (Runtime)"]
        User["User Browser"]
        OIDC["OpenShift OAuth<br/>(OIDC Provider)"]
        KProxy["kube-rbac-proxy<br/>Port: 8443/TCP"]
        Notebook["Notebook Container<br/>Port: 8888/TCP<br/>Auth: DISABLED"]
    end

    %% Auth flow
    User -->|"1. HTTPS/8443<br/>Bearer Token"| KProxy
    KProxy -->|"2. TokenReview"| TokenReview
    TokenReview -->|"3. Validate token"| OIDC
    KProxy -->|"4. SubjectAccessReview"| SAR
    SAR -->|"5. Check permissions"| Role_Notebook
    KProxy -->|"6. Proxy if authorized<br/>HTTP/8888 (no auth)"| Notebook

    %% Controller creates RBAC
    SA_Notebook -->|bound via| RB_Notebook
    RB_Notebook -->|grants| Role_Notebook

    %% Operator RBAC
    SA_Operator -->|bound via| CRB_Operator
    CRB_Operator -->|grants| CR_Operator

    %% Styling
    style Note1 fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    style SA_Notebook fill:#4a90e2,stroke:#333,color:#fff
    style SA_KRBAC fill:#4a90e2,stroke:#333,color:#fff
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style Role_Notebook fill:#f5a623,stroke:#333
    style CR_Operator fill:#f5a623,stroke:#333
    style RB_Notebook fill:#7ed321,stroke:#333
    style CRB_Operator fill:#7ed321,stroke:#333
    style TokenReview fill:#ffcdd2,stroke:#c62828
    style SAR fill:#ffcdd2,stroke:#c62828
    style User fill:#e1f5fe,stroke:#0288d1
    style KProxy fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    style Notebook fill:#bbdefb,stroke:#1565c0
    style OIDC fill:#e8e8e8,stroke:#333
