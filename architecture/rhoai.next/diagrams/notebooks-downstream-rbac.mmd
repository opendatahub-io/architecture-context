graph TD
    subgraph "Authentication & Authorization Flow"
        direction TB

        subgraph "Identity Provider"
            IDP["Platform OIDC/OAuth<br/>Identity Provider"]
        end

        subgraph "Platform Gateway"
            Gateway["Envoy Gateway<br/>TLS 1.3 Termination<br/>OIDC Token Validation"]
        end

        subgraph "Per-Pod Auth Sidecar (injected by ODH Notebook Controller)"
            KubeRBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP (TLS)<br/>Performs SubjectAccessReview"]
        end

        subgraph "Kubernetes RBAC (managed by ODH Notebook Controller)"
            SAR["SubjectAccessReview<br/>(per-request authorization)"]
            NotebookRB["Per-Notebook RoleBinding<br/>(created per workbench)"]
            UserSA["User Identity<br/>(from Bearer Token)"]
        end

        subgraph "Workbench Container Security"
            direction TB
            NonRoot["Non-Root Execution<br/>UID: 1001 / GID: 0"]
            RandomUID["OpenShift Random UID<br/>Compatible"]
            NoPriv["No Privileged<br/>Capabilities"]
            AuthNone["Internal Auth: NONE<br/>(--auth none / equivalent)"]
        end
    end

    subgraph "Secrets (Build-time only)"
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio BuildConfig<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Image Provenance"
        ImageDigest["Image References<br/>Pinned by SHA256 digest<br/>in params.env"]
        CommitHash["Build Commit Tracking<br/>opendatahub.io/<br/>notebook-build-commit<br/>annotation"]
        VersionTags["Version Tags: N through N-5<br/>N = current (2025.1)<br/>Outdated: opendatahub.io/<br/>image-tag-outdated=true"]
    end

    %% Auth flow
    IDP -->|"issues OIDC token"| Gateway
    Gateway -->|"forwards Bearer Token<br/>via HTTPRoute"| KubeRBACProxy
    KubeRBACProxy -->|"validates token"| SAR
    SAR -->|"checks"| NotebookRB
    NotebookRB -->|"authorizes"| UserSA

    %% Container security
    KubeRBACProxy -->|"if authorized,<br/>proxies to container"| NonRoot

    %% Build-time
    RHELSecret -->|"used by<br/>RStudio BuildConfig only"| ImageDigest

    %% Notes
    Note1["NOTE: This repository defines NO<br/>ClusterRoles or RoleBindings.<br/>All RBAC is managed per-workbench<br/>by the ODH Notebook Controller."]

    style KubeRBACProxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style SAR fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style NotebookRB fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style NonRoot fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RandomUID fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NoPriv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style AuthNone fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style RHELSecret fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ImageDigest fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style CommitHash fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style VersionTags fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Note1 fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style IDP fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style UserSA fill:#4a90e2,stroke:#333,color:#fff
