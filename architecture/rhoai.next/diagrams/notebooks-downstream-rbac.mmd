graph TD
    subgraph NotebooksDownstream["Notebooks-Downstream RBAC Model"]
        direction TB

        NoRBAC["This component defines NO RBAC resources.<br/>RBAC is managed by the ODH Notebook Controller."]
    end

    subgraph ExternalRBAC["RBAC Managed by ODH Notebook Controller (External)"]
        direction TB

        subgraph WorkbenchPod["Workbench Pod Security"]
            UID["Container UID: 1001<br/>(non-root)"]
            GID["Container GID: 0<br/>(OpenShift random UID model)"]
            NoToken["Auth Token: DISABLED<br/>(--ServerApp.token='')"]
        end

        subgraph AuthSidecar["Authentication Sidecar (Injected by Controller)"]
            KRBP["kube-rbac-proxy<br/>(RHOAI 3.x)<br/>Enforces K8s RBAC authz"]
            OAuthProxy["oauth-proxy<br/>(RHOAI 2.x)<br/>Enforces OAuth2 authz"]
        end

        subgraph SecretsUsed["Secrets"]
            RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription creds<br/>Mount: /opt/app-root/src/.sec<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
            GitSecret["git_auth_secret<br/>Type: kubernetes.io/basic-auth<br/>Purpose: Konflux Tekton auth<br/>Provisioned: Pipelines as Code<br/>Auto-Rotate: Yes"]
        end
    end

    subgraph AuthFlow["Authentication Flow"]
        direction LR
        UserReq["User Request<br/>(HTTPS/443)"] --> IngressTLS["TLS Termination<br/>(Ingress)"]
        IngressTLS --> SidecarAuth["Auth Sidecar<br/>(kube-rbac-proxy<br/>or oauth-proxy)"]
        SidecarAuth -->|"Authenticated"| WorkbenchApp["Workbench App<br/>(HTTP, no auth)"]
        SidecarAuth -->|"Rejected"| Denied["403 Forbidden"]
    end

    %% Styling
    style NotebooksDownstream fill:#f9f9f9,stroke:#999,stroke-width:2px
    style NoRBAC fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style ExternalRBAC fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style WorkbenchPod fill:#d5e8d4,stroke:#82b366
    style AuthSidecar fill:#ffe6cc,stroke:#d79b00
    style SecretsUsed fill:#f8cecc,stroke:#b85450
    style AuthFlow fill:#dae8fc,stroke:#6c8ebf
    style UID fill:#d5e8d4,stroke:#82b366
    style GID fill:#d5e8d4,stroke:#82b366
    style NoToken fill:#f8cecc,stroke:#b85450
    style KRBP fill:#ffe6cc,stroke:#d79b00
    style OAuthProxy fill:#ffe6cc,stroke:#d79b00
    style RHELSecret fill:#f8cecc,stroke:#b85450
    style GitSecret fill:#f8cecc,stroke:#b85450
    style UserReq fill:#f9f9f9,stroke:#999
    style IngressTLS fill:#ffe6cc,stroke:#d79b00
    style SidecarAuth fill:#ffe6cc,stroke:#d79b00
    style WorkbenchApp fill:#d5e8d4,stroke:#82b366
    style Denied fill:#f8cecc,stroke:#b85450
