graph TD
    subgraph SecurityModel["Notebooks Downstream Security Model"]
        direction TB

        subgraph AuthDelegation["Authentication Delegation (No Built-in Auth)"]
            direction TB
            Note1["CRITICAL: All workbench images<br/>DISABLE built-in authentication<br/>(--ServerApp.token='')"]
        end

        subgraph RHOAI3x["RHOAI 3.x Auth Model"]
            direction LR
            User3x["User Browser"]
            Route3x["HTTPRoute<br/>443/TCP HTTPS"]
            KubeRBAC["kube-rbac-proxy<br/>Sidecar"]
            Workbench3x["Workbench Container<br/>8888/TCP HTTP"]

            User3x -->|"TLS 1.2+"| Route3x
            Route3x -->|"TLS terminated"| KubeRBAC
            KubeRBAC -->|"Authenticated"| Workbench3x
        end

        subgraph RHOAI2x["RHOAI 2.x Auth Model"]
            direction LR
            User2x["User Browser"]
            Route2x["OpenShift Route<br/>443/TCP HTTPS"]
            OAuthProxy["oauth-proxy<br/>Sidecar"]
            Workbench2x["Workbench Container<br/>8888/TCP HTTP"]

            User2x -->|"TLS 1.2+"| Route2x
            Route2x -->|"TLS terminated"| OAuthProxy
            OAuthProxy -->|"Authenticated"| Workbench2x
        end

        subgraph ContainerSecurity["Container Security"]
            direction LR
            NonRoot["Non-root User<br/>UID 1001"]
            GID0["GID 0<br/>(root group)"]
            RandomUID["OpenShift Random UID<br/>Security Model"]

            NonRoot --- GID0
            GID0 --- RandomUID
        end

        subgraph RBACNote["RBAC"]
            direction LR
            NoRBAC["No ClusterRoles or<br/>RoleBindings defined<br/>by this component"]
            Delegated["RBAC managed by<br/>ODH Notebook Controller"]

            NoRBAC --- Delegated
        end

        subgraph SecretsInfo["Secrets"]
            direction LR
            RHELSub["rhel-subscription-secret<br/>Type: Opaque<br/>RHEL creds for entitled builds<br/>Manual provisioning<br/>No auto-rotate"]
            GitAuth["git_auth_secret<br/>Type: kubernetes.io/basic-auth<br/>Git auth for Konflux Tekton<br/>Konflux provisioned<br/>Auto-rotate: Yes"]
        end
    end

    %% Styling
    style SecurityModel fill:#f9f9f9,stroke:#333,stroke-width:2px
    style AuthDelegation fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RHOAI3x fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style RHOAI2x fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style ContainerSecurity fill:#e6d5f7,stroke:#7c3aed,stroke-width:1px
    style RBACNote fill:#f8cecc,stroke:#b85450,stroke-width:1px
    style SecretsInfo fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    style Note1 fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#b85450
    style KubeRBAC fill:#82b366,color:#fff
    style OAuthProxy fill:#6c8ebf,color:#fff
    style NoRBAC fill:#f8cecc,stroke:#b85450
    style RHELSub fill:#ffe6cc,stroke:#d79b00
    style GitAuth fill:#ffe6cc,stroke:#d79b00
