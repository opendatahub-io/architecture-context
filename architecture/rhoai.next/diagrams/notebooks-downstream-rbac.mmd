graph TD
    subgraph "Notebooks-Downstream RBAC Model"
        direction TB

        Note["NOTE: This repository defines container images,<br/>NOT operators. No ClusterRoles or RoleBindings<br/>are defined by notebooks-downstream itself."]

        subgraph ExternalRBAC["RBAC Managed by ODH Notebook Controller"]
            direction TB

            subgraph PerWorkbench["Per-Workbench (created at pod launch)"]
                SA["ServiceAccount<br/>{workbench-name}<br/>Namespace: {user-project}"]
                RB["RoleBinding<br/>{workbench-name}-rbac"]
                CR["ClusterRole<br/>(system:auth-delegator)"]
            end

            subgraph AuthEnforcement["Authentication Enforcement"]
                KRBAC["kube-rbac-proxy Sidecar<br/>Injected by Notebook Controller<br/>Port: 8443/TCP"]
                SAR["SubjectAccessReview<br/>Validates user identity<br/>per HTTP request"]
            end

            SA -->|bound via| RB
            RB -->|grants| CR
            KRBAC -->|performs| SAR
        end

        subgraph ContainerSecurity["Container Security Posture"]
            direction TB
            NonRoot["Non-Root Execution<br/>UID: 1001<br/>GID: 0 (root group)"]
            RandomUID["OpenShift Random UID<br/>Support enabled"]
            NoAuth["Internal Auth: None<br/>--auth none / equivalent<br/>All auth delegated to sidecar"]
        end

        subgraph BuildSecrets["Build-Time Secrets"]
            direction TB
            RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio BuildConfig builds<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        end
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#f5a623,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style KRBAC fill:#dae8fc,stroke:#6c8ebf
    style SAR fill:#dae8fc,stroke:#6c8ebf
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style RandomUID fill:#d5e8d4,stroke:#82b366
    style NoAuth fill:#ffe6cc,stroke:#d79b00
    style RHELSecret fill:#f8cecc,stroke:#b85450
