graph TD
    subgraph PlatformRBAC["Platform-Managed RBAC (odh-notebook-controller)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts (per-notebook)"]
            NotebookSA["Per-Notebook ServiceAccount<br/>(created by odh-notebook-controller)<br/>Namespace: {user-namespace}"]
        end

        subgraph SidecarAuth["Authentication Sidecar"]
            KubeRBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP HTTPS<br/>Injected by odh-notebook-controller"]
        end

        subgraph AuthMechanisms["Authentication Mechanisms"]
            SAR["SubjectAccessReview<br/>Per-user RBAC validation"]
            OAuthToken["OAuth Token Validation<br/>Forwarded from platform Gateway"]
        end

        NotebookSA -->|"bound to"| KubeRBACProxy
        KubeRBACProxy -->|"performs"| SAR
        KubeRBACProxy -->|"validates"| OAuthToken
    end

    subgraph WorkbenchEndpoints["Workbench Endpoints"]
        direction TB

        JupyterEndpoint["JupyterLab<br/>Port: 8888/TCP HTTP<br/>Auth: Token (configurable,<br/>disabled by default in kustomize)"]
        CodeServerEndpoint["Code Server<br/>Port: 8585/TCP HTTP<br/>Auth: None<br/>(delegated to platform)"]
        RStudioEndpoint["RStudio Server<br/>Port: 8585/TCP HTTP<br/>Auth: None<br/>(delegated to platform)"]
    end

    subgraph BuildSecrets["Build-Time Secrets"]
        RHELSub["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for<br/>RStudio RHEL9 builds<br/>Provisioned: Manual<br/>Rotation: None"]
        GitAuth["git_auth_secret<br/>Type: kubernetes.io/basic-auth<br/>Purpose: Konflux pipeline Git clones<br/>Provisioned: Konflux/PaC<br/>Rotation: Auto"]
    end

    subgraph AccessFlow["Request Flow"]
        User["User Request<br/>(OAuth authenticated)"]
        Gateway["Platform Gateway<br/>443/TCP HTTPS"]
    end

    %% Access flow
    User -->|"HTTPS/443<br/>OAuth token"| Gateway
    Gateway -->|"HTTPS/8443<br/>Token forwarded"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8888<br/>Trusted (post-auth)"| JupyterEndpoint
    KubeRBACProxy -->|"HTTP/8585<br/>Trusted (post-auth)"| CodeServerEndpoint
    KubeRBACProxy -->|"HTTP/8585<br/>Trusted (post-auth)"| RStudioEndpoint

    %% Notes
    subgraph RBACNotes["RBAC Design Notes"]
        Note1["Workbench images do NOT define<br/>their own RBAC resources"]
        Note2["All RBAC is managed externally by<br/>odh-notebook-controller"]
        Note3["Per-notebook ServiceAccount +<br/>RoleBinding created at workbench<br/>creation time"]
    end

    %% Styling
    style NotebookSA fill:#4a90e2,color:#fff
    style KubeRBACProxy fill:#f5a623,color:#fff
    style SAR fill:#f5a623,color:#fff
    style OAuthToken fill:#f5a623,color:#fff
    style JupyterEndpoint fill:#7ed321,color:#fff
    style CodeServerEndpoint fill:#7ed321,color:#fff
    style RStudioEndpoint fill:#7ed321,color:#fff
    style RHELSub fill:#e74c3c,color:#fff
    style GitAuth fill:#e74c3c,color:#fff
    style User fill:#f9f9f9,stroke:#333
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style Note1 fill:#fff,stroke:#ccc
    style Note2 fill:#fff,stroke:#ccc
    style Note3 fill:#fff,stroke:#ccc
