graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"inference payloads<br/>HTTP 8080/TCP"| KServe["KServe<br/>InferenceService"]
    TrustyAI -->|"inference payloads<br/>HTTP 8080/TCP"| ModelMesh["ModelMesh<br/>Serving"]
    TrustyAI -->|"inference calls<br/>gRPC 8033 / HTTP"| KServeModel["KServe Model<br/>Endpoint"]

    %% Operator
    TrustyAIOp["TrustyAI Operator"] -->|"deploys & manages<br/>CRD reconciliation"| TrustyAI

    %% Monitoring
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrapes metrics<br/>HTTP 8080/TCP"| TrustyAI

    %% Dashboard integration
    Dashboard["OpenShift AI<br/>Dashboard"] -->|"queries fairness/drift<br/>HTTP 8080/TCP"| TrustyAI

    %% CloudEvents
    TrustyAI -->|"receives events"| Kubeflow["Kubeflow<br/>CloudEvent Broker"]

    %% Storage backends
    TrustyAI -->|"data persistence<br/>filesystem I/O"| PVC["PVC Storage<br/>(default)"]
    TrustyAI -.->|"optional<br/>HTTP 9000/443"| MinIO["MinIO / S3"]
    TrustyAI -.->|"optional<br/>JDBC 3306"| DB["MariaDB / MySQL"]

    %% Framework dependencies
    TrustyAI -->|"app framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"inference protocol"| gRPC["gRPC 1.75.0 /<br/>Protobuf 3.25.5"]
    TrustyAI -->|"transport layer"| Netty["Netty 4.1.125.Final"]
    TrustyAI -->|"metrics export"| Micrometer["Micrometer<br/>(via Quarkus)"]
    TrustyAI -->|"constraint solver"| OptaPlanner["OptaPlanner 8.30.0<br/>(Counterfactual)"]
    TrustyAI -.->|"optional bridge"| Arrow["Apache Arrow 15.0.2<br/>(Python interop)"]

    %% Kubernetes API
    TrustyAI -->|"ConfigMap read/write"| K8sAPI["Kubernetes API"]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#7ed321,stroke:#333
