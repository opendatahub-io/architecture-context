graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"lifecycle mgmt<br/>CRD: TrustyAIService"| Operator["trustyai-service-operator"]
    TrustyAI -->|"inference payloads<br/>HTTP/gRPC"| KServe["KServe / ModelMesh"]
    TrustyAI -->|"metrics scraping<br/>GET /q/metrics"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% External Framework Dependencies
    TrustyAI -->|"application framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"REST endpoints"| RESTEasy["RESTEasy Reactive"]
    TrustyAI -->|"metrics collection"| Micrometer["Micrometer +<br/>Prometheus Registry"]
    TrustyAI -->|"health checks"| SmallRye["SmallRye Health"]
    TrustyAI -->|"CloudEvents"| Funqy["Quarkus Funqy<br/>Knative Events"]
    TrustyAI -->|"scheduling"| Scheduler["Quarkus Scheduler"]

    %% Data Dependencies
    TrustyAI -->|"columnar data"| Arrow["Apache Arrow 15.0.2"]
    TrustyAI -->|"gRPC transport"| gRPC["gRPC Netty Shaded 1.75.0"]
    TrustyAI -->|"protobuf"| Protobuf["Protocol Buffers 3.25.5"]
    TrustyAI -->|"constraint solving<br/>(counterfactual)"| OptaPlanner["OptaPlanner 8.30.0"]

    %% Storage Dependencies (conditional)
    TrustyAI -->|"JDBC persistence<br/>3306/TCP"| MariaDB["MariaDB/MySQL<br/>(DATABASE mode)"]
    TrustyAI -->|"S3 object storage<br/>HTTP API"| MinIO["MinIO<br/>(MINIO mode)"]
    TrustyAI -->|"filesystem<br/>/inputs"| PVC["PVC<br/>(PVC mode, default)"]

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    Route["OpenShift Route"] -->|"ingress<br/>80/TCP HTTP"| TrustyAI
    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"init container writes<br/>payload processor URL"| TrustyAI

    %% Conditional ORM
    TrustyAI -->|"JPA persistence"| Hibernate["Hibernate ORM<br/>(DATABASE mode)"]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style Operator fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333

    %% Frameworks
    style Quarkus fill:#4695EB,stroke:#333,color:#fff
    style RESTEasy fill:#4695EB,stroke:#333,color:#fff
    style Micrometer fill:#4695EB,stroke:#333,color:#fff
    style SmallRye fill:#4695EB,stroke:#333,color:#fff
    style Funqy fill:#4695EB,stroke:#333,color:#fff
    style Scheduler fill:#4695EB,stroke:#333,color:#fff

    %% Libraries
    style Arrow fill:#999,stroke:#333
    style gRPC fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333
    style OptaPlanner fill:#999,stroke:#333
    style Hibernate fill:#999,stroke:#333

    %% Storage
    style MariaDB fill:#f5a623,stroke:#333
    style MinIO fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333

    %% Infrastructure
    style Route fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#e8e8e8,stroke:#333
