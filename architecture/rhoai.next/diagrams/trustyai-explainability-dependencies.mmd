graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"CloudEvent consumer<br/>HTTP/8080"| KServe["KServe /<br/>ModelMesh Serving"]
    TrustyAI -->|"gRPC client<br/>KServe v2"| KServeModel["KServe Model Server"]
    TrustyAI -.->|"deployed by<br/>manages TLS, storage"| Operator["TrustyAI Service<br/>Operator"]
    TrustyAI -->|"CloudEvent routing<br/>HTTP/8080"| Knative["Knative Eventing"]

    %% Monitoring
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrapes /q/metrics<br/>HTTP GET, Bearer Token"| TrustyAI

    %% Dashboard integration
    Dashboard["ODH Dashboard"] -->|"REST client<br/>HTTP/8080"| TrustyAI

    %% Storage backends
    TrustyAI -->|"JDBC<br/>3306/TCP"| MariaDB["MariaDB / MySQL"]
    TrustyAI -->|"S3 API<br/>9000/TCP"| MinIO["MinIO Server"]
    TrustyAI -->|"filesystem I/O"| PVC["PersistentVolumeClaim"]

    %% Infrastructure
    TrustyAI -->|"API calls<br/>configmaps"| K8sAPI["Kubernetes API"]

    %% Key framework dependencies
    subgraph Frameworks["Application Frameworks"]
        Quarkus["Quarkus 3.8.5"]
        gRPC["io.grpc 1.75.0"]
        Arrow["Apache Arrow 15.0.2"]
        OptaPlanner["OptaPlanner 8.30.0<br/>(counterfactual solver)"]
        Micrometer["Micrometer<br/>(Prometheus registry)"]
        Hibernate["Hibernate ORM<br/>(Quarkus-managed)"]
    end

    TrustyAI -.->|"app framework"| Quarkus
    TrustyAI -.->|"KServe v2 protocol"| gRPC
    TrustyAI -.->|"batch data exchange"| Arrow
    TrustyAI -.->|"counterfactual explanations"| OptaPlanner
    TrustyAI -.->|"metrics exposition"| Micrometer
    TrustyAI -.->|"DB storage backend"| Hibernate

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeModel fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Knative fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style MariaDB fill:#f5a623,stroke:#333,color:#fff
    style MinIO fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Quarkus fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Arrow fill:#999,stroke:#333,color:#fff
    style OptaPlanner fill:#999,stroke:#333,color:#fff
    style Micrometer fill:#999,stroke:#333,color:#fff
    style Hibernate fill:#999,stroke:#333,color:#fff
    style Frameworks fill:#f0f0f0,stroke:#ccc
