graph LR
    TrustyAI["TrustyAI Explainability<br/>Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"CloudEvents consumer<br/>8080/TCP HTTP"| KServe["KServe / ModelMesh"]
    TrustyAI -->|"HTTP v1/v2 + gRPC v2<br/>client calls"| KServeServers["KServe Inference<br/>Servers"]
    TrustyAI -.->|"managed by"| Operator["trustyai-service-<br/>operator"]
    TrustyAI -->|"ConfigMap read"| TrustyAIConfig["trustyai-config<br/>ConfigMap"]
    TrustyAI -->|"ConfigMap write<br/>(init container)"| ModelServingConfig["model-serving-config<br/>ConfigMap"]

    %% Platform Dependencies
    TrustyAI -->|"ServiceMonitor scrape<br/>8080/TCP"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]
    TrustyAI -->|"oc apply 443/TCP<br/>HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% Framework Dependencies
    TrustyAI -->|"app framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"gRPC client"| GRPC["io.grpc 1.75.0"]
    TrustyAI -->|"metrics"| Micrometer["Micrometer<br/>Prometheus"]
    TrustyAI -->|"constraint solver<br/>(counterfactual)"| OptaPlanner["OptaPlanner<br/>8.30.0.Final"]

    %% Optional Storage Dependencies
    TrustyAI -->|"S3 API<br/>(optional)"| MinIO["MinIO / S3<br/>Storage"]
    TrustyAI -->|"JDBC 3306/TCP<br/>(optional)"| Database["MariaDB /<br/>MySQL"]
    TrustyAI -->|"volume mount<br/>(default)"| PVC["PVC Volume<br/>/inputs"]

    %% Integration Points (who calls TrustyAI)
    Dashboard["ODH Dashboard"] -->|"UI queries"| TrustyAI
    Operator -->|"deploys +<br/>kube-rbac-proxy"| TrustyAI

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeServers fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIConfig fill:#7ed321,stroke:#333,color:#fff
    style ModelServingConfig fill:#7ed321,stroke:#333,color:#fff

    %% Platform
    style Prometheus fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% Framework
    style Quarkus fill:#dae8fc,stroke:#6c8ebf
    style GRPC fill:#dae8fc,stroke:#6c8ebf
    style Micrometer fill:#dae8fc,stroke:#6c8ebf
    style OptaPlanner fill:#dae8fc,stroke:#6c8ebf

    %% External/Optional
    style MinIO fill:#f5a623,stroke:#333,color:#fff
    style Database fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
