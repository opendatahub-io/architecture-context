graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Framework Dependencies (Required)
    TrustyAI -->|"application framework<br/>REST, CDI, health, scheduler"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"networking<br/>gRPC transport, HTTP"| Netty["Netty 4.1.125.Final"]
    TrustyAI -->|"model inference protocol<br/>KServe V2"| GRPC["gRPC 1.75.0 /<br/>Protobuf 3.25.5"]
    TrustyAI -->|"metric publication"| Micrometer["Micrometer /<br/>Prometheus"]

    %% Optional External Dependencies
    TrustyAI -.->|"database backend<br/>(optional)"| Hibernate["Hibernate ORM<br/>6.2.13.Final"]
    TrustyAI -.->|"Java-Python interop<br/>(optional)"| Arrow["Apache Arrow<br/>15.0.2"]
    TrustyAI -.->|"counterfactual solver<br/>(optional)"| OptaPlanner["OptaPlanner<br/>8.30.0.Final"]
    TrustyAI -.->|"S3 storage backend<br/>(optional)"| MinIOClient["MinIO Client<br/>3.3.1 (Quarkiverse)"]

    %% Internal Platform Dependencies
    ModelMesh["ModelMesh Serving"] -->|"HTTP POST<br/>inference payloads"| TrustyAI
    TrustyAI -->|"gRPC/HTTP2<br/>V2 inference"| KServeServers["KServe Model Servers"]
    Prometheus["Prometheus"] -->|"HTTP GET /q/metrics<br/>Bearer token (SA)"| TrustyAI
    Operator["TrustyAI Service<br/>Operator"] -.->|"CRD-managed<br/>deployment lifecycle"| TrustyAI

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard /<br/>Grafana"] -->|"via Prometheus<br/>PromQL"| Prometheus

    %% Storage backends
    TrustyAI -->|"File I/O<br/>CSV/Parquet"| PVC["PVC Storage<br/>(default)"]
    TrustyAI -.->|"JDBC/3306<br/>Username/Password"| MariaDB["MariaDB / MySQL"]
    TrustyAI -.->|"S3 API/9000<br/>HTTPS TLS"| MinIOStorage["MinIO Storage"]

    %% ConfigMap integration
    InitContainer["Init Container"] -.->|"writes payloadProcessors<br/>URL → ModelMesh"| ModelServingConfig["model-serving-config<br/>ConfigMap"]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required framework deps
    style Quarkus fill:#999,stroke:#333
    style Netty fill:#999,stroke:#333
    style GRPC fill:#999,stroke:#333
    style Micrometer fill:#999,stroke:#333

    %% Optional deps
    style Hibernate fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Arrow fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style OptaPlanner fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style MinIOClient fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Internal RHOAI deps
    style ModelMesh fill:#7ed321,stroke:#333
    style KServeServers fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333

    %% Storage
    style PVC fill:#f5a623,stroke:#333
    style MariaDB fill:#f5a623,stroke:#333,stroke-dasharray: 5 5
    style MinIOStorage fill:#f5a623,stroke:#333,stroke-dasharray: 5 5

    %% Config
    style InitContainer fill:#e8e8e8,stroke:#333
    style ModelServingConfig fill:#e8e8e8,stroke:#333
