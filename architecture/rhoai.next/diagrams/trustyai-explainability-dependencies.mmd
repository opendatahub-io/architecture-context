    style KServeModel fill:#7ed321,stroke:#333
    style TrustyAIOp fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style Kubeflow fill:#7ed321,stroke:#333

    style PVC fill:#f5a623,stroke:#333
    style MinIO fill:#f5a623,stroke:#333
    style DB fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333

    style Quarkus fill:#999,stroke:#333
    style gRPC fill:#999,stroke:#333
