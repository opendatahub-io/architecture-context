graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"lifecycle mgmt<br/>CRD: TrustyAIService"| Operator["trustyai-service-<br/>operator"]
    TrustyAI -->|"HTTP/8080 v1/v2<br/>gRPC plaintext"| KServe["KServe /<br/>ModelMesh"]
    TrustyAI -->|"metrics scraping<br/>HTTP/8080 /q/metrics"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% External Framework Dependencies
    TrustyAI -->|"application framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"columnar data"| Arrow["Apache Arrow<br/>15.0.2"]
    TrustyAI -->|"gRPC transport"| GRPC["gRPC Netty Shaded<br/>1.75.0"]
    TrustyAI -->|"constraint solver<br/>(counterfactual)"| OptaPlanner["OptaPlanner<br/>8.30.0.Final"]
    TrustyAI -->|"network I/O"| Netty["Netty<br/>4.1.125.Final"]

    %% Conditional Storage Dependencies
    TrustyAI -.->|"JDBC/3306<br/>(DATABASE mode)"| MariaDB["MariaDB / MySQL"]
    TrustyAI -.->|"S3 API<br/>(MINIO mode)"| MinIO["MinIO<br/>(Quarkiverse 3.3.1)"]
    TrustyAI -.->|"filesystem<br/>(PVC mode)"| PVC["PersistentVolumeClaim"]

    %% Quarkus Extensions
    Quarkus -->|"REST framework"| RESTEasy["RESTEasy Reactive"]
    Quarkus -->|"metrics"| Micrometer["Micrometer +<br/>Prometheus"]
    Quarkus -->|"ORM"| Hibernate["Hibernate ORM"]
    Quarkus -->|"CloudEvents"| Funqy["Funqy Knative<br/>Events"]
    Quarkus -->|"health checks"| SmallRye["SmallRye Health"]
    Quarkus -->|"scheduling"| Scheduler["Quarkus Scheduler"]
    Quarkus -->|"caching"| Cache["Quarkus Cache"]

    %% Integration Points (other components that depend on TrustyAI)
    Dashboard["ODH Dashboard"] -->|"UI metrics display"| TrustyAI
    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"init container writes<br/>payload processor URL"| TrustyAI
    CertManager["cert-manager"] -.->|"TLS certs for<br/>HTTPS/4443"| TrustyAI
    Route["OpenShift Route"] -->|"external ingress<br/>HTTP/80"| TrustyAI

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style Operator fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333

    %% External frameworks
    style Quarkus fill:#999,stroke:#333
    style Arrow fill:#999,stroke:#333
    style GRPC fill:#999,stroke:#333
    style OptaPlanner fill:#999,stroke:#333
    style Netty fill:#999,stroke:#333

    %% Quarkus extensions
    style RESTEasy fill:#bbb,stroke:#333
    style Micrometer fill:#bbb,stroke:#333
    style Hibernate fill:#bbb,stroke:#333
    style Funqy fill:#bbb,stroke:#333
    style SmallRye fill:#bbb,stroke:#333
    style Scheduler fill:#bbb,stroke:#333
    style Cache fill:#bbb,stroke:#333

    %% Conditional / External services
    style MariaDB fill:#f5a623,stroke:#333
    style MinIO fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style CertManager fill:#f5a623,stroke:#333
    style Route fill:#ffecb3,stroke:#333
