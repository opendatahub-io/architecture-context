graph LR
    TrustyAI["TrustyAI<br/>Explainability Service"]

    %% External Framework Dependencies
    TrustyAI -->|"app framework"| Quarkus["Quarkus 3.8.5<br/>REST, CDI, Scheduler,<br/>Health, OpenAPI"]
    TrustyAI -->|"data format"| Arrow["Apache Arrow 15.0.2"]
    TrustyAI -->|"gRPC transport"| gRPC["gRPC Netty Shaded 1.75.0"]
    TrustyAI -->|"serialization"| Protobuf["Protocol Buffers 3.25.5"]
    TrustyAI -->|"network I/O"| Netty["Netty 4.1.125.Final"]
    TrustyAI -->|"constraint solver"| OptaPlanner["OptaPlanner 8.30.0.Final<br/>(Counterfactual)"]
    TrustyAI -->|"JSON"| Jackson["Jackson Databind 2.15.0"]

    %% Conditional External Dependencies
    TrustyAI -.->|"DB driver<br/>(DATABASE mode)"| MariaDBDriver["Quarkus JDBC<br/>MariaDB/MySQL"]
    TrustyAI -.->|"ORM<br/>(DATABASE mode)"| Hibernate["Quarkus Hibernate ORM"]
    TrustyAI -.->|"S3 client<br/>(MINIO mode)"| MinIOClient["Quarkiverse MinIO 3.3.1"]

    %% Internal Platform Dependencies
    TrustyAI -->|"lifecycle mgmt"| Operator["trustyai-service-operator"]
    TrustyAI -->|"model inference<br/>HTTP v1/v2, gRPC v2"| KServe["KServe / ModelMesh"]
    TrustyAI -->|"metrics scraping<br/>/q/metrics"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% Conditional Internal Dependencies
    TrustyAI -.->|"JDBC 3306/TCP<br/>(DATABASE mode)"| MariaDB["MariaDB / MySQL"]
    TrustyAI -.->|"filesystem<br/>(PVC mode)"| PVC["PersistentVolumeClaim"]
    TrustyAI -.->|"S3 API<br/>(MINIO mode)"| MinIO["MinIO"]

    %% Reverse Dependencies (components that depend on TrustyAI)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    KServeIS["KServe InferenceService"] -->|"CloudEvents<br/>(Knative trigger)"| TrustyAI
    ModelMesh["ModelMesh<br/>Serving Runtime"] -->|"POST payloads<br/>/consumer/kserve/v2"| TrustyAI

    %% Infrastructure
    TrustyAI -->|"ConfigMap mgmt"| K8sAPI["Kubernetes API"]
    TrustyAI -->|"ingress"| Route["OpenShift Route"]

