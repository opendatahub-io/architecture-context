graph LR
    TrustyAI["TrustyAI Explainability<br/>Quarkus 3.8.5 Service<br/>Java 17"]

    %% External Framework Dependencies
    TrustyAI -->|"app framework"| Quarkus["Quarkus 3.8.5"]
