graph LR
    SDK["CodeFlare SDK<br/>Python Client Library"]

    %% Internal Platform Dependencies
    SDK -->|"CRD Create/Delete<br/>ray.io/v1 RayCluster"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD Create/Delete<br/>workload.codeflare.dev/v1beta2"| AppWrapper["AppWrapper Controller<br/>(CodeFlare Operator)"]
    SDK -->|"CRD Read<br/>kueue.x-k8s.io/v1beta1"| Kueue["Kueue"]
    SDK -->|"API Read<br/>route.openshift.io/v1"| Routes["OpenShift Routes"]
    SDK -->|"REST API<br/>8265/TCP"| RayDashboard["Ray Dashboard"]
    SDK -->|"ray:// protocol<br/>10001/TCP mTLS"| RayClient["Ray Client Server"]
    SDK -.->|"ConfigMap mount"| CABundle["ODH Trusted CA Bundle"]

    %% External Dependencies (Python packages)
    SDK -->|"cluster mgmt"| OpenshiftClient["openshift-client<br/>1.0.18"]
    SDK -->|"job submission"| Ray["ray[data,default]<br/>2.35.0"]
    SDK -->|"K8s API client"| K8sClient["kubernetes<br/>>=25.3.0, <27"]
    SDK -->|"TLS cert gen"| Cryptography["cryptography<br/>40.0.2"]
    SDK -->|"terminal output"| Rich["rich<br/>^12.5"]
    SDK -->|"notebook UI"| IPyWidgets["ipywidgets<br/>8.1.2"]

    %% Infrastructure
    SDK -->|"all K8s ops<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Consumers (who depends on SDK)
    Workbench["RHOAI Workbench<br/>(Jupyter Notebooks)"] -->|"pip install"| SDK
    Pipelines["Data Science<br/>Pipelines"] -.->|"programmatic use"| SDK

