graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies"]
        Ray["ray 2.35.0<br/>(data, default extras)"]
        K8sClient["kubernetes<br/>>=25.3.0, <27"]
        OCPClient["openshift-client<br/>1.0.18"]
        Cryptography["cryptography<br/>40.0.2"]
        Rich["rich ^12.5"]
        Pydantic["pydantic <2"]
        IPyWidgets["ipywidgets 8.1.2"]
        Executing["executing 1.2.0"]
    end

    SDK -->|"job submission<br/>client"| Ray
    SDK -->|"K8s API<br/>operations"| K8sClient
    SDK -->|"OpenShift<br/>API"| OCPClient
    SDK -->|"TLS cert<br/>generation"| Cryptography
    SDK -->|"console<br/>output"| Rich
    SDK -->|"data<br/>validation"| Pydantic
    SDK -->|"notebook<br/>widgets"| IPyWidgets
    SDK -->|"error<br/>handling"| Executing

    %% Internal Platform Dependencies (Operators/Controllers)
    subgraph PlatformDeps["RHOAI Platform Components"]
        KubeRay["KubeRay Operator<br/>(ray.io/v1 RayCluster)"]
        AppWrapperCtrl["CodeFlare Operator<br/>(workload.codeflare.dev/v1beta2<br/>AppWrapper)"]
        KueueCtrl["Kueue<br/>(kueue.x-k8s.io/v1beta1<br/>LocalQueue)"]
    end

    SDK -->|"creates RayCluster CRs<br/>operator reconciles"| KubeRay
    SDK -->|"creates AppWrapper CRs<br/>(optional, for queuing)"| AppWrapperCtrl
    SDK -->|"queries LocalQueues<br/>labels workloads"| KueueCtrl

    %% Runtime Dependencies (Services)
    subgraph RuntimeDeps["Runtime Services"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        RayHead["Ray Head Node<br/>8265/TCP Dashboard<br/>10001/TCP Client"]
        OCPRouter["OpenShift Router<br/>(Routes)"]
        K8sIngress["Kubernetes Ingress<br/>(vanilla K8s)"]
    end

    SDK -->|"CRD CRUD<br/>Bearer Token"| K8sAPI
    SDK -->|"job submit/monitor<br/>HTTP(S)"| RayHead
    SDK -->|"dashboard URL<br/>discovery"| OCPRouter
    SDK -->|"dashboard URL<br/>discovery"| K8sIngress

    %% Trust / Config Dependencies
    subgraph ConfigDeps["Configuration / Trust"]
        CABundle["ODH Trusted CA Bundle<br/>(ConfigMap)"]
        Workbench["RHOAI Workbench<br/>(Runtime Host)"]
    end

    SDK -.->|"runs inside"| Workbench
    SDK -.->|"CA trust chain<br/>mounted in Ray pods"| CABundle

    %% Integration Points (components that use SDK-created resources)
    subgraph Consumers["Components Using SDK Resources"]
        Dashboard["ODH Dashboard<br/>(optional UI)"]
    end

    Dashboard -.->|"may display<br/>Ray cluster status"| KubeRay

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff
    style K8sClient fill:#999,stroke:#333,color:#fff
    style OCPClient fill:#999,stroke:#333,color:#fff
    style Cryptography fill:#999,stroke:#333,color:#fff
    style Rich fill:#999,stroke:#333,color:#fff
    style Pydantic fill:#999,stroke:#333,color:#fff
    style IPyWidgets fill:#999,stroke:#333,color:#fff
    style Executing fill:#999,stroke:#333,color:#fff
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style AppWrapperCtrl fill:#7ed321,stroke:#333,color:#fff
    style KueueCtrl fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style RayHead fill:#f5a623,stroke:#333,color:#fff
    style OCPRouter fill:#f5a623,stroke:#333,color:#fff
    style K8sIngress fill:#f5a623,stroke:#333,color:#fff
    style CABundle fill:#e8e8e8,stroke:#333
    style Workbench fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
