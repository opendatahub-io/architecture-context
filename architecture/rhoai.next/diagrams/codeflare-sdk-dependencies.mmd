graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies"]
        Ray["ray 2.35.0<br/>(client + job submission)"]
        K8sClient["kubernetes<br/>25.3.0 - 27<br/>(K8s API access)"]
        OCClient["openshift-client<br/>1.0.18<br/>(OpenShift API)"]
        Crypto["cryptography<br/>40.0.2<br/>(TLS cert gen)"]
        Rich["rich >= 12.5<br/>(terminal output)"]
        IPyWidgets["ipywidgets 8.1.2<br/>(Jupyter UI)"]
        PyYAML["PyYAML<br/>(YAML gen)"]
    end

    SDK -->|"job submission"| Ray
    SDK -->|"K8s API"| K8sClient
    SDK -->|"OpenShift API"| OCClient
    SDK -->|"mTLS certs"| Crypto
    SDK -->|"pretty print"| Rich
    SDK -->|"notebook UI"| IPyWidgets
    SDK -->|"CR generation"| PyYAML

    %% Internal RHOAI/ODH Platform Dependencies
    subgraph Platform["Internal RHOAI Platform"]
        KubeRay["KubeRay Operator<br/>Reconciles RayCluster CRs"]
        CFOperator["CodeFlare Operator<br/>AppWrapper Controller"]
        Kueue["Kueue<br/>Queue Management"]
        Workbench["RHOAI Workbench<br/>Runtime Environment"]
        CABundle["ODH Trusted CA Bundle<br/>ConfigMap"]
    end

    SDK -->|"CRD: ray.io/v1<br/>RayCluster"| KubeRay
    SDK -->|"CRD: workload.codeflare.dev/v1beta2<br/>AppWrapper"| CFOperator
    SDK -->|"CRD: kueue.x-k8s.io/v1beta1<br/>LocalQueue"| Kueue
    SDK -.->|"runs inside"| Workbench
    SDK -.->|"mounts in pods"| CABundle

    %% External Services
    subgraph External["External Services"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        OSRouter["OpenShift Router<br/>Route discovery"]
        Registry["quay.io/modh/ray<br/>Container images"]
    end

    SDK -->|"CRUD operations"| K8sAPI
    SDK -->|"dashboard URL"| OSRouter
    SDK -.->|"image ref in YAML"| Registry

    %% Integration Points (other components that use SDK)
    subgraph Consumers["Consumers"]
        Notebooks["Data Science Notebooks<br/>Import codeflare_sdk"]
        Pipelines["ML Pipelines<br/>Automated cluster creation"]
    end

    Notebooks -->|"pip install"| SDK
    Pipelines -.->|"programmatic use"| SDK

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Ray fill:#e8e8e8,stroke:#333
    style K8sClient fill:#e8e8e8,stroke:#333
    style OCClient fill:#e8e8e8,stroke:#333
    style Crypto fill:#e8e8e8,stroke:#333
    style Rich fill:#e8e8e8,stroke:#333
    style IPyWidgets fill:#e8e8e8,stroke:#333
    style PyYAML fill:#e8e8e8,stroke:#333
    style KubeRay fill:#7ed321,stroke:#333
    style CFOperator fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style Workbench fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style OSRouter fill:#f5a623,stroke:#333
    style Registry fill:#f5a623,stroke:#333
