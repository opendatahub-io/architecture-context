graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% Internal RHOAI Platform Dependencies
    SDK -->|"CRD: ray.io/v1<br/>RayCluster create/delete"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD: workload.codeflare.dev/v1beta2<br/>AppWrapper create/delete"| CFOperator["CodeFlare Operator"]
    SDK -->|"CRD: kueue.x-k8s.io/v1beta1<br/>LocalQueue read"| Kueue["Kueue Controller"]
    SDK -->|"Route read<br/>Dashboard URL discovery"| OSRouter["OpenShift Router"]
    SDK -->|"ConfigMap mount<br/>CA trust chain"| CABundle["ODH Trusted CA Bundle"]
    SDK -->|"Runtime environment<br/>Runs as pip dependency"| Workbench["RHOAI Workbench"]

    %% External Python Dependencies
    SDK -->|"Ray client +<br/>JobSubmissionClient"| Ray["ray 2.35.0"]
    SDK -->|"K8s API access"| K8sClient["kubernetes >= 25.3.0"]
    SDK -->|"OpenShift API"| OSClient["openshift-client 1.0.18"]
    SDK -->|"TLS cert generation"| Crypto["cryptography 40.0.2"]
    SDK -->|"Notebook UI"| IPyWidgets["ipywidgets 8.1.2"]
    SDK -->|"Terminal output"| Rich["rich >= 12.5"]

    %% External Services
    SDK -->|"CRUD operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    SDK -->|"Job submission<br/>8265/TCP HTTP"| RayDashboard["Ray Dashboard"]
    SDK -->|"Interactive session<br/>10001/TCP gRPC"| RayHead["Ray Head Node"]
    SDK -.->|"Image reference<br/>(pulled by kubelet)"| Registry["quay.io/modh/ray"]

    %% Consumers of the SDK
    Workbench -->|"pip install"| SDK

