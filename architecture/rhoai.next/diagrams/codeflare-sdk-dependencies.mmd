graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% Internal Platform Dependencies
    SDK -->|"CRD create/delete<br/>ray.io/v1 RayCluster, RayJob"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD read<br/>LocalQueue, Workload,<br/>WorkloadPriorityClass"| Kueue["Kueue Controller"]
    SDK -->|"CRD read<br/>HTTPRoute, Gateway"| GatewayAPI["Gateway API<br/>(RHOAI 3.x)"]
    SDK -->|"CRD read<br/>Route"| OSRoutes["OpenShift Routes<br/>(fallback)"]
    SDK -->|"API read<br/>Ingress"| K8sIngress["Kubernetes Ingress<br/>(fallback)"]
    SDK -->|"ConfigMap read<br/>CA bundle"| CABundle["ODH/RHOAI CA Bundle"]
    SDK -.->|"TCP connection<br/>GCS fault tolerance"| Redis["Redis<br/>(optional)"]

    %% External Python Dependencies
    SDK -->|"job submission<br/>runtime env"| Ray["ray 2.54.1"]
    SDK -->|"K8s API client"| K8sClient["kubernetes >= 27.2.0"]
    SDK -->|"cluster type<br/>detection"| OSClient["openshift-client 1.0.18"]
    SDK -->|"TLS cert gen<br/>RSA 3072-bit"| Crypto["cryptography 46.0.7"]
    SDK -->|"auth auto-detect<br/>OIDC, OAuth, Token"| KubeAuthkit["kube-authkit >= 0.4.0"]
    SDK -->|"config validation"| Pydantic["pydantic >= 2.10.6"]
    SDK -->|"terminal output"| Rich["rich >= 12.5"]
    SDK -->|"notebook widgets"| IPyWidgets["ipywidgets 8.1.2"]

    %% External Services
    SDK -->|"HTTPS/6443<br/>CRD CRUD"| K8sAPI["Kubernetes API Server"]
    SDK -->|"HTTP(S)/8265<br/>job mgmt"| RayHead["Ray Head Node"]
    SDK -.->|"HTTPS/443<br/>image pull"| Registry["Container Registry<br/>quay.io/modh/ray"]

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform deps (green)
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style OSRoutes fill:#7ed321,stroke:#333,color:#fff
    style K8sIngress fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff

    %% Python library deps (light blue)
    style Ray fill:#64b5f6,stroke:#333,color:#333
    style K8sClient fill:#64b5f6,stroke:#333,color:#333
    style OSClient fill:#64b5f6,stroke:#333,color:#333
    style Crypto fill:#64b5f6,stroke:#333,color:#333
    style KubeAuthkit fill:#64b5f6,stroke:#333,color:#333
    style Pydantic fill:#64b5f6,stroke:#333,color:#333
    style Rich fill:#64b5f6,stroke:#333,color:#333
    style IPyWidgets fill:#64b5f6,stroke:#333,color:#333

    %% External services (orange)
    style K8sAPI fill:#f5a623,stroke:#333,color:#333
    style RayHead fill:#f5a623,stroke:#333,color:#333
    style Registry fill:#f5a623,stroke:#333,color:#333

    %% Optional deps (grey)
    style Redis fill:#999,stroke:#333,color:#fff
