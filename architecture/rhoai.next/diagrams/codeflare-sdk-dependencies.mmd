graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% Internal RHOAI Platform Dependencies
    SDK -->|"CRD CRUD<br/>ray.io/v1 RayCluster"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD CRUD<br/>workload.codeflare.dev/v1beta2"| CFOperator["CodeFlare Operator<br/>AppWrapper Controller"]
    SDK -->|"CRD Read<br/>kueue.x-k8s.io/v1beta1"| Kueue["Kueue"]
    SDK -->|"Route Read<br/>route.openshift.io/v1"| OCPRouter["OpenShift Router"]
    SDK -.->|"ConfigMap volume mount<br/>odh-trusted-ca-bundle"| ODHCA["ODH Trusted CA Bundle"]

    %% External Python Dependencies
    SDK -->|"Job Submission Client"| RayLib["ray 2.35.0"]
    SDK -->|"K8s API Client"| K8sLib["kubernetes >=25.3, <27"]
    SDK -->|"OpenShift Client"| OCPLib["openshift-client 1.0.18"]
    SDK -->|"TLS cert generation"| CryptoLib["cryptography 40.0.2"]
    SDK -->|"Status pretty-printing"| RichLib["rich ^12.5"]
    SDK -->|"Notebook UI"| IPyWidgets["ipywidgets 8.1.2"]

    %% Infrastructure Dependencies
    SDK -->|"All CRUD operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]

    %% Runtime Dependencies (created by operators)
    SDK -->|"Dashboard + Job API<br/>8265/TCP or 443/TCP"| RayDashboard["Ray Dashboard"]
    SDK -->|"Client connections<br/>10001/TCP"| RayClient["Ray Client Endpoint"]

    %% Integration (other components that use SDK)
    Notebooks["RHOAI Workbenches<br/>(Jupyter)"] -->|"imports SDK"| SDK
    DSPipelines["Data Science Pipelines"] -.->|"optional usage"| SDK

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI - green
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style CFOperator fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style OCPRouter fill:#7ed321,stroke:#333,color:#fff
    style ODHCA fill:#7ed321,stroke:#333,color:#fff

    %% Python libraries - light blue
    style RayLib fill:#90caf9,stroke:#333
    style K8sLib fill:#90caf9,stroke:#333
    style OCPLib fill:#90caf9,stroke:#333
    style CryptoLib fill:#90caf9,stroke:#333
    style RichLib fill:#90caf9,stroke:#333
    style IPyWidgets fill:#90caf9,stroke:#333

    %% Infrastructure - gray
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% Runtime - orange
    style RayDashboard fill:#f5a623,stroke:#333
    style RayClient fill:#f5a623,stroke:#333

    %% Consumers - purple
    style Notebooks fill:#ce93d8,stroke:#333
    style DSPipelines fill:#ce93d8,stroke:#333
