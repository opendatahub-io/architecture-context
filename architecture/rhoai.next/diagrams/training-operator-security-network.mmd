graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        APIServer["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>Client certs / Bearer tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["Training Operator Pod<br/>SA: training-operator<br/>Image: quay.io/opendatahub/training-operator:v1.9.0-odh-3"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-signed, auto-rotated)<br/>Validates: PyTorchJob, TFJob,<br/>XGBoostJob, PaddleJob, JAXJob"]
            MetricsEP["Metrics Endpoint<br/>8080/TCP HTTP<br/>No encryption, No auth<br/>Path: /metrics"]
            HealthEP["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        end

        WebhookCert["Secret: kubeflow-training-operator-webhook-cert<br/>OPA cert-controller (auto-rotate)"]
    end

    subgraph UserNS["USER NAMESPACES (Training Workloads)"]
        direction TB

        subgraph PyTorchZone["PyTorch NetworkPolicy Zone"]
            PTWorker1["PyTorch Worker 0<br/>(Master)"]
            PTWorker2["PyTorch Worker 1..N"]
        end

        subgraph MPIZone["MPI Job Resources"]
            Launcher["Launcher Pod<br/>SA: per-job SA<br/>kubectl init container"]
            MPIWorker["MPI Workers"]
            MPICfg["ConfigMap<br/>hostfile + kubexec.sh"]
            MPIRBAC["Role + RoleBinding<br/>(pods/exec)"]
        end

        HeadlessSvc["Headless Services<br/>ClusterIP=None<br/>Pod DNS discovery"]
        OtherWorkers["TF/XGBoost/Paddle/JAX Workers"]
    end

    subgraph Monitoring["MONITORING (openshift-monitoring)"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
    end

    subgraph OptionalSched["OPTIONAL SCHEDULING"]
        Volcano["Volcano Scheduler<br/>scheduling.volcano.sh<br/>PodGroup CRD"]
        SchedPlugins["Scheduler Plugins<br/>scheduling.x-k8s.io<br/>PodGroup CRD"]
        Kueue["Kueue / MultiKueue<br/>managedBy field<br/>No direct network"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>User credentials"| APIServer

    %% Webhook callback
    APIServer -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API Server TLS client auth<br/>failurePolicy: Fail"| WebhookSrv

    %% Operator → API Server
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>CRUD: Pods, Services,<br/>CRDs, ConfigMaps, RBAC,<br/>HPA, NetworkPolicies"| APIServer

    %% Operator creates workload resources
    APIServer -.->|"creates"| PTWorker1
    APIServer -.->|"creates"| PTWorker2
    APIServer -.->|"creates"| Launcher
    APIServer -.->|"creates"| MPIWorker
    APIServer -.->|"creates"| OtherWorkers
    APIServer -.->|"creates"| HeadlessSvc

    %% Worker-to-worker (unencrypted)
    PTWorker1 <-->|"TCP/29500 (c10d)<br/>No encryption<br/>No auth"| PTWorker2
    OtherWorkers <-->|"TCP/framework-port<br/>No encryption<br/>No auth"| HeadlessSvc

    %% MPI launcher → API → workers
    Launcher -->|"HTTPS/443<br/>kubectl exec<br/>Launcher SA token"| APIServer

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth<br/>/metrics"| MetricsEP

    %% Optional scheduling
    OperatorPod -.->|"HTTPS/443<br/>via K8s API<br/>PodGroup CRUD"| Volcano
    OperatorPod -.->|"HTTPS/443<br/>via K8s API<br/>PodGroup CRUD"| SchedPlugins

    %% Cert management
    WebhookCert -.->|"mounts cert"| WebhookSrv

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class APIServer controlplane
    class WebhookSrv,MetricsEP,HealthEP,WebhookCert operatorns
    class PTWorker1,PTWorker2,Launcher,MPIWorker,MPICfg,MPIRBAC,HeadlessSvc,OtherWorkers userns
    class Prometheus monitoring
    class Volcano,SchedPlugins,Kueue optional
