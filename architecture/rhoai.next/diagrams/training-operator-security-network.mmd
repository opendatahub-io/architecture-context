graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / ML Engineer"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA tokens + client certs"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph WebhookSvc["Webhook Service (ClusterIP)"]
            Webhook["Validating Webhooks<br/>9443/TCP HTTPS<br/>TLS (cert-controller rotated)<br/>5 endpoints: PyTorch, TF,<br/>XGBoost, Paddle, JAX"]
        end

        subgraph OperatorPod["Training Operator Pod"]
            Controller["training-operator<br/>SA: training-operator<br/>Image: quay.io/opendatahub/<br/>training-operator:v1.9.0-odh-3<br/>FIPS: strictfipsruntime"]
            Metrics["Metrics Endpoint<br/>8080/TCP HTTP<br/>No encryption<br/>/metrics, /healthz, /readyz"]
        end

        CertCtrl["cert-controller (OPA)<br/>Rotates webhook TLS certs"]
    end

    subgraph UserNS["USER NAMESPACE (Job Execution)"]
        direction TB

        subgraph StandardJobs["PyTorch/TF/XGBoost/Paddle/JAX Jobs"]
            HeadlessSvc["Headless Services<br/>dynamic/TCP<br/>Per-pod DNS discovery"]
            MasterPod["Master Pod (RANK=0)<br/>env: MASTER_ADDR,<br/>WORLD_SIZE, RANK"]
            WorkerPods["Worker Pods (RANK=1..N)<br/>env: MASTER_ADDR,<br/>WORLD_SIZE, RANK"]
        end

        subgraph MPIJobs["MPI Jobs"]
            LauncherPod["Launcher Pod<br/>SA: {mpiJob}-launcher<br/>Init: kubectl-delivery"]
            MPIWorkers["MPI Worker Pods<br/>(sleeping, exec target)"]
            MPIConfig["ConfigMap<br/>(hostfile + kubexec.sh)"]
        end
    end

    subgraph OptionalSchedulers["OPTIONAL GANG SCHEDULING"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS TLS 1.2+<br/>PodGroup CRD"]
        SchedPlugins["scheduler-plugins<br/>443/TCP HTTPS TLS 1.2+<br/>PodGroup CRD"]
    end

    subgraph PeerComponents["PEER COMPONENTS"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
        Kueue["Kueue<br/>Mutating + Validating webhooks<br/>MultiKueue delegation"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control Plane → Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert<br/>failurePolicy: Fail"| Webhook

    %% Operator → K8s API (egress)
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRD watch, Pod/Svc CRUD"| K8sAPI

    %% Cert management
    CertCtrl -.->|"rotates certs"| Webhook

    %% Operator creates resources
    Controller -->|"creates"| HeadlessSvc
    Controller -->|"creates"| MasterPod
    Controller -->|"creates"| WorkerPods
    Controller -->|"creates"| LauncherPod
    Controller -->|"creates"| MPIWorkers
    Controller -->|"creates"| MPIConfig

    %% Worker-to-Master communication
    WorkerPods -->|"TCP/23456<br/>No encryption<br/>c10d rendezvous"| MasterPod

    %% MPI launcher → API → workers
    LauncherPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>kubectl exec"| K8sAPI
    K8sAPI -.->|"exec"| MPIWorkers

    %% Gang scheduling (optional)
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>PodGroup CRUD"| Volcano
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>PodGroup CRUD"| SchedPlugins

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>PodMonitor"| Metrics

    %% Kueue integration
    Kueue -.->|"webhooks on<br/>training CRDs"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef peer fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Webhook,Controller,Metrics,CertCtrl operator
    class HeadlessSvc,MasterPod,WorkerPods,LauncherPod,MPIWorkers,MPIConfig userns
    class Volcano,SchedPlugins optional
    class Prometheus,Kueue peer
