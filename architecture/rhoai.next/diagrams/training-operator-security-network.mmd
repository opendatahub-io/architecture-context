graph TB
    subgraph External["USER (External to Cluster)"]
        User["Data Scientist / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>Bearer Token / Client Certs"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["Training Operator Controller<br/>SA: training-operator<br/>Image: training-operator:v1.9.0-odh-3<br/>FIPS: strictfipsruntime"]

        subgraph OperatorPorts["Exposed Ports"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (self-signed)<br/>API server client cert auth"]
            Metrics["Metrics<br/>8080/TCP HTTP<br/>No auth"]
            Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end

        Service["Service: kubeflow-training-operator<br/>ClusterIP<br/>443→9443 (webhook)"]
    end

    subgraph JobNS["JOB NAMESPACE ({user-namespace})"]
        direction TB

        subgraph StandardJobs["Standard Jobs (PyTorch/TF/JAX/XGBoost/Paddle)"]
            MasterPod["Master Pod"]
            WorkerPods["Worker Pods"]
            HeadlessSvc["Headless Service<br/>{job}-{type}-{idx}<br/>ClusterIP: None<br/>No encryption"]
        end

        subgraph MPIJobs["MPI Jobs (Additional Resources)"]
            Launcher["MPI Launcher Pod<br/>SA: {job}-launcher<br/>Init: kubectl-delivery"]
            MPIWorkers["MPI Worker Pods"]
            MPIRole["Role: {job}-launcher<br/>(pods/exec on specific pods)"]
            MPIConfig["ConfigMap: {job}-config<br/>(hostfile, scripts)"]
        end
    end

    subgraph OptionalIntegrations["OPTIONAL INTEGRATIONS (Cluster-Internal)"]
        Volcano["Volcano Scheduler<br/>PodGroup CRD<br/>scheduling.volcano.sh"]
        SchedulerPlugins["scheduler-plugins<br/>PodGroup CRD<br/>scheduling.x-k8s.io"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
        Kueue["Kueue<br/>CRD labels + webhooks"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert"| Webhook
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>CRD reconciliation, Pod/Svc CRUD"| K8sAPI

    Operator -->|"Creates"| MasterPod
    Operator -->|"Creates"| WorkerPods
    Operator -->|"Creates"| HeadlessSvc
    Operator -->|"Creates"| Launcher
    Operator -->|"Creates"| MPIWorkers
    Operator -->|"Creates"| MPIRole
    Operator -->|"Creates"| MPIConfig

    WorkerPods <-->|"TCP (per job config)<br/>No encryption<br/>via headless DNS"| MasterPod
    Launcher -->|"HTTPS/443<br/>kubectl exec<br/>TLS 1.2+<br/>Per-job SA Token"| K8sAPI
    K8sAPI -->|"Kubernetes exec<br/>RBAC: pods/exec"| MPIWorkers

    Operator -.->|"HTTPS/443<br/>PodGroup CRUD"| Volcano
    Operator -.->|"HTTPS/443<br/>PodGroup CRUD"| SchedulerPlugins
    Prometheus -.->|"HTTP/8080<br/>No auth"| Metrics
    Kueue -.->|"Webhooks intercept<br/>training CRDs"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dce6f5,stroke:#4a78b0,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef port fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class User external
    class K8sAPI controlplane
    class Operator,Service,Webhook,Metrics,Health operator
    class MasterPod,WorkerPods,HeadlessSvc,Launcher,MPIWorkers,MPIRole,MPIConfig jobns
    class Volcano,SchedulerPlugins,Prometheus,Kueue optional
