graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["kubeflow-training-operator<br/>SA: training-operator<br/>Image: training-operator:v1.9.0-odh-3<br/>FIPS: strictfipsruntime"]

        subgraph OperatorPorts["Exposed Ports"]
            WebhookPort["9443/TCP HTTPS<br/>TLS (self-signed, cert-controller)<br/>Validating Webhooks<br/>(PyTorch, TF, XGBoost, JAX, Paddle)"]
            MetricsPort["8080/TCP HTTP<br/>No encryption<br/>/metrics"]
            HealthPort["8081/TCP HTTP<br/>No encryption<br/>/healthz /readyz"]
        end

        Operator --- WebhookPort
        Operator --- MetricsPort
        Operator --- HealthPort
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACES (user namespaces)"]
        direction TB

        MasterPod["Master Pod<br/>Framework env vars<br/>(TF_CONFIG, MASTER_ADDR, etc.)"]
        WorkerPods["Worker Pod(s)<br/>DNS peer discovery<br/>via headless Services"]
        HeadlessSvc["Headless Services<br/>ClusterIP: None<br/>DNS resolution"]

        MasterPod ---|"DNS"| HeadlessSvc
        WorkerPods ---|"DNS"| HeadlessSvc
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus / PodMonitor<br/>Scrapes 8080/TCP<br/>HTTP, No Auth"]
    end

    subgraph GangScheduling["OPTIONAL GANG SCHEDULING"]
        Volcano["Volcano Scheduler<br/>PodGroup CRD<br/>scheduling.volcano.sh/v1beta1"]
        SchedulerPlugins["Scheduler-Plugins<br/>PodGroup CRD<br/>scheduling.x-k8s.io/v1alpha1"]
        Kueue["Kueue<br/>managedBy field<br/>External webhooks on CRDs"]
    end

    %% Flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>Admission Review"| WebhookPort
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token (Bearer)<br/>CRUD: Pods, Services,<br/>ConfigMaps, CRDs, RBAC"| K8sAPI

    Operator -->|"Creates via K8s API"| MasterPod
    Operator -->|"Creates via K8s API"| WorkerPods
    Operator -->|"Creates via K8s API"| HeadlessSvc

    WorkerPods -->|"TCP/framework port<br/>No encryption<br/>No auth"| MasterPod

    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| MetricsPort

    Operator -.->|"Creates PodGroups<br/>via K8s API"| Volcano
    Operator -.->|"Creates PodGroups<br/>via K8s API"| SchedulerPlugins

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduling fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,WebhookPort,MetricsPort,HealthPort operator
    class MasterPod,WorkerPods,HeadlessSvc workload
    class Prometheus monitoring
    class Volcano,SchedulerPlugins,Kueue scheduling
