graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token / Client Cert"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: opendatahub"]
        direction TB
        subgraph OperatorPod["Training Operator Pod<br/>SA: training-operator<br/>Image: quay.io/opendatahub/training-operator:v1.9.0-odh-3"]
            WebhookSvr["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (auto-managed)<br/>Auth: K8s API server cert"]
            MetricsEP["Metrics Endpoint<br/>8080/TCP HTTP<br/>No encryption<br/>No auth"]
            HealthEP["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end
        WebhookSecret["Secret: kubeflow-training-operator-webhook-cert<br/>Type: Opaque (TLS cert/key)<br/>Provisioned: cert-controller<br/>Auto-Rotate: Yes"]
    end

    subgraph JobNS["JOB NAMESPACES (user namespaces)"]
        direction TB
        subgraph PyTorchJob["PyTorch Training Job"]
            MasterPod["Master Pod<br/>framework-port/TCP"]
            WorkerPods["Worker Pod(s)<br/>framework-port/TCP"]
            NP["NetworkPolicy<br/>Ingress: same-job pods<br/>+ openshift-monitoring:8080"]
        end

        subgraph MPIJob["MPI Training Job"]
            Launcher["Launcher Pod<br/>kubectl exec via K8s API<br/>Per-job SA token"]
            MPIWorkers["Worker Pod(s)<br/>MPI ports/TCP"]
        end

        HeadlessSvc["Headless Services<br/>ClusterIP: None<br/>Pod-to-pod DNS discovery"]
    end

    subgraph Monitoring["MONITORING: openshift-monitoring"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
    end

    subgraph OptionalScheduling["OPTIONAL: Gang Scheduling"]
        Volcano["Volcano Scheduler<br/>PodGroup CRs<br/>scheduling.volcano.sh"]
        SchedPlugins["Scheduler-Plugins<br/>PodGroup CRs<br/>scheduling.x-k8s.io"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control plane to operator
    K8sAPI -->|"HTTPS/9443<br/>TLS (auto-managed)<br/>API server client cert"| WebhookSvr

    %% Operator to control plane
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD: Pods, Services,<br/>ConfigMaps, RBAC, NetworkPolicies"| K8sAPI

    %% Operator creates job resources
    OperatorPod -.->|creates| MasterPod
    OperatorPod -.->|creates| WorkerPods
    OperatorPod -.->|creates| HeadlessSvc
    OperatorPod -.->|creates| NP
    OperatorPod -.->|creates| Launcher
    OperatorPod -.->|creates| MPIWorkers

    %% Inter-pod communication
    MasterPod <-->|"HTTP/framework-port<br/>No encryption<br/>No auth<br/>via headless DNS"| WorkerPods

    %% MPI specific
    Launcher -->|"HTTPS/443 via K8s API<br/>kubectl exec<br/>Per-job SA token"| K8sAPI
    MPIWorkers <-->|"MPI ports/TCP<br/>No encryption"| MPIWorkers

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth<br/>PodMonitor"| MetricsEP

    %% Secret
    WebhookSecret -.->|mounted at<br/>/tmp/k8s-webhook-server/serving-certs| WebhookSvr

    %% Optional gang scheduling
    OperatorPod -.->|"HTTPS/443<br/>Creates PodGroups"| Volcano
    OperatorPod -.->|"HTTPS/443<br/>Creates PodGroups"| SchedPlugins

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5
    classDef secret fill:#ffe6cc,stroke:#d79b00,stroke-width:1px

    class User external
    class K8sAPI controlplane
    class WebhookSvr,MetricsEP,HealthEP operator
    class MasterPod,WorkerPods,Launcher,MPIWorkers,HeadlessSvc,NP jobns
    class Prometheus monitoring
    class Volcano,SchedPlugins optional
    class WebhookSecret secret
