graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["Training Operator Pod"]
            Controller["Controller<br/>SA: training-operator<br/>FIPS: strictfipsruntime"]
            WebhookSrv["Webhook Server<br/>9443/TCP HTTPS<br/>TLS (cert-controller)"]
            Metrics["Metrics<br/>8080/TCP HTTP"]
            Probes["Health Probes<br/>8081/TCP HTTP"]
        end

        WebhookSvc["Service: kubeflow-training-operator<br/>ClusterIP 443→9443"]
    end

    subgraph JobNS["JOB NAMESPACE (user-namespace)"]
        direction TB

        subgraph StandardJob["Standard Job (PyTorch/TF/JAX/XGBoost/Paddle)"]
            MasterPod["Master Pod<br/>headless svc DNS"]
            WorkerPods["Worker Pods<br/>headless svc DNS"]
        end

        subgraph MPIJobGroup["MPI Job"]
            LauncherPod["Launcher Pod<br/>SA: jobName-launcher<br/>kubectl-delivery init"]
            MPIWorkers["MPI Worker Pods"]
        end
    end

    subgraph OptionalIntegrations["OPTIONAL INTEGRATIONS"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        SchedPlugins["scheduler-plugins<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        Prometheus["Prometheus<br/>PodMonitor<br/>8080/TCP HTTP"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert<br/>Fail policy"| WebhookSvc
    WebhookSvc --> WebhookSrv

    %% Controller to API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD: Pods, Services,<br/>CMs, SA, RBAC"| K8sAPI

    %% Controller creates job resources
    Controller -.->|"creates"| MasterPod
    Controller -.->|"creates"| WorkerPods
    Controller -.->|"creates"| LauncherPod
    Controller -.->|"creates"| MPIWorkers

    %% Pod-to-pod communication
    WorkerPods -->|"TCP (framework ports)<br/>No encryption<br/>Headless svc DNS"| MasterPod

    %% MPI launcher flow
    LauncherPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Per-job SA Token<br/>pods/exec RBAC"| K8sAPI
    K8sAPI -->|"kubectl exec<br/>pod-specific RBAC"| MPIWorkers

    %% Optional integrations
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRUD"| Volcano
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRUD"| SchedPlugins
    Prometheus -->|"HTTP/8080<br/>No auth<br/>PodMonitor"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef jobns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookSrv,Metrics,Probes,WebhookSvc operator
    class MasterPod,WorkerPods,LauncherPod,MPIWorkers jobns
    class Volcano,SchedPlugins,Prometheus optional
