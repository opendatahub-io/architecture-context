graph LR
    SparkOp["Spark Operator<br/>(v2.3.0)"]

    %% Required External Dependencies
    SparkOp -->|"runtime bundled<br/>in image"| Spark["Apache Spark 4.0.1<br/>(PySpark)"]
    SparkOp -->|"JVM runtime"| Java["Java 17<br/>(OpenJDK)"]
    SparkOp -->|"PID 1 init"| Catatonit["catatonit"]
    SparkOp -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.20.4"]

    %% Optional External Dependencies
    SparkOp -.->|"optional TLS certs"| CertManager["cert-manager"]
    SparkOp -.->|"optional gang<br/>scheduling"| Volcano["Volcano v1.10.0<br/>(PodGroup CRDs)"]
    SparkOp -.->|"optional co-scheduling<br/>(PodGroup CRDs)"| SchedPlugins["scheduler-plugins<br/>v0.32.7"]
    SparkOp -.->|"optional workload<br/>queuing (labels)"| Kueue["Kueue"]

    %% Internal Platform Dependencies
    SparkOp -->|"deployed via<br/>kustomize overlays"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    SparkOp -->|"reads TLS<br/>security profile"| OpenShiftAPI["OpenShift APIServer<br/>(config.openshift.io/v1)"]

    %% Core Platform
    SparkOp -->|"CRD watches, Pod CRUD,<br/>Service CRUD, Events"| K8sAPI["Kubernetes API<br/>Server"]

    %% Integration Points (things that interact with Spark Operator)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8080/TCP HTTP"| SparkOp
    Dashboard["ODH Dashboard"] -.->|"UI management"| SparkOp
    DSPipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>SparkApplications"| SparkOp

    %% Managed Resources (created by operator)
    SparkOp -->|"creates/manages"| DriverPods["Spark Driver Pods<br/>7078,7079,4040/TCP"]
    DriverPods -->|"creates via K8s API"| ExecutorPods["Spark Executor Pods<br/>7078,7079/TCP"]
    SparkOp -->|"creates/manages"| SparkConnectSrv["SparkConnect Server<br/>15002/TCP gRPC"]

