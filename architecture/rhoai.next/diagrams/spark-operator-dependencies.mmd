graph LR
    SparkOp["Spark Operator<br/>(v2.3.0)"]

    %% External Dependencies (Required)
    SparkOp -->|"controller-runtime<br/>watches + CRUD"| K8sAPI["Kubernetes API Server"]
    SparkOp -->|"spark-submit<br/>job execution"| Spark["Apache Spark 4.0.1<br/>(bundled in image)"]
    SparkOp -->|"JVM runtime"| Java17["Java 17 (OpenJDK)<br/>(bundled in image)"]
    SparkOp -->|"controller framework<br/>v0.20.4"| CtrlRuntime["controller-runtime"]
    SparkOp -->|"cron parsing"| Cron["robfig/cron v3"]
    SparkOp -->|"PID 1 init"| Catatonit["catatonit"]

    %% External Dependencies (Optional)
    SparkOp -.->|"gang scheduling<br/>PodGroup CRs"| Volcano["Volcano Scheduler"]
    SparkOp -.->|"gang scheduling<br/>pod annotations"| YuniKorn["YuniKorn Scheduler"]
    SparkOp -.->|"gang scheduling<br/>PodGroup CRs"| SchedPlugins["K8s Scheduler Plugins"]
    SparkOp -.->|"workload queueing<br/>label convention"| Kueue["Kueue"]
    SparkOp -.->|"optional TLS cert mgmt"| CertManager["cert-manager"]

    %% Internal Platform Dependencies
    RhodsOp["RHOAI / ODH Operator"] -->|"deploys via<br/>kustomize overlays"| SparkOp
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>PodMonitor 8080/TCP"| SparkOp
    SparkOp -->|"reads TLS profile<br/>config.openshift.io"| OpenShiftAPI["OpenShift APIServer CR"]

    %% Integration Points (consumers)
    Workbench["ODH/RHOAI Workbench"] -->|"SparkConnect gRPC<br/>15002/TCP"| SparkOp
    Browser["User / Browser"] -->|"Spark UI<br/>4040/TCP HTTP"| SparkOp

    %% Spark workload pods (created by operator)
    SparkOp -->|"creates + manages"| DriverPods["Spark Driver Pods<br/>7078, 7079/TCP"]
    SparkOp -->|"creates + manages"| ExecutorPods["Spark Executor Pods<br/>7078, 7079/TCP"]
    SparkOp -->|"creates"| ConnectServer["SparkConnect Server<br/>15002/TCP gRPC"]

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Spark fill:#999,stroke:#333,color:#fff
    style Java17 fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style Cron fill:#999,stroke:#333,color:#fff
    style Catatonit fill:#999,stroke:#333,color:#fff

    %% External optional
    style Volcano fill:#bbb,stroke:#333,color:#fff
    style YuniKorn fill:#bbb,stroke:#333,color:#fff
    style SchedPlugins fill:#bbb,stroke:#333,color:#fff
    style Kueue fill:#bbb,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftAPI fill:#7ed321,stroke:#333,color:#fff
    style Workbench fill:#7ed321,stroke:#333,color:#fff

    %% Workload pods
    style DriverPods fill:#f5a623,stroke:#333
    style ExecutorPods fill:#f5a623,stroke:#333
    style ConnectServer fill:#f5a623,stroke:#333
    style Browser fill:#fff,stroke:#333
