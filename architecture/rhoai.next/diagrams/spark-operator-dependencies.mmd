graph LR
    SparkOp["Spark Operator<br/>(v2.3.0)"]

    %% Required External Dependencies
    SparkOp -->|"app submission<br/>(bundled)"| ApacheSpark["Apache Spark 4.0.1<br/>(Required)"]
    SparkOp -->|"JVM runtime"| Java17["Java 17 OpenJDK<br/>(Required)"]
    SparkOp -->|"PID 1 init"| Tini["tini<br/>(Required)"]

    %% Core Platform Dependencies
    SparkOp -->|"CRUD: pods, services,<br/>ingresses, configmaps,<br/>secrets, CRDs<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>(Required)"]

    %% Optional Batch Schedulers
    SparkOp -->|"gang scheduling<br/>PodGroup CRD<br/>443/TCP HTTPS"| Volcano["Volcano v1.10.0+<br/>(Optional)"]
    SparkOp -->|"gang scheduling<br/>task group annotations"| Yunikorn["Yunikorn<br/>(Optional)"]
    SparkOp -->|"coscheduling<br/>PodGroup CRD<br/>443/TCP HTTPS"| SchedPlugins["scheduler-plugins v0.32.7<br/>(Optional)"]
    SparkOp -->|"workload queuing<br/>pod labels"| Kueue["Kueue<br/>(Optional)"]

    %% Optional Infrastructure
    SparkOp -->|"TLS cert provisioning<br/>(alternative to self-signed)"| CertManager["cert-manager<br/>(Optional)"]
    SparkOp -->|"metrics scrape<br/>8080/TCP HTTP"| Prometheus["Prometheus<br/>(Optional)"]

    %% Internal Platform Dependencies
    ODHOp["ODH Operator"] -->|"kustomize deploy<br/>overlays/odh"| SparkOp
    RHOAIOp["RHOAI Operator"] -->|"kustomize deploy<br/>overlays/rhoai"| SparkOp

    %% JMX Integration
    SparkOp -.->|"JMX metrics sidecar<br/>8090/TCP HTTP"| JMXExporter["JMX Exporter<br/>(Optional)"]

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required (dark gray)
    style ApacheSpark fill:#666,stroke:#333,color:#fff
    style Java17 fill:#666,stroke:#333,color:#fff
    style Tini fill:#666,stroke:#333,color:#fff
    style K8sAPI fill:#666,stroke:#333,color:#fff

    %% Optional external (light gray)
    style Volcano fill:#999,stroke:#333,color:#fff
    style Yunikorn fill:#999,stroke:#333,color:#fff
    style SchedPlugins fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style Kueue fill:#999,stroke:#333,color:#fff
    style JMXExporter fill:#999,stroke:#333,color:#fff

    %% Internal platform (green)
    style ODHOp fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
