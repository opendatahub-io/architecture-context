graph LR
    SparkOp["Spark Operator<br/>v2.4.0"]

    %% Required External Dependencies
    SparkOp -->|"runtime<br/>(required)"| Spark["Apache Spark 4.0.1<br/>+ PySpark"]
    SparkOp -->|"JVM runtime<br/>(required)"| Java["OpenJDK 17"]
    SparkOp -->|"init process<br/>(required)"| Tini["tini"]

    %% Optional External Dependencies
    SparkOp -.->|"TLS certs<br/>(optional)"| CertManager["cert-manager v1"]
    SparkOp -.->|"gang scheduling<br/>(optional)"| Volcano["Volcano Scheduler<br/>v1beta1 PodGroup"]
    SparkOp -.->|"gang scheduling<br/>(optional)"| Yunikorn["Yunikorn Scheduler<br/>annotations"]
    SparkOp -.->|"gang scheduling<br/>(optional)"| KubeSched["kube-scheduler-plugins<br/>v1alpha1 PodGroup"]
    SparkOp -.->|"workload mgmt<br/>(optional)"| Kueue["Kueue<br/>label propagation"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| SparkOp
    Prometheus["Prometheus /<br/>PodMonitor"] -->|"scrapes metrics<br/>8080/TCP"| SparkOp

    %% Core Infrastructure
    SparkOp -->|"API server<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    SparkOp -->|"quota checks<br/>443/TCP HTTPS"| ResourceQuota["Kubernetes ResourceQuota"]

    %% Managed Resources
    SparkOp -->|"creates/manages"| DriverPods["Spark Driver Pods"]
    SparkOp -->|"monitors"| ExecutorPods["Spark Executor Pods"]
    SparkOp -->|"creates"| Services["Services<br/>(UI, driver, connect)"]
    SparkOp -->|"creates (optional)"| Ingress["Ingress Resources"]

    %% JMX Integration
    SparkOp -->|"injects config"| JMXExporter["Prometheus JMX Exporter<br/>8090/TCP"]

