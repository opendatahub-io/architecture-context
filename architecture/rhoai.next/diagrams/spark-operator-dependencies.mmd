graph LR
    SparkOp["Spark Operator<br/>(controller + webhook)"]

    %% Core External Dependencies
    SparkOp -->|"controller framework<br/>v0.20.4"| ControllerRuntime["controller-runtime"]
    SparkOp -->|"API interactions<br/>v0.32.5"| K8sAPI["Kubernetes API"]
    SparkOp -->|"cron parsing<br/>v3.0.1"| Cron["robfig/cron/v3"]
    SparkOp -->|"chart support<br/>v3.18.5"| Helm["Helm v3"]
    SparkOp -->|"metrics<br/>v1.23.2"| PromClient["prometheus/client_golang"]

    %% Batch Scheduler Dependencies
    SparkOp -->|"PodGroup API<br/>v0.32.7"| SchedPlugins["scheduler-plugins"]
    SparkOp -->|"PodGroup API<br/>v1.10.0"| VolcanoAPI["volcano.sh/apis"]

    %% Runtime Dependencies (in image)
    SparkOp -->|"Spark runtime"| Java17["Java 17 OpenJDK"]
    SparkOp -->|"Python Spark API<br/>v4.0.1"| PySpark["PySpark"]
    SparkOp -->|"init system"| Tini["tini"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"kustomize deployment"| SparkOp
    Prometheus["Prometheus"] -->|"PodMonitor<br/>metrics scraping<br/>:8080/metrics"| SparkOp

    %% Optional Integration Points
    SparkOp -.->|"optional TLS<br/>cert issuance"| CertManager["cert-manager"]
    SparkOp -.->|"batch scheduling<br/>(PodGroup CRDs)"| Volcano["Volcano Scheduler"]
    SparkOp -.->|"batch scheduling<br/>(PodGroup CRDs)"| KubeSched["kube-scheduler<br/>plugins"]
    SparkOp -.->|"annotation-based<br/>scheduling"| Yunikorn["Yunikorn Scheduler"]

    %% Downstream Integrations
    SparkOp -->|"creates/manages"| DriverPods["Spark Driver Pods"]
    SparkOp -->|"mutates"| ExecutorPods["Spark Executor Pods"]
    SparkOp -->|"creates"| Services["K8s Services<br/>(Web UI, Connect)"]
    SparkOp -->|"creates"| Ingresses["K8s Ingresses<br/>(optional)"]

    %% NetworkPolicy
    NetworkPolicy["NetworkPolicy<br/>(ODH/RHOAI overlay)"] -.->|"allows :7078, :7079,<br/>:4040 same-ns"| DriverPods
    NetworkPolicy -.->|"allows :7078, :7079,<br/>:4040 same-ns"| ExecutorPods

