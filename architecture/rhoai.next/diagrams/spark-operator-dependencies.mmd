graph LR
    SparkOp["Spark Operator<br/>v2.4.0"]

    %% Required External Dependencies
    SparkOp -->|"runtime engine"| Spark["Apache Spark 4.0.1"]
    SparkOp -->|"JVM runtime"| Java["OpenJDK 17"]
    SparkOp -->|"Python API"| PySpark["PySpark 4.0.1"]
    SparkOp -->|"init process"| Tini["tini"]
    SparkOp -->|"CRD reconciliation<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Optional External Dependencies
    SparkOp -.->|"optional TLS certs<br/>Certificate CRD"| CertManager["cert-manager v1"]
    SparkOp -.->|"optional gang scheduling<br/>PodGroup CRD"| Volcano["Volcano Scheduler<br/>v1beta1"]
    SparkOp -.->|"optional gang scheduling<br/>PodGroup CRD"| KubeSchedPlugins["kube-scheduler-plugins<br/>v1alpha1"]
    SparkOp -.->|"optional gang scheduling<br/>annotations"| Yunikorn["Yunikorn Scheduler"]
    SparkOp -.->|"optional workload mgmt<br/>label propagation"| Kueue["Kueue"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| SparkOp
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080<br/>PodMonitor"| SparkOp

    %% Integration Points (consumers)
    SparkOp -->|"creates/manages"| DriverPods["Spark Driver Pods"]
    SparkOp -->|"monitors"| ExecutorPods["Spark Executor Pods<br/>7078, 7079/TCP"]
    SparkOp -->|"injects config"| JMXExporter["Prometheus JMX Exporter<br/>8090/TCP"]
    SparkOp -->|"validates against"| ResourceQuota["K8s ResourceQuota"]
    SparkOp -->|"creates"| IngressRes["Ingress Resources<br/>Spark Web UI"]

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style Spark fill:#999,stroke:#333,color:#fff
    style Java fill:#999,stroke:#333,color:#fff
    style PySpark fill:#999,stroke:#333,color:#fff
    style Tini fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Volcano fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style KubeSchedPlugins fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Yunikorn fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Kueue fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    style DriverPods fill:#f5a623,stroke:#333
    style ExecutorPods fill:#f5a623,stroke:#333
    style JMXExporter fill:#f5a623,stroke:#333
    style ResourceQuota fill:#f5a623,stroke:#333
    style IngressRes fill:#f5a623,stroke:#333
