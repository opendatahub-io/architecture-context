graph LR
    vLLM["vLLM CUDA Runtime<br/>(odh-vllm-cuda-rhel9)"]

    %% External Dependencies (Required)
    vLLM -->|"base image<br/>v3.2.2"| RHAIIS["RHAIIS vLLM CUDA<br/>Base Image<br/>registry.redhat.io/rhaiis/<br/>vllm-cuda-rhel9"]
    vLLM -->|"GPU acceleration<br/>required"| GPU["NVIDIA GPU<br/>(CUDA-compatible)"]
    vLLM -->|"multi-arch build<br/>amd64/arm64"| Konflux["Konflux<br/>Build System"]
    Konflux -->|"shared pipeline"| KonfluxCentral["konflux-central<br/>Pipeline Definitions"]

    %% Internal Platform Dependencies
    vLLM -->|"container image ref<br/>ServingRuntime"| KServe["KServe"]
    vLLM -->|"mTLS + traffic mgmt<br/>sidecar injection"| Istio["Istio /<br/>Service Mesh"]
    vLLM -->|"GPU allocation<br/>nvidia.com/gpu"| GPUPlugin["NVIDIA GPU<br/>Device Plugin"]

    %% Integration Points (consumed by)
    KServeIS["KServe<br/>InferenceService CR"] -->|"triggers pod<br/>deployment"| vLLM
    KServeSR["KServe<br/>ServingRuntime CR"] -->|"references<br/>container image"| vLLM

    %% External Services (egress)
    vLLM -->|"model weights<br/>HTTPS/443"| S3["S3 Storage"]
    vLLM -->|"model weights<br/>filesystem"| PVC["PVC Storage"]
    vLLM -->|"model weights &<br/>tokenizer configs<br/>HTTPS/443"| HuggingFace["Hugging Face Hub"]

