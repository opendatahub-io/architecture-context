graph LR
    VLLM["vLLM CUDA<br/>(Container Image)"]

    %% External Dependencies (bundled in base image)
    VLLM -->|"bundled runtime"| CUDARuntime["NVIDIA CUDA Runtime<br/>(bundled in base image)"]
    VLLM -->|"inference engine"| VLLMUpstream["vLLM Upstream<br/>v0.10.0.0 lineage<br/>(bundled in RHAIIS)"]
    VLLM -->|"gRPC entry point"| TGISAdapter["vllm_tgis_adapter<br/>(bundled in RHAIIS)"]
    VLLM -->|"runtime"| Python3["Python 3<br/>(RHEL 9 base)"]
    VLLM -->|"base image"| RHAIIS["RHAIIS vllm-cuda-rhel9<br/>v3.2.2"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe"] -->|"deploys pods"| VLLM
    KServe -->|"defines runtime"| ServingRuntime["ServingRuntime CR"]
    ServingRuntime -->|"references image"| VLLM

    %% Platform integration (injected at runtime)
    KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"] -->|"auth proxy<br/>8443/TCP HTTPS"| VLLM
    RHOAIGateway["RHOAI Gateway"] -->|"ingress<br/>443/TCP HTTPS"| KubeRBACProxy

    %% External services (runtime)
    VLLM -->|"model download<br/>443/TCP HTTPS"| S3["S3 / Object Storage"]
    VLLM -->|"model download<br/>443/TCP HTTPS"| HFHub["Hugging Face Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scrape<br/>8000/TCP HTTP"| VLLM

    %% Build infrastructure
    VLLM -.->|"built by"| Konflux["Konflux CI/CD<br/>(Tekton pipelines)"]

    style VLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CUDARuntime fill:#76b900,stroke:#333,color:#fff
    style VLLMUpstream fill:#999,stroke:#333,color:#fff
    style TGISAdapter fill:#999,stroke:#333,color:#fff
    style Python3 fill:#999,stroke:#333,color:#fff
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#f5a623,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style RHOAIGateway fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style HFHub fill:#ffd21e,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
