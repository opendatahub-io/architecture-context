graph LR
    vLLM["vLLM CUDA<br/>(odh-vllm-cuda-rhel9)"]

    %% External Dependencies (Required)
    vLLM -->|"base image<br/>(required)"| RHAIIS["RHAIIS vllm-cuda-rhel9<br/>v3.2.2"]
    vLLM -->|"inference acceleration<br/>(required)"| GPU["NVIDIA GPU<br/>CUDA 12.x+"]

    %% External Dependencies (Optional)
    vLLM -.->|"model download<br/>(optional)"| HF["HuggingFace Hub"]

    %% Internal RHOAI Dependencies
    vLLM -->|"pod deployment<br/>InferenceService CR"| KServe["KServe"]
    vLLM -->|"auth enforcement<br/>sidecar"| KRBP["kube-rbac-proxy"]
    KServeRT["KServe<br/>ServingRuntime CR"] -->|"container config<br/>args, resources"| vLLM

    %% Model Storage
    vLLM -.->|"model weights<br/>volume mount"| PVC["PVC Storage"]
    vLLM -.->|"model weights<br/>HTTPS 443"| S3["S3 / MinIO"]

    %% Integration Points (inbound)
    Gateway["Gateway API<br/>(HTTPRoute)"] -->|"external ingress<br/>HTTPS 443"| vLLM
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -.->|"metrics scrape<br/>HTTP /metrics"| vLLM

    %% Styling
    style vLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RHAIIS fill:#cc0000,stroke:#333,color:#fff
    style GPU fill:#76b900,stroke:#333,color:#fff
    style HF fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KRBP fill:#e8a838,stroke:#333,color:#fff
    style KServeRT fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#dae8fc,stroke:#6c8ebf
