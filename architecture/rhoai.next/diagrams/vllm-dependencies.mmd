graph LR
    VLLM["vLLM CUDA Runtime<br/>(odh-vllm-cuda-rhel9)"]

    %% External Dependencies (Required)
    VLLM -->|"GPU compute<br/>(CUDA API)"| NVIDIADrivers["NVIDIA CUDA Drivers<br/>Compatible version"]
    VLLM -->|"hardware accelerator"| NVIDIAGPUs["NVIDIA GPU Hardware<br/>CUDA-capable"]
    VLLM -->|"model weights<br/>(HTTPS/443)"| HuggingFace["HuggingFace Hub /<br/>S3-Compatible Storage"]
    VLLM -->|"base image<br/>(container registry)"| RHAIISBase["rhaiis/vllm-cuda-rhel9<br/>v3.2.2"]

    %% Internal RHOAI Dependencies
    VLLM -->|"lifecycle mgmt<br/>(ServingRuntime CR)"| KServe["KServe Operator"]
    VLLM -->|"orchestration"| ModelServing["RHOAI Model Serving"]
    VLLM -->|"ingress / auth<br/>(HTTP/8000, gRPC/8033)"| GatewayProxy["kube-rbac-proxy /<br/>Gateway API"]

    %% Integration Points (inbound)
    GatewayProxy -->|"TLS termination<br/>auth enforcement"| VLLM
    GPUPlugin["NVIDIA GPU<br/>Device Plugin"] -->|"device allocation"| VLLM

    %% Build Dependencies
    Konflux["Konflux / Tekton<br/>Build Pipeline"] -.->|"builds multi-arch<br/>container image"| VLLM

    %% Styling
    style VLLM fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style NVIDIADrivers fill:#999,stroke:#333,color:#fff
    style NVIDIAGPUs fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style RHAIISBase fill:#cc0000,stroke:#333,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelServing fill:#7ed321,stroke:#333,color:#fff
    style GatewayProxy fill:#7ed321,stroke:#333,color:#fff
    style GPUPlugin fill:#999,stroke:#333,color:#fff

    %% Build
    style Konflux fill:#e8e8e8,stroke:#333
