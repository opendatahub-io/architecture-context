graph TB
    subgraph TrainerOperator["Trainer Operator"]
        Controller["trainer-operator<br/>(Go Operator / controller-runtime)"]
        HealthProbe["Health Probes<br/>/healthz, /readyz<br/>8081/TCP"]
        Metrics["Metrics Endpoint<br/>/metrics<br/>8080/TCP"]
        ManifestRenderer["Manifest Renderer<br/>(kustomize + SSA)"]
        DependencyChecker["Dependency Checker<br/>(OLM + CRD validation)"]
        GCCollector["GC Collector<br/>(label-based discovery cleanup)"]
        DriftWatcher["Drift Correction<br/>(downstream resource watches)"]
    end

    subgraph PlatformUtilities["odh-platform-utilities"]
        PlatformObj["PlatformObject Interface"]
        CondMgmt["Condition Management"]
        GCLib["GC Collector Library"]
        KustomizeLib["Kustomize Rendering"]
        ClusterDetect["Cluster Detection"]
    end

    subgraph ManagedResources["Managed Resources (deployed by operator)"]
        KFTrainer["Kubeflow Trainer v2 Controller<br/>(Deployment + Service + RBAC + CRDs + Webhooks)"]
        subgraph Runtimes["ClusterTrainingRuntimes (15 variants)"]
            TorchCUDA["torch-distributed<br/>(CUDA 12.8)"]
            TorchROCm["torch-distributed<br/>(ROCm 6.4)"]
            TorchCPU["torch-distributed<br/>(CPU)"]
            THCUDA["training-hub<br/>(CUDA 13.0)"]
            THROCm["training-hub<br/>(ROCm 6.4)"]
            THCPU["training-hub<br/>(CPU)"]
        end
        subgraph ImageStreams["Training Hub ImageStreams (OpenShift only)"]
            ISCuda["CUDA ImageStream"]
            ISROCm["ROCm ImageStream"]
            ISCPU["CPU ImageStream"]
        end
    end

    PlatformOrchestrator["rhods-operator /<br/>opendatahub-operator"] -->|creates| TrainerCR["Trainer CR<br/>(default-trainer)<br/>components.platform.opendatahub.io/v1alpha1"]

    TrainerCR -->|watched by| Controller
    Controller --> DependencyChecker
    Controller --> ManifestRenderer
    Controller --> GCCollector
    Controller --> DriftWatcher
    Controller -->|uses| PlatformObj
    Controller -->|uses| CondMgmt
    Controller -->|uses| GCLib
    Controller -->|uses| KustomizeLib
    Controller -->|uses| ClusterDetect

    ManifestRenderer -->|deploys via SSA| KFTrainer
    ManifestRenderer -->|deploys via SSA| Runtimes
    ManifestRenderer -->|deploys via SSA<br/>(OpenShift only)| ImageStreams

    DependencyChecker -->|checks| JobSetOp["JobSet Operator<br/>(OLM)"]
    DependencyChecker -->|checks| JobSetCRD["JobSet CRD"]

    Controller -->|CRUD via| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]

    Prometheus["Prometheus"] -->|scrapes| Metrics

    DriftWatcher -->|watches labeled resources| K8sAPI

