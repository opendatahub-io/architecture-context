graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / KFP SDK"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 3000/TCP<br/>TLS Edge Termination"]
        VirtualService["Istio VirtualService<br/>80/TCP via kubeflow-gateway<br/>mTLS (ISTIO_MUTUAL)"]
    end

    subgraph AppTier["APPLICATION TIER (mTLS in multi-user mode)"]
        direction TB

        subgraph FrontendZone["Frontend"]
            FrontendUI["Frontend UI<br/>ml-pipeline-ui<br/>ClusterIP 80→3000/TCP<br/>No Auth (fronted by Istio/Route)"]
        end

        subgraph APIZone["API Layer"]
            APIServer["API Server<br/>ml-pipeline<br/>8888/TCP REST | 8887/TCP gRPC<br/>8443/TCP Webhook<br/>Configurable TLS<br/>TokenReview + SubjectAccessReview"]
        end

        subgraph InternalZone["Internal Services"]
            PersistenceAgent["Persistence Agent<br/>No listener<br/>SA: ml-pipeline-persistenceagent"]
            ScheduledWF["Scheduled Workflow Ctrl<br/>9090/TCP metrics<br/>SA: ml-pipeline-scheduledworkflow"]
            CacheServer["Cache Server<br/>cache-server<br/>ClusterIP 443→8443/TCP<br/>TLS (webhook cert)<br/>MutatingWebhookConfig"]
            MetadataWriter["Metadata Writer<br/>No listener<br/>SA: kubeflow-pipelines-metadata-writer"]
            VisualizationSvr["Visualization Server<br/>8888/TCP HTTP<br/>No Auth"]
        end

        subgraph ExecutionZone["Pipeline Step Execution (per-pod)"]
            Driver["Driver (init container)<br/>No listener<br/>SA: pipeline-runner"]
            Launcher["Launcher (sidecar)<br/>No listener<br/>FIPS-compliant<br/>SA: pipeline-runner"]
        end
    end

    subgraph DataTier["DATA TIER"]
        Database["MySQL / PostgreSQL<br/>3306/5432 TCP<br/>Wire protocol<br/>Configurable TLS<br/>Username/Password"]
        MLMD["ML Metadata (MLMD)<br/>metadata-grpc-service<br/>8080/TCP gRPC<br/>Configurable TLS<br/>None or mTLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ObjectStore["MinIO / S3 / GCS<br/>9000/443 TCP<br/>HTTP/HTTPS<br/>Access Key/Secret or IAM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
        ArgoWF["Argo Workflows v3.7.11<br/>CRD Watch + Create"]
    end

    subgraph InfraServices["INFRASTRUCTURE"]
        Istio["Istio Service Mesh<br/>mTLS STRICT<br/>AuthorizationPolicy"]
        CertManager["cert-manager<br/>Webhook TLS certs"]
        DSPA["DSPA Operator<br/>Lifecycle management"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS Edge<br/>Bearer Token"| Route
    User -->|"HTTP/gRPC<br/>Bearer Token"| VirtualService

    %% Ingress to Frontend
    Route -->|"HTTP/3000<br/>mTLS (Istio)"| FrontendUI
    VirtualService -->|"HTTP/3000<br/>mTLS"| FrontendUI

    %% Frontend to API
    FrontendUI -->|"REST/8888<br/>Configurable TLS<br/>Proxied Token"| APIServer

    %% API to Data Tier
    APIServer -->|"MySQL/PG wire<br/>3306/5432<br/>Configurable TLS<br/>User/Pass"| Database
    APIServer -->|"gRPC/8080<br/>Configurable TLS"| MLMD

    %% API to External
    APIServer -->|"HTTP(S)/9000/443<br/>Access Key/Secret"| ObjectStore
    APIServer -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% Internal services to API
    PersistenceAgent -->|"gRPC/8887<br/>Projected SA Token"| APIServer
    ScheduledWF -->|"gRPC/8887<br/>Projected SA Token"| APIServer

    %% Cache server
    K8sAPI -->|"HTTPS/8443<br/>Webhook CA"| CacheServer
    CacheServer -->|"MySQL wire/3306<br/>User/Pass"| Database

    %% Execution flows
    Driver -->|"gRPC/8080"| MLMD
    Driver -->|"gRPC/8887<br/>SA Token"| APIServer
    Driver -->|"HTTPS/443<br/>SA Token"| K8sAPI
    Launcher -->|"gRPC/8080"| MLMD
    Launcher -->|"HTTP(S)/9000/443<br/>Access Key/Secret"| ObjectStore

    %% Metadata writer
    MetadataWriter -->|"gRPC/8080"| MLMD

    %% Persistence Agent watches
    PersistenceAgent -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef apptier fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datatier fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef infra fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route,VirtualService ingress
    class FrontendUI,APIServer,PersistenceAgent,ScheduledWF,CacheServer,MetadataWriter,VisualizationSvr,Driver,Launcher apptier
    class Database,MLMD datatier
    class ObjectStore,K8sAPI,ArgoWF externalservice
    class Istio,CertManager,DSPA infra
