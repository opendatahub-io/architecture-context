graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / SDK / Dashboard"]
    end

    subgraph Ingress["INGRESS (Platform-managed TLS 1.2+)"]
        Gateway["RHOAI Gateway /<br/>OpenShift Route<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>DSPA-managed"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_DSP["Namespace: {dsp-namespace}"]
            direction TB

            APIServer["API Server (ml-pipeline)<br/>SA: ml-pipeline<br/>8888/TCP REST | 8887/TCP gRPC<br/>8443/TCP Webhooks (TLS)<br/>UID 1000, seccomp: RuntimeDefault"]

            Frontend["Frontend (ml-pipeline-ui)<br/>SA: ml-pipeline-ui<br/>3000/TCP HTTP"]

            PersistenceAgent["Persistence Agent<br/>SA: ml-pipeline-persistenceagent<br/>Projected Token (3600s)"]

            SWController["Scheduled Workflow Controller<br/>SA: ml-pipeline-scheduledworkflow<br/>Projected Token (3600s)"]

            CacheServer["Cache Server<br/>SA: kubeflow-pipelines-cache<br/>8443/TCP HTTPS (TLS)<br/>Mutating Admission Webhook"]

            MetadataWriter["Metadata Writer<br/>SA: kubeflow-pipelines-metadata-writer"]
        end
    end

    subgraph ExecutionPlane["EXECUTION PLANE (Argo Workflow Pods)"]
        Driver["V2 Driver (sidecar)<br/>SA: pipeline-runner<br/>Image: odh-ml-pipelines-driver"]
        Launcher["V2 Launcher (user container)<br/>SA: pipeline-runner<br/>Image: odh-ml-pipelines-launcher"]
    end

    subgraph DataServices["DATA SERVICES (Cluster Network)"]
        SQLDB["MySQL / PostgreSQL<br/>3306/5432 TCP<br/>No encryption (in-cluster)<br/>Username/Password"]
        ObjectStore["SeaweedFS / MinIO<br/>9000/TCP HTTP (S3 API)<br/>No encryption (in-cluster)<br/>Access Key / Secret Key"]
        MLMD["ML Metadata Service<br/>8080/TCP gRPC<br/>Optional TLS<br/>No auth"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        ArgoWF["Argo Workflows v3.7.14<br/>443/TCP (K8s API)<br/>TLS 1.2+<br/>ServiceAccount Token"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>8888/TCP, 9090/TCP HTTP"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Internal
    Gateway -->|"HTTP/8888<br/>No encryption<br/>Bearer Token"| APIServer
    Gateway -->|"HTTP/80→3000<br/>No encryption"| Frontend

    %% Frontend → API
    Frontend -->|"HTTP/8888<br/>Proxy requests"| APIServer

    %% Internal service → API Server (gRPC)
    PersistenceAgent -->|"gRPC/8887<br/>SA Token (projected)"| APIServer
    SWController -->|"gRPC/8887<br/>SA Token (projected)"| APIServer

    %% K8s API → Cache (webhook)
    K8sAPI -->|"HTTPS/8443<br/>TLS (mTLS)<br/>Admission webhook"| CacheServer

    %% API Server → Data Services
    APIServer -->|"SQL/3306 or 5432<br/>No encryption<br/>Username/Password"| SQLDB
    APIServer -->|"HTTP(S3)/9000<br/>No encryption<br/>Access Key"| ObjectStore
    APIServer -->|"gRPC/8080<br/>Optional TLS"| MLMD

    %% API Server → Platform
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Cache Server → DB
    CacheServer -->|"SQL/3306<br/>No encryption<br/>Username/Password"| SQLDB

    %% Persistence Agent → K8s
    PersistenceAgent -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% SWC → K8s
    SWController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Execution Plane
    Driver -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Driver -->|"gRPC/8887<br/>Optional TLS"| APIServer
    Driver -->|"HTTPS/443<br/>SA Token"| K8sAPI
    Launcher -->|"HTTP(S3)/9000<br/>Access Key"| ObjectStore
    Launcher -->|"gRPC/8080<br/>Optional TLS"| MLMD

    %% Prometheus scraping
    Prometheus -.->|"HTTP/8888<br/>/metrics"| APIServer
    Prometheus -.->|"HTTP/9090<br/>/metrics"| SWController

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef execution fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class APIServer,Frontend,PersistenceAgent,SWController,CacheServer,MetadataWriter internal
    class Driver,Launcher execution
    class SQLDB,ObjectStore,MLMD dataservice
    class K8sAPI,ArgoWF,Prometheus platform
