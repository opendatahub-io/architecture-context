graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User<br/>(SDK / Dashboard UI)"]
    end

    subgraph Ingress["INGRESS (Edge)"]
        Route["OpenShift Route<br/>443/TCP → 8888/TCP<br/>TLS Edge Termination"]
        VirtualService["Istio VirtualService<br/>(Multi-user variant)<br/>AuthorizationPolicy"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["API Server<br/>SA: ml-pipeline<br/>8888/TCP HTTP | 8887/TCP gRPC<br/>8443/TCP Webhook<br/>Auth: Bearer → TokenReview → SAR"]
        end

        subgraph Controllers["Controllers & Agents"]
            PA["Persistence Agent<br/>SA: ml-pipeline-persistenceagent<br/>Auth: Projected SA Token (1h)"]
            SWC["Scheduled Workflow Controller<br/>SA: ml-pipeline-scheduledworkflow<br/>9090/TCP metrics<br/>Auth: Projected SA Token (1h)"]
            CacheServer["Cache Server (Webhook)<br/>SA: kubeflow-pipelines-cache<br/>443→8443/TCP HTTPS<br/>TLS: webhook-server-tls"]
            ViewerCtrl["Viewer Controller"]
        end

        subgraph PipelineRuntime["Pipeline Runtime (per step)"]
            Driver["Driver (sidecar)<br/>SA: pipeline-runner<br/>FIPS: strictfipsruntime"]
            Launcher["Launcher (sidecar)<br/>SA: pipeline-runner<br/>⚠ FIPS/non-FIPS dual binary"]
            UserPod["User Container"]
        end

        subgraph UIServices["UI Services"]
            PipelineUI["ML Pipeline UI<br/>3000/TCP HTTP<br/>No Auth"]
            VizServer["Visualization Server<br/>8888/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>SA Token Auth"]
        ArgoCtrl["Argo Workflow Controller<br/>v3.7.11<br/>Watches Workflow CRDs"]
        MLMD["ML Metadata (MLMD)<br/>8080/TCP gRPC<br/>Optional TLS<br/>No Auth"]
        MetadataEnvoy["Metadata Envoy<br/>9090/TCP HTTP"]
    end

    subgraph DataStores["DATA STORES"]
        DB["MySQL/PostgreSQL<br/>3306/5432/TCP<br/>SQL wire protocol<br/>Optional TLS<br/>Auth: Username/Password"]
        S3["Object Store (MinIO/SeaweedFS)<br/>9000/TCP HTTP<br/>Optional TLS<br/>Auth: AccessKey/SecretKey"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Edge"| Route
    User -->|"HTTP/8888<br/>Istio AuthZ"| VirtualService

    %% Ingress to API
    Route -->|"HTTP/8888"| APIServer
    VirtualService -->|"HTTP/8888"| APIServer

    %% API Server connections
    APIServer -->|"SQL/3306-5432<br/>Optional TLS<br/>User/Pass"| DB
    APIServer -->|"HTTP/9000<br/>Optional TLS<br/>AccessKey"| S3
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    APIServer -->|"gRPC/8080<br/>Optional TLS"| MLMD

    %% K8s Admission to Cache
    K8sAPI -->|"HTTPS/443<br/>TLS<br/>K8s Client Cert"| CacheServer
    CacheServer -->|"SQL/3306<br/>Optional TLS<br/>User/Pass"| DB

    %% Controllers to API Server
    PA -->|"gRPC/8887<br/>Optional TLS<br/>Projected SA Token"| APIServer
    SWC -->|"gRPC/8887<br/>Optional TLS<br/>Projected SA Token"| APIServer

    %% Controllers to K8s
    PA -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    SWC -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Argo spawns sidecars
    ArgoCtrl -->|"Pod exec"| Driver
    ArgoCtrl -->|"Pod exec"| Launcher

    %% Driver connections
    Driver -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Driver -->|"gRPC/8887<br/>Optional TLS"| APIServer
    Driver -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Launcher connections
    Launcher -->|"HTTP/9000<br/>Optional TLS<br/>AccessKey"| S3
    Launcher -->|"gRPC/8080<br/>Optional TLS"| MLMD
    Launcher --> UserPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef apiLayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef datastore fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef ui fill:#f5f5f5,stroke:#666,stroke-width:1px

    class User external
    class Route,VirtualService ingress
    class APIServer apiLayer
    class PA,SWC,CacheServer,ViewerCtrl controller
    class Driver,Launcher,UserPod runtime
    class K8sAPI,ArgoCtrl,MLMD,MetadataEnvoy platform
    class DB,S3 datastore
    class PipelineUI,VizServer ui
