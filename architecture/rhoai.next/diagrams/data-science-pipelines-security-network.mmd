graph TB
    subgraph External["EXTERNAL CONSUMERS (Untrusted / Platform-Authenticated)"]
        Client["Client<br/>(KFP SDK / Dashboard / CLI)"]
    end

    subgraph ControlPlane["CONTROL PLANE (Pipeline Namespace)"]
        direction TB

        APIServer["API Server (ml-pipeline)<br/>SA: ds-pipeline-*<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP Webhook<br/>FIPS: strictfipsruntime"]

        PAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-*<br/>No listening ports (outbound-only)<br/>FIPS: strictfipsruntime"]

        SWFCtrl["SWF Controller<br/>SA: ds-pipeline-scheduledworkflow-*<br/>9090/TCP metrics<br/>FIPS: strictfipsruntime"]
    end

    subgraph DataPlane["DATA PLANE (Ephemeral Task Pods)"]
        direction TB

        Driver["Driver (init step)<br/>SA: pipeline-runner<br/>No listening ports<br/>FIPS: strictfipsruntime"]

        Launcher["Launcher (container wrapper)<br/>SA: pipeline-runner<br/>No listening ports<br/>FIPS: launcher-v2-fips binary"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS (in-cluster)<br/>ServiceAccount auth"]

        ArgoEngine["Argo Workflows v3.7.11<br/>443/TCP HTTPS<br/>TLS (in-cluster)<br/>ServiceAccount auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Database["MySQL / PostgreSQL<br/>3306/TCP or 5432/TCP<br/>Optional TLS<br/>Username/Password"]

        ObjectStore["MinIO / S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Static API keys / IAM"]

        MLMD["MLMD Server<br/>8080/TCP gRPC<br/>Optional TLS<br/>No auth"]
    end

    %% Client to API Server
    Client -->|"HTTP/8888 + gRPC/8887<br/>Optional TLS<br/>Bearer Token / None"| APIServer

    %% API Server egress
    APIServer -->|"TCP/3306 or 5432<br/>Optional TLS<br/>Username/Password"| Database
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Static API keys"| ObjectStore
    APIServer -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD
    APIServer -->|"HTTPS/443<br/>TLS in-cluster<br/>ServiceAccount"| K8sAPI

    %% Persistence Agent
    PAgent -->|"HTTP/8888 + gRPC/8887<br/>Optional TLS<br/>Bearer Token (SA)"| APIServer
    PAgent -->|"HTTPS/443<br/>TLS in-cluster<br/>ServiceAccount"| K8sAPI

    %% SWF Controller
    SWFCtrl -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token (SA)"| APIServer
    SWFCtrl -->|"HTTPS/443<br/>TLS in-cluster<br/>ServiceAccount"| K8sAPI

    %% Driver
    Driver -->|"gRPC/8887<br/>Optional TLS<br/>None"| APIServer
    Driver -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD
    Driver -->|"HTTPS/443<br/>TLS in-cluster<br/>ServiceAccount"| K8sAPI
    Driver -->|"HTTPS/443<br/>TLS 1.2+<br/>K8s Secret"| ObjectStore

    %% Launcher
    Launcher -->|"gRPC/8887<br/>Optional TLS<br/>None"| APIServer
    Launcher -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD
    Launcher -->|"HTTPS/443<br/>TLS 1.2+<br/>K8s Secret"| ObjectStore
    Launcher -->|"HTTPS/443<br/>TLS in-cluster<br/>ServiceAccount"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Client external
    class APIServer,PAgent,SWFCtrl controlplane
    class Driver,Launcher dataplane
    class K8sAPI,ArgoEngine k8s
    class Database,ObjectStore,MLMD extservice
