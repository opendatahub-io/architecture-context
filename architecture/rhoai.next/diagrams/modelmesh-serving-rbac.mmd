graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["modelmesh-controller"]
        SA_ModelMesh["modelmesh"]
        SA_ServingSA["modelmesh-serving-sa"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["modelmesh-controller-rolebinding<br/>(cluster-wide)"]
        CRB_SCC["modelmesh-controller-restricted-scc-rolebinding<br/>(controller namespace)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["modelmesh-controller-leader-election-rolebinding<br/>(controller namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["modelmesh-controller-role"]
        CR_SCC["modelmesh-controller-restricted-scc-role"]
    end

    subgraph Roles["Roles"]
        R_Leader["modelmesh-controller-leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["core<br/>endpoints<br/>get,list,watch"]
        PVCs["core<br/>persistentvolumeclaims<br/>get,list,watch"]
        Namespaces["core<br/>namespaces,<br/>namespaces/finalizers<br/>get,list,patch,<br/>update,watch"]
        Secrets["core<br/>secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        Services["core<br/>services,<br/>services/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>deployments,<br/>deployments/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph ServingResources["serving.kserve.io Resources"]
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>+ finalizers + status<br/>full CRUD + watch"]
        Predictors["serving.kserve.io<br/>predictors<br/>+ finalizers + status<br/>full CRUD + watch"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes<br/>+ finalizers + status<br/>full CRUD + watch"]
        ClusterServingRuntimes["serving.kserve.io<br/>clusterservingruntimes<br/>+ finalizers + status<br/>full CRUD + watch"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>+ status<br/>get,list,watch,create,<br/>delete,update"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph CoordinationResources["Coordination Resources"]
        Leases["coordination.k8s.io<br/>leases<br/>create,get,list,update"]
    end

    subgraph SCCResources["OpenShift SCC"]
        RestrictedSCC["security.openshift.io<br/>securitycontextconstraints<br/>(resourceName: restricted)<br/>use"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| RB_Leader
    SA_ModelMesh -->|bound via| CRB_SCC
    SA_ServingSA -->|bound via| CRB_SCC

    CRB_Main -->|grants| CR_Main
    CRB_SCC -->|grants| CR_SCC
    RB_Leader -->|grants| R_Leader

    %% ClusterRole permissions
    CR_Main -->|manages| ConfigMaps
    CR_Main -->|reads| Endpoints
    CR_Main -->|reads| PVCs
    CR_Main -->|manages| Namespaces
    CR_Main -->|manages| Secrets
    CR_Main -->|manages| Services
    CR_Main -->|manages| Deployments
    CR_Main -->|manages| InferenceServices
    CR_Main -->|manages| Predictors
    CR_Main -->|manages| ServingRuntimes
    CR_Main -->|manages| ClusterServingRuntimes
    CR_Main -->|manages| HPAs
    CR_Main -->|manages| ServiceMonitors

    %% Leader election role
    R_Leader -->|manages| Leases

    %% SCC role
    CR_SCC -->|uses| RestrictedSCC

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_ModelMesh fill:#4a90e2,color:#fff
    style SA_ServingSA fill:#4a90e2,color:#fff
    style CR_Main fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style CRB_Main fill:#e8e8e8,stroke:#333
    style CRB_SCC fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333

    style ConfigMaps fill:#7ed321,color:#fff
    style Endpoints fill:#7ed321,color:#fff
    style PVCs fill:#7ed321,color:#fff
    style Namespaces fill:#7ed321,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style InferenceServices fill:#7ed321,color:#fff
    style Predictors fill:#7ed321,color:#fff
    style ServingRuntimes fill:#7ed321,color:#fff
    style ClusterServingRuntimes fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style ServiceMonitors fill:#7ed321,color:#fff
    style Leases fill:#7ed321,color:#fff
    style RestrictedSCC fill:#ff6b6b,color:#fff
