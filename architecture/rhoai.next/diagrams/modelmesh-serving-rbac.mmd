graph TD
    subgraph "Service Accounts"
        SA_Controller["modelmesh-controller<br/>(controller namespace)"]
        SA_MM["modelmesh<br/>(runtime namespace)"]
        SA_Serving["modelmesh-serving-sa<br/>(runtime namespace)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Main["modelmesh-controller-rolebinding<br/>(cluster-wide)"]
        CRB_SCC["modelmesh-controller-restricted-scc-rolebinding<br/>(controller namespace)"]
    end

    subgraph "Role Bindings"
        RB_Leader["modelmesh-controller-leader-election-rolebinding<br/>(controller namespace)"]
    end

    subgraph "ClusterRoles"
        CR_Main["modelmesh-controller-role<br/>(ClusterRole)"]
        CR_SCC["modelmesh-controller-restricted-scc-role<br/>(ClusterRole)"]
    end

    subgraph "Roles"
        R_Leader["modelmesh-controller-leader-election-role<br/>(Role, controller namespace)"]
    end

    subgraph "Core API Resources"
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        Services["core<br/>services, services/finalizers"]
        Endpoints["core<br/>endpoints"]
        PVCs["core<br/>persistentvolumeclaims"]
        Namespaces["core<br/>namespaces, namespaces/finalizers"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments, deployments/finalizers"]
    end

    subgraph "serving.kserve.io Resources"
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>+ /finalizers + /status"]
        Predictors["serving.kserve.io<br/>predictors<br/>+ /finalizers + /status"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes<br/>+ /finalizers + /status"]
        ClusterServingRuntimes["serving.kserve.io<br/>clusterservingruntimes<br/>+ /finalizers + /status"]
    end

    subgraph "Other API Resources"
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>+ /status"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
        Leases["coordination.k8s.io<br/>leases"]
        SCCs["security.openshift.io<br/>securitycontextconstraints<br/>(resourceName: restricted)"]
    end

    %% Bindings
    SA_Controller -->|"bound via"| CRB_Main
    SA_Controller -->|"bound via"| RB_Leader
    SA_MM -->|"bound via"| CRB_SCC
    SA_Serving -->|"bound via"| CRB_SCC

    CRB_Main -->|"grants"| CR_Main
    CRB_SCC -->|"grants"| CR_SCC
    RB_Leader -->|"grants"| R_Leader

    %% ClusterRole permissions - Core
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| ConfigMaps
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| Secrets
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| Services
    CR_Main -->|"get,list,watch"| Endpoints
    CR_Main -->|"get,list,watch"| PVCs
    CR_Main -->|"get,list,patch<br/>update,watch"| Namespaces

    %% ClusterRole permissions - Apps
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| Deployments

    %% ClusterRole permissions - serving.kserve.io
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| InferenceServices
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| Predictors
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| ServingRuntimes
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| ClusterServingRuntimes

    %% ClusterRole permissions - Other
    CR_Main -->|"get,list,watch<br/>create,delete,update"| HPAs
    CR_Main -->|"create,delete,get,list<br/>patch,update,watch"| ServiceMonitors
    CR_Main -->|"create,get,list,update"| Leases

    %% SCC Role
    CR_SCC -->|"use"| SCCs

    %% Leader election
    R_Leader -->|"create,get,list,update"| Leases

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_MM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Serving fill:#4a90e2,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style CR_SCC fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style CRB_Main fill:#dae8fc,stroke:#6c8ebf
    style CRB_SCC fill:#dae8fc,stroke:#6c8ebf
    style RB_Leader fill:#dae8fc,stroke:#6c8ebf
    style InferenceServices fill:#7ed321,stroke:#333
    style Predictors fill:#7ed321,stroke:#333
    style ServingRuntimes fill:#7ed321,stroke:#333
    style ClusterServingRuntimes fill:#7ed321,stroke:#333
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style Services fill:#d5e8d4,stroke:#82b366
    style Endpoints fill:#d5e8d4,stroke:#82b366
    style PVCs fill:#d5e8d4,stroke:#82b366
    style Namespaces fill:#d5e8d4,stroke:#82b366
    style Deployments fill:#d5e8d4,stroke:#82b366
    style HPAs fill:#fff2cc,stroke:#d6b656
    style ServiceMonitors fill:#fff2cc,stroke:#d6b656
    style Leases fill:#fff2cc,stroke:#d6b656
    style SCCs fill:#f8cecc,stroke:#b85450
