graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["modelmesh-controller<br/>(ServiceAccount)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["modelmesh-controller-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph NamespaceRoleBindings["Namespace Role Bindings"]
        LERB["modelmesh-leader-election-rolebinding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["modelmesh-controller-role<br/>(ClusterRole)"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        LER["modelmesh-leader-election-role<br/>(Role)"]
    end

    subgraph CoreResources["API Group: core ('')"]
        ConfigMaps["configmaps"]
        Endpoints["endpoints"]
        PVCs["persistentvolumeclaims"]
        Namespaces["namespaces<br/>namespaces/finalizers"]
        Secrets["secrets"]
        Services["services<br/>services/finalizers"]
    end

    subgraph AppsResources["API Group: apps"]
        Deployments["deployments<br/>deployments/finalizers"]
    end

    subgraph MonitoringResources["API Group: monitoring.coreos.com"]
        ServiceMonitors["servicemonitors"]
    end

    subgraph KServeResources["API Group: serving.kserve.io"]
        InferenceServices["inferenceservices<br/>+ /finalizers, /status"]
        Predictors["predictors<br/>+ /finalizers, /status"]
        ServingRuntimes["servingruntimes<br/>+ /finalizers, /status"]
        ClusterServingRuntimes["clusterservingruntimes<br/>+ /finalizers, /status"]
    end

    subgraph AutoscalingResources["API Group: autoscaling"]
        HPAs["horizontalpodautoscalers<br/>+ /status"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        LEConfigMaps["configmaps<br/>(leader lock)"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LERB
    CRB -->|grants| CR
    LERB -->|grants| LER

    %% ClusterRole permissions
    CR -->|create,delete,get,list,<br/>patch,update,watch| ConfigMaps
    CR -->|get,list,watch| Endpoints
    CR -->|get,list,watch| PVCs
    CR -->|get,list,patch,<br/>update,watch| Namespaces
    CR -->|create,delete,get,list,<br/>patch,update,watch| Secrets
    CR -->|create,delete,get,list,<br/>patch,update,watch| Services
    CR -->|create,delete,get,list,<br/>patch,update,watch| Deployments
    CR -->|create,delete,get,list,<br/>patch,update,watch| ServiceMonitors
    CR -->|create,delete,get,list,<br/>patch,update,watch| InferenceServices
    CR -->|create,delete,get,list,<br/>patch,update,watch| Predictors
    CR -->|create,delete,get,list,<br/>patch,update,watch| ServingRuntimes
    CR -->|create,delete,get,list,<br/>patch,update,watch| ClusterServingRuntimes
    CR -->|get,list,watch,create,<br/>delete,update| HPAs

    %% Leader election permissions
    LER -->|create,get,update| LEConfigMaps

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#5ba3f5,stroke:#333,color:#fff
    style LERB fill:#5ba3f5,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style LER fill:#f5a623,stroke:#333,color:#fff

    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Endpoints fill:#7ed321,stroke:#333,color:#fff
    style PVCs fill:#7ed321,stroke:#333,color:#fff
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style ServiceMonitors fill:#7ed321,stroke:#333,color:#fff
    style InferenceServices fill:#7ed321,stroke:#333,color:#fff
    style Predictors fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntimes fill:#7ed321,stroke:#333,color:#fff
    style ClusterServingRuntimes fill:#7ed321,stroke:#333,color:#fff
    style HPAs fill:#7ed321,stroke:#333,color:#fff
    style LEConfigMaps fill:#7ed321,stroke:#333,color:#fff
