graph TD
    subgraph "Service Account"
        SA["modelmesh-controller<br/>(ServiceAccount)"]
    end

    subgraph "Bindings"
        CRB["modelmesh-controller-rolebinding<br/>(ClusterRoleBinding)"]
        RB["leader-election-rolebinding<br/>(RoleBinding, controller namespace)"]
    end

    subgraph "Roles"
        CR["modelmesh-controller-role<br/>(ClusterRole)"]
        LER["leader-election-role<br/>(Role, namespace-scoped)"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB
    CRB -->|"grants"| CR
    RB -->|"grants"| LER

    subgraph "Core API Resources"
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        Services["core<br/>services<br/>services/finalizers"]
        Endpoints["core<br/>endpoints"]
        PVCs["core<br/>persistentvolumeclaims"]
        Namespaces["core<br/>namespaces<br/>namespaces/finalizers"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments<br/>deployments/finalizers"]
    end

    subgraph "Autoscaling API Resources"
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>horizontalpodautoscalers/status"]
    end

    subgraph "KServe API Resources (serving.kserve.io)"
        InferenceServices["inferenceservices<br/>+ finalizers + status"]
        Predictors["predictors<br/>+ finalizers + status"]
        ServingRuntimes["servingruntimes<br/>+ finalizers + status"]
        ClusterServingRuntimes["clusterservingruntimes<br/>+ finalizers + status"]
    end

    subgraph "Monitoring API Resources"
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
    end

    subgraph "Leader Election Resources"
        Leases["coordination.k8s.io<br/>leases"]
        LEConfigMaps["core<br/>configmaps (leader election)"]
    end

    %% Full CRUD permissions
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| ConfigMaps
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| Secrets
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| Services
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| Deployments
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| InferenceServices
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| Predictors
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| ServingRuntimes
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| ClusterServingRuntimes
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| ServiceMonitors

    %% Read-only permissions
    CR -->|"get, list, watch"| Endpoints
    CR -->|"get, list, watch"| PVCs

    %% Limited write permissions
    CR -->|"get, list, patch,<br/>update, watch"| Namespaces
    CR -->|"get, list, watch,<br/>create, delete, update"| HPAs

    %% Leader election
    LER -->|"get, create, update"| Leases
    LER -->|"get, create, update"| LEConfigMaps

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style LER fill:#f5a623,stroke:#333,color:#fff

    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#e74c3c,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style Endpoints fill:#a8d8a8,stroke:#333
    style PVCs fill:#a8d8a8,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style HPAs fill:#7ed321,stroke:#333,color:#fff
    style InferenceServices fill:#3498db,stroke:#333,color:#fff
    style Predictors fill:#3498db,stroke:#333,color:#fff
    style ServingRuntimes fill:#3498db,stroke:#333,color:#fff
    style ClusterServingRuntimes fill:#3498db,stroke:#333,color:#fff
    style ServiceMonitors fill:#1abc9c,stroke:#333,color:#fff
    style Leases fill:#bdc3c7,stroke:#333
    style LEConfigMaps fill:#bdc3c7,stroke:#333
