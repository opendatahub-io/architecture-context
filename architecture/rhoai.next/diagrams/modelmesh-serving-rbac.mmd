graph TD
    subgraph "Service Accounts"
        SA_Controller["modelmesh-controller<br/>(controller namespace)"]
        SA_Serving["modelmesh-serving-sa<br/>(runtime namespaces)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Main["modelmesh-controller-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph "RoleBindings (Namespace-scoped)"
        RB_LeaderElection["modelmesh-controller-<br/>leader-election-rolebinding"]
        RB_SCC["modelmesh-controller-<br/>restricted-scc-rolebinding"]
    end

    subgraph "ClusterRole: modelmesh-controller-role"
        direction TB
        CR_Main["modelmesh-controller-role"]
    end

    subgraph "Namespace Roles"
        R_LeaderElection["modelmesh-controller-<br/>leader-election-role"]
        R_SCC["modelmesh-controller-<br/>restricted-scc-role"]
    end

    subgraph "Core API Resources"
        ConfigMaps["core/v1<br/>ConfigMaps<br/>CRUD + watch"]
        Secrets["core/v1<br/>Secrets<br/>CRUD + watch"]
        Services["core/v1<br/>Services, Services/finalizers<br/>CRUD + watch"]
        Endpoints["core/v1<br/>Endpoints, PVCs<br/>get, list, watch"]
        Namespaces["core/v1<br/>Namespaces, NS/finalizers<br/>get, list, patch, update, watch"]
    end

    subgraph "Apps API Resources"
        Deployments["apps/v1<br/>Deployments, Deployments/finalizers<br/>CRUD + watch"]
    end

    subgraph "Serving API Resources (serving.kserve.io)"
        InferenceServices["InferenceServices<br/>+ finalizers + status<br/>CRUD + watch"]
        Predictors["Predictors<br/>+ finalizers + status<br/>CRUD + watch"]
        ServingRuntimes["ServingRuntimes<br/>+ finalizers + status<br/>CRUD + watch"]
        ClusterServingRuntimes["ClusterServingRuntimes<br/>+ finalizers + status<br/>CRUD + watch"]
    end

    subgraph "Other API Resources"
        HPA["autoscaling<br/>HorizontalPodAutoscalers<br/>CRUD + watch"]
        ServiceMonitors["monitoring.coreos.com<br/>ServiceMonitors<br/>CRUD + watch"]
    end

    subgraph "Leader Election Resources"
        Leases["coordination.k8s.io<br/>Leases<br/>create, get, list, update"]
        LE_ConfigMaps["core/v1<br/>ConfigMaps<br/>CRUD + watch"]
        Events["core/v1<br/>Events<br/>create"]
    end

    subgraph "OpenShift SCC"
        SCC["security.openshift.io<br/>SecurityContextConstraints<br/>(restricted)<br/>use"]
    end

    %% SA to Binding connections
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| RB_LeaderElection
    SA_Controller -->|bound via| RB_SCC
    SA_Serving -->|bound via| RB_SCC

    %% Binding to Role connections
    CRB_Main -->|grants| CR_Main
    RB_LeaderElection -->|grants| R_LeaderElection
    RB_SCC -->|grants| R_SCC

    %% ClusterRole to Resources
    CR_Main -->|manages| ConfigMaps
    CR_Main -->|manages| Secrets
    CR_Main -->|manages| Services
    CR_Main -->|reads| Endpoints
    CR_Main -->|reads| Namespaces
    CR_Main -->|manages| Deployments
    CR_Main -->|manages| InferenceServices
    CR_Main -->|manages| Predictors
    CR_Main -->|manages| ServingRuntimes
    CR_Main -->|manages| ClusterServingRuntimes
    CR_Main -->|manages| HPA
    CR_Main -->|manages| ServiceMonitors

    %% Leader Election Role to Resources
    R_LeaderElection -->|manages| Leases
    R_LeaderElection -->|manages| LE_ConfigMaps
    R_LeaderElection -->|creates| Events

    %% SCC Role to Resources
    R_SCC -->|uses| SCC

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Serving fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Main fill:#e67e22,stroke:#333,color:#fff
    style RB_LeaderElection fill:#e67e22,stroke:#333,color:#fff
    style RB_SCC fill:#e67e22,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style R_LeaderElection fill:#f5a623,stroke:#333
    style R_SCC fill:#f5a623,stroke:#333
    style InferenceServices fill:#7ed321,stroke:#333
    style Predictors fill:#7ed321,stroke:#333
    style ServingRuntimes fill:#7ed321,stroke:#333
    style ClusterServingRuntimes fill:#7ed321,stroke:#333
    style SCC fill:#9b59b6,stroke:#333,color:#fff
