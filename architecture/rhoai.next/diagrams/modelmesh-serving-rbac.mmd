graph TD
    subgraph "Service Accounts"
        SA_Controller["modelmesh-controller<br/>(controller namespace)"]
        SA_MM["modelmesh<br/>(runtime pods)"]
        SA_Serving["modelmesh-serving-sa<br/>(runtime pods)"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Main["modelmesh-controller-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_SCC["modelmesh-controller-restricted-scc-rolebinding<br/>(RoleBinding, controller NS)"]
    end

    subgraph "Role Bindings"
        RB_Leader["modelmesh-controller-leader-election-rolebinding<br/>(RoleBinding, controller NS)"]
    end

    subgraph "Cluster Roles"
        CR_Main["modelmesh-controller-role<br/>(ClusterRole)"]
        CR_SCC["modelmesh-controller-restricted-scc-role<br/>(ClusterRole)"]
    end

    subgraph "Namespace Roles"
        R_Leader["modelmesh-controller-leader-election-role<br/>(Role, controller NS)"]
    end

    subgraph "Core API Resources"
        ConfigMaps["core<br/>configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["core<br/>endpoints<br/>get,list,watch"]
        PVCs["core<br/>persistentvolumeclaims<br/>get,list,watch"]
        Namespaces["core<br/>namespaces,<br/>namespaces/finalizers<br/>get,list,patch,update,watch"]
        Secrets["core<br/>secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        Services["core<br/>services,<br/>services/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments,<br/>deployments/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "Serving API Resources"
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>(+ finalizers, status)<br/>create,delete,get,list,<br/>patch,update,watch"]
        Predictors["serving.kserve.io<br/>predictors<br/>(+ finalizers, status)<br/>create,delete,get,list,<br/>patch,update,watch"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes<br/>(+ finalizers, status)<br/>create,delete,get,list,<br/>patch,update,watch"]
        ClusterServingRuntimes["serving.kserve.io<br/>clusterservingruntimes<br/>(+ finalizers, status)<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "Autoscaling API Resources"
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>(+ status)<br/>get,list,watch,<br/>create,delete,update"]
    end

    subgraph "Monitoring API Resources"
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "Coordination API Resources"
        Leases["coordination.k8s.io<br/>leases<br/>create,get,list,update"]
    end

    subgraph "OpenShift Security"
        SCC["security.openshift.io<br/>securitycontextconstraints<br/>(resourceName: restricted)<br/>use"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Main
    SA_Controller -->|bound via| RB_Leader
    SA_MM -->|bound via| CRB_SCC
    SA_Serving -->|bound via| CRB_SCC

    CRB_Main -->|grants| CR_Main
    CRB_SCC -->|grants| CR_SCC
    RB_Leader -->|grants| R_Leader

    %% ClusterRole permissions
    CR_Main -->|manages| ConfigMaps
    CR_Main -->|reads| Endpoints
    CR_Main -->|reads| PVCs
    CR_Main -->|manages| Namespaces
    CR_Main -->|manages| Secrets
    CR_Main -->|manages| Services
    CR_Main -->|manages| Deployments
    CR_Main -->|manages| InferenceServices
    CR_Main -->|manages| Predictors
    CR_Main -->|manages| ServingRuntimes
    CR_Main -->|manages| ClusterServingRuntimes
    CR_Main -->|manages| HPAs
    CR_Main -->|manages| ServiceMonitors
    CR_Main -->|manages| Leases

    CR_SCC -->|uses| SCC

    R_Leader -->|leader election| Leases

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_MM fill:#4a90e2,color:#fff
    style SA_Serving fill:#4a90e2,color:#fff
    style CR_Main fill:#f5a623,color:#fff
    style CR_SCC fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style CRB_Main fill:#e8e8e8
    style CRB_SCC fill:#e8e8e8
    style RB_Leader fill:#e8e8e8

    style ConfigMaps fill:#7ed321,color:#fff
    style Endpoints fill:#7ed321,color:#fff
    style PVCs fill:#7ed321,color:#fff
    style Namespaces fill:#7ed321,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style InferenceServices fill:#7ed321,color:#fff
    style Predictors fill:#7ed321,color:#fff
    style ServingRuntimes fill:#7ed321,color:#fff
    style ClusterServingRuntimes fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style ServiceMonitors fill:#7ed321,color:#fff
    style Leases fill:#7ed321,color:#fff
