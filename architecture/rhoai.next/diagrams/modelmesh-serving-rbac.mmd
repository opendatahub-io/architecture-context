graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller[modelmesh-controller]
        SA_ModelMesh[modelmesh]
        SA_ServingSA[modelmesh-serving-sa]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Main[modelmesh-controller-rolebinding<br/>Scope: Cluster]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader[modelmesh-controller-leader-election-rolebinding<br/>Scope: Controller namespace]
        RB_SCC[modelmesh-controller-restricted-scc-rolebinding<br/>Scope: Controller namespace]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main[modelmesh-controller-role<br/>ClusterRole]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        R_Leader[modelmesh-controller-leader-election-role<br/>Role]
        R_SCC[modelmesh-controller-restricted-scc-role<br/>Role]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Secrets["core<br/>secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        Services["core<br/>services, services/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
        Namespaces["core<br/>namespaces, namespaces/finalizers<br/>get,list,patch,update,watch"]
        Endpoints["core<br/>endpoints, persistentvolumeclaims<br/>get,list,watch"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["apps<br/>deployments, deployments/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph ServingResources["serving.kserve.io Resources"]
        Predictors["serving.kserve.io<br/>predictors, predictors/finalizers,<br/>predictors/status<br/>create,delete,get,list,<br/>patch,update,watch"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes, servingruntimes/finalizers,<br/>servingruntimes/status<br/>create,delete,get,list,<br/>patch,update,watch"]
        ClusterServingRuntimes["serving.kserve.io<br/>clusterservingruntimes,<br/>clusterservingruntimes/finalizers,<br/>clusterservingruntimes/status<br/>create,delete,get,list,<br/>patch,update,watch"]
        InferenceServices["serving.kserve.io<br/>inferenceservices,<br/>inferenceservices/finalizers,<br/>inferenceservices/status<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        HPAs["autoscaling<br/>horizontalpodautoscalers,<br/>horizontalpodautoscalers/status<br/>get,list,watch,create,<br/>delete,update"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        Leases["coordination.k8s.io<br/>leases<br/>create,get,list,update"]
        LE_ConfigMaps["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
        Events["core<br/>events<br/>create"]
    end

    subgraph SCCResources["Security Context Constraints"]
        SCC["security.openshift.io<br/>securitycontextconstraints<br/>(restricted)<br/>use"]
    end

    %% Controller service account bindings
    SA_Controller -->|bound via| CRB_Main
    CRB_Main -->|grants| CR_Main

    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% ModelMesh and Serving SA bindings
    SA_ModelMesh -->|bound via| RB_SCC
    SA_ServingSA -->|bound via| RB_SCC
    RB_SCC -->|grants| R_SCC

    %% ClusterRole permissions
    CR_Main -->|manages| ConfigMaps
    CR_Main -->|manages| Secrets
    CR_Main -->|manages| Services
    CR_Main -->|reads| Namespaces
    CR_Main -->|reads| Endpoints
    CR_Main -->|manages| Deployments
    CR_Main -->|manages| Predictors
    CR_Main -->|manages| ServingRuntimes
    CR_Main -->|manages| ClusterServingRuntimes
    CR_Main -->|manages| InferenceServices
    CR_Main -->|manages| HPAs
    CR_Main -->|manages| ServiceMonitors

    %% Leader election permissions
    R_Leader -->|manages| Leases
    R_Leader -->|manages| LE_ConfigMaps
    R_Leader -->|creates| Events

    %% SCC permissions
    R_SCC -->|uses| SCC

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_ModelMesh fill:#4a90e2,color:#fff
    style SA_ServingSA fill:#4a90e2,color:#fff
    style CR_Main fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style R_SCC fill:#f5a623,color:#fff
    style CRB_Main fill:#e8e8e8,color:#333
    style RB_Leader fill:#e8e8e8,color:#333
    style RB_SCC fill:#e8e8e8,color:#333
    style Predictors fill:#7ed321,color:#fff
    style ServingRuntimes fill:#7ed321,color:#fff
    style ClusterServingRuntimes fill:#7ed321,color:#fff
    style InferenceServices fill:#7ed321,color:#fff
    style Deployments fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Secrets fill:#7ed321,color:#fff
    style HPAs fill:#7ed321,color:#fff
    style ServiceMonitors fill:#7ed321,color:#fff
    style Namespaces fill:#7ed321,color:#fff
    style Endpoints fill:#7ed321,color:#fff
    style Leases fill:#ddd,color:#333
    style LE_ConfigMaps fill:#ddd,color:#333
    style Events fill:#ddd,color:#333
    style SCC fill:#ff6b6b,color:#fff
