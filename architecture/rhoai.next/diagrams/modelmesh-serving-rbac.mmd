graph TD
    subgraph "Service Accounts"
        SA_Controller["modelmesh-controller<br/>(controller pod)"]
        SA_Serving["modelmesh-serving-sa<br/>(runtime pods)"]
    end

    subgraph "ClusterRole Bindings"
        CRB["modelmesh-controller-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph "Role Bindings (namespace-scoped)"
        RB_Leader["modelmesh-controller-leader-election-rolebinding"]
        RB_SCC["modelmesh-controller-restricted-scc-rolebinding"]
    end

    subgraph "ClusterRole"
        CR["modelmesh-controller-role<br/>(ClusterRole)"]
    end

    subgraph "Namespace-scoped Roles"
        R_Leader["modelmesh-controller-leader-election-role"]
        R_SCC["modelmesh-controller-restricted-scc-role"]
    end

    subgraph "Core API Resources"
        ConfigMaps["core<br/>configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Secrets["core<br/>secrets<br/>create,delete,get,list,<br/>patch,update,watch"]
        Services["core<br/>services, services/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
        Endpoints["core<br/>endpoints, pvcs<br/>get,list,watch"]
        Namespaces["core<br/>namespaces, namespaces/finalizers<br/>get,list,patch,update,watch"]
    end

    subgraph "Apps API Resources"
        Deployments["apps<br/>deployments, deployments/finalizers<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "serving.kserve.io Resources"
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>(+ /finalizers, /status)<br/>full CRUD"]
        Predictors["serving.kserve.io<br/>predictors<br/>(+ /finalizers, /status)<br/>full CRUD"]
        ServingRuntimes["serving.kserve.io<br/>servingruntimes<br/>(+ /finalizers, /status)<br/>full CRUD"]
        ClusterServingRuntimes["serving.kserve.io<br/>clusterservingruntimes<br/>(+ /finalizers, /status)<br/>full CRUD"]
    end

    subgraph "Autoscaling Resources"
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>(+ /status)<br/>get,list,watch,create,<br/>delete,update"]
    end

    subgraph "Monitoring Resources"
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,list,<br/>patch,update,watch"]
    end

    subgraph "Leader Election Resources"
        Leases["coordination.k8s.io<br/>leases<br/>create,get,list,update"]
        LEConfigMaps["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch,delete"]
        Events["core<br/>events<br/>create"]
    end

    subgraph "OpenShift SCC"
        SCC["security.openshift.io<br/>securitycontextconstraints<br/>(restricted)<br/>use"]
    end

    %% ClusterRole bindings
    SA_Controller -->|bound via| CRB
    CRB -->|grants| CR

    %% ClusterRole to resources
    CR -->|manages| ConfigMaps
    CR -->|manages| Secrets
    CR -->|manages| Services
    CR -->|reads| Endpoints
    CR -->|manages| Namespaces
    CR -->|manages| Deployments
    CR -->|manages| InferenceServices
    CR -->|manages| Predictors
    CR -->|manages| ServingRuntimes
    CR -->|manages| ClusterServingRuntimes
    CR -->|manages| HPAs
    CR -->|manages| ServiceMonitors

    %% Leader election
    SA_Controller -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader
    R_Leader -->|manages| Leases
    R_Leader -->|manages| LEConfigMaps
    R_Leader -->|creates| Events

    %% SCC
    SA_Controller -->|bound via| RB_SCC
    SA_Serving -->|bound via| RB_SCC
    RB_SCC -->|grants| R_SCC
    R_SCC -->|uses| SCC

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Serving fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_SCC fill:#f5a623,stroke:#333
    style CRB fill:#d4a017,stroke:#333
    style RB_Leader fill:#d4a017,stroke:#333
    style RB_SCC fill:#d4a017,stroke:#333
    style InferenceServices fill:#7ed321,stroke:#333
    style Predictors fill:#7ed321,stroke:#333
    style ServingRuntimes fill:#7ed321,stroke:#333
    style ClusterServingRuntimes fill:#7ed321,stroke:#333
    style SCC fill:#cc0000,stroke:#333,color:#fff
