graph LR
    vLLMROCm["vllm-rocm<br/>Inference Runtime"]

    %% Internal Platform Dependencies
    vLLMROCm -->|"deployed by<br/>ServingRuntime CRD"| KServe["KServe"]
    vLLMROCm -->|"routing via<br/>InferenceService"| KServeIS["KServe<br/>InferenceService"]
    vLLMROCm -->|"auth enforcement<br/>8443/TCP HTTPS"| KubeRBACProxy["kube-rbac-proxy<br/>Sidecar"]
    vLLMROCm -->|"external access<br/>443/TCP HTTPS"| PlatformIngress["RHOAI Platform<br/>Ingress<br/>(Gateway API)"]

    %% Base Image Dependency
    vLLMROCm -->|"extends via FROM<br/>container base"| RHAIISBase["RHAIIS Base Image<br/>rhaiis/vllm-rocm-rhel9<br/>v3.2.1"]

    %% External Hardware Dependencies
    vLLMROCm -->|"HIP API<br/>GPU compute"| ROCmDriver["AMD ROCm<br/>GPU Driver<br/>7.1.1"]
    ROCmDriver -->|"runs on"| AMDGPU["AMD Instinct GPU<br/>MI200/MI300"]

    %% External Service Dependencies (optional)
    vLLMROCm -.->|"HTTPS/443<br/>Bearer Token"| HFHub["Hugging Face Hub<br/>(optional)"]
    vLLMROCm -.->|"HTTPS/443<br/>IAM/S3 Keys"| S3["S3-Compatible<br/>Storage<br/>(optional)"]

    %% Model Storage
    vLLMROCm -->|"filesystem mount"| PVC["PVC / Local<br/>Model Storage"]

    %% Styling
    style vLLMROCm fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI components
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeIS fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff

    %% AIPCC dependency
    style RHAIISBase fill:#4a90e2,stroke:#333,color:#fff

    %% Hardware
    style ROCmDriver fill:#999,stroke:#333,color:#fff
    style AMDGPU fill:#666,stroke:#333,color:#fff

    %% External services
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#fff2cc,stroke:#d6b656
