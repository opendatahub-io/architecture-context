graph LR
    VllmRocm["vllm-rocm<br/>(Inference Runtime)"]

    %% External Dependencies (Required)
    VllmRocm -->|"base image<br/>3.2.1"| RHAIIS["RHAIIS<br/>vllm-rocm-rhel9"]
    VllmRocm -->|"GPU acceleration<br/>HIP/ROCm"| ROCm["AMD ROCm<br/>GPU Drivers"]

    %% Internal Platform Dependencies
    KServe["KServe"] -->|"deploys via<br/>ServingRuntime CR"| VllmRocm
    KServeIS["KServe<br/>InferenceService"] -->|"triggers pod<br/>creation"| VllmRocm

    %% Model Storage
    VllmRocm -->|"load model<br/>volume mount"| PVC["PVC Storage"]
    VllmRocm -->|"download model<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]

    %% Optional External
    VllmRocm -.->|"download model<br/>HTTPS/443"| HFHub["Hugging Face Hub"]

    %% Platform Integration Points
    PlatformIngress["Platform Ingress<br/>(Gateway API)"] -->|"routes traffic<br/>8000/TCP, 8033/TCP"| VllmRocm

    %% Build Dependencies
    Konflux["Konflux CI/CD"] -->|"builds image<br/>Tekton Pipeline"| VllmRocm
    Konflux -->|"pulls base<br/>HTTPS/443"| RHAIIS

    %% Styling
    style VllmRocm fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style ROCm fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KServeIS fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Konflux fill:#7ed321,stroke:#333,color:#fff
