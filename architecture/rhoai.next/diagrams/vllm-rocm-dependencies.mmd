graph LR
    VLLMRocm["vllm-rocm<br/>Inference Runtime"]

    %% External Dependencies (Required)
    VLLMRocm -->|"base image<br/>v3.2.1"| RHAIIS["RHAIIS vllm-rocm-rhel9<br/>(registry.redhat.io)"]
    VLLMRocm -->|"GPU compute<br/>HIP/ROCm"| ROCmGPU["AMD ROCm GPU Drivers<br/>(Host Node)"]

    %% Internal Platform Dependencies
    KServe["KServe"] -->|"deploys via<br/>ServingRuntime CR"| VLLMRocm
    KServe -->|"triggers via<br/>InferenceService CR"| VLLMRocm

    %% Model Storage
    VLLMRocm -->|"model weights<br/>HTTPS/443 TLS 1.2+"| S3["S3-Compatible Storage"]
    VLLMRocm -->|"model weights<br/>volume mount"| PVC["PVC Mount"]
    VLLMRocm -->|"models/tokenizers<br/>HTTPS/443 TLS 1.2+"| HFHub["Hugging Face Hub"]

    %% Platform Integration Points
    PlatformIngress["Platform Ingress<br/>(Gateway API /<br/>kube-rbac-proxy)"] -->|"routes to<br/>8000/TCP, 8033/TCP"| VLLMRocm

    %% Build Pipeline
    Konflux["Konflux CI/CD<br/>(rhoai-tenant)"] -.->|"builds image<br/>Tekton PipelineRun"| VLLMRocm
    Konflux -.->|"pulls base<br/>HTTPS/443"| RHAIIS

