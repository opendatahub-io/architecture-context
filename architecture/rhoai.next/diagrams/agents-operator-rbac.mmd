graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kagenti-operator-<br/>controller-manager<br/>(kagenti-system)"]
        WorkloadSA["per-workload SA<br/>(dynamic, per namespace)"]
        OtelSA["otel-collector SA<br/>(per namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB["kagenti-operator-<br/>manager-rolebinding"]
        SCCCRB["kagenti-operator-<br/>scc-authbridge"]
    end

    subgraph DynamicBindings["Dynamic RoleBindings (per namespace)"]
        AgentSCCRB["agent-authbridge-scc<br/>RoleBinding"]
        MLflowRB["kagenti-mlflow-{name}<br/>RoleBinding"]
        OtelRB["otel-collector-mlflow<br/>RoleBinding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR["manager-role"]
        SCCCR["system:openshift:scc:<br/>kagenti-authbridge"]
    end

    subgraph KagentiResources["agent.kagenti.dev Resources"]
        AgentCards["AgentCards<br/>create, delete, get, list,<br/>patch, update, watch"]
        AgentRuntimes["AgentRuntimes<br/>create, delete, get, list,<br/>patch, update, watch"]
        AgentCardsStatus["AgentCards/status<br/>get, patch, update"]
        AgentRuntimesStatus["AgentRuntimes/status<br/>get, patch, update"]
        AgentCardsFin["AgentCards/finalizers<br/>update"]
        AgentRuntimesFin["AgentRuntimes/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["ConfigMaps<br/>create, delete, get, list,<br/>patch, update, watch"]
        Secrets["Secrets<br/>create, delete, get, list,<br/>patch, update, watch"]
        Pods["Pods<br/>get, list, patch,<br/>update, watch"]
        Namespaces["Namespaces<br/>create, get, list,<br/>patch, watch"]
        ServiceAccts["ServiceAccounts<br/>create, get, list,<br/>update, watch"]
        Services["Services<br/>create, get, list,<br/>update, watch"]
    end

    subgraph AppsResources["apps Resources"]
        Deployments["Deployments<br/>get, list, patch,<br/>update, watch"]
        StatefulSets["StatefulSets<br/>create, get, list,<br/>patch, update, watch"]
        DaemonSets["DaemonSets<br/>get, list, patch,<br/>update, watch"]
    end

    subgraph NetworkResources["networking.k8s.io Resources"]
        NetworkPolicies["NetworkPolicies<br/>create, delete, get, list,<br/>patch, update, watch"]
        Ingresses["Ingresses<br/>get, list"]
    end

    subgraph CertResources["cert-manager.io Resources"]
        Certificates["Certificates<br/>create, delete, get, list,<br/>patch, update, watch"]
        Issuers["Issuers<br/>create, delete, get, list,<br/>patch, update, watch"]
        ClusterIssuers["ClusterIssuers<br/>get, list, watch"]
    end

    subgraph IntegrationResources["Integration Resources"]
        KeycloakCRs["k8s.keycloak.org<br/>keycloaks, keycloakrealmimports<br/>create, get, list, patch, update"]
        MLflowCRs["mlflow.opendatahub.io<br/>mlflows<br/>create, get, list, update, watch"]
        KuadrantCRs["kuadrant.io<br/>kuadrants<br/>create, get, list, patch, update, watch"]
        TektonCRs["operator.tekton.dev<br/>tektonconfigs<br/>get, list, patch, watch"]
        DSCCRs["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list, watch"]
        RouteCRs["route.openshift.io<br/>routes<br/>create, get, list, update"]
        SandboxCRs["agents.x-k8s.io<br/>sandboxes<br/>get, list, patch, update, watch"]
    end

    subgraph SCCPerms["SCC Permissions"]
        SCCUse["security.openshift.io<br/>securitycontextconstraints<br/>(kagenti-authbridge)<br/>use"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| SCCCRB
    WorkloadSA -->|bound via| AgentSCCRB
    WorkloadSA -->|bound via| MLflowRB
    OtelSA -->|bound via| OtelRB

    CRB -->|grants| CR
    SCCCRB -->|grants| SCCCR

    AgentSCCRB -->|grants| SCCCR
    MLflowRB -->|grants| MLflowCRs

    %% ClusterRole to Resources
    CR -->|manages| KagentiResources
    CR -->|manages| CoreResources
    CR -->|manages| AppsResources
    CR -->|manages| NetworkResources
    CR -->|manages| CertResources
    CR -->|manages| IntegrationResources

    SCCCR -->|allows| SCCPerms

