graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-<br/>controller-manager"]
        SA_Instance["feast-{name}<br/>(per FeatureStore)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["feast-operator-<br/>manager-rolebinding"]
        CRB_Metrics["feast-operator-<br/>metrics-auth-rolebinding"]
        CRB_Instance["feast-{name}-<br/>feast-binding (dynamic)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["feast-operator-<br/>leader-election-rolebinding<br/>(operator namespace)"]
        RB_Instance["feast-{name}-binding<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["feast-operator-manager-role"]
        CR_Editor["feast-operator-<br/>featurestore-editor-role"]
        CR_Viewer["feast-operator-<br/>featurestore-viewer-role"]
        CR_MetricsAuth["feast-operator-<br/>metrics-auth-role"]
        CR_MetricsReader["feast-operator-<br/>metrics-reader"]
        CR_Instance["feast-{name}-feast-role<br/>(dynamic)"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["feast-operator-<br/>leader-election-role"]
        R_Instance["feast-{name}<br/>(dynamic, per namespace)"]
    end

    subgraph ManagerPermissions["Manager Role Resources"]
        Res_FeatureStore["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers<br/>ALL verbs"]
        Res_Deployments["apps<br/>deployments<br/>create,delete,get,<br/>list,update,watch"]
        Res_Core["core<br/>configmaps, pvcs,<br/>serviceaccounts, services<br/>create,delete,get,<br/>list,update,watch"]
        Res_Namespaces["core<br/>namespaces<br/>get,list,patch,<br/>update,watch"]
        Res_PodsSecrets["core<br/>pods, secrets<br/>get,list,watch"]
        Res_PodExec["core<br/>pods/exec<br/>create"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>ALL verbs"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        Res_Routes["route.openshift.io<br/>routes<br/>ALL verbs"]
        Res_CronJobs["batch<br/>cronjobs<br/>ALL verbs"]
        Res_HPA["autoscaling<br/>horizontalpodautoscalers<br/>ALL verbs"]
        Res_PDB["policy<br/>poddisruptionbudgets<br/>ALL verbs"]
        Res_ServiceMonitor["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,<br/>list,patch,watch"]
        Res_Notebooks["kubeflow.org<br/>notebooks<br/>get,list,watch"]
        Res_CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get,list"]
    end

    subgraph DynamicPermissions["Dynamic Instance Permissions"]
        Res_DynRoleBindings["rbac.authorization.k8s.io<br/>rolebindings<br/>list"]
        Res_DynTokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
    end

    %% Operator SA bindings
    SA_Operator -->|bound via| CRB_Manager
    SA_Operator -->|bound via| CRB_Metrics
    SA_Operator -->|bound via| RB_Leader

    %% Instance SA bindings
    SA_Instance -->|bound via| CRB_Instance
    SA_Instance -->|bound via| RB_Instance

    %% ClusterRoleBinding → ClusterRole
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    CRB_Instance -->|grants| CR_Instance

    %% RoleBinding → Role
    RB_Leader -->|grants| R_Leader
    RB_Instance -->|grants| R_Instance

    %% Manager Role → Resources
    CR_Manager -->|access| Res_FeatureStore
    CR_Manager -->|access| Res_Deployments
    CR_Manager -->|access| Res_Core
    CR_Manager -->|access| Res_Namespaces
    CR_Manager -->|access| Res_PodsSecrets
    CR_Manager -->|access| Res_PodExec
    CR_Manager -->|access| Res_RBAC
    CR_Manager -->|access| Res_TokenReview
    CR_Manager -->|access| Res_Routes
    CR_Manager -->|access| Res_CronJobs
    CR_Manager -->|access| Res_HPA
    CR_Manager -->|access| Res_PDB
    CR_Manager -->|access| Res_ServiceMonitor
    CR_Manager -->|access| Res_Notebooks
    CR_Manager -->|access| Res_CRDs

    %% Dynamic Instance Role → Resources
    CR_Instance -->|access| Res_DynRoleBindings
    CR_Instance -->|access| Res_DynTokenReview

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_Editor fill:#f5a623,color:#fff
    style CR_Viewer fill:#f5a623,color:#fff
    style CR_MetricsAuth fill:#f5a623,color:#fff
    style CR_MetricsReader fill:#f5a623,color:#fff
    style CR_Instance fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style R_Instance fill:#f5a623,color:#fff
    style Res_FeatureStore fill:#7ed321,color:#fff
    style Res_Deployments fill:#7ed321,color:#fff
    style Res_Core fill:#7ed321,color:#fff
    style Res_Namespaces fill:#7ed321,color:#fff
    style Res_PodsSecrets fill:#7ed321,color:#fff
    style Res_PodExec fill:#7ed321,color:#fff
    style Res_RBAC fill:#7ed321,color:#fff
    style Res_TokenReview fill:#7ed321,color:#fff
    style Res_Routes fill:#7ed321,color:#fff
    style Res_CronJobs fill:#7ed321,color:#fff
    style Res_HPA fill:#7ed321,color:#fff
    style Res_PDB fill:#7ed321,color:#fff
    style Res_ServiceMonitor fill:#7ed321,color:#fff
    style Res_Notebooks fill:#7ed321,color:#fff
    style Res_CRDs fill:#7ed321,color:#fff
    style Res_DynRoleBindings fill:#7ed321,color:#fff
    style Res_DynTokenReview fill:#7ed321,color:#fff
