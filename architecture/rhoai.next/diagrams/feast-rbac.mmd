graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-<br/>controller-manager<br/>(operator namespace)"]
        SA_Instance["feast-{name}<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["feast-operator-<br/>manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Metrics["feast-operator-<br/>metrics-auth-rolebinding<br/>(cluster-scoped)"]
        CRB_Instance["feast-{name}-<br/>feast-binding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["feast-operator-<br/>leader-election-rolebinding<br/>(operator namespace)"]
        RB_Instance["feast-{name}-binding<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["feast-operator-manager-role"]
        CR_Editor["feast-operator-<br/>featurestore-editor-role"]
        CR_Viewer["feast-operator-<br/>featurestore-viewer-role"]
        CR_MetricsAuth["feast-operator-<br/>metrics-auth-role"]
        CR_MetricsReader["feast-operator-<br/>metrics-reader"]
        CR_InstanceRole["feast-{name}-feast-role<br/>(dynamic)"]
        CR_Discover["feast-discover-namespaces<br/>(dynamic)"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["feast-operator-<br/>leader-election-role"]
        R_Instance["feast-{name}<br/>(dynamic, namespaced)"]
    end

    subgraph APIResources_Manager["Manager Role Resources"]
        Res_FS["feast.dev<br/>featurestores<br/>+ status + finalizers"]
        Res_Apps["apps<br/>deployments"]
        Res_Core["core ('')<br/>configmaps, pvcs,<br/>serviceaccounts, services"]
        Res_NS["core ('')<br/>namespaces"]
        Res_Pods["core ('')<br/>pods, secrets,<br/>pods/exec"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings"]
        Res_Auth["authentication.k8s.io<br/>tokenreviews"]
        Res_Routes["route.openshift.io<br/>routes"]
        Res_Batch["batch<br/>cronjobs"]
        Res_HPA["autoscaling<br/>horizontalpodautoscalers"]
        Res_PDB["policy<br/>poddisruptionbudgets"]
        Res_Monitor["monitoring.coreos.com<br/>servicemonitors"]
        Res_NB["kubeflow.org<br/>notebooks"]
        Res_CRD["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph APIResources_Instance["Instance Role Resources"]
        Res_RB["rbac.authorization.k8s.io<br/>rolebindings"]
        Res_TR["authentication.k8s.io<br/>tokenreviews"]
    end

    %% SA → Binding → Role connections
    SA_Operator -->|"bound via"| CRB_Manager
    SA_Operator -->|"bound via"| CRB_Metrics
    SA_Operator -->|"bound via"| RB_Leader

    SA_Instance -->|"bound via"| CRB_Instance
    SA_Instance -->|"bound via"| RB_Instance

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    CRB_Instance -->|"grants"| CR_InstanceRole

    RB_Leader -->|"grants"| R_Leader
    RB_Instance -->|"grants"| R_Instance

    %% Manager Role → Resources
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Res_FS
    CR_Manager -->|"create,delete,<br/>get,list,<br/>update,watch"| Res_Apps
    CR_Manager -->|"create,delete,<br/>get,list,<br/>update,watch"| Res_Core
    CR_Manager -->|"get,list,patch,<br/>update,watch"| Res_NS
    CR_Manager -->|"get,list,watch<br/>+ pods/exec create"| Res_Pods
    CR_Manager -->|"create,delete,<br/>get,list,<br/>update,watch"| Res_RBAC
    CR_Manager -->|"create"| Res_Auth
    CR_Manager -->|"create,delete,<br/>get,list,<br/>update,watch"| Res_Routes
    CR_Manager -->|"CRUD + patch"| Res_Batch
    CR_Manager -->|"CRUD + patch"| Res_HPA
    CR_Manager -->|"CRUD + patch"| Res_PDB
    CR_Manager -->|"create,delete,<br/>get,list,<br/>patch,watch"| Res_Monitor
    CR_Manager -->|"get,list,watch"| Res_NB
    CR_Manager -->|"get,list"| Res_CRD

    %% Instance Role → Resources
    CR_InstanceRole -->|"list"| Res_RB
    CR_InstanceRole -->|"create"| Res_TR

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style CR_MetricsAuth fill:#f5a623,stroke:#333
    style CR_MetricsReader fill:#f5a623,stroke:#333
    style CR_InstanceRole fill:#f5a623,stroke:#333
    style CR_Discover fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_Instance fill:#f5a623,stroke:#333
    style Res_FS fill:#7ed321,stroke:#333
    style Res_Apps fill:#7ed321,stroke:#333
    style Res_Core fill:#7ed321,stroke:#333
    style Res_NS fill:#7ed321,stroke:#333
    style Res_Pods fill:#7ed321,stroke:#333
    style Res_RBAC fill:#7ed321,stroke:#333
    style Res_Auth fill:#7ed321,stroke:#333
    style Res_Routes fill:#7ed321,stroke:#333
    style Res_Batch fill:#7ed321,stroke:#333
    style Res_HPA fill:#7ed321,stroke:#333
    style Res_PDB fill:#7ed321,stroke:#333
    style Res_Monitor fill:#7ed321,stroke:#333
    style Res_NB fill:#7ed321,stroke:#333
    style Res_CRD fill:#7ed321,stroke:#333
    style Res_RB fill:#7ed321,stroke:#333
    style Res_TR fill:#7ed321,stroke:#333
