    class ConfigMaps,Namespaces,PVCs,SAs,Services,Pods,PodsExec,Deployments,CronJobs,HPAs,PDBs,FeatureStores,RBAC_Res,TokenReviews,Routes,ServiceMonitors,Notebooks,CRDs resource
