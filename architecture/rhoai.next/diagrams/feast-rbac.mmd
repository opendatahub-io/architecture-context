graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-controller-manager<br/>(operator namespace)"]
        SA_FS["feast-{name}<br/>({user-namespace})"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["feast-operator-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_OIDC["feast-{name}-oidc-crb<br/>(cluster-scoped, dynamic)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["feast-operator-leader-election-rolebinding<br/>(operator namespace)"]
        RB_Authz["feast-{name}-authz-rolebinding<br/>({user-namespace}, dynamic)"]
        RB_CronJob["feast-{name}-cronjob-rolebinding<br/>({user-namespace}, dynamic)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["feast-operator-manager-role"]
        CR_Editor["featurestore-editor-role<br/>(aggregated)"]
        CR_Viewer["featurestore-viewer-role<br/>(aggregated)"]
        CR_NS["feast-discover-namespaces<br/>(dynamic)"]
        CR_OIDC["feast-oidc-token-review<br/>(dynamic)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["feast-operator-leader-election-role"]
        R_Authz["feast-{name}-authz-role<br/>(dynamic)"]
        R_CronJob["feast-{name}-cronjob-role<br/>(dynamic)"]
    end

    subgraph Resources_Core["Core API Resources"]
        ConfigMaps["configmaps<br/>create,delete,get,list,<br/>patch,update,watch"]
        Namespaces["namespaces<br/>get,list,patch,<br/>update,watch"]
        PVCs["persistentvolumeclaims<br/>create,delete,get,<br/>list,update,watch"]
        SAs["serviceaccounts<br/>create,delete,get,<br/>list,update,watch"]
        Services["services<br/>create,delete,get,<br/>list,update,watch"]
        Pods["pods, secrets<br/>get,list,watch"]
        PodsExec["pods/exec<br/>create"]
    end

    subgraph Resources_Apps["Apps / Batch / Policy"]
        Deployments["apps/deployments<br/>create,delete,get,<br/>list,update,watch"]
        CronJobs["batch/cronjobs<br/>full CRUD"]
        HPAs["autoscaling/hpa<br/>full CRUD"]
        PDBs["policy/pdb<br/>full CRUD"]
    end

    subgraph Resources_Feast["Feast Resources"]
        FeatureStores["feast.dev/featurestores<br/>featurestores/finalizers<br/>featurestores/status<br/>full CRUD"]
    end

    subgraph Resources_Platform["Platform Resources"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>create,delete,get,list,update,watch"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
        Routes["route.openshift.io<br/>routes<br/>create,delete,get,list,update,watch"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>create,delete,get,list,patch,watch"]
        Notebooks["kubeflow.org<br/>notebooks<br/>get,list,watch"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get,list"]
    end

    %% Bindings
    SA_Operator -->|"bound via"| CRB_Manager
    SA_Operator -->|"bound via"| RB_Leader
    SA_FS -->|"bound via"| CRB_OIDC
    SA_FS -->|"bound via"| RB_Authz
    SA_FS -->|"bound via"| RB_CronJob

    CRB_Manager -->|"grants"| CR_Manager
    CRB_OIDC -->|"grants"| CR_OIDC
    RB_Leader -->|"grants"| R_Leader
    RB_Authz -->|"grants"| R_Authz
    RB_CronJob -->|"grants"| R_CronJob

    %% Manager role permissions
    CR_Manager -->|"manages"| ConfigMaps
    CR_Manager -->|"manages"| Namespaces
    CR_Manager -->|"manages"| PVCs
    CR_Manager -->|"manages"| SAs
    CR_Manager -->|"manages"| Services
    CR_Manager -->|"reads"| Pods
    CR_Manager -->|"exec"| PodsExec
    CR_Manager -->|"manages"| Deployments
    CR_Manager -->|"manages"| CronJobs
    CR_Manager -->|"manages"| HPAs
    CR_Manager -->|"manages"| PDBs
    CR_Manager -->|"manages"| FeatureStores
    CR_Manager -->|"manages"| RBAC_Res
    CR_Manager -->|"creates"| TokenReviews
    CR_Manager -->|"manages"| Routes
    CR_Manager -->|"manages"| ServiceMonitors
    CR_Manager -->|"watches"| Notebooks
    CR_Manager -->|"reads"| CRDs

    %% Aggregated roles
    CR_Editor -->|"full CRUD"| FeatureStores
    CR_Viewer -->|"get,list,watch"| FeatureStores
    CR_NS -->|"get,list,watch"| Namespaces
    CR_OIDC -->|"create"| TokenReviews

