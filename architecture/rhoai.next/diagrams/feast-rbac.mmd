graph TD
    subgraph "Service Accounts"
        SA["controller-manager<br/>(feast-operator SA)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(ClusterRoleBinding)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding, namespace-scoped)"]
    end

    subgraph "Cluster Roles"
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Viewer["featurestore-viewer-role<br/>(ClusterRole)"]
        CR_Editor["featurestore-editor-role<br/>(ClusterRole)"]
        CR_MetricsReader["metrics-reader<br/>(ClusterRole)"]
        CR_MetricsAuth["metrics-auth-role<br/>(ClusterRole)"]
        R_Leader["leader-election-role<br/>(Role, namespace-scoped)"]
    end

    subgraph "Feast CRD Resources"
        FeatureStore["feast.dev<br/>featurestores"]
        FeatureStoreFin["feast.dev<br/>featurestores/finalizers"]
        FeatureStoreSts["feast.dev<br/>featurestores/status"]
    end

    subgraph "Core Kubernetes Resources"
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims"]
        ServiceAccounts["core<br/>serviceaccounts"]
        Services["core<br/>services"]
        Namespaces["core<br/>namespaces"]
        Pods["core<br/>pods"]
        Secrets["core<br/>secrets"]
        PodsExec["core<br/>pods/exec"]
        Events["core<br/>events"]
    end

    subgraph "Workload Resources"
        Deployments["apps<br/>deployments"]
        CronJobs["batch<br/>cronjobs"]
        HPAs["autoscaling<br/>horizontalpodautoscalers"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph "RBAC & Auth Resources"
        ClusterRoles["rbac<br/>clusterroles"]
        ClusterRoleBindings["rbac<br/>clusterrolebindings"]
        Roles["rbac<br/>roles"]
        RoleBindings["rbac<br/>rolebindings"]
        TokenReviews["authentication<br/>tokenreviews"]
        SAR["authorization<br/>subjectaccessreviews"]
    end

    subgraph "Platform Resources"
        Routes["route.openshift.io<br/>routes"]
        Notebooks["kubeflow.org<br/>notebooks"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors"]
        CRDs["apiextensions<br/>customresourcedefinitions"]
        Leases["coordination<br/>leases"]
        Metrics["/metrics<br/>(nonResourceURL)"]
    end

    %% SA → Bindings
    SA -->|bound via| CRB_Manager
    SA -->|bound via| CRB_Metrics
    SA -->|bound via| RB_Leader

    %% Bindings → Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    RB_Leader -->|grants| R_Leader

    %% manager-role permissions
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| FeatureStore
    CR_Manager -->|"update"| FeatureStoreFin
    CR_Manager -->|"get,patch,update"| FeatureStoreSts
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| ConfigMaps
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| PVCs
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| ServiceAccounts
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| Services
    CR_Manager -->|"get,list,watch"| Namespaces
    CR_Manager -->|"get,list,watch"| Pods
    CR_Manager -->|"get,list,watch"| Secrets
    CR_Manager -->|"create"| PodsExec
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| Deployments
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| CronJobs
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| HPAs
    CR_Manager -->|"create,delete,get,list,<br/>patch,update,watch"| PDBs
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| ClusterRoles
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| ClusterRoleBindings
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| Roles
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| RoleBindings
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create,delete,get,<br/>list,update,watch"| Routes
    CR_Manager -->|"get,list,watch"| Notebooks
    CR_Manager -->|"create,delete,get,<br/>list,patch,watch"| ServiceMonitors
    CR_Manager -->|"get,list"| CRDs

    %% viewer-role permissions
    CR_Viewer -->|"get,list,watch"| FeatureStore
    CR_Viewer -->|"get,list,watch"| FeatureStoreSts

    %% editor-role permissions
    CR_Editor -->|"create,delete,get,list,<br/>patch,update,watch"| FeatureStore
    CR_Editor -->|"create,delete,get,list,<br/>patch,update,watch"| FeatureStoreSts

    %% metrics-auth-role permissions
    CR_MetricsAuth -->|"create"| TokenReviews
    CR_MetricsAuth -->|"create"| SAR

    %% metrics-reader permissions
    CR_MetricsReader -->|"get"| Metrics

    %% leader-election-role permissions
    R_Leader -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    R_Leader -->|"get,list,watch,create,<br/>update,patch,delete"| Leases
    R_Leader -->|"create,patch"| Events

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Viewer fill:#f5a623,stroke:#333,color:#fff
    style CR_Editor fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style R_Leader fill:#f5a623,stroke:#333,color:#fff
    style CRB_Manager fill:#bd10e0,stroke:#333,color:#fff
    style CRB_Metrics fill:#bd10e0,stroke:#333,color:#fff
    style RB_Leader fill:#bd10e0,stroke:#333,color:#fff
    style FeatureStore fill:#7ed321,stroke:#333,color:#fff
    style FeatureStoreFin fill:#7ed321,stroke:#333,color:#fff
    style FeatureStoreSts fill:#7ed321,stroke:#333,color:#fff
