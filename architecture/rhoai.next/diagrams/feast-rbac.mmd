graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-controller-manager<br/>(operator namespace)"]
        SA_FeatureStore["feast-{name}<br/>(FeatureStore namespace)"]
        SA_PolicySubjects["Groups/SAs from<br/>permission policies"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["feast-operator-manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_TokenReview["feast-{name}-cluster-binding<br/>(Cluster-scoped)"]
        CRB_Discover["feast-{ns}--{name}-discover<br/>(Cluster-scoped)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["feast-operator-manager-role"]
        CR_TokenReview["feast-token-review-cluster-role"]
        CR_Discover["feast-discover-namespaces"]
        CR_Editor["feast-operator-featurestore-editor-role"]
        CR_Viewer["feast-operator-featurestore-viewer-role"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_FS["feast-{name}<br/>(FeatureStore namespace)"]
        RB_Viewer["feast-{ns}--{name}-viewer<br/>(FeatureStore namespace)"]
        RB_Leader["feast-operator-leader-election-rolebinding<br/>(Operator namespace)"]
    end

    subgraph Roles["Namespace Roles"]
        R_FS["feast-{name}<br/>(FeatureStore namespace)"]
        R_Viewer["feast-{ns}--{name}-viewer<br/>(FeatureStore namespace)"]
        R_Leader["feast-operator-leader-election-role<br/>(Operator namespace)"]
    end

    subgraph ManagerResources["Manager Role Resources"]
        direction LR
        Core["Core API<br/>configmaps, namespaces,<br/>pvcs, serviceaccounts,<br/>services, pods, secrets,<br/>pods/exec"]
        Apps["apps<br/>deployments"]
        Batch["batch<br/>cronjobs"]
        FeastDev["feast.dev<br/>featurestores,<br/>featurestores/finalizers,<br/>featurestores/status"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings,<br/>subjectaccessreviews"]
        Auth["authentication.k8s.io<br/>tokenreviews"]
        Scaling["autoscaling<br/>horizontalpodautoscalers"]
        Policy_Res["policy<br/>poddisruptionbudgets"]
        Route["route.openshift.io<br/>routes"]
        Monitoring["monitoring.coreos.com<br/>servicemonitors"]
        Kubeflow["kubeflow.org<br/>notebooks"]
        ApiExt["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph TokenReviewResources["Token Review Role Resources"]
        TR_Auth["authentication.k8s.io<br/>tokenreviews (create)"]
        TR_RBAC["rbac.authorization.k8s.io<br/>rolebindings (list, create)<br/>subjectaccessreviews (list, create)"]
        TR_NS["Core API<br/>namespaces (get, list, watch)"]
        TR_CR["rbac.authorization.k8s.io<br/>clusterroles (get, list)<br/>clusterrolebindings (get, list)"]
    end

    subgraph EditorViewerResources["Editor/Viewer Role Resources"]
        EV_FS["feast.dev<br/>featurestores"]
    end

    %% Service Account → Binding → Role → Resources
    SA_Operator -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Core
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| Apps
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Batch
    CR_Manager -->|"full CRUD + finalizers"| FeastDev
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| RBAC_Res
    CR_Manager -->|"create"| Auth
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Scaling
    CR_Manager -->|"create, delete, get,<br/>list, patch, update, watch"| Policy_Res
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| Route
    CR_Manager -->|"create, delete, get,<br/>list, patch, watch"| Monitoring
    CR_Manager -->|"get, list, watch"| Kubeflow
    CR_Manager -->|"get, list"| ApiExt

    SA_FeatureStore -->|bound via| CRB_TokenReview
    CRB_TokenReview -->|grants| CR_TokenReview
    CR_TokenReview -->|access| TR_Auth
    CR_TokenReview -->|access| TR_RBAC
    CR_TokenReview -->|access| TR_NS
    CR_TokenReview -->|access| TR_CR

    SA_PolicySubjects -->|bound via| CRB_Discover
    CRB_Discover -->|grants| CR_Discover

    SA_FeatureStore -->|bound via| RB_FS
    RB_FS -->|grants| R_FS

    SA_PolicySubjects -->|bound via| RB_Viewer
    RB_Viewer -->|grants| R_Viewer

    SA_Operator -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    CR_Editor -->|"full CRUD"| EV_FS
    CR_Viewer -->|"get, list, watch"| EV_FS

