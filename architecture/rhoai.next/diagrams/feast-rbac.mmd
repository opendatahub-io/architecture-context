graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-controller-manager<br/>(Namespace: redhat-ods-applications)"]
        SA_FeatureStore["feast-{name}<br/>(Namespace: {user-namespace})"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["feast-operator-manager-rolebinding"]
        CRB_TokenReview["feast-{name}-cluster-binding"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_LeaderElection["feast-operator-leader-election-rolebinding<br/>(operator namespace)"]
        RB_FeatureStore["feast-{name}<br/>({user-namespace})"]
        RB_CronJob["feast-{name}-cronjob<br/>({user-namespace})"]
        RB_ConfigReader["feast-configs-registry-reader<br/>(operator namespace)<br/>Subjects: system:authenticated"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["feast-operator-manager-role"]
        CR_Editor["feast-operator-featurestore-editor-role"]
        CR_Viewer["feast-operator-featurestore-viewer-role"]
        CR_TokenReview["feast-token-review-cluster-role"]
        CR_Namespaces["feast-discover-namespaces"]
        CR_OIDCToken["feast-oidc-token-review"]
    end

    subgraph Roles["Namespace Roles"]
        R_LeaderElection["feast-operator-leader-election-role"]
        R_FeatureStore["feast-{name} (Role)"]
        R_CronJob["feast-{name}-cronjob (Role)"]
        R_ConfigReader["feast-configs-registry-reader (Role)"]
    end

    subgraph ManagerResources["feast-operator-manager-role Resources"]
        direction LR
        Core["core API<br/>configmaps, pvcs,<br/>serviceaccounts, services<br/>→ CRUD + watch"]
        CoreRO["core API<br/>pods, secrets<br/>→ get, list, watch"]
        Namespaces["core API<br/>namespaces<br/>→ get, list, patch,<br/>update, watch"]
        PodsExec["core API<br/>pods/exec<br/>→ create"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions<br/>→ get, list"]
        Deployments["apps<br/>deployments<br/>→ CRUD + watch"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
        HPA["autoscaling<br/>horizontalpodautoscalers<br/>→ CRUD + watch"]
        CronJobs["batch<br/>cronjobs<br/>→ CRUD + watch"]
        FeatureStores["feast.dev<br/>featurestores,<br/>featurestores/finalizers,<br/>featurestores/status<br/>→ CRUD + watch"]
        Notebooks["kubeflow.org<br/>notebooks<br/>→ get, list, watch"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>→ create, delete, get,<br/>list, patch, watch"]
        PDBs["policy<br/>poddisruptionbudgets<br/>→ CRUD + watch"]
        RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>clusterroles, rolebindings,<br/>roles, subjectaccessreviews<br/>→ CRUD + watch"]
        Routes["route.openshift.io<br/>routes<br/>→ CRUD + watch"]
    end

    subgraph EditorResources["feast-operator-featurestore-editor-role Resources"]
        EditorFS["feast.dev<br/>featurestores,<br/>featurestores/status<br/>→ CRUD + watch"]
    end

    subgraph ViewerResources["feast-operator-featurestore-viewer-role Resources"]
        ViewerFS["feast.dev<br/>featurestores,<br/>featurestores/status<br/>→ get, list, watch"]
    end

    subgraph TokenReviewResources["feast-token-review-cluster-role Resources"]
        TokenReviewRes["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
    end

    subgraph DiscoverResources["feast-discover-namespaces Resources"]
        DiscoverNS["core API<br/>namespaces<br/>→ get, list, watch"]
    end

    %% SA → Binding → Role flows
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    CR_Manager -->|"permissions on"| ManagerResources

    SA_Operator -->|"bound via"| RB_LeaderElection
    RB_LeaderElection -->|"grants"| R_LeaderElection

    SA_FeatureStore -->|"bound via"| CRB_TokenReview
    CRB_TokenReview -->|"grants"| CR_TokenReview
    CR_TokenReview -->|"permissions on"| TokenReviewResources

    SA_FeatureStore -->|"bound via"| RB_FeatureStore
    RB_FeatureStore -->|"grants"| R_FeatureStore

    SA_FeatureStore -->|"bound via"| RB_CronJob
    RB_CronJob -->|"grants"| R_CronJob

    CR_Editor -->|"permissions on"| EditorResources
    CR_Viewer -->|"permissions on"| ViewerResources
    CR_Namespaces -->|"permissions on"| DiscoverResources

    %% Styling
    style SA_Operator fill:#4a90e2,color:#fff
    style SA_FeatureStore fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_Editor fill:#f5a623,color:#fff
    style CR_Viewer fill:#f5a623,color:#fff
    style CR_TokenReview fill:#f5a623,color:#fff
    style CR_Namespaces fill:#f5a623,color:#fff
    style CR_OIDCToken fill:#f5a623,color:#fff
    style R_LeaderElection fill:#e8a040,color:#fff
    style R_FeatureStore fill:#e8a040,color:#fff
    style R_CronJob fill:#e8a040,color:#fff
    style R_ConfigReader fill:#e8a040,color:#fff
    style CRB_Manager fill:#b8d4f0
    style CRB_TokenReview fill:#b8d4f0
    style RB_LeaderElection fill:#d4e8b8
    style RB_FeatureStore fill:#d4e8b8
    style RB_CronJob fill:#d4e8b8
    style RB_ConfigReader fill:#d4e8b8
