graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (operator namespace)"]
        RB_Leader["leader-election-rolebinding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Viewer["featurestore-viewer-role"]
        CR_Editor["featurestore-editor-role"]
        CR_MetricsReader["metrics-reader"]
        CR_MetricsAuth["metrics-auth-role"]
    end

    subgraph Roles["Roles (operator namespace)"]
        R_Leader["leader-election-role"]
    end

    subgraph ManagerResources["manager-role Permissions"]
        direction TB
        FeastCRD["feast.dev<br/>featurestores<br/>featurestores/finalizers<br/>featurestores/status<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        CoreRW["core - empty group<br/>configmaps, pvcs,<br/>serviceaccounts, services<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        CoreRO["core - empty group<br/>namespaces, pods, secrets<br/><i>get,list,watch</i>"]
        CoreExec["core - empty group<br/>pods/exec<br/><i>create</i>"]
        AppsRes["apps<br/>deployments<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        AuthRes["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        AutoscaleRes["autoscaling<br/>horizontalpodautoscalers<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        BatchRes["batch<br/>cronjobs<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MonitorRes["monitoring.coreos.com<br/>servicemonitors<br/><i>create,delete,get,list,<br/>patch,watch</i>"]
        PolicyRes["policy<br/>poddisruptionbudgets<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        RBACRes["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings,<br/>subjectaccessreviews<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        RouteRes["route.openshift.io<br/>routes<br/><i>create,delete,get,list,<br/>update,watch</i>"]
        KubeflowRes["kubeflow.org<br/>notebooks<br/><i>get,list,watch</i>"]
        APIExtRes["apiextensions.k8s.io<br/>customresourcedefinitions<br/><i>get,list</i>"]
    end

    subgraph ViewerResources["featurestore-viewer-role Permissions"]
        ViewerFeast["feast.dev<br/>featurestores,<br/>featurestores/status<br/><i>get,list,watch</i>"]
    end

    subgraph EditorResources["featurestore-editor-role Permissions"]
        EditorFeast["feast.dev<br/>featurestores,<br/>featurestores/status<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
    end

    subgraph LeaderResources["leader-election-role Permissions"]
        LeaderCM["core - empty group<br/>configmaps<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        LeaderLease["coordination.k8s.io<br/>leases<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        LeaderEvents["core - empty group<br/>events<br/><i>create,patch</i>"]
    end

    subgraph MetricsResources["metrics-auth-role Permissions"]
        MetricsTokenReview["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        MetricsSAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    subgraph MetricsReaderResources["metrics-reader Permissions"]
        MetricsURL["nonResourceURL: /metrics<br/><i>get</i>"]
    end

