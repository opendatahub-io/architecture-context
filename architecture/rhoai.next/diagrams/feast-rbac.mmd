    %% Service Account bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Metrics
    SA_CM -->|bound via| RB_Leader

    %% Cluster Role Binding → Cluster Role
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth

    %% Role Binding → Role
    RB_Leader -->|grants| R_Leader

    %% manager-role permissions
    CR_Manager -->|manages| FeatureStores
    CR_Manager -->|manages| FeatureStoresFinalizers
    CR_Manager -->|manages| FeatureStoresStatus
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| ServiceAccounts2
    CR_Manager -->|manages| CoreServices
    CR_Manager -->|reads| ReadOnly
    CR_Manager -->|manages| PodsExec
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| CronJobs
    CR_Manager -->|manages| HPAs
    CR_Manager -->|manages| PDBs
    CR_Manager -->|manages| RBACAll
    CR_Manager -->|creates| TokenReviews
    CR_Manager -->|manages| Routes
    CR_Manager -->|manages| ServiceMonitors
    CR_Manager -->|watches| Notebooks
    CR_Manager -->|reads| CRDs

    %% Viewer/Editor roles
    CR_Viewer -->|reads| ViewerFS
    CR_Editor -->|manages| EditorFS

    %% Metrics roles
    CR_MetricsReader -->|reads| MetricsURL
    CR_MetricsAuth -->|creates| TokenReviews
    CR_MetricsAuth -->|creates| SAR

    %% Leader election role
    R_Leader -->|manages| LEConfigMaps
    R_Leader -->|manages| LELeases
    R_Leader -->|manages| LEEvents

