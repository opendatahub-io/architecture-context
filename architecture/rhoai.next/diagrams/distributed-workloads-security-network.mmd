graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
        UserPipeline["User / Pipeline Client"]
    end

    subgraph PlatformIngress["INGRESS (Platform-managed)"]
        Route["OpenShift Route<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ termination<br/>OAuth proxy / kube-rbac-proxy"]
    end

    subgraph ControlPlane["CONTROL PLANE (Operators)"]
        TrainerV2Ctrl["Kubeflow Trainer v2<br/>Controller"]
        KFTOCtrl["Training Operator<br/>(KFTO v1)"]
        KubeRayCtrl["KubeRay Operator"]
        KueueCtrl["Kueue"]
        NotebooksCtrl["Notebooks Controller"]
    end

    subgraph WorkloadPods["WORKLOAD PODS (Cluster-internal)"]
        direction TB

        subgraph MPIJob["MPI Training Job"]
            Rank0["Training Pod (rank 0)<br/>UID:1001 GID:0<br/>SSH:2222/TCP<br/>StrictModes=no"]
            Workers["Worker Pods (rank 1..N)<br/>UID:1001 GID:0<br/>SSH:2222/TCP<br/>StrictModes=no"]
        end

        subgraph RayCluster["Ray Cluster"]
            RayHead["Ray Head<br/>GCS:6379/TCP<br/>Dashboard:8265/TCP<br/>Client:10001/TCP<br/>No encryption, No auth"]
            RayWorker["Ray Workers"]
        end

        subgraph JupyterWB["Jupyter Workbench"]
            Jupyter["Universal Training Image<br/>UID:1001 GID:0<br/>HTTP:8888/TCP<br/>No encryption internally"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>HTTPS/443, TLS 1.2+<br/>Bearer Token (optional)"]
        S3["S3 Storage<br/>HTTPS/443, TLS 1.2+<br/>AWS IAM credentials"]
        MLflow["MLflow Tracking<br/>HTTP(S)/5000<br/>Bearer Token"]
    end

    subgraph BuildTimeOnly["BUILD-TIME ONLY (not runtime)"]
        NVIDIA["NVIDIA repos<br/>HTTPS/443"]
        AMD["AMD ROCm repos<br/>HTTPS/443"]
        MLNX["Mellanox OFED repos<br/>HTTPS/443"]
        RHELPyPI["RHEL AI PyPI<br/>HTTPS/443"]
    end

    %% User → Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth"| Route

    %% Ingress → Workbench
    Route -->|"HTTP/8888<br/>No encryption<br/>Platform token"| Jupyter

    %% User → Ray
    UserPipeline -->|"Ray Protocol/10001<br/>No encryption<br/>No auth"| RayHead

    %% Control Plane → K8s API → Pods
    TrainerV2Ctrl -.->|"creates pods<br/>+ SSH key secrets"| Rank0
    TrainerV2Ctrl -.->|"creates pods"| Workers
    KFTOCtrl -.->|"creates PyTorchJob pods"| Rank0
    KubeRayCtrl -.->|"creates RayCluster"| RayHead
    KubeRayCtrl -.->|"creates RayCluster"| RayWorker
    NotebooksCtrl -.->|"creates Notebook"| Jupyter

    %% MPI inter-pod
    Rank0 -->|"SSH/2222<br/>Host key (verification DISABLED)<br/>SSH key pair (per-job)"| Workers

    %% NCCL/RCCL
    Rank0 <-->|"InfiniBand RDMA<br/>NCCL/RCCL<br/>NO encryption"| Workers

    %% Ray inter-pod
    RayHead -->|"TCP/6379<br/>No encryption<br/>No auth"| RayWorker

    %% Egress
    Rank0 -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Rank0 -->|"HTTP(S)/5000<br/>Bearer Token"| MLflow
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF
    Jupyter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Rank0 -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5 5

    class Browser,UserPipeline external
    class Route ingress
    class TrainerV2Ctrl,KFTOCtrl,KubeRayCtrl,KueueCtrl,NotebooksCtrl controlplane
    class Rank0,Workers,RayHead,RayWorker,Jupyter workload
    class HF,S3,MLflow externalservice
    class NVIDIA,AMD,MLNX,RHELPyPI buildtime
