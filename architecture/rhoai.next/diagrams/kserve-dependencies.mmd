graph LR
    KServe["KServe<br/>(kserve-controller-manager<br/>+ llmisvc-controller-manager<br/>+ localmodel-controller)"]

    %% ─── External Dependencies (Required) ───
    subgraph Required["Required External Dependencies"]
        ControllerRuntime["controller-runtime<br/>v0.19.7"]
        CertManager["cert-manager"]
    end

    KServe -->|"controller framework"| ControllerRuntime
    KServe -->|"webhook + internal TLS certs"| CertManager

    %% ─── External Dependencies (Optional) ───
    subgraph Optional["Optional External Dependencies"]
        KnativeServing["Knative Serving<br/>v0.48.1"]
        IstioAPI["Istio API<br/>v1.27.1"]
        GatewayAPI["Gateway API<br/>v1.4.2"]
        InferenceGWExt["Gateway API<br/>Inference Extension<br/>v1.3.1"]
        KEDA["KEDA<br/>v2.17.3"]
        LeaderWorkerSet["LeaderWorkerSet<br/>v0.8.0"]
        PrometheusOp["Prometheus Operator"]
    end

    KServe -->|"serverless mode"| KnativeServing
    KServe -->|"VirtualService / DestinationRule"| IstioAPI
    KServe -->|"HTTPRoute / Gateway"| GatewayAPI
    KServe -->|"InferencePool CRD"| InferenceGWExt
    KServe -->|"external metric autoscaling"| KEDA
    KServe -->|"multi-node LLM orchestration"| LeaderWorkerSet
    KServe -->|"PodMonitor / ServiceMonitor"| PrometheusOp

    %% ─── Internal RHOAI Dependencies ───
    subgraph InternalRHOAI["Internal RHOAI Dependencies"]
        RhodsOperator["rhods-operator /<br/>opendatahub-operator"]
        RHOAIGateway["RHOAI Gateway<br/>(data-science-gateway)"]
        ServiceCA["OpenShift service-ca"]
        Kuadrant["Kuadrant /<br/>Red Hat Connectivity Link"]
        Prometheus["Prometheus"]
    end

    RhodsOperator -->|"deploys via Kustomize"| KServe
    KServe -->|"HTTPRoute parent ref"| RHOAIGateway
    KServe -->|"CA signing key (OCP)"| ServiceCA
    KServe -->|"AuthPolicy CRD check"| Kuadrant
    KServe -->|"WVA metric queries"| Prometheus

    %% ─── Runtime Dependencies ───
    subgraph Runtime["Runtime Dependencies (LLM Stack)"]
        vLLM["vLLM<br/>v0.18.0"]
        LLMDScheduler["llm-d-inference-scheduler<br/>v0.7.1"]
        LLMDWVA["llm-d-workload-variant-autoscaler<br/>v0.6.0"]
    end

    KServe -.->|"LLM serving runtime"| vLLM
    KServe -.->|"scheduler/EPP for LLMISVC"| LLMDScheduler
    KServe -.->|"WVA autoscaling"| LLMDWVA

    %% ─── Integration Points (consumed by) ───
    subgraph IntegrationConsumers["Components Consuming KServe"]
        ODHModelController["odh-model-controller"]
        ModelMesh["modelmesh-serving"]
    end

    ODHModelController -->|"webhook intercept<br/>InferenceService/Graph"| KServe
    ModelMesh -->|"webhook intercept<br/>ServingRuntime"| KServe

    %% ─── External Cloud Services ───
    subgraph CloudStorage["External Cloud Services"]
        S3["AWS S3"]
        GCS["Google Cloud Storage"]
        AzureBlob["Azure Blob Storage"]
        HuggingFace["HuggingFace Hub"]
        OCIReg["OCI Registries"]
    end

    KServe -->|"model download<br/>HTTPS/443"| S3
    KServe -->|"model download<br/>HTTPS/443"| GCS
    KServe -->|"model download<br/>HTTPS/443"| AzureBlob
    KServe -->|"model download<br/>HTTPS/443"| HuggingFace
    KServe -->|"model pull<br/>HTTPS/443"| OCIReg

    %% ─── Kubernetes API ───
    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    KServe -->|"all controller operations<br/>SA Token"| K8sAPI

