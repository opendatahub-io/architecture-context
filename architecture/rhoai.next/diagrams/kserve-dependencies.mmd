        CertManager["cert-manager<br/><i>upstream only</i>"]
        OpenShiftAPI["OpenShift API"]
        CtrlRuntime["controller-runtime<br/><i>v0.22.5</i>"]
    end

    %% Internal ODH Dependencies
    subgraph IntODH["Internal ODH Platform"]
        ODHOperator["odh-operator /<br/>rhods-operator"]
