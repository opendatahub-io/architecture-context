graph LR
    KServe["KServe<br/>(Multi-Controller Platform)"]

    %% External Dependencies (Required)
    KServe -->|"container orchestration<br/>HTTPS/6443"| Kubernetes["Kubernetes 1.25+"]
    KServe -->|"controller framework"| ControllerRuntime["controller-runtime v0.20+"]

    %% External Dependencies (Optional)
    KServe -->|"serverless mode<br/>(scale-to-zero)"| Knative["Knative Serving v1"]
    KServe -->|"traffic routing<br/>mTLS, VirtualService"| Istio["Istio v1beta1"]
    KServe -->|"modern ingress<br/>HTTPRoute"| GatewayAPI["Gateway API v1"]
    KServe -->|"external metrics<br/>autoscaling"| KEDA["KEDA v1alpha1"]
    KServe -->|"metrics collection"| OTel["OpenTelemetry<br/>Operator v1beta1"]
    KServe -->|"metrics scraping<br/>PodMonitor"| PrometheusOp["Prometheus<br/>Operator v1"]
    KServe -->|"multi-node LLM<br/>orchestration"| LWS["LeaderWorkerSet v1"]
    KServe -->|"TLS certificates<br/>(non-OpenShift)"| CertManager["cert-manager v1"]
    KServe -->|"WVA scaling<br/>for LLM"| LLMDWVA["LLM-D WVA v1alpha1"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>ODH Operator"] -->|"deploys via<br/>kustomize overlays"| KServe
    KServe -->|"VirtualService<br/>DestinationRule"| IstioOSSM["Istio OSSM<br/>(Service Mesh)"]
    KServe -->|"annotation-based<br/>cert injection"| ServiceCA["OpenShift<br/>service-ca"]
    KServe -->|"oauth-proxy sidecar<br/>auth for endpoints"| OSAuth["OpenShift OAuth"]
    KServe -->|"auth proxy<br/>RBAC enforcement"| KubeRBACProxy["kube-rbac-proxy"]

    %% LLM-specific Dependencies
    KServe -->|"LLM inference<br/>runtime image"| vLLM["vLLM<br/>(CUDA/ROCm/Gaudi/Spyre)"]
    KServe -->|"request scheduling<br/>load balancing"| LLMDScheduler["llm-d-inference-<br/>scheduler"]
    KServe -->|"disaggregated P/D<br/>routing"| LLMDRouting["llm-d-routing-<br/>sidecar"]
    KServe -->|"UDS tokenizer<br/>prefix cache"| LLMDTokenizer["llm-d-kv-cache<br/>(tokenizer)"]

    %% Integration Points (Consumers of KServe)
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    Pipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>models"| KServe
    DSCluster["DataScienceCluster<br/>CR"] -.->|"platform config"| KServe

    %% External Services
    KServe -->|"model storage<br/>HTTPS/443"| S3["S3 Storage"]
    KServe -->|"model storage<br/>HTTPS/443"| GCS["Google Cloud<br/>Storage"]
    KServe -->|"model storage<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]
    KServe -->|"model download<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]
    KServe -->|"OCI artifacts<br/>HTTPS/443"| OCIReg["OCI Registries"]
    KServe -->|"K8s API<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]

