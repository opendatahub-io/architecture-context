graph LR
    KServe["KServe<br/><i>Multi-Controller Operator</i>"]

    %% ─── External Dependencies (Required/Conditional) ───
    subgraph ExternalDeps["External Dependencies"]
        K8s["Kubernetes 1.27+<br/><i>Required</i>"]
        Istio["Istio / Service Mesh 1.20+<br/><i>Conditional</i>"]
        Knative["Knative Serving 1.12+<br/><i>Optional</i>"]
        CertMgr["cert-manager 1.12+<br/><i>Conditional (XKS)</i>"]
        GatewayAPI["Gateway API v1<br/><i>Conditional (LLMISVC)</i>"]
        KEDA["KEDA v2<br/><i>Optional</i>"]
        LWS["LeaderWorkerSet v1<br/><i>Optional (multi-node)</i>"]
        OTelOp["OpenTelemetry Operator<br/><i>Optional</i>"]
        PromOp["Prometheus Operator<br/><i>Optional</i>"]
    end

    %% ─── Internal Platform Dependencies ───
    subgraph InternalDeps["Internal Platform (ODH/RHOAI)"]
        RhodsOp["rhods-operator /<br/>opendatahub-operator"]
        ODHModelCtrl["odh-model-controller"]
        WVA["Workload Variant<br/>Autoscaler (WVA)"]
        LlmdScheduler["llm-d Inference<br/>Scheduler (EPP)"]
        LlmdSidecar["llm-d Routing<br/>Sidecar"]
        vLLM["vLLM Runtime"]
    end

    %% ─── External Services (Egress) ───
    subgraph ExternalSvcs["External Services"]
        S3["S3-compatible<br/>Storage"]
        GCS["Google Cloud<br/>Storage"]
        Azure["Azure Blob<br/>Storage"]
        HF["HuggingFace Hub"]
        OCI["OCI Container<br/>Registry"]
        HDFS["HDFS"]
    end

    %% ─── Downstream Consumers ───
    subgraph Consumers["Downstream Consumers"]
        Dashboard["ODH Dashboard<br/><i>UI management</i>"]
        Pipelines["Data Science<br/>Pipelines"]
        ODHModel["odh-model-controller<br/><i>Webhook intercept</i>"]
    end

    %% ─── KServe → External Dependencies ───
    KServe -->|"CRD CRUD<br/>443/TCP HTTPS"| K8s
    KServe -->|"VirtualService, DestinationRule<br/>mTLS, traffic routing"| Istio
    KServe -->|"Knative Service<br/>serverless mode"| Knative
    KServe -->|"Certificate, Issuer<br/>TLS provisioning"| CertMgr
    KServe -->|"HTTPRoute, Gateway<br/>ingress routing"| GatewayAPI
    KServe -->|"ScaledObject<br/>event-driven autoscaling"| KEDA
    KServe -->|"LeaderWorkerSet<br/>multi-node LLM"| LWS
    KServe -->|"OpenTelemetryCollector<br/>tracing/metrics"| OTelOp
    KServe -->|"PodMonitor, ServiceMonitor<br/>metrics scraping"| PromOp

    %% ─── KServe → Internal Dependencies ───
    RhodsOp -->|"creates Kserve CR"| KServe
    KServe -.->|"deploys"| ODHModelCtrl
    KServe -.->|"deploys"| WVA
    KServe -->|"EPP container image<br/>9002/TCP gRPC"| LlmdScheduler
    KServe -->|"disaggregated serving<br/>sidecar image"| LlmdSidecar
    KServe -->|"default LLM runtime<br/>8000/TCP"| vLLM

    %% ─── KServe → External Services ───
    KServe -->|"model download<br/>443/TCP HTTPS<br/>AWS IAM"| S3
    KServe -->|"model download<br/>443/TCP HTTPS<br/>GCP SA"| GCS
    KServe -->|"model download<br/>443/TCP HTTPS<br/>Azure Identity"| Azure
    KServe -->|"model download<br/>443/TCP HTTPS<br/>HF Token"| HF
    KServe -->|"OCI image pull<br/>443/TCP HTTPS"| OCI
    KServe -->|"model download<br/>Kerberos"| HDFS

    %% ─── Downstream → KServe ───
    Dashboard -->|"UI/API mgmt"| KServe
    Pipelines -->|"auto deploy models"| KServe
    ODHModel -->|"webhook intercept<br/>ISVC/LLMISVC"| KServe

