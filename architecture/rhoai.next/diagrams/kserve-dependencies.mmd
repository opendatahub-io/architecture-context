    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff

    style KnativeServing fill:#bbb,stroke:#333
    style IstioAPI fill:#bbb,stroke:#333
    style GatewayAPI fill:#bbb,stroke:#333
    style InferenceGWExt fill:#bbb,stroke:#333
    style KEDA fill:#bbb,stroke:#333
    style LeaderWorkerSet fill:#bbb,stroke:#333
    style PrometheusOp fill:#bbb,stroke:#333

    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff
    style RHOAIGateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style Kuadrant fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    style vLLM fill:#d4a3e8,stroke:#333
    style LLMDScheduler fill:#d4a3e8,stroke:#333
    style LLMDWVA fill:#d4a3e8,stroke:#333

    style ODHModelController fill:#a8d8ea,stroke:#333
    style ModelMesh fill:#a8d8ea,stroke:#333

    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
