graph LR
    KServe["KServe Platform<br/>(serving.kserve.io)"]

    %% External Dependencies (Required)
    KServe -->|"container orchestration<br/>(required)"| K8s["Kubernetes 1.25+"]
    KServe -->|"controller framework<br/>(required)"| CtrlRuntime["controller-runtime v0.20+"]

    %% External Dependencies (Optional)
    KServe -->|"serverless mode<br/>(scale-to-zero)"| Knative["Knative Serving v1"]
    KServe -->|"VirtualService ingress<br/>mTLS enforcement"| Istio["Istio v1beta1"]
    KServe -->|"HTTPRoute ingress<br/>(modern)"| GatewayAPI["Gateway API v1"]
    KServe -->|"external metrics<br/>autoscaling"| KEDA["KEDA v1alpha1"]
    KServe -->|"metrics collection"| OTel["OpenTelemetry Operator<br/>v1beta1"]
    KServe -->|"metrics scraping<br/>(PodMonitor/ServiceMonitor)"| Prometheus["Prometheus Operator v1"]
    KServe -->|"multi-node LLM<br/>orchestration"| LWS["LeaderWorkerSet v1"]
    KServe -->|"TLS certificates<br/>(non-OpenShift)"| CertManager["cert-manager v1"]
    KServe -->|"workload variant<br/>autoscaling (LLM)"| LLMDWVA["LLM-D WVA v1alpha1"]

    %% Internal RHOAI Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize overlays"| KServe
    KServe -->|"VirtualService<br/>DestinationRule"| OSSM["Istio / OSSM<br/>(Service Mesh)"]
    KServe -->|"annotation-based<br/>cert injection"| ServiceCA["OpenShift service-ca"]
    KServe -->|"oauth-proxy sidecar<br/>auth for endpoints"| OAuthProxy["OpenShift OAuth"]
    KServe -->|"auth proxy sidecar<br/>RBAC enforcement"| KubeRBACProxy["kube-rbac-proxy"]

    %% LLM Runtime Dependencies
    KServe -->|"LLM inference runtime"| vLLM["vLLM<br/>(CUDA/ROCm/Gaudi/Spyre)"]
    KServe -->|"request scheduling<br/>load balancing"| LLMDScheduler["llm-d-inference-scheduler"]
    KServe -->|"disaggregated P/D<br/>request routing"| LLMDRouting["llm-d-routing-sidecar"]
    KServe -->|"UDS tokenizer<br/>prefix cache scoring"| LLMDTokenizer["llm-d-kv-cache<br/>(tokenizer)"]

    %% External Services (Egress)
    KServe -->|"model storage<br/>HTTPS/443"| S3["S3 Storage"]
    KServe -->|"model storage<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    KServe -->|"model storage<br/>HTTPS/443"| AzureBlob["Azure Blob Storage"]
    KServe -->|"model download<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]
    KServe -->|"OCI artifacts<br/>HTTPS/443"| OCIReg["OCI Registries"]

    %% Integration consumers
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    DSC["DataScienceCluster"] -.->|"platform config<br/>(CRD watch)"| KServe
    DSCI["DSCInitialization"] -.->|"init state<br/>(CRD watch)"| KServe

