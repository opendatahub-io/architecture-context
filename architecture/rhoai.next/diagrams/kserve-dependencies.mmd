graph LR
    KServe["KServe Platform<br/>(Multi-Controller)"]

    %% Required External Dependencies
    KServe -->|"container orchestration<br/>HTTPS/6443"| K8s["Kubernetes 1.25+"]
    KServe -->|"controller framework"| CtrlRuntime["controller-runtime v0.20+"]

    %% Optional External Dependencies
    KServe -.->|"serverless mode<br/>(scale-to-zero)"| Knative["Knative Serving v1"]
    KServe -.->|"VirtualService ingress<br/>mTLS, traffic routing"| Istio["Istio v1beta1"]
    KServe -.->|"HTTPRoute ingress<br/>(modern)"| GatewayAPI["Gateway API v1"]
    KServe -.->|"external metrics<br/>autoscaling"| KEDA["KEDA v1alpha1"]
    KServe -.->|"metrics collection"| OTel["OpenTelemetry<br/>Operator v1beta1"]
    KServe -.->|"PodMonitor /<br/>ServiceMonitor"| PromOp["Prometheus<br/>Operator v1"]
    KServe -.->|"multi-node LLM<br/>orchestration"| LWS["LeaderWorkerSet v1"]
    KServe -.->|"TLS cert mgmt<br/>(non-OpenShift)"| CertManager["cert-manager v1"]
    KServe -.->|"cost-based LLM<br/>replica scaling"| LLMDWVA["LLM-D WVA v1alpha1"]

    %% Internal ODH / RHOAI Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"kustomize deploy"| KServe
    KServe -.->|"DestinationRules<br/>mTLS enforcement"| OSSM["Istio Service Mesh<br/>(OSSM)"]
    KServe -.->|"webhook TLS certs<br/>(replaces cert-manager)"| ServiceCA["OpenShift<br/>service-ca"]
    KServe -.->|"oauth-proxy sidecar<br/>auth for endpoints"| OAuthProxy["OpenShift OAuth"]
    KServe -.->|"RBAC proxy sidecar"| KubeRBACProxy["kube-rbac-proxy"]
    KServe -.->|"LLM runtime images"| vLLM["vLLM<br/>(CUDA/ROCm/Gaudi/Spyre)"]
    KServe -.->|"LLM request scheduling<br/>InferencePool LB"| LLMDScheduler["llm-d-inference-<br/>scheduler"]
    KServe -.->|"disaggregated P/D<br/>request routing"| LLMDRouting["llm-d-routing-<br/>sidecar"]
    KServe -.->|"UDS tokenizer<br/>prefix cache scoring"| LLMDTokenizer["llm-d-kv-cache<br/>(tokenizer)"]

    %% Downstream consumers / integrations
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    DSPipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>models"| KServe
    ODHModelCtrl["odh-model-controller"] -.->|"mutates/validates<br/>InferenceService"| KServe
    ModelMesh["ModelMesh Serving"] -.->|"multi-model<br/>serving mode"| KServe

    %% External Services (runtime)
    KServe -->|"model download<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]
    KServe -->|"model download<br/>HTTPS/443"| GCS["Google Cloud<br/>Storage"]
    KServe -->|"model download<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]
    KServe -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace<br/>Hub"]
    KServe -->|"model download<br/>HTTPS/443"| OCIReg["OCI Registries"]
    KServe -->|"all CRUD ops<br/>HTTPS/6443"| K8sAPI["Kubernetes API<br/>Server"]

