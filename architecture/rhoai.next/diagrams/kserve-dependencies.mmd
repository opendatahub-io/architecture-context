graph LR
    KServe["KServe Platform<br/>(Multi-Controller)"]

    %% Core Controllers
    subgraph KServeControllers["KServe Controllers"]
        KCtrl["kserve-controller"]
        LLMCtrl["llmisvc-controller"]
        LMCtrl["localmodel-controller"]
        LMAgent["localmodelnode-agent"]
    end

    %% External Dependencies (Required)
    KServe -->|"container orchestration<br/>(required)"| K8s["Kubernetes v1.34+"]
    KServe -->|"operator framework<br/>(required)"| CR["controller-runtime v0.19.7"]

    %% External Dependencies (Optional)
    KCtrl -->|"serverless deploy mode"| Knative["Knative Serving v0.48+"]
    KCtrl -->|"traffic mgmt, VirtualService"| Istio["Istio v1.27+"]
    KCtrl -->|"event-driven autoscaling"| KEDA["KEDA v2.17+"]
    KCtrl -->|"OTel sidecar metrics"| OTel["OpenTelemetry Op v0.113+"]

    LLMCtrl -->|"HTTPRoute ingress"| GatewayAPI["Gateway API v1.4+"]
    LLMCtrl -->|"InferencePool, InferenceModel"| GWInfExt["Gateway API Inf Ext v1.3+"]
    LLMCtrl -->|"multi-node LLM workloads"| LWS["LeaderWorkerSet v0.8+"]
    LLMCtrl -->|"DestinationRules (mTLS)"| Istio
    LLMCtrl -->|"ScaledObjects"| KEDA
    LLMCtrl -->|"PodMonitor, ServiceMonitor"| PromOp["Prometheus Op v0.89+"]
    LLMCtrl -->|"cost-aware autoscaling"| WVA["llm-d WVA v0.6+"]
    LLMCtrl -->|"AuthPolicy check"| Kuadrant["Kuadrant v1"]

    %% Internal Platform Dependencies
    KServe -.->|"deployed by"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    KCtrl -.->|"watches"| DSCInit["DSCInitialization"]
    KCtrl -.->|"watches"| DSCluster["DataScienceCluster"]
    KCtrl -.->|"creates Routes"| OSRoutes["OpenShift Route API"]
    KCtrl -.->|"OpenShift serving certs<br/>(replaces cert-manager)"| OSCerts["OpenShift<br/>Serving Certs"]
    LLMCtrl -.->|"SCC for multi-node"| OSSCC["OpenShift SCC"]

    %% Integration Points (components that integrate WITH KServe)
    KRBACProxy["kube-rbac-proxy"] -->|"auth sidecar"| KServe
    CertManager["cert-manager<br/>(non-RHOAI only)"] -.->|"TLS certs"| KServe

    %% External Services (Egress)
    KServe -->|"model artifacts<br/>HTTPS/443"| S3["S3 Storage"]
    KServe -->|"model artifacts<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    KServe -->|"model artifacts<br/>HTTPS/443"| AzureBlob["Azure Blob Storage"]
    KServe -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    KServe -->|"model access<br/>RPC/8020"| HDFS["HDFS"]

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LMCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LMAgent fill:#4a90e2,stroke:#333,color:#fff

    %% Required dependencies
    style K8s fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff

    %% Optional external dependencies
    style Knative fill:#bbb,stroke:#333
    style Istio fill:#bbb,stroke:#333
    style KEDA fill:#bbb,stroke:#333
    style OTel fill:#bbb,stroke:#333
    style GatewayAPI fill:#bbb,stroke:#333
    style GWInfExt fill:#bbb,stroke:#333
    style LWS fill:#bbb,stroke:#333
    style PromOp fill:#bbb,stroke:#333
    style WVA fill:#bbb,stroke:#333
    style Kuadrant fill:#bbb,stroke:#333
    style CertManager fill:#bbb,stroke:#333

    %% Internal platform
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style DSCInit fill:#7ed321,stroke:#333,color:#fff
    style DSCluster fill:#7ed321,stroke:#333,color:#fff
    style OSRoutes fill:#7ed321,stroke:#333,color:#fff
    style OSCerts fill:#7ed321,stroke:#333,color:#fff
    style OSSCC fill:#7ed321,stroke:#333,color:#fff
    style KRBACProxy fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style HDFS fill:#f5a623,stroke:#333,color:#fff
