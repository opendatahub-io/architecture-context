graph LR
    KServe["KServe Platform<br/>(Multi-Controller)"]

    %% External Dependencies (Required)
    KServe -->|"container orchestration<br/>(required)"| K8s["Kubernetes v1.34+"]
    KServe -->|"operator framework<br/>(required)"| CtrlRuntime["controller-runtime v0.19.7"]

    %% External Dependencies (Optional)
    KServe -->|"serverless deployment"| Knative["Knative Serving v0.48+"]
    KServe -->|"traffic mgmt, mTLS,<br/>VirtualService, DestinationRule"| Istio["Istio v1.27+"]
    KServe -->|"HTTPRoute ingress<br/>(ISVC + LLMISVC)"| GatewayAPI["Gateway API v1.4+"]
    KServe -->|"InferencePool,<br/>InferenceModel"| GWInfExt["Gateway API<br/>Inference Extension v1.3+"]
    KServe -->|"event-driven autoscaling"| KEDA["KEDA v2.17+"]
    KServe -->|"multi-node LLM workloads"| LWS["LeaderWorkerSet v0.8+"]
    KServe -->|"OTel sidecar metrics"| OTelOp["OpenTelemetry<br/>Operator v0.113+"]
    KServe -->|"PodMonitor,<br/>ServiceMonitor"| PromOp["Prometheus<br/>Operator v0.89+"]
    KServe -->|"cost-aware LLM scaling"| LLMDWVA["llm-d WVA v0.6+"]
    KServe -->|"TLS certs (non-RHOAI)"| CertMgr["cert-manager"]
    KServe -->|"gateway auth (OCP)"| Kuadrant["Kuadrant v1"]

    %% Internal RHOAI Platform Dependencies
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize"| KServe
    KServe -.->|"watches CRDs"| DSCI["DSCInitialization"]
    KServe -.->|"watches CRDs"| DSC["DataScienceCluster"]
    KServe -->|"creates Routes<br/>(InferenceGraph)"| OCPRoute["OpenShift Route API"]
    KServe -->|"webhook TLS<br/>(annotation-based)"| OCPCerts["OpenShift<br/>Serving Certs"]
    KServe -->|"SCC for multi-node<br/>& LocalModel"| OCPSCC["OpenShift SCC"]

    %% External Services (Egress)
    KServe -->|"model artifacts<br/>HTTPS/443"| S3["S3 Storage"]
    KServe -->|"model artifacts<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    KServe -->|"model artifacts<br/>HTTPS/443"| Azure["Azure Blob Storage"]
    KServe -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    KServe -->|"model access<br/>RPC/8020"| HDFS["HDFS"]

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    classDef required fill:#2c3e50,stroke:#333,stroke-width:2px,color:#fff
    classDef optional fill:#7f8c8d,stroke:#333,stroke-width:1px,color:#fff
    classDef internal fill:#27ae60,stroke:#333,stroke-width:2px,color:#fff
    classDef extsvc fill:#e67e22,stroke:#333,stroke-width:2px,color:#fff
    classDef deployer fill:#8e44ad,stroke:#333,stroke-width:2px,color:#fff

    class K8s,CtrlRuntime required
    class Knative,Istio,GatewayAPI,GWInfExt,KEDA,LWS,OTelOp,PromOp,LLMDWVA,CertMgr,Kuadrant optional
    class DSCI,DSC,OCPRoute,OCPCerts,OCPSCC internal
    class RHOAIOp deployer
    class S3,GCS,Azure,HFHub,HDFS extsvc
