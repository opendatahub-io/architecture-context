        VLLM_ROCm["vLLM ROCm"]
        VLLM_Gaudi["vLLM Gaudi"]
        VLLM_Spyre["vLLM Spyre"]
    end

    %% External Storage Services
    subgraph Storage["Cloud Storage"]
        S3["S3 / MinIO"]
        GCS["Google Cloud Storage"]
        Azure["Azure Blob Storage"]
        HuggingFace["HuggingFace Hub"]
    end

    %% KServe to External Infrastructure
    KServe -->|"serverless mode<br/>(optional)"| Knative
    KServe -->|"VirtualService ingress<br/>(optional)"| Istio
    KServe -->|"HTTPRoute ingress<br/>(raw/LLM mode)"| GatewayAPI
    KServe -->|"InferencePool CRD<br/>(LLM routing)"| GIE
    KServe -->|"ScaledObject<br/>autoscaling"| KEDA
    KServe -->|"OTelCollector<br/>metrics pipeline"| OTel
    KServe -->|"ServiceMonitor<br/>metrics scraping"| Prometheus
    KServe -->|"multi-node<br/>inference"| LWS
    KServe -->|"webhook certs<br/>(upstream)"| CertManager
    KServe -->|"Routes<br/>(OpenShift)"| OpenShiftAPI
    KServe -->|"controller<br/>framework"| CtrlRuntime

    %% KServe to Internal ODH
    ODHOperator -->|"Kserve CR<br/>lifecycle mgmt"| KServe
    KServe -.->|"co-deployed"| ODHModelCtrl
    KServe -.->|"auth sidecar<br/>8443/TCP HTTPS"| AuthProxy

    %% KServe to llm-d
    KServe -->|"inference scheduler<br/>8080/TCP HTTP"| LLMD_EPP
    KServe -->|"disaggregated<br/>routing init"| LLMD_Sidecar
    KServe -->|"token counting<br/>UDS"| LLMD_UDS

    %% KServe to vLLM
    KServe -.->|"runtime images<br/>via LLMISvcConfig"| VLLM_CUDA
    KServe -.->|"runtime images"| VLLM_ROCm
    KServe -.->|"runtime images"| VLLM_Gaudi
    KServe -.->|"runtime images"| VLLM_Spyre

    %% Incoming integrations
    Dashboard["ODH Dashboard"] -->|"UI management"| KServe
    Pipelines["Data Science<br/>Pipelines"] -->|"auto deploy"| KServe

    %% Storage
    KServe -->|"model download<br/>443/TCP HTTPS"| S3
    KServe -->|"model download<br/>443/TCP HTTPS"| GCS
    KServe -->|"model download<br/>443/TCP HTTPS"| Azure
    KServe -->|"model download<br/>443/TCP HTTPS"| HuggingFace

