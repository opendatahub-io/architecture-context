graph TD
    subgraph "vllm-spyre RBAC Model"
        direction TB

        Note["NOTE: No RBAC resources defined<br/>in this repository.<br/><br/>vllm-spyre is a container image,<br/>not an operator.<br/><br/>All RBAC is managed by the<br/>platform components below."]
    end

    subgraph "Platform-Managed RBAC (External)"
        direction TB

        subgraph "KServe RBAC"
            KServeSA["ServiceAccount<br/>kserve-controller-manager"]
            KServeCR["ClusterRole<br/>kserve-manager-role"]
            KServeCRB["ClusterRoleBinding<br/>kserve-manager-rolebinding"]

            KServeSA -->|"bound via"| KServeCRB
            KServeCRB -->|"grants"| KServeCR
        end

        subgraph "KServe Permissions"
            ISVC["serving.kserve.io<br/>InferenceService<br/>get,list,watch,create,<br/>update,patch,delete"]
            SRT["serving.kserve.io<br/>ServingRuntime<br/>get,list,watch"]
        end

        KServeCR -->|"manages"| ISVC
        KServeCR -->|"reads"| SRT

        subgraph "Container Runtime Context"
            ContainerUID["vllm-spyre Container<br/>UID: 2000 (non-root)<br/>No privileged access<br/>SCC: restricted-v2"]
        end
    end

    subgraph "Auth Delegation Chain"
        direction LR
        Ingress["Platform Ingress<br/>(kube-rbac-proxy /<br/>Gateway API /<br/>OAuth proxy)"] -->|"enforces auth"| KServeRouting["KServe Routing"] -->|"forwards<br/>(no auth)"| Container["vllm-spyre<br/>(unauthenticated<br/>endpoints)"]
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeCR fill:#f5a623,stroke:#333
    style KServeCRB fill:#ddd,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style SRT fill:#7ed321,stroke:#333
    style ContainerUID fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Ingress fill:#ffe6cc,stroke:#d79b00
    style KServeRouting fill:#d5e8d4,stroke:#82b366
    style Container fill:#4a90e2,stroke:#333,color:#fff
