graph TD
    subgraph ContainerSecurity["Container Security Context"]
        UID["Container User<br/>UID: 2000 (non-root)"]
        SCC["OpenShift SCC<br/>restricted-v2"]
    end

    subgraph AuthDelegation["Authentication Delegation Model"]
        direction TB
        Note1["vllm-spyre exposes<br/>UNAUTHENTICATED endpoints"]
        Note2["All AuthN/AuthZ is DELEGATED<br/>to platform infrastructure"]
    end

    subgraph PlatformAuthOptions["Platform Auth Enforcement (one of)"]
        KRBAC["kube-rbac-proxy<br/>Sidecar Container<br/>(older RHOAI versions)"]
        GatewayAPI["Gateway API<br/>with EnvoyFilter<br/>(newer RHOAI versions)"]
        OAuthProxy["OAuth Proxy<br/>(alternative config)"]
    end

    subgraph KServeRBAC["KServe-Managed RBAC"]
        KServeSA["ServiceAccount<br/>(per InferenceService)"]
        KServeRole["KServe manages<br/>SA bindings for<br/>model storage access"]
    end

    subgraph StorageAuth["Storage Authentication"]
        S3Auth["S3 Access<br/>AWS IAM / IRSA<br/>(via SA annotations)"]
        HFAuth["Hugging Face<br/>Bearer Token<br/>(via Secret ref in CR)"]
        PVCAuth["PVC Access<br/>Kubernetes Volume Mount<br/>(SA permissions)"]
    end

    subgraph Ports["Exposed Ports (UNAUTHENTICATED)"]
        Port8000["8000/TCP HTTP<br/>OpenAI-compatible API<br/>Auth: NONE"]
        Port8033["8033/TCP gRPC<br/>TGIS GenerationService<br/>Auth: NONE"]
    end

    %% Relationships
    UID -->|"runs as"| Ports
    SCC -->|"restricts"| UID

    PlatformAuthOptions -->|"protects"| Ports

    KServeSA -->|"used by"| ContainerSecurity
    KServeRole -->|"grants access to"| StorageAuth

    %% Styling
    style Note1 fill:#f8cecc,stroke:#cc0000,stroke-width:2px
    style Note2 fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Port8000 fill:#f8cecc,stroke:#cc0000,stroke-width:2px
    style Port8033 fill:#f8cecc,stroke:#cc0000,stroke-width:2px
    style UID fill:#d5e8d4,stroke:#82b366
    style SCC fill:#d5e8d4,stroke:#82b366
    style KRBAC fill:#dae8fc,stroke:#6c8ebf
    style GatewayAPI fill:#dae8fc,stroke:#6c8ebf
    style OAuthProxy fill:#dae8fc,stroke:#6c8ebf
    style KServeSA fill:#7ed321,stroke:#333
    style KServeRole fill:#7ed321,stroke:#333
    style S3Auth fill:#fff2cc,stroke:#d6b656
    style HFAuth fill:#fff2cc,stroke:#d6b656
    style PVCAuth fill:#fff2cc,stroke:#d6b656
