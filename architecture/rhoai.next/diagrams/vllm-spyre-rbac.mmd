graph TD
    subgraph Note["RBAC for vllm-spyre"]
        direction TB
        Info["This component defines NO RBAC resources.<br/>All RBAC is managed by KServe and the RHOAI platform operator."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (External to this component)"]
        direction TB

        subgraph KServeSA["KServe-Assigned Service Account"]
            SA["ServiceAccount<br/>(assigned by KServe to<br/>InferenceService pod)"]
        end

        subgraph AuthEnforcement["Authentication & Authorization Enforcement"]
            direction TB
            HTTPAuth["HTTP API (/v1/*)<br/>Auth: Platform-managed<br/>Enforcement: kube-rbac-proxy<br/>or Gateway API auth"]
            GRPCAuth["gRPC API (TGIS)<br/>Auth: Platform-managed<br/>Enforcement: KServe"]
        end
    end

    subgraph ContainerSecurity["Container Security Context"]
        direction TB
        UID["Runtime User: UID 2000<br/>(non-root)"]
        BaseImage["Base Image: registry.redhat.io/<br/>rhaiis/vllm-spyre-rhel9:3.2.2<br/>(Red Hat certified)"]
        Packages["Package Sources:<br/>Inherited from RHAIIS<br/>(Red Hat repos only)"]
    end

    SA -->|"runs pod as"| UID
    SA -->|"auth delegated to"| HTTPAuth
    SA -->|"auth delegated to"| GRPCAuth

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style HTTPAuth fill:#f5a623,stroke:#333
    style GRPCAuth fill:#f5a623,stroke:#333
    style UID fill:#7ed321,stroke:#333
    style BaseImage fill:#7ed321,stroke:#333
    style Packages fill:#7ed321,stroke:#333
