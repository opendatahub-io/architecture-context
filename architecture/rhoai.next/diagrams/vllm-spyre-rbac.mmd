graph TD
    subgraph "vllm-spyre RBAC Model"
        direction TB

        Note["NOTE: vllm-spyre is a container image,<br/>not an operator. It defines no RBAC resources.<br/>All access control is delegated to the platform."]

        subgraph "Platform-Level Access Control"
            direction TB

            KubeRBAC["kube-rbac-proxy Sidecar<br/>(RHOAI 3.x)"]
            IstioAuthZ["Istio AuthorizationPolicy<br/>(Service Mesh)"]

            subgraph "kube-rbac-proxy Auth Flow"
                BearerToken["Bearer Token<br/>(from client)"]
                SAR["SubjectAccessReview<br/>(K8s API Server)"]
                BearerToken -->|"validated via"| SAR
                SAR -->|"grants/denies"| Access["Access to<br/>8000/TCP, 8033/TCP"]
            end

            subgraph "Istio Auth Flow"
                ServiceIdentity["Service Identity<br/>(SPIFFE/mTLS)"]
                AuthPolicy["AuthorizationPolicy<br/>(namespace-scoped)"]
                ServiceIdentity -->|"evaluated by"| AuthPolicy
                AuthPolicy -->|"grants/denies"| MeshAccess["Access to<br/>8000/TCP, 8033/TCP"]
            end
        end

        subgraph "Container Security Context"
            UID["User: 2000 (non-root)"]
            NoPriv["No privileged capabilities"]
            ReadOnly["No secrets or credentials<br/>defined in image"]
        end
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KubeRBAC fill:#ffe6cc,stroke:#d79b00
    style IstioAuthZ fill:#e6d5f5,stroke:#9673a6
    style BearerToken fill:#d5e8d4,stroke:#82b366
    style SAR fill:#d5e8d4,stroke:#82b366
    style Access fill:#d5e8d4,stroke:#82b366
    style ServiceIdentity fill:#dae8fc,stroke:#6c8ebf
    style AuthPolicy fill:#dae8fc,stroke:#6c8ebf
    style MeshAccess fill:#dae8fc,stroke:#6c8ebf
    style UID fill:#f8cecc,stroke:#b85450
    style NoPriv fill:#f8cecc,stroke:#b85450
    style ReadOnly fill:#f8cecc,stroke:#b85450
