graph TD
    subgraph "vllm-spyre RBAC Model"
        direction TB

        Note["NOTE: vllm-spyre is a container image,<br/>not an operator. It defines NO RBAC<br/>resources of its own."]

        subgraph "Platform-Managed Auth (kube-rbac-proxy sidecar)"
            KubeRBACProxy["kube-rbac-proxy<br/>(injected by RHOAI Operator)"]
        end

        subgraph "Authentication Flow"
            ClientToken["Client Bearer Token<br/>(platform-issued)"]
            SAR["SubjectAccessReview<br/>(Kubernetes API)"]
        end

        subgraph "Inference Endpoints (No Self-Auth)"
            HTTPAPI["HTTP API<br/>8000/TCP<br/>No container-level auth"]
            gRPCAPI["gRPC API<br/>8033/TCP<br/>No container-level auth"]
        end

        subgraph "KServe-Managed RBAC"
            KServeSA["KServe ServiceAccount<br/>(manages pod lifecycle)"]
            SRRuntime["ServingRuntime CR<br/>(defines image + config)"]
            ISvc["InferenceService CR<br/>(user-facing)"]
        end

        subgraph "Model Storage Access"
            StorageCreds["Storage Credentials<br/>(injected by KServe)"]
            S3IAM["S3: AWS IAM / SA"]
            HFTOKEN["HF Hub: Bearer Token<br/>(HF_TOKEN env var)"]
            PVCMount["PVC: Kubernetes<br/>volume mount (no creds)"]
        end
    end

    %% Auth flow
    ClientToken -->|"presented to"| KubeRBACProxy
    KubeRBACProxy -->|"validates via"| SAR
    SAR -->|"authorized"| KubeRBACProxy
    KubeRBACProxy -->|"forwards to<br/>8000/TCP (localhost)"| HTTPAPI
    KubeRBACProxy -->|"forwards to<br/>8033/TCP (localhost)"| gRPCAPI

    %% KServe management
    KServeSA -->|"creates pods from"| SRRuntime
    ISvc -->|"references"| SRRuntime

    %% Storage credentials
    StorageCreds -->|"S3 path"| S3IAM
    StorageCreds -->|"HF path"| HFTOKEN
    StorageCreds -->|"PVC path"| PVCMount

    %% Styles
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KubeRBACProxy fill:#f8cecc,stroke:#b85450,color:#333
    style ClientToken fill:#f8cecc,stroke:#b85450,color:#333
    style SAR fill:#f8cecc,stroke:#b85450,color:#333
    style HTTPAPI fill:#d5e8d4,stroke:#82b366,color:#333
    style gRPCAPI fill:#d5e8d4,stroke:#82b366,color:#333
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style SRRuntime fill:#7ed321,stroke:#333,color:#fff
    style ISvc fill:#7ed321,stroke:#333,color:#fff
    style StorageCreds fill:#fff2cc,stroke:#d6b656,color:#333
    style S3IAM fill:#fff2cc,stroke:#d6b656,color:#333
    style HFTOKEN fill:#fff2cc,stroke:#d6b656,color:#333
    style PVCMount fill:#fff2cc,stroke:#d6b656,color:#333
