graph TD
    subgraph "vLLM Spyre — RBAC & Access Control"
        direction TB

        subgraph ContainerSecurity["Container Security Context"]
            UID["UID 2000<br/>(non-root)"]
            SCC["SCC: restricted-v2<br/>(no capabilities, non-root)"]
            BaseImage["Base Image: RHAIIS<br/>registry.redhat.io/rhaiis/<br/>vllm-spyre-rhel9:3.2.2<br/>(Red Hat signed)"]
        end

        subgraph AuthModel["Authentication Model"]
            direction TB
            NoAuth["Container: No Auth<br/>(unauthenticated endpoints)"]
            PlatformAuth["Platform Auth<br/>(enforced at ingress)"]

            subgraph AuthOptions["Platform Auth Options"]
                KRBAC["kube-rbac-proxy<br/>(sidecar)"]
                GatewayAPI["Gateway API +<br/>EnvoyFilter"]
                OAuthProxy["OAuth Proxy"]
            end

            NoAuth -.->|"security boundary<br/>at ingress"| PlatformAuth
            PlatformAuth --> KRBAC
            PlatformAuth --> GatewayAPI
            PlatformAuth --> OAuthProxy
        end

        subgraph DelegatedRBAC["Delegated RBAC (via KServe)"]
            KServeSA["KServe ServiceAccount<br/>(manages pods)"]
            InferSA["InferenceService SA<br/>(model access)"]
            KServeSA -->|"creates/manages"| VllmPod["vllm-spyre Pod"]
            InferSA -->|"provides credentials for"| ModelAccess["Model Storage<br/>Access (S3/PVC)"]
        end
    end

    Note["NOTE: This repository defines no RBAC<br/>resources. All access control is delegated<br/>to KServe and the RHOAI platform operator."]

    style UID fill:#4a90e2,color:#fff
    style SCC fill:#4a90e2,color:#fff
    style BaseImage fill:#6c5ce7,color:#fff
    style NoAuth fill:#e74c3c,color:#fff
    style PlatformAuth fill:#7ed321,color:#fff
    style KRBAC fill:#f5a623,color:#fff
    style GatewayAPI fill:#f5a623,color:#fff
    style OAuthProxy fill:#f5a623,color:#fff
    style KServeSA fill:#7ed321,color:#fff
    style InferSA fill:#7ed321,color:#fff
    style VllmPod fill:#4a90e2,color:#fff
    style ModelAccess fill:#999,color:#fff
    style Note fill:#fff3cd,stroke:#856404,color:#856404
