graph TD
    subgraph "vllm-spyre RBAC Model"
        direction TB
        Note["No RBAC resources defined<br/>in this repository"]
    end

    subgraph "Container Security"
        direction TB
        Container["vllm-spyre Container"]
        UID["Runtime User: UID 2000<br/>(non-root)"]
        BaseImage["Base Image: registry.redhat.io<br/>/rhaiis/vllm-spyre-rhel9<br/>(Red Hat certified)"]
        Container --> UID
        Container --> BaseImage
    end

    subgraph "Platform-Managed Security (Delegated)"
        direction TB
        KServeRBAC["KServe RBAC<br/>(manages pod RBAC)"]
        PlatformAuth["RHOAI Platform Auth<br/>(kube-rbac-proxy /<br/>Gateway API auth)"]
        PlatformSecrets["Platform-Managed Secrets<br/>(model storage creds,<br/>TLS certificates)"]
    end

    subgraph "Authentication & Authorization"
        direction TB
        HTTPEndpoints["/v1/* HTTP Endpoints"]
        GRPCEndpoints["TGIS gRPC Service"]
        EnforcementHTTP["Enforcement: KServe /<br/>RHOAI Gateway"]
        EnforcementGRPC["Enforcement: KServe"]

        HTTPEndpoints -->|"auth delegated"| EnforcementHTTP
        GRPCEndpoints -->|"auth delegated"| EnforcementGRPC
    end

    Container -.->|"security managed by"| KServeRBAC
    Container -.->|"auth handled by"| PlatformAuth
    Container -.->|"secrets from"| PlatformSecrets

    style Note fill:#fff3cd,stroke:#856404
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style UID fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style KServeRBAC fill:#7ed321,stroke:#333,color:#fff
    style PlatformAuth fill:#7ed321,stroke:#333,color:#fff
    style PlatformSecrets fill:#7ed321,stroke:#333,color:#fff
    style HTTPEndpoints fill:#f5a623,stroke:#333
    style GRPCEndpoints fill:#f5a623,stroke:#333
    style EnforcementHTTP fill:#e8e8e8,stroke:#333
    style EnforcementGRPC fill:#e8e8e8,stroke:#333
