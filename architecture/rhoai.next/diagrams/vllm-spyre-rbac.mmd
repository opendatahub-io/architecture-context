graph TD
    subgraph "Authentication & Authorization Model"
        direction TB

        subgraph "Note"
            Note["No RBAC resources defined in this repository.<br/>All authentication and authorization is delegated<br/>to the platform-injected kube-rbac-proxy sidecar."]
        end

        subgraph "Runtime Auth Flow"
            Client["Client Request<br/>(Bearer Token / JWT)"]
            Proxy["kube-rbac-proxy Sidecar<br/>(Platform-Injected)"]
            SAR["SubjectAccessReview<br/>(Kubernetes API)"]
        end

        subgraph "Protected Endpoints"
            HTTP["HTTP API<br/>8000/TCP<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/health"]
            GRPC["gRPC API<br/>8033/TCP<br/>TGIS GenerationService"]
        end

        subgraph "Platform-Managed RBAC"
            KServeSA["KServe ServiceAccount<br/>(manages pod lifecycle)"]
            KServeRoles["KServe ClusterRoles<br/>(ServingRuntime, InferenceService)"]
        end

        Client -->|"HTTPS/8443<br/>Bearer Token"| Proxy
        Proxy -->|"validates token via"| SAR
        SAR -->|"authorized"| Proxy
        Proxy -->|"HTTP/8000 (localhost)"| HTTP
        Proxy -->|"gRPC/8033 (localhost)"| GRPC

        KServeSA -->|"bound via"| KServeRoles
        KServeRoles -->|"manages"| HTTP
        KServeRoles -->|"manages"| GRPC
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999
    style Proxy fill:#f5a623,stroke:#333,color:#fff
    style SAR fill:#f5a623,stroke:#333,color:#fff
    style HTTP fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#7ed321,stroke:#333,color:#fff
    style KServeRoles fill:#7ed321,stroke:#333,color:#fff
