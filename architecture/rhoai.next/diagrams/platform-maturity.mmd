graph TB
    subgraph Metrics["Platform Metrics - RHOAI.next"]
        direction LR
        A["Total Components: 70"]
        B["Operator-based: 23"]
        C["Container Images: 416 Dockerfiles"]
        D["CRDs: 137 across 37 API groups"]
        E["Webhook Servers: 15+"]
        F["Inference Runtimes: 10+"]
    end

    subgraph Security["Security Posture"]
        direction LR
        S1["mTLS: MIXED<br/>STRICT for serving,<br/>PERMISSIVE for metrics,<br/>service-ca for operators"]
        S2["Non-root Containers:<br/>292 of 416 (70%)"]
        S3["Multi-stage Builds:<br/>307 of 416 (74%)"]
        S4["FIPS Compliance:<br/>Partial (Go services +<br/>UBI 9 OpenSSL)"]
        S5["Auth Mechanisms: 7<br/>kube-rbac-proxy,<br/>kube-auth-proxy,<br/>OAuth proxy, Bearer,<br/>Authorino, Istio mTLS,<br/>App mTLS"]
        S6["UBI 9 Base Images:<br/>145 of 416 (35%)"]
    end

    subgraph Deployment["Deployment Readiness"]
        direction LR
        D1["High Availability:<br/>Leader election for all<br/>operators, 2 replicas for<br/>Dashboard + Gateway"]
        D2["Disconnected Support:<br/>RELATED_IMAGE +<br/>OLM relatedImages +<br/>oc-mirror + PVC<br/>model loading"]
        D3["Multi-Architecture:<br/>amd64 (full),<br/>arm64/ppc64le/s390x<br/>(partial)"]
        D4["OCP Versions:<br/>v4.14, v4.15,<br/>v4.16, v4.17"]
        D5["Gateway Migration:<br/>10+ HTTPRoutes (new)<br/>32 legacy Routes<br/>remaining"]
    end

    subgraph APIs["API Maturity"]
        direction LR
        API1["CRD API Versions:<br/>v1beta1, v1alpha1,<br/>v1alpha2<br/>(no v1 stable yet)"]
        API2["Total CRDs: 137<br/>37 API groups"]
        API3["Gateway API:<br/>HTTPRoute +<br/>InferencePool +<br/>InferenceModel"]
    end

    subgraph InferenceStack["Inference Stack Tiers"]
        direction LR
        IS1["Tier 1: ModelMesh<br/>Multi-model, CPU<br/>etcd distributed LRU"]
        IS2["Tier 2: KServe IS<br/>Single-model GPU<br/>Knative serverless"]
        IS3["Tier 3: KServe LLMIS<br/>LLM-specific + llm-d<br/>Disaggregated P/D"]
        IS4["Runtimes: vLLM<br/>(CUDA/ROCm/Gaudi/<br/>Spyre/CPU), TGIS,<br/>MLServer, Caikit,<br/>OpenVINO"]
    end

    subgraph ArchRisks["Architectural Risks"]
        direction LR
        R1["Monolithic Operator:<br/>16+ subsystems in<br/>one binary, any change<br/>requires operator release"]
        R2["Auth Fragmentation:<br/>5 distinct patterns,<br/>request may traverse<br/>3 auth checkpoints"]
        R3["Scheduling Overlap:<br/>Kueue (job-level) +<br/>llm-d EPP (request) +<br/>WVA (replica)<br/>No shared framework"]
        R4["25% Root Containers:<br/>105 Dockerfiles lack<br/>USER directive,<br/>19 explicitly root"]
    end

