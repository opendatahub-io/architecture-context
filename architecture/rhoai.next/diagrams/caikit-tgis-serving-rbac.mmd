graph TD
    subgraph Note["RBAC Configuration"]
        direction TB
        Info["This component defines NO custom RBAC resources.<br/>RBAC is fully managed by KServe and the RHOAI platform operator.<br/>Security is enforced via Istio Service Mesh."]
    end

    subgraph IstioSecurity["Istio Security (in lieu of RBAC)"]
        direction TB

        subgraph PeerAuth["PeerAuthentication"]
            PA_Strict["PeerAuthentication<br/>Mode: STRICT<br/>Scope: Pod-level"]
            PA_Permissive["portLevelMtls:<br/>8086: PERMISSIVE<br/>(metrics port)"]
        end

        subgraph AuthMechanisms["Authentication & Authorization"]
            HTTP_Auth["HTTP Inference (8080/TCP)<br/>Auth: mTLS (sidecar)<br/>+ Istio AuthorizationPolicy<br/>PeerAuth: STRICT"]
            GRPC_Auth["gRPC Inference (8085/TCP)<br/>Auth: mTLS (sidecar)<br/>+ Istio AuthorizationPolicy<br/>PeerAuth: STRICT"]
            Metrics_Auth["Metrics (8086/TCP)<br/>Auth: None<br/>PeerAuth: PERMISSIVE<br/>(allows Prometheus scraping)"]
        end

        subgraph OptionalAuth["Optional Authorization"]
            Authorino["Authorino (if deployed)<br/>Token-based authorization<br/>for inference endpoints"]
        end
    end

    subgraph NetworkPolicy["NetworkPolicy"]
        NP["networkpolicy-uwm<br/>Allows ingress from:<br/>openshift-user-workload-monitoring<br/>To port: 8086/TCP"]
    end

    subgraph Secrets["Secrets Used"]
        WildcardCert["wildcard-certs<br/>Type: kubernetes.io/tls<br/>Purpose: TLS for Knative ingress<br/>Provisioned: Manual / cert-manager"]
        MinioSecret["minio-secret (demo)<br/>Type: Opaque<br/>Purpose: S3 credentials<br/>Provisioned: Manual"]
    end

    PA_Strict -->|"enforces on"| HTTP_Auth
    PA_Strict -->|"enforces on"| GRPC_Auth
    PA_Permissive -->|"allows plaintext on"| Metrics_Auth

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style PA_Strict fill:#d4edda,stroke:#155724,color:#155724
    style PA_Permissive fill:#fff3cd,stroke:#856404,color:#856404
    style HTTP_Auth fill:#d5e8d4,stroke:#82b366
    style GRPC_Auth fill:#d5e8d4,stroke:#82b366
    style Metrics_Auth fill:#ffe6cc,stroke:#d79b00
    style Authorino fill:#e1d5e7,stroke:#9673a6
    style NP fill:#dae8fc,stroke:#6c8ebf
    style WildcardCert fill:#f8d7da,stroke:#721c24
    style MinioSecret fill:#f8d7da,stroke:#721c24
