graph TD
    subgraph ComponentRBAC["Caikit-TGIS-Serving RBAC"]
        Note["This component defines NO RBAC resources.<br/>All RBAC is managed by KServe and the<br/>platform operator (rhods-operator)."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (External)"]
        direction TB

        subgraph KServeRBAC["KServe RBAC"]
            KServeSA["ServiceAccount<br/>kserve-controller-manager"]
            KServeCRB["ClusterRoleBinding<br/>kserve-manager-rolebinding"]
            KServeCR["ClusterRole<br/>kserve-manager-role"]

            KServeRes1["serving.kserve.io<br/>ServingRuntime"]
            KServeRes2["serving.kserve.io<br/>InferenceService"]
            KServeRes3["core<br/>Pods, Services"]
            KServeRes4["apps<br/>Deployments"]

            KServeSA -->|"bound via"| KServeCRB
            KServeCRB -->|"grants"| KServeCR
            KServeCR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| KServeRes1
            KServeCR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| KServeRes2
            KServeCR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| KServeRes3
            KServeCR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| KServeRes4
        end

        subgraph IstioRBAC["Istio/Service Mesh Security"]
            PeerAuth["PeerAuthentication<br/>STRICT (namespace-scoped)"]
            PeerAuthMetrics["PeerAuthentication<br/>PERMISSIVE (port 8086)"]
            NetPolicy["NetworkPolicy<br/>Allow monitoring namespace<br/>→ 8086/TCP"]
        end
    end

    subgraph ContainerSecurity["Container Security Context"]
        RunAsUser["RunAsUser: 1001<br/>(non-root)"]
        Group["Group: caikit"]
        BaseImage["Base: UBI9 Minimal<br/>(no privileged capabilities)"]
    end

    %% Styling
    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeCR fill:#f5a623,stroke:#333,color:#fff
    style KServeRes1 fill:#7ed321,stroke:#333
    style KServeRes2 fill:#7ed321,stroke:#333
    style KServeRes3 fill:#7ed321,stroke:#333
    style KServeRes4 fill:#7ed321,stroke:#333
    style PeerAuth fill:#d5e8d4,stroke:#82b366
    style PeerAuthMetrics fill:#d5e8d4,stroke:#82b366
    style NetPolicy fill:#d5e8d4,stroke:#82b366
    style RunAsUser fill:#dae8fc,stroke:#6c8ebf
    style Group fill:#dae8fc,stroke:#6c8ebf
    style BaseImage fill:#dae8fc,stroke:#6c8ebf
