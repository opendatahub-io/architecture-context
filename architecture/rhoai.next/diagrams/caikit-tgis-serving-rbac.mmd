graph TD
    subgraph "Container Security Context"
        Container["caikit-tgis-serving container<br/>UID: 1001 (caikit)<br/>Non-root user"]
    end

    subgraph "RBAC Note"
        Note["No RBAC resources defined<br/>in this repository.<br/>RBAC managed by KServe<br/>and platform operator."]
    end

    subgraph "Network-Level Access Control"
        direction TB

        subgraph PeerAuth["PeerAuthentication"]
            StrictMTLS["Default: STRICT mTLS<br/>(all ports)"]
            PermissiveMetrics["Port Override: 8086/TCP<br/>→ PERMISSIVE<br/>(allows plaintext Prometheus)"]
        end

        subgraph NetPol["NetworkPolicy"]
            MetricsIngress["Ingress Rule:<br/>Allow from namespace<br/>openshift-user-workload-monitoring<br/>→ All ports"]
        end
    end

    subgraph "Secrets Access"
        WildcardCerts["wildcard-certs<br/>(kubernetes.io/tls)<br/>Knative ingress TLS cert<br/>Manual rotation"]
        StorageCreds["Storage credentials<br/>(Opaque, per-model SA)<br/>S3/MinIO access keys<br/>Manual rotation"]
    end

    subgraph "Authentication Enforcement Points"
        direction TB
        InferHTTP["Inference HTTP :8080<br/>→ mTLS STRICT via Istio"]
        InferGRPC["Inference gRPC :8085<br/>→ mTLS STRICT via Istio"]
        Metrics["Metrics :8086<br/>→ PERMISSIVE mTLS<br/>(plaintext allowed)"]
        TGISLocal["TGIS :8033<br/>→ None (localhost)"]
    end

    Container -->|"runs as"| Note
    PeerAuth -->|"enforces"| InferHTTP
    PeerAuth -->|"enforces"| InferGRPC
    PermissiveMetrics -->|"allows"| Metrics
    NetPol -->|"constrains source"| Metrics
    TGISLocal -->|"no auth needed"| Container

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style Note fill:#f0f0f0,stroke:#999
    style StrictMTLS fill:#27ae60,stroke:#333,color:#fff
    style PermissiveMetrics fill:#f39c12,stroke:#333,color:#fff
    style MetricsIngress fill:#e74c3c,stroke:#333,color:#fff
    style WildcardCerts fill:#9b59b6,stroke:#333,color:#fff
    style StorageCreds fill:#9b59b6,stroke:#333,color:#fff
    style InferHTTP fill:#27ae60,stroke:#333,color:#fff
    style InferGRPC fill:#27ae60,stroke:#333,color:#fff
    style Metrics fill:#f39c12,stroke:#333,color:#fff
    style TGISLocal fill:#bdc3c7,stroke:#333
