graph TD
    subgraph Component["Caikit-TGIS-Serving — RBAC"]
        direction TB
        Note["This component defines NO RBAC resources.<br/>RBAC is managed by KServe and the platform operator."]
    end

    subgraph AuthNAuthZ["Authentication & Authorization (Istio-managed)"]
        direction TB

        subgraph HTTPAuth["HTTP Inference (8080/TCP)"]
            HTTPmTLS["mTLS (Istio sidecar)"]
            HTTPPolicy["PeerAuthentication: STRICT"]
        end

        subgraph GRPCAuth["gRPC Inference (8085/TCP)"]
            GRPCmTLS["mTLS (Istio sidecar)"]
            GRPCPolicy["PeerAuthentication: STRICT"]
        end

        subgraph MetricsAuth["Metrics (8086/TCP)"]
            MetricsMode["PERMISSIVE mTLS<br/>(portLevelMtls)"]
            MetricsNote["Allows Prometheus scraping<br/>without mTLS certs"]
        end

        subgraph TGISAuth["TGIS Backend (8033/TCP)"]
            TGISMode["No Auth<br/>(localhost loopback)"]
        end
    end

    subgraph Secrets["Secrets"]
        direction TB
        WildcardCert["wildcard-certs<br/>Type: kubernetes.io/tls<br/>Purpose: Knative ingress TLS<br/>Provisioned: Manual / cert-manager<br/>Auto-Rotate: No"]
        MinioSecret["minio-secret (demo)<br/>Type: Opaque<br/>Purpose: S3 credentials<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret (Tekton)<br/>Type: Opaque<br/>Purpose: Git auth for Konflux<br/>Provisioned: Pipelines as Code<br/>Auto-Rotate: No"]
    end

    subgraph PlatformRBAC["Platform RBAC (managed externally)"]
        KServeRBAC["KServe Operator<br/>Manages ServingRuntime/<br/>InferenceService RBAC"]
        IstioRBAC["Istio<br/>Manages PeerAuthentication/<br/>AuthorizationPolicy"]
    end

    KServeRBAC -->|"controls"| Component
    IstioRBAC -->|"enforces"| AuthNAuthZ

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style HTTPmTLS fill:#d5e8d4,stroke:#82b366
    style HTTPPolicy fill:#d5e8d4,stroke:#82b366
    style GRPCmTLS fill:#d5e8d4,stroke:#82b366
    style GRPCPolicy fill:#d5e8d4,stroke:#82b366
    style MetricsMode fill:#ffe6cc,stroke:#d79b00
    style MetricsNote fill:#ffe6cc,stroke:#d79b00
    style TGISMode fill:#f8cecc,stroke:#b85450
    style WildcardCert fill:#dae8fc,stroke:#6c8ebf
    style MinioSecret fill:#dae8fc,stroke:#6c8ebf
    style GitAuth fill:#dae8fc,stroke:#6c8ebf
    style KServeRBAC fill:#7ed321,stroke:#333,color:#fff
    style IstioRBAC fill:#7ed321,stroke:#333,color:#fff
