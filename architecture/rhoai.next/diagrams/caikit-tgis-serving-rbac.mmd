graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Prometheus["prometheus-k8s<br/>(openshift-user-workload-monitoring)"]
        SA_KServe["kserve-controller-manager<br/>(managed by KServe operator)"]
        SA_Pod["default / model-server SA<br/>(user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (demo)"]
        CRB_Prom["kserve-prometheus-k8s<br/>ClusterRoleBinding"]
    end

    subgraph ClusterRoles["ClusterRoles (demo)"]
        CR_Prom["kserve-prometheus-k8s<br/>ClusterRole"]
    end

    subgraph APIResources["API Resources"]
        Services["core<br/>Services"]
        Endpoints["core<br/>Endpoints"]
        Pods["core<br/>Pods"]
    end

    subgraph MeshSecurity["Istio Service Mesh Security"]
        PeerAuth["PeerAuthentication<br/>Mode: STRICT<br/>Port 8086: PERMISSIVE"]
        NetworkPol["NetworkPolicy<br/>Allow from:<br/>openshift-user-workload-monitoring"]
    end

    subgraph Secrets["Secrets"]
        WildcardCert["wildcard-certs<br/>Type: kubernetes.io/tls<br/>Purpose: Knative ingress TLS<br/>Rotation: Manual"]
        S3Creds["S3 storage credentials<br/>Type: Opaque<br/>Purpose: Model storage access<br/>Rotation: Manual"]
        GitAuth["git_auth_secret<br/>Type: Opaque<br/>Purpose: Konflux CI/CD<br/>Provisioner: Pipelines-as-Code"]
    end

    %% RBAC flow
    SA_Prometheus -->|"bound via"| CRB_Prom
    CRB_Prom -->|"grants"| CR_Prom
    CR_Prom -->|"get, list, watch"| Services
    CR_Prom -->|"get, list, watch"| Endpoints
    CR_Prom -->|"get, list, watch"| Pods

    %% Mesh security applied to pod
    PeerAuth -->|"enforces mTLS on"| SA_Pod
    NetworkPol -->|"allows metrics ingress to"| SA_Pod

    %% KServe manages pod lifecycle
    SA_KServe -->|"creates/manages pods"| SA_Pod

    %% Secrets used by components
    SA_Pod -->|"mounts"| S3Creds
    SA_Pod -.->|"referenced by"| WildcardCert

    %% Styling
    style SA_Prometheus fill:#4a90e2,stroke:#333,color:#fff
    style SA_KServe fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pod fill:#4a90e2,stroke:#333,color:#fff
    style CR_Prom fill:#f5a623,stroke:#333
    style CRB_Prom fill:#f5c869,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Endpoints fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PeerAuth fill:#e74c3c,stroke:#333,color:#fff
    style NetworkPol fill:#e74c3c,stroke:#333,color:#fff
    style WildcardCert fill:#9b59b6,stroke:#333,color:#fff
    style S3Creds fill:#9b59b6,stroke:#333,color:#fff
    style GitAuth fill:#9b59b6,stroke:#333,color:#fff
