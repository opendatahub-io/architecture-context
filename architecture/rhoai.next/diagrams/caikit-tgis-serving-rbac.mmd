graph TD
    subgraph ComponentRBAC["Caikit-TGIS-Serving RBAC"]
        Note["No RBAC resources defined by this component.<br/>RBAC is managed by KServe and the platform operator (RHOAI)."]
    end

    subgraph PlatformRBAC["Platform-Level RBAC (managed externally)"]
        direction TB

        subgraph KServeRBAC["KServe RBAC"]
            KServeSA["ServiceAccount:<br/>kserve-controller-manager"]
            KServeCRB["ClusterRoleBinding:<br/>kserve-manager-rolebinding"]
            KServeCR["ClusterRole:<br/>kserve-manager-role"]
            KServeSA -->|"bound via"| KServeCRB
            KServeCRB -->|"grants"| KServeCR
        end

        subgraph Resources["API Resources Managed"]
            SR["serving.kserve.io<br/>ServingRuntime"]
            ISVC["serving.kserve.io<br/>InferenceService"]
        end

        KServeCR -->|"get, list, watch,<br/>create, update, patch, delete"| SR
        KServeCR -->|"get, list, watch,<br/>create, update, patch, delete"| ISVC
    end

    subgraph AuthN["Authentication & Authorization"]
        direction TB

        subgraph InferenceAuth["Inference Endpoints"]
            HTTP8080["HTTP 8080/TCP<br/>mTLS STRICT<br/>+ Istio AuthorizationPolicy"]
            GRPC8085["gRPC 8085/TCP<br/>mTLS STRICT<br/>+ Istio AuthorizationPolicy"]
        end

        subgraph MetricsAuth["Metrics Endpoint"]
            Metrics8086["HTTP 8086/TCP<br/>mTLS PERMISSIVE<br/>(allows Prometheus w/o cert)"]
        end

        subgraph MeshPolicy["Service Mesh Policies"]
            PeerAuth["PeerAuthentication:<br/>STRICT (pod-level)<br/>portLevelMtls: 8086 PERMISSIVE"]
            NP["NetworkPolicy:<br/>networkpolicy-uwm<br/>Allow from openshift-user-<br/>workload-monitoring"]
        end

        PeerAuth -->|"enforces"| HTTP8080
        PeerAuth -->|"enforces"| GRPC8085
        PeerAuth -->|"exception"| Metrics8086
        NP -->|"allows"| Metrics8086
    end

    subgraph Secrets["Secrets"]
        WildcardCert["wildcard-certs<br/>kubernetes.io/tls<br/>TLS cert for Knative gateway<br/>Manual / cert-manager"]
        MinioSecret["minio-secret (demo)<br/>Opaque<br/>S3 credentials<br/>Manual provisioning"]
    end

    %% Styling
    classDef noRbac fill:#f9f9f9,stroke:#999,stroke-width:2px,stroke-dasharray: 5
    classDef kserveRbac fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef resource fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef policy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Note noRbac
    class KServeSA,KServeCRB,KServeCR kserveRbac
    class SR,ISVC resource
    class HTTP8080,GRPC8085,Metrics8086 auth
    class PeerAuth,NP policy
    class WildcardCert,MinioSecret secret
