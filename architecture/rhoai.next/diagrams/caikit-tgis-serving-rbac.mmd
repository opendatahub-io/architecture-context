graph TD
    subgraph ServiceAccounts["Service Accounts"]
        PromSA["prometheus-k8s<br/>(openshift-user-workload-monitoring)"]
        PodSA["Pod ServiceAccount<br/>(managed by KServe)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        PromCRB["kserve-prometheus-k8s<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRole Permissions"]
        PromCR["kserve-prometheus-k8s<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Services["core<br/>Services"]
        Endpoints["core<br/>Endpoints"]
        Pods["core<br/>Pods"]
    end

    subgraph ManagedByPlatform["Managed by Platform Operator"]
        direction TB
        KServeRBAC["KServe RBAC<br/>(ServingRuntime, InferenceService<br/>management permissions)"]
        OperatorRBAC["rhods-operator RBAC<br/>(Platform-level permissions<br/>for runtime registration)"]
        Note1["Note: This repository does not<br/>define its own RBAC.<br/>Pod RBAC is managed by<br/>KServe and rhods-operator."]
    end

    subgraph NetworkSecurity["Network & Mesh Security"]
        direction TB
        PeerAuth["PeerAuthentication<br/>Mode: STRICT<br/>Port 8086: PERMISSIVE"]
        NetPol["NetworkPolicy<br/>networkpolicy-uwm<br/>Allow from: openshift-user-workload-monitoring<br/>Target: port 8086"]
    end

    %% Prometheus RBAC flow
    PromSA -->|"bound via"| PromCRB
    PromCRB -->|"grants"| PromCR
    PromCR -->|"get, list, watch"| Services
    PromCR -->|"get, list, watch"| Endpoints
    PromCR -->|"get, list, watch"| Pods

    %% Pod SA (managed externally)
    PodSA -.->|"permissions managed by"| KServeRBAC
    PodSA -.->|"registered by"| OperatorRBAC

    %% Network security enforcement
    PeerAuth -.->|"enforces mTLS on"| PodSA
    NetPol -.->|"allows metrics scraping"| PromSA

    %% Styling
    style PromSA fill:#4a90e2,stroke:#333,color:#fff
    style PodSA fill:#4a90e2,stroke:#333,color:#fff
    style PromCR fill:#f5a623,stroke:#333,color:#fff
    style PromCRB fill:#e8c96a,stroke:#333
    style Services fill:#7ed321,stroke:#333,color:#fff
    style Endpoints fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style KServeRBAC fill:#bdc3c7,stroke:#333
    style OperatorRBAC fill:#bdc3c7,stroke:#333
    style Note1 fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style PeerAuth fill:#e74c3c,stroke:#333,color:#fff
    style NetPol fill:#e74c3c,stroke:#333,color:#fff
