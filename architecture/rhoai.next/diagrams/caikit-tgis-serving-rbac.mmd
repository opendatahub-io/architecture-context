graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["This component does NOT define its own RBAC resources.<br/>RBAC is managed by KServe and the platform operator.<br/><br/>The following shows the platform-level RBAC context<br/>that governs access to this component's resources."]
    end

    subgraph PlatformRBAC["Platform RBAC Context (managed by KServe)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            StorageInitSA["Storage Initializer SA<br/>(KServe-managed)"]
            PodSA["ServingRuntime Pod SA<br/>(user-namespace)"]
        end

        subgraph IstioAuth["Istio Authorization"]
            PeerAuth["PeerAuthentication<br/>Mode: STRICT<br/>(namespace-scoped)"]
            PeerAuthMetrics["PeerAuthentication<br/>Mode: PERMISSIVE<br/>(port 8086 exception)"]
            AuthPolicy["AuthorizationPolicy<br/>(KServe-managed)"]
        end

        subgraph NetworkPolicies["Network Policies"]
            NPMetrics["NetworkPolicy<br/>Allow ingress from<br/>openshift-user-workload-monitoring<br/>→ port 8086"]
        end

        subgraph Secrets["Secrets"]
            S3Secret["S3 Credentials (Opaque)<br/>Provisioned by: User/Admin<br/>Auto-rotate: No<br/>Used by: Storage Initializer"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        InferenceHTTP["Inference HTTP<br/>8080/TCP<br/>Auth: Bearer + mTLS"]
        InferenceGRPC["Inference gRPC<br/>8085/TCP<br/>Auth: Bearer + mTLS"]
        Metrics["Metrics<br/>8086/TCP<br/>Auth: None (PERMISSIVE)"]
    end

    %% Relationships
    PeerAuth -->|"enforces mTLS"| InferenceHTTP
    PeerAuth -->|"enforces mTLS"| InferenceGRPC
    PeerAuthMetrics -->|"allows plain HTTP"| Metrics
    AuthPolicy -->|"authorizes access"| InferenceHTTP
    AuthPolicy -->|"authorizes access"| InferenceGRPC
    NPMetrics -->|"allows Prometheus"| Metrics
    StorageInitSA -->|"uses"| S3Secret
    PodSA -->|"runs"| InferenceHTTP
    PodSA -->|"runs"| InferenceGRPC

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style PeerAuth fill:#f5a623,stroke:#333
    style PeerAuthMetrics fill:#f5a623,stroke:#333
    style AuthPolicy fill:#f5a623,stroke:#333
    style NPMetrics fill:#d5e8d4,stroke:#82b366
    style S3Secret fill:#f8cecc,stroke:#b85450
    style StorageInitSA fill:#4a90e2,stroke:#333,color:#fff
    style PodSA fill:#4a90e2,stroke:#333,color:#fff
    style InferenceHTTP fill:#d5e8d4,stroke:#82b366
    style InferenceGRPC fill:#d5e8d4,stroke:#82b366
    style Metrics fill:#fff2cc,stroke:#d6b656
