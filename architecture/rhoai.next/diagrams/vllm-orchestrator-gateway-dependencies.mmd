graph LR
    Gateway[vLLM Orchestrator<br/>Gateway]

    %% Internal Platform Dependencies (TrustyAI Stack)
    Gateway -->|"POST /api/v2/chat/completions-detection<br/>HTTP/HTTPS 8085/TCP<br/>Optional mTLS"| Orchestrator[FMS Guardrails<br/>Orchestrator]
    Orchestrator -->|invokes| Detectors[Content Detectors<br/>regex-detector, etc.]
    Orchestrator -->|routes to| vLLM[vLLM Model Server]

    %% Configuration Dependencies
    Gateway -.->|"reads at startup<br/>GATEWAY_CONFIG env"| ConfigFile[config.yaml<br/>Routes + Detectors]

    %% TLS / Certificate Dependencies
    Gateway -.->|"mTLS client identity<br/>/etc/tls/private/"| CertManager[cert-manager]
    Gateway -.->|"CA trust<br/>/etc/tls/ca/"| ServiceCA[service-ca-operator]

    %% Runtime Dependencies (Rust crates)
    subgraph RustDeps["Key Rust Dependencies"]
        axum[axum 0.7.9<br/>HTTP Framework]
        reqwest[reqwest 0.12.12<br/>HTTP Client]
        tokio[tokio 1.41.1<br/>Async Runtime]
        openssl_crate[openssl 0.10.73<br/>TLS/PKCS#12]
        nativetls[native-tls 0.2.12<br/>TLS Transport]
    end

    Gateway -.->|framework| axum
    Gateway -.->|upstream calls| reqwest
    Gateway -.->|runtime| tokio
    Gateway -.->|cert handling| openssl_crate
    Gateway -.->|transport| nativetls

    %% Consumer Dependencies
    APIClients[API Clients] -->|"POST /{route}/v1/chat/completions<br/>HTTP 8090/TCP"| Gateway

    %% Deploying Platform
    Operator[TrustyAI Operator<br/>or RHOAI Platform] -.->|"deploys, creates<br/>K8s Service, mounts<br/>secrets & config"| Gateway

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style ConfigFile fill:#f5a623,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style APIClients fill:#e8e8e8,stroke:#333
    style Operator fill:#999,stroke:#333,color:#fff
    style axum fill:#ddd,stroke:#333
    style reqwest fill:#ddd,stroke:#333
    style tokio fill:#ddd,stroke:#333
    style openssl_crate fill:#ddd,stroke:#333
    style nativetls fill:#ddd,stroke:#333
