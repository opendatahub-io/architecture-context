graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust Service)"]

    %% Internal Platform Dependencies (Direct)
    Gateway -->|"REST API POST<br/>8085/TCP<br/>HTTP/HTTPS<br/>Conditional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (Indirect via Orchestrator)
    Orchestrator -->|"inference"| vLLM["vLLM Inference<br/>Server"]
    Orchestrator -->|"detection"| Detectors["Content Detectors<br/>(e.g., regex detector)"]

    %% Infrastructure Dependencies
    Gateway -.->|"TLS client cert<br/>volume mount"| CertManager["cert-manager"]
    Gateway -.->|"CA cert<br/>volume mount"| ServiceCA["OpenShift<br/>Service CA"]
    Gateway -.->|"TLS termination<br/>+ AuthN"| PlatformIngress["Platform Ingress<br/>(Gateway API /<br/>kube-rbac-proxy)"]

    %% Rust Crate Dependencies (key ones)
    subgraph "Key Rust Dependencies"
        direction TB
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        OpenSSL["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        NativeTLS["native-tls 0.2.12<br/>(TLS backend)"]
        SerdeYml["serde_yml 0.0.12<br/>(YAML config)"]
    end

    Gateway -.->|"serves HTTP"| Axum
    Gateway -.->|"async runtime"| Tokio
    Gateway -.->|"outbound HTTP"| Reqwest
    Gateway -.->|"cert handling"| OpenSSL
    Gateway -.->|"TLS transport"| NativeTLS
    Gateway -.->|"config parsing"| SerdeYml

    %% Styling
    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style PlatformIngress fill:#999,stroke:#333,color:#fff
    style Axum fill:#f5a623,stroke:#333
    style Tokio fill:#f5a623,stroke:#333
    style Reqwest fill:#f5a623,stroke:#333
    style OpenSSL fill:#f5a623,stroke:#333
    style NativeTLS fill:#f5a623,stroke:#333
    style SerdeYml fill:#f5a623,stroke:#333
