graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust/axum)"]

    %% Internal Platform Dependencies (Direct)
    Gateway -->|"REST API POST<br/>8085/TCP HTTP/HTTPS<br/>optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Indirect Dependencies (via Orchestrator)
    Orchestrator -.->|"content detection"| Detectors["Content Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -.->|"LLM inference"| vLLM["vLLM Model Server"]

    %% Platform Infrastructure Dependencies
    Gateway -->|"TLS cert/key<br/>volume mount"| CertManager["cert-manager"]
    Gateway -->|"CA cert<br/>volume mount"| ServiceCA["service-ca-operator"]
    Gateway -->|"config file<br/>volume mount"| ConfigMap["ConfigMap/Secret<br/>(YAML config)"]

    %% Deployment Dependencies
    TrustyAIOp["TrustyAI Operator"] -->|"deploys &<br/>manages lifecycle"| Gateway

    %% Consumer Dependencies
    APIClients["API Clients<br/>(consumers)"] -->|"POST /{route}/v1/<br/>chat/completions<br/>8090/TCP HTTP"| Gateway

    %% Rust Crate Dependencies (key ones)
    subgraph "Key Rust Dependencies"
        axum["axum 0.7.9<br/>HTTP framework"]
        reqwest["reqwest 0.12.12<br/>HTTP client"]
        openssl["openssl 0.10.73<br/>TLS/PKCS#12"]
        tokio["tokio 1.41.1<br/>Async runtime"]
    end

    Gateway -.->|"built with"| axum
    Gateway -.->|"built with"| reqwest
    Gateway -.->|"built with"| openssl
    Gateway -.->|"built with"| tokio

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#f5a623,stroke:#333,color:#fff
    style TrustyAIOp fill:#50e3c2,stroke:#333
    style APIClients fill:#e8e8e8,stroke:#333
    style axum fill:#fff2cc,stroke:#d6b656
    style reqwest fill:#fff2cc,stroke:#d6b656
    style openssl fill:#fff2cc,stroke:#d6b656
    style tokio fill:#fff2cc,stroke:#d6b656
