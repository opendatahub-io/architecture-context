graph LR
    GW["vllm-orchestrator-gateway<br/>(Rust/axum)"]

    %% Internal Platform Dependencies (direct)
    GW -->|"REST API POST<br/>HTTP(S)/8085<br/>optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Indirect Dependencies (via orchestrator)
    Orchestrator -.->|"content detection<br/>(indirect)"| Detectors["Content Detectors<br/>(e.g., regex-detector)"]
    Orchestrator -.->|"LLM inference<br/>(indirect)"| vLLM["vLLM Model Server"]

    %% Platform Dependencies
    CertManager["cert-manager"] -.->|"TLS cert/key<br/>provisioning"| GW
    ServiceCA["service-ca-operator"] -.->|"CA certificate<br/>provisioning"| GW
    PlatformOp["TrustyAI / RHOAI<br/>Operator"] -.->|"deploys, configures<br/>K8s Service, secrets"| GW

    %% Configuration Dependencies
    YAMLConfig["YAML Config File<br/>/app/config/config.yaml"] -.->|"routes, detectors,<br/>orchestrator config"| GW

    %% Rust Library Dependencies
    subgraph RustDeps["Key Rust Dependencies"]
        axum["axum 0.7.9<br/>(HTTP framework)"]
        reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        tokio["tokio 1.41.1<br/>(async runtime)"]
        openssl["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        nativeTLS["native-tls 0.2.12<br/>(TLS transport)"]
        serde["serde + serde_json<br/>(serialization)"]
    end

    GW -.->|"built with"| RustDeps

    %% Integration Points (consumers)
    APIClients["API Clients<br/>(consumers)"] -->|"POST<br/>HTTP/8090"| GW

    style GW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style CertManager fill:#f5a623,stroke:#333,color:#fff
    style ServiceCA fill:#f5a623,stroke:#333,color:#fff
    style PlatformOp fill:#f5a623,stroke:#333,color:#fff
    style YAMLConfig fill:#fff2cc,stroke:#d6b656
    style APIClients fill:#e8e8e8,stroke:#333
    style axum fill:#dae8fc,stroke:#6c8ebf
    style reqwest fill:#dae8fc,stroke:#6c8ebf
    style tokio fill:#dae8fc,stroke:#6c8ebf
    style openssl fill:#dae8fc,stroke:#6c8ebf
    style nativeTLS fill:#dae8fc,stroke:#6c8ebf
    style serde fill:#dae8fc,stroke:#6c8ebf
