graph LR
    Gateway["vLLM Orchestrator Gateway<br/>(Rust / axum)"]

    %% Internal Platform Dependencies (direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>HTTP/HTTPS 8085/TCP"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (indirect via Orchestrator)
    Orchestrator -.->|"invokes detectors"| Detectors["Guardrails Detectors<br/>(regex, PII, etc.)"]
    Orchestrator -.->|"dispatches generation"| LLMServer["vLLM / LLM<br/>Inference Server"]

    %% Configuration Dependencies
    Gateway -->|"reads at startup"| ConfigFile["config.yaml<br/>(GATEWAY_CONFIG env)"]
    Gateway -->|"reads TLS certs"| TLSSecrets["K8s Secrets<br/>(volume mounts)"]

    %% TLS/Certificate Dependencies
    TLSSecrets -.->|"provisioned by"| CertManager["cert-manager /<br/>service-ca-operator"]

    %% Rust Crate Dependencies (key runtime)
    subgraph RustCrates["Key Rust Dependencies"]
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        OpenSSL["openssl 0.10.73<br/>(TLS/mTLS)"]
        NativeTLS["native-tls 0.2.12<br/>(TLS backend)"]
        Serde["serde + serde_json<br/>(JSON serialization)"]
        SerdeYml["serde_yml 0.0.12<br/>(YAML config)"]
        Futures["futures 0.3.30<br/>(SSE streaming)"]
    end

    Gateway -->|"built with"| Axum
    Gateway -->|"built with"| Reqwest
    Gateway -->|"built with"| Tokio
    Gateway -->|"built with"| OpenSSL
    Gateway -->|"built with"| NativeTLS
    Gateway -->|"built with"| Serde
    Gateway -->|"built with"| SerdeYml
    Gateway -->|"built with"| Futures

    %% Build Dependencies
    Gateway -.->|"base image"| UBI["UBI 9 Minimal<br/>+ compat-openssl11"]

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style LLMServer fill:#7ed321,stroke:#333,color:#fff
    style ConfigFile fill:#d5e8d4,stroke:#82b366
    style TLSSecrets fill:#fff2cc,stroke:#d6b656
    style CertManager fill:#999,stroke:#333,color:#fff
    style UBI fill:#999,stroke:#333,color:#fff
    style Axum fill:#dae8fc,stroke:#6c8ebf
    style Reqwest fill:#dae8fc,stroke:#6c8ebf
    style Tokio fill:#dae8fc,stroke:#6c8ebf
    style OpenSSL fill:#dae8fc,stroke:#6c8ebf
    style NativeTLS fill:#dae8fc,stroke:#6c8ebf
    style Serde fill:#dae8fc,stroke:#6c8ebf
    style SerdeYml fill:#dae8fc,stroke:#6c8ebf
    style Futures fill:#dae8fc,stroke:#6c8ebf
