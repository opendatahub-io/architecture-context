graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust / axum)"]

    %% Internal Platform Dependencies (Direct)
    Gateway -->|"REST POST<br/>/api/v2/chat/completions-detection<br/>HTTP/HTTPS 8085/TCP<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (Indirect via Orchestrator)
    Orchestrator -->|"detector evaluation"| Detectors["Guardrails Detectors<br/>(e.g., regex-language)"]
    Orchestrator -->|"LLM inference"| vLLM["vLLM / Model Server"]

    %% Platform Dependencies
    Gateway -.->|"TLS client cert<br/>/etc/tls/private/"| CertManager["cert-manager<br/>(inferred)"]
    Gateway -.->|"CA cert<br/>/etc/tls/ca/service-ca.crt"| ServiceCA["OpenShift<br/>service-ca<br/>(inferred)"]

    %% Key Rust Dependencies
    subgraph RustDeps["Key Rust Dependencies"]
        direction TB
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        OpenSSL["openssl 0.10.73<br/>(TLS certs)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        Futures["futures 0.3.30<br/>(SSE streaming)"]
    end

    Gateway -->|"runtime deps"| RustDeps

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style Axum fill:#f5a623,stroke:#333,color:#fff
    style Reqwest fill:#f5a623,stroke:#333,color:#fff
    style OpenSSL fill:#f5a623,stroke:#333,color:#fff
    style Tokio fill:#f5a623,stroke:#333,color:#fff
    style Futures fill:#f5a623,stroke:#333,color:#fff
