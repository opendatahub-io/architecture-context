graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust/axum)"]

    %% Internal Platform Dependencies
    Gateway -->|"REST POST<br/>/api/v2/chat/completions-detection<br/>8085/TCP HTTP/HTTPS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    Gateway -.->|"indirect<br/>(via orchestrator)"| Detectors["Guardrails Detectors<br/>(e.g., regex-language)"]
    Gateway -.->|"indirect<br/>(via orchestrator)"| vLLM["vLLM /<br/>Model Server"]

    %% Certificate Dependencies
    Gateway -->|"CA cert mount"| ServiceCA["OpenShift service-ca<br/>/etc/tls/ca/service-ca.crt"]
    Gateway -->|"client cert mount"| CertManager["cert-manager<br/>/etc/tls/private/"]

    %% Key Rust Dependencies
    subgraph "Rust Crate Dependencies"
        Axum["axum 0.7.9<br/>HTTP framework"]
        Reqwest["reqwest 0.12.12<br/>HTTP client"]
        Tokio["tokio 1.41.1<br/>Async runtime"]
        OpenSSL["openssl 0.10.73<br/>TLS certs"]
        SerdeYml["serde_yml 0.0.12<br/>YAML config"]
        Futures["futures 0.3.30<br/>SSE streaming"]
    end

    Gateway --> Axum
    Gateway --> Reqwest
    Gateway --> Tokio
    Gateway --> OpenSSL
    Gateway --> SerdeYml
    Gateway --> Futures

    %% Upstream consumers (who calls us)
    Clients["Clients<br/>(OpenAI-compatible)"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP"| Gateway

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#f5a623,stroke:#333,color:#fff
    style CertManager fill:#f5a623,stroke:#333,color:#fff
    style Clients fill:#f9f9f9,stroke:#999
    style Axum fill:#e8e8e8,stroke:#333
    style Reqwest fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style OpenSSL fill:#e8e8e8,stroke:#333
    style SerdeYml fill:#e8e8e8,stroke:#333
    style Futures fill:#e8e8e8,stroke:#333
