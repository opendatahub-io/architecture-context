graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust HTTP Service)"]

    %% Internal Platform Dependencies (direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>HTTP or HTTPS / 8085"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (indirect via orchestrator)
    Orchestrator -.->|"indirect"| Detectors["Detector Services<br/>(e.g., regex-detector)"]
    Orchestrator -.->|"indirect"| vLLM["vLLM Model Server<br/>(e.g., Qwen2.5)"]

    %% Platform Infrastructure
    Gateway -.->|"volume mount<br/>TLS certs"| CertManager["cert-manager /<br/>service-serving-signer"]
    Gateway -.->|"volume mount<br/>CA cert"| ServiceCA["service-ca-operator"]
    Gateway -.->|"volume mount<br/>config.yaml"| ConfigMap["ConfigMap<br/>(gateway config)"]

    %% External Rust Dependencies (key libraries)
    subgraph RustDeps["Key Rust Dependencies"]
        axum["axum 0.7.9<br/>(HTTP framework)"]
        reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        tokio["tokio 1.41.1<br/>(async runtime)"]
        openssl["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        nativetls["native-tls 0.2.12<br/>(TLS backend)"]
        serde["serde 1.0.215<br/>(serialization)"]
    end

    Gateway -->|"framework"| axum
    Gateway -->|"proxy client"| reqwest
    Gateway -->|"async runtime"| tokio
    Gateway -->|"mTLS identity"| openssl
    reqwest -->|"TLS backend"| nativetls
    Gateway -->|"JSON payloads"| serde

    %% Exposure (who calls the gateway)
    Platform["Platform Mechanisms<br/>(HTTPRoute / Route /<br/>InferenceService)"] -->|"exposes externally"| Gateway

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#f5a623,stroke:#333
    style Platform fill:#e8e8e8,stroke:#333
    style axum fill:#fff2cc,stroke:#d6b656
    style reqwest fill:#fff2cc,stroke:#d6b656
    style tokio fill:#fff2cc,stroke:#d6b656
    style openssl fill:#fff2cc,stroke:#d6b656
    style nativetls fill:#fff2cc,stroke:#d6b656
    style serde fill:#fff2cc,stroke:#d6b656
