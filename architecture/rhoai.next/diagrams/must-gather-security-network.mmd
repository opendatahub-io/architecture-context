graph TB
    subgraph UserZone["USER WORKSTATION (Trusted)"]
        User["User / SRE<br/>Auth: kubeconfig"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph MustGatherPod["MUST-GATHER POD (Ephemeral Diagnostic)"]
        direction TB

        subgraph PodMeta["Pod Identity"]
            SA_OCP["OpenShift SA<br/>cluster-admin<br/>(oc adm must-gather)"]
            SA_XKS["xKS SA: must-gather-sa<br/>ClusterRole: must-gather-reader<br/>Verbs: get, list, watch"]
        end

        subgraph Tools["Bundled CLI Tools"]
            OC_CLI["oc CLI<br/>(from base image)"]
            Kubectl_CLI["kubectl v1.33.3<br/>(from ose-cli-rhel9)"]
            Helm_CLI["helm v4.1.4<br/>(Git LFS binary)"]
        end

        subgraph Scripts["Collection Scripts"]
            GatherSH["gather.sh<br/>Platform detection +<br/>dispatch orchestrator"]
            OCPScripts["OpenShift: 13 scripts<br/>parallel execution<br/>oc adm inspect"]
            XKSScripts["xKS: gather_llmd.sh<br/>kubectl_inspect +<br/>auto_discover_resources"]
        end
    end

    subgraph TargetResources["TARGET RESOURCES (Read-Only Access)"]
        direction TB

        subgraph PlatformCRDs["Platform CRDs"]
            DSC["DSCInitialization<br/>DataScienceCluster"]
        end

        subgraph ComponentCRDs["Component CRDs (20+ types)"]
            Serving["InferenceService<br/>ServingRuntime<br/>LLMInferenceService"]
            ML["RayCluster, PyTorchJob<br/>ModelRegistry, MLflow"]
            AI["TrustyAIService<br/>FeatureStore<br/>LlamaStackDistribution"]
        end

        subgraph NetworkCRDs["Networking CRDs"]
            GatewayAPI["Gateway, HTTPRoute<br/>GRPCRoute, GatewayClass"]
            IstioCRDs["VirtualService<br/>AuthorizationPolicy<br/>PeerAuthentication"]
        end

        subgraph CoreK8s["Core Kubernetes"]
            Pods["Pods, Deployments<br/>Services, Events<br/>ConfigMaps"]
            Logs["Pod Logs<br/>(current + previous)"]
            Nodes["Nodes, Namespaces<br/>API Resources"]
        end

        subgraph HelmData["Helm Data"]
            HelmSecrets["Helm Release Secrets<br/>(helm.sh/release.v1)<br/>Values + Manifests"]
        end
    end

    subgraph OutputZone["COLLECTION OUTPUT (Pod-Local)"]
        Output["/must-gather/ (OpenShift)<br/>/tmp/must-gather/ (xKS)<br/>Resource YAMLs, logs,<br/>Helm values, cluster metadata"]
    end

    %% Flows
    User -->|"oc adm must-gather<br/>or kubectl apply job.yaml"| K8sAPI
    K8sAPI -->|"Creates pod"| MustGatherPod

    GatherSH -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>GET, LIST only"| K8sAPI

    K8sAPI -.->|read| PlatformCRDs
    K8sAPI -.->|read| ComponentCRDs
    K8sAPI -.->|read| NetworkCRDs
    K8sAPI -.->|read| CoreK8s
    K8sAPI -.->|read| HelmData

    GatherSH -->|"writes"| Output
    User -->|"oc adm (auto) /<br/>kubectl cp (manual)"| Output

    %% Styling
    classDef userzone fill:#e8f4fd,stroke:#2196f3,stroke-width:2px
    classDef controlplane fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    classDef pod fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef target fill:#fce4ec,stroke:#e91e63,stroke-width:1px
    classDef output fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px

    class User userzone
    class K8sAPI controlplane
    class SA_OCP,SA_XKS,OC_CLI,Kubectl_CLI,Helm_CLI,GatherSH,OCPScripts,XKSScripts pod
    class DSC,Serving,ML,AI,GatewayAPI,IstioCRDs,Pods,Logs,Nodes,HelmSecrets target
    class Output output
