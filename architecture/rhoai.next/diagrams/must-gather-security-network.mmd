graph TB
    subgraph External["USER WORKSTATION (Trusted)"]
        User["User / SRE<br/>kubeconfig credentials"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: ServiceAccount Token / kubeconfig"]
    end

    subgraph MustGatherPod["MUST-GATHER POD (Ephemeral)"]
        direction TB

        subgraph CoreFramework["Core Framework"]
            GatherSH["gather.sh<br/>SA: must-gather / must-gather-sa"]
            CommonSH["common.sh"]
            XksSH["xks_util.sh"]
        end

        subgraph ComponentCollectors["RHOAI Component Collectors (Parallel)"]
            direction LR
            Serving["gather_serving.sh"]
            DSP["gather_dsp.sh"]
            Notebooks["gather_notebooks.sh"]
            Dashboard["gather_dashboard.sh"]
            KubeRay["gather_kuberay.sh"]
            Kueue["gather_kueue.sh"]
            KFTO["gather_kfto.sh"]
            MR["gather_mr.sh"]
            TrustyAI["gather_trustyai.sh"]
            Feast["gather_feastoperator.sh"]
            LLS["gather_lls.sh"]
            MLflow["gather_mlflow.sh"]
            Spark["gather_sparkoperator.sh"]
            MaaS["gather_maas.sh"]
        end

        subgraph LLMDCollectors["LLM-D Collectors"]
            direction LR
            LLMD["gather_llmd.sh"]
            WVA["gather_wva.sh<br/>(opt-in: ENABLE_WVA)"]
            O11y["gather_o11y.sh"]
            ClusterInfo["gather_cluster.sh"]
        end

        subgraph DepCollectors["LLM-D Dependency Collectors"]
            direction LR
            CertMgr["cert-manager.sh"]
            Sail["sail.sh<br/>(Istio/Sail)"]
            LWS["lws.sh"]
        end
    end

    subgraph Output["OUTPUT"]
        FS["/must-gather/<br/>YAML manifests, logs,<br/>Helm values, summary"]
    end

    %% Flows
    User -->|"oc adm must-gather /<br/>kubectl create Job<br/>HTTPS/443 TLS 1.2+<br/>kubeconfig auth"| APIServer

    APIServer -->|"Creates Pod"| GatherSH

    GatherSH -->|"dispatches"| ComponentCollectors
    GatherSH -->|"dispatches"| LLMDCollectors
    LLMD -->|"triggers"| DepCollectors

    ComponentCollectors -->|"GET, LIST, WATCH<br/>HTTPS/443 TLS 1.2+<br/>ServiceAccount Token<br/>(read-only)"| APIServer
    LLMDCollectors -->|"GET, LIST, WATCH<br/>HTTPS/443 TLS 1.2+<br/>ServiceAccount Token<br/>(read-only)"| APIServer
    DepCollectors -->|"GET, LIST, WATCH<br/>HTTPS/443 TLS 1.2+<br/>ServiceAccount Token<br/>(read-only)"| APIServer

    GatherSH -->|"writes collected data<br/>(no encryption at rest)"| FS
    FS -->|"oc rsync / kubectl cp<br/>to user workstation"| User

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef output fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef collector fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef llmd fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef dep fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class User external
    class APIServer controlplane
    class GatherSH,CommonSH,XksSH pod
    class Serving,DSP,Notebooks,Dashboard,KubeRay,Kueue,KFTO,MR,TrustyAI,Feast,LLS,MLflow,Spark,MaaS collector
    class LLMD,WVA,O11y,ClusterInfo llmd
    class CertMgr,Sail,LWS dep
    class FS output
