graph TB
    subgraph External["EXTERNAL (User Workstation)"]
        User["User / SRE<br/>oc CLI or kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        API["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph MustGatherPod["MUST-GATHER POD (Ephemeral Batch Job)"]
        direction TB

        subgraph EntryPoint["Entry Point"]
            Gather["gather.sh<br/>Distro Detection<br/>Namespace Config"]
        end

        subgraph Parallel["13 Parallel Component Gatherers"]
            Serving["gather_serving.sh"]
            DSP["gather_dsp.sh"]
            Notebooks["gather_notebooks.sh"]
            Dashboard["gather_dashboard.sh"]
            KubeRay["gather_kuberay.sh"]
            Kueue["gather_kueue.sh"]
            KFTO["gather_kfto.sh"]
            MR["gather_mr.sh"]
            TrustyAI["gather_trustyai.sh"]
            Feast["gather_feast.sh"]
            LLS["gather_lls.sh"]
            MLflow["gather_mlflow.sh"]
            Spark["gather_spark.sh"]
        end

        subgraph LLMD["LLM-D Sub-Gatherers"]
            LLMDMain["gather_llmd.sh"]
            CertMgr["cert-manager.sh"]
            LWSScript["lws.sh"]
            SailScript["sail.sh"]
        end
    end

    subgraph TargetNamespaces["TARGET NAMESPACES (Read-Only)"]
        direction LR
        NS_Operator["redhat-ods-operator"]
        NS_Apps["redhat-ods-applications"]
        NS_Notebooks["rhods-notebooks"]
        NS_Monitoring["redhat-ods-monitoring"]
        NS_MR["rhoai-model-registries"]
        NS_Ingress["openshift-ingress"]
        NS_Istio["istio-system"]
        NS_CertMgr["cert-manager"]
        NS_Dynamic["Dynamic Namespaces<br/>(discovered via CRD listing)"]
    end

    subgraph DataOutput["DATA OUTPUT"]
        FS["Local Filesystem<br/>$DST_DIR<br/>YAML + Logs + Events"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig auth"| API
    API -->|"Pod Scheduling<br/>SA: cluster-admin (OCP)<br/>SA: must-gather-sa (xKS)"| Gather

    Gather -->|"fork"| Parallel
    Serving --> LLMDMain
    LLMDMain -->|"parallel deps"| CertMgr
    LLMDMain -->|"parallel deps"| LWSScript
    LLMDMain -->|"parallel deps"| SailScript

    Parallel -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (read-only)<br/>oc adm inspect / kubectl get"| API
    LLMD -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (read-only)"| API

    API -->|"GET resources"| TargetNamespaces
    Parallel -->|"Write YAML + logs"| FS
    LLMD -->|"Write YAML + logs"| FS

    FS -->|"tar stream (OCP)<br/>kubectl cp (xKS)<br/>TLS 1.2+"| User

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef target fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef output fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class API controlplane
    class Gather,Serving,DSP,Notebooks,Dashboard,KubeRay,Kueue,KFTO,MR,TrustyAI,Feast,LLS,MLflow,Spark,LLMDMain,CertMgr,LWSScript,SailScript pod
    class NS_Operator,NS_Apps,NS_Notebooks,NS_Monitoring,NS_MR,NS_Ingress,NS_Istio,NS_CertMgr,NS_Dynamic target
    class FS output
