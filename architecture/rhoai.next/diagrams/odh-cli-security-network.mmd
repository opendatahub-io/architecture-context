graph TB
    subgraph ClientSide["CLIENT SIDE (User Workstation / CI / Container)"]
        CLI["odh-cli<br/>(rhai-cli / kubectl-odh)<br/>FIPS: CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>Base: ose-cli-rhel9 (UBI9)"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Authenticated via kubeconfig)"]
        direction TB

        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer / x509 / OIDC<br/>AuthZ: User's RBAC bindings"]

        subgraph ReadResources["Read-Only Resources (client.Reader)"]
            direction LR
            PlatformCRDs["Platform CRDs<br/>DSC, DSCI,<br/>Component CRs,<br/>ClusterVersion"]
            OLMResources["OLM Resources<br/>Subscriptions,<br/>CSVs"]
            WorkloadCRDs["Workload CRDs<br/>Notebooks, InferenceServices,<br/>RayClusters, PyTorchJobs,<br/>AppWrappers, Kuadrant"]
            CoreResources["Core Resources<br/>Pods, Nodes, Events,<br/>Deployments, ConfigMaps"]
        end

        subgraph WriteResources["Write Operations (restricted commands)"]
            direction LR
            DepsWrite["deps install<br/>CREATE Namespace,<br/>OperatorGroup,<br/>Subscription"]
            ComponentWrite["components enable/disable<br/>PATCH DSC"]
            MigrateWrite["migrate<br/>PATCH DSC, ConfigMap<br/>CREATE Subscription"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
    end

    %% Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>kubeconfig<br/>(Bearer / x509 / OIDC)"| APIServer
    CLI -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)<br/>--refresh flag only"| GitHub

    APIServer --> ReadResources
    APIServer --> WriteResources

    %% Security annotations
    DepsWrite -.-|"CWE-829: catalog allow-list<br/>CWE-269: reject system NS"| SecurityNote["Security<br/>Mitigations"]

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef cluster fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef apiserver fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef readonly fill:#c8e6c9,stroke:#388e3c,stroke-width:1px
    classDef writeop fill:#ffcdd2,stroke:#c62828,stroke-width:1px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef security fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px,stroke-dasharray: 5 5

    class CLI client
    class APIServer apiserver
    class PlatformCRDs,OLMResources,WorkloadCRDs,CoreResources readonly
    class DepsWrite,ComponentWrite,MigrateWrite writeop
    class GitHub external
    class SecurityNote security
