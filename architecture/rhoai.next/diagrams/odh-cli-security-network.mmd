graph TB
    subgraph ClientSide["CLIENT SIDE (Admin Workstation / CI Runner)"]
        CLI["kubectl-odh CLI<br/>FIPS: CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>QPS=50, Burst=100<br/>Auth: kubeconfig"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        direction TB

        APIServer["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>AuthN: Bearer/Cert/OIDC<br/>AuthZ: RBAC"]

        subgraph PlatformCRDs["ODH/RHOAI Platform CRDs (READ)"]
            DSC["DataScienceCluster<br/>(singleton)"]
            DSCI["DSCInitialization<br/>(singleton)"]
            ComponentCRs["Component CRs<br/>platform.opendatahub.io"]
            Profiles["AcceleratorProfiles<br/>HardwareProfiles"]
        end

        subgraph WorkloadCRDs["Workload CRDs (READ)"]
            Notebooks["Notebooks<br/>kubeflow.org"]
            ISVCs["InferenceServices<br/>ServingRuntimes<br/>LLMInferenceServices<br/>serving.kserve.io"]
            DSPAs["DataSciencePipelines<br/>Applications"]
            RayClusters["RayClusters<br/>RayJobs<br/>ray.io"]
            OtherWL["PyTorchJobs<br/>GuardrailsOrchestrators<br/>LlamaStackDistributions<br/>Kueue Queues"]
        end

        subgraph OLMResources["OLM (READ + CREATE for migrate)"]
            Subscriptions["Subscriptions<br/>CREATE: migrate only"]
            CSVs["ClusterServiceVersions"]
            PackageManifests["PackageManifests"]
        end

        subgraph CoreResources["Core Resources (READ)"]
            ConfigMaps["ConfigMaps<br/>PATCH: migrate only"]
            Secrets["Secrets"]
            PVCs["PVCs"]
            CRDs["CRDs"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)<br/>deps --refresh only"]
    end

    subgraph LocalIO["LOCAL (No Network)"]
        Filesystem["Local Filesystem<br/>Backup YAML output<br/>Migration backup files"]
    end

    %% Network flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+ (FIPS OpenSSL)<br/>Bearer Token / Client Cert / OIDC<br/>EGRESS"| APIServer

    APIServer --> PlatformCRDs
    APIServer --> WorkloadCRDs
    APIServer --> OLMResources
    APIServer --> CoreResources

    CLI -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)<br/>EGRESS (optional)"| GitHub

    CLI -->|"Local I/O<br/>No network<br/>OS file permissions"| Filesystem

    %% Write operations highlight
    CLI -.->|"PATCH DSC<br/>(migrate only)"| DSC
    CLI -.->|"CREATE Subscription<br/>(migrate only)"| Subscriptions
    CLI -.->|"PATCH ConfigMaps<br/>(migrate only)"| ConfigMaps

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef controlplane fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef platform fill:#c8e6c9,stroke:#388e3c
    classDef workload fill:#c8e6c9,stroke:#388e3c
    classDef olm fill:#fff9c4,stroke:#f9a825
    classDef core fill:#e0e0e0,stroke:#616161
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef local fill:#f3e5f5,stroke:#7b1fa2

    class CLI client
    class APIServer controlplane
    class DSC,DSCI,ComponentCRs,Profiles platform
    class Notebooks,ISVCs,DSPAs,RayClusters,OtherWL workload
    class Subscriptions,CSVs,PackageManifests olm
    class ConfigMaps,Secrets,PVCs,CRDs core
    class GitHub external
    class Filesystem local
