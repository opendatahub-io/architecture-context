graph TB
    subgraph Client["CLIENT WORKSTATION (Trusted)"]
        Admin["Platform Administrator"]
        CLIBinary["kubectl-odh CLI<br/>Go binary (FIPS)<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>client-go QPS=50 Burst=100"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (RBAC Enforced)"]
        direction TB

        APIServer["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>AuthN: Bearer/Cert/OIDC<br/>AuthZ: RBAC"]

        subgraph PlatformCRDs["ODH/RHOAI Platform CRDs"]
            DSC["DataScienceCluster<br/>(get, list, patch)"]
            DSCI["DSCInitialization<br/>(get, list)"]
            CompCRs["Component CRs<br/>platform.opendatahub.io<br/>(get, list)"]
            Profiles["Accelerator/Hardware<br/>Profiles<br/>(get, list)"]
        end

        subgraph WorkloadCRDs["Workload CRDs (READ only)"]
            Notebooks["Notebooks<br/>kubeflow.org"]
            ISVCs["InferenceServices<br/>serving.kserve.io"]
            SRs["ServingRuntimes<br/>serving.kserve.io"]
            DSPAs["DSPApplications<br/>opendatahub.io"]
            RayClusters["RayClusters/RayJobs<br/>ray.io"]
            Kueue["ClusterQueues<br/>LocalQueues<br/>kueue.x-k8s.io"]
            Others["PyTorchJobs, Guardrails,<br/>LlamaStack, LLMInference,<br/>Authorino, Kuadrant"]
        end

        subgraph OLMResources["OLM Resources"]
            Subs["Subscriptions<br/>(get, list, create)"]
            CSVs["CSVs, InstallPlans<br/>(get, list)"]
            PkgManifests["PackageManifests<br/>(get, list)"]
        end

        subgraph CoreK8s["Core Kubernetes (READ)"]
            CoreResources["ConfigMaps, Secrets,<br/>PVCs, Namespaces,<br/>Deployments, CRDs,<br/>ClusterVersions"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
    end

    %% Client to CLI
    Admin -->|"local invocation"| CLIBinary

    %% CLI to K8s API
    CLIBinary -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token /<br/>Client Certificate /<br/>OIDC"| APIServer

    %% API Server to resources
    APIServer --- DSC
    APIServer --- DSCI
    APIServer --- CompCRs
    APIServer --- Profiles
    APIServer --- Notebooks
    APIServer --- ISVCs
    APIServer --- SRs
    APIServer --- DSPAs
    APIServer --- RayClusters
    APIServer --- Kueue
    APIServer --- Others
    APIServer --- Subs
    APIServer --- CSVs
    APIServer --- PkgManifests
    APIServer --- CoreResources

    %% CLI to GitHub (optional)
    CLIBinary -.->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (public)<br/>Optional: --refresh"| GitHub

    %% Styling
    classDef client fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef cli fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef apiserver fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef platformcrd fill:#f5a623,stroke:#d79b00,stroke-width:1px
    classDef workloadcrd fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef olm fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef corek8s fill:#f8cecc,stroke:#b85450,stroke-width:1px
    classDef external fill:#999,stroke:#333,stroke-width:2px,color:#fff

    class Admin client
    class CLIBinary cli
    class APIServer apiserver
    class DSC,DSCI,CompCRs,Profiles platformcrd
    class Notebooks,ISVCs,SRs,DSPAs,RayClusters,Kueue,Others workloadcrd
    class Subs,CSVs,PkgManifests olm
    class CoreResources corek8s
    class GitHub external
