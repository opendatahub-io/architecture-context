graph TB
    subgraph Client["CLIENT (Operator Workstation / Job Pod)"]
        CLI["rhai-cli / kubectl-odh<br/>Go binary (FIPS-compliant)<br/>Image: quay.io/rhoai/rhoai-upgrade-helpers-rhel9"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        direction TB

        subgraph K8sAPI["Kubernetes API Server"]
            direction TB
            ReadAPIs["READ APIs (lint, get, deps, backup)<br/>25+ API groups, all namespaces"]
            WriteAPIs["WRITE APIs (migrate, components)<br/>DSC PATCH, OLM Subscription CREATE"]
        end

        subgraph ReadResources["Read-Only Resources"]
            direction LR
            DSC["DataScienceCluster<br/>DSCI"]
            OLM["OLM<br/>Subscriptions, CSVs"]
            Workloads["Workload CRDs<br/>Notebooks, ISVC,<br/>RayCluster, PyTorchJob"]
            Platform["Platform CRDs<br/>13 Component CRs,<br/>ClusterVersion"]
            CoreAPIs["Core APIs<br/>ConfigMaps, Secrets,<br/>PVCs, Namespaces"]
        end

        subgraph WriteResources["Mutable Resources"]
            direction LR
            DSCPatch["DataScienceCluster<br/>(PATCH - component state)"]
            OLMCreate["OLM Subscription<br/>(CREATE - RHBOK install)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["raw.githubusercontent.com<br/>odh-gitops manifests<br/>TLS 1.2+ / No Auth"]
    end

    subgraph BuildOnly["BUILD-TIME ONLY"]
        direction LR
        DLK8s["dl.k8s.io<br/>kubectl download"]
        Mirror["mirror.openshift.com<br/>oc CLI download"]
    end

    subgraph Local["LOCAL (Client-side)"]
        FS["Local Filesystem<br/>Backup YAML output<br/>kubeconfig read<br/>⚠ May contain Secret values"]
    end

    %% Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / Client Cert / OIDC"| K8sAPI
    K8sAPI --> ReadResources
    K8sAPI --> WriteResources

    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>(deps --refresh only)"| GitHub

    CLI -->|"Local I/O<br/>File permissions<br/>(backup command)"| FS

    CLI -.->|"Build-time only<br/>HTTPS/443"| DLK8s
    CLI -.->|"Build-time only<br/>HTTPS/443"| Mirror

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef controlplane fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef readonly fill:#c8e6c9,stroke:#388e3c
    classDef writable fill:#ffcdd2,stroke:#c62828
    classDef external fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef local fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef buildonly fill:#f5f5f5,stroke:#9e9e9e,stroke-dasharray: 5 5

    class CLI client
    class K8sAPI controlplane
    class DSC,OLM,Workloads,Platform,CoreAPIs readonly
    class DSCPatch,OLMCreate writable
    class GitHub external
    class FS local
    class DLK8s,Mirror buildonly
