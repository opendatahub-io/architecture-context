graph TB
    subgraph CLIHost["CLI HOST (User Workstation / CI / Container)"]
        CLI["odh-cli (rhai-cli / kubectl-odh)<br/>Go CLI, FIPS-enabled<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>Base: ose-cli-rhel9 (UBI)"]
    end

    subgraph Cluster["KUBERNETES CLUSTER (RBAC enforced)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>AuthN: Bearer / ClientCert<br/>AuthZ: Kubernetes RBAC"]

        subgraph ReadAPIs["API Groups — Read Access"]
            direction LR
            PlatformAPIs["Platform APIs<br/>opendatahub.io<br/>operators.coreos.com<br/>config.openshift.io<br/>route.openshift.io"]
            ComponentAPIs["Component APIs<br/>serving.kserve.io<br/>kubeflow.org<br/>ray.io<br/>kueue.x-k8s.io<br/>trustyai.opendatahub.io<br/>dashboard.opendatahub.io<br/>gateway.networking.k8s.io"]
        end

        subgraph WriteAPIs["API Groups — Write Access (Migration Only)"]
            MutateAPIs["Mutated Resources<br/>InferenceService<br/>ServingRuntime<br/>DSPA<br/>RayCluster<br/>TrustyAIService<br/>DataScienceCluster"]
        end

        TrustyAIRoute["TrustyAI Service Route<br/>443/TCP HTTPS<br/>TLS 1.2+ (InsecureSkipVerify)<br/>Auth: Bearer Token<br/>⚠️ Skips cert verification"]
    end

    subgraph External["EXTERNAL (Build-time only)"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None"]
    end

    subgraph LocalIO["LOCAL I/O"]
        FS["Local Filesystem<br/>Backup YAML files"]
        Stdout["stdout<br/>Table / JSON / YAML"]
    end

    %% Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / ClientCert<br/>All cluster operations"| K8sAPI
    K8sAPI --- ReadAPIs
    K8sAPI --- WriteAPIs
    CLI -->|"HTTPS/443<br/>TLS 1.2+ (InsecureSkipVerify)<br/>Bearer Token<br/>Metrics backup/restore<br/>(migration only)"| TrustyAIRoute
    CLI -.->|"HTTPS/443<br/>TLS 1.2+<br/>No auth<br/>(build-time only via make)"| GitHub
    CLI -->|"File I/O<br/>backup command"| FS
    CLI -->|"Console I/O<br/>all commands"| Stdout

    %% Styling
    classDef cli fill:#dbeafe,stroke:#2563eb,stroke-width:3px
    classDef cluster fill:#d1fae5,stroke:#059669,stroke-width:2px
    classDef apiserver fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef readapi fill:#e0f2fe,stroke:#0284c7
    classDef writeapi fill:#fecaca,stroke:#dc2626
    classDef trustyai fill:#fef9c3,stroke:#ca8a04
    classDef external fill:#f3f4f6,stroke:#6b7280
    classDef localio fill:#f9fafb,stroke:#9ca3af

    class CLI cli
    class K8sAPI apiserver
    class PlatformAPIs,ComponentAPIs readapi
    class MutateAPIs writeapi
    class TrustyAIRoute trustyai
    class GitHub external
    class FS,Stdout localio
