graph TB
    subgraph Local["LOCAL EXECUTION CONTEXT"]
        CLI["kubectl-odh / rhai-cli<br/>Go CLI (one-shot process)<br/>FIPS: strictfipsruntime + CGO<br/>API: QPS=50, Burst=100"]
    end

    subgraph Cluster["KUBERNETES CLUSTER (OpenShift 4.19.9+)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>RBAC: User Permissions"]

        subgraph PlatformCRDs["Platform CRDs (Read)"]
            DSC["DataScienceCluster v2/v1"]
            DSCI["DSCInitialization v2/v1"]
            ComponentCRs["Component CRs v1alpha1"]
        end

        subgraph OLM["OLM Resources (Read/Write)"]
            Subscription["Subscription"]
            CSVResource["CSV / InstallPlan"]
            PkgManifest["PackageManifest"]
        end

        subgraph WorkloadCRDs["Workload CRDs (Read/Write)"]
            IS["InferenceService v1beta1"]
            SR["ServingRuntime v1alpha1"]
            NB["Notebook v1"]
            DSPARes["DSPA v1/v1alpha1"]
            RC["RayCluster v1"]
            TAI["TrustyAIService v1alpha1"]
            LS["LlamaStackDistribution v1alpha1"]
        end

        subgraph SchedulingCRDs["Scheduling CRDs (Read)"]
            CQ["ClusterQueue v1beta1"]
            LQ["LocalQueue v1beta1"]
        end

        subgraph InCluster["In-Cluster Service"]
            TrustyAIRoute["TrustyAI Service<br/>(via OpenShift Route)<br/>Namespace: user-ns"]
        end
    end

    subgraph External["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>Dependency manifest source<br/>Pinned commit 1a55af0"]
        Quay["quay.io/rhoai/<br/>rhoai-upgrade-helpers-rhel9<br/>CLI container image"]
    end

    subgraph LocalFS["LOCAL FILESYSTEM"]
        Kubeconfig["kubeconfig<br/>(auth source)"]
        BackupFiles["Backup Files<br/>YAML + JSON<br/>Mode: 0600"]
    end

    %% Flows
    Kubeconfig -.->|"Auth credentials"| CLI
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / Client Cert"| K8sAPI

    K8sAPI --- PlatformCRDs
    K8sAPI --- OLM
    K8sAPI --- WorkloadCRDs
    K8sAPI --- SchedulingCRDs
    K8sAPI --- InCluster

    CLI -->|"HTTPS/443<br/>TLS 1.2 (InsecureSkipVerify!)<br/>Bearer Token<br/>GET/POST metrics"| TrustyAIRoute
    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| GitHub
    CLI -->|"File I/O<br/>YAML/JSON backup"| BackupFiles

    %% RBAC note
    RBAC["RBAC: No ClusterRoles installed<br/>Uses user permissions<br/>Pre-validates via<br/>SelfSubjectAccessReview"]

    %% Styling
    classDef local fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef cluster fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef apiserver fill:#ffcc80,stroke:#e65100,stroke-width:3px
    classDef crds fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px
    classDef incluster fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    classDef external fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef filesystem fill:#e0e0e0,stroke:#424242,stroke-width:1px
    classDef warning fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    classDef rbacnote fill:#e8eaf6,stroke:#283593,stroke-width:1px

    class CLI local
    class K8sAPI apiserver
    class DSC,DSCI,ComponentCRs,Subscription,CSVResource,PkgManifest crds
    class IS,SR,NB,DSPARes,RC,TAI,LS,CQ,LQ crds
    class TrustyAIRoute incluster
    class GitHub,Quay external
    class Kubeconfig,BackupFiles filesystem
    class RBAC rbacnote
