graph TB
    subgraph ClientHost["CLIENT HOST (Trusted - Admin Workstation / Job Pod)"]
        CLI["rhai-cli / kubectl-odh<br/>FIPS-compliant Go binary<br/>Image: quay.io/rhoai/rhoai-upgrade-helpers-rhel9<br/>No network listeners"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC enforcement"]

        subgraph ReadAPIs["READ Operations (lint, get, deps, backup, components)"]
            direction LR
            ODH_CRDs["ODH CRDs<br/>DataScienceCluster<br/>DSCInitialization<br/>Component CRs (13)"]
            OLM_APIs["OLM APIs<br/>Subscriptions<br/>CSVs<br/>InstallPlans"]
            Workload_CRDs["Workload CRDs<br/>Notebooks, ISVC<br/>RayCluster, PyTorchJob<br/>DSPA, ClusterQueue"]
            Platform_APIs["Platform APIs<br/>ClusterVersion<br/>ImageStreams<br/>CRD Discovery"]
            Core_APIs["Core APIs<br/>ConfigMaps, Secrets<br/>PVCs, Namespaces<br/>Deployments"]
        end

        subgraph WriteAPIs["WRITE Operations (migrate, components only)"]
            DSC_Patch["DataScienceCluster<br/>PATCH (MergePatch)"]
            OLM_Create["OLM Subscription<br/>CREATE (RHBOK only)"]
        end
    end

    subgraph LocalFS["CLIENT LOCAL FILESYSTEM"]
        BackupFiles["Backup YAML Files<br/>Metadata stripped<br/>(uid, resourceVersion, status)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Optional)"]
        GitHub["raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)<br/>odh-gitops manifests"]
    end

    subgraph BuildOnly["BUILD-TIME ONLY (Not Runtime)"]
        DLK8s["dl.k8s.io<br/>443/TCP HTTPS"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS"]
    end

    %% Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / Client Cert / OIDC<br/>QPS: 50, Burst: 100"| K8sAPI

    K8sAPI --> ReadAPIs
    K8sAPI --> WriteAPIs

    CLI -->|"Write sanitized YAML<br/>(cluster metadata stripped)"| BackupFiles

    CLI -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>(--refresh flag only)"| GitHub

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef readapi fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef writeapi fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef localfs fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:1px
    classDef buildonly fill:#f0f0f0,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5

    class CLI client
    class K8sAPI controlplane
    class ODH_CRDs,OLM_APIs,Workload_CRDs,Platform_APIs,Core_APIs readapi
    class DSC_Patch,OLM_Create writeapi
    class BackupFiles localfs
    class GitHub external
    class DLK8s,Mirror buildonly
