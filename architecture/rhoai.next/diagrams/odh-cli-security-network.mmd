graph TB
    subgraph Client["CLIENT (Local Machine / CI Runner)"]
        CLI["kubectl-odh CLI<br/>Go Binary (FIPS)<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>QPS=50, Burst=100"]
    end

    subgraph K8sBoundary["KUBERNETES CLUSTER BOUNDARY"]
        direction TB

        subgraph APIServer["API Server"]
            K8sAPI["kube-apiserver<br/>6443/TCP<br/>TLS 1.2+<br/>AuthN: Bearer/Cert/OIDC<br/>AuthZ: RBAC"]
        end

        subgraph PlatformCRDs["ODH/RHOAI Platform Resources"]
            DSC["DataScienceCluster<br/>(singleton) R/W"]
            DSCI["DSCInitialization<br/>(singleton) R"]
            CompCRs["Component CRs<br/>(platform.opendatahub.io) R"]
            Profiles["AcceleratorProfiles /<br/>HardwareProfiles R"]
        end

        subgraph WorkloadCRDs["Workload Resources"]
            Notebooks["Notebooks<br/>(kubeflow.org) R"]
            ISVCs["InferenceServices<br/>(kserve.io) R"]
            SRs["ServingRuntimes<br/>(kserve.io) R"]
            DSPA["DSPA<br/>(opendatahub.io) R"]
            Ray["RayClusters/Jobs<br/>(ray.io) R"]
            PyTorch["PyTorchJobs<br/>(kubeflow.org) R"]
            Guardrails["GuardrailsOrch<br/>(trustyai) R"]
            LlamaStack["LlamaStackDist<br/>(llamastack.io) R"]
            LLMIS["LLMInference<br/>(kserve.io) R"]
        end

        subgraph KueueCRDs["Kueue Resources"]
            CQ["ClusterQueues R/W"]
            LQ["LocalQueues R"]
        end

        subgraph KuadrantCRDs["Kuadrant Resources"]
            Authorino["Authorino R"]
            Kuadrant["Kuadrant R"]
        end

        subgraph OLMResources["OLM Resources"]
            Subs["Subscriptions R/C"]
            CSVs["ClusterServiceVersions R"]
            PkgMan["PackageManifests R"]
        end

        subgraph CoreResources["Core / OpenShift Resources"]
            CoreAPI["ConfigMaps, Secrets,<br/>PVCs, Namespaces R"]
            Deploys["Deployments R"]
            CRDefs["CRDs R"]
            ClusterVer["ClusterVersion R"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>raw.githubusercontent.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth (public)"]
    end

    subgraph LocalStorage["LOCAL FILESYSTEM"]
        BackupDir["Backup YAML Files<br/>(workloads + dependencies)<br/>Migration backups"]
    end

    %% Primary flow - all through API server
    CLI -->|"HTTPS/6443<br/>TLS 1.2+ (FIPS OpenSSL)<br/>Bearer Token / Client Cert"| K8sAPI

    K8sAPI --- DSC
    K8sAPI --- DSCI
    K8sAPI --- CompCRs
    K8sAPI --- Profiles
    K8sAPI --- Notebooks
    K8sAPI --- ISVCs
    K8sAPI --- SRs
    K8sAPI --- DSPA
    K8sAPI --- Ray
    K8sAPI --- PyTorch
    K8sAPI --- Guardrails
    K8sAPI --- LlamaStack
    K8sAPI --- LLMIS
    K8sAPI --- CQ
    K8sAPI --- LQ
    K8sAPI --- Authorino
    K8sAPI --- Kuadrant
    K8sAPI --- Subs
    K8sAPI --- CSVs
    K8sAPI --- PkgMan
    K8sAPI --- CoreAPI
    K8sAPI --- Deploys
    K8sAPI --- CRDefs
    K8sAPI --- ClusterVer

    %% Optional egress
    CLI -.->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth<br/>(--refresh only)"| GitHub

    %% Local writes
    CLI -->|"Local I/O<br/>Backup YAML"| BackupDir

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef apiserver fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    classDef platform fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px
    classDef workload fill:#fff9c4,stroke:#f9a825,stroke-width:1px
    classDef kueue fill:#e1bee7,stroke:#7b1fa2,stroke-width:1px
    classDef kuadrant fill:#b2dfdb,stroke:#00695c,stroke-width:1px
    classDef olm fill:#ffe0b2,stroke:#e65100,stroke-width:1px
    classDef core fill:#f5f5f5,stroke:#616161,stroke-width:1px
    classDef external fill:#fff3e0,stroke:#bf360c,stroke-width:2px
    classDef local fill:#f5f5f5,stroke:#999,stroke-width:1px

    class CLI client
    class K8sAPI apiserver
    class DSC,DSCI,CompCRs,Profiles platform
    class Notebooks,ISVCs,SRs,DSPA,Ray,PyTorch,Guardrails,LlamaStack,LLMIS workload
    class CQ,LQ kueue
    class Authorino,Kuadrant kuadrant
    class Subs,CSVs,PkgMan olm
    class CoreAPI,Deploys,CRDefs,ClusterVer core
    class GitHub external
    class BackupDir local
