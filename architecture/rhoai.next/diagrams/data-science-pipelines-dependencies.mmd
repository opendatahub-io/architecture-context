graph LR
    DSP["Data Science Pipelines<br/>(Kubeflow Pipelines v2)"]

    %% External Dependencies (Required)
    DSP -->|"execution engine<br/>CRD Watch + Create"| Argo["Argo Workflows<br/>v3.7.11"]
    DSP -->|"metadata persistence<br/>SQL 3306/5432"| DB["MySQL 5.7+ /<br/>PostgreSQL 12+"]
    DSP -->|"artifact storage<br/>HTTP 9000"| S3["S3-compatible Store<br/>(MinIO/SeaweedFS)"]
    DSP -->|"execution lineage<br/>gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"orchestration<br/>HTTPS 443"| K8s["Kubernetes<br/>1.29+"]

    %% External Dependencies (Optional)
    DSP -.->|"TLS certificates<br/>(optional)"| CertManager["cert-manager"]

    %% Internal RHOAI Dependencies
    DSPO["DSPO<br/>(DS Pipelines Operator)"] -->|"deploys &<br/>configures"| DSP
    Dashboard["RHOAI Dashboard"] -->|"REST API consumer<br/>8888/TCP"| DSP
    Workbench["Workbench<br/>(Notebooks)"] -->|"KFP Python SDK<br/>gRPC+REST"| DSP
    ModelRegistry["Model Registry"] -.->|"lineage tracking<br/>(proposed)"| DSP

    %% Integration Points
    DSP -.->|"optional<br/>sidecars"| Metacontroller["Metacontroller<br/>(multi-user profiles)"]
    DSP -.->|"SeldonDeployment<br/>(optional)"| Seldon["Seldon"]
    DSP -->|"visualization<br/>HTTP"| VizServer["Visualization<br/>Server"]

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style DB fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Workbench fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style Metacontroller fill:#f5a623,stroke:#333,color:#fff
    style Seldon fill:#f5a623,stroke:#333,color:#fff
