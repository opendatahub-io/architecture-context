graph LR
    DSP["Data Science Pipelines<br/>(DSP v2.16.1)"]

    %% External Dependencies (Required)
    DSP -->|"workflow execution<br/>DAG orchestration"| Argo["Argo Workflows<br/>v3.7.14"]
    DSP -->|"pipeline/run/cache<br/>persistent storage"| SQL["MySQL 8.x /<br/>PostgreSQL 15.x"]
    DSP -->|"artifact &<br/>package storage"| S3["SeaweedFS / MinIO<br/>(S3-compatible)"]
    DSP -->|"execution lineage<br/>artifact metadata"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"CRD controller<br/>framework"| CR["controller-runtime<br/>v0.23.3"]
    DSP -->|"REST ↔ gRPC<br/>transcoding"| GW["gRPC-Gateway<br/>v2.28.0"]

    %% Platform Dependencies
    DSP -->|"CRD ops, RBAC,<br/>TokenReview, SAR"| K8sAPI["Kubernetes<br/>API Server"]

    %% Internal RHOAI Dependencies
    DSPA["DSPA Operator<br/>(RHOAI)"] -->|"deploys DSP via<br/>DSPA CR"| DSP
    DSP -.->|"webhook TLS certs<br/>(optional)"| CertManager["cert-manager<br/>v1.13+"]

    %% Integration Points (consumers of DSP)
    Dashboard["ODH Dashboard /<br/>RHOAI UI"] -->|"pipeline UI<br/>embedding"| DSP
    Workbench["Data Science<br/>Workbench"] -->|"SDK pipeline<br/>submission"| DSP

    %% Optional Integrations
    DSP -.->|"experiment tracking<br/>(plugin, optional)"| MLflow["MLflow"]
    DSP -.->|"model deployment<br/>(pipeline runner)"| Seldon["Seldon<br/>(optional)"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrapes /metrics<br/>8888, 9090"| DSP

