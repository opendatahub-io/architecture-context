graph LR
    DSP["Data Science Pipelines<br/>(API Server + Agents + Controllers)"]

    %% External Dependencies (Required)
    DSP -->|"workflow execution<br/>v3.7.14"| Argo["Argo Workflows<br/>v3.7.14"]
    DSP -->|"metadata storage<br/>SQL 3306/5432"| DB["MySQL 5.7+ /<br/>PostgreSQL 13+"]
    DSP -->|"artifact storage<br/>S3 API 9000/443"| ObjStore["MinIO / S3 /<br/>GCS / SeaweedFS"]
    DSP -->|"artifact lineage<br/>gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]

    %% External Dependencies (Optional)
    DSP -.->|"TLS certs<br/>v1"| CertManager["cert-manager<br/>v1"]
    DSP -.->|"experiment tracking<br/>HTTP/HTTPS"| MLflow["MLflow"]

    %% Kubernetes Platform
    DSP -->|"RBAC, resources<br/>HTTPS 443"| K8sAPI["Kubernetes API"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys via<br/>DSPA CRD"| DSP
    OpenShift["OpenShift<br/>(platform)"] -->|"Route ingress"| DSP
    Istio["Istio /<br/>Service Mesh"] -.->|"multi-user routing<br/>VirtualService"| DSP

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -.->|"UI management"| DSP
    Notebooks["Data Science<br/>Notebooks"] -.->|"SDK submissions"| DSP

    %% Sub-component internal dependencies
    subgraph InternalDeps["Internal Sub-Component Dependencies"]
        direction TB
        API2["API Server"]
        PA2["Persistence Agent"] -->|"gRPC 8887<br/>Projected SA token"| API2
        SWF2["Scheduled Workflow<br/>Controller"] -->|"gRPC 8887<br/>Projected SA token"| API2
        Driver2["Driver"] -->|"gRPC 8887<br/>SA token"| API2
    end

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style DB fill:#999,stroke:#333,color:#fff
    style ObjStore fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333
    style MLflow fill:#bbb,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style OpenShift fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Notebooks fill:#7ed321,stroke:#333,color:#fff
    style API2 fill:#4a90e2,stroke:#333,color:#fff
    style PA2 fill:#6bc4a0,stroke:#333,color:#fff
    style SWF2 fill:#6bc4a0,stroke:#333,color:#fff
    style Driver2 fill:#5bb5e0,stroke:#333,color:#fff
