    DSP -->|"execution lineage<br/>gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"CRDs, RBAC, pods<br/>HTTPS 443"| K8sAPI["Kubernetes<br/>1.29+"]

    %% External Dependencies (Optional)
    DSP -.->|"TLS certificates<br/>(optional)"| CertManager["cert-manager"]

    %% Internal RHOAI Dependencies
    DSPO["DSPO<br/>(Operator)"] -->|"deploys &<br/>configures"| DSP
    Dashboard["RHOAI Dashboard"] -->|"REST API<br/>8888"| DSP
    Workbench["Workbench<br/>(Notebooks)"] -->|"SDK client<br/>gRPC/REST"| DSP

    %% Integration Points (proposed)
    DSP -.->|"lineage tracking<br/>(proposal)"| ModelRegistry["Model Registry"]

    %% Argo sub-dependency
    DSP -->|"sidecars in<br/>Workflow pods"| ArgoWF

    %% Optional integrations
    DSP -.->|"namespace setup<br/>(multi-user)"| Metacontroller["Metacontroller"]
    DSP -.->|"model deployment<br/>(optional)"| Seldon["Seldon"]

