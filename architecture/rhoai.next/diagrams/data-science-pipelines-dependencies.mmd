graph LR
    DSP["Data Science Pipelines<br/>(API Server + Agents)"]

    %% External Dependencies (Required)
    DSP -->|"workflow execution<br/>Workflow CRs"| Argo["Argo Workflows<br/>v3.7.11"]
    DSP -->|"metadata persistence<br/>TCP 3306/5432"| Database["MySQL 8.x /<br/>PostgreSQL 15.x"]
    DSP -->|"specs & artifacts<br/>HTTPS 443"| ObjectStore["MinIO / S3 / GCS"]
    DSP -->|"execution metadata<br/>gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"CRD ops, RBAC<br/>HTTPS 443"| K8s["Kubernetes 1.27+"]

    %% Internal ODH Dependencies
    DSPO["data-science-pipelines-<br/>operator (DSPO)"] -->|"deploys & manages<br/>DSPA CR"| DSP
    Dashboard["RHOAI Dashboard"] -->|"REST API consumer<br/>HTTP 8888"| DSP
    KFP["KFP Python SDK"] -->|"REST/gRPC consumer<br/>8888 + 8887"| DSP

    %% CRDs Managed
    DSP -.->|"creates/watches"| WF_CRD["Workflow CR<br/>argoproj.io/v1alpha1"]
    DSP -.->|"creates/watches"| SWF_CRD["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    DSP -.->|"manages"| Pipeline_CRD["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    DSP -.->|"validates/mutates"| PV_CRD["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    DSP -.->|"creates"| Viewer_CRD["Viewer CR<br/>kubeflow.org/v1beta1"]

    %% Webhook
    K8sAdmission["Kubernetes<br/>Admission Webhook"] -->|"PipelineVersion<br/>validation/mutation<br/>HTTPS 8443"| DSP

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style Database fill:#999,stroke:#333,color:#fff
    style ObjectStore fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff
    style K8sAdmission fill:#f5a623,stroke:#333,color:#fff
    style WF_CRD fill:#f5a623,stroke:#333,color:#fff
    style SWF_CRD fill:#f5a623,stroke:#333,color:#fff
    style Pipeline_CRD fill:#f5a623,stroke:#333,color:#fff
    style PV_CRD fill:#f5a623,stroke:#333,color:#fff
    style Viewer_CRD fill:#f5a623,stroke:#333,color:#fff
