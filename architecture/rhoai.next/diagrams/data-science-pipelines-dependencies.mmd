    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style ArgoWF fill:#999,stroke:#333,color:#fff
    style Database fill:#999,stroke:#333,color:#fff
    style ObjectStore fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% External optional
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style Metacontroller fill:#bbb,stroke:#333,color:#fff
    style Seldon fill:#bbb,stroke:#333,color:#fff

    %% Internal RHOAI
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Workbench fill:#7ed321,stroke:#333,color:#fff
