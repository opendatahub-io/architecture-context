graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        direction TB

        subgraph ControlPlane["Control Plane"]
            Controller["workflow-controller<br/>Go Controller<br/>UID: 8737<br/>Metrics: 9090/TCP<br/>Health: 6060/TCP"]
            LeaderElection["Leader Election<br/>(Lease-based)"]
            Controller -->|acquires| LeaderElection
        end

        subgraph WorkerPools["Worker Pools"]
            WFWorkers["Workflow Workers<br/>(32 concurrent)"]
            TTLWorkers["TTL GC Workers<br/>(4 concurrent)"]
            PodCleanup["Pod Cleanup Workers<br/>(4 concurrent)"]
            CronWorkers["Cron Workers<br/>(8 concurrent)"]
            ArchiveWorkers["Archive Workers<br/>(8 concurrent)"]
        end

        subgraph Executor["Executor (per step pod)"]
            ArgoExec["argoexec<br/>Go Executor Sidecar<br/>UID: 2000"]
            InitPhase["Init Container<br/>Download artifacts"]
            WaitPhase["Wait Container<br/>Upload artifacts<br/>Report results"]
            ArgoExec --- InitPhase
            ArgoExec --- WaitPhase
        end

        Controller --> WFWorkers
        Controller --> TTLWorkers
        Controller --> PodCleanup
        Controller --> CronWorkers
        Controller --> ArchiveWorkers
    end

    %% CRDs
    User["User / DSP API"] -->|creates| WorkflowCR["Workflow CR<br/>argoproj.io/v1alpha1"]
    WorkflowCR -->|watched by| Controller
    CronWorkflowCR["CronWorkflow CR"] -->|watched by| CronWorkers
    WFTemplateCR["WorkflowTemplate CR"] -->|referenced by| Controller
    ClusterWFTemplateCR["ClusterWorkflowTemplate CR"] -->|referenced by| Controller

    %% Controller actions
    Controller -->|creates| StepPod["Step Pod<br/>(with argoexec sidecar)"]
    Controller -->|manages| PDB["PodDisruptionBudget"]
    Controller -->|manages| PVC["PersistentVolumeClaim"]

    %% Executor interactions
    InitPhase -->|downloads from| S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    WaitPhase -->|uploads to| S3
    WaitPhase -->|patches annotations| K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]

    %% External dependencies
    Controller -->|CRUD operations| K8sAPI
    ArchiveWorkers -->|archives to| DB["PostgreSQL / MySQL<br/>(optional)"]

    %% DSPO management
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|deploys & configures| Controller
    DSPO -->|configures image| ArgoExec

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes /metrics| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ArgoExec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style CronWorkflowCR fill:#f5a623,stroke:#333,stroke-width:2px
    style WFTemplateCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ClusterWFTemplateCR fill:#f5a623,stroke:#333,stroke-width:2px
    style DSPO fill:#7ed321,stroke:#333,stroke-width:2px
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style DB fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style StepPod fill:#d5e8d4,stroke:#82b366
    style LeaderElection fill:#dae8fc,stroke:#6c8ebf
