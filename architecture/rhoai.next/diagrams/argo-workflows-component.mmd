graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB
        subgraph Controller["workflow-controller"]
            WFC[Workflow Controller<br/>Go / client-go informers<br/>Port: 9090 metrics, 6060 healthz]
            CronCtrl[Cron Controller<br/>CronWorkflow scheduling]
            ArtifactGC[Artifact GC Controller<br/>Artifact garbage collection]
            WFC --- CronCtrl
            WFC --- ArtifactGC
        end

        subgraph Executor["argoexec (per workflow pod)"]
            InitC[Init Container<br/>Artifact download<br/>Script staging]
            WaitC[Wait Sidecar<br/>Artifact upload<br/>Output parameter extraction<br/>Container lifecycle]
        end
    end

    subgraph CRDs["Custom Resource Definitions (argoproj.io/v1alpha1)"]
        WorkflowCR[Workflow CR]
        CronWorkflowCR[CronWorkflow CR]
        WFTemplate[WorkflowTemplate CR]
        ClusterWFTemplate[ClusterWorkflowTemplate CR]
        WFTaskSet[WorkflowTaskSet CR]
        WFTaskResult[WorkflowTaskResult CR]
        WFArtifactGCTask[WorkflowArtifactGCTask CR]
    end

    User[User / DSP Operator] -->|creates| WorkflowCR
    User -->|creates| CronWorkflowCR

    WorkflowCR -->|watched by| WFC
    CronWorkflowCR -->|watched by| CronCtrl
    WFTemplate -->|referenced by| WFC
    ClusterWFTemplate -->|referenced by| WFC
    WFTaskSet -->|managed by| WFC
    WFTaskResult -->|created by| WaitC
    WFArtifactGCTask -->|created by| ArtifactGC

    WFC -->|creates| WorkflowPod[Workflow Pod<br/>main + argoexec sidecar]
    ArtifactGC -->|creates| GCPod[GC Pod]

    WFC -->|CRUD| K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
    InitC -->|download artifacts| S3[S3 / Minio<br/>443/TCP HTTPS]
    WaitC -->|upload artifacts| S3
    WaitC -->|patch results| K8sAPI
    WFC -.->|optional archive| DB[(PostgreSQL / MySQL<br/>5432/TCP or 3306/TCP)]

    CronCtrl -->|creates| WorkflowCR

    style WFC fill:#4a90e2,stroke:#333,color:#fff
    style CronCtrl fill:#4a90e2,stroke:#333,color:#fff
    style ArtifactGC fill:#4a90e2,stroke:#333,color:#fff
    style InitC fill:#50c878,stroke:#333,color:#fff
    style WaitC fill:#50c878,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style CronWorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style WFTemplate fill:#f5a623,stroke:#333,color:#fff
    style ClusterWFTemplate fill:#f5a623,stroke:#333,color:#fff
    style WFTaskSet fill:#f5a623,stroke:#333,color:#fff
    style WFTaskResult fill:#f5a623,stroke:#333,color:#fff
    style WFArtifactGCTask fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style DB fill:#e8e8e8,stroke:#333
    style WorkflowPod fill:#d5e8d4,stroke:#333
    style GCPod fill:#d5e8d4,stroke:#333
    style User fill:#fff,stroke:#333
