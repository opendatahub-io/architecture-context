graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB
        subgraph Controller["workflow-controller"]
            WFC[Workflow Controller<br/>Go / client-go informers<br/>:9090 metrics, :6060 healthz]
            CronCtrl[Cron Controller<br/>CronWorkflow scheduling]
            GCCtrl[Artifact GC Controller<br/>Artifact cleanup]
            Archiver[Workflow Archiver<br/>SQL persistence]
            LeaderElect[Leader Election<br/>Lease-based HA]
            WFC --> CronCtrl
            WFC --> GCCtrl
            WFC --> Archiver
            WFC --> LeaderElect
        end

        subgraph Executor["argoexec (sidecar/init)"]
            ArgoExec[Argo Executor<br/>Go binary<br/>Emissary pattern]
            ArtifactMgr[Artifact Manager<br/>8 storage backends]
            ParamExtract[Parameter Extractor<br/>stdout/stderr capture]
            ArgoExec --> ArtifactMgr
            ArgoExec --> ParamExtract
        end
    end

    %% CRDs
    WorkflowCR[Workflow CR<br/>argoproj.io/v1alpha1]
    CronWorkflowCR[CronWorkflow CR<br/>argoproj.io/v1alpha1]
    WFTemplate[WorkflowTemplate CR<br/>argoproj.io/v1alpha1]
    ClusterWFTemplate[ClusterWorkflowTemplate CR<br/>argoproj.io/v1alpha1]
    TaskSetCR[WorkflowTaskSet CR<br/>argoproj.io/v1alpha1]
    TaskResultCR[WorkflowTaskResult CR<br/>argoproj.io/v1alpha1]
    GCTaskCR[WorkflowArtifactGCTask CR<br/>argoproj.io/v1alpha1]

    %% External actors
    User[User / DSP Operator]
    K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]

    %% External dependencies
    PostgreSQL[(PostgreSQL<br/>5432/TCP<br/>Optional)]
    S3[S3 / Minio<br/>443/TCP HTTPS]
    Prometheus[Prometheus<br/>Metrics Scraper]

    %% Flows
    User -->|creates| WorkflowCR
    User -->|creates| CronWorkflowCR
    WorkflowCR -->|watched by| WFC
    CronWorkflowCR -->|watched by| CronCtrl
    WFTemplate -->|referenced by| WFC
    ClusterWFTemplate -->|referenced by| WFC
    WFC -->|creates| TaskSetCR
    ArgoExec -->|patches| TaskResultCR
    GCCtrl -->|creates| GCTaskCR

    WFC -->|CRUD via| K8sAPI
    ArgoExec -->|patches via| K8sAPI
    Archiver -->|stores workflows| PostgreSQL
    ArtifactMgr -->|upload/download| S3
    Prometheus -->|scrapes :9090| WFC

    %% Styling
    style WFC fill:#4a90e2,stroke:#333,color:#fff
    style CronCtrl fill:#4a90e2,stroke:#333,color:#fff
    style GCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style Archiver fill:#4a90e2,stroke:#333,color:#fff
    style LeaderElect fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExec fill:#50b5e0,stroke:#333,color:#fff
    style ArtifactMgr fill:#50b5e0,stroke:#333,color:#fff
    style ParamExtract fill:#50b5e0,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style CronWorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style WFTemplate fill:#f5a623,stroke:#333,color:#fff
    style ClusterWFTemplate fill:#f5a623,stroke:#333,color:#fff
    style TaskSetCR fill:#f5a623,stroke:#333,color:#fff
    style TaskResultCR fill:#f5a623,stroke:#333,color:#fff
    style GCTaskCR fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style User fill:#9b59b6,stroke:#333,color:#fff
