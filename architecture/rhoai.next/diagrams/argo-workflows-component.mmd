graph TB
    subgraph "Argo Workflows Component"
        direction TB
        subgraph "Control Plane"
            Controller["workflow-controller<br/>Go Controller<br/>Ports: 9090/TCP (metrics), 6060/TCP (healthz)"]
            LeaderElection["Leader Election<br/>(Lease-based)"]
            Controller -->|acquires| LeaderElection
        end

        subgraph "Worker Pools"
            WFWorkers["Workflow Workers (32)"]
            TTLWorkers["TTL GC Workers (4)"]
            PodCleanup["Pod Cleanup Workers (4)"]
            CronWorkers["CronWorkflow Workers (8)"]
            ArchiveWorkers["Archive Workers (8)"]
        end

        Controller --> WFWorkers
        Controller --> TTLWorkers
        Controller --> PodCleanup
        Controller --> CronWorkers
        Controller --> ArchiveWorkers

        subgraph "Executor (per step pod)"
            ArgoExec["argoexec<br/>Go Executor (sidecar)<br/>UID: 2000"]
            InitPhase["Init Container<br/>(download artifacts)"]
            WaitPhase["Wait Container<br/>(upload artifacts, report results)"]
            ArgoExec --- InitPhase
            ArgoExec --- WaitPhase
        end
    end

    %% CRDs
    User["User / DSP API"] -->|creates| WorkflowCR["Workflow CR<br/>(argoproj.io/v1alpha1)"]
    WorkflowCR -->|watched by| Controller

    CronWF["CronWorkflow CR"] -->|processed by| CronWorkers
    WFTemplate["WorkflowTemplate CR"] -->|referenced by| WorkflowCR
    ClusterWFTemplate["ClusterWorkflowTemplate CR"] -->|referenced by| WorkflowCR

    %% Controller actions
    Controller -->|creates| StepPod["Workflow Step Pod<br/>(with argoexec sidecar)"]
    Controller -->|creates/manages| PVC["PersistentVolumeClaims"]
    Controller -->|creates| PDB["PodDisruptionBudgets"]

    %% External dependencies
    Controller -->|API calls| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    ArgoExec -->|patch annotations| K8sAPI
    ArgoExec -->|upload/download| S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    Controller -.->|optional archival| DB["PostgreSQL / MySQL<br/>5432/TCP or 3306/TCP"]

    %% DSPO relationship
    DSPO["Data Science Pipelines Operator"] -->|deploys & configures| Controller
    DSPO -->|manages image for| ArgoExec

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes /metrics| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExec fill:#4a90e2,stroke:#333,color:#fff
    style InitPhase fill:#6baed6,stroke:#333
    style WaitPhase fill:#6baed6,stroke:#333
    style LeaderElection fill:#6baed6,stroke:#333
    style WorkflowCR fill:#f5a623,stroke:#333
    style CronWF fill:#f5a623,stroke:#333
    style WFTemplate fill:#f5a623,stroke:#333
    style ClusterWFTemplate fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style DB fill:#e8e8e8,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style StepPod fill:#d5e8d4,stroke:#333
    style PVC fill:#d5e8d4,stroke:#333
    style PDB fill:#d5e8d4,stroke:#333
    style User fill:#f9f9f9,stroke:#333
    style WFWorkers fill:#b3cde3,stroke:#333
    style TTLWorkers fill:#b3cde3,stroke:#333
    style PodCleanup fill:#b3cde3,stroke:#333
    style CronWorkers fill:#b3cde3,stroke:#333
    style ArchiveWorkers fill:#b3cde3,stroke:#333
