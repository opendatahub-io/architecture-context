graph TB
    subgraph ArgoWorkflows["Argo Workflows"]
        direction TB

        subgraph Controller["workflow-controller"]
            WFReconciler["Workflow Reconciler<br/>32 workers"]
            CronCtrl["Cron Controller<br/>8 workers"]
            GCCtrl["GC Controller<br/>4 TTL workers"]
            PodCleanup["Pod Cleanup<br/>4 workers"]
            ArtifactGC["Artifact GC"]
            SyncMgr["Synchronization Manager<br/>(semaphores/mutexes)"]
            LeaderElection["Leader Election"]
            Metrics9090["Metrics :9090"]
            Health6060["Health :6060"]
        end

        subgraph Server["argo-server"]
            GRPCGW["gRPC-Gateway<br/>REST + gRPC :2746"]
            Gatekeeper["Gatekeeper<br/>(AuthN/AuthZ)"]
            SSOAuth["SSO/OIDC Auth"]
            ArtifactSrv["Artifact Server"]
            WebUI["Web UI"]
        end

        subgraph Executor["argoexec (sidecar)"]
            InitContainer["Init Container<br/>(load artifacts)"]
            WaitContainer["Wait Container<br/>(save artifacts, report results)"]
        end
    end

    %% CRDs
    WorkflowCR["Workflow CR"]
    WFTemplateCR["WorkflowTemplate CR"]
    ClusterWFT["ClusterWorkflowTemplate CR"]
    CronWFCR["CronWorkflow CR"]
    TaskResultCR["WorkflowTaskResult CR"]
    TaskSetCR["WorkflowTaskSet CR"]

    %% External Systems
    User["User / DSP API"]
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    S3["S3 / MinIO<br/>9000/TCP"]
    Prometheus["Prometheus"]
    DSPO["Data Science Pipelines<br/>Operator"]

    %% User interactions
    User -->|"creates"| WorkflowCR
    User -->|"HTTPS :2746"| GRPCGW

    %% Controller watches
    WorkflowCR -->|"watched by"| WFReconciler
    CronWFCR -->|"watched by"| CronCtrl
    WFTemplateCR -->|"referenced by"| WFReconciler
    ClusterWFT -->|"referenced by"| WFReconciler

    %% Controller actions
    WFReconciler -->|"creates pods"| K8sAPI
    CronCtrl -->|"creates Workflows"| K8sAPI
    GCCtrl -->|"deletes expired"| K8sAPI
    WFReconciler -->|"archives"| PostgreSQL
    LeaderElection -->|"lease"| K8sAPI

    %% Executor flows
    InitContainer -->|"load artifacts"| S3
    WaitContainer -->|"save artifacts"| S3
    WaitContainer -->|"creates"| TaskResultCR
    TaskResultCR -->|"watched by"| WFReconciler

    %% Server flows
    GRPCGW -->|"delegates auth"| Gatekeeper
    Gatekeeper -->|"OIDC"| SSOAuth
    GRPCGW -->|"queries"| K8sAPI
    GRPCGW -->|"queries archive"| PostgreSQL
    ArtifactSrv -->|"fetches"| S3

    %% Monitoring
    Prometheus -->|"scrapes"| Metrics9090
    Prometheus -->|"scrapes"| GRPCGW

    %% Deployment
    DSPO -.->|"deploys"| Controller
    DSPO -.->|"configures"| Executor

    %% Styling
    style WFReconciler fill:#4a90e2,color:#fff
    style CronCtrl fill:#4a90e2,color:#fff
    style GCCtrl fill:#4a90e2,color:#fff
    style PodCleanup fill:#4a90e2,color:#fff
    style ArtifactGC fill:#4a90e2,color:#fff
    style SyncMgr fill:#4a90e2,color:#fff
    style LeaderElection fill:#4a90e2,color:#fff
    style GRPCGW fill:#5b9bd5,color:#fff
    style Gatekeeper fill:#5b9bd5,color:#fff
    style SSOAuth fill:#5b9bd5,color:#fff
    style ArtifactSrv fill:#5b9bd5,color:#fff
    style WebUI fill:#5b9bd5,color:#fff
    style InitContainer fill:#70ad47,color:#fff
    style WaitContainer fill:#70ad47,color:#fff
    style WorkflowCR fill:#f5a623
    style WFTemplateCR fill:#f5a623
    style ClusterWFT fill:#f5a623
    style CronWFCR fill:#f5a623
    style TaskResultCR fill:#f5a623
    style TaskSetCR fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style PostgreSQL fill:#e8e8e8
    style S3 fill:#e8e8e8
    style DSPO fill:#7ed321,color:#fff
