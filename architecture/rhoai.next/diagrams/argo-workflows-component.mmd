graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB
        subgraph Controller["workflow-controller"]
            WC[Workflow Controller<br/>Go Operator<br/>Port: 9090/TCP metrics<br/>Port: 6060/TCP health]
            CronCtrl[Cron Controller<br/>8 workers]
            TTLCtrl[TTL GC Controller<br/>4 workers]
            PodCleanup[Pod Cleanup<br/>4 workers]
            ArchiveCtrl[Archive Controller<br/>8 workers]
            WorkflowWorkers[Workflow Workers<br/>32 goroutines]
            LeaderElection[Leader Election<br/>via Leases]
        end

        subgraph Executor["argoexec (sidecar)"]
            InitContainer[Init Container<br/>Download artifacts<br/>Stage scripts]
            WaitContainer[Wait/Emissary Sidecar<br/>Monitor execution<br/>Upload artifacts<br/>Report results]
            FIPSBinary[/bin/argoexec-fips<br/>FIPS-compliant]
            NonFIPSBinary[/bin/argoexec<br/>Non-FIPS default]
        end
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions (argoproj.io/v1alpha1)"]
        WorkflowCR[Workflow CR<br/>Namespaced]
        WorkflowTemplateCR[WorkflowTemplate CR<br/>Namespaced]
        ClusterWFTemplate[ClusterWorkflowTemplate CR<br/>Cluster]
        CronWorkflowCR[CronWorkflow CR<br/>Namespaced]
        WFTaskSet[WorkflowTaskSet CR<br/>Namespaced]
        WFTaskResult[WorkflowTaskResult CR<br/>Namespaced]
        WFArtifactGC[WorkflowArtifactGCTask CR<br/>Namespaced]
        WFEventBinding[WorkflowEventBinding CR<br/>Namespaced]
    end

    %% Internal Platform
    subgraph DSP["Data Science Pipelines"]
        DSPOperator[DSP Operator<br/>Deploys controller<br/>Configures argoexec]
        DSPAPIServer[DSP API Server<br/>Creates Workflow CRs]
    end

    %% External Dependencies
    K8sAPI[Kubernetes API Server<br/>443/TCP HTTPS]
    ObjectStorage[S3/MinIO Storage<br/>443/TCP HTTPS]
    Database[(MariaDB/PostgreSQL<br/>3306/5432 TCP)]
    Prometheus[Prometheus<br/>Scrapes 9090/TCP]

    %% Relationships
    DSPOperator -->|deploys & configures| WC
    DSPOperator -->|sets executor image| WaitContainer
    DSPAPIServer -->|creates| WorkflowCR

    WC -->|watches| WorkflowCR
    WC -->|watches| WorkflowTemplateCR
    WC -->|watches| ClusterWFTemplate
    CronCtrl -->|watches| CronWorkflowCR
    CronCtrl -->|creates| WorkflowCR
    WC -->|creates Pods with| InitContainer
    WC -->|creates Pods with| WaitContainer
    TTLCtrl -->|deletes expired| WorkflowCR
    ArchiveCtrl -->|archives to| Database

    WC -->|API calls| K8sAPI
    InitContainer -->|downloads artifacts| ObjectStorage
    WaitContainer -->|uploads artifacts| ObjectStorage
    WaitContainer -->|creates| WFTaskResult

    Prometheus -->|scrapes metrics| WC
    LeaderElection -->|Lease CRs| K8sAPI

