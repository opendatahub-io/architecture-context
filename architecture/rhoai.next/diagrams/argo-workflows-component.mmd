graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI Distribution)"]
        direction TB
        subgraph ControlPlane["Control Plane (DSP Namespace)"]
            Controller["workflow-controller<br/>Go Kubernetes Controller<br/>Metrics: 9090/TCP<br/>Health: 6060/TCP"]
        end

        subgraph WorkflowPods["Workflow Step Pods (Dynamic)"]
            Argoexec["argoexec<br/>Go Sidecar<br/>(FIPS + non-FIPS binaries)"]
            UserContainer["User Container<br/>(ML Pipeline Step)"]
            SharedVol["/var/run/argo/<br/>Shared Volume"]
            Argoexec -->|"manages lifecycle"| UserContainer
            Argoexec -->|"reads/writes artifacts"| SharedVol
            UserContainer -->|"writes outputs"| SharedVol
        end
    end

    subgraph NotShipped["Not Shipped in RHOAI"]
        ArgoServer["argo (CLI/Server)<br/>API Server + Web UI<br/>2746/TCP gRPC/HTTPS"]
    end

    subgraph CRDs["Argo CRDs (argoproj.io/v1alpha1)"]
        WorkflowCR["Workflow CR"]
        CronWorkflowCR["CronWorkflow CR"]
        WorkflowTemplateCR["WorkflowTemplate CR"]
        ClusterWFTemplate["ClusterWorkflowTemplate CR"]
        WorkflowTaskSet["WorkflowTaskSet CR"]
        WorkflowTaskResult["WorkflowTaskResult CR"]
        WorkflowArtifactGC["WorkflowArtifactGCTask CR"]
        WorkflowEventBinding["WorkflowEventBinding CR"]
    end

    subgraph Platform["RHOAI Platform"]
        DSPOperator["Data Science Pipelines<br/>Operator"]
        DSPAPIServer["DSP API Server"]
    end

    subgraph External["External Services"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
        ArtifactStore["Artifact Repository<br/>(S3/MinIO/GCS/Azure)<br/>443/TCP HTTPS"]
        SQLDB["SQL Database<br/>(MySQL/PostgreSQL)<br/>3306/5432/TCP"]
    end

    %% Platform interactions
    DSPOperator -->|"deploys & configures"| Controller
    DSPOperator -->|"configures image ref"| Argoexec
    DSPAPIServer -->|"creates"| WorkflowCR

    %% Controller watches CRDs
    WorkflowCR -->|"watched by"| Controller
    CronWorkflowCR -->|"watched by"| Controller
    WorkflowTemplateCR -->|"watched by"| Controller
    ClusterWFTemplate -->|"watched by"| Controller
    WorkflowTaskSet -->|"watched by"| Controller

    %% Controller creates resources
    Controller -->|"creates Pods"| WorkflowPods
    Controller -->|"CRUD"| K8sAPI
    Controller -->|"archival"| SQLDB

    %% Executor interactions
    Argoexec -->|"upload/download artifacts"| ArtifactStore
    Argoexec -->|"creates"| WorkflowTaskResult
    Argoexec -->|"reads Secrets/ConfigMaps"| K8sAPI

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Argoexec fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style UserContainer fill:#b8d4f0,stroke:#333
    style ArgoServer fill:#cccccc,stroke:#999,stroke-dasharray: 5 5
    style DSPOperator fill:#7ed321,stroke:#333,color:#fff
    style DSPAPIServer fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333
    style ArtifactStore fill:#f5a623,stroke:#333
    style SQLDB fill:#f5a623,stroke:#333
    style WorkflowCR fill:#f5d623,stroke:#333
    style CronWorkflowCR fill:#f5d623,stroke:#333
    style WorkflowTemplateCR fill:#f5d623,stroke:#333
    style ClusterWFTemplate fill:#f5d623,stroke:#333
    style WorkflowTaskSet fill:#f5d623,stroke:#333
    style WorkflowTaskResult fill:#f5d623,stroke:#333
    style WorkflowArtifactGC fill:#f5d623,stroke:#333
    style WorkflowEventBinding fill:#f5d623,stroke:#333
