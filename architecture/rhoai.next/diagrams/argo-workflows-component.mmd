graph TB
    subgraph "Argo Workflows (RHOAI)"
        direction TB
        subgraph Controller["workflow-controller"]
            WFC[Workflow Controller<br/>Go / client-go informers<br/>Port: 9090 metrics, 6060 healthz]
            CronCtrl[Cron Controller<br/>Schedules CronWorkflows]
            ArtifactGC[Artifact GC Controller<br/>Garbage collects artifacts]
            LeaderElect[Leader Election<br/>Lease-based HA]
            WFC --> CronCtrl
            WFC --> ArtifactGC
            WFC --> LeaderElect
        end

        subgraph Executor["argoexec (sidecar/init)"]
            ArgoExec[ArgoExec Binary<br/>Go Executor<br/>Emissary Pattern]
            ArtifactMgr[Artifact Manager<br/>Upload / Download]
            ParamExtract[Parameter Extractor<br/>Output capture]
            ArgoExec --> ArtifactMgr
            ArgoExec --> ParamExtract
        end
    end

    subgraph "CRDs (argoproj.io/v1alpha1)"
        WorkflowCR[Workflow]
        CronWorkflowCR[CronWorkflow]
        WFTemplate[WorkflowTemplate]
        ClusterWFTemplate[ClusterWorkflowTemplate]
        WFTaskSet[WorkflowTaskSet]
        WFTaskResult[WorkflowTaskResult]
        WFArtGCTask[WorkflowArtifactGCTask]
    end

    User[User / DSP Operator] -->|creates| WorkflowCR
    User -->|creates| CronWorkflowCR
    WorkflowCR -->|watched by| WFC
    CronWorkflowCR -->|watched by| CronCtrl
    WFTemplate -->|referenced by| WFC
    ClusterWFTemplate -->|referenced by| WFC

    WFC -->|creates| WorkflowPod[Workflow Pod<br/>main + argoexec sidecar]
    WFC -->|creates/updates| WFTaskSet
    WFC -->|creates| WFArtGCTask

    ArgoExec -->|patches| WFTaskResult
    ArgoExec -->|reads| K8sSecrets[K8s Secrets<br/>Artifact credentials]

    WFC -->|CRUD| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
    ArtifactMgr -->|S3 API| S3[S3 / Minio<br/>443/TCP HTTPS]
    WFC -.->|optional| PostgreSQL[PostgreSQL<br/>5432/TCP]
    WFC -->|metrics| Prometheus[Prometheus<br/>9090/TCP HTTP]

    style WFC fill:#4a90e2,stroke:#333,color:#fff
    style CronCtrl fill:#4a90e2,stroke:#333,color:#fff
    style ArtifactGC fill:#4a90e2,stroke:#333,color:#fff
    style LeaderElect fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExec fill:#50c878,stroke:#333,color:#fff
    style ArtifactMgr fill:#50c878,stroke:#333,color:#fff
    style ParamExtract fill:#50c878,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style CronWorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style WFTemplate fill:#f5a623,stroke:#333,color:#fff
    style ClusterWFTemplate fill:#f5a623,stroke:#333,color:#fff
    style WFTaskSet fill:#f5a623,stroke:#333,color:#fff
    style WFTaskResult fill:#f5a623,stroke:#333,color:#fff
    style WFArtGCTask fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style User fill:#d4edda,stroke:#333
    style WorkflowPod fill:#d4edda,stroke:#333
    style K8sSecrets fill:#e8e8e8,stroke:#333
