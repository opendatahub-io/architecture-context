graph LR
    vllmGaudi["vllm-gaudi<br/>v0.16.0"]

    %% External Dependencies (Required)
    vllmGaudi -->|"plugin framework"| vLLM["vLLM 0.16.0"]
    vllmGaudi -->|"device drivers,<br/>graph compiler"| SynapseAI["Intel Gaudi<br/>SynapseAI 1.23.0"]
    vllmGaudi -->|"HPU backend"| PyTorch["PyTorch<br/>(Habana fork) 2.9.0"]
    vllmGaudi -->|"distributed<br/>workers"| Ray["Ray >=2.48.0"]
    vllmGaudi -->|"model loading,<br/>tokenization"| Transformers["transformers<br/>>=4.56.0"]
    vllmGaudi -->|"runtime"| Python["Python<br/>>=3.9, <3.13"]

    %% External Dependencies (Optional)
    vllmGaudi -.->|"INC FP8<br/>quantization"| NeuralCompressor["Intel Neural<br/>Compressor"]
    vllmGaudi -.->|"KV cache<br/>transfer"| NIXL["NIXL"]

    %% Internal RHOAI Dependencies
    KServe["KServe /<br/>ModelMesh"] -->|"deploys container<br/>as ServingRuntime"| vllmGaudi
    KubeRBAC["kube-rbac-proxy"] -->|"sidecar: auth +<br/>TLS termination"| vllmGaudi
    Dashboard["RHOAI Dashboard"] -->|"UI: runtime<br/>selection"| vllmGaudi
    ModelReg["Model Registry"] -.->|"image reference"| vllmGaudi

    %% External Services (Egress)
    vllmGaudi -->|"model weights<br/>HTTPS/443<br/>HF_TOKEN"| HuggingFace["HuggingFace Hub"]
    vllmGaudi -->|"model artifacts<br/>HTTPS/443<br/>AWS IAM"| S3["S3 Storage"]

    %% Runtime Dependencies
    vllmGaudi -->|"collective comms<br/>RDMA/TCP"| HCCL["HCCL<br/>(Habana CCL)"]
    vllmGaudi -->|"media loading"| HabanaMedia["habana-media-<br/>loader 1.23.0"]

    %% Styling
    style vllmGaudi fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style vLLM fill:#999,stroke:#333,color:#fff
    style SynapseAI fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style Python fill:#999,stroke:#333,color:#fff
    style HCCL fill:#999,stroke:#333,color:#fff
    style HabanaMedia fill:#999,stroke:#333,color:#fff

    %% External optional
    style NeuralCompressor fill:#bbb,stroke:#333,stroke-dasharray:5 5
    style NIXL fill:#bbb,stroke:#333,stroke-dasharray:5 5

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
