graph LR
    VllmGaudi["vllm-gaudi Plugin<br/>(HPU Platform Plugin)"]

    %% Core Runtime Dependencies
    VllmGaudi -->|"extends via<br/>entry points"| VllmCore["vLLM v0.16.0"]
    VllmGaudi -->|"hardware driver<br/>Synapse API"| SynapseAI["Habana Synapse AI<br/>1.23.0"]
    VllmGaudi -->|"HPU device support<br/>lazy/eager mode"| PyTorchHabana["PyTorch for Habana<br/>2.9.0"]
    VllmGaudi -->|"media loading"| MediaLoader["habana-media-loader<br/>1.23.0.x"]

    %% Distributed Dependencies
    VllmGaudi -->|"multi-worker<br/>orchestration"| Ray["Ray >=2.48.0"]
    VllmGaudi -.->|"KV cache transfer<br/>RDMA/TCP"| NIXL["NIXL<br/>(Disaggregated Serving)"]

    %% ML Framework Dependencies
    VllmGaudi -->|"model loading<br/>tokenization"| Transformers["transformers<br/>>=4.56.0, <5"]
    VllmGaudi -->|"numerical<br/>computing"| NumPy["numpy >=1.26.0"]
    VllmGaudi -->|"JIT compilation"| Numba["numba >=0.58.0"]
    VllmGaudi -->|"data handling"| Pandas["pandas >=2.2.3"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe / ModelMesh"] -->|"deploys as<br/>InferenceService runtime"| VllmGaudi
    RHOAIOp["RHOAI Operator<br/>(rhods-operator)"] -->|"references in<br/>ServingRuntime CRs"| VllmGaudi

    %% External Services
    VllmGaudi -->|"model weights<br/>HTTPS/443"| S3["S3 / PVC<br/>(Model Storage)"]
    VllmGaudi -->|"model configs<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Styling
    style VllmGaudi fill:#4a90e2,stroke:#333,stroke-width:4px

    %% Core runtime (purple)
    style VllmCore fill:#9b59b6,stroke:#333
    style SynapseAI fill:#9b59b6,stroke:#333
    style PyTorchHabana fill:#9b59b6,stroke:#333
    style MediaLoader fill:#9b59b6,stroke:#333

    %% Distributed (orange)
    style Ray fill:#e67e22,stroke:#333
    style NIXL fill:#e67e22,stroke:#333

    %% ML frameworks (grey)
    style Transformers fill:#999,stroke:#333
    style NumPy fill:#999,stroke:#333
    style Numba fill:#999,stroke:#333
    style Pandas fill:#999,stroke:#333

    %% Internal RHOAI (green)
    style KServe fill:#7ed321,stroke:#333
    style RHOAIOp fill:#7ed321,stroke:#333

    %% External services (yellow)
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
