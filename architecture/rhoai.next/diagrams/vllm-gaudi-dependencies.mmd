graph LR
    VllmGaudi["vLLM Gaudi Plugin<br/>(odh-vllm-gaudi-rhel9)"]

    %% Core Framework Dependency
    VllmGaudi -->|"plugin entry points<br/>vllm.platform_plugins<br/>vllm.general_plugins"| vLLM["vLLM 0.16.0"]

    %% Hardware Dependencies (Required)
    VllmGaudi -->|"device driver<br/>graph compiler"| SynapseAI["Intel SynapseAI<br/>Runtime 1.23.0"]
    VllmGaudi -->|"FusedSDPA<br/>mark_step"| HabanaTorch["habana-torch-plugin<br/>1.23.0"]
    VllmGaudi -->|"image preprocessing<br/>vision models"| HabanaMedia["habana-media-loader<br/>1.23.0"]
    VllmGaudi -->|"HPU backend<br/>forked build"| PyTorch["PyTorch 2.9.0"]

    %% ML Framework Dependencies (Required)
    VllmGaudi -->|"model loading<br/>tokenization"| Transformers["transformers<br/>>=4.56.0, <5"]
    VllmGaudi -->|"multi-node<br/>distributed"| Ray["Ray >=2.48.0"]

    %% Optional Dependencies
    VllmGaudi -.->|"KV cache<br/>disaggregation"| NIXL["NIXL<br/>(optional)"]

    %% Internal RHOAI Dependencies
    KServe["KServe /<br/>ModelMesh"] -->|"deploys as<br/>ServingRuntime"| VllmGaudi
    Dashboard["RHOAI Dashboard"] -->|"runtime selection<br/>configuration"| KServe
    Controller["RHOAI Model<br/>Controller"] -->|"lifecycle<br/>management"| KServe

    %% External Service Dependencies
    VllmGaudi -->|"model weights<br/>HTTPS/443"| S3["S3 / MinIO<br/>Storage"]
    VllmGaudi -->|"models & tokenizers<br/>HTTPS/443"| HF["Hugging Face Hub"]

    %% Hardware
    VllmGaudi -->|"SynapseAI HAL<br/>inference execution"| Gaudi["Intel Gaudi 2/3<br/>Accelerator"]

    %% Runtime Communication
    VllmGaudi -->|"HCCL protocol<br/>tensor parallelism"| PeerWorkers["Peer HPU Workers"]
    VllmGaudi -->|"Ray protocol<br/>6379/TCP"| RayHead["Ray Head Node"]

