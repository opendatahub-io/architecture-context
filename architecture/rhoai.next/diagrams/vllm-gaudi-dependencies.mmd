graph LR
    VllmGaudi["vLLM Gaudi Plugin<br/>(odh-vllm-gaudi-rhel9)"]

    %% External Dependencies (Required)
    VllmGaudi -->|"base framework<br/>v0.16.0"| VllmUpstream["vLLM v0.16.0"]
    VllmGaudi -->|"device drivers<br/>graph compiler"| SynapseAI["Intel Gaudi<br/>SynapseAI v1.23.0"]
    VllmGaudi -->|"torch bridge<br/>FusedSDPA, HPU graphs"| HabanaTorch["habana-torch-plugin<br/>v1.23.0"]
    VllmGaudi -->|"image preprocessing<br/>vision models"| HabanaMedia["habana-media-loader<br/>v1.23.0"]
    VllmGaudi -->|"deep learning<br/>framework"| PyTorch["PyTorch 2.9.0<br/>(Gaudi fork)"]
    VllmGaudi -->|"distributed<br/>execution"| Ray["Ray >=2.48.0"]
    VllmGaudi -->|"model loading<br/>tokenization"| Transformers["transformers<br/>>=4.56.0, <5"]
    VllmGaudi -.->|"KV cache<br/>disaggregation"| NIXL["NIXL<br/>(optional)"]

    %% Internal RHOAI Platform Dependencies
    VllmGaudi -->|"deployed as<br/>ServingRuntime"| KServe["KServe /<br/>ModelMesh"]
    VllmGaudi -.->|"runtime selection<br/>UI"| Dashboard["RHOAI Dashboard"]
    VllmGaudi -.->|"lifecycle<br/>management"| ModelCtrl["RHOAI Model<br/>Controller"]

    %% External Services
    VllmGaudi -->|"model weights<br/>HTTPS/443"| S3["S3 / MinIO<br/>Storage"]
    VllmGaudi -->|"models & configs<br/>HTTPS/443"| HF["Hugging Face<br/>Hub"]

    %% Integration Points (consumers of vllm-gaudi)
    Dashboard -->|"selects runtime"| VllmGaudi
    ModelCtrl -->|"scales instances"| VllmGaudi

    %% Kubernetes
    VllmGaudi -->|"API server<br/>pod lifecycle"| K8sAPI["Kubernetes API"]

    %% Styling
    style VllmGaudi fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies
    style VllmUpstream fill:#999,stroke:#333,color:#fff
    style SynapseAI fill:#666,stroke:#333,color:#fff
    style HabanaTorch fill:#666,stroke:#333,color:#fff
    style HabanaMedia fill:#666,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style NIXL fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HF fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
