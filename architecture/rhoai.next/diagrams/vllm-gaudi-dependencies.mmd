graph LR
    VllmGaudi["vllm-gaudi<br/>HPU Plugin"]

    %% Core Runtime Dependencies (Required)
    VllmGaudi -->|"plugin framework<br/>v0.16.0"| VLLMCore["vLLM Core<br/>v0.16.0"]
    VllmGaudi -->|"HPU drivers<br/>v1.23.0"| SynapseAI["Intel SynapseAI<br/>v1.23.0"]
    VllmGaudi -->|"tensor ops<br/>v2.9.0"| PyTorch["PyTorch (Habana)<br/>v2.9.0"]
    VllmGaudi -->|"distributed exec<br/>>=2.48.0"| Ray["Ray<br/>>=2.48.0"]
    VllmGaudi -->|"model loading<br/>>=4.56.0"| Transformers["HuggingFace<br/>Transformers"]

    %% Supporting Libraries (Required)
    VllmGaudi -->|"data ops"| Pandas["pandas<br/>>=2.2.3"]
    VllmGaudi -->|"JIT compile"| Numba["numba<br/>>=0.58.0"]
    VllmGaudi -->|"numerical"| NumPy["numpy<br/>>=1.26.0"]
    VllmGaudi -->|"image pipeline"| MediaLoader["habana-media-loader<br/>v1.23.0.x"]

    %% Optional Dependencies
    VllmGaudi -.->|"INC FP8 quant"| NeuralCompressor["neural_compressor<br/>(optional)"]
    VllmGaudi -.->|"KV cache transfer<br/>v0.7.0"| NIXL["NIXL<br/>v0.7.0 (optional)"]
    NIXL -.->|"RDMA transport"| UCX["UCX + gaudi_gdr<br/>(optional)"]

    %% Internal Platform Dependencies
    KServe["KServe"] -->|"deploys as<br/>ServingRuntime"| VllmGaudi
    Dashboard["RHOAI Dashboard"] -->|"image reference<br/>runtime selection"| VllmGaudi
    ModelStorage["Model Storage<br/>(S3 / PVC)"] -->|"model weights<br/>volume mount"| VllmGaudi

    %% External Services (Runtime Egress)
    VllmGaudi -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    VllmGaudi -->|"model download<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]

    %% Styling
    style VllmGaudi fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style VLLMCore fill:#999,stroke:#333,color:#fff
    style SynapseAI fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style Ray fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style Pandas fill:#999,stroke:#333,color:#fff
    style Numba fill:#999,stroke:#333,color:#fff
    style NumPy fill:#999,stroke:#333,color:#fff
    style MediaLoader fill:#999,stroke:#333,color:#fff

    %% Optional deps
    style NeuralCompressor fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style NIXL fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style UCX fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff

    %% Internal platform
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
