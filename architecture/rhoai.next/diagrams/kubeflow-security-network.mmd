graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>HTTPRoute: /notebook/{ns}/{name}"]
    end

    subgraph PodAuth["POD-LEVEL AUTH (Per-Notebook)"]
        direction TB

        subgraph NotebookPod["Notebook Pod - Namespace: {user-namespace}"]
            RBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS (service-ca cert)<br/>SubjectAccessReview"]
            Jupyter["Jupyter Server<br/>8888/TCP<br/>No direct external access"]
        end
    end

    subgraph ControllerPlane["CONTROLLER PLANE (Platform Namespace)"]
        direction TB
        KFCtrl["kf-notebook-controller<br/>SA: notebook-controller-service-account<br/>8080/TCP metrics (no TLS)<br/>8081/TCP health"]
        ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>8080/TCP metrics (TLS 1.2+)<br/>8081/TCP health<br/>8443/TCP webhook (TLS)"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP<br/>TLS 1.2+<br/>SA tokens + mTLS"]
    end

    subgraph InternalSvcs["INTERNAL SERVICES"]
        OpenShiftAPI["OpenShift API<br/>config.openshift.io<br/>6443/TCP HTTPS<br/>Proxy config, TLS profile"]
        ServiceCA["OpenShift Service CA<br/>Annotation-triggered<br/>Auto-generates TLS certs"]
    end

    %% External access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (gateway)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Proxied auth"| RBACProxy
    RBACProxy -->|"SubjectAccessReview<br/>6443/TCP HTTPS"| K8sAPI
    RBACProxy -->|"HTTP/8888<br/>No TLS (localhost)<br/>Pre-authenticated"| Jupyter

    %% Controller to API
    KFCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (Bearer)"| K8sAPI
    ODHCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (Bearer)"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/8443<br/>TLS (service-ca)<br/>mTLS (API server cert)"| ODHCtrl

    %% Idle culling
    KFCtrl -.->|"HTTP/8888<br/>No TLS (in-cluster)<br/>No auth"| Jupyter

    %% OpenShift integration
    ODHCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| OpenShiftAPI
    ServiceCA -.->|"Annotation-triggered<br/>cert generation"| RBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podauth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class RBACProxy,Jupyter podauth
    class KFCtrl,ODHCtrl controller
    class K8sAPI k8s
    class OpenShiftAPI,ServiceCA internal
