graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser / kubectl / Dashboard"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → variable<br/>TLS SIMPLE termination"]
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: opendatahub)"]
        direction TB

        subgraph KFCtrl["kf-notebook-controller"]
            KFController["KF Controller<br/>SA: notebook-controller-service-account<br/>Health: 8081/TCP HTTP"]
        end

        subgraph ODHCtrl["odh-notebook-controller"]
            ODHController["ODH Controller<br/>SA: odh-notebook-controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
            Webhook["Webhook Server<br/>/mutate-notebook-v1<br/>/validate-notebook-v1<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert"]
        end
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph NotebookPod["Notebook Pod (StatefulSet)"]
            KRBP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS: serving cert<br/>Auth: SubjectAccessReview"]
            Notebook["Jupyter Container<br/>8888/TCP HTTP<br/>localhost only from KRBP"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token (Bearer)"]
        ImageRegistry["OpenShift Image Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
        DSPA["DSPA Instance<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
        MLflow["MLflow Operator<br/>ClusterRole reference"]
        Feast["Feast<br/>ConfigMap mount"]
        ClusterProxy["OpenShift Proxy<br/>config.openshift.io"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway

    %% Ingress → Notebook (Auth path)
    Gateway -->|"HTTPS/8443<br/>TLS (serving cert)<br/>Gateway-forwarded identity<br/>HTTPRoute: nb-{ns}-{name}"| KRBP

    %% kube-rbac-proxy → K8s API (SubjectAccessReview)
    KRBP -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReview"| K8sAPI

    %% kube-rbac-proxy → Notebook (localhost)
    KRBP -->|"HTTP/8888<br/>No encryption<br/>localhost 127.0.0.1<br/>X-Auth-Request headers"| Notebook

    %% K8s API → Webhook
    K8sAPI -->|"HTTPS/8443<br/>TLS (serving cert)<br/>API server internal"| Webhook

    %% KF Controller → K8s API
    KFController -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>CR, StatefulSet, Service"| K8sAPI

    %% KF Controller → Notebook (idle culling)
    KFController -.->|"HTTP/8888<br/>No encryption<br/>No auth<br/>/api/kernels, /api/terminals"| Notebook

    %% ODH Controller → K8s API
    ODHController -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>HTTPRoute, NetworkPolicy,<br/>ReferenceGrant, RBAC"| K8sAPI

    %% ODH Controller → External Services
    ODHController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| DSPA
    ODHController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| ImageRegistry
    ODHController -.->|"ClusterRole ref"| MLflow
    ODHController -.->|"ConfigMap mount"| Feast
    ODHController -.->|"CRD Read"| ClusterProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KFController,ODHController,Webhook controlplane
    class KRBP security
    class Notebook userns
    class K8sAPI,ImageRegistry,DSPA,MLflow,Feast,ClusterProxy platform
