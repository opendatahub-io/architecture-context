graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User Browser / API Client"]
    end

    subgraph Ingress["INGRESS (openshift-ingress namespace)"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP → backend<br/>TLS 1.3 SIMPLE termination<br/>HTTPRoute path: /notebook/{ns}/{name}"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER (per-notebook sidecar)"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (OpenShift service-ca cert)<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph UserNS["WORKLOAD (user namespace)"]
        direction TB
        NB["Notebook Container (Jupyter)<br/>8888/TCP HTTP<br/>NetworkPolicy: ingress from controller ns only"]
        SvcNB["Service: {name}<br/>ClusterIP 80→8888"]
        SvcKRBP["Service: {name}-kube-rbac-proxy<br/>ClusterIP 8443→8443"]
        NetPol1["NetworkPolicy<br/>8888: controller ns only<br/>8443: all (proxy enforces auth)"]
    end

    subgraph ControllerNS["CONTROLLER PLANE (redhat-ods-applications)"]
        direction TB
        KFCtrl["notebook-controller<br/>SA: notebook-controller-service-account<br/>8080/TCP metrics, 8081/TCP health"]
        ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>8080/TCP metrics, 8081/TCP health<br/>8443/TCP webhook (HTTPS)"]
        HTTPRoute["HTTPRoute: nb-{ns}-{name}<br/>(parentRef → gateway)"]
        RefGrant["ReferenceGrant<br/>(cross-namespace authorization)"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA token auth"]
        ImageReg["OpenShift Image Registry<br/>443/TCP HTTPS<br/>ImageStream resolution"]
        ServiceCA["OpenShift Service CA<br/>Auto TLS cert provisioning"]
        DSPA["Data Science Pipelines<br/>443/TCP HTTPS<br/>Elyra config"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>Metrics scrape"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>No auth (TLS termination)"| Gateway

    %% Ingress → Auth Layer
    Gateway -->|"HTTPS/8443<br/>TLS (service cert)<br/>Forwarded headers"| KRBP

    %% Auth verification
    KRBP -->|"HTTPS/443<br/>TLS 1.2+<br/>TokenReview"| K8sAPI
    KRBP -->|"HTTPS/443<br/>TLS 1.2+<br/>SubjectAccessReview"| K8sAPI

    %% Auth → Notebook
    KRBP -->|"HTTP/8888<br/>No encryption (localhost)<br/>X-Auth-Request-User"| NB

    %% Controller → K8s API
    KFCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller → Notebook (culler)
    KFCtrl -->|"HTTP/8888<br/>No encryption<br/>Idle polling"| NB

    %% ODH Controller integrations
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| ImageReg
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| DSPA

    %% HTTPRoute references
    HTTPRoute -.->|"parentRef"| Gateway
    RefGrant -.->|"authorizes"| HTTPRoute

    %% Prometheus
    Prometheus -->|"HTTP/8080<br/>Metrics scrape"| KFCtrl
    Prometheus -->|"HTTP/8080<br/>Metrics scrape"| ODHCtrl

    %% Service CA
    ServiceCA -.->|"provisions certs"| KRBP
    ServiceCA -.->|"provisions certs"| ODHCtrl

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class KRBP auth
    class NB,SvcNB,SvcKRBP,NetPol1 workload
    class KFCtrl,ODHCtrl,HTTPRoute,RefGrant controller
    class K8sAPI,ImageReg,ServiceCA,DSPA,Prometheus platform
