graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        direction TB

        subgraph RestProxySidecar["rest-proxy Sidecar"]
            RestProxy["rest-proxy<br/>(gRPC-Gateway)<br/>Go Service"]
            HTTPListener["HTTP/HTTPS Listener<br/>8008/TCP"]
            CustomMarshaler["CustomJSONPb<br/>Marshaler/Unmarshaler"]
            TensorHandler["Tensor Data Handler<br/>13 data types<br/>(BOOL, INT8-64, UINT8-64,<br/>FP16/32/64, BYTES)"]
            GRPCClient["gRPC Client<br/>GRPCInferenceService"]

            HTTPListener --> RestProxy
            RestProxy --> CustomMarshaler
            CustomMarshaler --> TensorHandler
            RestProxy --> GRPCClient
        end

        subgraph InferenceServer["Inference Server Container"]
            GRPCSrv["gRPC Inference Server<br/>8033/TCP"]
        end

        GRPCClient -->|"gRPC/8033<br/>localhost<br/>TLS optional"| GRPCSrv
    end

    Client["Client<br/>(REST)"] -->|"HTTP/HTTPS<br/>8008/TCP<br/>TLS optional"| HTTPListener

    subgraph RESTAPI["KServe V2 REST API"]
        EP1["GET /v2/models/{name}"]
        EP2["GET /v2/models/{name}/versions/{version}"]
        EP3["POST /v2/models/{name}/infer"]
        EP4["POST /v2/models/{name}/versions/{version}/infer"]
    end

    Client --> RESTAPI
    RESTAPI --> HTTPListener

    ConfigMap["model-serving-config<br/>ConfigMap"]
    ModelMesh["ModelMesh Serving<br/>Controller"] -->|"reads restProxy.image"| ConfigMap
    ConfigMap -.->|"configures sidecar image"| RestProxySidecar

    style RestProxy fill:#4a90e2,color:#fff
    style HTTPListener fill:#4a90e2,color:#fff
    style CustomMarshaler fill:#4a90e2,color:#fff
    style TensorHandler fill:#4a90e2,color:#fff
    style GRPCClient fill:#4a90e2,color:#fff
    style GRPCSrv fill:#7ed321,color:#fff
    style Client fill:#f5a623,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#999
    style ModelMesh fill:#7ed321,color:#fff
    style EP1 fill:#fff3e0,stroke:#f5a623
    style EP2 fill:#fff3e0,stroke:#f5a623
    style EP3 fill:#fff3e0,stroke:#f5a623
    style EP4 fill:#fff3e0,stroke:#f5a623
