graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        subgraph RestProxy["rest-proxy (Sidecar)"]
            HTTPListener["HTTP/HTTPS Listener<br/>8008/TCP"]
            JSONDecoder["CustomJSONPb Decoder<br/>JSON → Protobuf"]
            JSONEncoder["CustomJSONPb Encoder<br/>Protobuf → JSON"]
            GRPCClient["gRPC Client<br/>GRPCInferenceService"]

            HTTPListener -->|"incoming request"| JSONDecoder
            JSONDecoder -->|"protobuf message"| GRPCClient
            GRPCClient -->|"protobuf response"| JSONEncoder
            JSONEncoder -->|"JSON response"| HTTPListener
        end

        ModelMesh["ModelMesh gRPC Service<br/>8033/TCP"]
    end

    Client[External Client] -->|"REST V2 Predict Protocol<br/>8008/TCP HTTP/HTTPS"| HTTPListener
    GRPCClient -->|"gRPC V2 Predict Protocol<br/>8033/TCP (localhost)"| ModelMesh

    subgraph APIs["KServe V2 REST API"]
        direction LR
        GetModel["GET /v2/models/{name}"]
        GetModelVer["GET /v2/models/{name}/versions/{ver}"]
        Infer["POST /v2/models/{model}/infer"]
        InferVer["POST /v2/models/{model}/versions/{ver}/infer"]
    end

    Client -->|"uses"| APIs

    subgraph TensorTypes["Supported Tensor Types"]
        direction LR
        Types["BOOL | INT8-64 | UINT8-64<br/>FP32 | FP64 | BYTES"]
    end

    JSONDecoder -.->|"transforms"| TensorTypes

    %% Styling
    style RestProxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style HTTPListener fill:#5ba3f5,stroke:#333,color:#fff
    style JSONDecoder fill:#5ba3f5,stroke:#333,color:#fff
    style JSONEncoder fill:#5ba3f5,stroke:#333,color:#fff
    style GRPCClient fill:#5ba3f5,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style ModelMeshPod fill:#e8f5e9,stroke:#82b366,stroke-width:2px
    style APIs fill:#fff3e0,stroke:#ff9800
    style TensorTypes fill:#f3e5f5,stroke:#9c27b0
