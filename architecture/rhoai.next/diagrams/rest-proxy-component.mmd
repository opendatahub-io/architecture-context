graph TB
    subgraph "ModelMesh Serving Pod"
        subgraph "rest-proxy Sidecar"
            HTTPListener["HTTP Listener<br/>Port 8008/TCP<br/>Optional TLS"]
            GatewayStubs["grpc-gateway<br/>Generated Stubs"]
            CustomMarshaler["Custom JSON Marshaler<br/>(CustomJSONPb)"]
            GRPCClient["gRPC Client"]

            HTTPListener -->|"incoming REST request"| GatewayStubs
            GatewayStubs -->|"decode JSON"| CustomMarshaler
            CustomMarshaler -->|"protobuf message"| GRPCClient
        end

        subgraph "ModelMesh gRPC Server"
            InferenceService["GRPCInferenceService<br/>Port 8033/TCP"]
        end

        GRPCClient -->|"gRPC V2 Predict Protocol<br/>localhost:8033"| InferenceService
        InferenceService -->|"gRPC response"| GRPCClient
    end

    Client["External Client<br/>(via ModelMesh Service)"] -->|"POST /v2/models/{name}/infer<br/>GET /v2/models/{name}<br/>HTTP/HTTPS 8008/TCP"| HTTPListener

    KServeV2["KServe V2 REST<br/>Predict Protocol"] -.-|"API conformance"| HTTPListener
    ConfigMap["model-serving-config<br/>ConfigMap"] -.-|"rest-proxy image<br/>configuration"| HTTPListener

    style HTTPListener fill:#4a90e2,stroke:#333,color:#fff
    style GatewayStubs fill:#4a90e2,stroke:#333,color:#fff
    style CustomMarshaler fill:#4a90e2,stroke:#333,color:#fff
    style GRPCClient fill:#4a90e2,stroke:#333,color:#fff
    style InferenceService fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style KServeV2 fill:#e8e8e8,stroke:#999
    style ConfigMap fill:#e8e8e8,stroke:#999
