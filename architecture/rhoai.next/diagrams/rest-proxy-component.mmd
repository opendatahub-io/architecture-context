graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        subgraph RestProxy["rest-proxy Sidecar"]
            HTTPListener["HTTP Listener<br/>:8008/TCP<br/>HTTP or HTTPS"]
            GatewayCode["gRPC-Gateway<br/>(generated from proto)"]
            Marshaler["Custom Marshaler<br/>JSON ↔ Protobuf<br/>Tensor Data Handling"]
            GRPCClient["gRPC Client<br/>GRPCInferenceService"]

            HTTPListener -->|routes request| GatewayCode
            GatewayCode -->|marshals payload| Marshaler
            Marshaler -->|serialized protobuf| GRPCClient
        end

        subgraph ModelMeshInference["ModelMesh Inference Service"]
            GRPCServer["gRPC Server<br/>:8033/TCP"]
        end

        GRPCClient -->|gRPC call<br/>Optional TLS| GRPCServer
        GRPCServer -->|gRPC response| GRPCClient
    end

    subgraph ProtoDefinition["Protocol Definition"]
        Proto["grpc_predict_v2.proto<br/>KServe V2 Inference Protocol"]
        GenCode["gen/<br/>Generated Stubs + Gateway"]
        Proto -->|protoc + grpc-gateway| GenCode
        GenCode -->|compiled into| GatewayCode
    end

    Client["External Client<br/>(REST/HTTP)"] -->|"POST /v2/models/{name}/infer<br/>GET /v2/models/{name}<br/>8008/TCP"| HTTPListener

    TLSCert["TLS Cert/Key<br/>(MM_TLS_KEY_CERT_PATH)"] -.->|optional TLS| HTTPListener
    TLSConfig["REST_PROXY_USE_TLS<br/>env var"] -.->|optional TLS| GRPCClient

    style HTTPListener fill:#4a90e2,stroke:#333,color:#fff
    style GatewayCode fill:#4a90e2,stroke:#333,color:#fff
    style Marshaler fill:#4a90e2,stroke:#333,color:#fff
    style GRPCClient fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#7ed321,stroke:#333,color:#fff
    style Proto fill:#f5a623,stroke:#333,color:#fff
    style GenCode fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style TLSConfig fill:#fff2cc,stroke:#d6b656
