graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        direction TB

        subgraph RestProxySidecar["rest-proxy Sidecar"]
            GatewayMux["gRPC-Gateway Mux<br/>HTTP Router"]
            CustomMarshaler["Custom JSON Marshaler<br/>(KServe V2 Tensor Types)"]
            GRPCClient["gRPC Client<br/>(GRPCInferenceService)"]

            GatewayMux -->|"unmarshal JSON<br/>request body"| CustomMarshaler
            CustomMarshaler -->|"protobuf<br/>message"| GRPCClient
        end

        subgraph ModelMeshContainer["ModelMesh gRPC Server"]
            InferenceService["GRPCInferenceService<br/>8033/TCP gRPC"]
        end

        GRPCClient -->|"gRPC/8033<br/>Configurable TLS"| InferenceService
        InferenceService -->|"gRPC response"| GRPCClient
    end

    Client["External Client<br/>(REST)"] -->|"HTTP/HTTPS<br/>8008/TCP<br/>Configurable TLS"| GatewayMux

    GRPCClient -->|"protobuf<br/>response"| CustomMarshaler
    CustomMarshaler -->|"JSON response"| GatewayMux
    GatewayMux -->|"HTTP/HTTPS<br/>response"| Client

    subgraph ConfigSources["Configuration"]
        ConfigMap["model-serving-config<br/>ConfigMap"]
        TLSCerts["TLS Certificates<br/>(cert/key mount)"]
        EnvVars["Environment Variables<br/>REST_PROXY_LISTEN<br/>REST_PROXY_GRPC_PORT<br/>REST_PROXY_USE_TLS"]
    end

    ConfigMap -.->|"restProxy.image<br/>sidecar injection"| RestProxySidecar
    TLSCerts -.->|"MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"| RestProxySidecar
    EnvVars -.->|"runtime config"| RestProxySidecar

    MMController["modelmesh-serving<br/>Controller"] -->|"injects sidecar"| RestProxySidecar

    style RestProxySidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ModelMeshContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style GatewayMux fill:#5ba3e6,stroke:#333,color:#fff
    style CustomMarshaler fill:#5ba3e6,stroke:#333,color:#fff
    style GRPCClient fill:#5ba3e6,stroke:#333,color:#fff
    style InferenceService fill:#82c944,stroke:#333
    style Client fill:#f5a623,stroke:#333,stroke-width:2px
    style MMController fill:#9b59b6,stroke:#333,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#333
    style TLSCerts fill:#e8e8e8,stroke:#333
    style EnvVars fill:#e8e8e8,stroke:#333
