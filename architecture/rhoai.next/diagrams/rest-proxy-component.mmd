graph TB
    subgraph ModelMeshPod["ModelMesh Serving Pod"]
        direction TB

        subgraph RestProxy["rest-proxy Sidecar"]
            direction TB
            HTTPListener["HTTP Listener<br/>8008/TCP<br/>Optional TLS"]
            GatewayCode["gRPC-Gateway<br/>(generated from proto)"]
            Marshaler["Custom Marshaler<br/>JSON ↔ Tensor<br/>(marshaler.go, request.go, bytes.go)"]

            HTTPListener -->|routes requests| GatewayCode
            GatewayCode -->|transforms payload| Marshaler
        end

        subgraph ModelMesh["ModelMesh Inference Service"]
            GRPCServer["gRPC Server<br/>8033/TCP<br/>GRPCInferenceService"]
        end

        Marshaler -->|gRPC call| GRPCServer
    end

    Proto["grpc_predict_v2.proto<br/>(KServe V2 Protocol)"] -.->|protoc generates| GatewayCode
    Proto -.->|protoc generates| GenCode["gen/<br/>pb.go + pb.gw.go + grpc.pb.go"]
    GenCode -.->|compiled into| GatewayCode

    Client["REST Client"] -->|"POST /v2/models/{name}/infer<br/>GET /v2/models/{name}<br/>HTTP/HTTPS"| HTTPListener
    GRPCServer -->|"gRPC Response"| Marshaler
    Marshaler -->|"JSON Response"| HTTPListener
    HTTPListener -->|"HTTP/HTTPS Response"| Client

    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"restProxy.image<br/>sidecar injection"| RestProxy

    style HTTPListener fill:#4a90e2,color:#fff
    style GatewayCode fill:#4a90e2,color:#fff
    style Marshaler fill:#4a90e2,color:#fff
    style GRPCServer fill:#7ed321,color:#fff
    style Proto fill:#f5a623,color:#fff
    style GenCode fill:#f5a623,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style ConfigMap fill:#e8e8e8,stroke:#333
