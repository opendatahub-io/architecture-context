graph TB
    subgraph "ModelMesh Serving Pod"
        subgraph "rest-proxy Sidecar"
            HTTPListener["HTTP Listener<br/>Port 8008/TCP<br/>KServe V2 REST API"]
            GatewayCode["gRPC-Gateway<br/>(generated from proto)"]
            Marshaler["Custom Marshaler<br/>JSON ↔ Tensor<br/>marshaler.go / request.go / bytes.go"]
            GRPCClient["gRPC Client<br/>google.golang.org/grpc"]

            HTTPListener -->|"REST request"| GatewayCode
            GatewayCode -->|"marshal/unmarshal"| Marshaler
            GatewayCode -->|"translated call"| GRPCClient
        end

        subgraph "ModelMesh Inference Service"
            GRPCServer["GRPCInferenceService<br/>Port 8033/TCP<br/>KServe V2 gRPC Protocol"]
        end

        GRPCClient -->|"gRPC (localhost)"| GRPCServer
        GRPCServer -->|"gRPC response"| GRPCClient
    end

    Client["REST Client<br/>(Data Scientist / Application)"] -->|"POST /v2/models/{name}/infer<br/>GET /v2/models/{name}<br/>HTTP/HTTPS 8008/TCP"| HTTPListener

    Proto["grpc_predict_v2.proto<br/>KServe V2 Protocol Definition"] -.->|"protoc generates"| GatewayCode
    Proto -.->|"protoc generates"| GRPCClient

    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"restProxy.image<br/>sidecar injection"| HTTPListener

    style HTTPListener fill:#4a90e2,color:#fff
    style GatewayCode fill:#4a90e2,color:#fff
    style Marshaler fill:#4a90e2,color:#fff
    style GRPCClient fill:#4a90e2,color:#fff
    style GRPCServer fill:#7ed321,color:#fff
    style Client fill:#f5a623,color:#fff
    style Proto fill:#e8e8e8,color:#333
    style ConfigMap fill:#e8e8e8,color:#333
