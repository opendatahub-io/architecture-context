graph TB
    subgraph "ModelMesh Serving Pod"
        subgraph "rest-proxy Sidecar"
            HTTPListener["HTTP Listener<br/>8008/TCP<br/>Optional TLS"]
            CustomJSON["CustomJSONPb<br/>Marshaler/Unmarshaler"]
            GRPCGateway["grpc-gateway<br/>HTTP-to-gRPC Translation"]
            GRPCClient["gRPC Client<br/>GRPCInferenceService"]

            HTTPListener -->|"JSON request"| CustomJSON
            CustomJSON -->|"decoded tensor data"| GRPCGateway
            GRPCGateway -->|"protobuf message"| GRPCClient
        end

        ModelMesh["ModelMesh gRPC Server<br/>8033/TCP"]
        GRPCClient -->|"gRPC V2 Predict Protocol<br/>localhost:8033"| ModelMesh
        ModelMesh -->|"gRPC response"| GRPCClient
    end

    Client["REST Client<br/>(Data Scientist / Application)"]
    Client -->|"POST /v2/models/{name}/infer<br/>GET /v2/models/{name}<br/>HTTP/HTTPS 8008/TCP"| HTTPListener

    KServeV2["KServe V2 Predict Protocol<br/>(API Specification)"]
    KServeV2 -.->|"conforms to"| HTTPListener

    ConfigMap["model-serving-config<br/>ConfigMap"]
    ConfigMap -.->|"restProxy.image<br/>configuration"| HTTPListener

    style HTTPListener fill:#4a90e2,stroke:#333,color:#fff
    style CustomJSON fill:#4a90e2,stroke:#333,color:#fff
    style GRPCGateway fill:#4a90e2,stroke:#333,color:#fff
    style GRPCClient fill:#4a90e2,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333,color:#fff
    style KServeV2 fill:#e8e8e8,stroke:#999
    style ConfigMap fill:#e8e8e8,stroke:#999
