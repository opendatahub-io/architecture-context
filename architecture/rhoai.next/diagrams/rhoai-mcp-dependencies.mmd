graph LR
    %% RHOAI MCP Server - Component Dependency Graph
    %% Generated from: architecture/rhoai.next/rhoai-mcp.md

    MCP["RHOAI MCP Server<br/>(FastMCP + pluggy)"]

    %% External Library Dependencies
    subgraph ExtLibs["External Libraries (Python)"]
        FastMCP["mcp ≥1.0.0<br/>(FastMCP)"]
        K8sLib["kubernetes ≥28.1.0"]
        Pydantic["pydantic ≥2.0.0"]
        PydanticSettings["pydantic-settings ≥2.0.0"]
        HTTPX["httpx ≥0.27.0"]
        Pluggy["pluggy ≥1.4.0"]
        Uvicorn["uvicorn<br/>(ASGI server)"]
    end

    MCP -->|"MCP protocol"| FastMCP
    MCP -->|"K8s API client"| K8sLib
    MCP -->|"data models"| Pydantic
    MCP -->|"config mgmt"| PydanticSettings
    MCP -->|"HTTP client"| HTTPX
    MCP -->|"plugin system"| Pluggy
    MCP -->|"HTTP server"| Uvicorn

    %% Internal RHOAI Platform Dependencies (CRD-based)
    subgraph InternalCRD["Internal RHOAI (CRD Interactions via K8s API)"]
        KubeflowNotebook["Kubeflow Notebook Controller<br/>kubeflow.org/v1 Notebook"]
        KServe["KServe Controller<br/>serving.kserve.io/v1beta1"]
        DSPOp["DSP Operator<br/>opendatahub.io/v1alpha1 DSPA"]
        TrainingOp["Kubeflow Training Operator<br/>kubeflow.org/v1alpha1 TrainJob"]
        RHOAIOp["RHOAI Operator<br/>opendatahub.io/v1 DSC"]
        Dashboard["RHOAI Dashboard<br/>Labels/Annotations"]
        AccelProfile["AcceleratorProfile<br/>dashboard.opendatahub.io/v1"]
    end

    MCP -->|"Notebook CRUD"| KubeflowNotebook
    MCP -->|"InferenceService CRUD"| KServe
    MCP -->|"DSPA CRUD"| DSPOp
    MCP -->|"TrainJob CRUD"| TrainingOp
    MCP -->|"DSC read-only"| RHOAIOp
    MCP -.->|"label compat"| Dashboard
    MCP -.->|"GPU discovery"| AccelProfile

    %% Internal RHOAI Platform Dependencies (REST API)
    subgraph InternalAPI["Internal RHOAI (REST API)"]
        ModelReg["Model Registry<br/>HTTP/8080 (port-forward)"]
        ModelCatalog["Red Hat AI Model Catalog<br/>HTTP/8080 (port-forward)"]
    end

    MCP -->|"REST API<br/>model metadata"| ModelReg
    MCP -->|"REST API<br/>curated models"| ModelCatalog

    %% External Service Dependencies
    subgraph ExternalSvc["External Services"]
        K8sAPI["Kubernetes API Server<br/>HTTPS/6443"]
        NeuralNav["Neural Navigator<br/>HTTP/8000 in-cluster"]
        S3["S3-Compatible Storage<br/>HTTPS/443"]
        OSRoutes["OpenShift Routes<br/>HTTPS/6443"]
        OSTemplates["OpenShift Templates<br/>HTTPS/6443"]
    end

    MCP -->|"all K8s ops<br/>Bearer Token"| K8sAPI
    MCP -->|"model recommendations<br/>no auth"| NeuralNav
    MCP -.->|"S3 validation<br/>AWS IAM"| S3
    MCP -.->|"route discovery"| OSRoutes
    MCP -.->|"runtime templates"| OSTemplates

    %% Eval-only Dependencies
    subgraph EvalOnly["Evaluation Only (docker-compose)"]
        Lightspeed["Lightspeed Stack<br/>HTTP/8443"]
        LlamaStack["Llama Stack<br/>HTTP/8321"]
    end

    MCP -.->|"eval: LLM routing"| Lightspeed
    MCP -.->|"eval: LLM inference"| LlamaStack

    %% Reverse Dependencies (things that depend on MCP)
    subgraph Consumers["Consumers (depend on MCP Server)"]
        ClaudeDesktop["Claude Desktop"]
        LightspeedAgent["Lightspeed Agent"]
        CustomAgent["Custom LLM Agents"]
    end

    ClaudeDesktop -->|"MCP stdio"| MCP
    LightspeedAgent -->|"MCP HTTP"| MCP
    CustomAgent -->|"MCP SSE/HTTP"| MCP

    %% Styling
    style MCP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

