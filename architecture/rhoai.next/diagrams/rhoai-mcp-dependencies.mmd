    style AccelProfile fill:#7ed321,stroke:#333,color:#fff

    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff

    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style NeuralNav fill:#f5a623,stroke:#333,color:#fff
