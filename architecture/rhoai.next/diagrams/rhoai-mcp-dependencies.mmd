graph LR
    MCP["RHOAI MCP Server<br/>(60+ tools, 14 plugins)"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies"]
        FastMCPLib["mcp / FastMCP<br/>>=1.0.0"]
        K8sLib["kubernetes<br/>>=28.1.0"]
        Pydantic["pydantic<br/>>=2.0.0"]
        PydanticSettings["pydantic-settings<br/>>=2.0.0"]
        Httpx["httpx<br/>>=0.27.0"]
        Pluggy["pluggy<br/>>=1.4.0"]
        Starlette["starlette<br/>(transitive)"]
        Uvicorn["uvicorn<br/>(transitive)"]
    end

    MCP -->|"MCP framework"| FastMCPLib
    MCP -->|"K8s API client"| K8sLib
    MCP -->|"data validation"| Pydantic
    MCP -->|"config management"| PydanticSettings
    MCP -->|"async HTTP client"| Httpx
    MCP -->|"plugin system"| Pluggy
    MCP -->|"ASGI framework"| Starlette
    MCP -->|"ASGI server"| Uvicorn

    %% Internal RHOAI Platform Dependencies
    MCP -->|"all K8s CRUD<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    MCP -->|"CRD watch"| DSC["DataScienceCluster CR"]
    MCP -->|"CRD watch"| DSCInit["DSCInitialization CR"]
    MCP -->|"CRD CRUD"| NotebookCR["Kubeflow Notebook CR"]
    MCP -->|"CRD CRUD"| InferSvc["KServe InferenceService CR"]
    MCP -->|"CRD CRUD"| ServingRT["KServe ServingRuntime CR"]
    MCP -->|"CRD CRUD"| DSPA["DSPA CR"]
    MCP -->|"CRD CRUD"| TrainJob["TrainJob CR"]
    MCP -->|"CRD CRUD"| ClusterTR["ClusterTrainingRuntime CR"]
    MCP -->|"CRD read"| AccelProf["AcceleratorProfile CR"]

    %% REST API Dependencies
    MCP -->|"REST API<br/>HTTP/8080 or HTTPS/8443"| ModelRegistry["Model Registry API"]
    MCP -->|"REST API<br/>HTTP/8080 or HTTPS/8443"| ModelCatalog["Model Catalog API"]
    MCP -->|"REST API<br/>HTTP/8000"| NeuralNav["Neural Navigator Backend"]

    %% External Service Dependencies
    MCP -->|"git clone<br/>HTTPS/443"| GitHub["GitHub"]
    MCP -->|"image catalog<br/>HTTPS/5000"| ImageReg["Container Image Registry"]
    MCP -->|"API read"| Templates["OpenShift Templates"]
    MCP -->|"API read"| Routes["OpenShift Routes"]
    MCP -->|"API read"| Projects["OpenShift Projects"]

    %% Integration Points (consumers of MCP)
    Agent["AI Agent<br/>(Claude Desktop/Code)"] -->|"MCP JSON-RPC<br/>stdio or HTTP"| MCP

    %% Styling
    style MCP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Agent fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    style FastMCPLib fill:#d5e8d4,stroke:#82b366
    style K8sLib fill:#d5e8d4,stroke:#82b366
    style Pydantic fill:#d5e8d4,stroke:#82b366
    style PydanticSettings fill:#d5e8d4,stroke:#82b366
    style Httpx fill:#d5e8d4,stroke:#82b366
    style Pluggy fill:#d5e8d4,stroke:#82b366
    style Starlette fill:#d5e8d4,stroke:#82b366
    style Uvicorn fill:#d5e8d4,stroke:#82b366

    style K8sAPI fill:#999,stroke:#333,color:#fff
    style DSC fill:#f5a623,stroke:#333
    style DSCInit fill:#f5a623,stroke:#333
    style NotebookCR fill:#f5a623,stroke:#333
