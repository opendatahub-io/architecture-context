graph LR
    RHOAIMCP["RHOAI MCP Server<br/>(Python MCP Service)"]

    %% External Runtime Dependencies
    subgraph ExtDeps["External Dependencies"]
        Python["Python 3.10+"]
        FastMCP["mcp (FastMCP) >=1.0.0"]
        K8sPython["kubernetes-python >=28.1.0"]
        Pydantic["pydantic >=2.0.0"]
        Httpx["httpx >=0.27.0"]
        Pluggy["pluggy >=1.4.0"]
        PyJWT["PyJWT[crypto] >=2.12.0"]
        UBI9["Red Hat UBI 9<br/>(python-312)"]
    end

    RHOAIMCP -->|"runtime"| Python
    RHOAIMCP -->|"MCP protocol"| FastMCP
    RHOAIMCP -->|"K8s API client"| K8sPython
    RHOAIMCP -->|"data validation"| Pydantic
    RHOAIMCP -->|"async HTTP"| Httpx
    RHOAIMCP -->|"plugin framework"| Pluggy
    RHOAIMCP -->|"OIDC JWT auth"| PyJWT
    RHOAIMCP -->|"base image"| UBI9

    %% Internal RHOAI Dependencies (via K8s API)
    subgraph InternalK8s["Internal RHOAI (via K8s API 6443/TCP)"]
        K8sAPI["Kubernetes API Server"]
        KubeflowNB["Kubeflow Notebook Controller<br/>(kubeflow.org/v1 Notebook)"]
        KServe["KServe<br/>(serving.kserve.io InferenceService,<br/>ServingRuntime)"]
        DSPOperator["Data Science Pipelines Operator<br/>(opendatahub.io DSPA)"]
        TrainingOp["Kubeflow Training Operator<br/>(trainer.kubeflow.org TrainJob,<br/>ClusterTrainingRuntime)"]
        DSC["RHOAI Dashboard / DSC<br/>(DataScienceCluster,<br/>AcceleratorProfile)"]
        DSCI["DSCInitialization"]
        OSProjects["OpenShift Projects API"]
        OSRoutes["OpenShift Routes"]
        OSImageStreams["OpenShift ImageStreams"]
        OSTemplates["OpenShift Templates"]
    end

    RHOAIMCP -->|"CRUD operations"| K8sAPI
    RHOAIMCP -->|"workbench lifecycle"| KubeflowNB
    RHOAIMCP -->|"model serving"| KServe
    RHOAIMCP -->|"pipeline infra"| DSPOperator
    RHOAIMCP -->|"training jobs"| TrainingOp
    RHOAIMCP -->|"platform status"| DSC
    RHOAIMCP -->|"platform config"| DSCI
    RHOAIMCP -->|"project listing"| OSProjects
    RHOAIMCP -->|"route discovery"| OSRoutes
    RHOAIMCP -->|"notebook images"| OSImageStreams
    RHOAIMCP -->|"serving templates"| OSTemplates

    %% Internal RHOAI Dependencies (via REST API)
    subgraph InternalREST["Internal RHOAI (REST API)"]
        ModelReg["Model Registry<br/>8080/8443 TCP"]
        ModelCat["Model Catalog<br/>8080/8443 TCP"]
        PlannerBE["Planner Backend<br/>8000/TCP"]
    end

    RHOAIMCP -->|"REST API queries"| ModelReg
    RHOAIMCP -->|"artifact resolution"| ModelCat
    RHOAIMCP -->|"NL recommendations"| PlannerBE

    %% External Services
    subgraph ExtSvcs["External Services"]
        GitHub["GitHub<br/>(rh-ai-quickstart)"]
        OIDCIdP["OIDC Identity Provider"]
        OSAuthSvr["OpenShift OAuth Server"]
    end

    RHOAIMCP -->|"git clone 443/TCP"| GitHub
    RHOAIMCP -->|"JWKS fetch 443/TCP"| OIDCIdP
    RHOAIMCP -->|"TokenReview 6443/TCP"| OSAuthSvr

    %% Optional CLI Dependencies
    subgraph OptionalCLI["Optional CLI Tools"]
        Git["git (stable)"]
        Helm["helm v3.18.0"]
        OC["oc CLI (stable-4.18)"]
    end

    RHOAIMCP -.->|"quickstart deploy"| Git
    RHOAIMCP -.->|"Helm installs"| Helm
    RHOAIMCP -.->|"manifest apply,<br/>port-forward"| OC

    %% Consumers (who depends on RHOAI MCP)
    subgraph Consumers["Consumers"]
        ClaudeDesktop["Claude Desktop"]
        ClaudeCode["Claude Code"]
        Lightspeed["Lightspeed"]
    end

    ClaudeDesktop -->|"MCP protocol"| RHOAIMCP
    ClaudeCode -->|"MCP protocol"| RHOAIMCP
    Lightspeed -->|"MCP protocol"| RHOAIMCP

