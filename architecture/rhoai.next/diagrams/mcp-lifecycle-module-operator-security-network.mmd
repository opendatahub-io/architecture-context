graph TB
    subgraph ControlPlane["CONTROL PLANE"]
        PlatformOp["ODH Platform Operator<br/>SA: rhods-operator<br/>Creates MCPLifecycleOperator CR"]
    end

    subgraph K8sAPIZone["KUBERNETES API SERVER"]
        K8sAPI["kube-apiserver<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforced"]
    end

    subgraph ModuleOpZone["MODULE OPERATOR<br/>Namespace: mcp-lifecycle-module-operator-system<br/>Pod Security: restricted"]
        direction TB

        ModuleOp["mcp-lifecycle-module-operator<br/>controller-manager<br/>SA: mcp-lifecycle-module-operator-controller-manager<br/>FIPS: strictfipsruntime + CGO_ENABLED=1"]

        HealthProbes["Health Probes<br/>/healthz /readyz<br/>8081/TCP HTTP<br/>No TLS, No Auth"]
    end

    subgraph OperandZone["DEPLOYED OPERAND<br/>Namespace: mcp-lifecycle-module-operator-system"]
        direction TB

        Operand["MCP Lifecycle Operator<br/>controller-manager<br/>SA: mcp-lifecycle-operator-controller-manager<br/>Manages MCPServer CRDs"]

        MetricsService["Metrics Service<br/>ClusterIP 8443/TCP<br/>HTTPS/TLS<br/>Auth: TokenReview + SAR"]

        subgraph AggregatedRBAC["Aggregated RBAC"]
            AdminRole["mcpserver-admin-role<br/>aggregate-to-admin"]
            EditorRole["mcpserver-editor-role<br/>aggregate-to-edit"]
            ViewerRole["mcpserver-viewer-role<br/>aggregate-to-view"]
        end
    end

    %% Flows
    PlatformOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA bearer token<br/>Create/Update CR"| K8sAPI
    K8sAPI -->|"Watch event<br/>MCPLifecycleOperator CR"| ModuleOp
    ModuleOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA bearer token<br/>SSA Apply, GC, Status Patch"| K8sAPI
    K8sAPI -->|"Deploys via SSA"| Operand
    Operand -->|"HTTPS/443<br/>TLS 1.2+<br/>SA bearer token<br/>MCPServer CRUD"| K8sAPI

    %% Styling
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef apiserver fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef moduleop fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef operand fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef health fill:#f8cecc,stroke:#b85450,stroke-width:1px,color:#333
    classDef metrics fill:#e6d0de,stroke:#996185,stroke-width:1px,color:#333
    classDef rbac fill:#c8e6c9,stroke:#66bb6a,stroke-width:1px,color:#333

    class PlatformOp controlplane
    class K8sAPI apiserver
    class ModuleOp moduleop
    class HealthProbes health
    class Operand operand
    class MetricsService metrics
    class AdminRole,EditorRole,ViewerRole rbac
