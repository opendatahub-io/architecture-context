graph TB
    subgraph "vLLM Gaudi Plugin (odh-vllm-gaudi-rhel9)"
        direction TB

        subgraph "API Layer"
            APIServer["vLLM API Server<br/>(OpenAI-compatible)<br/>Port 8000/TCP"]
        end

        subgraph "Plugin Core (vllm_gaudi)"
            HpuPlatform["HpuPlatform<br/>Device detection, config validation<br/>dtype enforcement, backend selection"]
            ExtSystem["Extension System<br/>Feature flags, bucketing,<br/>profiling, defragmentation"]
        end

        subgraph "Attention Backends"
            HPUAttn["HPUAttention"]
            HPUMLA["HPU MLA"]
            HPUUnified["HPU UnifiedAttention"]
            HPUUnifiedMLA["HPU UnifiedMLA"]
        end

        subgraph "Custom Ops"
            FusedMoE["FusedMoE"]
            FP8Ops["FP8 Ops"]
            GPTQOps["GPTQ Ops"]
            AWQOps["AWQ Ops"]
            LayerNorm["LayerNorm"]
            RotaryEmb["RotaryEmbedding"]
            CompTensors["CompressedTensors"]
            MambaOps["Mamba/SSM Ops"]
        end

        subgraph "Model Overrides"
            Models["12+ Model Architectures<br/>DeepSeek, Qwen, Gemma,<br/>Pixtral, MiniMax, Granite..."]
        end

        subgraph "Worker Runtime"
            HPUWorker["HPUWorker<br/>Memory profiling, KV cache,<br/>async execution"]
            HPUModelRunner["HPUModelRunner<br/>Model execution pipeline"]
            HpuComm["HpuCommunicator<br/>HCCL all-reduce, all-gather"]
        end

        subgraph "Speculative Decoding"
            Eagle["Eagle Proposer"]
            EagleUnified["Eagle Unified"]
            RejSampler["Rejection Sampler<br/>(CPU-optimized)"]
        end

        subgraph "Calibration"
            CalibTools["FP8 Calibration Pipeline<br/>6-step quantization"]
        end
    end

    %% Internal connections
    APIServer -->|"requests"| HpuPlatform
    HpuPlatform -->|"selects backend"| HPUAttn
    HpuPlatform -->|"selects backend"| HPUUnified
    HpuPlatform -->|"configures"| ExtSystem
    HpuPlatform -->|"dispatches"| HPUWorker
    HPUWorker -->|"runs"| HPUModelRunner
    HPUModelRunner -->|"uses"| Models
    HPUModelRunner -->|"uses"| FusedMoE
    HPUModelRunner -->|"uses"| FP8Ops
    HPUWorker -->|"communicates"| HpuComm
    Eagle -->|"validates"| RejSampler

    %% External connections
    Client["Client"] -->|"POST /v1/*"| APIServer
    HPUWorker -->|"SynapseAI HAL"| GaudiDevice["Intel Gaudi 2/3<br/>Accelerator"]
    HpuComm -->|"HCCL"| PeerWorkers["Peer HPU Workers"]
    HPUWorker -->|"NIXL/RDMA"| NIXLTransfer["KV Cache<br/>Disaggregation"]

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style HpuPlatform fill:#4a90e2,stroke:#333,color:#fff
    style HPUWorker fill:#4a90e2,stroke:#333,color:#fff
    style HPUModelRunner fill:#4a90e2,stroke:#333,color:#fff
    style HpuComm fill:#4a90e2,stroke:#333,color:#fff
    style ExtSystem fill:#4a90e2,stroke:#333,color:#fff
    style HPUAttn fill:#7ed321,stroke:#333
    style HPUMLA fill:#7ed321,stroke:#333
    style HPUUnified fill:#7ed321,stroke:#333
    style HPUUnifiedMLA fill:#7ed321,stroke:#333
    style FusedMoE fill:#f5a623,stroke:#333
    style FP8Ops fill:#f5a623,stroke:#333
    style GPTQOps fill:#f5a623,stroke:#333
    style AWQOps fill:#f5a623,stroke:#333
    style LayerNorm fill:#f5a623,stroke:#333
    style RotaryEmb fill:#f5a623,stroke:#333
    style CompTensors fill:#f5a623,stroke:#333
    style MambaOps fill:#f5a623,stroke:#333
    style Models fill:#bd10e0,stroke:#333,color:#fff
    style Eagle fill:#50e3c2,stroke:#333
    style EagleUnified fill:#50e3c2,stroke:#333
    style RejSampler fill:#50e3c2,stroke:#333
    style CalibTools fill:#9b9b9b,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style GaudiDevice fill:#d0021b,stroke:#333,color:#fff
    style PeerWorkers fill:#e8e8e8,stroke:#333
    style NIXLTransfer fill:#e8e8e8,stroke:#333
