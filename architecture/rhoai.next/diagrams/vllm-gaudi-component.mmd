graph TB
    subgraph "vllm-gaudi Plugin"
        direction TB
        subgraph "Platform Registration"
            HpuPlatform["HpuPlatform<br/>(Platform Registration)"]
        end

        subgraph "Core Engine"
            HPUModelRunner["HPUModelRunner<br/>(Model Execution Engine)"]
            HPUWorker["HPUWorker<br/>(Worker Implementation)"]
            HPUWorker -->|manages| HPUModelRunner
        end

        subgraph "Extension Module"
            Config["Configuration &<br/>Feature Flags"]
            Bucketing["Bucketing Manager<br/>(Graph Compilation)"]
            Profiler["Profiler"]
            Config -->|controls| Bucketing
            Config -->|controls| Profiler
        end

        subgraph "Attention Backends"
            StdAttn["Standard HPU Attention"]
            MLA["MLA Attention<br/>(Multi-head Latent)"]
            UnifiedAttn["Unified Attention<br/>(Flash-Attn-2 style)"]
            UnifiedMLA["Unified MLA"]
        end

        subgraph "Quantization"
            FP8["FP8 (per-tensor/channel/block)"]
            INC["Intel Neural Compressor"]
            GPTQ["GPTQ (2/3/4/8-bit)"]
            AWQ["AWQ (4-bit)"]
            CompTensors["Compressed Tensors<br/>(W8A8, WNA16)"]
            ModelOpt["ModelOpt FP8"]
        end

        subgraph "Distributed"
            HpuComm["HPU Communicator"]
            NIXL_Conn["NIXL KV Connector"]
            DPUtils["Data Parallel Utils"]
        end

        subgraph "Speculative Decoding"
            Eagle["EAGLE Decoder"]
            EagleUnified["Unified EAGLE"]
        end
    end

    subgraph "Container Image: odh-vllm-gaudi-rhel9"
        vLLM["vLLM Engine<br/>(v0.16.0)"]
        SynapseAI["SynapseAI Runtime<br/>(v1.23.0)"]
        PyTorch["PyTorch HPU<br/>(v2.9.0)"]
        APIServer["OpenAI API Server<br/>Port 8000/TCP"]
    end

    %% Plugin registration
    HpuPlatform -->|registers via<br/>entry points| vLLM
    HPUModelRunner -->|executes on| SynapseAI
    HPUModelRunner -->|uses| PyTorch
    HPUWorker -->|selects| StdAttn
    HPUWorker -->|selects| MLA
    HPUWorker -->|selects| UnifiedAttn
    HPUWorker -->|selects| UnifiedMLA
    HPUModelRunner -->|applies| FP8
    HPUModelRunner -->|applies| INC
    HPUModelRunner -->|applies| GPTQ
    HPUModelRunner -->|applies| AWQ
    HPUModelRunner -->|applies| CompTensors
    HPUModelRunner -->|applies| ModelOpt

    %% External interactions
    Client[Client] -->|HTTPS/8443| KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"]
    KubeRBACProxy -->|HTTP/8000| APIServer
    APIServer -->|delegates| vLLM
    vLLM -->|dispatches| HPUWorker

    %% Platform
    KServe["KServe<br/>ServingRuntime"] -->|deploys| ContainerImage["odh-vllm-gaudi-rhel9"]

    %% Styling
    style HpuPlatform fill:#4a90e2,stroke:#333,color:#fff
    style HPUModelRunner fill:#4a90e2,stroke:#333,color:#fff
    style HPUWorker fill:#4a90e2,stroke:#333,color:#fff
    style Config fill:#9b59b6,stroke:#333,color:#fff
    style APIServer fill:#27ae60,stroke:#333,color:#fff
    style vLLM fill:#e67e22,stroke:#333,color:#fff
    style SynapseAI fill:#e67e22,stroke:#333,color:#fff
    style PyTorch fill:#e67e22,stroke:#333,color:#fff
    style KubeRBACProxy fill:#e74c3c,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style KServe fill:#7ed321,stroke:#333
    style StdAttn fill:#3498db,stroke:#333,color:#fff
    style MLA fill:#3498db,stroke:#333,color:#fff
    style UnifiedAttn fill:#3498db,stroke:#333,color:#fff
    style UnifiedMLA fill:#3498db,stroke:#333,color:#fff
    style FP8 fill:#f39c12,stroke:#333,color:#fff
    style INC fill:#f39c12,stroke:#333,color:#fff
    style GPTQ fill:#f39c12,stroke:#333,color:#fff
    style AWQ fill:#f39c12,stroke:#333,color:#fff
    style CompTensors fill:#f39c12,stroke:#333,color:#fff
    style ModelOpt fill:#f39c12,stroke:#333,color:#fff
