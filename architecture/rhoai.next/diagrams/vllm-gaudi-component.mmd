graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Platform["Platform Layer"]
        Gateway["Platform Gateway<br/>443/TCP HTTPS"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP TLS"]
    end

    subgraph VLLMContainer["vLLM + vllm-gaudi Container"]
        subgraph APILayer["API Layer"]
            APIServer["vLLM OpenAI API Server<br/>8000/TCP HTTP"]
        end

        subgraph PluginCore["vllm-gaudi Plugin"]
            HpuPlatform["HpuPlatform<br/>Platform Registration"]
            ExtFramework["Extension Framework<br/>Runtime Config"]
            HpuPlatform -->|configures| ExtFramework
        end

        subgraph ExecutionEngine["Execution Engine"]
            HPUModelRunner["HPUModelRunner<br/>Model Runner"]
            HPUWorker["HPUWorker<br/>Device Lifecycle"]
            HPUWorker -->|manages| HPUModelRunner
        end

        subgraph AttentionBackends["Attention Backends"]
            HPUAttnV1["HPUAttentionV1"]
            HPUUnified["HPUUnifiedAttention<br/>Chunked Prefill"]
            HPUMLA["HPUMLAAttention"]
            HPUUnifiedMLA["HPUUnifiedMLA"]
        end

        subgraph CustomOps["Custom Ops"]
            FP8Ops["FP8 Quantization"]
            FusedMoE["Fused MoE"]
            LayerNorm["Layer Norm"]
            RotaryEmb["Rotary Embeddings"]
            LoRA["LoRA Ops"]
            MambaSSM["Mamba/SSM Ops"]
        end

        subgraph ModelOverrides["Model Overrides"]
            Models["Gemma3, Qwen2.5-VL,<br/>Qwen3-VL-MoE, Pixtral,<br/>DeepSeek-V2, HunYuan, Ovis"]
        end

        APIServer -->|routes to| HPUModelRunner
        HPUModelRunner -->|selects| AttentionBackends
        HPUModelRunner -->|uses| CustomOps
        HPUModelRunner -->|loads| ModelOverrides
        ExtFramework -->|configures| HPUModelRunner
    end

    subgraph Distributed["Distributed Communication"]
        HpuComm["HpuCommunicator<br/>HCCL all-reduce/all-gather"]
        NIXL["NIXL Connector<br/>KV Cache Transfer"]
    end

    subgraph Hardware["Intel Gaudi Hardware"]
        HPU["Intel Gaudi 2/3<br/>HPU Accelerator"]
    end

    Client -->|HTTPS/443| Gateway
    Gateway -->|TLS/8443| KRBAC
    KRBAC -->|HTTP/8000| APIServer
    HPUModelRunner -->|PCIe/RDMA| HPU
    HPUWorker -->|HCCL| HpuComm
    HPUWorker -.->|UCX/TCP| NIXL

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style HpuPlatform fill:#4a90e2,stroke:#333,color:#fff
    style HPUWorker fill:#4a90e2,stroke:#333,color:#fff
    style HPUModelRunner fill:#4a90e2,stroke:#333,color:#fff
    style ExtFramework fill:#4a90e2,stroke:#333,color:#fff
    style HPUAttnV1 fill:#7ed321,stroke:#333
    style HPUUnified fill:#7ed321,stroke:#333
    style HPUMLA fill:#7ed321,stroke:#333
    style HPUUnifiedMLA fill:#7ed321,stroke:#333
    style FP8Ops fill:#f5a623,stroke:#333
    style FusedMoE fill:#f5a623,stroke:#333
    style LayerNorm fill:#f5a623,stroke:#333
    style RotaryEmb fill:#f5a623,stroke:#333
    style LoRA fill:#f5a623,stroke:#333
    style MambaSSM fill:#f5a623,stroke:#333
    style HPU fill:#e8e8e8,stroke:#333
    style Gateway fill:#999,stroke:#333,color:#fff
    style KRBAC fill:#999,stroke:#333,color:#fff
    style HpuComm fill:#9b59b6,stroke:#333,color:#fff
    style NIXL fill:#9b59b6,stroke:#333,color:#fff
