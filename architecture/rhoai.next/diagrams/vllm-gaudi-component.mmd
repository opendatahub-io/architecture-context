graph TB
    subgraph VllmGaudi["vLLM Gaudi Plugin (odh-vllm-gaudi-rhel9)"]
        direction TB

        subgraph PluginCore["Plugin Core"]
            Platform["HpuPlatform<br/>Device detection, config validation,<br/>attention backend selection,<br/>memory management"]
            ExtSystem["Extension System<br/>Dynamic config, feature flags,<br/>bucketing, profiling,<br/>defragmentation"]
        end

        subgraph AttentionLayer["Attention Backends"]
            HPUAttn["HPUAttention"]
            HPUMLA["HPU MLA"]
            HPUUnified["HPU UnifiedAttention"]
            HPUUnifiedMLA["HPU UnifiedMLA"]
        end

        subgraph OpsLayer["HPU Custom Ops"]
            FusedMoE["FusedMoE"]
            FP8Ops["FP8 Ops"]
            GPTQOps["GPTQ Ops"]
            AWQOps["AWQ Ops"]
            LayerNorm["LayerNorm"]
            RotaryEmbed["RotaryEmbedding"]
            CompTensors["CompressedTensors"]
            MambaOps["Mamba/SSM Ops"]
        end

        subgraph ModelOverrides["HPU Model Overrides"]
            DeepSeek["DeepSeek"]
            Qwen["Qwen2.5/3"]
            Gemma["Gemma3"]
            Pixtral["Pixtral"]
            MiniMax["MiniMax"]
            OtherModels["+ 7 more"]
        end

        subgraph WorkerRuntime["Worker Runtime"]
            HPUWorker["HPUWorker<br/>Memory profiling,<br/>KV cache allocation"]
            HPUModelRunner["HPUModelRunner<br/>Async execution on<br/>Gaudi devices"]
            HPUComm["HpuCommunicator<br/>HCCL all-reduce,<br/>all-gather"]
        end

        CalibTools["Calibration Tools<br/>FP8 quantization pipeline"]
    end

    subgraph VllmUpstream["vLLM v0.16.0 (Upstream)"]
        APIServer["OpenAI-compatible<br/>API Server<br/>:8000/TCP"]
        PluginSystem["Plugin System<br/>vllm.platform_plugins<br/>vllm.general_plugins"]
    end

    subgraph HardwareStack["Intel Gaudi Hardware Stack"]
        SynapseAI["SynapseAI Runtime v1.23.0<br/>Graph compiler, TPC kernels"]
        HabanaTorch["habana-torch-plugin<br/>FusedSDPA, mark_step,<br/>HPU graphs"]
        PyTorch["PyTorch 2.9.0<br/>(Gaudi fork)"]
    end

    %% Plugin registration
    Platform -->|registers via| PluginSystem
    PluginSystem -->|loads| Platform

    %% Internal flows
    APIServer -->|inference request| HPUWorker
    Platform -->|selects| HPUAttn
    Platform -->|selects| HPUMLA
    Platform -->|selects| HPUUnified
    HPUWorker -->|executes| HPUModelRunner
    HPUModelRunner -->|uses| FusedMoE
    HPUModelRunner -->|uses| FP8Ops

    %% Hardware integration
    HPUWorker -->|device calls| SynapseAI
    HPUModelRunner -->|torch ops| HabanaTorch
    HabanaTorch -->|backend| PyTorch

    %% External
    Client["Client"] -->|POST /v1/chat/completions| APIServer

    %% Styling
    style Platform fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style HPUWorker fill:#4a90e2,stroke:#333,color:#fff
    style HPUModelRunner fill:#4a90e2,stroke:#333,color:#fff
    style SynapseAI fill:#e8e8e8,stroke:#333
    style HabanaTorch fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style Client fill:#f5a623,stroke:#333
    style CalibTools fill:#7ed321,stroke:#333
    style HPUComm fill:#4a90e2,stroke:#333,color:#fff
    style ExtSystem fill:#4a90e2,stroke:#333,color:#fff
