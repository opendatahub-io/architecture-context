graph TB
    subgraph "vllm-gaudi Plugin Package"
        direction TB
        Platform["HpuPlatform<br/>(platform.py)<br/>Plugin Registration"]

        subgraph "Attention Backends"
            PagedAttn["HPUAttentionBackendV1<br/>Paged Attention"]
            UnifiedAttn["HPUUnifiedAttentionBackend<br/>Unified Prefill+Decode"]
            MLAAttn["HPUMLAAttentionBackend<br/>Multi-head Latent Attention"]
            UnifiedMLA["HPUUnifiedMLABackend<br/>Unified MLA"]
        end

        subgraph "Worker & Model Runner"
            Worker["HPUWorker<br/>Memory Management<br/>Sleep/Wake Cycles"]
            ModelRunner["HPUModelRunner<br/>Model Execution<br/>HPU Graph Compilation"]
        end

        subgraph "Quantization"
            FP8["FP8 Quantization"]
            INC["INC (Neural Compressor)"]
            AWQ["AWQ Quantization"]
            GPTQ["GPTQ Quantization"]
            ModelOpt["ModelOpt FP8"]
        end

        subgraph "Extensions"
            Config["Runtime Config<br/>Feature Flags"]
            Bucketing["Bucketing System<br/>Batch Optimization"]
            Defrag["OnlineDefragmenter<br/>Memory Defrag"]
        end

        subgraph "Model Overrides"
            Models["HPU-Optimized Models<br/>Gemma3, Qwen2.5-VL,<br/>DeepSeek-v2, Granite,<br/>Pixtral, HunYuan, ..."]
        end

        subgraph "Distributed"
            HCCL["HPU Communicator<br/>HCCL Collective Ops"]
            NIXL["NIXL Connector<br/>KV Cache Transfer"]
        end
    end

    subgraph "Container Image: odh-vllm-gaudi-rhel9"
        direction LR
        VLLMCore["vLLM Core<br/>v0.16.0"]
        APIServer["OpenAI-Compatible<br/>API Server<br/>Port 8000/TCP"]
        SynapseAI["Intel SynapseAI<br/>v1.23.0"]
        PyTorchHabana["PyTorch (Habana)<br/>v2.9.0"]
    end

    %% Plugin registration
    Platform -->|registers| PagedAttn
    Platform -->|registers| UnifiedAttn
    Platform -->|registers| MLAAttn
    Platform -->|registers| UnifiedMLA
    Platform -->|registers| Worker
    Platform -->|registers| HCCL
    Platform -->|configures| Config

    Worker -->|executes| ModelRunner
    ModelRunner -->|uses| Models
    Config -->|configures| Bucketing
    Config -->|configures| Defrag

    %% Container integration
    VLLMCore -->|loads plugin| Platform
    VLLMCore -->|serves| APIServer
    Worker -->|uses| SynapseAI
    Worker -->|uses| PyTorchHabana

    %% External consumers
    Client[Client Request] -->|POST /v1/chat/completions| APIServer
    KServe["KServe<br/>InferenceService"] -->|deploys| VLLMCore

    %% Styling
    style Platform fill:#4a90e2,stroke:#333,color:#fff
    style VLLMCore fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style SynapseAI fill:#f5a623,stroke:#333,color:#fff
    style PyTorchHabana fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Worker fill:#6c5ce7,stroke:#333,color:#fff
    style ModelRunner fill:#6c5ce7,stroke:#333,color:#fff
    style HCCL fill:#e17055,stroke:#333,color:#fff
    style NIXL fill:#e17055,stroke:#333,color:#fff
