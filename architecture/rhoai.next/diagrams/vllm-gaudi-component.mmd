graph TB
    subgraph "vllm-gaudi Container (odh-vllm-gaudi-rhel9)"
        subgraph "vLLM Core"
            APIServer["vLLM OpenAI API Server<br/>Port 8000/TCP"]
            Scheduler["Scheduler"]
            Tokenizer["Tokenizer"]
        end

        subgraph "vllm-gaudi Plugin"
            HpuPlatform["HpuPlatform<br/>(Platform Plugin)"]
            ModelRunner["HPUModelRunner<br/>(Model Execution)"]
            AttentionBackends["Attention Backends<br/>FusedSDPA | Unified | MLA"]
            CustomOps["Custom Ops<br/>(HPU Kernels)"]
            ModelOverrides["Model Overrides<br/>DeepSeek V2 | Qwen 3 | Gemma 3<br/>Pixtral | Ovis"]
            ConfigSystem["Config System<br/>features.py | environment.py"]
        end

        subgraph "Distributed Layer"
            HpuCommunicator["HpuCommunicator<br/>(HCCL Wrapper)"]
            NixlConnector["NixlConnectorWorker<br/>(KV Cache Transfer)"]
        end

        subgraph "Hardware Stack"
            SynapseAI["Habana Synapse AI 1.23.0<br/>(Driver Stack)"]
            PyTorchHabana["PyTorch for Habana 2.9.0<br/>(HPU Device Support)"]
        end
    end

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>8000/TCP HTTP"| APIServer
    APIServer --> Scheduler
    Scheduler --> Tokenizer
    APIServer -->|"inference request"| ModelRunner
    HpuPlatform -->|"configures"| ModelRunner
    ConfigSystem -->|"selects backend"| AttentionBackends
    ModelRunner -->|"uses"| AttentionBackends
    ModelRunner -->|"uses"| CustomOps
    ModelRunner -->|"loads"| ModelOverrides
    ModelRunner -->|"executes on"| SynapseAI
    SynapseAI -->|"device access"| PyTorchHabana
    ModelRunner -->|"collectives"| HpuCommunicator
    NixlConnector -->|"KV transfer"| HpuCommunicator

    KServe["KServe / RHOAI Operator"] -->|"deploys as<br/>InferenceService runtime"| APIServer
    ModelStorage["Model Storage<br/>(S3 / PVC / HuggingFace)"] -.->|"model weights"| ModelRunner
    PeerWorkers["Peer Gaudi Workers"] <-->|"HCCL/RDMA<br/>all-reduce, all-gather"| HpuCommunicator

    style APIServer fill:#4a90e2,stroke:#333
    style HpuPlatform fill:#e8744f,stroke:#333
    style ModelRunner fill:#e8744f,stroke:#333
    style AttentionBackends fill:#e8744f,stroke:#333
    style CustomOps fill:#e8744f,stroke:#333
    style ModelOverrides fill:#e8744f,stroke:#333
    style ConfigSystem fill:#e8744f,stroke:#333
    style HpuCommunicator fill:#d4a017,stroke:#333
    style NixlConnector fill:#d4a017,stroke:#333
    style SynapseAI fill:#9b59b6,stroke:#333
    style PyTorchHabana fill:#9b59b6,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style PeerWorkers fill:#f5a623,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
