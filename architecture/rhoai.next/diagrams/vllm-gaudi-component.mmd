graph TB
    subgraph "vllm-gaudi Plugin"
        direction TB
        HpuPlatform["HpuPlatform<br/>(Platform Registration)"]
        ExtModule["Extension Module<br/>(Config, Features, Validation)"]

        subgraph "Worker Layer"
            HPUWorker["HPUWorker<br/>(Device Init, Memory Profiling,<br/>Distributed Communication)"]
            HPUModelRunner["HPUModelRunner<br/>(Forward Pass, KV Cache,<br/>Graph Compilation)"]
        end

        subgraph "Attention Backends"
            StdAttn["Standard HPU Attention"]
            MLAAttn["MLA Attention<br/>(Multi-head Latent)"]
            UnifiedAttn["Unified Attention<br/>(Flash-style Online Merge)"]
            UnifiedMLA["Unified MLA"]
        end

        subgraph "Quantization"
            FP8["FP8<br/>(per-tensor/channel/block)"]
            INC["Intel Neural<br/>Compressor"]
            GPTQ["GPTQ<br/>(2/3/4/8-bit)"]
            AWQ["AWQ (4-bit)"]
            CompTensors["Compressed<br/>Tensors"]
            ModelOpt["ModelOpt FP8"]
        end

        subgraph "Distributed"
            HPUComm["HPU Communicator<br/>(HCCL)"]
            NIXLConn["NIXL Connector<br/>(KV Transfer)"]
            DPUtils["Data Parallel<br/>MoE Utils"]
        end

        subgraph "Speculative Decoding"
            EAGLE["EAGLE<br/>Spec Decode"]
            RejSampler["Rejection<br/>Sampler"]
        end
    end

    subgraph "Container: odh-vllm-gaudi-rhel9"
        vLLMServer["vLLM OpenAI API Server<br/>Port 8000/TCP"]
    end

    User[Data Scientist / Client] -->|"POST /v1/completions<br/>POST /v1/chat/completions"| KubeRBACProxy
    KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar, 8443/TCP TLS)"] -->|"HTTP 8000/TCP<br/>(pre-authenticated)"| vLLMServer

    vLLMServer -->|"plugin entry points<br/>vllm.platform_plugins"| HpuPlatform
    HpuPlatform -->|registers| HPUWorker
    HpuPlatform -->|configures| ExtModule
    HPUWorker -->|executes| HPUModelRunner
    HPUModelRunner -->|selects| StdAttn
    HPUModelRunner -->|selects| UnifiedAttn
    HPUModelRunner -->|selects| MLAAttn
    HPUModelRunner -->|applies| FP8
    HPUModelRunner -->|applies| GPTQ
    HPUWorker -->|coordinates| HPUComm
    HPUWorker -->|transfers KV| NIXLConn

    HPUModelRunner -->|loads weights| ModelStorage["Model Storage<br/>(S3 / HuggingFace / PVC)"]

    KServe["KServe<br/>(ServingRuntime)"] -->|"deploys container<br/>manages lifecycle"| vLLMServer

    HPUModelRunner -->|"executes on"| GaudiHPU["Intel Gaudi HPU<br/>(Gaudi2 / Gaudi3)"]
    HPUComm -->|"RDMA/TCP"| GaudiHPU

    style HpuPlatform fill:#4a90e2,color:#fff
    style HPUWorker fill:#4a90e2,color:#fff
    style HPUModelRunner fill:#4a90e2,color:#fff
