graph TB
    subgraph "vLLM Gaudi Plugin (vllm_gaudi)"
        direction TB

        subgraph "Platform Layer"
            HpuPlatform["HpuPlatform<br/>Device detection, config validation,<br/>attention backend selection, memory mgmt"]
        end

        subgraph "Attention Backends"
            HPUAttn["HPUAttention"]
            HPUMLA["HPU MLA"]
            HPUUnified["HPU UnifiedAttention"]
            HPUUnifiedMLA["HPU UnifiedMLA"]
        end

        subgraph "Custom Ops"
            FusedMoE["FusedMoE"]
            FP8Ops["FP8 Ops"]
            GPTQOps["GPTQ Ops"]
            AWQOps["AWQ Ops"]
            LayerNorm["LayerNorm"]
            RotaryEmbed["RotaryEmbedding"]
            CompTensors["CompressedTensors"]
            MambaOps["Mamba/SSM Ops"]
        end

        subgraph "Model Overrides"
            DeepSeek["DeepSeek"]
            Qwen["Qwen2.5/3 VL"]
            Gemma["Gemma3"]
            Pixtral["Pixtral"]
            MiniMax["MiniMax"]
            OtherModels["+ 7 more architectures"]
        end

        subgraph "Worker Runtime"
            HPUWorker["HPUWorker"]
            HPUModelRunner["HPUModelRunner"]
            HPUInputBatch["HPUInputBatch"]
        end

        subgraph "Distributed"
            HpuComm["HpuCommunicator<br/>HCCL all-reduce/all-gather"]
            NIXLConn["NIXL Connector<br/>KV cache disaggregation"]
            HeteroNIXL["Hetero NIXL Connector<br/>Block size/layout conversion"]
        end

        subgraph "Extension System"
            Config["Dynamic Config"]
            Features["Feature Flags"]
            Bucketing["Bucketing Strategies"]
            Defrag["Cache Defragmentation"]
            Profiler["Profiler"]
        end
    end

    subgraph "vLLM Framework (upstream v0.16.0)"
        APIServer["vLLM OpenAI API Server<br/>Port 8000/TCP"]
        PluginSystem["Plugin System<br/>vllm.platform_plugins<br/>vllm.general_plugins"]
    end

    subgraph "Intel Habana Runtime"
        SynapseAI["SynapseAI v1.23.0<br/>Graph compiler, TPC kernels"]
        HabanaTorch["habana_frameworks.torch<br/>FusedSDPA, HPU graphs"]
    end

    subgraph "External Services"
        KServe["KServe InferenceService"]
        S3["S3 / MinIO<br/>Model Storage"]
        HFHub["Hugging Face Hub"]
    end

    %% Plugin registration
    PluginSystem -->|loads plugin| HpuPlatform
    HpuPlatform -->|selects| HPUAttn
    HpuPlatform -->|selects| HPUMLA
    HpuPlatform -->|selects| HPUUnified
    HpuPlatform -->|selects| HPUUnifiedMLA

    %% Worker flow
    APIServer -->|inference request| HPUWorker
    HPUWorker -->|executes| HPUModelRunner
    HPUModelRunner -->|uses| HabanaTorch
    HabanaTorch -->|compiles/runs| SynapseAI

    %% Deployment
    KServe -->|routes to| APIServer
    HPUWorker -->|downloads models| S3
    HPUWorker -->|downloads models| HFHub

    %% Distributed
    HPUWorker -->|collective ops| HpuComm
    HPUWorker -.->|KV transfer| NIXLConn

    %% Styling
    style HpuPlatform fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style HPUWorker fill:#4a90e2,stroke:#333,color:#fff
    style HPUModelRunner fill:#4a90e2,stroke:#333,color:#fff
    style SynapseAI fill:#9b59b6,stroke:#333,color:#fff
    style HabanaTorch fill:#9b59b6,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style HPUAttn fill:#3498db,stroke:#333,color:#fff
    style HPUMLA fill:#3498db,stroke:#333,color:#fff
    style HPUUnified fill:#3498db,stroke:#333,color:#fff
    style HPUUnifiedMLA fill:#3498db,stroke:#333,color:#fff
