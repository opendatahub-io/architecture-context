graph LR
    OGX["ogx<br/>(Llama Stack)"]

    %% ─── Core Runtime Dependencies ───
    subgraph CoreDeps["Core Runtime"]
        Python["Python >=3.10"]
        FastAPI["FastAPI >=0.115"]
        Uvicorn["Uvicorn"]
        Pydantic["Pydantic >=2"]
        httpx["httpx"]
    end

    OGX -->|"runtime"| Python
    OGX -->|"HTTP framework"| FastAPI
    OGX -->|"ASGI server"| Uvicorn
    OGX -->|"data validation"| Pydantic
    OGX -->|"async HTTP client"| httpx

    %% ─── Security Dependencies ───
    subgraph SecurityDeps["Security Libraries"]
        jose["python-jose 3.4.0<br/>(JWT validation)"]
        openai_sdk["openai SDK >=1.66<br/>(API compat types)"]
    end

    OGX -->|"JWT auth"| jose
    OGX -->|"OpenAI compat"| openai_sdk

    %% ─── Inference Providers (Remote) ───
    subgraph InferenceProviders["Inference Providers"]
        vLLM["vLLM Server<br/>HTTP/HTTPS"]
        Ollama["Ollama Server<br/>HTTP :11434"]
        OpenAI["OpenAI API<br/>HTTPS :443"]
        Anthropic["Anthropic API<br/>HTTPS :443"]
        Bedrock["AWS Bedrock<br/>HTTPS :443"]
        TGI["HuggingFace TGI<br/>HTTP/HTTPS"]
        Gemini["Google Gemini<br/>HTTPS :443"]
        NVIDIA["NVIDIA NIM<br/>HTTPS :443"]
    end

    OGX -->|"primary inference<br/>(RHOAI)"| vLLM
    OGX -->|"local inference"| Ollama
    OGX -->|"cloud inference"| OpenAI
    OGX -->|"cloud inference"| Anthropic
    OGX -->|"cloud inference + safety"| Bedrock
    OGX -->|"text generation"| TGI
    OGX -->|"cloud inference"| Gemini
    OGX -->|"inference + eval"| NVIDIA

    %% ─── Vector Database Providers ───
    subgraph VectorDBs["Vector Databases"]
        ChromaDB["ChromaDB<br/>HTTP/HTTPS"]
        PGVector["PostgreSQL pgvector<br/>:5432/TCP"]
        Qdrant["Qdrant<br/>HTTP/HTTPS"]
        Milvus["Milvus<br/>gRPC/HTTP"]
        Weaviate["Weaviate<br/>HTTP/HTTPS"]
    end

    OGX -->|"vector storage"| ChromaDB
    OGX -->|"vector storage"| PGVector
    OGX -->|"vector storage"| Qdrant
    OGX -->|"vector storage"| Milvus
    OGX -->|"vector storage"| Weaviate

    %% ─── Authentication ───
    subgraph AuthServices["Authentication"]
        OAuth2["OAuth2/OIDC Provider<br/>JWKS + Introspection"]
        CustomAuth["Custom Auth Endpoint"]
    end

    OGX -->|"JWT validation"| OAuth2
    OGX -.->|"custom token validation"| CustomAuth

    %% ─── Tool Runtimes ───
    subgraph ToolRuntimes["Tool Runtimes"]
        Brave["Brave Search<br/>HTTPS :443"]
        Tavily["Tavily Search<br/>HTTPS :443"]
        Wolfram["Wolfram Alpha<br/>HTTPS :443"]
        Bing["Bing Search<br/>HTTPS :443"]
        MCP["MCP Servers<br/>HTTP/stdio"]
    end

    OGX -->|"web search"| Brave
    OGX -->|"web search"| Tavily
    OGX -->|"computation"| Wolfram
    OGX -->|"web search"| Bing
    OGX -->|"tool integration"| MCP

    %% ─── Observability & Downloads ───
    subgraph External["External Services"]
        OTEL["OpenTelemetry Collector<br/>HTTP OTLP"]
        HFHub["HuggingFace Hub<br/>HTTPS :443"]
    end

    OGX -->|"tracing + metrics"| OTEL
    OGX -->|"model downloads"| HFHub

    %% ─── Internal Storage (no network) ───
    subgraph LocalStorage["Local Storage (in-process)"]
        SQLite["SQLite<br/>(metadata, KV, sqlite-vec)"]
        FAISS["FAISS<br/>(in-memory vector search)"]
        LocalFS["Local File Storage"]
    end

    OGX -->|"local storage"| SQLite
    OGX -->|"vector similarity"| FAISS
    OGX -->|"file storage"| LocalFS

