graph LR
    OGX["Llama Stack<br/>(ogx)"]

    %% Core Runtime Dependencies
    subgraph CoreRuntime["Core Runtime"]
        Python["Python >=3.10"]
        FastAPI["FastAPI >=0.115"]
        Uvicorn["uvicorn"]
        Pydantic["Pydantic >=2"]
        httpx["httpx"]
        aiohttp["aiohttp"]
    end

    OGX -->|runtime| Python
    OGX -->|HTTP framework| FastAPI
    OGX -->|ASGI server| Uvicorn
    OGX -->|data validation| Pydantic
    OGX -->|async HTTP client| httpx
    OGX -->|async HTTP| aiohttp

    %% Security Dependencies
    subgraph SecurityDeps["Security / Auth"]
        PythonJose["python-jose<br/>(JWT validation)"]
        SSLModule["Python ssl module<br/>(TLS)"]
    end

    OGX -->|JWT auth| PythonJose
    OGX -->|TLS/mTLS| SSLModule

    %% AI/ML Client Dependencies
    subgraph AIClients["AI/ML Client Libraries"]
        OpenAISDK["openai >=1.66<br/>(OpenAI-compatible client)"]
        LSClient["llama-stack-client >=0.2.10"]
        Tiktoken["tiktoken<br/>(token counting)"]
        HFHub["huggingface-hub<br/>(model downloads)"]
    end

    OGX -->|provider client| OpenAISDK
    OGX -->|client library| LSClient
    OGX -->|tokenization| Tiktoken
    OGX -->|model registry| HFHub

    %% Inference Providers (Remote)
    subgraph InferenceRemote["Remote Inference Providers"]
        vLLM["vLLM Server<br/>(default 8000/TCP)"]
        Ollama["Ollama<br/>(11434/TCP)"]
        OpenAIAPI["OpenAI API<br/>(443/TCP)"]
        AnthropicAPI["Anthropic API<br/>(443/TCP)"]
        GeminiAPI["Google Gemini<br/>(443/TCP)"]
        BedrockAPI["AWS Bedrock<br/>(443/TCP)"]
        NVIDIANIMAPI["NVIDIA NIM<br/>(443/TCP)"]
        DatabricksAPI["Databricks<br/>(443/TCP)"]
        HFTgiAPI["HuggingFace TGI"]
    end

    OGX -->|primary RHOAI backend| vLLM
    OGX -->|local inference| Ollama
    OGX -->|cloud inference| OpenAIAPI
    OGX -->|cloud inference| AnthropicAPI
    OGX -->|cloud inference| GeminiAPI
    OGX -->|cloud inference| BedrockAPI
    OGX -->|cloud inference| NVIDIANIMAPI
    OGX -->|model serving| DatabricksAPI
    OGX -->|inference| HFTgiAPI

    %% Optional Local Inference
    subgraph InferenceLocal["Optional Local Inference"]
        Torch["torch >=2.6.0"]
        VLLMInline["vllm (inline)"]
        LiteLLM["litellm<br/>(multi-provider)"]
    end

    OGX -.->|GPU inference| Torch
    OGX -.->|in-process vLLM| VLLMInline
    OGX -.->|multi-provider| LiteLLM

    %% Vector Databases
    subgraph VectorDBs["Vector Database Providers"]
        PGVector["PostgreSQL pgvector<br/>(5432/TCP)"]
        Chroma["Chroma"]
        Qdrant["Qdrant"]
        Milvus["Milvus"]
        Weaviate["Weaviate"]
        FAISS["FAISS (local)"]
        SQLiteVec["sqlite-vec"]
    end

    OGX -->|vector storage| PGVector
    OGX -.->|vector DB| Chroma
    OGX -.->|vector DB| Qdrant
    OGX -.->|vector DB| Milvus
    OGX -.->|vector DB| Weaviate
    OGX -.->|local vector| FAISS
    OGX -.->|local vector| SQLiteVec

    %% KV Stores
    subgraph KVStores["KV Store Backends"]
        Redis["Redis<br/>(6379/TCP)"]
        MongoDB["MongoDB<br/>(27017/TCP)"]
        SQLite["SQLite<br/>(file-based, default)"]
    end

    OGX -->|session/cache| Redis
    OGX -->|KV store| MongoDB
    OGX -->|default KV store| SQLite

    %% Tool Providers
    subgraph ToolProviders["Tool Providers"]
        BraveSearch["Brave Search API"]
        TavilySearch["Tavily Search API"]
        BingSearch["Bing Search API"]
        WolframAlpha["Wolfram Alpha API"]
        MCPServers["MCP Servers"]
    end

    OGX -.->|search tools| BraveSearch
    OGX -.->|search tools| TavilySearch
    OGX -.->|search tools| BingSearch
    OGX -.->|computation| WolframAlpha
    OGX -.->|tool protocol| MCPServers

    %% Auth Providers
    subgraph AuthProviders["Auth Providers"]
        OIDCProvider["OIDC Provider<br/>(JWKS / Introspection)"]
        CustomAuthEP["Custom Auth Endpoint"]
    end

    OGX -.->|JWT validation| OIDCProvider
    OGX -.->|token validation| CustomAuthEP

    %% Observability
    subgraph Observability["Observability"]
        OTelCollector["OpenTelemetry Collector"]
        OTelSDK["opentelemetry-sdk"]
    end

    OGX -.->|traces/metrics| OTelCollector
    OGX -.->|instrumentation| OTelSDK

