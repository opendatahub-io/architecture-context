graph TB
    subgraph Note["SECURITY CONTEXT"]
        direction TB
        InfoNote["OpenVINO is a NATIVE C++ LIBRARY<br/>No network exposure, no ports, no TLS, no auth<br/>All interactions are in-process C++ API calls"]
    end

    subgraph OVMSContainer["OVMS Container (network boundary owner)"]
        direction TB

        subgraph OVMSLayer["OVMS Application Layer"]
            OVMSgRPC["OVMS gRPC Handler<br/>(network-facing)"]
            OVMSREST["OVMS REST Handler<br/>(network-facing)"]
        end

        subgraph OpenVINOLibs["OpenVINO Shared Libraries (IN-PROCESS)<br/>No network listeners, no TLS, no auth"]
            direction TB

            subgraph RuntimeLayer["Runtime Layer"]
                OVCore["ov::Core<br/>libopenvino.so<br/>Model loading & compilation"]
                InferReq["Inference Request<br/>Scheduling & execution"]
            end

            subgraph FrontendLayer["Frontend Layer (File I/O only)"]
                ONNXFrontend["ONNX Frontend<br/>protobuf parsing"]
                TFFrontend["TensorFlow Frontend<br/>37 proto definitions"]
                TFLiteFrontend["TFLite Frontend<br/>flatbuffers parsing"]
                OtherFrontend["PyTorch / PaddlePaddle / IR<br/>Format conversion"]
            end

            subgraph PluginLayer["Plugin Layer (Device drivers only)"]
                CPUPlugin["Intel CPU Plugin<br/>libopenvino_intel_cpu_plugin.so<br/>oneDNN, AVX2/AVX-512/AMX, xbyak JIT"]
                GPUPlugin["Intel GPU Plugin<br/>libopenvino_intel_gpu_plugin.so<br/>OpenCL, oneDNN GPU"]
                AutoPlugin["Auto / AutoBatch / Hetero<br/>Device selection & scheduling"]
            end
        end
    end

    subgraph LocalResources["LOCAL RESOURCES (no network)"]
        ModelFiles["Model Files<br/>ONNX / SavedModel / IR / TFLite<br/>Local filesystem / mounted volume"]
        IntelCPU["Intel CPU Hardware<br/>Pure compute<br/>No network I/O"]
        IntelGPU["Intel GPU Hardware<br/>Pure compute<br/>No network I/O"]
    end

    %% In-process flows (no network)
    OVMSgRPC -->|"C++ API<br/>in-process call<br/>NO NETWORK"| OVCore
    OVMSREST -->|"C++ API<br/>in-process call<br/>NO NETWORK"| OVCore
    OVCore --> InferReq
    OVCore --> ONNXFrontend
    OVCore --> TFFrontend
    OVCore --> TFLiteFrontend
    OVCore --> OtherFrontend
    InferReq --> AutoPlugin
    AutoPlugin --> CPUPlugin
    AutoPlugin --> GPUPlugin

    %% Local I/O (no network)
    ONNXFrontend -->|"File I/O<br/>NO NETWORK"| ModelFiles
    TFFrontend -->|"File I/O<br/>NO NETWORK"| ModelFiles
    TFLiteFrontend -->|"File I/O<br/>NO NETWORK"| ModelFiles
    OtherFrontend -->|"File I/O<br/>NO NETWORK"| ModelFiles
    CPUPlugin -->|"Device driver<br/>oneDNN/xbyak<br/>NO NETWORK"| IntelCPU
    GPUPlugin -->|"OpenCL ICD<br/>NO NETWORK"| IntelGPU

    %% Styling
    classDef note fill:#fff3cd,stroke:#856404,stroke-width:2px,color:#856404
    classDef ovms fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef openvino fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef local fill:#f9f9f9,stroke:#999,stroke-width:2px

    class InfoNote note
    class OVMSgRPC,OVMSREST ovms
    class OVCore,InferReq,ONNXFrontend,TFFrontend,TFLiteFrontend,OtherFrontend,CPUPlugin,GPUPlugin,AutoPlugin openvino
    class ModelFiles,IntelCPU,IntelGPU local
