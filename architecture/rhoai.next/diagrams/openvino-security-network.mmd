graph TB
    subgraph External["EXTERNAL (Network — handled by OVMS)"]
        Client["External Client<br/>gRPC/REST"]
    end

    subgraph OVMSBoundary["OVMS CONTAINER PROCESS"]
        direction TB

        OVMS["OpenVINO Model Server<br/>(network I/O, TLS, auth)<br/>Ports: 8443/gRPC, 8080/REST"]

        subgraph InProcess["IN-PROCESS (libopenvino.so — no network)"]
            direction TB

            subgraph RuntimeLayer["OpenVINO Runtime"]
                Runtime["ov::Core<br/>Model loading, compilation,<br/>inference scheduling<br/>Threading: Intel oneTBB"]
            end

            subgraph FrontendLayer["Frontends (Deserialization Surface)"]
                direction LR
                FE_ONNX["ONNX Frontend<br/>protobuf 3.21.12"]
                FE_TF["TensorFlow Frontend<br/>37 proto definitions"]
                FE_TFL["TF Lite Frontend<br/>flatbuffers"]
                FE_Other["PyTorch / PaddlePaddle<br/>/ IR (pugixml)"]
            end

            subgraph CoreLayer["Core + Transformations"]
                CoreGraph["ov::Model Graph<br/>200+ ops, opsets 1-13"]
                TransformPipeline["Optimization Passes<br/>Constant fold, op fusion,<br/>INT8/INT4 quantization"]
                JIT["Snippets + xbyak<br/>JIT kernel generation<br/>(executable memory)"]
            end

            subgraph PluginLayer["Device Plugins (.so dynamic loading)"]
                direction LR
                CPUPlugin["CPU Plugin<br/>oneDNN + xbyak JIT<br/>AVX2/AVX-512/AMX"]
                GPUPlugin["GPU Plugin<br/>OpenCL ICD"]
                AutoPlugin["Auto/Hetero/Batch<br/>Orchestration"]
            end
        end
    end

    subgraph Hardware["HARDWARE"]
        direction LR
        IntelCPU["Intel CPU<br/>ISA: AVX2/AVX-512/AMX"]
        IntelGPU["Intel GPU<br/>OpenCL driver"]
    end

    subgraph FileSystem["FILE SYSTEM (Read-Only)"]
        Models["Model Files<br/>ONNX, SavedModel, TF Lite,<br/>IR (XML+bin), PaddlePaddle"]
    end

    %% Network flows (OVMS handles these, not OpenVINO)
    Client -->|"gRPC/8443 or REST/8080<br/>TLS (OVMS-managed)<br/>Auth: OVMS/RHOAI"| OVMS

    %% In-process flows (C++ API, no network)
    OVMS -->|"C++ API<br/>in-process call"| Runtime
    Runtime -->|"select by format"| FrontendLayer
    FrontendLayer -->|"ov::Model"| CoreGraph
    CoreGraph --> TransformPipeline
    TransformPipeline --> JIT
    Runtime -->|"plugin API<br/>.so loading"| PluginLayer

    %% Hardware access
    CPUPlugin -->|"oneDNN kernels<br/>ISA instructions"| IntelCPU
    GPUPlugin -->|"OpenCL commands"| IntelGPU

    %% File access
    FrontendLayer -->|"File I/O<br/>read-only"| Models

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ovms fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef inprocess fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security_risk fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef filesystem fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class OVMS ovms
    class Runtime,CoreGraph,TransformPipeline inprocess
    class FE_ONNX,FE_TF,FE_TFL,FE_Other security_risk
    class JIT security_risk
    class CPUPlugin,GPUPlugin,AutoPlugin inprocess
    class IntelCPU,IntelGPU hardware
    class Models filesystem
