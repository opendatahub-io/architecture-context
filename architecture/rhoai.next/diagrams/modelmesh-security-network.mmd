graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(Inference / Management)"]
    end

    subgraph PodBoundary["MODELMESH POD (ServingRuntime)"]
        direction TB

        subgraph MMSidecar["ModelMesh Sidecar (Java 21)"]
            direction TB
            GrpcServer["ModelMeshApi gRPC Server<br/>8033/TCP<br/>TLS (BoringSSL-static)<br/>ClientAuth: NONE/REQUIRE/OPTIONAL<br/>FIPS: DISABLED"]
            HealthProbes["Health Probes<br/>8089/TCP HTTP<br/>No encryption, No auth"]
            MetricsServer["Prometheus Metrics<br/>2112/TCP HTTPS<br/>TLS (self-signed, BouncyCastle)<br/>No auth"]
            PreStop["PreStop Server<br/>8090/TCP HTTP<br/>No encryption, No auth"]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)<br/>ModelRuntime gRPC API"]
        end

        GrpcServer -->|"gRPC 8085/TCP or UDS<br/>plaintext (localhost)<br/>No auth"| ModelRuntime
    end

    subgraph PeerZone["PEER PODS (Same Deployment)"]
        PeerPod["ModelMesh Peer<br/>Headless ClusterIP Service<br/>model-mesh"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd Cluster<br/>2379/TCP gRPC<br/>TLS (configurable)<br/>Client cert (optional)"]
        ModelStorage["Model Storage (S3/PVC)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM / access keys"]
        Prometheus["Prometheus Server<br/>scrapes 2112/TCP"]
        StatsD["StatsD/Datadog Agent<br/>8125/UDP StatsD<br/>No encryption"]
    end

    %% External to Pod
    Client -->|"gRPC 8033/TCP<br/>TLS (optional)<br/>mTLS (optional)"| GrpcServer

    %% Inter-pod
    GrpcServer -->|"Thrift/Litelinks 8080/TCP<br/>TLS (optional)<br/>mTLS (optional)<br/>Request forwarding"| PeerPod

    %% Pod to external services
    GrpcServer -->|"gRPC 2379/TCP<br/>TLS (configurable)<br/>Client cert (optional)<br/>Model registry, leader election"| etcd
    ModelRuntime -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>IAM / access keys<br/>Model artifact download"| ModelStorage

    %% Monitoring
    Prometheus -->|"scrape HTTPS 2112/TCP<br/>TLS (self-signed)"| MetricsServer
    GrpcServer -.->|"UDP 8125<br/>StatsD metrics"| StatsD

    %% Health
    K8s["Kubernetes<br/>kubelet"] -->|"HTTP 8089/TCP<br/>/ready, /live"| HealthProbes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef peer fill:#c4b5fd,stroke:#7c3aed,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e8e8e8,stroke:#999,stroke-width:1px

    class Client external
    class GrpcServer,HealthProbes,MetricsServer,PreStop sidecar
    class ModelRuntime runtime
    class PeerPod peer
    class etcd,ModelStorage externalservice
    class Prometheus,StatsD,K8s monitoring
