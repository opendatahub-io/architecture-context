graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / modelmesh-serving<br/>Controller"]
    end

    subgraph PodBoundary["MODELMESH POD (Namespace Boundary)"]
        direction TB

        subgraph SidecarContainer["ModelMesh Sidecar Container"]
            direction TB
            API["ModelMeshApi<br/>:8033/TCP gRPC/HTTP2<br/>TLS (optional)<br/>mTLS client auth (optional)"]
            Cache["SidecarModelMesh<br/>LRU Cache & Router"]
            Litelinks["Litelinks Thrift<br/>:8080/TCP<br/>TLS (optional)<br/>mTLS (optional)"]
            Metrics["Prometheus Server<br/>:2112/TCP HTTPS<br/>TLS (self-signed)"]
            Health["Health Probes<br/>:8089/TCP HTTP<br/>No encryption"]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            Runtime["Model Runtime<br/>(Triton/MLServer)<br/>:8085/TCP or UDS<br/>plaintext gRPC"]
        end

        Cache -->|"gRPC :8085/TCP<br/>or UDS /tmp/mmesh/grpc.sock<br/>plaintext<br/>No auth"| Runtime
    end

    subgraph IntraCluster["INTRA-CLUSTER (Instance Mesh)"]
        RemoteMM["Other ModelMesh Instances<br/>:8080/TCP Thrift<br/>TLS + mTLS (optional)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        direction TB
        etcd["etcd (model-mesh-etcd)<br/>:2379/TCP gRPC<br/>TLS (optional)<br/>Client cert (optional)"]
        Prometheus["Prometheus<br/>Scrapes :2112/TCP HTTPS"]
        K8sAPI["Kubernetes API<br/>ConfigMap watch<br/>Downward API"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        direction TB
        ZK["ZooKeeper (alt)<br/>:2181/TCP<br/>TLS + SASL (optional)"]
        PayloadProc["Payload Processor<br/>configurable/TCP<br/>HTTP/HTTPS (optional)"]
        StatsD["StatsD Server<br/>:8125/UDP<br/>No encryption"]
    end

    %% External → Pod
    Client -->|"gRPC/HTTP2 :8033<br/>TLS (opt) + mTLS (opt)<br/>PKCS8 keys"| API
    API --> Cache

    %% Inter-instance
    Litelinks <-->|"Thrift/TCP :8080<br/>TLS (MM_ENABLE_SSL)<br/>mTLS (MM_INTRACLUSTER_CLIENTAUTH)"| RemoteMM

    %% Platform services
    Cache -->|"gRPC :2379<br/>TLS (opt)<br/>Client cert (opt)"| etcd
    Prometheus -->|"HTTPS :2112<br/>TLS (self-signed)"| Metrics
    K8sAPI -.->|"file watch<br/>downward API"| Cache

    %% External services (optional)
    Cache -.->|"ZK proto :2181<br/>TLS + SASL (opt)"| ZK
    Cache -.->|"HTTP/HTTPS<br/>TLS (opt)"| PayloadProc
    Cache -.->|"UDP :8125<br/>No encryption"| StatsD

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#333,stroke-width:1px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef intracluster fill:#e9d5ff,stroke:#8b5cf6,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class API,Cache,Litelinks,Metrics,Health sidecar
    class Runtime runtime
    class RemoteMM intracluster
    class etcd,Prometheus,K8sAPI platform
    class ZK,PayloadProc,StatsD externalservice
