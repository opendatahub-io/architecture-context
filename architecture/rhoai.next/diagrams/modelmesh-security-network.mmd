graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / modelmesh-serving<br/>Controller"]
    end

    subgraph PodBoundary["SERVING RUNTIME POD (Trust Boundary)"]
        direction TB

        subgraph SidecarContainer["ModelMesh Sidecar Container"]
            direction TB
            API["ModelMeshApi<br/>:8033/TCP gRPC/HTTP2<br/>TLS (opt) + mTLS (opt)<br/>Netty SSL handler"]
            MM["SidecarModelMesh<br/>LRU Cache & Routing"]
            VMM["VModelManager<br/>(leader only)"]
            LL["Litelinks Service<br/>:8080/TCP Thrift/TCP<br/>TLS (opt) + mTLS (opt)"]
            Metrics["Prometheus Metrics<br/>:2112/TCP HTTPS<br/>TLS (self-signed)<br/>No auth"]
            Health["Health Probes<br/>:8089/TCP HTTP<br/>No encryption, No auth"]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            Runtime["Model Runtime<br/>(Triton, MLServer)<br/>:8085/TCP or UDS<br/>gRPC plaintext<br/>No auth"]
        end
    end

    subgraph IntraCluster["INTRA-CLUSTER (Pod-to-Pod)"]
        OtherMM["Other ModelMesh<br/>Instances<br/>:8080/TCP Thrift"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd (model-mesh-etcd)<br/>:2379/TCP gRPC<br/>TLS (opt)<br/>Client cert (opt)"]
        ZK["ZooKeeper (alternative)<br/>:2181/TCP<br/>TLS (opt), SASL (opt)"]
        StatsD["StatsD (optional)<br/>:8125/UDP<br/>No encryption"]
        PayloadProc["Payload Processor (opt)<br/>HTTP/HTTPS<br/>TLS (opt)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Scraper"]
        K8s["Kubernetes<br/>Probe Controller"]
    end

    %% External to Pod flows
    Client -->|"gRPC :8033/TCP<br/>TLS + mTLS (opt)<br/>PKCS8 keys"| API

    %% Internal pod flows
    API -->|"in-process"| MM
    MM -->|"in-process"| VMM
    MM -->|"gRPC :8085 or UDS<br/>plaintext, no auth<br/>pod-local only"| Runtime
    MM -->|"Thrift forward"| LL

    %% Inter-instance flows
    LL <-->|"Thrift :8080/TCP<br/>TLS (MM_ENABLE_SSL)<br/>mTLS (INTRACLUSTER_CLIENTAUTH)"| OtherMM

    %% Egress flows
    MM -->|"gRPC :2379/TCP<br/>TLS (opt)<br/>Client cert (opt)"| etcd
    VMM -->|"gRPC :2379/TCP<br/>vmodel records"| etcd
    MM -.->|":2181/TCP<br/>TLS + SASL (opt)"| ZK
    MM -.->|"UDP :8125<br/>no encryption"| StatsD
    MM -.->|"HTTP/S<br/>TLS (opt)"| PayloadProc

    %% Monitoring flows
    Prometheus -->|"HTTPS :2112/TCP<br/>TLS (self-signed)<br/>no auth"| Metrics
    K8s -->|"HTTP :8089/TCP<br/>no encryption<br/>GET /ready, /live"| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef sidecar fill:#4a90e2,color:#fff,stroke:#2563eb,stroke-width:2px
    classDef runtime fill:#7ed321,color:#fff,stroke:#5cb300,stroke-width:2px
    classDef intracluster fill:#e9d5ff,stroke:#9333ea,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e8e8e8,stroke:#666,stroke-width:1px

    class Client external
    class API,MM,VMM,LL,Metrics,Health sidecar
    class Runtime runtime
    class OtherMM intracluster
    class etcd,ZK,StatsD,PayloadProc extservice
    class Prometheus,K8s monitoring
