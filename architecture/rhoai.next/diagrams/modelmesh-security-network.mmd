graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Proxy"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph PodA["ServingRuntime Pod (Instance A)"]
            direction TB

            subgraph MMSidecar["ModelMesh Sidecar"]
                GrpcAPI["gRPC API Server<br/>8033/TCP<br/>Optional TLS/mTLS"]
                HealthProbes["Health Probes<br/>8089/TCP HTTP<br/>Plaintext, No Auth"]
                PreStop["PreStop Hook<br/>8090/TCP HTTP<br/>Plaintext, No Auth"]
                MetricsEP["Metrics Endpoint<br/>2112/TCP HTTPS<br/>Self-signed TLS, No Auth"]
            end

            subgraph RuntimeAdapter["Runtime Adapter"]
                Adapter["modelmesh-runtime-adapter"]
            end

            subgraph RuntimeContainer["Model Runtime"]
                Runtime["Triton / MLServer / Custom"]
            end
        end

        subgraph PodB["Other ModelMesh Instances"]
            OtherMM["ModelMesh Instance B+<br/>8033/TCP<br/>Thrift/gRPC"]
        end

        subgraph KVStore["Key-Value Store"]
            etcd["etcd Cluster<br/>2379/TCP gRPC<br/>Optional TLS"]
        end
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        PayloadProc["Remote Payload Processor<br/>Configurable Port<br/>HTTP/HTTPS"]
        StatsD["StatsD Collector<br/>8126/UDP<br/>No Encryption"]
        Prometheus["Prometheus<br/>Scrapes 2112/TCP<br/>HTTPS (self-signed)"]
    end

    %% External to Pod
    Client -->|"gRPC/8033<br/>TLS (optional)<br/>mTLS: NONE/REQUIRE/OPTIONAL"| GrpcAPI

    %% Pod-internal (no encryption)
    GrpcAPI -->|"gRPC/8085 or UDS<br/>No Encryption<br/>No Auth (localhost)"| Adapter
    Adapter --> Runtime

    %% Inter-instance
    GrpcAPI -->|"Thrift+gRPC/8033<br/>TLS (shared certs)<br/>mTLS (pod-to-pod)<br/>litelinks"| OtherMM

    %% KV Store
    GrpcAPI -->|"gRPC/2379<br/>TLS (optional)<br/>TLS client certs (optional)"| etcd

    %% Optional external
    GrpcAPI -.->|"HTTP/HTTPS<br/>Configurable TLS<br/>No Auth"| PayloadProc
    GrpcAPI -.->|"UDP/8126<br/>StatsD<br/>No Encryption"| StatsD
    Prometheus -.->|"HTTPS/2112<br/>Self-signed TLS<br/>No Auth"| MetricsEP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef kvstore fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Client external
    class GrpcAPI,HealthProbes,PreStop,MetricsEP sidecar
    class Adapter,Runtime pod
    class OtherMM pod
    class etcd kvstore
    class PayloadProc,StatsD,Prometheus optional
