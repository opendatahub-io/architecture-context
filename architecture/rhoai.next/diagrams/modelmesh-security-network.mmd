graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PodBoundary["MODELMESH POD (Trust Boundary)"]
        direction TB

        subgraph Sidecar["ModelMesh Sidecar (Java 21)"]
            GRPCServer["ModelMeshApi gRPC Server<br/>8033/TCP<br/>TLS (optional)<br/>mTLS: NONE|REQUIRE|OPTIONAL"]
            LitelinksRPC["Litelinks Inter-Pod RPC<br/>8080/TCP<br/>Thrift-over-TCP<br/>TLS (optional) + mTLS"]
            MetricsSrv["Prometheus Metrics<br/>2112/TCP HTTPS<br/>TLS (self-signed, BouncyCastle)<br/>No Auth"]
            HealthSrv["Health Probes<br/>8089/TCP HTTP<br/>No Encryption<br/>/ready, /live"]
            PreStopSrv["PreStop Server<br/>8090/TCP HTTP<br/>No Encryption<br/>/prestop"]
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            RuntimeGRPC["ModelRuntime gRPC<br/>8085/TCP or UDS<br/>plaintext (localhost)<br/>No Auth"]
        end

        GRPCServer -->|"gRPC 8085/TCP or UDS<br/>plaintext<br/>Trusted sidecar"| RuntimeGRPC
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod-to-Pod)"]
        OtherMM["Other ModelMesh Pods<br/>Headless Service: model-mesh<br/>clusterIP: None"]
        PromServer["Prometheus"]
        StatsD["StatsD Agent<br/>(localhost)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd Cluster<br/>2379/TCP gRPC<br/>TLS + mTLS (configurable)<br/>Secret: model-mesh-icd-etcd"]
        ModelStorage["Model Storage<br/>(S3 / PVC)<br/>443/TCP HTTPS (S3)<br/>IAM Auth (S3)"]
    end

    %% External flows
    Client -->|"gRPC/8033<br/>TLS (optional)<br/>mTLS client certs"| GRPCServer

    %% Inter-pod flows
    LitelinksRPC <-->|"Thrift/8080<br/>TLS (optional)<br/>mTLS (optional)<br/>Cache miss forwarding"| OtherMM

    %% Monitoring flows
    PromServer -->|"HTTPS/2112<br/>TLS (self-signed)<br/>Scrape /metrics"| MetricsSrv
    GRPCServer -.->|"UDP/8126<br/>StatsD<br/>No encryption"| StatsD

    %% External service flows
    GRPCServer -->|"gRPC/2379<br/>TLS + mTLS<br/>Model registry,<br/>leader election"| etcd
    RuntimeGRPC -->|"HTTPS/443 (S3)<br/>TLS + IAM<br/>Model artifacts"| ModelStorage

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef extservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#fecaca,stroke:#ef4444,stroke-width:2px

    class Client external
    class GRPCServer,LitelinksRPC,MetricsSrv,HealthSrv,PreStopSrv sidecar
    class RuntimeGRPC runtime
    class OtherMM,PromServer,StatsD cluster
    class etcd,ModelStorage extservice
