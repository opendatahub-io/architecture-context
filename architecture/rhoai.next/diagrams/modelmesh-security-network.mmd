graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Proxy"]
        Controller["modelmesh-serving Controller"]
    end

    subgraph Pod["MODELMESH POD (ServingRuntime)"]
        direction TB

        subgraph Sidecar["ModelMesh Sidecar Container"]
            GRPCServer["gRPC Server<br/>:8033/TCP<br/>TLS (configurable)<br/>mTLS: NONE/REQUIRE/OPTIONAL"]
            HealthProbes["Health Probes<br/>:8089/TCP HTTP<br/>Plaintext, No Auth"]
            MetricsEP["Metrics Server<br/>:2112/TCP HTTPS<br/>Self-signed TLS<br/>No Client Auth"]
            PreStop["PreStop Server<br/>:8090/TCP HTTP<br/>Plaintext, No Auth"]
        end

        subgraph Runtime["Model Runtime Container"]
            ModelRT["ModelRuntime Service<br/>:8085/TCP or UDS<br/>gRPC, No TLS<br/>No Auth (localhost)"]
        end

        GRPCServer -->|"gRPC :8085 or UDS<br/>No encryption<br/>Pod-internal"| ModelRT
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Headless Service)"]
        RemoteInstances["Other ModelMesh Instances<br/>Service: model-mesh (ClusterIP: None)<br/>:8033/TCP Thrift/gRPC<br/>TLS + mTLS (shared certs)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        etcd["etcd Cluster<br/>:2379/TCP gRPC<br/>TLS (optional)<br/>TLS Client Certs (optional)"]
        Prometheus["Prometheus<br/>Scrapes :2112/TCP<br/>HTTPS (self-signed)"]
        StatsD["StatsD Collector<br/>:8126/UDP<br/>No Encryption"]
        PayloadProc["Remote Payload Processor<br/>(optional)<br/>HTTP/HTTPS<br/>Configurable TLS"]
    end

    %% Inbound flows
    Client -->|"gRPC :8033<br/>TLS (optional)<br/>mTLS (configurable)"| GRPCServer
    Controller -->|"gRPC :8033<br/>TLS + mTLS<br/>register/unregister"| GRPCServer

    %% Inter-instance flows
    GRPCServer -->|"Thrift/gRPC :8033<br/>TLS + mTLS<br/>Inference forwarding"| RemoteInstances

    %% Outbound flows
    GRPCServer -->|"gRPC :2379<br/>TLS (optional)<br/>Model records, leader election"| etcd
    Prometheus -->|"HTTPS :2112<br/>Self-signed TLS<br/>Scrape /metrics"| MetricsEP
    GRPCServer -.->|"UDP :8126<br/>No encryption<br/>(optional)"| StatsD
    GRPCServer -.->|"HTTP/HTTPS<br/>Configurable TLS<br/>(optional)"| PayloadProc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Client,Controller external
    class GRPCServer,HealthProbes,MetricsEP,PreStop sidecar
    class ModelRT runtime
    class RemoteInstances cluster
    class etcd,Prometheus,StatsD,PayloadProc extsvc
