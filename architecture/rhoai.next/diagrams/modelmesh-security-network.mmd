graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Proxy"]
    end

    subgraph ModelMeshPod["MODELMESH POD"]
        direction TB

        subgraph MMContainer["ModelMesh Sidecar (Java 21)"]
            GRPC_API["gRPC API<br/>8033/TCP<br/>Optional TLS<br/>Optional mTLS"]
            Health["Health Probes<br/>8089/TCP HTTP<br/>Plaintext, No Auth"]
            Metrics["Prometheus Metrics<br/>2112/TCP HTTPS<br/>Self-signed TLS, No Auth"]
            PreStop["PreStop Hook<br/>8090/TCP HTTP<br/>Plaintext, No Auth"]
        end

        subgraph RuntimeContainer["Colocated Runtime Container"]
            Runtime["Model Runtime<br/>(Triton / MLServer / Custom)"]
        end

        subgraph AdapterContainer["Runtime Adapter"]
            Adapter["modelmesh-runtime-adapter"]
        end

        GRPC_API -->|"gRPC :8085 or UDS<br/>No encryption<br/>No auth<br/>(pod-internal)"| Adapter
        Adapter -->|"bridges"| Runtime
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Pod-to-Pod)"]
        RemoteMM["Other ModelMesh<br/>Instances"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        etcd["etcd Cluster<br/>:2379/TCP gRPC<br/>Optional TLS<br/>Optional TLS Client Certs"]
        Controller["modelmesh-serving<br/>Controller"]
        Prometheus["Prometheus"]
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        StatsD["StatsD Collector<br/>:8126/UDP<br/>No encryption"]
        PayloadProc["Remote Payload<br/>Processor<br/>HTTP/HTTPS POST<br/>⚠ Data Governance"]
    end

    %% External → ModelMesh
    Client -->|"gRPC/8033<br/>TLS optional<br/>mTLS: NONE/REQUIRE/OPTIONAL"| GRPC_API

    %% ModelMesh ↔ Other Instances
    GRPC_API -->|"Thrift/gRPC :8033<br/>TLS (shared certs)<br/>mTLS pod-to-pod"| RemoteMM

    %% ModelMesh → Platform Services
    GRPC_API -->|"gRPC/2379<br/>Optional TLS<br/>Optional client certs"| etcd
    Controller -->|"gRPC/8033<br/>TLS/mTLS<br/>register/unregister"| GRPC_API
    Prometheus -->|"HTTPS/2112<br/>Self-signed TLS<br/>scrape /metrics"| Metrics

    %% ModelMesh → Optional External
    GRPC_API -.->|"StatsD/8126 UDP<br/>No encryption"| StatsD
    GRPC_API -.->|"HTTP(S) POST<br/>Configurable TLS<br/>Payload logging"| PayloadProc

    %% Kubernetes → Health
    K8s["Kubernetes"] -->|"HTTP/8089<br/>Plaintext"| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef modelmesh fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class GRPC_API,Health,Metrics,PreStop modelmesh
    class Runtime,Adapter runtime
    class etcd,Controller,Prometheus platform
    class StatsD,PayloadProc optional
    class RemoteMM cluster
    class K8s external
