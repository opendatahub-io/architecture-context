graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe InferenceService"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph PodBoundary["ModelMesh Pod Boundary"]
            direction TB

            subgraph MeshSidecar["ModelMesh Container"]
                API["ModelMeshApi (gRPC)<br/>Port: 8033/TCP<br/>Encryption: TLS (PKCS8, optional)<br/>Auth: mTLS (NONE/REQUIRE/OPTIONAL)"]
                Mesh["SidecarModelMesh<br/>Distributed Cache & Router"]
                Metrics["Prometheus Metrics<br/>Port: 2112/TCP<br/>Encryption: TLS (self-signed, optional)<br/>Auth: None"]
                Health["Health Probes<br/>Port: 8089/TCP<br/>Encryption: None<br/>Auth: None"]
                PreStop["PreStop Server<br/>Port: configurable/TCP<br/>Encryption: None<br/>Auth: None"]
            end

            subgraph RuntimeSidecar["Model Runtime Container"]
                RuntimeGRPC["ModelRuntime gRPC<br/>Port: 8085/TCP or UDS<br/>Encryption: plaintext (localhost)<br/>Auth: None"]
            end

            Mesh -->|"gRPC 8085/TCP or UDS<br/>plaintext (localhost-only)<br/>No auth"| RuntimeGRPC
        end

        subgraph PeerPods["Other ModelMesh Pods (Same Deployment)"]
            PeerMesh["Peer ModelMesh Instance<br/>Port: 8080/TCP<br/>Thrift (Litelinks)"]
        end

        Mesh <-->|"Thrift 8080/TCP<br/>TLS (optional, same keypair)<br/>mTLS (configurable via<br/>MM_INTRACLUSTER_CLIENTAUTH)"| PeerMesh
    end

    subgraph CoordinationStore["COORDINATION STORE"]
        etcd["etcd Cluster<br/>Port: 2379/TCP<br/>gRPC<br/>TLS (configurable)<br/>Auth: Client cert (configurable)"]
    end

    subgraph Monitoring["MONITORING (Optional)"]
        Prometheus["Prometheus Server"]
        StatsD["StatsD / Sysdig<br/>Port: 8126/UDP<br/>No encryption<br/>No auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        RemotePayload["Remote Payload Processor<br/>Port: configurable/TCP<br/>HTTP/HTTPS<br/>TLS (optional)<br/>Auth: None"]
    end

    %% External flows
    Client -->|"gRPC 8033/TCP<br/>TLS (PKCS8 key)<br/>mTLS client certs<br/>(NONE/REQUIRE/OPTIONAL)"| API

    %% Internal flows
    Mesh -->|"gRPC 2379/TCP<br/>TLS (configurable)<br/>Client cert (configurable)"| etcd

    Prometheus -->|"HTTP(S) 2112/TCP<br/>TLS (self-signed)<br/>No auth"| Metrics

    Mesh -->|"UDP 8126<br/>No encryption<br/>No auth"| StatsD

    Mesh -->|"HTTP/HTTPS<br/>TLS (optional)<br/>No auth"| RemotePayload

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef runtime fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef coordination fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class API ingress
    class Mesh,Health,PreStop,Metrics internal
    class RuntimeGRPC runtime
    class PeerMesh internal
    class etcd coordination
    class Prometheus,StatsD monitoring
    class RemotePayload extsvc
