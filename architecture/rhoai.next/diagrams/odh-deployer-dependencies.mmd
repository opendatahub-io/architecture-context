graph LR
    ODHDeployer["odh-deployer<br/>(Init Container)"]

    %% External Dependencies
    ODHDeployer -->|"oc CLI<br/>(applies resources)"| OC["oc (OpenShift CLI)<br/>latest"]
    ODHDeployer -->|"base image"| UBI["UBI8 minimal<br/>8.x"]

    %% Internal Platform Dependencies (KfDef-based)
    ODHDeployer -->|"creates KfDef CRs"| Operator["rhods-operator<br/>(opendatahub operator)"]
    ODHDeployer -->|"KfDef + CRDs<br/>(OdhApplication, OdhDocument,<br/>OdhQuickStart, OdhDashboardConfig)"| Dashboard["odh-dashboard"]
    ODHDeployer -->|"KfDef<br/>(rhods-nbc)"| NBC["odh-notebook-controller"]
    ODHDeployer -->|"KfDef<br/>(rhods-model-mesh)"| ModelMesh["model-mesh"]
    ODHDeployer -->|"KfDef<br/>(rhods-data-science-<br/>pipelines-operator)"| DSPO["data-science-pipelines-<br/>operator"]
    ODHDeployer -->|"KfDef + Secret"| Anaconda["Anaconda CE"]

    %% Monitoring Dependencies
    ODHDeployer -->|"federation<br/>9091/TCP HTTPS"| OcpProm["OpenShift Prometheus<br/>(openshift-monitoring)"]

    %% Integration Points (other components integrating with deployer outputs)
    OcpConsole["OpenShift Console"] -.->|"ConsoleLink CR"| ODHDeployer
    SegmentIO["Segment.io"] -.->|"analytics key<br/>(ConfigMap + Secret)"| ODHDeployer

    %% External Services (managed service alerting)
    ODHDeployer -->|"critical alerts<br/>443/TCP HTTPS"| PagerDuty["PagerDuty API"]
    ODHDeployer -->|"notifications<br/>SMTP TLS"| SMTP["SMTP Server"]
    ODHDeployer -->|"heartbeat<br/>443/TCP HTTPS"| DMS["Dead Man's Snitch"]

    %% Metrics scrape targets (from deployed monitoring)
    Dashboard -.->|"metrics 8080/TCP"| ODHDeployer
    NBC -.->|"metrics 8080/TCP"| ODHDeployer
    ModelMesh -.->|"metrics 8080/TCP"| ODHDeployer
    DSPO -.->|"metrics 8080/TCP"| ODHDeployer
    Operator -.->|"metrics 8383/TCP"| ODHDeployer

    %% Serving Runtimes
    ODHDeployer -->|"ServingRuntime<br/>Templates"| OVMS["OpenVINO Model Server<br/>(CPU + GPU)"]

    %% Styling
    style ODHDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style OC fill:#999,stroke:#333
    style UBI fill:#999,stroke:#333

    style Operator fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style NBC fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333

    style OcpProm fill:#e1d5e7,stroke:#9673a6
    style OcpConsole fill:#e1d5e7,stroke:#9673a6

    style PagerDuty fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SegmentIO fill:#f5a623,stroke:#333
    style Anaconda fill:#e6522c,stroke:#333,color:#fff
    style OVMS fill:#7ed321,stroke:#333
