graph LR
    OdhDeployer["odh-deployer<br/>(Init Container)"]

    %% External Dependencies
    OdhDeployer -->|"CLI for all<br/>cluster operations"| OcCLI["oc CLI<br/>(latest)"]
    OdhDeployer -->|"base image"| UBI["ubi8/ubi-minimal<br/>(latest)"]
    OdhDeployer -->|"secret generation<br/>& config hashing"| OpenSSL["openssl<br/>(latest)"]

    %% Internal Platform Dependencies (KfDef-based)
    OdhDeployer -->|"creates KfDef CRs<br/>operator watches"| RhodsOperator["rhods-operator<br/>(opendatahub operator)"]
    OdhDeployer -->|"manifests tarball<br/>in operator image"| OdhManifests["odh-manifests<br/>(tarball)"]

    %% Service Dependencies (monitoring waits for)
    OdhDeployer -.->|"monitoring init<br/>waits for :8443"| RhodsDashboard["rhods-dashboard"]
    OdhDeployer -.->|"monitoring init<br/>waits for :8080"| NotebookCtrl["odh-notebook-controller"]
    OdhDeployer -.->|"monitoring init<br/>waits for :8080"| ModelCtrl["odh-model-controller"]
    OdhDeployer -.->|"monitoring init<br/>waits for :8080"| ModelMeshCtrl["modelmesh-controller"]
    OdhDeployer -.->|"monitoring init<br/>waits for :8080"| DSPO["data-science-pipelines-operator"]

    %% Federated monitoring
    OdhDeployer -->|"Prometheus federates<br/>metrics :9091"| ClusterProm["prometheus-k8s<br/>(openshift-monitoring)"]

    %% Mode detection
    OdhDeployer -.->|"checks CatalogSource<br/>for managed mode"| AddonCatalog["addon-managed-odh-catalog<br/>(CatalogSource)"]

    %% Integration Points (things that consume deployer output)
    RhodsOperator -->|"reconciles KfDefs<br/>deploys components"| OdhDeployer
    OpenShiftConsole["OpenShift Console"] -->|"ConsoleLink CR<br/>Application Launcher"| OdhDeployer

    %% External Services (managed service only)
    OdhDeployer -->|"critical alerts<br/>HTTPS/443"| PagerDuty["PagerDuty"]
    OdhDeployer -->|"heartbeat<br/>HTTPS/443"| DMS["Dead Man's Snitch"]
    OdhDeployer -->|"email alerts<br/>SMTP/TLS"| SMTPServer["SMTP Server"]
    OdhDeployer -.->|"reads addon<br/>secrets"| OSDAddon["OSD Addon Framework"]

    %% Styling
    style OdhDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style OcCLI fill:#999,stroke:#333
    style UBI fill:#999,stroke:#333
    style OpenSSL fill:#999,stroke:#333

    style RhodsOperator fill:#7ed321,stroke:#333
    style OdhManifests fill:#7ed321,stroke:#333
    style RhodsDashboard fill:#7ed321,stroke:#333
    style NotebookCtrl fill:#7ed321,stroke:#333
    style ModelCtrl fill:#7ed321,stroke:#333
    style ModelMeshCtrl fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333

    style ClusterProm fill:#e8e8e8,stroke:#333
    style AddonCatalog fill:#e8e8e8,stroke:#333
    style OpenShiftConsole fill:#e8e8e8,stroke:#333

    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTPServer fill:#f5a623,stroke:#333
    style OSDAddon fill:#f5a623,stroke:#333
