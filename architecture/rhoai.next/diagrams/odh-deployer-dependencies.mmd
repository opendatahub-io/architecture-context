graph LR
    Deployer["odh-deployer<br/>(Init Container)"]

    %% External Dependencies
    Deployer -->|"CLI tool"| OC["oc CLI<br/>(latest)"]
    Deployer -->|"base image"| UBI["ubi8/ubi-minimal<br/>(latest)"]
    Deployer -->|"secret generation"| OpenSSL["openssl<br/>(latest)"]

    %% Internal Platform Dependencies - Direct
    Deployer -->|"creates KfDef CRs"| Operator["rhods-operator<br/>(opendatahub operator)"]
    Deployer -->|"references manifests"| Manifests["odh-manifests<br/>(tarball in operator image)"]

    %% Internal Platform Dependencies - Service checks
    Deployer -.->|"waits for service"| Dashboard["rhods-dashboard<br/>:8443"]
    Deployer -.->|"waits for metrics"| NBC["odh-notebook-controller<br/>:8080"]
    Deployer -.->|"waits for metrics"| ModelCtrl["odh-model-controller<br/>:8080"]
    Deployer -.->|"waits for metrics"| MMCtrl["modelmesh-controller<br/>:8080"]
    Deployer -.->|"waits for metrics"| DSPO["data-science-pipelines-operator<br/>:8080"]

    %% Cluster Dependencies
    Deployer -->|"federated scraping"| ClusterProm["prometheus-k8s<br/>(openshift-monitoring)<br/>:9091"]
    Deployer -->|"mode detection"| AddonCatalog["addon-managed-odh-catalog<br/>(CatalogSource)"]

    %% External Services (managed mode)
    Deployer -.->|"alert routing"| PagerDuty["PagerDuty<br/>:443 HTTPS"]
    Deployer -.->|"heartbeat"| DMS["Dead Man's Snitch<br/>:443 HTTPS"]
    Deployer -.->|"email notifications"| SMTP["SMTP Server<br/>TLS"]

    %% Integration Points - components that depend on deployer
    Console["OpenShift Console"] -->|"ConsoleLink CR"| Deployer
    OSD["OSD Addon Framework"] -->|"provisions secrets"| Deployer

    %% Styling
    style Deployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OC fill:#999,stroke:#333
    style UBI fill:#999,stroke:#333
    style OpenSSL fill:#999,stroke:#333
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style Manifests fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style NBC fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style MMCtrl fill:#7ed321,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style ClusterProm fill:#e1d5e7,stroke:#9673a6
    style AddonCatalog fill:#e1d5e7,stroke:#9673a6
    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style Console fill:#e1d5e7,stroke:#9673a6
    style OSD fill:#e1d5e7,stroke:#9673a6
