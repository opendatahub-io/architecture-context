graph LR
    ODHDeployer["odh-deployer<br/>(Deployment Job)"]

    %% External Dependencies
    ODHDeployer -->|"executes commands"| OC["OpenShift CLI (oc)<br/>latest"]
    ODHDeployer -->|"base image"| UBI["UBI 8 Minimal<br/>ubi8/ubi-minimal"]
    ODHDeployer -->|"auth proxy"| OAuthProxy["OpenShift OAuth Proxy<br/>openshift4/ose-oauth-proxy"]
    ODHDeployer -->|"metrics collection"| Prometheus["Prometheus<br/>openshift4/ose-prometheus"]
    ODHDeployer -->|"alert routing"| Alertmanager["Alertmanager<br/>openshift4/ose-prometheus-alertmanager"]

    %% Internal Platform Dependencies
    ODHDeployer -->|"creates KfDef CRs"| ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    ODHDeployer -->|"KfDef + config CRDs"| Dashboard["RHODS Dashboard"]
    ODHDeployer -->|"KfDef"| NBC["ODH Notebook Controller"]
    ODHDeployer -->|"KfDef"| ModelMesh["ModelMesh Serving"]
    ODHDeployer -->|"KfDef"| DSPO["Data Science Pipelines<br/>Operator"]
    ODHDeployer -->|"KfDef + Secret"| Anaconda["Anaconda CE"]
    ODHOperator -->|"installs from"| Manifests["odh-manifests<br/>(tarball file://)"]

    %% Components that integrate back
    Dashboard -.->|"monitored by"| ODHDeployer
    NBC -.->|"metrics scraped"| ODHDeployer
    ModelMesh -.->|"metrics scraped"| ODHDeployer
    DSPO -.->|"metrics scraped"| ODHDeployer

    %% External Services (managed only)
    ODHDeployer -.->|"critical alerts<br/>443/TCP HTTPS"| PagerDuty["PagerDuty<br/>(managed only)"]
    ODHDeployer -.->|"heartbeat<br/>443/TCP HTTPS"| DMS["Dead Man's Snitch<br/>(managed only)"]
    ODHDeployer -.->|"email alerts<br/>SMTP STARTTLS"| SMTP["SMTP Server<br/>(managed only)"]

    %% Cluster dependencies
    ODHDeployer -->|"federation<br/>9091/TCP HTTPS"| ClusterProm["OpenShift Cluster<br/>Prometheus"]
    ODHDeployer -->|"all API calls<br/>443/TCP HTTPS"| K8sAPI["OpenShift API Server"]
    ODHDeployer -->|"addon params"| OSDAddon["OSD Addon Framework"]

