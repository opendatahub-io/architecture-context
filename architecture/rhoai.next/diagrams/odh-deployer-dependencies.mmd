graph LR
    ODHDeployer["odh-deployer<br/>(deploy.sh + manifests)"]

    %% External Dependencies
    ODHDeployer -->|"oc apply<br/>HTTPS/443"| OpenShiftAPI["OpenShift API Server"]
    ODHDeployer -->|"base image"| UBI8["UBI 8 Minimal"]
    ODHDeployer -->|"CLI tool"| OC["OpenShift CLI (oc)"]
    ODHDeployer -->|"auth proxy<br/>sidecar"| OAuthProxy["OpenShift<br/>OAuth Proxy"]
    ODHDeployer -->|"deploys<br/>monitoring"| Prometheus["Prometheus<br/>(ose-prometheus)"]
    ODHDeployer -->|"deploys<br/>alerting"| Alertmanager["Alertmanager<br/>(ose-prometheus-alertmanager)"]

    %% External Alerting (Managed Only)
    Alertmanager -->|"HTTPS/443<br/>Service Key"| PagerDuty["PagerDuty<br/>(managed only)"]
    Alertmanager -->|"HTTPS/443<br/>URL Token"| DMS["Dead Man's Snitch<br/>(managed only)"]
    Alertmanager -->|"STARTTLS<br/>Username/Pwd"| SMTP["SMTP Server<br/>(managed only)"]

    %% Internal ODH Dependencies
    ODHDeployer -->|"creates KfDef CRs"| ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    ODHDeployer -->|"KfDef + CRD config<br/>ISV tiles"| RHODSDashboard["RHODS Dashboard"]
    ODHDeployer -->|"KfDef"| NotebookCtrl["ODH Notebook<br/>Controller"]
    ODHDeployer -->|"KfDef"| ModelMesh["ModelMesh<br/>Serving"]
    ODHDeployer -->|"KfDef"| DSPO["Data Science Pipelines<br/>Operator"]
    ODHDeployer -->|"KfDef + Secret"| AnacondaCE["Anaconda CE"]
    ODHOperator -->|"reads manifests<br/>file://"| ODHManifests["odh-manifests<br/>(tarball)"]

    %% Integration Points (other components interacting with deployer outputs)
    Prometheus -->|"federation<br/>HTTPS/9091<br/>Bearer Token"| ClusterProm["OpenShift Cluster<br/>Prometheus"]
    Prometheus -->|"scrape<br/>HTTP/8080"| NotebookCtrl
    Prometheus -->|"scrape<br/>HTTP/8080"| ModelMesh
    Prometheus -->|"scrape<br/>HTTP/8080"| DSPO
    Prometheus -->|"scrape<br/>HTTP/8383"| RHODSOp["RHODS Operator"]
    Prometheus -->|"probe<br/>HTTPS/8443"| RHODSDashboard

    %% Environment detection
    ODHDeployer -->|"checks CatalogSource"| OSDAddon["OSD Addon<br/>Framework"]
    ODHDeployer -->|"ConsoleLink CR"| OSConsole["OpenShift Console"]
    ODHDeployer -->|"analytics config"| SegmentIO["Segment.io"]
    ODHDeployer -->|"ServingRuntime<br/>templates"| OVMS["OpenVINO Model<br/>Server"]

    %% Styling
    style ODHDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style UBI8 fill:#999,stroke:#333,color:#fff
    style OC fill:#999,stroke:#333,color:#fff
    style OAuthProxy fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style RHODSDashboard fill:#7ed321,stroke:#333,color:#fff
    style NotebookCtrl fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style AnacondaCE fill:#7ed321,stroke:#333,color:#fff
    style ODHManifests fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style ClusterProm fill:#999,stroke:#333,color:#fff
    style OSDAddon fill:#f5a623,stroke:#333
    style OSConsole fill:#999,stroke:#333,color:#fff
    style SegmentIO fill:#f5a623,stroke:#333
    style OVMS fill:#7ed321,stroke:#333,color:#fff
