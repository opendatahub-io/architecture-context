graph LR
    ODHDeployer["odh-deployer<br/>(Bash Deployer)"]

    %% External Dependencies
    ODHDeployer -->|"oc apply<br/>443/TCP HTTPS"| OC["OpenShift CLI (oc)<br/>latest"]
    ODHDeployer -->|"base image"| UBI["UBI 8 Minimal"]
    ODHDeployer -->|"auth proxy<br/>9091, 10443/TCP"| OAuthProxy["OpenShift OAuth Proxy"]
    ODHDeployer -->|"metrics collection<br/>9090/TCP"| Prometheus["Prometheus"]
    ODHDeployer -->|"alert routing<br/>9093/TCP"| Alertmanager["Alertmanager"]
    ODHDeployer -.->|"critical alerts<br/>managed only<br/>443/TCP HTTPS"| PagerDuty["PagerDuty"]
    ODHDeployer -.->|"liveness check<br/>managed only<br/>443/TCP HTTPS"| DMS["Dead Man's Snitch"]
    ODHDeployer -.->|"email alerts<br/>managed only<br/>STARTTLS"| SMTP["SMTP Server"]

    %% Internal ODH Dependencies
    ODHDeployer -->|"creates KfDef CRs"| ODHOperator["ODH Operator<br/>(KfDef Controller)"]
    ODHDeployer -->|"KfDef + CRD config<br/>ISV tiles"| Dashboard["RHODS Dashboard"]
    ODHDeployer -->|"KfDef"| NBC["ODH Notebook<br/>Controller"]
    ODHDeployer -->|"KfDef"| ModelMesh["ModelMesh Serving"]
    ODHDeployer -->|"KfDef"| DSPO["Data Science Pipelines<br/>Operator"]
    ODHDeployer -->|"KfDef + Secret"| Anaconda["Anaconda CE"]
    ODHDeployer -->|"manifests tarball<br/>file://"| Manifests["odh-manifests"]

    %% Integration Points (components that interact with deployer's outputs)
    ODHOperator -->|"installs via KfDef"| Dashboard
    ODHOperator -->|"installs via KfDef"| NBC
    ODHOperator -->|"installs via KfDef"| ModelMesh
    ODHOperator -->|"installs via KfDef"| DSPO

    ODHDeployer -->|"ConsoleLink CR"| Console["OpenShift Console"]
    ODHDeployer -.->|"reads addon params<br/>managed only"| OSDAddon["OSD Addon<br/>Framework"]
    ODHDeployer -->|"ServingRuntime<br/>templates"| OVMS["OpenVINO Model Server"]
    ODHDeployer -->|"analytics config"| Segment["Segment.io"]

    %% Monitoring scrape targets
    Prometheus -->|"scrape 8080/TCP"| NBC
    Prometheus -->|"scrape 8080/TCP"| ModelMesh
    Prometheus -->|"scrape 8080/TCP"| DSPO
    Prometheus -->|"scrape 8383/TCP"| RHODSOp["RHODS Operator"]
    Prometheus -->|"federate 9091/TCP<br/>HTTPS"| ClusterProm["Cluster Prometheus"]

    %% Styling
    style ODHDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OC fill:#999,stroke:#333,color:#fff
    style UBI fill:#999,stroke:#333,color:#fff
    style OAuthProxy fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Alertmanager fill:#e6522c,stroke:#333,color:#fff
    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style ODHOperator fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style NBC fill:#7ed321,stroke:#333,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style Anaconda fill:#7ed321,stroke:#333,color:#fff
    style Manifests fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#999,stroke:#333,color:#fff
    style OSDAddon fill:#f5a623,stroke:#333
    style OVMS fill:#7ed321,stroke:#333,color:#fff
    style Segment fill:#f5a623,stroke:#333
    style ClusterProm fill:#999,stroke:#333,color:#fff
