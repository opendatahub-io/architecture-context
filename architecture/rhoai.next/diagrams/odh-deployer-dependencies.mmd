graph LR
    ODHDeployer["odh-deployer<br/>(Init Container)"]

    %% External Dependencies (Required)
    ODHDeployer -->|"CLI operations"| OcCLI["oc CLI<br/>(latest)"]
    ODHDeployer -->|"secret generation"| OpenSSL["openssl"]
    ODHDeployer -->|"KfDef reconciliation"| KfDefController["opendatahub-operator<br/>(KfDef Controller)"]
    ODHDeployer -->|"OAuth proxy auth<br/>(managed service)"| OSAuth["OpenShift OAuth"]

    %% Internal Platform Dependencies (KfDef-based)
    ODHDeployer -->|"KfDef CR creation"| RHODSOperator["rhods-operator"]
    ODHDeployer -->|"KfDef + CRDs +<br/>ISV tiles + Config"| Dashboard["odh-dashboard"]
    ODHDeployer -->|"KfDef CR"| NBC["odh-notebook-<br/>controller"]
    ODHDeployer -->|"KfDef CR +<br/>image refs"| ModelMesh["model-mesh"]
    ODHDeployer -->|"KfDef CR +<br/>image refs"| DSPO["data-science-pipelines-<br/>operator"]
    ODHDeployer -->|"KfDef CR"| Notebooks["rhods-notebooks"]
    ODHDeployer -->|"KfDef + direct<br/>manifests"| Monitoring["monitoring<br/>(Prometheus/Alertmanager)"]
    ODHDeployer -->|"KfDef CR + Secret"| Anaconda["anaconda-ce"]

    %% Monitoring Dependencies (Egress)
    Monitoring -->|"metrics federation<br/>9091/TCP HTTPS"| OSProm["OpenShift Prometheus<br/>Federation"]
    Monitoring -->|"critical alerts<br/>443/TCP HTTPS"| PagerDuty["PagerDuty API"]
    Monitoring -->|"liveness heartbeat<br/>443/TCP HTTPS"| DMS["Dead Man's Snitch"]
    Monitoring -->|"user alerts<br/>SMTP/TLS"| SMTP["SMTP Relay"]

    %% Integration Points (Other components integrating with deployer's resources)
    OSConsole["OpenShift Console"] -->|"ConsoleLink"| ODHDeployer

    %% Monitoring scrape targets
    Monitoring -.->|"metrics scrape<br/>8080/TCP HTTP"| NBC
    Monitoring -.->|"metrics scrape<br/>8080/TCP HTTP"| ModelMesh
    Monitoring -.->|"metrics scrape<br/>8080/TCP HTTP"| DSPO
    Monitoring -.->|"metrics scrape<br/>8383/TCP HTTP"| RHODSOperator
    Monitoring -.->|"health probe<br/>8443/TCP HTTPS"| Dashboard

    %% Cert provisioning
    CertSigner["OpenShift Serving<br/>Cert Signer"] -.->|"auto-provision TLS"| Monitoring

    %% Styling
    style ODHDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style OcCLI fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff
    style KfDefController fill:#999,stroke:#333,color:#fff
    style OSAuth fill:#999,stroke:#333,color:#fff
    style RHODSOperator fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style NBC fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style Notebooks fill:#7ed321,stroke:#333
    style Monitoring fill:#e8744f,stroke:#333,color:#fff
    style Anaconda fill:#7ed321,stroke:#333
    style OSProm fill:#f5a623,stroke:#333
    style PagerDuty fill:#f8cecc,stroke:#333
    style DMS fill:#f8cecc,stroke:#333
    style SMTP fill:#f8cecc,stroke:#333
    style OSConsole fill:#999,stroke:#333,color:#fff
    style CertSigner fill:#999,stroke:#333,color:#fff
