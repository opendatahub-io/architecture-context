graph LR
    ODHDeployer["odh-deployer<br/>(Bootstrap Container)"]

    %% External Dependencies
    ODHDeployer -->|"oc CLI interaction<br/>443/TCP HTTPS"| K8sAPI["OpenShift API Server"]
    ODHDeployer -->|"base image"| UBI8["UBI8-minimal<br/>registry.access.redhat.com"]
    ODHDeployer -->|"OAuth proxy sidecar"| OAuthProxy["ose-oauth-proxy<br/>registry.redhat.io<br/>(pinned by digest)"]
    ODHDeployer -->|"monitoring server"| PromImage["ose-prometheus<br/>registry.redhat.io<br/>(pinned by digest)"]
    ODHDeployer -->|"alert routing"| AlertImage["ose-prometheus-alertmanager<br/>registry.redhat.io<br/>(pinned by digest)"]
    ODHDeployer -->|"endpoint probing"| BBImage["prometheus-blackbox-exporter<br/>quay.io/integreatly<br/>(pinned by digest)"]
    ODHDeployer -->|"serving runtime"| OVMSImage["openvino_model_server<br/>quay.io/opendatahub<br/>(pinned by digest)"]

    %% Internal Platform Dependencies (KfDef triggers)
    ODHDeployer -->|"KfDef CRs trigger<br/>component deployment"| ODHOperator["opendatahub operator<br/>(KfDef Controller)"]
    ODHDeployer -->|"init container waits<br/>8443/TCP HTTPS"| Dashboard["rhods-dashboard"]
    ODHDeployer -->|"init container waits<br/>8080/TCP HTTP"| NBC["odh-notebook-controller"]
    ODHDeployer -->|"init container waits<br/>8080/TCP HTTP"| ModelCtrl["odh-model-controller"]
    ODHDeployer -->|"init container waits<br/>8080/TCP HTTP"| ModelMesh["modelmesh-controller"]
    ODHDeployer -->|"init container waits<br/>8080/TCP HTTP"| DSPO["data-science-pipelines-operator"]

    %% Monitoring integrations
    ODHDeployer -->|"federation<br/>9091/TCP HTTPS"| ClusterProm["OpenShift Prometheus<br/>(openshift-monitoring)"]
    ODHDeployer -->|"environment check"| CatalogSource["addon-managed-odh-catalog<br/>(CatalogSource)"]

    %% Managed service external dependencies
    ODHDeployer -.->|"critical alerts<br/>443/TCP HTTPS"| PagerDuty["PagerDuty API"]
    ODHDeployer -.->|"heartbeat<br/>443/TCP HTTPS"| DMS["Dead Man's Snitch"]
    ODHDeployer -.->|"email alerts<br/>SMTP STARTTLS"| SMTP["SMTP Server"]

    %% Secrets dependencies
    ODHDeployer -.->|"PagerDuty key"| PDSecret["redhat-rhods-pagerduty<br/>(Secret)"]
    ODHDeployer -.->|"DMS URL"| DMSSecret["redhat-rhods-deadmanssnitch<br/>(Secret)"]
    ODHDeployer -.->|"SMTP creds"| SMTPSecret["redhat-rhods-smtp<br/>(Secret)"]
    ODHDeployer -.->|"addon params"| AddonSecret["addon-managed-odh-parameters<br/>(Secret)"]

    %% Components that integrate with deployer's outputs
    DashboardUI["ODH Dashboard UI"] -->|"reads CRDs"| ODHDeployer
    ConsoleLink["OpenShift Console"] -->|"ConsoleLink CR"| ODHDeployer

    %% Styling
    style ODHDeployer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ODHOperator fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style NBC fill:#7ed321,stroke:#333
    style ModelCtrl fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style ClusterProm fill:#7ed321,stroke:#333
    style CatalogSource fill:#7ed321,stroke:#333
    style DashboardUI fill:#7ed321,stroke:#333

    style K8sAPI fill:#f5a623,stroke:#333
    style UBI8 fill:#999,stroke:#333,color:#fff
    style OAuthProxy fill:#999,stroke:#333,color:#fff
    style PromImage fill:#999,stroke:#333,color:#fff
    style AlertImage fill:#999,stroke:#333,color:#fff
    style BBImage fill:#999,stroke:#333,color:#fff
    style OVMSImage fill:#999,stroke:#333,color:#fff

    style PagerDuty fill:#f5a623,stroke:#333
    style DMS fill:#f5a623,stroke:#333
    style SMTP fill:#f5a623,stroke:#333
    style ConsoleLink fill:#f5a623,stroke:#333

    style PDSecret fill:#e8e8e8,stroke:#333
    style DMSSecret fill:#e8e8e8,stroke:#333
    style SMTPSecret fill:#e8e8e8,stroke:#333
    style AddonSecret fill:#e8e8e8,stroke:#333
