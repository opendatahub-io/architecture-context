graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(wva-system)"]
        SA_EPP["epp-metrics-reader"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Mgr["manager-rolebinding<br/>(Cluster)"]
        CRB_Auth["metrics-auth-rolebinding<br/>(Cluster)"]
        CRB_Reader["metrics-reader-rolebinding<br/>(Cluster)"]
        CRB_EPP["epp-metrics-reader-rolebinding<br/>(Cluster)"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(wva-system)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Mgr["manager-role"]
        CR_Auth["metrics-auth-role"]
        CR_Reader["metrics-reader"]
        CR_EPP["epp-metrics-reader-role"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role<br/>(wva-system)"]
    end

    subgraph UserFacing["User-Facing ClusterRoles"]
        CR_Admin["variantautoscaling-admin-role"]
        CR_Editor["variantautoscaling-editor-role"]
        CR_Viewer["variantautoscaling-viewer-role"]
    end

    %% SA → Binding → Role
    SA_CM -->|bound via| CRB_Mgr
    SA_CM -->|bound via| CRB_Auth
    SA_CM -->|bound via| CRB_Reader
    SA_CM -->|bound via| RB_Leader
    SA_EPP -->|bound via| CRB_EPP

    CRB_Mgr -->|grants| CR_Mgr
    CRB_Auth -->|grants| CR_Auth
    CRB_Reader -->|grants| CR_Reader
    CRB_EPP -->|grants| CR_EPP
    RB_Leader -->|grants| R_Leader

    %% manager-role resources
    subgraph ManagerResources["manager-role API Resources"]
        direction LR
        Res_Core["core<br/>configmaps, events,<br/>namespaces, pods,<br/>resourcequotas, secrets,<br/>services, nodes"]
        Res_Apps["apps<br/>deployments,<br/>deployments/scale,<br/>replicasets, statefulsets"]
        Res_Auto["autoscaling<br/>horizontalpodautoscalers"]
        Res_Inf["inference.networking.*<br/>inferencepools"]
        Res_Keda["keda.sh<br/>scaledobjects"]
        Res_LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets,<br/>leaderworkersets/scale"]
        Res_LLMD["llmd.ai<br/>variantautoscalings,<br/>variantautoscalings/finalizers,<br/>variantautoscalings/status"]
        Res_Mon["monitoring.coreos.com<br/>servicemonitors"]
    end

    CR_Mgr -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Res_Core
    CR_Mgr -->|"get,list,watch,<br/>patch,update"| Res_Apps
    CR_Mgr -->|"get,list,watch,<br/>patch,update"| Res_Auto
    CR_Mgr -->|"get,list,watch"| Res_Inf
    CR_Mgr -->|"get,list,watch"| Res_Keda
    CR_Mgr -->|"get,list,watch,<br/>patch,update"| Res_LWS
    CR_Mgr -->|"full CRUD"| Res_LLMD
    CR_Mgr -->|"get,list,watch"| Res_Mon

    %% Auth role resources
    subgraph AuthResources["metrics-auth-role Resources"]
        Res_TokenReview["authentication.k8s.io<br/>tokenreviews → create"]
        Res_SAR["authorization.k8s.io<br/>subjectaccessreviews → create"]
    end
    CR_Auth -->|create| Res_TokenReview
    CR_Auth -->|create| Res_SAR

    %% Metrics reader
    subgraph MetricsResources["Non-Resource URLs"]
        Res_Metrics["/metrics → get"]
        Res_Debug["/metrics, /debug/pprof/* → get"]
    end
    CR_Reader -->|get| Res_Metrics
    CR_EPP -->|get| Res_Debug

    %% Leader election
    subgraph LeaderResources["leader-election-role Resources"]
        Res_Leases["coordination.k8s.io<br/>leases → full CRUD"]
        Res_Events["core<br/>events → create, patch"]
    end
    R_Leader -->|full CRUD| Res_Leases
    R_Leader -->|create, patch| Res_Events

    %% User-facing roles
    subgraph VAResources["VariantAutoscaling Resources"]
        Res_VA["llmd.ai<br/>variantautoscalings"]
    end
    CR_Admin -->|"* (all verbs)"| Res_VA
    CR_Editor -->|"create,delete,get,<br/>list,patch,update,watch"| Res_VA
    CR_Viewer -->|"get,list,watch"| Res_VA

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style CR_Mgr fill:#f5a623,stroke:#333
    style CR_Auth fill:#f5a623,stroke:#333
    style CR_Reader fill:#f5a623,stroke:#333
    style CR_EPP fill:#f5a623,stroke:#333
    style R_Leader fill:#ed7d31,stroke:#333,color:#fff
    style CR_Admin fill:#9b59b6,stroke:#333,color:#fff
    style CR_Editor fill:#9b59b6,stroke:#333,color:#fff
    style CR_Viewer fill:#9b59b6,stroke:#333,color:#fff
    style Res_LLMD fill:#7ed321,stroke:#333
    style Res_VA fill:#7ed321,stroke:#333
