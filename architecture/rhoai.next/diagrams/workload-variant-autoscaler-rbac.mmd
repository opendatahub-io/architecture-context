graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(system namespace)"]
        SA_Prometheus["prometheus<br/>(monitoring namespace)"]
        SA_EPP["epp-metrics-reader"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_MetricsAuth["metrics-auth-rolebinding<br/>(cluster-scoped)"]
        CRB_MetricsReader["metrics-reader-rolebinding<br/>(cluster-scoped)"]
        CRB_EPP["epp-metrics-reader-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(system namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader-role"]
        CR_EPP["epp-metrics-reader-role"]
    end

    subgraph Roles["Namespace Roles"]
        R_Leader["leader-election-role<br/>(system namespace)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        Res_ConfigMaps["configmaps<br/>get, list, update, watch"]
        Res_Events["events<br/>create, patch"]
        Res_Namespaces["namespaces, pods,<br/>secrets, services<br/>get, list, watch"]
        Res_Nodes["nodes, nodes/status<br/>get, list, patch,<br/>update, watch"]
        Res_Deployments["apps/deployments<br/>get, list, patch,<br/>update, watch"]
        Res_DeployScale["apps/deployments/scale<br/>get, update"]
        Res_ReplicaSets["apps/replicasets,<br/>statefulsets<br/>get, list, watch"]
        Res_InfPools["inferencepools<br/>(both API groups)<br/>get, list, watch"]
        Res_LWS["leaderworkersets<br/>get, list, patch,<br/>update, watch"]
        Res_LWSScale["leaderworkersets/scale<br/>get, update"]
        Res_VA["variantautoscalings<br/>create, delete, get, list,<br/>patch, update, watch"]
        Res_VAFinalizers["variantautoscalings/<br/>finalizers<br/>update"]
        Res_VAStatus["variantautoscalings/<br/>status<br/>get, patch, update"]
        Res_ServiceMon["servicemonitors<br/>get, list, watch"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        Res_LeaderCM["configmaps<br/>full CRUD"]
        Res_Leases["leases<br/>full CRUD"]
        Res_LeaderEvents["events<br/>create, patch"]
    end

    subgraph AuthResources["metrics-auth-role Resources"]
        Res_TokenReview["tokenreviews<br/>create"]
        Res_SAR["subjectaccessreviews<br/>create"]
    end

    subgraph MetricsResources["metrics-reader-role Resources"]
        Res_Metrics["/metrics<br/>(non-resource URL)<br/>get"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_MetricsAuth
    SA_Controller -->|bound via| RB_Leader
    SA_Prometheus -->|bound via| CRB_MetricsReader
    SA_EPP -->|bound via| CRB_EPP

    CRB_Manager -->|grants| CR_Manager
    CRB_MetricsAuth -->|grants| CR_MetricsAuth
    CRB_MetricsReader -->|grants| CR_MetricsReader
    RB_Leader -->|grants| R_Leader

    %% Role to Resources
    CR_Manager -->|permits| Res_ConfigMaps
    CR_Manager -->|permits| Res_Events
    CR_Manager -->|permits| Res_Namespaces
    CR_Manager -->|permits| Res_Nodes
    CR_Manager -->|permits| Res_Deployments
    CR_Manager -->|permits| Res_DeployScale
    CR_Manager -->|permits| Res_ReplicaSets
    CR_Manager -->|permits| Res_InfPools
    CR_Manager -->|permits| Res_LWS
    CR_Manager -->|permits| Res_LWSScale
    CR_Manager -->|permits| Res_VA
    CR_Manager -->|permits| Res_VAFinalizers
    CR_Manager -->|permits| Res_VAStatus
    CR_Manager -->|permits| Res_ServiceMon

    R_Leader -->|permits| Res_LeaderCM
    R_Leader -->|permits| Res_Leases
    R_Leader -->|permits| Res_LeaderEvents

    CR_MetricsAuth -->|permits| Res_TokenReview
    CR_MetricsAuth -->|permits| Res_SAR

    CR_MetricsReader -->|permits| Res_Metrics

