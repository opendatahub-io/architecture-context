graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(wva-system)"]
        SA_EPP["epp-metrics-reader<br/>(wva-system)"]
        SA_Prom["prometheus-user-workload<br/>(openshift-user-workload-monitoring)<br/>[OpenShift only]"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(cluster-wide)"]
        CRB_EPP["epp-metrics-reader-rolebinding<br/>(cluster-wide)"]
        CRB_MonView["manager-cluster-monitoring-view<br/>(cluster-wide) [OpenShift]"]
        CRB_PromView["prometheus-cluster-monitoring-view<br/>(cluster-wide) [OpenShift]"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["leader-election-rolebinding<br/>(wva-system)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
        CR_EPP["epp-metrics-reader-role"]
        CR_MonView["cluster-monitoring-view<br/>[OpenShift]"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_Leader["leader-election-role<br/>(wva-system)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        VA["llmd.ai<br/>variantautoscalings<br/>[get, list, watch, create,<br/>update, patch, delete]"]
        VAStatus["llmd.ai<br/>variantautoscalings/status<br/>[get, update, patch]"]
        VAFinalizers["llmd.ai<br/>variantautoscalings/finalizers<br/>[update]"]
        Nodes["core<br/>nodes, nodes/status<br/>[get, list, watch,<br/>update, patch]"]
        Deployments["apps<br/>deployments<br/>[get, list, watch,<br/>update, patch]"]
        DeployScale["apps<br/>deployments/scale<br/>[get, update]"]
        ReplicaSets["apps<br/>replicasets, statefulsets<br/>[get, list, watch]"]
        CoreRead["core<br/>pods, services, secrets,<br/>namespaces<br/>[get, list, watch]"]
        ConfigMaps["core<br/>configmaps<br/>[get, update, list, watch]"]
        ResourceQuotas["core<br/>resourcequotas<br/>[get, list, watch]"]
        Events["core<br/>events<br/>[create, patch]"]
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>[get, list, watch,<br/>update, patch]"]
        LWS["leaderworkerset.x-k8s.io<br/>leaderworkersets<br/>[get, list, watch,<br/>update, patch]"]
        LWSScale["leaderworkerset.x-k8s.io<br/>leaderworkersets/scale<br/>[get, update]"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>[get, list, watch]"]
        InferencePools["inference.networking.*<br/>inferencepools<br/>[get, list, watch]"]
        ScaledObjects["keda.sh<br/>scaledobjects<br/>[get, list, watch]"]
    end

    subgraph AuthResources["metrics-auth-role Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>[create]"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>[create]"]
    end

    subgraph NonResourceURLs["Non-Resource URLs"]
        MetricsURL["/metrics<br/>[get]"]
        EPPUrls["/metrics<br/>/debug/pprof/*<br/>[get]"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        Leases["core<br/>leases<br/>[get, list, watch, create,<br/>update, patch, delete]"]
        LEConfigMaps["core<br/>configmaps<br/>[get, list, watch, create,<br/>update, patch, delete]"]
        LEEvents["core<br/>events<br/>[create, patch]"]
    end

    subgraph Secrets["Secrets"]
        EPPToken["epp-metrics-token<br/>(kubernetes.io/service-account-token)<br/>EPP metrics scraping auth<br/>Auto-Rotate: No"]
        CMToken["controller-manager-token<br/>(kubernetes.io/service-account-token)<br/>ServiceMonitor + Thanos auth<br/>[OpenShift only]<br/>Auto-Rotate: No"]
    end

    %% SA to Binding connections
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| CRB_Metrics
    SA_CM -->|bound via| RB_Leader
    SA_CM -->|bound via| CRB_MonView
    SA_EPP -->|bound via| CRB_EPP
    SA_Prom -->|bound via| CRB_PromView

    %% Binding to Role connections
    CRB_Manager -->|grants| CR_Manager
    CRB_Metrics -->|grants| CR_MetricsAuth
    CRB_EPP -->|grants| CR_EPP
    CRB_MonView -->|grants| CR_MonView
    CRB_PromView -->|grants| CR_MonView
    RB_Leader -->|grants| R_Leader

    %% Role to Resource connections
    CR_Manager -->|accesses| ManagerResources
    CR_MetricsAuth -->|accesses| AuthResources
    CR_MetricsReader -->|accesses| MetricsURL
    CR_EPP -->|accesses| EPPUrls
    R_Leader -->|accesses| LeaderResources

    %% Secret associations
    SA_EPP ---|token| EPPToken
    SA_CM ---|token| CMToken

