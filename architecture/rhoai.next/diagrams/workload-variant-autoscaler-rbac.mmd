graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(system namespace)"]
        SA_Prom["prometheus SA"]
        SA_EPP["epp-metrics-reader SA"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_MetricsAuth["metrics-auth-rolebinding<br/>(cluster-scoped)"]
        CRB_MetricsReader["metrics-reader-rolebinding<br/>(cluster-scoped)"]
        CRB_EPP["epp-metrics-reader-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(system namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader-role"]
        CR_EPPReader["epp-metrics-reader-role"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction LR

        subgraph CoreAPI["Core API ('')"]
            ConfigMaps["configmaps<br/>get, list, update, watch"]
            ConfigMapsStatus["configmaps/status<br/>get"]
            Events["events<br/>create, patch"]
            NSPodSecSvc["namespaces, pods,<br/>secrets, services<br/>get, list, watch"]
            NodesRes["nodes, nodes/status<br/>get, list, patch,<br/>update, watch"]
        end

        subgraph AppsAPI["Apps API"]
            Deployments["deployments<br/>get, list, patch,<br/>update, watch"]
            DeployScale["deployments/scale<br/>get, update"]
            RSStateful["replicasets, statefulsets<br/>get, list, watch"]
        end

        subgraph InferenceAPI["Inference API"]
            InferencePools["inferencepools<br/>(k8s.io + x-k8s.io)<br/>get, list, watch"]
        end

        subgraph LWSAPI["LeaderWorkerSet API"]
            LWSRes["leaderworkersets<br/>get, list, patch,<br/>update, watch"]
            LWSScale["leaderworkersets/scale<br/>get, update"]
        end

        subgraph LLMDAPI["llmd.ai API"]
            VA["variantautoscalings<br/>create, delete, get, list,<br/>patch, update, watch"]
            VAFin["variantautoscalings/<br/>finalizers<br/>update"]
            VAStatus["variantautoscalings/<br/>status<br/>get, patch, update"]
        end

        subgraph MonitoringAPI["Monitoring API"]
            SM["servicemonitors<br/>get, list, watch"]
        end
    end

    subgraph AuthResources["metrics-auth-role Resources"]
        TokenReviews["tokenreviews<br/>create"]
        SAR["subjectaccessreviews<br/>create"]
    end

    subgraph MetricsResources["metrics-reader-role Resources"]
        MetricsURL["/metrics (non-resource)<br/>get"]
    end

    subgraph LeaderResources["leader-election-role Resources"]
        LEConfigMaps["configmaps<br/>full CRUD"]
        LELeases["leases<br/>full CRUD"]
        LEEvents["events<br/>create, patch"]
    end

    %% Service Account → Binding → Role
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_MetricsAuth
    SA_CM -->|"bound via"| RB_Leader
    SA_Prom -->|"bound via"| CRB_MetricsReader
    SA_EPP -->|"bound via"| CRB_EPP

    CRB_Manager -->|"grants"| CR_Manager
    CRB_MetricsAuth -->|"grants"| CR_MetricsAuth
    CRB_MetricsReader -->|"grants"| CR_MetricsReader
    RB_Leader -->|"grants"| R_Leader

    %% Role → Resources
    CR_Manager -->|"permits"| ConfigMaps
    CR_Manager -->|"permits"| ConfigMapsStatus
    CR_Manager -->|"permits"| Events
    CR_Manager -->|"permits"| NSPodSecSvc
    CR_Manager -->|"permits"| NodesRes
    CR_Manager -->|"permits"| Deployments
    CR_Manager -->|"permits"| DeployScale
    CR_Manager -->|"permits"| RSStateful
    CR_Manager -->|"permits"| InferencePools
    CR_Manager -->|"permits"| LWSRes
    CR_Manager -->|"permits"| LWSScale
    CR_Manager -->|"permits"| VA
    CR_Manager -->|"permits"| VAFin
    CR_Manager -->|"permits"| VAStatus
    CR_Manager -->|"permits"| SM

    CR_MetricsAuth -->|"permits"| TokenReviews
    CR_MetricsAuth -->|"permits"| SAR

    CR_MetricsReader -->|"permits"| MetricsURL

    R_Leader -->|"permits"| LEConfigMaps
    R_Leader -->|"permits"| LELeases
    R_Leader -->|"permits"| LEEvents

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_Prom fill:#4a90e2,color:#fff
    style SA_EPP fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#000
    style CR_MetricsAuth fill:#f5a623,color:#000
    style CR_MetricsReader fill:#f5a623,color:#000
    style CR_EPPReader fill:#f5a623,color:#000
    style R_Leader fill:#e67e22,color:#fff
    style VA fill:#7ed321,color:#000
    style VAFin fill:#7ed321,color:#000
    style VAStatus fill:#7ed321,color:#000
