graph TB
    subgraph ExternalAccess["External Access"]
        Client[Client]
    end

    subgraph IngressLayer["Ingress Layer"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP HTTPS"]
        KnativeRoute["Knative Route"]
    end

    subgraph ServingPod["KServe ServingRuntime Pod"]
        direction TB
        subgraph CaikitContainer["Caikit Transformer Container"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            CaikitNLP["caikit-nlp<br/>v0.5.14"]
            CaikitTGISBackend["caikit-tgis-backend<br/>v0.1.39"]
            CaikitCore["caikit<br/>v0.28.1"]
            CaikitConfig["caikit.yml<br/>Configuration"]

            CaikitRuntime -->|"uses"| CaikitNLP
            CaikitRuntime -->|"uses"| CaikitTGISBackend
            CaikitRuntime -->|"uses"| CaikitCore
            CaikitRuntime -->|"reads"| CaikitConfig

            HTTP_EP["HTTP API<br/>8080/TCP"]
            GRPC_EP["gRPC API<br/>8085/TCP"]
            Metrics_EP["Metrics<br/>8086/TCP"]
        end

        subgraph TGISContainer["TGIS Container"]
            TGIS["Text Generation<br/>Inference Server<br/>8033/TCP gRPC"]
        end

        subgraph StorageInit["Storage Initializer (init container)"]
            SI["KServe Storage<br/>Initializer"]
        end

        ModelVolume[("/mnt/models/<br/>Model Files")]

        CaikitRuntime --> HTTP_EP
        CaikitRuntime --> GRPC_EP
        CaikitRuntime --> Metrics_EP
        CaikitTGISBackend -->|"gRPC localhost:8033"| TGIS
        TGIS -->|"reads"| ModelVolume
        SI -->|"populates"| ModelVolume
    end

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    end

    subgraph ExternalStorage["External Storage"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
    end

    Client -->|"HTTPS/443"| IstioGW
    IstioGW -->|"mTLS"| KnativeRoute
    KnativeRoute -->|"HTTP/8080 or gRPC/8085"| CaikitRuntime
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS"| Metrics_EP
    SI -->|"HTTPS/443<br/>AWS IAM / S3 keys"| S3

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style CaikitNLP fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitCore fill:#5b9bd5,stroke:#333,color:#fff
    style TGIS fill:#e8744f,stroke:#333,color:#fff
    style SI fill:#7ed321,stroke:#333,color:#fff
    style IstioGW fill:#466bb0,stroke:#333,color:#fff
    style KnativeRoute fill:#0865ad,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style CaikitConfig fill:#f0f0f0,stroke:#999
    style ModelVolume fill:#fff2cc,stroke:#d6b656
    style HTTP_EP fill:#d5e8d4,stroke:#82b366
    style GRPC_EP fill:#d5e8d4,stroke:#82b366
    style Metrics_EP fill:#d5e8d4,stroke:#82b366
