graph TB
    subgraph ExternalClients["External Clients"]
        Client[Client Application]
    end

    subgraph IngressLayer["Ingress Layer"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP TLS 1.2+"]
    end

    subgraph ServingPod["KServe Serving Pod"]
        direction TB

        subgraph IstioSidecar["Istio Sidecar (mTLS)"]
            Proxy["Envoy Proxy<br/>mTLS STRICT"]
        end

        subgraph TransformerContainer["transformer-container (Caikit)"]
            CaikitRuntime["Caikit Runtime<br/>python -m caikit.runtime"]
            HTTPAPI["HTTP API<br/>8080/TCP"]
            GRPCAPI["gRPC API<br/>8085/TCP"]
            Metrics["Metrics<br/>8086/TCP"]
            HealthProbe["caikit_health_probe<br/>Readiness/Liveness"]
            CaikitRuntime --> HTTPAPI
            CaikitRuntime --> GRPCAPI
            CaikitRuntime --> Metrics
            CaikitRuntime --> HealthProbe
        end

        subgraph KServeContainer["kserve-container (TGIS)"]
            TGIS["Text Generation<br/>Inference Server<br/>8033/TCP gRPC"]
            GPU["GPU Inference Engine"]
            TGIS --> GPU
        end

        subgraph ModelVolume["Shared Volume"]
            Models["/mnt/models<br/>Model Artifacts"]
        end

        Proxy -->|"HTTP 8080"| HTTPAPI
        Proxy -->|"gRPC 8085"| GRPCAPI
        CaikitRuntime -->|"gRPC 8033<br/>localhost"| TGIS
        TGIS --> Models
    end

    subgraph PlatformServices["Platform Services"]
        KServe["KServe Controller<br/>ServingRuntime / InferenceService"]
        Knative["Knative Serving<br/>Autoscaling / Scale-to-Zero"]
        Prometheus["Prometheus<br/>User Workload Monitoring"]
    end

    subgraph ExternalStorage["External Storage"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
    end

    %% External flows
    Client -->|"HTTPS 443<br/>Bearer Token"| IstioGW
    IstioGW -->|"mTLS"| Proxy

    %% Platform management
    KServe -->|"manages lifecycle"| ServingPod
    Knative -->|"autoscaling"| ServingPod
    Prometheus -->|"HTTP 8086<br/>PERMISSIVE mTLS"| Metrics

    %% Model loading
    S3 -.->|"model download<br/>via storage initializer"| Models

    %% Styling
    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style TGIS fill:#e67e22,stroke:#333,color:#fff
    style IstioGW fill:#9b59b6,stroke:#333,color:#fff
    style Proxy fill:#9b59b6,stroke:#333,color:#fff
    style KServe fill:#27ae60,stroke:#333,color:#fff
    style Knative fill:#27ae60,stroke:#333,color:#fff
    style Prometheus fill:#27ae60,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#ecf0f1,stroke:#333
    style Models fill:#bdc3c7,stroke:#333
    style GPU fill:#e74c3c,stroke:#333,color:#fff
