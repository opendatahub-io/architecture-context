graph TB
    subgraph External["External Clients"]
        Client[External Client]
    end

    subgraph IstioIngress["Istio Ingress Gateway"]
        Gateway["Istio Gateway<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph KnativeLayer["Knative Serving Layer"]
        Activator["Knative Activator<br/>8012/TCP mTLS"]
        QueueProxy["Queue Proxy<br/>Sidecar"]
    end

    subgraph InferencePod["Inference Pod (Multi-Container)"]
        direction TB
        subgraph TransformerContainer["transformer-container (Caikit Runtime)"]
            CaikitRuntime["Caikit Runtime<br/>python -m caikit.runtime"]
            HTTPEndpoint["HTTP API<br/>8080/TCP<br/>/api/v1/task/text-generation"]
            GRPCEndpoint["gRPC API<br/>8085/TCP<br/>caikit.runtime.TextGeneration"]
            HealthProbe["Health Probe<br/>8080/TCP /health"]
            MetricsPort["Metrics<br/>8086/TCP"]
        end

        subgraph KServeContainer["kserve-container (TGIS)"]
            TGIS["Text Generation<br/>Inference Server<br/>8033/TCP gRPC"]
            ModelLoader["Model Loader<br/>/mnt/models/"]
        end

        CaikitRuntime --> HTTPEndpoint
        CaikitRuntime --> GRPCEndpoint
        CaikitRuntime -->|"gRPC localhost:8033"| TGIS
    end

    subgraph ModelStorage["Model Storage"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
        PVC["PersistentVolumeClaim<br/>/mnt/models/"]
    end

    subgraph Monitoring["Observability"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    end

    subgraph ConvertUtility["Utility"]
        Convert["convert.py<br/>HuggingFace → Caikit format"]
    end

    Client -->|"HTTPS/443"| Gateway
    Gateway -->|"mTLS/8012"| Activator
    Activator --> QueueProxy
    QueueProxy -->|"HTTP/8080 or gRPC/8085"| CaikitRuntime
    ModelLoader -->|"Filesystem or HTTPS"| S3
    ModelLoader --- PVC
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS"| MetricsPort

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style TGIS fill:#4a90e2,stroke:#333,color:#fff
    style HTTPEndpoint fill:#7ed321,stroke:#333
    style GRPCEndpoint fill:#7ed321,stroke:#333
    style MetricsPort fill:#f5a623,stroke:#333
    style HealthProbe fill:#f5a623,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style Activator fill:#e8e8e8,stroke:#333
    style QueueProxy fill:#e8e8e8,stroke:#333
    style S3 fill:#fff2cc,stroke:#d6b656
    style PVC fill:#fff2cc,stroke:#d6b656
    style Prometheus fill:#dae8fc,stroke:#6c8ebf
    style Convert fill:#d5e8d4,stroke:#82b366
