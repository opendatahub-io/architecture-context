graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph IngressLayer["Ingress Layer"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP HTTPS"]
        KnativeRoute["Knative Route<br/>(OpenShift Route)"]
    end

    subgraph KnativeLayer["Knative Serving"]
        Activator["Knative Activator"]
        QueueProxy["Queue-Proxy Sidecar"]
    end

    subgraph ServingPod["KServe ServingRuntime Pod"]
        direction TB

        subgraph TransformerContainer["transformer-container"]
            CaikitRuntime["Caikit Runtime<br/><i>python -m caikit.runtime</i>"]
            CaikitNLP["caikit-nlp 0.5.14"]
            CaikitTGISBackend["caikit-tgis-backend 0.1.39"]
            CaikitCore["caikit 0.28.1"]
            CaikitConfig["caikit.yml<br/>(TGIS-AUTO finder)"]

            CaikitRuntime --> CaikitNLP
            CaikitRuntime --> CaikitTGISBackend
            CaikitRuntime --> CaikitCore
            CaikitRuntime -.->|reads| CaikitConfig
        end

        subgraph KServeContainer["kserve-container"]
            TGIS["TGIS Inference Server<br/>8033/TCP gRPC"]
            LLMModel["LLM Model<br/>/mnt/models"]
            TGIS -->|loads| LLMModel
        end

        subgraph IstioSidecar["Istio Sidecar"]
            EnvoyProxy["Envoy Proxy<br/>mTLS STRICT"]
        end

        CaikitTGISBackend -->|"gRPC localhost:8033"| TGIS
    end

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    end

    Client -->|"HTTPS/443"| IstioGW
    IstioGW --> KnativeRoute
    KnativeRoute --> Activator
    Activator --> QueueProxy
    QueueProxy -->|"HTTP :8080 / gRPC :8085"| CaikitRuntime
    Prometheus -->|"HTTP :8086<br/>PERMISSIVE mTLS"| CaikitRuntime

    subgraph ModelStorage["Model Storage"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        PVC["PersistentVolumeClaim"]
    end

    LLMModel -.->|"volume mount"| PVC
    ServingPod -.->|"storage initializer<br/>HTTPS/443"| S3

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style CaikitNLP fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitCore fill:#5b9bd5,stroke:#333,color:#fff
    style TGIS fill:#e67e22,stroke:#333,color:#fff
    style EnvoyProxy fill:#9b59b6,stroke:#333,color:#fff
    style IstioGW fill:#9b59b6,stroke:#333,color:#fff
    style Activator fill:#27ae60,stroke:#333,color:#fff
    style QueueProxy fill:#27ae60,stroke:#333,color:#fff
    style Prometheus fill:#f39c12,stroke:#333,color:#fff
    style S3 fill:#95a5a6,stroke:#333,color:#fff
    style PVC fill:#95a5a6,stroke:#333,color:#fff
    style Client fill:#ecf0f1,stroke:#333
    style CaikitConfig fill:#85c1e9,stroke:#333
    style LLMModel fill:#f5cba7,stroke:#333
    style KnativeRoute fill:#9b59b6,stroke:#333,color:#fff
