graph TB
    subgraph "Caikit-TGIS-Serving Pod"
        direction TB
        subgraph TransformerContainer["transformer-container"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            CaikitNLP["caikit-nlp Module"]
            CaikitTGISBackend["caikit-tgis-backend"]
            HealthProbe["caikit_health_probe"]
            CaikitRuntime --> CaikitNLP
            CaikitRuntime --> CaikitTGISBackend
        end

        subgraph KServeContainer["kserve-container"]
            TGIS["TGIS<br/>(text-generation-launcher)"]
            GPU["GPU / Model Memory"]
            TGIS --> GPU
        end

        CaikitTGISBackend -->|"gRPC :8033<br/>(localhost)"| TGIS
    end

    subgraph "External APIs"
        HTTPEndpoint["HTTP API<br/>:8080/TCP"]
        GRPCEndpoint["gRPC API<br/>:8085/TCP (h2c)"]
        MetricsEndpoint["Metrics<br/>:8086/TCP"]
    end

    Client[Client Request] -->|"POST /api/v1/task/text-generation"| HTTPEndpoint
    Client -->|"caikit.runtime.Nlp"| GRPCEndpoint
    HTTPEndpoint --> CaikitRuntime
    GRPCEndpoint --> CaikitRuntime
    CaikitRuntime -->|"Prometheus metrics"| MetricsEndpoint

    ConvertPy["convert.py<br/>(CLI Utility)"]
    HFHub["HuggingFace Hub"]
    ConvertPy -->|"Download & Convert<br/>HTTPS/443"| HFHub

    ServingRuntimeCR["ServingRuntime CR<br/>(serving.kserve.io/v1alpha1)"]
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]

    ServingRuntimeCR -->|"defines"| TransformerContainer
    ServingRuntimeCR -->|"defines"| KServeContainer
    InferenceServiceCR -->|"references"| ServingRuntimeCR

    S3["S3-compatible Storage"]
    InferenceServiceCR -->|"storageUri"| S3

    style TransformerContainer fill:#4a90e2,stroke:#333,color:#fff
    style KServeContainer fill:#e67e22,stroke:#333,color:#fff
    style CaikitRuntime fill:#3498db,stroke:#333,color:#fff
    style CaikitNLP fill:#3498db,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#3498db,stroke:#333,color:#fff
    style TGIS fill:#d35400,stroke:#333,color:#fff
    style GPU fill:#d35400,stroke:#333,color:#fff
    style HTTPEndpoint fill:#27ae60,stroke:#333,color:#fff
    style GRPCEndpoint fill:#27ae60,stroke:#333,color:#fff
    style MetricsEndpoint fill:#27ae60,stroke:#333,color:#fff
    style ServingRuntimeCR fill:#f5a623,stroke:#333,color:#fff
    style InferenceServiceCR fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style ConvertPy fill:#8e44ad,stroke:#333,color:#fff
    style HealthProbe fill:#3498db,stroke:#333,color:#fff
