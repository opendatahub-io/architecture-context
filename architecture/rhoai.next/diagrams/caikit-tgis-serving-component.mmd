graph TB
    subgraph External["External Clients"]
        HTTPClient["HTTP Client"]
        GRPCClient["gRPC Client"]
    end

    subgraph IstioIngress["Istio Ingress Gateway"]
        Gateway["Istio Gateway<br/>443/TCP TLS 1.2+"]
    end

    subgraph KnativeLayer["Knative Serving"]
        Activator["Knative Activator /<br/>Queue Proxy<br/>8012/TCP"]
    end

    subgraph InferencePod["KServe Inference Pod (Multi-Container)"]
        direction TB

        subgraph TransformerContainer["transformer-container (Caikit)"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            CaikitNLP["caikit-nlp<br/>Text Generation Tasks"]
            CaikitTGIS["caikit-tgis-backend<br/>TGIS Connector"]
            HealthProbe["caikit_health_probe<br/>Readiness / Liveness"]
            HTTPPort["HTTP API<br/>8080/TCP"]
            GRPCPort["gRPC API<br/>8085/TCP"]
            MetricsPort["Metrics<br/>8086/TCP"]

            CaikitRuntime --> CaikitNLP
            CaikitRuntime --> CaikitTGIS
            CaikitRuntime --> HealthProbe
            CaikitRuntime --> HTTPPort
            CaikitRuntime --> GRPCPort
            CaikitRuntime --> MetricsPort
        end

        subgraph KServeContainer["kserve-container (TGIS)"]
            TGIS["Text Generation<br/>Inference Server<br/>GPU-accelerated"]
            TGISPort["gRPC<br/>8033/TCP"]
            TGIS --> TGISPort
        end

        CaikitTGIS -->|"gRPC localhost:8033"| TGISPort
    end

    subgraph Storage["Model Storage"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
        PVC["PersistentVolumeClaim<br/>/mnt/models/"]
    end

    subgraph Monitoring["Observability"]
        Prometheus["Prometheus<br/>(User Workload Monitoring)"]
    end

    subgraph ConvertUtility["Offline Utility"]
        Convert["convert.py<br/>HuggingFace → Caikit Format"]
    end

    %% External flows
    HTTPClient -->|"HTTPS/443"| Gateway
    GRPCClient -->|"HTTPS (h2)/443"| Gateway
    Gateway -->|"mTLS/8012"| Activator
    Activator -->|"mTLS/8080 HTTP"| HTTPPort
    Activator -->|"mTLS/8085 gRPC"| GRPCPort

    %% Storage
    TGIS -->|"Filesystem"| PVC
    TGIS -->|"HTTPS/443<br/>IAM Auth"| S3

    %% Monitoring
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef knative fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef caikit fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef tgis fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef utility fill:#e8e8e8,stroke:#666,stroke-width:1px

    class HTTPClient,GRPCClient external
    class Gateway ingress
    class Activator knative
    class CaikitRuntime,CaikitNLP,CaikitTGIS,HealthProbe,HTTPPort,GRPCPort,MetricsPort caikit
    class TGIS,TGISPort tgis
    class S3,PVC storage
    class Prometheus monitoring
    class Convert utility
