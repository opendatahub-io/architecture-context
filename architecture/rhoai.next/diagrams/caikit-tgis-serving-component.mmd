graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph IngressLayer["Ingress Layer"]
        IstioGW["Istio Ingress Gateway<br/>443/TCP HTTPS TLS 1.2+"]
        KnativeRoute["Knative Route<br/>Traffic Splitting & Revisions"]
    end

    subgraph KServePod["KServe ServingRuntime Pod"]
        direction TB
        subgraph TransformerContainer["transformer-container"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            HTTP_EP["HTTP API<br/>8080/TCP"]
            GRPC_EP["gRPC API<br/>8085/TCP"]
            Metrics["Metrics Endpoint<br/>8086/TCP"]
            CaikitConfig["caikit.yml<br/>Configuration"]
            CaikitNLP["caikit-nlp 0.5.14"]
            CaikitBackend["caikit-tgis-backend 0.1.39"]

            CaikitRuntime --> HTTP_EP
            CaikitRuntime --> GRPC_EP
            CaikitRuntime --> Metrics
            CaikitRuntime --> CaikitConfig
            CaikitRuntime --> CaikitNLP
            CaikitRuntime --> CaikitBackend
        end

        subgraph KServeContainer["kserve-container"]
            TGIS["Text Generation<br/>Inference Server (TGIS)<br/>8033/TCP gRPC"]
        end

        CaikitBackend -->|"gRPC localhost:8033"| TGIS
    end

    subgraph ModelStorage["Model Storage"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        PVC["PersistentVolumeClaim<br/>/mnt/models"]
    end

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>(openshift-user-workload-monitoring)"]
    end

    Client -->|"HTTPS/443"| IstioGW
    IstioGW -->|"mTLS"| KnativeRoute
    KnativeRoute -->|"HTTP/8080 or gRPC/8085"| CaikitRuntime
    TGIS -->|"Volume Mount"| PVC
    TGIS -->|"Storage Initializer"| S3
    Prometheus -->|"HTTP/8086<br/>PERMISSIVE mTLS"| Metrics

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style TGIS fill:#4a90e2,stroke:#333,color:#fff
    style HTTP_EP fill:#7ed321,stroke:#333
    style GRPC_EP fill:#7ed321,stroke:#333
    style Metrics fill:#7ed321,stroke:#333
    style IstioGW fill:#f5a623,stroke:#333
    style KnativeRoute fill:#f5a623,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
    style Prometheus fill:#9b59b6,stroke:#333,color:#fff
    style CaikitNLP fill:#85c1e9,stroke:#333
    style CaikitBackend fill:#85c1e9,stroke:#333
    style CaikitConfig fill:#85c1e9,stroke:#333
