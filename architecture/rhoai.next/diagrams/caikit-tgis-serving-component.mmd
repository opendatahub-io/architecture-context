graph TB
    subgraph InferencePod["Multi-Container Inference Pod (KServe)"]
        direction TB

        subgraph TransformerContainer["transformer-container"]
            CaikitRuntime["Caikit Runtime<br/>(python -m caikit.runtime)"]
            CaikitNLP["caikit-nlp<br/>v0.5.14"]
            CaikitTGISBackend["caikit-tgis-backend<br/>v0.1.39"]
            HealthProbe["caikit_health_probe<br/>(readiness/liveness)"]

            CaikitRuntime -->|"text generation tasks"| CaikitNLP
            CaikitRuntime -->|"inference delegation"| CaikitTGISBackend
        end

        subgraph KServeContainer["kserve-container"]
            TGIS["TGIS<br/>(Text Generation Inference Server)<br/>GPU-accelerated"]
        end

        CaikitTGISBackend -->|"gRPC :8033<br/>(localhost)"| TGIS
    end

    Client["External Client"] -->|"POST /api/v1/task/text-generation<br/>8080/TCP HTTP"| CaikitRuntime
    GRPCClient["gRPC Client"] -->|"caikit.runtime.TextGeneration<br/>8085/TCP gRPC (h2c)"| CaikitRuntime
    Prometheus["Prometheus"] -->|"GET /metrics<br/>8086/TCP HTTP"| CaikitRuntime

    TGIS -->|"load models"| ModelStorage["/mnt/models/<br/>(PVC or S3)"]

    KServe["KServe Controller"] -->|"manages lifecycle via<br/>ServingRuntime + InferenceService CRDs"| InferencePod
    Knative["Knative Serving"] -->|"autoscaling &<br/>traffic routing"| InferencePod
    Istio["Istio Service Mesh"] -->|"mTLS sidecar<br/>injection"| InferencePod

    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style CaikitNLP fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitTGISBackend fill:#5b9bd5,stroke:#333,color:#fff
    style HealthProbe fill:#5b9bd5,stroke:#333,color:#fff
    style TGIS fill:#e8744f,stroke:#333,color:#fff
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#333
    style GRPCClient fill:#f9f9f9,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
