graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>KServe Router"]
    end

    subgraph PodBoundary["KSERVE POD BOUNDARY (InferenceService Pod)"]
        direction TB

        RBAC["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.2+ termination<br/>Bearer Token + K8s RBAC"]

        subgraph Container["vLLM ROCm Container (non-root UID 1001)"]
            direction TB
            HTTPAPI["OpenAI-compatible HTTP API<br/>8000/TCP HTTP plaintext<br/>/v1/completions, /v1/chat/completions<br/>/v1/models, /health"]
            GRPCAPI["TGIS gRPC API<br/>8033/TCP gRPC plaintext<br/>Generation Service"]
            Engine["vLLM Inference Engine"]
            GPU["AMD ROCm GPU<br/>ROCm 7.1.1<br/>x86_64"]

            Engine --> GPU
        end

        RBAC -->|"HTTP/8000<br/>localhost<br/>No encryption<br/>Trusted (same pod)"| HTTPAPI
    end

    subgraph Internal["INTERNAL (Platform)"]
        ModelMesh["ModelMesh Serving"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| RBAC

    %% Internal flows
    ModelMesh -->|"gRPC/8033<br/>No encryption (pod-level)<br/>No auth (pod-level)"| GRPCAPI

    %% Egress flows
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class RBAC ingress
    class HTTPAPI,GRPCAPI,Engine container
    class GPU gpu
    class HFHub,S3 externalservice
    class ModelMesh internal
