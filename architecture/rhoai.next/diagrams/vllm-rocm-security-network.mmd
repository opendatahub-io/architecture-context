graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["KServe Gateway<br/>443/TCP<br/>TLS 1.2+ Termination<br/>Bearer Token / OAuth"]
        AuthProxy["Auth Proxy Sidecar<br/>(kube-rbac-proxy / oauth-proxy)<br/>Enforces AuthN/AuthZ"]
    end

    subgraph Application["APPLICATION (Container - UID 2000)"]
        direction TB

        subgraph Container["vllm-rocm (odh-vllm-rocm-rhel9)"]
            direction LR
            HTTPPort["HTTP API<br/>8000/TCP<br/>No TLS<br/>No App Auth"]
            GRPCPort["gRPC TGIS<br/>8033/TCP<br/>No TLS<br/>No App Auth"]
        end

        subgraph GPUAccess["GPU (Hardware)"]
            GPU["AMD ROCm GPU<br/>PCIe/HIP<br/>Device API"]
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        S3["Model Storage (S3/PVC)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA Credentials"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| Gateway
    Gateway -->|"HTTP (internal)<br/>Platform mTLS if mesh enabled"| AuthProxy
    AuthProxy -->|"HTTP/8000<br/>No encryption (pod-local)<br/>Auth already enforced"| HTTPPort
    AuthProxy -->|"gRPC/8033<br/>No encryption (pod-local)<br/>Auth already enforced"| GRPCPort
    HTTPPort -->|"PCIe/HIP<br/>Device API"| GPU
    GRPCPort -->|"PCIe/HIP<br/>Device API"| GPU
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA Credentials"| S3
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef gpu fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egressservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,AuthProxy ingress
    class HTTPPort,GRPCPort application
    class GPU gpu
    class S3,HFHub egressservice
