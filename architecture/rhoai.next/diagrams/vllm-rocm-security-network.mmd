graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress<br/>Gateway API / kube-rbac-proxy<br/>TLS Termination<br/>AuthN/AuthZ Enforcement"]
    end

    subgraph Container["CONTAINER (vllm-rocm)"]
        direction TB

        subgraph Runtime["odh-vllm-rocm-rhel9 (UID 2000)"]
            HTTPApi["OpenAI HTTP API<br/>8000/TCP<br/>No TLS / No Auth"]
            GRPCApi["TGIS gRPC API<br/>8033/TCP<br/>No TLS / No Auth"]
        end

        GPU["AMD ROCm GPU<br/>HIP/ROCm<br/>Hardware Interface"]
    end

    subgraph EgressZone["EGRESS (Outbound)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA Token"]
        PVC["PVC Mount<br/>Filesystem<br/>No Network"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    subgraph BuildTime["BUILD-TIME (Konflux)"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
        Konflux["Konflux CI/CD<br/>rhoai-tenant namespace<br/>Tekton PipelineRun"]
    end

    %% Flows
    Client -->|"HTTPS<br/>Platform TLS<br/>Bearer / kube-rbac-proxy"| Gateway
    Gateway -->|"HTTP/8000<br/>No Encryption<br/>No Auth (validated upstream)"| HTTPApi
    Gateway -->|"gRPC/8033<br/>No Encryption<br/>No Auth (validated upstream)"| GRPCApi
    HTTPApi -->|"HIP/ROCm<br/>Hardware Bus"| GPU
    GRPCApi -->|"HIP/ROCm<br/>Hardware Bus"| GPU
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / Token"| S3
    Runtime -->|"Filesystem<br/>Volume Mount"| PVC
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (optional)"| HFHub
    Konflux -.->|"Build-time<br/>HTTPS/443"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef gpu fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class HTTPApi,GRPCApi container
    class GPU gpu
    class S3,PVC,HFHub egress
    class Registry,Konflux build
