graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress<br/>Gateway API / HTTPRoute<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph AuthProxy["AUTH PROXY (Pod Sidecar)"]
        KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview<br/>Platform RBAC"]
    end

    subgraph InferenceRuntime["INFERENCE RUNTIME (Pod, USER 2000)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            vLLMHTTP["vLLM HTTP API<br/>Port 8000/TCP<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>GET /health"]
            TGISgRPC["TGIS gRPC API<br/>Port 8033/TCP<br/>vllm_tgis_adapter"]
        end
    end

    subgraph GPUHardware["GPU HARDWARE"]
        GPU["AMD Instinct GPU<br/>MI200/MI300 Series<br/>ROCm 7.1.1<br/>HIP API"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / S3 Keys"]
    end

    %% Ingress Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Platform RBAC"| KubeRBAC
    KubeRBAC -->|"HTTP/8000<br/>No encryption<br/>(pod-internal)"| vLLMHTTP
    KubeRBAC -->|"gRPC/8033<br/>No encryption<br/>(pod-internal)"| TGISgRPC

    %% GPU Flow
    vLLMHTTP -->|"HIP API<br/>(device driver)"| GPU
    TGISgRPC -->|"via vLLM engine"| vLLMHTTP

    %% Egress Flows
    vLLMHTTP -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    vLLMHTTP -.->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/S3 Keys"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class KubeRBAC authproxy
    class vLLMHTTP,TGISgRPC runtime
    class GPU gpu
    class HFHub,S3 externalservice
