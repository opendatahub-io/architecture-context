graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Platform["PLATFORM LAYER (KServe-Managed)"]
        KServeRouter["KServe Router / Ingress<br/>TLS termination<br/>Auth: kube-rbac-proxy / Route"]
    end

    subgraph PodBoundary["POD BOUNDARY (vllm-rocm)"]
        direction TB

        subgraph Container["Container (UID 2000, non-root)"]
            direction TB
            OpenAI["OpenAI HTTP API<br/>8000/TCP<br/>Plaintext"]
            TGIS["TGIS gRPC Service<br/>8033/TCP<br/>Plaintext"]
        end

        GPU["AMD ROCm GPU<br/>PCIe/ROCm<br/>Device Plugin"]
    end

    subgraph EgressZone["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA"]
        PVC["PVC Volume Mount<br/>Filesystem<br/>SA Permissions"]
        HF["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Flows
    Client -->|"Platform-managed TLS + Auth"| KServeRouter

    KServeRouter -->|"HTTP/8000<br/>Plaintext<br/>No pod-level auth"| OpenAI
    KServeRouter -->|"gRPC/8033<br/>Plaintext<br/>No pod-level auth"| TGIS

    OpenAI -->|"PCIe/ROCm"| GPU
    TGIS -->|"PCIe/ROCm"| GPU

    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    Container -->|"Filesystem<br/>Volume mount"| PVC
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeRouter platform
    class OpenAI,TGIS pod
    class GPU gpu
    class S3,PVC,HF egress
