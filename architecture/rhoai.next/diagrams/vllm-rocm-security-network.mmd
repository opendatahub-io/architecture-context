graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Ingress<br/>(Gateway API / kube-rbac-proxy)<br/>TLS Termination<br/>AuthN/AuthZ Enforced"]
    end

    subgraph Container["CONTAINER (vllm-rocm)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace (KServe-managed)"]
            direction TB
            HTTPApi["OpenAI-Compatible HTTP API<br/>8000/TCP HTTP<br/>No TLS, No Auth<br/>/v1/completions<br/>/v1/chat/completions<br/>/v1/models, /health"]
            GRPCApi["TGIS gRPC API<br/>8033/TCP gRPC<br/>No TLS, No Auth<br/>TGIS Generation Service"]
            Engine["vLLM Engine<br/>UID: 2000 (non-root)<br/>Base: RHAIIS vllm-rocm-rhel9:3.2.1"]
        end

        HTTPApi --> Engine
        GRPCApi --> Engine
    end

    subgraph Hardware["GPU (Hardware Bus)"]
        GPU["AMD ROCm GPU<br/>HIP/ROCm Runtime<br/>PagedAttention"]
    end

    subgraph EgressServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA Token"]
        PVC["PVC Mount<br/>Filesystem<br/>No Network"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS (platform-managed)<br/>Bearer Token / Platform AuthN"| Gateway

    %% Ingress → Container
    Gateway -->|"HTTP/8000<br/>No encryption (internal)<br/>Auth enforced upstream"| HTTPApi
    Gateway -->|"gRPC/8033<br/>No encryption (internal)<br/>Auth enforced upstream"| GRPCApi

    %% Container → GPU
    Engine -->|"HIP/ROCm<br/>Hardware bus<br/>No network encryption"| GPU

    %% Container → Egress
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / SA Token"| S3
    Engine -->|"Filesystem mount<br/>Volume"| PVC
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef egress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway ingress
    class HTTPApi,GRPCApi,Engine container
    class GPU hardware
    class S3,PVC,HFHub egress
