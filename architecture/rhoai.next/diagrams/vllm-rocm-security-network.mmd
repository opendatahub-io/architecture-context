graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / KServe Router"]
    end

    subgraph Platform["PLATFORM SERVICES (KServe-managed)"]
        KServe["KServe Controller<br/>Manages ServingRuntime<br/>Provides auth via kube-rbac-proxy"]
    end

    subgraph PodNetwork["POD NETWORK (Internal)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            VLLMPod["vllm-rocm Container<br/>SA: {kserve-assigned-sa}<br/>UID: 2000 (non-root)<br/>Image: RHAIIS vllm-rocm-rhel9:3.2.1"]
        end

        GPU["AMD ROCm GPU<br/>Device Plugin: amd.com/gpu"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        PVC["PVC Model Storage<br/>Filesystem mount<br/>No network"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Ingress Flows
    Client -->|"HTTP/8000 TCP<br/>Plaintext (pod-level)<br/>No auth (pod-level)<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models"| VLLMPod
    Client -->|"gRPC/8033 TCP<br/>Plaintext (pod-level)<br/>No auth (pod-level)<br/>GenerationService"| VLLMPod

    %% Platform
    KServe -.->|"deploys as<br/>ServingRuntime"| VLLMPod

    %% GPU
    VLLMPod -->|"PCIe/ROCm<br/>Device driver<br/>No encryption"| GPU

    %% Egress Flows
    VLLMPod -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3
    VLLMPod -->|"Filesystem<br/>Volume mount"| PVC
    VLLMPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServe platform
    class VLLMPod podnetwork
    class GPU gpu
    class S3,PVC,HFHub externalservice
