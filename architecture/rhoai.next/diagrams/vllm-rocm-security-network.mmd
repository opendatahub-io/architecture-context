graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        KServeIngress["KServe Ingress / OpenShift Route<br/>TLS Termination<br/>AuthN: kube-rbac-proxy / Route auth<br/>AuthZ: Platform RBAC"]
    end

    subgraph Pod["POD (Internal - Plaintext)"]
        direction TB

        subgraph Container["vllm-rocm Container (UID 2000, non-root)"]
            direction TB
            HTTPPort["OpenAI HTTP API<br/>Port 8000/TCP<br/>Plaintext HTTP<br/>No Auth (pod-level)"]
            GRPCPort["TGIS gRPC Service<br/>Port 8033/TCP<br/>Plaintext gRPC<br/>No Auth (pod-level)"]
        end

        GPU["AMD ROCm GPU<br/>PCIe/ROCm<br/>Device Plugin"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / SA"]
        PVC["Model Storage PVC<br/>Filesystem Mount<br/>No Auth"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    %% Ingress flows
    Client -->|"HTTPS<br/>TLS (platform)<br/>Platform Auth"| KServeIngress
    KServeIngress -->|"HTTP/8000<br/>Plaintext<br/>No Auth (handled at ingress)"| HTTPPort
    KServeIngress -->|"gRPC/8033<br/>Plaintext<br/>No Auth (handled at ingress)"| GRPCPort

    %% GPU flow
    Container -->|"PCIe/ROCm<br/>Hardware bus"| GPU

    %% Egress flows
    Container -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / SA credentials"| S3
    Container -->|"Filesystem<br/>Volume mount"| PVC
    Container -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef gpu fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KServeIngress ingress
    class HTTPPort,GRPCPort container
    class GPU gpu
    class S3,PVC,HFHub externalservice
