graph TB
    subgraph KueueComponent["Kueue Controller Manager"]
        direction TB
        Controller["Kueue Controller<br/>(controller-runtime)"]
        Scheduler["Scheduler<br/>(StrictFIFO / BestEffortFIFO)"]
        Preemption["Preemption Engine<br/>(LowerPriority / Any)"]
        WebhookServer["Webhook Server<br/>9443/TCP TLS"]
        MetricsServer["Metrics Server<br/>8443/TCP HTTPS"]
        CertManager["Internal Cert Manager<br/>(self-signed TLS)"]
        TAS["Topology-Aware Scheduling<br/>(TAS)"]

        Controller --> Scheduler
        Scheduler --> Preemption
        Controller --> WebhookServer
        Controller --> MetricsServer
        Controller --> CertManager
        Controller --> TAS
    end

    %% CRDs
    subgraph CRDs["Kueue CRDs (kueue.x-k8s.io)"]
        direction TB
        ClusterQueue["ClusterQueue<br/>(Cluster)"]
        LocalQueue["LocalQueue<br/>(Namespaced)"]
        Workload["Workload<br/>(Namespaced)"]
        ResourceFlavor["ResourceFlavor<br/>(Cluster)"]
        AdmissionCheck["AdmissionCheck<br/>(Cluster)"]
        WPC["WorkloadPriorityClass<br/>(Cluster)"]
        Cohort["Cohort<br/>(Cluster, alpha)"]
        Topology["Topology<br/>(Cluster, alpha)"]
    end

    %% User interaction
    User[User / Admin] -->|"creates"| LocalQueue
    User -->|"creates"| ClusterQueue
    User -->|"submits workloads"| K8sAPI[Kubernetes API Server]

    %% Webhook interception
    K8sAPI -->|"webhook call<br/>9443/TCP mTLS"| WebhookServer
    WebhookServer -->|"mutates/validates"| K8sAPI

    %% Controller watches
    Controller -->|"watches"| ClusterQueue
    Controller -->|"watches"| LocalQueue
    Controller -->|"watches/creates"| Workload
    Controller -->|"watches"| ResourceFlavor
    Controller -->|"watches"| AdmissionCheck
    Controller -->|"watches"| Cohort
    Controller -->|"watches"| Topology

    %% Queue hierarchy
    LocalQueue -.->|"references"| ClusterQueue
    ClusterQueue -.->|"member of"| Cohort
    ClusterQueue -.->|"uses"| ResourceFlavor

    %% Integrated workloads
    subgraph IntegratedWorkloads["Integrated Workload Frameworks"]
        BatchJob["batch/v1 Job"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        MPIJob["MPIJob"]
        RayJob["RayJob"]
        RayCluster["RayCluster"]
        JobSet["JobSet"]
        AppWrapper["AppWrapper"]
        LWS["LeaderWorkerSet"]
        Pod["Pod"]
    end

    WebhookServer -->|"intercepts creation"| IntegratedWorkloads
    Controller -->|"suspend/unsuspend"| IntegratedWorkloads

    %% Metrics
    Prometheus["Prometheus<br/>(OpenShift Monitoring)"] -->|"scrape<br/>8443/TCP HTTPS"| MetricsServer

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Scheduler fill:#4a90e2,stroke:#333,color:#fff
    style Preemption fill:#4a90e2,stroke:#333,color:#fff
    style WebhookServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style CertManager fill:#4a90e2,stroke:#333,color:#fff
    style TAS fill:#4a90e2,stroke:#333,color:#fff
