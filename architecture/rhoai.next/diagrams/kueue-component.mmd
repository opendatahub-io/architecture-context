graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        subgraph Controllers["Core Controllers"]
            CQCtrl["ClusterQueue<br/>Controller"]
            LQCtrl["LocalQueue<br/>Controller"]
            WlCtrl["Workload<br/>Controller"]
            RFCtrl["ResourceFlavor<br/>Controller"]
            ACCtrl["AdmissionCheck<br/>Controller"]
            CohortCtrl["Cohort<br/>Controller"]
        end

        subgraph Scheduler["Scheduler (Runnable)"]
            SchedLoop["Scheduling Loop"]
            FlavorAssigner["Flavor Assigner"]
            Preemption["Preemption Engine"]
            SchedLoop --> FlavorAssigner
            SchedLoop --> Preemption
        end

        subgraph Webhooks["Webhook Server (9443/TCP TLS)"]
            MutatingWH["Mutating Webhooks"]
            ValidatingWH["Validating Webhooks"]
        end

        subgraph JobFramework["Job Framework (Plugin Architecture)"]
            BatchJob["batch/v1 Job"]
            JobSet["JobSet"]
            PyTorchJob["PyTorchJob"]
            TFJob["TFJob"]
            MPIJob["MPIJob"]
            RayJob["RayJob"]
            RayCluster["RayCluster"]
            AppWrapper["AppWrapper"]
            PodIntegration["Pod/Deployment/<br/>StatefulSet"]
        end

        subgraph MultiKueue["MultiKueue Subsystem"]
            MKClusterReconciler["Clusters<br/>Reconciler"]
            MKWlReconciler["Workload<br/>Reconciler"]
        end

        subgraph TAS["Topology-Aware Scheduling"]
            TopoCtrl["Topology Controller"]
            TopoUngater["Pod Ungater"]
        end

        subgraph Provisioning["Provisioning Integration"]
            ProvCtrl["Provisioning<br/>Controller"]
        end

        Controllers -->|"cache updates"| Scheduler
        Controllers -->|"watcher events"| Scheduler
        RFCtrl -->|"flavor changes"| CQCtrl
    end

    %% External CRDs
    User["User / CI Pipeline"] -->|"creates"| JobCR["Job / PyTorchJob /<br/>RayJob CR"]
    JobCR -->|"webhook intercepts"| Webhooks
    Webhooks -->|"validates/mutates"| K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]

    JobCR -->|"watched by"| JobFramework
    JobFramework -->|"creates"| WorkloadCR["Workload CR"]
    WorkloadCR -->|"watched by"| WlCtrl
    WlCtrl -->|"enqueues"| SchedLoop
    SchedLoop -->|"admits"| WorkloadCR
    JobFramework -->|"unsuspends"| JobCR

    %% CRDs created by user/admin
    Admin["Cluster Admin"] -->|"creates"| ClusterQueueCR["ClusterQueue CR"]
    Admin -->|"creates"| LocalQueueCR["LocalQueue CR"]
    Admin -->|"creates"| ResourceFlavorCR["ResourceFlavor CR"]
    ClusterQueueCR -->|"watched by"| CQCtrl
    LocalQueueCR -->|"watched by"| LQCtrl
    ResourceFlavorCR -->|"watched by"| RFCtrl

    %% MultiKueue
    MKClusterReconciler -->|"connects to"| RemoteCluster["Remote Cluster API<br/>6443/TCP HTTPS"]
    MKWlReconciler -->|"syncs workloads"| RemoteCluster

    %% Provisioning
    ProvCtrl -->|"creates"| ProvReq["ProvisioningRequest CR"]
    ProvReq -->|"read by"| ClusterAutoscaler["Cluster Autoscaler"]

    %% Metrics
    Prometheus["Prometheus"] -->|"scrapes<br/>8443/TCP HTTPS"| MetricsEndpoint["Metrics Endpoint"]

    %% Styles
    style KueueSystem fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#dcedc8,stroke:#82b366
    style Scheduler fill:#fff3cd,stroke:#d79b00
    style Webhooks fill:#f8d7da,stroke:#d32f2f
    style JobFramework fill:#d1ecf1,stroke:#0c5460
    style MultiKueue fill:#e2d5f1,stroke:#6f42c1
    style TAS fill:#fce4ec,stroke:#c62828
    style Provisioning fill:#fff8e1,stroke:#f57f17
    style User fill:#f5f5f5,stroke:#333
    style Admin fill:#f5f5f5,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RemoteCluster fill:#e8e8e8,stroke:#333
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
