graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        Controller["kueue-controller-manager<br/>(Go Operator)"]
        Scheduler["Scheduler<br/>(In-process)"]
        WebhookServer["Webhook Server<br/>9443/TCP HTTPS"]
        VisibilityAPI["Visibility API Server<br/>(Aggregated API, feature-gated)"]

        Controller --> Scheduler
        Controller --> WebhookServer
        Controller --> VisibilityAPI
    end

    %% Users & Entry Points
    User[Data Scientist / Admin] -->|"kubectl create Job/PyTorchJob"| K8sAPI[Kubernetes API Server]
    K8sAPI -->|"mutate/validate webhooks<br/>9443/TCP HTTPS"| WebhookServer

    %% CRDs - Core Quota Model
    subgraph CoreCRDs["Core Quota Model (CRDs)"]
        CQ[ClusterQueue<br/>Cluster-scoped]
        LQ[LocalQueue<br/>Namespaced]
        WL[Workload<br/>Namespaced]
        RF[ResourceFlavor<br/>Cluster-scoped]
        AC[AdmissionCheck<br/>Cluster-scoped]
        WPC[WorkloadPriorityClass<br/>Cluster-scoped]
    end

    subgraph AdvancedCRDs["Advanced Features (CRDs)"]
        MKC[MultiKueueCluster]
        MKCfg[MultiKueueConfig]
        PRC[ProvisioningRequestConfig]
        Cohort[Cohort<br/>alpha]
        Topology[Topology<br/>alpha]
    end

    %% Controller watches CRDs
    Controller -->|watches/reconciles| CQ
    Controller -->|watches/reconciles| LQ
    Controller -->|watches/reconciles| WL
    Controller -->|watches/reconciles| RF
    Controller -->|watches/reconciles| AC
    Controller -->|reads| WPC

    %% Scheduler uses CRDs
    Scheduler -->|"admits workloads<br/>quota + priority + fair sharing"| WL
    WL -->|"references"| LQ
    LQ -->|"points to"| CQ
    CQ -->|"defines quotas per"| RF

    %% Advanced CRDs
    Controller -->|manages| MKC
    Controller -->|reads| MKCfg
    Controller -->|reads| PRC
    Controller -->|watches| Cohort
    Controller -->|watches| Topology

    %% Supported Job Types
    subgraph JobTypes["Supported Job Frameworks"]
        BatchJob["batch/v1 Job"]
        JobSet["JobSet"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        XGBoostJob["XGBoostJob"]
        PaddleJob["PaddleJob"]
        MPIJob["MPIJob"]
        RayJob["RayJob"]
        RayCluster["RayCluster"]
        AppWrapper["AppWrapper"]
        LWS["LeaderWorkerSet"]
        Pod["Pod"]
        Deploy["Deployment"]
        STS["StatefulSet"]
    end

    Controller -->|"suspend/unsuspend<br/>via GenericJob interface"| JobTypes

    %% Monitoring
    Prometheus[Prometheus / OpenShift Monitoring] -->|"scrape /metrics<br/>8443/TCP HTTPS"| Controller

    %% MultiKueue
    Controller -->|"dispatch workloads<br/>443/TCP HTTPS"| RemoteK8s[Remote Kubernetes Clusters]

    %% Styling
    style KueueSystem fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style CoreCRDs fill:#fff3e0,stroke:#ef6c00,stroke-width:2px
    style AdvancedCRDs fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style JobTypes fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px

    style Controller fill:#1565c0,color:#fff
    style Scheduler fill:#1565c0,color:#fff
    style WebhookServer fill:#1565c0,color:#fff
    style VisibilityAPI fill:#1565c0,color:#fff

    style CQ fill:#f5a623,stroke:#333
    style LQ fill:#f5a623,stroke:#333
    style WL fill:#f5a623,stroke:#333
    style RF fill:#f5a623,stroke:#333
    style AC fill:#f5a623,stroke:#333
    style WPC fill:#f5a623,stroke:#333

    style MKC fill:#ef9a9a
    style MKCfg fill:#ef9a9a
    style PRC fill:#ef9a9a
    style Cohort fill:#ef9a9a
    style Topology fill:#ef9a9a

    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style RemoteK8s fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
