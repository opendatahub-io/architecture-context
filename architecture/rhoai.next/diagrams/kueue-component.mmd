graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        subgraph Controllers["Core Controllers"]
            CQCtrl["ClusterQueue Controller"]
            LQCtrl["LocalQueue Controller"]
            WLCtrl["Workload Controller"]
            ACCtrl["AdmissionCheck Controller"]
            RFCtrl["ResourceFlavor Controller"]
            CohortCtrl["Cohort Controller"]
        end

        subgraph Scheduler["Admission Scheduler"]
            SchedLoop["Periodic Scheduling Loop"]
            Cache["In-Memory Cache<br/>(Quotas, Flavors, Workloads)"]
            SchedLoop -->|reads| Cache
        end

        subgraph Webhooks["Webhook Server (9443/TCP TLS)"]
            MutatingWH["Mutating Webhooks<br/>(queue defaulting, suspension)"]
            ValidatingWH["Validating Webhooks<br/>(immutability, topology)"]
        end

        subgraph JobFrameworks["Job Framework Integrations"]
            BatchJob["batch/v1 Job"]
            PyTorch["PyTorchJob"]
            TFJob["TFJob"]
            XGBoost["XGBoostJob"]
            PaddleJob["PaddleJob"]
            MPIJob["MPIJob"]
            RayCluster["RayCluster"]
            RayJob["RayJob"]
            JobSet["JobSet"]
            AppWrapper["AppWrapper"]
            LWS["LeaderWorkerSet"]
            Deploy["Deployment"]
            STS["StatefulSet"]
            Pod["Pod"]
        end

        subgraph Advanced["Advanced Features"]
            MultiKueue["MultiKueue Controller<br/>(Multi-cluster distribution)"]
            Provisioning["Provisioning Controller<br/>(Autoscaler integration)"]
            TAS["TAS Controller<br/>(Topology-Aware Scheduling)"]
            Ungater["Topology Ungater"]
        end

        subgraph Endpoints["Endpoints"]
            Metrics["Metrics Server<br/>8443/TCP HTTPS"]
            Health["Health Probes<br/>8081/TCP HTTP"]
            VisAPI["Visibility API"]
        end

        Controllers -->|notify| Cache
        SchedLoop -->|admits| WLCtrl
        WLCtrl -->|creates workloads for| JobFrameworks
    end

    %% CRDs
    ClusterQueueCR["ClusterQueue CR"]
    LocalQueueCR["LocalQueue CR"]
    WorkloadCR["Workload CR"]
    AdmissionCheckCR["AdmissionCheck CR"]
    ResourceFlavorCR["ResourceFlavor CR"]
    CohortCR["Cohort CR"]
    MultiKueueClusterCR["MultiKueueCluster CR"]
    TopologyCR["Topology CR"]

    %% External
    User["User / Data Scientist"] -->|submits jobs| K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    K8sAPI -->|webhook calls| Webhooks
    ClusterQueueCR -->|watched by| CQCtrl
    LocalQueueCR -->|watched by| LQCtrl
    WorkloadCR -->|watched by| WLCtrl
    AdmissionCheckCR -->|watched by| ACCtrl
    ResourceFlavorCR -->|watched by| RFCtrl
    CohortCR -->|watched by| CohortCtrl
    MultiKueueClusterCR -->|watched by| MultiKueue
    TopologyCR -->|watched by| TAS

    MultiKueue -->|connects to| RemoteAPI["Remote K8s API Servers<br/>6443/TCP HTTPS"]

    %% Styles
    style KueueSystem fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8d4,stroke:#82b366
    style Scheduler fill:#fff2cc,stroke:#d6b656
    style Webhooks fill:#f8cecc,stroke:#b85450
    style JobFrameworks fill:#dae8fc,stroke:#6c8ebf
    style Advanced fill:#e1d5e7,stroke:#9673a6
    style Endpoints fill:#d5e8d4,stroke:#82b366
    style User fill:#f5f5f5,stroke:#666
    style K8sAPI fill:#f5a623,stroke:#333
    style RemoteAPI fill:#f5a623,stroke:#333
    style ClusterQueueCR fill:#fff2cc,stroke:#d6b656
    style LocalQueueCR fill:#fff2cc,stroke:#d6b656
    style WorkloadCR fill:#fff2cc,stroke:#d6b656
    style AdmissionCheckCR fill:#fff2cc,stroke:#d6b656
    style ResourceFlavorCR fill:#fff2cc,stroke:#d6b656
    style CohortCR fill:#fff2cc,stroke:#d6b656
    style MultiKueueClusterCR fill:#fff2cc,stroke:#d6b656
    style TopologyCR fill:#fff2cc,stroke:#d6b656
