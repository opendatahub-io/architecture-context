graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        subgraph Controllers["Controllers"]
            CQCtrl["ClusterQueue<br/>Controller"]
            LQCtrl["LocalQueue<br/>Controller"]
            WLCtrl["Workload<br/>Controller"]
            ACCtrl["AdmissionCheck<br/>Controller"]
            RFCtrl["ResourceFlavor<br/>Controller"]
            CohortCtrl["Cohort<br/>Controller"]
        end

        subgraph Scheduler["Admission Scheduler"]
            SchedLoop["Periodic Scheduling<br/>Loop"]
            Cache["In-Memory<br/>Quota Cache"]
            QueueMgr["Queue Manager"]
            SchedLoop -->|reads pending| QueueMgr
            SchedLoop -->|checks quota| Cache
        end

        subgraph Webhooks["Webhook Server :9443"]
            MutatingWH["Mutating Webhooks<br/>(queue defaulting,<br/>suspension injection)"]
            ValidatingWH["Validating Webhooks<br/>(queue immutability,<br/>topology validation)"]
        end

        subgraph Subsystems["Advanced Subsystems"]
            MultiKueue["MultiKueue<br/>Controller"]
            TAS["Topology-Aware<br/>Scheduling (TAS)"]
            Provisioning["Provisioning<br/>Request Controller"]
        end

        subgraph Endpoints["HTTP Endpoints"]
            Health["/healthz :8081"]
            Metrics["/metrics :8443<br/>HTTPS + Bearer Token"]
        end
    end

    %% CRDs
    User["User / Client"] -->|creates| JobCR["batch/v1 Job"]
    User -->|creates| PTJCR["PyTorchJob / TFJob<br/>XGBoostJob / PaddleJob"]
    User -->|creates| RayCR["RayCluster / RayJob"]
    User -->|creates| JSCR["JobSet / AppWrapper<br/>LeaderWorkerSet"]
    User -->|configures| CQCR["ClusterQueue CR"]
    User -->|configures| LQCR["LocalQueue CR"]
    User -->|configures| RFCR["ResourceFlavor CR"]

    %% CRD watches
    JobCR -->|"watched by"| CQCtrl
    PTJCR -->|"watched by"| CQCtrl
    RayCR -->|"watched by"| CQCtrl
    JSCR -->|"watched by"| CQCtrl
    CQCR -->|"watched by"| CQCtrl
    LQCR -->|"watched by"| LQCtrl
    RFCR -->|"watched by"| RFCtrl

    %% Internal flow
    CQCtrl -->|updates| Cache
    LQCtrl -->|enqueues| QueueMgr
    WLCtrl -->|manages| WorkloadCR["Workload CR"]
    SchedLoop -->|admits workloads| WLCtrl

    %% External
    MultiKueue -->|"HTTPS/6443"| RemoteK8s["Remote K8s<br/>API Servers"]
    Provisioning -->|creates| ProvReq["ProvisioningRequest CR"]
    ProvReq -->|"consumed by"| Autoscaler["Cluster Autoscaler"]
    TAS -->|watches| Nodes["Kubernetes Nodes"]

    %% API Server
    Controllers -->|"HTTPS/6443"| K8sAPI["Kubernetes<br/>API Server"]
    Webhooks -->|"called by"| K8sAPI

    %% Styling
    style KueueSystem fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style Controllers fill:#d5e8d4,stroke:#82b366
    style Scheduler fill:#fff2cc,stroke:#d6b656
    style Webhooks fill:#f8cecc,stroke:#b85450
    style Subsystems fill:#e1d5e7,stroke:#9673a6
    style Endpoints fill:#dae8fc,stroke:#6c8ebf
    style K8sAPI fill:#f5f5f5,stroke:#666
    style RemoteK8s fill:#f5f5f5,stroke:#666
    style Autoscaler fill:#f5f5f5,stroke:#666
    style Nodes fill:#f5f5f5,stroke:#666
    style User fill:#fff,stroke:#333
    style JobCR fill:#f5a623,stroke:#d68a00
    style PTJCR fill:#f5a623,stroke:#d68a00
    style RayCR fill:#f5a623,stroke:#d68a00
    style JSCR fill:#f5a623,stroke:#d68a00
    style CQCR fill:#f5a623,stroke:#d68a00
    style LQCR fill:#f5a623,stroke:#d68a00
    style RFCR fill:#f5a623,stroke:#d68a00
    style WorkloadCR fill:#f5a623,stroke:#d68a00
    style ProvReq fill:#f5a623,stroke:#d68a00
