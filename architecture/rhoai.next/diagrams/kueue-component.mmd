graph TB
    subgraph KueueOperator["Kueue Controller Manager"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            CQCtrl["ClusterQueue Controller"]
            LQCtrl["LocalQueue Controller"]
            WLCtrl["Workload Controller"]
            RFCtrl["ResourceFlavor Controller"]
            ACCtrl["AdmissionCheck Controller"]
            CohortCtrl["Cohort Controller"]
        end

        subgraph SchedulerEngine["Scheduler"]
            Scheduler["Scheduler Loop<br/>(manager.Runnable)"]
            FlavorAssigner["Flavor Assigner"]
            Preemption["Preemption Engine"]
            Scheduler --> FlavorAssigner
            Scheduler --> Preemption
        end

        subgraph JobFramework["Job Framework (Plugin Architecture)"]
            BatchJob["batch/v1 Job"]
            JobSetCtrl["JobSet"]
            PyTorchCtrl["PyTorchJob"]
            TFCtrl["TFJob"]
            MPICtrl["MPIJob"]
            RayJobCtrl["RayJob"]
            RayClusterCtrl["RayCluster"]
            AppWrapperCtrl["AppWrapper"]
            PodCtrl["Pod/PodGroup"]
            DeployCtrl["Deployment"]
            StatefulCtrl["StatefulSet"]
            LWSCtrl["LeaderWorkerSet"]
        end

        subgraph AdmissionChecks["Admission Check Controllers"]
            ProvisioningCtrl["Provisioning Controller"]
            MultiKueueCtrl["MultiKueue Controller"]
        end

        subgraph TAS["Topology-Aware Scheduling"]
            TopoCtrl["Topology Controller"]
            TopoUngater["Topology Ungater"]
            TASFlavor["TAS ResourceFlavor"]
        end

        WebhookServer["Webhook Server<br/>9443/TCP HTTPS"]
        MetricsServer["Metrics Server<br/>8443/TCP HTTPS"]
        HealthProbe["Health Probe<br/>8081/TCP HTTP"]
    end

    %% CRDs
    ClusterQueueCR["ClusterQueue CR<br/>(cluster-scoped)"]
    LocalQueueCR["LocalQueue CR<br/>(namespaced)"]
    WorkloadCR["Workload CR<br/>(namespaced)"]
    ResourceFlavorCR["ResourceFlavor CR<br/>(cluster-scoped)"]
    AdmissionCheckCR["AdmissionCheck CR<br/>(cluster-scoped)"]
    WorkloadPCCR["WorkloadPriorityClass CR"]

    %% External Actors
    User["User / Data Scientist"]
    K8sAPI["Kubernetes API Server<br/>6443/TCP"]
    Prometheus["Prometheus"]

    %% User creates jobs
    User -->|"creates Job/PyTorchJob/etc."| K8sAPI
    K8sAPI -->|"webhook call<br/>HTTPS/9443"| WebhookServer

    %% CRD watches
    ClusterQueueCR -->|watched by| CQCtrl
    LocalQueueCR -->|watched by| LQCtrl
    WorkloadCR -->|watched by| WLCtrl
    ResourceFlavorCR -->|watched by| RFCtrl
    AdmissionCheckCR -->|watched by| ACCtrl

    %% Scheduler flow
    CQCtrl -->|"notifies"| Scheduler
    WLCtrl -->|"notifies"| Scheduler
    Scheduler -->|"admits workload"| K8sAPI
    JobFramework -->|"unsuspends job"| K8sAPI

    %% Metrics & Health
    Prometheus -->|"scrapes<br/>HTTPS/8443<br/>Bearer Token"| MetricsServer

    %% Styling
    style KueueOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#dbeafe,stroke:#3b82f6
    style SchedulerEngine fill:#fef3c7,stroke:#f59e0b
    style JobFramework fill:#d1fae5,stroke:#10b981
    style AdmissionChecks fill:#fce7f3,stroke:#ec4899
    style TAS fill:#ede9fe,stroke:#8b5cf6
    style WebhookServer fill:#4a90e2,color:#fff
    style MetricsServer fill:#4a90e2,color:#fff
    style HealthProbe fill:#4a90e2,color:#fff
    style ClusterQueueCR fill:#f5a623
    style LocalQueueCR fill:#f5a623
    style WorkloadCR fill:#f5a623
    style ResourceFlavorCR fill:#f5a623
    style AdmissionCheckCR fill:#f5a623
    style WorkloadPCCR fill:#f5a623
    style K8sAPI fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style User fill:#f9f9f9,stroke:#333
