graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        Controller["Kueue Controller<br/>(controller-runtime)"]
        Scheduler["Scheduler<br/>(admission decisions)"]
        Cache["In-Memory Cache<br/>(queue state)"]
        QueueMgr["Queue Manager<br/>(queue ordering)"]
        Webhook["Webhook Server<br/>9443/TCP TLS<br/>(36 webhooks)"]

        Controller -->|state sync| Cache
        Scheduler -->|reads state| Cache
        Scheduler -->|reads order| QueueMgr
        Controller -->|notifies| QueueMgr
    end

    subgraph CRDs["Kueue CRDs (kueue.x-k8s.io)"]
        CQ["ClusterQueue<br/>(cluster-scoped)<br/>quotas, flavors, preemption"]
        LQ["LocalQueue<br/>(namespace-scoped)<br/>user-facing queue"]
        WL["Workload<br/>(namespace-scoped)<br/>job resource request"]
        RF["ResourceFlavor<br/>(cluster-scoped)<br/>hardware types"]
        AC["AdmissionCheck<br/>(cluster-scoped)<br/>external gates"]
        WPC["WorkloadPriorityClass<br/>(cluster-scoped)"]
        MKC["MultiKueueCluster<br/>(cluster-scoped)"]
        Cohort["Cohort<br/>(cluster-scoped, v1alpha1)"]
        Topology["Topology<br/>(cluster-scoped, v1alpha1)"]
    end

    subgraph JobFrameworks["Job Framework Integrations"]
        Job["batch/v1 Job"]
        JobSet["JobSet"]
        PyTorch["PyTorchJob"]
        TFJob["TFJob"]
        MPIJob["MPIJob"]
        XGBoost["XGBoostJob"]
        Paddle["PaddleJob"]
        RayJob["RayJob"]
        RayCluster["RayCluster"]
        AppWrapper["AppWrapper"]
    end

    subgraph AdmissionChecks["Admission Check Controllers"]
        ProvCtrl["Provisioning Controller<br/>(ProvisioningRequest)"]
        MKCtrl["MultiKueue Controller<br/>(multi-cluster)"]
    end

    %% User interaction
    User["Data Scientist / User"] -->|submits job with<br/>queue-name label| JobFrameworks
    Admin["Platform Admin"] -->|creates| CQ
    Admin -->|creates| RF
    Admin -->|creates| LQ

    %% Queue hierarchy
    LQ -->|references| CQ
    CQ -->|member of| Cohort
    CQ -->|uses| RF
    CQ -->|requires| AC

    %% Job → Workload flow
    JobFrameworks -->|webhook intercept| Webhook
    Controller -->|creates Workload from| JobFrameworks
    Controller -->|watches| CRDs

    %% Scheduler admission
    Scheduler -->|admits| WL
    WL -->|submitted to| LQ
    Controller -->|suspends/resumes| JobFrameworks

    %% Admission checks
    AC -->|delegates to| AdmissionChecks
    ProvCtrl -->|creates ProvisioningRequest| K8sAPI["Kubernetes API Server"]
    MKCtrl -->|distributes to| RemoteCluster["Remote Kueue Cluster"]

    %% External
    Controller -->|all operations via| K8sAPI
    Prometheus["Prometheus"] -->|scrapes :8443| Controller

