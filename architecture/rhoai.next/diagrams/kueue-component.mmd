graph TB
    subgraph KueueSystem["Kueue Controller Manager"]
        direction TB
        subgraph CoreControllers["Core Controllers"]
            CQCtrl["ClusterQueue<br/>Controller"]
            LQCtrl["LocalQueue<br/>Controller"]
            WLCtrl["Workload<br/>Controller"]
            RFCtrl["ResourceFlavor<br/>Controller"]
            ACCtrl["AdmissionCheck<br/>Controller"]
            CohortCtrl["Cohort<br/>Controller"]
        end

        subgraph SchedulerEngine["Scheduler"]
            Scheduler["Scheduler Loop<br/>(manager.Runnable)"]
            FlavorAssigner["Flavor Assigner"]
            Preemptor["Preemption Engine"]
            Scheduler --> FlavorAssigner
            Scheduler --> Preemptor
        end

        subgraph TAS["Topology-Aware Scheduling"]
            TopoCtrl["Topology Controller"]
            TopoUngater["Topology Ungater"]
            TASFlavorCtrl["TAS ResourceFlavor<br/>Controller"]
        end

        subgraph MultiKueueSub["MultiKueue (disabled in RHOAI)"]
            MKClusterCtrl["Clusters Reconciler"]
            MKWlCtrl["Workload Reconciler"]
            MKACCtrl["AdmissionCheck<br/>Reconciler"]
        end

        subgraph Provisioning["Provisioning Integration"]
            ProvCtrl["Provisioning<br/>Controller"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutatingWH["17 Mutating<br/>Webhooks"]
            ValidatingWH["18 Validating<br/>Webhooks"]
            ConversionWH["1 Conversion<br/>Webhook"]
        end

        subgraph Cache["In-Memory Cache"]
            QueueCache["Queue Snapshot"]
            ClusterQueueCache["ClusterQueue Cache"]
        end

        CQCtrl --> ClusterQueueCache
        LQCtrl --> QueueCache
        WLCtrl --> QueueCache
        RFCtrl -->|notifies| CQCtrl
        Scheduler -->|reads| QueueCache
        Scheduler -->|reads| ClusterQueueCache
    end

    %% CRDs
    User[User / Data Scientist] -->|creates| JobCR["batch/v1 Job<br/>PyTorchJob, RayJob,<br/>JobSet, AppWrapper, etc."]
    JobCR -->|intercepted by| Webhooks
    Webhooks -->|creates| WorkloadCR["Workload CR"]

    %% Core CRDs managed
    ClusterQueueCR["ClusterQueue CR"] -->|watched by| CQCtrl
    LocalQueueCR["LocalQueue CR"] -->|watched by| LQCtrl
    WorkloadCR -->|watched by| WLCtrl
    ResourceFlavorCR["ResourceFlavor CR"] -->|watched by| RFCtrl
    AdmissionCheckCR["AdmissionCheck CR"] -->|watched by| ACCtrl

    %% Scheduler output
    Scheduler -->|admits workload<br/>unsuspends job| K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% Provisioning
    ProvCtrl -->|creates| ProvReqCR["ProvisioningRequest CR"]
    ProvReqCR -->|read by| ClusterAutoscaler["Cluster Autoscaler"]

    %% Metrics & Health
    Prometheus["Prometheus"] -->|scrapes 8443/TCP<br/>Bearer Token + TLS| KueueSystem

    %% Styling
    style KueueSystem fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#d5e8d4,stroke:#82b366
    style SchedulerEngine fill:#fff2cc,stroke:#d6b656
    style TAS fill:#f8cecc,stroke:#b85450
    style MultiKueueSub fill:#e1d5e7,stroke:#9673a6,stroke-dasharray: 5 5
    style Provisioning fill:#dae8fc,stroke:#6c8ebf
    style Webhooks fill:#ffe6cc,stroke:#d79b00
    style Cache fill:#f5f5f5,stroke:#666

    style User fill:#4a90e2,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5

    style ClusterQueueCR fill:#f5a623,color:#fff
    style LocalQueueCR fill:#f5a623,color:#fff
    style WorkloadCR fill:#f5a623,color:#fff
    style ResourceFlavorCR fill:#f5a623,color:#fff
    style AdmissionCheckCR fill:#f5a623,color:#fff
    style JobCR fill:#f5a623,color:#fff
    style ProvReqCR fill:#f5a623,color:#fff
