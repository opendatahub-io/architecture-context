graph TB
    subgraph OGXDistribution["OGX Distribution Container"]
        direction TB
        subgraph BuildPipeline["Build Pipeline (build-time only)"]
            BuildScript["build/build.py<br/>Python Script"]
            BuildManifest["build/build.yaml<br/>Provider Manifest"]
            LabelSync["scripts/sync_labels.py<br/>OCI Label Sync"]
            BuildScript -->|reads| BuildManifest
            BuildScript -->|generates| GenConfig["distribution/config.yaml"]
            BuildScript -->|generates| GenReqs["distribution/requirements.txt"]
            BuildScript -->|generates| GenContainerfile["Containerfile"]
            LabelSync -->|syncs labels| DockerfileKonflux["Dockerfile.konflux"]
        end

        subgraph Runtime["Runtime Components"]
            Entrypoint["entrypoint.sh<br/>Container Entrypoint"]
            OGXServer["OGX Server<br/>AI Gateway<br/>Port 8321/TCP"]
            ConfigYAML["config.yaml<br/>Runtime Configuration"]
            Entrypoint -->|runs ogx with| ConfigYAML
            Entrypoint -->|starts| OGXServer
        end

        subgraph APIs["API Surface"]
            HealthAPI["/v1/health"]
            ChatAPI["/v1/chat/completions"]
            MessagesAPI["/v1/messages"]
            ResponsesAPI["/v1/responses"]
            InferenceAPI["/v1/inference/*"]
            VectorAPI["/v1/vector-io/*"]
            FilesAPI["/v1/files/*"]
            FileProcessAPI["/v1alpha/file-processors/*"]
            ToolRuntimeAPI["/v1/tool-runtime/*"]
            BatchesAPI["/v1/batches/*"]
        end

        OGXServer --> APIs
    end

    subgraph BaseImage["AIPCC Base Image"]
        RHEL9["RHEL 9.6 + Python 3.12"]
        RHAIPyPI["RHEL AI PyPI"]
    end

    subgraph InferenceProviders["Inference Providers (env-activated)"]
        vLLM["vLLM"]
        Bedrock["AWS Bedrock"]
        WatsonX["IBM WatsonX"]
        AzureOAI["Azure OpenAI"]
        VertexAI["Google Vertex AI"]
        OpenAI["OpenAI"]
        Gemini["Google Gemini"]
        Anthropic["Anthropic"]
    end

    subgraph VectorDBs["Vector Databases (env-activated)"]
        Milvus["Milvus"]
        PGVector["pgvector"]
        Qdrant["Qdrant"]
    end

    subgraph StateStore["State Store"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
    end

    subgraph ToolRuntimes["Tool Runtimes (env-activated)"]
        BraveSearch["Brave Search"]
        TavilySearch["Tavily Search"]
        MCPServers["MCP Servers"]
        DoclingServe["Docling Serve"]
    end

    Client["Client"] -->|HTTP 8321/TCP<br/>OAuth2 Bearer (optional)| OGXServer

    OGXServer -->|configurable| InferenceProviders
    OGXServer -->|configurable| VectorDBs
    OGXServer -->|5432/TCP| PostgreSQL
    OGXServer -->|configurable| ToolRuntimes

    BaseImage -.->|base layer| OGXDistribution

    subgraph OCI["OCI Labels"]
        ConfigLabel["com.ogx.config.config.yaml<br/>Base64-encoded config"]
    end

    DockerfileKonflux -.->|embeds| ConfigLabel

