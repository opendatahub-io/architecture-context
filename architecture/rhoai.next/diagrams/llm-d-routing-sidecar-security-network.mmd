graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Route - Optional)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
    end

    subgraph PodBoundary["POD BOUNDARY (Kubernetes Pod)"]
        direction TB

        subgraph SidecarContainer["Sidecar Container"]
            Sidecar["llm-d-routing-sidecar<br/>8000/TCP HTTPS<br/>TLS 1.2+<br/>FIPS-compatible ciphers<br/>SSRF AllowlistValidator"]
        end

        subgraph DecoderContainer["Decoder Container (same pod)"]
            Decoder["vLLM Decoder<br/>8001/TCP (default)<br/>HTTP or HTTPS<br/>Optional TLS 1.2+"]
        end
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Other Pods)"]
        Prefiller["Remote vLLM Prefiller Pods<br/>Port varies (from header)<br/>HTTP or HTTPS<br/>Optional TLS 1.2+<br/>SSRF-validated targets"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        PodAPI["Pod Resources<br/>(watch/list for SSRF allowlist)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>No client auth"| Route

    %% Ingress → Sidecar
    Route -->|"HTTP/8080<br/>Post TLS termination"| Sidecar

    %% Direct access (no Route)
    Client -.->|"HTTPS/8000<br/>TLS 1.2+<br/>No client auth<br/>(direct pod access)"| Sidecar

    %% Sidecar → Decoder (intra-pod)
    Sidecar -->|"HTTP or HTTPS/8001<br/>Optional TLS 1.2+<br/>No auth<br/>Modified request + KV params"| Decoder

    %% Sidecar → Prefiller (inter-pod)
    Sidecar -->|"HTTP or HTTPS/varies<br/>Optional TLS 1.2+<br/>No auth<br/>Prefill request"| Prefiller

    %% Prefiller → Sidecar (response)
    Prefiller -.->|"Response<br/>kv_transfer_params"| Sidecar

    %% Sidecar → K8s API (SSRF allowlist)
    Sidecar -->|"HTTPS/443<br/>TLS<br/>ServiceAccount Token<br/>Watch InferencePool + Pods"| K8sAPI

    K8sAPI --- InferencePool
    K8sAPI --- PodAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef decoder fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterinternal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class Sidecar sidecar
    class Decoder decoder
    class Prefiller clusterinternal
    class K8sAPI,InferencePool,PodAPI controlplane
