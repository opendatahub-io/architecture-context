graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / EPP / Gateway"]
    end

    subgraph Ingress["INGRESS (Edge TLS Termination)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination<br/>HTTPS"]
        Service["ClusterIP Service<br/>8080/TCP → 8080<br/>HTTP<br/>Internal Only"]
    end

    subgraph Pod["POD (vLLM Decoder + Routing Sidecar)"]
        direction TB

        subgraph SidecarContainer["Routing Sidecar Container"]
            TLSEndpoint["TLS Server<br/>8000/TCP<br/>TLS 1.2+<br/>Self-signed 4096-bit RSA"]
            SSRFValidator["SSRF Validator<br/>InferencePool Allowlist<br/>IP-based (any port)"]
        end

        subgraph DecoderContainer["vLLM Decoder Container"]
            Decoder["vLLM Decoder<br/>8001/TCP<br/>HTTP(S)<br/>Optional TLS"]
        end
    end

    subgraph RemoteInfra["CLUSTER INTERNAL (Remote Pods)"]
        Prefiller["Remote Prefiller vLLM<br/>varies port<br/>HTTP(S)<br/>Optional TLS 1.2+"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>HTTPS TLS<br/>SA Token Auth"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        Pods["Pod Resources<br/>Matching Pool Selectors"]
    end

    %% Ingress flows
    Client -->|"HTTPS/443<br/>TLS Edge"| Route
    Route -->|"HTTP/8080<br/>Post-TLS termination"| Service
    Service -->|"HTTP/8080"| TLSEndpoint

    %% Pod-to-pod direct
    Client -.->|"HTTPS/8000<br/>TLS 1.2+<br/>Direct pod access"| TLSEndpoint

    %% Internal pod flows
    TLSEndpoint -->|"Validate target IP"| SSRFValidator
    TLSEndpoint -->|"HTTP(S)/8001<br/>Optional TLS<br/>InsecureSkipVerify"| Decoder

    %% Prefiller egress
    TLSEndpoint -->|"HTTP(S)/varies<br/>Optional TLS 1.2+<br/>InsecureSkipVerify<br/>x-prefiller-host-port"| Prefiller

    %% Control plane
    SSRFValidator -->|"HTTPS/443<br/>TLS<br/>ServiceAccount Token<br/>get,watch,list"| K8sAPI
    K8sAPI --- InferencePool
    K8sAPI --- Pods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef decoder fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef remote fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef controlplane fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#333

    class Client external
    class Route,Service ingress
    class TLSEndpoint,SSRFValidator sidecar
    class Decoder decoder
    class Prefiller remote
    class K8sAPI,InferencePool,Pods controlplane
