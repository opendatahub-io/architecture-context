graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Gateway"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS edge termination"]
    end

    subgraph PodBoundary["KUBERNETES POD"]
        direction TB

        subgraph SidecarContainer["Sidecar Container"]
            Sidecar["llm-d-routing-sidecar<br/>8000/TCP HTTPS<br/>TLS 1.2+ RSA-4096<br/>ECDHE cipher suites<br/>No client auth"]
            AllowlistVal["AllowlistValidator<br/>SSRF Protection<br/>(optional)"]
            Sidecar -->|"validate prefiller host"| AllowlistVal
        end

        subgraph DecoderContainer["Co-located Container"]
            Decoder["vLLM Decoder<br/>8001/TCP<br/>HTTP or HTTPS<br/>Optional TLS 1.2+"]
        end
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Other Pods)"]
        Prefiller["Remote vLLM Prefiller<br/>Variable port<br/>HTTP or HTTPS<br/>Optional TLS 1.2+<br/>Must match InferencePool selector"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    end

    %% Flows
    Client -->|"HTTPS/8000<br/>TLS 1.2+<br/>No auth<br/>x-prefiller-host-port header"| Route
    Route -->|"HTTP/8080<br/>Post-TLS termination"| Sidecar

    Sidecar -->|"HTTP(S)/variable<br/>Optional TLS 1.2+<br/>SSRF validated<br/>Prefill request (max_tokens=1)"| Prefiller
    Prefiller -->|"KV transfer params<br/>(engine IDs, block IDs)"| Sidecar

    Sidecar -->|"HTTP(S)/8001<br/>localhost<br/>Optional TLS 1.2+<br/>Decode request + KV params"| Decoder

    AllowlistVal -->|"Watch<br/>HTTPS/443<br/>ServiceAccount token"| K8sAPI
    K8sAPI --- InferencePool

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef decoder fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route ingress
    class Sidecar,AllowlistVal sidecar
    class Decoder decoder
    class Prefiller cluster
    class K8sAPI,InferencePool controlplane
