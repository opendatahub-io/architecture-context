graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(via EPP/Gateway)"]
    end

    subgraph Ingress["INGRESS (OpenShift Route - Edge TLS)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
        Service["ClusterIP Service<br/>8080/TCP → 8000/TCP"]
        Route --> Service
    end

    subgraph PodNetwork["POD NETWORK (vLLM Decoder Pod)"]
        direction TB

        subgraph SidecarContainer["Sidecar Container"]
            Sidecar["llm-d-routing-sidecar<br/>:8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (AES-GCM, CHACHA20)<br/>4096-bit RSA certs"]
            SSRFCheck["AllowlistValidator<br/>SSRF Protection<br/>(optional)"]
            Sidecar -.->|"validates prefiller host<br/>403 if unauthorized"| SSRFCheck
        end

        subgraph DecoderContainer["Decoder Container"]
            Decoder["vLLM Decoder<br/>localhost:8001/TCP<br/>HTTP/HTTPS<br/>Optional TLS 1.2+"]
        end
    end

    subgraph ClusterEgress["CLUSTER NETWORK (Cross-pod Egress)"]
        Prefiller["Remote vLLM Prefiller<br/>{host}:{port} (dynamic)<br/>HTTP/HTTPS<br/>Optional TLS 1.2+"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS Edge"| Route

    %% Ingress to Pod
    Service -->|"HTTP or HTTPS/8000<br/>TLS 1.2+ (default)"| Sidecar

    %% Pod internal
    Sidecar -->|"HTTP or HTTPS/8001<br/>Optional TLS 1.2+<br/>localhost (in-pod)"| Decoder

    %% Cross-pod egress
    Sidecar -->|"HTTP or HTTPS/{dynamic}<br/>Optional TLS 1.2+<br/>SSRF validated"| Prefiller

    %% Control plane
    SSRFCheck -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watch: InferencePool, Pods"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Sidecar,Decoder pod
    class Prefiller egress
    class K8sAPI controlplane
    class SSRFCheck security
