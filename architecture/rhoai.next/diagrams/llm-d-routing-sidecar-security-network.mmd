graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Gateway"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS Edge Termination"]
        Service["ClusterIP Service<br/>8080/TCP<br/>Internal Only"]
    end

    subgraph PodBoundary["POD BOUNDARY (Sidecar + Decoder)"]
        direction TB

        subgraph SidecarContainer["llm-d-routing-sidecar"]
            Proxy["HTTP Reverse Proxy<br/>:8000/TCP HTTPS<br/>TLS 1.2+ (RSA-4096)<br/>Ciphers: ECDHE+AES-GCM,<br/>ECDHE+CHACHA20"]
            Allowlist["AllowlistValidator<br/>SSRF Protection<br/>(optional)"]
        end

        subgraph DecoderContainer["vLLM Decoder (co-located)"]
            Decoder["vLLM Decoder<br/>:8001/TCP<br/>HTTP/HTTPS"]
        end
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Other Pods)"]
        Prefiller["Remote Prefiller Pods<br/>Variable port<br/>HTTP/HTTPS<br/>Must be in InferencePool allowlist"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>:443/TCP HTTPS<br/>TLS<br/>ServiceAccount Token Auth"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS Edge<br/>No Client Auth"| Route
    Route -->|"HTTP/8080<br/>Post-TLS termination"| Service
    Service -->|"HTTP/8080"| Proxy

    %% Sidecar internal
    Proxy -->|"SSRF check<br/>(in-process)"| Allowlist

    %% Sidecar to Prefiller (egress)
    Proxy -->|"HTTP or HTTPS<br/>Variable port<br/>Optional TLS 1.2+<br/>No Auth"| Prefiller

    %% Sidecar to Decoder (localhost)
    Proxy -->|"HTTP or HTTPS<br/>:8001/TCP localhost<br/>Optional TLS 1.2+<br/>No Auth"| Decoder

    %% SSRF watches
    Allowlist -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watch InferencePool + Pods"| K8sAPI

    %% Response path
    Decoder -.->|"Response<br/>(streamed through sidecar)"| Client

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Proxy,Allowlist sidecar
    class Decoder pod
    class Prefiller cluster
    class K8sAPI externalservice
