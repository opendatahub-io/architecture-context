graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Application"]
    end

    subgraph Platform["PLATFORM BOUNDARY (RHOAI)"]
        Proxy["kube-rbac-proxy Sidecar<br/>Bearer Token AuthN/AuthZ<br/>TLS Termination"]
    end

    subgraph CaikitRuntime["CAIKIT RUNTIME (Application Boundary)"]
        direction TB

        subgraph Servers["Serving Layer"]
            HTTPServer["HTTP Server (FastAPI)<br/>8080/TCP HTTP/1.1<br/>Optional TLS/mTLS<br/>Endpoints: /api/v1/*"]
            GRPCServer["gRPC Server<br/>8085/TCP gRPC (HTTP/2)<br/>Optional TLS/mTLS<br/>Dynamic {Task}Service RPCs"]
            Metrics["Prometheus Metrics<br/>8086/TCP HTTP<br/>Plaintext (no encryption)<br/>No auth"]
        end

        subgraph Internal["Application Logic"]
            Predict["GlobalPredictServicer"]
            Train["GlobalTrainServicer"]
            ModelMgr["ModelManager"]
            LoadedModel["LoadedModel<br/>(Module.run)"]
        end

        subgraph MMeshAPI["Model Mesh Interface"]
            MRServicer["ModelRuntimeServicer<br/>mmesh.ModelRuntime<br/>Unix socket or 8085/TCP<br/>Optional TLS"]
        end
    end

    subgraph Sidecars["SIDECAR / CO-LOCATED"]
        MMesh["Model Mesh Controller<br/>Unix socket: /tmp/mmesh/grpc.sock<br/>gRPC, Optional TLS"]
        HealthProbe["caikit_health_probe<br/>Liveness: psutil check<br/>Readiness: gRPC + HTTP<br/>with full TLS handshake"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Optional TLS/mTLS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS, AWS IAM / access key"]
        RemoteCaikit["Remote Caikit Servers<br/>Configurable port<br/>gRPC or HTTP<br/>Optional TLS/mTLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Server<br/>Scrapes 8086/TCP<br/>HTTP, No encryption"]
    end

    %% External to Platform
    Client -->|"HTTP 8080 or gRPC 8085<br/>Optional TLS/mTLS<br/>Bearer Token (RHOAI)"| Proxy

    %% Platform to Caikit
    Proxy -->|"HTTP 8080<br/>Validated request"| HTTPServer
    Proxy -->|"gRPC 8085<br/>Validated request"| GRPCServer

    %% Internal flows
    HTTPServer --> Predict
    HTTPServer --> Train
    GRPCServer --> Predict
    Predict --> ModelMgr
    Train --> ModelMgr
    ModelMgr --> LoadedModel

    %% Model Mesh
    MMesh -->|"gRPC<br/>Unix socket<br/>loadModel/unloadModel"| MRServicer
    MRServicer --> ModelMgr

    %% Health probe
    HealthProbe -->|"gRPC 8085<br/>health check + TLS"| GRPCServer
    HealthProbe -->|"HTTP 8080<br/>GET /health + TLS"| HTTPServer

    %% Egress
    CaikitRuntime -->|"gRPC 4317 or HTTP 4318<br/>Optional TLS/mTLS<br/>Trace export"| OTEL
    LoadedModel -->|"HTTPS 443<br/>TLS, IAM Auth<br/>Model artifacts"| S3
    LoadedModel -->|"gRPC or HTTP<br/>Optional TLS/mTLS<br/>Remote inference"| RemoteCaikit

    %% Monitoring
    Prometheus -->|"HTTP 8086<br/>Plaintext scrape"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef danger fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Proxy platform
    class HTTPServer,GRPCServer,Metrics,Predict,Train,ModelMgr,LoadedModel,MRServicer runtime
    class MMesh,HealthProbe sidecar
    class OTEL,S3,RemoteCaikit externalservice
    class Prometheus monitoring
