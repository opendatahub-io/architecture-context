graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Application"]
    end

    subgraph RHOAI_Proxy["RHOAI AUTH LAYER (optional)"]
        KubeRBACProxy["kube-rbac-proxy<br/>Bearer Token / K8s RBAC<br/>HTTPS"]
    end

    subgraph CaikitRuntime["CAIKIT RUNTIME (Application Boundary)"]
        direction TB

        subgraph Servers["Dual-Protocol Servers"]
            HTTPServer["HTTP Server (FastAPI)<br/>Port: 8080/TCP<br/>HTTP/1.1<br/>Optional TLS/mTLS"]
            gRPCServer["gRPC Server (grpcio)<br/>Port: 8085/TCP<br/>gRPC (HTTP/2)<br/>Optional TLS/mTLS"]
        end

        subgraph Metrics["Metrics"]
            PrometheusEndpoint["Prometheus Metrics<br/>Port: 8086/TCP<br/>HTTP (plaintext)<br/>No Auth"]
        end

        subgraph InternalLogic["Shared Servicers (in-process)"]
            Servicers["GlobalPredictServicer<br/>GlobalTrainServicer<br/>ModelManager<br/>CoreModelLoader"]
        end
    end

    subgraph SidecarLocal["SIDECAR / LOCAL (Same Pod)"]
        ModelMesh["Model Mesh Sidecar<br/>Unix: /tmp/mmesh/grpc.sock<br/>or 8085/TCP gRPC<br/>Optional TLS, No Auth"]
        HealthProbe["caikit-health-probe<br/>exec'd by K8s<br/>gRPC + HTTP checks<br/>Full TLS/mTLS handshake"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        Prometheus["Prometheus<br/>Metrics scraper"]
        KServe["KServe Pod<br/>(container runtime host)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Optional TLS/mTLS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS, AWS IAM / access key"]
        RemoteCaikit["Remote Caikit Servers<br/>Configurable port<br/>gRPC or HTTP<br/>Optional TLS/mTLS"]
    end

    %% External flows
    Client -->|"HTTP/8080 or gRPC/8085<br/>Optional TLS/mTLS<br/>Optional mTLS client cert"| KubeRBACProxy
    KubeRBACProxy -->|"Authenticated request<br/>Bearer Token verified"| HTTPServer
    KubeRBACProxy -->|"Authenticated request<br/>Bearer Token verified"| gRPCServer

    Client -.->|"Direct (non-RHOAI)<br/>Optional TLS/mTLS"| HTTPServer
    Client -.->|"Direct (non-RHOAI)<br/>Optional TLS/mTLS"| gRPCServer

    %% Internal flows
    HTTPServer --> Servicers
    gRPCServer --> Servicers

    %% Sidecar flows
    ModelMesh -->|"gRPC (Unix socket)<br/>loadModel/unloadModel<br/>Optional TLS"| gRPCServer
    HealthProbe -->|"gRPC health check<br/>8085/TCP + TLS"| gRPCServer
    HealthProbe -->|"HTTP GET /health<br/>8080/TCP + TLS"| HTTPServer

    %% Cluster internal
    Prometheus -->|"HTTP/8086<br/>plaintext<br/>No Auth"| PrometheusEndpoint

    %% Egress
    Servicers -->|"gRPC/4317 or HTTP/4318<br/>Optional TLS/mTLS"| OTEL
    Servicers -->|"HTTPS/443<br/>TLS, IAM auth"| S3
    Servicers -->|"gRPC or HTTP<br/>Optional TLS/mTLS"| RemoteCaikit

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef authproxy fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef clusterinternal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KubeRBACProxy authproxy
    class HTTPServer,gRPCServer,PrometheusEndpoint,Servicers runtime
    class ModelMesh,HealthProbe sidecar
    class Prometheus,KServe clusterinternal
    class OTEL,S3,RemoteCaikit externalservice
