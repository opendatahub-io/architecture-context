graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph Platform["PLATFORM BOUNDARY (RHOAI)"]
        KRBAC["kube-rbac-proxy sidecar<br/>(RHOAI only)<br/>Bearer Token Auth<br/>K8s TokenReview"]
    end

    subgraph CaikitRuntime["CAIKIT RUNTIME (Application Boundary)"]
        direction TB

        HTTPServer["HTTP Server (FastAPI/Uvicorn)<br/>8080/TCP HTTP/1.1<br/>Optional TLS/mTLS<br/>Endpoints: /api/v1/{task}/..., /health, /models"]
        GRPCServer["gRPC Server<br/>8085/TCP gRPC (HTTP/2)<br/>Optional TLS/mTLS<br/>Services: {Task}Service, ModelRuntime, Health"]
        Metrics["Prometheus Metrics<br/>8086/TCP HTTP<br/>Plaintext (no encryption)<br/>No Auth"]
    end

    subgraph Sidecar["SIDECAR / LOCAL"]
        ModelMesh["Model Mesh Controller<br/>Unix: /tmp/mmesh/grpc.sock<br/>Fallback: 8085/TCP gRPC<br/>Optional TLS, No Auth"]
        HealthProbe["caikit_health_probe<br/>K8s liveness/readiness<br/>Probes both servers<br/>Full TLS handshake"]
    end

    subgraph EgressZone["EGRESS (Outbound)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Optional TLS/mTLS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS, AWS IAM / Access Key"]
        RemoteCaikit["Remote Caikit Servers<br/>Configurable port<br/>gRPC or HTTP<br/>Optional TLS/mTLS"]
    end

    %% External flows
    Client -->|"HTTP/8080 or gRPC/8085<br/>Optional TLS/mTLS<br/>Optional mTLS cert"| KRBAC
    KRBAC -->|"Authenticated request<br/>Bearer → TokenReview"| HTTPServer
    KRBAC -->|"Authenticated request<br/>Bearer → TokenReview"| GRPCServer

    %% Sidecar flows
    ModelMesh -->|"gRPC Unix socket<br/>/tmp/mmesh/grpc.sock<br/>loadModel/unloadModel"| GRPCServer
    HealthProbe -->|"HTTP GET /api/v1/health<br/>+ gRPC health.v1.Health<br/>Full TLS verification"| HTTPServer
    HealthProbe -->|"gRPC health check<br/>Full TLS verification"| GRPCServer

    %% Egress flows
    CaikitRuntime -->|"Traces: gRPC/4317<br/>or HTTP/4318<br/>Optional TLS/mTLS"| OTEL
    CaikitRuntime -->|"Model artifacts<br/>HTTPS/443<br/>TLS, IAM Auth"| S3
    CaikitRuntime -->|"Remote inference<br/>gRPC or HTTP<br/>Optional TLS/mTLS"| RemoteCaikit

    %% Monitoring
    Prom["Prometheus"] -->|"Scrape HTTP/8086<br/>Plaintext"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KRBAC platform
    class HTTPServer,GRPCServer,Metrics runtime
    class ModelMesh,HealthProbe sidecar
    class OTEL,S3,RemoteCaikit egress
    class Prom monitoring
