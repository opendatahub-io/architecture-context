graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application / Pipeline"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (KServe/Istio-Managed)"]
        Gateway["KServe / Istio Gateway<br/>TLS termination<br/>Platform-managed auth"]
    end

    subgraph PodBoundary["POD BOUNDARY (KServe/ModelMesh Pod)"]
        direction TB

        subgraph CaikitContainer["Caikit Runtime Container"]
            gRPCServer["gRPC Server<br/>8085/TCP gRPC/HTTP2<br/>TLS 1.2+/mTLS/plaintext<br/>ssl_server_credentials"]
            HTTPServer["HTTP Server (FastAPI)<br/>8080/TCP HTTP/HTTPS<br/>TLS 1.2+/mTLS/plaintext<br/>ssl.SSLContext CERT_REQUIRED"]
            MetricsServer["Metrics Server<br/>8086/TCP HTTP<br/>plaintext<br/>No auth"]
            UnixSocket["Unix Domain Socket<br/>unix:///tmp/mmesh/grpc.sock<br/>gRPC plaintext<br/>Pod-local only"]
        end

        subgraph ModelMeshSidecar["ModelMesh Sidecar"]
            MMController["ModelMesh Controller<br/>loadModel/unloadModel"]
        end

        MMController -->|gRPC plaintext<br/>unix socket<br/>No auth| UnixSocket
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        Kubelet["Kubernetes kubelet"]
        HealthProbe["caikit-health-probe<br/>Separate process<br/>psutil + protocol checks"]
        Prometheus["Prometheus<br/>Metrics scrape"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS/mTLS/plaintext"]
        RemoteCaikit["Remote Caikit Runtime<br/>8085/8080/TCP<br/>TLS/mTLS<br/>Bearer Token"]
    end

    %% External flows
    Client -->|gRPC/8085 or HTTP/8080<br/>TLS 1.2+/mTLS<br/>Client cert or None| Gateway
    Gateway -->|routed to pod| gRPCServer
    Gateway -->|routed to pod| HTTPServer

    %% Cluster internal flows
    Kubelet -->|exec| HealthProbe
    HealthProbe -->|HTTP/8080<br/>TLS matches config<br/>No auth /health| HTTPServer
    HealthProbe -->|gRPC/8085 or unix<br/>TLS matches config<br/>Health.Check| gRPCServer
    Prometheus -->|HTTP/8086<br/>plaintext<br/>No auth - scrape| MetricsServer

    %% Egress flows
    gRPCServer -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    gRPCServer -->|OTLP gRPC/4317<br/>TLS/mTLS<br/>Client certs| OTEL
    gRPCServer -->|gRPC/HTTP<br/>TLS/mTLS<br/>Bearer Token| RemoteCaikit

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class gRPCServer,HTTPServer,MetricsServer,UnixSocket container
    class MMController sidecar
    class Kubelet,HealthProbe,Prometheus internal
    class S3,OTEL,RemoteCaikit externalservice
