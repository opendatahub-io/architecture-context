graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph Platform["PLATFORM LAYER (KServe / Service Mesh)"]
        Ingress["Platform Ingress<br/>KServe Route / Istio Gateway<br/>TLS termination or passthrough"]
    end

    subgraph CaikitPod["CAIKIT RUNTIME POD"]
        direction TB

        HTTPServer["HTTP Server (FastAPI/Uvicorn)<br/>8080/TCP<br/>HTTP/1.1<br/>Optional TLS 1.2+ / mTLS<br/>Auth: None (platform-delegated)"]

        GRPCServer["gRPC Server<br/>8085/TCP<br/>gRPC (HTTP/2)<br/>Optional TLS 1.2+ / mTLS<br/>Auth: None (platform-delegated)"]

        MetricsEndpoint["Prometheus Metrics<br/>8086/TCP<br/>HTTP<br/>No encryption<br/>Auth: None"]

        MMeshSocket["ModelMesh Sidecar Interface<br/>Unix socket: /tmp/mmesh/grpc.sock<br/>gRPC<br/>No encryption (pod-local)<br/>Auth: Unix socket permissions"]

        HealthProbe["caikit_health_probe<br/>Probes gRPC + HTTP<br/>TLS/mTLS aware<br/>verify=False workaround"]
    end

    subgraph Egress["EGRESS DESTINATIONS"]
        direction TB

        OTel["OpenTelemetry Collector<br/>4317/TCP (gRPC) or 4318/TCP (HTTP)<br/>OTLP<br/>Optional TLS/mTLS"]

        RemoteRuntime["Remote Caikit Runtime<br/>Configurable port<br/>gRPC or HTTPS<br/>Optional TLS/mTLS"]

        ModelStorage["Model Storage<br/>Filesystem / Mounted Volume<br/>File I/O<br/>Filesystem permissions"]
    end

    subgraph SidecarPod["SAME POD (ModelMesh)"]
        ModelMesh["ModelMesh Controller<br/>Model lifecycle management"]
    end

    %% Inbound flows
    Client -->|"HTTP 8080 or gRPC 8085<br/>Optional TLS 1.2+/mTLS<br/>Auth: None (platform-delegated)"| Ingress
    Ingress -->|"HTTP/8080<br/>Optional TLS"| HTTPServer
    Ingress -->|"gRPC/8085<br/>Optional TLS"| GRPCServer

    %% Pod-local flows
    ModelMesh -->|"gRPC<br/>Unix socket<br/>No encryption<br/>Pod-local only"| MMeshSocket
    HealthProbe -.->|"Probes"| HTTPServer
    HealthProbe -.->|"Probes"| GRPCServer

    %% Egress flows
    GRPCServer -->|"OTLP gRPC/4317<br/>or HTTP/4318<br/>Optional TLS/mTLS"| OTel
    GRPCServer -->|"gRPC or HTTPS<br/>Optional TLS/mTLS"| RemoteRuntime
    GRPCServer -->|"File I/O"| ModelStorage
    HTTPServer -->|"File I/O"| ModelStorage

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#dce6f1,stroke:#4472c4,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef sidecar fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef probe fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class Ingress platform
    class HTTPServer,GRPCServer,MetricsEndpoint,MMeshSocket runtime
    class OTel,RemoteRuntime,ModelStorage egress
    class ModelMesh sidecar
    class HealthProbe probe
