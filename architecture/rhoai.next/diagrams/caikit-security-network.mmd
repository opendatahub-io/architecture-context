graph TB
    subgraph External["EXTERNAL (Platform / Clients)"]
        Client["KServe / Platform Ingress<br/>Inference & Training Requests"]
        Kubelet["Kubernetes kubelet<br/>Liveness/Readiness Probes"]
        PromScraper["Prometheus<br/>Metrics Scraper"]
    end

    subgraph PodBoundary["KUBERNETES POD BOUNDARY"]
        direction TB

        subgraph CaikitProcess["CAIKIT RUNTIME PROCESS"]
            direction TB
            GRPCServer["gRPC Server<br/>8085/TCP<br/>gRPC/HTTP2<br/>TLS 1.2+ / mTLS / plaintext<br/>Auth: Client cert (configurable)"]
            HTTPServer["HTTP Server (FastAPI)<br/>8080/TCP<br/>HTTP/HTTPS<br/>TLS 1.2+ / mTLS / plaintext<br/>Auth: Client cert (configurable)"]
            MetricsServer["Metrics Server<br/>8086/TCP<br/>HTTP plaintext<br/>Auth: None"]
            UDS["Unix Domain Socket<br/>unix:///tmp/mmesh/grpc.sock<br/>gRPC plaintext<br/>Auth: None (pod-local)"]
        end

        subgraph ModelMeshSidecar["MODELMESH SIDECAR"]
            MMController["ModelMesh Controller<br/>ModelRuntime API<br/>loadModel/unloadModel"]
        end

        subgraph ProbeContainer["HEALTH PROBE"]
            HealthProbe["caikit-health-probe<br/>Exec probe binary"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM credentials"]
        OTELCollector["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS/mTLS/plaintext<br/>Auth: None or mTLS certs"]
        RemoteCaikit["Remote Caikit Runtime<br/>8085/8080/TCP<br/>gRPC or HTTP<br/>TLS/mTLS<br/>Auth: Bearer Token"]
    end

    %% Inbound flows
    Client -->|"gRPC/8085 or HTTP/8080<br/>TLS 1.2+ / mTLS<br/>Client cert (configurable)"| GRPCServer
    Client -->|"HTTP/8080<br/>TLS 1.2+ / mTLS<br/>Client cert (configurable)"| HTTPServer
    Kubelet -->|"exec probe"| HealthProbe
    PromScraper -->|"HTTP/8086<br/>plaintext<br/>No auth"| MetricsServer

    %% Pod-internal flows
    HealthProbe -->|"HTTP /health<br/>8080/TCP<br/>TLS (matches config)"| HTTPServer
    HealthProbe -->|"gRPC Health<br/>8085/TCP<br/>TLS (matches config)"| GRPCServer
    MMController -->|"gRPC ModelRuntime<br/>unix socket<br/>plaintext, pod-local"| UDS

    %% Egress flows
    CaikitProcess -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    CaikitProcess -->|"gRPC/4317 or HTTP/4318<br/>TLS/mTLS (configurable)"| OTELCollector
    CaikitProcess -->|"gRPC/8085 or HTTP/8080<br/>TLS/mTLS<br/>Bearer Token"| RemoteCaikit

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef probe fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,Kubelet,PromScraper external
    class GRPCServer,HTTPServer,MetricsServer,UDS runtime
    class MMController sidecar
    class HealthProbe probe
    class S3,OTELCollector,RemoteCaikit egress
