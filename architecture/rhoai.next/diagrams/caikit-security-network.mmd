graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Platform["PLATFORM LAYER (KServe / Istio)"]
        Gateway["KServe / Istio Gateway<br/>443/TCP<br/>TLS 1.2+<br/>Platform AuthN/AuthZ"]
    end

    subgraph CaikitPod["CAIKIT RUNTIME POD"]
        direction TB

        subgraph Servers["Network Listeners"]
            GRPCServer["gRPC Server<br/>runtime.grpc.port/TCP<br/>gRPC/HTTP2<br/>Configurable: TLS/mTLS/plaintext"]
            HTTPServer["HTTP Server (FastAPI)<br/>runtime.http.port/TCP<br/>HTTP/1.1 + SSE<br/>Configurable: TLS/mTLS/plaintext"]
            MetricsServer["Metrics Server<br/>runtime.metrics.port/TCP<br/>HTTP plaintext"]
        end

        subgraph Sidecar["ModelMesh Sidecar Interface"]
            ModelRuntime["ModelRuntime gRPC<br/>Unix socket (preferred)<br/>No encryption (local)"]
        end

        subgraph Processing["Processing Layer"]
            Servicers["GlobalPredictServicer<br/>GlobalTrainServicer<br/>ModelManager"]
        end

        GRPCServer --> Servicers
        HTTPServer --> Servicers
        ModelRuntime --> Servicers
    end

    subgraph PodLocal["POD-LOCAL"]
        ModelMesh["ModelMesh Controller<br/>Unix socket<br/>gRPC ModelRuntime protocol"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HMAC / IAM Auth"]
        OTel["OTel Collector<br/>configurable/TCP<br/>gRPC or HTTP (OTLP)<br/>Configurable TLS/mTLS"]
        RemoteCaikit["Remote Caikit Runtime<br/>configurable/TCP<br/>gRPC or HTTP<br/>Configurable TLS/mTLS/Bearer"]
    end

    subgraph Monitoring["MONITORING (Inbound)"]
        Prometheus["Prometheus<br/>HTTP scrape<br/>plaintext"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| Gateway
    Gateway -->|"gRPC or HTTP<br/>Configurable TLS/mTLS<br/>Client cert (optional)"| GRPCServer
    Gateway -->|"HTTP/HTTPS<br/>Configurable TLS/mTLS<br/>Client cert (optional)"| HTTPServer

    ModelMesh -->|"gRPC (Unix socket)<br/>No encryption<br/>Pod-local only"| ModelRuntime

    Servicers -->|"HTTPS/443<br/>TLS 1.2+<br/>HMAC/IAM"| S3
    Servicers -->|"gRPC or HTTP<br/>Configurable TLS/mTLS"| OTel
    Servicers -->|"gRPC or HTTP<br/>TLS/mTLS/Bearer"| RemoteCaikit

    Prometheus -->|"HTTP scrape<br/>plaintext<br/>No auth"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef caikitpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef podlocal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway platform
    class GRPCServer,HTTPServer,MetricsServer,ModelRuntime,Servicers caikitpod
    class ModelMesh podlocal
    class S3,OTel,RemoteCaikit externalservice
    class Prometheus monitoring
