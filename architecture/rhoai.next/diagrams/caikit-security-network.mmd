graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph CaikitPod["CAIKIT RUNTIME (In-Pod)"]
        direction TB

        subgraph Servers["Network Servers"]
            HTTPServer["HTTP Server (FastAPI/Uvicorn)<br/>8080/TCP<br/>HTTP/HTTPS<br/>None/TLS/mTLS (configurable)"]
            GRPCServer["gRPC Server<br/>8085/TCP<br/>gRPC (HTTP/2)<br/>None/TLS/mTLS (configurable)"]
            MetricsServer["Prometheus Metrics<br/>8086/TCP<br/>HTTP<br/>No encryption"]
        end

        subgraph Internal["Internal Processing"]
            Servicers["Servicers<br/>(Predict, Train, Manage)"]
            ModelManager["Model Manager"]
            Modules["AI Modules<br/>(in-process)"]
        end

        HealthProbe["caikit_health_probe<br/>Standalone binary<br/>psutil + health checks"]
    end

    subgraph PodLocal["POD-LOCAL"]
        ModelMesh["Model Mesh Controller<br/>Unix socket<br/>/tmp/mmesh/grpc.sock<br/>gRPC (no encryption)"]
    end

    subgraph EgressServices["EGRESS (External Services)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Configurable TLS/mTLS"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS, AWS IAM"]
        RemoteCaikit["Remote Caikit Servers<br/>Configurable port<br/>gRPC/HTTP, TLS/mTLS"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrape 8086/TCP<br/>HTTP, No encryption"]
    end

    %% External flows
    Client -->|"HTTP 8080/TCP<br/>Configurable: None/TLS/mTLS<br/>Auth: Platform-level"| HTTPServer
    Client -->|"gRPC 8085/TCP<br/>Configurable: None/TLS/mTLS<br/>Auth: Platform-level"| GRPCServer

    %% Internal flows
    HTTPServer --> Servicers
    GRPCServer --> Servicers
    Servicers --> ModelManager
    ModelManager --> Modules

    %% Health probe
    HealthProbe -->|"HTTP /health<br/>Matches server TLS"| HTTPServer
    HealthProbe -->|"gRPC Health.Check()<br/>Matches server TLS"| GRPCServer

    %% Pod-local
    ModelMesh -->|"Unix socket<br/>gRPC, No encryption<br/>loadModel/unloadModel"| GRPCServer

    %% Egress
    Servicers -.->|"OTLP 4317/4318 TCP<br/>Configurable TLS"| OTEL
    Servicers -.->|"HTTPS 443/TCP<br/>TLS, AWS IAM"| S3
    Servicers -.->|"gRPC/HTTP<br/>Configurable TLS/mTLS"| RemoteCaikit

    %% Monitoring
    Prometheus -->|"HTTP 8086/TCP<br/>No encryption"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef server fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef podlocal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef probe fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Client external
    class HTTPServer,GRPCServer,MetricsServer server
    class Servicers,ModelManager,Modules internal
    class ModelMesh podlocal
    class OTEL,S3,RemoteCaikit egress
    class Prometheus monitoring
    class HealthProbe probe
