graph LR
    LMES["lm-evaluation-harness<br/>(Batch Job)"]

    %% Internal RHOAI Platform Dependencies
    LMES -->|"REST callbacks<br/>status + results"| EvalHub["EvalHub Service"]
    LMES -->|"POST /v1/completions<br/>OpenAI-compatible API"| ModelInference["Model Inference<br/>Endpoint"]
    LMES -->|"OCI artifact push"| OCIRegistry["OCI Registry"]
    LMES -->|"REST API<br/>metrics logging"| MLflow["MLflow Tracking<br/>Server"]

    %% Operator dependency (creates the job)
    TrustyAI["trustyai-service-<br/>operator"] -->|"creates Job<br/>from LMEvalJob CRD"| LMES

    %% External Service Dependencies
    LMES -->|"datasets +<br/>tokenizers"| HFHub["HuggingFace Hub"]
    LMES -.->|"offline data cache<br/>(init container)"| S3["S3/COS<br/>Object Storage"]
    LMES -.->|"optional<br/>experiment tracking"| WandB["W&B"]

    %% Key Python Dependencies
    subgraph PythonDeps["Key Python Dependencies"]
        direction TB
        PyTorch["PyTorch 2.6.0"]
        Transformers["transformers 4.48.0"]
        EvalHubSDK["eval-hub-sdk 0.1.5"]
        Datasets["datasets 3.1.0"]
        Unitxt["unitxt 1.17.2"]
        Accelerate["accelerate 1.0.1"]
        Boto3["boto3 1.42.12"]
        Aiohttp["aiohttp 3.13.3"]
        OLOT["olot 0.1.15"]
    end

    LMES -->|"runtime deps"| PythonDeps

    %% Build/Infrastructure
    subgraph BuildInfra["Build Infrastructure"]
        direction TB
        UBI9["UBI 9 Python 3.11<br/>(base image)"]
        Skopeo["skopeo<br/>(image inspection)"]
    end

    LMES -->|"container base"| BuildInfra

    %% Styling
    style LMES fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style ModelInference fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style WandB fill:#f5a623,stroke:#333,color:#fff
    style PythonDeps fill:#fff2cc,stroke:#d6b656
    style BuildInfra fill:#e8e8e8,stroke:#999
