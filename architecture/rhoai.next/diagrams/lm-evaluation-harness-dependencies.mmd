graph LR
    LMES["lm-evaluation-harness<br/>(lmes-job)"]

    %% Internal RHOAI Dependencies
    LMES -->|"job lifecycle<br/>status callbacks"| EvalHub["EvalHub Service"]
    LMES -->|"created by operator<br/>via LMEvalJob CRD"| TrustyAI["trustyai-service-<br/>operator"]

    %% Model Inference
    LMES -->|"POST /v1/completions<br/>Bearer Token"| ModelInference["Model Inference<br/>Endpoint<br/>(vLLM / TGI)"]

    %% External Service Dependencies
    LMES -->|"OCI artifact push"| OCIRegistry["OCI Registry"]
    LMES -->|"metrics logging"| MLflow["MLflow Tracking<br/>Server"]
    LMES -->|"datasets &<br/>tokenizers"| HFHub["HuggingFace Hub"]
    LMES -->|"offline data cache"| S3["S3/COS<br/>Object Storage"]
    LMES -.->|"optional tracking"| WandB["Weights & Biases"]

    %% Python Library Dependencies
    LMES -->|"eval framework"| LMEval["lm_eval v0.4.8"]
    LMES -->|"job lifecycle SDK"| EvalHubSDK["eval-hub-sdk 0.1.5"]
    LMES -->|"tensor compute"| PyTorch["PyTorch 2.6.0"]
    LMES -->|"tokenizers & models"| Transformers["transformers 4.48.0"]
    LMES -->|"datasets"| Datasets["datasets 3.1.0"]
    LMES -->|"data preparation"| Unitxt["unitxt 1.17.2"]
    LMES -->|"S3 access"| Boto3["boto3 1.42.12"]
    LMES -->|"OCI transport"| Olot["olot 0.1.15"]
    LMES -->|"async HTTP"| Aiohttp["aiohttp 3.13.3"]

    %% Platform Dependencies
    LMES -->|"container runtime"| Python["Python 3.11"]
    LMES -->|"base image"| UBI9["UBI 9<br/>(OpenSSL/FIPS)"]
    LMES -->|"image inspection"| Skopeo["skopeo"]

    %% Styling
    style LMES fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style ModelInference fill:#7ed321,stroke:#333,color:#fff

    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style MLflow fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style WandB fill:#f5a623,stroke:#333,color:#fff

    style LMEval fill:#e8e8e8,stroke:#333
    style EvalHubSDK fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style Datasets fill:#e8e8e8,stroke:#333
    style Unitxt fill:#e8e8e8,stroke:#333
    style Boto3 fill:#e8e8e8,stroke:#333
    style Olot fill:#e8e8e8,stroke:#333
    style Aiohttp fill:#e8e8e8,stroke:#333

