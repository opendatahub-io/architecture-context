graph LR
    LMEval["LMEval Job<br/>(Batch Container)"]

    %% Internal RHOAI Dependencies
    LMEval -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    LMEval -->|"evaluation prompts<br/>HTTP(S)"| Inference["Inference Endpoint<br/>(vLLM / TGI)"]
    LMEval -->|"result artifacts<br/>HTTPS/443"| OCI["OCI Registry<br/>(Quay)"]
    LMEval -->|"metrics export<br/>HTTP(S)"| MLflow["MLflow Tracking<br/>Server"]

    %% Operator dependency
    Operator["TrustyAI LMEval<br/>Operator"] -->|"creates K8s Job<br/>(LMEvalJob CR)"| LMEval

    %% External Service Dependencies
    LMEval -->|"datasets & tokenizers<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LMEval -->|"offline test data<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]

    %% Core Python Dependencies
    subgraph CoreDeps["Core Python Libraries"]
        direction TB
        Python["Python 3.11"]
        PyTorch["PyTorch 2.6.0"]
        Transformers["transformers 4.48.0"]
        Accelerate["accelerate 1.0.1"]
        Datasets["datasets 3.1.0"]
        EvalHubSDK["eval-hub-sdk 0.1.5"]
        Unitxt["unitxt 1.17.2"]
    end

    subgraph MetricsDeps["Evaluation Metrics Libraries"]
        direction TB
        SacreBLEU["sacrebleu 2.4.3"]
        RougeScore["rouge-score 0.1.2"]
        Sklearn["scikit-learn 1.5.2"]
        Jiwer["jiwer 3.0.5"]
        MathVerify["math-verify 0.9.0"]
        NLTK["nltk 3.9.3"]
    end

    subgraph InfraDeps["Infrastructure Tools"]
        direction TB
        Boto3["boto3 1.42.12"]
        Olot["olot 0.1.15"]
        Skopeo["skopeo (system)"]
        Peft["peft 0.13.2"]
    end

    LMEval -.->|"runtime"| CoreDeps
    LMEval -.->|"metrics"| MetricsDeps
    LMEval -.->|"infra"| InfraDeps

    %% Integration Points (incoming)
    LMEval -.->|"K8s API"| K8sAPI["Kubernetes API"]

