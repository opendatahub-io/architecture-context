graph LR
    LMEval["LM Evaluation Harness<br/>(lmes-job)"]

    %% Internal RHOAI Dependencies
    LMEval -->|"job orchestration<br/>status callbacks"| EvalHub["EvalHub Service"]
    LMEval -->|"job creation<br/>lifecycle mgmt"| LMEvalOperator["TrustyAI LMEval Operator<br/>(trustyai-service-operator)"]
    LMEval -.->|"metrics logging<br/>(optional)"| MLflow["MLflow Tracking"]

    %% Core Python Dependencies
    subgraph "Core Python Dependencies"
        EvalHubSDK["eval-hub-sdk 0.1.7<br/>Adapter framework"]
        Torch["torch 2.6.0<br/>Tensor operations"]
        Transformers["transformers 4.48.0<br/>Tokenizer loading"]
        Accelerate["accelerate 1.0.1<br/>Device management"]
        Datasets["datasets 3.1.0<br/>Dataset loading"]
        Unitxt["unitxt 1.17.2<br/>Modular evaluation"]
        Evaluate["evaluate 0.4.3<br/>Metric computation"]
        PEFT["peft 0.13.2<br/>LoRA adapter support"]
    end

    LMEval -->|"adapter interface"| EvalHubSDK
    LMEval -->|"ML runtime"| Torch
    LMEval -->|"tokenization"| Transformers
    LMEval -->|"device mgmt"| Accelerate
    LMEval -->|"benchmark data"| Datasets
    LMEval -->|"eval framework"| Unitxt
    LMEval -->|"metrics"| Evaluate
    LMEval -->|"LoRA support"| PEFT

    %% Evaluation Metrics Dependencies
    subgraph "Evaluation Metrics"
        ScikitLearn["scikit-learn 1.5.2"]
        SacreBLEU["sacrebleu 2.4.3"]
        RougeScore["rouge-score 0.1.2"]
        Jiwer["jiwer 3.0.5"]
    end

    LMEval -->|"ML metrics"| ScikitLearn
    LMEval -->|"translation metrics"| SacreBLEU
    LMEval -->|"summarization metrics"| RougeScore
    LMEval -->|"WER metrics"| Jiwer

    %% Infrastructure Dependencies
    subgraph "Infrastructure Tools"
        Boto3["boto3 1.42.12<br/>S3 client"]
        Olot["olot 0.1.15<br/>OCI Layout Tool"]
        Skopeo["skopeo (system)<br/>OCI transfer"]
    end

    LMEval -->|"S3 storage"| Boto3
    LMEval -->|"OCI artifacts"| Olot
    LMEval -->|"artifact push"| Skopeo

    %% External Services
    LMEval -->|"POST /v1/completions<br/>HTTPS/443"| ModelEndpoint["Model Inference Endpoint<br/>(vLLM, TGI, etc.)"]
    LMEval -->|"OCI push<br/>HTTPS/443"| OCIRegistry["OCI Registry"]
    LMEval -.->|"datasets & tokenizers<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    LMEval -.->|"optional backend"| WatsonX["IBM watsonx.ai 1.4.11"]

    %% Integration Points (other components that interact)
    Dashboard["ODH Dashboard"] -.->|"UI management"| LMEvalOperator

