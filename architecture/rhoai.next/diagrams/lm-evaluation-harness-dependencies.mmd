graph LR
    LMEval["LMEval Harness<br/>(Batch Job)"]

    %% Internal RHOAI Dependencies
    LMEval -->|"container image<br/>consumed by"| TrustyAI["TrustyAI Operator<br/>(LMEvalJob Controller)"]
    LMEval -->|"status callbacks<br/>REST API"| EvalHub["EvalHub Service"]
    LMEval -->|"experiment runs<br/>REST API"| MLflow["MLflow"]

    %% External Service Dependencies
    LMEval -->|"POST /v1/completions<br/>OpenAI-compatible"| ModelEndpoint["Model Inference<br/>Endpoint"]
    LMEval -->|"tokenizers &<br/>datasets"| HFHub["HuggingFace Hub"]
    LMEval -->|"OCI push<br/>via skopeo"| OCIRegistry["OCI Registry<br/>(Quay.io)"]
    LMEval -.->|"offline assets<br/>S3 API"| S3["S3-compatible<br/>Storage"]

    %% Key Library Dependencies
    subgraph "Python Dependencies"
        direction TB
        PyTorch["PyTorch 2.6.0"]
        Transformers["Transformers 4.48.0"]
        Datasets["Datasets 3.1.0"]
        EvalHubSDK["eval-hub-sdk 0.1.7"]
        Unitxt["Unitxt 1.17.2"]
        Boto3["boto3 1.42.12"]
        Olot["olot 0.1.15"]
        Aiohttp["aiohttp 3.13.3"]
    end

    LMEval -->|"tensor ops"| PyTorch
    LMEval -->|"tokenizers"| Transformers
    LMEval -->|"benchmark data"| Datasets
    LMEval -->|"adapter framework"| EvalHubSDK
    LMEval -->|"custom tasks"| Unitxt
    LMEval -->|"S3 client"| Boto3
    LMEval -->|"OCI layout"| Olot
    LMEval -->|"async HTTP"| Aiohttp

    %% System Dependencies
    LMEval -->|"OCI transport"| Skopeo["skopeo (system)"]
    LMEval -->|"runtime"| Python["Python 3.11"]

    %% Reverse dependencies (components that depend on LMEval)
    Dashboard["ODH Dashboard"] -.->|"UI for LMEvalJob"| TrustyAI

