graph LR
    LMES["lm-evaluation-harness<br/>(Batch Job)"]

    %% Internal RHOAI Dependencies
    LMES -->|"created by<br/>(Kubernetes Job)"| TrustyAI["trustyai-service-operator<br/>(manages LMEvalJob CRD)"]
    LMES -->|"REST callbacks<br/>status & results"| EvalHub["EvalHub Service"]
    LMES -->|"POST /v1/completions<br/>(OpenAI-compatible)"| ModelEndpoint["Model Inference<br/>Endpoint<br/>(vLLM / TGI)"]
    LMES -->|"push artifacts"| OCIRegistry["OCI Registry"]
    LMES -->|"log metrics"| MLflow["MLflow Tracking<br/>Server"]

    %% External Dependencies
    LMES -->|"download datasets<br/>& tokenizers"| HFHub["HuggingFace Hub"]
    LMES -->|"offline data<br/>caches"| S3["S3 / COS<br/>Object Storage"]
    LMES -.->|"experiment<br/>tracking"| WandB["Weights & Biases<br/>(optional)"]

    %% Key Library Dependencies
    subgraph "Key Python Dependencies"
        PyTorch["PyTorch 2.6.0"]
        Transformers["transformers 4.48.0"]
        EvalHubSDK["eval-hub-sdk 0.1.5"]
        Unitxt["unitxt 1.17.2"]
        Accelerate["accelerate 1.0.1"]
        Datasets["datasets 3.1.0"]
        Aiohttp["aiohttp 3.13.3"]
        Boto3["boto3 1.42.12"]
        OLOT["olot 0.1.15<br/>(OCI Layout Transport)"]
    end

    LMES -->|"tensor computation"| PyTorch
    LMES -->|"tokenizer & model support"| Transformers
    LMES -->|"job lifecycle adapter"| EvalHubSDK
    LMES -->|"dynamic task definitions"| Unitxt
    LMES -->|"distributed inference"| Accelerate
    LMES -->|"dataset loading"| Datasets
    LMES -->|"async HTTP client"| Aiohttp
    LMES -->|"S3 API client"| Boto3
    LMES -->|"OCI artifact push"| OLOT

    %% Base Image
    LMES -->|"base image"| UBI9["UBI 9<br/>python-311:latest<br/>(OpenSSL / FIPS)"]

    %% Build Tool
    LMES -->|"container inspection"| Skopeo["skopeo"]

