graph TB
    subgraph External["External Access"]
        Browser["Browser<br/>(Data Scientist / Admin)"]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["Gateway API<br/>(data-science-gateway)<br/>443/TCP HTTPS"]
    end

    subgraph DashboardPod["ODH Dashboard Pod (2 replicas)"]
        direction TB

        subgraph HostApp["Host Application"]
            KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift RBAC Auth"]
            Fastify["Fastify Backend<br/>8080/TCP HTTP<br/>API Gateway + Static Assets"]
            ReactFE["React Frontend<br/>(PatternFly 6 + MF Host)"]
            KubeRBACProxy -->|"auth headers<br/>x-forwarded-access-token"| Fastify
            Fastify -->|"serves"| ReactFE
        end

        subgraph BFFSidecars["BFF Sidecar Containers (Go + React Remotes)"]
            MR_BFF["Model Registry BFF<br/>8043/TCP HTTPS"]
            GenAI_BFF["Gen AI BFF<br/>8143/TCP HTTPS"]
            MaaS_BFF["MaaS BFF<br/>8243/TCP HTTPS"]
            MLflow_BFF["MLflow BFF<br/>8343/TCP HTTPS"]
            EvalHub_BFF["Eval Hub BFF<br/>8543/TCP HTTPS"]
            AutoML_BFF["AutoML BFF<br/>8643/TCP HTTPS"]
            AutoRAG_BFF["AutoRAG BFF<br/>8743/TCP HTTPS"]
        end

        Fastify -->|"/_mf/model-registry/*<br/>HTTPS"| MR_BFF
        Fastify -->|"/_mf/gen-ai/*<br/>HTTPS"| GenAI_BFF
        Fastify -->|"/_mf/maas/*<br/>HTTPS"| MaaS_BFF
        Fastify -->|"/_mf/mlflow/*<br/>HTTPS"| MLflow_BFF
        Fastify -->|"/_mf/eval-hub/*<br/>HTTPS"| EvalHub_BFF
        Fastify -->|"/_mf/automl/*<br/>HTTPS"| AutoML_BFF
        Fastify -->|"/_mf/autorag/*<br/>HTTPS"| AutoRAG_BFF
        GenAI_BFF -->|"inter-BFF<br/>token delegation"| MaaS_BFF
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhDashboardConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApplication["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDocument["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQuickStart["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph PlatformServices["Platform Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        ThanosQuerier["Thanos Querier<br/>9092/TCP"]
        Perses["Data Science Perses<br/>8080/TCP"]
    end

    subgraph UpstreamServices["Upstream Domain Services"]
        ModelRegistry["Model Registry"]
        ModelCatalog["Model Catalog"]
        LlamaStack["LlamaStack API"]
        MaaSAPI["MaaS API"]
        MLflowServer["MLflow Tracking Server"]
        NeMo["NeMo Guardrails"]
        PipelineServer["Pipeline Server (DSPA)"]
        EvalHubSvc["EvalHub (TrustyAI)"]
        S3["S3/MinIO Storage"]
        MCPServers["MCP Servers"]
    end

    %% External flows
    Browser -->|"HTTPS/443"| Gateway
    Gateway -->|"HTTPS/8443"| KubeRBACProxy

    %% Host to platform
    Fastify -->|"HTTPS/6443"| K8sAPI
    Fastify -->|"HTTPS/9092"| ThanosQuerier
    Fastify -->|"HTTP/8080"| Perses

    %% CRD interactions
    Fastify -->|"watches/CRUD"| OdhDashboardConfig
    Fastify -->|"reads"| OdhApplication
    KubeRBACProxy -->|"SubjectAccessReview"| K8sAPI

    %% BFF to upstream
    MR_BFF -->|"REST API"| ModelRegistry
    MR_BFF -->|"REST API"| ModelCatalog
    GenAI_BFF -->|"HTTPS"| LlamaStack
    GenAI_BFF -->|"HTTPS"| MaaSAPI
    GenAI_BFF -->|"HTTPS"| NeMo
    GenAI_BFF -->|"HTTP"| MCPServers
    MaaS_BFF -->|"HTTPS"| MaaSAPI
    MLflow_BFF -->|"REST API"| MLflowServer
    EvalHub_BFF -->|"HTTPS"| EvalHubSvc
    AutoML_BFF -->|"HTTPS"| PipelineServer
    AutoML_BFF -->|"HTTPS"| S3
    AutoRAG_BFF -->|"HTTPS"| PipelineServer
    AutoRAG_BFF -->|"HTTPS"| S3
    AutoRAG_BFF -->|"HTTPS"| LlamaStack

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef host fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef bff fill:#7ed321,stroke:#333,stroke-width:1px
    classDef crd fill:#f5a623,stroke:#333,stroke-width:1px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef upstream fill:#e8e8e8,stroke:#999,stroke-width:1px

    class Browser external
    class Gateway gateway
    class KubeRBACProxy,Fastify,ReactFE host
    class MR_BFF,GenAI_BFF,MaaS_BFF,MLflow_BFF,EvalHub_BFF,AutoML_BFF,AutoRAG_BFF bff
    class OdhDashboardConfig,OdhApplication,OdhDocument,OdhQuickStart crd
    class K8sAPI,ThanosQuerier,Perses platform
    class ModelRegistry,ModelCatalog,LlamaStack,MaaSAPI,MLflowServer,NeMo,PipelineServer,EvalHubSvc,S3,MCPServers upstream
