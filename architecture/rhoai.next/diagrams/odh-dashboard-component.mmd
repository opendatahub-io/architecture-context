graph TB
    Browser["Browser<br/>(React SPA)"]

    subgraph Gateway["INGRESS · Gateway API (openshift-ingress)"]
        HTTPRoute["HTTPRoute<br/>443/TCP HTTPS<br/>TLS termination"]
    end

    subgraph DashboardPod["ODH Dashboard Pod (2 replicas)"]
        direction TB

        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift RBAC Auth<br/>(SubjectAccessReview)"]

        subgraph Host["Host Application (Node.js 22)"]
            ReactFE["React Frontend<br/>(Module Federation Host)<br/>PatternFly 6 · Webpack 5"]
            FastifyBE["Fastify Backend<br/>8080/TCP HTTP<br/>API Gateway · K8s Proxy<br/>WebSocket Watch Streams"]
            ReactFE -->|"API calls"| FastifyBE
        end

        subgraph BFFs["BFF Sidecar Containers (Go 1.25 · TLS 1.3)"]
            direction TB
            MRBFF["Model Registry BFF<br/>8043/TCP HTTPS<br/>Model CRUD · Catalog · Transfer Jobs"]
            GenAIBFF["Gen AI BFF<br/>8143/TCP HTTPS<br/>LlamaStack · NeMo · MCP · Prompts"]
            MaaSBFF["MaaS BFF<br/>8243/TCP HTTPS<br/>Subscriptions · API Keys · Policies"]
            MLflowBFF["MLflow BFF<br/>8343/TCP HTTPS<br/>Experiments · Auto-Discovery"]
            EvalHubBFF["Eval Hub BFF<br/>8543/TCP HTTPS<br/>Evaluation Jobs · Collections"]
            AutoMLBFF["AutoML BFF<br/>8643/TCP HTTPS<br/>Tabular/TimeSeries Pipelines"]
            AutoRAGBFF["AutoRAG BFF<br/>8743/TCP HTTPS<br/>RAG Pipelines · Vector Stores"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhDashboardConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApplication["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDocument["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQuickStart["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph UpstreamServices["Upstream Platform Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        ModelRegistry["Model Registry<br/>REST API"]
        LlamaStack["LlamaStack<br/>REST API"]
        MaaSAPI["MaaS API<br/>HTTPS"]
        MLflowServer["MLflow Tracking<br/>REST API"]
        PipelineServer["Pipeline Server<br/>(DSPA)"]
        EvalHubSvc["EvalHub<br/>(TrustyAI)"]
        ThanosQuerier["Thanos Querier<br/>9092/TCP"]
        S3["S3/MinIO<br/>443/TCP"]
        NeMo["NeMo Guardrails"]
    end

    %% External flow
    Browser -->|"HTTPS/443"| HTTPRoute
    HTTPRoute -->|"HTTPS/8443"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8080<br/>x-forwarded-access-token<br/>x-auth-request-user"| FastifyBE

    %% Host to BFF routing (Module Federation Proxy)
    FastifyBE -->|"HTTPS/8043<br/>/_mf/model-registry/*"| MRBFF
    FastifyBE -->|"HTTPS/8143<br/>/_mf/gen-ai/*"| GenAIBFF
    FastifyBE -->|"HTTPS/8243<br/>/_mf/maas/*"| MaaSBFF
    FastifyBE -->|"HTTPS/8343<br/>/_mf/mlflow/*"| MLflowBFF
    FastifyBE -->|"HTTPS/8543<br/>/_mf/eval-hub/*"| EvalHubBFF
    FastifyBE -->|"HTTPS/8643<br/>/_mf/automl/*"| AutoMLBFF
    FastifyBE -->|"HTTPS/8743<br/>/_mf/autorag/*"| AutoRAGBFF

    %% Inter-BFF communication
    GenAIBFF -.->|"HTTPS/8243<br/>inter-BFF token delegation"| MaaSBFF

    %% Host upstream connections
    FastifyBE -->|"HTTPS/6443"| K8sAPI
    FastifyBE -->|"HTTPS/9092"| ThanosQuerier
    KubeRBACProxy -->|"HTTPS/6443<br/>SubjectAccessReview"| K8sAPI

    %% BFF upstream connections
    MRBFF -->|"REST API"| ModelRegistry
    GenAIBFF -->|"REST API"| LlamaStack
    GenAIBFF -->|"REST API"| NeMo
    MaaSBFF -->|"REST API"| MaaSAPI
    MLflowBFF -->|"REST API"| MLflowServer
    AutoMLBFF -->|"REST API"| PipelineServer
    AutoMLBFF -->|"HTTPS/443"| S3
    AutoRAGBFF -->|"REST API"| PipelineServer
    AutoRAGBFF -->|"REST API"| LlamaStack
    EvalHubBFF -->|"REST API"| EvalHubSvc

    %% CRD relationships
    FastifyBE -.->|"watches/CRUD"| OdhDashboardConfig
    FastifyBE -.->|"reads"| OdhApplication
    FastifyBE -.->|"reads"| OdhDocument
    FastifyBE -.->|"reads"| OdhQuickStart

