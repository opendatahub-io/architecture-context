graph TB
    subgraph External["External Access"]
        Browser[Browser / Client]
    end

    subgraph Gateway["Gateway API"]
        DSGateway["data-science-gateway<br/>HTTPRoute<br/>443/TCP HTTPS"]
    end

    subgraph DashboardPod["ODH Dashboard Pod"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP TLS<br/>OpenShift project list check"]
        end

        subgraph HostApp["Host Application"]
            Backend["Node.js Backend<br/>(Fastify)<br/>8080/TCP HTTP"]
            Frontend["React SPA<br/>(PatternFly 6)<br/>Module Federation Host"]
            Backend -->|serves| Frontend
        end

        subgraph BFFSidecars["BFF Sidecar Containers"]
            CoreBFF["core-bff<br/>Go BFF<br/>healthcheck"]
            GenAI["gen-ai BFF<br/>8143/TCP<br/>LlamaStack, Prompts,<br/>Vector Stores, MCP"]
            MaaS["maas BFF<br/>8243/TCP<br/>API Keys, Models,<br/>Subscriptions"]
            ModelReg["model-registry BFF<br/>8043/TCP<br/>Model Catalog"]
            MLflow["mlflow BFF<br/>8343/TCP<br/>Experiments, Runs"]
            EvalHub["eval-hub BFF<br/>8543/TCP<br/>TrustyAI Evals"]
            AutoML["automl BFF<br/>8643/TCP<br/>ML Pipelines"]
            AutoRAG["autorag BFF<br/>8743/TCP<br/>RAG Pipelines"]
            AgentOps["agent-ops BFF<br/>8843/TCP<br/>Agent Runtimes"]
        end

        subgraph PluginLibs["Shared Plugin Libraries"]
            PluginCore["plugin-core<br/>Extension Points,<br/>PluginStore"]
            AppConfig["app-config<br/>Module Federation,<br/>Feature Flags"]
            K8sCore["k8s-core<br/>K8s Types,<br/>API Helpers"]
        end
    end

    subgraph Operator["Dashboard Operator"]
        DashOp["dashboard-operator<br/>Go (controller-runtime)<br/>Reconciles Dashboard CR"]
    end

    subgraph K8sResources["Kubernetes Resources (CRDs)"]
        DashboardCR["Dashboard CR<br/>components.platform.opendatahub.io"]
        OdhApp["OdhApplication CR"]
        OdhConfig["OdhDashboardConfig CR"]
        OdhDoc["OdhDocument CR"]
        OdhQS["OdhQuickStart CR"]
    end

    %% External flow
    Browser -->|HTTPS/443| DSGateway
    DSGateway -->|HTTPS/8443| KubeRBACProxy
    KubeRBACProxy -->|HTTP/8080<br/>localhost| Backend

    %% Module Federation proxy
    Backend -->|"/_mf/gen-ai/*"| GenAI
    Backend -->|"/_mf/maas/*"| MaaS
    Backend -->|"/_mf/model-registry/*"| ModelReg
    Backend -->|"/_mf/mlflow/*"| MLflow
    Backend -->|"/_mf/eval-hub/*"| EvalHub
    Backend -->|"/_mf/automl/*"| AutoML
    Backend -->|"/_mf/autorag/*"| AutoRAG
    Backend -->|"/_mf/agent-ops/*"| AgentOps

    %% Inter-BFF
    GenAI -->|"HTTPS/8243<br/>token mgmt"| MaaS

    %% Operator
    DashOp -->|reconciles| DashboardCR
    DashOp -->|deploys| DashboardPod

    %% Plugin libs
    Frontend -.->|uses| PluginCore
    Frontend -.->|uses| AppConfig
    Frontend -.->|uses| K8sCore

    %% CRD watches
    Backend -->|watches| OdhApp
    Backend -->|watches| OdhConfig
    Backend -->|watches| OdhDoc
    Backend -->|watches| OdhQS

    %% Styles
    style KubeRBACProxy fill:#e74c3c,stroke:#333,color:#fff
    style Backend fill:#4a90e2,stroke:#333,color:#fff
    style Frontend fill:#4a90e2,stroke:#333,color:#fff
    style DashOp fill:#9b59b6,stroke:#333,color:#fff
    style GenAI fill:#27ae60,stroke:#333,color:#fff
    style MaaS fill:#27ae60,stroke:#333,color:#fff
