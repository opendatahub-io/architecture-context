graph TB
    subgraph External["External Access"]
        Browser[Browser / Client]
    end

    subgraph IngressLayer["Ingress Layer"]
        Route["OpenShift Route<br/>443/TCP HTTPS<br/>TLS Reencrypt"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    end

    subgraph Pod["odh-dashboard Pod"]
        direction TB

        subgraph AuthProxy["Authentication Boundary"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift RBAC Enforcement"]
        end

        subgraph CoreDashboard["Core Dashboard"]
            Frontend["odh-dashboard Frontend<br/>React SPA (TypeScript)<br/>Module Federation Host<br/>PatternFly 6 + Redux"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify BFF<br/>8080/TCP HTTP<br/>K8s API Proxy + WebSocket Relay"]
            Frontend -->|"serves SPA"| Backend
        end

        subgraph FederatedModules["Federated UI Modules (Sidecars)"]
            GenAI["gen-ai BFF<br/>Go + React<br/>8143/TCP HTTPS"]
            MaaS["maas BFF<br/>Go + React<br/>8243/TCP HTTPS"]
            AutoML["automl BFF<br/>Go + React<br/>8643/TCP HTTPS"]
            AutoRAG["autorag BFF<br/>Go + React<br/>8743/TCP HTTPS"]
            EvalHub["eval-hub BFF<br/>Go + React<br/>8543/TCP HTTPS"]
            MLflow["mlflow BFF<br/>Go + React<br/>8343/TCP HTTPS"]
            ModelReg["model-registry BFF<br/>Go + React<br/>8043/TCP HTTPS"]
        end

        KRBP -->|"x-forwarded-access-token"| Backend
        Backend -->|"/_mf/* proxy"| GenAI
        Backend -->|"/_mf/* proxy"| MaaS
        Backend -->|"/_mf/* proxy"| AutoML
        Backend -->|"/_mf/* proxy"| AutoRAG
        Backend -->|"/_mf/* proxy"| EvalHub
        Backend -->|"/_mf/* proxy"| MLflow
        Backend -->|"/_mf/* proxy"| ModelReg
        GenAI -->|"inter-BFF<br/>token issuance"| MaaS
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhDashboardConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApplication["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDocument["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQuickStart["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph PlatformServices["Platform Services"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS"]
    end

    subgraph MLServices["ML/AI Services"]
        DSPipelines["DS Pipeline API<br/>8443/TCP HTTPS"]
        ModelRegSvc["Model Registry<br/>8080/TCP HTTP"]
        TrustyAI["TrustyAI / EvalHub<br/>8080/TCP HTTP"]
        LlamaStack["LlamaStack<br/>8321/TCP HTTP"]
        MaaSAPI["MaaS API<br/>8443/TCP HTTPS"]
        MLflowSvc["MLflow Tracking<br/>5000/TCP HTTP"]
        KServe["KServe<br/>ServingRuntime CRDs"]
    end

    subgraph ExternalSvc["External Services"]
        S3["S3 Storage<br/>443/TCP HTTPS"]
    end

    %% External flows
    Browser -->|"HTTPS/443"| Route
    Browser -->|"HTTPS"| HTTPRoute
    Route -->|"TLS Reencrypt"| KRBP
    HTTPRoute -->|"TLS Passthrough"| KRBP

    %% OAuth flow
    Browser -.->|"OAuth2 redirect"| OAuth

    %% CRD watches
    Backend -->|"watches"| OdhDashboardConfig
    Backend -->|"watches"| OdhApplication
    Backend -->|"watches"| OdhDocument
    Backend -->|"watches"| OdhQuickStart

    %% Backend to services
    Backend -->|"REST + WebSocket"| K8sAPI
    Backend -->|"Prometheus queries"| Thanos
    Backend -->|"Pipeline proxy"| DSPipelines
    Backend -->|"Registry proxy"| ModelRegSvc
    Backend -->|"TrustyAI proxy"| TrustyAI
    Backend -->|"LlamaStack proxy"| LlamaStack

    %% BFF to services
    GenAI -->|"inference, RAG"| LlamaStack
    GenAI -->|"prompts"| MLflowSvc
    GenAI -->|"models"| MaaSAPI
    MaaS -->|"tiers, keys"| MaaSAPI
    AutoML -->|"pipeline runs"| DSPipelines
    AutoML -->|"data files"| S3
    AutoRAG -->|"RAG pipelines"| DSPipelines
    AutoRAG -->|"models, vectors"| LlamaStack
    AutoRAG -->|"data files"| S3
    EvalHub -->|"eval jobs"| TrustyAI
    MLflow -->|"experiments"| MLflowSvc
    ModelReg -->|"model CRUD"| ModelRegSvc

    %% Styling
    classDef authProxy fill:#e74c3c,stroke:#c0392b,stroke-width:3px,color:#fff
    classDef core fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    classDef federated fill:#2ecc71,stroke:#27ae60,stroke-width:2px,color:#fff
    classDef crd fill:#f39c12,stroke:#e67e22,stroke-width:2px,color:#fff
    classDef platform fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px,color:#fff
    classDef mlservice fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    classDef external fill:#1abc9c,stroke:#16a085,stroke-width:2px,color:#fff
    classDef ingress fill:#e67e22,stroke:#d35400,stroke-width:2px,color:#fff

    class KRBP authProxy
    class Frontend,Backend core
    class GenAI,MaaS,AutoML,AutoRAG,EvalHub,MLflow,ModelReg federated
    class OdhDashboardConfig,OdhApplication,OdhDocument,OdhQuickStart crd
    class K8sAPI,OAuth,Thanos platform
    class DSPipelines,ModelRegSvc,TrustyAI,LlamaStack,MaaSAPI,MLflowSvc,KServe mlservice
    class S3 external
    class Route,HTTPRoute ingress
