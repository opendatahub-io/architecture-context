graph TB
    subgraph External["External Access"]
        Browser["Browser<br/>(Data Scientist / Admin)"]
    end

    subgraph Gateway["OpenShift Ingress"]
        HTTPRoute["HTTPRoute<br/>443/TCP HTTPS"]
    end

    subgraph DashboardPod["ODH Dashboard Pod"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift RBAC enforcement"]
        end

        subgraph HostApp["Host Application"]
            Frontend["React Frontend<br/>(PatternFly 6, Module Federation)<br/>Static Assets"]
            Backend["Node.js Fastify Backend<br/>8080/TCP HTTP<br/>K8s API proxy, WebSocket, routing"]
            Frontend -->|"served by"| Backend
        end

        subgraph FederatedModules["Federated Module BFF Sidecars"]
            direction LR
            ModelRegBFF["model-registry BFF<br/>8043/TCP"]
            GenAiBFF["gen-ai BFF<br/>8143/TCP"]
            MaasBFF["maas BFF<br/>8243/TCP"]
            MlflowBFF["mlflow BFF<br/>8343/TCP"]
            EvalHubBFF["eval-hub BFF<br/>8543/TCP"]
            AutomlBFF["automl BFF<br/>8643/TCP"]
            AutoragBFF["autorag BFF<br/>8743/TCP"]
            AgentOpsBFF["agent-ops BFF<br/>8843/TCP"]
        end

        KRBP -->|"X-Auth-Request-User/Groups<br/>HTTP 8080"| Backend
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| ModelRegBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| GenAiBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| MaasBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| MlflowBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| EvalHubBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| AutomlBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| AutoragBFF
        Backend -->|"x-forwarded-access-token<br/>HTTPS"| AgentOpsBFF
    end

    subgraph Operator["Dashboard Operator"]
        DashOp["dashboard-operator<br/>(controller-runtime)<br/>Manages Dashboard CR"]
    end

    subgraph CRDs["Custom Resources"]
        DashboardCR["Dashboard CR"]
        OdhDashConfig["OdhDashboardConfig"]
        OdhApp["OdhApplication"]
        OdhDoc["OdhDocument"]
    end

    Browser -->|"HTTPS 443"| HTTPRoute
    HTTPRoute -->|"HTTPS 8443"| KRBP
    KRBP -->|"SAR check"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    DashOp -->|"reconciles"| DashboardCR
    DashOp -->|"renders kustomize<br/>manages modules"| DashboardPod

    Backend -->|"REST/WebSocket<br/>HTTPS 6443"| K8sAPI
    Backend -->|"watches"| OdhDashConfig
    Backend -->|"reads"| OdhApp
    Backend -->|"reads"| OdhDoc

    %% Inter-BFF communication
    GenAiBFF -.->|"HTTPS 8243<br/>token forwarding"| MaasBFF

    %% Styling
    style KRBP fill:#e74c3c,stroke:#c0392b,color:#fff
    style Backend fill:#3498db,stroke:#2980b9,color:#fff
    style Frontend fill:#3498db,stroke:#2980b9,color:#fff
    style DashOp fill:#9b59b6,stroke:#8e44ad,color:#fff
    style ModelRegBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style GenAiBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style MaasBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style MlflowBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style EvalHubBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style AutomlBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style AutoragBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style AgentOpsBFF fill:#2ecc71,stroke:#27ae60,color:#fff
    style DashboardCR fill:#f39c12,stroke:#e67e22,color:#fff
    style OdhDashConfig fill:#f39c12,stroke:#e67e22,color:#fff
    style OdhApp fill:#f39c12,stroke:#e67e22,color:#fff
    style OdhDoc fill:#f39c12,stroke:#e67e22,color:#fff
    style K8sAPI fill:#95a5a6,stroke:#7f8c8d,color:#fff
    style Browser fill:#ecf0f1,stroke:#bdc3c7
    style HTTPRoute fill:#ecf0f1,stroke:#bdc3c7
