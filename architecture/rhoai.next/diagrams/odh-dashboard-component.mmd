graph TB
    subgraph Pod["ODH Dashboard Pod"]
        direction TB

        subgraph MainContainers["Core Containers"]
            KRBP["kube-rbac-proxy<br/>8443/TCP<br/>Auth Sidecar"]
            Backend["odh-dashboard Backend<br/>Node.js Fastify<br/>8080/TCP"]
            Frontend["odh-dashboard Frontend<br/>React 18 SPA<br/>Module Federation Host"]
        end

        subgraph BFFSidecars["BFF Sidecar Containers"]
            GenAI["gen-ai BFF<br/>Go HTTP<br/>8143/TCP"]
            MaaS["maas BFF<br/>Go HTTP<br/>8243/TCP"]
            ModelReg["model-registry BFF<br/>Go HTTP<br/>8043/TCP"]
            AutoML["automl BFF<br/>Go HTTP<br/>8643/TCP"]
            AutoRAG["autorag BFF<br/>Go HTTP<br/>8743/TCP"]
            EvalHub["eval-hub BFF<br/>Go HTTP<br/>8543/TCP"]
            MLflow["mlflow BFF<br/>Go HTTP<br/>8343/TCP"]
        end

        subgraph SharedPackages["Shared Packages"]
            PluginCore["plugin-core<br/>Extension Points"]
            AppConfig["app-config<br/>Module Federation Config"]
        end
    end

    %% External User
    User[User Browser] -->|HTTPS/443| Gateway["Platform Gateway<br/>(Envoy)"]
    Gateway -->|HTTPS/8443| KRBP
    KRBP -->|HTTP/8080<br/>Identity Headers| Backend

    %% Frontend loading
    Backend -->|serves| Frontend
    Frontend -->|"/_mf/* (remoteEntry.js)"| GenAI
    Frontend -->|"/_mf/*"| MaaS
    Frontend -->|"/_mf/*"| ModelReg
    Frontend -->|"/_mf/*"| AutoML
    Frontend -->|"/_mf/*"| AutoRAG
    Frontend -->|"/_mf/*"| EvalHub
    Frontend -->|"/_mf/*"| MLflow

    %% Backend proxying to BFFs
    Backend -->|HTTPS/8143| GenAI
    Backend -->|HTTPS/8243| MaaS
    Backend -->|HTTPS/8043| ModelReg
    Backend -->|HTTPS/8643| AutoML
    Backend -->|HTTPS/8743| AutoRAG
    Backend -->|HTTPS/8543| EvalHub
    Backend -->|HTTPS/8343| MLflow

    %% Inter-BFF
    GenAI -->|"HTTPS/8243<br/>Token Delegation"| MaaS

    %% CRDs watched
    Backend -->|watches| DashCfgCR["OdhDashboardConfig CR"]
    Backend -->|watches| AppCR["OdhApplication CR"]
    Backend -->|watches| ISVCR["InferenceService CR"]

    %% External dependencies
    Backend -->|HTTPS/443| K8sAPI["Kubernetes API Server"]
    Backend -->|WSS/443| K8sAPI
    Backend -->|HTTPS/443| Prometheus["Prometheus / Thanos"]

    %% Shared packages usage
    Frontend -.->|uses| PluginCore
    Frontend -.->|uses| AppConfig

    %% Styling
    classDef core fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef bff fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#e8e8e8,stroke:#666,stroke-width:1px
    classDef cr fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef gateway fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef shared fill:#3498db,stroke:#333,stroke-width:1px,color:#fff

    class KRBP,Backend,Frontend core
    class GenAI,MaaS,ModelReg,AutoML,AutoRAG,EvalHub,MLflow bff
    class K8sAPI,Prometheus,User external
    class DashCfgCR,AppCR,ISVCR cr
    class Gateway gateway
    class PluginCore,AppConfig shared
