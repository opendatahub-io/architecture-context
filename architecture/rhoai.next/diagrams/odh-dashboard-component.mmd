    style KubeRBACProxy fill:#e74c3c,stroke:#c0392b,color:#fff,stroke-width:2px
    style Frontend fill:#3498db,stroke:#2980b9,color:#fff,stroke-width:2px
    style Backend fill:#2980b9,stroke:#1a5276,color:#fff,stroke-width:2px
