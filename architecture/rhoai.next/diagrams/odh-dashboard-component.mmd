graph TB
    subgraph External["External Access"]
        Browser["Browser<br/>(Data Scientist / Admin)"]
    end

    subgraph Ingress["Ingress Layer"]
        Route["OpenShift Route / Gateway API<br/>443/TCP HTTPS"]
    end

    subgraph Pod["odh-dashboard Pod"]
        direction TB

        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift RBAC Enforcement"]

        subgraph Core["Core Dashboard"]
            Frontend["odh-dashboard Frontend<br/>React SPA (TypeScript)<br/>Module Federation Host<br/>PatternFly + Redux"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify BFF<br/>8080/TCP HTTP<br/>K8s API Proxy + WebSocket Relay"]
        end

        subgraph FederatedModules["Federated BFF Modules (Go Sidecars)"]
            direction TB
            GenAI["gen-ai BFF<br/>8143/TCP HTTPS<br/>LlamaStack, RAG, Guardrails"]
            MaaS["maas BFF<br/>8243/TCP HTTPS<br/>Tier Mgmt, API Keys"]
            MLflow["mlflow BFF<br/>8343/TCP HTTPS<br/>Experiment Tracking"]
            EvalHub["eval-hub BFF<br/>8543/TCP HTTPS<br/>Model Evaluation"]
            AutoML["automl BFF<br/>8643/TCP HTTPS<br/>Automated ML Pipelines"]
            AutoRAG["autorag BFF<br/>8743/TCP HTTPS<br/>RAG Pipeline Orchestration"]
            ModelReg["model-registry BFF<br/>8043/TCP HTTPS<br/>Model Versioning, Catalog"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhDashboardConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApplication["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDocument["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQuickStart["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph PlatformServices["Internal Platform Services"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS"]
    end

    subgraph UpstreamServices["Upstream ML/AI Services"]
        DSPipelines["DS Pipelines API<br/>8443/TCP HTTPS"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP"]
        TrustyAI["TrustyAI / EvalHub<br/>8080/TCP HTTP"]
        LlamaStack["LlamaStack Distribution<br/>8321/TCP HTTP"]
        MaaSAPI["MaaS API<br/>8443/TCP HTTPS"]
        MLflowServer["MLflow Tracking Server<br/>5000/TCP HTTP"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>OAuth2"| Route
    Route -->|"TLS reencrypt"| KubeRBACProxy
    Browser -->|"OAuth2 login"| OAuth

    %% Pod internal flows
    KubeRBACProxy -->|"HTTP/8080<br/>x-forwarded-access-token"| Backend
    Backend -->|"serves"| Frontend
    Backend -->|"/_mf/* proxy"| GenAI
    Backend -->|"/_mf/* proxy"| MaaS
    Backend -->|"/_mf/* proxy"| MLflow
    Backend -->|"/_mf/* proxy"| EvalHub
    Backend -->|"/_mf/* proxy"| AutoML
    Backend -->|"/_mf/* proxy"| AutoRAG
    Backend -->|"/_mf/* proxy"| ModelReg

    %% Inter-BFF
    GenAI -.->|"inter-BFF<br/>8243/TCP"| MaaS

    %% CRD watches
    Backend -->|"watches"| OdhDashboardConfig
    Backend -->|"watches"| OdhApplication
    Backend -->|"watches"| OdhDocument
    Backend -->|"watches"| OdhQuickStart

    %% Platform dependencies
    Backend -->|"REST + WebSocket<br/>6443/TCP"| K8sAPI
    Backend -->|"HTTPS/9092"| Thanos

    %% Upstream service proxying
    Backend -->|"proxy"| DSPipelines
    Backend -->|"proxy"| ModelRegistry
    Backend -->|"proxy"| TrustyAI
    GenAI -->|"proxy"| LlamaStack
    MaaS -->|"proxy"| MaaSAPI
    MLflow -->|"proxy"| MLflowServer
    AutoML -->|"proxy"| DSPipelines
    AutoML -->|"proxy"| S3
    AutoRAG -->|"proxy"| LlamaStack
    AutoRAG -->|"proxy"| S3
    ModelReg -->|"proxy"| ModelRegistry

