graph TB
    subgraph Platform["RHOAI Platform - 17 Components"]
        direction TB

        subgraph Operators["Kubernetes Operators"]
            direction LR
            CFOperator["codeflare-operator<br/>Go | controller-runtime<br/>9443/HTTPS webhooks<br/>8080/HTTP metrics"]
            DSPOperator["data-science-pipelines-operator<br/>Go | controller-runtime<br/>8080/HTTP metrics"]
            FeastOp["feast-operator<br/>Go | controller-runtime<br/>Kustomize overlays"]
        end

        subgraph InferenceServices["Inference & Serving"]
            direction LR
            CaikitTGIS["caikit-tgis-serving<br/>Python | KServe ServingRuntime<br/>8080/HTTP 8085/gRPC<br/>TGIS backend 8033/gRPC"]
            FeastServer["feast-feature-server<br/>Python | Feature serving<br/>6566/HTTP REST<br/>8000/HTTP metrics"]
            GuardrailsDet["guardrails-detectors<br/>Python | KServe InferenceService<br/>8080/HTTP 8085/HTTP metrics"]
        end

        subgraph GatewayLayer["Gateway & Traffic Management"]
            direction LR
            AIGateway["ai-gateway-payload-processing<br/>Go | Envoy ext-proc<br/>9004/gRPC 9005/HTTP"]
            GWExtension["gateway-api-inference-extension<br/>Go | EPP + BBR ext-proc<br/>9002,9004/gRPC 9003,9005/HTTP"]
            BatchGW["batch-gateway<br/>Go | OpenAI Batch API<br/>HTTP REST configurable"]
        end

        subgraph Orchestration["Orchestration & Pipelines"]
            direction LR
            ArgoWF["argo-workflows<br/>Go | Controller + Executor<br/>9090/HTTP metrics<br/>6060/HTTP health"]
            DSPipelines["data-science-pipelines<br/>Go | 7 sub-components<br/>8888/HTTP 8887/gRPC<br/>8443/HTTPS webhook"]
            Guardrails["fms-guardrails-orchestrator<br/>Rust (axum+tokio)<br/>8033/HTTP 8034/HTTP health"]
        end

        subgraph Training["Training & Tuning"]
            direction LR
            FMSTuning["fms-hf-tuning<br/>Python | CUDA 12.1<br/>29500/TCP FSDP"]
        end

        subgraph EvalMonitoring["Evaluation & Monitoring"]
            direction LR
            EvalHub["eval-hub<br/>Go | REST + MCP<br/>8080/HTTP 8443/HTTPS"]
        end

        subgraph Libraries["Libraries & SDKs (No K8s Resources)"]
            direction LR
            AI4RAG["ai4rag<br/>Python | Library"]
            Caikit["caikit<br/>Python | SDK/Runtime framework"]
            CaikitNLP["caikit-nlp<br/>Python | NLP modules"]
            CFSDK["codeflare-sdk<br/>Python | Client SDK"]
        end
    end

    %% External Dependencies
    K8sAPI["Kubernetes API"]
    Istio["Istio Service Mesh"]
    KServe["KServe"]
    Kueue["Kueue"]
    KubeRay["KubeRay"]
    Envoy["Envoy Proxy"]
    PostgreSQL["PostgreSQL"]
    S3["S3/Minio Storage"]
    HFHub["HuggingFace Hub"]

    %% Key Relationships
    CFOperator -->|manages| KubeRay
    CFOperator -->|integrates| Kueue
    DSPOperator -->|manages| DSPipelines
    DSPipelines -->|orchestrates| ArgoWF
    DSPipelines -->|stores| PostgreSQL
    DSPipelines -->|artifacts| S3
    CaikitTGIS -->|deployed via| KServe
    CaikitTGIS -->|mTLS| Istio
    GuardrailsDet -->|deployed via| KServe
    AIGateway -->|ext-proc| Envoy
    GWExtension -->|ext-proc| Envoy
    Guardrails -->|calls| CaikitTGIS
    Guardrails -->|calls| GuardrailsDet
    FMSTuning -->|downloads| HFHub
    FeastOp -->|manages| FeastServer
    EvalHub -->|auth| K8sAPI
    BatchGW -->|stores| PostgreSQL
    BatchGW -->|stores| S3

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef inference fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef gateway fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef orchestration fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef training fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff
    classDef eval fill:#1abc9c,stroke:#333,stroke-width:2px,color:#fff
    classDef library fill:#95a5a6,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#ecf0f1,stroke:#999,stroke-width:1px

    class CFOperator,DSPOperator,FeastOp operator
    class CaikitTGIS,FeastServer,GuardrailsDet inference
    class AIGateway,GWExtension,BatchGW gateway
    class ArgoWF,DSPipelines,Guardrails orchestration
    class FMSTuning training
    class EvalHub eval
    class AI4RAG,Caikit,CaikitNLP,CFSDK library
    class K8sAPI,Istio,KServe,Kueue,KubeRay,Envoy,PostgreSQL,S3,HFHub external
