graph TD
    subgraph ServiceAccounts["Service Accounts"]
        EPPSA["EPP ServiceAccount<br/>(epp-service-account)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        EPPCRB["EPP ClusterRoleBinding"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        EPPCR["EPP ClusterRole<br/>(metrics auth)"]
    end

    subgraph ClusterResources["Cluster-Scoped API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews"]
        MetricsURL["nonResourceURLs<br/>/metrics"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        EPPRB["EPP RoleBinding"]
        EPPLERB["EPP Leader Election<br/>RoleBinding"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        EPPRole["EPP Role"]
        EPPLERole["EPP Leader Election Role"]
    end

    subgraph NamespaceResources["Namespace-Scoped API Resources"]
        Pods["core<br/>pods"]
        InferencePoolsLegacy["inference.networking.x-k8s.io<br/>inferencepools<br/>inferenceobjectives<br/>inferencemodelrewrites"]
        InferencePoolsNew["inference.networking.k8s.io<br/>inferencepools"]
        LLMDResources["llm-d.ai<br/>inferenceobjectives<br/>inferencemodelrewrites"]
        Leases["coordination.k8s.io<br/>leases"]
        Events["core<br/>events"]
    end

    %% Cluster-level bindings
    EPPSA -->|"bound via"| EPPCRB
    EPPCRB -->|"grants"| EPPCR
    EPPCR -->|"create"| TokenReviews
    EPPCR -->|"create"| SubjectAccessReviews
    EPPCR -->|"get"| MetricsURL

    %% Namespace-level bindings
    EPPSA -->|"bound via"| EPPRB
    EPPRB -->|"grants"| EPPRole
    EPPRole -->|"get, watch, list"| Pods
    EPPRole -->|"get, watch, list"| InferencePoolsLegacy
    EPPRole -->|"get, watch, list"| InferencePoolsNew
    EPPRole -->|"get, watch, list"| LLMDResources

    %% Leader election bindings
    EPPSA -->|"bound via"| EPPLERB
    EPPLERB -->|"grants"| EPPLERole
    EPPLERole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Leases
    EPPLERole -->|"create, patch"| Events

    %% Styling
    style EPPSA fill:#4a90e2,stroke:#333,color:#fff
    style EPPCRB fill:#c0c0c0,stroke:#333
    style EPPRB fill:#c0c0c0,stroke:#333
    style EPPLERB fill:#c0c0c0,stroke:#333
    style EPPCR fill:#f5a623,stroke:#333
    style EPPRole fill:#f5a623,stroke:#333
    style EPPLERole fill:#f5a623,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SubjectAccessReviews fill:#7ed321,stroke:#333
    style MetricsURL fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style InferencePoolsLegacy fill:#7ed321,stroke:#333
    style InferencePoolsNew fill:#7ed321,stroke:#333
    style LLMDResources fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
