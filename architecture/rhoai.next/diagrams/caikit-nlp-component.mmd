graph TB
    subgraph CaikitRuntime["Caikit Runtime Container"]
        direction TB
        Runtime["caikit Runtime<br/>HTTP :8080 / gRPC :8085"]

        subgraph TextGenModules["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local HF)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftPT["PeftPromptTuning<br/>(Local Training)"]
            PeftPTTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
        end

        subgraph EmbeddingModules["Embedding & Reranking Modules"]
            EmbeddingMod["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEncoder["CrossEncoderModule<br/>(cross-encoder rerank)"]
            STTruncate["SentenceTransformerWithTruncate"]
            CETruncate["CrossEncoderWithTruncate"]
        end

        subgraph ClassificationModules["Classification & Tokenization Modules"]
            SeqClass["SequenceClassification<br/>(HF transformers)"]
            SpanClass["FilteredSpanClassification"]
            RegexSplit["RegexSentenceSplitter"]
        end

        subgraph ModelManagement["Model Management"]
            TGISAutoFinder["TGISAutoFinder<br/>(Model Discovery)"]
        end

        Runtime -->|loads modules| TextGenModules
        Runtime -->|loads modules| EmbeddingModules
        Runtime -->|loads modules| ClassificationModules
        Runtime -->|uses| ModelManagement
        EmbeddingMod -->|wraps| STTruncate
        CrossEncoder -->|wraps| CETruncate
    end

    Client[Client] -->|HTTP POST :8080<br/>or gRPC :8085| Runtime

    TextGenLocal -->|PyTorch inference| HFModel["HuggingFace Model<br/>(in-memory GPU/CPU)"]
    TextGenTGIS -->|gRPC| TGISServer["TGIS Server"]
    PeftPT -->|PyTorch training| HFModel
    PeftPTTGIS -->|gRPC| TGISServer
    EmbeddingMod -->|PyTorch inference| STModel["sentence-transformers<br/>(in-memory)"]
    TGISAutoFinder -.->|discovers models| TGISServer

    PeftPT -->|saves prompt vectors| Disk["Disk Storage<br/>(encoder.pt / decoder.pt)"]

    style Runtime fill:#4a90e2,color:#fff
    style TextGenLocal fill:#5cb85c,color:#fff
    style TextGenTGIS fill:#5cb85c,color:#fff
    style PeftPT fill:#5cb85c,color:#fff
    style PeftPTTGIS fill:#5cb85c,color:#fff
    style EmbeddingMod fill:#8e44ad,color:#fff
    style CrossEncoder fill:#8e44ad,color:#fff
    style SeqClass fill:#e67e22,color:#fff
    style SpanClass fill:#e67e22,color:#fff
    style RegexSplit fill:#e67e22,color:#fff
    style TGISAutoFinder fill:#3498db,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style TGISServer fill:#e8e8e8,stroke:#333
    style HFModel fill:#e8e8e8,stroke:#333
    style STModel fill:#e8e8e8,stroke:#333
    style Disk fill:#e8e8e8,stroke:#333
    style STTruncate fill:#9b59b6,color:#fff
    style CETruncate fill:#9b59b6,color:#fff
