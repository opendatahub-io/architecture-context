graph TB
    subgraph CaikitNLP["caikit-nlp Library"]
        direction TB

        subgraph TextEmbedding["Text Embedding Modules"]
            EmbeddingModule["EmbeddingModule<br/><i>sentence-transformers</i><br/>embedding, similarity, reranking"]
            CrossEncoderModule["CrossEncoderModule<br/><i>cross-encoder</i><br/>reranking, tokenization"]
        end

        subgraph TextGeneration["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/><i>HuggingFace CausalLM/Seq2Seq</i><br/>local inference"]
            TextGenTGIS["TextGenerationTGIS<br/><i>TGIS gRPC client</i><br/>remote inference"]
        end

        subgraph PeftModules["PEFT Prompt Tuning Modules"]
            PeftLocal["PeftPromptTuning<br/><i>PEFT + Accelerate</i><br/>local fine-tuning & inference"]
            PeftTGIS["PeftPromptTuningTGIS<br/><i>TGIS gRPC client</i><br/>remote PEFT inference"]
        end

        subgraph Classification["Classification Modules"]
            SeqClass["SequenceClassification<br/><i>AutoModelForSequenceClassification</i>"]
            SpanClass["FilteredSpanClassification<br/><i>token/span classification</i>"]
        end

        subgraph Tokenization["Tokenization"]
            RegexSplitter["RegexSentenceSplitter<br/><i>regex-based sentence splitting</i>"]
        end

        subgraph ModelMgmt["Model Management"]
            TGISAutoFinder["TGISAutoFinder<br/><i>auto-discover remote TGIS models</i>"]
            PretrainedBase["PretrainedModelBase<br/><i>HuggingFace model resource</i>"]
        end
    end

    subgraph Runtime["Caikit Runtime"]
        RuntimeHTTP["HTTP Server<br/>8080/TCP"]
        RuntimeGRPC["gRPC Server<br/>8085/TCP"]
        ModuleRegistry["Module Registry<br/><i>auto-discovers @module() classes</i>"]
    end

    Client["Client<br/><i>inference/training requests</i>"]

    %% Client to Runtime
    Client -->|"HTTP POST /api/v1/task/*"| RuntimeHTTP
    Client -->|"gRPC caikit.runtime.Nlp"| RuntimeGRPC

    %% Runtime loads library
    RuntimeHTTP -->|dispatches| ModuleRegistry
    RuntimeGRPC -->|dispatches| ModuleRegistry
    ModuleRegistry -->|"RUNTIME_LIBRARY=caikit_nlp"| CaikitNLP

    %% External dependencies
    TGIS["TGIS Server<br/><i>8033/TCP gRPC</i>"]
    HFHub["HuggingFace Hub<br/><i>443/TCP HTTPS</i>"]
    LocalModels["Local Model Storage<br/><i>filesystem</i>"]
    GPU["PyTorch CUDA / IPEX<br/><i>GPU acceleration</i>"]

    TextGenTGIS -->|"gRPC (TLS optional)"| TGIS
    PeftTGIS -->|"gRPC (TLS optional)"| TGIS
    TGISAutoFinder -->|"discovers models"| TGIS
    PretrainedBase -->|"downloads models"| HFHub
    PretrainedBase -->|"loads models"| LocalModels
    EmbeddingModule -->|"inference"| GPU
    PeftLocal -->|"training/inference"| GPU

    %% Styling
    style CaikitNLP fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Runtime fill:#f0f0f0,stroke:#666,stroke-width:2px
    style Client fill:#fff,stroke:#333,stroke-width:2px
    style TGIS fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style HFHub fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style LocalModels fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style GPU fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style EmbeddingModule fill:#4a90e2,color:#fff
    style CrossEncoderModule fill:#4a90e2,color:#fff
    style TextGenLocal fill:#4a90e2,color:#fff
    style TextGenTGIS fill:#4a90e2,color:#fff
    style PeftLocal fill:#4a90e2,color:#fff
    style PeftTGIS fill:#4a90e2,color:#fff
    style SeqClass fill:#4a90e2,color:#fff
    style SpanClass fill:#4a90e2,color:#fff
    style RegexSplitter fill:#4a90e2,color:#fff
    style TGISAutoFinder fill:#f5a623,color:#fff
    style PretrainedBase fill:#f5a623,color:#fff
