graph TB
    subgraph CaikitNLP["caikit-nlp Python Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local HuggingFace)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftPT["PeftPromptTuning<br/>(Local Training)"]
            PeftPTTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
        end

        subgraph Embedding["Embedding & Reranking Modules"]
            EmbMod["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEnc["CrossEncoderModule<br/>(cross-encoder reranking)"]
        end

        subgraph Classification["Classification Modules"]
            SeqClass["SequenceClassification<br/>(text classification)"]
            SpanClass["FilteredSpanClassification<br/>(token classification)"]
        end

        subgraph Tokenization["Tokenization"]
            RegexSplit["RegexSentenceSplitter"]
        end

        subgraph Utilities["Utility Classes"]
            STTrunc["SentenceTransformerWithTruncate<br/>(thread-safe tokenization)"]
            CETrunc["CrossEncoderWithTruncate<br/>(thread-safe tokenization)"]
            TGISFinder["TGISAutoFinder<br/>(model discovery)"]
        end
    end

    subgraph CaikitRuntime["caikit Runtime (Host Process)"]
        HTTPServer["HTTP Server<br/>8080/TCP"]
        GRPCServer["gRPC Server<br/>8085/TCP"]
        ModuleLoader["Module Loader<br/>RUNTIME_LIBRARY=caikit_nlp"]
    end

    Client["Client<br/>(Data Scientist / Application)"]

    Client -->|"POST /api/v1/task/*"| HTTPServer
    Client -->|"gRPC NlpService.*"| GRPCServer
    HTTPServer -->|loads modules| ModuleLoader
    GRPCServer -->|loads modules| ModuleLoader
    ModuleLoader -->|discovers & loads| CaikitNLP

    EmbMod -->|wraps| STTrunc
    CrossEnc -->|wraps| CETrunc
    TextGenTGIS -->|uses| TGISFinder
    PeftPTTGIS -->|uses| TGISFinder

    TextGenLocal -->|inference| HFModels["HuggingFace Models<br/>(in-memory)"]
    PeftPT -->|training| HFModels
    EmbMod -->|inference| STModels["SentenceTransformer Models<br/>(in-memory)"]
    CrossEnc -->|inference| CEModels["CrossEncoder Models<br/>(in-memory)"]

    TextGenTGIS -->|gRPC| TGISServer["TGIS Server<br/>(Remote)"]
    PeftPTTGIS -->|gRPC| TGISServer

    style CaikitNLP fill:#4a90e2,stroke:#333,color:#fff
    style TextGen fill:#5b9bd5,stroke:#333,color:#fff
    style Embedding fill:#5b9bd5,stroke:#333,color:#fff
    style Classification fill:#5b9bd5,stroke:#333,color:#fff
    style Tokenization fill:#5b9bd5,stroke:#333,color:#fff
    style Utilities fill:#5b9bd5,stroke:#333,color:#fff
    style CaikitRuntime fill:#7ed321,stroke:#333,color:#fff
    style HFModels fill:#f5a623,stroke:#333
    style STModels fill:#f5a623,stroke:#333
    style CEModels fill:#f5a623,stroke:#333
    style TGISServer fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
