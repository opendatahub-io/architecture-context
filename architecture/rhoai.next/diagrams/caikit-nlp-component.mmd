graph TB
    subgraph CaikitNLP["Caikit-NLP Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local HF Models)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftLocal["PeftPromptTuning<br/>(Local Training + Inference)"]
            PeftTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS + Prompt Cache)"]
        end

        subgraph Embedding["Embedding Modules"]
            EmbeddingMod["EmbeddingModule<br/>(embed, similarity, rerank, tokenize)"]
            CrossEncoder["CrossEncoderModule<br/>(cross-encoder reranking)"]
        end

        subgraph Classification["Classification Modules"]
            SeqClass["SequenceClassification<br/>(text classification)"]
            SpanClass["FilteredSpanClassification<br/>(token classification, bidi streaming)"]
        end

        subgraph Tokenization["Tokenization"]
            RegexSplitter["RegexSentenceSplitter"]
        end

        subgraph Resources["HuggingFace Resources"]
            HFCausalLM["HFAutoCausalLM"]
            HFSeq2Seq["HFAutoSeq2SeqLM"]
            HFSeqClass["HFAutoSequenceClassifier"]
        end

        subgraph Clients["Backend Clients"]
            TGISClient["TGISGenerationClient<br/>(gRPC)"]
            TGISFinder["TGISAutoFinder<br/>(model discovery)"]
        end
    end

    subgraph Runtime["Caikit Runtime (Host)"]
        gRPCServer["gRPC Server<br/>8085/TCP"]
        HTTPServer["HTTP REST Gateway<br/>8080/TCP"]
    end

    Client["Client Application"] -->|gRPC| gRPCServer
    Client -->|HTTP REST| HTTPServer

    gRPCServer -->|dispatches| TextGen
    gRPCServer -->|dispatches| Embedding
    gRPCServer -->|dispatches| Classification
    gRPCServer -->|dispatches| Tokenization
    HTTPServer -->|dispatches| TextGen
    HTTPServer -->|dispatches| Embedding
    HTTPServer -->|dispatches| Classification
    HTTPServer -->|dispatches| Tokenization

    TextGenLocal -->|loads| HFCausalLM
    TextGenLocal -->|loads| HFSeq2Seq
    PeftLocal -->|wraps| HFCausalLM
    PeftLocal -->|wraps| HFSeq2Seq
    SeqClass -->|loads| HFSeqClass

    TextGenTGIS -->|delegates| TGISClient
    PeftTGIS -->|delegates| TGISClient
    TGISFinder -->|discovers via| TGISClient

    EmbeddingMod -->|loads| SentenceTransformers["SentenceTransformers<br/>(local models)"]
    CrossEncoder -->|loads| CrossEncoderLib["CrossEncoder<br/>(local models)"]

    TGISClient -->|gRPC| TGISBackend["TGIS Backend<br/>(external)"]
    HFCausalLM -.->|optional download| HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    PeftLocal -.->|distributed training| PyTorchDist["PyTorch Distributed<br/>29550/TCP"]

    subgraph Platform["RHOAI Platform"]
        KServe["KServe / ModelMesh"]
    end

    KServe -->|deploys & manages| Runtime

    style CaikitNLP fill:#4a90e2,stroke:#333,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style Platform fill:#d5e8d4,stroke:#82b366
    style TGISBackend fill:#999,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style PyTorchDist fill:#999,stroke:#333,color:#fff
    style SentenceTransformers fill:#e8e8e8,stroke:#333
    style CrossEncoderLib fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style KServe fill:#7ed321,stroke:#333
