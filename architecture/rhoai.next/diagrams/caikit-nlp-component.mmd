graph TB
    subgraph CaikitNLP["caikit-nlp Python Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local HuggingFace)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftPT["PeftPromptTuning<br/>(Local Training)"]
            PeftPTTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS)"]
        end

        subgraph Embedding["Embedding & Reranking Modules"]
            EmbMod["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEnc["CrossEncoderModule<br/>(cross-encoder)"]
            STTrunc["SentenceTransformerWithTruncate"]
            CETrunc["CrossEncoderWithTruncate"]
            EmbMod -->|wraps| STTrunc
            CrossEnc -->|wraps| CETrunc
        end

        subgraph Classification["Classification & Tokenization"]
            SeqClass["SequenceClassification"]
            SpanClass["FilteredSpanClassification"]
            RegexSplit["RegexSentenceSplitter"]
        end

        subgraph ModelMgmt["Model Management"]
            AutoFinder["TGISAutoFinder<br/>(Model Discovery)"]
        end
    end

    subgraph CaikitRuntime["caikit Runtime Container"]
        HTTPServer["HTTP Server<br/>8080/TCP"]
        GRPCServer["gRPC Server<br/>8085/TCP"]
    end

    Client["Client<br/>(Data Scientist / Application)"]

    Client -->|"POST /api/v1/task/*"| HTTPServer
    Client -->|"gRPC NlpService"| GRPCServer
    HTTPServer -->|"loads modules"| CaikitNLP
    GRPCServer -->|"loads modules"| CaikitNLP

    TextGenLocal -->|"PyTorch inference"| HFModel["HuggingFace Model<br/>(in-memory GPU/CPU)"]
    TextGenTGIS -->|"gRPC"| TGIS["TGIS Server<br/>(Remote)"]
    PeftPT -->|"training"| HFModel
    PeftPTTGIS -->|"gRPC"| TGIS
    AutoFinder -->|"discovers models"| TGIS
    EmbMod -->|"inference"| STModel["SentenceTransformer Model<br/>(in-memory)"]

    style CaikitNLP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CaikitRuntime fill:#50c878,stroke:#333,stroke-width:2px,color:#fff
    style TextGenLocal fill:#6ba3d6,stroke:#333
    style TextGenTGIS fill:#6ba3d6,stroke:#333
    style PeftPT fill:#6ba3d6,stroke:#333
    style PeftPTTGIS fill:#6ba3d6,stroke:#333
    style EmbMod fill:#6ba3d6,stroke:#333
    style CrossEnc fill:#6ba3d6,stroke:#333
    style SeqClass fill:#6ba3d6,stroke:#333
    style SpanClass fill:#6ba3d6,stroke:#333
    style RegexSplit fill:#6ba3d6,stroke:#333
    style AutoFinder fill:#6ba3d6,stroke:#333
    style STTrunc fill:#8db8e0,stroke:#333
    style CETrunc fill:#8db8e0,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style HFModel fill:#e8e8e8,stroke:#333
    style STModel fill:#e8e8e8,stroke:#333
    style Client fill:#f5a623,stroke:#333
    style HTTPServer fill:#7ed321,stroke:#333
    style GRPCServer fill:#7ed321,stroke:#333
