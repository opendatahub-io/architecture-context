graph TB
    subgraph CaikitNLP["caikit-nlp Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGeneration["TextGeneration<br/>(Local HuggingFace)"]
            TextGenerationTGIS["TextGenerationTGIS<br/>(Remote TGIS Backend)"]
            PeftPromptTuning["PeftPromptTuning<br/>(Local PEFT Training/Inference)"]
            PeftPromptTuningTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS PEFT Inference)"]
        end

        subgraph Embedding["Embedding & Reranking Modules"]
            EmbeddingModule["EmbeddingModule<br/>(Bi-encoder: Embeddings,<br/>Similarity, Reranking)"]
            CrossEncoderModule["CrossEncoderModule<br/>(Cross-encoder: Reranking,<br/>Tokenization)"]
        end

        subgraph Classification["Classification Modules"]
            SequenceClassification["SequenceClassification<br/>(Text Classification)"]
            FilteredSpanClassification["FilteredSpanClassification<br/>(Token Classification)"]
        end

        subgraph Tokenization["Tokenization Modules"]
            RegexSentenceSplitter["RegexSentenceSplitter<br/>(Regex-based Splitting)"]
        end

        subgraph ModelMgmt["Model Management"]
            TGISAutoFinder["TGISAutoFinder<br/>(TGIS Model Discovery)"]
        end
    end

    %% Runtime Integration
    CaikitRuntime["Caikit Runtime Server<br/>(gRPC :8085 / HTTP :8080)"]
    CaikitRuntime -->|"loads via<br/>RUNTIME_LIBRARY=caikit_nlp"| CaikitNLP

    %% Client
    Client["Client"] -->|"gRPC / HTTP"| CaikitRuntime

    %% Backend Connections
    TextGenerationTGIS -->|"gRPC"| TGISServer["TGIS Server<br/>(Remote Inference)"]
    PeftPromptTuningTGIS -->|"gRPC"| TGISServer
    TGISAutoFinder -.->|"discovers models"| TGISServer

    %% Local Model Dependencies
    TextGeneration -->|"loads"| HFModels["HuggingFace<br/>Transformer Models"]
    EmbeddingModule -->|"loads"| STModels["sentence-transformers<br/>Models"]
    CrossEncoderModule -->|"loads"| STModels
    SequenceClassification -->|"loads"| HFModels
    PeftPromptTuning -->|"fine-tunes"| HFModels

    %% Optional Downloads
    HFModels -.->|"optional download<br/>HTTPS :443"| HFHub["HuggingFace Hub"]

    %% Dual-backend pattern
    TextGeneration -.->|"backend_type<br/>selection"| TextGenerationTGIS
    PeftPromptTuning -.->|"backend_type<br/>selection"| PeftPromptTuningTGIS

    %% Styling
    style CaikitNLP fill:#e8f4f8,stroke:#4a90e2,stroke-width:2px
    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style TGISServer fill:#f5a623,stroke:#333
    style HFModels fill:#7ed321,stroke:#333
    style STModels fill:#7ed321,stroke:#333
    style HFHub fill:#999,stroke:#333
    style TextGeneration fill:#d5e8d4,stroke:#82b366
    style TextGenerationTGIS fill:#ffe6cc,stroke:#d79b00
    style PeftPromptTuning fill:#d5e8d4,stroke:#82b366
    style PeftPromptTuningTGIS fill:#ffe6cc,stroke:#d79b00
    style EmbeddingModule fill:#d5e8d4,stroke:#82b366
    style CrossEncoderModule fill:#d5e8d4,stroke:#82b366
    style SequenceClassification fill:#d5e8d4,stroke:#82b366
    style FilteredSpanClassification fill:#d5e8d4,stroke:#82b366
    style RegexSentenceSplitter fill:#d5e8d4,stroke:#82b366
    style TGISAutoFinder fill:#dae8fc,stroke:#6c8ebf
