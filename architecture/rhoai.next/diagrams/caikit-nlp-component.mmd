graph TB
    subgraph CaikitNLP["caikit-nlp Library"]
        direction TB

        subgraph TextGen["Text Generation Domain"]
            TextGenLocal["TextGeneration<br/>(Local HF Models)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS Backend)"]
            PeftLocal["PeftPromptTuning<br/>(Local Training + Inference)"]
            PeftTGIS["PeftPromptTuningTGIS<br/>(TGIS + Prompt Cache)"]
        end

        subgraph Embedding["Embedding Domain"]
            EmbeddingMod["EmbeddingModule<br/>(7 tasks: embed, similarity,<br/>rerank, tokenize)"]
            CrossEncoder["CrossEncoderModule<br/>(Cross-Encoder Reranking)"]
        end

        subgraph Classification["Classification Domain"]
            SeqClass["SequenceClassification<br/>(Text Classification)"]
            SpanClass["FilteredSpanClassification<br/>(Token Classification,<br/>Bidirectional Streaming)"]
        end

        subgraph Tokenization["Tokenization Domain"]
            RegexSplitter["RegexSentenceSplitter<br/>(Regex Tokenization)"]
        end

        subgraph Resources["HuggingFace Resources"]
            HFCausalLM["HFAutoCausalLM"]
            HFSeq2Seq["HFAutoSeq2SeqLM"]
            HFSeqClass["HFAutoSequenceClassifier"]
        end

        subgraph Toolkit["Toolkit"]
            TGISClient["TGISGenerationClient<br/>(gRPC Client)"]
            TGISFinder["TGISAutoFinder<br/>(Model Discovery)"]
        end
    end

    %% Client access
    Client["Client"] -->|"gRPC :8085<br/>HTTP :8080"| CaikitRuntime["Caikit Runtime<br/>(gRPC + REST Server)"]
    CaikitRuntime -->|"RUNTIME_LIBRARY=caikit_nlp"| CaikitNLP

    %% Internal relationships
    TextGenLocal -->|loads| HFCausalLM
    TextGenLocal -->|loads| HFSeq2Seq
    PeftLocal -->|wraps with PEFT| HFCausalLM
    PeftLocal -->|wraps with PEFT| HFSeq2Seq
    TextGenTGIS -->|delegates| TGISClient
    PeftTGIS -->|delegates + prompt cache| TGISClient
    TGISFinder -->|discovers models| TGISClient
    SeqClass -->|loads| HFSeqClass
    EmbeddingMod -->|"sentence-transformers"| SentenceTransformers["SentenceTransformers<br/>(Local Models)"]
    CrossEncoder -->|"CrossEncoder model"| SentenceTransformers

    %% External dependencies
    TGISClient -->|"gRPC (configurable port)<br/>Optional mTLS"| TGIS["TGIS Backend"]
    HFCausalLM -->|"HTTPS :443<br/>(when allow_downloads=true)"| HFHub["HuggingFace Hub"]
    PeftLocal -->|"TCP :29550<br/>(distributed training)"| PyTorchDist["PyTorch Distributed<br/>(torchrun / FSDP)"]

    %% Platform integration
    KServe["KServe / ModelMesh"] -->|"deploys container<br/>odh-caikit-nlp-rhel9"| CaikitRuntime

    %% Styling
    style CaikitNLP fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style TextGen fill:#d5e8d4,stroke:#82b366
    style Embedding fill:#fff2cc,stroke:#d6b656
    style Classification fill:#f8cecc,stroke:#b85450
    style Tokenization fill:#e1d5e7,stroke:#9673a6
    style Resources fill:#dae8fc,stroke:#6c8ebf
    style Toolkit fill:#f5f5f5,stroke:#666666

    style CaikitRuntime fill:#4a90e2,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style TGIS fill:#999,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style PyTorchDist fill:#999,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style SentenceTransformers fill:#999,stroke:#333
