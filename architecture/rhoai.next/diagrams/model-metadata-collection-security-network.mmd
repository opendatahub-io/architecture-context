graph TB
    subgraph BuildTime["CI/CD BUILD ENVIRONMENT (Build-Time Only)"]
        direction TB
        Extractor["model-extractor<br/>(Go CLI — NOT shipped)<br/>CGO_ENABLED=0<br/>Pure-Go crypto"]
    end

    subgraph ExternalAPIs["EXTERNAL SERVICES (Build-Time Egress)"]
        direction TB
        HF["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (optional)"]
        RHReg["OCI Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
        AccReg["OCI Registry<br/>registry.access.redhat.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
    end

    subgraph ContainerBuild["CONTAINER BUILD & PUSH"]
        direction TB
        Konflux["Konflux Pipeline<br/>hermetic: true<br/>Multi-arch: x86_64, ppc64le,<br/>s390x, arm64"]
        GHA["GitHub Actions<br/>(ODH upstream)"]
    end

    subgraph Registry["CONTAINER REGISTRY"]
        QuayRHOAI["quay.io/rhoai/<br/>odh-model-metadata-collection"]
        QuayODH["quay.io/opendatahub/<br/>odh-model-metadata-collection"]
    end

    subgraph Runtime["RUNTIME (On-Cluster — ZERO Network Surface)"]
        direction TB

        subgraph DataPod["Data Container Pod"]
            DC["odh-model-metadata-collection<br/>UBI9-minimal | UID 1001<br/>Process: sleep infinity<br/>No binary | No listeners<br/>No ingress | No egress"]
            DataVol["/app/data<br/>Catalog YAML Files"]
            DC --- DataVol
        end

        Dashboard["RHOAI Dashboard<br/>Volume mount consumer"]
        Operator["rhods-operator<br/>Deployment orchestrator"]
    end

    %% Build-time flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN (opt.)"| HF
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>OCI Registry v2"| RHReg
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>OCI Registry v2"| AccReg

    %% Build & push flows
    Extractor -->|"generates<br/>catalog YAML"| Konflux
    Extractor -->|"generates<br/>catalog YAML"| GHA
    Konflux -->|"HTTPS/443<br/>Quay credentials"| QuayRHOAI
    GHA -->|"HTTPS/443<br/>Quay credentials"| QuayODH

    %% Runtime flows (no network!)
    DataVol -->|"Volume mount<br/>Filesystem only<br/>Pod-level RBAC"| Dashboard
    Operator -->|"K8s API<br/>Deployment lifecycle"| DataPod

    %% Styling
    classDef buildtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef registry fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef zerosurface fill:#e1d5e7,stroke:#9673a6,stroke-width:3px

    class Extractor buildtime
    class HF,RHReg,AccReg external
    class Konflux,GHA buildtime
    class QuayRHOAI,QuayODH registry
    class DC zerosurface
    class DataVol,Dashboard,Operator runtime
