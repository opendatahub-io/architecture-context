graph TB
    subgraph BuildTime["BUILD-TIME ENVIRONMENT (CI/CD - Trusted)"]
        direction TB

        Extractor["model-extractor<br/>(Go CLI - build-time only)<br/>NOT shipped in image"]
    end

    subgraph External["EXTERNAL SERVICES (Untrusted)"]
        direction TB

        HF["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        OCIRedHat["OCI Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OCI Distribution v2"]
        OCIOther["Other OCI Registries<br/>(MCP server images)<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph CIBuild["CONTAINER BUILD (Konflux/Tekton)"]
        direction TB

        Dockerfile["Dockerfile.konflux<br/>Base: ubi9-minimal<br/>User: 1001 (non-root)<br/>COPY data/*.yaml /app/data/"]
    end

    subgraph Registry["CONTAINER REGISTRY"]
        Quay["quay.io/opendatahub/<br/>odh-model-metadata-collection<br/>443/TCP HTTPS"]
    end

    subgraph Runtime["RUNTIME (Zero Attack Surface)"]
        direction TB

        Container["odh-model-metadata-collection<br/>CMD: sleep infinity<br/>Ports: NONE<br/>Ingress: NONE<br/>Egress: NONE<br/>User: 1001"]

        Dashboard["RHOAI Dashboard<br/>Reads /app/data/*.yaml<br/>Volume mount (read-only)"]
    end

    %% Build-time flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| HF
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Auth (anonymous)"| OCIRedHat
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Varies"| OCIOther

    %% Build output to container
    Extractor -.->|"YAML files<br/>(local filesystem)"| Dockerfile
    Dockerfile -->|"HTTPS/443<br/>Registry Push Auth"| Quay

    %% Runtime (no network)
    Quay -.->|"Image pull"| Container
    Container -->|"Volume mount<br/>/app/data/<br/>NO NETWORK"| Dashboard

    %% Styling
    classDef buildtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef cibuild fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef registry fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef zeroattack fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#333

    class Extractor buildtime
    class HF,OCIRedHat,OCIOther external
    class Dockerfile cibuild
    class Quay registry
    class Container zeroattack
    class Dashboard runtime
