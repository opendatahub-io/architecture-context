graph TB
    subgraph BuildTime["BUILD-TIME ENVIRONMENT (CI/CD Pipeline)"]
        direction TB

        subgraph CLI["Build-Time CLI Tools (not shipped)"]
            Extractor["model-extractor<br/>(Go 1.24 CLI)<br/>Build-time only"]
            Report["metadata-report<br/>(Go 1.24 CLI)<br/>Build-time only"]
        end

        subgraph BuildOutput["Build Artifacts"]
            CatalogYAML["Catalog YAML Files<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>mcp-servers-catalog.yaml"]
        end

        Extractor -->|"generates"| CatalogYAML
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Untrusted)"]
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>REST API"]
        OCIRegistry["OCI Registry<br/>registry.redhat.io<br/>OCI Distribution v2"]
    end

    subgraph ContainerBuild["CONTAINER BUILD"]
        Konflux["Konflux / Tekton<br/>Dockerfile.konflux<br/>Individual COPY (no globs)"]
    end

    subgraph Runtime["RUNTIME (Kubernetes Cluster)"]
        direction TB

        subgraph DataContainer["odh-model-metadata-collection<br/>ubi9-minimal | UID 1001 (non-root)<br/>No listeners | No egress"]
            DataVolume["/app/data/<br/>Catalog YAML"]
            BenchmarkVolume["/app/benchmarks/<br/>Benchmark data"]
        end

        subgraph Consumer["Platform Consumer"]
            Dashboard["RHOAI Dashboard"]
        end
    end

    %% Build-time egress flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| OCIRegistry

    %% Build to container
    CatalogYAML -->|"COPY into image"| Konflux
    Konflux -->|"builds"| DataContainer

    %% Runtime data access
    Dashboard -->|"Volume Mount<br/>Filesystem<br/>No network"| DataVolume

    %% Styling
    classDef buildtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datacontainer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef build fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Extractor,Report buildtime
    class HuggingFace,OCIRegistry external
    class DataVolume,BenchmarkVolume datacontainer
    class Dashboard consumer
    class Konflux build
    class CatalogYAML buildtime
