graph TB
    subgraph BuildTime["BUILD-TIME ENVIRONMENT (CI/CD Pipeline)"]
        direction TB

        Extractor["model-extractor CLI<br/>Go 1.24<br/>Not shipped in container<br/>Max 5 concurrent jobs"]
        Report["metadata-report CLI<br/>Go 1.24<br/>Not shipped in container"]
        Artifacts["Generated Artifacts<br/>(checked into repo)<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>redhat-mcp-servers-catalog.yaml"]

        Extractor -->|"File I/O<br/>No network"| Artifacts
        Report -->|"File I/O<br/>No network"| Artifacts
    end

    subgraph ExternalAPIs["EXTERNAL SERVICES (Outbound from CI/CD only)"]
        HF["HuggingFace API<br/>huggingface.co<br/>GET /api/collections<br/>GET /api/models/{id}<br/>GET /{id}/raw/main/README.md"]
        OCI["OCI Container Registry<br/>registry.redhat.io<br/>GET /v2/{repo}/manifests/{tag}<br/>GET /v2/{repo}/blobs/{digest}"]
    end

    subgraph ContainerBuild["CONTAINER BUILD"]
        Dockerfile["Dockerfile.konflux<br/>Base: ubi9-minimal<br/>Copies YAML files individually<br/>No Go binaries included"]
    end

    subgraph Runtime["RUNTIME ENVIRONMENT (Kubernetes Cluster)"]
        direction TB

        subgraph DataContainer["odh-model-metadata-collection Container"]
            direction TB
            ContainerInfo["Image: odh-model-metadata-collection-rhel9<br/>User: UID 1001 (non-root)<br/>CMD: sleep infinity<br/>No network listeners"]
            DataVol["/app/data/<br/>Catalog YAML Files"]
            BenchVol["/app/benchmarks/<br/>Benchmark Data"]
        end

        Dashboard["RHOAI Dashboard<br/>(Consumer)"]
    end

    %% Build-time network flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN (optional)"| HF
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| OCI

    %% Build pipeline
    Artifacts -->|"copied into image"| Dockerfile
    Dockerfile -->|"produces"| ContainerInfo

    %% Runtime data access
    DataVol -->|"Volume Mount<br/>Filesystem<br/>No encryption<br/>K8s volume access"| Dashboard

    %% Styling
    classDef buildtime fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e3a5f
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#5a4a00
    classDef build fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#5a3500
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#2d5016
    classDef container fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#1b5e20
    classDef consumer fill:#e1bee7,stroke:#9c27b0,stroke-width:2px,color:#4a148c

    class Extractor,Report,Artifacts buildtime
    class HF,OCI external
    class Dockerfile build
    class ContainerInfo,DataVol,BenchVol container
    class Dashboard consumer
