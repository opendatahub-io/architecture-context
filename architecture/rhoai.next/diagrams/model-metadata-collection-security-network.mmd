graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Pipeline Only)"]
        direction TB

        subgraph CICD["CI/CD Environment"]
            Extractor["model-extractor CLI<br/>Go 1.24+<br/>TLS: Go stdlib default<br/>Max concurrency: 5"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time Egress)"]
        HF["HuggingFace API<br/>huggingface.co<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        RHIR["registry.redhat.io<br/>Red Hat OCI Registry<br/>443/TCP<br/>TLS 1.2+<br/>Public pull"]
        Quay["quay.io<br/>Quay OCI Registry<br/>443/TCP<br/>TLS 1.2+<br/>Public pull"]
    end

    subgraph Runtime["RUNTIME (Production Kubernetes)"]
        direction TB

        subgraph DashboardPod["RHOAI Dashboard Pod"]
            direction LR

            subgraph InitContainer["Init Container / Sidecar"]
                DataContainer["odh-model-metadata-collection<br/>UBI9-minimal<br/>Command: sleep infinity<br/>Ports: NONE<br/>Network: NONE<br/>RBAC: NONE"]
                Volume["/app/data/*.yaml<br/>/app/benchmarks/"]
                DataContainer --- Volume
            end

            subgraph DashboardContainer["Dashboard Container"]
                Dashboard["RHOAI Dashboard<br/>Reads catalog YAML<br/>via shared volume"]
            end

            Volume -->|"Shared Volume<br/>File I/O<br/>No network"| Dashboard
        end
    end

    %% Build-time egress flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)<br/>Collections + Model Details"| HF
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Public Pull<br/>OCI v2 API<br/>Modelcar manifests + layers"| RHIR
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Public Pull<br/>OCI v2 API<br/>MCP server images"| Quay

    %% Build artifacts flow
    Extractor -.->|"Git commit<br/>Generated YAML catalogs"| DataContainer

    %% Styling
    classDef buildtime fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef runtime fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef datacontainer fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    classDef dashboard fill:#a5d6a7,stroke:#2e7d32,stroke-width:2px
    classDef nonetwork fill:#e0e0e0,stroke:#616161,stroke-width:2px,stroke-dasharray: 5 5

    class Extractor buildtime
    class HF,RHIR,Quay external
    class DataContainer,Volume nonetwork
    class Dashboard runtime
