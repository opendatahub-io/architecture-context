graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Pipeline Only)"]
        direction TB
        Extractor["model-extractor<br/>(Go CLI, CGO_ENABLED=0)<br/>Not shipped in final image"]
    end

    subgraph ExternalAPIs["EXTERNAL APIs (Build-Time Egress)"]
        direction TB
        HF["HuggingFace API<br/>huggingface.co<br/>TLS 1.2+"]
        RHIO["OCI Registry<br/>registry.redhat.io<br/>Registry API v2<br/>TLS 1.2+"]
        RHACCESS["OCI Registry<br/>registry.access.redhat.com<br/>Registry API v2<br/>TLS 1.2+"]
    end

    subgraph ContainerBuild["CONTAINER BUILD"]
        direction TB
        Konflux["Konflux Pipeline<br/>hermetic: true<br/>Multi-arch: x86_64, ppc64le,<br/>s390x, arm64"]
        GHA["GitHub Actions<br/>Docker Buildx<br/>Multi-arch: amd64, arm64, ppc64le"]
    end

    subgraph Registry["CONTAINER REGISTRY"]
        QuayRHOAI["quay.io/rhoai/<br/>odh-model-metadata-collection"]
        QuayODH["quay.io/opendatahub/<br/>odh-model-metadata-collection"]
    end

    subgraph Runtime["RUNTIME (On-Cluster) — ZERO NETWORK SURFACE"]
        direction TB
        DataContainer["odh-model-metadata-collection<br/>UBI9-minimal, UID 1001<br/>sleep infinity<br/>No binaries, No ports<br/>No egress, No K8s API"]

        subgraph DataFiles["/app/data (Volume Mount)"]
            Catalogs["models-catalog.yaml<br/>validated-models-catalog.yaml<br/>other-models-catalog.yaml<br/>*-mcp-servers-catalog.yaml"]
        end
    end

    subgraph Consumers["PLATFORM CONSUMERS"]
        Dashboard["RHOAI Dashboard<br/>(Volume Mount Reader)"]
        Operator["rhods-operator<br/>(Deployment Orchestrator)"]
    end

    %% Build-Time Flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| HF
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| RHIO
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public)"| RHACCESS

    %% Container Build Flows
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>Quay credentials"| QuayRHOAI
    GHA -->|"HTTPS/443<br/>TLS 1.2+<br/>Quay credentials"| QuayODH

    %% Runtime Flows (no network)
    DataContainer --- Catalogs
    Dashboard -->|"Volume mount<br/>Shared filesystem<br/>Pod-level RBAC"| Catalogs
    Operator -->|"Deploys"| DataContainer

    %% Styling
    classDef buildtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef containerbuild fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef registry fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef consumer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef data fill:#f5f5f5,stroke:#666

    class Extractor buildtime
    class HF,RHIO,RHACCESS external
    class Konflux,GHA containerbuild
    class QuayRHOAI,QuayODH registry
    class DataContainer runtime
    class Catalogs data
    class Dashboard,Operator consumer
