graph TB
    subgraph External["EXTERNAL SERVICES (Outbound Only)"]
        RHRegistry["registry.redhat.io<br/>OCI Registry API v2<br/>443/TCP, TLS 1.2+<br/>Auth: None (public)"]
        AccessRegistry["registry.access.redhat.com<br/>OCI Registry API v2<br/>443/TCP, TLS 1.2+<br/>Auth: None (public)"]
        HuggingFace["huggingface.co<br/>REST API<br/>443/TCP, TLS 1.2+<br/>Auth: Bearer Token (optional)"]
        Quay["quay.io/rhoai<br/>Container Registry<br/>443/TCP, TLS 1.2+<br/>Auth: Quay credentials"]
    end

    subgraph BuildTime["CI/CD ENVIRONMENT (Build Time Only)"]
        direction TB

        subgraph KonfluxPipeline["Konflux Pipeline (hermetic: true)"]
            Extractor["model-extractor<br/>(Go CLI, build-time only)<br/>NOT in final image<br/>Max concurrency: 5"]
            DockerBuild["Docker Build<br/>(Dockerfile.konflux)<br/>COPY data/*.yaml"]
        end

        subgraph GitHubActions["GitHub Actions (Upstream)"]
            GHBuild["Docker Buildx<br/>Multi-arch:<br/>amd64, arm64, ppc64le"]
        end
    end

    subgraph Cluster["KUBERNETES CLUSTER (Runtime)"]
        direction TB

        subgraph DataPod["Data Container Pod"]
            Container["odh-model-metadata-collection<br/>Image: UBI9-minimal<br/>Entrypoint: sleep infinity<br/>User: UID 1001 (non-root)<br/>No binaries, no ports<br/>No egress, no ingress"]
            DataVol["/app/data<br/>(Catalog YAML files)"]
        end

        subgraph Consumers["Platform Consumers"]
            Dashboard["RHOAI Dashboard<br/>Reads catalog via<br/>volume mount"]
        end

        Operator["rhods-operator<br/>Deploys data container"]
    end

    %% Build-time flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| RHRegistry
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth"| AccessRegistry
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN (optional)"| HuggingFace
    Extractor -->|"generates<br/>catalog YAML"| DockerBuild
    DockerBuild -->|"HTTPS/443<br/>TLS 1.2+<br/>Quay credentials"| Quay
    GHBuild -->|"HTTPS/443<br/>TLS 1.2+<br/>QUAY_USERNAME/PASSWORD"| Quay

    %% Runtime flows (no network!)
    Container --- DataVol
    DataVol -->|"Shared Volume Mount<br/>Filesystem (no network)<br/>Pod-level RBAC"| Dashboard
    Operator -->|"deploys"| Container

    %% Styling
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datacontainer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class RHRegistry,AccessRegistry,HuggingFace,Quay external
    class Extractor,DockerBuild,GHBuild buildtime
    class Container,DataVol datacontainer
    class Dashboard consumer
    class Operator operator
