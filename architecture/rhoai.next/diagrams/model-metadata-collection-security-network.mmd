graph TB
    subgraph BuildEnv["BUILD ENVIRONMENT (CI/CD - Trusted)"]
        direction TB
        Extractor["model-extractor<br/>(Go CLI Tool)<br/>Go 1.24 | CGO_ENABLED=0<br/>No network listener"]
        Reporter["metadata-report<br/>(Go CLI Tool)<br/>No network listener"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Outbound Only - Build Time)"]
        direction TB
        HF_API["HuggingFace API<br/>huggingface.co/api<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        HF_Raw["HuggingFace Raw<br/>huggingface.co/{model}/raw<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        OCI_RH["OCI Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth (public)"]
        OCI_Other["Other OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth (public)"]
    end

    subgraph BuildOutput["BUILD OUTPUT (Artifact Pipeline)"]
        direction TB
        Konflux["Konflux Tekton Pipeline<br/>Auth: git_auth_secret"]
        GitHubCI["GitHub Actions CI<br/>Auth: QUAY_USERNAME/PASSWORD"]
        Quay["quay.io/opendatahub/<br/>odh-model-metadata-collection"]
    end

    subgraph Runtime["RUNTIME (Cluster - No Network)"]
        direction TB

        subgraph DataPod["Data Container Pod"]
            DataContainer["odh-model-metadata-collection<br/>Image: ubi9-minimal<br/>CMD: sleep infinity<br/>No network listeners<br/>No RBAC required"]
            Volume["/app/data/<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>redhat-mcp-servers-catalog.yaml"]
            DataContainer --- Volume
        end

        Dashboard["RHOAI Dashboard<br/>(Volume Mount Consumer)"]
    end

    %% Build-time egress flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)<br/>GET collections, models"| HF_API
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)<br/>GET README"| HF_Raw
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (public)<br/>GET manifests, blobs"| OCI_RH
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (public)<br/>GET image metadata"| OCI_Other

    %% Build pipeline
    Extractor -->|"generates<br/>YAML catalogs"| Konflux
    Extractor -->|"generates<br/>YAML catalogs"| GitHubCI
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds"| Quay
    GitHubCI -->|"HTTPS/443<br/>TLS 1.2+<br/>QUAY creds"| Quay

    %% Runtime (no network)
    Quay -->|"image pull"| DataContainer
    Volume -->|"Volume mount<br/>File I/O<br/>No network"| Dashboard

    %% Styling
    classDef buildenv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildoutput fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef runtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef nonetwork fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Extractor,Reporter buildenv
    class HF_API,HF_Raw,OCI_RH,OCI_Other external
    class Konflux,GitHubCI,Quay buildoutput
    class DataContainer,Volume nonetwork
    class Dashboard consumer
