graph TD
    subgraph "ModelMesh Runtime Adapter - RBAC & Security Model"
        direction TB

        subgraph PodIdentity["Pod Identity"]
            SA["Pod ServiceAccount<br/>(inherited from ModelMesh Serving pod)<br/><br/>No dedicated SA defined<br/>by this component"]
        end

        subgraph RBACNote["RBAC Delegation"]
            Note1["No ClusterRoles defined"]
            Note2["No Roles defined"]
            Note3["No RoleBindings defined"]
            Note4["RBAC managed by parent<br/>ModelMesh Serving deployment"]
        end

        subgraph SecretAccess["Secret Access (Volume Mount)"]
            StorageSecret["storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned by: User/Platform Operator<br/>Auto-Rotate: No"]
        end

        subgraph CredentialTypes["Storage Credential Types"]
            S3Creds["S3 / IBM COS<br/>• access_key_id<br/>• secret_access_key<br/>• region<br/>• endpoint_url"]
            GCSCreds["Google Cloud Storage<br/>• service_account JSON<br/>• project_id"]
            AzureCreds["Azure Blob Storage<br/>• client_id<br/>• client_secret<br/>• tenant_id<br/>• connection_string (alt)"]
            HTTPCreds["HTTP/HTTPS<br/>• certificate (TLS client cert)<br/>• headers (custom auth)"]
        end

        subgraph SecurityControls["Security Controls"]
            CredStrip["Credential Stripping<br/>Puller strips credentials<br/>from LoadModelRequest<br/>before forwarding to<br/>runtime adapter"]
            CacheHash["Cache Security<br/>FNV-64a hash keys<br/>No raw credentials<br/>stored in cache"]
            FIPS["FIPS Compliance<br/>GOEXPERIMENT=strictfipsruntime<br/>CGO_ENABLED=1"]
            BaseImage["Base Image<br/>UBI 9 Minimal<br/>registry.access.redhat.com"]
        end

        subgraph NetworkAuth["Network Authentication"]
            InternalAuth["Internal (localhost)<br/>No auth required<br/>All ports plaintext<br/>8084/TCP, 8085/TCP"]
            ExternalAuth["External (egress)<br/>TLS 1.2+ required<br/>Provider-specific credentials<br/>443/TCP"]
        end

        SA -.->|"no direct RBAC<br/>bindings in this repo"| RBACNote
        SA -->|"volume mount"| StorageSecret
        StorageSecret -->|"provides"| S3Creds
        StorageSecret -->|"provides"| GCSCreds
        StorageSecret -->|"provides"| AzureCreds
        StorageSecret -->|"provides"| HTTPCreds
        CredStrip -->|"protects"| InternalAuth
        CacheHash -->|"secures"| ExternalAuth
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#f9f9f9,stroke:#ccc
    style Note2 fill:#f9f9f9,stroke:#ccc
    style Note3 fill:#f9f9f9,stroke:#ccc
    style Note4 fill:#f9f9f9,stroke:#ccc
    style StorageSecret fill:#f8cecc,stroke:#b85450
    style S3Creds fill:#fff2cc,stroke:#d6b656
    style GCSCreds fill:#fff2cc,stroke:#d6b656
    style AzureCreds fill:#fff2cc,stroke:#d6b656
    style HTTPCreds fill:#fff2cc,stroke:#d6b656
    style CredStrip fill:#d5e8d4,stroke:#82b366
    style CacheHash fill:#d5e8d4,stroke:#82b366
    style FIPS fill:#d5e8d4,stroke:#82b366
    style BaseImage fill:#d5e8d4,stroke:#82b366
    style InternalAuth fill:#dae8fc,stroke:#6c8ebf
    style ExternalAuth fill:#dae8fc,stroke:#6c8ebf
