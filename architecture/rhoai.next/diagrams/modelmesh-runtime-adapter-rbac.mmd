graph TD
    subgraph Legend["RBAC Model"]
        direction TB
        Note["This component defines NO Kubernetes RBAC roles.<br/>It runs as a sidecar container and does not<br/>interact directly with the Kubernetes API.<br/><br/>RBAC is managed by the parent<br/>ModelMesh Serving deployment."]
    end

    subgraph CredentialAccess["Credential Access Model"]
        direction TB

        subgraph SidecarProcess["Sidecar Process (model-serving-puller)"]
            PullerProc["model-serving-puller<br/>(reads credentials at runtime)"]
        end

        subgraph MountedSecret["Mounted Secret Volume"]
            StorageConfig["Secret: storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned by: User / Operator<br/>Auto-rotate: No"]
        end

        subgraph Credentials["Credential Types"]
            S3Creds["S3 Credentials<br/>access_key_id<br/>secret_access_key<br/>endpoint_url<br/>region"]
            AzureCreds["Azure Credentials<br/>client_id<br/>client_secret<br/>tenant_id<br/>(or connection_string)"]
            GCSCreds["GCS Credentials<br/>service_account JSON<br/>private_key<br/>client_email"]
            HTTPCreds["HTTP Credentials<br/>custom headers<br/>client certificate (mTLS)<br/>client key<br/>CA bundle (PEM)"]
        end

        StorageConfig -->|"contains"| S3Creds
        StorageConfig -->|"contains"| AzureCreds
        StorageConfig -->|"contains"| GCSCreds
        StorageConfig -->|"contains"| HTTPCreds
        PullerProc -->|"reads from filesystem"| StorageConfig
    end

    subgraph AuthEndpoints["Authentication by Endpoint"]
        direction TB
        InternalEndpoint["Pod-Internal gRPC<br/>8084/TCP, 8085/TCP<br/>Auth: None<br/>Reason: localhost only"]
        S3Endpoint["S3/MinIO/IBM COS<br/>443/TCP HTTPS<br/>Auth: AWS IAM credentials"]
        AzureEndpoint["Azure Blob<br/>443/TCP HTTPS<br/>Auth: Service Principal"]
        GCSEndpoint["Google Cloud Storage<br/>443/TCP HTTPS<br/>Auth: Service Account JSON"]
        HTTPEndpoint["HTTP/HTTPS Storage<br/>Configurable port<br/>Auth: Custom headers + mTLS certs"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#333
    style StorageConfig fill:#fff2cc,stroke:#d6b656
    style PullerProc fill:#dae8fc,stroke:#6c8ebf
    style S3Creds fill:#f8cecc,stroke:#b85450
    style AzureCreds fill:#f8cecc,stroke:#b85450
    style GCSCreds fill:#f8cecc,stroke:#b85450
    style HTTPCreds fill:#f8cecc,stroke:#b85450
    style InternalEndpoint fill:#d5e8d4,stroke:#82b366
    style S3Endpoint fill:#f8cecc,stroke:#b85450
    style AzureEndpoint fill:#f8cecc,stroke:#b85450
    style GCSEndpoint fill:#f8cecc,stroke:#b85450
    style HTTPEndpoint fill:#f8cecc,stroke:#b85450
