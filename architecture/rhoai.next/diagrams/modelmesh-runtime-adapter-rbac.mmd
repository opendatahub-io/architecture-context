graph TD
    subgraph "Pod Identity"
        SA["Pod ServiceAccount<br/>(inherited from ModelMesh)"]
    end

    subgraph "RBAC Management"
        Note["No RBAC resources defined<br/>in this repository"]
        ParentRBAC["RBAC managed by parent<br/>ModelMesh Serving deployment"]
    end

    subgraph "Authentication Mechanisms"
        direction TB

        subgraph "Pod-Internal (No Auth)"
            PullerAuth["Puller gRPC 8084/TCP<br/>Auth: None<br/>Trust: localhost only"]
            AdapterAuth["Adapter gRPC 8085/TCP<br/>Auth: None<br/>Trust: localhost only"]
            RuntimeAuth["Runtime APIs<br/>Auth: None<br/>Trust: localhost only"]
        end

        subgraph "Cloud Storage Auth (Egress)"
            S3Auth["S3 / IBM COS<br/>Auth: Access Key ID +<br/>Secret Access Key"]
            GCSAuth["Google Cloud Storage<br/>Auth: Service Account<br/>(JSON credentials)"]
            AzureAuth["Azure Blob Storage<br/>Auth: Service Principal<br/>(client_id/client_secret/tenant_id)<br/>or Connection String"]
            HTTPAuth["HTTP/HTTPS Endpoints<br/>Auth: Optional headers<br/>/ mTLS client certs"]
        end
    end

    subgraph "Secrets & Credentials"
        StorageSecret["storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned by: User/Platform operator<br/>Auto-rotate: No"]
    end

    subgraph "Security Controls"
        CredStrip["Credential Stripping<br/>Credentials removed from<br/>LoadModel request before<br/>forwarding to runtime adapter"]
        CacheHash["Cache Key Hashing<br/>FNV-64a hash of credentials<br/>for pullman cache keys<br/>(no raw creds in memory)"]
        PathSanit["Path Sanitization<br/>Directory traversal prevention<br/>via path joining validation"]
        FIPS["FIPS Compliance<br/>GOEXPERIMENT=strictfipsruntime<br/>CGO_ENABLED=1"]
    end

    SA -->|"identity for"| Note
    Note -->|"delegated to"| ParentRBAC
    StorageSecret -->|"credentials for"| S3Auth
    StorageSecret -->|"credentials for"| GCSAuth
    StorageSecret -->|"credentials for"| AzureAuth
    StorageSecret -->|"credentials for"| HTTPAuth

    style SA fill:#4a90e2,color:#fff
    style Note fill:#f5a623,color:#fff
    style ParentRBAC fill:#f5a623,color:#fff
    style StorageSecret fill:#e74c3c,color:#fff
    style PullerAuth fill:#d5e8d4,stroke:#82b366
    style AdapterAuth fill:#d5e8d4,stroke:#82b366
    style RuntimeAuth fill:#d5e8d4,stroke:#82b366
    style S3Auth fill:#fff2cc,stroke:#d6b656
    style GCSAuth fill:#fff2cc,stroke:#d6b656
    style AzureAuth fill:#fff2cc,stroke:#d6b656
    style HTTPAuth fill:#fff2cc,stroke:#d6b656
    style CredStrip fill:#e1d5e7,stroke:#9673a6
    style CacheHash fill:#e1d5e7,stroke:#9673a6
    style PathSanit fill:#e1d5e7,stroke:#9673a6
    style FIPS fill:#e1d5e7,stroke:#9673a6
