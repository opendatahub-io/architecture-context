graph TD
    subgraph "Component: ModelMesh Runtime Adapter"
        Note["No Kubernetes RBAC Required<br/><br/>This component runs as a sidecar container<br/>and does not interact with the Kubernetes API.<br/>No ClusterRoles, Roles, or RoleBindings are defined."]
    end

    subgraph "Authentication & Authorization"
        direction TB

        subgraph "Pod-Internal (No Auth)"
            PullerEP["mmesh.ModelRuntime gRPC<br/>:8084/TCP<br/>Auth: None (pod-internal)<br/>Trusted localhost"]
            AdapterEP["mmesh.ModelRuntime gRPC<br/>:8085/TCP<br/>Auth: None (pod-internal)<br/>Trusted localhost"]
        end

        subgraph "Cloud Storage Auth (via storage-config Secret)"
            S3Auth["S3 / IBM COS<br/>Auth: access_key_id +<br/>secret_access_key<br/>IAM/RBAC at provider"]
            GCSAuth["Google Cloud Storage<br/>Auth: Service Account<br/>(private_key + client_email)<br/>IAM at GCP"]
            AzureAuth["Azure Blob Storage<br/>Auth: Service Principal<br/>(client_id + client_secret +<br/>tenant_id) OR connection_string"]
            HTTPAuth["HTTP/HTTPS Server<br/>Auth: Custom headers<br/>OR mTLS client certificate<br/>(client_certificate + client_key)"]
        end
    end

    subgraph "Secrets Management"
        StorageSecret["storage-config Secret<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned: User/Admin<br/>Auto-Rotate: No"]
    end

    StorageSecret -->|"provides credentials"| S3Auth
    StorageSecret -->|"provides credentials"| GCSAuth
    StorageSecret -->|"provides credentials"| AzureAuth
    StorageSecret -->|"provides credentials"| HTTPAuth

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style PullerEP fill:#d4edda,stroke:#155724
    style AdapterEP fill:#d4edda,stroke:#155724
