graph TD
    subgraph Component["modelmesh-runtime-adapter"]
        MRA["modelmesh-runtime-adapter<br/>(Sidecar Container)<br/>No direct K8s API access"]
    end

    subgraph NoRBAC["RBAC Status: None Required"]
        direction TB
        Note1["This component runs as a sidecar container<br/>within ModelMesh Serving pods"]
        Note2["It does NOT interact with the<br/>Kubernetes API server directly"]
        Note3["No ClusterRoles, Roles,<br/>or RoleBindings defined"]
    end

    subgraph CredentialAccess["Credential Access (Non-RBAC)"]
        direction TB

        subgraph SecretMount["Volume Mount: /storage-config"]
            StorageSecret["storage-config Secret (Opaque)<br/>Mounted as files by kubelet"]
        end

        subgraph Credentials["Credential Types"]
            S3Creds["S3 Credentials<br/>access_key_id<br/>secret_access_key<br/>region, bucket, endpoint_url"]
            GCSCreds["GCS Credentials<br/>private_key<br/>client_email<br/>project_id, bucket"]
            AzureCreds["Azure Credentials<br/>client_id<br/>client_secret<br/>tenant_id, container_name"]
            HTTPCreds["HTTP Credentials<br/>custom_headers<br/>client_certificate<br/>client_key, ca_certificate"]
        end

        StorageSecret --> S3Creds
        StorageSecret --> GCSCreds
        StorageSecret --> AzureCreds
        StorageSecret --> HTTPCreds
    end

    subgraph ParentPodRBAC["Parent Pod RBAC (inherited context)"]
        SA["ServiceAccount<br/>(defined by ModelMesh Serving pod)"]
        Note4["The parent pod's ServiceAccount<br/>determines K8s API access.<br/>The adapter sidecar inherits this SA<br/>but does not use it."]
    end

    MRA -.->|"reads credentials<br/>via filesystem"| StorageSecret
    MRA -.->|"inherits but<br/>does not use"| SA

    %% Styling
    style MRA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Note1 fill:#fff,stroke:#999
    style Note2 fill:#fff,stroke:#999
    style Note3 fill:#fff,stroke:#999
    style Note4 fill:#fff,stroke:#999
    style StorageSecret fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#ffe6cc,stroke:#d79b00
    style GCSCreds fill:#ffe6cc,stroke:#d79b00
    style AzureCreds fill:#ffe6cc,stroke:#d79b00
    style HTTPCreds fill:#ffe6cc,stroke:#d79b00
    style SA fill:#d5e8d4,stroke:#82b366
