graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Component has NO Kubernetes RBAC"]
        L2["Runs as sidecar — inherits pod SA"]
    end

    subgraph PodIdentity["Pod Identity (Inherited)"]
        SA["ServiceAccount<br/>(inherited from parent<br/>ModelMesh deployment)"]
    end

    subgraph SidecarContainers["Sidecar Containers (No K8s API Access)"]
        Puller["model-serving-puller<br/>No RBAC required<br/>No K8s API calls"]
        Adapter["runtime-adapter<br/>(triton/mlserver/ovms/torchserve)<br/>No RBAC required<br/>No K8s API calls"]
    end

    subgraph SecretAccess["Secret Access (Volume Mount — Not RBAC)"]
        StorageConfig["Secret: storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned by: User / modelmesh-serving"]
    end

    subgraph SecretContents["Storage Credentials in Secret"]
        S3Creds["S3 Credentials<br/>access_key_id<br/>secret_access_key<br/>endpoint_url, region, bucket"]
        GCSCreds["GCS Credentials<br/>service_account JSON<br/>(private_key, client_email, token_uri)"]
        AzureCreds["Azure Credentials<br/>client_id, client_secret, tenant_id<br/>OR connection_string"]
        HTTPCreds["HTTP Credentials<br/>custom headers<br/>CA cert PEM<br/>client cert/key PEM (mTLS)"]
    end

    SA -->|"pod-level SA<br/>(not used by sidecar)"| Puller
    SA -->|"pod-level SA<br/>(not used by sidecar)"| Adapter
    StorageConfig -->|"volume mount<br/>/storage-config"| Puller
    StorageConfig --> S3Creds
    StorageConfig --> GCSCreds
    StorageConfig --> AzureCreds
    StorageConfig --> HTTPCreds

    subgraph Notes["Security Notes"]
        N1["No ClusterRole or ClusterRoleBinding"]
        N2["No Role or RoleBinding"]
        N3["No PeerAuthentication or AuthorizationPolicy"]
        N4["No NetworkPolicy defined by this component"]
        N5["FIPS: GOEXPERIMENT=strictfipsruntime<br/>CGO_ENABLED=1, dynamic linking via OpenSSL"]
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Puller fill:#7ed321,stroke:#333,color:#fff
    style Adapter fill:#7ed321,stroke:#333,color:#fff
    style StorageConfig fill:#f5a623,stroke:#333,color:#fff
    style S3Creds fill:#f8e71c,stroke:#333
    style GCSCreds fill:#f8e71c,stroke:#333
    style AzureCreds fill:#f8e71c,stroke:#333
    style HTTPCreds fill:#f8e71c,stroke:#333
    style N1 fill:#ffcccc,stroke:#cc0000
    style N2 fill:#ffcccc,stroke:#cc0000
    style N3 fill:#ffcccc,stroke:#cc0000
    style N4 fill:#ffcccc,stroke:#cc0000
    style N5 fill:#d5e8d4,stroke:#82b366
    style L1 fill:#fff2cc,stroke:#d6b656
