graph TD
    subgraph Component["ModelMesh Runtime Adapter"]
        MRA["modelmesh-runtime-adapter<br/>(sidecar container)"]
    end

    subgraph RBAC["Kubernetes RBAC"]
        NoRBAC["No ClusterRoles<br/>No RoleBindings<br/>No ServiceAccount RBAC<br/><br/>Component does not interact<br/>with the Kubernetes API"]
    end

    subgraph Secrets["Secret Access"]
        StorageConfig["storage-config<br/>Type: Opaque<br/>Mount: /storage-config<br/>Provisioned By: User/Admin<br/>Auto-Rotate: No"]
    end

    subgraph SecretFields["Secret Fields by Provider"]
        S3Fields["S3 / IBM COS:<br/>- type<br/>- access_key_id<br/>- secret_access_key<br/>- endpoint_url<br/>- region<br/>- default_bucket<br/>- certificate (CA bundle)"]
        GCSFields["GCS:<br/>- type<br/>- service_account JSON<br/>  (private_key, client_email)"]
        AzureFields["Azure:<br/>- type<br/>- client_id<br/>- client_secret<br/>- tenant_id<br/>- container_name<br/>  (or connection_string)"]
        HTTPFields["HTTP:<br/>- type<br/>- headers (custom)<br/>- client_certificate<br/>- client_key<br/>- certificate (CA bundle)"]
    end

    subgraph FIPSCompliance["FIPS Compliance"]
        FIPS["Build Flags:<br/>GOEXPERIMENT=strictfipsruntime<br/>CGO_ENABLED=1<br/>-tags strictfipsruntime<br/><br/>Linking: Dynamic (OpenSSL)<br/>Base Image: UBI 9 minimal<br/>No non-FIPS crypto detected"]
    end

    MRA -->|"no K8s API access"| NoRBAC
    MRA -->|"filesystem mount<br/>read at model load time"| StorageConfig
    StorageConfig --> S3Fields
    StorageConfig --> GCSFields
    StorageConfig --> AzureFields
    StorageConfig --> HTTPFields
    MRA -->|"crypto compliance"| FIPS

