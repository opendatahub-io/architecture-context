graph TD
    subgraph PodSecurity["Pod Security Context"]
        direction TB
        Pod["Model Server Pod<br/>(managed by ModelMesh Controller)"]
    end

    subgraph Sidecars["Sidecar Containers (No K8s API Access)"]
        direction TB
        PullerContainer["model-serving-puller<br/>8084/TCP gRPC<br/>No ServiceAccount API calls"]
        AdapterContainer["runtime-adapter<br/>8085/TCP gRPC<br/>No ServiceAccount API calls"]
    end

    subgraph SecretAccess["Secret Access (Volume Mount Only)"]
        direction TB
        StorageSecret["storage-config Secret<br/>Type: Opaque<br/>Mount: /storage-config"]

        subgraph S3Creds["S3/IBM COS Credentials"]
            S3Key["access_key_id"]
            S3Secret["secret_access_key"]
            S3Endpoint["endpoint_url"]
            S3Region["region"]
            S3Bucket["default_bucket"]
            S3Cert["certificate (optional CA)"]
        end

        subgraph GCSCreds["GCS Credentials"]
            GCSKey["private_key"]
            GCSEmail["client_email"]
            GCSProject["project_id"]
        end

        subgraph AzureCreds["Azure Credentials"]
            AzClientId["client_id"]
            AzClientSecret["client_secret"]
            AzTenantId["tenant_id"]
            AzConnStr["connection_string (alt)"]
        end

        subgraph HTTPCreds["HTTP Credentials"]
            HTTPHeaders["custom headers"]
            HTTPCert["client_certificate"]
            HTTPKey["client_key"]
        end

        StorageSecret --> S3Creds
        StorageSecret --> GCSCreds
        StorageSecret --> AzureCreds
        StorageSecret --> HTTPCreds
    end

    subgraph FIPSCompliance["FIPS Compliance"]
        FIPS["Build Flags:<br/>GOEXPERIMENT=strictfipsruntime<br/>CGO_ENABLED=1<br/>-tags strictfipsruntime<br/>Dynamic linking to OpenSSL<br/>UBI 9 base image"]
    end

    subgraph PathSecurity["Path Traversal Protection"]
        SecureJoin["cyphar/filepath-securejoin v0.2.4<br/>All storage providers<br/>Prevents escape from /models root"]
    end

    Pod --> PullerContainer
    Pod --> AdapterContainer
    PullerContainer -->|"reads credentials<br/>at model load time"| StorageSecret
    AdapterContainer -.->|"reads credentials<br/>(embedded puller mode)"| StorageSecret

    PullerContainer --> FIPSCompliance
    AdapterContainer --> FIPSCompliance
    PullerContainer --> PathSecurity
    AdapterContainer --> PathSecurity

    Note1["NOTE: This component has NO ClusterRoles,<br/>RoleBindings, or ServiceAccount API permissions.<br/>It runs as a sidecar and does NOT interact<br/>with the Kubernetes API server."]

    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style PullerContainer fill:#5ba3f5,stroke:#333,color:#fff
    style AdapterContainer fill:#5ba3f5,stroke:#333,color:#fff
