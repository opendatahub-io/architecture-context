graph LR
    PC["Pipelines Components<br/>(KFP Component Library)"]

    %% Internal RHOAI Dependencies
    PC -->|"volume mount<br/>(init container)"| KFPServer["KFP API Server"]
    PC -->|"CRD create/patch/delete<br/>ServingRuntime,<br/>InferenceService"| KServe["KServe"]
    PC -->|"REST API<br/>8080/TCP HTTP"| ModelRegistry["Model Registry"]
    PC -->|"REST API<br/>443/TCP HTTPS"| EvalHub["Eval Hub"]
    PC -->|"CRD create<br/>RayJob"| KubeRay["KubeRay Operator"]
    PC -->|"CRD read<br/>ClusterTrainingRuntime"| TrainingOp["Training Operator"]
    PC -->|"CRD read<br/>HardwareProfile"| HWProfile["HardwareProfile CRD"]
    PC -.->|"optional<br/>Queue labels"| Kueue["Kueue"]

    %% External Dependencies (Libraries)
    PC -->|"pipeline SDK<br/>>=2.16.1"| KFP["KFP SDK (kfp)"]
    PC -->|"K8s extensions<br/>>=2.16.1"| KFPk8s["kfp-kubernetes"]
    PC -->|"AutoML training<br/>1.5.0+"| AutoGluon["AutoGluon"]
    PC -->|"RAG optimization<br/>~=0.6.4"| AI4RAG["ai4rag"]
    PC -->|"doc extraction<br/>>=2.88.0"| Docling["Docling"]
    PC -->|"deep learning<br/>>=2.11.0"| PyTorch["PyTorch"]
    PC -->|"LLM evaluation<br/>>=0.4.0"| LMEval["lm-eval"]

    %% External Services
    PC -->|"datasets/models<br/>HTTPS/443"| S3["S3 Storage"]
    PC -->|"model downloads<br/>HTTPS/443"| HF["HuggingFace Hub"]
    PC -->|"vector store<br/>HTTPS/443"| OGX["OGX API"]
    PC -->|"vector ingestion<br/>gRPC/19530"| Milvus["Milvus"]
    PC -->|"SDG backend<br/>HTTPS/443"| LLMAPI["LLM API"]
    PC -->|"K8s CRD ops<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]

    %% Components that consume pipelines-components
    Dashboard["ODH Dashboard"] -->|"UI management"| PC
    DSPipelines["Data Science Pipelines<br/>Operator"] -->|"deploys managed<br/>pipelines"| PC

    %% Optional dependencies
    PC -.->|"optional metrics<br/>HTTPS/443"| WandB["W&B"]
    PC -.->|"optional tracking<br/>HTTPS/443"| MLflow["MLflow"]
    PC -.->|"optional distributed<br/>processing"| CodeFlare["codeflare-sdk"]

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI - green
    style KFPServer fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style KubeRay fill:#7ed321,stroke:#333,color:#fff
    style TrainingOp fill:#7ed321,stroke:#333,color:#fff
    style HWProfile fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style DSPipelines fill:#7ed321,stroke:#333,color:#fff

    %% External libraries - light blue
    style KFP fill:#b3d9ff,stroke:#333
    style KFPk8s fill:#b3d9ff,stroke:#333
    style AutoGluon fill:#b3d9ff,stroke:#333
    style AI4RAG fill:#b3d9ff,stroke:#333
    style Docling fill:#b3d9ff,stroke:#333
    style PyTorch fill:#b3d9ff,stroke:#333
    style LMEval fill:#b3d9ff,stroke:#333

