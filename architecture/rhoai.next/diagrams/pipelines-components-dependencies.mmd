graph LR
    PC["Pipelines Components<br/>(KFP Component Library +<br/>Init Container + Runtime Images)"]

    %% External Dependencies (required libraries)
    PC -->|"KFP DSL + compiler"| KFP["kfp >=2.16.1"]
    PC -->|"K8s extensions<br/>(secrets, PVCs, GPU)"| KFPK8s["kfp-kubernetes >=2.16.1"]
    PC -->|"pipeline spec<br/>serialization"| Protobuf["protobuf <6.32"]
    PC -->|"TLS/SSL support"| Crypto["cryptography 49.0.0"]
    PC -->|"S3 client"| Boto3["boto3"]
    PC -->|"K8s API client"| K8sClient["kubernetes >=28.1.0"]

    %% Bundled in AutoML image
    PC -->|"tabular + timeseries<br/>AutoML training"| AutoGluon["AutoGluon<br/>(bundled in odh-automl)"]

    %% Bundled in AutoRAG image
    PC -->|"RAG optimization"| AI4RAG["AI4RAG<br/>(bundled in odh-autorag)"]
    PC -->|"embedding, vector<br/>store, LLM API"| OGXClient["OGX Client<br/>(bundled in odh-autorag)"]
    PC -->|"PDF/DOCX/PPTX<br/>text extraction"| Docling["Docling<br/>(bundled in odh-autorag)"]

    %% Optional / bundled in training images
    PC -.->|"model registration<br/>(optional)"| ModelRegSDK["model-registry 0.3.4"]
    PC -->|"SFT training<br/>backend"| InstructLab["instructlab-training<br/>(bundled in training image)"]
    PC -->|"LLM evaluation<br/>harness"| LMEval["lm-eval<br/>(bundled in training image)"]
    PC -->|"LLM inference<br/>engine"| vLLM["vLLM<br/>(bundled in training/eval images)"]

    %% Internal Platform Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"runs init container<br/>deploys KFP API"| PC
    PC -->|"creates CRDs<br/>InferenceService<br/>ServingRuntime"| KServe["KServe"]
    PC -->|"pipeline submission<br/>SDK"| KFPAPI["KFP API Server"]
    PC -->|"vector DB<br/>19530/TCP gRPC"| Milvus["Milvus"]
    PC -->|"submits RayJob<br/>CRDs"| RayOp["Ray Operator"]
    PC -.->|"optional queue<br/>management"| Kueue["Kueue"]
    PC -.->|"GPU resource<br/>annotation"| HWProfile["HardwareProfile CRD"]
    PC -->|"evaluation jobs<br/>443/TCP HTTPS"| EvalHub["Eval Hub"]
    PC -->|"model registration<br/>80/TCP HTTP"| ModelReg["Model Registry"]
    PC -->|"training jobs<br/>ClusterTrainingRuntime"| KFTrainer["Kubeflow Trainer"]

    %% External Services
    PC -->|"model/dataset downloads<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]
    PC -->|"data + artifacts<br/>443/TCP HTTPS"| S3["S3 Storage"]
    PC -->|"embedding, vector,<br/>LLM inference<br/>443/TCP HTTPS"| OGXAPI["OGX API"]
    PC -->|"synthetic data gen<br/>443/TCP HTTPS"| LiteLLM["LLM Endpoint<br/>(LiteLLM)"]

    %% Integration Points (other components integrating with PC)
    ODHDash["ODH Dashboard"] -.->|"pipeline mgmt UI"| PC

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External library dependencies
    style KFP fill:#e8e8e8,stroke:#333
    style KFPK8s fill:#e8e8e8,stroke:#333
    style Protobuf fill:#e8e8e8,stroke:#333
    style Crypto fill:#e8e8e8,stroke:#333
    style Boto3 fill:#e8e8e8,stroke:#333
    style K8sClient fill:#e8e8e8,stroke:#333

    %% Bundled dependencies
    style AutoGluon fill:#dae8fc,stroke:#6c8ebf
    style AI4RAG fill:#dae8fc,stroke:#6c8ebf
    style OGXClient fill:#dae8fc,stroke:#6c8ebf
    style Docling fill:#dae8fc,stroke:#6c8ebf
    style InstructLab fill:#dae8fc,stroke:#6c8ebf
    style LMEval fill:#dae8fc,stroke:#6c8ebf
    style vLLM fill:#dae8fc,stroke:#6c8ebf
    style ModelRegSDK fill:#dae8fc,stroke:#6c8ebf

    %% Internal platform dependencies (green)
    style DSPO fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style KFPAPI fill:#7ed321,stroke:#333
    style Milvus fill:#7ed321,stroke:#333
    style RayOp fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style HWProfile fill:#7ed321,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333
    style ModelReg fill:#7ed321,stroke:#333
    style KFTrainer fill:#7ed321,stroke:#333
    style ODHDash fill:#7ed321,stroke:#333

    %% External services (orange)
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OGXAPI fill:#f5a623,stroke:#333
    style LiteLLM fill:#f5a623,stroke:#333
