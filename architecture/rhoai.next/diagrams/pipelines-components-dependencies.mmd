graph LR
    PC["Pipelines Components<br/>(KFP Component Library)"]

    %% ============================================
    %% External Dependencies (Python Libraries)
    %% ============================================
    PC -->|"pipeline SDK"| KFP["kfp >=2.16.1"]
    PC -->|"K8s extensions"| KFPK8s["kfp-kubernetes >=2.16.1"]
    PC -->|"S3 access"| Boto3["boto3 >=1.42.34"]
    PC -->|"tabular/TS ML"| AutoGluon["AutoGluon<br/>(bundled in odh-automl)"]
    PC -->|"RAG optimization"| AI4RAG["ai4rag ~=0.6.1"]
    PC -->|"doc extraction"| Docling["docling >=1.0.0"]
    PC -->|"embeddings/vectors"| OGXClient["OGX Client >=1.0.0"]
    PC -->|"synthetic data"| SDGHub["sdg-hub >=0.7.0, <1.0"]
    PC -->|"LLM proxy"| LiteLLM["LiteLLM >=1.0.0"]
    PC -->|"model eval"| LMEval["lm-eval<br/>(with vllm extra)"]
    PC -->|"model registry SDK"| ModelRegSDK["model-registry ==0.3.4"]
    PC -->|"datasets"| HFDatasets["HF Datasets >=2.14.0"]
    PC -->|"hub client"| HFHub["huggingface-hub >=0.20.0"]
    PC -->|"data manipulation"| Pandas["pandas >=2.0"]
    PC -->|"text chunking"| LangChain["langchain-core >=0.1"]
    PC -->|"LoRA training"| Unsloth["Unsloth<br/>(bundled)"]
    PC -->|"stratified split"| SKLearn["scikit-learn >=1.0"]

    %% ============================================
    %% Internal Platform Dependencies
    %% ============================================
    PC -->|"pipeline YAML delivery<br/>(init container shared vol)"| KFPAPI["KFP API Server"]
    PC -->|"model registration<br/>REST 8080/TCP"| KFModelReg["Kubeflow Model Registry"]
    PC -->|"fine-tuning jobs<br/>TrainJob CRD"| KFTrainer["Kubeflow Trainer"]
    PC -->|"data/model storage<br/>HTTPS 443/TCP"| S3["S3 Storage<br/>(MinIO / Ceph)"]
    PC -->|"workspace sharing<br/>filesystem"| PVC["PersistentVolumeClaim"]
    PC -->|"embeddings + vectors<br/>HTTPS 443/TCP"| OGXAPI["OGX API (RHOAI)"]
    PC -->|"credentials<br/>vol/env mount"| K8sSecrets["Kubernetes Secrets"]

    %% ============================================
    %% Integration Points (inbound)
    %% ============================================
    Dashboard["ODH Dashboard"] -.->|"pipeline mgmt UI"| PC
    DSPA["DS Pipelines Application"] -.->|"deploys init container"| PC
    Operator["rhods-operator"] -.->|"RELATED_IMAGE_* injection"| PC

    %% ============================================
    %% External Services
    %% ============================================
    PC -->|"model/dataset download<br/>HTTPS 443/TCP"| HFHubSvc["HuggingFace Hub<br/>(huggingface.co)"]
    OGXAPI -->|"vector persistence<br/>gRPC 19530/TCP"| MilvusSvc["Milvus Vector DB"]
    PC -->|"synthetic data gen<br/>HTTPS 443/TCP"| LLMProviderSvc["LLM Provider<br/>(via LiteLLM)"]

    %% ============================================
    %% Styling
    %% ============================================
