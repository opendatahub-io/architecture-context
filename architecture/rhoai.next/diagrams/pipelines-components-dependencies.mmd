graph LR
    PC["pipelines-components<br/>(KFP Component Library)"]

    %% ──────────────────────────────────────────────
    %% Internal RHOAI Platform Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"shared volume<br/>(init container)"| KFPServer["KFP API Server"]
    PC -->|"REST API<br/>HTTP/8080"| ModelReg["Kubeflow Model Registry"]
    PC -->|"K8s API<br/>HTTPS/443"| Trainer["Kubeflow Trainer<br/>(ClusterTrainingRuntime)"]
    PC -->|"K8s Secrets<br/>env injection"| Connections["RHOAI Connections API"]
    PC -->|"REST API<br/>HTTP(S)"| LlamaStack["Llama Stack"]
    PC -.->|"filesystem<br/>50Gi RWX / 12Gi RWO"| PVC["PVC Workspace"]

    %% ──────────────────────────────────────────────
    %% External Service Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"REST API<br/>HTTPS/443"| S3["AWS S3"]
    PC -->|"REST API<br/>HTTPS/443"| HF["HuggingFace Hub"]
    PC -->|"REST API<br/>HTTPS/configurable"| LLMAPI["OpenAI-compatible<br/>LLM Endpoints"]
    PC -->|"HTTPS/443"| K8sAPI["Kubernetes API"]

    %% ──────────────────────────────────────────────
    %% Core Framework Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"pipeline SDK"| KFP["kfp >=2.15.2"]
    PC -->|"K8s extensions"| KFPK8s["kfp-kubernetes >=2.15.2"]
    PC -->|"S3 client"| Boto3["boto3"]
    PC -->|"deep learning"| PyTorch["torch"]
    PC -->|"tokenization"| Transformers["transformers"]
    PC -->|"datasets"| Datasets["datasets (HuggingFace)"]

    %% ──────────────────────────────────────────────
    %% AutoML Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"AutoML training"| AutoGluon["AutoGluon"]

    %% ──────────────────────────────────────────────
    %% AutoRAG Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"RAG optimization"| ai4rag["ai4rag >=1.0.0"]
    PC -->|"text extraction"| Docling["Docling"]
    PC -->|"Llama Stack client"| LSClient["llama-stack-client"]

    %% ──────────────────────────────────────────────
    %% Training Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"LoRA fine-tuning"| Unsloth["unsloth >=2024.11.0"]
    PC -->|"SFT/OSFT training"| ILab["instructlab-training"]
    PC -->|"distributed training"| KFTrainer["kubeflow-trainer >=0.1.0"]
    PC -->|"OCI model artifacts"| OLOT["olot"]

    %% ──────────────────────────────────────────────
    %% Evaluation Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"LLM benchmarks"| LMEval["lm-eval >=0.4.0"]
    PC -->|"GPU inference"| vLLM["vLLM >=0.4.0"]

    %% ──────────────────────────────────────────────
    %% SDG Dependencies
    %% ──────────────────────────────────────────────
    PC -->|"data generation"| SDGHub["sdg-hub >=0.7.0"]

    %% ──────────────────────────────────────────────
    %% Integration Points (inbound)
    %% ──────────────────────────────────────────────
    ArgoWF["Argo Workflows"] -->|"orchestrates steps"| PC

    %% ──────────────────────────────────────────────
    %% Styling
    %% ──────────────────────────────────────────────
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KFPServer fill:#7ed321,stroke:#333,color:#fff
    style ModelReg fill:#7ed321,stroke:#333,color:#fff
    style Trainer fill:#7ed321,stroke:#333,color:#fff
