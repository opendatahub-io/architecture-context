graph LR
    PC["pipelines-components<br/>(KFP Component Library)"]

    %% Internal RHOAI Dependencies
    PC -->|"shared volume<br/>init container"| KFPServer["KFP API Server"]
    PC -->|"HTTP/8080<br/>model registration"| ModelRegistry["Kubeflow Model Registry"]
    PC -->|"HTTPS/443<br/>TrainingJob CR"| Trainer["Kubeflow Trainer<br/>(ClusterTrainingRuntime)"]
    PC -->|"K8s Secrets<br/>credentials"| RHOAIConn["RHOAI Connections API"]
    PC -->|"HTTP/HTTPS<br/>vector store + inference"| LlamaStack["Llama Stack"]
    PC -.->|"filesystem<br/>checkpoints"| PVC["PVC Workspace<br/>(RWX/RWO)"]

    %% External Service Dependencies
    PC -->|"HTTPS/443<br/>AWS IAM"| S3["AWS S3"]
    PC -->|"HTTPS/443<br/>HF_TOKEN"| HFHub["HuggingFace Hub"]
    PC -->|"HTTPS<br/>API key"| LLMAPI["LLM API / OpenAI-compat"]
    PC -->|"HTTPS/443<br/>SA token"| K8sAPI["Kubernetes API"]

    %% Library Dependencies
    PC -.->|"core SDK"| KFP["kfp >=2.15.2"]
    PC -.->|"K8s extensions"| KFPKube["kfp-kubernetes >=2.15.2"]
    PC -.->|"S3 client"| Boto3["boto3"]
    PC -.->|"AutoML training"| AutoGluon["AutoGluon"]
    PC -.->|"RAG optimization"| ai4rag["ai4rag >=1.0.0"]
    PC -.->|"text extraction"| DoclingLib["Docling"]
    PC -.->|"Llama Stack SDK"| LSClient["llama-stack-client"]
    PC -.->|"LLM evaluation"| LMEval["lm-eval >=0.4.0"]
    PC -.->|"GPU inference"| vLLMLib["vLLM >=0.4.0"]
    PC -.->|"model registry SDK"| MRClient["model-registry 0.3.4"]
    PC -.->|"dataset loading"| HFDatasets["datasets >=2.14.0"]
    PC -.->|"distributed training"| KFTrainer["kubeflow-trainer >=0.1.0"]
    PC -.->|"SDG engine"| SDGHub["sdg-hub >=0.7.0"]
    PC -.->|"deep learning"| PyTorch["torch"]
    PC -.->|"tokenization"| Transformers["transformers"]
    PC -.->|"LoRA fine-tuning"| Unsloth["unsloth >=2024.11.0"]
    PC -.->|"SFT training"| ILabTraining["instructlab-training"]
    PC -.->|"OCI artifacts"| OLOT["olot"]

    %% Consumers / Integrators
    Dashboard["ODH Dashboard"] -.->|"UI pipeline mgmt"| PC
    DSPipelines["Data Science Pipelines"] -.->|"orchestration"| PC

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style KFPServer fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
