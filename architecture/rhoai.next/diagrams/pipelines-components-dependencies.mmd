graph LR
    PC["Pipelines Components<br/>(KFP v2 Library + Init Container)"]

    %% External Dependencies (Required)
    PC -->|"pipeline framework<br/>kfp >=2.15.2"| KFP["Kubeflow Pipelines SDK<br/>(kfp)"]
    PC -->|"K8s integration<br/>kfp-kubernetes >=2.15.2"| KFPk8s["kfp-kubernetes"]
    PC -->|"model training<br/>v1.5.0+rhaiv.2"| AutoGluon["AutoGluon<br/>(tabular, timeseries)"]
    PC -->|"deep learning<br/>v2.10.0"| PyTorch["PyTorch"]
    PC -->|"document extraction<br/>v2.73.1"| Docling["Docling"]
    PC -->|"RAG framework<br/>v1.1.3"| LangChain["LangChain"]
    PC -->|"vector database<br/>v1.5.5"| ChromaDB["ChromaDB"]
    PC -->|"RAG optimization<br/>v0.5.4"| ai4rag["ai4rag"]
    PC -->|"LLM client<br/>v0.7.1"| LlamaClient["Llama Stack Client"]
    PC -->|"synthetic data<br/>>=0.7.0"| SDGHub["SDG Hub"]
    PC -->|"LLM evaluation"| LMEval["lm-eval Harness"]
    PC -->|"training backends"| TrainingHub["training_hub<br/>(unsloth, mini-trainer,<br/>instructlab)"]
    PC -->|"tokenization<br/>v4.57.6"| Transformers["transformers<br/>(Hugging Face)"]

    %% Internal Platform Dependencies
    PC -->|"shared volume<br/>(filesystem)"| KFPServer["KFP API Server"]
    PC -->|"pipeline execution<br/>HTTPS/443"| DSPA["DSPA<br/>(Data Science Pipelines)"]
    PC -->|"model registration<br/>REST/443"| ModelRegistry["Kubeflow Model<br/>Registry"]
    PC -->|"embeddings + inference<br/>REST/443"| LlamaStack["Llama Stack"]

    %% External Services
    PC -->|"dataset/model storage<br/>S3 API/443"| S3["S3-Compatible Storage<br/>(MinIO/Ceph/AWS)"]
    PC -->|"model downloads<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    PC -->|"secret reads, PVCs<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]
    PC -->|"model artifacts<br/>OCI/443"| OCIRegistry["OCI Container<br/>Registry"]

    %% Optional Dependencies
    PC -.->|"inference (optional)<br/>v2.23.0"| OpenAI["OpenAI SDK"]
    PC -.->|"experiment tracking<br/>(optional)"| WandB["W&B / MLflow /<br/>TensorBoard"]
    PC -.->|"testing (optional)"| Boto3["boto3"]

    %% Build Dependencies
    PC -->|"container builds<br/>Tekton"| Konflux["Konflux Build System"]
    Konflux -->|"Python deps<br/>HTTPS/443"| PyPIMirror["Red Hat PyPI Mirror"]

    %% Consumers
    Dashboard["ODH Dashboard"] -.->|"pipeline UI"| PC
    Notebooks["Jupyter Notebooks"] -.->|"import kfp-components<br/>Python package"| PC

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External libraries
    style KFP fill:#999,stroke:#333
    style KFPk8s fill:#999,stroke:#333
    style AutoGluon fill:#999,stroke:#333
    style PyTorch fill:#999,stroke:#333
    style Docling fill:#999,stroke:#333
    style LangChain fill:#999,stroke:#333
    style ChromaDB fill:#999,stroke:#333
    style ai4rag fill:#999,stroke:#333
    style LlamaClient fill:#999,stroke:#333
    style SDGHub fill:#999,stroke:#333
    style LMEval fill:#999,stroke:#333
    style TrainingHub fill:#999,stroke:#333
    style Transformers fill:#999,stroke:#333
    style OpenAI fill:#ccc,stroke:#333,stroke-dasharray:5 5
    style Boto3 fill:#ccc,stroke:#333,stroke-dasharray:5 5

    %% Internal platform
    style KFPServer fill:#7ed321,stroke:#333
    style DSPA fill:#7ed321,stroke:#333
    style ModelRegistry fill:#7ed321,stroke:#333
    style LlamaStack fill:#7ed321,stroke:#333

    %% External services
    style S3 fill:#f5a623,stroke:#333
