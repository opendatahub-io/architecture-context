graph LR
    PC["Pipelines Components<br/>(KFP v2 Library + Init Container)"]

    %% External Dependencies - Required
    PC -->|"pipeline SDK"| KFP["KFP SDK<br/>>=2.15.2"]
    PC -->|"K8s resources"| KFPKube["kfp-kubernetes<br/>>=2.15.2"]
    PC -->|"training backend"| PyTorch["PyTorch<br/>2.10.0"]
    PC -->|"model loading"| Transformers["transformers<br/>4.57.6"]

    %% External Dependencies - AutoML
    PC -->|"tabular/timeseries ML"| AutoGluon["AutoGluon<br/>1.5.0+rhaiv.2"]

    %% External Dependencies - AutoRAG
    PC -->|"document extraction"| Docling["Docling<br/>2.73.1"]
    PC -->|"RAG framework"| LangChain["LangChain<br/>1.1.3"]
    PC -->|"vector store"| ChromaDB["ChromaDB<br/>1.5.5"]
    PC -->|"RAG optimization"| ai4rag["ai4rag<br/>0.5.4"]

    %% External Dependencies - Other
    PC -->|"evaluation harness"| lmeval["lm-eval"]
    PC -->|"training backends"| training_hub["training_hub<br/>(unsloth, mini-trainer,<br/>instructlab)"]
    PC -->|"synthetic data"| SDGHub["SDG Hub<br/>>=0.7.0"]
    PC -->|"LLM client"| LlamaClient["Llama Stack Client<br/>0.7.1"]

    %% Internal Platform Dependencies
    PC -->|"filesystem<br/>(shared volume)"| KFPServer["KFP API Server"]
    PC -->|"pipeline execution"| DSPA["DSPA"]
    PC -->|"dataset/model I/O"| S3["S3-Compatible<br/>Storage"]
    PC -->|"model registration"| ModelReg["Kubeflow<br/>Model Registry"]
    PC -->|"embeddings & inference"| LlamaStack["Llama Stack<br/>API"]
    PC -->|"model downloads"| HFHub["Hugging Face<br/>Hub"]
    PC -->|"model artifacts"| OCIReg["OCI Container<br/>Registry"]
    PC -->|"secrets, PVCs"| K8sAPI["Kubernetes API"]

    %% Build Dependencies
    PC -.->|"CI/CD builds"| Konflux["Konflux Build<br/>System"]
    PC -.->|"PyPI mirror"| PyPI["Red Hat PyPI<br/>Mirror"]

    %% Optional
    PC -.->|"experiment tracking"| Tracking["W&B / MLflow /<br/>TensorBoard"]

