graph LR
    PC["Pipelines Components<br/>(KFP Library + Init Container)"]

    %% Internal Platform Dependencies
    PC -->|"shared volume<br/>managed pipeline YAMLs"| KFPServer["KFP API Server"]
    PC -->|"HTTP/8080<br/>model registration"| ModelRegistry["Kubeflow Model Registry"]
    PC -->|"K8s API<br/>TrainingJob CRs"| Trainer["Kubeflow Trainer<br/>ClusterTrainingRuntime"]
    PC -->|"K8s Secrets<br/>credential injection"| Connections["RHOAI Connections API"]
    PC -->|"REST API<br/>vector store + inference"| LlamaStack["Llama Stack"]
    PC -.->|"filesystem<br/>shared workspace"| PVC["PVC<br/>(RWX 50Gi / RWO 12Gi)"]

    %% External Dependencies - Core
    PC -->|"HTTPS/443<br/>datasets, documents"| S3["AWS S3"]
    PC -->|"HTTPS/443<br/>models, datasets"| HFHub["HuggingFace Hub"]
    PC -->|"HTTPS<br/>LLM inference"| LLMAPI["LLM API Endpoint"]
    PC -->|"HTTPS<br/>chat + embeddings"| OpenAI["OpenAI-compatible<br/>Endpoints"]
    PC -->|"HTTPS/443<br/>resource management"| K8sAPI["Kubernetes API"]

    %% Key Python Dependencies
    PC -->|"SDK"| KFP["kfp >=2.15.2"]
    PC -->|"SDK"| KFPk8s["kfp-kubernetes >=2.15.2"]
    PC -->|"ML framework"| AutoGluon["AutoGluon<br/>(AutoML)"]
    PC -->|"RAG framework"| ai4rag["ai4rag >=1.0.0<br/>(AutoRAG)"]
    PC -->|"doc extraction"| Docling["Docling"]
    PC -->|"eval framework"| lmeval["lm-eval >=0.4.0"]
    PC -->|"inference engine"| vLLM["vLLM >=0.4.0"]
    PC -->|"training"| PyTorch["PyTorch"]
    PC -->|"LoRA backend"| Unsloth["Unsloth >=2024.11"]
    PC -->|"SFT backend"| ILab["instructlab-training"]
    PC -->|"S3 client"| boto3["boto3"]
    PC -->|"SDG engine"| SDGHub["sdg-hub >=0.7.0"]
    PC -->|"model registry SDK"| MRClient["model-registry 0.3.4"]
    PC -->|"trainer SDK"| TrainerSDK["kubeflow-trainer >=0.1.0"]

    %% Integration Points (who depends on pipelines-components)
    %% None directly - components are consumed via KFP pipelines

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

