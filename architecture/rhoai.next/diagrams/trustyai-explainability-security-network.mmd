graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Dashboard / ODH UI"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route: trustyai<br/>80/TCP<br/>TLS: None (tls: null)"]
    end

    subgraph PodBoundary["POD BOUNDARY (Auth Enforcement)"]
        direction TB

        AuthProxy["kube-rbac-proxy / oauth-proxy<br/>(sidecar injected by Operator)<br/>Validates Bearer/OAuth tokens"]

        subgraph App["APPLICATION"]
            TrustyAI["TrustyAI Service<br/>Quarkus 3.8.5 / Java 17<br/>SA: trustyai-serviceaccount<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS)"]
        end

        AuthProxy -->|"HTTP/8080<br/>plaintext<br/>pre-authenticated"| TrustyAI
    end

    subgraph InternalSources["INTERNAL SOURCES (Cluster)"]
        ModelMesh["ModelMesh Serving<br/>POST /consumer/kserve/v2<br/>via payloadProcessors ConfigMap"]
        Prometheus["Prometheus<br/>GET /q/metrics<br/>Bearer token (SA)<br/>ServiceMonitor"]
    end

    subgraph StorageBackends["STORAGE BACKENDS"]
        PVC["PVC (default)<br/>ReadWriteOnce 1Gi<br/>/inputs<br/>CSV / Parquet"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP<br/>JDBC plaintext<br/>Username/Password"]
        MinIO["MinIO<br/>9000/TCP<br/>S3 API HTTPS/TLS<br/>Access Key / Secret Key"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Model Inference)"]
        KServeModels["KServe / ModelMesh<br/>Model Servers<br/>gRPC/HTTP2 plaintext<br/>No Auth"]
    end

    subgraph OperatorManagement["OPERATOR MANAGEMENT"]
        Operator["TrustyAI Service Operator<br/>Manages: Deployment, Service,<br/>PVC, ConfigMap, Auth Proxy"]
    end

    %% External flows
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Route
    Route -->|"HTTP/80<br/>plaintext"| AuthProxy

    %% Internal inbound flows
    ModelMesh -->|"HTTP/80<br/>plaintext<br/>No Auth"| TrustyAI
    Prometheus -->|"HTTP/80<br/>plaintext<br/>Bearer token (SA)"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"File I/O<br/>local mount"| PVC
    TrustyAI -->|"JDBC/3306<br/>plaintext<br/>Username/Password"| MariaDB
    TrustyAI -->|"S3 API/9000<br/>HTTPS TLS<br/>Access Key"| MinIO
    TrustyAI -->|"gRPC-HTTP2/varies<br/>plaintext<br/>No Auth"| KServeModels

    %% Operator management
    Operator -.->|"creates & manages"| PodBoundary

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internalsource fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Client external
    class Route ingress
    class AuthProxy authproxy
    class TrustyAI application
    class PVC,MariaDB,MinIO storage
    class KServeModels externalservice
    class Operator operator
    class ModelMesh,Prometheus internalsource
