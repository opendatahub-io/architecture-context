graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route: trustyai<br/>80/TCP → 8080/TCP<br/>TLS: operator-configured"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_Model["Namespace: {model-namespace}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS opt.)<br/>Image: registry.redhat.io/rhoai/..."]
        end

        subgraph NS_KServe["KServe / ModelMesh Namespace"]
            KServeIS["KServe InferenceService<br/>(payload processor)"]
            ModelMesh["ModelMesh Serving"]
            KServeModel["KServe Model Endpoint"]
        end

        subgraph NS_Monitoring["Monitoring Namespace"]
            Prometheus["Prometheus<br/>ServiceMonitor"]
        end

        subgraph NS_Operator["Operator Namespace"]
            Operator["TrustyAI Operator<br/>CRD reconciliation"]
        end

        CloudEvents["Kubeflow CloudEvent<br/>Broker"]
    end

    subgraph StorageBackends["STORAGE BACKENDS"]
        PVC["PVC: trustyai-service-pvc<br/>Local FS at /inputs<br/>CSV format"]
        MinIO["MinIO / S3<br/>9000/TCP or 443/TCP<br/>TLS optional<br/>Access Key auth"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP JDBC<br/>TLS optional<br/>Username/Password"]
    end

    %% External flows
    User -->|"HTTP 8080/TCP or HTTPS 4443/TCP<br/>Auth: proxy-delegated"| Route
    Route -->|"HTTP 8080/TCP<br/>No encryption (internal)"| TrustyAI

    %% Inbound cluster flows
    KServeIS -->|"POST /consumer/kserve/v2<br/>HTTP 8080/TCP<br/>No encryption, No auth"| TrustyAI
    ModelMesh -->|"POST /consumer/kserve/v2<br/>HTTP 8080/TCP Protobuf<br/>No encryption, No auth"| TrustyAI
    CloudEvents -->|"CloudEvent HTTP 8080/TCP<br/>No encryption, No auth"| TrustyAI
    Prometheus -->|"GET /q/metrics<br/>HTTP 8080/TCP<br/>Auth: Bearer Token (SA)"| TrustyAI

    %% Operator management
    Operator -.->|"CRD reconciliation<br/>Kubernetes API"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"gRPC 8033/TCP or HTTP 80/TCP<br/>Encryption varies<br/>No auth"| KServeModel

    %% Storage flows
    TrustyAI -->|"Local FS I/O<br/>Mounted volume"| PVC
    TrustyAI -->|"HTTP/HTTPS<br/>9000 or 443/TCP<br/>Access Key/Secret Key"| MinIO
    TrustyAI -->|"JDBC 3306/TCP<br/>TLS optional<br/>Username/Password"| MariaDB

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#7ed321,stroke:#333,stroke-width:2px

    class User external
    class Route ingress
    class TrustyAI,KServeIS,ModelMesh,KServeModel,Prometheus,CloudEvents clusterinternal
    class Operator operator
    class PVC,MinIO,MariaDB storage
