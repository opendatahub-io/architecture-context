graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / ODH Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Route["OpenShift Route: trustyai<br/>80/TCP → 8080/TCP<br/>TLS: None (base manifests)<br/>Auth: None (base); oauth-proxy (operator)"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph TrustyAINS["Namespace: {model-namespace}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Image: registry.redhat.io/rhods/odh-trustyai-service-rhel8<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS when TLS configured)"]
        end

        subgraph KServeNS["KServe / Knative"]
            KServeInference["KServe InferenceService<br/>CloudEvent Source"]
            KnativeEventing["Knative Eventing<br/>Trigger Router"]
        end

        subgraph ModelMeshNS["ModelMesh"]
            ModelMesh["ModelMesh Serving<br/>Payload Processor"]
        end

        subgraph MonitoringNS["Namespace: openshift-monitoring"]
            Prometheus["Prometheus Server<br/>ServiceMonitor scrape"]
        end

        subgraph ModelServing["Model Namespace"]
            KServeModel["KServe Model Server<br/>gRPC v2 endpoint"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Storage Backends)"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP<br/>JDBC<br/>plaintext<br/>Username/Password"]
        MinIO["MinIO Server<br/>9000/TCP<br/>HTTP (S3 API)<br/>plaintext<br/>Access Key/Secret Key"]
        PVC["PersistentVolumeClaim<br/>Filesystem I/O<br/>/inputs/data.csv"]
    end

    %% Inbound flows
    User -->|"HTTP/80<br/>No TLS (base)<br/>No Auth (base)"| Route
    Route -->|"HTTP/8080<br/>No TLS<br/>internal"| TrustyAI

    KServeInference -->|"CloudEvent<br/>inference req/resp<br/>GZIP-compressed"| KnativeEventing
    KnativeEventing -->|"HTTP/8080<br/>CloudEvent<br/>No TLS, No Auth"| TrustyAI

    ModelMesh -->|"HTTP POST/8080<br/>JSON payload<br/>No TLS, No Auth"| TrustyAI

    Prometheus -->|"HTTP GET/8080<br/>/q/metrics<br/>Bearer Token (SA token)"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"gRPC/model-port<br/>KServe v2<br/>plaintext, No Auth"| KServeModel

    TrustyAI -->|"JDBC/3306<br/>MySQL wire protocol<br/>plaintext<br/>Username/Password"| MariaDB

    TrustyAI -->|"HTTP/9000<br/>S3 API<br/>plaintext<br/>Access Key/Secret Key"| MinIO

    TrustyAI -->|"Filesystem I/O<br/>Local mount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef trustyai fill:#bbdefb,stroke:#1565c0,stroke-width:3px

    class User external
    class Route ingress
    class TrustyAI trustyai
    class KServeInference,KnativeEventing,ModelMesh,KServeModel internal
    class Prometheus monitoring
    class MariaDB,MinIO,PVC externalservice
