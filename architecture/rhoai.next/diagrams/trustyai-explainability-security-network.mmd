graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["trustyai Route<br/>80/TCP → 8080/TCP<br/>TLS: None<br/>Auth: None"]
    end

    subgraph Application["APPLICATION (In-Cluster)"]
        direction TB

        subgraph NS_DSP["Namespace: {data-science-project}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Image: odh-trustyai-service-rhel8"]

            subgraph Ports["Service Ports"]
                HTTP["8080/TCP HTTP<br/>(primary, no TLS)"]
                HTTPS["4443/TCP HTTPS<br/>(TLS cert files)"]
            end

            subgraph StoragePVC["PVC Storage"]
                PVC["PersistentVolumeClaim<br/>/inputs mount"]
            end
        end
    end

    subgraph InboundSources["INBOUND DATA SOURCES"]
        ModelMesh["ModelMesh Serving Runtime<br/>POST /consumer/kserve/v2"]
        KServeIS["KServe InferenceService<br/>CloudEvents (Knative)"]
        Prometheus["Prometheus<br/>GET /q/metrics<br/>Bearer Token (SA)"]
    end

    subgraph EgressTargets["EGRESS TARGETS"]
        ModelServerHTTP["KServe/ModelMesh Model Server<br/>8080/TCP HTTP<br/>No TLS, No Auth"]
        ModelServerGRPC["KServe/ModelMesh Model Server<br/>gRPC, plaintext<br/>No TLS, No Auth"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP JDBC<br/>No TLS<br/>Username/Password"]
        MinIO["MinIO Object Storage<br/>HTTP (S3 API)<br/>Encryption: configurable<br/>Access Key/Secret Key"]
    end

    %% External → Ingress → Application
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Route
    Route -->|"HTTP/8080<br/>No Encryption<br/>No Auth"| TrustyAI

    %% Inbound connections
    ModelMesh -->|"HTTP/8080<br/>No TLS<br/>No Auth"| TrustyAI
    KServeIS -->|"HTTP/8080<br/>CloudEvents<br/>No Auth"| TrustyAI
    Prometheus -->|"HTTP/8080<br/>No TLS<br/>Bearer Token"| TrustyAI

    %% Internal
    TrustyAI --- HTTP
    TrustyAI --- HTTPS
    TrustyAI -->|"Filesystem"| PVC

    %% Egress
    TrustyAI -->|"HTTP/8080<br/>KServe v1/v2<br/>No TLS"| ModelServerHTTP
    TrustyAI -->|"gRPC/configurable<br/>plaintext<br/>usePlaintext()"| ModelServerGRPC
    TrustyAI -->|"JDBC/3306<br/>No TLS<br/>Username/Password"| MariaDB
    TrustyAI -->|"HTTP S3 API<br/>configurable TLS<br/>Access Key/Secret"| MinIO

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inbound fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI,HTTP,HTTPS,PVC application
    class ModelMesh,KServeIS,Prometheus inbound
    class ModelServerHTTP,MariaDB,MinIO egress
    class ModelServerGRPC warning
