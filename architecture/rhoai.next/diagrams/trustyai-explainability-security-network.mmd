graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Dashboard"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route: trustyai<br/>80/TCP → 8080/TCP<br/>TLS: None (tls: null)<br/>Auth: Delegated to proxy"]
    end

    subgraph Application["APPLICATION (In-Cluster)"]
        direction TB

        subgraph NS_DSP["Namespace: {data-science-project}"]
            direction TB

            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Image: registry.redhat.io/rhods/<br/>odh-trustyai-service-rhel8:latest"]

            subgraph Ports["Service Ports"]
                HTTP["8080/TCP HTTP<br/>(primary, all endpoints)"]
                HTTPS["4443/TCP HTTPS<br/>(optional, TLS cert file)<br/>Cert: /etc/tls/internal/"]
            end
        end
    end

    subgraph Monitoring["MONITORING (In-Cluster)"]
        Prometheus["Prometheus /<br/>OpenShift Monitoring<br/>ServiceMonitor:<br/>trustyai_spd, trustyai_dir"]
    end

    subgraph InboundSources["INBOUND SOURCES (In-Cluster)"]
        ModelMesh["KServe / ModelMesh<br/>Model Servers<br/>(payload producer)"]
        KServeIS["KServe InferenceService<br/>(CloudEvents producer)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        ModelServer["KServe / ModelMesh<br/>Model Servers<br/>(inference target)"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP JDBC<br/>Auth: Username/Password"]
        MinIO["MinIO Object Storage<br/>HTTP S3 API<br/>Auth: Access Key/Secret Key"]
        PVC["PersistentVolumeClaim<br/>Filesystem /inputs"]
    end

    %% Inbound flows
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth (delegated)"| Route
    Route -->|"HTTP/8080<br/>No Encryption<br/>No Auth"| TrustyAI

    ModelMesh -->|"POST /consumer/kserve/v2<br/>HTTP/8080<br/>No Encryption, No Auth"| TrustyAI
    KServeIS -->|"CloudEvents<br/>HTTP/8080<br/>No Encryption, No Auth"| TrustyAI

    %% Monitoring
    Prometheus -->|"GET /q/metrics<br/>HTTP/8080<br/>Bearer Token (SA)"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"HTTP/8080<br/>KServe v1/v2 REST<br/>No Encryption, No Auth"| ModelServer
    TrustyAI -->|"gRPC/configurable<br/>⚠️ plaintext<br/>No Auth"| ModelServer
    TrustyAI -->|"JDBC/3306<br/>No Encryption<br/>Username/Password"| MariaDB
    TrustyAI -->|"HTTP S3 API<br/>Encryption: configurable<br/>Access Key/Secret Key"| MinIO
    TrustyAI -->|"Filesystem<br/>Volume Mount"| PVC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef inbound fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI,HTTP,HTTPS application
    class Prometheus monitoring
    class ModelMesh,KServeIS inbound
    class ModelServer,MariaDB,MinIO,PVC externalservice
