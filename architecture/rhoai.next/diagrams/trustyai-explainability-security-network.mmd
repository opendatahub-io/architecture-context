graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route<br/>80/TCP → 8080/TCP<br/>TLS: None (base)"]
    end

    subgraph InCluster["IN-CLUSTER"]
        direction TB

        subgraph NS_Monitored["Namespace: {monitored-namespace}"]
            direction TB
            TrustyAI["TrustyAI Explainability Service<br/>SA: trustyai-serviceaccount<br/>Image: registry.redhat.io/rhods/<br/>odh-trustyai-service-rhel8<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS)"]
            InitContainer["Init Container: config-map-overrider<br/>(ose-cli)"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(operator-injected)<br/>RBAC enforcement"]
        end

        subgraph NS_ModelServing["Model Serving Namespace"]
            KServeIS["KServe InferenceService<br/>(CloudEvents source)"]
            ModelMesh["ModelMesh Serving<br/>(REST payload source)"]
            InferenceServers["KServe Inference Servers<br/>(v1/v2 HTTP, v2 gRPC)"]
        end

        subgraph NS_Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus<br/>ServiceMonitor scrape"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        MinIO["MinIO / S3 Storage<br/>configurable/TCP<br/>HTTP/HTTPS<br/>Access Key / Secret Key"]
        Database["MariaDB / MySQL<br/>3306/TCP<br/>MySQL protocol<br/>Username / Password"]
    end

    %% Inbound flows
    User -->|"HTTP/80<br/>No TLS (base)<br/>No Auth (base)"| Route
    Route -->|"HTTP/8080<br/>No encryption<br/>kube-rbac-proxy (operator)"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8080<br/>RBAC enforced"| TrustyAI

    KServeIS -->|"HTTP/8080<br/>CloudEvents<br/>No encryption<br/>No Auth"| TrustyAI
    ModelMesh -->|"HTTP/8080<br/>POST /consumer/kserve/v2<br/>No encryption<br/>No Auth"| TrustyAI

    Prometheus -->|"HTTP/8080<br/>GET /q/metrics<br/>Bearer SA token<br/>every 4s"| TrustyAI

    %% Outbound flows
    TrustyAI -->|"HTTP + gRPC<br/>configurable port<br/>plaintext<br/>No Auth"| InferenceServers
    InitContainer -->|"HTTPS/443<br/>TLS<br/>SA token<br/>oc apply ConfigMap"| K8sAPI
    TrustyAI -->|"S3 API<br/>configurable port<br/>TLS optional<br/>Access Key/Secret"| MinIO
    TrustyAI -->|"MySQL/3306<br/>No encryption<br/>Username/Password"| Database

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef incluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef rbacproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class TrustyAI,InitContainer,KServeIS,ModelMesh,InferenceServers,K8sAPI incluster
    class Prometheus monitoring
    class MinIO,Database externalservice
    class KubeRBACProxy rbacproxy
