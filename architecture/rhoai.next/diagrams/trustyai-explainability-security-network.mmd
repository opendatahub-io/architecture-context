graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Dashboard"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route: trustyai<br/>80/TCP -> 8080/TCP<br/>TLS: None (tls: null)<br/>Auth: None (delegated to proxy)"]
    end

    subgraph Application["APPLICATION (trustyai-service)"]
        direction TB

        subgraph NS_DSP["Namespace: {data-science-project}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Image: registry.redhat.io/rhods/<br/>odh-trustyai-service-rhel8:latest<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS)"]
        end
    end

    subgraph InCluster["IN-CLUSTER SERVICES"]
        direction TB

        ModelMesh["ModelMesh Serving Runtime<br/>(same namespace)<br/>Sends inference payloads"]
        KServeIS["KServe InferenceService<br/>CloudEvents emitter"]
        Prometheus["Prometheus / OpenShift Monitoring<br/>ServiceMonitor scraping"]
        Operator["trustyai-service-operator<br/>Lifecycle management"]
    end

    subgraph StorageBackends["STORAGE BACKENDS (conditional)"]
        direction TB

        PVC["PersistentVolumeClaim<br/>/inputs (filesystem)<br/>Default storage mode"]
        MariaDB["MariaDB / MySQL<br/>3306/TCP JDBC<br/>Auth: Username/Password<br/>Encryption: None"]
        MinIO["MinIO<br/>S3 HTTP API<br/>Auth: Access Key/Secret Key<br/>Encryption: configurable"]
    end

    subgraph ModelServing["MODEL SERVING (egress)"]
        ModelServer["KServe/ModelMesh Model Server"]
    end

    %% External to Ingress
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Route

    %% Ingress to Application
    Route -->|"HTTP/8080<br/>No Encryption<br/>No Auth"| TrustyAI

    %% In-cluster inbound
    ModelMesh -->|"POST /consumer/kserve/v2<br/>HTTP/8080<br/>No Encryption, No Auth"| TrustyAI
    KServeIS -->|"CloudEvents HTTP/8080<br/>org.kubeflow.serving.inference.*<br/>No Encryption, No Auth"| TrustyAI
    Prometheus -->|"GET /q/metrics<br/>HTTP/8080<br/>Auth: Bearer Token (SA)"| TrustyAI
    Operator -.->|"Lifecycle mgmt<br/>Deploys & configures"| TrustyAI

    %% Egress to model servers
    TrustyAI -->|"HTTP/8080<br/>KServe v1/v2<br/>No Encryption, No Auth"| ModelServer
    TrustyAI -->|"gRPC/configurable<br/>PLAINTEXT<br/>No Auth<br/>⚠ UNENCRYPTED"| ModelServer

    %% Egress to storage
    TrustyAI -->|"Filesystem mount<br/>/inputs"| PVC
    TrustyAI -->|"JDBC/3306<br/>No Encryption<br/>Username/Password"| MariaDB
    TrustyAI -->|"S3 HTTP API<br/>Access Key/Secret Key"| MinIO

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef incluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef modelserving fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI application
    class ModelMesh,KServeIS,Prometheus,Operator incluster
    class PVC,MariaDB,MinIO storage
    class ModelServer modelserving
