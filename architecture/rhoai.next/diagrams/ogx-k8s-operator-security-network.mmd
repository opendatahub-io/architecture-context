graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        OCIRegistry["OCI Container Registries<br/>quay.io, docker.io<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph IngressZone["INGRESS (Optional External Access)"]
        IngressResource["{instance}-ingress<br/>Kubernetes Ingress<br/>80/TCP HTTP<br/>Host: auto or configured"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Namespace Isolated)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["OGX Operator<br/>SA: controller-manager<br/>Ports: 8080 (metrics), 8081 (health), 9443 (webhook)"]
            WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS<br/>failurePolicy: Fail"]
            MetricsSvc["Metrics Service<br/>8443/TCP → 8080/TCP<br/>HTTP, kube-rbac-proxy"]
        end

        subgraph InstanceNS["Namespace: {user-namespace}"]
            InstanceSvc["{instance}-service<br/>8321/TCP (configurable)<br/>HTTP, no auth"]
            OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid"]
            NetPol["NetworkPolicy<br/>Ingress: same-ns + operator-ns only"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount token auth"]
    end

    subgraph PlatformIntegrations["PLATFORM INTEGRATIONS"]
        CertManager["cert-manager /<br/>service-serving-cert-signer"]
        ODHCA["odh-trusted-ca-bundle<br/>ConfigMap"]
        MonitoringCRDs["monitoring.coreos.com<br/>ServiceMonitor / PrometheusRule"]
        SCC["security.openshift.io<br/>SCC: anyuid"]
    end

    %% External flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry credentials"| OCIRegistry

    %% Ingress flow
    IngressResource -->|"HTTP/8321<br/>No encryption<br/>No auth"| InstanceSvc

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token<br/>Watch + SSA + Status"| K8sAPI

    %% K8s API to Webhook
    K8sAPI -->|"HTTPS/443<br/>TLS (mTLS)<br/>API server cert<br/>Admission review"| WebhookSvc

    %% Operator to OGX instances
    Operator -->|"HTTP/8321<br/>No encryption<br/>No auth<br/>Health: /v1/health, /v1/providers, /v1/version"| InstanceSvc

    %% Instance service to pod
    InstanceSvc --> OGXPod
    NetPol -.->|"protects"| OGXPod

    %% Platform integrations
    CertManager -.->|"provisions TLS cert"| WebhookSvc
    Operator -.->|"reads CA bundle"| ODHCA
    Operator -.->|"conditional create"| MonitoringCRDs
    SCC -.->|"grants anyuid"| OGXPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef api fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class OCIRegistry external
    class IngressResource ingress
    class Operator,WebhookSvc,MetricsSvc,InstanceSvc,OGXPod internal
    class K8sAPI api
    class CertManager,ODHCA,MonitoringCRDs,SCC platform
    class NetPol security
