graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA tokens, user creds"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB

        Operator["OGX Operator Manager<br/>SA: controller-manager<br/>Image: rhoai/odh-ogx-operator-rhel9<br/>FIPS: CGO_ENABLED=1, strictfipsruntime"]

        MetricsProxy["Metrics Proxy<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Auth: Bearer token review"]

        WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP HTTPS<br/>service-serving-cert<br/>failurePolicy: Fail"]

        HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]

        Metrics["Metrics<br/>8080/TCP HTTP<br/>/metrics"]

        ModuleOp["OGX Module Operator<br/>SA: ogx-module-controller-manager<br/>8081/TCP (health only)<br/>(scaffold - no reconciler yet)"]
    end

    subgraph UserNS["USER NAMESPACES (per-instance)"]
        direction TB

        OGXPod["OGX Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid<br/>Port: 8321/TCP (default)"]

        InstanceSvc["{instance}-service<br/>ClusterIP<br/>8321/TCP HTTP"]

        NetPol["NetworkPolicy<br/>Ingress: same-ns + operator-ns + router<br/>Custom rules override defaults<br/>Auto kube-dns egress injection"]

        InstanceIngress["{instance}-ingress<br/>K8s Ingress (optional)<br/>80/TCP HTTP<br/>External access"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OCIRegistry["OCI Image Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Registry credentials"]

        CertProvider["cert-manager /<br/>service-serving-cert-signer<br/>Auto-rotation: Yes"]
    end

    %% External → Control Plane
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>User credentials"| K8sAPI

    %% Control Plane → Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (service-serving-cert)<br/>API server CA mutual auth"| WebhookSvc

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA bearer token<br/>CR watches, CRUD, leader election"| K8sAPI

    %% Module → K8s API
    ModuleOp -.->|"HTTPS/6443<br/>TLS 1.2+<br/>SA bearer token<br/>OGX CR watch"| K8sAPI

    %% Operator → OGX instances
    Operator -->|"HTTP/8321<br/>Configurable TLS<br/>No auth (NetworkPolicy-restricted)<br/>GET /v1/health, /v1/providers"| OGXPod

    %% Operator → OCI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds<br/>OCI label fetch"| OCIRegistry

    %% Cert provisioning
    CertProvider -.->|"TLS cert provisioning<br/>ogx-k8s-operator-webhook-cert"| WebhookSvc

    %% Metrics path
    MetricsProxy -->|"HTTP/8080<br/>Internal"| Metrics

    %% Optional external access
    InstanceIngress -.->|"HTTP/8321<br/>Routes to"| InstanceSvc
    InstanceSvc -->|"HTTP/8321"| OGXPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Operator,MetricsProxy,WebhookSvc,HealthProbe,Metrics,ModuleOp operatorns
    class OGXPod,InstanceSvc,NetPol,InstanceIngress userns
    class OCIRegistry,CertProvider externalservice
