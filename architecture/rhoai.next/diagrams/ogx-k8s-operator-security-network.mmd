graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist /<br/>Platform Admin"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications / opendatahub)"]
        direction TB

        Controller["OGX K8s Operator<br/>SA: controller-manager<br/>Probes: 8081/TCP HTTP<br/>Metrics: 8080/TCP HTTP"]
        WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS TLS<br/>failurePolicy: Fail"]
        MetricsSvc["Metrics Service<br/>8443/TCP → 8080/TCP<br/>kube-rbac-proxy"]
    end

    subgraph InstanceNS["INSTANCE NAMESPACE (user-configured)"]
        direction TB

        subgraph OGXPod["OGX Server Pod"]
            ServerContainer["OGX Server<br/>SA: {instance}-sa<br/>SCC: anyuid (FSGroup 1001)<br/>8321/TCP HTTP"]
        end

        InstanceSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP"]
        NetPolicy["NetworkPolicy<br/>(ingress restricted)"]
        PVC["PVC<br/>(local file storage)"]
        CABundle["{instance}-ca-bundle<br/>ConfigMap<br/>(validated X.509)"]
        IngressRes["{instance}-ingress<br/>80/TCP HTTP<br/>(optional external)"]
    end

    subgraph ConfigNS["CONFIGURATION"]
        OperatorConfig["ogx-operator-config<br/>ConfigMap<br/>(image overrides)"]
        TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap<br/>(platform CA certs)"]
        UserSecrets["User Secrets<br/>(ogx.io/watch: true)<br/>API keys, DB passwords"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
        Providers["AI Provider Backends<br/>vLLM, OpenAI, Azure,<br/>Bedrock, watsonx, etc."]
    end

    %% External to Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kubeconfig"| K8sAPI

    %% Control Plane to Operator
    K8sAPI -->|"HTTPS/443<br/>TLS<br/>Webhook callback"| WebhookSvc
    K8sAPI -->|"Watch events<br/>TLS 1.2+<br/>SA token"| Controller

    %% Operator to Control Plane
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD resources"| K8sAPI

    %% Operator to Config
    Controller -->|"API Read<br/>TLS 1.2+<br/>SA token"| OperatorConfig
    Controller -->|"API Read<br/>TLS 1.2+<br/>SA token"| TrustedCA
    Controller -->|"API Read<br/>TLS 1.2+<br/>SA token"| UserSecrets

    %% Operator to Instance
    Controller -->|"HTTP/8321<br/>No TLS<br/>No Auth<br/>Health checks"| ServerContainer

    %% Operator to External
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry auth"| Registry

    %% OGX Server to External Providers
    ServerContainer -->|"HTTPS<br/>TLS<br/>API keys from Secrets"| Providers

    %% Instance internal
    InstanceSvc --> ServerContainer
    CABundle -.->|mounted| ServerContainer
    PVC -.->|mounted| ServerContainer
    IngressRes -->|"HTTP/80"| InstanceSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef instance fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookSvc,MetricsSvc operator
    class ServerContainer,InstanceSvc,NetPolicy,PVC,CABundle,IngressRes instance
    class OperatorConfig,TrustedCA,UserSecrets config
    class Registry,Providers externalsvc
