graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API - DMZ)"]
        direction TB
        Gateway["MaaS Default Gateway<br/>maas.${CLUSTER_DOMAIN}<br/>443/TCP → TLS Terminate<br/>GatewayClass: openshift-default"]
        WasmPlugin["Kuadrant Wasm Plugin<br/>(in-process)"]
        DefaultDeny["Default Deny Policies:<br/>AuthPolicy → 401<br/>TRLP → 0 tokens/1m"]
        Gateway --- WasmPlugin
        Gateway --- DefaultDeny
    end

    subgraph KuadrantAuth["KUADRANT AUTH PLANE (mTLS)"]
        direction TB
        Authorino["Authorino<br/>50051/TCP gRPC mTLS<br/>Auth: API key callback,<br/>K8s TokenReview, OIDC JWT"]
        Limitador["Limitador<br/>Token-level rate limiting<br/>per model per subscription"]
    end

    subgraph AppPlane["APPLICATION PLANE (Cluster-Internal)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP HTTP | 9090/TCP metrics<br/>Optional TLS 1.2+ overlay"]
            MaaSController["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics<br/>Go Operator"]
        end

        subgraph NS_Ingress["Namespace: openshift-ingress"]
            PayloadProc["payload-processing<br/>SA: payload-processing<br/>9004/TCP gRPC TLS SIMPLE<br/>9005/TCP metrics<br/>Plugins: model-to-header,<br/>provider-resolver,<br/>api-translation, apikey-injection"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount tokens"]
        OSAuth["OpenShift Auth API<br/>443/TCP HTTPS TLS 1.2+<br/>OIDC issuer discovery"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS configurable<br/>Auth: Connection URL (Secret)"]
        KServe["KServe InferenceServices<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount"]
        ExtProviders["External Model Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: API key (injected)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer: sk-oai-* / K8s token / OIDC JWT"| Gateway

    %% Ingress → Kuadrant
    WasmPlugin -->|"gRPC/50051<br/>mTLS"| Authorino
    WasmPlugin -->|"Rate limit check"| Limitador

    %% Kuadrant → App
    Authorino -->|"HTTP(S)/8080 or 8443<br/>Optional TLS 1.2+<br/>NetworkPolicy restricted"| MaaSAPI

    %% Ingress → Payload Processing
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>ext_proc (fail-closed)"| PayloadProc

    %% Ingress → Backends
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Proxied request"| KServe
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected API key"| ExtProviders

    %% App → Data Stores
    MaaSAPI -->|"PostgreSQL/5432<br/>TLS configurable<br/>Connection URL Secret"| PostgreSQL

    %% App → Control Plane
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token: TokenReview, SAR,<br/>informer cache"| K8sAPI
    MaaSController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token: CR reconciliation,<br/>SSA, policy CRUD"| K8sAPI
    MaaSController -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC discovery"| OSAuth
    PayloadProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token: Secrets,<br/>ConfigMaps, ExternalModels"| K8sAPI

    %% Controller → KServe
    MaaSController -.->|"CRD Watch<br/>LLMInferenceService"| KServe

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kuadrant fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef appplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,WasmPlugin,DefaultDeny ingress
    class Authorino,Limitador kuadrant
    class MaaSAPI,MaaSController,PayloadProc appplane
    class K8sAPI,OSAuth controlplane
    class PostgreSQL,KServe,ExtProviders externalservice
