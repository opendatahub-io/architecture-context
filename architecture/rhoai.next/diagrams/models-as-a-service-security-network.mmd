graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Bearer Token / X-Api-Key / OIDC JWT"]
    end

    subgraph Ingress["INGRESS (Gateway API - openshift-ingress)"]
        Gateway["maas-default-gateway<br/>443/TCP → internal routing<br/>TLS 1.2+ SIMPLE (Terminate)<br/>gateway-default-deny: zero tokens"]

        subgraph ExtProc["Envoy ext_proc Pipeline"]
            PreAuth["payload-processing<br/>(Pre-Auth)<br/>9004/TCP gRPC<br/>TLS DestinationRule SIMPLE<br/>SA: payload-processing"]
            PostAuth["payload-processing<br/>(Post-Auth)<br/>9004/TCP gRPC<br/>TLS DestinationRule SIMPLE<br/>SA: payload-processing"]
        end
    end

    subgraph AuthZ["AUTHENTICATION (Kuadrant)"]
        Authorino["Authorino<br/>443/TCP HTTPS TLS<br/>AuthPolicy evaluation<br/>OpenShift token + OIDC + API key"]
    end

    subgraph Internal["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Controller["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics<br/>8081/TCP health<br/>443/TCP webhook"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8443/TCP HTTPS (service-ca cert)<br/>9090/TCP HTTP metrics"]
            CronJob["api-key-cleanup CronJob<br/>UBI9 minimal"]
        end

        subgraph NS_Ingress["Namespace: openshift-ingress"]
            PayloadProc["payload-processing<br/>SA: payload-processing<br/>9004/TCP gRPC/HTTP2<br/>TLS DestinationRule"]
        end
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS<br/>DB credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        LLMProviders["External LLM Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS TLS 1.2+<br/>API key from Secret"]
        KServe["KServe Endpoints<br/>443/TCP HTTPS<br/>TLS 1.2+ (cluster CA)<br/>User Authorization header"]
    end

    %% External → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer/ApiKey/OIDC"| Gateway

    %% Gateway → ext_proc pipeline
    Gateway -->|"gRPC/9004<br/>TLS (DR SIMPLE)<br/>Model extraction"| PreAuth
    Gateway -->|"gRPC/9004<br/>TLS (DR SIMPLE)<br/>Provider resolution"| PostAuth

    %% Gateway → Authorino
    Gateway -->|"HTTPS/443<br/>TLS<br/>Token/ApiKey"| Authorino

    %% Authorino → maas-api callbacks
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy: Authorino only"| MaaSAPI

    %% Gateway → model backends
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Subscription credentials"| KServe
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected API key"| LLMProviders

    %% CronJob → maas-api
    CronJob -.->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy: CronJob only"| MaaSAPI

    %% maas-api → external
    MaaSAPI -->|"PostgreSQL/5432<br/>TLS<br/>DB_CONNECTION_URL"| PostgreSQL
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller → K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authz fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef extproc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class PreAuth,PostAuth,PayloadProc extproc
    class Authorino authz
    class Controller,MaaSAPI,CronJob internal
    class PostgreSQL,K8sAPI,LLMProviders,KServe externalservice
