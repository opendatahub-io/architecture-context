graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API - openshift-ingress namespace)"]
        Gateway["maas-default-gateway<br/>80/TCP HTTP + 443/TCP HTTPS<br/>TLS Terminate (OpenShift cert)<br/>Host: maas.$$CLUSTER_DOMAIN$$<br/>Default: deny-unconfigured-models"]
    end

    subgraph AuthZ["AUTHENTICATION & AUTHORIZATION"]
        Authorino["Kuadrant Authorino<br/>5001/TCP gRPC<br/>mTLS (Istio)<br/>AuthPolicy evaluation"]
        Limitador["Kuadrant Limitador<br/>8081/TCP gRPC<br/>mTLS (Istio)<br/>TokenRateLimitPolicy"]
    end

    subgraph Processing["REQUEST PROCESSING (openshift-ingress namespace)"]
        BBR["payload-processing BBR<br/>SA: payload-processing<br/>9004/TCP gRPC ext_proc<br/>TLS (DestinationRule SIMPLE)<br/>9005/TCP metrics"]
    end

    subgraph Application["APPLICATION (opendatahub namespace)"]
        MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP HTTP or 8443/TCP HTTPS<br/>TLS 1.2+ (OpenShift serving cert)<br/>Authorino callbacks via NetworkPolicy"]
        Controller["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics<br/>8081/TCP health probes"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        KServe["KServe Model Pods<br/>8000/TCP HTTP/HTTPS<br/>Cluster-internal<br/>Auth header stripped by Authorino"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Auth: maas-db-config Secret"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtProviders["External Model Providers<br/>OpenAI, Anthropic, etc.<br/>443/TCP HTTPS<br/>TLS 1.2+ (Istio origination)<br/>API key from credentialRef Secret"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS (terminate)<br/>Bearer: sk-oai-* / OCP token / OIDC"| Gateway
    Gateway -->|"gRPC/5001<br/>mTLS (Istio)<br/>Service Identity"| Authorino
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>ext_proc pipeline"| BBR
    Gateway -->|"gRPC/8081<br/>mTLS (Istio)<br/>Token quota check"| Limitador
    Authorino -->|"HTTP/8080<br/>No encryption<br/>NetworkPolicy-restricted"| MaaSAPI
    Gateway -->|"HTTP(S)/8000<br/>Cluster-internal<br/>Auth header stripped"| KServe
    Gateway -->|"HTTPS/443<br/>TLS 1.2+ origination<br/>Injected API key"| ExtProviders
    MaaSAPI -->|"TCP/5432<br/>DB credentials<br/>from Secret"| PostgreSQL
    MaaSAPI -->|"HTTPS/8000<br/>TLS InsecureSkipVerify<br/>Bearer passthrough"| KServe
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (read CRDs)"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authz fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef processing fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Authorino,Limitador authz
    class BBR processing
    class MaaSAPI,Controller application
    class KServe,PostgreSQL,K8sAPI internal
    class ExtProviders externalservice
