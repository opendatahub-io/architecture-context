graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist / Application"]
    end

    subgraph Ingress["INGRESS (Gateway API — TLS Terminate)"]
        Gateway["maas-default-gateway<br/>GatewayClass: openshift-default<br/>443/TCP → internal<br/>TLS Terminate<br/>Host: maas.CLUSTER_DOMAIN"]
    end

    subgraph PayloadPipeline["PAYLOAD PROCESSING (ext_proc Pipeline)"]
        direction TB
        PreProc["payload-pre-processing<br/>NS: openshift-ingress<br/>SA: payload-processing<br/>9004/TCP gRPC TLS SIMPLE<br/>failure_mode: ALLOW"]
        PostProc["payload-processing<br/>NS: openshift-ingress<br/>SA: payload-processing<br/>9004/TCP gRPC TLS SIMPLE<br/>failure_mode: DENY"]
    end

    subgraph AuthLayer["AUTH LAYER (Kuadrant)"]
        direction TB
        Authorino["Authorino<br/>NS: kuadrant-system<br/>OIDC + API Key validation<br/>Per-model AuthPolicy"]
        Limitador["Limitador<br/>Token Rate Limiting<br/>Per-subscription limits<br/>mTLS enforcement"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS)"]
        direction TB

        subgraph NS_Controller["NS: opendatahub"]
            Controller["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics<br/>8081/TCP health<br/>9443/TCP webhook (TLS)"]
        end

        subgraph NS_Tenant["NS: per-tenant"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP HTTP (8443 TLS)<br/>9090/TCP metrics"]
        end

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (connection URL)<br/>Username/password"]
        ExternalLLM["External LLM Providers<br/>api.openai.com<br/>api.anthropic.com<br/>443/TCP HTTPS TLS 1.2+<br/>API key (injected)"]
        KServe["KServe Model Endpoints<br/>443/TCP HTTPS<br/>mTLS (Istio)<br/>Bearer token"]
    end

    %% Client → Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer: sk-oai-* or OIDC"| Gateway

    %% Gateway → Pre-processing (pre-auth)
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>Model name extraction"| PreProc

    %% Gateway → Authorino (auth)
    Gateway -->|"mTLS<br/>Auth evaluation<br/>per-model AuthPolicy"| Authorino

    %% Authorino → maas-api internal
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy-protected<br/>/internal/v1/api-keys/validate"| MaaSAPI

    %% Authorino → Limitador
    Authorino -->|"mTLS<br/>Token rate check"| Limitador

    %% Gateway → Post-processing (post-auth)
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>API translation +<br/>credential injection"| PostProc

    %% Gateway → backends
    Gateway -->|"HTTPS/443<br/>mTLS (Istio)<br/>Bearer token"| KServe
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected API key<br/>via ServiceEntry"| ExternalLLM

    %% maas-api → PostgreSQL
    MaaSAPI -->|"TCP/5432<br/>TLS<br/>DB credentials<br/>API key hashes"| PostgreSQL

    %% Controller → K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRD CRUD + SSA"| K8sAPI

    %% maas-api → K8s API
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Informer caches"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#e6d5ff,stroke:#9673a6,stroke-width:2px
    classDef payload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class Authorino,Limitador auth
    class PreProc,PostProc payload
    class Controller,MaaSAPI,K8sAPI servicemesh
    class PostgreSQL,ExternalLLM,KServe externalservice
