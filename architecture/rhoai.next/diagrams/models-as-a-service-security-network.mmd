graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / AI Engineer"]
    end

    subgraph Ingress["INGRESS - Gateway API (openshift-ingress)"]
        direction TB
        Gateway["maas-default-gateway<br/>80/TCP HTTP → 443/TCP HTTPS<br/>TLS Terminate (TLS 1.2+)<br/>Host: maas.CLUSTER_DOMAIN"]
        BBR["payload-processing (BBR)<br/>SA: payload-processing<br/>9004/TCP gRPC ext-proc<br/>9005/TCP metrics"]
        Authorino["Authorino<br/>(AuthPolicy enforcement)<br/>AuthN: API key | K8s token | OIDC"]
        Limitador["Limitador<br/>(TokenRateLimitPolicy)<br/>Per-user token rate limiting"]
        HTTPRoutes["HTTPRoutes<br/>Per-model: /{ns}/{model}/v1/*<br/>API: /v1/models, /v1/api-keys/*"]

        Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>No auth"| BBR
        Gateway --> Authorino
        Authorino --> Limitador
        Gateway --> HTTPRoutes
    end

    subgraph Internal["INTERNAL SERVICES (opendatahub namespace)"]
        direction TB

        Controller["maas-controller<br/>SA: maas-controller-manager<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)"]

        MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP HTTP | 8443/TCP HTTPS<br/>TLS 1.2+ (service-ca cert)<br/>Auth: Authorino (ext) | NetworkPolicy (int)"]

        CronJob["API Key Cleanup CronJob<br/>POST /internal/v1/api-keys/cleanup"]
    end

    subgraph DataStorage["DATA STORAGE"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Auth: DB credentials<br/>(maas-db-config Secret)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        ExtLLM["External LLM Providers<br/>(api.openai.com, etc.)<br/>443/TCP HTTPS<br/>TLS SIMPLE (DestinationRule)<br/>Auth: Provider API key (BBR-injected)"]
        KServe["KServe InferenceServices<br/>HTTPS (varies)<br/>Auth: Bearer token"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>API key (sk-oai-*) OR<br/>OpenShift token OR OIDC JWT"| Gateway

    %% Auth callbacks
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy"| MaaSAPI

    %% Internal flows
    HTTPRoutes -->|"HTTPS/8443<br/>TLS 1.2+"| MaaSAPI
    HTTPRoutes -->|"HTTPS<br/>TLS"| KServe
    HTTPRoutes -->|"HTTPS/443<br/>TLS SIMPLE<br/>via ServiceEntry"| ExtLLM

    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    BBR -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    MaaSAPI -->|"PostgreSQL/5432<br/>DB credentials"| PostgreSQL

    CronJob -->|"HTTP/8080<br/>NetworkPolicy"| MaaSAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class Client external
    class Gateway,BBR,Authorino,Limitador,HTTPRoutes ingress
    class Controller,MaaSAPI,CronJob internal
    class PostgreSQL storage
    class ExtLLM,KServe,K8sAPI externalservice
