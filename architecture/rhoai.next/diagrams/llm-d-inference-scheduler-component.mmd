graph TB
    subgraph "llm-d Inference Scheduler"
        subgraph "EPP (Endpoint Picker)"
            ExtProc["ext-proc gRPC Server<br/>9002/TCP"]
            HealthSvc["Health Service<br/>9003/TCP"]
            MetricsSvc["Metrics Server<br/>9090/TCP"]
            ZMQSub["ZMQ KV-Events Subscriber<br/>5557/TCP"]

            subgraph "Scheduling Pipeline"
                Filters["Filters<br/>(ByLabel, PrefixCacheAffinity,<br/>SLOHeadroomTier)"]
                Scorers["Scorers<br/>(ActiveRequest, KVCacheUtil,<br/>Latency, LoadAware, LoRAffinity,<br/>PrecisePrefixCache, SessionAffinity)"]
                Pickers["Pickers<br/>(MaxScore, WeightedRandom)"]
                Filters --> Scorers --> Pickers
            end

            subgraph "Profile Handlers"
                DisaggPH["Disagg P/D Handler"]
                DPPH["Data Parallel Handler"]
            end

            subgraph "Flow Control (Experimental)"
                Admission["Admission Control"]
                Fairness["Fairness Policies<br/>(GlobalStrict, RoundRobin)"]
                Ordering["Ordering Policies<br/>(FCFS, EDF)"]
                SatDetect["Saturation Detection"]
            end

            ExtProc --> Filters
            ExtProc --> DisaggPH
        end

        subgraph "PD Sidecar Proxy"
            ProxyServer["HTTP Reverse Proxy<br/>8000/TCP"]
            subgraph "KV Transfer Connectors"
                NIXLv2["NIXL v2"]
                SharedStorage["Shared Storage"]
                SGLang["SGLang"]
            end
            SSRFGuard["SSRF Protection<br/>(InferencePool Allowlist)"]
            ProxyServer --> NIXLv2
            ProxyServer --> SharedStorage
            ProxyServer --> SGLang
            ProxyServer --> SSRFGuard
        end

        subgraph "UDS Tokenizer"
            Tokenizer["Tokenizer Sidecar<br/>Unix Domain Socket"]
        end
    end

    Client["External Client"] -->|HTTP/80| Gateway["Envoy Gateway"]
    Gateway -->|gRPC ext-proc<br/>9002/TCP TLS| ExtProc
    ExtProc -->|routing decision<br/>target-endpoint header| Gateway
    Gateway -->|HTTP/8000| ProxyServer
    Gateway -->|HTTP/8000| ModelServer["vLLM Model Server"]

    ExtProc -->|gRPC over UDS| Tokenizer
    ExtProc -->|HTTP/3000<br/>metrics scrape| ModelServer
    ZMQSub -->|ZMQ SUB/5557| ModelServer

    ProxyServer -->|HTTP/8001<br/>localhost| Decoder["Local Decoder (vLLM)"]
    ProxyServer -->|HTTP/HTTPS<br/>Dynamic port| Prefiller["Prefiller Instances"]
    ProxyServer -->|HTTP/HTTPS<br/>Dynamic port| Encoder["Encoder Instances"]

    ExtProc -->|HTTPS/443<br/>SA Token| K8sAPI["Kubernetes API"]
    ExtProc -->|gRPC/4317| OTel["OpenTelemetry Collector"]

    InferencePoolCR["InferencePool CR"] -->|watched by| ExtProc
    InferenceObjCR["InferenceObjective CR"] -->|watched by| ExtProc
    ModelRewriteCR["InferenceModelRewrite CR"] -->|watched by| ExtProc

    Prometheus["Prometheus"] -->|scrapes /metrics<br/>9090/TCP| MetricsSvc

    style ExtProc fill:#4a90e2,color:#fff
    style HealthSvc fill:#4a90e2,color:#fff
    style MetricsSvc fill:#4a90e2,color:#fff
    style ZMQSub fill:#4a90e2,color:#fff
    style ProxyServer fill:#4a90e2,color:#fff
    style Tokenizer fill:#4a90e2,color:#fff
    style Gateway fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OTel fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style InferencePoolCR fill:#f5a623,color:#fff
    style InferenceObjCR fill:#f5a623,color:#fff
    style ModelRewriteCR fill:#f5a623,color:#fff
    style ModelServer fill:#7ed321,color:#fff
    style Decoder fill:#7ed321,color:#fff
    style Prefiller fill:#7ed321,color:#fff
    style Encoder fill:#7ed321,color:#fff
    style Client fill:#f9f9f9,stroke:#999
