graph TB
    subgraph "llm-d Inference Scheduler"
        direction TB

        subgraph EPP["EPP (Endpoint Picker)"]
            direction TB
            ExtProcServer["ext_proc gRPC Server<br/>9002/TCP"]
            HealthServer["gRPC Health Server<br/>9003/TCP"]
            MetricsServer["Prometheus Metrics<br/>9090/TCP"]

            subgraph SchedulingPipeline["Scheduling Pipeline"]
                Filters["Filters"]
                Scorers["Scorers"]
                Pickers["Pickers"]
                ProfileHandler["Profile Handler"]
                ProfileHandler --> Filters
                Filters --> Scorers
                Scorers --> Pickers
            end

            subgraph Controllers["Controller-Runtime Reconcilers"]
                PoolReconciler["InferencePool<br/>Reconciler"]
                PodReconciler["Pod<br/>Reconciler"]
                ObjectiveReconciler["InferenceObjective<br/>Reconciler"]
                RewriteReconciler["InferenceModelRewrite<br/>Reconciler"]
            end

            subgraph DataLayer["Data Layer"]
                MetricsScraper["Metrics Scraper<br/>(HTTP)"]
                KVEventSub["KV Cache Event<br/>Subscriber (ZMQ)"]
                KVCacheIndex["KV Cache Index<br/>(llm-d-kv-cache)"]
                KVEventSub --> KVCacheIndex
            end

            subgraph FlowControl["Flow Control (Experimental)"]
                AdmissionCtrl["Admission Controller"]
                PriorityBands["Priority Bands"]
                FairnessPolicy["Fairness Policy"]
                AdmissionCtrl --> PriorityBands
                AdmissionCtrl --> FairnessPolicy
            end

            ExtProcServer --> ProfileHandler
            Controllers --> DataLayer
        end

        subgraph Sidecar["P/D Routing Sidecar"]
            direction TB
            SidecarProxy["HTTP/HTTPS Proxy<br/>8000/TCP"]
            PDOrchestrator["P/D Orchestrator"]
            EPDOrchestrator["E/P/D Orchestrator"]
            SSRFAllowlist["SSRF Allowlist<br/>(InferencePool-based)"]

            subgraph KVConnectors["KV Connectors"]
                NIXLV2["NIXL V2"]
                SharedStorage["Shared Storage"]
                SGLang["SGLang"]
            end

            SidecarProxy --> PDOrchestrator
            SidecarProxy --> EPDOrchestrator
            PDOrchestrator --> KVConnectors
        end

        UDSTokenizer["UDS Tokenizer<br/>(Sidecar Container)<br/>Unix Domain Socket"]
    end

    %% External Inputs
    Client["Client"] -->|HTTP/80| Gateway
    Gateway["Gateway (Envoy)"] -->|gRPC ext_proc<br/>9002/TCP| ExtProcServer

    %% EPP to external
    Controllers -->|HTTPS/443<br/>SA token| K8sAPI["Kubernetes API Server"]
    MetricsScraper -->|HTTP/HTTPS| ModelServers["vLLM Model Servers"]
    KVEventSub -->|ZMQ PUB/SUB<br/>5556/TCP| ModelServers
    UDSTokenizer -.->|gRPC over UDS| ExtProcServer

    %% EPP routing decision
    ExtProcServer -->|gRPC response<br/>target endpoint| Gateway
    Gateway -->|HTTP/8000| SidecarProxy

    %% Sidecar to model servers
    SidecarProxy -->|HTTP/HTTPS| PrefillerPod["Prefiller Pod"]
    SidecarProxy -->|HTTP/HTTPS<br/>8001/TCP| DecoderPod["Local Decoder (vLLM)"]
    SidecarProxy -->|HTTP/HTTPS| EncoderPod["Encoder Pod<br/>(E/P/D)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|HTTP/9090| MetricsServer
    OTelCollector["OpenTelemetry<br/>Collector"] -.->|gRPC/4317| EPP

    %% Styling
    style EPP fill:#4a90e2,stroke:#2c5f8f,color:#fff
    style Sidecar fill:#7ed321,stroke:#4a8f14,color:#fff
    style UDSTokenizer fill:#9b59b6,stroke:#6c3c80,color:#fff
    style Gateway fill:#f5a623,stroke:#c4841c
    style K8sAPI fill:#e8e8e8,stroke:#999
    style ModelServers fill:#e8e8e8,stroke:#999
    style PrefillerPod fill:#e8e8e8,stroke:#999
    style DecoderPod fill:#e8e8e8,stroke:#999
    style EncoderPod fill:#e8e8e8,stroke:#999
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
    style OTelCollector fill:#e8e8e8,stroke:#999
