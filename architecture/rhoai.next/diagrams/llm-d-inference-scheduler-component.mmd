graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Gateway["Inference Gateway"]
        Envoy["Envoy Proxy<br/>ext_proc filter"]
    end

    subgraph EPP_Component["Endpoint Picker (EPP)<br/>Go gRPC Service"]
        direction TB
        ExtProc["ext_proc Server<br/>9002/TCP gRPC"]
        HealthSvc["Health Service<br/>9003/TCP gRPC"]
        MetricsSvc["Metrics Endpoint<br/>9090/TCP HTTP"]

        subgraph Controllers["K8s Controllers"]
            PoolCtrl["InferencePool<br/>Controller"]
            ObjectiveCtrl["InferenceObjective<br/>Controller"]
            RewriteCtrl["InferenceModelRewrite<br/>Controller"]
            PodCtrl["Pod Controller"]
        end

        subgraph PluginFramework["Plugin Framework"]
            Filters["Filters"]
            Scorers["Scorers<br/>(prefix-cache, LoRA,<br/>session affinity)"]
            Pickers["Pickers<br/>(max-score)"]
            ProfileHandlers["Profile Handlers<br/>(disagg, data-parallel)"]
            FlowControl["Flow Control<br/>(priority, admission)"]
        end

        subgraph DataLayer["Data Layer"]
            Collectors["Metric Collectors<br/>(per-endpoint polling)"]
            KVEvents["KV-Cache Event<br/>Receiver (ZMQ)"]
            DataProducers["Data Producers<br/>(tokenizer, load est.)"]
        end

        ExtProc --> PluginFramework
        PluginFramework --> DataLayer
        Controllers --> DataLayer
    end

    subgraph Sidecar_Component["PD-Sidecar<br/>Go HTTP Reverse Proxy"]
        SidecarProxy["Sidecar Proxy<br/>8000/TCP HTTP/HTTPS"]

        subgraph Connectors["KV-Transfer Connectors"]
            NIXL["NIXL v2"]
            SharedStorage["Shared Storage"]
            SGLang["SGLang"]
            Mooncake["Mooncake"]
        end

        SidecarProxy --> Connectors
    end

    subgraph K8s["Kubernetes"]
        K8sAPI["K8s API Server<br/>443/TCP HTTPS"]
        InferencePoolCR["InferencePool CR"]
        InferenceObjCR["InferenceObjective CR"]
        InferenceRewriteCR["InferenceModelRewrite CR"]
        ModelPods["Model Server Pods<br/>(vLLM / SGLang)"]
    end

    subgraph Observability["Observability"]
        Prometheus["Prometheus"]
        OTLPCollector["OTLP Collector<br/>4317/TCP gRPC"]
    end

    %% External flows
    Client -->|"HTTPS/443"| Envoy
    Envoy -->|"gRPC ext_proc<br/>9002/TCP TLS"| ExtProc
    ExtProc -->|"routing decision<br/>(target endpoint)"| Envoy
    Envoy -->|"HTTP/HTTPS"| ModelPods
    Envoy -->|"HTTP/HTTPS<br/>8000/TCP"| SidecarProxy

    %% Controller watches
    PoolCtrl -->|watches| InferencePoolCR
    ObjectiveCtrl -->|watches| InferenceObjCR
    RewriteCtrl -->|watches| InferenceRewriteCR
    PodCtrl -->|watches| ModelPods
    Controllers -->|"HTTPS/443"| K8sAPI

    %% Data layer
    Collectors -->|"HTTP poll<br/>metrics"| ModelPods
    KVEvents -->|"ZMQ SUB<br/>5557/TCP"| ModelPods

    %% Sidecar flows
    SidecarProxy -->|"prefill request"| ModelPods
    SidecarProxy -->|"decode request<br/>8001/TCP"| ModelPods

    %% Observability
    MetricsSvc -->|scraped by| Prometheus
    ExtProc -->|"OTLP traces<br/>4317/TCP"| OTLPCollector
    SidecarProxy -->|"OTLP traces<br/>4317/TCP"| OTLPCollector

    %% Styling
    classDef epp fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef sidecar fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef controller fill:#3498db,stroke:#333,stroke-width:1px,color:#fff
    classDef plugin fill:#2ecc71,stroke:#333,stroke-width:1px,color:#fff
    classDef external fill:#e8e8e8,stroke:#999,stroke-width:1px
    classDef crd fill:#f5a623,stroke:#333,stroke-width:1px
    classDef observability fill:#1abc9c,stroke:#333,stroke-width:1px,color:#fff

    class ExtProc,HealthSvc,MetricsSvc epp
    class SidecarProxy sidecar
    class PoolCtrl,ObjectiveCtrl,RewriteCtrl,PodCtrl controller
    class Filters,Scorers,Pickers,ProfileHandlers,FlowControl,Collectors,KVEvents,DataProducers plugin
    class Envoy,Client,K8sAPI,ModelPods external
    class InferencePoolCR,InferenceObjCR,InferenceRewriteCR crd
    class Prometheus,OTLPCollector observability
    class NIXL,SharedStorage,SGLang,Mooncake plugin
