graph TB
    subgraph ExternalClients["External Clients"]
        Client[Inference Client]
    end

    subgraph IngressLayer["Ingress Layer"]
        Gateway["Gateway API<br/>(inference-gateway)<br/>80/TCP HTTP"]
        Envoy["Envoy Proxy<br/>ext-proc filter"]
    end

    subgraph EPPComponent["EPP (Endpoint Picker)"]
        ExtProc["gRPC ext-proc Server<br/>9002/TCP"]
        HealthGRPC["gRPC Health<br/>9003/TCP"]
        Metrics["Prometheus Metrics<br/>9090/TCP HTTP"]
        ZMQ["ZMQ KV-Events SUB<br/>5557/TCP"]

        subgraph SchedulingPipeline["Scheduling Pipeline"]
            Filters["Filters<br/>(ByLabel, PrefixCacheAffinity,<br/>SLOHeadroomTier)"]
            Scorers["Scorers<br/>(ActiveRequest, KVCache,<br/>Latency, LoadAware,<br/>LoRAffinity, PrefixCache,<br/>SessionAffinity)"]
            Pickers["Pickers<br/>(MaxScore, WeightedRandom)"]
        end

        ExtProc --> Filters
        Filters --> Scorers
        Scorers --> Pickers
    end

    subgraph PDSidecar["PD Sidecar Proxy"]
        Proxy["HTTP Reverse Proxy<br/>8000/TCP"]
        subgraph Connectors["KV Transfer Connectors"]
            NIXL["NIXL v2"]
            SharedStorage["Shared Storage"]
            SGLang["SGLang"]
        end
        Proxy --> Connectors
    end

    subgraph Tokenizer["UDS Tokenizer Sidecar"]
        UDS["gRPC over UDS<br/>/tmp/tokenizer"]
    end

    subgraph ModelServers["Model Servers (vLLM)"]
        Prefiller["Prefiller Instances"]
        Decoder["Decoder Instances<br/>8001/TCP"]
        ModelMetrics["Metrics Endpoint<br/>3000/TCP"]
    end

    subgraph KubernetesAPI["Kubernetes API"]
        K8sAPI["API Server<br/>443/TCP HTTPS"]
        InferencePoolCR["InferencePool CR"]
        InferenceObjCR["InferenceObjective CR"]
        ModelRewriteCR["InferenceModelRewrite CR"]
        PodResource["Pod Resources"]
    end

    %% Request Flow
    Client -->|HTTP| Gateway
    Gateway --> Envoy
    Envoy -->|gRPC ext-proc<br/>9002/TCP| ExtProc
    Pickers -->|routing decision<br/>target endpoint header| Envoy
    Envoy -->|routed request<br/>8000/TCP| Decoder

    %% PD Flow
    Envoy -->|P/D request<br/>8000/TCP| Proxy
    Proxy -->|prefill| Prefiller
    Proxy -->|decode<br/>8001/TCP| Decoder

    %% EPP Data Sources
    ExtProc -->|watch CRDs| K8sAPI
    K8sAPI --- InferencePoolCR
    K8sAPI --- InferenceObjCR
    K8sAPI --- ModelRewriteCR
    K8sAPI --- PodResource
    ExtProc -->|scrape metrics<br/>3000/TCP| ModelMetrics
    ZMQ -->|KV cache events| ModelServers
    ExtProc -->|tokenize prompts| UDS

    %% Styling
    style ExtProc fill:#4a90e2,stroke:#333,color:#fff
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style UDS fill:#4a90e2,stroke:#333,color:#fff
    style Envoy fill:#e8a838,stroke:#333,color:#fff
    style Gateway fill:#e8a838,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjCR fill:#f5a623,stroke:#333
    style ModelRewriteCR fill:#f5a623,stroke:#333
    style PodResource fill:#f5a623,stroke:#333
    style Prefiller fill:#7ed321,stroke:#333
    style Decoder fill:#7ed321,stroke:#333
    style ModelMetrics fill:#7ed321,stroke:#333
    style Filters fill:#d5e8d4,stroke:#82b366
    style Scorers fill:#d5e8d4,stroke:#82b366
    style Pickers fill:#d5e8d4,stroke:#82b366
    style NIXL fill:#dae8fc,stroke:#6c8ebf
    style SharedStorage fill:#dae8fc,stroke:#6c8ebf
    style SGLang fill:#dae8fc,stroke:#6c8ebf
