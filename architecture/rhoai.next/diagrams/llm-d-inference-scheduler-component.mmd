graph TB
    subgraph EPP_Pod["EPP Pod"]
        direction TB
        subgraph EPP["EPP (Endpoint Picker)"]
            ExtProc["ext-proc gRPC Server<br/>9002/TCP"]
            HealthSvc["Health Service<br/>9003/TCP"]
            MetricsSvc["Metrics Endpoint<br/>9090/TCP"]
        end

        subgraph SchedulingFramework["Scheduling Framework"]
            direction LR
            Filters["Filters<br/>ByLabel | PrefixCacheAffinity<br/>SLOHeadroomTier"]
            Scorers["Scorers<br/>LoadAware | PrefixCache<br/>KVCacheUtil | LoRAffinity<br/>Latency | PrecisePrefixCache"]
            Pickers["Pickers<br/>MaxScore | WeightedRandom"]
            Filters --> Scorers --> Pickers
        end

        subgraph FlowControl["Flow Control Layer"]
            Admission["Admission Control"]
            Fairness["Fairness Policies<br/>GlobalStrict | RoundRobin"]
            Ordering["Ordering Policies<br/>FCFS | EDF | SLO-Deadline"]
        end

        subgraph DataLayer["Data Layer"]
            DataGraph["DAG-Ordered<br/>Data Producers"]
            MetricsScraper["Metrics Scraper<br/>HTTP Polling"]
            ZMQSub["ZMQ Subscriber<br/>5557/TCP"]
        end

        subgraph Controllers["Kubernetes Controllers"]
            PoolCtrl["InferencePool<br/>Reconciler"]
            PodCtrl["Pod<br/>Reconciler"]
            ObjCtrl["InferenceObjective<br/>Reconciler"]
            RewriteCtrl["InferenceModelRewrite<br/>Reconciler"]
        end

        UDSTokenizer["UDS Tokenizer<br/>Sidecar"]

        ExtProc --> SchedulingFramework
        SchedulingFramework --> FlowControl
        DataLayer --> SchedulingFramework
    end

    subgraph ModelPod["Model Server Pod (with P/D)"]
        direction TB
        PDSidecar["PD Sidecar Proxy<br/>8000/TCP HTTP/HTTPS"]
        vLLM["vLLM Decoder<br/>8001/TCP"]
        PDSidecar -->|decode requests| vLLM
    end

    %% External Actors
    Client["External Client"]
    EnvoyGW["Envoy Gateway"]

    %% CRDs
    InferencePoolCR["InferencePool CR"]
    InferenceObjCR["InferenceObjective CR"]
    ModelRewriteCR["InferenceModelRewrite CR"]

    %% External Services
    K8sAPI["Kubernetes API<br/>443/TCP"]
    OTLPCollector["OTLP Collector<br/>4317/TCP"]
    KVCacheSource["llm-d-kv-cache<br/>5557/TCP ZMQ"]
    ModelMetrics["Model Server<br/>/metrics"]
    Prometheus["Prometheus"]

    %% Flows
    Client -->|HTTP/80| EnvoyGW
    EnvoyGW -->|gRPC ext-proc<br/>9002/TCP TLS| ExtProc
    ExtProc -->|routing decision| EnvoyGW
    EnvoyGW -->|routed request<br/>8000/TCP| PDSidecar

    Controllers -->|watch| K8sAPI
    InferencePoolCR -->|watched by| PoolCtrl
    InferenceObjCR -->|watched by| ObjCtrl
    ModelRewriteCR -->|watched by| RewriteCtrl

    MetricsScraper -->|scrape| ModelMetrics
    ZMQSub -->|subscribe| KVCacheSource
    EPP -->|traces| OTLPCollector
    Prometheus -->|scrape| MetricsSvc

    PDSidecar -->|prefill requests| RemotePrefiller["Remote Prefiller Pods"]
    PDSidecar -->|encoder requests| RemoteEncoder["Remote Encoder Pods"]

    %% Styles
    style ExtProc fill:#4a90e2,stroke:#333,color:#fff
    style HealthSvc fill:#4a90e2,stroke:#333,color:#fff
    style MetricsSvc fill:#4a90e2,stroke:#333,color:#fff
    style PDSidecar fill:#4a90e2,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style EnvoyGW fill:#f5a623,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjCR fill:#f5a623,stroke:#333
    style ModelRewriteCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OTLPCollector fill:#e8e8e8,stroke:#333
    style KVCacheSource fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ModelMetrics fill:#e8e8e8,stroke:#333
    style RemotePrefiller fill:#7ed321,stroke:#333,color:#fff
    style RemoteEncoder fill:#7ed321,stroke:#333,color:#fff
    style UDSTokenizer fill:#4a90e2,stroke:#333,color:#fff
