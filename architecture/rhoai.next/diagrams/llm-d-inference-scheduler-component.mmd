graph TB
    subgraph EPP["Endpoint Picker (EPP) - ext-proc Service"]
        direction TB
        ExtProc["gRPC ext-proc Server<br/>9002/TCP"]
        HealthGRPC["gRPC Health Server<br/>9003/TCP"]
        MetricsServer["Metrics Server<br/>9090/TCP"]

        subgraph Reconcilers["Controller-Runtime Reconcilers"]
            PoolReconciler["InferencePool<br/>Reconciler"]
            PodReconciler["Pod<br/>Reconciler"]
            ObjectiveReconciler["InferenceObjective<br/>Reconciler"]
            RewriteReconciler["InferenceModelRewrite<br/>Reconciler"]
        end

        subgraph SchedulingPipeline["Scheduling Pipeline"]
            Filters["Filters<br/>(CEL, affinity,<br/>capacity)"]
            Scorers["Scorers<br/>(KV-cache, latency,<br/>prefix, LoRA)"]
            Picker["Picker<br/>(endpoint selection)"]
            Filters --> Scorers --> Picker
        end

        subgraph DataLayer["Data Layer Runtime"]
            MetricsScraper["Metrics Scraper<br/>(HTTP polling)"]
            ZMQSubscriber["ZMQ Subscriber<br/>5557/TCP"]
            DataProducers["Data Producers<br/>(DAG pipeline)"]
            MetricsScraper --> DataProducers
            ZMQSubscriber --> DataProducers
        end

        subgraph FlowControl["Flow Control Layer (experimental)"]
            PriorityBands["Priority Bands"]
            FairnessPolicy["Fairness Policy"]
            SaturationDetect["Saturation<br/>Detection"]
            PriorityBands --> FairnessPolicy
            SaturationDetect --> PriorityBands
        end

        ExtProc --> SchedulingPipeline
        DataProducers --> SchedulingPipeline
        Reconcilers --> DataLayer
        ObjectiveReconciler --> FlowControl
    end

    subgraph Sidecar["PD-Sidecar (per model server pod)"]
        ReverseProxy["HTTP Reverse Proxy<br/>8000/TCP"]
        KVConnector["KV Connector<br/>(NIXLv2/Mooncake/<br/>SGLang/shared-storage)"]
        ECConnector["EC Connector<br/>(encoder cache)"]
        SSRFValidator["SSRF Allowlist<br/>Validator"]
        ReverseProxy --> KVConnector
        ReverseProxy --> ECConnector
        ReverseProxy --> SSRFValidator
    end

    %% External Inputs
    Client["External Client"] -->|"HTTP/HTTPS"| Gateway["Envoy/Istio<br/>Gateway"]
    Gateway -->|"gRPC ext-proc<br/>9002/TCP TLS"| ExtProc

    %% CRDs
    InferencePoolCR["InferencePool CR<br/>(GIE)"] -->|"watched by"| PoolReconciler
    InferenceObjCR["InferenceObjective CR<br/>(llm-d.ai)"] -->|"watched by"| ObjectiveReconciler
    InferenceRewriteCR["InferenceModelRewrite CR<br/>(llm-d.ai)"] -->|"watched by"| RewriteReconciler
    PodResources["Model Server Pods"] -->|"watched by"| PodReconciler

    %% EPP to Model Servers
    MetricsScraper -->|"HTTP scrape<br/>/metrics"| ModelServers["vLLM/SGLang<br/>Model Servers"]
    ZMQSubscriber -->|"ZMQ SUB<br/>KV-cache events"| ModelServers

    %% Gateway to Sidecar flow
    Gateway -->|"HTTP/HTTPS<br/>8000/TCP"| ReverseProxy
    ReverseProxy -->|"prefill dispatch"| RemotePrefiller["Remote Prefiller<br/>Pod"]
    ReverseProxy -->|"encode dispatch"| RemoteEncoder["Remote Encoder<br/>Pod"]
    ReverseProxy -->|"decode forward<br/>8001/TCP"| LocalDecoder["Local Decoder<br/>(vLLM)"]

    %% Observability
    ExtProc -.->|"gRPC OTLP<br/>4317/TCP"| OTELCollector["OTEL Collector"]
    ReverseProxy -.->|"gRPC OTLP<br/>4317/TCP"| OTELCollector
    MetricsServer -.->|"HTTP /metrics<br/>9090/TCP"| Prometheus["Prometheus"]

    %% Styling
    style EPP fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Sidecar fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style ExtProc fill:#4a90e2,color:#fff
    style HealthGRPC fill:#4a90e2,color:#fff
    style MetricsServer fill:#4a90e2,color:#fff
    style ReverseProxy fill:#66bb6a,color:#fff
    style Gateway fill:#ff9800,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style InferencePoolCR fill:#f5a623
    style InferenceObjCR fill:#f5a623
    style InferenceRewriteCR fill:#f5a623
    style PodResources fill:#f5a623
    style ModelServers fill:#999,color:#fff
    style RemotePrefiller fill:#999,color:#fff
    style RemoteEncoder fill:#999,color:#fff
    style LocalDecoder fill:#999,color:#fff
    style OTELCollector fill:#e8e8e8
    style Prometheus fill:#e8e8e8
