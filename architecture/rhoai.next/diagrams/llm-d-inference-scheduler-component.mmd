graph TB
    subgraph External["External Traffic"]
        Client[External Client]
    end

    subgraph GatewayLayer["Gateway Layer"]
        Gateway["Inference Gateway<br/>(Envoy)"]
        HTTPRoute["HTTPRoute<br/>(backendRef → InferencePool)"]
        Gateway -->|routes via| HTTPRoute
    end

    subgraph EPPComponent["EPP (Endpoint Picker)"]
        direction TB
        ExtProc["ext_proc gRPC Server<br/>9002/TCP"]
        HealthGRPC["Health gRPC Server<br/>9003/TCP"]
        MetricsHTTP["Metrics HTTP Server<br/>9090/TCP"]
        ZMQSub["ZMQ Subscriber<br/>5557/TCP"]

        subgraph SchedulingPipeline["Scheduling Pipeline"]
            Filters["Filters<br/>(plugin framework)"]
            Scorers["Weighted Scorers<br/>(plugin framework)"]
            Pickers["Pickers<br/>(plugin framework)"]
            ProfileHandler["Profile Handler"]
            Filters --> Scorers --> Pickers
            ProfileHandler -->|selects profile| Filters
        end

        subgraph Controllers["Controller-Runtime Reconcilers"]
            PoolCtrl["InferencePool<br/>Reconciler"]
            PodCtrl["Pod<br/>Reconciler"]
            ObjCtrl["InferenceObjective<br/>Reconciler"]
            RewriteCtrl["InferenceModelRewrite<br/>Reconciler"]
        end

        subgraph DataLayer["Data Layer"]
            KVCacheIndex["KV Cache Index<br/>(llm-d-kv-cache)"]
            EndpointStore["Endpoint<br/>Attribute Map"]
        end

        subgraph FlowControl["Flow Control (Experimental)"]
            Admission["Admission Controller"]
            PriorityBands["Priority Bands"]
            Admission -->|uses| PriorityBands
        end

        ExtProc --> ProfileHandler
        ZMQSub --> KVCacheIndex
    end

    subgraph SidecarComponent["P/D Routing Sidecar"]
        direction TB
        SidecarProxy["HTTP/HTTPS Proxy<br/>8000/TCP"]
        subgraph Connectors["KV Connectors"]
            NIXL["NIXL V2"]
            SharedStorage["Shared Storage"]
            SGLang["SGLang"]
        end
        SSRFAllowlist["SSRF Allowlist<br/>(InferencePool-based)"]
        SidecarProxy --> Connectors
        SidecarProxy --> SSRFAllowlist
    end

    subgraph TokenizerSidecar["UDS Tokenizer"]
        Tokenizer["Tokenizer Service<br/>Unix Domain Socket"]
    end

    subgraph ModelServers["vLLM Model Server Pods"]
        vLLMPod["vLLM Pod"]
        vLLMMetrics["Prometheus Metrics"]
        vLLMKVEvents["KV Cache Events<br/>(ZMQ PUB 5556/TCP)"]
        vLLMDecoder["Decoder<br/>8001/TCP"]
        vLLMPrefiller["Prefiller<br/>configurable/TCP"]
    end

    subgraph K8sServices["Kubernetes"]
        K8sAPI["API Server<br/>443/TCP"]
        InferencePoolCR["InferencePool CR"]
        InferenceObjCR["InferenceObjective CR"]
        ModelRewriteCR["InferenceModelRewrite CR"]
    end

    %% External flows
    Client -->|HTTP/80| Gateway
    Gateway -->|gRPC ext_proc<br/>9002/TCP| ExtProc
    ExtProc -->|"routing decision<br/>target endpoint headers"| Gateway
    Gateway -->|routed request| vLLMPod
    Gateway -->|"routed request<br/>P/D mode"| SidecarProxy

    %% EPP to dependencies
    Controllers -->|watch| K8sAPI
    K8sAPI --- InferencePoolCR
    K8sAPI --- InferenceObjCR
    K8sAPI --- ModelRewriteCR
    EPPComponent -->|scrape metrics| vLLMMetrics
    ZMQSub -->|subscribe KV events| vLLMKVEvents
    Tokenizer -->|tokenize prompts| ExtProc

    %% Sidecar flows
    SidecarProxy -->|prefill request| vLLMPrefiller
    SidecarProxy -->|decode request| vLLMDecoder
    SSRFAllowlist -->|watch| K8sAPI

    %% Monitoring
    Prometheus["Prometheus"] -->|scrape /metrics| MetricsHTTP

    %% Styling
    style ExtProc fill:#4a90e2,stroke:#333,color:#fff
    style HealthGRPC fill:#4a90e2,stroke:#333,color:#fff
    style MetricsHTTP fill:#4a90e2,stroke:#333,color:#fff
    style ZMQSub fill:#4a90e2,stroke:#333,color:#fff
    style SidecarProxy fill:#50c878,stroke:#333,color:#fff
    style Tokenizer fill:#9b59b6,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjCR fill:#f5a623,stroke:#333
    style ModelRewriteCR fill:#f5a623,stroke:#333
    style vLLMPod fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
