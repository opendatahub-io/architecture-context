graph TD
    subgraph "caikit-tgis-backend RBAC"
        Note["This is a Python library, not a deployed service.<br/>No RBAC resources are defined by this component.<br/><br/>RBAC is inherited from the consuming application's<br/>ServiceAccount (e.g., caikit-tgis-serving runtime)."]
    end

    subgraph "Inherited Security Context"
        direction TB
        ConsumingSA["Consuming App ServiceAccount<br/>(e.g., caikit-tgis-serving)"]
        ConsumingRB["RoleBinding / ClusterRoleBinding<br/>(defined by consuming app)"]
        ConsumingRole["Role / ClusterRole<br/>(defined by consuming app)"]

        ConsumingSA -->|"bound via"| ConsumingRB
        ConsumingRB -->|"grants"| ConsumingRole
    end

    subgraph "Library Security Controls"
        direction TB
        TLSConfig["TLS Configuration<br/>grpc.ssl_channel_credentials"]
        CertValidation["Certificate Validation<br/>- CA cert required before client cert<br/>- Client cert+key must be a pair<br/>- File existence checked at init"]
        FIPSCompliance["FIPS Compliance<br/>Inherited from container OpenSSL<br/>(FIPS-validated on UBI)"]

        TLSConfig --> CertValidation
        CertValidation --> FIPSCompliance
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404,stroke-width:2px
    style ConsumingSA fill:#4a90e2,stroke:#333,color:#fff
    style ConsumingRB fill:#f5a623,stroke:#333,color:#fff
    style ConsumingRole fill:#f5a623,stroke:#333,color:#fff
    style TLSConfig fill:#d5e8d4,stroke:#82b366
    style CertValidation fill:#d5e8d4,stroke:#82b366
    style FIPSCompliance fill:#d5e8d4,stroke:#82b366
