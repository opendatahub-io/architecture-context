graph TB
    %% RHOAI MCP Server - Security Network Diagram
    %% Generated from: architecture/rhoai.next/rhoai-mcp.md

    subgraph External["EXTERNAL (Untrusted)"]
        Agent["AI Agent<br/>(Claude Desktop / Lightspeed / Custom LLM)"]
    end

    subgraph Ingress["INGRESS (DMZ) - OpenShift Router"]
        Route["OpenShift Route<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination<br/>Auth: None"]
    end

    subgraph AppLayer["APPLICATION (Namespace: rhoai-mcp)"]
        direction TB

        subgraph MCPPod["RHOAI MCP Server Pod"]
            MCPService["Service: rhoai-mcp (ClusterIP)<br/>Port: 8000/TCP<br/>SA: rhoai-mcp<br/>Image: UBI9/python-312"]
            SafetyCtrl["Safety Controls:<br/>read_only_mode<br/>dangerous_ops gating"]
        end
    end

    subgraph PlatformSvc["PLATFORM SERVICES (In-Cluster)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token → RBAC"]

        ModelRegSvc["Model Registry Service<br/>8080/TCP HTTP<br/>No Encryption (in-cluster)<br/>Auth: None / OAuth / Bearer"]

        NeuralNavSvc["Neural Navigator Backend<br/>backend.neuralnav.svc.cluster.local<br/>8000/TCP HTTP<br/>No Encryption<br/>Auth: None"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM Credentials"]
    end

    %% Flows with security details
    Agent -->|"HTTPS/443<br/>TLS Edge<br/>No App Auth"| Route
    Route -->|"HTTP/8000<br/>No Encryption (post-TLS)<br/>No Auth"| MCPService
    MCPService -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (SA/kubeconfig)"| K8sAPI
    MCPService -->|"HTTP/8080<br/>via port-forward tunnel<br/>None / OAuth / Bearer"| ModelRegSvc
    MCPService -->|"HTTP/8000<br/>No Encryption<br/>No Auth"| NeuralNavSvc
    MCPService -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef safety fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Agent external
    class Route ingress
    class MCPService,MCPPod application
    class SafetyCtrl safety
    class K8sAPI,ModelRegSvc,NeuralNavSvc platform
    class S3 externalservice
