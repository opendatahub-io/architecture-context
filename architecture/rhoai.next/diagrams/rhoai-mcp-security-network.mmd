graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Agent["AI Agent<br/>(Claude Desktop/Code)"]
    end

    subgraph Ingress["INGRESS (DMZ - Edge TLS)"]
        Route["OpenShift Route<br/>443/TCP → 8000/TCP<br/>TLS edge termination<br/>No Route-level auth"]
    end

    subgraph Application["APPLICATION TIER (Cluster-Internal)"]
        direction TB

        subgraph NS_MCP["Namespace: rhoai-mcp"]
            MCPServer["RHOAI MCP Server<br/>Service: rhoai-mcp (ClusterIP)<br/>Port: 8000/TCP HTTP<br/>SA: rhoai-mcp<br/>Image: UBI 9 / Python 3.12<br/>Endpoints: /health, /sse, /message"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]

        ModelRegistry["Model Registry Service<br/>8080/TCP HTTP (no auth)<br/>8443/TCP HTTPS (OAuth)<br/>Auto-discovered via CRD"]

        ModelCatalog["Model Catalog API<br/>8080/TCP HTTP (no auth)<br/>8443/TCP HTTPS (OAuth)"]

        NeuralNav["Neural Navigator Backend<br/>8000/TCP HTTP<br/>No auth (in-cluster)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitHub["GitHub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]

        Registry["Container Image Registry<br/>5000/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
    end

    %% Flows
    Agent -->|"HTTPS/443<br/>TLS edge<br/>No MCP auth"| Route
    Agent -.->|"stdio (local)<br/>No encryption<br/>kubeconfig auth"| MCPServer

    Route -->|"HTTP/8000<br/>No encryption<br/>(post-TLS termination)"| MCPServer

    MCPServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token (SA/kubeconfig)"| K8sAPI

    MCPServer -->|"HTTP/8080 or HTTPS/8443<br/>None or TLS<br/>None or OAuth Bearer"| ModelRegistry
    MCPServer -->|"HTTP/8080 or HTTPS/8443<br/>None or TLS<br/>None or OAuth Bearer"| ModelCatalog

    MCPServer -->|"HTTP/8000<br/>No encryption<br/>No auth"| NeuralNav

    MCPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (git clone)"| GitHub
    MCPServer -->|"HTTPS/5000<br/>TLS 1.2+<br/>No auth"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Agent external
    class Route ingress
    class MCPServer application
    class K8sAPI,ModelRegistry,ModelCatalog,NeuralNav internal
    class GitHub,Registry externalservice
