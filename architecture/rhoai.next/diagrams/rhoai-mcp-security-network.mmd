graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Agent["AI Agent<br/>(Claude Desktop / Code / Lightspeed)"]
    end

    subgraph Ingress["INGRESS (DMZ - OpenShift Router)"]
        Route["OpenShift Route: rhoai-mcp<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination<br/>Auto-generated certificate"]
    end

    subgraph Application["APPLICATION (Namespace: redhat-ods-applications)"]
        direction TB

        subgraph MCPPod["RHOAI MCP Server Pod"]
            direction TB
            MCPServer["FastMCP Server<br/>Port: 8000/TCP<br/>Endpoints: /health, /sse, /messages<br/>SA: rhoai-mcp"]
            AuthMiddleware["Auth Middleware (ASGI)<br/>OIDC JWT / OCP TokenReview<br/>Per-tool RBAC filtering<br/>SubjectAccessReview"]
            K8sClient["K8s Dynamic Client<br/>Impersonate-User headers<br/>(multi-user mode)"]
        end

        SecurityContext["Security Context:<br/>runAsNonRoot: true<br/>readOnlyRootFilesystem: true<br/>drop ALL capabilities<br/>seccompProfile: RuntimeDefault"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token / Impersonation"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP or 8443/TCP HTTPS<br/>Optional TLS<br/>None / OAuth / Bearer"]
        ModelCatalog["Model Catalog<br/>8080/8443 TCP<br/>Optional TLS<br/>No auth"]
        PlannerSvc["Planner Backend<br/>8000/TCP HTTP<br/>No encryption<br/>No auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        GitHub["GitHub<br/>(rh-ai-quickstart)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        OIDC["OIDC Identity Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS public endpoint"]
    end

    %% Flows
    Agent -->|"HTTPS/443<br/>TLS Edge<br/>Optional OIDC Bearer"| Route
    Route -->|"HTTP/8000<br/>No encryption<br/>(post-TLS termination)"| MCPServer
    MCPServer --> AuthMiddleware
    AuthMiddleware --> K8sClient

    K8sClient -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token / Impersonate headers"| K8sAPI
    K8sClient -->|"HTTP(S)/8080-8443<br/>Optional TLS<br/>Optional OAuth"| ModelRegistry
    K8sClient -->|"HTTP(S)/8080-8443<br/>Optional TLS"| ModelCatalog
    K8sClient -->|"HTTP/8000<br/>No encryption"| PlannerSvc
    K8sClient -->|"HTTPS/443<br/>TLS 1.2+<br/>git clone"| GitHub
    AuthMiddleware -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS fetch"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterinternal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secctx fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class Agent external
    class Route ingress
    class MCPServer,AuthMiddleware,K8sClient application
    class K8sAPI,ModelRegistry,ModelCatalog,PlannerSvc clusterinternal
    class GitHub,OIDC externalservice
    class SecurityContext secctx
