graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["🟢 No RBAC defined by this component"]
        L2["Container images run as non-root"]
    end

    subgraph ContainerSecurity["Container Security Profile"]
        direction TB
        UID["UID: 1001<br/>(non-root)"]
        GID["GID: 0<br/>(OpenShift pattern)"]
        UID --- GID
    end

    subgraph ImageTypes["Image Security Profiles"]
        direction TB

        subgraph RuntimeProfile["Runtime Training Images"]
            RT["Runtime Training<br/>(CUDA/ROCm)"]
            RT_Caps["Capabilities:<br/>- No privileged access<br/>- No host network<br/>- No host PID<br/>- GPU device access<br/>  (via device plugin)"]
            RT --- RT_Caps
        end

        subgraph OpenMPIProfile["OpenMPI Training Images"]
            MPI["OpenMPI Training<br/>(CUDA/ROCm)"]
            MPI_Caps["Capabilities:<br/>- SSH server (port 2222)<br/>- StrictModes=no<br/>- StrictHostKeyChecking=no<br/>- uid_entrypoint.sh modifies /etc/passwd<br/>- GPU + InfiniBand RDMA"]
            MPI --- MPI_Caps
        end

        subgraph UniversalProfile["Universal Training Images"]
            UNI["Universal Training<br/>(TH06)"]
            UNI_Caps["Capabilities:<br/>- JupyterLab server (port 8888)<br/>- Dual-mode entrypoint<br/>- GPU device access<br/>  (via device plugin)"]
            UNI --- UNI_Caps
        end

        subgraph RayProfile["Ray Runtime Images"]
            RAY["Ray Runtime<br/>(CPU/CUDA/ROCm)"]
            RAY_Caps["Capabilities:<br/>- Ray GCS (port 6379)<br/>- Ray Dashboard (port 8265)<br/>- Ray Client (port 10001)<br/>- No encryption/auth<br/>- GPU device access<br/>  (CUDA/ROCm variants)"]
            RAY --- RAY_Caps
        end
    end

    subgraph Secrets["Secrets Consumed (not defined)"]
        direction TB
        SSHKey["SSH Key Pair<br/>Type: Opaque<br/>Provisioned by: Trainer v2 controller<br/>Scope: Per-job<br/>Auto-rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Provisioned by: User<br/>Auto-rotate: No"]
        AWSCreds["AWS Credentials<br/>Type: Opaque<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    subgraph ConsumingOperatorRBAC["RBAC Defined by Consuming Operators<br/>(not this component)"]
        direction TB
        KFTORbac["Training Operator RBAC<br/>→ manages PyTorchJob pods"]
        TrainerRbac["Kubeflow Trainer v2 RBAC<br/>→ manages TrainJob pods + secrets"]
        KubeRayRbac["KubeRay Operator RBAC<br/>→ manages RayCluster pods"]
        NotebooksRbac["Notebooks Controller RBAC<br/>→ manages Notebook pods + routes"]
    end

    %% Relationships
    ContainerSecurity -->|"applies to all"| ImageTypes
    SSHKey -->|"mounted in"| MPI
    HFToken -->|"mounted in"| RT
    HFToken -->|"mounted in"| UNI
    AWSCreds -->|"mounted in"| RT
    AWSCreds -->|"mounted in"| UNI

    %% Styling
    style Legend fill:#f0f0f0,stroke:#ccc
    style ContainerSecurity fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RuntimeProfile fill:#fff3e0,stroke:#f5a623
    style OpenMPIProfile fill:#fce4ec,stroke:#e91e63
    style UniversalProfile fill:#e8f5e9,stroke:#7ed321
    style RayProfile fill:#f3e5f5,stroke:#9c27b0
    style Secrets fill:#fff9c4,stroke:#f9a825,stroke-width:2px
    style ConsumingOperatorRBAC fill:#e0e0e0,stroke:#999,stroke-dasharray:5 5

    style UID fill:#bbdefb,stroke:#1565c0
    style GID fill:#bbdefb,stroke:#1565c0
