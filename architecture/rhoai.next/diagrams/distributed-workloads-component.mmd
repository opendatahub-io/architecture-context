graph TB
    subgraph DW["Distributed Workloads Component"]
        direction TB

        subgraph RuntimeTraining["Runtime Training Images"]
            RT_CUDA["Runtime CUDA<br/>12.1 / 12.4 / 12.8 / 13.0<br/>(UBI9 + vendor RPMs)"]
            RT_ROCm["Runtime ROCm<br/>6.2 / 6.4<br/>(UBI9 + vendor RPMs)"]
            RT_OpenMPI_CUDA["OpenMPI CUDA 13.0<br/>(AIPCC base)<br/>SSH:2222/TCP"]
            RT_OpenMPI_ROCm["OpenMPI ROCm 6.4<br/>(AIPCC base)<br/>SSH:2222/TCP"]
        end

        subgraph UniversalTraining["Universal Training Images (TH06)"]
            UT_CPU["Universal CPU<br/>Jupyter + Runtime<br/>8888/TCP"]
            UT_CUDA["Universal CUDA 13.0<br/>Jupyter + Runtime<br/>8888/TCP"]
            UT_ROCm["Universal ROCm 6.4<br/>Jupyter + Runtime<br/>8888/TCP"]
        end

        subgraph RayRuntime["Ray Runtime Images"]
            Ray_CPU["Ray CPU<br/>2.52.1"]
            Ray_CUDA["Ray CUDA<br/>2.52.1 / 2.55.1"]
            Ray_ROCm["Ray ROCm<br/>2.52.1 / 2.55.1"]
        end

        subgraph Testing["Test Harness"]
            E2E["E2E Test Suite<br/>(Go)"]
            TestImage["Test Harness Image<br/>(Go + OC CLI)"]
            OSU["OSU Benchmarks"]
        end
    end

    %% Consuming Operators
    KFTO["Training Operator<br/>(KFTO v1)"]
    TrainerV2["Kubeflow Trainer v2"]
    KubeRay["KubeRay Operator"]
    Kueue["Kueue"]
    Notebooks["Notebooks Controller"]

    %% Operator → Image references
    KFTO -->|"PyTorchJob CR<br/>image reference"| RT_CUDA
    KFTO -->|"PyTorchJob CR<br/>image reference"| RT_ROCm
    TrainerV2 -->|"TrainJob CR<br/>image reference"| RT_OpenMPI_CUDA
    TrainerV2 -->|"TrainJob CR<br/>image reference"| RT_OpenMPI_ROCm
    TrainerV2 -->|"TrainJob CR<br/>image reference"| UT_CUDA
    KubeRay -->|"RayCluster CR<br/>image reference"| Ray_CPU
    KubeRay -->|"RayCluster CR<br/>image reference"| Ray_CUDA
    KubeRay -->|"RayCluster CR<br/>image reference"| Ray_ROCm
    Kueue -.->|"job queuing"| KFTO
    Kueue -.->|"job queuing"| TrainerV2
    Kueue -.->|"job queuing"| KubeRay
    Notebooks -->|"Notebook CR<br/>image reference"| UT_CPU
    Notebooks -->|"Notebook CR<br/>image reference"| UT_CUDA
    Notebooks -->|"Notebook CR<br/>image reference"| UT_ROCm

    %% Base Image Dependencies
    AIPCC["AIPCC Base Images<br/>(CUDA/ROCm runtimes)"]
    Workbench["RHOAI Workbench<br/>Base Images"]

    AIPCC -->|"base image"| RT_OpenMPI_CUDA
    AIPCC -->|"base image"| RT_OpenMPI_ROCm
    Workbench -->|"base image"| UT_CPU
    Workbench -->|"base image"| UT_CUDA
    Workbench -->|"base image"| UT_ROCm

    %% E2E tests validate
    E2E -.->|"validates"| RT_CUDA
    E2E -.->|"validates"| RT_OpenMPI_CUDA
    E2E -.->|"validates"| Ray_CUDA
    E2E -.->|"validates"| UT_CUDA

    %% External Runtime Dependencies
    HF["HuggingFace Hub<br/>443/TCP"]
    S3["S3 Storage<br/>443/TCP"]
    MLflow["MLflow<br/>5000/TCP"]

    RT_CUDA -.->|"model download"| HF
    UT_CUDA -.->|"model download"| HF
    RT_CUDA -.->|"checkpoints"| S3
    UT_CUDA -.->|"experiment tracking"| MLflow

    %% Styling
    style DW fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style RuntimeTraining fill:#fff3e0,stroke:#f5a623,stroke-width:1px
    style UniversalTraining fill:#e8f5e9,stroke:#7ed321,stroke-width:1px
    style RayRuntime fill:#f3e5f5,stroke:#9c27b0,stroke-width:1px
    style Testing fill:#fce4ec,stroke:#e91e63,stroke-width:1px

    style KFTO fill:#bbdefb,stroke:#1565c0
    style TrainerV2 fill:#bbdefb,stroke:#1565c0
    style KubeRay fill:#bbdefb,stroke:#1565c0
    style Kueue fill:#bbdefb,stroke:#1565c0
    style Notebooks fill:#bbdefb,stroke:#1565c0
    style AIPCC fill:#c8e6c9,stroke:#2e7d32
    style Workbench fill:#c8e6c9,stroke:#2e7d32

    style HF fill:#fff9c4,stroke:#f9a825
    style S3 fill:#fff9c4,stroke:#f9a825
    style MLflow fill:#fff9c4,stroke:#f9a825
