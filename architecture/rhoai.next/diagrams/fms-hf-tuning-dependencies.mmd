graph LR
    FMS["FMS HF Tuning<br/>(quay.io/modh/fms-hf-tuning)"]

    %% Internal Platform Dependencies
    FMS -->|"PyTorchJob CR<br/>orchestrates training"| KFTO["Kubeflow Training<br/>Operator (KFTO)"]
    FMS -.->|"queue label<br/>GPU scheduling"| Kueue["Kueue"]

    %% Core Python Dependencies (Required)
    subgraph CoreDeps["Core Python Dependencies (Required)"]
        Transformers["transformers<br/>>=4.55.0,<=4.55.4"]
        Torch["torch<br/>>2.7.0,<2.9.0"]
        TRL["trl<br/>>=0.19.1,<0.20.0"]
        Accelerate["accelerate<br/>>=1.9.0,<2.0.0"]
        PEFT["peft<br/>>=0.18.0,<0.19.0"]
        Datasets["datasets<br/>>=4.0.0,<5.0.0"]
    end

    FMS -->|"model loading<br/>training loop"| Transformers
    FMS -->|"CUDA, FSDP<br/>distributed"| Torch
    FMS -->|"SFTTrainer<br/>SFTConfig"| TRL
    FMS -->|"distributed launcher<br/>FSDP config"| Accelerate
    FMS -->|"LoRA, QLoRA<br/>Prompt Tuning"| PEFT
    FMS -->|"dataset loading<br/>processing"| Datasets

    %% Optional Dependencies
    subgraph OptionalDeps["Optional Dependencies"]
        FlashAttn["flash-attn<br/>>=2.8.3"]
        FMSAccel["fms-acceleration<br/>>=0.6.2"]
        MambaSSM["mamba-ssm<br/>>=2.0.0,<3.0.0"]
        Recommender["tuning_config<br/>_recommender >=0.1.7"]
    end

    FMS -.->|"efficient attention"| FlashAttn
    FMS -.->|"QLoRA, fused LoRA<br/>padding-free, ScatterMoE"| FMSAccel
    FMS -.->|"state space models"| MambaSSM
    FMS -.->|"hyperparameter<br/>optimization"| Recommender

    %% Experiment Tracking (Optional)
    subgraph Trackers["Experiment Tracking (Optional)"]
        AimPkg["aim<br/>>=3.19.0,<4.0"]
        MLflowPkg["mlflow"]
        ClearMLPkg["clearml<br/>==2.0.0"]
    end

    FMS -.->|"metrics logging"| AimPkg
    FMS -.->|"metrics logging"| MLflowPkg
    FMS -.->|"metrics logging"| ClearMLPkg

    %% External Services
    subgraph ExtServices["External Services"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
        PVC["Persistent Volumes<br/>Filesystem"]
        CUDA["NVIDIA CUDA 12.1<br/>cuDNN 9.6 / NCCL 2.18.3"]
    end

    FMS -->|"model download<br/>Bearer Token"| HFHub
    FMS -->|"data I/O<br/>checkpoints"| PVC
    FMS -->|"GPU compute<br/>PCIe/NVLink"| CUDA

    %% Downstream consumers
    subgraph Consumers["Downstream Consumers"]
        vLLM["vLLM<br/>Inference Engine"]
    end

    FMS -->|"LoRA adapter<br/>safetensors"| vLLM

