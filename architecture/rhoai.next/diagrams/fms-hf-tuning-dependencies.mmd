graph LR
    FMS["fms-hf-tuning<br/>SFT Training Toolkit"]

    %% Internal RHOAI Dependencies
    FMS -->|"container image<br/>consumer"| KFTO["Kubeflow Training<br/>Operator (KFTO)"]
    FMS -->|"queue scheduling<br/>kueue.x-k8s.io/queue-name"| Kueue["Kueue"]
    FMS -->|"nvidia.com/gpu<br/>device plugin"| GPUOp["NVIDIA GPU<br/>Operator"]

    %% Core Python Dependencies (Required)
    FMS -->|"SFTTrainer<br/>>=0.19.1"| TRL["trl"]
    FMS -->|"model loading<br/>>=4.55.0"| Transformers["transformers"]
    FMS -->|"PEFT methods<br/>>=0.18.0"| PEFT["peft"]
    FMS -->|"distributed launch<br/>>=1.9.0"| Accelerate["accelerate"]
    FMS -->|"deep learning<br/>>2.7.0"| PyTorch["torch"]
    FMS -->|"data loading<br/>>=4.0.0"| Datasets["datasets"]

    %% Optional Acceleration
    FMS -.->|"QLoRA, padding-free<br/>multipack, ScatterMoE, ODM"| FMSAccel["fms-acceleration<br/>>=0.6.2"]
    FMS -.->|"flash attention<br/>>=2.8.3"| FlashAttn["flash-attn"]
    FMS -.->|"quantization<br/>>0.4.2"| AutoGPTQ["auto-gptq"]

    %% Optional Trackers
    FMS -.->|"metrics tracking"| Aim["AimStack<br/>>=3.19.0"]
    FMS -.->|"metrics tracking"| MLflow["MLflow"]
    FMS -.->|"metrics tracking"| ClearML["ClearML<br/>==2.0.0"]

    %% Kubernetes Resources
    FMS -->|"model/data/output<br/>storage"| PVC["PersistentVolumeClaim"]
    FMS -->|"training config<br/>/etc/config/config.json"| ConfigMap["ConfigMap"]

    %% External Services
    FMS -->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Post-processing integration
    vLLM["vLLM Serving"] -.->|"consumes LoRA<br/>adapters from"| FMS

    %% Styling
    style FMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI (green)
    style KFTO fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff

    %% Core dependencies (blue)
    style TRL fill:#6db3f2,stroke:#333
    style Transformers fill:#6db3f2,stroke:#333
    style PEFT fill:#6db3f2,stroke:#333
    style Accelerate fill:#6db3f2,stroke:#333
    style PyTorch fill:#6db3f2,stroke:#333
    style Datasets fill:#6db3f2,stroke:#333

    %% Optional dependencies (light gray)
    style FMSAccel fill:#d4d4d4,stroke:#333
    style FlashAttn fill:#d4d4d4,stroke:#333
    style AutoGPTQ fill:#d4d4d4,stroke:#333
    style Aim fill:#d4d4d4,stroke:#333
    style MLflow fill:#d4d4d4,stroke:#333
    style ClearML fill:#d4d4d4,stroke:#333

    %% Infrastructure (orange)
    style GPUOp fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
