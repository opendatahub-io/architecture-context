graph LR
    FMS["fms-hf-tuning<br/>SFT Training Framework"]

    %% Internal Platform Dependencies
    FMS -->|"job orchestration<br/>(PyTorchJob CR)"| KFTO["Kubeflow Training<br/>Operator"]
    FMS -.->|"optional queue mgmt<br/>(kueue label)"| Kueue["Kueue"]

    %% Core Python Dependencies (Required)
    FMS -->|"model loading,<br/>tokenization"| Transformers["transformers<br/>>=4.55.0,<=4.55.4"]
    FMS -->|"tensor ops,<br/>FSDP, CUDA"| PyTorch["torch<br/>>2.7.0,<2.9.0"]
    FMS -->|"multi-GPU<br/>orchestration"| Accelerate["accelerate<br/>>=1.9.0,<2.0.0"]
    FMS -->|"SFTTrainer,<br/>SFTConfig"| TRL["trl<br/>>=0.19.1,<0.20.0"]
    FMS -->|"LoRA, aLoRA,<br/>Prompt Tuning"| PEFT["peft<br/>>=0.18.0,<0.19.0"]
    FMS -->|"dataset loading<br/>& processing"| Datasets["datasets<br/>>=4.0.0,<5.0.0"]

    %% Acceleration Plugins (Optional)
    FMS -.->|"quantized LoRA<br/>(4-bit QLoRA)"| FMSPeft["fms-acceleration-peft"]
    FMS -.->|"fused LoRA &<br/>triton kernels"| FMSFoak["fms-acceleration-foak"]
    FMS -.->|"padding-free attn<br/>& multipack"| FMSAadp["fms-acceleration-aadp"]
    FMS -.->|"ScatterMoE<br/>parallelization"| FMSMoe["fms-acceleration-moe"]
    FMS -.->|"online data<br/>mixing"| FMSODM["fms-acceleration-odm"]
    FMS -.->|"flash attention<br/>v2"| FlashAttn["flash-attn<br/>>=2.8.3"]
    FMS -.->|"state-space<br/>models"| Mamba["mamba-ssm<br/>>=2.0.0,<3.0.0"]

    %% External Services
    FMS -->|"model/dataset<br/>downloads<br/>HTTPS/443"| HFHub["Hugging Face Hub"]

    %% Optional Tracking Backends
    FMS -.->|"experiment tracking<br/>HTTP"| AimStack["AimStack"]
    FMS -.->|"experiment tracking<br/>HTTP/HTTPS"| MLflow["MLflow"]
    FMS -.->|"experiment tracking<br/>HTTPS"| ClearML["ClearML"]

    %% Infrastructure
    FMS -->|"model I/O<br/>training data"| PVC["PVC<br/>(Persistent Volume)"]
    FMS -->|"CUDA/NCCL<br/>compute"| GPU["GPU(s)"]

    %% Consumers (reverse dependencies)
    Dashboard["ODH Dashboard"] -.->|"job monitoring<br/>(via KFTO)"| FMS
    DSPipelines["Data Science<br/>Pipelines"] -.->|"training step<br/>(via KFTO)"| FMS

