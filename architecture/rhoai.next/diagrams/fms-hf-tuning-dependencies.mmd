graph LR
    FMS["FMS HF Tuning<br/>quay.io/modh/fms-hf-tuning"]

    %% Internal RHOAI Dependencies
    FMS -->|"PyTorchJob CR<br/>Kubernetes API"| KFTO["Kubeflow Training<br/>Operator (KFTO)"]
    FMS -.->|"queue label<br/>kueue.x-k8s.io/queue-name"| Kueue["Kueue<br/>(optional)"]

    %% Core ML Framework Dependencies
    FMS -->|"model loading<br/>AutoModelForCausalLM"| Transformers["transformers<br/>>=4.55.0,<=4.55.4"]
    FMS -->|"deep learning<br/>CUDA, FSDP"| PyTorch["torch<br/>>2.7.0,<2.9.0"]
    FMS -->|"SFTTrainer<br/>SFTConfig"| TRL["trl<br/>>=0.19.1,<0.20.0"]
    FMS -->|"distributed launch<br/>FSDP config"| Accelerate["accelerate<br/>>=1.9.0,<2.0.0"]
    FMS -->|"LoRA, QLoRA<br/>Prompt Tuning"| PEFT["peft<br/>>=0.18.0,<0.19.0"]
    FMS -->|"dataset loading"| Datasets["datasets<br/>>=4.0.0,<5.0.0"]

    %% Hardware Acceleration
    FMS -.->|"QLoRA, fused LoRA<br/>padding-free, ScatterMoE"| FMSAccel["fms-acceleration<br/>>=0.6.2 (optional)"]
    FMS -.->|"flash attention"| FlashAttn["flash-attn<br/>>=2.8.3 (optional)"]
    FMS -->|"GPU compute<br/>CUDA 12.1"| NVIDIA["NVIDIA CUDA/cuDNN<br/>NCCL 2.18.3"]

    %% External Services
    FMS -->|"model downloads<br/>HTTPS/443 TLS 1.2+<br/>Bearer Token"| HFHub["HuggingFace Hub<br/>huggingface.co"]
    FMS -->|"dataset downloads<br/>HTTPS/443 TLS 1.2+"| HFDatasets["HuggingFace Datasets<br/>huggingface.co"]

    %% Experiment Tracking (optional)
    FMS -.->|"metrics logging<br/>HTTP/HTTPS"| MLflow["MLflow Server<br/>(optional)"]
    FMS -.->|"metrics logging<br/>HTTP/HTTPS"| Aim["Aim Server<br/>(optional)"]
    FMS -.->|"task logging<br/>HTTPS/API key"| ClearML["ClearML Server<br/>(optional)"]

    %% Storage
    FMS -->|"/data/input<br/>/data/output<br/>/data/models"| PVC["PersistentVolumeClaims"]

    %% Downstream Consumer
    vLLM["vLLM<br/>(downstream)"] -.->|"reads adapters<br/>new_embeddings.safetensors"| PVC

