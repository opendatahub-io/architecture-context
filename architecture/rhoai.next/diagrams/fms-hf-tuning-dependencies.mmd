graph LR
    FMS["fms-hf-tuning<br/>SFT Training Toolkit"]

    %% Internal RHOAI Platform Dependencies
    FMS -->|"container image<br/>consumer"| KFTO["Kubeflow Training<br/>Operator (KFTO)"]
    FMS -->|"queue scheduling<br/>label annotation"| Kueue["Kueue"]
    FMS -->|"GPU resources<br/>device plugin"| GPUOp["NVIDIA GPU<br/>Operator"]
    FMS -.->|"Python import<br/>(optional)"| FMSAccel["fms-acceleration<br/>>=0.6.2"]

    %% Post-processing Consumer
    vLLM["vLLM<br/>(post-processing)"] -.->|"consumes LoRA<br/>adapters"| FMS

    %% Core ML Dependencies (Required)
    FMS -->|"model loading<br/>& training"| Transformers["transformers<br/>>=4.55.0,<=4.55.4"]
    FMS -->|"SFTTrainer"| TRL["trl<br/>>=0.19.1,<0.20.0"]
    FMS -->|"PEFT methods<br/>(LoRA, aLoRA)"| PEFT["peft<br/>>=0.18.0,<0.19.0"]
    FMS -->|"distributed<br/>training"| Accelerate["accelerate<br/>>=1.9.0,<2.0.0"]
    FMS -->|"deep learning<br/>framework"| Torch["torch<br/>>2.7.0,<2.9.0"]
    FMS -->|"data loading"| Datasets["datasets<br/>>=4.0.0,<5.0.0"]

    %% Optional Acceleration Dependencies
    FMS -.->|"flash attention<br/>(optional)"| FlashAttn["flash-attn<br/>>=2.8.3"]
    FMS -.->|"QLoRA quantization<br/>(optional)"| AutoGPTQ["auto-gptq<br/>>0.4.2"]
    FMS -.->|"Mamba SSM<br/>(optional)"| MambaSSM["mamba-ssm<br/>>=2.0.0,<3.0.0"]

    %% Experiment Tracker Dependencies
    FMS -.->|"metrics tracking<br/>(optional)"| Aim["aim<br/>>=3.19.0,<4.0"]
    FMS -.->|"metrics tracking<br/>(optional)"| MLflow["mlflow"]
    FMS -.->|"metrics tracking<br/>(optional)"| ClearML["clearml<br/>==2.0.0"]

    %% External Services
    FMS -->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]

    %% Kubernetes Infrastructure
    FMS -->|"storage mount"| PVC["PersistentVolumeClaims"]
    FMS -->|"config mount"| ConfigMap["ConfigMap"]

    %% Utility Dependencies
    FMS -->|"tokenizer"| SentencePiece["sentencepiece<br/>>=0.1.99"]
    FMS -->|"image processing"| Pillow["pillow<br/>>=12.1.1"]
    FMS -->|"safe eval<br/>for rules"| SimpleEval["simpleeval<br/>>=0.9.13"]
    FMS -.->|"config recommender<br/>(optional)"| Recommender["tuning_config_recommender<br/>>=0.1.7"]

    %% Styling
    style FMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI (green)
    style KFTO fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style FMSAccel fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff

    %% Core ML (blue)
    style Transformers fill:#4a90e2,stroke:#333,color:#fff
    style TRL fill:#4a90e2,stroke:#333,color:#fff
    style PEFT fill:#4a90e2,stroke:#333,color:#fff
    style Accelerate fill:#4a90e2,stroke:#333,color:#fff
    style Torch fill:#4a90e2,stroke:#333,color:#fff
    style Datasets fill:#4a90e2,stroke:#333,color:#fff

    %% Optional acceleration (purple)
    style FlashAttn fill:#9b59b6,stroke:#333,color:#fff
    style AutoGPTQ fill:#9b59b6,stroke:#333,color:#fff
    style MambaSSM fill:#9b59b6,stroke:#333,color:#fff

    %% Trackers (orange)
    style Aim fill:#f5a623,stroke:#333,color:#fff
    style MLflow fill:#f5a623,stroke:#333,color:#fff
    style ClearML fill:#f5a623,stroke:#333,color:#fff

    %% External services (red-ish)
    style HFHub fill:#e74c3c,stroke:#333,color:#fff

    %% Infrastructure (grey)
    style GPUOp fill:#999,stroke:#333,color:#fff
    style PVC fill:#999,stroke:#333,color:#fff
    style ConfigMap fill:#999,stroke:#333,color:#fff

    %% Utilities (light blue)
    style SentencePiece fill:#85c1e9,stroke:#333,color:#fff
    style Pillow fill:#85c1e9,stroke:#333,color:#fff
    style SimpleEval fill:#85c1e9,stroke:#333,color:#fff
    style Recommender fill:#85c1e9,stroke:#333,color:#fff
