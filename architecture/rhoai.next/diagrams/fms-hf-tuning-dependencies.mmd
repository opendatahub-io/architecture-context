graph LR
    FMSHFTuning["FMS HF Tuning<br/>LLM Fine-Tuning Framework"]

    %% Internal Platform Dependencies
    FMSHFTuning -->|"PyTorchJob CR<br/>pod lifecycle, GPU scheduling"| KFTO["Kubeflow Training<br/>Operator (KFTO)"]
    FMSHFTuning -.->|"queue-name label<br/>optional scheduling"| Kueue["Kueue"]

    %% Core ML Dependencies (Required)
    FMSHFTuning -->|"model loading<br/>AutoModelForCausalLM"| Transformers["transformers<br/>>=4.55.0,<=4.55.4"]
    FMSHFTuning -->|"FSDP, CUDA<br/>distributed training"| PyTorch["torch<br/>>2.7.0,<2.9.0"]
    FMSHFTuning -->|"SFTTrainer<br/>supervised fine-tuning"| TRL["trl<br/>>=0.19.1,<0.20.0"]
    FMSHFTuning -->|"multi-GPU launch<br/>FSDP config"| Accelerate["accelerate<br/>>=1.9.0,<2.0.0"]
    FMSHFTuning -->|"LoRA, QLoRA<br/>prompt tuning"| PEFT["peft<br/>>=0.18.0,<0.19.0"]
    FMSHFTuning -->|"dataset loading<br/>& processing"| Datasets["datasets<br/>>=4.0.0,<5.0.0"]

    %% Optional ML Dependencies
    FMSHFTuning -.->|"efficient attention"| FlashAttn["flash-attn<br/>>=2.8.3"]
    FMSHFTuning -.->|"hardware accel plugins<br/>QLoRA, fused LoRA, ODM"| FMSAccel["fms-acceleration<br/>>=0.6.2"]
    FMSHFTuning -.->|"state space models"| Mamba["mamba-ssm<br/>>=2.0.0,<3.0.0"]

    %% Experiment Tracking (Optional)
    FMSHFTuning -.->|"experiment tracking"| AimDep["aim<br/>>=3.19.0,<4.0"]
    FMSHFTuning -.->|"experiment tracking"| MLflowDep["mlflow<br/>latest"]
    FMSHFTuning -.->|"experiment tracking"| ClearMLDep["clearml<br/>==2.0.0"]
    FMSHFTuning -.->|"resource monitoring"| HFScanner["HFResourceScanner<br/>>=0.1.0"]

    %% External Services
    FMSHFTuning -->|"model downloads<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    FMSHFTuning -->|"input/output data"| PVC["PersistentVolumeClaim"]
    FMSHFTuning -->|"GPU compute<br/>CUDA 12.1"| CUDA["NVIDIA CUDA/cuDNN"]

    %% Downstream Consumer
    FMSHFTuning -->|"adapter checkpoints<br/>safetensors"| vLLM["vLLM<br/>(inference)"]

    %% Utility Dependencies (Required)
    FMSHFTuning -->|"safe eval<br/>rule engine"| Simpleeval["simpleeval<br/>>=0.9.13,<2.0"]
    FMSHFTuning -->|"model serialization"| Safetensors["safetensors<br/>latest"]

