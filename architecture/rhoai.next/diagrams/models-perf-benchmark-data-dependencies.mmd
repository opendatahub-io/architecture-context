graph LR
    MPBD["models-perf-benchmark-data<br/>(Data Container Image)"]

    %% Internal RHOAI Dependencies
    MPBD -->|"init container<br/>shared volume"| ModelCatalog["model-catalog"]
    ModelRegOp["model-registry-operator"] -->|"manages Deployment<br/>spec"| MPBD

    %% External Dependencies (Build)
    MPBD -->|"base image"| UBI9["UBI9-minimal<br/>(latest)"]
    MPBD -->|"build system"| Konflux["Konflux<br/>(CI/CD)"]

    %% Dev Tool Dependencies (Not Shipped)
    subgraph DevDeps["Development Dependencies (Not Shipped)"]
        direction TB
        ConfluentKafka["confluent-kafka<br/>>=2.11.1"]
        LZ4["lz4<br/>>=4.4.4"]
        Requests["requests<br/>>=2.32.0"]
        PythonDotenv["python-dotenv<br/>>=1.1.1"]
    end

    %% Dev Tool External Services
    subgraph DevServices["Development Services (Not Shipped)"]
        direction TB
        KafkaBroker["Kafka Broker<br/>dev.aihub-public-* topics"]
        ValidationHub["model-validation-hub<br/>us-east4.gcp.redhat.com"]
    end

    KProc["kafka-processor<br/>(dev tool)"] -->|"SASL_SSL/9096"| KafkaBroker
    KProc -->|"uses"| ConfluentKafka
    KProc -->|"uses"| LZ4
    KProc -->|"uses"| PythonDotenv

    AClient["api-client<br/>(dev tool)"] -->|"HTTPS/443"| ValidationHub
    AClient -->|"uses"| Requests
    AClient -->|"uses"| PythonDotenv

    KProc -.->|"writes data/"| MPBD
    AClient -.->|"writes data/"| MPBD

    %% Styling
    style MPBD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelCatalog fill:#b8d4f0,stroke:#333
    style ModelRegOp fill:#b8d4f0,stroke:#333
    style UBI9 fill:#999,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style KafkaBroker fill:#f5a623,stroke:#333
    style ValidationHub fill:#f5a623,stroke:#333
    style ConfluentKafka fill:#7ed321,stroke:#333
    style LZ4 fill:#7ed321,stroke:#333
    style Requests fill:#7ed321,stroke:#333
    style PythonDotenv fill:#7ed321,stroke:#333
    style KProc fill:#7ed321,stroke:#333
    style AClient fill:#7ed321,stroke:#333
