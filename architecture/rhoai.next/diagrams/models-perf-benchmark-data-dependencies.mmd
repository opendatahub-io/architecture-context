graph LR
    DataContainer["odh-model-performance-data<br/>(Data Container)"]

    %% Internal RHOAI Dependencies
    DataContainer -->|init container<br/>volume mount| ModelCatalog["model-catalog<br/>(model-registry)"]
    ModelRegistryOp["model-registry-operator"] -->|manages deployment<br/>patches init container ref| DataContainer

    %% Development Tool Dependencies
    subgraph DevOnly["Development Only (not shipped)"]
        KafkaProcessor["kafka-processor<br/>(Python 3.12 CLI)"]
    end

    KafkaProcessor -->|populates data/| DataContainer

    %% External Dependencies (Dev Only)
    KafkaProcessor -->|9092/TCP SASL_SSL| Kafka["Kafka Broker<br/>(dev.aihub-public-*)"]

    %% Python Dependencies (Dev Only)
    KafkaProcessor -->|consumer library| ConfluentKafka["confluent-kafka<br/>>=2.11.1"]
    KafkaProcessor -->|decompression| LZ4["lz4<br/>>=4.4.4"]
    KafkaProcessor -->|env loading| PythonDotenv["python-dotenv<br/>>=1.1.1"]

    %% Build Dependencies
    DataContainer -->|base image| UBI9["UBI9-minimal<br/>(unpinned :latest)"]

    style DataContainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistryOp fill:#7ed321,stroke:#333,color:#fff
    style KafkaProcessor fill:#f5a623,stroke:#333
    style Kafka fill:#999,stroke:#333,color:#fff
    style ConfluentKafka fill:#e8e8e8,stroke:#333
    style LZ4 fill:#e8e8e8,stroke:#333
    style PythonDotenv fill:#e8e8e8,stroke:#333
    style UBI9 fill:#999,stroke:#333,color:#fff
