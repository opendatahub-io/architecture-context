graph LR
    MPBD["models-perf-benchmark-data<br/>(Data Container)"]

    %% Internal RHOAI Dependencies
    MPBD -->|"init container<br/>volume mount"| ModelCatalog["model-catalog<br/>(model-registry)"]
    ModelRegOp["model-registry-operator"] -->|"manages deployment<br/>image reference"| MPBD
    Dashboard["RHOAI Dashboard"] -->|"queries"| ModelCatalog

    %% External Data Sources (Ingestion - not shipped)
    subgraph IngestionDeps["Data Ingestion Dependencies (CI/Dev only)"]
        Kafka["Kafka Brokers<br/>9092/TCP"]
        VHub["model-validation-hub<br/>443/TCP"]
    end
    MPBD -.->|"kafka-processor<br/>SASL_SSL"| Kafka
    MPBD -.->|"api-client<br/>HTTPS/TLS"| VHub

    %% Python Library Dependencies
    subgraph PythonLibs["Python Libraries (Not in shipped image)"]
        ConfluentKafka["confluent-kafka >=2.11.1"]
        LZ4["lz4 >=4.4.4"]
        PythonDotenv["python-dotenv >=1.1.1"]
        Requests["requests >=2.32.0"]
        Librdkafka["librdkafka (runtime)"]
    end
    MPBD -.->|"kafka-processor"| ConfluentKafka
    MPBD -.->|"kafka-processor"| LZ4
    MPBD -.->|"both utilities"| PythonDotenv
    MPBD -.->|"api-client"| Requests
    MPBD -.->|"kafka-processor"| Librdkafka

    %% Base Image
    UBI9["UBI9-minimal<br/>(Base Image)"]
    MPBD -->|"FROM"| UBI9

    %% Styling
    style MPBD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style ModelRegOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Kafka fill:#f5a623,stroke:#333
    style VHub fill:#f5a623,stroke:#333
    style ConfluentKafka fill:#e8e8e8,stroke:#333
    style LZ4 fill:#e8e8e8,stroke:#333
    style PythonDotenv fill:#e8e8e8,stroke:#333
    style Requests fill:#e8e8e8,stroke:#333
    style Librdkafka fill:#e8e8e8,stroke:#333
    style UBI9 fill:#999,stroke:#333,color:#fff

    linkStyle 3,4,5,6,7,8,9 stroke:#999,stroke-dasharray: 5 5
