graph TB
    subgraph "OpenVINO Toolkit"
        direction TB

        subgraph Core["Core Layer"]
            OVCore["OpenVINO Core<br/>(ov::Model, graph ops,<br/>opsets 1-13)"]
            Transforms["Common Transformations<br/>(constant folding, op fusion,<br/>precision conversion)"]
            LPT["Low Precision Transformations<br/>(INT8/INT4 quantization)"]
            Snippets["Snippets<br/>(JIT kernel code generation)"]
        end

        subgraph Runtime["Runtime Layer"]
            OVRuntime["OpenVINO Runtime<br/>(model loading, compilation,<br/>inference scheduling,<br/>plugin management)"]
        end

        subgraph Frontends["Frontend Layer (Model Format Readers)"]
            direction LR
            FE_ONNX["ONNX Frontend<br/>(protobuf)"]
            FE_TF["TensorFlow Frontend<br/>(37 proto defs)"]
            FE_PT["PyTorch Frontend"]
            FE_PP["PaddlePaddle Frontend"]
            FE_TFL["TF Lite Frontend<br/>(flatbuffers)"]
            FE_IR["IR Frontend<br/>(XML+bin)"]
        end

        subgraph Plugins["Device Plugins (Dynamically Loaded .so)"]
            direction LR
            CPU["Intel CPU Plugin<br/>(oneDNN, AVX2/AVX-512/AMX)"]
            GPU["Intel GPU Plugin<br/>(OpenCL)"]
            Auto["Auto Plugin<br/>(device selection)"]
            AutoBatch["Auto Batch Plugin<br/>(throughput optimization)"]
            Hetero["Hetero Plugin<br/>(multi-device split)"]
            Proxy["Proxy Plugin"]
        end

        subgraph Bindings["Language Bindings"]
            direction LR
            PyBind["Python Bindings<br/>(pybind11, openvino wheel)"]
            CAPI["C API"]
            JSAPI["JavaScript Bindings<br/>(Node.js addon)"]
        end

        subgraph Tools["Tools"]
            OVC["Model Converter (OVC)<br/>(CLI: framework → IR)"]
        end
    end

    %% Internal connections
    OVRuntime -->|"manages"| OVCore
    OVRuntime -->|"selects & loads"| Frontends
    OVRuntime -->|"applies"| Transforms
    Transforms -->|"includes"| LPT
    Transforms -->|"uses"| Snippets
    OVRuntime -->|"dispatches to"| Plugins

    Frontends -->|"produces<br/>ov::Model"| OVCore

    Bindings -->|"wraps"| OVRuntime
    OVC -->|"uses"| OVRuntime

    %% External consumer
    OVMS["OpenVINO Model Server (OVMS)<br/>(links libopenvino.so)"]
    OVMS -->|"C++ shared library<br/>linkage (build-time)"| OVRuntime

    %% Hardware targets
    CPU -->|"oneDNN / xbyak JIT"| IntelCPU["Intel CPU<br/>(AVX2/AVX-512/AMX)"]
    GPU -->|"OpenCL ICD"| IntelGPU["Intel GPU<br/>(HD/Iris/Discrete)"]

    %% Model sources
    ModelFiles["Model Files<br/>(ONNX, SavedModel, IR,<br/>PaddlePaddle, TF Lite)"]
    ModelFiles -->|"file I/O"| Frontends

    %% Styling
    style OVCore fill:#4a90e2,stroke:#333,color:#fff
    style OVRuntime fill:#4a90e2,stroke:#333,color:#fff
    style Transforms fill:#6baed6,stroke:#333,color:#fff
    style LPT fill:#6baed6,stroke:#333,color:#fff
    style Snippets fill:#6baed6,stroke:#333,color:#fff

    style FE_ONNX fill:#9ecae1,stroke:#333
    style FE_TF fill:#9ecae1,stroke:#333
    style FE_PT fill:#9ecae1,stroke:#333
    style FE_PP fill:#9ecae1,stroke:#333
    style FE_TFL fill:#9ecae1,stroke:#333
    style FE_IR fill:#9ecae1,stroke:#333

    style CPU fill:#f5a623,stroke:#333,color:#fff
    style GPU fill:#f5a623,stroke:#333,color:#fff
    style Auto fill:#f5a623,stroke:#333,color:#fff
    style AutoBatch fill:#f5a623,stroke:#333,color:#fff
    style Hetero fill:#f5a623,stroke:#333,color:#fff
    style Proxy fill:#f5a623,stroke:#333,color:#fff

    style PyBind fill:#7ed321,stroke:#333,color:#fff
    style CAPI fill:#7ed321,stroke:#333,color:#fff
    style JSAPI fill:#7ed321,stroke:#333,color:#fff
