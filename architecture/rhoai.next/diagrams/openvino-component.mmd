graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)<br/>Links OpenVINO as shared library"]
        OVMSHandler["OVMS gRPC/REST Handler<br/>(consuming application)"]
    end

    subgraph OpenVINO["OpenVINO Toolkit"]
        subgraph Runtime["OpenVINO Runtime"]
            Core["ov::Core<br/>Model loading, compilation,<br/>device management"]
            InferReq["Inference Request<br/>Scheduling & execution"]
            Core --> InferReq
        end

        subgraph Frontends["Model Frontends"]
            ONNXFE["ONNX Frontend<br/>(protobuf)"]
            TFFE["TensorFlow Frontend<br/>(37 proto definitions)"]
            TFLFE["TensorFlow Lite Frontend<br/>(flatbuffers)"]
            PyTorchFE["PyTorch Frontend"]
            PaddleFE["PaddlePaddle Frontend"]
            IRFE["IR Frontend<br/>(XML+bin)"]
        end

        subgraph CoreGraph["Core Graph Layer"]
            OVModel["ov::Model<br/>Graph representation<br/>200+ ops (opsets 1-13)"]
            Transforms["Common Transformations<br/>constant folding, op fusion,<br/>precision conversion"]
            LPT["Low Precision Transforms<br/>INT8/INT4 quantization"]
            Snippets["Snippets<br/>Code generation framework"]
            OVModel --> Transforms
            Transforms --> LPT
            Transforms --> Snippets
        end

        subgraph Plugins["Device Plugins (.so)"]
            CPUPlugin["Intel CPU Plugin<br/>oneDNN, AVX2/AVX-512/AMX<br/>ARM: AArch64, ARMv7"]
            GPUPlugin["Intel GPU Plugin<br/>OpenCL, oneDNN GPU"]
            AutoPlugin["Auto Plugin<br/>Automatic device selection"]
            AutoBatch["Auto Batch Plugin<br/>Request batching"]
            HeteroPlugin["Hetero Plugin<br/>Multi-device splitting"]
            ProxyPlugin["Proxy Plugin"]
        end

        subgraph Bindings["Language Bindings"]
            PythonAPI["Python Bindings<br/>(pybind11)"]
            CAPI["C API"]
            JSAPI["JavaScript Bindings<br/>(Node.js addon)"]
        end
    end

    subgraph Hardware["Hardware Targets"]
        IntelCPU["Intel CPU<br/>AVX2/AVX-512/AMX"]
        IntelGPU["Intel GPU<br/>HD/Iris Graphics"]
    end

    OVMSHandler -->|"C++ API<br/>in-process"| Core
    Core -->|"selects by format"| ONNXFE
    Core -->|"selects by format"| TFFE
    Core -->|"selects by format"| TFLFE
    Core -->|"selects by format"| PyTorchFE
    Core -->|"selects by format"| PaddleFE
    Core -->|"selects by format"| IRFE

    ONNXFE --> OVModel
    TFFE --> OVModel
    TFLFE --> OVModel
    PyTorchFE --> OVModel
    PaddleFE --> OVModel
    IRFE --> OVModel

    LPT --> CPUPlugin
    LPT --> GPUPlugin
    Snippets --> CPUPlugin

    InferReq -->|"Plugin API"| AutoPlugin
    AutoPlugin --> CPUPlugin
    AutoPlugin --> GPUPlugin
    AutoBatch --> CPUPlugin
    AutoBatch --> GPUPlugin
    HeteroPlugin --> CPUPlugin
    HeteroPlugin --> GPUPlugin

    CPUPlugin -->|"oneDNN / xbyak JIT"| IntelCPU
    GPUPlugin -->|"OpenCL API"| IntelGPU

    PythonAPI --> Core
    CAPI --> Core
    JSAPI --> Core

