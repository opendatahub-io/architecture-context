graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Prom["SA: prometheus<br/>NS: redhat-ods-monitoring"]
        SA_ModelMesh["SA: modelmesh-controller<br/>NS: redhat-ods-applications"]
        SA_NBC["SA: notebook-controller-service-account<br/>NS: redhat-ods-applications"]
        SA_ModelCtrl["SA: odh-model-controller<br/>NS: redhat-ods-applications"]
        SA_Dashboard["SA: rhods-dashboard<br/>NS: redhat-ods-applications"]
        SA_MM["SA: modelmesh<br/>NS: redhat-ods-applications"]
        SA_MonGroup["Group: system:serviceaccounts<br/>:redhat-ods-monitoring"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Scraper["prometheus-scraper<br/>(ClusterRoleBinding)"]
        CRB_ModelCtrl["odh-model-controller-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["RoleBindings (Namespaced)"]
        RB_Apps["deployer-baseline-permissions<br/>NS: redhat-ods-applications"]
        RB_Mon["deployer-baseline-permissions<br/>NS: redhat-ods-monitoring"]
        RB_Viewer["prometheus-viewer<br/>NS: redhat-ods-applications"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Scraper["prometheus-scraper"]
        CR_AnyUID_Apps["system:openshift:scc:anyuid<br/>(applications)"]
        CR_AnyUID_Mon["system:openshift:scc:anyuid<br/>(monitoring)"]
        CR_ModelCtrl["odh-model-controller-role"]
        CR_View["view<br/>(built-in)"]
    end

    subgraph APIResources_Scraper["API Resources (prometheus-scraper)"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
        Namespaces["core<br/>namespaces<br/>Verbs: get"]
        RouteMetrics["route.openshift.io<br/>routers/metrics, routers/federate<br/>Verbs: get"]
        RegistryMetrics["image.openshift.io<br/>registry/metrics<br/>Verbs: get"]
        CoreResources["core<br/>endpoints, pods, services<br/>Verbs: list, get, watch"]
    end

    subgraph SCC_Resources["SCC Permissions"]
        AnyUID["SecurityContextConstraint<br/>anyuid<br/>Allows: arbitrary UIDs"]
    end

    %% prometheus-scraper chain
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"create"| TokenReviews
    CR_Scraper -->|"create"| SAR
    CR_Scraper -->|"get"| Namespaces
    CR_Scraper -->|"get"| RouteMetrics
    CR_Scraper -->|"get"| RegistryMetrics
    CR_Scraper -->|"list,get,watch"| CoreResources

    %% anyuid SCC (applications namespace)
    SA_ModelMesh -->|"bound via"| RB_Apps
    SA_NBC -->|"bound via"| RB_Apps
    SA_ModelCtrl -->|"bound via"| RB_Apps
    SA_Dashboard -->|"bound via"| RB_Apps
    SA_MM -->|"bound via"| RB_Apps
    RB_Apps -->|"grants"| CR_AnyUID_Apps
    CR_AnyUID_Apps -->|"allows"| AnyUID

    %% anyuid SCC (monitoring namespace)
    SA_MonGroup -->|"bound via"| RB_Mon
    RB_Mon -->|"grants"| CR_AnyUID_Mon
    CR_AnyUID_Mon -->|"allows"| AnyUID

    %% prometheus-viewer
    SA_Prom -->|"bound via"| RB_Viewer
    RB_Viewer -->|"grants"| CR_View

    %% odh-model-controller
    SA_ModelCtrl -->|"bound via"| CRB_ModelCtrl
    CRB_ModelCtrl -->|"grants"| CR_ModelCtrl

    %% Styling
    style SA_Prom fill:#4a90e2,color:#fff
    style SA_ModelMesh fill:#4a90e2,color:#fff
    style SA_NBC fill:#4a90e2,color:#fff
    style SA_ModelCtrl fill:#4a90e2,color:#fff
    style SA_Dashboard fill:#4a90e2,color:#fff
    style SA_MM fill:#4a90e2,color:#fff
    style SA_MonGroup fill:#4a90e2,color:#fff
    style CR_Scraper fill:#f5a623
    style CR_AnyUID_Apps fill:#f5a623
    style CR_AnyUID_Mon fill:#f5a623
    style CR_ModelCtrl fill:#f5a623
    style CR_View fill:#f5a623
    style TokenReviews fill:#7ed321
    style SAR fill:#7ed321
    style Namespaces fill:#7ed321
    style RouteMetrics fill:#7ed321
    style RegistryMetrics fill:#7ed321
    style CoreResources fill:#7ed321
    style AnyUID fill:#e74c3c,color:#fff
    style CRB_Scraper fill:#dae8fc,stroke:#6c8ebf
    style CRB_ModelCtrl fill:#dae8fc,stroke:#6c8ebf
    style RB_Apps fill:#d5e8d4,stroke:#82b366
    style RB_Mon fill:#d5e8d4,stroke:#82b366
    style RB_Viewer fill:#d5e8d4,stroke:#82b366
