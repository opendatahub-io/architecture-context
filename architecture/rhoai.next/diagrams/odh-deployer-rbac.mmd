graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_ModelMesh["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBC["notebook-controller-<br/>service-account<br/>(redhat-ods-applications)"]
        SA_ModelCtrl["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dashboard["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_MM["modelmesh<br/>(redhat-ods-applications)"]
        SA_MonGroup["system:serviceaccounts:<br/>redhat-ods-monitoring<br/>(Group)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Scraper["prometheus-scraper<br/>(ClusterRoleBinding)"]
        CRB_ModelCtrl["odh-model-controller-<br/>rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["RoleBindings (Namespaced)"]
        RB_AppsAnyuid["deployer-baseline-permissions<br/>(redhat-ods-applications)<br/>→ system:openshift:scc:anyuid"]
        RB_MonAnyuid["deployer-baseline-permissions<br/>(redhat-ods-monitoring)<br/>→ system:openshift:scc:anyuid"]
        RB_PromViewer["prometheus-viewer<br/>(redhat-ods-applications)<br/>→ view"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Scraper["prometheus-scraper"]
        CR_ModelCtrl["odh-model-controller-role"]
        CR_Anyuid["system:openshift:scc:anyuid"]
        CR_View["view"]
    end

    subgraph APIResources_Scraper["API Resources (prometheus-scraper)"]
        R_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>(create)"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>(create)"]
        R_NS["core<br/>namespaces<br/>(get)"]
        R_Routes["route.openshift.io<br/>routers/metrics,<br/>routers/federate<br/>(get)"]
        R_Registry["image.openshift.io<br/>registry/metrics<br/>(get)"]
        R_Discovery["core<br/>endpoints, pods,<br/>services, namespaces<br/>(list, get, watch)"]
    end

    subgraph APIResources_ModelCtrl["API Resources (odh-model-controller)"]
        R_ModelCtrlRes["Model Controller<br/>managed resources<br/>(full CRUD)"]
    end

    subgraph SCCGrant["SCC Grant: anyuid"]
        SCC_Info["Allows containers to run<br/>with any UID<br/>(permissive posture for<br/>Prometheus UID:1000)"]
    end

    %% Prometheus scraper chain
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"create"| R_TokenReview
    CR_Scraper -->|"create"| R_SAR
    CR_Scraper -->|"get"| R_NS
    CR_Scraper -->|"get"| R_Routes
    CR_Scraper -->|"get"| R_Registry
    CR_Scraper -->|"list,get,watch"| R_Discovery

    %% ODH Model Controller chain
    SA_ModelCtrl -->|"bound via"| CRB_ModelCtrl
    CRB_ModelCtrl -->|"grants"| CR_ModelCtrl
    CR_ModelCtrl -->|"full CRUD"| R_ModelCtrlRes

    %% anyuid SCC for applications namespace
    SA_ModelMesh -->|"bound via"| RB_AppsAnyuid
    SA_NBC -->|"bound via"| RB_AppsAnyuid
    SA_ModelCtrl -->|"bound via"| RB_AppsAnyuid
    SA_Dashboard -->|"bound via"| RB_AppsAnyuid
    SA_MM -->|"bound via"| RB_AppsAnyuid
    RB_AppsAnyuid -->|"grants"| CR_Anyuid
    CR_Anyuid --- SCC_Info

    %% anyuid SCC for monitoring namespace
    SA_MonGroup -->|"bound via"| RB_MonAnyuid
    RB_MonAnyuid -->|"grants"| CR_Anyuid

    %% Prometheus viewer
    SA_Prom -->|"bound via"| RB_PromViewer
    RB_PromViewer -->|"grants"| CR_View

    %% Styling
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style SA_NBC fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style SA_MM fill:#4a90e2,stroke:#333,color:#fff
    style SA_MonGroup fill:#4a90e2,stroke:#333,color:#fff
    style CR_Scraper fill:#f5a623,stroke:#333
    style CR_ModelCtrl fill:#f5a623,stroke:#333
    style CR_Anyuid fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style CRB_Scraper fill:#ffe6cc,stroke:#d79b00
    style CRB_ModelCtrl fill:#ffe6cc,stroke:#d79b00
    style RB_AppsAnyuid fill:#ffe6cc,stroke:#d79b00
    style RB_MonAnyuid fill:#ffe6cc,stroke:#d79b00
    style RB_PromViewer fill:#ffe6cc,stroke:#d79b00
    style R_TokenReview fill:#7ed321,stroke:#333
    style R_SAR fill:#7ed321,stroke:#333
    style R_NS fill:#7ed321,stroke:#333
    style R_Routes fill:#7ed321,stroke:#333
    style R_Registry fill:#7ed321,stroke:#333
    style R_Discovery fill:#7ed321,stroke:#333
    style R_ModelCtrlRes fill:#7ed321,stroke:#333
    style SCC_Info fill:#f8cecc,stroke:#b85450
