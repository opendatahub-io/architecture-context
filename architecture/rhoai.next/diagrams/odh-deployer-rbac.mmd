graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_MMCtrl["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBC["notebook-controller-<br/>service-account<br/>(redhat-ods-applications)"]
        SA_ODHModel["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dashboard["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_MM["modelmesh<br/>(redhat-ods-applications)"]
        SA_AllMon["system:serviceaccounts:<br/>redhat-ods-monitoring<br/>(ALL SAs)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings / RoleBindings"]
        CRB_Scraper["prometheus-scraper<br/>(ClusterRoleBinding)"]
        RB_AppsSCC["rhods-applications-scc<br/>(RoleBinding in<br/>redhat-ods-applications)"]
        RB_MonSCC["rhods-monitoring-scc<br/>(RoleBinding in<br/>redhat-ods-monitoring)"]
        RB_Viewer["rhods-prometheus-viewer<br/>(RoleBinding in<br/>redhat-ods-applications)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Scraper["prometheus-scraper"]
        CR_AnyUID["system:openshift:<br/>scc:anyuid"]
        CR_View["view<br/>(built-in)"]
    end

    subgraph APIResources_Scraper["API Resources (prometheus-scraper)"]
        R_TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>[create]"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>[create]"]
        R_Namespaces["core<br/>namespaces<br/>[get]"]
        R_RouterMetrics["route.openshift.io<br/>routers/metrics<br/>routers/federate<br/>[get]"]
        R_RegistryMetrics["image.openshift.io<br/>registry/metrics<br/>[get]"]
        R_Discovery["core<br/>endpoints, pods,<br/>services, namespaces<br/>[list, get, watch]"]
    end

    subgraph APIResources_SCC["API Resources (anyuid SCC)"]
        R_SCC["security.openshift.io<br/>securitycontextconstraints<br/>[use]"]
    end

    %% Prometheus bindings
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"create"| R_TokenReviews
    CR_Scraper -->|"create"| R_SAR
    CR_Scraper -->|"get"| R_Namespaces
    CR_Scraper -->|"get"| R_RouterMetrics
    CR_Scraper -->|"get"| R_RegistryMetrics
    CR_Scraper -->|"list,get,watch"| R_Discovery

    SA_Prom -->|"bound via"| RB_Viewer
    RB_Viewer -->|"grants"| CR_View

    %% Applications SCC bindings
    SA_MMCtrl -->|"bound via"| RB_AppsSCC
    SA_NBC -->|"bound via"| RB_AppsSCC
    SA_ODHModel -->|"bound via"| RB_AppsSCC
    SA_Dashboard -->|"bound via"| RB_AppsSCC
    SA_MM -->|"bound via"| RB_AppsSCC
    RB_AppsSCC -->|"grants"| CR_AnyUID
    CR_AnyUID -->|"use"| R_SCC

    %% Monitoring SCC bindings
    SA_AllMon -->|"bound via"| RB_MonSCC
    RB_MonSCC -->|"grants"| CR_AnyUID

    %% Styling
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_MMCtrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_NBC fill:#4a90e2,stroke:#333,color:#fff
    style SA_ODHModel fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style SA_MM fill:#4a90e2,stroke:#333,color:#fff
    style SA_AllMon fill:#e8744f,stroke:#333,color:#fff
    style CR_Scraper fill:#f5a623,stroke:#333
    style CR_AnyUID fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style R_TokenReviews fill:#7ed321,stroke:#333
    style R_SAR fill:#7ed321,stroke:#333
    style R_Namespaces fill:#7ed321,stroke:#333
    style R_RouterMetrics fill:#7ed321,stroke:#333
    style R_RegistryMetrics fill:#7ed321,stroke:#333
    style R_Discovery fill:#7ed321,stroke:#333
    style R_SCC fill:#f8cecc,stroke:#333
