graph TD
    subgraph SAs["Service Accounts"]
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_MM["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBC["notebook-controller-service-account<br/>(redhat-ods-applications)"]
        SA_Model["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dash["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_MMesh["modelmesh<br/>(redhat-ods-applications)"]
        SA_MonAll["All SAs<br/>(redhat-ods-monitoring)"]
    end

    subgraph CRBs["ClusterRoleBindings / RoleBindings"]
        CRB_Scraper["prometheus-scraper<br/>(ClusterRoleBinding)"]
        RB_AppsSCC["rhods-applications-scc<br/>(RoleBinding: redhat-ods-applications)"]
        RB_MonSCC["rhods-monitoring-scc<br/>(RoleBinding: redhat-ods-monitoring)"]
        RB_PromView["rhods-prometheus-viewer<br/>(RoleBinding: redhat-ods-applications)"]
    end

    subgraph CRs["ClusterRoles"]
        CR_Scraper["prometheus-scraper<br/>(ClusterRole)"]
        CR_SCC["system:openshift:scc:anyuid<br/>(ClusterRole)"]
        CR_View["view<br/>(ClusterRole)"]
    end

    subgraph Resources_Scraper["API Resources (prometheus-scraper)"]
        R_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>[create]"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>[create]"]
        R_NS["core ('')<br/>namespaces<br/>[get]"]
        R_Endpoints["core ('')<br/>endpoints, pods, services, namespaces<br/>[list, get, watch]"]
        R_Routes["route.openshift.io<br/>routers/metrics, routers/federate<br/>[get]"]
        R_Registry["image.openshift.io<br/>registry/metrics<br/>[get]"]
    end

    subgraph Resources_SCC["SCC Permissions"]
        R_AnyUID["Security Context Constraint<br/>anyuid<br/>[use]"]
    end

    subgraph Resources_View["View Permissions"]
        R_ViewAll["Most namespaced resources<br/>(read-only)<br/>[get, list, watch]"]
    end

    %% prometheus-scraper chain
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"create"| R_TokenReview
    CR_Scraper -->|"create"| R_SAR
    CR_Scraper -->|"get"| R_NS
    CR_Scraper -->|"list, get, watch"| R_Endpoints
    CR_Scraper -->|"get"| R_Routes
    CR_Scraper -->|"get"| R_Registry

    %% SCC chain - applications
    SA_MM -->|"bound via"| RB_AppsSCC
    SA_NBC -->|"bound via"| RB_AppsSCC
    SA_Model -->|"bound via"| RB_AppsSCC
    SA_Dash -->|"bound via"| RB_AppsSCC
    SA_MMesh -->|"bound via"| RB_AppsSCC
    RB_AppsSCC -->|"grants"| CR_SCC
    CR_SCC -->|"use"| R_AnyUID

    %% SCC chain - monitoring
    SA_MonAll -->|"bound via"| RB_MonSCC
    RB_MonSCC -->|"grants"| CR_SCC

    %% Viewer chain
    SA_Prom -->|"bound via"| RB_PromView
    RB_PromView -->|"grants"| CR_View
    CR_View -->|"read-only"| R_ViewAll

    %% Styling
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_MM fill:#4a90e2,stroke:#333,color:#fff
    style SA_NBC fill:#4a90e2,stroke:#333,color:#fff
    style SA_Model fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dash fill:#4a90e2,stroke:#333,color:#fff
    style SA_MMesh fill:#4a90e2,stroke:#333,color:#fff
    style SA_MonAll fill:#4a90e2,stroke:#333,color:#fff

    style CR_Scraper fill:#f5a623,stroke:#333,color:#fff
    style CR_SCC fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#f5a623,stroke:#333,color:#fff

    style CRB_Scraper fill:#dae8fc,stroke:#6c8ebf
    style RB_AppsSCC fill:#dae8fc,stroke:#6c8ebf
    style RB_MonSCC fill:#dae8fc,stroke:#6c8ebf
    style RB_PromView fill:#dae8fc,stroke:#6c8ebf

    style R_TokenReview fill:#7ed321,stroke:#333,color:#fff
    style R_SAR fill:#7ed321,stroke:#333,color:#fff
    style R_NS fill:#7ed321,stroke:#333,color:#fff
    style R_Endpoints fill:#7ed321,stroke:#333,color:#fff
    style R_Routes fill:#7ed321,stroke:#333,color:#fff
    style R_Registry fill:#7ed321,stroke:#333,color:#fff
    style R_AnyUID fill:#e6522c,stroke:#333,color:#fff
    style R_ViewAll fill:#7ed321,stroke:#333,color:#fff
