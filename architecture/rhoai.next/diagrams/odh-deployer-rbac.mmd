graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_ModelCtrl["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_MMesh["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBC["notebook-controller-service-account<br/>(redhat-ods-applications)"]
        SA_ODHModel["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dashboard["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_ModelMesh["modelmesh<br/>(redhat-ods-applications)"]
        SA_MonGroup["system:serviceaccounts:<br/>redhat-ods-monitoring<br/>(Group)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Prom["prometheus-scraper<br/>(ClusterRoleBinding)"]
        CRB_Model["odh-model-controller-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["RoleBindings (Namespace-scoped)"]
        RB_Apps["deployer-baseline-permissions<br/>(redhat-ods-applications)"]
        RB_Mon["deployer-baseline-permissions<br/>(redhat-ods-monitoring)"]
        RB_View["prometheus-viewer<br/>(redhat-ods-applications)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Scraper["prometheus-scraper"]
        CR_ModelCtrl["odh-model-controller-role"]
    end

    subgraph SCCs["Security Context Constraints"]
        SCC_AnyUID["system:openshift:scc:anyuid"]
    end

    subgraph Roles["Roles"]
        R_View["view<br/>(built-in)"]
    end

    subgraph APIResources_Scraper["API Resources (prometheus-scraper)"]
        TR["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        NS["core<br/>namespaces<br/>get"]
        Routes["route.openshift.io<br/>routers/metrics,<br/>routers/federate<br/>get"]
        Registry["image.openshift.io<br/>registry/metrics<br/>get"]
        CoreResources["core<br/>endpoints, pods,<br/>services, namespaces<br/>list, get, watch"]
    end

    %% ClusterRoleBindings
    SA_Prom -->|"bound via"| CRB_Prom
    CRB_Prom -->|"grants"| CR_Scraper
    SA_ModelCtrl -->|"bound via"| CRB_Model
    CRB_Model -->|"grants"| CR_ModelCtrl

    %% ClusterRole permissions
    CR_Scraper -->|"create"| TR
    CR_Scraper -->|"create"| SAR
    CR_Scraper -->|"get"| NS
    CR_Scraper -->|"get"| Routes
    CR_Scraper -->|"get"| Registry
    CR_Scraper -->|"list,get,watch"| CoreResources

    %% SCC RoleBindings
    SA_MMesh -->|"bound via"| RB_Apps
    SA_NBC -->|"bound via"| RB_Apps
    SA_ODHModel -->|"bound via"| RB_Apps
    SA_Dashboard -->|"bound via"| RB_Apps
    SA_ModelMesh -->|"bound via"| RB_Apps
    RB_Apps -->|"grants"| SCC_AnyUID

    SA_MonGroup -->|"bound via"| RB_Mon
    RB_Mon -->|"grants"| SCC_AnyUID

    %% View RoleBinding
    SA_Prom -->|"bound via"| RB_View
    RB_View -->|"grants"| R_View

    %% Styling
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_MMesh fill:#4a90e2,stroke:#333,color:#fff
    style SA_NBC fill:#4a90e2,stroke:#333,color:#fff
    style SA_ODHModel fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style SA_MonGroup fill:#4a90e2,stroke:#333,color:#fff
    style CR_Scraper fill:#f5a623,stroke:#333,color:#fff
    style CR_ModelCtrl fill:#f5a623,stroke:#333,color:#fff
    style SCC_AnyUID fill:#e74c3c,stroke:#333,color:#fff
    style R_View fill:#f5a623,stroke:#333,color:#fff
    style TR fill:#7ed321,stroke:#333,color:#fff
    style SAR fill:#7ed321,stroke:#333,color:#fff
    style NS fill:#7ed321,stroke:#333,color:#fff
    style Routes fill:#7ed321,stroke:#333,color:#fff
    style Registry fill:#7ed321,stroke:#333,color:#fff
    style CoreResources fill:#7ed321,stroke:#333,color:#fff
