graph TD
    subgraph "Service Accounts"
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_MMCtrl["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBC["notebook-controller-service-account<br/>(redhat-ods-applications)"]
        SA_ModelCtrl["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dashboard["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_MM["modelmesh<br/>(redhat-ods-applications)"]
        SA_AllMon["All SAs<br/>(redhat-ods-monitoring)"]
    end

    subgraph "ClusterRoleBindings"
        CRB_Scraper["prometheus-scraper<br/>(ClusterRoleBinding)"]
    end

    subgraph "RoleBindings"
        RB_AppsSCC["rhods-applications-scc<br/>(redhat-ods-applications)"]
        RB_MonSCC["rhods-monitoring-scc<br/>(redhat-ods-monitoring)"]
        RB_PromViewer["rhods-prometheus-viewer<br/>(redhat-ods-applications)"]
    end

    subgraph "ClusterRoles"
        CR_Scraper["prometheus-scraper<br/>(ClusterRole)"]
        CR_AnyUID["system:openshift:scc:anyuid<br/>(ClusterRole)"]
        CR_View["view<br/>(ClusterRole)"]
    end

    subgraph "API Resources - Prometheus Scraper"
        direction TB
        R_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        R_NS["core<br/>namespaces"]
        R_RouterMetrics["route.openshift.io<br/>routers/metrics,<br/>routers/federate"]
        R_Registry["image.openshift.io<br/>registry/metrics"]
        R_Endpoints["core<br/>endpoints, pods,<br/>services, namespaces"]
    end

    subgraph "SCC Permissions"
        SCC_AnyUID["anyuid SCC<br/>Allows running as any UID<br/>(privileged)"]
    end

    subgraph "View Permissions"
        ViewPerms["Standard view access<br/>to redhat-ods-applications<br/>namespace resources"]
    end

    %% Prometheus scraper bindings
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"create"| R_TokenReview
    CR_Scraper -->|"create"| R_SAR
    CR_Scraper -->|"get"| R_NS
    CR_Scraper -->|"get"| R_RouterMetrics
    CR_Scraper -->|"get"| R_Registry
    CR_Scraper -->|"list, get, watch"| R_Endpoints

    %% SCC bindings - applications namespace
    SA_MMCtrl -->|"bound via"| RB_AppsSCC
    SA_NBC -->|"bound via"| RB_AppsSCC
    SA_ModelCtrl -->|"bound via"| RB_AppsSCC
    SA_Dashboard -->|"bound via"| RB_AppsSCC
    SA_MM -->|"bound via"| RB_AppsSCC
    RB_AppsSCC -->|"grants"| CR_AnyUID
    CR_AnyUID -->|"permits"| SCC_AnyUID

    %% SCC bindings - monitoring namespace
    SA_AllMon -->|"bound via"| RB_MonSCC
    RB_MonSCC -->|"grants"| CR_AnyUID

    %% Prometheus viewer binding
    SA_Prom -->|"bound via"| RB_PromViewer
    RB_PromViewer -->|"grants"| CR_View
    CR_View -->|"permits"| ViewPerms

    %% Styling
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style SA_MMCtrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_NBC fill:#4a90e2,stroke:#333,color:#fff
    style SA_ModelCtrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_Dashboard fill:#4a90e2,stroke:#333,color:#fff
    style SA_MM fill:#4a90e2,stroke:#333,color:#fff
    style SA_AllMon fill:#4a90e2,stroke:#333,color:#fff

    style CR_Scraper fill:#f5a623,stroke:#333
    style CR_AnyUID fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333

    style CRB_Scraper fill:#e1d5e7,stroke:#9673a6
    style RB_AppsSCC fill:#e1d5e7,stroke:#9673a6
    style RB_MonSCC fill:#e1d5e7,stroke:#9673a6
    style RB_PromViewer fill:#e1d5e7,stroke:#9673a6

    style R_TokenReview fill:#7ed321,stroke:#333
    style R_SAR fill:#7ed321,stroke:#333
    style R_NS fill:#7ed321,stroke:#333
    style R_RouterMetrics fill:#7ed321,stroke:#333
    style R_Registry fill:#7ed321,stroke:#333
    style R_Endpoints fill:#7ed321,stroke:#333

    style SCC_AnyUID fill:#f8cecc,stroke:#b85450
    style ViewPerms fill:#d5e8d4,stroke:#82b366
