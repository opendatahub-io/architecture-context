graph TD
    subgraph "Service Accounts"
        SA_Prom["prometheus<br/>(redhat-ods-monitoring)"]
        SA_ModelmeshCtrl["modelmesh-controller<br/>(redhat-ods-applications)"]
        SA_NBCtrl["notebook-controller-service-account<br/>(redhat-ods-applications)"]
        SA_ModelCtrl["odh-model-controller<br/>(redhat-ods-applications)"]
        SA_Dashboard["rhods-dashboard<br/>(redhat-ods-applications)"]
        SA_Modelmesh["modelmesh<br/>(redhat-ods-applications)"]
        SA_AllMonitoring["All SAs<br/>(redhat-ods-monitoring)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Scraper["prometheus-scraper<br/>(Cluster-scoped)"]
        CRB_AppsSCC["rhods-applications-scc<br/>(redhat-ods-applications)"]
        CRB_MonSCC["rhods-monitoring-scc<br/>(redhat-ods-monitoring)"]
        CRB_Viewer["rhods-prometheus-viewer<br/>(redhat-ods-applications)"]
    end

    subgraph "ClusterRoles"
        CR_Scraper["prometheus-scraper<br/>(ClusterRole)"]
        CR_AnyUID["system:openshift:scc:anyuid<br/>(ClusterRole)"]
        CR_View["view<br/>(ClusterRole)"]
    end

    subgraph "API Resources (prometheus-scraper)"
        AuthTokenReviews["authentication.k8s.io<br/>tokenreviews<br/>[create]"]
        AuthzSAR["authorization.k8s.io<br/>subjectaccessreviews<br/>[create]"]
        CoreNS["core<br/>namespaces<br/>[get]"]
        RouteMetrics["route.openshift.io<br/>routers/metrics<br/>routers/federate<br/>[get]"]
        ImageMetrics["image.openshift.io<br/>registry/metrics<br/>[get]"]
        CoreResources["core<br/>endpoints, pods,<br/>services, namespaces<br/>[list, get, watch]"]
    end

    subgraph "SCC Permissions"
        AnyUID["SecurityContextConstraint<br/>anyuid<br/>(run as any UID)"]
    end

    subgraph "View Permissions"
        ViewAccess["Read-only access<br/>to namespace resources"]
    end

    %% prometheus-scraper flow
    SA_Prom -->|"bound via"| CRB_Scraper
    CRB_Scraper -->|"grants"| CR_Scraper
    CR_Scraper -->|"permits"| AuthTokenReviews
    CR_Scraper -->|"permits"| AuthzSAR
    CR_Scraper -->|"permits"| CoreNS
    CR_Scraper -->|"permits"| RouteMetrics
    CR_Scraper -->|"permits"| ImageMetrics
    CR_Scraper -->|"permits"| CoreResources

    %% SCC anyuid flow (applications)
    SA_ModelmeshCtrl -->|"bound via"| CRB_AppsSCC
    SA_NBCtrl -->|"bound via"| CRB_AppsSCC
    SA_ModelCtrl -->|"bound via"| CRB_AppsSCC
    SA_Dashboard -->|"bound via"| CRB_AppsSCC
    SA_Modelmesh -->|"bound via"| CRB_AppsSCC
    CRB_AppsSCC -->|"grants"| CR_AnyUID
    CR_AnyUID -->|"permits"| AnyUID

    %% SCC anyuid flow (monitoring)
    SA_AllMonitoring -->|"bound via"| CRB_MonSCC
    CRB_MonSCC -->|"grants"| CR_AnyUID

    %% View flow
    SA_Prom -->|"bound via"| CRB_Viewer
    CRB_Viewer -->|"grants"| CR_View
    CR_View -->|"permits"| ViewAccess

    %% Styling
    style SA_Prom fill:#4a90e2,color:#fff
    style SA_ModelmeshCtrl fill:#4a90e2,color:#fff
    style SA_NBCtrl fill:#4a90e2,color:#fff
    style SA_ModelCtrl fill:#4a90e2,color:#fff
    style SA_Dashboard fill:#4a90e2,color:#fff
    style SA_Modelmesh fill:#4a90e2,color:#fff
    style SA_AllMonitoring fill:#4a90e2,color:#fff

    style CR_Scraper fill:#f5a623,stroke:#333
    style CR_AnyUID fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333

    style AuthTokenReviews fill:#7ed321,stroke:#333
    style AuthzSAR fill:#7ed321,stroke:#333
    style CoreNS fill:#7ed321,stroke:#333
    style RouteMetrics fill:#7ed321,stroke:#333
    style ImageMetrics fill:#7ed321,stroke:#333
    style CoreResources fill:#7ed321,stroke:#333
    style AnyUID fill:#7ed321,stroke:#333
    style ViewAccess fill:#7ed321,stroke:#333
