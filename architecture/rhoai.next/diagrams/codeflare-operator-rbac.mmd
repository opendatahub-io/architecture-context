graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/>(operator namespace)"]
        SA_OAuth["per-RayCluster:<br/>{raycluster}-oauth-proxy<br/>(RayCluster namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Leader["leader-election-rolebinding<br/>(Namespace-scoped)"]
        CRB_OAuth["per-RayCluster:<br/>{raycluster}-{ns}-auth<br/>(Cluster-scoped)"]
    end

    subgraph Roles["Roles"]
        CR_Manager["ClusterRole:<br/>manager-role"]
        R_Leader["Role:<br/>leader-election-role"]
        CR_AuthDelegator["ClusterRole:<br/>system:auth-delegator"]
    end

    %% Bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_Manager -->|"bound via"| CRB_Leader
    SA_OAuth -->|"bound via"| CRB_OAuth

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Leader -->|"grants"| R_Leader
    CRB_OAuth -->|"grants"| CR_AuthDelegator

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods"]
        Services["core<br/>services"]
        Secrets["core<br/>secrets"]
        SAs["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Nodes["core<br/>nodes"]
    end

    subgraph RayResources["Ray API Resources"]
        RayClusters["ray.io<br/>rayclusters"]
        RayClustersFinalize["ray.io<br/>rayclusters/finalizers"]
        RayClustersStatus["ray.io<br/>rayclusters/status"]
        RayJobs["ray.io<br/>rayjobs"]
    end

    subgraph CodeFlareResources["CodeFlare API Resources"]
        AppWrappers["workload.codeflare.dev<br/>appwrappers"]
