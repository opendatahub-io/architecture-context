graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/><i>Operator namespace</i>"]
        SA_OAuth["per-RayCluster<br/>{cluster}-oauth-proxy<br/><i>Workload namespace</i>"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/><i>Cluster-scoped</i>"]
        CRB_Auth["{cluster}-{ns}-auth<br/><i>Cluster-scoped, per RayCluster</i>"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/><i>Operator namespace</i>"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDelegator["system:auth-delegator<br/><i>(built-in)</i>"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, services"]
        Secrets["core<br/>secrets"]
        SAs["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Nodes["core<br/>nodes"]
    end

    subgraph AdmissionResources["Admission Resources"]
        MWC["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations"]
        VWC["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
