graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["controller-manager<br/>(operator namespace)"]
        SA_OAuth["{cluster}-oauth-proxy<br/>(per RayCluster, user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Auth["{cluster}-{ns}-auth<br/>(per RayCluster, cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDelegator["system:auth-delegator<br/>(built-in)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        Events["events<br/>create, patch, update, watch"]
        Nodes["nodes<br/>get, list, watch"]
        Pods["pods<br/>create, delete, get, list,<br/>patch, update, watch"]
        Services["services<br/>create, delete, get, list,<br/>patch, update, watch"]
        Secrets["secrets<br/>create, delete, get, list,<br/>patch, update, watch"]
        ServiceAccts["serviceaccounts<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph AdmissionResources["Admission API Resources"]
        MWC["mutatingwebhookconfigurations<br/>get, list, update, watch"]
        VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
        CRDs["customresourcedefinitions<br/>get, list, watch"]
    end

    subgraph WorkloadResources["Workload API Resources"]
        Deployments["apps/deployments, statefulsets<br/>create, delete, get, list,<br/>patch, update, watch"]
        Jobs["batch/jobs<br/>create, delete, get, list,<br/>patch, update, watch"]
        TokenReviews["authentication.k8s.io/tokenreviews<br/>create"]
        SAR["authorization.k8s.io/subjectaccessreviews<br/>create"]
    end

    subgraph RayResources["Ray / CodeFlare Resources"]
        RayClusters["ray.io/rayclusters<br/>+ finalizers + status<br/>create, delete, get, list,<br/>patch, update, watch"]
        RayJobs["ray.io/rayjobs<br/>create, delete, get, list,<br/>patch, update, watch"]
        AppWrappers["workload.codeflare.dev/appwrappers<br/>+ finalizers + status<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph NetworkResources["Network / Route Resources"]
        Ingresses["networking.k8s.io/ingresses<br/>create, delete, get, list,<br/>patch, update, watch"]
        NetworkPolicies["networking.k8s.io/networkpolicies<br/>create, delete, get, list,<br/>patch, update, watch"]
        Routes["route.openshift.io/routes<br/>+ custom-host<br/>create, delete, get, list,<br/>patch, update, watch"]
        ClusterRoleBindings2["rbac/clusterrolebindings<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph OpenShiftResources["OpenShift / ODH Resources"]
        OSIngresses["config.openshift.io/ingresses<br/>get"]
        DSCI["dscinitialization.opendatahub.io<br/>get, list, watch"]
    end

    subgraph OptionalResources["Optional Resources (AppWrapper)"]
        PyTorchJobs["kubeflow.org/pytorchjobs<br/>full CRUD"]
        JobSets["jobset.x-k8s.io/jobsets<br/>full CRUD"]
        PodGroups["scheduling.*.k8s.io/podgroups<br/>full CRUD"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        ConfigMaps["configmaps<br/>full CRUD"]
        Leases["coordination.k8s.io/leases<br/>full CRUD"]
        LEEvents["events<br/>create, patch"]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| RB_Leader
    SA_OAuth -->|bound via| CRB_Auth

    CRB_Manager -->|grants| CR_Manager
    CRB_Auth -->|grants| CR_AuthDelegator
    RB_Leader -->|grants| R_Leader

    %% Permissions
    CR_Manager -->|access| CoreResources
    CR_Manager -->|access| AdmissionResources
    CR_Manager -->|access| WorkloadResources
    CR_Manager -->|access| RayResources
    CR_Manager -->|access| NetworkResources
    CR_Manager -->|access| OpenShiftResources
    CR_Manager -->|access| OptionalResources

    R_Leader -->|access| LeaderElection

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,color:#fff
    style SA_OAuth fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_AuthDelegator fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_Auth fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
