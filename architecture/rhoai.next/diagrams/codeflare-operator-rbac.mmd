graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["codeflare-operator-<br/>controller-manager<br/>NS: opendatahub"]
        SA_OAuth["per-cluster:<br/>{cluster}-oauth-proxy<br/>NS: {user-namespace}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["codeflare-operator-<br/>manager-rolebinding<br/>(Cluster)"]
        CRB_Auth["{cluster}-{ns}-auth<br/>(Cluster, per RayCluster)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["codeflare-operator-<br/>leader-election-rolebinding<br/>NS: opendatahub"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Editor["appwrapper-editor-role"]
        CR_Viewer["viewer-role"]
        CR_AuthDelegator["system:auth-delegator<br/>(built-in)"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/>NS: opendatahub"]
    end

    subgraph RayIOResources["ray.io Resources"]
        RC["rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers"]
        RJ["rayjobs"]
    end

    subgraph CoreResources["Core Resources"]
        Secrets["secrets"]
        Services["services"]
        SAs["serviceaccounts"]
        Pods["pods"]
        Events["events"]
        Nodes["nodes"]
    end

    subgraph NetworkResources["Network Resources"]
        Routes["route.openshift.io<br/>routes, routes/custom-host"]
        Ingresses["networking.k8s.io<br/>ingresses"]
        NetPolicies["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph RBACResources["RBAC & Auth Resources"]
        CRBs["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph WebhookResources["Webhook Resources"]
        WebhookConfigs["admissionregistration.k8s.io<br/>mutating/validating<br/>webhookconfigurations"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph CodeFlareResources["CodeFlare Resources"]
        AppWrappers["workload.codeflare.dev<br/>appwrappers<br/>appwrappers/status<br/>appwrappers/finalizers"]
    end

    subgraph WorkloadResources["Workload Resources"]
        Deployments["apps<br/>deployments, statefulsets"]
        Jobs["batch<br/>jobs"]
        PyTorchJobs["kubeflow.org<br/>pytorchjobs"]
        PodGroups["scheduling.sigs.k8s.io<br/>scheduling.x-k8s.io<br/>podgroups"]
        JobSets["jobset.x-k8s.io<br/>jobsets"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        ConfigMaps["core<br/>configmaps"]
        Leases["coordination.k8s.io<br/>leases"]
        LEEvents["core<br/>events"]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| RB_Leader
    SA_OAuth -->|bound via| CRB_Auth

    CRB_Manager -->|grants| CR_Manager
    CRB_Auth -->|grants| CR_AuthDelegator
    RB_Leader -->|grants| R_Leader

    %% Manager role permissions
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| RC
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| RJ
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Routes
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Ingresses
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| NetPolicies
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Secrets
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Services
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| SAs
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Pods
    CR_Manager -->|"create,patch,<br/>update,watch"| Events
    CR_Manager -->|"get,list,watch"| Nodes
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CRBs
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create"| SAR
    CR_Manager -->|"get,list,<br/>watch,update"| WebhookConfigs
    CR_Manager -->|"get,list,watch"| CRDs
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| AppWrappers
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Deployments
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Jobs
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| PyTorchJobs
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| PodGroups
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| JobSets

    %% Editor/Viewer roles
    CR_Editor -->|"create,delete,get,<br/>list,patch,update,watch"| AppWrappers
    CR_Viewer -->|"get,list,watch"| AppWrappers

    %% Leader election
    R_Leader -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ConfigMaps
    R_Leader -->|"create,patch"| LEEvents
    R_Leader -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Leases

