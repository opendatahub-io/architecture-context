graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["codeflare-operator-<br/>controller-manager<br/>Namespace: opendatahub"]
        SA_OAuth["&lbrace;cluster&rbrace;-oauth-proxy<br/>(dynamic, per RayCluster)<br/>Namespace: &lbrace;user-ns&rbrace;"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["codeflare-operator-<br/>manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_LeaderElection["codeflare-operator-<br/>leader-election-rolebinding<br/>(Namespace: opendatahub)"]
        CRB_AuthDelegator["&lbrace;cluster&rbrace;-&lbrace;ns&rbrace;-auth<br/>(Cluster-scoped, dynamic)"]
    end

    subgraph Roles["Roles"]
        CR_Manager["ClusterRole:<br/>manager-role"]
        R_LeaderElection["Role:<br/>leader-election-role<br/>(Namespace: opendatahub)"]
        CR_AuthDelegator["ClusterRole:<br/>system:auth-delegator"]
        CR_Editor["ClusterRole:<br/>appwrapper-editor-role"]
        CR_Viewer["ClusterRole:<br/>viewer-role"]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_LeaderElection
    SA_OAuth -->|bound via| CRB_AuthDelegator

    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| R_LeaderElection
    CRB_AuthDelegator -->|grants| CR_AuthDelegator

    %% manager-role resources
    subgraph ManagerResources["manager-role API Resources"]
        RayClusters["ray.io<br/>rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers<br/>rayjobs"]
        Routes["route.openshift.io<br/>routes<br/>routes/custom-host"]
        Networking["networking.k8s.io<br/>ingresses<br/>networkpolicies"]
        CoreResources["core<br/>secrets, services<br/>serviceaccounts<br/>pods, events, nodes"]
        RBAC_Resources["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        AuthResources["authentication.k8s.io<br/>tokenreviews<br/>authorization.k8s.io<br/>subjectaccessreviews"]
        WebhookResources["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations<br/>validatingwebhookconfigurations"]
        CRDResources["apiextensions.k8s.io<br/>customresourcedefinitions"]
        OSHiftResources["config.openshift.io<br/>ingresses"]
        DSCIResources["dscinitialization.<br/>opendatahub.io<br/>dscinitializations"]
        AppWrapperResources["workload.codeflare.dev<br/>appwrappers<br/>appwrappers/status<br/>appwrappers/finalizers"]
        WorkloadResources["apps: deployments, statefulsets<br/>batch: jobs<br/>kubeflow.org: pytorchjobs<br/>jobset.x-k8s.io: jobsets<br/>scheduling: podgroups"]
    end

    CR_Manager -->|"full CRUD"| RayClusters
    CR_Manager -->|"full CRUD"| Routes
    CR_Manager -->|"full CRUD"| Networking
    CR_Manager -->|"full CRUD<br/>(events: create,patch,update<br/>nodes: read-only)"| CoreResources
    CR_Manager -->|"full CRUD"| RBAC_Resources
    CR_Manager -->|"create"| AuthResources
    CR_Manager -->|"get,list,watch,update"| WebhookResources
    CR_Manager -->|"read-only"| CRDResources
    CR_Manager -->|"get"| OSHiftResources
    CR_Manager -->|"read-only"| DSCIResources
    CR_Manager -->|"full CRUD"| AppWrapperResources
    CR_Manager -->|"full CRUD"| WorkloadResources

    %% leader-election-role resources
    subgraph LeaderResources["leader-election-role Resources"]
        LeaseResources["core: configmaps, events<br/>coordination.k8s.io: leases"]
    end

    R_LeaderElection -->|"full CRUD"| LeaseResources

    %% Editor/Viewer roles
    subgraph EditorViewerResources["Editor/Viewer Resources"]
        AW_EditorRes["workload.codeflare.dev<br/>appwrappers (CRUD)<br/>appwrappers/status (get)"]
        AW_ViewerRes["workload.codeflare.dev<br/>appwrappers (read-only)<br/>appwrappers/status (get)"]
    end

    CR_Editor -->|"create,delete,get<br/>list,patch,update,watch"| AW_EditorRes
    CR_Viewer -->|"get,list,watch"| AW_ViewerRes

    %% Styling
    style SA_Manager fill:#4a90e2,stroke:#333,color:#fff
    style SA_OAuth fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Manager fill:#e67e22,stroke:#333,color:#fff
    style CRB_LeaderElection fill:#e67e22,stroke:#333,color:#fff
    style CRB_AuthDelegator fill:#e67e22,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style R_LeaderElection fill:#f5a623,stroke:#333
    style CR_AuthDelegator fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style RayClusters fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Networking fill:#7ed321,stroke:#333
    style CoreResources fill:#7ed321,stroke:#333
    style RBAC_Resources fill:#7ed321,stroke:#333
    style AuthResources fill:#7ed321,stroke:#333
    style WebhookResources fill:#7ed321,stroke:#333
    style CRDResources fill:#7ed321,stroke:#333
    style OSHiftResources fill:#7ed321,stroke:#333
    style DSCIResources fill:#7ed321,stroke:#333
    style AppWrapperResources fill:#7ed321,stroke:#333
    style WorkloadResources fill:#7ed321,stroke:#333
    style LeaseResources fill:#7ed321,stroke:#333
    style AW_EditorRes fill:#7ed321,stroke:#333
    style AW_ViewerRes fill:#7ed321,stroke:#333
