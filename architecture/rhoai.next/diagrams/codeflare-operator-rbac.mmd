    subgraph ExtensionResources["Extension Resources"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph AppResources["App Resources"]
        Deployments["apps<br/>deployments, statefulsets"]
        Jobs["batch<br/>jobs"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph RayResources["Ray & CodeFlare Resources"]
        RayClusters["ray.io<br/>rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers"]
