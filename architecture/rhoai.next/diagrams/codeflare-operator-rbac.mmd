        PyTorchJobs["kubeflow.org<br/>pytorchjobs"]
    end

    subgraph OpenShiftResources["OpenShift & RHOAI Resources"]
        OSIngress["config.openshift.io<br/>ingresses"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations"]
        CRBs["rbac.authorization.k8s.io<br/>clusterrolebindings"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        ConfigMaps["core<br/>configmaps"]
        Leases["coordination.k8s.io<br/>leases"]
    end

    %% Bindings
    SA_Manager -->|"bound via"| CRB_Manager
    SA_Manager -->|"bound via"| RB_Leader
    SA_OAuth -->|"bound via"| CRB_Auth

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Auth -->|"grants"| CR_AuthDelegator
    RB_Leader -->|"grants"| R_Leader

    %% manager-role permissions
    CR_Manager -->|"full CRUD"| Pods
    CR_Manager -->|"full CRUD"| Secrets
    CR_Manager -->|"full CRUD"| SAs
    CR_Manager -->|"create,patch,update,watch"| Events
    CR_Manager -->|"get,list,watch"| Nodes
    CR_Manager -->|"get,list,update,watch"| MWC
    CR_Manager -->|"get,list,update,watch"| VWC
    CR_Manager -->|"get,list,watch"| CRDs
    CR_Manager -->|"full CRUD"| Deployments
    CR_Manager -->|"full CRUD"| Jobs
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create"| SAR
    CR_Manager -->|"full CRUD"| RayClusters
    CR_Manager -->|"full CRUD"| RayJobs
    CR_Manager -->|"full CRUD"| AppWrappers
    CR_Manager -->|"full CRUD"| Ingresses
    CR_Manager -->|"full CRUD"| NetPolicies
    CR_Manager -->|"full CRUD"| Routes
    CR_Manager -->|"full CRUD"| PodGroups
    CR_Manager -->|"full CRUD"| JobSets
    CR_Manager -->|"full CRUD"| PyTorchJobs
    CR_Manager -->|"get"| OSIngress
    CR_Manager -->|"get,list,watch"| DSCI
    CR_Manager -->|"full CRUD"| CRBs

    %% leader-election-role permissions
    R_Leader -->|"full CRUD"| ConfigMaps
    R_Leader -->|"full CRUD"| Leases
