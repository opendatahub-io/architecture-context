graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/><i>Operator namespace</i>"]
        SA_OAuth["{raycluster}-oauth-proxy<br/><i>Per RayCluster, user namespace</i>"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/><i>Cluster-scoped</i>"]
        CRB_Auth["{raycluster}-{ns}-auth<br/><i>Cluster-scoped, per cluster</i>"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/><i>Operator namespace</i>"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Editor["appwrapper-editor-role"]
        CR_Viewer["viewer-role"]
        CR_AuthDelegator["system:auth-delegator"]
    end

    subgraph Roles["Roles"]
        R_Leader["leader-election-role<br/><i>Operator namespace</i>"]
    end

    subgraph RayIOResources["ray.io Resources"]
        RayClusters["rayclusters<br/>rayclusters/status<br/>rayclusters/finalizers"]
        RayJobs["rayjobs"]
    end

    subgraph CoreResources["Core Resources"]
        Secrets["secrets"]
        Services["services"]
        ServiceAcctsRes["serviceaccounts"]
        Pods["pods"]
        Events["events"]
        Nodes["nodes"]
    end

    subgraph NetworkResources["Networking Resources"]
        Routes["routes<br/>routes/custom-host<br/><i>route.openshift.io</i>"]
        Ingresses["ingresses<br/><i>networking.k8s.io</i>"]
        NetworkPolicies["networkpolicies<br/><i>networking.k8s.io</i>"]
    end

    subgraph WorkloadResources["Workload Resources"]
        AppWrappers["appwrappers<br/>appwrappers/status<br/>appwrappers/finalizers<br/><i>workload.codeflare.dev</i>"]
        Deployments["deployments<br/>statefulsets<br/><i>apps</i>"]
        Jobs["jobs<br/><i>batch</i>"]
        PodGroups["podgroups<br/><i>scheduling.sigs.k8s.io</i>"]
        PyTorchJobs["pytorchjobs<br/><i>kubeflow.org</i>"]
        JobSets["jobsets<br/><i>jobset.x-k8s.io</i>"]
    end

    subgraph AuthResources["Auth & Admin Resources"]
        TokenReviews["tokenreviews<br/><i>authentication.k8s.io</i>"]
        SAR["subjectaccessreviews<br/><i>authorization.k8s.io</i>"]
        WebhookConfigs["mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/><i>admissionregistration.k8s.io</i>"]
        CRDs["customresourcedefinitions<br/><i>apiextensions.k8s.io</i>"]
        DSCInit["dscinitializations<br/><i>dscinitialization.opendatahub.io</i>"]
        IngressCfg["ingresses<br/><i>config.openshift.io</i>"]
    end

    subgraph LeaderElectionResources["Leader Election Resources"]
        ConfigMaps["configmaps"]
        Leases["leases<br/><i>coordination.k8s.io</i>"]
    end

    %% Bindings
    SA_CM -->|bound via| CRB_Manager
    SA_CM -->|bound via| RB_Leader
    SA_OAuth -->|bound via| CRB_Auth

    CRB_Manager -->|grants| CR_Manager
    CRB_Auth -->|grants| CR_AuthDelegator
    RB_Leader -->|grants| R_Leader

    %% manager-role permissions
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| RayClusters
    CR_Manager -->|"get,list,watch,create,<br/>update,patch,delete"| RayJobs
    CR_Manager -->|"CRUD + watch"| Routes
    CR_Manager -->|"CRUD + watch"| Ingresses
    CR_Manager -->|"CRUD + watch"| NetworkPolicies
    CR_Manager -->|"CRUD + watch"| Secrets
    CR_Manager -->|"CRUD + watch"| Services
    CR_Manager -->|"CRUD + watch"| ServiceAcctsRes
    CR_Manager -->|"CRUD + watch"| Pods
    CR_Manager -->|"create,patch,update,watch"| Events
    CR_Manager -->|"get,list,watch"| Nodes
    CR_Manager -->|"CRUD + watch"| AppWrappers
    CR_Manager -->|"CRUD + watch"| Deployments
    CR_Manager -->|"CRUD + watch"| Jobs
    CR_Manager -->|"CRUD + watch"| PodGroups
    CR_Manager -->|"CRUD + watch"| PyTorchJobs
    CR_Manager -->|"CRUD + watch"| JobSets
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create"| SAR
    CR_Manager -->|"get,list,watch,update"| WebhookConfigs
    CR_Manager -->|"get,list,watch"| CRDs
    CR_Manager -->|"get,list,watch"| DSCInit
    CR_Manager -->|"get"| IngressCfg
    CR_Manager -->|"CRUD + watch"| ClusterRoleBindingsRes["clusterrolebindings<br/><i>rbac.authorization.k8s.io</i>"]

    %% editor/viewer roles
    CR_Editor -->|"CRUD + watch"| AppWrappers
    CR_Viewer -->|"get,list,watch"| AppWrappers

    %% leader election
    R_Leader -->|"CRUD + watch"| ConfigMaps
    R_Leader -->|"CRUD + watch"| Leases
    R_Leader -->|"create,patch"| Events

