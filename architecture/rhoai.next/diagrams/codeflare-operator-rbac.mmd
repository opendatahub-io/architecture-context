graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["controller-manager<br/>Namespace: opendatahub"]
        OAuthSA["{cluster}-oauth-proxy<br/>Namespace: {user-namespace}<br/>(per RayCluster, dynamic)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["manager-rolebinding<br/>(Cluster-scoped)"]
        AuthCRB["{cluster}-{ns}-auth<br/>(Cluster-scoped, per RayCluster)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        LERB["leader-election-rolebinding<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR["manager-role"]
        AuthDelegator["system:auth-delegator<br/>(built-in)"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        LER["leader-election-role<br/>Namespace: opendatahub"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        Pods["pods"]
        Services["services"]
        Secrets["secrets"]
        ServiceAccts["serviceaccounts"]
        Events["events"]
        Nodes["nodes"]
        ConfigMaps["configmaps"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["deployments"]
        StatefulSets["statefulsets"]
    end

    subgraph RayResources["ray.io API Resources"]
        RayClusters["rayclusters<br/>+ /finalizers, /status"]
        RayJobs["rayjobs"]
    end

    subgraph CodeFlareResources["workload.codeflare.dev Resources"]
        AppWrappers["appwrappers<br/>+ /finalizers, /status"]
    end

    subgraph NetworkResources["networking.k8s.io Resources"]
        Ingresses["ingresses"]
        NetworkPolicies["networkpolicies"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        Routes["routes, routes/custom-host<br/>(route.openshift.io)"]
        OSHIngresses["ingresses<br/>(config.openshift.io)"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["tokenreviews<br/>(authentication.k8s.io)"]
        SAR["subjectaccessreviews<br/>(authorization.k8s.io)"]
    end

    subgraph AdmissionResources["Admission Resources"]
        MWC["mutatingwebhookconfigurations"]
        VWC["validatingwebhookconfigurations"]
        CRDs["customresourcedefinitions"]
    end

    subgraph BatchResources["Batch & Scheduling Resources"]
        Jobs["jobs (batch)"]
        JobSets["jobsets (jobset.x-k8s.io)"]
        PyTorchJobs["pytorchjobs (kubeflow.org)"]
        PodGroups["podgroups<br/>(scheduling.sigs.k8s.io,<br/>scheduling.x-k8s.io)"]
    end

    subgraph OtherResources["Other Resources"]
        DSCI["dscinitializations<br/>(opendatahub.io)"]
        CRBResource["clusterrolebindings<br/>(rbac.authorization.k8s.io)"]
        Leases["leases<br/>(coordination.k8s.io)"]
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    SA -->|"bound via"| LERB
    LERB -->|"grants"| LER
    OAuthSA -->|"bound via"| AuthCRB
    AuthCRB -->|"grants"| AuthDelegator

    %% manager-role permissions (CRUD)
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Pods
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Services
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Secrets
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| ServiceAccts
    CR -->|"create,patch,update,watch"| Events
    CR -->|"get,list,watch"| Nodes
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Deployments
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| StatefulSets
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RayClusters
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RayJobs
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| AppWrappers
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Ingresses
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| NetworkPolicies
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Routes
    CR -->|"get"| OSHIngresses
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR
    CR -->|"get,list,update,watch"| MWC
    CR -->|"get,list,update,watch"| VWC
    CR -->|"get,list,watch"| CRDs
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Jobs
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| JobSets
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| PyTorchJobs
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| PodGroups
    CR -->|"get,list,watch"| DSCI
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| CRBResource

    %% leader-election-role permissions
    LER -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    LER -->|"get,list,watch,create,<br/>update,patch,delete"| Leases
    LER -->|"create,patch"| Events

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style OAuthSA fill:#6ba5e7,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style LER fill:#f5c869,stroke:#333
    style AuthDelegator fill:#f5c869,stroke:#333
    style CRB fill:#d4a017,stroke:#333
    style AuthCRB fill:#d4a017,stroke:#333
    style LERB fill:#d4a017,stroke:#333
    style RayClusters fill:#7ed321,stroke:#333
    style RayJobs fill:#7ed321,stroke:#333
    style AppWrappers fill:#7ed321,stroke:#333
    style Routes fill:#CC0000,stroke:#333,color:#fff
    style OSHIngresses fill:#CC0000,stroke:#333,color:#fff
