graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["controller-manager<br/>(operator namespace)"]
        OAuthSA["{cluster}-oauth-proxy<br/>(per RayCluster, user namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["manager-rolebinding<br/>(cluster-scoped)"]
        AuthCRB["{cluster}-{ns}-auth<br/>(per RayCluster, cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        LERB["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["manager-role"]
        AuthDelegator["system:auth-delegator<br/>(built-in)"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        LER["leader-election-role"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, services"]
        Secrets["core<br/>secrets"]
        SvcAccts["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Nodes["core<br/>nodes"]
    end

    subgraph AppsResources["Apps Resources"]
        Deployments["apps<br/>deployments, statefulsets"]
        Jobs["batch<br/>jobs"]
    end

    subgraph RayResources["Ray Resources"]
        RayClusters["ray.io<br/>rayclusters<br/>+ /finalizers, /status"]
        RayJobs["ray.io<br/>rayjobs"]
    end

    subgraph NetworkResources["Network Resources"]
        Ingresses["networking.k8s.io<br/>ingresses"]
        NetPolicies["networking.k8s.io<br/>networkpolicies"]
        Routes["route.openshift.io<br/>routes, routes/custom-host"]
    end

    subgraph SecurityResources["Security Resources"]
        CRBindings["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        WebhookConfigs["admissionregistration.k8s.io<br/>mutating/validating<br/>webhookconfigurations"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAReviews["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph AppWrapperResources["AppWrapper Resources"]
        AppWrappers["workload.codeflare.dev<br/>appwrappers<br/>+ /finalizers, /status"]
        PyTorchJobs["kubeflow.org<br/>pytorchjobs"]
        JobSets["jobset.x-k8s.io<br/>jobsets"]
        PodGroups["scheduling.sigs.k8s.io<br/>scheduling.x-k8s.io<br/>podgroups"]
    end

    subgraph PlatformResources["Platform Resources"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
        DSCInit["dscinitialization.opendatahub.io<br/>dscinitializations"]
        OSIngress["config.openshift.io<br/>ingresses"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        ConfigMaps["core<br/>configmaps"]
        Leases["coordination.k8s.io<br/>leases"]
        LEEvents["core<br/>events"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LERB
    OAuthSA -->|bound via| AuthCRB

    CRB -->|grants| CR
    AuthCRB -->|grants| AuthDelegator
    LERB -->|grants| LER

    %% manager-role permissions
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Pods
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Secrets
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| SvcAccts
    CR -->|"create,patch,<br/>update,watch"| Events
    CR -->|"get,list,watch"| Nodes
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Deployments
    CR -->|"get,list,watch,create,<br/>update,patch,delete"| Jobs
    CR -->|"full CRUD +<br/>finalizers,status"| RayClusters
    CR -->|"full CRUD"| RayJobs
    CR -->|"full CRUD"| Ingresses
    CR -->|"full CRUD"| NetPolicies
    CR -->|"full CRUD"| Routes
    CR -->|"full CRUD"| CRBindings
    CR -->|"get,list,<br/>update,watch"| WebhookConfigs
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAReviews
    CR -->|"full CRUD +<br/>finalizers,status"| AppWrappers
    CR -->|"full CRUD"| PyTorchJobs
    CR -->|"full CRUD"| JobSets
    CR -->|"full CRUD"| PodGroups
    CR -->|"get,list,watch"| CRDs
    CR -->|"get,list,watch"| DSCInit
    CR -->|"get"| OSIngress

    %% leader-election-role permissions
    LER -->|"full CRUD"| ConfigMaps
    LER -->|"full CRUD"| Leases
    LER -->|"create,patch"| LEEvents

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style OAuthSA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style LER fill:#f5a623,stroke:#333
    style AuthDelegator fill:#f5a623,stroke:#333
    style RayClusters fill:#7ed321,stroke:#333
    style AppWrappers fill:#7ed321,stroke:#333
    style Secrets fill:#f8cecc,stroke:#b85450
    style CRBindings fill:#f8cecc,stroke:#b85450
    style TokenReviews fill:#f8cecc,stroke:#b85450
    style SAReviews fill:#f8cecc,stroke:#b85450
