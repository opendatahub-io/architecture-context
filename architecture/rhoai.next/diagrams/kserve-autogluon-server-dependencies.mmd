graph LR
    AG["KServe AutoGluon Server<br/>(ML Serving Runtime)"]

    %% Internal Platform Dependencies
    AG -->|"pod creation via<br/>InferenceService CR"| KServeCtrl["KServe Controller"]
    AG -->|"auth sidecar<br/>8443/TCP HTTPS"| KubeRBAC["kube-rbac-proxy<br/>(RHOAI 3.x)"]
    AG -->|"metrics scrape<br/>8080/TCP HTTP"| Prometheus["Prometheus"]
    AG -.->|"defined by"| CSR["ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1"]

    %% External Cloud Dependencies (Egress)
    AG -->|"model download<br/>443/TCP HTTPS"| S3["S3 Storage<br/>(boto3)"]
    AG -->|"model download<br/>443/TCP HTTPS"| GCS["Google Cloud Storage<br/>(google-cloud-storage)"]
    AG -->|"model download<br/>443/TCP HTTPS"| Azure["Azure Blob Storage<br/>(azure-storage-blob)"]
    AG -->|"model download<br/>443/TCP HTTPS"| HFHub["Hugging Face Hub<br/>(huggingface-hub)"]

    %% Key Python Dependencies (vendored + external)
    AG -->|"ML framework"| AutoGluon["autogluon 1.5.0+rhaiv.2<br/>(tabular + timeseries)"]
    AG -->|"serving framework"| KServeSDK["kserve SDK<br/>(vendored)"]
    AG -->|"storage download"| KServeStorage["kserve-storage<br/>(vendored)"]
    AutoGluon -->|"deep learning"| Torch["torch 2.10.0"]
    AutoGluon -->|"gradient boosting"| LightGBM["lightgbm 4.6.0"]
    AutoGluon -->|"gradient boosting"| XGBoost["xgboost 3.1.3"]
    KServeSDK -->|"HTTP server"| Uvicorn["uvicorn + fastapi"]
    KServeSDK -->|"gRPC server"| gRPC["grpcio"]

    %% Platform Ingress
    PlatformIngress["Platform Ingress<br/>Gateway / Route"] -->|"routes to<br/>443/TCP HTTPS"| AG

    %% Styling
    style AG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style CSR fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style AutoGluon fill:#9b59b6,stroke:#333,color:#fff
    style KServeSDK fill:#9b59b6,stroke:#333,color:#fff
    style KServeStorage fill:#9b59b6,stroke:#333,color:#fff
    style Torch fill:#e8e8e8,stroke:#333
    style LightGBM fill:#e8e8e8,stroke:#333
    style XGBoost fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style gRPC fill:#e8e8e8,stroke:#333
