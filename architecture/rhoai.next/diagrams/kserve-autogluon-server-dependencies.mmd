graph LR
    AutoGluon["AutoGluon Server<br/>(KServe Runtime)"]

    %% Internal Platform Dependencies
    AutoGluon -->|"CRD: InferenceService<br/>pod lifecycle"| KServeCtrl["KServe Controller"]
    AutoGluon -->|"init container<br/>model download"| StorageInit["Storage Initializer"]
    AutoGluon -->|"sidecar<br/>mTLS enforcement"| Istio["Istio Service Mesh"]
    AutoGluon -->|"autoscaling<br/>serverless mode"| Knative["Knative Serving"]

    %% ML Framework Dependencies
    AutoGluon -->|"tabular inference<br/>1.5.0+rhaiv.2"| AGTabular["autogluon.tabular"]
    AutoGluon -->|"time series forecast<br/>1.5.0+rhaiv.2"| AGTimeSeries["autogluon.timeseries"]

    %% ML Backend Dependencies
    AGTabular -->|"gradient boosting"| LightGBM["LightGBM 4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["XGBoost 3.1.3"]
    AGTabular -->|"ML algorithms"| Sklearn["scikit-learn ≥1.7"]
    AGTimeSeries -->|"deep learning<br/>(Chronos)"| Torch["PyTorch 2.10.0"]
    AGTimeSeries -->|"transformers<br/>(Chronos)"| Transformers["transformers ≥4.57"]
    AGTimeSeries -->|"acceleration"| Accelerate["accelerate ≥1.13"]

    %% Data Processing Dependencies
    AutoGluon -->|"DataFrame processing"| Pandas["pandas ≥2.3"]
    AutoGluon -->|"array operations"| Numpy["numpy ≥2.1"]

    %% Server Framework Dependencies
    AutoGluon -->|"HTTP/gRPC server<br/>framework"| KServeSDK["KServe SDK<br/>(local)"]
    AutoGluon -->|"model storage<br/>download"| KServeStorage["kserve-storage<br/>(local)"]

    %% External Storage Services
    KServeStorage -->|"model artifacts<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]
    KServeStorage -->|"model artifacts<br/>HTTPS/443"| GCS["GCS Storage"]
    Transformers -->|"model/tokenizer<br/>downloads"| HFHub["HuggingFace Hub"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP/8080"| AutoGluon
    KServeCtrl -->|"deploys"| AutoGluon

    %% Styling
    style AutoGluon fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal Platform (green)
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% External Infrastructure (gray)
    style Istio fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff

    %% ML Frameworks (purple)
    style AGTabular fill:#9b59b6,stroke:#333,color:#fff
    style AGTimeSeries fill:#9b59b6,stroke:#333,color:#fff

    %% ML Backends (light purple)
    style LightGBM fill:#c39bd3,stroke:#333
    style XGBoost fill:#c39bd3,stroke:#333
    style Sklearn fill:#c39bd3,stroke:#333
    style Torch fill:#c39bd3,stroke:#333
    style Transformers fill:#c39bd3,stroke:#333
    style Accelerate fill:#c39bd3,stroke:#333

    %% Data Processing (teal)
    style Pandas fill:#1abc9c,stroke:#333,color:#fff
    style Numpy fill:#1abc9c,stroke:#333,color:#fff

    %% Server Framework (blue)
    style KServeSDK fill:#5dade2,stroke:#333,color:#fff
    style KServeStorage fill:#5dade2,stroke:#333,color:#fff

    %% External Services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
