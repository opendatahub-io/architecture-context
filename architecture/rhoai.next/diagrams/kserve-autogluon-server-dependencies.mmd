graph LR
    AutoGluon["KServe AutoGluon<br/>Server"]

    %% Core ML Dependencies
    AutoGluon -->|"tabular inference"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
    AutoGluon -->|"time series inference"| AGTimeSeries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]

    %% ML Framework Dependencies
    AGTabular -->|"gradient boosting"| LightGBM["lightgbm<br/>4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["xgboost<br/>3.1.3"]
    AGTabular -->|"ML algorithms"| SKLearn["scikit-learn<br/>&ge;1.7"]
    AGTimeSeries -->|"deep learning"| Torch["torch<br/>2.10.0"]
    AGTimeSeries -->|"Chronos models"| Transformers["transformers<br/>&ge;4.57"]
    AGTimeSeries -->|"GPU acceleration"| Accelerate["accelerate<br/>&ge;1.13"]

    %% Data Processing Dependencies
    AutoGluon -->|"DataFrame ops"| Pandas["pandas<br/>&ge;2.3"]
    AutoGluon -->|"array ops"| NumPy["numpy<br/>&ge;2.1"]

    %% KServe Framework Dependencies
    AutoGluon -->|"server framework"| KServeSDK["kserve SDK<br/>(local)"]
    AutoGluon -->|"model download"| KServeStorage["kserve-storage<br/>(local)"]

    %% Internal Platform Dependencies
    KServeCtrl["KServe Controller"] -->|"deploys pod"| AutoGluon
    StorageInit["Storage Initializer"] -->|"downloads models<br/>to /mnt/models"| AutoGluon
    AutoGluon -.->|"sidecar mTLS"| Istio["Istio Service Mesh"]
    AutoGluon -.->|"autoscaling"| Knative["Knative Serving"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080"| AutoGluon

    %% External Services (outbound)
    KServeStorage -->|"model artifacts<br/>HTTPS/443"| S3["S3 Storage"]
    KServeStorage -->|"model artifacts<br/>HTTPS/443"| GCS["GCS Storage"]
    KServeStorage -->|"model artifacts<br/>HTTPS or HTTP"| GenericURI["HTTP/HTTPS URI"]
    AutoGluon -->|"tokenizers/models<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Styling - Core component
    style AutoGluon fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% ML Dependencies
    style AGTabular fill:#8b5cf6,stroke:#333,color:#fff
    style AGTimeSeries fill:#8b5cf6,stroke:#333,color:#fff
    style LightGBM fill:#c4b5fd,stroke:#333
    style XGBoost fill:#c4b5fd,stroke:#333
    style SKLearn fill:#c4b5fd,stroke:#333
    style Torch fill:#c4b5fd,stroke:#333
    style Transformers fill:#c4b5fd,stroke:#333
    style Accelerate fill:#c4b5fd,stroke:#333
    style Pandas fill:#c4b5fd,stroke:#333
    style NumPy fill:#c4b5fd,stroke:#333

    %% KServe Framework
    style KServeSDK fill:#50c878,stroke:#333,color:#fff
    style KServeStorage fill:#50c878,stroke:#333,color:#fff

    %% Internal Platform
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#9673a6,stroke:#333,color:#fff

    %% External Services
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style GenericURI fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
