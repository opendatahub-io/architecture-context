graph LR
    AutoGluon["KServe AutoGluon Server<br/>(odh-kserve-autogluon-server)"]

    %% Core ML Dependencies
    AutoGluon -->|"tabular inference"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.3"]
    AutoGluon -->|"timeseries inference"| AGTimeseries["autogluon.timeseries<br/>1.5.0+rhaiv.3"]
    AutoGluon -->|"server framework"| KServeSDK["kserve SDK<br/>0.19.0"]
    AutoGluon -->|"model download"| KServeStorage["kserve-storage<br/>0.19.0"]

    %% ML Backends (via AutoGluon)
    AGTabular -->|"NN backend"| PyTorch["torch<br/>2.11.0"]
    AGTabular -->|"GBDT backend"| LightGBM["lightgbm<br/>4.6.0"]
    AGTabular -->|"GBDT backend"| XGBoost["xgboost<br/>3.1.3"]
    AGTabular -->|"NN backend"| FastAI["fastai<br/>2.8.7"]
    AGTimeseries -->|"NN models"| PyTorch

    %% Server Infrastructure
    KServeSDK -->|"HTTP server"| Uvicorn["uvicorn<br/>0.49.0"]
    KServeSDK -->|"REST framework"| FastAPI["fastapi<br/>0.136.3"]
    KServeSDK -->|"gRPC server"| gRPC["grpcio<br/>1.81.0"]

    %% Storage Backends
    KServeStorage -->|"S3 access"| Boto3["boto3<br/>1.43.24"]
    KServeStorage -->|"HF models"| HFHub["huggingface-hub<br/>0.36.2"]

    %% Security
    KServeSDK -.->|"TLS/crypto"| Crypto["cryptography<br/>48.0.0"]

    %% Internal Platform Dependencies
    KServeCtrl["KServe Controller"] -->|"manages pod"| AutoGluon
    CSR["ClusterServingRuntime"] -.->|"defines runtime"| KServeCtrl
    PlatformIngress["Platform Ingress<br/>(Gateway API / Istio)"] -->|"routes traffic"| AutoGluon
    Prometheus["Prometheus"] -->|"scrapes metrics"| AutoGluon

    %% External Services
    AutoGluon -->|"model storage"| S3["S3 Storage"]
    AutoGluon -->|"model storage"| GCS["GCS"]
    AutoGluon -->|"model storage"| AzureBlob["Azure Blob"]
    AutoGluon -->|"model storage"| HuggingFace["HuggingFace Hub"]

    %% Styling
    style AutoGluon fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core dependencies
    style AGTabular fill:#e3f2fd,stroke:#1565c0
    style AGTimeseries fill:#e3f2fd,stroke:#1565c0
    style KServeSDK fill:#e3f2fd,stroke:#1565c0
    style KServeStorage fill:#e3f2fd,stroke:#1565c0

    %% ML backends
    style PyTorch fill:#ee4c2c,stroke:#333,color:#fff
    style LightGBM fill:#2ca02c,stroke:#333,color:#fff
    style XGBoost fill:#ff9800,stroke:#333,color:#fff
    style FastAI fill:#1a237e,stroke:#333,color:#fff

    %% Infrastructure
    style Uvicorn fill:#e8e8e8,stroke:#333
    style FastAPI fill:#e8e8e8,stroke:#333
    style gRPC fill:#e8e8e8,stroke:#333
    style Boto3 fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style Crypto fill:#e8e8e8,stroke:#333

    %% Internal platform
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style CSR fill:#7ed321,stroke:#333,color:#fff
    style PlatformIngress fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

