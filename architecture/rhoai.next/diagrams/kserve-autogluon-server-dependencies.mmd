graph LR
    AutoGluonServer["AutoGluon Server<br/>(kserve-autogluon-server)"]

    %% Core ML Dependencies
    AutoGluonServer -->|"tabular prediction"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
    AutoGluonServer -->|"time series forecasting"| AGTimeSeries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]

    %% ML Backend Models
    AGTabular -->|"gradient boosting"| LightGBM["LightGBM<br/>4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["XGBoost<br/>3.1.3"]
    AGTabular -->|"neural networks"| PyTorch["PyTorch<br/>2.10.0"]

    %% KServe SDK Dependencies
    AutoGluonServer -->|"serving framework"| KServeSDK["KServe Python SDK<br/>0.17.0"]
    AutoGluonServer -->|"model download"| KServeStorage["kserve-storage<br/>0.17.0"]

    %% Web Framework Dependencies
    KServeSDK -->|"REST API"| FastAPI["FastAPI<br/>>=0.115.3"]
    KServeSDK -->|"HTTP server"| Uvicorn["Uvicorn<br/>>=0.30.6"]
    KServeSDK -->|"gRPC server"| GRPCIO["grpcio<br/>>=1.73.0"]
    KServeSDK -->|"metrics"| PromClient["prometheus-client<br/>>=0.20.0"]

    %% Storage Dependencies
    KServeStorage -->|"S3/AWS access"| Boto3["boto3<br/>>=1.29.0"]
    KServeStorage -->|"HuggingFace models"| HFHub["huggingface-hub<br/>>=0.32.0"]

    %% Security Dependencies
    KServeSDK -->|"TLS/crypto"| Cryptography["cryptography<br/>>=46.0.5"]

    %% Internal Platform Dependencies
    KServeCtrl["KServe Controller"] -->|"creates pods via<br/>InferenceService CR"| AutoGluonServer
    KServeRouter["KServe Router"] -->|"routes inference<br/>traffic"| AutoGluonServer

    %% External Service Dependencies
    KServeStorage -->|"HTTPS/443<br/>AWS IAM"| S3["S3 Storage"]
    KServeStorage -->|"HTTPS/443<br/>Bearer Token"| HuggingFace["HuggingFace Hub"]
    KServeStorage -->|"HTTPS/443<br/>SA / SAS"| GCSAzure["GCS / Azure Blob"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8080"| AutoGluonServer

