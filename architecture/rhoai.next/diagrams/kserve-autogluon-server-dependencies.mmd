graph LR
    AutoGluonServer["kserve-autogluon-server<br/>(ML Inference Service)"]

    %% Core ML Dependencies
    AutoGluonServer -->|"tabular prediction"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
    AutoGluonServer -->|"time series forecasting"| AGTimeSeries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]

    %% ML Backend Dependencies
    AGTabular -->|"gradient boosting"| LightGBM["lightgbm 4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["xgboost 3.1.3"]
    AGTabular -->|"neural networks"| PyTorch["torch 2.10.0"]

    %% Serving Framework Dependencies
    AutoGluonServer -->|"serving framework<br/>v1/v2 protocol"| KServeSDK["kserve SDK<br/>0.17.0"]
    AutoGluonServer -->|"model download"| KServeStorage["kserve-storage<br/>0.17.0"]

    %% KServe SDK Sub-dependencies
    KServeSDK -->|"REST API"| FastAPI["fastapi >=0.115.3"]
    KServeSDK -->|"HTTP server"| Uvicorn["uvicorn >=0.30.6"]
    KServeSDK -->|"gRPC server"| GRPCIO["grpcio >=1.73.0"]
    KServeSDK -->|"metrics"| PromClient["prometheus-client >=0.20.0"]

    %% Storage Sub-dependencies
    KServeStorage -->|"S3/AWS access"| Boto3["boto3 >=1.29.0"]
    KServeStorage -->|"HuggingFace models"| HFHub["huggingface-hub >=0.32.0"]

    %% Security
    AutoGluonServer -->|"TLS/crypto"| Cryptography["cryptography >=46.0.5<br/>(CVE-2026-26007 fix)"]

    %% Internal Platform Dependencies
    KServeCtrl["KServe Controller"] -->|"creates pods via<br/>InferenceService CR"| AutoGluonServer
    AutoGluonServer -->|"model artifacts<br/>at startup"| ModelStorage["Model Storage<br/>(S3/PVC/GCS)"]

    %% Integration Points
    KServeRouter["KServe Router"] -->|"inference traffic<br/>8080/TCP, 8081/TCP"| AutoGluonServer
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8080/TCP"| AutoGluonServer

    %% Styling
    style AutoGluonServer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% ML deps - green
    style AGTabular fill:#7ed321,stroke:#333,color:#fff
    style AGTimeSeries fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#a8e063,stroke:#333
    style XGBoost fill:#a8e063,stroke:#333
    style PyTorch fill:#a8e063,stroke:#333

    %% Serving framework - blue
    style KServeSDK fill:#5b9bd5,stroke:#333,color:#fff
    style KServeStorage fill:#5b9bd5,stroke:#333,color:#fff
    style FastAPI fill:#9dc3e6,stroke:#333
    style Uvicorn fill:#9dc3e6,stroke:#333
    style GRPCIO fill:#9dc3e6,stroke:#333
    style PromClient fill:#9dc3e6,stroke:#333
    style Boto3 fill:#9dc3e6,stroke:#333
    style HFHub fill:#9dc3e6,stroke:#333

    %% Security - orange
    style Cryptography fill:#f5a623,stroke:#333,color:#fff

    %% Internal platform - teal
    style KServeCtrl fill:#50c878,stroke:#333,color:#fff
    style KServeRouter fill:#50c878,stroke:#333,color:#fff
    style ModelStorage fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#9673a6
