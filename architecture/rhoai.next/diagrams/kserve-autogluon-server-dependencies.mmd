graph LR
    AutoGluonServer["AutoGluon Server<br/>(kserve-autogluon-server)"]

    %% Core Framework Dependencies
    AutoGluonServer -->|"serving framework<br/>REST + gRPC + metrics"| KServeSDK["KServe Python SDK<br/>0.17.0"]
    AutoGluonServer -->|"model download<br/>S3/GCS/HF/Azure"| KServeStorage["kserve-storage<br/>0.17.0"]

    %% ML Framework Dependencies
    AutoGluonServer -->|"tabular prediction"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
    AutoGluonServer -->|"time series prediction"| AGTimeSeries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]

    %% ML Backend Dependencies
    AGTabular -->|"gradient boosting"| LightGBM["LightGBM 4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["XGBoost 3.1.3"]
    AGTabular -->|"neural networks"| PyTorch["PyTorch 2.10.0"]
    AGTimeSeries -->|"neural networks"| PyTorch

    %% Web Framework Dependencies
    KServeSDK -->|"REST API"| FastAPI["FastAPI >=0.115.3"]
    KServeSDK -->|"HTTP server"| Uvicorn["uvicorn >=0.30.6"]
    KServeSDK -->|"gRPC server"| gRPCio["grpcio >=1.73.0"]
    KServeSDK -->|"metrics"| PromClient["prometheus-client >=0.20.0"]

    %% Storage Backend Dependencies
    KServeStorage -->|"S3 access"| Boto3["boto3 >=1.29.0"]
    KServeStorage -->|"HF download"| HFHub["huggingface-hub >=0.32.0"]

    %% Crypto
    KServeSDK -->|"TLS/crypto"| Crypto["cryptography >=46.0.5"]

    %% Internal Platform Dependencies
    KServeCtrl["KServe Controller"] -->|"creates pods via<br/>InferenceService CRD"| AutoGluonServer
    KServeRouter["KServe Router"] -->|"routes inference<br/>traffic"| AutoGluonServer

    %% External Services
    AutoGluonServer -->|"model storage<br/>HTTPS/443"| S3["S3-compatible Storage"]
    AutoGluonServer -->|"model download<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]
    AutoGluonServer -->|"model storage<br/>HTTPS/443"| GCSAzure["GCS / Azure Blob"]
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8080"| AutoGluonServer

