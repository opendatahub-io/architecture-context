graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        GatewayAPI["Gateway API + Kuadrant/Authorino<br/>HTTPRoute: /v1/batches, /v1/files<br/>AuthN: Envoy ext_authz<br/>Tenant: X-MaaS-Username (last value)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Batch Gateway)"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            APIServer["batch-gateway-apiserver<br/>SA: {release}-apiserver<br/>Ports: 8000/TCP (API), 8081/TCP (obs)<br/>TLS 1.2+ optional (cert-manager)<br/>Tenant-scoped data access<br/>Cross-tenant: 404"]
            Processor["batch-gateway-processor<br/>SA: {release}-processor<br/>Port: 9090/TCP (metrics only)<br/>No inbound connections<br/>Workers: 20, Global: 100, Per-model: 10"]
            GCSvc["batch-gateway-gc<br/>SA: {release}-gc<br/>No ports, single replica<br/>Interval: 30m"]
        end
    end

    subgraph DataLayer["DATA LAYER (Egress)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>Plaintext or TLS<br/>Auth: URL credentials"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>RESP protocol<br/>Optional TLS<br/>Auth: URL credentials"]
        S3["S3-compatible Storage<br/>443/TCP<br/>HTTPS, TLS 1.2+<br/>Auth: AWS IAM credentials"]
    end

    subgraph InferenceLayer["INFERENCE (Egress)"]
        InferenceGW["Inference Gateway<br/>(llm-d / vLLM)<br/>Configurable port<br/>HTTP/HTTPS, TLS 1.2+<br/>Auth: Bearer token or mTLS"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>Plaintext or TLS"]
        Prometheus["Prometheus<br/>ServiceMonitor + PodMonitor<br/>HTTP plaintext"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Delegated auth"| GatewayAPI

    %% Ingress to API Server
    GatewayAPI -->|"HTTP(S)/8000<br/>TLS 1.2+ optional<br/>Tenant header validated"| APIServer

    %% API Server to Data Layer
    APIServer -->|"TCP/5432<br/>PG wire protocol<br/>URL credentials"| PostgreSQL
    APIServer -->|"TCP/6379<br/>RESP<br/>URL credentials"| Redis
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Processor to Data Layer
    Processor -->|"TCP/5432<br/>PG wire protocol<br/>URL credentials"| PostgreSQL
    Processor -->|"TCP/6379<br/>RESP (queue dequeue)<br/>URL credentials"| Redis
    Processor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Processor to Inference
    Processor -->|"HTTP(S)/configurable<br/>TLS 1.2+ + mTLS<br/>Bearer token or client certs"| InferenceGW

    %% GC to Data Layer
    GCSvc -->|"TCP/5432<br/>Delete expired"| PostgreSQL
    GCSvc -->|"TCP/6379<br/>Delete expired"| Redis
    GCSvc -->|"HTTPS/443<br/>Delete expired files"| S3

    %% Observability
    APIServer -.->|"HTTP/8081<br/>plaintext<br/>ServiceMonitor"| Prometheus
    Processor -.->|"HTTP/9090<br/>plaintext<br/>PodMonitor"| Prometheus
    APIServer -.->|"gRPC/4317<br/>OTel traces"| OTLP
    Processor -.->|"gRPC/4317<br/>OTel traces"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inference fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef obs fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class GatewayAPI ingress
    class APIServer,Processor,GCSvc app
    class PostgreSQL,Redis,S3 data
    class InferenceGW inference
    class OTLP,Prometheus obs
