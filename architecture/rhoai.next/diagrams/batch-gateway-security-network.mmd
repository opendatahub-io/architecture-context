graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Optional - Gateway API)"]
        HTTPRoute["Gateway API HTTPRoute<br/>/v1/batches, /v1/files<br/>TLS: Depends on Gateway"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph ApiserverSvc["Service: batch-gateway-apiserver (ClusterIP)"]
            Apiserver["batch-gateway-apiserver<br/>Ports: service.port (API), 8081 (observability)<br/>SA: {release}-batch-gateway-apiserver<br/>TLS 1.2+ (optional)"]
        end

        subgraph ProcessorDeploy["Deployment: batch-gateway-processor"]
            Processor["batch-gateway-processor<br/>Port: configurable addr (observability)<br/>SA: {release}-batch-gateway-processor<br/>Workers: num_workers"]
        end

        subgraph GCDeploy["Deployment: batch-gateway-gc"]
            GCPod["batch-gateway-gc<br/>No ports (no listener)<br/>SA: {release}-batch-gateway-gc"]
        end
    end

    subgraph BackendServices["BACKEND SERVICES (Egress)"]
        PG["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Auth: Connection URL"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>TLS / mTLS (configurable)<br/>Auth: Connection URL"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS<br/>Auth: AWS Credentials"]
        InferenceGW["LLM Inference Gateway<br/>(llm-d / vLLM)<br/>Configurable Port<br/>TLS 1.2+ (configurable)<br/>Auth: Bearer Token"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>ServiceMonitor + PodMonitor"]
        OTel["OpenTelemetry Collector<br/>4317/TCP OTLP/gRPC"]
        Grafana["Grafana<br/>Dashboards via ConfigMap"]
    end

    %% External → Ingress → Apiserver
    Client -->|"HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>Header: X-MaaS-Username<br/>No authn (upstream proxy)"| HTTPRoute
    HTTPRoute -->|"HTTP/HTTPS<br/>service.port"| Apiserver

    %% Apiserver → Backend
    Apiserver -->|"TCP/5432<br/>TLS (configurable)<br/>pgx v5 pool"| PG
    Apiserver -->|"TCP/6379<br/>TLS/mTLS<br/>go-redis v9"| Redis
    Apiserver -->|"HTTPS/443<br/>TLS<br/>AWS SDK v2"| S3

    %% Processor → Backend
    Processor -->|"TCP/5432<br/>TLS (configurable)"| PG
    Processor -->|"TCP/6379<br/>TLS/mTLS"| Redis
    Processor -->|"HTTPS/443<br/>TLS"| S3
    Processor -->|"HTTP/HTTPS<br/>TLS 1.2+<br/>Bearer Token<br/>CA cert + client certs"| InferenceGW

    %% GC → Backend
    GCPod -->|"TCP/5432<br/>TLS (configurable)"| PG
    GCPod -->|"TCP/6379<br/>TLS/mTLS"| Redis
    GCPod -->|"HTTPS/443<br/>TLS"| S3

    %% Observability
    Prometheus -.->|"HTTP/8081<br/>No auth<br/>/metrics"| Apiserver
    Prometheus -.->|"HTTP<br/>No auth<br/>/metrics"| Processor
    Apiserver -.->|"gRPC/4317<br/>OTLP"| OTel
    Processor -.->|"gRPC/4317<br/>OTLP"| OTel
    GCPod -.->|"gRPC/4317<br/>OTLP"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class HTTPRoute ingress
    class Apiserver,Processor,GCPod clusterservice
    class PG,Redis,S3,InferenceGW backend
    class Prometheus,OTel,Grafana observability
