graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>API Consumer"]
    end

    subgraph Ingress["INGRESS (Authentication)"]
        AuthGW["Kuadrant/Authorino<br/>Auth Gateway<br/>Injects X-MaaS-Username"]
        GatewayAPI["llm-d Gateway<br/>HTTPRoute<br/>/v1/batches, /v1/files"]
    end

    subgraph BatchServices["BATCH GATEWAY SERVICES"]
        direction TB

        subgraph NS_API["API Server"]
            APIServer["batch-gateway-apiserver<br/>SA: {release}-batch-gateway-apiserver<br/>Ports: 8000/TCP (API), 8081/TCP (obs)<br/>readOnlyRootFS, UID 65532, drop ALL"]
        end

        subgraph NS_Proc["Processor"]
            Processor["batch-gateway-processor<br/>SA: {release}-batch-gateway-processor<br/>Port: 9090/TCP (obs only)<br/>readOnlyRootFS, UID 65532, drop ALL<br/>Concurrency: global=100, per_model=10"]
        end

        subgraph NS_GC["Garbage Collector"]
            GColl["batch-gateway-gc<br/>SA: {release}-batch-gateway-gc<br/>No exposed ports<br/>readOnlyRootFS, UID 65532, drop ALL<br/>Interval: 30m, Replicas: 1"]
        end
    end

    subgraph DataLayer["DATA LAYER"]
        PostgreSQL["PostgreSQL<br/>5432/TCP pgx<br/>Optional TLS<br/>Auth: Connection URL (K8s secret)"]
        Redis["Redis/Valkey<br/>6379/TCP RESP<br/>Optional TLS/mTLS<br/>Auth: Connection URL (K8s secret)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM credentials"]
        InferGlobal["Inference Gateway (Global)<br/>Configurable port HTTP/HTTPS<br/>Optional TLS 1.2+ / mTLS<br/>Auth: Bearer token / mTLS cert"]
        InferModel["Inference Gateway (Per-Model)<br/>Configurable port HTTP/HTTPS<br/>Optional TLS 1.2+ / mTLS<br/>Auth: Bearer token"]
        OTel["OpenTelemetry Collector<br/>Configurable gRPC<br/>Optional TLS<br/>OTLP traces"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>ServiceMonitor + PodMonitor"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| AuthGW
    AuthGW -->|"Tenant header injected"| GatewayAPI

    %% Ingress → Services
    GatewayAPI -->|"HTTP or HTTPS/8000<br/>Optional TLS 1.2+<br/>X-MaaS-Username"| APIServer

    %% API Server → Data Layer
    APIServer -->|"pgx/5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    APIServer -->|"RESP/6379<br/>Optional TLS<br/>Connection URL"| Redis
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Processor → Data Layer
    Processor -->|"pgx/5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    Processor -->|"RESP/6379<br/>Optional TLS<br/>Connection URL"| Redis
    Processor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Processor → Inference
    Processor -->|"HTTP(S)/configurable<br/>Optional TLS/mTLS<br/>Bearer/mTLS"| InferGlobal
    Processor -->|"HTTP(S)/configurable<br/>Optional TLS/mTLS<br/>Bearer token"| InferModel

    %% GC → Data Layer
    GColl -->|"pgx/5432<br/>Optional TLS<br/>Connection URL"| PostgreSQL
    GColl -->|"RESP/6379<br/>Optional TLS<br/>Connection URL"| Redis
    GColl -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Observability
    APIServer -.->|"HTTP/8081<br/>scrape /metrics"| Prometheus
    Processor -.->|"HTTP/9090<br/>scrape /metrics"| Prometheus
    APIServer -.->|"gRPC OTLP<br/>Optional TLS"| OTel
    Processor -.->|"gRPC OTLP<br/>Optional TLS"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datalayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class AuthGW,GatewayAPI ingress
    class APIServer,Processor,GColl service
    class PostgreSQL,Redis datalayer
    class S3,InferGlobal,InferModel,OTel externalservice
    class Prometheus observability
