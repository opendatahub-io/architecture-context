graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>API key / SA token / OpenShift token"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (AuthN/AuthZ Enforcement)"]
        Authorino["Kuadrant / Authorino<br/>Batch API admission policy<br/>Validates API key, SA token, OCP token"]
        HTTPRoute["Gateway API HTTPRoute<br/>/v1/batches/*, /v1/files/*<br/>Parent: llm-d-inference-gateway"]
        Authorino --> HTTPRoute
    end

    subgraph AppLayer["APPLICATION LAYER (ClusterIP)"]
        direction TB

        Apiserver["batch-gateway-apiserver<br/>Port: 8000/TCP (API) + 8081/TCP (obs)<br/>Optional TLS 1.2+ / mTLS<br/>SA: {release}-batch-gateway-apiserver<br/>Tenant isolation: X-MaaS-Username"]

        Processor["batch-gateway-processor<br/>Port: 9090/TCP (metrics/health)<br/>AIMD concurrency control<br/>SA: {release}-batch-gateway-processor<br/>Graceful shutdown: 30s"]

        GC["batch-gateway-gc<br/>Port: 9091/TCP (metrics/health)<br/>Singleton worker<br/>SA: {release}-batch-gateway-gc<br/>GC interval: 1h"]
    end

    subgraph DataLayer["DATA LAYER"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>pgx wire protocol<br/>Optional TLS<br/>Auth: Connection URL"]

        Redis["Redis / Valkey<br/>6379/TCP<br/>RESP protocol<br/>Optional TLS<br/>Auth: Connection URL"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS<br/>Auth: AWS IAM (access key + secret)"]

        InferenceGW["llm-d Router<br/>Inference Gateway<br/>Configurable port<br/>HTTP/HTTPS<br/>Optional TLS 1.2+ / mTLS<br/>Auth: API key (Bearer) or mTLS"]

        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>Optional TLS<br/>Auth: None"]
    end

    %% External → Gateway
    Client -->|"HTTP/HTTPS 8000/TCP<br/>Optional TLS 1.2+<br/>API key / SA token / OCP token"| Authorino

    %% Gateway → Application
    HTTPRoute -->|"HTTP/HTTPS 8000/TCP<br/>Inherited TLS<br/>Pre-validated + X-MaaS-Username"| Apiserver

    %% Application → Data Layer
    Apiserver -->|"pgx 5432/TCP<br/>Optional TLS<br/>Connection URL creds"| PostgreSQL
    Apiserver -->|"RESP 6379/TCP<br/>Optional TLS<br/>Connection URL creds"| Redis
    Processor -->|"pgx 5432/TCP<br/>Optional TLS<br/>Connection URL creds"| PostgreSQL
    Processor -->|"RESP 6379/TCP<br/>Optional TLS<br/>Connection URL creds"| Redis
    GC -->|"pgx 5432/TCP<br/>Optional TLS<br/>Connection URL creds"| PostgreSQL
    GC -->|"RESP 6379/TCP<br/>Optional TLS<br/>Connection URL creds"| Redis

    %% Application → External Services
    Apiserver -->|"HTTPS 443/TCP<br/>TLS<br/>AWS IAM"| S3
    Processor -->|"HTTPS 443/TCP<br/>TLS<br/>AWS IAM"| S3
    GC -->|"HTTPS 443/TCP<br/>TLS<br/>AWS IAM"| S3
    Processor -->|"HTTP/HTTPS<br/>Optional TLS 1.2+ / mTLS<br/>API key or mTLS certs"| InferenceGW

    %% Observability (optional)
    Apiserver -.->|"gRPC 4317/TCP<br/>Optional TLS"| OTLP
    Processor -.->|"gRPC 4317/TCP<br/>Optional TLS"| OTLP
    GC -.->|"gRPC 4317/TCP<br/>Optional TLS"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datalayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Authorino,HTTPRoute gateway
    class Apiserver,Processor,GC application
    class PostgreSQL,Redis datalayer
    class S3,InferenceGW,OTLP externalservice
