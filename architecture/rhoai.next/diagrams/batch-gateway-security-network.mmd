graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        HTTPRoute["HTTPRoute<br/>Routes: /v1/batches/*, /v1/files/*<br/>TLS: Depends on Gateway"]
    end

    subgraph Application["APPLICATION TIER"]
        direction TB

        subgraph NS_Release["Namespace: {release-namespace}"]
            APIServer["apiserver<br/>SA: batch-gateway-apiserver<br/>API: Configurable/TCP (HTTP/HTTPS)<br/>Obs: 8081/TCP<br/>Multi-tenant isolation"]
            Processor["batch-processor<br/>SA: batch-gateway-processor<br/>Obs: 9090/TCP<br/>AIMD concurrency control"]
            BatchGC["batch-gc<br/>SA: batch-gateway-gc<br/>Metrics: 9091/TCP<br/>Singleton"]
        end
    end

    subgraph DataTier["DATA TIER (Shared State)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>DSN Credentials"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>Optional TLS/mTLS<br/>URL Credentials"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS<br/>AWS IAM / Static Creds"]
        InferenceGW["llm-d Inference Gateway<br/>Configurable/TCP<br/>TLS 1.2+<br/>Bearer Token / mTLS"]
        LLMDAsync["llm-d-async (optional)<br/>6379/TCP Redis<br/>Optional TLS<br/>URL Credentials"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>ServiceMonitor + PodMonitor"]
        OTelCollector["OpenTelemetry Collector<br/>gRPC OTLP"]
    end

    %% External to Ingress
    Client -->|"HTTP(S) / Configurable port<br/>TLS 1.2+ (optional)<br/>Tenant ID: X-MaaS-Username"| HTTPRoute

    %% Ingress to Application
    HTTPRoute -->|"HTTP(S) / Configurable port<br/>TLS 1.2+ (when configured)<br/>Tenant ID header"| APIServer

    %% Application to Data Tier
    APIServer -->|"TCP/5432<br/>Optional TLS<br/>DSN credentials"| PostgreSQL
    APIServer -->|"TCP/6379<br/>Optional TLS/mTLS<br/>URL credentials"| Redis
    Processor -->|"TCP/5432<br/>Optional TLS"| PostgreSQL
    Processor -->|"TCP/6379<br/>Optional TLS/mTLS"| Redis
    BatchGC -->|"TCP/5432<br/>Optional TLS"| PostgreSQL
    BatchGC -->|"TCP/6379<br/>Optional TLS/mTLS"| Redis

    %% Application to External Services
    APIServer -->|"HTTPS/443<br/>TLS<br/>AWS credentials"| S3
    Processor -->|"HTTPS/443<br/>TLS<br/>AWS credentials"| S3
    Processor -->|"HTTP(S) / Configurable<br/>TLS 1.2+<br/>Bearer token / mTLS"| InferenceGW
    Processor -.->|"TCP/6379 Redis<br/>Optional TLS<br/>Async dispatch"| LLMDAsync
    BatchGC -->|"HTTPS/443<br/>TLS<br/>AWS credentials"| S3

    %% Observability
    Prometheus -.->|"HTTP/8081<br/>No auth"| APIServer
    Prometheus -.->|"HTTP/9090<br/>No auth"| Processor
    Prometheus -.->|"HTTP/9091<br/>No auth"| BatchGC
    APIServer -.->|"gRPC OTLP<br/>Configurable"| OTelCollector
    Processor -.->|"gRPC OTLP<br/>Configurable"| OTelCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datatier fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class HTTPRoute ingress
    class APIServer,Processor,BatchGC application
    class PostgreSQL,Redis datatier
    class S3,InferenceGW,LLMDAsync externalservice
    class Prometheus,OTelCollector observability
