graph TB
    subgraph Platform["PIPELINE ORCHESTRATION (Platform Layer)"]
        direction TB
        KFP["KFP API Server<br/>SA: ds-pipeline-{dsp}"]
        Argo["Argo Workflow Controller"]
        KFP -->|creates workflows| Argo
    end

    subgraph InitZone["INIT CONTAINER (Startup Only)"]
        Init["odh-pipelines-components<br/>Image: UBI9/python-311<br/>No network access<br/>Filesystem only"]
    end

    Init -->|"/config/managed-pipelines<br/>(shared volume, no network)"| KFP

    subgraph PipelineSteps["PIPELINE STEP PODS (Ephemeral)"]
        direction TB

        subgraph DataProc["Data Processing"]
            DL["dataset_download<br/>automl_data_loader<br/>text_extraction"]
            SDG["sdg<br/>(Synthetic Data Gen)"]
        end

        subgraph FineTune["Fine-Tuning Control Plane"]
            TrainCtrl["train_model<br/>(LoRA / OSFT / SFT)<br/>SA: pipeline-runner"]
        end

        subgraph AutoRAGSteps["AutoRAG Steps"]
            RAGComps["documents_discovery<br/>documents_indexing<br/>text_extraction<br/>rag_templates_optimization"]
        end

        subgraph DeploySteps["Deployment"]
            RegComp["kubeflow_model_registry"]
        end
    end

    Argo -->|schedules| DataProc
    Argo -->|schedules| FineTune
    Argo -->|schedules| AutoRAGSteps
    Argo -->|schedules| DeploySteps

    subgraph TrainingZone["TRAINING WORKER PODS (GPU)"]
        Workers["Training Workers<br/>Multi-GPU / Multi-Node<br/>Created by Kubeflow Trainer"]
    end

    TrainCtrl -->|"POST TrainingJob CR<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        LlamaStack["Llama Stack API<br/>configurable/TCP<br/>HTTP/HTTPS<br/>API Key"]
        LLMAPI["OpenAI-compatible LLM<br/>configurable/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / API Key"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / RBAC"]
        ModelReg["Model Registry<br/>8080/TCP HTTP<br/>⚠ PLAINTEXT<br/>⚠ NO AUTH"]
    end

    subgraph Storage["SHARED STORAGE"]
        PVC_RWX["PVC (RWX, 50Gi, nfs-csi)<br/>Fine-tuning workspace"]
        PVC_RWO["PVC (RWO, 12Gi)<br/>AutoML workspace"]
    end

    %% Data Processing egress
    DL -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>⚠ SSL fallback"| S3
    DL -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    SDG -->|"HTTPS/configurable<br/>TLS 1.2+<br/>LLM_API_KEY"| LLMAPI

    %% AutoRAG egress
    RAGComps -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>⚠ SSL fallback"| S3
    RAGComps -->|"HTTP(S)/configurable<br/>TLS optional<br/>API Key<br/>⚠ SSL fallback"| LlamaStack
    RAGComps -->|"HTTPS/configurable<br/>TLS 1.2+<br/>Bearer Token"| LLMAPI

    %% Training
    K8sAPI -->|creates| Workers
    Workers -->|"read/write"| PVC_RWX
    TrainCtrl -->|"read/write"| PVC_RWX

    %% Deployment
    RegComp -->|"HTTP/8080<br/>⚠ PLAINTEXT<br/>⚠ NO AUTH"| ModelReg

    %% Storage
    DL -->|write datasets| PVC_RWX
    DL -->|write datasets| PVC_RWO

    %% Styling
    classDef platform fill:#b8e6ff,stroke:#4a90e2,stroke-width:2px
    classDef init fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef pipeline fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef training fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef internal fill:#e8f5e9,stroke:#82b366,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef warning fill:#ffe6cc,stroke:#d79b00,stroke-width:3px

    class KFP,Argo platform
    class Init init
    class DL,SDG,TrainCtrl,RAGComps,RegComp pipeline
    class Workers training
    class S3,HF,LlamaStack,LLMAPI external
    class K8sAPI internal
    class ModelReg warning
    class PVC_RWX,PVC_RWO storage
