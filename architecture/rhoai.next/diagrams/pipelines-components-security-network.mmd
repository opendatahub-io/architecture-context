graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        S3["S3 Storage (MinIO/AWS)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS Signature V4"]
        OGX["OGX API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        RHAIPyPI["RHEL AI PyPI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        LiteLLM["LLM Endpoint (LiteLLM)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
    end

    subgraph Cluster["OPENSHIFT CLUSTER"]
        direction TB

        subgraph InitPhase["INIT CONTAINER (No Network)"]
            InitContainer["odh-pipelines-components<br/>Image: UBI9 Python 3.12<br/>No ports exposed"]
            SharedVol["Shared Volume<br/>/config/managed-pipelines/<br/>emptyDir mount"]
        end

        subgraph TaskPods["KFP TASK PODS (Ephemeral)"]
            AutoMLPod["AutoML Task Pod<br/>Image: odh-automl<br/>Base: AIPCC CPU<br/>SA: KFP execution SA"]
            AutoRAGPod["AutoRAG Task Pod<br/>Image: odh-autorag<br/>Base: AIPCC CPU<br/>SA: KFP execution SA"]
            TrainingPod["Training Task Pod<br/>SA: KFP execution SA"]
            DeployPod["Deployment Task Pod<br/>SA: KFP execution SA"]
            EvalPod["Evaluation Task Pod<br/>SA: KFP execution SA"]
        end

        subgraph InternalSvc["CLUSTER-INTERNAL SERVICES"]
            KFPAPI["KFP API Server<br/>(managed by DSPO)"]
            K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
            Milvus["Milvus<br/>19530/TCP gRPC<br/>Plaintext<br/>Token (optional)"]
            ModelReg["Model Registry<br/>80/TCP HTTP<br/>Plaintext<br/>No Auth"]
            EvalHub["Eval Hub<br/>443/TCP HTTPS<br/>TLS (verify=False default)<br/>Bearer Token"]
            KServe["KServe<br/>(via K8s API CRDs)"]
            RayOp["Ray Operator<br/>(via K8s API CRDs)"]
        end
    end

    %% Init container flow (filesystem only)
    InitContainer -->|"Filesystem<br/>No encryption"| SharedVol
    SharedVol -->|"Filesystem<br/>emptyDir"| KFPAPI

    %% AutoML egress
    AutoMLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>⚠ verify=False fallback"| S3

    %% AutoRAG egress
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>⚠ verify=False fallback"| S3
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key<br/>⚠ verify=False fallback"| OGX
    AutoRAGPod -->|"gRPC/19530<br/>Plaintext<br/>Token (optional)"| Milvus

    %% Training egress
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Deployment egress
    DeployPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    DeployPod -->|"HTTP/80<br/>Plaintext<br/>⚠ No Auth"| ModelReg

    %% Evaluation egress
    EvalPod -->|"HTTPS/443<br/>TLS (verify=False)<br/>Bearer Token"| EvalHub
    EvalPod -->|"HTTP/80<br/>Plaintext<br/>⚠ No Auth"| ModelReg

    %% K8s API to operators
    K8sAPI -.->|"CRD CRUD"| KServe
    K8sAPI -.->|"CRD CRUD"| RayOp

    %% SDG egress
    TrainingPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LiteLLM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef initphase fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef taskpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class HFHub,S3,OGX,RHAIPyPI,LiteLLM external
    class InitContainer,SharedVol initphase
    class AutoMLPod,AutoRAGPod,TrainingPod,DeployPod,EvalPod taskpod
    class KFPAPI,K8sAPI,KServe,RayOp internalsvc
    class Milvus,ModelReg warning
    class EvalHub internalsvc
