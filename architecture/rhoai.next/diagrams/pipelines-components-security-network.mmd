graph TB
    subgraph Cluster["KUBERNETES CLUSTER (Trusted)"]
        direction TB

        subgraph KFPContext["KFP Pipeline Execution Context"]
            direction TB

            InitContainer["Init Container<br/>pipelines-components<br/>SA: DSPA pipeline runner<br/>No network ports"]
            SharedVol["Shared Volume<br/>/config/managed-pipelines/"]
            KFPServer["KFP API Server<br/>Discovers pipeline YAMLs"]

            InitContainer -->|"Filesystem<br/>Volume mount<br/>No network"| SharedVol
            SharedVol -->|"Filesystem<br/>Volume mount"| KFPServer
        end

        subgraph TaskPods["KFP Task Pods (Ephemeral Batch Jobs)"]
            direction TB

            AutoMLPod["AutoML Task Pod<br/>Image: odh-automl<br/>PVC: 12Gi RWO"]
            AutoRAGPod["AutoRAG Task Pod<br/>Image: odh-autorag<br/>PVC: 50Gi RWX"]
            FineTunePod["Fine-Tuning Task Pod<br/>GPU-accelerated<br/>PVC: 50Gi RWX nfs-csi"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP"]
        DSPA["DSPA<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
    end

    subgraph Internal["INTERNAL PLATFORM SERVICES"]
        ModelRegistry["Kubeflow Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (SA)"]
    end

    subgraph External["EXTERNAL SERVICES"]
        S3["S3-Compatible Storage<br/>(MinIO/Ceph/AWS)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]

        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]

        LlamaStack["Llama Stack API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]

        LLMAPI["LLM API<br/>(OpenAI-compatible)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]

        OCIRegistry["OCI Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Credentials"]

        PyPIMirror["Red Hat PyPI Mirror<br/>console.redhat.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
    end

    %% Egress flows from task pods
    AutoMLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HFHub
    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| ModelRegistry

    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LlamaStack
    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LLMAPI

    FineTunePod -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Creds"| OCIRegistry

    %% K8s API access
    TaskPods -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% DSPA integration
    KFPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| DSPA

    %% Styling
    classDef cluster fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    classDef kfpcontext fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef taskpods fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#f5f5f5,stroke:#999,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6

    class InitContainer,SharedVol,KFPServer kfpcontext
    class AutoMLPod,AutoRAGPod,FineTunePod taskpods
    class ModelRegistry internal
    class S3,HFHub,LlamaStack,LLMAPI,OCIRegistry,PyPIMirror external
    class K8sAPI,DSPA k8s
