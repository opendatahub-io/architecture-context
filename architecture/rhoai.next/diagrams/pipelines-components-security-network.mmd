graph TB
    subgraph InitContainer["INIT CONTAINER (Platform Startup - No Network)"]
        direction TB
        InitPod["odh-pipelines-components<br/>Image: ubi9/python-311<br/>Port: N/A (filesystem only)"]
        SharedVol["Shared Volume<br/>/config/managed-pipelines"]
        InitPod -->|"Filesystem<br/>No network"| SharedVol
    end

    subgraph PipelineRuntime["PIPELINE RUNTIME (Ephemeral Argo Workflow Pods)"]
        direction TB

        subgraph PipelinePods["Namespace: {user-namespace}<br/>SA: pipeline-runner"]
            GeneralPod["General Components<br/>Image: python:3.11"]
            AutoMLPod["AutoML Components<br/>Image: odh-automl<br/>(AutoGluon, pandas)"]
            AutoRAGPod["AutoRAG Components<br/>Image: odh-autorag<br/>(ai4rag, Docling)"]
        end

        subgraph LocalProcessing["LOCAL (No Network)"]
            vLLM["vLLM GPU Inference"]
            LMEval["lm-eval Benchmarks"]
            Docling["Docling Text Extraction"]
            ChromaDB["ChromaDB In-Memory"]
        end

        subgraph Storage["PERSISTENT STORAGE"]
            PVC_RWX["PVC ReadWriteMany<br/>50Gi nfs-csi<br/>(Fine-tuning)"]
            PVC_RWO["PVC ReadWriteOnce<br/>12Gi<br/>(AutoML)"]
        end
    end

    subgraph K8sInternal["KUBERNETES INTERNAL"]
        KFPAPI["KFP API Server"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        ModelReg["Kubeflow Model Registry<br/>8080/TCP HTTP<br/>⚠ plaintext, no auth"]
        TrainerPods["Training Worker Pods<br/>(GPU, multi-node)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM<br/>⚠ verify=False fallback"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        LlamaStack["Llama Stack API<br/>configurable/TCP<br/>HTTP/HTTPS<br/>API Key<br/>⚠ verify=False fallback"]
        LLMAPI["LLM API Endpoint<br/>configurable/TCP<br/>HTTPS TLS 1.2+<br/>API Key"]
        OpenAICompat["OpenAI-compat Endpoints<br/>configurable/TCP<br/>HTTPS TLS<br/>Bearer Token<br/>⚠ verify=False fallback"]
    end

    %% Init container flow
    SharedVol -->|"Filesystem"| KFPAPI

    %% Pipeline pod egress
    GeneralPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    GeneralPod -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub
    GeneralPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    GeneralPod -->|"HTTP/8080<br/>plaintext<br/>no auth"| ModelReg
    GeneralPod -->|"HTTPS<br/>TLS 1.2+<br/>LLM_API_KEY"| LLMAPI

    AutoMLPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    AutoRAGPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AutoRAGPod -->|"HTTP/HTTPS<br/>API Key"| LlamaStack
    AutoRAGPod -->|"HTTPS<br/>Bearer Token"| OpenAICompat

    K8sAPI -->|"Schedule"| TrainerPods

    %% Styling
    classDef init fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef pipeline fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sinternal fill:#7ed321,stroke:#333,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef storage fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class InitPod,SharedVol init
    class GeneralPod,AutoMLPod,AutoRAGPod pipeline
    class KFPAPI,K8sAPI,TrainerPods k8sinternal
    class ModelReg warning
    class S3,HFHub,LlamaStack,LLMAPI,OpenAICompat external
    class PVC_RWX,PVC_RWO storage
    class vLLM,LMEval,Docling,ChromaDB pipeline
