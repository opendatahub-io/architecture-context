graph TB
    subgraph External["External Clients"]
        Client[Client / KServe Router]
        Prometheus[Prometheus]
    end

    subgraph KServeInfra["KServe Infrastructure"]
        Controller[KServe Controller<br/>manages InferenceService]
    end

    subgraph AutoGluonServer["AutoGluon Server Pod"]
        direction TB

        subgraph ServingLayer["Serving Layer (KServe Python SDK)"]
            FastAPI[FastAPI REST Server<br/>Port 8080/TCP]
            GRPC[gRPC Server<br/>Port 8081/TCP]
            ModelRepo[Model Repository<br/>Manager]
            Metrics[Prometheus Metrics<br/>/metrics]
        end

        subgraph ProtocolLayer["Protocol Handlers"]
            V1[v1 Protocol Handler<br/>/v1/models/...]
            V2[v2 Open Inference Protocol<br/>/v2/models/...]
        end

        subgraph ModelLayer["AutoGluon Model Layer"]
            DetectedModel[AutoGluonDetectedModel<br/>predictor_detect.py]
            Factory[PredictorFactory<br/>predictor_factory.py]
            TabularModel[TabularModel<br/>tabular_model.py]
            TSModel[TimeSeriesModel<br/>timeseries_model.py]
        end

        subgraph MLBackends["ML Backends"]
            AutoGluonTab[autogluon.tabular<br/>1.5.0+rhaiv.2]
            AutoGluonTS[autogluon.timeseries<br/>1.5.0+rhaiv.2]
            LightGBM[LightGBM 4.6.0]
            XGBoost[XGBoost 3.1.3]
            PyTorch[PyTorch 2.10.0]
        end

        subgraph Storage["Model Storage Client"]
            KServeStorage[kserve-storage<br/>Storage.download]
        end
    end

    subgraph ExternalStorage["External Model Storage"]
        S3[S3-compatible Storage<br/>443/TCP HTTPS]
        HF[HuggingFace Hub<br/>443/TCP HTTPS]
        GCS[GCS / Azure Blob<br/>443/TCP HTTPS]
    end

    %% Control plane
    Controller -->|creates pod| AutoGluonServer

    %% Client flows
    Client -->|HTTP 8080/TCP| FastAPI
    Client -->|gRPC 8081/TCP| GRPC
    Prometheus -->|GET /metrics<br/>8080/TCP| Metrics

    %% Internal routing
    FastAPI --> V1
    FastAPI --> V2
    GRPC --> V2
    V1 --> DetectedModel
    V2 --> DetectedModel
    DetectedModel --> Factory
    Factory -->|auto-detect| TabularModel
    Factory -->|auto-detect| TSModel
    TabularModel --> AutoGluonTab
    TSModel --> AutoGluonTS
    AutoGluonTab --> LightGBM
    AutoGluonTab --> XGBoost
    AutoGluonTab --> PyTorch
    AutoGluonTS --> PyTorch

    %% Model loading
    ModelRepo --> KServeStorage
    KServeStorage --> S3
    KServeStorage --> HF
    KServeStorage --> GCS

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style FastAPI fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style DetectedModel fill:#7ed321,stroke:#333
    style TabularModel fill:#7ed321,stroke:#333
    style TSModel fill:#7ed321,stroke:#333
    style Factory fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HF fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style AutoGluonTab fill:#9b59b6,stroke:#333,color:#fff
    style AutoGluonTS fill:#9b59b6,stroke:#333,color:#fff
