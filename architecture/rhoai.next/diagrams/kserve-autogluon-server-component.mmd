graph TB
    subgraph AutoGluonServer["AutoGluon Model Server (Pod)"]
        direction TB

        subgraph SidecarContainer["kube-rbac-proxy Sidecar"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS Termination + Auth"]
        end

        subgraph MainContainer["autogluonserver Container (UID 1001)"]
            direction TB
            MainModule["__main__.py<br/>Entry Point"]
            PredictorFactory["predictor_factory.py<br/>Model Type Detection"]
            ModelRepo["autogluon_model_repository.py<br/>Model Repository"]
            VersionCompat["version_compat.py<br/>Patch-Level Version Tolerance"]
            RuntimePaths["runtime_paths.py<br/>Writable CWD Setup"]

            subgraph Models["Model Implementations"]
                TabularModel["tabular_model.py<br/>AutoGluonTabularModel<br/>v1 + v2 Protocol"]
                TSModel["timeseries_model.py<br/>AutoGluonTimeSeriesModel<br/>v1 Protocol Only"]
            end

            subgraph KServeSDK["kserve SDK (vendored 0.19.0)"]
                ModelServer["ModelServer<br/>HTTP + gRPC Serving"]
                HTTPServer["FastAPI/uvicorn<br/>8080/TCP HTTP"]
                GRPCServer["gRPC Server<br/>8081/TCP gRPC"]
                StorageLib["kserve-storage<br/>S3/GCS/Azure/HF Download"]
            end

            MainModule -->|initializes| RuntimePaths
            MainModule -->|creates| PredictorFactory
            PredictorFactory -->|auto-detects| TabularModel
            PredictorFactory -->|auto-detects| TSModel
            PredictorFactory -->|uses| VersionCompat
            PredictorFactory -->|registers with| ModelRepo
            ModelRepo -->|served by| ModelServer
            ModelServer -->|HTTP endpoints| HTTPServer
            ModelServer -->|gRPC endpoints| GRPCServer
            ModelServer -->|model download| StorageLib
        end

        KRBP -->|proxy 8080/TCP| HTTPServer
    end

    Client["External Client"] -->|HTTPS 8443/TCP<br/>Bearer Token| KRBP

    subgraph CloudStorage["Cloud Storage"]
        S3["S3-compatible<br/>443/TCP HTTPS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    end

    StorageLib -->|model download| S3
    StorageLib -->|model download| GCS
    StorageLib -->|model download| Azure
    StorageLib -->|model download| HFHub

    KServeCtrl["KServe Controller"] -->|manages lifecycle via<br/>InferenceService CR| AutoGluonServer
    CSR["ClusterServingRuntime"] -.->|defines image + ports<br/>for modelFormat: autogluon| AutoGluonServer
    Prometheus["Prometheus"] -->|scrapes /metrics<br/>8080/TCP HTTP| HTTPServer

    style KRBP fill:#e8a838,stroke:#333,stroke-width:2px
    style TabularModel fill:#4a90e2,stroke:#333,stroke-width:2px
    style TSModel fill:#4a90e2,stroke:#333,stroke-width:2px
    style ModelServer fill:#6c5ce7,stroke:#333,stroke-width:2px
    style HTTPServer fill:#6c5ce7,stroke:#333,stroke-width:1px
    style GRPCServer fill:#6c5ce7,stroke:#333,stroke-width:1px
    style StorageLib fill:#6c5ce7,stroke:#333,stroke-width:1px
    style KServeCtrl fill:#7ed321,stroke:#333,stroke-width:2px
    style CSR fill:#7ed321,stroke:#333,stroke-width:1px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:1px
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
