graph TB
    subgraph AutoGluonServer["AutoGluon Server Pod"]
        direction TB
        MainPy["__main__.py<br/>Entry Point"]
        Factory["predictor_factory.py<br/>Model Factory"]
        Detect["predictor_detect.py<br/>Auto-Detection"]
        DetectedModel["AutoGluonDetectedModel<br/>Facade Pattern"]
        VersionCompat["version_compat.py<br/>Version Compatibility"]
        RuntimePaths["runtime_paths.py<br/>Container Path Setup"]

        subgraph Models["Model Implementations"]
            TabularModel["tabular_model.py<br/>TabularPredictor<br/>v1 + v2 REST, gRPC"]
            TSModel["timeseries_model.py<br/>TimeSeriesPredictor<br/>v1 REST only"]
        end

        subgraph KServeSDK["KServe Python SDK (kserve 0.19.0)"]
            ModelServer["Model Server Framework"]
            V1Protocol["v1 REST Protocol"]
            V2Protocol["v2 REST Protocol"]
            GRPCProtocol["gRPC Protocol"]
            HealthProbes["Health Probes<br/>/v2/health/live, /v2/health/ready"]
            Metrics["Prometheus Metrics"]
        end

        subgraph StorageLib["KServe Storage (kserve-storage 0.19.0)"]
            StorageDownload["Storage.download()"]
        end

        MainPy --> Factory
        Factory --> Detect
        Detect --> VersionCompat
        Detect -->|"Try TS first"| TSModel
        Detect -->|"Fallback to Tabular"| TabularModel
        Factory --> DetectedModel
        DetectedModel -->|delegates| TabularModel
        DetectedModel -->|delegates| TSModel
        MainPy --> RuntimePaths
        MainPy --> ModelServer
    end

    Client["External Client"] -->|"HTTPS/443<br/>TLS 1.3"| Ingress["Platform Ingress<br/>(Gateway API / Istio)"]
    Ingress -->|"HTTP/8080"| ModelServer
    Ingress -->|"gRPC/8081"| GRPCProtocol

    KServeCtrl["KServe Controller"] -->|"manages pod lifecycle"| AutoGluonServer
    CSR["ClusterServingRuntime"] -.->|"defines runtime config"| KServeCtrl

    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+"| S3["S3 Storage"]
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+"| GCS["GCS"]
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+"| Azure["Azure Blob"]
    StorageDownload -->|"HTTPS/443<br/>TLS 1.2+"| HFHub["HuggingFace Hub"]

    Prometheus["Prometheus"] -->|"scrape HTTP/8080"| Metrics

    style AutoGluonServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style TabularModel fill:#4a90e2,color:#fff
    style TSModel fill:#4a90e2,color:#fff
    style DetectedModel fill:#4a90e2,color:#fff
    style KServeSDK fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style StorageLib fill:#fff3e0,stroke:#ef6c00,stroke-width:1px
    style Models fill:#e3f2fd,stroke:#1565c0,stroke-width:1px
    style Ingress fill:#ffe0b2,stroke:#e65100
    style KServeCtrl fill:#7ed321,stroke:#333
    style CSR fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#333
