graph TB
    subgraph External["External Clients"]
        Client[Client / KServe Router]
        PromScraper[Prometheus]
    end

    subgraph KServeController["KServe Controller"]
        Controller[KServe Controller<br/>manages InferenceService]
    end

    subgraph AutoGluonServer["kserve-autogluon-server Pod"]
        direction TB

        subgraph ServingLayer["KServe Python SDK"]
            FastAPIServer["FastAPI REST Server<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server<br/>Port 8081/TCP"]
            ModelRepo["Model Repository<br/>kserve.ModelRepository"]
            MetricsEndpoint["Prometheus Metrics<br/>/metrics"]
            V1Endpoints["v1 Protocol Handler<br/>/v1/models/..."]
            V2Endpoints["v2 Protocol Handler<br/>/v2/models/..."]
        end

        subgraph ModelLayer["AutoGluon Model Layer"]
            PredictorFactory["predictor_factory.py<br/>Auto-detect model type"]
            TabularModel["TabularPredictor<br/>Classification / Regression"]
            TimeSeriesModel["TimeSeriesPredictor<br/>Forecasting"]
            RuntimePaths["runtime_paths.py<br/>Writable CWD workaround"]
        end

        subgraph StorageLayer["Storage Layer"]
            KServeStorage["kserve-storage<br/>Storage.download()"]
        end
    end

    subgraph ModelStorage["Model Storage"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS"]
        GCS["GCS / Azure Blob<br/>443/TCP HTTPS"]
        PVC["PersistentVolumeClaim"]
    end

    %% Control plane flows
    Controller -->|"creates pod with<br/>serving runtime image"| AutoGluonServer

    %% Client request flows
    Client -->|"POST /v1/models/{name}:predict<br/>HTTP 8080/TCP"| FastAPIServer
    Client -->|"gRPC InferRequest<br/>8081/TCP"| GRPCServer

    %% Internal serving flows
    FastAPIServer --> V1Endpoints
    FastAPIServer --> V2Endpoints
    FastAPIServer --> MetricsEndpoint
    V1Endpoints --> ModelRepo
    V2Endpoints --> ModelRepo
    GRPCServer --> ModelRepo
    ModelRepo --> PredictorFactory

    %% Model detection
    PredictorFactory -->|"TimeSeriesPredictor<br/>(tried first)"| TimeSeriesModel
    PredictorFactory -->|"TabularPredictor<br/>(fallback)"| TabularModel
    RuntimePaths -.->|"sets writable CWD"| PredictorFactory

    %% Storage flows
    KServeStorage -->|"HTTPS/443<br/>AWS IAM / Bearer"| S3
    KServeStorage -->|"HTTPS/443<br/>Bearer Token"| HuggingFace
    KServeStorage -->|"HTTPS/443<br/>SA / SAS"| GCS
    KServeStorage -->|"local mount"| PVC
    KServeStorage -->|"model artifacts"| PredictorFactory

    %% Metrics scraping
    PromScraper -->|"GET /metrics<br/>HTTP 8080/TCP"| MetricsEndpoint

    %% Styling
    style AutoGluonServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style ServingLayer fill:#e8eaf6,stroke:#3949ab,stroke-width:1px
    style ModelLayer fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px
    style StorageLayer fill:#fff3e0,stroke:#e65100,stroke-width:1px
    style Controller fill:#4a90e2,color:#fff
    style Client fill:#f5f5f5,stroke:#999
    style PromScraper fill:#f5f5f5,stroke:#999
    style FastAPIServer fill:#4a90e2,color:#fff
    style GRPCServer fill:#4a90e2,color:#fff
    style PredictorFactory fill:#7ed321
    style TabularModel fill:#7ed321
    style TimeSeriesModel fill:#7ed321
    style S3 fill:#f5a623
    style HuggingFace fill:#f5a623
    style GCS fill:#f5a623
    style PVC fill:#f5a623
