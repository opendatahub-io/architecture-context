graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph KServeGateway["KServe Networking Layer"]
        Gateway["KServe Gateway<br/>(Istio Gateway)"]
    end

    subgraph AutoGluonServer["AutoGluon Server (Pod)"]
        direction TB
        subgraph HTTPServer["FastAPI HTTP Server (8080/TCP)"]
            V1Endpoints["V1 REST Endpoints<br/>/v1/models/{name}:predict"]
            V2Endpoints["V2 OIP Endpoints<br/>/v2/models/{name}/infer"]
            HealthEndpoints["Health Endpoints<br/>/v2/health/live | /ready"]
        end

        subgraph GRPCServer["gRPC Server (8081/TCP)"]
            GRPCInfer["V2 gRPC Inference"]
        end

        subgraph ModelRuntime["Model Runtime"]
            PredictorFactory["Predictor Factory<br/>(auto-detect model type)"]
            TabularModel["TabularPredictor<br/>(classification, regression,<br/>quantile, predict_proba)"]
            TimeSeriesModel["TimeSeriesPredictor<br/>(forecasting)"]
            ModelRepo["AutoGluon Model Repository<br/>(multi-model support)"]
        end

        subgraph KServeSDK["KServe SDK"]
            ModelServer["ModelServer<br/>(lifecycle management)"]
            StorageLib["kserve-storage<br/>(S3/GCS/PVC/URI download)"]
        end
    end

    subgraph StorageInit["Init Container"]
        StorageInitializer["Storage Initializer<br/>(downloads model artifacts)"]
    end

    subgraph PlatformServices["Platform Services"]
        KServeController["KServe Controller"]
        IstioSidecar["Istio Sidecar (Envoy)<br/>mTLS enforcement"]
        KnativeServing["Knative Serving<br/>autoscaling"]
        Prometheus["Prometheus<br/>metrics scrape"]
    end

    subgraph ExternalStorage["External Storage"]
        S3["S3 Storage"]
        GCS["GCS Storage"]
        HFHub["HuggingFace Hub"]
    end

    %% External flows
    Client -->|HTTPS/443| Gateway
    Gateway -->|HTTP/8080| V1Endpoints
    Gateway -->|HTTP/8080| V2Endpoints
    Gateway -->|gRPC/8081| GRPCInfer

    %% Internal flows
    V1Endpoints --> PredictorFactory
    V2Endpoints --> PredictorFactory
    GRPCInfer --> PredictorFactory
    PredictorFactory -->|tabular model| TabularModel
    PredictorFactory -->|time series model| TimeSeriesModel
    ModelServer --> ModelRepo
    ModelRepo --> PredictorFactory
    StorageLib -->|downloads| S3
    StorageLib -->|downloads| GCS

    %% Platform interactions
    KServeController -->|deploys pod| AutoGluonServer
    StorageInitializer -->|writes to /mnt/models| ModelRuntime
    IstioSidecar ---|mTLS proxy| AutoGluonServer
    KnativeServing -->|autoscales| AutoGluonServer
    Prometheus -->|scrapes :8080| HTTPServer

    %% Health checks
    HealthEndpoints -.->|liveness/readiness| ModelServer

    %% Styling
    style AutoGluonServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style HTTPServer fill:#5ba3f5,stroke:#333,color:#fff
    style GRPCServer fill:#5ba3f5,stroke:#333,color:#fff
    style ModelRuntime fill:#5ba3f5,stroke:#333,color:#fff
    style KServeSDK fill:#5ba3f5,stroke:#333,color:#fff
    style TabularModel fill:#7ed321,stroke:#333,color:#fff
    style TimeSeriesModel fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style KServeController fill:#f5a623,stroke:#333,color:#fff
    style IstioSidecar fill:#e8e8e8,stroke:#333
    style KnativeServing fill:#e8e8e8,stroke:#333
    style StorageInitializer fill:#f5a623,stroke:#333,color:#fff
