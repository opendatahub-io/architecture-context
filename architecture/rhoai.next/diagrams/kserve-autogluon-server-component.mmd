graph TB
    subgraph External["External Clients"]
        Client[Client / KServe Router]
        PromClient[Prometheus]
    end

    subgraph KServeInfra["KServe Infrastructure"]
        Controller[KServe Controller<br/>Manages InferenceService CR]
    end

    subgraph AutoGluonServer["AutoGluon Server Pod"]
        direction TB

        subgraph RESTLayer["REST Layer (FastAPI) — 8080/TCP"]
            V1Endpoints["v1 Endpoints<br/>/v1/models/{name}:predict<br/>/v1/models/{name}:explain"]
            V2Endpoints["v2 Endpoints (OIP)<br/>/v2/models/{name}/infer<br/>/v2/health/live<br/>/v2/health/ready"]
            Metrics["/metrics<br/>Prometheus Histograms"]
        end

        subgraph GRPCLayer["gRPC Layer — 8081/TCP"]
            GRPCInfer["gRPC Inference Service<br/>Open Inference Protocol"]
        end

        subgraph ModelLayer["Model Layer"]
            DetectedModel["AutoGluonDetectedModel<br/>predictor_detect.py"]
            Factory["PredictorFactory<br/>predictor_factory.py"]
            TabularModel["TabularModel<br/>tabular_model.py<br/>TabularPredictor"]
            TimeSeriesModel["TimeSeriesModel<br/>timeseries_model.py<br/>TimeSeriesPredictor"]
        end

        subgraph SDKLayer["KServe Python SDK"]
            ModelServer["ModelServer<br/>model_server.py"]
            ModelRepo["ModelRepository<br/>autogluon_model_repository.py"]
            StorageLib["kserve-storage<br/>Storage.download()"]
        end

        V1Endpoints --> DetectedModel
        V2Endpoints --> DetectedModel
        GRPCInfer --> DetectedModel
        DetectedModel --> Factory
        Factory -->|auto-detect| TabularModel
        Factory -->|auto-detect| TimeSeriesModel
        ModelServer --> V1Endpoints
        ModelServer --> V2Endpoints
        ModelServer --> GRPCInfer
        ModelServer --> ModelRepo
        ModelRepo --> StorageLib
    end

    subgraph Storage["Model Storage"]
        S3["S3-compatible<br/>443/TCP HTTPS"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS"]
        PVC["PVC / Local"]
    end

    Controller -->|creates pod| AutoGluonServer
    Client -->|HTTP 8080/TCP| V1Endpoints
    Client -->|HTTP 8080/TCP| V2Endpoints
    Client -->|gRPC 8081/TCP| GRPCInfer
    PromClient -->|GET /metrics<br/>8080/TCP| Metrics
    StorageLib -->|HTTPS 443/TCP<br/>AWS IAM| S3
    StorageLib -->|HTTPS 443/TCP<br/>Bearer Token| HuggingFace
    StorageLib -->|local read| PVC

    style Controller fill:#4a90e2,stroke:#333
    style V1Endpoints fill:#5ba8f7,stroke:#333
    style V2Endpoints fill:#5ba8f7,stroke:#333
    style GRPCInfer fill:#5ba8f7,stroke:#333
    style Metrics fill:#5ba8f7,stroke:#333
    style DetectedModel fill:#7ed321,stroke:#333
    style TabularModel fill:#7ed321,stroke:#333
    style TimeSeriesModel fill:#7ed321,stroke:#333
    style Factory fill:#7ed321,stroke:#333
    style ModelServer fill:#a0d8ef,stroke:#333
    style ModelRepo fill:#a0d8ef,stroke:#333
    style StorageLib fill:#a0d8ef,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style PVC fill:#f5a623,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
