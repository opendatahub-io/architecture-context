graph TB
    subgraph "KServe AutoGluon Server"
        direction TB
        Main["__main__.py<br/>Entry Point"]
        Factory["PredictorFactory<br/>Model Type Detection"]
        Detect["predictor_detect.py<br/>Try-Load Detection"]
        TabModel["AutoGluonTabularModel<br/>v1 + v2 inference"]
        TSModel["AutoGluonTimeSeriesModel<br/>v1 inference only"]
        RuntimePaths["runtime_paths.py<br/>CWD Hardening"]

        Main -->|initializes| Factory
        Factory -->|delegates to| Detect
        Detect -->|TimeSeriesPredictor?| TSModel
        Detect -->|TabularPredictor?| TabModel
        Main -->|ensures writable cwd| RuntimePaths
    end

    subgraph "Vendored KServe SDK"
        ModelServer["KServe ModelServer<br/>HTTP/gRPC Framework"]
        InferProto["Inference Protocol<br/>v1 JSON + v2 Tensor"]
        ModelRepo["Model Repository"]
    end

    subgraph "Vendored kserve-storage"
        StorageLib["Storage Library<br/>S3, GCS, Azure, HF Hub"]
    end

    Main -->|starts| ModelServer
    TabModel -->|implements| InferProto
    TSModel -->|implements| InferProto
    Main -->|registers models| ModelRepo
    Main -->|downloads model via| StorageLib

    %% External interactions
    Client[External Client] -->|POST /v1/models/:predict<br/>POST /v2/models/:infer| ModelServer
    Prometheus[Prometheus] -->|GET /metrics| ModelServer

    subgraph "Sidecar (Platform-injected)"
        RBAC["kube-rbac-proxy<br/>8443/TCP HTTPS"]
    end

    Client -->|443/TCP HTTPS| Ingress["Platform Ingress<br/>Gateway / Route"]
    Ingress -->|8443/TCP HTTPS| RBAC
    RBAC -->|8080/TCP HTTP<br/>localhost| ModelServer

    StorageLib -->|443/TCP HTTPS| S3["S3 / GCS / Azure / HF Hub"]

    KServeCtrl["KServe Controller"] -->|creates pods with<br/>this image| Main
    CSR["ClusterServingRuntime CR<br/>serving.kserve.io/v1alpha1"] -.->|defines container spec| KServeCtrl

    %% Styling
    style Main fill:#4a90e2,color:#fff
    style Factory fill:#4a90e2,color:#fff
    style Detect fill:#4a90e2,color:#fff
    style TabModel fill:#4a90e2,color:#fff
    style TSModel fill:#4a90e2,color:#fff
    style RuntimePaths fill:#4a90e2,color:#fff
    style ModelServer fill:#7ed321,color:#fff
    style InferProto fill:#7ed321,color:#fff
    style ModelRepo fill:#7ed321,color:#fff
    style StorageLib fill:#7ed321,color:#fff
    style RBAC fill:#f5a623,color:#fff
    style Ingress fill:#f5a623,color:#fff
    style S3 fill:#e8e8e8
    style KServeCtrl fill:#e8e8e8
    style CSR fill:#e8e8e8
    style Client fill:#f9f9f9
    style Prometheus fill:#f9f9f9
