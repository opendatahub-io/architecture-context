graph LR
    BatchGW["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% External Dependencies (Required)
    BatchGW -->|"metadata CRUD<br/>TCP/5432"| PostgreSQL["PostgreSQL 12+"]
    BatchGW -->|"queue, events, status<br/>TCP/6379"| Redis["Redis 6+ /<br/>Valkey 8+"]
    BatchGW -->|"file storage<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    BatchGW -->|"inference dispatch<br/>HTTP(S), Bearer/mTLS"| InferenceGW["Inference Gateway<br/>(llm-d / vLLM)"]

    %% External Dependencies (Optional)
    BatchGW -.->|"TLS cert provisioning<br/>Certificate CRD"| CertManager["cert-manager v1"]

    %% Internal Platform Dependencies
    BatchGW -->|"ingress routing<br/>HTTPRoute CRD"| GatewayAPI["Gateway API<br/>(gateway.networking.k8s.io)"]
    BatchGW -->|"authN/authZ<br/>Envoy ext_authz"| Kuadrant["Kuadrant /<br/>Authorino"]

    %% Observability Dependencies
    BatchGW -.->|"metrics scraping<br/>ServiceMonitor + PodMonitor"| Prometheus["Prometheus<br/>Operator"]
    BatchGW -.->|"dashboard JSON<br/>ConfigMap sidecar"| Grafana["Grafana"]
    BatchGW -.->|"distributed tracing<br/>gRPC/4317"| OTLP["OTLP Collector"]

    %% Integration Points (Inbound)
    InferenceObj["GIE InferenceObjective"] -.->|"batch priority<br/>x-gateway-inference-objective"| BatchGW

    %% Downstream from Batch Gateway
    InferenceGW -->|"model serving"| LLMModels["LLM Models<br/>(vLLM pods)"]

    %% Styling
    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style InferenceGW fill:#7ed321,stroke:#333
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333
    style Kuadrant fill:#7ed321,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Grafana fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style InferenceObj fill:#fff2cc,stroke:#d6b656
    style LLMModels fill:#e1d5e7,stroke:#9673a6
