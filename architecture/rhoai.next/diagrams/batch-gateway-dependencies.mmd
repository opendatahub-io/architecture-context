graph LR
    BG["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% Required External Dependencies
    BG -->|"metadata CRUD<br/>pgx v5<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>(Required)"]
    BG -->|"priority queue<br/>events, status<br/>go-redis v9<br/>6379/TCP"| Redis["Redis / Valkey<br/>(Required)"]

    %% Optional External Dependencies
    BG -->|"file storage<br/>AWS SDK v2<br/>443/TCP"| S3["S3-Compatible Storage<br/>(MinIO / AWS S3)<br/>(Optional - alt to FS)"]
    BG -.->|"TLS certs<br/>Certificate CRD"| CertManager["cert-manager v1<br/>(Optional)"]
    BG -.->|"distributed tracing<br/>OTLP/gRPC<br/>4317/TCP"| OTel["OpenTelemetry<br/>Collector<br/>(Optional)"]

    %% Internal Platform Dependencies
    BG -->|"inference requests<br/>HTTP/HTTPS<br/>Bearer token"| InferenceGW["LLM Inference Gateway<br/>(llm-d / vLLM)<br/>(Internal Platform)"]
    BG -.->|"external ingress<br/>HTTPRoute CRD"| GatewayAPI["Gateway API<br/>(Optional)"]

    %% Observability Integration
    Prometheus["Prometheus<br/>(Optional)"] -->|"scrape metrics<br/>ServiceMonitor<br/>PodMonitor<br/>8081/TCP"| BG
    Grafana["Grafana<br/>(Optional)"] -.->|"pre-built dashboards<br/>ConfigMap"| BG

    %% File system alternative
    BG -.->|"file storage<br/>local I/O"| PVC["Filesystem (PVC)<br/>(Optional - alt to S3)"]

    %% Styling
    style BG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OTel fill:#425cc7,stroke:#333,color:#fff
    style InferenceGW fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
    style PVC fill:#999,stroke:#333,color:#fff
