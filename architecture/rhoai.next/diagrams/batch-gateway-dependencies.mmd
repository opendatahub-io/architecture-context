graph LR
    BatchGW["Batch Gateway<br/>(Apiserver + Processor + GC)"]

    %% External Dependencies (Required)
    BatchGW -->|"metadata CRUD<br/>pgx/5432"| PostgreSQL["PostgreSQL 12+<br/>(Required)"]
    BatchGW -->|"queue, events,<br/>status, inflight<br/>RESP/6379"| Redis["Redis 6+ / Valkey 8+<br/>(Required)"]

    %% External Dependencies (Conditional)
    BatchGW -->|"file storage<br/>HTTPS/443"| S3["S3-compatible Storage<br/>(Conditional - alt: filesystem)"]

    %% External Dependencies (Optional)
    BatchGW -.->|"trace export<br/>gRPC/4317"| OTLP["OTLP Collector<br/>(Optional)"]

    %% Internal Platform Dependencies
    BatchGW -->|"inference requests<br/>HTTP(S)"| InferenceGW["llm-d Router<br/>Inference Gateway"]
    BatchGW -.->|"ingress routing<br/>HTTPRoute CR"| GatewayAPI["Gateway API<br/>(Kubernetes)"]
    BatchGW -.->|"async dispatch<br/>Redis queue"| LlmdAsync["llm-d-async<br/>(Optional)"]

    %% Gateway-level Dependencies
    Kuadrant["Kuadrant / Authorino"] -->|"AuthN/AuthZ<br/>gateway policy"| BatchGW
    GIE["GIE InferenceObjective"] -.->|"per-model routing<br/>HTTP header"| BatchGW

    %% Integration Points (consume Batch Gateway)
    Prometheus["Prometheus Operator"] -.->|"scrape metrics<br/>ServiceMonitor/PodMonitor<br/>:8081, :9090, :9091"| BatchGW
    CertManager["cert-manager"] -.->|"TLS certs<br/>Certificate CR"| BatchGW
    Grafana["Grafana"] -.->|"dashboards<br/>ConfigMap sidecar"| BatchGW

    %% Styling
    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff

    %% Conditional external
    style S3 fill:#ff9900,stroke:#333,color:#fff

    %% Optional external
    style OTLP fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
    style Kuadrant fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style GIE fill:#7ed321,stroke:#333,color:#fff
    style LlmdAsync fill:#7ed321,stroke:#333,color:#fff

    %% Observability
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style CertManager fill:#7ed321,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
