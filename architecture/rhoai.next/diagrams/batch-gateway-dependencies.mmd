graph LR
    BatchGW["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% External Dependencies (Required)
    BatchGW -->|"metadata storage<br/>TCP/5432"| PostgreSQL["PostgreSQL<br/>(required)"]
    BatchGW -->|"priority queue, events,<br/>status store<br/>TCP/6379"| Redis["Redis / Valkey<br/>(required)"]

    %% External Dependencies (Optional)
    BatchGW -.->|"file storage<br/>HTTPS/443"| S3["S3-Compatible Storage<br/>MinIO / AWS S3<br/>(optional, alt to FS)"]
    BatchGW -.->|"TLS certificates<br/>CRD: Certificate"| CertManager["cert-manager v1<br/>(optional)"]
    BatchGW -.->|"distributed tracing<br/>OTLP/gRPC/4317"| OTel["OpenTelemetry Collector<br/>(optional)"]

    %% Internal Platform Dependencies
    BatchGW -->|"inference requests<br/>HTTP/HTTPS<br/>Bearer token"| InferenceGW["LLM Inference Gateway<br/>llm-d / vLLM"]
    BatchGW -.->|"external ingress<br/>HTTPRoute"| GatewayAPI["Gateway API<br/>(optional)"]

    %% Observability (scrape direction)
    Prometheus["Prometheus<br/>(optional)"] -.->|"metrics scrape<br/>HTTP/8081"| BatchGW
    Grafana["Grafana<br/>(optional)"] -.->|"dashboards<br/>via ConfigMap"| BatchGW

    %% Filesystem alternative
    BatchGW -.->|"file storage<br/>local I/O"| PVC["PersistentVolumeClaim<br/>(optional, alt to S3)"]

    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style InferenceGW fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
    style PVC fill:#999,stroke:#333,color:#fff
