graph LR
    BG["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% External Dependencies (Required)
    BG -->|"metadata persistence<br/>TCP/5432"| PostgreSQL["PostgreSQL<br/>(via pgx v5)"]
    BG -->|"queue, events, status<br/>TCP/6379"| Redis["Redis / Valkey<br/>(via go-redis v9)"]
    BG -->|"file storage<br/>HTTPS/443"| S3["S3-Compatible Storage<br/>(AWS S3 API)"]

    %% External Dependencies (Optional)
    BG -.->|"TLS certificates<br/>Certificate CR"| CertManager["cert-manager v1"]
    BG -.->|"distributed tracing<br/>gRPC OTLP"| OTel["OpenTelemetry Collector"]
    BG -.->|"metrics scrape<br/>HTTP"| Prometheus["Prometheus v2+"]

    %% Internal Platform Dependencies
    BG -->|"inference dispatch<br/>HTTP(S), Bearer/mTLS"| InferenceGW["llm-d Inference Gateway"]
    BG -.->|"async dispatch<br/>Redis queue"| LLMDAsync["llm-d-async"]

    %% Kubernetes Infrastructure
    BG -->|"external ingress<br/>HTTPRoute CR"| GatewayAPI["Gateway API<br/>(Kubernetes)"]

    %% Observability integrations
    Grafana["Grafana"] -.->|"dashboard<br/>ConfigMap"| BG

    style BG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff

    %% External optional
    style CertManager fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style InferenceGW fill:#7ed321,stroke:#333,color:#fff
    style LLMDAsync fill:#7ed321,stroke:#333,color:#fff

    %% Infrastructure
    style GatewayAPI fill:#f5a623,stroke:#333,color:#fff
