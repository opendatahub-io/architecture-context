graph LR
    BG["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% Required External Dependencies
    BG -->|"metadata storage<br/>pgx/5432"| PostgreSQL["PostgreSQL 12+<br/>(Required)"]
    BG -->|"queue, events, status<br/>RESP/6379"| Redis["Redis 6+ / Valkey 8+<br/>(Required)"]
    BG -->|"file storage<br/>HTTPS/443"| S3["S3-Compatible Storage<br/>(Required when type=s3)"]
    BG -->|"container orchestration"| K8s["Kubernetes 1.19+<br/>(Required)"]
    BG -->|"deployment"| Helm["Helm 3.0+<br/>(Required)"]

    %% Optional External Dependencies
    BG -.->|"TLS cert provisioning"| CertManager["cert-manager<br/>(Optional)"]
    BG -.->|"ingress routing"| GatewayAPI["Gateway API CRDs v1<br/>(Optional)"]
    BG -.->|"external auth"| Kuadrant["Kuadrant / Authorino<br/>(Optional)"]
    BG -.->|"distributed tracing<br/>gRPC/OTLP"| OTel["OpenTelemetry Collector<br/>(Optional)"]
    BG -.->|"metrics scrape<br/>HTTP/8081, 9090"| Prometheus["Prometheus<br/>(Optional)"]
    BG -.->|"dashboards"| Grafana["Grafana<br/>(Optional)"]

    %% Internal Platform Dependencies
    BG -->|"inference requests<br/>HTTP(S)/configurable<br/>Bearer / mTLS"| InfGW["llm-d Inference Gateway<br/>(Required)"]
    BG -.->|"ingress parentRef"| GWRoute["llm-d Gateway<br/>(Gateway API HTTPRoute)<br/>(Optional)"]
    BG -.->|"priority-band flow control<br/>x-gateway-inference-objective"| GIE["GIE InferenceObjective CRD<br/>(Optional)"]

    %% Integration Points (inbound)
    Prometheus -->|"ServiceMonitor<br/>PodMonitor"| BG
    Grafana -.->|"ConfigMap discovery<br/>grafana_dashboard: 1"| BG

    %% Alternative file storage
    BG -.->|"local file storage<br/>(alternative to S3)"| PVC["Filesystem / PVC<br/>(Optional)"]

    style BG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required externals
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style Helm fill:#0f1689,stroke:#333,color:#fff

    %% Optional externals
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Kuadrant fill:#9b59b6,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff

    %% Internal platform
    style InfGW fill:#7ed321,stroke:#333,color:#fff
    style GWRoute fill:#7ed321,stroke:#333,color:#fff
    style GIE fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#999,stroke:#333,color:#fff
