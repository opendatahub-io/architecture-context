graph LR
    BatchGW["Batch Gateway<br/>(API Server + Processor + GC)"]

    %% Required External Dependencies
    BatchGW -->|"metadata storage<br/>pgx/5432"| PostgreSQL["PostgreSQL 12+"]
    BatchGW -->|"queue/events/status<br/>RESP/6379"| Redis["Redis 6+ /<br/>Valkey 8+"]
    BatchGW -->|"file storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]
    BatchGW -->|"container orchestration"| K8s["Kubernetes 1.19+"]
    BatchGW -->|"deployment"| Helm["Helm 3.0+"]

    %% Internal Platform Dependencies
    BatchGW -->|"inference dispatch<br/>HTTP(S)"| InferGW["llm-d Inference<br/>Gateway"]
    BatchGW -->|"ingress routing<br/>HTTPRoute"| GatewayAPI["llm-d Gateway<br/>(Gateway API)"]
    BatchGW -->|"priority-band flow<br/>x-gateway-inference-objective"| GIE["GIE InferenceObjective<br/>CRD"]

    %% Optional External Dependencies
    BatchGW -.->|"TLS certs"| CertManager["cert-manager"]
    BatchGW -.->|"external auth<br/>tenant header"| Kuadrant["Kuadrant/<br/>Authorino"]
    BatchGW -.->|"trace export<br/>gRPC OTLP"| OTel["OpenTelemetry<br/>Collector"]

    %% Observability Integration
    Prometheus["Prometheus"] -.->|"scrape metrics<br/>HTTP/8081,9090"| BatchGW
    Grafana["Grafana"] -.->|"dashboard discovery<br/>ConfigMap sidecar"| BatchGW

    %% Styling
    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#569a31,stroke:#333,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style Helm fill:#0f1689,stroke:#333,color:#fff

    %% Internal platform
    style InferGW fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style GIE fill:#7ed321,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#999,stroke:#333,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff

    %% Observability
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
