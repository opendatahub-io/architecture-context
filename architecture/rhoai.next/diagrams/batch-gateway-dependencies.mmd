graph LR
    BatchGW["Batch Gateway<br/>(apiserver + processor + gc)"]

    %% External Dependencies (Required)
    BatchGW -->|"metadata storage<br/>TCP/5432 TLS"| PostgreSQL["PostgreSQL<br/>(Required — primary backend)"]
    BatchGW -->|"priority queue, events,<br/>status store<br/>TCP/6379 TLS/mTLS"| Redis["Redis / Valkey<br/>(Required)"]

    %% External Dependencies (Optional)
    BatchGW -->|"file storage<br/>HTTPS/443"| S3["S3-Compatible Storage<br/>(MinIO, AWS S3)<br/>(Optional — alt to FS)"]
    BatchGW -->|"TLS cert provisioning<br/>Certificate CRD"| CertManager["cert-manager v1<br/>(Optional)"]
    BatchGW -->|"distributed tracing<br/>OTLP/gRPC :4317"| OTel["OpenTelemetry Collector<br/>(Optional)"]

    %% Observability
    Prometheus["Prometheus<br/>(Optional)"] -->|"metrics scrape<br/>HTTP :8081"| BatchGW
    Grafana["Grafana<br/>(Optional)"] -->|"pre-built dashboards<br/>ConfigMap"| BatchGW

    %% Internal Platform Dependencies
    BatchGW -->|"inference requests<br/>HTTP/HTTPS Bearer token"| InferenceGW["LLM Inference Gateway<br/>(llm-d / vLLM)<br/>(Required for processing)"]

    %% Ingress
    GatewayAPI["Gateway API<br/>HTTPRoute<br/>(Optional)"] -->|"external routing<br/>/v1/batches, /v1/files"| BatchGW

    %% Filesystem alternative
    BatchGW -->|"file storage<br/>local I/O"| PVC["Filesystem PVC<br/>(Optional — alt to S3)"]

    %% Styling
    style BatchGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style Grafana fill:#f46800,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style PVC fill:#e8e8e8,stroke:#333
