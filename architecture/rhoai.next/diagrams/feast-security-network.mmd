graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Model / Client"]
        DataPipeline["Data Pipeline"]
        DataScientist["Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Edge TLS)"]
        RouteOnline["Route: {feast-name}<br/>443/TCP → 6566/TCP<br/>TLS edge, service-serving certs"]
        RouteRegistry["Route: {feast-name}-registry<br/>443/TCP → 6001/TCP<br/>TLS edge"]
        RouteRegistryREST["Route: {feast-name}-registry-rest<br/>443/TCP → 8001/TCP<br/>TLS edge"]
        RouteUI["Route: {feast-name}-ui<br/>443/TCP → 3000/TCP<br/>TLS edge"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            FeastOperator["feast-operator<br/>SA: controller-manager<br/>8081/TCP health (plaintext)<br/>8443/TCP metrics (HTTPS)<br/>FIPS: strictfipsruntime"]
        end

        subgraph UserNS["Namespace: {user-namespace}"]
            FeatureServer["feature-server<br/>6566/TCP REST (TLS optional)<br/>8000/TCP metrics (HTTP)<br/>Python 3.12, UBI9 OpenSSL"]
            GoFeatureServer["Go feature server<br/>50051/TCP gRPC (TLS optional)"]
            RegistrySvc["Registry Service<br/>6001/TCP gRPC<br/>8001/TCP REST<br/>TLS: service-serving certs"]
            FeastUI["feast-ui<br/>3000/TCP HTTP<br/>TLS: service-serving certs"]
            CronJob["Materialization CronJob<br/>ose-cli image<br/>kubectl exec"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Password auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>User/password"]
        DynamoDB["DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        BigQuery["BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        Elasticsearch["Elasticsearch<br/>9200/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Milvus["Milvus<br/>19530/TCP gRPC<br/>TLS optional<br/>Token"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS discovery"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS (service-serving)<br/>Bearer Token (OIDC/K8s)"| RouteOnline
    Client -->|"HTTPS/443<br/>gRPC"| RouteRegistry
    DataPipeline -->|"HTTPS/443<br/>Bearer Token"| RouteOnline
    DataScientist -->|"HTTPS/443<br/>Browser"| RouteUI

    %% Ingress → Services
    RouteOnline -->|"HTTP/6566<br/>TLS terminated at Route"| FeatureServer
    RouteRegistry -->|"gRPC/6001<br/>TLS terminated"| RegistrySvc
    RouteRegistryREST -->|"HTTP/8001<br/>TLS terminated"| RegistrySvc
    RouteUI -->|"HTTP/3000<br/>TLS terminated"| FeastUI

    %% Operator → API & Services
    FeastOperator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    FeastOperator -->|"HTTP/8001<br/>TLS (service-serving)<br/>Intra-comm JWT"| RegistrySvc

    %% CronJob → Feature Server
    CronJob -->|"kubectl exec<br/>SA RBAC"| FeatureServer

    %% Feature Server → External Services
    FeatureServer -->|"TCP/6379<br/>TLS optional, Password"| Redis
    FeatureServer -->|"TCP/5432<br/>TLS optional, User/pass"| PostgreSQL
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, AWS IAM"| DynamoDB
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, GCP SA"| BigQuery
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, AWS IAM"| S3
    FeatureServer -->|"HTTPS/9200<br/>TLS 1.2+, API key"| Elasticsearch
    FeatureServer -->|"gRPC/19530<br/>TLS optional, Token"| Milvus
    FeatureServer -->|"HTTPS/443<br/>JWKS validation"| OIDC
    FeatureServer -->|"HTTPS/6443<br/>SA token, TokenReview"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client,DataPipeline,DataScientist external
    class RouteOnline,RouteRegistry,RouteRegistryREST,RouteUI ingress
    class FeatureServer,GoFeatureServer,RegistrySvc,FeastUI,CronJob,K8sAPI clusterinternal
    class FeastOperator operator
    class Redis,PostgreSQL,DynamoDB,BigQuery,S3,Elasticsearch,Milvus,OIDC externalservice
