graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Application / Notebook<br/>External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        Route["feast-{name}-ui Route<br/>443/TCP → 8443/TCP<br/>TLS Edge Termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["Feast Operator<br/>Controller Manager<br/>SA: feast-operator-controller-manager<br/>Health: 8081/TCP (HTTP)<br/>Metrics: 8443/TCP (HTTPS, self-signed)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OnlineSvc["feast-{name}-online<br/>ClusterIP<br/>6566/TCP (HTTP) | 6567/TCP (HTTPS)<br/>TLS: service-serving certs<br/>Auth: Bearer Token (OIDC/K8s)"]
            OfflineSvc["feast-{name}-offline<br/>ClusterIP<br/>8815/TCP (HTTP) | 8816/TCP (HTTPS)<br/>TLS: service-serving certs<br/>Auth: Bearer Token"]
            RegistrySvc["feast-{name}-registry<br/>ClusterIP<br/>6570/TCP (gRPC) | 6571/TCP (gRPC+TLS)<br/>6572/TCP (REST) | 6573/TCP (REST+TLS)<br/>Auth: Bearer / Intra-comm token"]
            UISvc["feast-{name}-ui<br/>ClusterIP<br/>8888/TCP (HTTP) | 8443/TCP (HTTPS)<br/>TLS: service-serving certs"]
            FeatureServerPod["Feature Server Pod<br/>SA: feast-{name}<br/>Image: feature-server:0.62.0<br/>Gunicorn + Uvicorn<br/>Auth: OIDC or K8s RBAC"]
            CronJobPod["CronJob Pod<br/>Image: ose-cli (RHOAI)<br/>Auth: Intra-comm token"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        Redis["Redis<br/>6379/TCP<br/>TLS (configurable)<br/>Auth: Password/mTLS"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (sslmode=verify-full)<br/>Auth: Username/Password"]
        BigQuery["BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Google SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Snowflake creds"]
        S3GCS["S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Google SA"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Discovery + JWKS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Edge<br/>Bearer Token"| Route
    Route -->|"HTTPS/8443"| UISvc

    Client -->|"HTTPS/6567<br/>TLS (service-serving)<br/>Bearer Token"| OnlineSvc

    %% Internal service flows
    OnlineSvc --> FeatureServerPod
    OfflineSvc --> FeatureServerPod
    RegistrySvc --> FeatureServerPod
    UISvc --> FeatureServerPod

    CronJobPod -->|"HTTPS/6567<br/>Intra-comm token"| OnlineSvc

    %% Operator flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTP/6572<br/>Intra-comm token"| RegistrySvc

    %% Egress flows
    FeatureServerPod -->|"TCP/6379<br/>TLS (config)<br/>Password"| Redis
    FeatureServerPod -->|"TCP/5432<br/>TLS verify-full<br/>User/Pass"| PostgreSQL
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Google SA"| BigQuery
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Creds"| Snowflake
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA"| S3GCS
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS"| OIDCProvider
    FeatureServerPod -->|"HTTPS/6443<br/>TLS 1.2+<br/>TokenReview"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef pod fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class OnlineSvc,OfflineSvc,RegistrySvc,UISvc clusterinternal
    class Operator operator
    class FeatureServerPod,CronJobPod pod
    class Redis,PostgreSQL,BigQuery,Snowflake,S3GCS,OIDCProvider,K8sAPI externalservice
