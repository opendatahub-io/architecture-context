graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Model / Client"]
        DataScientist["Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - edge TLS)"]
        RouteOnline["Route: {feast-name}<br/>443/TCP → 6566/TCP<br/>TLS edge termination"]
        RouteRegistry["Route: {feast-name}-registry<br/>443/TCP → 6001/TCP<br/>TLS edge termination"]
        RouteRegistryREST["Route: {feast-name}-registry-rest<br/>443/TCP → 8001/TCP<br/>TLS edge termination"]
        RouteUI["Route: {feast-name}-ui<br/>443/TCP → 3000/TCP<br/>TLS edge termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (User Namespace)"]
        direction TB

        FeatureServer["Feature Server<br/>6566/TCP REST (TLS optional)<br/>8000/TCP metrics (HTTP)<br/>Auth: Bearer Token (OIDC/K8s)<br/>Image: feature-server:0.63.0"]
        GoFeatureServer["Go Feature Server<br/>50051/TCP gRPC (TLS optional)<br/>Auth: Bearer Token"]
        Registry["Registry Service<br/>6001/TCP gRPC (TLS)<br/>8001/TCP REST (TLS)<br/>Auth: Intra-communication JWT"]
        FeastUI["Feast UI<br/>3000/TCP HTTP (TLS)<br/>Auth: None"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        Operator["Feast Operator<br/>SA: controller-manager<br/>8081/TCP health (HTTP)<br/>8443/TCP metrics (HTTPS/TLS)<br/>Image: feast-operator:0.63.0"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        OpenShiftAPI["OpenShift API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        OIDC["Platform OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS discovery"]
        KubeflowCtrl["Kubeflow Notebook Controller<br/>CRD Watch"]
    end

    subgraph ExternalDataServices["EXTERNAL DATA SERVICES (Egress)"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Password auth"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Username/password"]
        DynamoDB["DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        BigQuery["BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        Elasticsearch["Elasticsearch<br/>9200/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
        Milvus["Milvus<br/>19530/TCP gRPC<br/>TLS optional<br/>Token"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token (OIDC/K8s)"| RouteOnline
    Client -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| RouteRegistry
    DataScientist -->|"HTTPS/443<br/>TLS edge"| RouteUI

    %% Ingress → Cluster Internal
    RouteOnline -->|"HTTP/6566<br/>TLS (service-serving)"| FeatureServer
    RouteRegistry -->|"gRPC/6001<br/>TLS (service-serving)"| Registry
    RouteRegistryREST -->|"HTTP/8001<br/>TLS (service-serving)"| Registry
    RouteUI -->|"HTTP/3000<br/>TLS (service-serving)"| FeastUI

    %% Operator → Platform
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| OpenShiftAPI
    Operator -->|"HTTP/8001<br/>TLS (service-serving)<br/>Intra-communication JWT"| Registry

    %% Feature Server → External Data
    FeatureServer -->|"TCP/6379<br/>TLS optional<br/>Password"| Redis
    FeatureServer -->|"TCP/5432<br/>TLS optional<br/>User/pass"| PostgreSQL
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| DynamoDB
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| BigQuery
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    FeatureServer -->|"HTTPS/9200<br/>TLS 1.2+<br/>API key"| Elasticsearch
    FeatureServer -->|"gRPC/19530<br/>TLS optional<br/>Token"| Milvus

    %% Feature Server → Platform
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS"| OIDC
    FeatureServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (TokenReview)"| K8sAPI

    %% Operator → Kubeflow
    Operator -.->|"CRD Watch<br/>kubeflow.org/v1 Notebook"| KubeflowCtrl

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externaldata fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,DataScientist external
    class RouteOnline,RouteRegistry,RouteRegistryREST,RouteUI ingress
    class FeatureServer,GoFeatureServer,Registry,FeastUI clusterinternal
    class Operator operatorns
    class K8sAPI,OpenShiftAPI,OIDC,KubeflowCtrl platform
    class Redis,PostgreSQL,DynamoDB,BigQuery,S3,Elasticsearch,Milvus externaldata
