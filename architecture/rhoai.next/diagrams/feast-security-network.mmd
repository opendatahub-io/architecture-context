graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        App["ML Application / Notebook"]
    end

    subgraph IngressZone["INGRESS (OpenShift Route)"]
        UIRoute["feast-{name}-ui Route<br/>443/TCP → 8888/TCP<br/>TLS Edge Termination<br/>Auth: None"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (ClusterIP Services)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["Feast Operator<br/>SA: feast-operator-controller-manager<br/>Image: feast-operator:0.62.0<br/>Ports: 8081 (health), 8443 (metrics)<br/>HTTP/2: Disabled"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>TLS (self-signed)<br/>Auth: Bearer Token (SA)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            OnlineSvc["feast-{name}-online<br/>6566/TCP HTTP, 6567/TCP HTTPS<br/>TLS (service-serving certs)<br/>Auth: Bearer Token (OIDC/K8s)"]
            OfflineSvc["feast-{name}-offline<br/>8815/TCP HTTP, 8816/TCP HTTPS<br/>TLS (service-serving certs)<br/>Auth: Bearer Token"]
            RegistrySvc["feast-{name}-registry<br/>6570/TCP gRPC, 6571/TCP gRPC+TLS<br/>6572/TCP REST, 6573/TCP REST+TLS<br/>Auth: Bearer Token / Intra-comm"]
            UISvc["feast-{name}-ui<br/>8888/TCP HTTP, 8443/TCP HTTPS<br/>TLS (service-serving certs)<br/>Auth: None"]
            FeatureServerPod["Feature Server Pod<br/>SA: feast-{name}<br/>SecurityManager: OIDC / K8s RBAC"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token"]
        Redis["Redis<br/>6379/TCP<br/>TLS (configurable)<br/>Auth: Password/mTLS"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (sslmode=verify-full)<br/>Auth: Username/Password"]
        BigQuery["BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Google SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Credentials"]
        S3GCS["S3 / GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Google SA"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Discovery + JWKS"]
    end

    %% External flows
    App -->|"HTTPS/6567<br/>TLS (svc-serving certs)<br/>Bearer Token"| OnlineSvc
    App -->|"HTTPS/8816<br/>TLS<br/>Bearer Token"| OfflineSvc
    App -->|"gRPC-TLS/6571 or HTTPS/6573<br/>TLS<br/>Bearer Token"| RegistrySvc
    App -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| UIRoute
    UIRoute -->|"HTTP/8888"| UISvc

    %% Internal flows
    OnlineSvc --> FeatureServerPod
    OfflineSvc --> FeatureServerPod
    RegistrySvc --> FeatureServerPod
    UISvc --> FeatureServerPod

    %% Egress flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    FeatureServerPod -->|"TCP/6379<br/>TLS (config)<br/>Password/mTLS"| Redis
    FeatureServerPod -->|"TCP/5432<br/>TLS verify-full<br/>User/Pass"| PostgreSQL
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Google SA"| BigQuery
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Credentials"| Snowflake
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/SA"| S3GCS
    FeatureServerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS"| OIDCProvider
    FeatureServerPod -->|"HTTPS/6443<br/>TokenReview"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class App external
    class UIRoute ingress
    class Operator,OnlineSvc,OfflineSvc,RegistrySvc,UISvc,MetricsSvc clusterinternal
    class FeatureServerPod pod
    class K8sAPI,Redis,PostgreSQL,BigQuery,Snowflake,S3GCS,OIDCProvider externalservice
