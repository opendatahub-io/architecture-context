graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>Data Scientist / ML Engineer"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        UIRoute["feast-{name}-ui Route<br/>443/TCP → 8888/8443<br/>TLS edge/reencrypt"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal - ClusterIP)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["feast-operator-controller-manager<br/>SA: feast-operator-controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP (HTTPS, kube-rbac-proxy)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            RegistrySvc["feast-{name}-registry<br/>80/443 → 6570(gRPC), 6572(REST)<br/>TLS: OpenShift service-serving CA<br/>Auth: Bearer JWT / None"]
            OnlineSvc["feast-{name}-online<br/>80/443 → 6566/TCP<br/>TLS: OpenShift service-serving CA<br/>Auth: Bearer JWT (K8s/OIDC) / None"]
            OfflineSvc["feast-{name}-offline<br/>80/443 → 8815/TCP<br/>TLS: OpenShift service-serving CA<br/>Auth: Bearer JWT / None"]
            UISvc["feast-{name}-ui<br/>80/443 → 8888/8443<br/>TLS: OpenShift service-serving CA<br/>Auth: None"]
        end
    end

    subgraph EgressServices["EGRESS (External Services)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Password"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Password optional"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Account creds"]
        DynamoDB["AWS DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        BigQuery["GCP BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP creds"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client creds"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer JWT (optional)"| UIRoute
    Client -->|"HTTP(S)/6566<br/>TLS configurable<br/>Bearer JWT (optional)"| OnlineSvc

    %% Ingress → Services
    UIRoute -->|"HTTP(S)/8888 or 8443<br/>TLS (service-serving CA)"| UISvc

    %% Internal flows
    UISvc -->|"HTTP(S)/6572<br/>REST API<br/>Bearer JWT"| RegistrySvc
    Operator -->|"HTTP(S)/6572<br/>Bearer JWT<br/>(HMAC-SHA256 intra-comm)"| RegistrySvc

    %% Egress flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    OnlineSvc -->|"TCP/6379<br/>TLS optional<br/>Password"| Redis
    OnlineSvc -->|"TCP/5432<br/>TLS optional<br/>Password"| PostgreSQL
    RegistrySvc -->|"TCP/5432<br/>TLS optional<br/>Password"| PostgreSQL
    OfflineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>Account creds"| Snowflake
    OfflineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP creds"| BigQuery
    OnlineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| DynamoDB
    OnlineSvc -->|"HTTPS/443<br/>TLS 1.2+<br/>Client creds"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egressservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class UIRoute ingress
    class Operator,RegistrySvc,OnlineSvc,OfflineSvc,UISvc clusterservice
    class K8sAPI,PostgreSQL,Redis,Snowflake,DynamoDB,BigQuery,OIDC egressservice
