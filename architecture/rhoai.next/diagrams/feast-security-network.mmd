graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Application /<br/>External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - reencrypt TLS)"]
        RouteOnline["feast-online Route<br/>443/TCP → 6567/TCP<br/>TLS reencrypt"]
        RouteRegistry["feast-registry Route<br/>443/TCP → 6573/TCP<br/>TLS reencrypt"]
        RouteUI["feast-ui Route<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph OperatorNS["Namespace: redhat-ods-applications"]
            Operator["feast-operator<br/>SA: feast-operator-controller-manager<br/>Ports: 8443 (metrics), 8081 (health)<br/>FIPS: strictfipsruntime"]
            OperatorMetrics["Operator Metrics Service<br/>8443/TCP HTTPS<br/>Auth: TokenReview"]
        end

        subgraph UserNS["Namespace: {user-namespace}"]
            direction TB

            OfflineSvc["feast-offline Service<br/>ClusterIP 80|443 → 8815|8816<br/>gRPC, TLS optional<br/>Auth: Bearer JWT"]
            OnlineSvc["feast-online Service<br/>ClusterIP 80|443 → 6566|6567<br/>gRPC, TLS optional<br/>Auth: Bearer JWT"]
            OnlineMetrics["feast-online Metrics<br/>8000/TCP HTTP<br/>No auth, no TLS"]
            RegistrySvc["feast-registry Service<br/>ClusterIP 80|443 → 6570|6571<br/>gRPC, TLS optional<br/>Auth: Bearer JWT"]
            RegistryREST["feast-registry-rest Service<br/>ClusterIP 80|443 → 6572|6573<br/>HTTP/HTTPS REST /api/v1/*<br/>Auth: Bearer JWT"]
            UISvc["feast-ui Service<br/>ClusterIP 80|443 → 8888|8443<br/>HTTP/HTTPS<br/>Auth: Bearer JWT"]

            subgraph Pod["FeatureStore Pod (Multi-Container)"]
                OfflineC["offline container<br/>8815/8816"]
                OnlineC["online container<br/>6566/6567, 8000"]
                RegistryC["registry container<br/>6570/6571, 6572/6573"]
                UIC["ui container<br/>8888/8443"]
            end

            OfflineSvc --> OfflineC
            OnlineSvc --> OnlineC
            OnlineMetrics --> OnlineC
            RegistrySvc --> RegistryC
            RegistryREST --> RegistryC
            UISvc --> UIC
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Credentials from Secret"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Credentials from Secret"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Credentials from Secret"]
        S3["S3/GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM credentials"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>Bearer JWT"| RouteOnline
    Client -->|"HTTPS/443<br/>Bearer JWT"| RouteRegistry
    Client -->|"HTTPS/443<br/>Bearer JWT"| RouteUI

    %% Route to Service flows
    RouteOnline -->|"TLS reencrypt<br/>6567/TCP"| OnlineSvc
    RouteRegistry -->|"TLS reencrypt<br/>6573/TCP"| RegistryREST
    RouteUI -->|"TLS reencrypt<br/>8443/TCP"| UISvc

    %% Operator flows
    Operator -->|"HTTPS/443<br/>SA token"| K8sAPI
    Operator -->|"HTTP(S)<br/>HMAC-SHA256 JWT<br/>InsecureSkipVerify"| RegistryREST

    %% Feature server egress
    OnlineC -->|"Store-specific<br/>Credentials"| Redis
    OnlineC -->|"Store-specific<br/>Credentials"| PostgreSQL
    OfflineC -->|"Store-specific<br/>Credentials"| PostgreSQL
    OfflineC -->|"HTTPS/443<br/>Credentials"| Snowflake
    RegistryC -->|"HTTPS/443<br/>IAM creds"| S3
    RegistryC -->|"Store-specific<br/>Credentials"| PostgreSQL
    OnlineC -->|"HTTPS/443<br/>SA token"| K8sAPI
    RegistryC -->|"HTTPS/443"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef pod fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Client external
    class RouteOnline,RouteRegistry,RouteUI ingress
    class OfflineSvc,OnlineSvc,OnlineMetrics,RegistrySvc,RegistryREST,UISvc clusterinternal
    class Operator,OperatorMetrics operator
    class OfflineC,OnlineC,RegistryC,UIC pod
    class K8sAPI,OIDC,Redis,PostgreSQL,Snowflake,S3 externalservice
