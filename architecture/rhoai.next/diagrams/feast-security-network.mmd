graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Model / External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Edge)"]
        RouteOnline["Route: {feast-name}<br/>443/TCP → 6566/TCP<br/>TLS edge termination"]
        RouteRegistry["Route: {feast-name}-registry<br/>443/TCP → 6001/TCP gRPC<br/>TLS edge termination"]
        RouteRegistryREST["Route: {feast-name}-registry-rest<br/>443/TCP → 8001/TCP REST<br/>TLS edge, JWT auth"]
        RouteUI["Route: {feast-name}-ui<br/>443/TCP → 3000/TCP<br/>TLS edge termination"]
    end

    subgraph Internal["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["feast-operator-controller-manager<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>FIPS: strictfipsruntime"]
        end

        subgraph NS_User["Namespace: {feast-namespace}"]
            FeatureServer["Feature Server<br/>SA: {feast-name}<br/>REST: 6566/TCP HTTP, TLS opt<br/>gRPC: configurable/TCP, TLS opt<br/>Metrics: 8000/TCP HTTP<br/>Registry REST: 8001/TCP<br/>Registry gRPC: 6001/TCP<br/>Auth: Bearer Token (OIDC/K8s)"]
            FeastUI["Feast UI<br/>Port: 3000/TCP HTTP"]
            CronJob["Materialization CronJob<br/>Image: ose-cli<br/>Auth: SA RBAC (pods/exec)"]
        end
    end

    subgraph ExternalServices["EGRESS - EXTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional<br/>Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>User/Pass"]
        DynamoDB["DynamoDB<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        BigQuery["BigQuery<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Account creds"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Elasticsearch["Elasticsearch<br/>9200/TCP HTTPS<br/>TLS 1.2+<br/>API Key"]
        Milvus["Milvus<br/>19530/TCP gRPC<br/>TLS optional<br/>Token"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS edge<br/>Bearer Token"| RouteOnline
    Client -->|"HTTPS/443<br/>TLS edge"| RouteUI

    %% Ingress to Internal
    RouteOnline -->|"HTTP/6566<br/>TLS optional"| FeatureServer
    RouteRegistry -->|"gRPC/6001<br/>TLS optional"| FeatureServer
    RouteRegistryREST -->|"HTTP/8001<br/>TLS, JWT"| FeatureServer
    RouteUI -->|"HTTP/3000"| FeastUI

    %% Operator flows
    Operator -->|"HTTP/8001<br/>TLS service-serving<br/>Intra-comm JWT"| FeatureServer
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% CronJob
    CronJob -->|"kubectl exec<br/>SA RBAC"| FeatureServer

    %% Feature Server egress
    FeatureServer -->|"TCP/6379<br/>TLS opt, Password"| Redis
    FeatureServer -->|"TCP/5432<br/>TLS opt, User/Pass"| PostgreSQL
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, AWS IAM"| DynamoDB
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, GCP SA"| BigQuery
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, Creds"| Snowflake
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, AWS IAM"| S3
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, GCP SA"| GCS
    FeatureServer -->|"HTTPS/9200<br/>TLS 1.2+, API Key"| Elasticsearch
    FeatureServer -->|"gRPC/19530<br/>TLS opt, Token"| Milvus
    FeatureServer -->|"HTTPS/443<br/>TLS 1.2+, JWKS"| OIDC
    FeatureServer -->|"HTTPS/6443<br/>TLS 1.2+, SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class RouteOnline,RouteRegistry,RouteRegistryREST,RouteUI ingress
    class FeatureServer,FeastUI,CronJob internal
    class Operator operator
    class K8sAPI,Redis,PostgreSQL,DynamoDB,BigQuery,Snowflake,S3,GCS,Elasticsearch,Milvus,OIDC externalservice
