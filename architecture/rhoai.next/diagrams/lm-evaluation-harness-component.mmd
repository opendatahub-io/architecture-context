graph TB
    subgraph "Kubernetes Job Pod"
        subgraph "LM Evaluation Harness Container"
            Adapter["EvalHub Adapter<br/>(main.py)<br/>FrameworkAdapter interface"]
            LMEvalCore["lm_eval Core Library<br/>(EleutherAI fork)<br/>Task mgmt, metrics, eval orchestration"]
            LocalCompletions["local-completions Backend<br/>(openai_completions.py)<br/>OpenAI-compatible HTTP client"]
            OCIPusher["OCI Artifact Pusher<br/>(scripts/oci.py)<br/>olot + skopeo"]

            Adapter -->|"simple_evaluate()"| LMEvalCore
            LMEvalCore -->|"sends prompts via"| LocalCompletions
            Adapter -->|"persists results"| OCIPusher
        end

        JobSpec["/meta/job.json<br/>(ConfigMap mount)"]
        TestData["/test_data<br/>(Volume mount)<br/>Offline datasets & tokenizers"]
        Secrets["Model Auth Secret<br/>(Secret mount)<br/>OPENAI_API_KEY, HF_TOKEN, CA cert"]
    end

    Operator["TrustyAI LMEval Operator<br/>(trustyai-service-operator)"]
    Operator -->|"creates Job,<br/>mounts ConfigMap & Secrets"| Adapter

    JobSpec -->|"parsed by"| Adapter
    TestData -.->|"auto-detected for<br/>air-gapped mode"| Adapter
    Secrets -->|"credentials loaded"| Adapter

    Adapter -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    LocalCompletions -->|"POST /v1/completions<br/>HTTPS/443"| ModelEndpoint["Model Inference Endpoint<br/>(vLLM, TGI, etc.)"]
    OCIPusher -->|"skopeo push<br/>HTTPS/443"| OCIRegistry["OCI Registry"]
    LMEvalCore -.->|"downloads datasets<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    Adapter -.->|"logs metrics<br/>(optional)"| MLflow["MLflow Tracking"]

    style Adapter fill:#4a90e2,color:#fff
    style LMEvalCore fill:#4a90e2,color:#fff
    style LocalCompletions fill:#4a90e2,color:#fff
    style OCIPusher fill:#4a90e2,color:#fff
    style Operator fill:#7ed321,color:#fff
    style EvalHub fill:#7ed321,color:#fff
    style ModelEndpoint fill:#f5a623,color:#fff
    style OCIRegistry fill:#f5a623,color:#fff
    style HFHub fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style JobSpec fill:#fff2cc,stroke:#d6b656
    style TestData fill:#fff2cc,stroke:#d6b656
    style Secrets fill:#ffcccc,stroke:#cc0000
