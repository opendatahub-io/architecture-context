graph TB
    subgraph "trustyai-service-operator"
        Operator[trustyai-service-operator<br/>Controller]
        LMEvalJobCR[LMEvalJob CR]
    end

    subgraph "lm-evaluation-harness Job Pod"
        subgraph "EvalHub Adapter Layer"
            MainPy["main.py<br/>EvalHub Adapter"]
            JobSpec["JobSpec JSON<br/>(from ConfigMap /meta/job.json)"]
        end

        subgraph "lm_eval Core Library"
            Evaluator["simple_evaluate()<br/>Evaluator Engine"]
            TaskSystem["Task System<br/>6,500+ YAML Definitions"]
            ModelRegistry["Model Backend Registry<br/>(@register_model)"]
            Metrics["Metrics Engine<br/>117 Metrics"]
            Cache["Caching Layer<br/>(hashlib.sha256)"]
        end

        subgraph "Model Backends"
            LocalCompletions["local-completions<br/>(Primary in RHOAI)"]
            TemplateAPI["TemplateAPI Base Class<br/>async HTTP client"]
        end

        subgraph "Result Handlers"
            Callbacks["DefaultCallbacks<br/>(eval-hub-sdk)"]
            OCIPush["OCI Artifact Push<br/>(olot)"]
            MLflowLog["MLflow Logger"]
        end

        subgraph "Unitxt Integration"
            Unitxt["Unitxt Module<br/>Dynamic Task Definitions"]
        end
    end

    %% External Systems
    EvalHub["EvalHub Service"]
    ModelEndpoint["Model Inference Endpoint<br/>(vLLM / TGI / OpenAI-compatible)"]
    OCIRegistry["OCI Registry"]
    MLflowServer["MLflow Tracking Server"]
    HFHub["HuggingFace Hub"]
    S3["S3 / COS<br/>Object Storage"]

    %% Flow: Operator creates Job
    Operator -->|creates Job| MainPy
    LMEvalJobCR -->|watched by| Operator
    JobSpec -->|loaded by| MainPy

    %% Internal flows
    MainPy -->|configures & invokes| Evaluator
    Evaluator -->|loads| TaskSystem
    Evaluator -->|instantiates via| ModelRegistry
    Evaluator -->|computes| Metrics
    ModelRegistry -->|creates| LocalCompletions
    LocalCompletions -->|extends| TemplateAPI
    TaskSystem -->|includes| Unitxt
    Evaluator -->|uses| Cache

    %% Result publishing
    MainPy -->|status & results| Callbacks
    MainPy -->|artifact push| OCIPush
    MainPy -->|log metrics| MLflowLog

    %% External connections
    Callbacks -->|REST callbacks| EvalHub
    TemplateAPI -->|POST /v1/completions| ModelEndpoint
    OCIPush -->|push artifacts| OCIRegistry
    MLflowLog -->|log runs| MLflowServer
    TaskSystem -->|download datasets| HFHub
    MainPy -.->|offline data| S3

    %% Styling
    style MainPy fill:#4a90e2,stroke:#333,color:#fff
    style Evaluator fill:#4a90e2,stroke:#333,color:#fff
    style LocalCompletions fill:#4a90e2,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style LMEvalJobCR fill:#f5a623,stroke:#333,color:#fff
    style EvalHub fill:#e8e8e8,stroke:#333
    style ModelEndpoint fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style MLflowServer fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
