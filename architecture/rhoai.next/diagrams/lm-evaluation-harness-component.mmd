graph TB
    subgraph Operator["TrustyAI LMEval Operator"]
        LMEvalJobCR["LMEvalJob CR"]
    end

    subgraph LMEvalJob["LMEval Batch Job Pod"]
        direction TB
        Adapter["LMEval Adapter<br/>(main.py)<br/>Job Orchestration"]
        LMEvalLib["lm_eval Library<br/>Task Management &<br/>Metric Computation"]
        OCIPublisher["OCI Artifact Publisher<br/>(scripts/oci.py)<br/>Result Packaging"]
        S3Downloader["S3 Downloader<br/>(scripts/s3_downloader.py)<br/>Offline Data Fetch"]

        Adapter -->|configures & invokes| LMEvalLib
        Adapter -->|calls| OCIPublisher
        S3Downloader -->|populates /test_data| LMEvalLib
    end

    subgraph ConfigSources["Configuration"]
        JobSpec["Job Spec ConfigMap<br/>(/meta/job.json)"]
        ModelSecret["Model Auth Secret<br/>(OPENAI_API_KEY, HF_TOKEN)"]
    end

    LMEvalJobCR -->|creates K8s Job| LMEvalJob
    JobSpec -->|mounted into| Adapter
    ModelSecret -->|env vars| Adapter

    Adapter -->|status callbacks| EvalHub["EvalHub Service"]
    LMEvalLib -->|POST /completions| InferenceEndpoint["Inference Endpoint<br/>(vLLM / TGI)"]
    LMEvalLib -->|downloads datasets| HFHub["HuggingFace Hub"]
    OCIPublisher -->|pushes artifacts| OCIRegistry["OCI Registry<br/>(Quay)"]
    Adapter -->|logs metrics| MLflow["MLflow Tracking<br/>Server"]
    S3Downloader -->|downloads data| S3["S3-compatible<br/>Storage"]

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style LMEvalLib fill:#4a90e2,stroke:#333,color:#fff
    style OCIPublisher fill:#4a90e2,stroke:#333,color:#fff
    style S3Downloader fill:#4a90e2,stroke:#333,color:#fff
    style LMEvalJobCR fill:#f5a623,stroke:#333,color:#fff
    style JobSpec fill:#e8e8e8,stroke:#333
    style ModelSecret fill:#e8e8e8,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style InferenceEndpoint fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
