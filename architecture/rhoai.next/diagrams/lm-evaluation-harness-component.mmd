graph TB
    subgraph "LMEval Job Container"
        Adapter["LMEval Adapter<br/>(main.py)<br/>EvalHub integration"]
        LMEvalLib["lm_eval Library<br/>Task mgmt, metrics,<br/>result aggregation"]
        OCIPublisher["OCI Artifact Publisher<br/>(scripts/oci.py)<br/>Packages & pushes results"]
        S3Downloader["S3 Downloader<br/>(scripts/s3_downloader.py)<br/>Offline data retrieval"]

        Adapter -->|"configures & invokes<br/>simple_evaluate()"| LMEvalLib
        Adapter -->|"publishes results"| OCIPublisher
        S3Downloader -->|"populates /test_data<br/>(init container)"| Adapter
    end

    Operator["TrustyAI LMEval Operator"] -->|"creates K8s Job<br/>from LMEvalJob CR"| Adapter
    ConfigMap["/meta/job.json<br/>ConfigMap"] -->|"job spec"| Adapter

    LMEvalLib -->|"POST /v1/completions<br/>Bearer Token"| InferenceEndpoint["OpenAI-compatible<br/>Inference Endpoint<br/>(vLLM / TGI)"]

    Adapter -->|"status callbacks<br/>HTTPS/443"| EvalHub["EvalHub Service"]
    OCIPublisher -->|"skopeo push<br/>HTTPS/443"| OCIRegistry["OCI Registry<br/>(Quay)"]
    LMEvalLib -->|"downloads datasets<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    Adapter -->|"saves metrics<br/>REST API"| MLflow["MLflow Tracking<br/>Server"]
    S3Downloader -->|"downloads test data<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style LMEvalLib fill:#4a90e2,stroke:#333,color:#fff
    style OCIPublisher fill:#4a90e2,stroke:#333,color:#fff
    style S3Downloader fill:#4a90e2,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style ConfigMap fill:#f5a623,stroke:#333,color:#fff
    style InferenceEndpoint fill:#e8e8e8,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
