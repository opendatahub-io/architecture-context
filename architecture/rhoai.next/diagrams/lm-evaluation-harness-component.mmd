graph TB
    subgraph "LMEval Batch Job Pod"
        direction TB
        Adapter["LMEval EvalHub Adapter<br/>(main.py)<br/>Python Batch Job"]
        Harness["lm-evaluation-harness<br/>(lm_eval/)<br/>Core Evaluation Library"]
        S3Downloader["S3 Downloader<br/>(scripts/s3_downloader.py)<br/>Asset Download Utility"]
        OCIBuilder["OCI Artifact Builder<br/>(scripts/oci.py)<br/>Result Packaging"]

        Adapter -->|"orchestrates"| Harness
        Adapter -->|"invokes post-eval"| OCIBuilder
    end

    subgraph "Init Container (Air-Gapped)"
        InitS3["S3 Download Init"]
        InitS3 -->|"pre-populates /test_data"| S3Downloader
    end

    %% External Triggers
    TrustyAI["TrustyAI Operator<br/>(LMEvalJob Controller)"]
    JobSpec["Job Spec ConfigMap<br/>(/meta/job.json)"]

    TrustyAI -->|"creates K8s Job"| Adapter
    TrustyAI -->|"mounts"| JobSpec
    JobSpec -->|"read by"| Adapter

    %% Evaluation Flow
    Harness -->|"calls /v1/completions"| ModelEndpoint["Model Inference Endpoint<br/>(OpenAI-compatible)"]
    Harness -->|"downloads tokenizers<br/>& datasets"| HFHub["HuggingFace Hub"]

    %% Result Outputs
    Adapter -->|"status & results<br/>callbacks"| EvalHub["EvalHub Service"]
    OCIBuilder -->|"pushes artifacts<br/>via skopeo"| OCIRegistry["OCI Registry<br/>(Quay.io)"]
    Adapter -->|"persists metrics"| MLflow["MLflow Server"]

    %% Offline path
    S3Downloader -->|"downloads assets"| S3["S3-compatible Storage"]

    %% Styling
    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style Harness fill:#4a90e2,stroke:#333,color:#fff
    style S3Downloader fill:#4a90e2,stroke:#333,color:#fff
    style OCIBuilder fill:#4a90e2,stroke:#333,color:#fff
    style InitS3 fill:#4a90e2,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style ModelEndpoint fill:#f5a623,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style JobSpec fill:#f5a623,stroke:#333
