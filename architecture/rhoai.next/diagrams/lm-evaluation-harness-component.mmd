graph TB
    subgraph Operator["trustyai-service-operator"]
        OpController["Operator Controller<br/>Manages LMEvalJob CRD"]
    end

    subgraph LMESJob["lm-evaluation-harness (lmes-job Pod)"]
        direction TB
        Adapter["EvalHub Adapter<br/>(main.py)<br/>Job lifecycle management"]
        LMEvalCore["lm_eval Core Library<br/>Task management, metrics,<br/>model abstraction"]
        TaskDefs["Task YAML Definitions<br/>6,500+ benchmark tasks<br/>(MMLU, HellaSwag, ARC, etc.)"]
        Unitxt["Unitxt Integration<br/>Flexible data preparation"]
        ModelBackend["Model Backend Registry<br/>local-completions (primary)<br/>OpenAI-compatible API client"]

        Adapter -->|"loads job spec<br/>runs evaluation"| LMEvalCore
        LMEvalCore -->|"loads tasks"| TaskDefs
        LMEvalCore -->|"alternative tasks"| Unitxt
        LMEvalCore -->|"sends prompts via"| ModelBackend
    end

    LMEvalJobCR["LMEvalJob CR<br/>(CRD managed by operator)"]
    ConfigMap["ConfigMap<br/>/meta/job.json<br/>Job specification"]

    User["Data Scientist / Platform"] -->|"creates"| LMEvalJobCR
    LMEvalJobCR -->|"watched by"| OpController
    OpController -->|"creates K8s Job +<br/>mounts ConfigMap"| ConfigMap
    ConfigMap -->|"read by"| Adapter

    ModelBackend -->|"POST /v1/completions<br/>Bearer Token"| InferenceEndpoint["Model Inference Endpoint<br/>(vLLM / TGI / OpenAI-compatible)"]
    Adapter -->|"status updates<br/>results callback"| EvalHub["EvalHub Service"]
    Adapter -->|"push artifacts"| OCIRegistry["OCI Registry"]
    Adapter -->|"log metrics"| MLflow["MLflow Tracking Server"]
    LMEvalCore -->|"download datasets"| HFHub["HuggingFace Hub"]

    style Adapter fill:#4a90e2,color:#fff
    style LMEvalCore fill:#4a90e2,color:#fff
    style ModelBackend fill:#4a90e2,color:#fff
    style TaskDefs fill:#7ed321,color:#fff
    style Unitxt fill:#7ed321,color:#fff
    style OpController fill:#f5a623,color:#fff
    style LMEvalJobCR fill:#f5a623,color:#fff
    style ConfigMap fill:#f5a623,color:#fff
    style InferenceEndpoint fill:#e8e8e8,stroke:#333
    style EvalHub fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
