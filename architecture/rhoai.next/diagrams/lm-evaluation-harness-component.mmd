graph TB
    subgraph Operator["trustyai-service-operator"]
        LMEvalJobCR["LMEvalJob CR"]
    end

    subgraph JobPod["lm-evaluation-harness (Batch Job Pod)"]
        direction TB

        subgraph Adapter["EvalHub Adapter (main.py)"]
            JobLoader["JobSpec Loader<br/>Reads /meta/job.json"]
            StatusReporter["Status Reporter<br/>Phase callbacks"]
            ResultPublisher["Result Publisher<br/>OCI + MLflow"]
        end

        subgraph CoreLib["lm_eval Core Library"]
            Evaluator["simple_evaluate()<br/>Evaluation orchestrator"]
            TaskManager["Task Manager<br/>6,500+ YAML tasks"]
            MetricsEngine["Metrics Engine<br/>117 metrics"]
            CacheManager["Cache Manager<br/>SHA-256 keyed"]
        end

        subgraph ModelBackends["Model Backend (Registry Pattern)"]
            LocalCompletions["local-completions<br/>Primary RHOAI backend"]
            TemplateAPI["TemplateAPI Base<br/>Async HTTP client<br/>num_concurrent: 1-128"]
        end

        subgraph Integrations["Integrations"]
            Unitxt["Unitxt Module<br/>Custom task definitions"]
        end
    end

    ConfigMap["ConfigMap<br/>/meta/job.json"] -->|mounted| JobLoader
    LMEvalJobCR -->|creates Job| JobPod
    JobLoader -->|configures| Evaluator
    Evaluator -->|loads| TaskManager
    Evaluator -->|computes| MetricsEngine
    Evaluator -->|uses| CacheManager
    Evaluator -->|sends prompts via| LocalCompletions
    LocalCompletions -->|extends| TemplateAPI
    TaskManager -.->|optional| Unitxt
    StatusReporter -->|reports phases| EvalHub["EvalHub Service"]
    ResultPublisher -->|pushes artifacts| OCIRegistry["OCI Registry"]
    ResultPublisher -->|logs metrics| MLflow["MLflow Server"]
    TemplateAPI -->|POST /v1/completions| InferenceEndpoint["Model Inference Endpoint"]
    Evaluator -->|downloads datasets| HFHub["HuggingFace Hub"]

    style JobPod fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Adapter fill:#d5e8d4,stroke:#82b366
    style CoreLib fill:#fff2cc,stroke:#d6b656
    style ModelBackends fill:#f8cecc,stroke:#b85450
    style Integrations fill:#e1d5e7,stroke:#9673a6
    style LMEvalJobCR fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333
    style OCIRegistry fill:#7ed321,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style InferenceEndpoint fill:#7ed321,stroke:#333
    style HFHub fill:#999,stroke:#333
