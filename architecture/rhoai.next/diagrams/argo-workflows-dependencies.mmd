graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"CRD mgmt, Pod creation<br/>HTTPS/443"| K8s["Kubernetes 1.32+"]

    %% External Dependencies (Optional)
    ArgoWF -->|"artifact storage<br/>HTTPS/443"| S3["S3-compatible Storage"]
    ArgoWF -->|"artifact storage<br/>HTTPS/443"| GCS["GCS"]
    ArgoWF -->|"artifact storage<br/>HTTPS/443"| Azure["Azure Blob Storage"]
    ArgoWF -->|"artifact storage<br/>TCP/8020"| HDFS["HDFS"]
    ArgoWF -->|"workflow archiving<br/>TCP/5432"| PostgreSQL["PostgreSQL 10+"]
    ArgoWF -->|"workflow archiving<br/>TCP/3306"| MySQL["MySQL 5.7+"]

    %% Internal Platform Dependencies
    DSPOperator["DSP Operator"] -->|"deploys & configures<br/>image reference"| ArgoWF
    DSPAPIServer["DSP API Server"] -->|"creates Workflow CRs<br/>HTTPS/443"| ArgoWF
    MariaDB["MariaDB (DSP)"] ---|"SQL persistence<br/>TCP/3306"| ArgoWF
    ObjStorage["Object Storage (DSP)<br/>S3/MinIO"] ---|"artifact persistence<br/>HTTPS/443"| ArgoWF

    %% Integration Points (consumers)
    ArgoWF ---|"metrics scrape<br/>HTTP(S)/9090"| Prometheus["Prometheus"]
    ArgoWF -->|"K8s events<br/>HTTPS/443"| K8sEvents["Kubernetes Events"]
    ArgoWF -->|"concurrency limits<br/>HTTPS/443"| Semaphore["ConfigMap (semaphore)"]
    ArgoWF -.->|"executor plugins<br/>HTTP (configurable)"| Plugins["Executor Plugins<br/>(optional)"]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style K8s fill:#999,stroke:#333,color:#fff

    %% External optional
    style S3 fill:#bbb,stroke:#333
    style GCS fill:#bbb,stroke:#333
    style Azure fill:#bbb,stroke:#333
    style HDFS fill:#bbb,stroke:#333
    style PostgreSQL fill:#bbb,stroke:#333
    style MySQL fill:#bbb,stroke:#333

    %% Internal RHOAI
    style DSPOperator fill:#7ed321,stroke:#333
    style DSPAPIServer fill:#7ed321,stroke:#333
    style MariaDB fill:#7ed321,stroke:#333
    style ObjStorage fill:#7ed321,stroke:#333

    %% Integration
    style Prometheus fill:#f5a623,stroke:#333
    style K8sEvents fill:#f5a623,stroke:#333
    style Semaphore fill:#f5a623,stroke:#333
    style Plugins fill:#f5a623,stroke:#333
