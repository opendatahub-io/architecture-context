graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% Internal RHOAI Dependencies
    ArgoWF -.->|"deployed by"| DSPOperator["Data Science Pipelines<br/>Operator"]
    DSPAPIServer["DSP API Server"] -->|"creates Workflow CRs"| ArgoWF

    %% Kubernetes Infrastructure
    ArgoWF -->|"CRD Watch<br/>Pod CRUD<br/>PVC CRUD<br/>ConfigMap R/W<br/>PDB CRUD<br/>Event creation<br/>Lease mgmt<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server 1.32+"]

    %% External Dependencies - Storage
    ArgoWF -->|"artifact storage<br/>443/TCP HTTPS<br/>IAM/AccessKey"| S3["S3-compatible<br/>(MinIO/AWS S3)"]
    ArgoWF -.->|"artifact storage<br/>443/TCP HTTPS<br/>GCP IAM"| GCS["Google Cloud<br/>Storage"]
    ArgoWF -.->|"artifact storage<br/>443/TCP HTTPS<br/>Azure AD"| Azure["Azure Blob<br/>Storage"]
    ArgoWF -.->|"artifact storage"| HDFS["HDFS"]
    ArgoWF -.->|"artifact storage"| OSS["Alibaba Cloud<br/>OSS"]

    %% External Dependencies - Database
    ArgoWF -.->|"workflow archival<br/>3306/TCP<br/>Password"| MySQL["MySQL 5.7+"]
    ArgoWF -.->|"workflow archival<br/>5432/TCP<br/>Password"| PostgreSQL["PostgreSQL 12+"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>9090/TCP HTTP"| ArgoWF

    %% CRDs
    subgraph CRDs["Argo CRDs (argoproj.io/v1alpha1)"]
        Workflow["Workflow"]
        CronWorkflow["CronWorkflow"]
        WorkflowTemplate["WorkflowTemplate"]
        ClusterWFTemplate["ClusterWorkflow<br/>Template"]
        WorkflowTaskSet["WorkflowTaskSet"]
        WorkflowTaskResult["WorkflowTaskResult"]
        WorkflowArtifactGC["WorkflowArtifact<br/>GCTask"]
        WorkflowEventBinding["WorkflowEvent<br/>Binding"]
    end

    ArgoWF -->|"watches/manages"| CRDs

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DSPOperator fill:#7ed321,stroke:#333,color:#fff
    style DSPAPIServer fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style HDFS fill:#f5a623,stroke:#333
    style OSS fill:#f5a623,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#666
    style Workflow fill:#f5d623,stroke:#333
    style CronWorkflow fill:#f5d623,stroke:#333
    style WorkflowTemplate fill:#f5d623,stroke:#333
    style ClusterWFTemplate fill:#f5d623,stroke:#333
    style WorkflowTaskSet fill:#f5d623,stroke:#333
    style WorkflowTaskResult fill:#f5d623,stroke:#333
    style WorkflowArtifactGC fill:#f5d623,stroke:#333
    style WorkflowEventBinding fill:#f5d623,stroke:#333
