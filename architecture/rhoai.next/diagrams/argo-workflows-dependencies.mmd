graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"container orchestration<br/>443/TCP HTTPS"| K8s["Kubernetes 1.32+"]

    %% Internal RHOAI Dependencies
    DSP["data-science-pipelines-operator"] -->|"deploys & configures<br/>CRD/Deployment"| ArgoWF

    %% Artifact Storage (Primary)
    ArgoWF -->|"artifact I/O<br/>443/TCP S3 API"| S3["S3 / Minio"]

    %% Artifact Storage (Alternative)
    ArgoWF -.->|"artifact I/O<br/>443/TCP HTTPS"| GCS["GCS"]
    ArgoWF -.->|"artifact I/O<br/>443/TCP HTTPS"| Azure["Azure Blob Storage"]
    ArgoWF -.->|"artifact I/O<br/>443/TCP HTTPS"| OSS["Alibaba OSS"]

    %% Artifact Sources (Optional)
    ArgoWF -.->|"git artifacts<br/>22/TCP SSH or 443/TCP HTTPS"| Git["Git Repositories"]
    ArgoWF -.->|"HDFS artifacts<br/>9000/TCP Hadoop RPC"| HDFS["HDFS"]
    ArgoWF -.->|"HTTP artifacts<br/>443/TCP HTTPS"| HTTP["HTTP / Artifactory"]

    %% Optional Data Services
    ArgoWF -.->|"workflow archive<br/>5432/TCP PostgreSQL"| PostgreSQL["PostgreSQL 13+"]
    ArgoWF -.->|"workflow archive<br/>3306/TCP MySQL"| MySQL["MySQL 8.0+"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scrape<br/>9090/TCP HTTP"| ArgoWF

    %% Leader Election
    ArgoWF -->|"leader election<br/>Lease API 443/TCP"| K8s

    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style Azure fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style OSS fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style Git fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style HDFS fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style HTTP fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5
    style PostgreSQL fill:#ffe6cc,stroke:#d79b00
    style MySQL fill:#ffe6cc,stroke:#d79b00
    style Prometheus fill:#f8cecc,stroke:#b85450
