graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"CRD hosting<br/>pod execution<br/>HTTPS/443"| K8s["Kubernetes 1.24+"]

    %% External Dependencies (Optional)
    ArgoWF -.->|"workflow archival<br/>TCP/5432"| PostgreSQL["PostgreSQL 12+<br/>(optional)"]
    ArgoWF -.->|"workflow archival<br/>TCP/3306"| MySQL["MySQL 5.7+<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| S3["S3-compatible Storage<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| GCS["GCS Storage<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| AzureBlob["Azure Blob Storage<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>RPC/8020"| HDFS["HDFS<br/>(optional)"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys & configures"| ArgoWF

    %% Integration Points (inbound)
    DSPApi["Data Science Pipelines API"] -->|"creates Workflow CRs"| ArgoWF
    ArgoEvents["Argo Events<br/>(optional)"] -.->|"triggers via<br/>WorkflowEventBinding"| ArgoWF

    %% Integration Points (outbound)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| ArgoWF

    %% Kubernetes Resources Created
    ArgoWF -->|"creates"| StepPods["Workflow Step Pods"]
    ArgoWF -->|"creates"| PVCs["PersistentVolumeClaims"]
    ArgoWF -->|"creates"| PDBs["PodDisruptionBudgets"]
    ArgoWF -->|"manages"| Leases["Leases<br/>(leader election)"]
    ArgoWF -->|"manages"| ConfigMaps["ConfigMaps<br/>(semaphore locks)"]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style AzureBlob fill:#f5a623,stroke:#333
    style HDFS fill:#f5a623,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style DSPApi fill:#7ed321,stroke:#333
    style ArgoEvents fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#333
    style StepPods fill:#d5e8d4,stroke:#333
    style PVCs fill:#d5e8d4,stroke:#333
    style PDBs fill:#d5e8d4,stroke:#333
    style Leases fill:#d5e8d4,stroke:#333
    style ConfigMaps fill:#d5e8d4,stroke:#333
