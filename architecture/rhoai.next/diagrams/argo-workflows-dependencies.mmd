graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"CRUD Pods/Workflows<br/>443/TCP HTTPS"| K8s["Kubernetes 1.32+"]

    %% External Dependencies (Optional)
    ArgoWF -.->|"workflow archive<br/>5432/TCP"| PostgreSQL["PostgreSQL 13+<br/>(optional)"]
    ArgoWF -.->|"workflow archive<br/>3306/TCP"| MySQL["MySQL 8.0+<br/>(optional)"]

    %% Artifact Storage Backends
    ArgoWF -->|"artifact I/O<br/>443/TCP S3 API"| S3["S3 / Minio<br/>(primary for RHOAI)"]
    ArgoWF -.->|"artifact I/O<br/>443/TCP"| GCS["Google Cloud Storage<br/>(alternative)"]
    ArgoWF -.->|"artifact I/O<br/>443/TCP"| Azure["Azure Blob Storage<br/>(alternative)"]
    ArgoWF -.->|"artifact I/O<br/>9000/TCP"| HDFS["HDFS<br/>(alternative)"]
    ArgoWF -.->|"artifact clone<br/>22/443 TCP"| Git["Git Repositories<br/>(alternative)"]

    %% Internal Platform Dependencies
    DSP["data-science-pipelines-<br/>operator"] -->|"deploys & configures"| ArgoWF
    DSP -->|"creates Workflow CRs"| ArgoWF

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>9090/TCP HTTP"| ArgoWF

    %% Leader Election
    ArgoWF -->|"leader election<br/>Lease API 443/TCP"| K8s

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style MySQL fill:#4479a1,stroke:#333,color:#fff
    style S3 fill:#e25d33,stroke:#333,color:#fff
    style GCS fill:#4285f4,stroke:#333,color:#fff
    style Azure fill:#0089d6,stroke:#333,color:#fff
    style HDFS fill:#66ccff,stroke:#333
    style Git fill:#f05032,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
