graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% Required External Dependencies
    ArgoWF -->|"CRUD: Pods, Workflows, CRDs<br/>HTTPS/443"| K8s["Kubernetes 1.32+"]

    %% Optional External Dependencies
    ArgoWF -->|"artifact storage<br/>S3 API HTTPS/443"| S3["S3 / Minio"]
    ArgoWF -->|"workflow archive<br/>5432/TCP"| PostgreSQL["PostgreSQL 13+<br/>(Optional)"]
    ArgoWF -.->|"workflow archive<br/>3306/TCP"| MySQL["MySQL 8.0+<br/>(Optional alt)"]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| GCS["GCS<br/>(Optional)"]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| Azure["Azure Blob<br/>(Optional)"]
    ArgoWF -.->|"artifact cloning<br/>SSH/22 or HTTPS/443"| Git["Git Repos<br/>(Optional)"]
    ArgoWF -.->|"artifact storage<br/>Hadoop RPC/9000"| HDFS["HDFS<br/>(Optional)"]

    %% Internal RHOAI Dependencies
    DSP["data-science-pipelines-operator"] -->|"deploys & configures<br/>CRD/Deployment"| ArgoWF
    DSP -->|"creates Workflow CRs<br/>for pipeline runs"| ArgoWF

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/9090"| ArgoWF

    %% Kubernetes subsystems
    ArgoWF -->|"leader election<br/>Lease API HTTPS/443"| LeaseAPI["Kubernetes Lease API"]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style S3 fill:#e8913a,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style MySQL fill:#4479a1,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style Azure fill:#999,stroke:#333,color:#fff
    style Git fill:#999,stroke:#333,color:#fff
    style HDFS fill:#999,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style LeaseAPI fill:#326ce5,stroke:#333,color:#fff
