graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller +<br/>argo-server + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"API server<br/>6443/TCP HTTPS"| K8s["Kubernetes v1.32+"]

    %% External Dependencies (Optional)
    ArgoWF -->|"archival<br/>5432/TCP"| PostgreSQL["PostgreSQL 12+"]
    ArgoWF -->|"archival<br/>3306/TCP"| MySQL["MySQL 5.7+"]
    ArgoWF -->|"artifact storage<br/>9000/TCP HTTPS"| S3["S3 / MinIO"]
    ArgoWF -->|"SSO auth<br/>443/TCP HTTPS"| OIDC["OIDC Provider"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator"] -->|"deploys &<br/>configures"| ArgoWF
    ArgoWF -.->|"artifact storage"| MinIO["MinIO<br/>(RHOAI-managed)"]
    ArgoWF -.->|"archival"| MariaDB["MariaDB<br/>(RHOAI-managed)"]

    %% Integration Points (inbound)
    Dashboard["ODH Dashboard"] -.->|"UI / API access<br/>2746/TCP HTTPS"| ArgoWF
    DSP["Data Science Pipelines<br/>API"] -->|"submits Workflows<br/>via K8s API"| ArgoWF
    ArgoEvt["Argo Events<br/>(EventSource/Sensor)"] -->|"event-triggered<br/>workflow creation"| ArgoWF
    GitHub["GitHub / GitLab /<br/>Bitbucket"] -->|"webhook<br/>2746/TCP HTTPS"| ArgoWF

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>9090 + 2746/TCP"| ArgoWF

    %% Executor Plugins
    ArgoWF -.->|"plugin execution<br/>gRPC"| Plugins["Executor Plugins"]

    %% Artifact storage backends (additional)
    ArgoWF -.->|"443/TCP HTTPS"| GCS["Google Cloud<br/>Storage"]
    ArgoWF -.->|"443/TCP HTTPS"| Azure["Azure Blob<br/>Storage"]
    ArgoWF -.->|"22/443/TCP"| Git["Git Repositories"]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8s fill:#999,stroke:#333,color:#fff

    %% Optional external
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OIDC fill:#999,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style Git fill:#f5a623,stroke:#333

    %% Internal RHOAI
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style MinIO fill:#7ed321,stroke:#333,color:#fff
    style MariaDB fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style ArgoEvt fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style GitHub fill:#f5a623,stroke:#333
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style Plugins fill:#e8e8e8,stroke:#333
