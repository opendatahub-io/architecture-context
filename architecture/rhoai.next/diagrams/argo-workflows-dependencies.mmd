graph LR
    ArgoWF["Argo Workflows<br/>(workflow-controller + argoexec)"]

    %% External Dependencies (Required)
    ArgoWF -->|"container orchestration<br/>CRD hosting, pod execution"| K8s["Kubernetes 1.24+"]

    %% External Dependencies (Optional)
    ArgoWF -.->|"workflow archival<br/>node status offloading"| PostgreSQL["PostgreSQL 12+<br/>(optional)"]
    ArgoWF -.->|"workflow archival<br/>(alternative)"| MySQL["MySQL 5.7+<br/>(optional)"]
    ArgoWF -.->|"artifact storage<br/>(S3, GCS, Azure, HDFS)"| S3["S3-compatible Storage<br/>(optional)"]

    %% Internal RHOAI Dependencies
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"] -->|"deploys & configures<br/>manages lifecycle"| ArgoWF
    ArgoWF -->|"CRD CRUD, pod mgmt<br/>leader election (Lease)"| K8sAPI["Kubernetes API Server"]

    %% Integration Points - Inbound
    DSPApi["DSP API"] -->|"submits workflows<br/>via Workflow CRDs"| ArgoWF
    ArgoEvents["Argo Events<br/>(optional)"] -.->|"event-driven triggers<br/>WorkflowEventBinding"| ArgoWF

    %% Integration Points - Outbound
    ArgoWF -->|"metrics scraping<br/>HTTP/9090"| Prometheus["Prometheus"]

    %% Resource Management
    ArgoWF -->|"creates/manages"| PDB["PodDisruptionBudgets"]
    ArgoWF -->|"creates/manages"| PVC["PersistentVolumeClaims"]
    ArgoWF -->|"parallelism control<br/>semaphore locks"| ConfigMap["ConfigMap (semaphore)"]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
    style DSPApi fill:#7ed321,stroke:#333
    style ArgoEvents fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e1d5e7,stroke:#9673a6
    style PDB fill:#dae8fc,stroke:#6c8ebf
    style PVC fill:#dae8fc,stroke:#6c8ebf
    style ConfigMap fill:#dae8fc,stroke:#6c8ebf
