graph TB
    subgraph Trainer["Kubeflow Trainer Operator"]
        direction TB
        subgraph ControllerManager["trainer-controller-manager (Go)"]
            Controller["TrainJob Controller<br/>Reconciler"]
            RTController["TrainingRuntime Controller<br/>Reconciler"]
            CRTController["ClusterTrainingRuntime Controller<br/>Reconciler"]
            Webhook["Webhook Server<br/>9443/TCP HTTPS"]
            Metrics["Metrics Server<br/>8443/TCP HTTPS"]
            Health["Health Probes<br/>8081/TCP HTTP"]

            subgraph PluginFramework["Plugin Framework"]
                PyTorch["PyTorch Plugin<br/>(torchrun/torchtune)"]
                MPI["MPI Plugin<br/>(OpenMPI)"]
                PlainML["PlainML Plugin<br/>(Generic)"]
                CoSched["CoScheduling Plugin"]
                VolcanoPlugin["Volcano Plugin"]
                JobSetPlugin["JobSet Plugin<br/>(Component Builder)"]
            end

            subgraph RHAI["RHAI Features (RHOAI)"]
                Progression["Progression Tracker<br/>HTTP poll 28080/TCP"]
                NetPolicy["NetworkPolicy Enforcer"]
            end

            Controller --> PluginFramework
            Controller --> RHAI
        end

        subgraph DataCache["Data Cache (Rust, Optional)"]
            Head["Head Node<br/>Arrow Flight gRPC"]
            Worker["Worker Nodes<br/>Arrow Flight gRPC"]
            Head -->|"do_put<br/>distribute data"| Worker
        end

        subgraph InitContainers["Init Containers (Go)"]
            DatasetInit["dataset-initializer"]
            ModelInit["model-initializer"]
        end
    end

    %% Custom Resources
    User["Data Scientist"] -->|"creates"| TrainJobCR["TrainJob CR"]
    Admin["Platform Admin"] -->|"defines"| CTRCR["ClusterTrainingRuntime CR"]
    Admin -->|"defines"| TRCR["TrainingRuntime CR"]

    TrainJobCR -->|"watched by"| Controller
    CTRCR -->|"watched by"| CRTController
    TRCR -->|"watched by"| RTController
    TrainJobCR -->|"references"| CTRCR
    TrainJobCR -->|"references"| TRCR

    %% Controller outputs
    JobSetPlugin -->|"creates"| JobSet["JobSet Resource"]
    CoSched -->|"creates"| PodGroup["PodGroup<br/>(CoScheduling)"]
    VolcanoPlugin -->|"creates"| VPodGroup["PodGroup<br/>(Volcano)"]
    MPI -->|"creates"| SSHSecret["SSH Key Secret<br/>(ECDSA P521)"]

    %% JobSet creates training pods
    JobSet -->|"orchestrates"| TrainingPods["Training Pods<br/>(PyTorch/MPI)"]
    TrainingPods -->|"use"| DatasetInit
    TrainingPods -->|"use"| ModelInit

    %% RHAI interactions
    Progression -->|"polls metrics<br/>28080/TCP"| TrainingPods
    NetPolicy -->|"restricts network"| TrainingPods

    %% Data cache interactions
    TrainingPods -.->|"query data<br/>Arrow Flight"| Worker

    %% External dependencies
    Controller -->|"443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    Controller -->|"CRD watch"| JobSetCtrl["JobSet Controller"]

    %% Webhook
    K8sAPI -->|"validates"| Webhook

    %% Monitoring
    Prometheus["Prometheus<br/>OpenShift Monitoring"] -->|"scrapes<br/>8443/TCP HTTPS"| Metrics

    %% Iceberg
    Head -.->|"reads metadata"| Iceberg["Iceberg Metadata<br/>(S3/HTTP)"]

