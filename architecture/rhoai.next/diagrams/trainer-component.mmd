graph TB
    subgraph Trainer["Kubeflow Trainer V2"]
        direction TB
        Controller["trainer-controller-manager<br/><i>Go Operator (controller-runtime)</i>"]
        Webhooks["Validating Webhooks<br/><i>9443/TCP HTTPS</i>"]
        PluginFramework["Runtime Plugin Framework"]

        subgraph Plugins["ML Policy Plugins"]
            TorchPlugin["Torch Plugin"]
            MPIPlugin["MPI Plugin"]
            PlainMLPlugin["PlainML Plugin"]
        end

        subgraph Schedulers["Gang-Scheduling Plugins"]
            CoScheduling["CoScheduling Plugin"]
            VolcanoPlugin["Volcano Plugin"]
        end

        subgraph Builders["Resource Builder Plugins"]
            JobSetBuilder["JobSet Builder"]
        end

        Controller --> PluginFramework
        PluginFramework --> Plugins
        PluginFramework --> Schedulers
        PluginFramework --> Builders
        Controller -->|validates via| Webhooks
    end

    %% CRDs
    User["User / Dashboard"] -->|creates| TrainJobCR["TrainJob CR<br/><i>trainer.kubeflow.org/v1alpha1</i>"]
    TrainJobCR -->|watched by| Controller
    Controller -->|resolves| TrainingRuntimeCR["TrainingRuntime CR<br/><i>Namespaced</i>"]
    Controller -->|resolves| ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/><i>Cluster-scoped</i>"]

    %% Created Resources
    Controller -->|creates| JobSetCR["JobSet CR<br/><i>jobset.x-k8s.io/v1alpha2</i>"]
    Controller -->|creates| PodGroupCR["PodGroup CR<br/><i>(CoScheduling or Volcano)</i>"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy<br/><i>(RHAI progression)</i>"]
    MPIPlugin -->|creates| SSHSecret["SSH Secret<br/><i>ECDSA keypair</i>"]
    MPIPlugin -->|creates| HostfileCM["Hostfile ConfigMap"]

    %% RHOAI-specific
    subgraph RHOAI["RHOAI Enhancements"]
        Progression["Progression Tracking<br/><i>Polls 2113/TCP</i>"]
        RHOAIRuntimes["Pre-configured<br/>ClusterTrainingRuntimes<br/><i>CUDA / ROCm / CPU</i>"]
        ImageStreams["OpenShift ImageStreams<br/><i>Training Hub images</i>"]
    end

    Controller -->|RHAI features| Progression
    Progression -->|reads metrics| TrainingPod["Training Pod<br/><i>2113/TCP HTTP</i>"]

    %% External Dependencies
    JobSetCR -->|reconciled by| JobSetController["JobSet Controller"]
    JobSetController -->|creates| Jobs["Jobs / Pods"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Webhooks fill:#4a90e2,stroke:#333,color:#fff
    style PluginFramework fill:#5ba3d9,stroke:#333,color:#fff
    style TorchPlugin fill:#6db3e8,stroke:#333
    style MPIPlugin fill:#6db3e8,stroke:#333
    style PlainMLPlugin fill:#6db3e8,stroke:#333
    style CoScheduling fill:#9b59b6,stroke:#333,color:#fff
    style VolcanoPlugin fill:#9b59b6,stroke:#333,color:#fff
    style JobSetBuilder fill:#27ae60,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style TrainingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333
    style JobSetCR fill:#f5a623,stroke:#333
    style PodGroupCR fill:#f5a623,stroke:#333
    style NetworkPolicy fill:#e74c3c,stroke:#333,color:#fff
    style SSHSecret fill:#e74c3c,stroke:#333,color:#fff
    style Progression fill:#2ecc71,stroke:#333
    style RHOAIRuntimes fill:#2ecc71,stroke:#333
    style ImageStreams fill:#2ecc71,stroke:#333
    style JobSetController fill:#999,stroke:#333,color:#fff
    style User fill:#ecf0f1,stroke:#333
