graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        Controller["trainer-controller-manager<br/>Go Operator (controller-runtime)<br/>Ports: 9443, 8443, 8081"]
        Webhook["Validating Webhooks<br/>9443/TCP HTTPS"]
        RuntimeFramework["Runtime Plugin Framework"]
        RHAI["RHAI Progression Tracking<br/>Controller Extension"]

        Controller -->|runs| Webhook
        Controller -->|uses| RuntimeFramework
        Controller -->|extends| RHAI
    end

    subgraph Plugins["Plugin Framework"]
        TorchPlugin["PyTorch Plugin"]
        MPIPlugin["MPI Plugin"]
        TorchTunePlugin["TorchTune Plugin"]
        PlainMLPlugin["PlainML Plugin"]
        JobSetPlugin["JobSet Plugin"]
        VolcanoPlugin["Volcano Plugin"]
        CoSchedPlugin["CoScheduling Plugin"]

        RuntimeFramework --> TorchPlugin
        RuntimeFramework --> MPIPlugin
        RuntimeFramework --> TorchTunePlugin
        RuntimeFramework --> PlainMLPlugin
        RuntimeFramework --> JobSetPlugin
        RuntimeFramework --> VolcanoPlugin
        RuntimeFramework --> CoSchedPlugin
    end

    %% CRDs
    User["Data Scientist / API Client"] -->|creates| TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1alpha1"]
    Admin["Cluster Admin"] -->|creates| ClusterRuntimeCR["ClusterTrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]
    Admin -->|creates| RuntimeCR["TrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]

    TrainJobCR -->|watched by| Controller
    TrainJobCR -->|references| RuntimeCR
    TrainJobCR -->|references| ClusterRuntimeCR
    RuntimeCR -->|watched by| Controller
    ClusterRuntimeCR -->|watched by| Controller

    %% Created Resources
    Controller -->|creates| JobSet["JobSet<br/>jobset.x-k8s.io/v1alpha2"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy<br/>(per TrainJob, RHOAI)"]
    Controller -->|creates| PodGroup["PodGroup<br/>(Volcano/CoScheduling)"]
    MPIPlugin -->|creates| SSHSecret["SSH Secret<br/>ECDSA P521 Key Pair"]
    MPIPlugin -->|creates| Hostfile["Hostfile ConfigMap"]

    %% External Dependencies
    Controller -->|watches/CRUD| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    RHAI -->|polls metrics| TrainingPod["Training Pod (rank-0)<br/>28080/TCP HTTP"]

    %% Monitoring
    Prometheus["Prometheus<br/>(PodMonitor)"] -->|scrapes| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style RuntimeFramework fill:#4a90e2,stroke:#333,color:#fff
    style RHAI fill:#e67e22,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style ClusterRuntimeCR fill:#f5a623,stroke:#333
    style RuntimeCR fill:#f5a623,stroke:#333
    style JobSet fill:#7ed321,stroke:#333
    style NetworkPolicy fill:#7ed321,stroke:#333
    style PodGroup fill:#7ed321,stroke:#333
