graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        Controller["trainer-controller-manager<br/>(Go / controller-runtime)<br/>Ports: 9443, 8443, 8081"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>TLS auto-rotated"]
        Metrics["Metrics Server<br/>8443/TCP HTTPS<br/>TLS 1.2+"]
        Health["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]
        CertMgmt["cert-controller<br/>Auto cert rotation"]
        Controller --- Webhook
        Controller --- Metrics
        Controller --- Health
        CertMgmt -->|rotates certs| Webhook
    end

    subgraph DataCache["Data Cache (Optional)"]
        CacheService["data_cache<br/>(Rust Service)"]
    end

    User["Data Scientist / User"] -->|"kubectl create"| TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    TrainJobCR -->|"watched by"| Controller

    Admin["Platform Admin"] -->|"creates"| RuntimeCR["TrainingRuntime /<br/>ClusterTrainingRuntime CR"]
    RuntimeCR -->|"referenced by"| Controller

    Controller -->|"validates"| Webhook
    Controller -->|"creates"| JobSetCR["JobSet CR<br/>(jobset.x-k8s.io/v1alpha2)"]
    Controller -->|"creates (RHAI)"| NetworkPolicyCR["NetworkPolicy<br/>(networking.k8s.io)"]
    Controller -->|"creates (optional)"| PodGroupCR["PodGroup CR<br/>(scheduling.x-k8s.io /<br/>scheduling.volcano.sh)"]
    Controller -->|"creates (MPI)"| MPISecret["SSH Keys Secret"]
    Controller -->|"creates (MPI)"| MPIConfigMap["Hostfile ConfigMap"]

    Controller -->|"polls /metrics<br/>28080/TCP HTTP"| TrainingPod["Training Pod<br/>(rank 0)"]
    Controller -->|"HTTPS 443/TCP"| K8sAPI["Kubernetes API Server"]

    JobSetCtrl["JobSet Controller"] -->|"watches"| JobSetCR
    JobSetCtrl -->|"manages"| TrainingPods["Training Pods"]

    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8443/TCP HTTPS"| Metrics

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style Health fill:#4a90e2,stroke:#333,color:#fff
    style CertMgmt fill:#4a90e2,stroke:#333,color:#fff
    style CacheService fill:#9b59b6,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style RuntimeCR fill:#f5a623,stroke:#333
    style JobSetCR fill:#f5a623,stroke:#333
    style NetworkPolicyCR fill:#f5a623,stroke:#333
    style PodGroupCR fill:#f5a623,stroke:#333
    style MPISecret fill:#e74c3c,stroke:#333,color:#fff
    style MPIConfigMap fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style JobSetCtrl fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style TrainingPod fill:#3498db,stroke:#333,color:#fff
    style TrainingPods fill:#3498db,stroke:#333,color:#fff
