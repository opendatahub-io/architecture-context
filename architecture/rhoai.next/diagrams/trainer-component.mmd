graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        direction TB
        Controller["trainer-controller-manager<br/>(Go Operator / controller-runtime)"]

        subgraph Plugins["Runtime Plugin Framework"]
            direction LR
            TorchPlugin["Torch Plugin<br/>(torchrun/torchtune)"]
            MPIPlugin["MPI Plugin<br/>(OpenMPI / SSH)"]
            CoschedulingPlugin["Coscheduling Plugin<br/>(scheduler-plugins)"]
            VolcanoPlugin["Volcano Plugin<br/>(PodGroup)"]
            JobSetPlugin["JobSet Plugin<br/>(workload orchestration)"]
            PlainMLPlugin["PlainML Plugin<br/>(basic ML policy)"]
        end

        subgraph RHAIFeatures["RHOAI-Specific Features"]
            direction LR
            Progression["RHAI Progression Tracking<br/>(HTTP metrics polling)"]
            NetPolicy["RHAI NetworkPolicy<br/>(per-TrainJob isolation)"]
        end

        subgraph Webhooks["Validating Webhooks (9443/TCP TLS)"]
            direction LR
            WH_TrainJob["TrainJob Validator"]
            WH_Runtime["TrainingRuntime Validator"]
            WH_ClusterRuntime["ClusterTrainingRuntime Validator"]
        end

        Controller --> Plugins
        Controller --> RHAIFeatures
        Controller --> Webhooks
    end

    %% CRDs
    User["User / SDK"] -->|creates| TrainJobCR["TrainJob CR<br/>(trainer.kubeflow.org/v1alpha1)"]
    TrainJobCR -->|watched by| Controller
    RuntimeCR["TrainingRuntime /<br/>ClusterTrainingRuntime CR"] -->|referenced by| TrainJobCR
    RuntimeCR -->|watched by| Controller

    %% Created Resources
    Controller -->|creates via JobSet plugin| JobSetCR["JobSet CR<br/>(jobset.x-k8s.io/v1alpha2)"]
    Controller -->|creates via Coscheduling plugin| PodGroupSched["PodGroup CR<br/>(scheduling.x-k8s.io)"]
    Controller -->|creates via Volcano plugin| PodGroupVolcano["PodGroup CR<br/>(scheduling.volcano.sh)"]
    MPIPlugin -->|creates| SSHSecret["SSH Secret<br/>(ECDSA P-521 key pair)"]
    MPIPlugin -->|creates| Hostfile["Hostfile ConfigMap"]
    NetPolicy -->|creates| NetworkPolicyCR["NetworkPolicy<br/>(per-TrainJob isolation)"]

    %% External Dependencies
    Controller -->|depends on| JobSetCtrl["JobSet Controller"]
    Controller -->|depends on| CertController["cert-controller<br/>(webhook TLS certs)"]
    Progression -->|polls :28080/HTTP| TrainingPods["Training Pods"]

    %% Platform Integration
    JobSetCR -->|managed by| JobSetCtrl
    JobSetCtrl -->|creates| TrainingPods
    Prometheus["Prometheus"] -->|scrapes :8443/HTTPS| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style TorchPlugin fill:#6bb5e0,stroke:#333
    style MPIPlugin fill:#6bb5e0,stroke:#333
    style CoschedulingPlugin fill:#6bb5e0,stroke:#333
    style VolcanoPlugin fill:#6bb5e0,stroke:#333
    style JobSetPlugin fill:#6bb5e0,stroke:#333
    style PlainMLPlugin fill:#6bb5e0,stroke:#333
    style Progression fill:#e8a838,stroke:#333
    style NetPolicy fill:#e8a838,stroke:#333
    style WH_TrainJob fill:#9b59b6,stroke:#333,color:#fff
    style WH_Runtime fill:#9b59b6,stroke:#333,color:#fff
    style WH_ClusterRuntime fill:#9b59b6,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style RuntimeCR fill:#f5a623,stroke:#333
    style JobSetCR fill:#7ed321,stroke:#333
    style PodGroupSched fill:#7ed321,stroke:#333
    style PodGroupVolcano fill:#7ed321,stroke:#333
    style SSHSecret fill:#7ed321,stroke:#333
    style Hostfile fill:#7ed321,stroke:#333
    style NetworkPolicyCR fill:#7ed321,stroke:#333
    style JobSetCtrl fill:#999,stroke:#333
    style CertController fill:#999,stroke:#333
    style TrainingPods fill:#e74c3c,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333
