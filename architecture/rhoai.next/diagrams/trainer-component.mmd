graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        direction TB
        Controller["trainer-controller-manager<br/><i>Go Operator (controller-runtime)</i><br/>Ports: 9443, 8443, 8081"]
        Webhook["Validating Webhooks<br/><i>3 webhooks (TrainJob, TrainingRuntime,<br/>ClusterTrainingRuntime)</i><br/>Port: 9443/TCP TLS"]
        ProgressionTracker["RHAI Progression Tracker<br/><i>Real-time training metrics polling</i>"]
        NetworkPolicyMgr["NetworkPolicy Manager<br/><i>RHAI pod isolation</i>"]
        CertController["cert-controller (OPA)<br/><i>Auto webhook cert rotation</i>"]

        Controller --> Webhook
        Controller --> ProgressionTracker
        Controller --> NetworkPolicyMgr
        Controller --> CertController
    end

    subgraph CRDs["Custom Resource Definitions"]
        TrainJobCR["TrainJob CR<br/><i>trainer.kubeflow.org/v1alpha1</i><br/>Namespaced"]
        TrainingRuntimeCR["TrainingRuntime CR<br/><i>trainer.kubeflow.org/v1alpha1</i><br/>Namespaced"]
        ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/><i>trainer.kubeflow.org/v1alpha1</i><br/>Cluster-scoped"]
    end

    subgraph DynamicResources["Dynamically Created Resources"]
        JobSetRes["JobSet<br/><i>jobset.x-k8s.io/v1alpha2</i>"]
        NetworkPolicyRes["NetworkPolicy<br/><i>networking.k8s.io/v1</i>"]
        PodGroupRes["PodGroup<br/><i>scheduling.x-k8s.io /<br/>scheduling.volcano.sh</i>"]
        MPISecret["MPI SSH Secret<br/><i>RSA key pair</i>"]
        MPIConfigMap["MPI Hostfile ConfigMap"]
    end

    subgraph Runtimes["Pre-configured ClusterTrainingRuntimes (RHOAI)"]
        TorchDist["torch-distributed<br/><i>CPU / CUDA / ROCm</i>"]
        TrainingHub["Training Hub<br/><i>Universal workbench</i>"]
        OpenMPI["openmpi-cuda<br/><i>MPI + CUDA</i>"]
    end

    User["Data Scientist / ML Engineer"] -->|"kubectl create"| TrainJobCR
    TrainJobCR -->|"references"| TrainingRuntimeCR
    TrainJobCR -->|"references"| ClusterTrainingRuntimeCR
    TrainJobCR -->|"watched by"| Controller

    TrainingRuntimeCR -->|"watched by"| Controller
    ClusterTrainingRuntimeCR -->|"watched by"| Controller

    Controller -->|"creates"| JobSetRes
    Controller -->|"creates (RHAI)"| NetworkPolicyRes
    Controller -->|"creates (gang-sched)"| PodGroupRes
    Controller -->|"creates (MPI)"| MPISecret
    Controller -->|"creates (MPI)"| MPIConfigMap

    ProgressionTracker -->|"HTTP GET /metrics<br/>28080/TCP plaintext"| TrainingPods["Training Pods<br/>(rank 0)"]

    Controller -->|"HTTPS 443/TCP"| K8sAPI["Kubernetes API Server"]
    Webhook -->|"TLS 9443/TCP"| K8sAPI

    JobSetRes -->|"managed by"| JobSetCtrl["JobSet Controller"]
    JobSetCtrl -->|"creates"| TrainingPods

    Prometheus["Prometheus / Monitoring"] -->|"HTTPS 8443/TCP<br/>PodMonitor scrape"| Controller

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style ProgressionTracker fill:#4a90e2,stroke:#333,color:#fff
    style NetworkPolicyMgr fill:#4a90e2,stroke:#333,color:#fff
    style CertController fill:#4a90e2,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style TrainingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333
    style JobSetRes fill:#d5e8d4,stroke:#82b366
    style NetworkPolicyRes fill:#d5e8d4,stroke:#82b366
    style PodGroupRes fill:#d5e8d4,stroke:#82b366
    style MPISecret fill:#d5e8d4,stroke:#82b366
    style MPIConfigMap fill:#d5e8d4,stroke:#82b366
    style TorchDist fill:#e1d5e7,stroke:#9673a6
    style TrainingHub fill:#e1d5e7,stroke:#9673a6
    style OpenMPI fill:#e1d5e7,stroke:#9673a6
    style K8sAPI fill:#e8e8e8,stroke:#333
    style JobSetCtrl fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style TrainingPods fill:#fff2cc,stroke:#d6b656
    style User fill:#dae8fc,stroke:#6c8ebf
