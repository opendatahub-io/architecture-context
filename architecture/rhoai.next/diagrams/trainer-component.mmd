graph TB
    subgraph TrainerComponent["Kubeflow Trainer Component"]
        subgraph Controller["trainer-controller-manager"]
            Reconciler["TrainJob Reconciler<br/>Go / controller-runtime"]
            RuntimeFramework["Runtime Framework<br/>(Plugin Architecture)"]
            WebhookServer["Webhook Server<br/>9443/TCP HTTPS"]
            MetricsServer["Metrics Server<br/>8443/TCP HTTPS"]
            HealthProbes["Health Probes<br/>8081/TCP HTTP"]
            CertManager["Cert Controller<br/>(OPA cert-controller)"]
            ProgressionTracker["RHAI Progression Tracker<br/>(HTTP metrics polling)"]
            NetworkPolicyMgr["RHAI NetworkPolicy Manager"]

            Reconciler -->|uses| RuntimeFramework
            Reconciler -->|triggers| ProgressionTracker
            Reconciler -->|creates| NetworkPolicyMgr
            CertManager -->|provisions TLS| WebhookServer
        end

        subgraph Plugins["Runtime Framework Plugins"]
            TorchPlugin["Torch ML Policy Plugin"]
            MPIPlugin["MPI ML Policy Plugin"]
            CoschedulingPlugin["Coscheduling PodGroup Plugin"]
            VolcanoPlugin["Volcano PodGroup Plugin"]
            JobSetBuilder["JobSet Builder Plugin"]
        end

        RuntimeFramework -->|loads| TorchPlugin
        RuntimeFramework -->|loads| MPIPlugin
        RuntimeFramework -->|loads| CoschedulingPlugin
        RuntimeFramework -->|loads| VolcanoPlugin
        RuntimeFramework -->|loads| JobSetBuilder
    end

    %% CRDs
    User["Data Scientist / User"] -->|creates| TrainJobCR["TrainJob CR"]
    Admin["Platform Admin"] -->|creates| ClusterRuntimeCR["ClusterTrainingRuntime CR"]
    Admin -->|creates| RuntimeCR["TrainingRuntime CR"]

    TrainJobCR -->|validated by| WebhookServer
    TrainJobCR -->|watched by| Reconciler
    RuntimeCR -->|validated by| WebhookServer
    RuntimeCR -->|referenced by| Reconciler
    ClusterRuntimeCR -->|validated by| WebhookServer
    ClusterRuntimeCR -->|referenced by| Reconciler

    %% Created Resources
    Reconciler -->|creates| JobSetCR["JobSet CR"]
    NetworkPolicyMgr -->|creates| NetworkPolicyCR["NetworkPolicy"]
    MPIPlugin -->|creates| SSHSecret["SSH Key Secret"]
    MPIPlugin -->|creates| HostfileConfigMap["MPI Hostfile ConfigMap"]
    CoschedulingPlugin -->|creates| PodGroupCR["PodGroup CR<br/>(scheduling.x-k8s.io)"]
    VolcanoPlugin -->|creates| VolcanoPodGroup["PodGroup CR<br/>(scheduling.volcano.sh)"]

    %% External Dependencies
    JobSetCR -->|managed by| JobSetController["JobSet Controller"]
    JobSetController -->|creates| TrainingPods["Training Pods"]
    ProgressionTracker -->|polls :28080/TCP HTTP| TrainingPods

    %% Platform
    RHODSOperator["rhods-operator"] -->|deploys via kustomize| Controller
    Prometheus["Prometheus"] -->|scrapes :8443/TCP HTTPS| MetricsServer

