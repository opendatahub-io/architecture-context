graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        direction TB
        Controller["trainer-controller-manager<br/>Go Operator (controller-runtime)<br/>Ports: 9443, 8443, 8081"]
        RuntimeFramework["Runtime Framework<br/>Plugin System"]
        Webhooks["Validating Webhooks<br/>9443/TCP HTTPS"]
        RHAI["RHAI Progression Tracking<br/>Metrics Polling"]

        Controller -->|uses| RuntimeFramework
        Controller -->|runs| Webhooks
        Controller -->|runs| RHAI
    end

    subgraph Plugins["Runtime Plugins"]
        direction TB
        PyTorch["PyTorch Plugin<br/>torch/torchtune"]
        MPI["MPI Plugin<br/>OpenMPI + SSH"]
        PlainML["PlainML Plugin"]
        JobSetPlugin["JobSet Plugin<br/>ComponentBuilder"]
        VolcanoPlugin["Volcano Plugin<br/>PodGroupPolicy"]
        CoSchedulingPlugin["CoScheduling Plugin<br/>PodGroupPolicy"]

        RuntimeFramework -->|loads| PyTorch
        RuntimeFramework -->|loads| MPI
        RuntimeFramework -->|loads| PlainML
        RuntimeFramework -->|loads| JobSetPlugin
        RuntimeFramework -->|loads| VolcanoPlugin
        RuntimeFramework -->|loads| CoSchedulingPlugin
    end

    %% CRDs
    User[User / API Client] -->|creates| TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1alpha1"]
    Admin[Platform Admin] -->|creates| TrainingRuntimeCR["TrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]
    Admin -->|creates| ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]

    TrainJobCR -->|watched by| Controller
    TrainingRuntimeCR -->|watched by| Controller
    ClusterTrainingRuntimeCR -->|watched by| Controller

    TrainJobCR -->|references| TrainingRuntimeCR
    TrainJobCR -->|references| ClusterTrainingRuntimeCR

    %% Created Resources
    Controller -->|creates| JobSet["JobSet<br/>jobset.x-k8s.io/v1alpha2"]
    Controller -->|creates| NetworkPolicy["NetworkPolicy<br/>(per TrainJob, RHOAI)"]
    Controller -->|creates| PodGroup["PodGroup<br/>(Volcano or CoScheduling)"]
    Controller -->|creates| SSHSecret["SSH Secret<br/>(MPI only, ECDSA P521)"]
    Controller -->|creates| HostfileCM["Hostfile ConfigMap<br/>(MPI only)"]

    %% External Dependencies
    Controller -->|watches/creates via| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    RHAI -->|polls metrics| TrainingPod["Training Pod rank-0<br/>28080/TCP HTTP"]
    Prometheus["Prometheus<br/>(PodMonitor)"] -->|scrapes| Controller

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style RuntimeFramework fill:#4a90e2,stroke:#333,color:#fff
    style Webhooks fill:#4a90e2,stroke:#333,color:#fff
    style RHAI fill:#4a90e2,stroke:#333,color:#fff
    style PyTorch fill:#6cb4ee,stroke:#333
    style MPI fill:#6cb4ee,stroke:#333
    style PlainML fill:#6cb4ee,stroke:#333
    style JobSetPlugin fill:#6cb4ee,stroke:#333
    style VolcanoPlugin fill:#6cb4ee,stroke:#333
    style CoSchedulingPlugin fill:#6cb4ee,stroke:#333
    style TrainJobCR fill:#f5a623,stroke:#333
    style TrainingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333
    style JobSet fill:#7ed321,stroke:#333
    style NetworkPolicy fill:#7ed321,stroke:#333
    style PodGroup fill:#7ed321,stroke:#333
    style SSHSecret fill:#7ed321,stroke:#333
    style HostfileCM fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style TrainingPod fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
