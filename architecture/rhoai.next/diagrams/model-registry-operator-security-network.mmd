graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / API Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        RegistryRoute["Registry Route<br/>{name}-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        CatalogRoute["Catalog Route<br/>model-catalog-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthLayer["AUTH LAYER (kube-rbac-proxy sidecars)"]
        direction TB
        RegistryProxy["kube-rbac-proxy (Registry)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>Auth: SubjectAccessReview<br/>Policy: GET services/{name}"]
        CatalogProxy["kube-rbac-proxy (Catalog)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>Auth: SubjectAccessReview<br/>Policy: GET services/model-catalog"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB
        RegistryREST["Model Registry REST<br/>8080/TCP HTTP (localhost)<br/>Liveness: /readyz/isDirty<br/>Readiness: /readyz/health"]
        CatalogREST["Model Catalog REST<br/>8080/TCP HTTP (localhost)<br/>Init: catalog-data, benchmark-data"]
    end

    subgraph DataLayer["DATA LAYER"]
        direction TB
        RegistryDB["Registry PostgreSQL<br/>5432/TCP<br/>NetworkPolicy: label-matched ingress only<br/>Credentials: auto-generated Secret"]
        CatalogDB["Catalog PostgreSQL<br/>5432/TCP<br/>NetworkPolicy: catalog pods only<br/>Credentials: auto-generated Secret"]
    end

    subgraph ExternalDB["EXTERNAL DATABASES (Optional)"]
        ExtPostgres["External PostgreSQL<br/>5432/TCP<br/>SSL: configurable sslMode<br/>Auth: user-provided Secret"]
        ExtMySQL["External MySQL<br/>3306/TCP<br/>SSL: cert/key/CA configurable<br/>Auth: user-provided Secret"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>SA: controller-manager<br/>Metrics: 8443/TCP HTTPS<br/>Health: 8081/TCP HTTP<br/>Webhook: 9443/TCP HTTPS"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: SA Token"]
        CertMgr["cert-manager<br/>Webhook TLS provisioning"]
        ServingCert["OpenShift serving-cert-signer<br/>kube-rbac-proxy TLS"]
        Prometheus["Prometheus<br/>Scrapes 8443/TCP HTTPS<br/>Auth: Bearer Token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress to Auth
    RegistryRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer forwarded"| RegistryProxy
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer forwarded"| CatalogProxy

    %% Auth to K8s API (SAR check)
    RegistryProxy -->|"HTTPS/443<br/>TLS<br/>SA Token (SAR)"| K8sAPI
    CatalogProxy -->|"HTTPS/443<br/>TLS<br/>SA Token (SAR)"| K8sAPI

    %% Auth to App (localhost)
    RegistryProxy -->|"HTTP/8080<br/>None (localhost)<br/>No auth"| RegistryREST
    CatalogProxy -->|"HTTP/8080<br/>None (localhost)<br/>No auth"| CatalogREST

    %% App to Data
    RegistryREST -->|"TCP/5432<br/>Optional SSL<br/>Password"| RegistryDB
    RegistryREST -.->|"TCP/5432 SSL<br/>or TCP/3306 SSL"| ExtPostgres
    RegistryREST -.->|"TCP/3306<br/>Optional SSL"| ExtMySQL
    CatalogREST -->|"TCP/5432<br/>Password"| CatalogDB

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    CertMgr -.->|"provisions"| Operator
    ServingCert -.->|"provisions"| RegistryProxy
    ServingCert -.->|"provisions"| CatalogProxy
    Prometheus -->|"HTTPS/8443<br/>TLS self-signed<br/>Bearer Token"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extdb fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#e8e8e8,stroke:#666,stroke-width:2px

    class Client external
    class RegistryRoute,CatalogRoute ingress
    class RegistryProxy,CatalogProxy auth
    class RegistryREST,CatalogREST app
    class RegistryDB,CatalogDB data
    class ExtPostgres,ExtMySQL extdb
    class Operator controlplane
    class K8sAPI,CertMgr,ServingCert,Prometheus k8s
