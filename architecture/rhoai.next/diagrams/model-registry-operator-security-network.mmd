graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        MRRoute["OpenShift Route<br/><registry-name>-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        MCRoute["OpenShift Route<br/>model-catalog-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER"]
        KRBAC_MR["kube-rbac-proxy (Registry)<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>TokenReview + SubjectAccessReview"]
        KRBAC_MC["kube-rbac-proxy (Catalog)<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>TokenReview + SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB
        subgraph NS_Registry["Namespace: {registry-namespace}"]
            MRREST["Model Registry REST API<br/>8080/TCP HTTP<br/>Protected by proxy + NetworkPolicy"]
            MCREST["Model Catalog REST API<br/>8080/TCP HTTP<br/>Protected by proxy + NetworkPolicy"]
        end
    end

    subgraph DataLayer["DATA LAYER"]
        MRPG["PostgreSQL (Registry)<br/><registry-name>-postgres<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password"]
        MCPG["PostgreSQL (Catalog)<br/>model-catalog-postgres<br/>5432/TCP plaintext<br/>Username/Password"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>Webhooks: 9443/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>SA Token"]
        OSIngress["config.openshift.io/Ingress<br/>443/TCP HTTPS TLS<br/>SA Token"]
        PlatformAuth["Platform Auth CR<br/>services.platform.opendatahub.io<br/>443/TCP HTTPS TLS"]
        ExtPG["PostgreSQL (External)<br/>5432/TCP<br/>Configurable TLS<br/>User-provided credentials"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token JWT"| MRRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token JWT"| MCRoute

    %% Ingress → Auth Proxy
    MRRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBAC_MR
    MCRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBAC_MC

    %% Auth Proxy → K8s API (auth delegation)
    KRBAC_MR -->|"HTTPS/443<br/>TLS<br/>TokenReview"| K8sAPI
    KRBAC_MC -->|"HTTPS/443<br/>TLS<br/>TokenReview"| K8sAPI

    %% Auth Proxy → Application
    KRBAC_MR -->|"HTTP/8080<br/>No TLS<br/>Pod-local"| MRREST
    KRBAC_MC -->|"HTTP/8080<br/>No TLS<br/>Pod-local"| MCREST

    %% Application → Data
    MRREST -->|"PostgreSQL/5432<br/>Configurable TLS<br/>Username/Password"| MRPG
    MCREST -->|"PostgreSQL/5432<br/>Plaintext<br/>Username/Password"| MCPG

    %% Application → External DB (optional)
    MRREST -.->|"PostgreSQL/5432<br/>Configurable TLS<br/>User credentials"| ExtPG

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Reconciliation"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| OSIngress
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| PlatformAuth

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class MRRoute,MCRoute ingress
    class KRBAC_MR,KRBAC_MC authproxy
    class MRREST,MCREST application
    class MRPG,MCPG data
    class Operator controlplane
    class K8sAPI,OSIngress,PlatformAuth,ExtPG externalservice
