graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - OpenShift Router"]
        Route_MR["Route: registry-name-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        Route_MC["Route: model-catalog-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER"]
        KRBP_MR["kube-rbac-proxy (Registry)<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>TokenReview + SAR"]
        KRBP_MC["kube-rbac-proxy (Catalog)<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>TokenReview + SAR"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        MRREST["Model Registry REST API<br/>8080/TCP HTTP<br/>SA: registry-name<br/>NetworkPolicy: proxy-only"]
        MCREST["Model Catalog REST API<br/>8080/TCP HTTP<br/>NetworkPolicy: proxy-only"]
    end

    subgraph DataLayer["DATA LAYER"]
        PG_MR["PostgreSQL (Registry)<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password<br/>NetworkPolicy: registry-only"]
        PG_MC["PostgreSQL (Catalog)<br/>5432/TCP<br/>plaintext<br/>Username/Password"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>SA: controller-manager"]
        Metrics["Metrics: 8443/TCP HTTPS<br/>TLS (serving cert)<br/>Bearer Token"]
        Webhooks["Webhooks: 9443/TCP HTTPS<br/>TLS (serving cert)<br/>API Server client cert"]
        Health["Health: 8081/TCP HTTP<br/>/healthz, /readyz"]
    end

    subgraph PlatformSvc["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>SA Token"]
        OSIngress["config.openshift.io<br/>Ingress Config<br/>443/TCP"]
        AuthCR["Platform Auth CR<br/>services.platform<br/>.opendatahub.io"]
        PlatformMR["Platform ModelRegistry CR<br/>components.platform<br/>.opendatahub.io"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        ExtPG["External PostgreSQL<br/>5432/TCP<br/>Configurable TLS<br/>Username/Password"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token (JWT)"| Route_MR
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token (JWT)"| Route_MC

    %% Ingress to Auth Proxy
    Route_MR -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBP_MR
    Route_MC -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBP_MC

    %% Auth Proxy to K8s API (auth delegation)
    KRBP_MR -->|"HTTPS/443<br/>TokenReview + SAR<br/>SA Token"| K8sAPI
    KRBP_MC -->|"HTTPS/443<br/>TokenReview + SAR<br/>SA Token"| K8sAPI

    %% Auth Proxy to Application
    KRBP_MR -->|"HTTP/8080<br/>None (pod-local)<br/>Validated"| MRREST
    KRBP_MC -->|"HTTP/8080<br/>None (pod-local)<br/>Validated"| MCREST

    %% Application to Data
    MRREST -->|"PostgreSQL/5432<br/>Configurable TLS<br/>User/Pass"| PG_MR
    MCREST -->|"PostgreSQL/5432<br/>plaintext<br/>User/Pass"| PG_MC

    %% Operator to Platform
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    Operator -->|"HTTPS/443<br/>Read ingress domain"| OSIngress
    Operator -->|"HTTPS/443<br/>Read admin groups"| AuthCR
    Operator -->|"HTTPS/443<br/>Read default registry"| PlatformMR

    %% Operator optional egress
    MRREST -.->|"PostgreSQL/5432<br/>Configurable TLS"| ExtPG

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalsvc fill:#f5f5f5,stroke:#666,stroke-width:2px,stroke-dasharray: 5

    class Client external
    class Route_MR,Route_MC ingress
    class KRBP_MR,KRBP_MC authproxy
    class MRREST,MCREST application
    class PG_MR,PG_MC data
    class Operator,Metrics,Webhooks,Health controlplane
    class K8sAPI,OSIngress,AuthCR,PlatformMR platform
    class ExtPG externalsvc
