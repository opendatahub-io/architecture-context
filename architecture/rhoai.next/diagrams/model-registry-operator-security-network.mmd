graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / User"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        direction TB
        Route["OpenShift Route<br/>{name}-https<br/>443/TCP → 8443/TCP<br/>TLS Passthrough"]
        Gateway["Data Science Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS Gateway-terminated<br/>HTTPRoute: /model-registry/{name}/"]
    end

    subgraph AppLayer["APPLICATION LAYER (Cluster Internal)"]
        direction TB

        subgraph RegistryPod["Per-Instance Registry Pod"]
            KRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift serving cert<br/>TokenReview + SAR"]
            MR["model-registry REST<br/>8080/TCP HTTP<br/>No auth (localhost)"]
        end

        subgraph CatalogPod["Model Catalog Pod (Singleton)"]
            CatKRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OpenShift serving cert"]
            CatMR["model-catalog<br/>8080/TCP HTTP"]
        end
    end

    subgraph DataLayer["DATA LAYER"]
        AutoPG["PostgreSQL 16<br/>Auto-provisioned<br/>5432/TCP<br/>Password auth<br/>NetworkPolicy restricted"]
        ExternalDB["External PostgreSQL/MySQL<br/>5432/3306 TCP<br/>Configurable SSL<br/>Password + cert auth"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["model-registry-operator<br/>SA: controller-manager<br/>NS: redhat-ods-applications"]

        subgraph WebhookEP["Webhook Endpoints"]
            WHMutate["Mutating: /mutate-...<br/>9443/TCP HTTPS<br/>API server cert auth"]
            WHValidate["Validating: /validate-...<br/>9443/TCP HTTPS<br/>API server cert auth"]
        end

        Metrics["Metrics: /metrics<br/>8443/TCP HTTPS<br/>Bearer Token RBAC"]
        Health["Health: /healthz /readyz<br/>8081/TCP HTTP<br/>No auth"]
    end

    subgraph K8sAPI["KUBERNETES / OPENSHIFT API"]
        APIServer["API Server<br/>6443/TCP HTTPS TLS<br/>SA token auth"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| Route
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| Gateway

    %% Ingress → App Layer
    Route -->|"HTTPS/8443<br/>TLS Passthrough<br/>Bearer Token"| KRBAC
    Gateway -->|"HTTPS/8443<br/>URLRewrite<br/>Bearer Token"| KRBAC

    %% kube-rbac-proxy auth delegation
    KRBAC -->|"HTTPS/6443<br/>TokenReview + SAR<br/>SA token"| APIServer
    CatKRBAC -->|"HTTPS/6443<br/>TokenReview + SAR<br/>SA token"| APIServer

    %% kube-rbac-proxy → backend
    KRBAC -->|"HTTP/8080<br/>localhost<br/>No auth"| MR
    CatKRBAC -->|"HTTP/8080<br/>localhost<br/>No auth"| CatMR

    %% App → Data
    MR -->|"PostgreSQL/5432<br/>Configurable SSL<br/>Password"| AutoPG
    MR -->|"PostgreSQL·MySQL<br/>5432·3306<br/>SSL configurable<br/>Password"| ExternalDB
    CatMR -->|"PostgreSQL/5432<br/>Password"| AutoPG

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS<br/>SA token<br/>CRUD + Watch"| APIServer

    %% K8s API → Webhooks
    APIServer -->|"HTTPS/9443<br/>TLS<br/>API server cert"| WHMutate
    APIServer -->|"HTTPS/9443<br/>TLS<br/>API server cert"| WHValidate

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef appLayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataLayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlPlane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8sapi fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Route,Gateway ingress
    class KRBAC,MR,CatKRBAC,CatMR appLayer
    class AutoPG,ExternalDB dataLayer
    class Operator,WHMutate,WHValidate,Metrics,Health controlPlane
    class APIServer k8sapi
