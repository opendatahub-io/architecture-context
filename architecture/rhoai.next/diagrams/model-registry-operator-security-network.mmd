graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        RegistryRoute["OpenShift Route<br/>{registry-name}-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        CatalogRoute["OpenShift Route<br/>model-catalog-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthLayer["AUTH ENFORCEMENT (kube-rbac-proxy)"]
        RegistryProxy["kube-rbac-proxy (Registry)<br/>8443/TCP HTTPS<br/>OpenShift serving cert<br/>SubjectAccessReview"]
        CatalogProxy["kube-rbac-proxy (Catalog)<br/>8443/TCP HTTPS<br/>OpenShift serving cert<br/>SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph RegistryPod["Registry Pod"]
            RegistryREST["Model Registry REST<br/>8080/TCP HTTP<br/>SA: {registry-name}"]
        end

        subgraph CatalogPod["Catalog Pod"]
            CatalogApp["Model Catalog<br/>8080/TCP HTTP<br/>SA: model-catalog"]
        end
    end

    subgraph DataLayer["DATA LAYER (NetworkPolicy Protected)"]
        RegistryDB["PostgreSQL (Registry)<br/>5432/TCP<br/>Ingress: registry pod only"]
        CatalogDB["PostgreSQL (Catalog)<br/>5432/TCP<br/>Ingress: catalog pod only"]
    end

    subgraph ExternalDB["EXTERNAL DATABASES (Optional)"]
        ExtPostgres["External PostgreSQL<br/>5432/TCP<br/>SSL configurable<br/>Password auth"]
        ExtMySQL["External MySQL<br/>3306/TCP<br/>SSL configurable<br/>Password auth"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS"]
        WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP HTTPS<br/>TLS: cert-manager"]
    end

    subgraph K8s["KUBERNETES"]
        K8sAPI["K8s API Server<br/>443/TCP HTTPS TLS 1.2+"]
        PromSM["Prometheus<br/>(ServiceMonitor)<br/>8443/TCP HTTPS"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress to Auth
    RegistryRoute -->|"HTTPS/8443<br/>reencrypt TLS<br/>Token forwarded"| RegistryProxy
    CatalogRoute -->|"HTTPS/8443<br/>reencrypt TLS<br/>Token forwarded"| CatalogProxy

    %% Auth to K8s API (SAR)
    RegistryProxy -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>SubjectAccessReview"| K8sAPI
    CatalogProxy -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>SubjectAccessReview"| K8sAPI

    %% Auth to App (loopback)
    RegistryProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| RegistryREST
    CatalogProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| CatalogApp

    %% App to Data
    RegistryREST -->|"TCP/5432<br/>Password<br/>Optional SSL"| RegistryDB
    RegistryREST -.->|"TCP/5432<br/>Password<br/>SSL configurable"| ExtPostgres
    RegistryREST -.->|"TCP/3306<br/>Password<br/>SSL configurable"| ExtMySQL
    CatalogApp -->|"TCP/5432<br/>Password"| CatalogDB

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Reconciliation"| K8sAPI
    K8sAPI -->|"HTTPS/9443<br/>TLS (cert-manager)<br/>Admission"| WebhookSvc
    PromSM -->|"HTTPS/8443<br/>TLS (self-signed)<br/>Bearer Token"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extdata fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef control fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#e8e8e8,stroke:#666,stroke-width:2px

    class Client external
    class RegistryRoute,CatalogRoute ingress
    class RegistryProxy,CatalogProxy auth
    class RegistryREST,CatalogApp app
    class RegistryDB,CatalogDB data
    class ExtPostgres,ExtMySQL extdata
    class Operator,WebhookSvc control
    class K8sAPI,PromSM k8s
