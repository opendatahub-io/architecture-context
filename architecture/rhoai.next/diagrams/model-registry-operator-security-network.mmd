graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ reencrypt<br/>Host: {name}-rest.{domain}"]
        Gateway["Data Science Gateway<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>Path: /model-registry/{name}/"]
    end

    subgraph AppPod["APPLICATION POD"]
        direction TB
        subgraph RegistryPod["Pod: {registry-name}"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (serving cert)<br/>Auth: SubjectAccessReview<br/>Image: origin-kube-rbac-proxy"]
            MR["model-registry REST<br/>8080/TCP HTTP<br/>Unauthenticated (direct)<br/>Image: model-registry"]
        end
    end

    subgraph OperatorPod["OPERATOR POD"]
        Operator["model-registry-operator<br/>SA: controller-manager<br/>FIPS: strictfipsruntime"]
        Metrics["Metrics: 8443/TCP HTTPS<br/>TLS (cluster profile)<br/>Auth: Bearer Token (SAR)"]
        Webhooks["Webhooks: 9443/TCP HTTPS<br/>TLS<br/>Auth: K8s API Server"]
        Health["Health: 8081/TCP HTTP<br/>No auth"]
    end

    subgraph K8sControl["CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        OSAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph DataTier["DATA TIER"]
        PGAuto["PostgreSQL (auto)<br/>5432/TCP<br/>Configurable SSL<br/>Auth: Password (Secret)"]
        PGUser["PostgreSQL/MySQL (user)<br/>5432/3306 TCP<br/>Configurable SSL/TLS<br/>Auth: Username/Password"]
    end

    subgraph PlatformSvcs["PLATFORM SERVICES"]
        IngressCfg["config.openshift.io/Ingress<br/>Cluster domain discovery"]
        APIServerCfg["config.openshift.io/APIServer<br/>TLS profile (triggers restart)"]
        AuthCR["services.platform.opendatahub.io/Auth<br/>Admin groups for RBAC"]
        PlatformMR["components.platform.opendatahub.io<br/>/ModelRegistry<br/>Owner references"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Router
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform auth"| Gateway

    %% Ingress → App Pod
    Router -->|"HTTPS/8443<br/>TLS reencrypt<br/>serving cert"| KRBP
    Gateway -->|"HTTPS/8443<br/>TLS<br/>URL rewrite"| KRBP

    %% Within App Pod
    KRBP -->|"HTTP/8080<br/>localhost<br/>SAR authorized"| MR

    %% Auth check
    KRBP -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>SubjectAccessReview"| K8sAPI

    %% App → Data
    MR -->|"PostgreSQL/5432<br/>Configurable SSL<br/>Password"| PGAuto
    MR -->|"PostgreSQL/5432<br/>MySQL/3306<br/>Configurable SSL"| PGUser

    %% Operator → Control Plane
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>CRUD operations"| K8sAPI
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Route, Group, Ingress"| OSAPI

    %% Operator → Platform
    Operator -.->|"via K8s API"| IngressCfg
    Operator -.->|"via K8s API"| APIServerCfg
    Operator -.->|"via K8s API"| AuthCR
    Operator -.->|"via K8s API"| PlatformMR

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef control fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef data fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router,Gateway ingress
    class KRBP,MR app
    class Operator,Metrics,Webhooks,Health operator
    class K8sAPI,OSAPI control
    class PGAuto,PGUser data
    class IngressCfg,APIServerCfg,AuthCR,PlatformMR platform
