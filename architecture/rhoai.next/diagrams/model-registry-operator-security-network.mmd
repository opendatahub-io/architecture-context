graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        RegistryRoute["Registry Route<br/>{registry-name}-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        CatalogRoute["Catalog Route<br/>model-catalog-https<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthLayer["AUTH ENFORCEMENT (kube-rbac-proxy)"]
        direction TB
        RegistryProxy["kube-rbac-proxy<br/>(Registry)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>Auth: SubjectAccessReview<br/>Policy: GET services/{name}"]
        CatalogProxy["kube-rbac-proxy<br/>(Catalog)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>Auth: SubjectAccessReview<br/>Policy: GET services/model-catalog"]
    end

    subgraph AppLayer["APPLICATION LAYER"]
        direction TB

        subgraph RegistryPod["Registry Pod"]
            RegistryREST["Model Registry REST<br/>8080/TCP HTTP<br/>SA: {registry-name}"]
        end

        subgraph CatalogPod["Catalog Pod"]
            CatalogApp["Model Catalog<br/>8080/TCP HTTP<br/>SA: model-catalog<br/>Init: catalog-data, benchmark-data"]
        end
    end

    subgraph DataLayer["DATA LAYER (NetworkPolicy Protected)"]
        direction TB
        RegistryDB["Registry PostgreSQL<br/>{registry-name}-postgres<br/>5432/TCP<br/>NP: ingress only from registry pods"]
        CatalogDB["Catalog PostgreSQL<br/>model-catalog-postgres<br/>5432/TCP<br/>NP: ingress only from catalog pods"]
    end

    subgraph ExternalDB["EXTERNAL DATA (Optional)"]
        ExtPostgres["External PostgreSQL<br/>5432/TCP<br/>SSL: configurable<br/>Auth: Password via Secret"]
        ExtMySQL["External MySQL<br/>3306/TCP<br/>SSL: cert/key/CA<br/>Auth: Password via Secret"]
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>SA: controller-manager<br/>8081/TCP probes<br/>8443/TCP metrics (HTTPS)<br/>9443/TCP webhook (HTTPS)"]
    end

    subgraph K8sPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["K8s API Server<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph CertProviders["CERTIFICATE PROVIDERS"]
        CertMgr["cert-manager<br/>Self-signed Issuer"]
        ServingCert["OpenShift<br/>serving-cert-signer"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress → Auth
    RegistryRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Token forwarded"| RegistryProxy
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Token forwarded"| CatalogProxy

    %% Auth → K8s API (SAR)
    RegistryProxy -->|"HTTPS/443<br/>TLS<br/>SubjectAccessReview"| K8sAPI
    CatalogProxy -->|"HTTPS/443<br/>TLS<br/>SubjectAccessReview"| K8sAPI

    %% Auth → App (loopback)
    RegistryProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| RegistryREST
    CatalogProxy -->|"HTTP/8080<br/>localhost<br/>No auth"| CatalogApp

    %% App → Data
    RegistryREST -->|"TCP/5432<br/>Optional SSL<br/>Password"| RegistryDB
    RegistryREST -.->|"TCP/5432 or 3306<br/>Optional SSL<br/>Password"| ExtPostgres
    RegistryREST -.->|"TCP/3306<br/>Optional SSL<br/>Password"| ExtMySQL
    CatalogApp -->|"TCP/5432<br/>Password"| CatalogDB

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Cert providers
    CertMgr -.->|"TLS cert"| Operator
    ServingCert -.->|"TLS cert"| RegistryProxy
    ServingCert -.->|"TLS cert"| CatalogProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extdata fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef control fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef certs fill:#f5f5f5,stroke:#666,stroke-dasharray:5 5

    class Client external
    class RegistryRoute,CatalogRoute ingress
    class RegistryProxy,CatalogProxy auth
    class RegistryREST,CatalogApp app
    class RegistryDB,CatalogDB data
    class ExtPostgres,ExtMySQL extdata
    class Operator control
    class K8sAPI k8s
    class CertMgr,ServingCert certs
