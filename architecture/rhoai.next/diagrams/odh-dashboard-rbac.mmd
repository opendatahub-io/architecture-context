graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["odh-dashboard<br/>(dashboard namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Main["odh-dashboard<br/>(ClusterRoleBinding)"]
        CRB_AuthDelegator["odh-dashboard-auth-delegator<br/>(ClusterRoleBinding)"]
        CRB_Monitoring["odh-dashboard-monitoring<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (dashboard namespace)"]
        RB_Main["odh-dashboard<br/>(RoleBinding)"]
        RB_Builds["builds-and-images<br/>→ system:authenticated"]
        RB_HW["hardware-profile-role-binding<br/>→ system:authenticated"]
        RB_NIM["nim-account-access-binding<br/>→ system:authenticated"]
        RB_MCP["gen-ai-aa-mcp-servers-reader<br/>→ system:authenticated"]
        RB_EvalHub["trustyai-evalhubs-role-binding<br/>→ system:authenticated"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["ClusterRole: odh-dashboard"]
        CR_AuthDelegator["ClusterRole: system:auth-delegator"]
        CR_Monitoring["ClusterRole: cluster-monitoring-view"]
        CR_HW["ClusterRole: aggregate-hardware-profiles-permissions"]
        CR_DSG["ClusterRole: dsg-cluster-roles"]
    end

    %% SA → Bindings → Roles
    SA -->|"bound via"| CRB_Main
    SA -->|"bound via"| CRB_AuthDelegator
    SA -->|"bound via"| CRB_Monitoring
    SA -->|"bound via"| RB_Main

    CRB_Main -->|"grants"| CR_Main
    CRB_AuthDelegator -->|"grants"| CR_AuthDelegator
    CRB_Monitoring -->|"grants"| CR_Monitoring

    %% ────────────────────────────────────────────────────
    %% ClusterRole: odh-dashboard — API Resources
    %% ────────────────────────────────────────────────────
    subgraph ODH_CRDs["ODH/RHOAI CRDs"]
        Notebooks["kubeflow.org<br/>notebooks<br/>get,list,watch,create,<br/>update,patch,delete"]
        ModelRegistries["modelregistry.opendatahub.io<br/>modelregistries<br/>get,list,watch,create,<br/>update,patch,delete"]
        InferenceServices["serving.kserve.io<br/>inferenceservices<br/>get,list,watch"]
        DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>list,watch,get"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations<br/>list,watch,get"]
        LSD["llamastack.io<br/>llamastackdistributions<br/>get,list,watch"]
        TrustyAI["trustyai.opendatahub.io<br/>guardrailsorchestrators,<br/>evalhubs<br/>get,list,watch"]
        Feast["feast.dev<br/>featurestores<br/>get,list,watch"]
        MLflow["mlflow.opendatahub.io<br/>mlflows<br/>get,list,watch"]
        PlatformAuths["services.platform.opendatahub.io<br/>auths<br/>get"]
    end

    subgraph CoreResources["Core Kubernetes Resources"]
        ConfigMaps["core<br/>configmaps,secrets,pvcs<br/>create,delete,get,list,<br/>patch,update,watch"]
        Nodes["core<br/>nodes<br/>get,list"]
        Pods["core<br/>pods,serviceaccounts,<br/>services<br/>get,list,watch"]
        StorageClasses["storage.k8s.io<br/>storageclasses<br/>update,patch"]
    end

    subgraph AuthResources["Auth/RBAC Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        RBACResources["rbac.authorization.k8s.io<br/>rolebindings,<br/>clusterrolebindings,roles<br/>list,get,create,patch,delete"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        ClusterVersions["config.openshift.io<br/>clusterversions,ingresses<br/>get,watch,list"]
        CSVs["operators.coreos.com<br/>csvs,subscriptions<br/>get,list,watch"]
        Routes["route.openshift.io<br/>routes<br/>get,list,watch"]
        Users["user.openshift.io<br/>groups,users<br/>get,list,watch"]
        MachineAutoscalers["machine.openshift.io<br/>machineautoscalers,<br/>machinesets<br/>get,list"]
    end

    %% ClusterRole → Resources
    CR_Main -->|"grants access to"| ODH_CRDs
    CR_Main -->|"grants access to"| CoreResources
    CR_Main -->|"grants access to"| AuthResources
    CR_Main -->|"grants access to"| OpenShiftResources

