graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Dashboard["odh-dashboard<br/>(main container)"]
        SA_Modules["odh-dashboard-modules<br/>(BFF containers)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Dashboard["odh-dashboard<br/>(ClusterRoleBinding)<br/>cluster-scoped"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Dashboard["odh-dashboard<br/>(RoleBinding)<br/>dashboard namespace"]
        RB_Modules["odh-dashboard-modules<br/>(RoleBinding)<br/>dashboard namespace"]
    end

    subgraph ClusterRolePerms["ClusterRole: odh-dashboard"]
        direction TB
        P_Storage["storage.k8s.io<br/>storageclasses<br/>update, patch"]
        P_Nodes["core ('')<br/>nodes<br/>get, list"]
        P_Config["config.openshift.io<br/>clusterversions, ingresses<br/>get, list, watch"]
        P_Operators["operators.coreos.com<br/>clusterserviceversions,<br/>subscriptions<br/>get, list, watch"]
        P_Images["image.openshift.io<br/>imagestreams,<br/>imagestreamtags<br/>get, list, watch, create,<br/>update, patch, delete"]
        P_Machine["machine.openshift.io<br/>machineautoscalers,<br/>machinesets<br/>get, list, watch"]
        P_Quota["quota.openshift.io<br/>clusterresourcequotas<br/>get, list, watch"]
    end

    subgraph NamespacedRole["Role: odh-dashboard (namespaced)"]
        NR_Desc["Namespace-scoped permissions<br/>(dashboard namespace)"]
    end

    subgraph ModulesRole["Role: odh-dashboard-modules (namespaced)"]
        MR_Desc["Limited permissions for<br/>BFF sidecar containers"]
    end

    subgraph AuthMechanisms["Authentication & Authorization Layers"]
        direction TB
        L1["Layer 1: kube-rbac-proxy<br/>OAuth proxy headers<br/>X-Forwarded-Access-Token<br/>X-Auth-Request-User<br/>X-Auth-Request-Groups"]
        L2["Layer 2: Dashboard Backend<br/>secureRoute (user auth)<br/>secureAdminRoute (admin check)"]
        L3["Layer 3: BFF Middleware<br/>InjectRequestIdentity<br/>SubjectAccessReview (SAR)"]
        L4["Layer 4: Kubernetes API<br/>Native RBAC on user identity<br/>(pass-through /api/k8s/*)"]
    end

    subgraph TokenIsolation["SA Token Isolation"]
        T1["dashboard-sa-token<br/>(projected volume)<br/>Full dashboard RBAC"]
        T2["modules-sa-token<br/>(projected volume)<br/>Limited BFF permissions"]
        T3["automountServiceAccountToken: false<br/>(prevents automatic mounting)"]
    end

    %% Bindings
    SA_Dashboard -->|bound via| CRB_Dashboard
    SA_Dashboard -->|bound via| RB_Dashboard
    SA_Modules -->|bound via| RB_Modules

    CRB_Dashboard -->|grants| ClusterRolePerms
    RB_Dashboard -->|grants| NamespacedRole
    RB_Modules -->|grants| ModulesRole

    %% Token isolation
    SA_Dashboard -->|uses| T1
    SA_Modules -->|uses| T2

    %% Auth flow
    L1 -->|identity headers| L2
    L2 -->|user token| L3
    L3 -->|SAR check| L4

    %% Styling
    classDef sa fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    classDef perm fill:#7ed321,stroke:#333,stroke-width:1px,color:#fff
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef auth fill:#e74c3c,stroke:#333,stroke-width:1px,color:#fff
    classDef token fill:#3498db,stroke:#333,stroke-width:1px,color:#fff

    class SA_Dashboard,SA_Modules sa
    class CRB_Dashboard,RB_Dashboard,RB_Modules binding
    class P_Storage,P_Nodes,P_Config,P_Operators,P_Images,P_Machine,P_Quota perm
    class NR_Desc,MR_Desc,NamespacedRole,ModulesRole role
    class L1,L2,L3,L4 auth
    class T1,T2,T3 token
