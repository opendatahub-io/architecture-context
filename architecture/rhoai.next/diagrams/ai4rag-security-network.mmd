graph TB
    subgraph CallingContext["CALLING CONTEXT (Trusted)"]
        Caller["KFP Pipeline Component<br/>or Python Script"]
    end

    subgraph Library["ai4rag LIBRARY (In-Process)"]
        direction TB

        subgraph Core["Experiment Engine"]
            Experiment["AI4RAGExperiment"]
            MPS["ModelsPreSelector"]
            Optimizer["GAM / Random Optimizer"]
        end

        subgraph RAG["RAG Pipeline"]
            Template["SimpleRAGTemplate"]
            Chunker["LangChainChunker"]
            Retriever["Retriever"]
        end

        subgraph ProviderLayer["Provider Abstraction"]
            OGXClient["OGXFoundationModel<br/>OGXEmbeddingModel<br/>OGXVectorStore<br/>(via ogx-client/httpx)"]
            ChromaLocal["ChromaDB<br/>(In-Memory)<br/>No network access"]
        end

        subgraph EvalLayer["Evaluation"]
            Evaluator["UnitxtEvaluator<br/>(In-Process)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OGXServer["OGX Server<br/>Port: Configurable<br/>Protocol: HTTPS<br/>Encryption: TLS<br/>Auth: API Key (Bearer)"]

        subgraph OGXEndpoints["OGX API Endpoints"]
            Chat["/chat/completions"]
            Embeddings["/embeddings"]
            VectorStores["/vector_stores"]
            VectorIO["/vector_io/insert + /query"]
            Models["/models"]
        end
    end

    %% Flows
    Caller -->|"In-process<br/>Python API"| Experiment

    Experiment --> MPS
    Experiment --> Optimizer
    Experiment --> Template
    Template --> Chunker
    Template --> Retriever

    MPS -->|"In-process"| ChromaLocal
    MPS -->|"In-process"| Evaluator
    Experiment -->|"In-process"| Evaluator

    OGXClient -->|"HTTPS<br/>TLS<br/>API Key (Bearer)<br/>Configurable Port"| OGXServer
    OGXServer --- Chat
    OGXServer --- Embeddings
    OGXServer --- VectorStores
    OGXServer --- VectorIO
    OGXServer --- Models

    %% Styling
    classDef caller fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef library fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef endpoint fill:#fff2cc,stroke:#d6b656

    class Caller caller
    class Experiment,MPS,Optimizer,Template,Chunker,Retriever,OGXClient,ChromaLocal,Evaluator internal
    class OGXServer external
    class Chat,Embeddings,VectorStores,VectorIO,Models endpoint
