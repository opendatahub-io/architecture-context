graph TB
    subgraph UserEnv["USER ENVIRONMENT (Notebook / Pipeline / Workstation)"]
        direction TB

        subgraph Library["ai4rag Library (in-process, no listening ports)"]
            direction TB

            subgraph InProcess["IN-PROCESS COMPONENTS (no network I/O)"]
                Experiment["AI4RAGExperiment<br/>Orchestrator"]
                GAM["GAMOptimizer<br/>(surrogate model)"]
                Random["RandomOptimizer<br/>(baseline)"]
                Chunker["LangChainChunker<br/>(text splitting)"]
                Evaluator["UnitxtEvaluator<br/>(metrics)"]
                ChromaDB["ChromaDB<br/>(in-memory vector store)"]
            end

            subgraph NetworkClients["NETWORK CLIENTS (egress only)"]
                LSEmbedClient["LlamaStack<br/>EmbeddingModel"]
                LSFMClient["LlamaStack<br/>FoundationModel"]
                LSVSClient["LlamaStack<br/>VectorStore"]
                LSDiscover["LlamaStack<br/>AutoDiscovery"]
                OAIEmbedClient["OpenAI<br/>EmbeddingModel"]
                OAIFMClient["OpenAI<br/>FoundationModel"]
            end

            subgraph Events["EVENT HANDLERS"]
                LocalEH["LocalEventHandler<br/>→ JSON/filesystem"]
                KFPEH["KFPEventHandler<br/>→ KFP metadata (mem)"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (egress destinations)"]
        LlamaStack["Llama Stack Server<br/>Port: Configurable<br/>Protocol: HTTP/HTTPS<br/>Encryption: Configurable<br/>Auth: API Key (Bearer)"]

        OpenAI["OpenAI-Compatible API<br/>Port: Configurable<br/>Protocol: HTTPS<br/>Encryption: TLS<br/>Auth: API Key (Bearer)"]
    end

    %% Orchestration flows (in-process)
    Experiment --> GAM
    Experiment --> Random
    Experiment --> Chunker
    Experiment --> Evaluator
    Experiment --> ChromaDB

    %% Egress flows to Llama Stack
    LSEmbedClient -->|"HTTP/HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>POST /embeddings"| LlamaStack
    LSFMClient -->|"HTTP/HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>POST /chat/completions"| LlamaStack
    LSVSClient -->|"HTTP/HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>POST /vector_io/*"| LlamaStack
    LSDiscover -->|"HTTP/HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>GET /models"| LlamaStack

    %% Egress flows to OpenAI
    OAIEmbedClient -->|"HTTPS<br/>Configurable Port<br/>TLS<br/>API Key (Bearer)<br/>POST /embeddings"| OpenAI
    OAIFMClient -->|"HTTPS<br/>Configurable Port<br/>TLS<br/>API Key (Bearer)<br/>POST /chat/completions"| OpenAI

    %% Styling
    classDef userenv fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    classDef library fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inprocess fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef netclient fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef events fill:#ffe6cc,stroke:#d79b00,stroke-width:1px
    classDef external fill:#f5f5f5,stroke:#666,stroke-width:2px

    class Experiment,GAM,Random,Chunker,Evaluator,ChromaDB inprocess
    class LSEmbedClient,LSFMClient,LSVSClient,LSDiscover,OAIEmbedClient,OAIFMClient netclient
    class LocalEH,KFPEH events
    class LlamaStack,OpenAI external
