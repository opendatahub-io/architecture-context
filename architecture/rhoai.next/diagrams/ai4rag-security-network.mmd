graph TB
    subgraph ConsumingService["CONSUMING SERVICE PROCESS (Trusted)"]
        direction TB

        subgraph Library["ai4rag Library (in-process, no network listeners)"]
            direction TB

            subgraph CoreEngine["Core Engine"]
                Experiment["AI4RAGExperiment<br/><i>Orchestration</i>"]
                GAM["GAMOptimizer<br/><i>pygam - in-process</i>"]
                SearchSpace["SearchSpace<br/><i>scikit-learn - in-process</i>"]
            end

            subgraph EvalLayer["Evaluation (in-process)"]
                Evaluator["UnitxtEvaluator<br/><i>unitxt - in-process</i>"]
            end

            subgraph LocalStorage["Local Storage (in-process)"]
                ChromaDB["ChromaDB<br/><i>In-memory vector store<br/>No network</i>"]
            end

            subgraph Handlers["Event Handlers (in-process)"]
                KFPHandler["KFPEventHandler<br/><i>In-memory aggregation</i>"]
                LocalHandler["LocalEventHandler<br/><i>Filesystem write only</i>"]
            end

            OgxClient["OgxClient<br/><i>HTTP client (httpx)<br/>EGRESS ONLY</i>"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OGX["OGX Server<br/>Port: Configurable<br/>HTTPS / TLS 1.2+<br/>Auth: API Key (Bearer)"]

        subgraph OGXEndpoints["OGX API Endpoints"]
            EmbAPI["POST /embeddings"]
            VSAPI["POST /vector_stores<br/>GET /vector_stores/{id}<br/>DELETE /vector_stores/{id}"]
            VIOAPI["POST /vector_io/insert<br/>POST /vector_io/query"]
            ChatAPI["POST /chat/completions"]
        end
    end

    %% Flows
    Experiment -->|in-process| GAM
    Experiment -->|in-process| SearchSpace
    Experiment -->|in-process| Evaluator
    Experiment -->|in-process| ChromaDB
    Experiment -->|in-process| KFPHandler
    Experiment -->|in-process| LocalHandler
    Experiment -->|outbound calls| OgxClient

    OgxClient -->|"HTTPS / TLS 1.2+<br/>API Key (Bearer)<br/>EGRESS ONLY"| OGX

    OGX --- EmbAPI
    OGX --- VSAPI
    OGX --- VIOAPI
    OGX --- ChatAPI

    %% Annotations
    NoIngress["NO INGRESS<br/>ai4rag exposes no ports,<br/>services, or listeners"]

    %% Styling
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef library fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inprocess fill:#e8f4fd,stroke:#4a90e2
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5
    classDef egress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Experiment,GAM,SearchSpace trusted
    class Evaluator,ChromaDB,KFPHandler,LocalHandler inprocess
    class OgxClient egress
    class OGX,EmbAPI,VSAPI,VIOAPI,ChatAPI external
    class NoIngress warning
