graph TB
    subgraph Consumer["CONSUMER PROCESS (Trusted)"]
        direction TB
        UserCode["User Code / KFP Component<br/><i>Invokes ai4rag library</i>"]

        subgraph Library["ai4rag Library (In-Process)"]
            direction TB

            subgraph Core["Core Engine"]
                Experiment["AI4RAGExperiment"]
                MPS["ModelsPreSelector"]
                GAMOpt["GAMOptimizer"]
            end

            subgraph Pipeline["RAG Pipeline"]
                SimpleRAG["SimpleRAG Template"]
                Chunker["LangChainChunker"]
                Evaluator["UnitxtEvaluator"]
            end

            subgraph Adapters["OGX Provider Adapters"]
                OGXFoundation["OGXFoundationModel"]
                OGXEmbedding["OGXEmbeddingModel"]
                OGXVectorStore["OGXVectorStore"]
            end

            subgraph Local["Local (No Network)"]
                ChromaDB["ChromaDB<br/>(In-Memory, Ephemeral)"]
            end
        end
    end

    subgraph External["EXTERNAL SERVICES"]
        OGXServer["OGX Server<br/>Configurable Port<br/>TLS 1.2+<br/>API Key (Bearer)"]
    end

    %% In-process flows (no network)
    UserCode -->|"Python call<br/>(in-process)"| Experiment
    Experiment -->|"in-process"| MPS
    Experiment -->|"in-process"| GAMOpt
    GAMOpt -->|"in-process"| SimpleRAG
    SimpleRAG -->|"in-process"| Chunker
    SimpleRAG -->|"in-process"| Evaluator
    MPS -->|"in-process"| ChromaDB

    %% Network egress (all via ogx-client)
    OGXFoundation -->|"HTTPS<br/>TLS 1.2+<br/>API Key Bearer<br/>POST /chat/completions"| OGXServer
    OGXEmbedding -->|"HTTPS<br/>TLS 1.2+<br/>API Key Bearer<br/>POST /embeddings"| OGXServer
    OGXVectorStore -->|"HTTPS<br/>TLS 1.2+<br/>API Key Bearer<br/>POST /vector_stores<br/>POST /vector_io"| OGXServer

    %% Internal adapter usage
    SimpleRAG -.->|"uses"| OGXFoundation
    SimpleRAG -.->|"uses"| OGXEmbedding
    SimpleRAG -.->|"uses"| OGXVectorStore
    MPS -.->|"uses"| OGXEmbedding
    MPS -.->|"uses"| OGXFoundation

    %% Styling
    classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef library fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef adapter fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef local fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class UserCode consumer
    class Experiment,MPS,GAMOpt,SimpleRAG,Chunker,Evaluator library
    class OGXFoundation,OGXEmbedding,OGXVectorStore adapter
    class ChromaDB local
    class OGXServer external
