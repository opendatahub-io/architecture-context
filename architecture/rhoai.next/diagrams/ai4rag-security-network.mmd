graph TB
    subgraph HostProcess["HOST PROCESS (Trusted - Library Consumer)"]
        direction TB

        subgraph ai4rag["ai4rag Library (Python Package v0.5.5)"]
            direction TB
            Experiment["AI4RAGExperiment<br/>Orchestrator"]

            subgraph PreSelection["Models Pre-Selection"]
                MPS["ModelsPreSelector"]
                ChromaLocal["ChromaDB<br/>(In-process)<br/>No Network"]
            end

            subgraph OptEngine["Optimization Engine"]
                GAM["GAMOptimizer"]
                Random["RandomOptimizer"]
            end

            subgraph Pipeline["RAG Pipeline"]
                SimpleRAG["SimpleRAG"]
                Chunker["LangChainChunker<br/>(In-process)"]
                Retriever["Retriever"]
            end

            subgraph Eval["Evaluation"]
                Unitxt["UnitxtEvaluator<br/>(In-process)<br/>No Network"]
            end

            subgraph Handlers["Event Handlers"]
                LocalEH["LocalEventHandler<br/>(Disk I/O only)"]
                KFPEH["KFPEventHandler<br/>(In-memory)"]
            end
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress Only)"]
        direction TB

        subgraph LlamaStackZone["Llama Stack Server"]
            LS["Llama Stack API<br/>Port: Configurable (BASE_URL)<br/>Protocol: HTTP/HTTPS<br/>Auth: API Key (Bearer)<br/>━━━━━━━━━━━━━━━━━━━━━<br/>Services:<br/>• Embeddings<br/>• VectorIO (Milvus/Qdrant)<br/>• Chat Completions<br/>• Models List"]
        end

        subgraph OpenAIZone["OpenAI-compatible Server"]
            OAI["OpenAI-compatible API<br/>Port: Configurable<br/>Protocol: HTTP/HTTPS<br/>Auth: API Key (Bearer)<br/>━━━━━━━━━━━━━━━━━━━━━<br/>Services:<br/>• Embeddings<br/>• Chat Completions"]
        end
    end

    %% Egress flows
    SimpleRAG -->|"HTTP/HTTPS<br/>API Key (Bearer)<br/>Embeddings + Chat"| LS
    Retriever -->|"HTTP/HTTPS<br/>API Key (Bearer)<br/>VectorIO Query"| LS
    MPS -->|"HTTP/HTTPS<br/>API Key (Bearer)<br/>Model Validation"| LS

    SimpleRAG -.->|"HTTP/HTTPS<br/>API Key (Bearer)<br/>Alternative Backend"| OAI

    %% Internal flows (no network)
    Experiment --> MPS
    Experiment --> GAM
    Experiment --> Random
    GAM --> SimpleRAG
    SimpleRAG --> Chunker
    SimpleRAG --> Retriever
    MPS --> ChromaLocal
    GAM --> Unitxt
    MPS --> Unitxt
    GAM --> LocalEH
    GAM --> KFPEH

    %% Styling
    classDef hostprocess fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef library fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inprocess fill:#e1d5e7,stroke:#9673a6
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef llamastack fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef openai fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef nonetwork fill:#f5f5f5,stroke:#666,stroke-dasharray: 5 5

    class Experiment,GAM,Random,SimpleRAG,Chunker,Retriever library
    class MPS,Unitxt,ChromaLocal,LocalEH,KFPEH inprocess
    class LS llamastack
    class OAI openai
