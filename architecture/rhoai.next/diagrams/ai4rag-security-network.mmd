graph TB
    subgraph UserEnv["USER ENVIRONMENT (Notebook / Pipeline Runtime)"]
        direction TB

        User["Data Scientist / ML Engineer"]

        subgraph Library["ai4rag Library (Python Package)"]
            direction TB

            Experiment["AI4RAGExperiment<br/>Orchestration"]

            subgraph InProcess["IN-PROCESS DEPENDENCIES (No Network)"]
                direction LR
                GAM["pygam.LinearGAM<br/>Surrogate HPO"]
                Unitxt["Unitxt<br/>Evaluation Metrics"]
                LangChain["LangChain<br/>Text Splitting"]
                Chroma["ChromaDB<br/>In-Memory Vector Store"]
                SKLearn["scikit-learn<br/>LabelEncoder"]
                Pandas["pandas<br/>DataFrames"]
            end

            subgraph Clients["API CLIENTS"]
                direction LR
                LSClient["LlamaStackClient<br/>(httpx-based)"]
                OAIClient["OpenAI SDK<br/>(openai package)"]
            end

            EventHandler["EventHandler<br/>Local JSON / KFP Metadata"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        LlamaStack["Llama Stack Server<br/>Port: Configurable<br/>Protocol: HTTP/HTTPS<br/>Encryption: Configurable<br/>Auth: API Key (Bearer)<br/><br/>APIs:<br/>- /chat/completions<br/>- /embeddings<br/>- /vector_stores<br/>- /vector_io/insert<br/>- /vector_io/query<br/>- /models"]

        OpenAI["OpenAI-Compatible API<br/>Port: Configurable (typically 443)<br/>Protocol: HTTPS<br/>Encryption: TLS<br/>Auth: API Key (Bearer)<br/><br/>APIs:<br/>- /v1/chat/completions<br/>- /v1/embeddings"]
    end

    %% User to library
    User -->|"In-process<br/>Python API"| Experiment

    %% Internal flows (no network)
    Experiment --> GAM
    Experiment --> Unitxt
    Experiment --> LangChain
    Experiment --> Chroma
    Experiment --> EventHandler

    %% External network flows
    LSClient -->|"HTTP/HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>TLS: Configurable"| LlamaStack
    OAIClient -->|"HTTPS<br/>Configurable Port<br/>API Key (Bearer)<br/>TLS"| OpenAI

    Experiment --> LSClient
    Experiment --> OAIClient

    %% Styling
    classDef userenv fill:#e8f4fd,stroke:#2196F3,stroke-width:2px
    classDef library fill:#e3f2fd,stroke:#1565C0,stroke-width:2px
    classDef inprocess fill:#e8f5e9,stroke:#4CAF50,stroke-width:1px
    classDef clients fill:#fff3e0,stroke:#FF9800,stroke-width:1px
    classDef external fill:#fff8e1,stroke:#FFC107,stroke-width:2px
    classDef component fill:#bbdefb,stroke:#1976D2
    classDef extservice fill:#ffe082,stroke:#F57F17

    class User userenv
    class Experiment,EventHandler component
    class GAM,Unitxt,LangChain,Chroma,SKLearn,Pandas inprocess
    class LSClient,OAIClient clients
    class LlamaStack,OpenAI extservice
