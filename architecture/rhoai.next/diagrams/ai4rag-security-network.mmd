graph TB
    subgraph UserEnv["USER ENVIRONMENT (Notebook / Workstation)"]
        direction TB
        User["Data Scientist<br/>Jupyter Notebook / Script"]

        subgraph Library["ai4rag Library (in-process)"]
            direction TB
            Experiment["AI4RAGExperiment<br/>.search()"]

            subgraph InProcess["In-Process Components (no network)"]
                Chunker["LangChain Chunker"]
                Evaluator["Unitxt Evaluator"]
                GAM["pygam LinearGAM"]
                SKLearn["scikit-learn<br/>LabelEncoder"]
                ChromaDB["ChromaDB<br/>(in-memory)"]
            end

            subgraph APIClients["API Clients (outbound network)"]
                LSClient["Llama Stack Client<br/>(httpx)"]
                OAIClient["OpenAI Client<br/>(openai SDK)"]
            end

            EventHandler["Event Handler<br/>(Local FS / KFP)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        subgraph LlamaStack["Llama Stack Server"]
            LS_Chat["POST /inference/chat_completion"]
            LS_Embed["POST /inference/embeddings"]
            LS_Insert["POST /vector_io/insert"]
            LS_Query["POST /vector_io/query"]
            LS_Models["GET /models/list"]
            LS_VS["POST/GET/DELETE /vector_stores"]
        end

        subgraph OpenAI["OpenAI-compatible API"]
            OAI_Chat["POST /v1/chat/completions"]
            OAI_Embed["POST /v1/embeddings"]
        end
    end

    %% User to library
    User -->|"In-process<br/>Python import"| Experiment

    %% Library to external services
    LSClient -->|"HTTP/HTTPS<br/>Configurable port<br/>TLS: Configurable<br/>Auth: API Key (Bearer)"| LlamaStack
    OAIClient -->|"HTTPS<br/>Configurable port<br/>TLS: Yes<br/>Auth: API Key (Bearer)"| OpenAI

    %% Internal connections
    Experiment --> Chunker
    Experiment --> Evaluator
    Experiment --> GAM
    Experiment --> LSClient
    Experiment --> OAIClient
    Experiment --> ChromaDB
    Experiment --> EventHandler

    %% Styling - Trust zones
    classDef userenv fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef library fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inprocess fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef apiclient fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef endpoint fill:#fff,stroke:#999,stroke-width:1px

    class User userenv
    class Experiment,EventHandler library
    class Chunker,Evaluator,GAM,SKLearn,ChromaDB inprocess
    class LSClient,OAIClient apiclient
    class LS_Chat,LS_Embed,LS_Insert,LS_Query,LS_Models,LS_VS,OAI_Chat,OAI_Embed endpoint
