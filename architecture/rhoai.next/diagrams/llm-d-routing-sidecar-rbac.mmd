graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        SA_Auth["Group: system:authenticated<br/>(all authenticated users)"]
        SA_Placeholder["ServiceAccount: placeholder<br/>(to be configured)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Exec["exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        RB_SSRF["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        R_Exec["exec-role"]
        R_SSRF["ssrf-allowlist-role"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            PodsExec["pods/exec"]
            Pods["pods"]
        end

        subgraph InferenceAPI["API Group: inference.networking.x-k8s.io"]
            InferencePools["inferencepools"]
        end
    end

    %% Binding flows
    SA_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| R_Exec

    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| R_SSRF

    %% Permission flows
    R_Exec -->|"create"| PodsExec

    R_SSRF -->|"get, watch, list"| Pods
    R_SSRF -->|"get, watch, list"| InferencePools

    %% Auth & Enforcement
    subgraph SSRFProtection["SSRF Protection (Application-Level)"]
        Allowlist["AllowlistValidator<br/>Validates x-prefiller-host-port<br/>against InferencePool pod IPs"]
        Enforcement["HTTP 403 Forbidden<br/>for unauthorized targets"]
        Allowlist -->|"rejects unauthorized"| Enforcement
    end

    R_SSRF -.->|"enables data for"| Allowlist

    %% Styling
    style SA_Auth fill:#4a90e2,stroke:#333,color:#fff
    style SA_Placeholder fill:#4a90e2,stroke:#333,color:#fff
    style RB_Exec fill:#dae8fc,stroke:#6c8ebf
    style RB_SSRF fill:#dae8fc,stroke:#6c8ebf
    style R_Exec fill:#f5a623,stroke:#333,color:#fff
    style R_SSRF fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style InferencePools fill:#7ed321,stroke:#333,color:#fff
    style Allowlist fill:#f8cecc,stroke:#b85450
    style Enforcement fill:#f8cecc,stroke:#b85450
