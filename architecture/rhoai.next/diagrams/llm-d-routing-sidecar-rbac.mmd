graph TD
    subgraph "Service Accounts & Subjects"
        SA_Placeholder["ServiceAccount: placeholder<br/>(template - to be replaced)"]
        Group_Auth["Group: system:authenticated<br/>(all authenticated users)"]
    end

    subgraph "Role Bindings (Namespace: ${NAMESPACE})"
        RB_Exec["RoleBinding:<br/>${PROJECT_NAME}-exec-rolebinding"]
        RB_SSRF["RoleBinding:<br/>ssrf-allowlist-rolebinding"]
    end

    subgraph "Roles (Namespace-scoped)"
        R_Exec["Role:<br/>${PROJECT_NAME}-exec-role"]
        R_SSRF["Role:<br/>ssrf-allowlist-role"]
    end

    subgraph "API Resources (Core)"
        PodsExec["API Group: core<br/>Resource: pods/exec"]
        Pods["API Group: core<br/>Resource: pods"]
    end

    subgraph "API Resources (Inference)"
        InferencePools["API Group: inference.networking.x-k8s.io<br/>Resource: inferencepools"]
    end

    %% Exec Role chain
    Group_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| R_Exec
    R_Exec -->|"create"| PodsExec

    %% SSRF Allowlist Role chain
    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| R_SSRF
    R_SSRF -->|"get, watch, list"| Pods
    R_SSRF -->|"get, watch, list"| InferencePools

    style SA_Placeholder fill:#4a90e2,color:#fff
    style Group_Auth fill:#4a90e2,color:#fff
    style R_Exec fill:#f5a623,color:#fff
    style R_SSRF fill:#f5a623,color:#fff
    style RB_Exec fill:#e8e8e8
    style RB_SSRF fill:#e8e8e8
    style PodsExec fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style InferencePools fill:#7ed321,color:#fff
