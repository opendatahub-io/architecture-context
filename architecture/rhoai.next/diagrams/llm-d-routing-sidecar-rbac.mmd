graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Placeholder["ServiceAccount: placeholder<br/>(template - namespace scoped)"]
        Group_Auth["Group: system:authenticated<br/>(all authenticated users)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace: ${NAMESPACE})"]
        RB_Exec["RoleBinding:<br/>${PROJECT_NAME}-exec-rolebinding"]
        RB_SSRF["RoleBinding:<br/>ssrf-allowlist-rolebinding"]
    end

    subgraph Roles["Roles (Namespace-Scoped)"]
        Role_Exec["Role:<br/>${PROJECT_NAME}-exec-role"]
        Role_SSRF["Role:<br/>ssrf-allowlist-role"]
    end

    subgraph Resources_Exec["API Resources (Exec)"]
        PodsExec["API Group: core (\"\")<br/>Resource: pods/exec"]
    end

    subgraph Resources_SSRF["API Resources (SSRF Allowlist)"]
        Pods["API Group: core (\"\")<br/>Resource: pods"]
        InferencePools["API Group: inference.networking.x-k8s.io<br/>Resource: inferencepools"]
    end

    %% Exec role chain
    Group_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| Role_Exec
    Role_Exec -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| Role_SSRF
    Role_SSRF -->|"get, watch, list"| Pods
    Role_SSRF -->|"get, watch, list"| InferencePools

    %% Styling
    style SA_Placeholder fill:#4a90e2,stroke:#333,color:#fff
    style Group_Auth fill:#4a90e2,stroke:#333,color:#fff
    style RB_Exec fill:#e67e22,stroke:#333,color:#fff
    style RB_SSRF fill:#e67e22,stroke:#333,color:#fff
    style Role_Exec fill:#f5a623,stroke:#333,color:#fff
    style Role_SSRF fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style InferencePools fill:#7ed321,stroke:#333,color:#fff
