graph TD
    subgraph "Service Accounts & Groups"
        SA_Placeholder["ServiceAccount<br/>placeholder (template)"]
        Group_Auth["Group<br/>system:authenticated"]
    end

    subgraph "Role Bindings"
        RB_Exec["RoleBinding<br/>${PROJECT_NAME}-exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        RB_SSRF["RoleBinding<br/>ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph "Roles"
        Role_Exec["Role<br/>${PROJECT_NAME}-exec-role"]
        Role_SSRF["Role<br/>ssrf-allowlist-role"]
    end

    subgraph "API Resources - Exec Access"
        PodsExec["API: core ('')<br/>Resource: pods/exec"]
    end

    subgraph "API Resources - SSRF Allowlist"
        Pods["API: core ('')<br/>Resource: pods"]
        InferencePools["API: inference.networking.x-k8s.io<br/>Resource: inferencepools"]
    end

    %% Exec role chain
    Group_Auth -->|"bound via"| RB_Exec
    RB_Exec -->|"grants"| Role_Exec
    Role_Exec -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SA_Placeholder -->|"bound via"| RB_SSRF
    RB_SSRF -->|"grants"| Role_SSRF
    Role_SSRF -->|"get, watch, list"| Pods
    Role_SSRF -->|"get, watch, list"| InferencePools

    style SA_Placeholder fill:#4a90e2,color:#fff
    style Group_Auth fill:#4a90e2,color:#fff
    style RB_Exec fill:#e8e8e8
    style RB_SSRF fill:#e8e8e8
    style Role_Exec fill:#f5a623,color:#fff
    style Role_SSRF fill:#f5a623,color:#fff
    style PodsExec fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style InferencePools fill:#7ed321,color:#fff
