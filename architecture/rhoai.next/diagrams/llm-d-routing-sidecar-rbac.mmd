graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        AuthGroup["system:authenticated<br/>(Group)"]
        PlaceholderSA["placeholder<br/>(ServiceAccount)"]
    end

    subgraph RoleBindings["Role Bindings"]
        ExecBinding["${PROJECT_NAME}-exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        SSRFBinding["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Cluster Roles"]
        ExecRole["${PROJECT_NAME}-exec-role"]
        SSRFRole["ssrf-allowlist-role"]
    end

    subgraph CoreResources["API Resources: Core ('')"]
        PodsExec["pods/exec"]
        Pods["pods"]
    end

    subgraph InferenceResources["API Resources: inference.networking.x-k8s.io"]
        InferencePools["inferencepools"]
    end

    %% Bindings
    AuthGroup -->|"bound via"| ExecBinding
    PlaceholderSA -->|"bound via"| SSRFBinding

    ExecBinding -->|"grants"| ExecRole
    SSRFBinding -->|"grants"| SSRFRole

    %% Exec Role Permissions
    ExecRole -->|"create"| PodsExec

    %% SSRF Allowlist Role Permissions
    SSRFRole -->|"get, watch, list"| Pods
    SSRFRole -->|"get, watch, list"| InferencePools

    %% Notes
    Note1["Note: exec-role allows authenticated<br/>users to exec into pods<br/>(for debugging/testing)"]
    Note2["Note: ssrf-allowlist-role enables<br/>watching InferencePool CRs and<br/>matching pods for SSRF protection"]

    style AuthGroup fill:#4a90e2,stroke:#333,color:#fff
    style PlaceholderSA fill:#4a90e2,stroke:#333,color:#fff
    style ExecBinding fill:#9b59b6,stroke:#333,color:#fff
    style SSRFBinding fill:#9b59b6,stroke:#333,color:#fff
    style ExecRole fill:#f5a623,stroke:#333
    style SSRFRole fill:#f5a623,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style InferencePools fill:#7ed321,stroke:#333
    style Note1 fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
    style Note2 fill:#fff,stroke:#ccc,stroke-dasharray: 5 5
