graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP API"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE (Managed by DSPO)"]
        direction TB

        subgraph ControllerPod["workflow-controller Pod"]
            Controller["workflow-controller<br/>SA: argo<br/>UID: 8737<br/>Read-Only FS: Yes<br/>Drop caps: ALL"]
            MetricsPort["9090/TCP HTTP<br/>Metrics (no auth)"]
            HealthPort["6060/TCP HTTP<br/>Healthz (no auth)"]
        end

        subgraph StepPods["Workflow Step Pods"]
            ArgoExec["argoexec (sidecar)<br/>UID: 2000<br/>Read-Only FS: No<br/>Drop caps: ALL<br/>FIPS: dual build"]
            MainContainer["Main Container<br/>(user workload)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        GCS["GCS Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP service account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure AD"]
        HDFS["HDFS<br/>8020/TCP RPC<br/>Kerberos (optional)"]
    end

    subgraph DataStores["DATA STORES (Optional Egress)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS configurable<br/>Username/password"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS configurable<br/>Username/password"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    %% External → K8s
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% K8s → Controller (watch)
    K8sAPI -->|"Watch stream<br/>TLS 1.2+<br/>SA Token"| Controller

    %% Controller → K8s (CRUD)
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>pods, CRDs, leases"| K8sAPI

    %% Controller creates step pods
    Controller -->|"creates pods<br/>via K8s API"| StepPods

    %% ArgoExec → K8s
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>patch annotations"| K8sAPI

    %% ArgoExec → Storage
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM / access key"| S3
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+"| GCS
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+"| Azure
    ArgoExec -.->|"RPC/8020<br/>Kerberos"| HDFS

    %% Controller → DB (optional)
    Controller -.->|"TCP/5432<br/>TLS configurable<br/>Username/password"| PostgreSQL
    Controller -.->|"TCP/3306<br/>TLS configurable<br/>Username/password"| MySQL

    %% Monitoring
    Prometheus -->|"HTTP/9090<br/>No encryption<br/>No auth"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8scontrol fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef steppod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef datastore fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI k8scontrol
    class Controller,MetricsPort,HealthPort controller
    class ArgoExec,MainContainer steppod
    class S3,GCS,Azure,HDFS externalservice
    class PostgreSQL,MySQL datastore
    class Prometheus monitoring
