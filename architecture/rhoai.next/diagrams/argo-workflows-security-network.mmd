graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP API Client"]
        Client["Client / Dashboard"]
        Webhooks["GitHub / GitLab / Bitbucket<br/>Webhook Sources"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_Argo["Namespace: {install-namespace}"]
            ArgoServer["argo-server<br/>SA: argo-server<br/>ClusterIP :2746/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Bearer/SSO/Webhook"]
            WFController["workflow-controller<br/>SA: argo<br/>:9090 metrics (HTTP)<br/>:6060 health (HTTP)<br/>Leader election"]
        end

        subgraph NS_Workflow["Namespace: {workflow-namespace}"]
            ArgoExec["argoexec (sidecar)<br/>SA: {workflow-sa}<br/>No inbound ports<br/>FIPS: dual binary"]
            WorkflowPod["Workflow Pod<br/>(user workload)"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph DatabaseTier["DATABASE TIER"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>SSL optional<br/>Username/Password"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>TLS optional<br/>Username/Password"]
    end

    subgraph ArtifactStorage["ARTIFACT STORAGE"]
        S3["S3 / MinIO<br/>443 or 9000/TCP<br/>HTTPS TLS 1.2+<br/>Access Key/IAM Role"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>SA Key/Workload Identity"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>Account Key/SAS/WI"]
    end

    subgraph ExternalAuth["EXTERNAL AUTH"]
        OIDC["OIDC Provider<br/>(Keycloak)<br/>443/TCP HTTPS<br/>Client ID/Secret"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    %% External → Cluster flows
    User -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Client -->|"HTTPS/2746<br/>TLS 1.2+<br/>Bearer Token / SSO"| ArgoServer
    Webhooks -->|"HTTPS/2746<br/>TLS 1.2+<br/>HMAC-SHA256"| ArgoServer

    %% Internal flows
    ArgoServer -->|"HTTPS/6443<br/>TLS 1.2+<br/>Delegated Token"| K8sAPI
    WFController -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    ArgoExec -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Database flows
    WFController -->|"TCP/5432<br/>SSL optional<br/>Username/Password"| PostgreSQL
    ArgoServer -->|"TCP/5432<br/>SSL optional<br/>Username/Password"| PostgreSQL
    WFController -.->|"TCP/3306<br/>TLS optional"| MySQL
    ArgoServer -.->|"TCP/3306<br/>TLS optional"| MySQL

    %% Artifact flows
    ArgoExec -->|"HTTPS/9000<br/>TLS 1.2+<br/>Access Key/Secret"| S3
    ArgoServer -->|"HTTPS/9000<br/>TLS 1.2+<br/>Access Key/Secret"| S3
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+"| GCS
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+"| Azure

    %% Auth flows
    ArgoServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Client ID/Secret"| OIDC

    %% Monitoring flows
    Prometheus -->|"HTTP/9090<br/>TLS optional"| WFController
    Prometheus -->|"HTTPS/2746<br/>TLS 1.2+<br/>Auth optional"| ArgoServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,Client,Webhooks external
    class ArgoServer,WFController,ArgoExec,WorkflowPod,K8sAPI cluster
    class PostgreSQL,MySQL database
    class S3,GCS,Azure storage
    class OIDC auth
    class Prometheus monitoring
