graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP Operator"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB
        WFC["workflow-controller<br/>SA: argo<br/>Image: odh-...-workflowcontroller<br/>FIPS: strictfipsruntime<br/>:9090 metrics (HTTP)<br/>:6060 healthz (HTTP)"]
    end

    subgraph UserNS["USER NAMESPACE (Workflow Pods)"]
        direction TB
        subgraph WFPod["Workflow Pod"]
            ArgoExec["argoexec (init/sidecar)<br/>SA: {workflow-sa}<br/>Image: odh-...-argoexec<br/>FIPS: dual binary (gap)"]
            MainContainer["Main Container<br/>(user workload)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Minio<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AccessKey/SecretKey"]
        PostgreSQL["PostgreSQL (Optional)<br/>5432/TCP<br/>TLS configurable<br/>Secret credentials"]
        GCS["GCS (Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Workload Identity"]
        Azure["Azure Blob (Optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SharedKey/SAS"]
        Git["Git Repos (Optional)<br/>22/TCP SSH or 443/TCP HTTPS<br/>SSH Key/BasicAuth"]
        HDFS["HDFS (Optional)<br/>9000/TCP Hadoop RPC<br/>Kerberos/Basic"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Informer watch"| WFC
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRUD: Pods, Workflows, CRDs"| K8sAPI
    WFC -->|"Creates workflow pods"| WFPod
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>Patch TaskResult"| K8sAPI
    ArgoExec -->|"S3 API/443<br/>TLS 1.2+<br/>AccessKey/SecretKey"| S3
    ArgoExec <-->|"emptyDir<br/>/var/run/argo/<br/>Emissary pattern"| MainContainer
    WFC -->|"PostgreSQL/5432<br/>TLS configurable<br/>Secret creds"| PostgreSQL
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+<br/>SA Key"| GCS
    ArgoExec -.->|"HTTPS/443<br/>TLS 1.2+<br/>SharedKey"| Azure
    ArgoExec -.->|"SSH/22 or HTTPS/443<br/>TLS/SSH<br/>SSH Key"| Git
    ArgoExec -.->|"Hadoop RPC/9000<br/>Kerberos"| HDFS
    Prometheus -->|"HTTP/9090<br/>No encryption<br/>No auth"| WFC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e8d5f5,stroke:#9b59b6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class WFC controller
    class ArgoExec,MainContainer userns
    class S3,PostgreSQL,GCS,Azure,Git,HDFS externalservice
    class Prometheus monitoring
