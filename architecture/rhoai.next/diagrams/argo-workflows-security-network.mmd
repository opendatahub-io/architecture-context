graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP Operator"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC: ServiceAccount Bearer"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB
        WFC["workflow-controller<br/>SA: argo<br/>Image: odh-dsp-argo-workflowcontroller<br/>FIPS: strictfipsruntime"]

        subgraph Ports["Internal Endpoints (No Encryption)"]
            Metrics["Metrics<br/>9090/TCP HTTP<br/>No Auth"]
            Healthz["Healthz<br/>6060/TCP HTTP<br/>No Auth"]
        end
    end

    subgraph WorkflowNS["WORKFLOW NAMESPACE (user/pipeline)"]
        direction TB
        subgraph WFPod["Workflow Pod"]
            MainC["Main Container<br/>(pipeline step)"]
            InitExec["argoexec (init)<br/>Artifact download"]
            WaitExec["argoexec (wait)<br/>Artifact upload<br/>Result reporting"]
        end
    end

    subgraph ArtifactStorage["ARTIFACT STORAGE"]
        S3["S3 / Minio<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AccessKey/SecretKey"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccountKey"]
        Azure["Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SharedKey/SAS"]
    end

    subgraph OptionalData["OPTIONAL DATA SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS configurable<br/>Secret credentials"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS configurable<br/>Secret credentials"]
    end

    subgraph OptionalSources["OPTIONAL ARTIFACT SOURCES"]
        Git["Git Repos<br/>22/TCP SSH or 443/TCP HTTPS<br/>SSH Key / BasicAuth"]
        HDFS["HDFS<br/>9000/TCP Hadoop RPC<br/>Kerberos / Basic"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    K8sAPI <-->|"HTTPS/443<br/>TLS 1.2+<br/>SA: argo"| WFC

    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>Create Pods"| K8sAPI

    WFC -.->|"PostgreSQL/5432<br/>Configurable TLS<br/>Secret credentials"| PostgreSQL
    WFC -.->|"MySQL/3306<br/>Configurable TLS<br/>Secret credentials"| MySQL

    InitExec -->|"HTTPS/443<br/>TLS 1.2+<br/>AccessKey/SecretKey"| S3
    WaitExec -->|"HTTPS/443<br/>TLS 1.2+<br/>AccessKey/SecretKey"| S3
    InitExec -.->|"HTTPS/443<br/>TLS 1.2+"| GCS
    InitExec -.->|"HTTPS/443<br/>TLS 1.2+"| Azure
    InitExec -.->|"SSH/22 or HTTPS/443"| Git
    InitExec -.->|"Hadoop RPC/9000"| HDFS

    WaitExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer"| K8sAPI

    Prometheus -->|"HTTP/9090<br/>No encryption<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workflow fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef dataservice fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class K8sAPI controlplane
    class WFC,Metrics,Healthz controller
    class MainC,InitExec,WaitExec workflow
    class S3 storage
    class GCS,Azure optional
    class PostgreSQL,MySQL dataservice
    class Git,HDFS optional
    class Prometheus monitoring
