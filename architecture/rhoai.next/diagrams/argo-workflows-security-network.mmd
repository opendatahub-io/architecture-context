graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / DSP API"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: ServiceAccount Token<br/>AuthZ: RBAC"]
    end

    subgraph Internal["INTERNAL (Controller Namespace)"]
        direction TB

        subgraph ControllerBox["workflow-controller"]
            Controller["workflow-controller<br/>SA: argo<br/>UID: 8737<br/>Read-Only FS: Yes<br/>Capabilities: ALL dropped"]
            Metrics["Metrics: 9090/TCP HTTP<br/>No auth"]
            Healthz["Healthz: 6060/TCP HTTP<br/>No auth"]
        end

        subgraph StepPodBox["Step Pod (per workflow step)"]
            ArgoExec["argoexec (sidecar)<br/>SA: {workflow-sa}<br/>UID: 2000<br/>Capabilities: ALL dropped<br/>FIPS: dual build"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (optional)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS configurable<br/>Username/password"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS configurable<br/>Username/password"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        GCS["GCS Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        AzureBlob["Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure AD"]
        HDFS["HDFS<br/>8020/TCP RPC<br/>Kerberos optional"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    K8sAPI -->|"Watch stream<br/>TLS 1.2+<br/>SA Token"| Controller
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD CRUD, Pod mgmt,<br/>Leader Election (Lease)"| K8sAPI

    Controller -->|"Creates step pods<br/>with argoexec sidecar"| ArgoExec

    Controller -->|"TCP/5432<br/>TLS configurable<br/>Username/password<br/>Workflow archival"| PostgreSQL
    Controller -->|"TCP/3306<br/>TLS configurable<br/>Username/password<br/>Workflow archival"| MySQL

    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Patch annotations"| K8sAPI
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/access key<br/>Artifact I/O"| S3
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA<br/>Artifact I/O"| GCS
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure AD<br/>Artifact I/O"| AzureBlob
    ArgoExec -->|"RPC/8020<br/>Kerberos<br/>Artifact I/O"| HDFS

    Prometheus -->|"HTTP/9090<br/>No encryption<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,ArgoExec,Metrics,Healthz internal
    class Prometheus monitoring
    class PostgreSQL,MySQL,S3,GCS,AzureBlob,HDFS externalservice
