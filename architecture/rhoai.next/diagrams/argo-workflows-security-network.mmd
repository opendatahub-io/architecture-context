graph TB
    subgraph Platform["RHOAI PLATFORM (Trusted)"]
        direction TB

        subgraph DSPNamespace["Namespace: data-science-pipelines"]
            DSPOperator["DSP Operator<br/>SA: dspa-controller-manager"]
            DSPAPIServer["DSP API Server<br/>SA: ds-pipeline"]
        end
    end

    subgraph ControllerNamespace["CONTROLLER NAMESPACE (DSP-managed)"]
        direction TB

        Controller["workflow-controller<br/>SA: argo<br/>Image: odh-data-science-pipelines-argo-workflowcontroller<br/>Ports: 9090/TCP (metrics), 6060/TCP (health)<br/>Leader Election: coordination.k8s.io Leases"]
    end

    subgraph WorkflowNamespace["WORKFLOW NAMESPACE (Dynamic Pods)"]
        direction TB

        subgraph StepPod["Workflow Step Pod"]
            Argoexec["argoexec sidecar<br/>SA: workflow-specific<br/>Image: odh-data-science-pipelines-argo-argoexec<br/>(FIPS or non-FIPS binary)<br/>No network listener"]
            UserContainer["User Container<br/>(ML step image)"]
            SharedVol["Shared Volume<br/>/var/run/argo/"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ArtifactStore["Artifact Repository<br/>(S3/MinIO/GCS/Azure)<br/>443/TCP or 9000/TCP<br/>HTTPS TLS 1.2+<br/>IAM/AccessKey Auth"]
        SQLDB["SQL Database<br/>(MySQL 5.7+ / PostgreSQL 12+)<br/>3306/5432/TCP<br/>TLS optional<br/>Password Auth"]
        Prometheus["Prometheus<br/>Metrics Scrape"]
    end

    subgraph ArgoServerZone["ARGO SERVER (Not Shipped in RHOAI)"]
        ArgoServer["Argo Server<br/>2746/TCP gRPC/HTTPS<br/>TLS 1.2+ (self-signed or cert)<br/>Auth: Bearer Token / SSO / Server mode"]
        OIDCProvider["OIDC Provider<br/>443/TCP HTTPS<br/>OAuth2 Client Credentials"]
    end

    %% Platform → Controller
    DSPOperator -->|"Deployment management<br/>(no network call)"| Controller
    DSPAPIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Create Workflow CR"| K8sAPI

    %% Controller → K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRDs, CRUD Pods/PVCs/ConfigMaps/PDBs/Events/Leases"| K8sAPI

    %% Controller → External
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/AccessKey<br/>Artifact GC"| ArtifactStore
    Controller -.->|"TCP/3306 or 5432<br/>TLS optional<br/>Password<br/>Workflow archival"| SQLDB

    %% Argoexec → K8s API
    Argoexec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Create WorkflowTaskResult, Read Secrets"| K8sAPI

    %% Argoexec → Artifact Store
    Argoexec -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM/AccessKey<br/>Upload/download artifacts"| ArtifactStore

    %% Prometheus scrape
    Prometheus -.->|"HTTP/9090<br/>No encryption<br/>No auth<br/>Metrics scrape"| Controller

    %% Argo Server (not shipped)
    ArgoServer -.->|"HTTPS/443<br/>OAuth2<br/>SSO validation"| OIDCProvider

    %% Styling
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef executor fill:#5ba3d9,stroke:#333,stroke-width:2px,color:#fff
    classDef platform fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef k8s fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#f5a623,stroke:#333,stroke-width:2px
    classDef notshipped fill:#cccccc,stroke:#999,stroke-dasharray: 5 5
    classDef monitoring fill:#e8e8e8,stroke:#666

    class Controller controller
    class Argoexec,UserContainer,SharedVol executor
    class DSPOperator,DSPAPIServer platform
    class K8sAPI k8s
    class ArtifactStore,SQLDB external
    class ArgoServer,OIDCProvider notshipped
    class Prometheus monitoring
