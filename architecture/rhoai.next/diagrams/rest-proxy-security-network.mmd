graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>or Platform Ingress"]
    end

    subgraph PodBoundary["MODELMESH SERVING POD (Pod-level isolation)"]
        direction TB

        subgraph SidecarContainer["Sidecar: rest-proxy"]
            HTTPListener["HTTP Listener<br/>8008/TCP<br/>HTTP or HTTPS<br/>Optional TLS<br/>(MM_TLS_KEY_CERT_PATH)"]
            GRPCGateway["gRPC-Gateway<br/>REST → gRPC Translation"]
            GRPCClientConn["gRPC Client<br/>Optional TLS<br/>(REST_PROXY_USE_TLS)"]

            HTTPListener --> GRPCGateway
            GRPCGateway --> GRPCClientConn
        end

        subgraph MainContainer["Main: ModelMesh Inference"]
            GRPCInference["gRPC Inference Service<br/>8033/TCP<br/>inference.GRPCInferenceService<br/>KServe V2 Protocol"]
        end

        GRPCClientConn -->|"gRPC/8033<br/>localhost<br/>Optional TLS<br/>No Auth"| GRPCInference
    end

    subgraph Security["SECURITY CONTEXT"]
        direction TB
        FIPS["FIPS Compliant<br/>CGO_ENABLED=1<br/>strictfipsruntime<br/>OpenSSL via UBI9"]
        NoRBAC["No RBAC<br/>No K8s API Access"]
        NoAuth["No Proxy-Level Auth<br/>Delegated to Platform"]
    end

    %% Flows
    Client -->|"HTTP(S)/8008<br/>Optional TLS<br/>No Auth (proxy-level)"| HTTPListener

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef main fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5
    classDef pod fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class HTTPListener,GRPCGateway,GRPCClientConn sidecar
    class GRPCInference main
    class FIPS,NoRBAC,NoAuth security
