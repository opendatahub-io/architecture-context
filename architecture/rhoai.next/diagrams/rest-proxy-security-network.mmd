graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS"]
        MMService["ModelMesh Kubernetes Service<br/>Auth enforced at platform level"]
    end

    subgraph Pod["MODELMESH SERVING POD (Pod-local boundary)"]
        direction TB

        subgraph Sidecar["rest-proxy Sidecar Container"]
            HTTPListener["HTTP Listener<br/>8008/TCP<br/>HTTP or HTTPS<br/>Optional TLS via<br/>MM_TLS_KEY_CERT_PATH"]
            JSONMarshaler["CustomJSONPb<br/>Marshaler"]
            GRPCClient["gRPC Client<br/>MaxMsgSize: 16MB"]
        end

        subgraph MMContainer["ModelMesh Container"]
            GRPCServer["GRPCInferenceService<br/>8033/TCP gRPC<br/>Optional TLS"]
        end

        HTTPListener --> JSONMarshaler
        JSONMarshaler --> GRPCClient
    end

    %% Flows with security annotations
    Client -->|"HTTP/HTTPS<br/>Auth: Platform-enforced"| MMService
    MMService -->|"Forward to pod<br/>8008/TCP"| HTTPListener
    GRPCClient -->|"gRPC/8033<br/>localhost only<br/>Optional TLS<br/>REST_PROXY_USE_TLS<br/>Auth: None"| GRPCServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelmesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class MMService ingress
    class HTTPListener,JSONMarshaler,GRPCClient sidecar
    class GRPCServer modelmesh
