graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Platform Ingress"]
    end

    subgraph PodBoundary["POD BOUNDARY (ModelMesh Serving Pod)"]
        direction TB

        subgraph SidecarContainer["Sidecar: rest-proxy"]
            RestProxy["rest-proxy<br/>(gRPC-Gateway)<br/>Go 1.23.6<br/>FIPS: strictfipsruntime"]
            HTTPEndpoints["HTTP Endpoints:<br/>GET /v2/models/{name}<br/>GET /v2/models/{name}/versions/{ver}<br/>POST /v2/models/{name}/infer<br/>POST /v2/models/{name}/versions/{ver}/infer"]

            RestProxy --- HTTPEndpoints
        end

        subgraph InferenceContainer["Container: gRPC Inference Server"]
            GRPCSrv["GRPCInferenceService<br/>RPCs: ModelInfer, ModelMetadata,<br/>ModelReady, ServerLive, ServerReady"]
        end

        RestProxy -->|"gRPC/8033<br/>localhost<br/>TLS optional<br/>(REST_PROXY_USE_TLS)<br/>Verify: configurable<br/>(REST_PROXY_SKIP_VERIFY)<br/>Auth: None<br/>Max msg: 16 MiB"| GRPCSrv
    end

    subgraph ConfigLayer["CONFIGURATION"]
        ConfigMap["model-serving-config<br/>ConfigMap<br/>restProxy.image"]
        TLSCert["TLS Certificate<br/>(MM_TLS_KEY_CERT_PATH)<br/>Provisioned by:<br/>ModelMesh / cert-manager"]
    end

    %% Flows
    Client -->|"HTTP or HTTPS/8008<br/>TLS optional<br/>Auth: None<br/>(delegated to platform)"| RestProxy
    ConfigMap -.->|"configures<br/>sidecar image"| SidecarContainer
    TLSCert -.->|"mounted as<br/>file path"| SidecarContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef inference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class RestProxy,HTTPEndpoints sidecar
    class GRPCSrv inference
    class ConfigMap,TLSCert config
