graph TB
    subgraph External["EXTERNAL (Cluster-internal or via Platform Ingress)"]
        Client["REST Client / Application<br/>Data Scientist / ML Pipeline"]
    end

    subgraph Pod["ModelMesh Serving Pod"]
        direction TB

        subgraph Sidecar["SIDECAR: rest-proxy"]
            HTTPListener["HTTP(S) Listener<br/>Port 8008/TCP<br/>Optional TLS<br/>FIPS crypto (OpenSSL)"]
            GRPCGateway["gRPC-Gateway<br/>REST ↔ gRPC Translation"]
            GRPCUpstream["gRPC Client<br/>Port 8033/TCP<br/>Optional TLS"]

            HTTPListener --> GRPCGateway
            GRPCGateway --> GRPCUpstream
        end

        subgraph MainContainer["MAIN: ModelMesh Inference Service"]
            GRPCService["GRPCInferenceService<br/>Port 8033/TCP<br/>KServe V2 gRPC Protocol"]
        end

        GRPCUpstream -->|"gRPC/8033<br/>localhost<br/>Optional TLS<br/>No Auth"| GRPCService
    end

    subgraph Config["CONFIGURATION"]
        ConfigMap["model-serving-config<br/>ConfigMap<br/>restProxy.image"]
        TLSSecret["TLS Cert/Key Secret<br/>kubernetes.io/tls<br/>Provisioned by ModelMesh operator"]
    end

    %% Flows
    Client -->|"HTTP(S)/8008<br/>Optional TLS<br/>No proxy-level Auth"| HTTPListener

    %% Config flows
    ConfigMap -.->|"sidecar injection"| Sidecar
    TLSSecret -.->|"MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"| HTTPListener

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef maincontainer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class HTTPListener,GRPCGateway,GRPCUpstream sidecar
    class GRPCService maincontainer
    class ConfigMap,TLSSecret config
