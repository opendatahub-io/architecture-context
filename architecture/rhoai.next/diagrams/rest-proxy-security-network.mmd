graph TB
    subgraph External["EXTERNAL (Untrusted / Pod-External)"]
        Client["REST Client<br/>(KServe V2 compatible)"]
    end

    subgraph Pod["MODELMESH SERVING POD (Sidecar Boundary)"]
        direction TB

        subgraph ProxyContainer["rest-proxy Sidecar Container"]
            Proxy["rest-proxy<br/>Go 1.23 | UBI9-minimal<br/>FIPS: strictfipsruntime<br/>Listener: 8008/TCP"]
        end

        subgraph ModelMeshContainer["ModelMesh Inference Container"]
            ModelMesh["ModelMesh gRPC Service<br/>inference.GRPCInferenceService<br/>8033/TCP"]
        end
    end

    subgraph Config["CONFIGURATION"]
        ConfigMap["model-serving-config<br/>ConfigMap<br/>restProxy.image"]
    end

    %% Network Flows
    Client -->|"HTTP(S)/8008<br/>Optional TLS<br/>(MM_TLS_KEY_CERT_PATH)<br/>Auth: None (proxy-level)"| Proxy
    Proxy -->|"gRPC/8033<br/>localhost (loopback)<br/>Optional TLS<br/>(REST_PROXY_USE_TLS)<br/>Auth: None"| ModelMesh

    %% Configuration
    ConfigMap -.->|"sidecar image<br/>injection config"| ProxyContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef proxy fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef modelmesh fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Proxy proxy
    class ModelMesh modelmesh
    class ConfigMap config
