graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(via ModelMesh Service)"]
    end

    subgraph PodBoundary["POD BOUNDARY (ModelMesh Serving Pod)"]
        direction TB

        subgraph Sidecar["rest-proxy Sidecar Container"]
            RESTListener["REST Listener<br/>8008/TCP<br/>HTTP or HTTPS<br/>Optional TLS (cert/key via env)"]
        end

        subgraph MainContainer["ModelMesh Container"]
            GRPCService["gRPC Inference Service<br/>8033/TCP<br/>gRPC<br/>Optional TLS"]
        end
    end

    %% Flows with security details
    Client -->|"Port: 8008/TCP<br/>Protocol: HTTP or HTTPS<br/>Encryption: Optional TLS (SIMPLE)<br/>Auth: None (proxy-level)<br/>Auth delegated to ModelMesh"| RESTListener

    RESTListener -->|"Port: 8033/TCP<br/>Protocol: gRPC<br/>Encryption: Optional TLS<br/>Auth: None<br/>Transport: localhost"| GRPCService

    %% TLS Configuration Notes
    subgraph TLSConfig["TLS Configuration"]
        direction LR
        InboundTLS["Inbound TLS:<br/>MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"]
        OutboundTLS["Outbound TLS:<br/>REST_PROXY_USE_TLS=true<br/>REST_PROXY_SKIP_VERIFY<br/>(InsecureSkipVerify)"]
        FIPSNote["FIPS: strictfipsruntime<br/>CGO_ENABLED=1<br/>(Konflux builds only)"]
    end

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#e8f5e9,stroke:#82b366,stroke-width:2px
    classDef sidecar fill:#bbdefb,stroke:#1976d2,stroke-width:2px
    classDef main fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    classDef tlsconfig fill:#fff9c4,stroke:#f9a825,stroke-width:1px

    class Client external
    class RESTListener sidecar
    class GRPCService main
    class InboundTLS,OutboundTLS,FIPSNote tlsconfig
