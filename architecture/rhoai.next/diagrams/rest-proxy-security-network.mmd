graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["REST Client<br/>(Data Scientist / Application)"]
    end

    subgraph PodBoundary["MODELMESH SERVING POD (Pod-local boundary)"]
        direction TB

        subgraph Sidecar["rest-proxy Sidecar Container"]
            HTTPListener["HTTP Listener<br/>8008/TCP<br/>HTTP or HTTPS<br/>Optional TLS via MM_TLS_*<br/>Auth: None (upstream enforced)"]
            CustomJSON["CustomJSONPb<br/>JSON ↔ Protobuf"]
            GRPCClient["gRPC Client<br/>Max msg: 16MB default"]
        end

        subgraph MainContainer["ModelMesh Serving Container"]
            GRPCServer["gRPC V2 Predict Protocol<br/>8033/TCP<br/>Optional TLS"]
        end
    end

    subgraph Config["CONFIGURATION"]
        ConfigMap["model-serving-config<br/>ConfigMap<br/>restProxy.image"]
        TLSSecret["TLS Certificate<br/>MM_TLS_KEY_CERT_PATH<br/>Provisioned by cert-manager"]
    end

    %% Flows
    Client -->|"HTTP/HTTPS 8008/TCP<br/>Optional TLS<br/>Auth: None"| HTTPListener
    HTTPListener --> CustomJSON
    CustomJSON --> GRPCClient
    GRPCClient -->|"gRPC 8033/TCP<br/>localhost only<br/>Optional TLS<br/>Auth: None"| GRPCServer

    ConfigMap -.->|"image config"| Sidecar
    TLSSecret -.->|"TLS cert/key"| HTTPListener

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef maincontainer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef config fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class HTTPListener,CustomJSON,GRPCClient sidecar
    class GRPCServer maincontainer
    class ConfigMap,TLSSecret config
