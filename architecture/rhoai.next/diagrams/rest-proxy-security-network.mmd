graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS"]
        AuthProxy["kube-rbac-proxy /<br/>oauth-proxy sidecar<br/>Auth: Bearer Token / OAuth"]
    end

    subgraph ModelMeshPod["MODELMESH POD (Pod-internal / localhost)"]
        direction TB

        subgraph RestProxyContainer["rest-proxy Sidecar"]
            RestProxy["rest-proxy<br/>8008/TCP HTTP/HTTPS<br/>Configurable TLS<br/>No Auth (delegated)"]
        end

        subgraph ModelMeshContainer["ModelMesh Container"]
            GRPC["ModelMesh gRPC Server<br/>8033/TCP gRPC<br/>Configurable TLS<br/>No Auth"]
        end
    end

    subgraph Secrets["SECRETS & CONFIG"]
        TLSSecret["TLS cert/key<br/>kubernetes.io/tls<br/>cert-manager provisioned"]
        ConfigMap["model-serving-config<br/>ConfigMap"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OAuth"| AuthProxy
    AuthProxy -->|"HTTP or HTTPS/8008<br/>Configurable TLS<br/>No Auth (pre-authenticated)"| RestProxy
    RestProxy -->|"gRPC/8033<br/>Configurable TLS<br/>localhost only<br/>No Auth"| GRPC

    %% Config flows
    TLSSecret -.->|"MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"| RestProxy
    ConfigMap -.->|"restProxy.image<br/>sidecar injection config"| RestProxyContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef proxy fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef grpcserver fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secrets fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class AuthProxy ingress
    class RestProxy proxy
    class GRPC grpcserver
    class TLSSecret,ConfigMap secrets
