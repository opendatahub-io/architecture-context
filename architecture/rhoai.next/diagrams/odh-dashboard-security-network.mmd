graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["OpenShift Gateway<br/>HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE"]
    end

    subgraph AuthEnforcement["AUTH ENFORCEMENT"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS (dashboard-proxy-tls)<br/>Policy: list projects"]
    end

    subgraph DashboardPod["APPLICATION LAYER — odh-dashboard Pod<br/>Namespace: redhat-ods-applications"]
        direction TB

        subgraph HostContainer["SA: odh-dashboard"]
            Backend["Fastify Backend<br/>8080/TCP HTTP (pod-internal)<br/>secureRoute / secureAdminRoute"]
        end

        subgraph BFFContainers["SA: odh-dashboard-modules<br/>Auth: SAR per namespace/resource"]
            direction LR
            MR["model-registry<br/>8043/TCP HTTPS"]
            GA["gen-ai<br/>8143/TCP HTTPS"]
            MS["maas<br/>8243/TCP HTTPS"]
            ML["mlflow<br/>8343/TCP HTTPS"]
            EH["eval-hub<br/>8543/TCP HTTPS"]
            AM["automl<br/>8643/TCP HTTPS"]
            AR["autorag<br/>8743/TCP HTTPS"]
            AO["agent-ops<br/>8843/TCP HTTPS"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Cluster-internal)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA Token / User Token"]
        Thanos["Thanos Querier<br/>443/TCP HTTPS<br/>Bearer Token"]
        DSPipeline["ds-pipeline<br/>8443/TCP HTTPS<br/>userToken"]
        ModelReg["Model Registry<br/>8080/TCP HTTP<br/>userToken"]
        TrustyAI["TrustyAI<br/>443/TCP HTTPS<br/>userToken"]
        Perses["Perses<br/>8080/TCP HTTP<br/>userToken"]
    end

    subgraph AIServices["AI/ML SERVICES"]
        LlamaStack["LlamaStack<br/>443/TCP HTTPS<br/>Bearer Token"]
        MaaSGW["MaaS Gateway<br/>443/TCP HTTPS<br/>Bearer Token"]
        MLflowSrv["MLflow Tracking<br/>443/TCP HTTPS<br/>Bearer Token"]
        NeMo["NeMo Guardrails<br/>443/TCP HTTPS<br/>Bearer Token"]
        OGX["OGX<br/>8443/TCP HTTPS<br/>userToken"]
        EvalHubAPI["EvalHub API<br/>443/TCP HTTPS<br/>Bearer Token"]
        Feast["Feast Registry<br/>Dynamic HTTPS<br/>userToken"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Off-cluster)"]
        S3["AWS S3 / MinIO<br/>443/TCP HTTPS<br/>AWS SigV4"]
    end

    %% External → Ingress → Auth
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Cookie/Token"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (svc-ca cert)<br/>Bearer Token"| KRBP

    %% Auth enforcement
    KRBP -->|"HTTPS/6443<br/>TLS<br/>SA Token<br/>SubjectAccessReview"| K8sAPI
    KRBP -->|"HTTP/8080<br/>localhost<br/>X-Auth-Request-User/Groups"| Backend

    %% Backend → BFF sidecars
    Backend -->|"HTTPS/8043-8843<br/>TLS (svc cert)<br/>x-forwarded-access-token"| MR
    Backend -->|"HTTPS/8143<br/>x-forwarded-access-token"| GA
    Backend -->|"HTTPS/8243<br/>x-forwarded-access-token"| MS

    %% Inter-BFF
    GA -.->|"HTTPS/8243<br/>TLS<br/>token forwarding"| MS

    %% Backend egress
    Backend -->|"HTTPS/6443<br/>User Token"| K8sAPI
    Backend -->|"HTTPS/443<br/>Bearer"| Thanos
    Backend -->|"HTTPS/8443<br/>userToken"| DSPipeline
    Backend -->|"HTTP/8080<br/>userToken"| ModelReg
    Backend -->|"HTTPS/443<br/>userToken"| TrustyAI
    Backend -->|"HTTP/8080<br/>userToken"| Perses

    %% BFF egress
    GA -->|"HTTPS/443<br/>Bearer"| LlamaStack
    GA -->|"HTTPS/443<br/>Bearer"| NeMo
    GA -->|"HTTPS/443<br/>Bearer"| MLflowSrv
    MS -->|"HTTPS/443<br/>Bearer"| MaaSGW
    ML -->|"HTTPS/443<br/>Bearer"| MLflowSrv
    EH -->|"HTTPS/443<br/>Bearer"| EvalHubAPI
    AM -->|"HTTPS/8443<br/>userToken"| DSPipeline
    AM -->|"HTTPS/443<br/>SigV4"| S3
    AR -->|"HTTPS/8443<br/>userToken"| OGX
    AR -->|"HTTPS/443<br/>SigV4"| S3
    MR -->|"HTTPS/443<br/>Bearer"| ModelReg
    Backend -->|"HTTPS/Dynamic<br/>userToken"| Feast
    AO -->|"HTTPS/6443<br/>userToken"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef aiservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class Gateway ingress
    class KRBP auth
    class Backend,MR,GA,MS,ML,EH,AM,AR,AO app
    class K8sAPI,Thanos,DSPipeline,ModelReg,TrustyAI,Perses platform
    class LlamaStack,MaaSGW,MLflowSrv,NeMo,OGX,EvalHubAPI,Feast aiservice
    class S3 extsvc
