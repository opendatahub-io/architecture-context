graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) — Gateway API"]
        HTTPRoute["HTTPRoute<br/>data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS (service-serving-cert)<br/>SubjectAccessReview:<br/>can list projects?"]
    end

    subgraph AppLayer["APPLICATION LAYER (Dashboard Pod · 2 replicas)"]
        direction TB

        subgraph HostApp["Host — Fastify Backend (Node.js 22)"]
            Fastify["Fastify Backend<br/>8080/TCP HTTP (pod-internal)<br/>SA: odh-dashboard<br/>K8s Proxy · MF Router · WebSocket"]
        end

        subgraph BFFLayer["BFF Sidecars (Go 1.25 · TLS 1.3 · strictfipsruntime)"]
            direction TB
            MRBFF["Model Registry BFF<br/>8043/TCP HTTPS<br/>Auth: Bearer + SAR"]
            GenAIBFF["Gen AI BFF<br/>8143/TCP HTTPS<br/>Auth: RequireAccessToService"]
            MaaSBFF["MaaS BFF<br/>8243/TCP HTTPS<br/>Auth: user_token + SAR"]
            MLflowBFF["MLflow BFF<br/>8343/TCP HTTPS<br/>Auth: RequireValidIdentity"]
            EvalHubBFF["Eval Hub BFF<br/>8543/TCP HTTPS<br/>Auth: Bearer Token"]
            AutoMLBFF["AutoML BFF<br/>8643/TCP HTTPS<br/>Auth: RequestIdentity"]
            AutoRAGBFF["AutoRAG BFF<br/>8743/TCP HTTPS<br/>Auth: RequestIdentity"]
        end
    end

    subgraph PlatformSvc["PLATFORM SERVICES (In-Cluster)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS · SA/User Token"]
        ThanosQuerier["Thanos Querier<br/>9092/TCP HTTPS<br/>openshift-monitoring<br/>TLS · User Token"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        LlamaStack["LlamaStack API<br/>HTTPS · TLS 1.3<br/>Bearer Token"]
        MaaSAPI["MaaS API<br/>443/TCP HTTPS<br/>Bearer Token"]
        MLflowSvc["MLflow Tracking<br/>HTTPS · Bearer Token"]
        NeMo["NeMo Guardrails<br/>HTTPS · Bearer Token"]
        PipelineSvc["Pipeline Server (DSPA)<br/>HTTPS · Bearer Token"]
        S3["S3/MinIO<br/>443/TCP HTTPS<br/>AWS IAM credentials"]
        ModelRegistry["Model Registry<br/>HTTP/HTTPS<br/>Bearer Token"]
        ModelCatalog["Model Catalog<br/>HTTP/HTTPS<br/>Bearer Token"]
        EvalHubSvc["EvalHub/TrustyAI<br/>HTTPS · Bearer Token"]
        MCPServers["MCP Servers<br/>HTTP (no TLS)<br/>No Auth"]
        Perses["Data Science Perses<br/>8080/TCP HTTP<br/>User Token"]
    end

    %% External → Ingress → Auth → App
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| HTTPRoute
    HTTPRoute -->|"HTTPS/8443<br/>TLS (service cert)"| KubeRBACProxy
    KubeRBACProxy -->|"HTTPS/6443<br/>SA Token<br/>SubjectAccessReview"| K8sAPI
    KubeRBACProxy -->|"HTTP/8080<br/>x-forwarded-access-token<br/>x-auth-request-user<br/>x-auth-request-groups"| Fastify

    %% Fastify → BFF sidecars (all HTTPS with user token passthrough)
    Fastify -->|"HTTPS/8043<br/>user token"| MRBFF
    Fastify -->|"HTTPS/8143<br/>user token"| GenAIBFF
    Fastify -->|"HTTPS/8243<br/>user token"| MaaSBFF
    Fastify -->|"HTTPS/8343<br/>user token"| MLflowBFF
    Fastify -->|"HTTPS/8543<br/>user token"| EvalHubBFF
    Fastify -->|"HTTPS/8643<br/>user token"| AutoMLBFF
    Fastify -->|"HTTPS/8743<br/>user token"| AutoRAGBFF

    %% Inter-BFF
    GenAIBFF -.->|"HTTPS/8243<br/>inter-BFF<br/>token delegation"| MaaSBFF

    %% Host → Platform
    Fastify -->|"HTTPS/6443<br/>SA/User Token"| K8sAPI
    Fastify -->|"HTTPS/9092<br/>User Token"| ThanosQuerier

    %% BFF → External Services
    MRBFF -->|"HTTP/S<br/>Bearer"| ModelRegistry
    MRBFF -->|"HTTP/S<br/>Bearer"| ModelCatalog
    GenAIBFF -->|"HTTPS<br/>TLS 1.3<br/>Bearer"| LlamaStack
    GenAIBFF -->|"HTTPS<br/>Bearer"| MaaSAPI
    GenAIBFF -->|"HTTP/S<br/>Bearer"| MLflowSvc
    GenAIBFF -->|"HTTPS<br/>Bearer"| NeMo
    GenAIBFF -->|"HTTP<br/>no auth"| MCPServers
    MaaSBFF -->|"HTTPS<br/>Bearer"| MaaSAPI
    MLflowBFF -->|"HTTP/S<br/>Bearer"| MLflowSvc
    EvalHubBFF -->|"HTTPS<br/>Bearer"| EvalHubSvc
    AutoMLBFF -->|"HTTPS<br/>Bearer"| PipelineSvc
    AutoMLBFF -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAGBFF -->|"HTTPS<br/>Bearer"| PipelineSvc
    AutoRAGBFF -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAGBFF -->|"HTTPS<br/>Bearer"| LlamaStack
    Fastify -->|"HTTP/8080<br/>User Token"| Perses

    %% BFFs → K8s API (SAR checks + CR management)
    MRBFF -->|"HTTPS/6443"| K8sAPI
    GenAIBFF -->|"HTTPS/6443"| K8sAPI
    MaaSBFF -->|"HTTPS/6443"| K8sAPI
    MLflowBFF -->|"HTTPS/6443"| K8sAPI
    EvalHubBFF -->|"HTTPS/6443"| K8sAPI
    AutoMLBFF -->|"HTTPS/6443"| K8sAPI
    AutoRAGBFF -->|"HTTPS/6443"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#ffcdd2,stroke:#c62828,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class HTTPRoute ingress
    class KubeRBACProxy auth
    class Fastify,MRBFF,GenAIBFF,MaaSBFF,MLflowBFF,EvalHubBFF,AutoMLBFF,AutoRAGBFF app
    class K8sAPI,ThanosQuerier platform
    class LlamaStack,MaaSAPI,MLflowSvc,NeMo,PipelineSvc,S3,ModelRegistry,ModelCatalog,EvalHubSvc,MCPServers,Perses externalsvc
