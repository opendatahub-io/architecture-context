graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / Client"]
    end

    subgraph Auth["AUTHENTICATION"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Authorization Code"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        GWRoute["HTTPRoute (Gateway API)<br/>SIMPLE TLS"]
    end

    subgraph AuthBoundary["AUTHORIZATION BOUNDARY"]
        KRBP["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS Termination<br/>SubjectAccessReview: list projects<br/>Injects: x-forwarded-access-token"]
    end

    subgraph AppLayer["APPLICATION LAYER (Dashboard Pod)"]
        direction TB

        subgraph Core["Core Dashboard"]
            DashBackend["odh-dashboard Backend<br/>Node.js/Fastify<br/>SA: odh-dashboard<br/>App AuthZ: secureAdminRoute<br/>secureRoute (namespace ownership)"]
        end

        subgraph Sidecars["Federated BFF Sidecars"]
            GenAI["gen-ai BFF<br/>8143/TCP HTTPS"]
            MaaS["maas BFF<br/>8243/TCP HTTPS"]
            AutoML["automl BFF<br/>8643/TCP HTTPS"]
            AutoRAG["autorag BFF<br/>8743/TCP HTTPS"]
            EvalHub["eval-hub BFF<br/>8543/TCP HTTPS"]
            MLflowBFF["mlflow BFF<br/>8343/TCP HTTPS"]
            ModelRegBFF["model-registry BFF<br/>8043/TCP HTTPS"]
        end
    end

    subgraph PlatformSvc["PLATFORM SERVICES (In-Cluster)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>SA token + Bearer"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS TLS 1.2+<br/>SA token"]
    end

    subgraph MLSvc["ML/AI SERVICES (In-Cluster)"]
        DSPipelines["DS Pipeline API<br/>8443/TCP HTTPS TLS 1.2+<br/>Bearer (user)"]
        MLMD["DS Pipeline Metadata<br/>9090/TCP HTTP plaintext<br/>Bearer (user)"]
        ModelReg["Model Registry<br/>8080/TCP HTTP plaintext<br/>Bearer (user)"]
        TrustyAI["TrustyAI / EvalHub<br/>8080/TCP HTTP plaintext<br/>Bearer (user)"]
        LlamaStack["LlamaStack<br/>8321/TCP HTTP plaintext<br/>Bearer (user)"]
        MaaSAPI["MaaS API<br/>8443/TCP HTTPS TLS 1.2+<br/>Bearer (user)"]
        MLflowSvc["MLflow Tracking<br/>5000/TCP HTTP plaintext<br/>Bearer (user)"]
    end

    subgraph ExtSvc["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM credentials"]
        ExtHTTPS["External HTTPS<br/>443/TCP, 80/TCP<br/>Docs, support URLs"]
    end

    %% Authentication flow
    Browser -.->|"OAuth2 redirect<br/>HTTPS/443"| OAuth
    OAuth -.->|"Bearer Token issued"| Browser

    %% Ingress flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Route
    Browser -->|"HTTPS<br/>TLS<br/>Bearer Token"| GWRoute
    Route -->|"HTTPS/8443<br/>TLS Reencrypt"| KRBP
    GWRoute -->|"HTTPS/8443<br/>TLS Passthrough"| KRBP

    %% Auth to app
    KRBP -->|"HTTP/8080<br/>plaintext (localhost)<br/>x-forwarded-access-token"| DashBackend

    %% Module federation proxy
    DashBackend -->|"HTTPS TLS"| GenAI
    DashBackend -->|"HTTPS TLS"| MaaS
    DashBackend -->|"HTTPS TLS"| AutoML
    DashBackend -->|"HTTPS TLS"| AutoRAG
    DashBackend -->|"HTTPS TLS"| EvalHub
    DashBackend -->|"HTTPS TLS"| MLflowBFF
    DashBackend -->|"HTTPS TLS"| ModelRegBFF

    %% Inter-BFF
    GenAI -->|"HTTPS/8243<br/>internal token"| MaaS

    %% Platform egress
    DashBackend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA + Bearer"| K8sAPI
    DashBackend -->|"HTTPS/9092<br/>TLS 1.2+<br/>SA token"| Thanos

    %% ML service egress (from core)
    DashBackend -->|"HTTPS/8443<br/>Bearer"| DSPipelines
    DashBackend -->|"HTTP/9090<br/>Bearer"| MLMD
    DashBackend -->|"HTTP/8080<br/>Bearer"| ModelReg
    DashBackend -->|"HTTP/8080<br/>Bearer"| TrustyAI
    DashBackend -->|"HTTP/8321<br/>Bearer"| LlamaStack

    %% BFF egress
    GenAI -->|"HTTP/8321<br/>Bearer"| LlamaStack
    GenAI -->|"HTTP/5000<br/>Bearer"| MLflowSvc
    GenAI -->|"HTTPS/8443<br/>Bearer"| MaaSAPI
    MaaS -->|"HTTPS/8443<br/>Bearer"| MaaSAPI
    AutoML -->|"HTTPS/8443<br/>Bearer"| DSPipelines
    AutoML -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAG -->|"HTTPS/8443<br/>Bearer"| DSPipelines
    AutoRAG -->|"HTTP/8321<br/>Bearer"| LlamaStack
    AutoRAG -->|"HTTPS/443<br/>AWS IAM"| S3
    EvalHub -->|"HTTP/8080<br/>Bearer"| TrustyAI
    MLflowBFF -->|"HTTP/5000<br/>Bearer"| MLflowSvc
    ModelRegBFF -->|"HTTP/8080<br/>Bearer"| ModelReg

    %% External
    DashBackend -.->|"HTTPS/443<br/>HTTP/80"| ExtHTTPS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef auth fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authboundary fill:#ff9999,stroke:#cc0000,stroke-width:3px
    classDef appLayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platformsvc fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef mlsvc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class OAuth auth
    class Route,GWRoute ingress
    class KRBP authboundary
    class DashBackend,GenAI,MaaS,AutoML,AutoRAG,EvalHub,MLflowBFF,ModelRegBFF appLayer
    class K8sAPI,Thanos platformsvc
    class DSPipelines,MLMD,ModelReg,TrustyAI,LlamaStack,MaaSAPI,MLflowSvc mlsvc
    class S3,ExtHTTPS extsvc
