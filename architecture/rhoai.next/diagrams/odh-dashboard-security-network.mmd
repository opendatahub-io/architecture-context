graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>HTTPRoute PathPrefix /"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KRBP["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS (service-ca cert)<br/>AuthN: project list check<br/>Secret: dashboard-proxy-tls"]
    end

    subgraph AppLayer["APPLICATION LAYER (Dashboard Pod)"]
        direction TB

        subgraph HostContainer["Host Container"]
            Backend["Node.js Backend (Fastify)<br/>SA: odh-dashboard<br/>Port: 8080/TCP HTTP<br/>Token: dashboard-sa-token<br/>automountSAToken: false"]
        end

        subgraph BFFContainers["BFF Sidecar Containers (Go, FIPS)"]
            GenAI["gen-ai BFF<br/>8143/TCP TLS 1.3<br/>Token: modules-sa-token"]
            MaaS["maas BFF<br/>8243/TCP TLS 1.3<br/>Token: modules-sa-token"]
            ModelReg["model-registry BFF<br/>8043/TCP TLS 1.3<br/>Token: modules-sa-token"]
            MLflow["mlflow BFF<br/>8343/TCP TLS 1.3<br/>Token: modules-sa-token"]
            EvalHub["eval-hub BFF<br/>8543/TCP TLS 1.3<br/>Token: modules-sa-token"]
            AutoML["automl BFF<br/>8643/TCP TLS 1.3<br/>Token: modules-sa-token"]
            AutoRAG["autorag BFF<br/>8743/TCP TLS 1.3<br/>Token: modules-sa-token"]
            AgentOps["agent-ops BFF<br/>8843/TCP TLS 1.3<br/>Token: modules-sa-token"]
        end
    end

    subgraph ClusterServices["CLUSTER INTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA + Impersonation"]
        DSP["DataScience Pipelines<br/>8443/TCP HTTPS<br/>Bearer Token"]
        MR["Model Registry API<br/>8443/TCP HTTPS<br/>Bearer Token"]
        KServe["Model Serving (KServe)<br/>varies HTTPS<br/>Bearer Token"]
        MLMD["ML Metadata<br/>8443/TCP gRPC-web<br/>Bearer Token"]
        TrustyAI["TrustyAI<br/>varies HTTPS<br/>Bearer Token"]
        Prometheus["Prometheus/Thanos<br/>9091/TCP HTTPS<br/>Bearer Token"]
        Perses["Perses<br/>8080/TCP HTTP<br/>No Auth ⚠️"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        LlamaStack["LlamaStack Server<br/>HTTPS TLS 1.2+<br/>Bearer Token / API Key"]
        MaaSAPI["MaaS API Server<br/>HTTPS TLS<br/>Bearer Token"]
        MLflowSrv["MLflow Tracking<br/>HTTPS TLS<br/>Session Auth"]
        NeMo["NeMo Guardrails<br/>HTTPS TLS<br/>API Key"]
        MCPServers["MCP Servers<br/>Stdio/HTTP<br/>No Auth"]
    end

    %% Ingress flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>project list check"| KRBP
    KRBP -->|"HTTP/8080<br/>localhost (no TLS)<br/>X-Auth-Request-User<br/>x-forwarded-access-token"| Backend

    %% Backend to BFF sidecars
    Backend -->|"HTTPS/8143 TLS<br/>x-forwarded-access-token"| GenAI
    Backend -->|"HTTPS/8243 TLS<br/>x-forwarded-access-token"| MaaS
    Backend -->|"HTTPS/8043 TLS<br/>x-forwarded-access-token"| ModelReg
    Backend -->|"HTTPS/8343 TLS<br/>x-forwarded-access-token"| MLflow
    Backend -->|"HTTPS/8543 TLS<br/>x-forwarded-access-token"| EvalHub
    Backend -->|"HTTPS/8643 TLS<br/>x-forwarded-access-token"| AutoML
    Backend -->|"HTTPS/8743 TLS<br/>x-forwarded-access-token"| AutoRAG
    Backend -->|"HTTPS/8843 TLS<br/>x-forwarded-access-token"| AgentOps

    %% Inter-BFF
    GenAI -->|"HTTPS/8243 TLS 1.2+<br/>x-forwarded-access-token<br/>Token mgmt"| MaaS

    %% Backend to cluster services
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA + Impersonation"| K8sAPI
    Backend -->|"HTTPS/8443<br/>Bearer Token"| DSP
    Backend -->|"HTTPS/8443<br/>Bearer Token"| MR
    Backend -->|"HTTPS varies<br/>Bearer Token"| KServe
    Backend -->|"gRPC-web/8443<br/>Bearer Token"| MLMD
    Backend -->|"HTTPS varies<br/>Bearer Token"| TrustyAI
    Backend -->|"HTTPS/9091<br/>Bearer Token"| Prometheus
    Backend -->|"HTTP/8080<br/>No Auth"| Perses

    %% BFF to external services
    GenAI -->|"HTTPS TLS 1.2+<br/>Bearer Token"| LlamaStack
    GenAI -->|"HTTPS TLS<br/>Session"| MLflowSrv
    GenAI -->|"HTTPS TLS<br/>API Key"| NeMo
    GenAI -->|"Stdio/HTTP<br/>varies"| MCPServers
    MaaS -->|"HTTPS TLS<br/>Bearer Token"| MaaSAPI

    %% BFF to K8s API
    GenAI -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    MaaS -->|"HTTPS/6443<br/>SA Token"| K8sAPI
    AgentOps -->|"HTTPS/6443<br/>SA Token + SSAR"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Browser external
    class Gateway ingress
    class KRBP auth
    class Backend,GenAI,MaaS,ModelReg,MLflow,EvalHub,AutoML,AutoRAG,AgentOps app
    class K8sAPI,DSP,MR,KServe,MLMD,TrustyAI,Prometheus cluster
    class Perses warning
    class LlamaStack,MaaSAPI,MLflowSrv,NeMo,MCPServers externalservice
