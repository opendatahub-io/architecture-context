graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / Client"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Authorization Code"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route / HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt / Passthrough"]
    end

    subgraph AuthBoundary["AUTH BOUNDARY (kube-rbac-proxy)"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-ca cert (dashboard-proxy-tls)<br/>AuthN: TokenReview<br/>AuthZ: SAR (list projects)<br/>Bypass: /api/health, /api/quickstarts, /api/docs"]
    end

    subgraph AppLayer["APPLICATION LAYER (Pod Internal)"]
        direction TB

        subgraph CoreDashboard["Core Dashboard"]
            Backend["odh-dashboard BFF<br/>8080/TCP HTTP (localhost)<br/>SA: odh-dashboard<br/>App AuthZ: admin group, NS ownership"]
        end

        subgraph Sidecars["Federated BFF Sidecars"]
            direction LR
            MR["model-registry<br/>8043/TCP HTTPS"]
            GA["gen-ai<br/>8143/TCP HTTPS"]
            MS["maas<br/>8243/TCP HTTPS"]
            ML["mlflow<br/>8343/TCP HTTPS"]
            EH["eval-hub<br/>8543/TCP HTTPS"]
            AM["automl<br/>8643/TCP HTTPS"]
            AR["autorag<br/>8743/TCP HTTPS"]
        end
    end

    subgraph PlatformTLS["PLATFORM SERVICES (TLS Encrypted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS + WSS<br/>TLS 1.2+<br/>SA Token + Bearer"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS<br/>TLS 1.2+<br/>SA Token"]
        DSPipeline["DS Pipeline API<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer (user)"]
        MaaSAPI["MaaS API<br/>8443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer (user)"]
    end

    subgraph PlatformPlain["PLATFORM SERVICES (Plaintext In-Cluster)"]
        ModelReg["Model Registry<br/>8080/TCP HTTP<br/>plaintext<br/>Bearer (user)"]
        TrustyAI["TrustyAI / EvalHub<br/>8080/TCP HTTP<br/>plaintext<br/>Bearer (user)"]
        LlamaStack["LlamaStack<br/>8321/TCP HTTP<br/>plaintext<br/>Bearer (user)"]
        MLflowSvc["MLflow Server<br/>5000/TCP HTTP<br/>plaintext<br/>Bearer (user)"]
        MLMD["Pipeline Metadata<br/>9090/TCP HTTP<br/>plaintext<br/>Bearer (user)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
    end

    %% Flows
    Browser -->|"OAuth2 login<br/>HTTPS/443"| OAuthServer
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Route
    Route -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBAC
    KRBAC -->|"HTTP/8080<br/>plaintext (localhost)<br/>x-forwarded-access-token"| Backend

    Backend -->|"/_mf/* proxy<br/>HTTPS + token"| GA
    Backend -->|"/_mf/* proxy"| MR
    Backend -->|"/_mf/* proxy"| MS
    Backend -->|"/_mf/* proxy"| ML
    Backend -->|"/_mf/* proxy"| EH
    Backend -->|"/_mf/* proxy"| AM
    Backend -->|"/_mf/* proxy"| AR
    GA -.->|"inter-BFF<br/>HTTPS/8243<br/>token issuance"| MS

    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA + Bearer"| K8sAPI
    Backend -->|"HTTPS/9092<br/>TLS 1.2+<br/>SA Token"| Thanos
    Backend -->|"HTTPS/8443<br/>Bearer"| DSPipeline
    MS -->|"HTTPS/8443<br/>Bearer"| MaaSAPI

    Backend -->|"HTTP/8080<br/>plaintext<br/>Bearer"| ModelReg
    Backend -->|"HTTP/8080<br/>plaintext<br/>Bearer"| TrustyAI
    GA -->|"HTTP/8321<br/>plaintext<br/>Bearer"| LlamaStack
    ML -->|"HTTP/5000<br/>plaintext<br/>Bearer"| MLflowSvc
    Backend -->|"HTTP/9090<br/>plaintext<br/>Bearer"| MLMD

    AM -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AR -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:3px,color:#333
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef platformtls fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef platformplain fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef externalsvc fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333

    class Browser,OAuthServer external
    class Route ingress
    class KRBAC auth
    class Backend,MR,GA,MS,ML,EH,AM,AR app
    class K8sAPI,Thanos,DSPipeline,MaaSAPI platformtls
    class ModelReg,TrustyAI,LlamaStack,MLflowSvc,MLMD platformplain
    class S3 externalsvc
