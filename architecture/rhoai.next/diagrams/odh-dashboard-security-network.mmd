graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Gateway API<br/>data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS (SIMPLE)"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KRBP["kube-rbac-proxy<br/>8443/TCP → 8080/TCP<br/>TLS (service-serving-cert)<br/>SubjectAccessReview<br/>SA: odh-dashboard"]
    end

    subgraph HostApp["HOST APPLICATION (Pod Internal)"]
        Fastify["Fastify Backend<br/>8080/TCP HTTP<br/>Node.js 22 (UBI 9 FIPS)<br/>Identity header validation<br/>Admin group checks"]
    end

    subgraph BFFLayer["BFF SIDECARS (Pod Internal, Go FIPS)"]
        direction TB

        subgraph BFF_Row1[" "]
            MR["Model Registry BFF<br/>8043/TCP HTTPS<br/>TLS 1.3 min"]
            GenAI["Gen AI BFF<br/>8143/TCP HTTPS<br/>TLS 1.3 min"]
            MaaS["MaaS BFF<br/>8243/TCP HTTPS<br/>TLS 1.3 min"]
        end

        subgraph BFF_Row2[" "]
            MLflow["MLflow BFF<br/>8343/TCP HTTPS<br/>TLS 1.3 min"]
            EvalHub["Eval Hub BFF<br/>8543/TCP HTTPS<br/>TLS 1.3 min"]
            AutoML["AutoML BFF<br/>8643/TCP HTTPS<br/>TLS 1.3 min"]
        end

        subgraph BFF_Row3[" "]
            AutoRAG["AutoRAG BFF<br/>8743/TCP HTTPS<br/>TLS 1.3 min"]
        end
    end

    subgraph Platform["PLATFORM SERVICES (Cluster Internal)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA Token / User Token"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS<br/>User Token"]
        Perses["Data Science Perses<br/>8080/TCP HTTP<br/>User Token"]
    end

    subgraph UpstreamServices["UPSTREAM AI/ML SERVICES"]
        LlamaStack["LlamaStack API<br/>HTTPS TLS 1.3<br/>Bearer Token"]
        MaaSAPI["MaaS API<br/>443/TCP HTTPS<br/>Bearer Token"]
        MLflowSvc["MLflow Server<br/>HTTPS TLS<br/>Bearer Token"]
        NeMo["NeMo Guardrails<br/>HTTPS TLS<br/>Bearer Token"]
        Pipeline["Pipeline Server<br/>HTTPS TLS<br/>Bearer Token"]
        ModelReg["Model Registry<br/>HTTP/HTTPS<br/>Bearer Token"]
        EvalHubSvc["EvalHub (TrustyAI)<br/>HTTPS TLS<br/>Bearer Token"]
        S3["S3/MinIO<br/>443/TCP HTTPS<br/>AWS IAM"]
        MCP["MCP Servers<br/>HTTP<br/>No Auth"]
    end

    %% External → Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS (service cert)"| KRBP

    %% Auth → K8s (SAR check)
    KRBP -.->|"HTTPS/6443<br/>SubjectAccessReview"| K8sAPI

    %% Auth → Host
    KRBP -->|"HTTP/8080<br/>x-forwarded-access-token<br/>x-auth-request-user"| Fastify

    %% Host → BFFs
    Fastify -->|"HTTPS/8043<br/>Token passthrough"| MR
    Fastify -->|"HTTPS/8143<br/>Token passthrough"| GenAI
    Fastify -->|"HTTPS/8243<br/>Token passthrough"| MaaS
    Fastify -->|"HTTPS/8343<br/>Token passthrough"| MLflow
    Fastify -->|"HTTPS/8543<br/>Token passthrough"| EvalHub
    Fastify -->|"HTTPS/8643<br/>Token passthrough"| AutoML
    Fastify -->|"HTTPS/8743<br/>Token passthrough"| AutoRAG

    %% Inter-BFF
    GenAI -.->|"HTTPS/8243<br/>Inter-BFF<br/>Token delegation"| MaaS

    %% Host → Platform
    Fastify -->|"HTTPS/6443<br/>User Token"| K8sAPI
    Fastify -->|"HTTPS/9092<br/>User Token"| Thanos
    Fastify -->|"HTTP/8080<br/>User Token"| Perses

    %% BFFs → Upstream
    MR -->|"HTTP(S)<br/>Bearer Token"| ModelReg
    GenAI -->|"HTTPS TLS 1.3<br/>Bearer Token"| LlamaStack
    GenAI -->|"HTTPS<br/>Bearer Token"| NeMo
    GenAI -->|"HTTP<br/>No Auth"| MCP
    MaaS -->|"HTTPS/443<br/>Bearer Token"| MaaSAPI
    MLflow -->|"HTTPS<br/>Bearer Token"| MLflowSvc
    EvalHub -->|"HTTPS<br/>Bearer Token"| EvalHubSvc
    AutoML -->|"HTTPS<br/>Bearer Token"| Pipeline
    AutoML -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAG -->|"HTTPS<br/>Bearer Token"| Pipeline
    AutoRAG -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAG -->|"HTTPS TLS 1.3<br/>Bearer Token"| LlamaStack

    %% BFFs → K8s
    MR -.->|"HTTPS/6443"| K8sAPI
    GenAI -.->|"HTTPS/6443"| K8sAPI
    MaaS -.->|"HTTPS/6443"| K8sAPI
    AutoML -.->|"HTTPS/6443"| K8sAPI
    AutoRAG -.->|"HTTPS/6443"| K8sAPI
    EvalHub -.->|"HTTPS/6443"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef host fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef bff fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef upstream fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef unencrypted fill:#ffcccc,stroke:#cc0000,stroke-width:2px

    class Browser external
    class Gateway ingress
    class KRBP auth
    class Fastify host
    class MR,GenAI,MaaS,MLflow,EvalHub,AutoML,AutoRAG bff
    class K8sAPI,Thanos platform
    class Perses unencrypted
    class LlamaStack,MaaSAPI,MLflowSvc,NeMo,Pipeline,ModelReg,EvalHubSvc,S3 upstream
    class MCP unencrypted
