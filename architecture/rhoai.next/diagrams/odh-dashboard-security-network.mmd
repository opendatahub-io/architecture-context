graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser<br/>(Data Scientist / Admin)"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Gateway API<br/>(data-science-gateway)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>HTTPRoute (SIMPLE TLS)"]
    end

    subgraph AuthProxy["AUTH PROXY (Trust Boundary)"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS: service-serving-cert<br/>AuthN: SubjectAccessReview<br/>(can user list projects?)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Pod-Internal)"]
        direction TB

        Fastify["Fastify Backend<br/>8080/TCP HTTP<br/>SA: odh-dashboard<br/>Image: Node.js 22 / UBI 9"]

        subgraph BFFs["BFF Sidecars (Go 1.25 / FIPS strictfipsruntime / TLS 1.3 min)"]
            direction LR
            MR["Model Registry<br/>8043/TCP"]
            GenAI["Gen AI<br/>8143/TCP"]
            MaaS["MaaS<br/>8243/TCP"]
            MLflow["MLflow<br/>8343/TCP"]
            EvalHub["Eval Hub<br/>8543/TCP"]
            AutoML["AutoML<br/>8643/TCP"]
            AutoRAG["AutoRAG<br/>8743/TCP"]
        end

        Fastify -->|"HTTPS<br/>x-forwarded-access-token<br/>shared TLS cert"| BFFs
        GenAI -.->|"inter-BFF HTTPS/8243<br/>token delegation"| MaaS
    end

    subgraph Platform["PLATFORM SERVICES (Cluster-Internal)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA Token / User Token"]
        Thanos["Thanos Querier<br/>9092/TCP HTTPS<br/>User Token"]
        Perses["Perses<br/>8080/TCP HTTP<br/>User Token"]
    end

    subgraph Upstream["UPSTREAM DOMAIN SERVICES"]
        ModelRegSvc["Model Registry<br/>dynamic port<br/>HTTP/HTTPS<br/>Bearer Token"]
        LlamaStackSvc["LlamaStack API<br/>dynamic port<br/>HTTPS TLS 1.3<br/>Bearer Token"]
        MaaSAPI["MaaS API<br/>443/TCP HTTPS<br/>Bearer Token"]
        MLflowSvc["MLflow Server<br/>dynamic port<br/>HTTPS<br/>Bearer Token"]
        NeMoSvc["NeMo Guardrails<br/>dynamic port<br/>HTTPS<br/>Bearer Token"]
        PipelineSvr["Pipeline Server<br/>dynamic port<br/>HTTPS<br/>Bearer Token"]
        EvalHubSvc["EvalHub (TrustyAI)<br/>dynamic port<br/>HTTPS<br/>Bearer Token"]
        S3["S3/MinIO<br/>443/TCP HTTPS<br/>AWS IAM Credentials"]
        MCPServers["MCP Servers<br/>dynamic port<br/>HTTP (no TLS)<br/>No Auth"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>No user auth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service cert)<br/>Forwarded headers"| KRBP
    KRBP -->|"SubjectAccessReview<br/>HTTPS/6443"| K8sAPI
    KRBP -->|"HTTP/8080<br/>No encryption (localhost)<br/>x-forwarded-access-token<br/>x-auth-request-user<br/>x-auth-request-groups"| Fastify

    %% Platform egress
    Fastify -->|"HTTPS/6443<br/>SA/User Token"| K8sAPI
    Fastify -->|"HTTPS/9092<br/>User Token"| Thanos
    Fastify -->|"HTTP/8080<br/>User Token"| Perses

    %% BFF to upstream
    MR -->|"Bearer Token"| ModelRegSvc
    GenAI -->|"Bearer Token"| LlamaStackSvc
    GenAI -->|"Bearer Token"| NeMoSvc
    GenAI -->|"No Auth"| MCPServers
    MaaS -->|"Bearer Token"| MaaSAPI
    MLflow -->|"Bearer Token"| MLflowSvc
    EvalHub -->|"Bearer Token"| EvalHubSvc
    AutoML -->|"Bearer Token"| PipelineSvr
    AutoML -->|"AWS IAM"| S3
    AutoRAG -->|"Bearer Token"| PipelineSvr
    AutoRAG -->|"AWS IAM"| S3

    %% BFF to K8s
    BFFs -->|"HTTPS/6443<br/>SA/User Token<br/>SubjectAccessReview"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef applayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef upstream fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef insecure fill:#ffcccc,stroke:#cc0000,stroke-width:2px

    class Browser external
    class Gateway ingress
    class KRBP authproxy
    class Fastify,MR,GenAI,MaaS,MLflow,EvalHub,AutoML,AutoRAG applayer
    class K8sAPI,Thanos,Perses platform
    class ModelRegSvc,LlamaStackSvc,MaaSAPI,MLflowSvc,NeMoSvc,PipelineSvr,EvalHubSvc,S3 upstream
    class MCPServers insecure
