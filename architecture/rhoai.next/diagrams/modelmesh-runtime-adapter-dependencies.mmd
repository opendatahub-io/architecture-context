graph LR
    MRA["ModelMesh Runtime Adapter<br/>(Sidecar Container Image)"]

    %% Internal RHOAI Dependencies
    MRA -->|"gRPC server<br/>8084/TCP"| ModelMesh["ModelMesh Serving<br/>(modelmesh-serving)"]

    %% Runtime Dependencies (one per pod)
    MRA -->|"gRPC client<br/>8001/TCP"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"gRPC client<br/>8001/TCP"| MLServer["SeldonIO MLServer"]
    MRA -->|"HTTP REST client<br/>8001/TCP"| OVMS["OpenVINO Model Server"]
    MRA -->|"gRPC client<br/>7071+7070/TCP"| TorchServe["PyTorch TorchServe"]

    %% Cloud Storage Egress
    MRA -->|"HTTPS/443<br/>AccessKey auth"| S3["AWS S3 / IBM COS"]
    MRA -->|"HTTPS/443<br/>SA JSON auth"| GCS["Google Cloud Storage"]
    MRA -->|"HTTPS/443<br/>ServicePrincipal"| Azure["Azure Blob Storage"]
    MRA -->|"HTTP(S)<br/>Optional TLS"| HTTPEp["HTTP/HTTPS Endpoints"]

    %% Platform Dependencies
    MRA -.->|"volume mount<br/>/storage-config"| K8sSecrets["Kubernetes Secrets"]
    MRA -.->|"volume mount<br/>/pvc_mounts"| PVC["PVC Mounts"]

    %% Build/Runtime Dependencies
    MRA -.->|"base image"| UBI9["UBI 9 Minimal"]
    MRA -.->|"language"| Go["Go 1.23.6<br/>FIPS: strictfipsruntime"]
    MRA -.->|"Keras conversion"| Python["Python 3.11<br/>+ TensorFlow 2.19.0"]

    %% Platform Integration
    RHOAIOp["RHOAI Operator"] -.->|"configures<br/>storageHelperImage"| ModelMesh
    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"image reference"| MRA

    %% Cloud SDK Dependencies
    MRA -.->|"Go SDK"| IBMSDK["IBM COS SDK 1.9.1"]
    MRA -.->|"Go SDK"| AzureSDK["Azure SDK 0.13.2"]
    MRA -.->|"Go SDK"| GCSSDK["GCS SDK 1.28.1"]

    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style Triton fill:#f5a623,stroke:#333,color:#fff
    style MLServer fill:#f5a623,stroke:#333,color:#fff
    style OVMS fill:#f5a623,stroke:#333,color:#fff
    style TorchServe fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style Azure fill:#999,stroke:#333,color:#fff
    style HTTPEp fill:#999,stroke:#333,color:#fff
    style K8sSecrets fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
    style UBI9 fill:#e8e8e8,stroke:#333
    style Go fill:#e8e8e8,stroke:#333
    style Python fill:#9b59b6,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#333
    style IBMSDK fill:#e8e8e8,stroke:#333
