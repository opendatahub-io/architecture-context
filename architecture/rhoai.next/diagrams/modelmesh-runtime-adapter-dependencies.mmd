graph LR
    MRA["modelmesh-runtime-adapter<br/>(Multi-Binary Sidecar Image)"]

    %% Internal Platform Dependencies
    MRA -->|"gRPC server<br/>8084/TCP"| ModelMesh["ModelMesh<br/>(gRPC client → puller)"]
    MRA -->|"ConfigMap ref<br/>storageHelperImage"| MMServing["modelmesh-serving<br/>(Controller)"]

    %% Runtime Dependencies (localhost, one per pod)
    MRA -->|"gRPC client<br/>8001/TCP localhost"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"HTTP client<br/>8001/TCP localhost"| OVMS["OpenVINO<br/>Model Server"]
    MRA -->|"gRPC client<br/>8001/TCP localhost"| MLServer["Seldon<br/>MLServer"]
    MRA -->|"gRPC client<br/>7071+7070/TCP localhost"| TorchServe["PyTorch<br/>TorchServe"]

    %% External Storage Dependencies
    MRA -->|"HTTPS/443<br/>TLS 1.2+<br/>IAM credentials"| S3["S3 / MinIO / IBM COS"]
    MRA -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Principal"| Azure["Azure Blob Storage"]
    MRA -->|"HTTPS/443<br/>TLS 1.2+<br/>Service Account"| GCS["Google Cloud Storage"]
    MRA -->|"HTTP(S)<br/>Optional mTLS"| HTTPEndpoints["HTTP/HTTPS Endpoints"]
    MRA -.->|"Filesystem<br/>Symlinks"| PVC["PVC Volumes"]

    %% Build Dependencies
    MRA -.->|"build"| Go["Go 1.23.6"]
    MRA -.->|"Keras conversion"| Python["Python 3.11"]
    MRA -.->|"Keras conversion"| TensorFlow["TensorFlow 2.19.0"]
    MRA -.->|"gRPC framework"| gRPC["google.golang.org/grpc<br/>1.56.3"]
    MRA -.->|"S3 SDK"| IBMCOS["IBM COS SDK 1.9.1"]
    MRA -.->|"Azure SDK"| AzureSDK["Azure SDK (azblob)<br/>0.3.0"]
    MRA -.->|"GCS SDK"| GCSSDK["cloud.google.com/go/storage<br/>1.28.1"]
    MRA -.->|"path safety"| SecureJoin["cyphar/filepath-securejoin<br/>0.2.4"]

    %% Styling
    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style MMServing fill:#7ed321,stroke:#333,color:#fff

    style Triton fill:#775599,stroke:#333,color:#fff
    style OVMS fill:#775599,stroke:#333,color:#fff
    style MLServer fill:#775599,stroke:#333,color:#fff
    style TorchServe fill:#775599,stroke:#333,color:#fff

    style S3 fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style HTTPEndpoints fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#ddd,stroke:#333

    style Go fill:#e8e8e8,stroke:#999
    style Python fill:#e8e8e8,stroke:#999
    style TensorFlow fill:#e8e8e8,stroke:#999
    style gRPC fill:#e8e8e8,stroke:#999
    style IBMCOS fill:#e8e8e8,stroke:#999
    style AzureSDK fill:#e8e8e8,stroke:#999
    style GCSSDK fill:#e8e8e8,stroke:#999
    style SecureJoin fill:#e8e8e8,stroke:#999
