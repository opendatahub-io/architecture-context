graph LR
    MRA["ModelMesh Runtime Adapter<br/>(Sidecar Container)"]

    %% Internal RHOAI Dependencies (call INTO this component)
    ModelMesh["ModelMesh<br/>(Orchestrator)"] -->|"gRPC client<br/>8084/TCP"| MRA
    MMS["modelmesh-serving<br/>(Configuration)"] -.->|"references image in<br/>ServingRuntime CR"| MRA

    %% External Runtime Dependencies (this component calls OUT)
    MRA -->|"gRPC/8001<br/>triton-adapter"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"gRPC/8001<br/>mlserver-adapter"| MLServer["Seldon MLServer"]
    MRA -->|"HTTP/8001<br/>ovms-adapter"| OVMS["OpenVINO<br/>Model Server"]
    MRA -->|"gRPC/7071+7070<br/>torchserve-adapter"| TorchServe["TorchServe"]

    %% External Storage Dependencies
    MRA -->|"S3 SDK<br/>HTTPS/443"| S3["S3 / IBM COS"]
    MRA -->|"GCS SDK<br/>HTTPS/443"| GCS["Google Cloud<br/>Storage"]
    MRA -->|"Azure SDK<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]
    MRA -->|"HTTP GET<br/>Optional TLS"| HTTPEndpoints["HTTP(S)<br/>Endpoints"]
    MRA -->|"Filesystem<br/>symlink"| PVC["PVC Volumes"]

    %% Go Library Dependencies
    MRA -->|"gRPC framework"| gRPC["google.golang.org/grpc<br/>v1.56.3"]
    MRA -->|"protobuf"| Protobuf["google.golang.org/protobuf<br/>v1.33.0"]
    MRA -->|"logging"| Zap["go.uber.org/zap<br/>v1.24.0"]
    MRA -->|"logr interface"| CtrlRuntime["sigs.k8s.io/controller-runtime<br/>v0.14.6"]

    %% Python Dependencies (Triton Keras conversion only)
    MRA -.->|"Keras-to-TF<br/>(Triton only)"| TensorFlow["tensorflow 2.19.0<br/>+ keras 3.11.3<br/>(Python)"]

    %% Styling
    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style MMS fill:#7ed321,stroke:#333,color:#fff
    style Triton fill:#bd10e0,stroke:#333,color:#fff
    style MLServer fill:#bd10e0,stroke:#333,color:#fff
    style OVMS fill:#bd10e0,stroke:#333,color:#fff
    style TorchServe fill:#bd10e0,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HTTPEndpoints fill:#f5a623,stroke:#333,color:#fff
    style PVC fill:#f5a623,stroke:#333,color:#fff
    style gRPC fill:#e8e8e8,stroke:#333
    style Protobuf fill:#e8e8e8,stroke:#333
    style Zap fill:#e8e8e8,stroke:#333
