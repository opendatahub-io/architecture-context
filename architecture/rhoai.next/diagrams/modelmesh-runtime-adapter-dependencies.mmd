graph LR
    MRA["ModelMesh Runtime Adapter<br/>(Sidecar Container)"]

    %% Internal RHOAI Dependencies
    MRA -->|"gRPC server<br/>mmesh.ModelRuntime"| ModelMesh["ModelMesh<br/>(gRPC client)"]
    MRA -.->|"ConfigMap ref<br/>storageHelperImage"| MMController["ModelMesh Controller"]

    %% Co-located Runtime Dependencies
    MRA -->|"gRPC 8001/TCP<br/>RepositoryModelLoad"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"HTTP 8001/TCP<br/>/v1/config/reload"| OVMS["OpenVINO Model<br/>Server (OVMS)"]
    MRA -->|"gRPC 8001/TCP<br/>RepositoryModelLoad"| MLServer["Seldon MLServer"]
    MRA -->|"gRPC 7071/TCP mgmt<br/>gRPC 7070/TCP infer"| TorchServe["PyTorch<br/>TorchServe"]

    %% External Cloud Storage Dependencies
    MRA -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Static credentials"| S3["S3 / IBM COS"]
    MRA -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>SA credentials"| GCS["Google Cloud<br/>Storage"]
    MRA -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>SP credentials"| Azure["Azure Blob<br/>Storage"]
    MRA -->|"HTTP/HTTPS<br/>80-443/TCP<br/>Custom headers/mTLS"| HTTPSrv["HTTP/HTTPS<br/>Server"]

    %% Go Library Dependencies
    MRA -->|"gRPC framework"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    MRA -->|"protobuf serialization"| Protobuf["google.golang.org/protobuf<br/>v1.33.0"]
    MRA -->|"S3 storage SDK"| IBMSDK["IBM/ibm-cos-sdk-go<br/>v1.9.1"]
    MRA -->|"GCS storage SDK"| GCSSDK["cloud.google.com/go/storage<br/>v1.28.1"]
    MRA -->|"Azure storage SDK"| AzureSDK["Azure/azblob<br/>v0.3.0"]
    MRA -->|"path traversal protection"| SecureJoin["cyphar/filepath-securejoin<br/>v0.2.4"]

    %% Python/Runtime Dependencies
    MRA -->|"Keras-to-TF conversion"| TF["TensorFlow 2.19<br/>(Python runtime)"]
    MRA -->|"model loading"| Keras["Keras 3.11.3<br/>(Python runtime)"]

    %% Infrastructure Dependencies
    K8sSecret["Kubernetes Secrets<br/>(storage-config)"] -.->|"volume mount<br/>/storage-config"| MRA
    PVC["PVC Volumes<br/>(optional)"] -.->|"symlink mount<br/>/pvc_mounts"| MRA

    %% Integrators (components that use this adapter)
    ModelMesh -->|"deploys pods with"| MRA

    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style MMController fill:#7ed321,stroke:#333,color:#fff
    style Triton fill:#f5a623,stroke:#333
    style OVMS fill:#f5a623,stroke:#333
    style MLServer fill:#f5a623,stroke:#333
    style TorchServe fill:#f5a623,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style Azure fill:#e8e8e8,stroke:#333
    style HTTPSrv fill:#e8e8e8,stroke:#333
    style GRPC fill:#ddd,stroke:#999
    style Protobuf fill:#ddd,stroke:#999
    style IBMSDK fill:#ddd,stroke:#999
    style GCSSDK fill:#ddd,stroke:#999
    style AzureSDK fill:#ddd,stroke:#999
    style SecureJoin fill:#ddd,stroke:#999
    style TF fill:#9b59b6,stroke:#333,color:#fff
    style Keras fill:#9b59b6,stroke:#333,color:#fff
    style K8sSecret fill:#e74c3c,stroke:#333,color:#fff
    style PVC fill:#e1d5e7,stroke:#333
