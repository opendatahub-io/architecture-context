graph LR
    MRA["ModelMesh Runtime Adapter<br/>(Sidecar Container)"]

    %% Internal Platform Dependencies
    ModelMesh["ModelMesh<br/>(modelmesh-serving)"] -->|"gRPC client<br/>mmesh.ModelRuntime<br/>8084/TCP"| MRA

    %% Inference Runtime Dependencies (downstream)
    MRA -->|"gRPC<br/>RepositoryModelLoad/Unload<br/>8001/TCP"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"gRPC<br/>RepositoryModelLoad/Unload<br/>8001/TCP"| MLServer["SeldonIO MLServer"]
    MRA -->|"HTTP REST<br/>POST /v1/config/reload<br/>8001/TCP"| OVMS["OpenVINO Model Server"]
    MRA -->|"gRPC<br/>RegisterModel/UnregisterModel<br/>7071/TCP"| TorchServe["PyTorch TorchServe"]

    %% External Cloud Dependencies (egress)
    MRA -->|"HTTPS/443<br/>Access Key + Secret"| S3["AWS S3 / IBM COS"]
    MRA -->|"HTTPS/443<br/>Service Account JSON"| GCS["Google Cloud Storage"]
    MRA -->|"HTTPS/443<br/>Service Principal"| Azure["Azure Blob Storage"]
    MRA -->|"HTTP/HTTPS<br/>Optional TLS/headers"| HTTPEp["HTTP/HTTPS Endpoints"]

    %% Kubernetes Dependencies
    K8sSecrets["Kubernetes Secrets"] -.->|"Volume mount<br/>/storage-config"| MRA
    PVC["PVC Mounts"] -.->|"Filesystem<br/>/pvc_mounts"| MRA
    ConfigMap["model-serving-config<br/>ConfigMap"] -.->|"storageHelperImage<br/>reference"| MRA

    %% Build Dependencies
    MRA -.->|"build"| Go["Go 1.23.6"]
    MRA -.->|"runtime"| Python["Python 3.11"]
    MRA -.->|"runtime"| TF["TensorFlow 2.19.0"]
    MRA -.->|"base image"| UBI["UBI 9 Minimal"]

    %% SDK Dependencies
    MRA -.->|"SDK"| IBMCOS["IBM COS SDK 1.9.1"]
    MRA -.->|"SDK"| AzureSDK["Azure SDK 0.13.2"]
    MRA -.->|"SDK"| GCSSDK["GCS SDK 1.28.1"]

    %% Styling
    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelMesh fill:#e74c3c,stroke:#333,color:#fff
    style Triton fill:#f5a623,stroke:#333,color:#fff
    style MLServer fill:#f5a623,stroke:#333,color:#fff
    style OVMS fill:#f5a623,stroke:#333,color:#fff
    style TorchServe fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style Azure fill:#999,stroke:#333,color:#fff
    style HTTPEp fill:#999,stroke:#333,color:#fff
    style K8sSecrets fill:#326ce5,stroke:#333,color:#fff
    style PVC fill:#326ce5,stroke:#333,color:#fff
    style ConfigMap fill:#326ce5,stroke:#333,color:#fff
    style Go fill:#e8e8e8,stroke:#333
    style Python fill:#e8e8e8,stroke:#333
    style TF fill:#e8e8e8,stroke:#333
    style UBI fill:#e8e8e8,stroke:#333
    style IBMCOS fill:#e8e8e8,stroke:#333
    style AzureSDK fill:#e8e8e8,stroke:#333
    style GCSSDK fill:#e8e8e8,stroke:#333
