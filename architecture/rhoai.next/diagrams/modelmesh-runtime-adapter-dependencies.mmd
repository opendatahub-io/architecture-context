    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style HTTP fill:#f5a623,stroke:#333,color:#fff

    %% Filesystem
    style PVC fill:#e8e8e8,stroke:#999
    style StorageSecret fill:#e8e8e8,stroke:#999

