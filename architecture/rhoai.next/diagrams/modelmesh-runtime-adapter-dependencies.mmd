graph LR
    Adapter["ModelMesh Runtime Adapter<br/>(Sidecar Service)"]

    %% Internal RHOAI Dependencies
    Adapter -->|"gRPC client<br/>mmesh.ModelRuntime<br/>:8084/:8085"| ModelMesh["ModelMesh<br/>(modelmesh)"]
    MMController["ModelMesh Controller<br/>(modelmesh-controller)"] -.->|"ConfigMap ref<br/>storageHelperImage"| Adapter

    %% Co-located Runtime Dependencies
    Adapter -->|"gRPC :8001<br/>Model Repository API"| Triton["NVIDIA Triton<br/>Inference Server"]
    Adapter -->|"HTTP :8001<br/>REST Config API"| OVMS["OpenVINO<br/>Model Server"]
    Adapter -->|"gRPC :8001<br/>Inference Service API"| MLServer["Seldon<br/>MLServer"]
    Adapter -->|"gRPC :7071/:7070<br/>Management + Inference"| TorchServe["PyTorch<br/>TorchServe"]

    %% External Cloud Storage Dependencies
    Adapter -->|"HTTPS :443<br/>TLS 1.2+<br/>Static creds"| S3["S3 / IBM COS"]
    Adapter -->|"HTTPS :443<br/>TLS 1.2+<br/>SA creds"| GCS["Google Cloud<br/>Storage"]
    Adapter -->|"HTTPS :443<br/>TLS 1.2+<br/>SP creds"| Azure["Azure Blob<br/>Storage"]
    Adapter -->|"HTTP/S :80/:443<br/>mTLS optional"| HTTP["HTTP/HTTPS<br/>Server"]

    %% Kubernetes Dependencies
    K8sSecrets["Kubernetes Secrets<br/>(storage-config)"] -.->|"volume mount<br/>/storage-config"| Adapter
    PVC["PVC Filesystem"] -.->|"symlink<br/>/pvc_mounts"| Adapter

    %% Go Library Dependencies
    Adapter -->|"gRPC framework"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    Adapter -->|"protobuf"| Protobuf["google.golang.org/protobuf<br/>v1.33.0"]
    Adapter -->|"S3 SDK"| IBMSDK["IBM COS SDK<br/>v1.9.1"]
    Adapter -->|"GCS SDK"| GCSSDK["cloud.google.com/go/storage<br/>v1.28.1"]
    Adapter -->|"Azure SDK"| AzureSDK["Azure Blob SDK<br/>v0.3.0"]
    Adapter -->|"path security"| SecureJoin["filepath-securejoin<br/>v0.2.4"]

    %% Python Dependencies
    Adapter -->|"Keras→TF conversion"| TF["TensorFlow 2.19<br/>+ Keras 3.11.3"]

