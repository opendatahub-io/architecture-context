graph LR
    MRA["ModelMesh Runtime Adapter<br/>(sidecar container)"]

    %% Internal Platform Dependencies (callers / references)
    ModelMesh["ModelMesh Serving"] -->|"gRPC client<br/>mmesh.ModelRuntime<br/>:8084/:8085"| MRA
    Controller["ModelMesh Controller"] -.->|"ConfigMap reference<br/>storageHelperImage"| MRA

    %% Co-located Runtime Dependencies (same pod)
    MRA -->|"gRPC :8001<br/>RepositoryModel*"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"HTTP :8001<br/>/v1/config/reload"| OVMS["OpenVINO<br/>Model Server"]
    MRA -->|"gRPC :8001<br/>RepositoryModel*"| MLServer["Seldon<br/>MLServer"]
    MRA -->|"gRPC :7071/:7070<br/>Register/Unregister/Ping"| TorchServe["PyTorch<br/>TorchServe"]

    %% External Storage Dependencies
    MRA -->|"HTTPS :443<br/>TLS 1.2+<br/>Static credentials"| S3["S3 / IBM COS"]
    MRA -->|"HTTPS :443<br/>TLS 1.2+<br/>Service account"| GCS["Google Cloud<br/>Storage"]
    MRA -->|"HTTPS :443<br/>TLS 1.2+<br/>Service principal"| Azure["Azure Blob<br/>Storage"]
    MRA -->|"HTTPS :443<br/>TLS 1.2+ / mTLS"| HTTP["HTTP/HTTPS<br/>Server"]

    %% Filesystem Dependencies
    MRA -.->|"filesystem mount"| PVC["PVC<br/>Filesystem"]
    MRA -.->|"mounted credentials"| StorageSecret["/storage-config<br/>Secret"]

    %% Go Library Dependencies
    MRA -.->|"gRPC framework"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    MRA -.->|"protobuf"| Protobuf["google.golang.org/protobuf<br/>v1.33.0"]
    MRA -.->|"GCS SDK"| GCSSDK["cloud.google.com/go/storage<br/>v1.28.1"]
    MRA -.->|"Azure SDK"| AzureSDK["azure-sdk-for-go/azblob<br/>v0.3.0"]
    MRA -.->|"S3 SDK"| IBMSDK["IBM/ibm-cos-sdk-go<br/>v1.9.1"]
    MRA -.->|"path security"| SecureJoin["cyphar/filepath-securejoin<br/>v0.2.4"]

    %% Python Dependencies
    MRA -.->|"Keras→TF conversion"| TF["TensorFlow 2.19.0<br/>+ Keras 3.11.3"]

    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (callers)
