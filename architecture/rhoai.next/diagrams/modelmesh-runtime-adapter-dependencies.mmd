graph LR
    MRA["modelmesh-runtime-adapter<br/>(Sidecar Container)"]

    %% Internal Platform Dependencies
    MRA -->|"gRPC server :8084<br/>model lifecycle"| ModelMesh["ModelMesh<br/>(modelmesh-serving)"]
    MRA -->|"gRPC client :8001<br/>model load/unload"| Triton["NVIDIA Triton<br/>Inference Server"]
    MRA -->|"gRPC client :8001<br/>model load/unload"| MLServer["Seldon MLServer"]
    MRA -->|"HTTP client :8001<br/>config reload"| OVMS["OpenVINO Model Server<br/>(OVMS)"]
    MRA -->|"gRPC client :7071/:7070<br/>register/unregister"| TorchServe["PyTorch TorchServe"]
    MRA -.->|"volume mount<br/>/storage-config"| K8sSecrets["Kubernetes Secrets"]

    %% External Cloud Storage Dependencies
    MRA -->|"HTTPS :443<br/>AWS IAM"| S3["AWS S3 / IBM COS /<br/>MinIO"]
    MRA -->|"HTTPS :443<br/>GCP SA JWT"| GCS["Google Cloud Storage"]
    MRA -->|"HTTPS :443<br/>Service Principal"| Azure["Azure Blob Storage"]
    MRA -->|"HTTP/HTTPS<br/>Custom Auth"| HTTPEndpoints["HTTP/HTTPS<br/>Model Endpoints"]

    %% Build / Language Dependencies
    MRA -.->|"primary language"| Go["Go 1.23.6"]
    MRA -.->|"Keras conversion"| Python["Python 3.11<br/>TensorFlow 2.19.0"]

    %% Key Library Dependencies
    MRA -.->|"gRPC framework"| GRPC["google.golang.org/grpc<br/>v1.56.3"]
    MRA -.->|"S3 SDK"| IBMCOS["IBM COS SDK<br/>(S3-compatible)<br/>v1.9.1"]
    MRA -.->|"GCS SDK"| GCSSDK["cloud.google.com/go/storage<br/>v1.28.1"]
    MRA -.->|"Azure SDK"| AzureSDK["Azure Blob SDK<br/>v0.3.0"]
    MRA -.->|"path security"| SecureJoin["filepath-securejoin<br/>v0.2.4"]

    %% Integration Points (components that call into adapter)
    ModelMesh -->|"deploys as<br/>storageHelperImage"| MRA

    %% Styling
    style MRA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (green)
    style ModelMesh fill:#7ed321,stroke:#333,color:#fff
    style Triton fill:#7ed321,stroke:#333,color:#fff
    style MLServer fill:#7ed321,stroke:#333,color:#fff
    style OVMS fill:#7ed321,stroke:#333,color:#fff
    style TorchServe fill:#7ed321,stroke:#333,color:#fff
    style K8sSecrets fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff
    style HTTPEndpoints fill:#f5a623,stroke:#333,color:#fff

    %% Build dependencies (grey)
    style Go fill:#e8e8e8,stroke:#333
    style Python fill:#e8e8e8,stroke:#333
    style GRPC fill:#e8e8e8,stroke:#333
    style IBMCOS fill:#e8e8e8,stroke:#333
    style GCSSDK fill:#e8e8e8,stroke:#333
    style AzureSDK fill:#e8e8e8,stroke:#333
    style SecureJoin fill:#e8e8e8,stroke:#333
