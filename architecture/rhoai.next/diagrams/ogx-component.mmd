graph TB
    subgraph OGX["Llama Stack Server (ogx)"]
        direction TB

        subgraph ServerLayer["Server Layer"]
            Server["FastAPI/uvicorn Server<br/>Port 8321/TCP"]
            TracingMW["Tracing Middleware<br/>W3C TraceContext"]
            AuthMW["Authentication Middleware<br/>OAuth2 JWT / Custom"]
            QuotaMW["Quota Middleware<br/>Rate Limiting"]
            RouteReg["Dynamic Route Registration<br/>Protocol-to-HTTP mapping"]
        end

        subgraph APILayer["API Layer (18 APIs)"]
            InferenceAPI["Inference API<br/>/v1/inference/*"]
            OpenAIAPI["OpenAI-Compatible API<br/>/v1/openai/v1/*"]
            AgentsAPI["Agents API<br/>/v1/agents/*"]
            SafetyAPI["Safety API<br/>/v1/safety/*"]
            VectorAPI["Vector I/O API<br/>/v1/vector-io/*"]
            EvalAPI["Eval API<br/>/v1/eval/*"]
            ToolsAPI["Tools API<br/>/v1/tool-runtime/*"]
            TelemetryAPI["Telemetry API<br/>/v1/telemetry/*"]
            ModelsAPI["Models API<br/>/v1/models"]
            DatasetsAPI["Datasets API<br/>/v1/datasets"]
            ScoringAPI["Scoring API<br/>/v1/scoring/*"]
            PostTrainAPI["Post-Training API<br/>/v1/post-training/*"]
        end

        subgraph ProviderLayer["Provider Framework"]
            Resolver["Provider Resolver<br/>Dependency Injection<br/>Topological Sort"]
            InlineProviders["Inline Providers (19)<br/>In-process execution"]
            RemoteProviders["Remote Providers (41)<br/>External service adapters"]
        end

        subgraph AccessControlLayer["Access Control"]
            ABAC["ABAC Engine<br/>Cedar-like Policy Language"]
            PolicyRules["Permit/Forbid Rules<br/>Principal, Action, Resource"]
        end

        subgraph DistributionLayer["Distribution System"]
            Templates["Distribution Templates (25)<br/>starter, remote-vllm, etc."]
            BuildConfig["build.yaml Generator"]
            RunConfig["run.yaml Generator"]
        end

        CLI["CLI Tool (llama)<br/>Build, Run, Configure"]
        LibClient["Library Client<br/>Direct Python API"]
    end

    %% Server Layer Flow
    Server --> TracingMW
    TracingMW --> AuthMW
    AuthMW --> QuotaMW
    QuotaMW --> RouteReg
    RouteReg --> APILayer

    %% API to Provider routing
    InferenceAPI --> Resolver
    OpenAIAPI --> Resolver
    AgentsAPI --> Resolver
    SafetyAPI --> Resolver
    VectorAPI --> Resolver
    EvalAPI --> Resolver
    ToolsAPI --> Resolver
    TelemetryAPI --> Resolver
    ScoringAPI --> Resolver
    PostTrainAPI --> Resolver

    Resolver --> InlineProviders
    Resolver --> RemoteProviders

    %% Access Control
    AuthMW --> ABAC
    ABAC --> PolicyRules

    %% Distribution
    Templates --> BuildConfig
    Templates --> RunConfig
    RunConfig -->|configures| Server
    CLI -->|manages| Templates
    LibClient -->|bypasses| Server

    %% External connections
    Client["Client<br/>(HTTP/Library)"] -->|8321/TCP| Server
    Client -.->|Direct Python| LibClient

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style AuthMW fill:#e74c3c,stroke:#333,color:#fff
    style ABAC fill:#e74c3c,stroke:#333,color:#fff
    style Resolver fill:#f5a623,stroke:#333,color:#fff
    style InlineProviders fill:#7ed321,stroke:#333,color:#fff
    style RemoteProviders fill:#9b59b6,stroke:#333,color:#fff
    style Templates fill:#3498db,stroke:#333,color:#fff
    style CLI fill:#95a5a6,stroke:#333,color:#fff
    style LibClient fill:#95a5a6,stroke:#333,color:#fff
    style Client fill:#ecf0f1,stroke:#333
