graph TB
    subgraph OGX["ogx (Llama Stack) Service"]
        direction TB

        subgraph Server["Llama Stack Server (FastAPI/Uvicorn)"]
            direction LR
            AuthMW["AuthenticationMiddleware<br/>(ASGI)"]
            QuotaMW["QuotaMiddleware<br/>(Rate Limiting)"]
            DynRoutes["Dynamic Route Generator<br/>(@webmethod introspection)"]
            SSE["SSE Streaming<br/>(Server-Sent Events)"]
            TLS["TLS/mTLS Handler<br/>(ssl stdlib)"]
        end

        subgraph Auth["Access Control"]
            direction LR
            OAuth2["OAuth2/JWT Provider<br/>(JWKS + Introspection)"]
            CustomAuth["Custom Auth Provider<br/>(External Endpoint)"]
            ABAC["Cedar-like ABAC Engine<br/>(permit/forbid rules)"]
        end

        subgraph Routing["Routing Layer"]
            direction LR
            InfRouter["InferenceRouter"]
            AgentRouter["AgentRouter"]
            SafetyRouter["SafetyRouter"]
            VecRouter["VectorIORouter"]
            EvalRouter["EvalRouter"]
            ToolRouter["ToolRuntimeRouter"]
            OtherRouters["+ 13 more API routers"]
        end

        subgraph Providers["Provider System"]
            direction TB
            subgraph Inline["Inline Providers (in-process)"]
                MetaRef["meta-reference<br/>(inference)"]
                SQLiteVec["sqlite-vec<br/>(vector store)"]
                FAISS["FAISS<br/>(vector search)"]
                LocalFS["Local File Storage"]
            end
            subgraph Remote["Remote Providers (proxy)"]
                RemVLLM["remote-vllm"]
                RemOllama["remote-ollama"]
                RemOpenAI["remote-openai"]
                RemAnthropic["remote-anthropic"]
                RemBedrock["remote-bedrock"]
                RemChroma["remote-chromadb"]
                RemPG["remote-pgvector"]
                RemMore["+ many more"]
            end
        end

        subgraph Distribution["Distribution System"]
            Templates["24 Built-in Templates<br/>(YAML configs)"]
            Resolver["Provider Resolver<br/>(topological sort)"]
            Builder["Build System<br/>(container/conda/venv)"]
        end

        subgraph CLI_Block["CLI (llama)"]
            Build["llama stack build"]
            Run["llama stack run"]
        end
    end

    %% External API Surface
    Client["API Client"] -->|"POST /v1/inference/*<br/>POST /v1/agents/*<br/>POST /v1/openai/v1/*<br/>76 endpoints on 8321/TCP"| TLS
    TLS --> AuthMW
    AuthMW --> QuotaMW
    QuotaMW --> DynRoutes
    DynRoutes --> Routing

    AuthMW -->|"validates token"| Auth
    ABAC -->|"enforces policy"| Routing

    %% Routing to Providers
    InfRouter -->|"auto-route by model"| Providers
    AgentRouter -->|"orchestrates"| Providers
    SafetyRouter -->|"shield dispatch"| Providers
    VecRouter -->|"vector ops"| Providers

    %% CLI to Distribution
    CLI_Block -->|"configures & launches"| Distribution
    Distribution -->|"resolves providers"| Server

    %% External connections from Remote Providers
    RemVLLM -->|"HTTP/HTTPS"| vLLM["vLLM Server"]
    RemOllama -->|"HTTP :11434"| Ollama["Ollama Server"]
    RemOpenAI -->|"HTTPS :443"| OpenAIAPI["OpenAI API"]
    RemAnthropic -->|"HTTPS :443"| AnthropicAPI["Anthropic API"]
    RemBedrock -->|"HTTPS :443"| Bedrock["AWS Bedrock"]
    RemChroma -->|"HTTP/HTTPS"| ChromaDB["ChromaDB"]
    RemPG -->|"PostgreSQL :5432"| PGVector["PostgreSQL<br/>(pgvector)"]

    %% Optional UI
    StreamlitUI["Streamlit Playground UI<br/>8501/TCP"] -.->|"HTTP"| TLS

    %% Styling
    style Server fill:#4a90e2,color:#fff
    style Auth fill:#e74c3c,color:#fff
    style Routing fill:#2ecc71,color:#fff
    style Inline fill:#8e44ad,color:#fff
    style Remote fill:#f39c12,color:#fff
    style Distribution fill:#3498db,color:#fff
    style CLI_Block fill:#1abc9c,color:#fff
    style Client fill:#ecf0f1,stroke:#333,stroke-width:2px
    style vLLM fill:#999,stroke:#333
    style Ollama fill:#999,stroke:#333
    style OpenAIAPI fill:#999,stroke:#333
    style AnthropicAPI fill:#999,stroke:#333
    style Bedrock fill:#999,stroke:#333
    style ChromaDB fill:#999,stroke:#333
    style PGVector fill:#999,stroke:#333
    style StreamlitUI fill:#95a5a6,stroke:#333
