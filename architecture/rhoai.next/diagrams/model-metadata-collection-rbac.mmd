graph TD
    subgraph "Runtime Security Profile"
        direction TB
        Container["odh-model-metadata-collection<br/>(Data Container)"]
        UID["User: UID 1001<br/>(non-root)"]
        NoSA["No elevated ServiceAccount"]
    end

    subgraph "Kubernetes API Access"
        NoAccess["NONE<br/>Container has no<br/>Kubernetes API access"]
    end

    subgraph "RBAC Resources"
        NoCR["No ClusterRoles defined"]
        NoRB["No RoleBindings defined"]
        NoCRB["No ClusterRoleBindings defined"]
    end

    subgraph "Network Permissions"
        NoIngress["No Ingress<br/>(no Services exposed)"]
        NoEgress["No Runtime Egress<br/>(data-only container)"]
        NoPorts["No Ports<br/>(no network listeners)"]
    end

    subgraph "Build-Time Secrets"
        direction TB
        HFToken["HF_TOKEN<br/>Type: env var<br/>Purpose: HuggingFace API auth<br/>Provisioned: Manual<br/>Rotation: None<br/>Note: Build-time only"]
        GitAuth["git_auth_secret<br/>Type: Opaque (Tekton)<br/>Purpose: Git checkout<br/>Provisioned: Konflux/PaC<br/>Rotation: Auto"]
        QuayCreds["QUAY_USERNAME / QUAY_PASSWORD<br/>Type: Opaque (GitHub)<br/>Purpose: Registry push<br/>Provisioned: Manual<br/>Rotation: None"]
    end

    Container --- UID
    Container --- NoSA
    Container -->|"zero API access"| NoAccess
    NoAccess -->|"no RBAC needed"| NoCR
    NoAccess -->|"no RBAC needed"| NoRB
    NoAccess -->|"no RBAC needed"| NoCRB
    Container -->|"zero network surface"| NoIngress
    Container -->|"zero network surface"| NoEgress
    Container -->|"zero network surface"| NoPorts

    %% Styling
    style Container fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    style UID fill:#d5e8d4,stroke:#82b366
    style NoSA fill:#d5e8d4,stroke:#82b366
    style NoAccess fill:#f5f5f5,stroke:#999
    style NoCR fill:#f5f5f5,stroke:#999
    style NoRB fill:#f5f5f5,stroke:#999
    style NoCRB fill:#f5f5f5,stroke:#999
    style NoIngress fill:#d5e8d4,stroke:#82b366
    style NoEgress fill:#d5e8d4,stroke:#82b366
    style NoPorts fill:#d5e8d4,stroke:#82b366
    style HFToken fill:#fff2cc,stroke:#d6b656
    style GitAuth fill:#fff2cc,stroke:#d6b656
    style QuayCreds fill:#fff2cc,stroke:#d6b656
