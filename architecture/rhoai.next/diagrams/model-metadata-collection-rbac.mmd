graph TD
    subgraph "model-metadata-collection RBAC"
        direction TB
        Note["This component has NO RBAC requirements"]
    end

    subgraph "Build-Time (CI/CD)"
        direction TB
        ExtractorCLI["model-extractor CLI<br/>(runs outside cluster)"]
        NoK8sAccess1["No Kubernetes API access<br/>No ServiceAccount<br/>No ClusterRole"]
        ExtractorCLI --- NoK8sAccess1
    end

    subgraph "Runtime (Kubernetes)"
        direction TB
        DataContainer["odh-model-metadata-collection<br/>Init Container / Sidecar"]
        NoK8sAccess2["No Kubernetes API access<br/>No ServiceAccount required<br/>No ClusterRole<br/>No RBAC bindings"]
        DataContainer --- NoK8sAccess2
    end

    subgraph "Secrets (CI/CD Only)"
        direction TB
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace API auth<br/>Provisioned: Manual (.env)<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret<br/>Type: Opaque (Tekton)<br/>Purpose: Git auth for Konflux<br/>Provisioned: Konflux RHTAP<br/>Auto-Rotate: No"]
        QuayCreds["QUAY_USERNAME / QUAY_PASSWORD<br/>Type: Opaque (GitHub Actions)<br/>Purpose: Quay.io registry push<br/>Provisioned: GitHub Secrets<br/>Auto-Rotate: No"]
    end

    ExtractorCLI -.->|"uses (optional)"| HFToken
    ExtractorCLI -.->|"used by Tekton"| GitAuth
    ExtractorCLI -.->|"used by GH Actions"| QuayCreds

    style Note fill:#f0f0f0,stroke:#999,stroke-width:2px
    style ExtractorCLI fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style NoK8sAccess1 fill:#e0e0e0,stroke:#999,stroke-dasharray: 5 5
    style NoK8sAccess2 fill:#e0e0e0,stroke:#999,stroke-dasharray: 5 5
    style HFToken fill:#fff3e0,stroke:#e65100
    style GitAuth fill:#fff3e0,stroke:#e65100
    style QuayCreds fill:#fff3e0,stroke:#e65100
