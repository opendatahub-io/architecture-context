graph TD
    subgraph "Runtime Security Profile"
        DC["odh-model-metadata-collection<br/>Data Container"]
    end

    subgraph "Container Security Context"
        UID["UID: 1001<br/>(non-root)"]
        NoAPI["Kubernetes API Access: NONE"]
        NoNet["Network Listeners: NONE"]
        NoEgress["Runtime Egress: NONE"]
        NoIngress["Runtime Ingress: NONE"]
    end

    subgraph "RBAC Configuration"
        NoCR["ClusterRoles: NONE"]
        NoRB["RoleBindings: NONE"]
        NoSA["ServiceAccount Privileges: NONE"]
    end

    subgraph "Build-Time Secrets (NOT in shipped image)"
        HFToken["HF_TOKEN<br/>Type: env var<br/>Purpose: HuggingFace API auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret<br/>Type: Opaque (Tekton)<br/>Purpose: Git checkout<br/>Provisioned: Konflux/PaC<br/>Auto-Rotate: Yes"]
        QuayCreds["QUAY_USERNAME / QUAY_PASSWORD<br/>Type: Opaque (GitHub)<br/>Purpose: Registry push<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Data Access Model"
        VolMount["Volume Mount: /app/data<br/>Access: Read-only by consumers<br/>Auth: Pod-level RBAC<br/>No network involved"]
    end

    DC --> UID
    DC --> NoAPI
    DC --> NoNet
    DC --> NoEgress
    DC --> NoIngress

    DC -->|"no RBAC required"| NoCR
    NoCR --- NoRB
    NoRB --- NoSA

    DC -->|"data served via"| VolMount

    %% Build-time only notation
    HFToken -.->|"build-time only"| DC
    GitAuth -.->|"build-time only"| DC
    QuayCreds -.->|"build-time only"| DC

    style DC fill:#e1d5e7,stroke:#9673a6,stroke-width:3px
    style UID fill:#d5e8d4,stroke:#82b366
    style NoAPI fill:#d5e8d4,stroke:#82b366
    style NoNet fill:#d5e8d4,stroke:#82b366
    style NoEgress fill:#d5e8d4,stroke:#82b366
    style NoIngress fill:#d5e8d4,stroke:#82b366
    style NoCR fill:#d5e8d4,stroke:#82b366
    style NoRB fill:#d5e8d4,stroke:#82b366
    style NoSA fill:#d5e8d4,stroke:#82b366
    style HFToken fill:#fff2cc,stroke:#d6b656
    style GitAuth fill:#fff2cc,stroke:#d6b656
    style QuayCreds fill:#fff2cc,stroke:#d6b656
    style VolMount fill:#dae8fc,stroke:#6c8ebf
