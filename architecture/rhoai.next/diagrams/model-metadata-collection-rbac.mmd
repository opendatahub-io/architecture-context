graph TD
    subgraph "model-metadata-collection RBAC"
        direction TB
        Note["This component does NOT interact<br/>with Kubernetes RBAC"]
    end

    subgraph "Build-Time Secrets (CI/CD Only)"
        HF_TOKEN["HF_TOKEN<br/>(Environment Variable)<br/>HuggingFace API auth<br/>Provisioned: Manual (.env / CI)<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret<br/>(Opaque)<br/>Git auth for Tekton pipeline<br/>Provisioned: Konflux/PipelinesAsCode<br/>Auto-Rotate: No"]
        QuayCreds["QUAY_USERNAME / QUAY_PASSWORD<br/>(GitHub Secret)<br/>Container registry push auth<br/>Provisioned: Manual (GH secrets)<br/>Auto-Rotate: No"]
    end

    subgraph "Secret Usage"
        Extractor["model-extractor<br/>(CI/CD build tool)"]
        Konflux["Konflux Tekton Pipeline"]
        GitHubCI["GitHub Actions CI"]
    end

    subgraph "Runtime (No RBAC)"
        DataContainer["odh-model-metadata-collection<br/>(Data Container)<br/>No ClusterRoles<br/>No RoleBindings<br/>No ServiceAccounts<br/>No API server access"]
    end

    %% Secret bindings
    HF_TOKEN -->|"Bearer Token<br/>(optional)"| Extractor
    GitAuth -->|"git clone auth"| Konflux
    QuayCreds -->|"registry push auth"| GitHubCI

    %% Runtime note
    DataContainer -.->|"No RBAC required<br/>Static data container<br/>sleep infinity"| Note

    %% Styling
    style Note fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style HF_TOKEN fill:#fff2cc,stroke:#d6b656
    style GitAuth fill:#fff2cc,stroke:#d6b656
    style QuayCreds fill:#fff2cc,stroke:#d6b656
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333
    style GitHubCI fill:#e8e8e8,stroke:#333
    style DataContainer fill:#d5e8d4,stroke:#82b366
