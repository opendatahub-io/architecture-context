graph TD
    subgraph "Runtime Security Posture"
        subgraph "Data Container"
            Container["odh-model-metadata-collection<br/>(UBI9-minimal)"]
            UID["User: UID 1001<br/>(non-root)"]
            NoAPI["No Kubernetes API Access"]
            NoPorts["No Network Listeners"]
            NoEgress["No Egress Traffic"]
        end

        Container --- UID
        Container --- NoAPI
        Container --- NoPorts
        Container --- NoEgress
    end

    subgraph "RBAC Configuration"
        NoClusterRole["No ClusterRoles Defined"]
        NoClusterBinding["No ClusterRoleBindings Defined"]
        NoRole["No Roles Defined"]
        NoRoleBinding["No RoleBindings Defined"]
    end

    subgraph "Build-Time Secrets (CI/CD Only)"
        HFToken["HF_TOKEN<br/>Type: Environment Variable<br/>Purpose: HuggingFace API auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        GitAuth["git_auth_secret<br/>Type: Opaque (Tekton)<br/>Purpose: Git checkout<br/>Provisioned: Konflux/PaC<br/>Auto-Rotate: Yes"]
        QuayCreds["QUAY_USERNAME / QUAY_PASSWORD<br/>Type: Opaque (GitHub Actions)<br/>Purpose: Registry push<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication & Authorization"
        HFAuth["HuggingFace API<br/>Method: GET<br/>Auth: Bearer Token (optional)<br/>Enforcement: HF API server<br/>Note: Public data unauthenticated"]
        OCIAuth["OCI Registries<br/>Method: GET<br/>Auth: None<br/>Enforcement: Registry server<br/>Note: Public read access"]
    end

    %% Relationships
    Container -->|"zero RBAC required"| NoClusterRole
    Container -->|"zero RBAC required"| NoRole

    %% Styling
    style Container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style UID fill:#d5e8d4,stroke:#82b366
    style NoAPI fill:#d5e8d4,stroke:#82b366
    style NoPorts fill:#d5e8d4,stroke:#82b366
    style NoEgress fill:#d5e8d4,stroke:#82b366
    style NoClusterRole fill:#e8e8e8,stroke:#999
    style NoClusterBinding fill:#e8e8e8,stroke:#999
    style NoRole fill:#e8e8e8,stroke:#999
    style NoRoleBinding fill:#e8e8e8,stroke:#999
    style HFToken fill:#fff2cc,stroke:#d6b656
    style GitAuth fill:#fff2cc,stroke:#d6b656
    style QuayCreds fill:#fff2cc,stroke:#d6b656
    style HFAuth fill:#f8cecc,stroke:#b85450
    style OCIAuth fill:#f8cecc,stroke:#b85450
