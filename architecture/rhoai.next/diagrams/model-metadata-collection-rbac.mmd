graph TD
    subgraph Legend["RBAC Overview"]
        Note["Model Metadata Collection<br/>has NO Kubernetes RBAC definitions.<br/>It is a data pipeline tool,<br/>not a Kubernetes operator."]
    end

    subgraph BuildTimeAuth["Build-Time Authentication"]
        direction TB

        subgraph HFAuth["HuggingFace API Auth"]
            HFToken["HF_TOKEN<br/>(env var / .env file)"]
            HFEndpoint["HuggingFace API<br/>huggingface.co"]
            HFToken -->|"Bearer Token<br/>(optional - enables<br/>gated model access)"| HFEndpoint
        end

        subgraph OCIAuth["OCI Registry Auth"]
            OCIAnon["Anonymous Pull<br/>(public images)"]
            OCIRegAuth["Registry API v2 Auth<br/>(private images)"]
            OCIEndpoint["registry.redhat.io"]
            OCIAnon -->|"Standard OCI auth"| OCIEndpoint
            OCIRegAuth -->|"Registry credentials"| OCIEndpoint
        end
    end

    subgraph CICDSecrets["CI/CD Secrets"]
        direction TB

        GitSecret["git_auth_secret<br/>(Tekton workspace)<br/>Provisioned by: Konflux tenant"]
        QuayCreds["QUAY_USERNAME /<br/>QUAY_PASSWORD<br/>(GitHub Actions secret)<br/>Provisioned by: Manual"]

        GitSecret -->|"Git checkout"| Konflux["Konflux Pipeline"]
        QuayCreds -->|"Registry push"| GHA["GitHub Actions"]
    end

    subgraph RuntimeSecurity["Runtime Security Posture"]
        direction TB

        Container["odh-model-metadata-collection<br/>Container"]
        NoRBAC["No RBAC needed"]
        NoSA["No ServiceAccount defined"]
        NoSecrets["No runtime secrets"]
        NonRoot["User: 1001 (non-root)"]
        NoNetwork["No network access"]

        Container --- NoRBAC
        Container --- NoSA
        Container --- NoSecrets
        Container --- NonRoot
        Container --- NoNetwork
    end

    %% Styling
    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style HFToken fill:#f8cecc,stroke:#b85450
    style GitSecret fill:#f8cecc,stroke:#b85450
    style QuayCreds fill:#f8cecc,stroke:#b85450
    style Container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NoRBAC fill:#d5e8d4,stroke:#82b366
    style NoSA fill:#d5e8d4,stroke:#82b366
    style NoSecrets fill:#d5e8d4,stroke:#82b366
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style NoNetwork fill:#d5e8d4,stroke:#82b366
