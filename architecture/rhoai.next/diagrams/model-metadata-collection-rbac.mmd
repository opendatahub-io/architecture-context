graph TD
    subgraph "Model Metadata Collection - RBAC & Security"
        direction TB

        subgraph "Runtime Container Security"
            Container["odh-model-metadata-collection<br/>UID: 1001 (non-root)<br/>CMD: sleep infinity"]
            NoRBAC["No RBAC Required<br/>No Kubernetes API access<br/>No ServiceAccount needed"]
            NoNetwork["No Network Access<br/>No listeners<br/>No egress at runtime"]
        end

        subgraph "Build-Time Secrets"
            HFToken["HF_TOKEN<br/>Type: Environment Variable<br/>Purpose: HuggingFace API Auth<br/>Required: No (optional)<br/>Provisioned: Manual / CI secret<br/>Auto-Rotate: No"]
        end

        subgraph "Build-Time Network Access"
            HFAccess["HuggingFace API Access<br/>huggingface.co:443/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: Bearer Token (optional)"]
            OCIAccess["OCI Registry Access<br/>registry.redhat.io:443/TCP<br/>Protocol: HTTPS<br/>Encryption: TLS 1.2+<br/>Auth: None (public)"]
        end

        subgraph "Data Access (Volume Mount)"
            VolumeAccess["Volume Mount to /app/data/<br/>Consumer: RHOAI Dashboard<br/>Auth: Kubernetes volume mount<br/>Encryption: N/A (local filesystem)"]
        end

        subgraph "Security Hardening"
            NonRoot["Non-root execution (UID 1001)"]
            NoCLI["CLI tools not shipped in image"]
            PathProtection["Path traversal protection<br/>filepath.Clean + rejection of<br/>absolute and .. paths"]
            MinimalBase["Minimal base image (ubi9-minimal)"]
            ExplicitCopy["Explicit file copy in Dockerfile<br/>(no globs for Konflux builds)"]
        end
    end

    HFToken -->|"authenticates"| HFAccess
    Container --- NoRBAC
    Container --- NoNetwork

    %% Styling
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#d5e8d4,stroke:#82b366
    style NoNetwork fill:#d5e8d4,stroke:#82b366
    style HFToken fill:#fff2cc,stroke:#d6b656
    style HFAccess fill:#ffe6cc,stroke:#d79b00
    style OCIAccess fill:#ffe6cc,stroke:#d79b00
    style VolumeAccess fill:#e1bee7,stroke:#9c27b0
    style NonRoot fill:#c8e6c9,stroke:#4caf50
    style NoCLI fill:#c8e6c9,stroke:#4caf50
    style PathProtection fill:#c8e6c9,stroke:#4caf50
    style MinimalBase fill:#c8e6c9,stroke:#4caf50
    style ExplicitCopy fill:#c8e6c9,stroke:#4caf50
