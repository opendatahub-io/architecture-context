graph TD
    subgraph RestProxyRBAC["rest-proxy RBAC"]
        direction TB
        Note["No RBAC Required"]
        Explanation["The rest-proxy does not interact<br/>with the Kubernetes API server.<br/><br/>It is a stateless reverse-proxy sidecar<br/>that only performs localhost network<br/>communication within the pod boundary.<br/><br/>No ServiceAccount, ClusterRole,<br/>or RoleBinding resources are needed."]
    end

    subgraph SecurityContext["Security Posture"]
        direction TB
        NoK8sAPI["No Kubernetes API Access"]
        NoCRDs["No CRDs Defined or Watched"]
        NoSecrets["No Direct Secret Access<br/>(TLS certs mounted by ModelMesh)"]
        NoRBAC["No RBAC Permissions"]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB
        ProxyLevel["Proxy Level: No Auth"]
        Delegation["Auth delegated to<br/>upstream ModelMesh infrastructure"]
    end

    Note --> Explanation
    NoK8sAPI --> NoCRDs
    NoCRDs --> NoSecrets
    NoSecrets --> NoRBAC
    ProxyLevel --> Delegation

    %% Styling
    style RestProxyRBAC fill:#e8f5e9,stroke:#82b366,stroke-width:2px
    style Note fill:#4caf50,stroke:#333,color:#fff,font-size:16px
    style Explanation fill:#c8e6c9,stroke:#388e3c
    style SecurityContext fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style AuthModel fill:#fff3e0,stroke:#ff9800,stroke-width:2px
    style NoK8sAPI fill:#bbdefb,stroke:#1976d2
    style NoCRDs fill:#bbdefb,stroke:#1976d2
    style NoSecrets fill:#bbdefb,stroke:#1976d2
    style NoRBAC fill:#bbdefb,stroke:#1976d2
    style ProxyLevel fill:#ffe0b2,stroke:#ff9800
    style Delegation fill:#ffe0b2,stroke:#ff9800
