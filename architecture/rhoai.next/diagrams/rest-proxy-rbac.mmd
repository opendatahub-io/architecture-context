graph TD
    subgraph ProxyInfo["rest-proxy RBAC"]
        direction TB
        Note["rest-proxy has NO Kubernetes RBAC<br/><br/>This component is a stateless reverse proxy<br/>that does not interact with the Kubernetes API.<br/><br/>No ServiceAccount required.<br/>No ClusterRoles defined.<br/>No RoleBindings created."]
    end

    subgraph SecurityModel["Security Model"]
        direction TB
        NetworkIsolation["Network Isolation<br/>Pod-local gRPC (loopback)<br/>No external gRPC exposure"]
        TLSConfig["TLS Configuration<br/>Optional server TLS (HTTP listener)<br/>Optional client TLS (gRPC upstream)<br/>FIPS: strictfipsruntime"]
        NoAuth["No Proxy-Level Auth<br/>Relies on platform ingress<br/>and ModelMesh auth"]
    end

    subgraph ParentRBAC["Parent: ModelMesh Serving Operator"]
        direction TB
        OperatorSA["ModelMesh Operator SA<br/>(manages pod lifecycle)"]
        OperatorSA -->|"creates pods with<br/>rest-proxy sidecar"| SidecarDeploy["Sidecar Deployment<br/>via model-serving-config"]
    end

    ProxyInfo --- SecurityModel
    SecurityModel --- ParentRBAC

    style Note fill:#fff3cd,stroke:#d6b656,stroke-width:2px
    style NetworkIsolation fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style TLSConfig fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NoAuth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style OperatorSA fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style SidecarDeploy fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
