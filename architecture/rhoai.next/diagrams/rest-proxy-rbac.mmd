graph TD
    subgraph "rest-proxy RBAC Summary"
        direction TB

        Note["rest-proxy requires NO RBAC permissions"]

        subgraph "Rationale"
            R1["No Kubernetes API interaction"]
            R2["No CRDs defined or watched"]
            R3["No ServiceAccount of its own"]
            R4["No ClusterRoles or Roles"]
            R5["No RoleBindings or ClusterRoleBindings"]
        end

        subgraph "Security Posture"
            S1["Auth: None at proxy level<br/>Delegated to ModelMesh / platform ingress"]
            S2["TLS: Optional for HTTP listener<br/>Optional for gRPC upstream"]
            S3["FIPS: Supported via Konflux build<br/>GOEXPERIMENT=strictfipsruntime"]
        end

        subgraph "Inherited Context"
            I1["ServiceAccount: Inherited from<br/>ModelMesh Serving pod"]
            I2["Network Policy: Inherited from<br/>ModelMesh namespace"]
            I3["Secret Access: MM_TLS_KEY_CERT_PATH<br/>mounted by parent pod spec"]
        end
    end

    Note --> R1
    Note --> S1
    Note --> I1

    style Note fill:#4a90e2,stroke:#333,color:#fff
    style R1 fill:#d5e8d4,stroke:#82b366
    style R2 fill:#d5e8d4,stroke:#82b366
    style R3 fill:#d5e8d4,stroke:#82b366
    style R4 fill:#d5e8d4,stroke:#82b366
    style R5 fill:#d5e8d4,stroke:#82b366
    style S1 fill:#fff2cc,stroke:#d6b656
    style S2 fill:#fff2cc,stroke:#d6b656
    style S3 fill:#fff2cc,stroke:#d6b656
    style I1 fill:#dae8fc,stroke:#6c8ebf
    style I2 fill:#dae8fc,stroke:#6c8ebf
    style I3 fill:#dae8fc,stroke:#6c8ebf
