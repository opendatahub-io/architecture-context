graph TD
    subgraph Component["rest-proxy Component"]
        RestProxy["rest-proxy<br/>(gRPC-Gateway Sidecar)"]
    end

    subgraph RBACStatus["RBAC Configuration"]
        NoRBAC["No Kubernetes RBAC Required"]
        NoSA["No dedicated ServiceAccount"]
        NoCR["No ClusterRoles"]
        NoRB["No RoleBindings"]
    end

    subgraph Rationale["Rationale"]
        R1["Does not interact with<br/>Kubernetes API"]
        R2["Runs as sidecar container<br/>in ModelMesh pod"]
        R3["Uses pod's existing<br/>ServiceAccount"]
        R4["All configuration via<br/>environment variables<br/>and file mounts"]
    end

    subgraph AuthDelegation["Authentication Delegation"]
        NoAuth["No auth implemented<br/>by rest-proxy"]
        PlatformAuth["Auth delegated to<br/>ModelMesh / Platform Ingress"]
    end

    subgraph SecurityControls["Security Controls (Non-RBAC)"]
        TLS_In["Inbound TLS<br/>MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"]
        TLS_Out["Outbound TLS<br/>REST_PROXY_USE_TLS"]
        SkipVerify["TLS Verify Skip<br/>REST_PROXY_SKIP_VERIFY<br/>⚠ Dev only"]
        FIPS["FIPS Compliance<br/>strictfipsruntime<br/>CGO_ENABLED=1"]
    end

    RestProxy --> NoRBAC
    NoRBAC --> R1
    NoRBAC --> R2
    R2 --> R3
    R3 --> R4
    RestProxy --> NoAuth
    NoAuth --> PlatformAuth
    RestProxy --> TLS_In
    RestProxy --> TLS_Out
    RestProxy --> FIPS
    TLS_Out -.->|"⚠ can disable"| SkipVerify

    style RestProxy fill:#4a90e2,color:#fff
    style NoRBAC fill:#d5e8d4,stroke:#82b366
    style NoSA fill:#d5e8d4,stroke:#82b366
    style NoCR fill:#d5e8d4,stroke:#82b366
    style NoRB fill:#d5e8d4,stroke:#82b366
    style R1 fill:#f0f0f0,stroke:#999
    style R2 fill:#f0f0f0,stroke:#999
    style R3 fill:#f0f0f0,stroke:#999
    style R4 fill:#f0f0f0,stroke:#999
    style NoAuth fill:#fff2cc,stroke:#d6b656
    style PlatformAuth fill:#fff2cc,stroke:#d6b656
    style TLS_In fill:#dae8fc,stroke:#6c8ebf
    style TLS_Out fill:#dae8fc,stroke:#6c8ebf
    style SkipVerify fill:#f8cecc,stroke:#b85450
    style FIPS fill:#d5e8d4,stroke:#82b366
