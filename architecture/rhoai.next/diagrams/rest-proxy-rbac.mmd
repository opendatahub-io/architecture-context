graph TD
    subgraph "rest-proxy RBAC & Security Model"
        direction TB

        subgraph NoRBAC["Kubernetes RBAC"]
            Note1["No ClusterRoles"]
            Note2["No Roles"]
            Note3["No RoleBindings"]
            Note4["No ServiceAccount interactions"]
            Note5["Does not contact Kubernetes API"]
        end

        subgraph AuthModel["Authentication & Authorization"]
            direction TB

            ProxyAuth["rest-proxy<br/>No proxy-level authentication"]

            subgraph NetworkIsolation["Network-Level Security (Defense in Depth)"]
                PodLocal["Pod-local gRPC<br/>localhost:8033<br/>Not network-accessible"]
                PlatformIngress["Platform Ingress<br/>(if exposed externally)<br/>Auth handled by ingress controller"]
                ServiceMesh["Service Mesh Policies<br/>(if Istio/OSSM deployed)<br/>mTLS + AuthorizationPolicy"]
            end

            ProxyAuth --> PodLocal
            ProxyAuth --> PlatformIngress
            ProxyAuth --> ServiceMesh
        end

        subgraph TLSConfig["TLS Configuration"]
            direction TB
            ServerTLS["Server TLS (HTTP Listener)<br/>MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH<br/>Optional"]
            ClientTLS["Client TLS (gRPC Upstream)<br/>REST_PROXY_USE_TLS<br/>Optional"]
            SkipVerify["REST_PROXY_SKIP_VERIFY<br/>⚠ Can disable cert verification<br/>Security Risk in Production"]

            ServerTLS --> SkipVerify
            ClientTLS --> SkipVerify
        end

        subgraph FIPSCompliance["FIPS Compliance"]
            FIPS["Build: CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime<br/>Crypto: OpenSSL backend<br/>Base: UBI9 minimal"]
        end
    end

    style Note1 fill:#f9f9f9,stroke:#999
    style Note2 fill:#f9f9f9,stroke:#999
    style Note3 fill:#f9f9f9,stroke:#999
    style Note4 fill:#f9f9f9,stroke:#999
    style Note5 fill:#f9f9f9,stroke:#999
    style ProxyAuth fill:#dae8fc,stroke:#6c8ebf
    style PodLocal fill:#d5e8d4,stroke:#82b366
    style PlatformIngress fill:#d5e8d4,stroke:#82b366
    style ServiceMesh fill:#d5e8d4,stroke:#82b366
    style ServerTLS fill:#fff2cc,stroke:#d6b656
    style ClientTLS fill:#fff2cc,stroke:#d6b656
    style SkipVerify fill:#f8cecc,stroke:#b85450
    style FIPS fill:#e1d5e7,stroke:#9673a6
