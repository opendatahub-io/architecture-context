graph TD
    subgraph "rest-proxy RBAC Model"
        direction TB

        Note["rest-proxy defines NO RBAC resources.<br/>It runs as a sidecar container and inherits<br/>the pod-level ServiceAccount from ModelMesh Serving."]

        subgraph "Inherited from ModelMesh Pod"
            SA["ServiceAccount<br/>(ModelMesh pod SA)"]
        end

        subgraph "Authentication Model"
            direction TB
            NoAuth["No Auth at Proxy Level<br/>(port 8008)"]
            Delegated["Authentication Delegated to:<br/>- kube-rbac-proxy sidecar<br/>- oauth-proxy sidecar<br/>- Platform ingress layer"]
        end

        subgraph "Network Access Control"
            direction TB
            Listener["REST Listener<br/>8008/TCP<br/>Pod-internal or Service-scoped"]
            GRPCUpstream["gRPC Upstream<br/>8033/TCP<br/>localhost only"]
        end

        SA -.->|"inherited by<br/>rest-proxy container"| NoAuth
        NoAuth -->|"auth handled by"| Delegated
        Listener -->|"localhost"| GRPCUpstream
    end

    subgraph "Security Controls"
        TLS["Configurable TLS<br/>MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH"]
        SkipVerify["REST_PROXY_SKIP_VERIFY<br/>(Risk: disables cert verification)<br/>Mitigated: localhost only"]
        FIPS["FIPS Compliance<br/>CGO_ENABLED=1<br/>GOEXPERIMENT=strictfipsruntime"]
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style NoAuth fill:#f8d7da,stroke:#dc3545,stroke-width:2px
    style Delegated fill:#d4edda,stroke:#28a745,stroke-width:2px
    style Listener fill:#cce5ff,stroke:#004085
    style GRPCUpstream fill:#cce5ff,stroke:#004085
    style TLS fill:#d4edda,stroke:#28a745
    style SkipVerify fill:#f8d7da,stroke:#dc3545
    style FIPS fill:#d4edda,stroke:#28a745
