            AuthDelegation["Auth Delegation<br/>No proxy-level authentication<br/>Relies on platform ingress auth<br/>and ModelMesh-level policies"]
        end

        subgraph ConfigAccess["Configuration Access"]
            EnvVars["Environment Variables Only<br/>REST_PROXY_GRPC_PORT<br/>REST_PROXY_LISTEN_PORT<br/>REST_PROXY_USE_TLS<br/>REST_PROXY_SKIP_VERIFY<br/>MM_TLS_KEY_CERT_PATH<br/>MM_TLS_PRIVATE_KEY_PATH<br/>MM_SERVING_HOSTNAME"]
            ConfigMap["model-serving-config<br/>ConfigMap<br/>(read by operator,<br/>not by rest-proxy)"]
        end
    end

    style Note1 fill:#d5e8d4,stroke:#82b366
