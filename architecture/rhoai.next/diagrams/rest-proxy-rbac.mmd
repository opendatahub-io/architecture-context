graph TD
    subgraph RestProxyComponent["rest-proxy - RBAC Summary"]
        direction TB

        subgraph NoRBAC["No Kubernetes RBAC Required"]
            Note1["rest-proxy does not interact<br/>with the Kubernetes API"]
            Note2["No ServiceAccount bindings needed"]
            Note3["No ClusterRoles or Roles defined"]
        end

        subgraph SecurityModel["Security Model"]
            direction TB
            NetworkIsolation["Network Isolation<br/>Pod-local gRPC (localhost:8033)<br/>No external network calls"]
