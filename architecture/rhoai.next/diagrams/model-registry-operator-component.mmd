graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        subgraph Controllers["Controllers"]
            MRReconciler["ModelRegistryReconciler<br/>Reconciles individual<br/>ModelRegistry CRs"]
            MCReconciler["ModelCatalogReconciler<br/>Reconciles singleton<br/>Model Catalog service"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            DefaultingWH["Defaulting Webhook<br/>Sets defaults, migrates<br/>Istio→OAuth→KubeRBACProxy"]
            ValidatingWH["Validating Webhook<br/>Validates namespace,<br/>DB config, unique name"]
            ConversionWH["Conversion Webhook<br/>v1alpha1 ↔ v1beta1"]
        end

        MigrationMgr["StorageMigrationManager<br/>v1alpha1 → v1beta1<br/>migration"]
    end

    subgraph ManagedResources["Managed Resources (per ModelRegistry CR)"]
        direction TB
        MRDeploy["Model Registry<br/>Deployment<br/>REST API + kube-rbac-proxy"]
        MRService["Service<br/>8080/TCP (HTTP)<br/>8443/TCP (HTTPS)"]
        MRRoute["OpenShift Route<br/>443/TCP reencrypt"]
        MRPG["PostgreSQL<br/>Deployment<br/>5432/TCP"]
        MRNetPol["NetworkPolicies"]
        MRRBAC["RBAC Resources<br/>Roles, Bindings, Groups"]
    end

    subgraph CatalogResources["Catalog Resources (singleton)"]
        CatalogDeploy["Model Catalog<br/>Deployment<br/>REST API + kube-rbac-proxy"]
        CatalogPG["Catalog PostgreSQL<br/>5432/TCP"]
        CatalogCM["Catalog Source<br/>ConfigMaps<br/>opendatahub.io/catalog-source=true"]
    end

    %% CRDs
    MRCR["ModelRegistry CR<br/>modelregistry.opendatahub.io<br/>v1beta1"]
    PlatformAuthCR["Platform Auth CR<br/>services.platform.opendatahub.io"]
    PlatformMRCR["Platform ModelRegistry CR<br/>components.platform.opendatahub.io"]

    %% User interaction
    User["User / Platform Operator"]

    %% Flows
    User -->|"creates"| MRCR
    MRCR -->|"watched by"| MRReconciler
    MRReconciler -->|"creates/manages"| MRDeploy
    MRReconciler -->|"creates/manages"| MRService
    MRReconciler -->|"creates/manages"| MRRoute
    MRReconciler -->|"creates/manages"| MRPG
    MRReconciler -->|"creates/manages"| MRNetPol
    MRReconciler -->|"creates/manages"| MRRBAC

    PlatformAuthCR -->|"watched by"| MCReconciler
    PlatformMRCR -->|"read by"| MCReconciler
    MCReconciler -->|"creates/manages"| CatalogDeploy
    MCReconciler -->|"creates/manages"| CatalogPG
    CatalogCM -->|"discovered by"| MCReconciler

    MRCR -->|"validated by"| ValidatingWH
    MRCR -->|"defaulted by"| DefaultingWH
    MRCR -->|"converted by"| ConversionWH

    MigrationMgr -->|"migrates CRD storage"| MRCR

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style MRReconciler fill:#5b9bd5,stroke:#333,color:#fff
    style MCReconciler fill:#5b9bd5,stroke:#333,color:#fff
    style DefaultingWH fill:#6facd5,stroke:#333,color:#fff
    style ValidatingWH fill:#6facd5,stroke:#333,color:#fff
    style ConversionWH fill:#6facd5,stroke:#333,color:#fff
    style MigrationMgr fill:#6facd5,stroke:#333,color:#fff
    style MRCR fill:#f5a623,stroke:#333
    style PlatformAuthCR fill:#f5a623,stroke:#333
    style PlatformMRCR fill:#f5a623,stroke:#333
    style MRDeploy fill:#7ed321,stroke:#333
    style MRService fill:#7ed321,stroke:#333
    style MRRoute fill:#7ed321,stroke:#333
    style MRPG fill:#7ed321,stroke:#333
    style MRNetPol fill:#7ed321,stroke:#333
    style MRRBAC fill:#7ed321,stroke:#333
    style CatalogDeploy fill:#7ed321,stroke:#333
    style CatalogPG fill:#7ed321,stroke:#333
    style CatalogCM fill:#7ed321,stroke:#333
