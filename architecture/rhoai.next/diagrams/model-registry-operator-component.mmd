graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        Controller["ModelRegistry Controller<br/>(controller-runtime)"]
        CatalogCtrl["ModelCatalog Controller<br/>(embedded)"]
        MigrationMgr["Storage Migration Manager<br/>(background goroutine)"]
        Webhooks["Admission Webhooks<br/>(defaulting + validation + conversion)"]

        Controller -->|"shares templates"| CatalogCtrl
        MigrationMgr -->|"migrates v1alpha1 to v1beta1"| Controller
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(v1beta1)<br/>modelregistry.opendatahub.io"]
    ModelRegistryCRLegacy["ModelRegistry CR<br/>(v1alpha1 - DEPRECATED)"]

    %% Managed Resources per Registry
    subgraph ManagedResources["Managed Resources (per ModelRegistry)"]
        direction TB
        RESTDeploy["REST API Deployment<br/>(model-registry image)"]
        KRBPSidecar["kube-rbac-proxy Sidecar<br/>(port 8443)"]
        RegistrySvc["Service<br/>(ClusterIP 8443/8080)"]
        HTTPSRoute["HTTPS Route<br/>reencrypt"]
        HTTPRoute["HTTP Route"]
        NetPol["NetworkPolicy<br/>(ingress restriction)"]
        RegistrySA["ServiceAccount +<br/>auth-delegator binding"]
        UserGroup["OpenShift Group<br/>({name}-users)"]
        PostgresDeploy["PostgreSQL Deployment<br/>(auto-provisioned, optional)"]
        PostgresNetPol["PostgreSQL NetworkPolicy<br/>(pod-only access)"]
    end

    %% Catalog Resources
    subgraph CatalogResources["Model Catalog Resources (singleton)"]
        direction TB
        CatalogDeploy["Catalog Deployment<br/>(REST + kube-rbac-proxy)"]
        CatalogPostgres["Catalog PostgreSQL"]
        CatalogSvc["Catalog Service<br/>(ClusterIP 8443)"]
        CatalogRoute["Catalog HTTPS Route"]
        CatalogCM["Catalog Source ConfigMaps<br/>(label discovery)"]
    end

    %% Flows
    ModelRegistryCR -->|"watched by"| Controller
    ModelRegistryCRLegacy -->|"auto-converts"| Webhooks
    Webhooks -->|"defaults + validates"| ModelRegistryCR

    Controller -->|"reconciles"| RESTDeploy
    Controller -->|"injects"| KRBPSidecar
    Controller -->|"creates"| RegistrySvc
    Controller -->|"creates"| HTTPSRoute
    Controller -->|"creates"| HTTPRoute
    Controller -->|"creates"| NetPol
    Controller -->|"creates"| RegistrySA
    Controller -->|"creates (non-BYOIDC)"| UserGroup
    Controller -->|"creates (optional)"| PostgresDeploy
    Controller -->|"creates"| PostgresNetPol

    CatalogCtrl -->|"manages"| CatalogDeploy
    CatalogCtrl -->|"manages"| CatalogPostgres
    CatalogCtrl -->|"manages"| CatalogSvc
    CatalogCtrl -->|"manages"| CatalogRoute
    CatalogCtrl -->|"discovers by label"| CatalogCM

    MigrationMgr -->|"creates SVM or manual re-read/write"| ModelRegistryCR

    %% External Dependencies
    K8sAPI["Kubernetes API Server"]
    OSConfig["OpenShift Config<br/>(ingress domain)"]
    PlatformMR["components.platform.opendatahub.io<br/>ModelRegistry CR"]
    PlatformAuth["services.platform.opendatahub.io<br/>Auth CR"]

    Controller -->|"CRUD via"| K8sAPI
    Controller -->|"reads domain"| OSConfig
    CatalogCtrl -->|"owner ref"| PlatformMR
    CatalogCtrl -->|"reads adminGroups"| PlatformAuth

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style CatalogCtrl fill:#4a90e2,color:#fff
    style MigrationMgr fill:#4a90e2,color:#fff
    style Webhooks fill:#4a90e2,color:#fff
    style ModelRegistryCR fill:#f5a623,color:#fff
    style ModelRegistryCRLegacy fill:#d0021b,color:#fff
    style RESTDeploy fill:#7ed321,color:#fff
    style KRBPSidecar fill:#7ed321,color:#fff
    style PostgresDeploy fill:#7ed321,color:#fff
    style CatalogDeploy fill:#50e3c2,color:#333
    style CatalogPostgres fill:#50e3c2,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style OSConfig fill:#e8e8e8,color:#333
    style PlatformMR fill:#bd10e0,color:#fff
    style PlatformAuth fill:#bd10e0,color:#fff
