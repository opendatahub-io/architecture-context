graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        Controller["ModelRegistryReconciler<br/>(controller-runtime)"]
        CatalogController["ModelCatalogReconciler"]
        Webhook["Admission Webhooks<br/>(mutating + validating + conversion)"]
        Migration["Storage Version Migration<br/>(v1alpha1 → v1beta1)"]
        Controller -->|"manages"| Migration
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(v1beta1 / v1alpha1)<br/>modelregistry.opendatahub.io"]
    ModelRegistryCR -->|"watched by"| Controller
    ModelRegistryCR -->|"validated by"| Webhook

    %% Platform CRDs watched
    PlatformMRCR["components.platform.opendatahub.io<br/>ModelRegistry CR"]
    AuthCR["services.platform.opendatahub.io<br/>Auth CR"]
    PlatformMRCR -->|"watched by"| CatalogController
    AuthCR -->|"watched by"| CatalogController

    %% Resources created by ModelRegistryReconciler
    subgraph RegistryInstance["Registry Instance (per ModelRegistry CR)"]
        direction TB
        RegistryDeployment["Deployment<br/>(model-registry REST + kube-rbac-proxy sidecar)"]
        RegistryService["Service<br/>8443/TCP HTTPS"]
        RegistryRoute["OpenShift Route<br/>443/TCP reencrypt"]
        RegistryPostgres["PostgreSQL Deployment<br/>5432/TCP"]
        RegistryPostgresService["PostgreSQL Service<br/>5432/TCP"]
        RegistryRBAC["RBAC<br/>(Role, RoleBinding, Group)"]
        RegistryNetPol["NetworkPolicies"]
    end

    Controller -->|"creates/manages"| RegistryDeployment
    Controller -->|"creates/manages"| RegistryService
    Controller -->|"creates/manages"| RegistryRoute
    Controller -->|"creates/manages"| RegistryPostgres
    Controller -->|"creates/manages"| RegistryPostgresService
    Controller -->|"creates/manages"| RegistryRBAC
    Controller -->|"creates/manages"| RegistryNetPol

    %% Resources created by ModelCatalogReconciler
    subgraph CatalogInstance["Model Catalog"]
        direction TB
        CatalogDeployment["Deployment<br/>(catalog + kube-rbac-proxy + init containers)"]
        CatalogService["Service<br/>8443/TCP HTTPS"]
        CatalogRoute["OpenShift Route<br/>443/TCP reencrypt"]
        CatalogPostgres["PostgreSQL Deployment<br/>5432/TCP"]
        CatalogPostgresService["PostgreSQL Service<br/>5432/TCP"]
        CatalogRBAC["Catalog RBAC<br/>(admin, user roles)"]
    end

    CatalogController -->|"creates/manages"| CatalogDeployment
    CatalogController -->|"creates/manages"| CatalogService
    CatalogController -->|"creates/manages"| CatalogRoute
    CatalogController -->|"creates/manages"| CatalogPostgres
    CatalogController -->|"creates/manages"| CatalogPostgresService
    CatalogController -->|"creates/manages"| CatalogRBAC

    %% External dependencies
    K8sAPI["Kubernetes API Server"]
    CertManager["cert-manager"]
    ServingCerts["OpenShift Serving Cert Signer"]
    Prometheus["Prometheus / ServiceMonitor"]

    Controller -->|"reconciles via"| K8sAPI
    CatalogController -->|"reconciles via"| K8sAPI
    Webhook -->|"TLS certs from"| CertManager
    RegistryDeployment -->|"TLS certs from"| ServingCerts
    CatalogDeployment -->|"TLS certs from"| ServingCerts
    Operator -->|"metrics 8443/TCP"| Prometheus

    %% Catalog data sources
    CatalogConfigMaps["ConfigMaps<br/>(opendatahub.io/catalog-source)"]
    CatalogConfigMaps -->|"discovered by"| CatalogController

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RegistryInstance fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style CatalogInstance fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style ModelRegistryCR fill:#f5a623,stroke:#d79b00,stroke-width:2px
    style PlatformMRCR fill:#f5a623,stroke:#d79b00,stroke-width:2px
    style AuthCR fill:#f5a623,stroke:#d79b00,stroke-width:2px
    style CatalogConfigMaps fill:#f5a623,stroke:#d79b00,stroke-width:2px
    style K8sAPI fill:#e8e8e8,stroke:#999
    style CertManager fill:#e8e8e8,stroke:#999
    style ServingCerts fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
