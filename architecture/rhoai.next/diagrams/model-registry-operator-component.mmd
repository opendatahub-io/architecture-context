graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        MRReconciler["ModelRegistry<br/>Reconciler"]
        MCReconciler["ModelCatalog<br/>Reconciler"]
        Webhook["Admission Webhook<br/>9443/TCP TLS"]
        Migration["Storage Version<br/>Migration"]
        MRReconciler -->|"deploys"| RegistryResources
        MCReconciler -->|"deploys"| CatalogResources
        Webhook -->|"validates/mutates"| MRReconciler
        Migration -->|"v1alpha1 → v1beta1"| MRReconciler
    end

    subgraph RegistryResources["Registry Instance Resources"]
        direction TB
        RegistryDeploy["Registry Deployment<br/>model-registry REST<br/>+ kube-rbac-proxy sidecar"]
        RegistrySvc["Registry Service<br/>8443/TCP HTTPS"]
        RegistryRoute["OpenShift Route<br/>443/TCP reencrypt"]
        RegistryDB["PostgreSQL/MySQL<br/>5432/TCP or 3306/TCP"]
        RegistryNP["NetworkPolicies"]
        RegistryRBAC["Per-Registry RBAC<br/>Roles, Bindings, Groups"]
    end

    subgraph CatalogResources["Model Catalog Resources"]
        direction TB
        CatalogDeploy["Catalog Deployment<br/>+ kube-rbac-proxy sidecar<br/>+ init containers"]
        CatalogSvc["Catalog Service<br/>8443/TCP HTTPS"]
        CatalogRoute["Catalog Route<br/>443/TCP reencrypt"]
        CatalogDB["Catalog PostgreSQL<br/>5432/TCP"]
        CatalogNP["Catalog NetworkPolicies"]
    end

    User["User / Data Scientist"] -->|"creates"| ModelRegistryCR["ModelRegistry CR<br/>modelregistry.opendatahub.io/v1beta1"]
    ModelRegistryCR -->|"watched by"| MRReconciler

    PlatformOp["ODH / RHOAI<br/>Platform Operator"] -->|"deploys via<br/>kustomize overlay"| Operator

    Client["API Client"] -->|"HTTPS/443"| RegistryRoute
    Client -->|"HTTPS/443"| CatalogRoute

    RegistryRoute -->|"reencrypt"| RegistrySvc
    RegistrySvc --> RegistryDeploy
    RegistryDeploy -->|"5432/TCP"| RegistryDB

    CatalogRoute -->|"reencrypt"| CatalogSvc
    CatalogSvc --> CatalogDeploy
    CatalogDeploy -->|"5432/TCP"| CatalogDB

    MCReconciler -->|"watches"| PlatformMRCR["components.platform.opendatahub.io<br/>ModelRegistry CR"]
    MCReconciler -->|"watches"| AuthCR["services.platform.opendatahub.io<br/>Auth CR"]
    MCReconciler -->|"discovers"| CatalogCMs["ConfigMaps<br/>opendatahub.io/catalog-source"]

    MRReconciler -->|"reads"| IngressConfig["config.openshift.io<br/>Ingress"]

    CertManager["cert-manager"] -->|"provisions TLS"| Webhook
    ServingCerts["OpenShift<br/>serving-cert-signer"] -->|"provisions TLS"| RegistrySvc
    ServingCerts -->|"provisions TLS"| CatalogSvc

    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| MetricsSvc["Metrics Service<br/>8443/TCP"]

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MRReconciler fill:#357abd,stroke:#333,color:#fff
    style MCReconciler fill:#357abd,stroke:#333,color:#fff
    style Webhook fill:#357abd,stroke:#333,color:#fff
    style Migration fill:#357abd,stroke:#333,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333,stroke-width:2px
    style PlatformMRCR fill:#f5a623,stroke:#333
    style AuthCR fill:#f5a623,stroke:#333
    style RegistryDeploy fill:#7ed321,stroke:#333
    style CatalogDeploy fill:#7ed321,stroke:#333
    style RegistryDB fill:#bd10e0,stroke:#333,color:#fff
    style CatalogDB fill:#bd10e0,stroke:#333,color:#fff
    style RegistryRoute fill:#e8e8e8,stroke:#333
    style CatalogRoute fill:#e8e8e8,stroke:#333
    style PlatformOp fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServingCerts fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
