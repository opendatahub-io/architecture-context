graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        Controller["ModelRegistryReconciler<br/>(controller-runtime)"]
        CatalogCtrl["ModelCatalogReconciler"]
        Webhook["Webhook Server<br/>9443/TCP TLS"]
        Migration["Storage Version Migration<br/>(v1alpha1 → v1beta1)"]

        Controller -->|"reconciles"| Webhook
        CatalogCtrl -->|"shares auth pattern"| Controller
        Migration -->|"converts CRs"| Controller
    end

    %% CRDs
    User["User / Platform Operator"] -->|"creates"| ModelRegistryCR["ModelRegistry CR<br/>(v1beta1)"]
    ModelRegistryCR -->|"watched by"| Controller

    PlatformCR["ModelRegistry Component CR<br/>(platform.opendatahub.io)"] -->|"watched by"| CatalogCtrl
    AuthCR["Auth CR<br/>(services.platform.opendatahub.io)"] -->|"watched by"| CatalogCtrl

    %% Resources Created by Controller
    Controller -->|"creates"| RegistryDeploy["Registry Deployment<br/>(REST + kube-rbac-proxy)"]
    Controller -->|"creates"| RegistrySvc["Registry Service<br/>8443/TCP HTTPS"]
    Controller -->|"creates"| RegistryRoute["OpenShift Route<br/>443/TCP reencrypt"]
    Controller -->|"creates"| PostgresDeploy["PostgreSQL Deployment<br/>5432/TCP"]
    Controller -->|"creates"| RBAC["RBAC Resources<br/>(Roles, Bindings, Groups)"]
    Controller -->|"creates"| NetPol["NetworkPolicies"]

    %% Resources Created by CatalogCtrl
    CatalogCtrl -->|"creates"| CatalogDeploy["Catalog Deployment<br/>(REST + kube-rbac-proxy)"]
    CatalogCtrl -->|"creates"| CatalogSvc["Catalog Service<br/>8443/TCP HTTPS"]
    CatalogCtrl -->|"creates"| CatalogRoute["Catalog Route<br/>443/TCP reencrypt"]
    CatalogCtrl -->|"creates"| CatalogDB["Catalog PostgreSQL<br/>5432/TCP"]

    %% External Dependencies
    Controller -->|"depends on"| CertManager["cert-manager"]
    Controller -->|"depends on"| K8sAPI["Kubernetes API Server"]
    CatalogCtrl -->|"discovers"| CatalogCMs["Catalog Source ConfigMaps<br/>(opendatahub.io/catalog-source)"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CatalogCtrl fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style Migration fill:#4a90e2,stroke:#333,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333,color:#000
    style PlatformCR fill:#f5a623,stroke:#333,color:#000
    style AuthCR fill:#f5a623,stroke:#333,color:#000
    style RegistryDeploy fill:#7ed321,stroke:#333,color:#000
    style RegistrySvc fill:#7ed321,stroke:#333,color:#000
    style RegistryRoute fill:#7ed321,stroke:#333,color:#000
    style PostgresDeploy fill:#7ed321,stroke:#333,color:#000
    style RBAC fill:#7ed321,stroke:#333,color:#000
    style NetPol fill:#7ed321,stroke:#333,color:#000
    style CatalogDeploy fill:#7ed321,stroke:#333,color:#000
    style CatalogSvc fill:#7ed321,stroke:#333,color:#000
    style CatalogRoute fill:#7ed321,stroke:#333,color:#000
    style CatalogDB fill:#7ed321,stroke:#333,color:#000
    style CertManager fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CatalogCMs fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333
