graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        subgraph Controllers["Controllers"]
            MRReconciler["ModelRegistryReconciler<br/>Manages individual ModelRegistry CRs"]
            MCReconciler["ModelCatalogReconciler<br/>Singleton Model Catalog service"]
            MigrationMgr["StorageMigrationManager<br/>v1alpha1 → v1beta1 migration"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            DefaultingWH["Defaulting Webhook<br/>Sets defaults, migrates API fields"]
            ValidatingWH["Validating Webhook<br/>Validates namespace, DB config"]
            ConversionWH["Conversion Webhook<br/>v1alpha1 ↔ v1beta1"]
        end
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>modelregistry.opendatahub.io<br/>(v1alpha1 / v1beta1)"]

    %% Managed Resources - Model Registry
    subgraph ManagedMR["Managed Resources (per ModelRegistry)"]
        MRDeployment["Model Registry Deployment<br/>REST API (8080) + kube-rbac-proxy (8443)"]
        MRPostgres["PostgreSQL StatefulSet<br/>5432/TCP"]
        MRService["ClusterIP Service<br/>8080 + 8443"]
        MRRoute["OpenShift Route<br/>443/TCP reencrypt"]
        MRNetPol["NetworkPolicy"]
        MRRBAC["RBAC Resources<br/>ClusterRoleBinding + Group"]
    end

    %% Managed Resources - Model Catalog
    subgraph ManagedMC["Managed Resources (Model Catalog)"]
        MCDeployment["Model Catalog Deployment<br/>REST API (8080) + kube-rbac-proxy (8443)"]
        MCPostgres["Catalog PostgreSQL<br/>5432/TCP"]
        MCService["ClusterIP Service<br/>8080 + 8443"]
        MCRoute["Model Catalog Route<br/>443/TCP reencrypt"]
        MCConfigMaps["Catalog Source ConfigMaps<br/>opendatahub.io/catalog-source=true"]
    end

    %% User interaction
    User["User / Data Scientist"] -->|"creates/manages"| ModelRegistryCR

    %% Webhook processing
    ModelRegistryCR -->|"admission"| DefaultingWH
    ModelRegistryCR -->|"admission"| ValidatingWH
    ModelRegistryCR -->|"version conversion"| ConversionWH

    %% Controller watches
    ModelRegistryCR -->|"watched by"| MRReconciler

    %% ModelRegistry Reconciler creates resources
    MRReconciler -->|"creates"| MRDeployment
    MRReconciler -->|"creates"| MRPostgres
    MRReconciler -->|"creates"| MRService
    MRReconciler -->|"creates (OpenShift)"| MRRoute
    MRReconciler -->|"creates"| MRNetPol
    MRReconciler -->|"creates"| MRRBAC

    %% ModelCatalog Reconciler creates resources
    MCReconciler -->|"creates"| MCDeployment
    MCReconciler -->|"creates"| MCPostgres
    MCReconciler -->|"creates"| MCService
    MCReconciler -->|"creates (OpenShift)"| MCRoute
    MCReconciler -->|"discovers"| MCConfigMaps

    %% Migration
    MigrationMgr -->|"monitors CRD versions"| ModelRegistryCR

    %% External dependencies
    K8sAPI["Kubernetes API Server"]
    PlatformAuth["Platform Auth CR<br/>services.platform.opendatahub.io"]
    PlatformMR["Platform ModelRegistry CR<br/>components.platform.opendatahub.io"]

    MRReconciler -->|"CRUD via"| K8sAPI
    MCReconciler -->|"reads admin groups"| PlatformAuth
    MCReconciler -->|"owner reference"| PlatformMR

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,color:#fff
    style MRReconciler fill:#4a90e2,stroke:#333,color:#fff
    style MCReconciler fill:#4a90e2,stroke:#333,color:#fff
    style MigrationMgr fill:#4a90e2,stroke:#333,color:#fff
    style DefaultingWH fill:#4a90e2,stroke:#333,color:#fff
    style ValidatingWH fill:#4a90e2,stroke:#333,color:#fff
    style ConversionWH fill:#4a90e2,stroke:#333,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333,color:#000
    style MRDeployment fill:#7ed321,stroke:#333,color:#000
    style MRPostgres fill:#7ed321,stroke:#333,color:#000
    style MRService fill:#7ed321,stroke:#333,color:#000
    style MRRoute fill:#7ed321,stroke:#333,color:#000
    style MRNetPol fill:#7ed321,stroke:#333,color:#000
    style MRRBAC fill:#7ed321,stroke:#333,color:#000
    style MCDeployment fill:#50c878,stroke:#333,color:#000
    style MCPostgres fill:#50c878,stroke:#333,color:#000
    style MCService fill:#50c878,stroke:#333,color:#000
    style MCRoute fill:#50c878,stroke:#333,color:#000
    style MCConfigMaps fill:#50c878,stroke:#333,color:#000
    style K8sAPI fill:#e8e8e8,stroke:#333,color:#000
    style PlatformAuth fill:#e8e8e8,stroke:#333,color:#000
