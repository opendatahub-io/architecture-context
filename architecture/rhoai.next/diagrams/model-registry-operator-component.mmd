graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        MRReconciler["ModelRegistryReconciler<br/>(Controller)"]
        MCReconciler["ModelCatalogReconciler<br/>(Controller)"]
        Webhook["Admission Webhook<br/>(Mutating + Validating)"]
        SVM["StorageMigrationManager<br/>(v1alpha1 → v1beta1)"]
        TemplateApplier["TemplateApplier<br/>(Go templates → YAML)"]
        ResourceManager["ResourceManager<br/>(k8s-objectmatcher diffs)"]

        MRReconciler -->|renders resources| TemplateApplier
        MCReconciler -->|renders resources| TemplateApplier
        TemplateApplier -->|calculates diffs| ResourceManager
        SVM -->|migrates CRDs| MRReconciler
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(v1beta1)"]
    ModelRegistryCRLegacy["ModelRegistry CR<br/>(v1alpha1 - deprecated)"]

    %% Managed Resources per Registry
    subgraph ManagedStack["Managed Resources (per ModelRegistry CR)"]
        direction TB
        Deployment["Deployment<br/>(model-registry + kube-rbac-proxy)"]
        Service["Service<br/>(ClusterIP 8443/TCP)"]
        Route["OpenShift Route<br/>(HTTPS reencrypt)"]
        HTTPRoute["HTTPRoute<br/>(Gateway API)"]
        RBAC["Role + RoleBinding<br/>+ ClusterRoleBinding"]
        NetPolicy["NetworkPolicy"]
        Group["OpenShift Group<br/>(per-registry users)"]
        PostgresStack["PostgreSQL Stack<br/>(Deployment + PVC + Secret)"]
    end

    %% Managed Resources for Catalog
    subgraph CatalogStack["Managed Resources (Model Catalog - singleton)"]
        direction TB
        CatalogDeployment["Catalog Deployment<br/>(model-registry + kube-rbac-proxy)"]
        CatalogService["Catalog Service<br/>(ClusterIP 8443/TCP)"]
        CatalogRoute["Catalog Route<br/>(HTTPS reencrypt)"]
        CatalogHTTPRoute["Catalog HTTPRoute<br/>(Gateway API)"]
        CatalogPostgres["Catalog PostgreSQL<br/>(auto-provisioned)"]
        CatalogConfigMaps["Catalog Source ConfigMaps<br/>(labeled discovery)"]
    end

    %% User interaction
    User["User / Platform Operator"] -->|creates| ModelRegistryCR
    ModelRegistryCRLegacy -->|auto-converted| ModelRegistryCR
    ModelRegistryCR -->|watched by| MRReconciler
    Webhook -->|defaults & validates| ModelRegistryCR

    %% Registry reconciler outputs
    MRReconciler -->|creates/manages| Deployment
    MRReconciler -->|creates/manages| Service
    MRReconciler -->|creates/manages| Route
    MRReconciler -->|creates/manages| HTTPRoute
    MRReconciler -->|creates/manages| RBAC
    MRReconciler -->|creates/manages| NetPolicy
    MRReconciler -->|creates/manages| Group
    MRReconciler -->|creates/manages| PostgresStack

    %% Catalog reconciler outputs
    MCReconciler -->|creates/manages| CatalogDeployment
    MCReconciler -->|creates/manages| CatalogService
    MCReconciler -->|creates/manages| CatalogRoute
    MCReconciler -->|creates/manages| CatalogHTTPRoute
    MCReconciler -->|creates/manages| CatalogPostgres
    MCReconciler -->|watches| CatalogConfigMaps

    %% Platform dependencies
    MCReconciler -->|reads admin groups| AuthCR["Auth CR<br/>(services.platform.opendatahub.io)"]
    MCReconciler -->|reads owner ref| PlatformMR["Platform ModelRegistry CR<br/>(components.platform.opendatahub.io)"]
    MRReconciler -->|reads domain| IngressConfig["config.openshift.io/Ingress"]

    %% Styling
    style MRReconciler fill:#4a90e2,color:#fff
    style MCReconciler fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style SVM fill:#4a90e2,color:#fff
    style TemplateApplier fill:#6baed6,color:#fff
    style ResourceManager fill:#6baed6,color:#fff
    style ModelRegistryCR fill:#f5a623,color:#fff
    style ModelRegistryCRLegacy fill:#d4a017,color:#fff
    style AuthCR fill:#7ed321,color:#fff
    style PlatformMR fill:#7ed321,color:#fff
    style IngressConfig fill:#7ed321,color:#fff
