graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB

        subgraph Controllers["Controllers"]
            MRReconciler["ModelRegistryReconciler<br/>Reconciles per-instance<br/>ModelRegistry CRs"]
            MCReconciler["ModelCatalogReconciler<br/>Manages singleton<br/>model-catalog deployment"]
            TLSWatcher["TLS Security Profile Watcher<br/>Watches APIServer TLS changes<br/>triggers pod restart"]
            SVM["StorageMigrationManager<br/>v1alpha1 → v1beta1<br/>CRD migration"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            MutatingWH["Mutating Webhook<br/>Defaults fields, migrates<br/>Istio→OAuth→KubeRBACProxy"]
            ValidatingWH["Validating Webhook<br/>DB config, namespace,<br/>unique name enforcement"]
            ConversionWH["Conversion Webhook<br/>v1alpha1 ↔ v1beta1"]
        end
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(modelregistry.opendatahub.io)<br/>v1beta1 / v1alpha1"]
    AuthCR["Auth CR<br/>(services.platform.opendatahub.io)<br/>Admin groups config"]
    ComponentCR["ModelRegistries CR<br/>(components.platform.opendatahub.io)<br/>Owner reference"]

    %% Per-Instance Resources
    subgraph PerInstance["Per-Instance Resources (per ModelRegistry)"]
        MRDeployment["Deployment<br/>model-registry + kube-rbac-proxy"]
        MRService["Service<br/>8443/TCP (HTTPS)"]
        MRSA["ServiceAccount"]
        MRRoute["OpenShift Route<br/>{name}-https"]
        MRHTTPRoute["HTTPRoute<br/>model-registry-{name}"]
        MRNetPol["NetworkPolicy"]
        MRGroup["OpenShift Group<br/>{name}-users"]
        MRRBAC["Role + RoleBinding<br/>+ ClusterRoleBinding"]
    end

    %% Catalog Resources
    subgraph CatalogResources["Model Catalog Resources (singleton)"]
        CatalogDeploy["Deployment<br/>model-catalog + kube-rbac-proxy<br/>+ init containers"]
        CatalogService["Service<br/>8443/TCP (HTTPS)"]
        CatalogRoute["OpenShift Route<br/>model-catalog-https"]
        CatalogHTTPRoute["HTTPRoute<br/>model-catalog"]
        CatalogPostgres["PostgreSQL 16<br/>Auto-provisioned"]
    end

    %% Database
    PostgreSQL["PostgreSQL / MySQL<br/>External or auto-provisioned"]

    %% Flows
    ModelRegistryCR -->|watched by| MRReconciler
    AuthCR -->|read by| MCReconciler
    ComponentCR -->|read by| MCReconciler

    MRReconciler -->|creates/manages| MRDeployment
    MRReconciler -->|creates| MRService
    MRReconciler -->|creates| MRSA
    MRReconciler -->|creates| MRRoute
    MRReconciler -->|creates| MRHTTPRoute
    MRReconciler -->|creates| MRNetPol
    MRReconciler -->|creates| MRGroup
    MRReconciler -->|creates| MRRBAC

    MCReconciler -->|creates/manages| CatalogDeploy
    MCReconciler -->|creates| CatalogService
    MCReconciler -->|creates| CatalogRoute
    MCReconciler -->|creates| CatalogHTTPRoute
    MCReconciler -->|creates| CatalogPostgres

    MRDeployment -->|connects| PostgreSQL
    CatalogDeploy -->|connects| CatalogPostgres

    ModelRegistryCR -->|validated by| ValidatingWH
    ModelRegistryCR -->|defaulted by| MutatingWH
    ModelRegistryCR -->|converted by| ConversionWH

    TLSWatcher -->|restarts| MRDeployment
    SVM -->|migrates CRDs| ModelRegistryCR

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style MRReconciler fill:#5ba3f5,stroke:#333
    style MCReconciler fill:#5ba3f5,stroke:#333
    style TLSWatcher fill:#5ba3f5,stroke:#333
    style SVM fill:#5ba3f5,stroke:#333
    style MutatingWH fill:#9b59b6,stroke:#333,color:#fff
    style ValidatingWH fill:#9b59b6,stroke:#333,color:#fff
    style ConversionWH fill:#9b59b6,stroke:#333,color:#fff
    style ModelRegistryCR fill:#f5a623,stroke:#333
    style AuthCR fill:#f5a623,stroke:#333
    style ComponentCR fill:#f5a623,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style CatalogPostgres fill:#e8e8e8,stroke:#333
