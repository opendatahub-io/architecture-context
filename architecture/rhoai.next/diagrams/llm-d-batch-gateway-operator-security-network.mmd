graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Optional - Gateway API)"]
        HTTPRoute["HTTPRoute → Gateway<br/>/v1/batches, /v1/files<br/>TLS depends on Gateway listener"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB
        Operator["llm-d-batch-gateway-operator<br/>SA: llm-d-batch-gateway-operator<br/>FIPS: strictfipsruntime<br/>8081/TCP health, 8443/TCP metrics"]
    end

    subgraph CRNS["CR NAMESPACE (user-specified)"]
        direction TB
        APIServer["batch-gateway-apiserver<br/>8000/TCP (http) | 8081/TCP (obs)<br/>Optional TLS via cert-manager"]
        Processor["batch-gateway-processor<br/>9090/TCP (metrics)<br/>Polls DB, dispatches inference"]
        GC["batch-gateway-gc<br/>9091/TCP (metrics)<br/>Periodic cleanup"]
        ManagedSecret["{gw-name}-credentials<br/>Cross-NS Secret copy<br/>batch.llm-d.ai/copied-from"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        InferenceGW["Inference Gateway<br/>(vLLM / GIE/EPP)<br/>Configurable port<br/>HTTP/HTTPS<br/>Optional TLS/mTLS"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL protocol<br/>Optional TLS"]
        Redis["Redis / Valkey<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS"]
        S3["S3-compatible Storage<br/>443/TCP<br/>HTTPS<br/>S3 credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
    end

    %% External to Ingress
    Client -->|"HTTP/HTTPS<br/>Optional Bearer token"| HTTPRoute

    %% Ingress to API Server
    HTTPRoute -->|"8000/TCP HTTP<br/>Optional TLS"| APIServer

    %% Operator to K8s API
    Operator -->|"443/TCP HTTPS<br/>TLS<br/>SA token"| K8sAPI

    %% Operator manages workloads (Server-Side Apply)
    Operator -.->|"Server-Side Apply<br/>creates/manages"| APIServer
    Operator -.->|"Server-Side Apply<br/>creates/manages"| Processor
    Operator -.->|"Server-Side Apply<br/>creates/manages"| GC
    Operator -.->|"Secret sync<br/>via ReferenceGrant"| ManagedSecret

    %% API Server egress
    APIServer -->|"5432/TCP or 6379/TCP<br/>DB protocol<br/>Optional TLS<br/>Connection string"| PostgreSQL
    APIServer -->|"443/TCP HTTPS<br/>S3 credentials"| S3

    %% Processor egress
    Processor -->|"Configurable port<br/>HTTP/HTTPS<br/>Optional mTLS<br/>Optional API key"| InferenceGW
    Processor -->|"5432/TCP or 6379/TCP<br/>DB protocol<br/>Optional TLS"| PostgreSQL
    Processor -->|"443/TCP HTTPS<br/>S3 credentials"| S3

    %% GC egress
    GC -->|"5432/TCP or 6379/TCP<br/>DB protocol<br/>Optional TLS"| PostgreSQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef crns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class HTTPRoute ingress
    class Operator operatorns
    class APIServer,Processor,GC crns
    class ManagedSecret secret
    class InferenceGW,PostgreSQL,Redis,S3,K8sAPI externalservice
