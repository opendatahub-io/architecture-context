graph TD
    subgraph "vllm-gaudi RBAC Model"
        direction TB

        subgraph "Container Runtime"
            Container["odh-vllm-gaudi-rhel9<br/>UID: 2000 (non-root)<br/>OpenShift compatible"]
        end

        subgraph "No RBAC Defined"
            Note["This is a container image,<br/>not an operator.<br/>No ClusterRoles, Roles,<br/>or RoleBindings defined."]
        end

        subgraph "Platform-Managed RBAC"
            KServeSA["ServiceAccount<br/>(created by KServe)"]
            RHOAIRoles["RHOAI Operator Roles<br/>(manages inference permissions)"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(enforces API auth in RHOAI 3.x)"]
        end

        subgraph "Authentication at API Level"
            Endpoint["/v1/* endpoints"]
            AuthNone["Auth: None (by default)<br/>vLLM has no built-in auth"]
            PlatformAuth["Enforcement: Platform-level<br/>kube-rbac-proxy sidecar"]
        end

        subgraph "Secrets (Platform-Injected)"
            HFToken["HuggingFace Token<br/>(env var / mounted secret)<br/>Provisioned by: Platform"]
            S3Creds["S3 Credentials<br/>(env var / mounted secret)<br/>Provisioned by: Platform"]
            NoSecrets["No secrets defined<br/>in this repository"]
        end
    end

    Container -->|"runs with"| KServeSA
    KServeSA -->|"granted permissions by"| RHOAIRoles
    KubeRBACProxy -->|"protects"| Endpoint
    Endpoint -->|"default"| AuthNone
    Endpoint -->|"RHOAI 3.x"| PlatformAuth

    Container -.->|"uses at runtime"| HFToken
    Container -.->|"uses at runtime"| S3Creds
    NoSecrets -.->|"all injected by"| RHOAIRoles

    style Container fill:#4a90e2,stroke:#333
    style Note fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
    style KServeSA fill:#7ed321,stroke:#333
    style RHOAIRoles fill:#7ed321,stroke:#333
    style KubeRBACProxy fill:#7ed321,stroke:#333
    style AuthNone fill:#f8cecc,stroke:#b85450
    style PlatformAuth fill:#d5e8d4,stroke:#82b366
    style HFToken fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#fff2cc,stroke:#d6b656
    style NoSecrets fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
