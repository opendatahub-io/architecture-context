graph TD
    subgraph "Authentication Flow (Platform-Managed)"
        Client["External Client<br/>(Bearer Token)"]
        KubeAPI["Kubernetes API Server<br/>(Token Validation)"]
        Proxy["kube-rbac-proxy Sidecar<br/>(Injected by RHOAI Platform)"]
        VllmAPI["vLLM OpenAI API Server<br/>Port 8000/TCP<br/>(No auth - pre-authenticated)"]
    end

    subgraph "RBAC Enforcement (Not defined by this component)"
        Note1["No ClusterRoles defined"]
        Note2["No RoleBindings defined"]
        Note3["RBAC managed by KServe<br/>and rhods-operator"]
    end

    subgraph "Endpoint Access Matrix"
        direction TB
        Authenticated["Authenticated Endpoints<br/>(via kube-rbac-proxy on 8443/TCP)"]
        V1Completions["POST /v1/completions"]
        V1Chat["POST /v1/chat/completions"]
        V1Models["GET /v1/models"]
        V1Embeddings["POST /v1/embeddings"]

        Internal["Internal-Only Endpoints<br/>(pod-local, no auth)"]
        Health["GET /health"]
        Metrics["GET /metrics"]
    end

    subgraph "Secrets"
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>Provisioned by: User/admin<br/>Auto-Rotate: No"]
    end

    subgraph "Container Security"
        NonRoot["Run-as: non-root (UID 2000)"]
        UBI["Base: UBI 9.6"]
        Konflux["Build: Konflux pipeline"]
    end

    %% Auth flow
    Client -->|"1. HTTPS/8443<br/>Bearer Token"| Proxy
    Proxy -->|"2. Validate token"| KubeAPI
    KubeAPI -->|"3. RBAC decision"| Proxy
    Proxy -->|"4. HTTP/8000<br/>(pre-authenticated)"| VllmAPI

    %% Endpoint access
    Authenticated --- V1Completions
    Authenticated --- V1Chat
    Authenticated --- V1Models
    Authenticated --- V1Embeddings
    Internal --- Health
    Internal --- Metrics

    %% Secret usage
    HFToken -.->|"model downloads"| VllmAPI

    %% Styling
    style Client fill:#f9f9f9,stroke:#999
    style KubeAPI fill:#e74c3c,stroke:#333,color:#fff
    style Proxy fill:#e67e22,stroke:#333,color:#fff
    style VllmAPI fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#f0f0f0,stroke:#ccc
    style Note2 fill:#f0f0f0,stroke:#ccc
    style Note3 fill:#f0f0f0,stroke:#ccc
    style V1Completions fill:#d5e8d4,stroke:#82b366
    style V1Chat fill:#d5e8d4,stroke:#82b366
    style V1Models fill:#d5e8d4,stroke:#82b366
    style V1Embeddings fill:#d5e8d4,stroke:#82b366
    style Health fill:#fff2cc,stroke:#d6b656
    style Metrics fill:#fff2cc,stroke:#d6b656
    style HFToken fill:#f8cecc,stroke:#b85450
    style NonRoot fill:#e1d5e7,stroke:#9673a6
    style UBI fill:#e1d5e7,stroke:#9673a6
    style Konflux fill:#e1d5e7,stroke:#9673a6
    style Authenticated fill:#d5e8d4,stroke:#82b366
    style Internal fill:#fff2cc,stroke:#d6b656
