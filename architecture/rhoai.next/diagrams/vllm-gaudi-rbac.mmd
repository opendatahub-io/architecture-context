graph TD
    subgraph "Authentication & Authorization Model"
        direction TB

        subgraph "External Access"
            Client["External Client"]
        end

        subgraph "Platform-Managed Auth (kube-rbac-proxy Sidecar)"
            KRBAC["kube-rbac-proxy<br/>Port: 8443/TCP<br/>TLS 1.3 Termination"]
            K8sAPI["Kubernetes API Server<br/>(Token Validation)"]
        end

        subgraph "Pod-Internal (No Auth)"
            vLLM["vLLM OpenAI API Server<br/>Port: 8000/TCP<br/>HTTP Plaintext"]
        end

        subgraph "Endpoint Authorization"
            APIEndpoints["/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/v1/embeddings"]
            InfoEndpoints["/health<br/>/metrics"]
        end
    end

    subgraph "Secret Management"
        HF_TOKEN["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: User/admin<br/>Auto-Rotate: No"]
    end

    subgraph "Container Security"
        Container["odh-vllm-gaudi-rhel9<br/>Base: UBI 9.6<br/>UID: 2000 (non-root)<br/>Build: Konflux pipeline"]
    end

    subgraph "Platform RBAC (External to this component)"
        KServeRBAC["KServe RBAC<br/>(ServingRuntime management)"]
        PlatformRBAC["rhods-operator RBAC<br/>(Platform operator)"]
    end

    %% Auth Flow
    Client -->|"Bearer Token<br/>HTTPS/8443"| KRBAC
    KRBAC -->|"Validate token"| K8sAPI
    K8sAPI -->|"RBAC decision<br/>(allow/deny)"| KRBAC
    KRBAC -->|"Pre-authenticated<br/>HTTP/8000 localhost"| vLLM
    vLLM -->|"Requires auth<br/>(via proxy)"| APIEndpoints
    vLLM -->|"No auth required<br/>(pod-internal only)"| InfoEndpoints

    %% Secret usage
    HF_TOKEN -.->|"Injected as<br/>env var"| vLLM

    %% Platform RBAC
    KServeRBAC -.->|"Manages deployment<br/>of this component"| Container
    PlatformRBAC -.->|"Manages KServe<br/>and sidecar injection"| KRBAC

    %% Notes
    Note1["NOTE: This component defines<br/>NO Kubernetes RBAC resources.<br/>All RBAC is managed by the<br/>platform (KServe + rhods-operator)."]

    style Client fill:#f9f9f9,stroke:#333
    style KRBAC fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style vLLM fill:#50c878,color:#fff
    style APIEndpoints fill:#4a90e2,color:#fff
    style InfoEndpoints fill:#6cb4ee,color:#fff
    style HF_TOKEN fill:#d9534f,color:#fff
    style Container fill:#5bc0de,color:#fff
    style KServeRBAC fill:#7ed321,color:#fff
    style PlatformRBAC fill:#7ed321,color:#fff
    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
