graph TD
    subgraph Note["RBAC Context"]
        direction TB
        Info["vLLM Gaudi is a container image,<br/>NOT an operator.<br/>No RBAC resources are defined<br/>in this repository."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (KServe / RHOAI)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            PodSA["InferenceService Pod SA<br/>(assigned by KServe)"]
        end

        subgraph AuthEnforcement["Authentication Enforcement"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x)<br/>Validates JWT tokens"]
            OAuthProxy["oauth-proxy<br/>(RHOAI 2.x)<br/>OAuth2 flow"]
        end

        subgraph Endpoints["Endpoint Access Control"]
            AuthEndpoints["/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/v1/embeddings<br/>Auth: Bearer Token (JWT)"]
            UnauthEndpoints["/health<br/>/metrics<br/>Auth: None (direct access)"]
        end
    end

    subgraph Secrets["Secrets (User-Provisioned)"]
        S3Creds["Model Storage Credentials<br/>Type: Opaque<br/>Purpose: S3/MinIO access<br/>Provisioned by: User / Dashboard<br/>Auto-Rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Purpose: Gated model access<br/>Provisioned by: User<br/>Auto-Rotate: No"]
    end

    subgraph FIPSWarning["FIPS Compliance"]
        FIPS["WARNING: OpenSSL FIPS provider<br/>explicitly removed in Dockerfile<br/>(rpm -e --nodeps openssl-fips-provider-so)<br/>Container does NOT run in FIPS mode"]
    end

    %% Flows
    PodSA -->|"runs as"| KubeRBACProxy
    PodSA -->|"runs as"| OAuthProxy
    KubeRBACProxy -->|"protects"| AuthEndpoints
    OAuthProxy -->|"protects"| AuthEndpoints
    PodSA -->|"mounts"| S3Creds
    PodSA -->|"mounts"| HFToken

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style KubeRBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style OAuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style PodSA fill:#7ed321,stroke:#333,color:#fff
    style AuthEndpoints fill:#d5e8d4,stroke:#82b366
    style UnauthEndpoints fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#f5a623,stroke:#333,color:#fff
    style HFToken fill:#f5a623,stroke:#333,color:#fff
    style FIPS fill:#ff6666,stroke:#cc0000,color:#fff
