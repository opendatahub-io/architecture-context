graph TD
    subgraph Component["vllm-gaudi (Container Image)"]
        Note["This component defines NO RBAC resources.<br/>It is a container image, not a Kubernetes operator.<br/>All RBAC is managed by the deploying platform."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC"]
        direction TB

        subgraph Sidecar["kube-rbac-proxy Sidecar"]
            KRBAC["kube-rbac-proxy<br/>Enforces authorization<br/>at pod boundary"]
        end

        subgraph PlatformOps["Platform Operator"]
            RHODSOp["rhods-operator<br/>Manages serving<br/>runtime RBAC"]
        end
    end

    subgraph AuthFlow["Authentication Flow"]
        direction TB
        EP_API["/v1/* endpoints<br/>Auth: Platform-delegated<br/>Method: kube-rbac-proxy"]
        EP_Health["/health endpoint<br/>Auth: None<br/>Unauthenticated"]
    end

    subgraph Secrets["Secrets (User-Provisioned)"]
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>Auto-rotate: No"]
        QuantConfig["QUANT_CONFIG<br/>Type: Opaque (env var)<br/>Purpose: Quantization config path<br/>Auto-rotate: No"]
    end

    RHODSOp -->|"creates RBAC for"| KRBAC
    KRBAC -->|"protects"| EP_API
    EP_Health -.->|"no auth required"| Note

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style KRBAC fill:#ffe6cc,stroke:#d79b00
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style EP_API fill:#d5e8d4,stroke:#82b366
    style EP_Health fill:#d5e8d4,stroke:#82b366
    style HFToken fill:#ffcccc,stroke:#cc0000
    style QuantConfig fill:#ffcccc,stroke:#cc0000
