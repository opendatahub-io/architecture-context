graph TD
    subgraph "Authentication Flow (Platform-Managed)"
        Client["External Client<br/>Bearer Token (JWT)"]
        Gateway["KServe Ingress<br/>TLS 1.3 Termination"]
        KRBAC["kube-rbac-proxy Sidecar<br/>(Injected by KServe/RHOAI)"]
    end

    subgraph "Authorization Decision"
        JWTValidation["JWT Token Validation"]
        K8sRBAC["Kubernetes RBAC Check<br/>SubjectAccessReview"]
        K8sAPI["Kubernetes API Server"]
    end

    subgraph "vLLM Endpoints (No Built-in Auth)"
        direction TB
        AuthProtected["/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/v1/embeddings<br/>(Protected by kube-rbac-proxy)"]
        OpenEndpoints["/health<br/>/metrics<br/>(Unauthenticated - direct access)"]
    end

    subgraph "Secrets"
        HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: User-managed<br/>Auto-Rotate: No"]
    end

    subgraph "Platform RBAC (Not in this component)"
        Note["No RBAC resources defined<br/>in vllm-gaudi repo.<br/>All RBAC is managed by:<br/>- KServe operator<br/>- RHOAI platform operator<br/>- kube-rbac-proxy sidecar"]
    end

    %% Auth flow
    Client -->|"HTTPS/443<br/>JWT Bearer Token"| Gateway
    Gateway -->|"Forward"| KRBAC
    KRBAC -->|"Validate"| JWTValidation
    KRBAC -->|"Authorize"| K8sRBAC
    K8sRBAC -->|"SubjectAccessReview"| K8sAPI
    KRBAC -->|"Allowed → HTTP/8000"| AuthProtected
    Client -.->|"Direct pod access<br/>(no auth)"| OpenEndpoints

    %% Secret usage
    HFToken -.->|"env var injection"| AuthProtected

    %% Styling
    style Client fill:#e8e8e8,stroke:#333
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KRBAC fill:#ffe6cc,stroke:#d79b00
    style JWTValidation fill:#d5e8d4,stroke:#82b366
    style K8sRBAC fill:#d5e8d4,stroke:#82b366
    style K8sAPI fill:#d5e8d4,stroke:#82b366
    style AuthProtected fill:#4a90e2,stroke:#333,color:#fff
    style OpenEndpoints fill:#f5a623,stroke:#333,color:#fff
    style HFToken fill:#f8cecc,stroke:#b85450
    style Note fill:#f9f9f9,stroke:#999,stroke-dasharray: 5 5
