graph TD
    subgraph "vLLM Gaudi — RBAC Model"
        direction TB

        Note["NOTE: vLLM Gaudi is a container image,<br/>not an operator. It defines NO RBAC<br/>resources of its own. All RBAC is<br/>managed by KServe and the RHOAI operator."]
    end

    subgraph "Platform-Level RBAC (Managed by KServe/RHOAI)"
        direction TB

        subgraph "Service Accounts"
            SA_KServe["KServe Controller<br/>ServiceAccount"]
            SA_Pod["InferenceService Pod<br/>ServiceAccount"]
        end

        subgraph "Auth Enforcement"
            RBAC_Proxy["kube-rbac-proxy sidecar<br/>(RHOAI 3.x)<br/>Enforces RBAC on /v1/* endpoints"]
            OAuth_Proxy["oauth-proxy sidecar<br/>(RHOAI 2.x)<br/>Alternative auth enforcement"]
        end

        subgraph "Authentication Endpoints"
            Authed["/v1/completions<br/>/v1/chat/completions<br/>/v1/models<br/>/v1/embeddings<br/>Auth: Bearer Token (JWT)<br/>Methods: GET, POST"]
            Unauthed["/health<br/>/metrics<br/>Auth: None<br/>Methods: GET"]
        end
    end

    subgraph "Secrets (User-Provisioned)"
        direction TB
        S3Creds["Model Storage Credentials<br/>Type: Opaque<br/>S3/MinIO access keys<br/>Provisioned by: User / Dashboard<br/>Auto-rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Gated model access<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    %% Relationships
    SA_KServe -->|"manages"| SA_Pod
    SA_Pod -->|"runs"| RBAC_Proxy
    SA_Pod -->|"runs"| OAuth_Proxy
    RBAC_Proxy -->|"protects"| Authed
    OAuth_Proxy -.->|"alternative"| Authed
    SA_Pod -->|"mounts"| S3Creds
    SA_Pod -->|"mounts"| HFToken

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style SA_KServe fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pod fill:#4a90e2,stroke:#333,color:#fff
    style RBAC_Proxy fill:#7ed321,stroke:#333,color:#fff
    style OAuth_Proxy fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style Authed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Unauthed fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style S3Creds fill:#f5a623,stroke:#333,color:#fff
    style HFToken fill:#f5a623,stroke:#333,color:#fff
