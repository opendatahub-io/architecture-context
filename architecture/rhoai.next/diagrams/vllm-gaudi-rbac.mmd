graph TD
    subgraph "vLLM Gaudi RBAC Model"
        direction TB

        Note["ℹ No RBAC resources defined in this repository.<br/>RBAC is managed by KServe and the RHOAI operator.<br/>Authentication is enforced by the kube-rbac-proxy sidecar."]
    end

    subgraph "Platform-Level Auth (Managed by RHOAI/KServe)"
        direction TB

        subgraph "Authentication Flow"
            Client["External Client"]
            JWT["Bearer Token (JWT)"]
            Client -->|presents| JWT
        end

        subgraph "Auth Enforcement (kube-rbac-proxy sidecar)"
            RBACProxy["kube-rbac-proxy"]
            SAR["SubjectAccessReview<br/>(Kubernetes API)"]
            RBACProxy -->|validates JWT| JWT
            RBACProxy -->|checks authorization| SAR
        end

        subgraph "Endpoint Access Policy"
            Authenticated["/v1/* endpoints<br/>Bearer JWT required<br/>RHOAI platform auth policy"]
            Unauthenticated["/health, /metrics<br/>No auth required<br/>Direct access"]
        end

        RBACProxy -->|authorized| Authenticated
        Client -.->|bypasses sidecar| Unauthenticated
    end

    subgraph "Secrets"
        direction LR
        ModelCreds["Model Storage Credentials<br/>Type: Opaque<br/>Purpose: S3/MinIO access<br/>Provisioned by: User / RHOAI Dashboard<br/>Auto-Rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Purpose: Hub auth for gated models<br/>Provisioned by: User<br/>Auto-Rotate: No"]
    end

    subgraph "FIPS Warning"
        FIPS["⚠ FIPS DISABLED<br/>openssl-fips-provider-so removed<br/>Container uses standard OpenSSL<br/>Dockerfile.konflux.gaudi:63"]
    end

    style Note fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style RBACProxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Authenticated fill:#d5e8d4,stroke:#82b366
    style Unauthenticated fill:#fff2cc,stroke:#d6b656
    style ModelCreds fill:#e8e8e8,stroke:#666
    style HFToken fill:#e8e8e8,stroke:#666
    style FIPS fill:#f8cecc,stroke:#b85450,stroke-width:2px
