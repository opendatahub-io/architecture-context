graph TB
    subgraph ConsumingApp["CONSUMING APPLICATION (Runtime Container)"]
        direction TB

        subgraph Library["caikit-tgis-backend Library (in-process)"]
            direction TB
            Backend["TGISBackend<br/>BackendBase plugin"]
            Connection["TGISConnection<br/>gRPC connection manager"]
            LBProxy["GRPCLoadBalancerProxy<br/>DNS polling (10s interval)"]
            Subprocess["ManagedTGISSubprocess<br/>Dev/test only"]
        end
    end

    subgraph RemoteZone["REMOTE TGIS (Production Mode)"]
        RemoteTGIS["TGIS Server<br/>Text Generation Inference"]
    end

    subgraph LocalZone["LOCAL SUBPROCESS (Dev/Test Mode)"]
        LocalTGIS["Local TGIS Process<br/>localhost only"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        DNSServer["DNS Resolver"]
    end

    subgraph Filesystem["FILESYSTEM"]
        PromptDir["Shared Prompt Directory"]
        TLSCerts["TLS Certificate Files<br/>ca_cert_file<br/>client_cert_file<br/>client_key_file"]
    end

    %% Remote mode connections
    LBProxy -->|"gRPC/50055 TCP<br/>TLS 1.2+ with CA cert<br/>OR mTLS (client cert+key)<br/>OR plaintext<br/>grpc.ssl_channel_credentials"| RemoteTGIS

    %% DNS polling
    LBProxy -->|"DNS/53 UDP<br/>plaintext<br/>socket.getaddrinfo()<br/>No auth"| DNSServer

    %% Local mode connections
    Subprocess -->|"gRPC/50055 TCP<br/>plaintext (localhost)<br/>No auth"| LocalTGIS
    Subprocess -->|"HTTP/3000 TCP<br/>plaintext (localhost)<br/>Health check polling<br/>No auth"| LocalTGIS

    %% Filesystem
    Connection -->|"File read<br/>Certificate loading<br/>at initialization"| TLSCerts
    Connection -->|"File copy<br/>shutil.copyfile<br/>Prompt vectors"| PromptDir

    %% Styling
    classDef library fill:#4a90e2,stroke:#333,color:#fff,stroke-width:2px
    classDef remote fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef local fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef filesystem fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class Backend,Connection,LBProxy,Subprocess library
    class RemoteTGIS remote
    class LocalTGIS local
    class DNSServer external
    class PromptDir,TLSCerts filesystem
