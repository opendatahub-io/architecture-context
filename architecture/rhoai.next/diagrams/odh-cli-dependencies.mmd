graph LR
    ODHCLI["odh-cli<br/>(kubectl-odh)"]

    %% External Dependencies (Required)
    ODHCLI -->|"all commands<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v1.29+"]
    ODHCLI -->|"ClusterVersion,<br/>Routes, ImageStreams"| OpenShiftAPI["OpenShift API<br/>v4.14+"]

    %% External Dependencies (Recommended/Checked)
    ODHCLI -->|"dependency checking,<br/>operator install"| OLM["OLM<br/>v0.39+"]
    ODHCLI -->|"lint validates<br/>installation"| CertManager["cert-manager<br/>operator"]
    ODHCLI -->|"lint validates<br/>catalog availability"| ServiceMeshV3["Service Mesh v3<br/>operator"]
    ODHCLI -.->|"optional --refresh<br/>443/TCP HTTPS"| ODHGitops["odh-gitops<br/>(GitHub)"]

    %% Internal ODH Platform CRDs (Read)
    ODHCLI -->|"version detection,<br/>state mgmt, lint"| DSC["DataScienceCluster"]
    ODHCLI -->|"version detection,<br/>namespace lookup"| DSCI["DSCInitialization"]
    ODHCLI -->|"health enrichment"| ComponentCRs["Component CRs<br/>platform.opendatahub.io"]

    %% Workload CRDs (Read for lint/backup/get)
    ODHCLI -->|"backup, get,<br/>7 lint checks"| Notebooks["Notebooks<br/>kubeflow.org"]
    ODHCLI -->|"get, 6 lint<br/>condition types"| ISVCs["InferenceServices<br/>serving.kserve.io"]
    ODHCLI -->|"get, deprecated<br/>runtime checks"| ServingRuntimes["ServingRuntimes<br/>serving.kserve.io"]
    ODHCLI -->|"backup, get,<br/>lint checks"| DSPAs["DSPApplications"]
    ODHCLI -->|"lint workload<br/>checks"| RayClusters["RayClusters<br/>ray.io"]
    ODHCLI -->|"lint deprecation<br/>checks"| PyTorchJobs["PyTorchJobs<br/>kubeflow.org"]
    ODHCLI -->|"data integrity,<br/>migration"| Kueue["ClusterQueues /<br/>LocalQueues<br/>kueue.x-k8s.io"]
    ODHCLI -->|"config validation,<br/>OTEL migration"| Guardrails["GuardrailsOrchestrator<br/>trustyai"]
    ODHCLI -->|"requires-recreation<br/>check"| LlamaStack["LlamaStackDistribution"]
    ODHCLI -->|"Authorino TLS,<br/>Kuadrant readiness"| LLMInference["LLMInferenceService<br/>serving.kserve.io"]
    ODHCLI -->|"migration checks"| Profiles["Accelerator / Hardware<br/>Profiles"]

    %% Core Resources
    ODHCLI -->|"backup dependency<br/>resolution"| CoreResources["ConfigMaps / Secrets<br/>/ PVCs"]

    %% Styling
    style ODHCLI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External - gray
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style OLM fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style ServiceMeshV3 fill:#999,stroke:#333,color:#fff
    style ODHGitops fill:#999,stroke:#333,color:#fff

    %% Internal ODH Platform - green
    style DSC fill:#7ed321,stroke:#333
    style DSCI fill:#7ed321,stroke:#333
    style ComponentCRs fill:#7ed321,stroke:#333

    %% Workload CRDs - orange/yellow
    style Notebooks fill:#f5a623,stroke:#333
    style ISVCs fill:#f5a623,stroke:#333
    style ServingRuntimes fill:#f5a623,stroke:#333
    style DSPAs fill:#f5a623,stroke:#333
    style RayClusters fill:#f5a623,stroke:#333
    style PyTorchJobs fill:#f5a623,stroke:#333
    style Kueue fill:#f5a623,stroke:#333
    style Guardrails fill:#f5a623,stroke:#333
    style LlamaStack fill:#f5a623,stroke:#333
    style LLMInference fill:#f5a623,stroke:#333
    style Profiles fill:#f5a623,stroke:#333

    %% Core - light red
    style CoreResources fill:#f8cecc,stroke:#b85450
