graph LR
    ODHCLI["odh-cli<br/>(kubectl-odh)"]

    %% External Dependencies (Required)
    ODHCLI -->|"all commands<br/>HTTPS/6443"| K8sAPI["Kubernetes API<br/>v1.29+"]
    ODHCLI -->|"ClusterVersion<br/>HTTPS/6443"| OpenShiftAPI["OpenShift API<br/>v4.14+"]

    %% External Dependencies (Recommended)
    ODHCLI -->|"deps check, migrate<br/>HTTPS/6443"| OLM["OLM<br/>v0.39+"]

    %% External Dependencies (Checked by lint)
    ODHCLI -.->|"lint validates<br/>installation"| CertManager["cert-manager<br/>Operator"]
    ODHCLI -.->|"lint validates<br/>catalog availability"| ServiceMeshV3["Service Mesh v3<br/>Operator"]

    %% External Dependencies (Optional)
    ODHCLI -.->|"deps --refresh<br/>HTTPS/443"| ODHGitOps["odh-gitops<br/>(GitHub)<br/>Pinned: 1a55af06"]

    %% Internal ODH Platform Dependencies (Read)
    ODHCLI -->|"version detection<br/>component state<br/>READ + PATCH"| DSC["DataScienceCluster<br/>(singleton)"]
    ODHCLI -->|"namespace lookup<br/>ServiceMesh state<br/>READ"| DSCI["DSCInitialization<br/>(singleton)"]

    %% Internal Workload Dependencies (Read)
    ODHCLI -->|"backup, get, lint<br/>READ"| Notebooks["Notebooks<br/>kubeflow.org"]
    ODHCLI -->|"get, lint<br/>(6 condition types)<br/>READ"| ISVC["InferenceServices<br/>serving.kserve.io"]
    ODHCLI -->|"get, lint<br/>READ"| ServingRT["ServingRuntimes<br/>serving.kserve.io"]
    ODHCLI -->|"backup, get, lint<br/>(9-field deps)<br/>READ"| DSPA["DataSciencePipelines<br/>Application"]
    ODHCLI -->|"lint workload checks<br/>READ"| Ray["RayClusters<br/>RayJobs<br/>ray.io"]
    ODHCLI -->|"lint deprecation<br/>READ"| PyTorch["PyTorchJobs<br/>kubeflow.org"]
    ODHCLI -->|"lint + migrate<br/>data integrity<br/>READ"| Kueue["ClusterQueues<br/>LocalQueues<br/>kueue.x-k8s.io"]
    ODHCLI -->|"lint config<br/>validation<br/>READ"| Guardrails["Guardrails<br/>Orchestrator<br/>trustyai"]
    ODHCLI -.->|"lint blocking<br/>check, READ"| LlamaStack["LlamaStack<br/>Distribution"]
    ODHCLI -.->|"lint TLS/Kuadrant<br/>readiness, READ"| LLMISVC["LLMInference<br/>Service<br/>kserve.io"]
    ODHCLI -.->|"lint TLS check<br/>READ"| Authorino["Authorino<br/>kuadrant.io"]
    ODHCLI -.->|"lint readiness<br/>READ"| Kuadrant["Kuadrant<br/>kuadrant.io"]
    ODHCLI -->|"lint migration<br/>READ"| AccelHW["AcceleratorProfiles<br/>HardwareProfiles"]
    ODHCLI -->|"components health<br/>READ"| CompCRs["Component CRs<br/>platform.opendatahub.io"]

    %% Core Resources
    ODHCLI -->|"backup deps<br/>READ"| CoreRes["ConfigMaps<br/>Secrets<br/>PVCs"]

    %% Build Dependencies
    Konflux["Konflux<br/>Build System"] -->|"hermetic build<br/>FIPS"| ODHCLI
    GoReleaser["GoReleaser"] -->|"standalone binary<br/>release"| ODHCLI

