graph LR
    ODHCLI["odh-cli<br/>(rhai-cli / kubectl-odh)"]

    %% External Infrastructure Dependencies
    ODHCLI -->|"REST API<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API Server<br/>v1.28+"]
    ODHCLI -->|"ClusterVersion<br/>OLM, Routes"| OpenShift["OpenShift<br/>4.14+"]
    ODHCLI -->|"Subscriptions<br/>CSVs, OperatorGroups"| OLM["OLM<br/>v0.39+"]

    %% Go Library Dependencies
    ODHCLI -->|"K8s client"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    ODHCLI -->|"CLI framework"| Cobra["spf13/cobra<br/>v1.10.2"]
    ODHCLI -->|"version parsing"| Semver["blang/semver<br/>v4"]
    ODHCLI -->|"JSON/YAML query"| GoJQ["itchyny/gojq<br/>v0.12.18"]
    ODHCLI -->|"table output"| TableWriter["olekukonko/tablewriter<br/>v1.1.3"]
    ODHCLI -->|"health checks"| ClusterHealth["clusterhealth<br/>v0.1.1"]

    %% Embedded Data Dependencies
    ODHCLI -->|"embedded at build<br/>(Helm manifests)"| ODHGitOps["odh-gitops<br/>commit 1a55af0"]
    ODHCLI -.->|"runtime refresh<br/>HTTPS/443"| GitHub["GitHub<br/>raw.githubusercontent.com"]

    %% Internal RHOAI Platform Dependencies (CRD interactions)
    ODHCLI -->|"CRD Read/Patch"| DSC["DataScienceCluster"]
    ODHCLI -->|"CRD Read"| DSCI["DSCInitialization"]
    ODHCLI -->|"CRD Read"| ComponentCRs["Component CRs<br/>(platform.opendatahub.io)"]

    %% Workload CRDs Validated
    ODHCLI -->|"lint/get"| KServe["KServe<br/>InferenceServices<br/>ServingRuntimes"]
    ODHCLI -->|"lint/get/backup"| Notebooks["Kubeflow Notebooks"]
    ODHCLI -->|"lint/get/backup"| Pipelines["DSP Applications"]
    ODHCLI -->|"lint"| RayCluster["Ray<br/>RayClusters / RayJobs"]
    ODHCLI -->|"lint"| PyTorch["PyTorchJobs"]
    ODHCLI -->|"lint"| AppWrappers["AppWrappers<br/>(CodeFlare)"]
    ODHCLI -->|"lint"| Kuadrant["Kuadrant / Authorino"]
    ODHCLI -->|"lint"| LlamaStack["LlamaStack<br/>Distributions"]
    ODHCLI -->|"lint/migrate"| Kueue["Kueue<br/>ClusterQueues"]
    ODHCLI -->|"lint"| HWProfile["HardwareProfile<br/>AcceleratorProfile"]

    %% Bundled Tools
    ODHCLI -.->|"bundled in<br/>container image"| YQ["yq<br/>(FIPS-compliant)"]
    ODHCLI -.->|"bundled scripts"| UpgradeHelpers["rhoai-upgrade-helpers<br/>(shell scripts)"]
    ODHCLI -.->|"bundled scripts"| PythonHelpers["Python helpers<br/>(ray_cluster_migration.py)"]

