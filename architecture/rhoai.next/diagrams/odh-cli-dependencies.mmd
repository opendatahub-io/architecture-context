graph LR
    ODH_CLI["odh-cli<br/>(kubectl-odh)"]

    %% External Dependencies (Required)
    ODH_CLI -->|"all queries<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v1.29+"]
    ODH_CLI -->|"ClusterVersion,<br/>Routes"| OpenShift["OpenShift API<br/>v4.14+"]

    %% External Dependencies (Recommended/Checked)
    ODH_CLI -->|"operator lifecycle<br/>subscriptions, CSVs"| OLM["OLM<br/>v0.39+"]
    ODH_CLI -.->|"lint validates<br/>installation"| CertManager["cert-manager<br/>Operator"]
    ODH_CLI -.->|"lint validates<br/>catalog availability"| ServiceMeshV3["Service Mesh v3<br/>Operator"]

    %% External Service (Optional)
    ODH_CLI -.->|"--refresh mode<br/>443/TCP HTTPS"| GitHub["odh-gitops<br/>(GitHub)"]

    %% Internal Platform Dependencies (Read)
    ODH_CLI -->|"version detection<br/>component state"| DSC["DataScienceCluster<br/>(singleton)"]
    ODH_CLI -->|"version fallback<br/>namespace lookup"| DSCI["DSCInitialization<br/>(singleton)"]

    %% Workload CRD Dependencies (Read)
    ODH_CLI -->|"backup, get,<br/>7 lint checks"| Notebooks["Notebooks<br/>(kubeflow.org)"]
    ODH_CLI -->|"get, 6 lint<br/>condition types"| ISVC["InferenceServices<br/>(kserve.io)"]
    ODH_CLI -->|"get, lint deprecated<br/>runtimes"| SR["ServingRuntimes<br/>(kserve.io)"]
    ODH_CLI -->|"backup (9-field),<br/>lint renaming"| DSPA["DSPA<br/>(opendatahub.io)"]
    ODH_CLI -->|"lint AppWrapper<br/>cleanup"| Ray["RayClusters/Jobs<br/>(ray.io)"]
    ODH_CLI -->|"lint deprecation<br/>checks"| PyTorch["PyTorchJobs<br/>(kubeflow.org)"]
    ODH_CLI -->|"lint integrity,<br/>migration"| Kueue["ClusterQueues/<br/>LocalQueues<br/>(kueue.x-k8s.io)"]
    ODH_CLI -->|"lint config (5 fields),<br/>OTEL migration"| Guardrails["GuardrailsOrch<br/>(trustyai)"]
    ODH_CLI -.->|"lint requires-<br/>recreation"| LlamaStack["LlamaStack<br/>(llamastack.io)"]
    ODH_CLI -.->|"lint Authorino TLS,<br/>Kuadrant readiness"| LLMIS["LLMInference<br/>(kserve.io)"]
    ODH_CLI -.->|"lint TLS config,<br/>ready status"| Authorino["Authorino<br/>(kuadrant.io)"]
    ODH_CLI -.->|"lint readiness<br/>(llm-d gate)"| Kuadrant["Kuadrant<br/>(kuadrant.io)"]
    ODH_CLI -->|"lint migration<br/>checks"| Profiles["AcceleratorProfile/<br/>HardwareProfile"]
    ODH_CLI -->|"component health<br/>enrichment"| CompCRs["Component CRs<br/>(platform.opendatahub.io)"]
    ODH_CLI -->|"backup dependency<br/>resolution"| CoreAPI["ConfigMaps /<br/>Secrets / PVCs"]

    %% Local output
    ODH_CLI -->|"backup YAML,<br/>migration files"| LocalFS["Local Filesystem"]

