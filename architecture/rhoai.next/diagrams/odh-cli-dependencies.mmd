graph LR
    ODHCLI["odh-cli<br/>(rhai-cli / kubectl-odh)"]

    %% External Dependencies (Required)
    ODHCLI -->|"HTTPS/6443<br/>All operations"| K8sAPI["Kubernetes API<br/>1.28+<br/>(Required)"]
    ODHCLI -->|"HTTPS/6443<br/>ClusterVersion,<br/>ImageStreams"| OpenShift["OpenShift API<br/>4.19+<br/>(Required)"]

    %% External Dependencies (Optional)
    ODHCLI -.->|"HTTPS/6443<br/>Subscription/CSV queries"| OLM["OLM<br/>v1alpha1<br/>(Optional, nil-safe)"]
    ODHCLI -.->|"HTTPS/443<br/>--refresh mode"| GitOps["odh-gitops<br/>GitHub<br/>(Optional)"]
    ODHCLI -.->|"validated by<br/>lint checks"| CertManager["cert-manager<br/>v1<br/>(Optional)"]
    ODHCLI -.->|"installed by<br/>migrate run"| RHBOK["RH Build of Kueue<br/>Operator<br/>stable-v1.1<br/>(Optional)"]

    %% Internal RHOAI Platform Dependencies
    ODHCLI -->|"Read/Patch<br/>version detection,<br/>component mgmt"| DSC["DataScienceCluster"]
    ODHCLI -->|"Read<br/>namespace discovery"| DSCI["DSCInitialization"]
    ODHCLI -->|"Read OLM<br/>version detection"| RHOAIOp["RHOAI Operator<br/>(rhods-operator)"]

    %% Workload CRDs Read
    ODHCLI -->|"Read<br/>8 lint checks,<br/>backup"| NotebookCRDs["Kubeflow Notebooks"]
    ODHCLI -->|"Read<br/>4 lint checks,<br/>backup"| KServeCRDs["KServe<br/>InferenceService<br/>ServingRuntime"]
    ODHCLI -->|"Read<br/>data integrity,<br/>migration"| KueueCRDs["Kueue<br/>ClusterQueue<br/>LocalQueue"]
    ODHCLI -->|"Read<br/>backup with deps"| DSPACRDs["Data Science Pipelines<br/>DSPA"]
    ODHCLI -->|"Read<br/>AppWrapper cleanup"| RayCRDs["Ray<br/>RayCluster<br/>RayJob"]
    ODHCLI -->|"Read<br/>completion checks"| TrainingCRDs["Training Operator<br/>PyTorchJob"]

    %% Component CRDs Read
    ODHCLI -.->|"Read<br/>migration readiness"| DashboardCRDs["Dashboard<br/>AcceleratorProfile<br/>HardwareProfile"]
    ODHCLI -.->|"Read<br/>removal validation"| CodeFlareCRDs["CodeFlare<br/>AppWrapper"]
    ODHCLI -.->|"Read<br/>OTEL migration"| TrustyAICRDs["TrustyAI<br/>GuardrailsOrchestrator"]
    ODHCLI -.->|"Read<br/>arch compat"| LlamaStackCRDs["LlamaStack<br/>LlamaStackDistribution"]
    ODHCLI -.->|"Read<br/>Gateway API ready"| KuadrantCRDs["Kuadrant"]
    ODHCLI -.->|"Read<br/>TLS readiness"| AuthorinoCRDs["Authorino"]
    ODHCLI -.->|"Read<br/>health status"| ComponentCRs["Component CRs<br/>(13 types)"]

    %% Bundled Tools
    ODHCLI ---|"bundled in<br/>container image"| YQ["yq (vendored)<br/>FIPS-compliant"]
    ODHCLI ---|"bundled in<br/>container image"| UpgradeHelpers["rhoai-upgrade-helpers<br/>Shell/Python"]

    %% Styling
    style ODHCLI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff

    %% Optional external
