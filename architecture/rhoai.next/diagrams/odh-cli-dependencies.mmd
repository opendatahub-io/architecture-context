graph LR
    ODHCLI["odh-cli<br/>(rhai-cli / kubectl-odh)"]

    %% External Dependencies (Required)
    ODHCLI -->|"all operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>1.28+"]
    ODHCLI -->|"ClusterVersion,<br/>ImageStreams<br/>6443/TCP HTTPS"| OpenShift["OpenShift API<br/>4.19+"]

    %% External Dependencies (Optional)
    ODHCLI -.->|"operator queries<br/>6443/TCP HTTPS"| OLM["OLM<br/>v1alpha1"]
    ODHCLI -.->|"manifest fetch<br/>443/TCP HTTPS"| GitOps["odh-gitops<br/>(GitHub)"]
    ODHCLI -.->|"lint validation"| CertManager["cert-manager<br/>v1"]
    ODHCLI -.->|"RHBOK install<br/>(migrate run)"| KueueOp["Red Hat Build of<br/>Kueue Operator<br/>stable-v1.1"]

    %% Internal Platform Dependencies (Read)
    ODHCLI -->|"version detection<br/>component state"| DSC["DataScienceCluster"]
    ODHCLI -->|"namespace discovery<br/>version detection"| DSCI["DSCInitialization"]
    ODHCLI -->|"version detection"| RHODSOp["rhods-operator<br/>(OLM Subscription)"]

    %% Workload CRDs (Read for lint/backup)
    ODHCLI -.->|"8 lint checks<br/>backup"| Notebooks["Kubeflow<br/>Notebooks"]
    ODHCLI -.->|"4 lint checks<br/>backup"| ISVC["KServe<br/>InferenceServices"]
    ODHCLI -.->|"serving runtimes"| ServingRT["KServe<br/>ServingRuntimes"]
    ODHCLI -.->|"data integrity<br/>migration"| Kueue["Kueue<br/>ClusterQueue/LocalQueue"]
    ODHCLI -.->|"AppWrapper cleanup<br/>impact assessment"| Ray["Ray<br/>RayCluster/RayJob"]
    ODHCLI -.->|"completion status"| Training["Training Operator<br/>PyTorchJob"]
    ODHCLI -.->|"backup + deps<br/>renaming checks"| DSP["Data Science Pipelines<br/>DSPA"]

    %% Component CRDs (Read for lint)
    ODHCLI -.->|"migration readiness"| AccProfile["Dashboard<br/>AcceleratorProfiles"]
    ODHCLI -.->|"migration tracking"| HWProfile["Dashboard<br/>HardwareProfiles"]
    ODHCLI -.->|"removal validation"| AppWrapper["CodeFlare<br/>AppWrappers"]
    ODHCLI -.->|"OTEL migration"| Guardrails["TrustyAI<br/>GuardrailsOrchestrator"]
    ODHCLI -.->|"arch compatibility"| LlamaStack["LlamaStack<br/>Distributions"]
    ODHCLI -.->|"Gateway API<br/>readiness"| Kuadrant["Kuadrant"]
    ODHCLI -.->|"TLS readiness"| Authorino["Authorino"]
    ODHCLI -.->|"health status"| ComponentCRs["Component CRs<br/>(13 types)"]

    %% Local output
    ODHCLI -->|"backup YAML<br/>output"| LocalFS["Local Filesystem"]

    %% Styling
    style ODHCLI fill:#4a90e2,stroke:#1565c0,stroke-width:4px,color:#fff

    %% External required
    style K8sAPI fill:#e53935,stroke:#b71c1c,color:#fff
    style OpenShift fill:#e53935,stroke:#b71c1c,color:#fff

    %% External optional
    style OLM fill:#999,stroke:#616161,color:#fff
    style GitOps fill:#999,stroke:#616161,color:#fff
    style CertManager fill:#999,stroke:#616161,color:#fff
    style KueueOp fill:#999,stroke:#616161,color:#fff

    %% Internal platform
    style DSC fill:#7ed321,stroke:#558b2f,color:#fff
    style DSCI fill:#7ed321,stroke:#558b2f,color:#fff
    style RHODSOp fill:#7ed321,stroke:#558b2f,color:#fff

