graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Producer["External Producer<br/>(submits jobs)"]
        Consumer["External Consumer<br/>(retrieves results)"]
    end

    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph NS_AP["Namespace: llm-d"]
            AP["Async Processor Pod<br/>Image: ghcr.io/llm-d/async-processor:0.6.0<br/>SA: &lt;release&gt;-async-processor<br/>FIPS: strictfipsruntime + CGO<br/>Base: UBI 9 minimal"]
            MetricsEP["/metrics endpoint<br/>9090/TCP HTTP<br/>No encryption<br/>Optional K8s TokenReview+SAR"]
        end

        subgraph NS_IGW["Namespace: llm-d-inference-scheduler"]
            IGW["Inference Gateway<br/>(Envoy/Istio)<br/>80/TCP or 443/TCP"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Redis["Redis Server<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS (rediss://)<br/>URL credentials"]
        Prometheus["Prometheus<br/>9090/TCP<br/>HTTP<br/>No encryption<br/>No auth"]
        GCP["GCP Pub/Sub<br/>443/TCP<br/>HTTPS (gRPC)<br/>TLS 1.2+<br/>OAuth2"]
        GMP["Google Managed Prometheus<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 / GCP IAM"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>SA Token"]
    end

    %% External to Redis
    Producer -->|"Redis/6379<br/>Optional TLS<br/>URL credentials<br/>ZADD (sorted set)"| Redis
    Consumer -->|"Redis/6379<br/>Optional TLS<br/>URL credentials<br/>BRPOP (results)"| Redis

    %% AP to Redis
    AP -->|"Redis/6379<br/>Optional TLS<br/>URL credentials<br/>ZPOPMIN/ZADD/LPUSH"| Redis

    %% AP to IGW
    AP -->|"HTTP(S)/80 or 443<br/>TLS 1.2+ (configurable)<br/>Optional mTLS client cert<br/>POST inference"| IGW

    %% AP to Prometheus
    AP -->|"HTTP/9090<br/>No encryption<br/>PromQL queries<br/>pool_saturation, queue_size"| Prometheus

    %% AP to GCP (optional)
    AP -.->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2<br/>Subscribe/Publish"| GCP

    %% AP to GMP (optional)
    AP -.->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2<br/>PromQL (alternative)"| GMP

    %% AP to K8s API
    AP -.->|"HTTPS/443<br/>TLS<br/>SA Token<br/>TokenReview, SAR"| K8sAPI

    %% Metrics scraping
    Prometheus -.->|"HTTP/9090<br/>Scrape /metrics"| MetricsEP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ap fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef igw fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef metrics fill:#e8d5f5,stroke:#9b59b6,stroke-width:1px

    class Producer,Consumer external
    class AP ap
    class MetricsEP metrics
    class IGW igw
    class Redis,Prometheus,GCP,GMP,K8sAPI externalservice
