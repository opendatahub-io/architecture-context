graph TB
    subgraph "ModelMesh Sidecar (Java 21)"
        direction TB
        CacheManager["Cache Manager<br/>(Distributed LRU)"]
        RequestRouter["Request Router<br/>(gRPC Proxy)"]
        VModelMgr["VModel Manager<br/>(Zero-Downtime Updates)"]
        ProtoSplicer["Proto Splicer<br/>(Model ID Injection)"]
        PayloadProc["Payload Processor<br/>(Logging/Remote)"]
        MetricsServer["Metrics Server<br/>(Prometheus/StatsD)"]
        HealthServer["Health Server<br/>(Ready/Live)"]
        PreStopServer["PreStop Server<br/>(Graceful Shutdown)"]

        RequestRouter -->|"routes to cache"| CacheManager
        RequestRouter -->|"injects model ID"| ProtoSplicer
        RequestRouter -->|"resolves vmodel"| VModelMgr
        RequestRouter -->|"observes payloads"| PayloadProc
        CacheManager -->|"eviction/load decisions"| RequestRouter
    end

    Client["Client / KServe Proxy"] -->|"gRPC :8033<br/>Optional TLS/mTLS"| RequestRouter
    Controller["modelmesh-serving<br/>Controller"] -->|"gRPC :8033<br/>register/unregister"| RequestRouter

    subgraph "Colocated Model Runtime"
        Runtime["Model Runtime<br/>(Triton / MLServer / Custom)"]
        Adapter["modelmesh-runtime-adapter"]
        Adapter -->|"bridges"| Runtime
    end

    CacheManager -->|"gRPC :8085 or UDS<br/>load/unload/status"| Adapter

    subgraph "Other Pods"
        RemoteMM["Remote ModelMesh<br/>Instance(s)"]
    end

    RequestRouter -->|"Thrift/gRPC :8033<br/>TLS/mTLS<br/>forward inference"| RemoteMM

    etcd["etcd Cluster<br/>:2379/TCP"]
    CacheManager -->|"gRPC :2379<br/>model records<br/>leader election"| etcd
    VModelMgr -->|"gRPC :2379<br/>vmodel mappings"| etcd

    MetricsServer -->|"HTTPS :2112<br/>self-signed TLS"| Prometheus["Prometheus"]
    HealthServer -->|"HTTP :8089"| K8sProbes["Kubernetes<br/>Probes"]

    style CacheManager fill:#4a90e2,stroke:#333,color:#fff
    style RequestRouter fill:#4a90e2,stroke:#333,color:#fff
    style VModelMgr fill:#4a90e2,stroke:#333,color:#fff
    style ProtoSplicer fill:#4a90e2,stroke:#333,color:#fff
    style PayloadProc fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#4a90e2,stroke:#333,color:#fff
    style PreStopServer fill:#4a90e2,stroke:#333,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style Adapter fill:#7ed321,stroke:#333,color:#fff
    style RemoteMM fill:#f5a623,stroke:#333,color:#fff
    style etcd fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Controller fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sProbes fill:#e8e8e8,stroke:#333
