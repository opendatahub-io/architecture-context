graph TB
    subgraph ModelMeshPod["ModelMesh Pod (ServingRuntime)"]
        direction TB

        subgraph ModelMeshSidecar["ModelMesh Sidecar (Java 21)"]
            ModelMeshCore["ModelMesh Core<br/>Distributed LRU Cache<br/>Model Placement & Routing"]
            ModelMeshApi["ModelMeshApi<br/>gRPC Server<br/>8033/TCP"]
            SidecarModelMesh["SidecarModelMesh<br/>gRPC Client<br/>8085/TCP or UDS"]
            VModelManager["VModelManager<br/>Virtual Model Aliases<br/>Blue-Green Transitions"]
            MetricsReporter["Metrics Reporter<br/>Prometheus / StatsD"]
            PreStopServer["PreStop Server<br/>HTTP 8090/TCP"]

            ModelMeshApi -->|"routes requests"| ModelMeshCore
            ModelMeshCore -->|"manages vModels"| VModelManager
            ModelMeshCore -->|"delegates load/serve"| SidecarModelMesh
            ModelMeshCore -->|"exports metrics"| MetricsReporter
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            Runtime["Model Runtime<br/>(Triton / MLServer / Custom)<br/>ModelRuntime gRPC API"]
        end

        SidecarModelMesh -->|"gRPC: loadModel,<br/>unloadModel, serve<br/>8085/TCP or UDS<br/>plaintext"| Runtime
    end

    Client["Client<br/>(Inference / Management)"] -->|"gRPC 8033/TCP<br/>TLS + mTLS (optional)"| ModelMeshApi

    subgraph OtherPods["Other ModelMesh Pods"]
        Peer["ModelMesh Peer<br/>Litelinks RPC"]
    end

    ModelMeshCore -->|"Litelinks Thrift<br/>8080/TCP<br/>TLS + mTLS (optional)<br/>Request Forwarding"| Peer

    etcd["etcd Cluster<br/>2379/TCP"]
    ModelMeshCore -->|"gRPC 2379/TCP<br/>TLS (configurable)<br/>Model Registry,<br/>Leader Election,<br/>Instance Records"| etcd

    VModelManager -->|"vModel state<br/>KVTable"| etcd

    Prometheus["Prometheus"] -->|"scrape HTTPS<br/>2112/TCP<br/>TLS (self-signed)"| MetricsReporter

    HealthCheck["Kubernetes<br/>Health Probes"] -->|"GET /ready, /live<br/>8089/TCP HTTP"| ModelMeshSidecar

    style ModelMeshCore fill:#4a90e2,stroke:#333,color:#fff
    style ModelMeshApi fill:#4a90e2,stroke:#333,color:#fff
    style SidecarModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style VModelManager fill:#4a90e2,stroke:#333,color:#fff
    style MetricsReporter fill:#4a90e2,stroke:#333,color:#fff
    style PreStopServer fill:#4a90e2,stroke:#333,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#f5a623,stroke:#333,color:#fff
    style Peer fill:#9b59b6,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style HealthCheck fill:#e8e8e8,stroke:#333
