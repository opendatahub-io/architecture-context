graph TB
    subgraph ServingRuntimePod["ServingRuntime Pod"]
        direction TB

        subgraph ModelMeshSidecar["ModelMesh Sidecar Container"]
            direction TB
            ModelMeshApi["ModelMeshApi<br/>gRPC Server<br/>:8033/TCP"]
            SidecarModelMesh["SidecarModelMesh<br/>Distributed LRU Cache<br/>& Routing Engine"]
            VModelManager["VModelManager<br/>Virtual Model Layer<br/>Zero-downtime transitions"]
            Litelinks["Litelinks Service<br/>Thrift RPC Framework<br/>:8080/TCP"]
            PrometheusServer["Prometheus Metrics Server<br/>Netty HTTP/HTTPS<br/>:2112/TCP"]
            PreStopServer["PreStop Server<br/>HTTP<br/>:8089/TCP"]

            ModelMeshApi -->|"inference & mgmt<br/>requests"| SidecarModelMesh
            SidecarModelMesh -->|"vmodel lookup"| VModelManager
            SidecarModelMesh -->|"forward to<br/>remote instance"| Litelinks
            SidecarModelMesh -->|"report metrics"| PrometheusServer
        end

        subgraph RuntimeContainer["Model Runtime Container<br/>(Triton, MLServer, etc.)"]
            ModelRuntime["Model Runtime<br/>gRPC Server"]
        end

        SidecarModelMesh -->|"gRPC :8085/TCP<br/>or UDS /tmp/mmesh/grpc.sock<br/>loadModel, unloadModel,<br/>inference"| ModelRuntime
    end

    Client["Client<br/>(modelmesh-serving<br/>or external)"] -->|"gRPC :8033/TCP<br/>TLS + mTLS (optional)"| ModelMeshApi

    OtherInstances["Other ModelMesh<br/>Instances"] <-->|"Thrift :8080/TCP<br/>TLS + mTLS (optional)<br/>inference forwarding"| Litelinks

    etcd["etcd<br/>(model-mesh-etcd)<br/>:2379/TCP"] <-->|"gRPC<br/>model registry,<br/>instance registry,<br/>leader election,<br/>dynamic config"| SidecarModelMesh
    VModelManager -->|"gRPC :2379/TCP<br/>vmodel records"| etcd

    Prometheus["Prometheus<br/>Scraper"] -->|"HTTPS :2112/TCP<br/>TLS (self-signed)<br/>GET /metrics"| PrometheusServer

    K8sProbes["Kubernetes<br/>Probes"] -->|"HTTP :8089/TCP<br/>GET /ready, /live"| PreStopServer

    ModelmeshServing["modelmesh-serving<br/>Controller"] -.->|"Deploys & configures<br/>sidecar container"| ServingRuntimePod

    style ModelMeshApi fill:#4a90e2,color:#fff
    style SidecarModelMesh fill:#4a90e2,color:#fff
    style VModelManager fill:#4a90e2,color:#fff
    style Litelinks fill:#4a90e2,color:#fff
    style PrometheusServer fill:#4a90e2,color:#fff
    style PreStopServer fill:#4a90e2,color:#fff
    style ModelRuntime fill:#7ed321,color:#fff
    style etcd fill:#f5a623,color:#fff
    style OtherInstances fill:#9b59b6,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sProbes fill:#e8e8e8,stroke:#333
    style ModelmeshServing fill:#7ed321,color:#fff
