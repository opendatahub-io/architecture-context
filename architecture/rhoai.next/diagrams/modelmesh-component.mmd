graph TB
    subgraph External["External Clients"]
        Client[Client / modelmesh-serving]
    end

    subgraph ModelMeshPod["ModelMesh Pod"]
        direction TB

        subgraph ModelMeshSidecar["ModelMesh Sidecar Container"]
            direction TB
            ModelMeshApi["ModelMeshApi<br/>gRPC Server<br/>:8033/TCP"]
            SidecarModelMesh["SidecarModelMesh<br/>Distributed LRU Cache<br/>& Routing Engine"]
            VModelManager["VModelManager<br/>Virtual Model Layer<br/>Zero-downtime transitions"]
            Litelinks["Litelinks Service<br/>Thrift RPC<br/>:8080/TCP"]
            PrometheusServer["Prometheus Metrics Server<br/>Netty HTTP/HTTPS<br/>:2112/TCP"]
            PreStopServer["PreStop Server<br/>HTTP<br/>:8089/TCP"]

            ModelMeshApi -->|"validates &<br/>routes"| SidecarModelMesh
            SidecarModelMesh -->|"vmodel<br/>lookups"| VModelManager
            SidecarModelMesh -->|"forwards to<br/>remote instances"| Litelinks
            SidecarModelMesh -->|"reports"| PrometheusServer
        end

        subgraph RuntimeContainer["Model Runtime Container<br/>(Triton, MLServer, etc.)"]
            ModelRuntime["Model Runtime<br/>gRPC Server"]
        end

        SidecarModelMesh -->|"gRPC :8085/TCP<br/>or UDS<br/>/tmp/mmesh/grpc.sock"| ModelRuntime
    end

    subgraph KVStore["Distributed KV Store"]
        etcd["etcd<br/>:2379/TCP"]
    end

    subgraph OtherInstances["Other ModelMesh Instances"]
        RemoteMM["Remote ModelMesh<br/>:8080/TCP Thrift"]
    end

    subgraph Platform["Platform Components"]
        MMServing["modelmesh-serving<br/>Controller"]
        Prometheus["Prometheus<br/>Monitoring"]
    end

    %% External flows
    Client -->|"gRPC/HTTP2<br/>:8033/TCP<br/>TLS + mTLS (optional)"| ModelMeshApi
    MMServing -->|"deploys &<br/>configures"| ModelMeshPod

    %% KV-store flows
    SidecarModelMesh -->|"model registry<br/>leader election<br/>:2379/TCP gRPC"| etcd
    VModelManager -->|"vmodel records<br/>:2379/TCP gRPC"| etcd

    %% Inter-instance flows
    Litelinks <-->|"Thrift/TCP<br/>:8080/TCP<br/>TLS + mTLS (optional)"| RemoteMM

    %% Monitoring
    Prometheus -->|"scrape<br/>HTTPS :2112/TCP<br/>TLS (self-signed)"| PrometheusServer

    %% Styling
    style ModelMeshApi fill:#4a90e2,stroke:#333,color:#fff
    style SidecarModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style VModelManager fill:#4a90e2,stroke:#333,color:#fff
    style Litelinks fill:#4a90e2,stroke:#333,color:#fff
    style PrometheusServer fill:#4a90e2,stroke:#333,color:#fff
    style PreStopServer fill:#4a90e2,stroke:#333,color:#fff
    style ModelRuntime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#f5a623,stroke:#333,color:#fff
    style RemoteMM fill:#9b59b6,stroke:#333,color:#fff
    style MMServing fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
