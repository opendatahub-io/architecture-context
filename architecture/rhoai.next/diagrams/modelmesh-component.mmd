graph TB
    subgraph ModelMeshPod["ModelMesh Pod (ServingRuntime)"]
        direction TB

        subgraph SidecarContainer["ModelMesh Sidecar (Java 21)"]
            CacheManager["Cache Manager<br/>(Distributed LRU)"]
            RequestRouter["Request Router<br/>(gRPC Proxy)"]
            VModelMgr["VModel Manager<br/>(Zero-Downtime Updates)"]
            ProtoSplicer["Proto Splicer<br/>(Model ID Injection)"]
            PayloadProc["Payload Processor<br/>(Logging/Auditing)"]
            MetricsServer["Metrics Server<br/>(Netty :2112)"]
            HealthServer["Health Server<br/>(:8089 /ready /live)"]
            PreStopServer["PreStop Server<br/>(:8090 /prestop)"]

            CacheManager -->|eviction policy| RequestRouter
            RequestRouter -->|inject model ID| ProtoSplicer
            RequestRouter -->|observe| PayloadProc
            VModelMgr -->|atomic switch| CacheManager
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)"]
        end

        RequestRouter -->|"gRPC :8085 or UDS<br/>ModelRuntime API<br/>load/unload/status"| ModelRuntime
    end

    Client["Client / KServe Proxy"] -->|"gRPC :8033<br/>Inference Request<br/>TLS + mTLS (optional)"| RequestRouter

    Controller["modelmesh-serving<br/>Controller"] -->|"gRPC :8033<br/>register/unregister<br/>TLS + mTLS"| RequestRouter

    RequestRouter -->|"gRPC/Thrift :8033<br/>Forward Inference<br/>TLS + mTLS"| RemoteInstance["Other ModelMesh<br/>Instances"]

    CacheManager -->|"gRPC :2379<br/>Model Records<br/>Leader Election"| etcd["etcd Cluster"]

    MetricsServer -->|"HTTPS :2112<br/>Self-signed TLS"| Prometheus["Prometheus"]

    PayloadProc -.->|"HTTP/HTTPS<br/>(optional)"| RemotePayload["Remote Payload<br/>Processor"]

    style SidecarContainer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RuntimeContainer fill:#7ed321,stroke:#333,stroke-width:2px
    style CacheManager fill:#3a7bc8,stroke:#333,color:#fff
    style RequestRouter fill:#3a7bc8,stroke:#333,color:#fff
    style VModelMgr fill:#3a7bc8,stroke:#333,color:#fff
    style ProtoSplicer fill:#3a7bc8,stroke:#333,color:#fff
    style PayloadProc fill:#3a7bc8,stroke:#333,color:#fff
    style MetricsServer fill:#3a7bc8,stroke:#333,color:#fff
    style HealthServer fill:#3a7bc8,stroke:#333,color:#fff
    style PreStopServer fill:#3a7bc8,stroke:#333,color:#fff
    style ModelRuntime fill:#5cb85c,stroke:#333,color:#fff
    style Client fill:#f5a623,stroke:#333
    style Controller fill:#7ed321,stroke:#333
    style RemoteInstance fill:#4a90e2,stroke:#333,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style RemotePayload fill:#e8e8e8,stroke:#333
