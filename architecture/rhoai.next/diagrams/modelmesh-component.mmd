graph TB
    subgraph "ModelMesh Pod"
        direction TB

        subgraph "ModelMesh Sidecar (Java 21)"
            ModelMeshApi["ModelMeshApi<br/>gRPC Server<br/>8033/TCP"]
            RoutingLogic["Routing Logic<br/>LRU Cache Manager"]
            VModelManager["VModel Manager<br/>Virtual Model Aliases"]
            Litelinks["Litelinks RPC<br/>Inter-Pod Communication<br/>8080/TCP"]
            MetricsServer["Metrics Server<br/>Prometheus HTTPS<br/>2112/TCP"]
            HealthProbes["Health Probes<br/>Ready: 8089/TCP<br/>Live: 8089/TCP"]
            PreStopServer["PreStop Server<br/>8090/TCP"]

            ModelMeshApi -->|routes request| RoutingLogic
            ModelMeshApi -->|resolves vmodel| VModelManager
            RoutingLogic -->|forwards cache miss| Litelinks
            RoutingLogic -->|reports| MetricsServer
        end

        subgraph "Model Runtime Container"
            Runtime["Model Runtime<br/>(Triton / MLServer / Custom)<br/>Implements ModelRuntime gRPC"]
        end

        RoutingLogic -->|"gRPC 8085/TCP or UDS<br/>loadModel, unloadModel,<br/>inference (plaintext)"| Runtime
    end

    Client[External Client] -->|"gRPC 8033/TCP<br/>TLS + mTLS (optional)"| ModelMeshApi
    Controller["modelmesh-serving<br/>Controller"] -->|"Deploys & configures<br/>sidecar + env vars"| ModelMeshApi

    subgraph "Distributed State"
        etcd["etcd Cluster<br/>2379/TCP"]
    end

    RoutingLogic -->|"gRPC 2379/TCP<br/>Model registry, leader election,<br/>instance state"| etcd
    VModelManager -->|"Persists vmodel state"| etcd

    OtherPod["Other ModelMesh Pod"] <-->|"Thrift/Litelinks 8080/TCP<br/>TLS (optional)<br/>Cache miss forwarding"| Litelinks

    Prometheus["Prometheus"] -->|"HTTPS scrape<br/>2112/TCP"| MetricsServer

    Runtime -->|"Model artifacts"| Storage["Model Storage<br/>(S3 / PVC)"]

    style ModelMeshApi fill:#4a90e2,stroke:#333,color:#fff
    style RoutingLogic fill:#4a90e2,stroke:#333,color:#fff
    style VModelManager fill:#4a90e2,stroke:#333,color:#fff
    style Litelinks fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthProbes fill:#4a90e2,stroke:#333,color:#fff
    style PreStopServer fill:#4a90e2,stroke:#333,color:#fff
    style Runtime fill:#7ed321,stroke:#333,color:#fff
    style etcd fill:#f5a623,stroke:#333,color:#fff
    style Controller fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style OtherPod fill:#4a90e2,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style Storage fill:#f5a623,stroke:#333,color:#fff
