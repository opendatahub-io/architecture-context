graph TB
    subgraph ModelMeshPod["ModelMesh Pod"]
        direction TB

        subgraph MeshContainer["ModelMesh Container (Java 21)"]
            direction TB
            SidecarModelMesh["SidecarModelMesh<br/>Distributed LRU Cache<br/>Model Lifecycle Mgmt"]
            ModelMeshApi["ModelMeshApi<br/>gRPC Server<br/>8033/TCP"]
            VModelManager["VModelManager<br/>Virtual Model Transitions<br/>Atomic Version Swap"]
            TypeConstraintMgr["TypeConstraintManager<br/>GPU/Non-GPU Routing"]
            PayloadPipeline["PayloadProcessor Pipeline<br/>Logging / Forwarding / Filtering"]
            MetricsExporter["PrometheusMetrics<br/>2112/TCP HTTP/HTTPS"]
            StatsDExporter["StatsDMetrics<br/>8126/UDP Push"]
            PreStopServer["PreStop Server<br/>Graceful Shutdown"]

            ModelMeshApi -->|routes requests| SidecarModelMesh
            SidecarModelMesh -->|manages| VModelManager
            SidecarModelMesh -->|checks constraints| TypeConstraintMgr
            SidecarModelMesh -->|processes payloads| PayloadPipeline
            SidecarModelMesh -->|emits metrics| MetricsExporter
            SidecarModelMesh -->|emits metrics| StatsDExporter
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            ModelRuntime["Model Server<br/>(Triton / MLServer / Custom)<br/>ModelRuntime gRPC Service"]
        end

        SidecarModelMesh -->|"gRPC 8085/TCP or UDS<br/>loadModel / unloadModel<br/>predictModelSize / inference"| ModelRuntime
        PreStopServer -->|"HTTP prestop hook"| RuntimeContainer
    end

    Client["Client / KServe<br/>InferenceService"] -->|"gRPC 8033/TCP<br/>TLS + mTLS (optional)"| ModelMeshApi

    OtherPods["Other ModelMesh Pods<br/>(Same Deployment)"] <-->|"Thrift (Litelinks) 8080/TCP<br/>TLS (optional)<br/>Cache Miss Forwarding"| SidecarModelMesh

    etcd["etcd<br/>v3.5.x"] <-->|"gRPC 2379/TCP<br/>TLS (configurable)<br/>Model Registry / State"| SidecarModelMesh

    Prometheus["Prometheus"] -->|"HTTP(S) 2112/TCP<br/>Scrape /metrics"| MetricsExporter

    StatsD["StatsD / Sysdig"] <---|"UDP 8126<br/>Metrics Push"| StatsDExporter

    RemotePayload["Remote Payload<br/>Processor"] <---|"HTTP/HTTPS<br/>Payload Forwarding"| PayloadPipeline

    style SidecarModelMesh fill:#4a90e2,stroke:#333,color:#fff
    style ModelMeshApi fill:#4a90e2,stroke:#333,color:#fff
    style VModelManager fill:#4a90e2,stroke:#333,color:#fff
    style TypeConstraintMgr fill:#4a90e2,stroke:#333,color:#fff
    style PayloadPipeline fill:#4a90e2,stroke:#333,color:#fff
    style MetricsExporter fill:#50c878,stroke:#333,color:#fff
    style StatsDExporter fill:#50c878,stroke:#333,color:#fff
    style PreStopServer fill:#50c878,stroke:#333,color:#fff
    style ModelRuntime fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style OtherPods fill:#b8d4f0,stroke:#333
    style etcd fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style StatsD fill:#e8e8e8,stroke:#333
    style RemotePayload fill:#e8e8e8,stroke:#333
