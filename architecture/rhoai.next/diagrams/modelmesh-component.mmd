graph TB
    subgraph Pod["ServingRuntime Pod"]
        direction TB

        subgraph ModelMeshSidecar["ModelMesh Sidecar (Java 21)"]
            CacheManager["Cache Manager<br/>Distributed LRU Cache<br/>ConcurrentLinkedHashMap"]
            RequestRouter["Request Router<br/>Model-aware routing"]
            ModelRegistry["Model Registry<br/>register/unregister/status"]
            VModelMgr["VModel Manager<br/>Zero-downtime model updates"]
            GrpcServer["gRPC Server<br/>8033/TCP"]
            MetricsServer["Metrics Server<br/>2112/TCP HTTPS"]
            HealthServer["Health Server<br/>8089/TCP HTTP"]
            PreStopServer["PreStop Server<br/>8090/TCP HTTP"]
            PayloadProcessor["Payload Processor<br/>Logging / Remote HTTP"]

            GrpcServer -->|manages| ModelRegistry
            GrpcServer -->|routes| RequestRouter
            RequestRouter -->|checks| CacheManager
            ModelRegistry -->|updates| CacheManager
            CacheManager -->|eviction| CacheManager
            VModelMgr -->|atomic switch| ModelRegistry
            GrpcServer -->|observes| PayloadProcessor
            CacheManager -->|reports| MetricsServer
        end

        subgraph RuntimeContainer["Model Runtime Container"]
            ModelRuntime["Model Runtime<br/>(Triton / MLServer / Custom)<br/>ModelRuntime gRPC API"]
        end

        subgraph AdapterContainer["Runtime Adapter"]
            Adapter["modelmesh-runtime-adapter<br/>Bridges ModelRuntime API"]
        end
    end

    Controller["modelmesh-serving<br/>Controller"] -->|deploys pod with<br/>sidecar injection| Pod

    Client["Client / KServe Proxy"] -->|gRPC/8033<br/>Optional TLS/mTLS| GrpcServer

    CacheManager -->|gRPC/8085 or UDS<br/>load/unload/size/status| Adapter
    Adapter -->|translates| ModelRuntime

    CacheManager -->|gRPC/2379<br/>model records, leader election| etcd["etcd Cluster"]

    RequestRouter -->|gRPC+Thrift/8033<br/>TLS, forward inference| OtherInstances["Other ModelMesh<br/>Instances"]

    PayloadProcessor -.->|HTTP/HTTPS<br/>inference payloads| RemoteProcessor["Remote Payload<br/>Processor"]
    MetricsServer -.->|scrape| Prometheus["Prometheus"]

    style CacheManager fill:#4a90e2,stroke:#333,color:#fff
    style RequestRouter fill:#4a90e2,stroke:#333,color:#fff
    style ModelRegistry fill:#4a90e2,stroke:#333,color:#fff
    style VModelMgr fill:#4a90e2,stroke:#333,color:#fff
    style GrpcServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style HealthServer fill:#4a90e2,stroke:#333,color:#fff
    style PreStopServer fill:#4a90e2,stroke:#333,color:#fff
    style PayloadProcessor fill:#4a90e2,stroke:#333,color:#fff
    style ModelRuntime fill:#7ed321,stroke:#333,color:#fff
    style Adapter fill:#7ed321,stroke:#333,color:#fff
    style Controller fill:#f5a623,stroke:#333,color:#fff
    style etcd fill:#999,stroke:#333,color:#fff
    style OtherInstances fill:#e8e8e8,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style RemoteProcessor fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
