graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (Required)
    DSPO -->|"workflow orchestration<br/>(Argo 3.6.12)"| ArgoWF["Argo Workflows<br/>3.6.12"]
    DSPO -->|"pipeline framework<br/>(KFP 2.16.0)"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"TLS certificates<br/>(service-ca annotation)"| ServiceCA["OpenShift<br/>service-ca"]
    DSPO -->|"MLMD gRPC proxy<br/>(proxyv2 2.6)"| Envoy["Envoy Proxy<br/>(Istio proxyv2 2.6)"]
    DSPO -->|"external auth<br/>(SAR proxy)"| KubeRBACProxy["kube-rbac-proxy"]

    %% External Dependencies (Optional)
    DSPO -.->|"metadata storage<br/>(managed or external)"| MariaDB["MariaDB 10.5<br/>(optional managed)"]
    DSPO -.->|"artifact storage<br/>(managed or external)"| MinIO["MinIO<br/>(optional managed)"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize<br/>dspo-parameters ConfigMap"| DSPO
    DSPO -->|"watches for CA changes"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"creates Routes<br/>(TLS Reencrypt)"| RouteAPI["OpenShift Route API"]
    DSPO -->|"creates ServiceMonitors"| Prometheus["Prometheus /<br/>ServiceMonitor"]

    %% Integration Points - Consumers
    Dashboard["ODH Dashboard /<br/>Workbenches"] -->|"REST/gRPC client<br/>8888/8887"| DSPO
    KFPSDK["KFP SDK"] -->|"pipeline CRUD<br/>run submission"| DSPO

    %% Integration Points - Resources DSPO can create
    DSPO -.->|"pipeline steps create<br/>InferenceService CRs"| KServe["KServe"]
    DSPO -.->|"pipeline steps create<br/>Ray CRs"| Ray["Ray<br/>(rayclusters, rayjobs)"]
    DSPO -.->|"pipeline steps create<br/>AppWrapper CRs"| CodeFlare["CodeFlare<br/>(AppWrappers)"]

    %% External Services
    DSPO -->|"managed pipelines<br/>OCI fetch (443/TCP)"| OCIRegistry["OCI Registry"]
    DSPO -->|"all resource CRUD<br/>(443/TCP)"| K8sAPI["Kubernetes API<br/>Server"]
    DSPO -.->|"external DB<br/>(3306/TCP TLS)"| ExtDB["External<br/>MySQL/MariaDB"]
    DSPO -.->|"external storage<br/>(443/TCP HTTPS)"| ExtS3["External S3<br/>Object Store"]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ArgoWF fill:#999,stroke:#333,color:#fff
    style KFP fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style Envoy fill:#999,stroke:#333,color:#fff
    style KubeRBACProxy fill:#999,stroke:#333,color:#fff

    %% Optional managed storage
    style MariaDB fill:#e74c3c,stroke:#333,color:#fff
    style MinIO fill:#e74c3c,stroke:#333,color:#fff

    %% Internal platform
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style RouteAPI fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KFPSDK fill:#7ed321,stroke:#333,color:#fff

    %% Integration targets
    style KServe fill:#1abc9c,stroke:#333,color:#fff
    style Ray fill:#1abc9c,stroke:#333,color:#fff
    style CodeFlare fill:#1abc9c,stroke:#333,color:#fff

    %% External services
    style OCIRegistry fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style ExtDB fill:#f5a623,stroke:#333
    style ExtS3 fill:#f5a623,stroke:#333
