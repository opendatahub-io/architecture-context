graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (Required)
    DSPO -->|"pipeline framework<br/>KFP 2.16.0"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"workflow execution<br/>Argo 3.6.12"| Argo["Argo Workflows<br/>3.6.12"]
    DSPO -->|"TLS certificates<br/>annotation-based"| ServiceCA["OpenShift service-ca"]
    DSPO -->|"auth proxy sidecar"| KubeRBAC["kube-rbac-proxy<br/>(RHEL9)"]
    DSPO -->|"MLMD proxy<br/>Envoy 2.6"| Envoy["OpenShift Service Mesh<br/>Envoy proxyv2-rhel9:2.6"]

    %% External Dependencies (Optional infrastructure)
    DSPO -.->|"default database<br/>(replaceable)"| MariaDB["MariaDB 10.5<br/>(RHEL9)"]
    DSPO -.->|"default object store<br/>(replaceable)"| Minio["Minio"]

    %% Internal RHOAI Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys DSPO<br/>params.env config"| DSPO
    DSPO -->|"CA trust injection<br/>ConfigMap watch"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"external access<br/>Reencrypt Routes"| Routes["OpenShift Route API"]
    DSPO -->|"component metrics<br/>ServiceMonitor"| Prometheus["Prometheus /<br/>monitoring.coreos.com"]

    %% Integration Points (DSPO manages resources for)
    Dashboard["ODH Dashboard"] -->|"UI pipeline mgmt<br/>HTTPS/443"| DSPO
    Workbenches["Workbenches<br/>(Notebooks)"] -->|"direct API access<br/>NetworkPolicy"| DSPO
    PipelinePods["Pipeline Runner<br/>Pods"] -->|"API + MLMD access<br/>NetworkPolicy"| DSPO

    %% Pipeline step integrations (CRD CRUD from pipeline steps)
    DSPO -->|"InferenceService CRUD<br/>serving.kserve.io"| KServe["KServe"]
    DSPO -->|"RayCluster/Job CRUD<br/>ray.io"| Ray["Ray"]
    DSPO -->|"AppWrapper CRUD<br/>workload.codeflare.dev"| CodeFlare["CodeFlare"]
    DSPO -->|"SeldonDeployment CRUD<br/>machinelearning.seldon.io"| Seldon["Seldon"]
    DSPO -->|"full CRUD<br/>kubeflow.org"| Kubeflow["Kubeflow Resources"]

    %% External Services
    DSPO -->|"managed pipelines<br/>HTTPS/443"| OCIReg["OCI Container<br/>Registry"]
    DSPO -->|"resource management<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server"]
    DSPO -.->|"external DB option<br/>MySQL/3306 TLS"| ExtDB["External Database"]
    DSPO -.->|"external S3 option<br/>HTTPS/443"| ExtS3["External S3<br/>Storage"]

    %% Webhook
    K8sAPI -->|"admission webhook<br/>HTTPS/8443"| DSPO

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required deps
    style KFP fill:#999,stroke:#333,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style KubeRBAC fill:#999,stroke:#333,color:#fff
    style Envoy fill:#999,stroke:#333,color:#fff

    %% Optional infrastructure
    style MariaDB fill:#bbb,stroke:#333,stroke-dasharray:5 5,color:#fff
    style Minio fill:#bbb,stroke:#333,stroke-dasharray:5 5,color:#fff

    %% Internal RHOAI
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style Routes fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Workbenches fill:#7ed321,stroke:#333,color:#fff
    style PipelinePods fill:#7ed321,stroke:#333,color:#fff

    %% Pipeline step integrations
    style KServe fill:#27ae60,stroke:#333,color:#fff
    style Ray fill:#27ae60,stroke:#333,color:#fff
    style CodeFlare fill:#27ae60,stroke:#333,color:#fff
    style Seldon fill:#27ae60,stroke:#333,color:#fff
    style Kubeflow fill:#27ae60,stroke:#333,color:#fff

    %% External services
    style OCIReg fill:#f5a623,stroke:#333,color:#fff
