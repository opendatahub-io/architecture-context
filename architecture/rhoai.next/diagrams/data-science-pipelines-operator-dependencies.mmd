graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (required)
    DSPO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    DSPO -->|"template rendering"| Manifestival["manifestival<br/>v0.7.2"]
    DSPO -->|"OpenShift types"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260331"]
    DSPO -->|"S3 health checks"| MinIOGo["minio-go<br/>v7.0.99"]
    DSPO -->|"DB health checks"| MySQLDriver["go-sql-driver/mysql<br/>v1.9.3"]
    DSPO -->|"config mgmt"| Viper["viper<br/>v1.21.0"]
    DSPO -->|"metrics"| PromClient["prometheus/client_golang<br/>v1.23.2"]

    %% External Dependencies (optional)
    DSPO -.->|"MLflow types"| MLflowAPI["mlflow-operator/api<br/>v0.0.0-20260331"]
    DSPO -.->|"OCI bundles"| ContainerReg["go-containerregistry<br/>v0.21.3"]

    %% Internal Platform Dependencies
    RHODSOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys DSPO,<br/>creates DSPA CRs"| DSPO
    DSPO -->|"CRD Read<br/>auto-detect tracking"| MLflowOp["MLflow Operator"]
    DSPO -->|"cert generation<br/>annotation-based"| ServiceCA["OpenShift<br/>Service CA"]
    DSPO -->|"external access<br/>TLS Reencrypt"| Router["OpenShift<br/>Router"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"ServiceMonitor<br/>scrape 8080/TCP"| DSPO

    %% Integration Points (DSPO provides RBAC for pipeline steps)
    DSPO -->|"InferenceService CRs<br/>K8s API"| KServe["KServe"]
    DSPO -->|"Ray clusters/jobs<br/>K8s API"| Ray["Ray"]
    DSPO -->|"AppWrappers<br/>K8s API"| CodeFlare["CodeFlare"]
    DSPO -->|"SeldonDeployments<br/>K8s API"| Seldon["Seldon"]

    %% Consumers
    Dashboard["ODH Dashboard"] -->|"pipeline mgmt UI<br/>8888,8887/TCP"| DSPO
    Workbenches["Jupyter Workbenches"] -->|"pipeline SDK<br/>8888,8887/TCP"| DSPO
    ArgoWF["Argo Workflows<br/>CRDs"] -->|"workflow execution"| DSPO

    %% External Services
    DSPO -->|"model/artifact storage<br/>9000/TCP or 443/TCP"| S3["S3 / MinIO<br/>Storage"]
    DSPO -->|"pipeline metadata<br/>3306/TCP MySQL"| MySQL["MariaDB /<br/>External MySQL"]
    DSPO -->|"managed bundles<br/>443/TCP HTTPS"| OCIReg["OCI Registry"]
    DSPO -->|"resource mgmt<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API"]

