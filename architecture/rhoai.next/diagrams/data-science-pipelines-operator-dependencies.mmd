graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (Required)
    DSPO -->|"workflow orchestration<br/>(v3.6.12)"| Argo["Argo Workflows<br/>3.6.12"]
    DSPO -->|"pipeline framework<br/>(v2.16.0)"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"TLS certificates<br/>(service annotation)"| ServiceCA["OpenShift<br/>service-ca"]
    DSPO -->|"MLMD gRPC proxy"| Envoy["Envoy Proxy<br/>(Istio proxyv2 2.6)"]
    DSPO -->|"external auth<br/>(SAR enforcement)"| KubeRBACProxy["kube-rbac-proxy"]

    %% External Dependencies (Optional backends)
    DSPO -->|"metadata storage<br/>(managed or external)"| MariaDB["MariaDB 10.5<br/>(UBI)"]
    DSPO -->|"artifact storage<br/>(managed or external)"| MinIO["MinIO / S3<br/>Compatible Store"]

    %% Internal Platform Dependencies
    DSPO -->|"deployed by<br/>(kustomize + ConfigMap)"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    DSPO -->|"CA trust bundle<br/>(watch trigger)"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"service CA certs"| ServiceCACM["openshift-service-ca<br/>ConfigMap"]
    DSPO -->|"external access<br/>(TLS reencrypt)"| RouteAPI["OpenShift Route API"]
    DSPO -->|"metrics scraping"| Prometheus["Prometheus /<br/>ServiceMonitor"]

    %% Integration Points (consumers of DSPO)
    Dashboard["ODH Dashboard /<br/>Workbenches"] -->|"pipeline mgmt UI<br/>REST/gRPC"| DSPO
    KFPSdk["KFP SDK"] -->|"pipeline CRUD<br/>8888/8887"| DSPO

    %% Integration Points (DSPO creates CRs for)
    DSPO -.->|"model deployment<br/>(InferenceService CRs)"| KServe["KServe"]
    DSPO -.->|"model deployment<br/>(SeldonDeployment CRs)"| Seldon["Seldon"]
    DSPO -.->|"distributed compute<br/>(Ray CRs)"| Ray["Ray"]
    DSPO -.->|"batch scheduling<br/>(AppWrapper CRs)"| CodeFlare["CodeFlare"]

    %% External services
    DSPO -->|"managed pipelines<br/>OCI fetch"| OCIRegistry["OCI Registry"]
    DSPO -->|"resource management<br/>443/TCP"| K8sAPI["Kubernetes API"]

