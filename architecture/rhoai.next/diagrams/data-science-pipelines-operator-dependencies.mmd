graph LR
    DSPO["DSPO<br/>(Data Science Pipelines<br/>Operator)"]

    %% External Dependencies (Required)
    DSPO -->|"pipeline framework<br/>(embedded)"| KFP["Kubeflow Pipelines<br/>v2.16.0"]
    DSPO -->|"operator framework"| CR["controller-runtime<br/>0.23.3"]
    DSPO -->|"pipeline execution<br/>engine (bundled)"| Argo["Argo Workflows"]
    DSPO -->|"template rendering"| Manifestival["manifestival<br/>0.7.2"]
    DSPO -->|"S3 health checks"| MinIOSDK["MinIO SDK<br/>7.0.99"]
    DSPO -->|"OCI manifest fetch"| GoContainerReg["go-containerregistry<br/>0.21.3"]

    %% External Dependencies (Optional)
    DSPO -.->|"Routes, ImageStreams"| OpenShiftAPI["OpenShift API"]

    %% Internal ODH/RHOAI Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys &<br/>configures"| DSPO
    DSPO -.->|"auto-detect MLflow<br/>CRD watch"| MLflow["MLflow Operator"]

    %% Integration Points (RBAC grants to pipeline-runner)
    DSPO -.->|"pipeline steps create<br/>InferenceService CRs"| KServe["KServe"]
    DSPO -.->|"pipeline steps create<br/>AppWrapper CRs"| CodeFlare["CodeFlare / MCAD"]
    DSPO -.->|"pipeline steps create<br/>RayCluster/Job/Service CRs"| Ray["Ray"]
    DSPO -.->|"pipeline steps create<br/>SeldonDeployment CRs"| Seldon["Seldon"]

    %% Platform Integration
    Dashboard["ODH Dashboard"] -->|"UI management<br/>HTTPS/8443"| DSPO
    Workbenches["Workbenches"] -->|"pipeline API access<br/>NetworkPolicy allowed"| DSPO
    DSPO -->|"cert injection<br/>annotations"| ServiceCA["OpenShift<br/>Service CA"]
    DSPO -->|"CA trust chain"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    Monitoring["Prometheus /<br/>OpenShift Monitoring"] -->|"metrics scraping<br/>ServiceMonitor"| DSPO

    %% External Services
    DSPO -->|"artifact storage<br/>HTTPS/443"| S3["S3 Storage"]
    DSPO -->|"managed pipeline<br/>manifests<br/>HTTPS/443"| OCI["OCI Registries"]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (gray)
    style KFP fill:#999,stroke:#333,color:#fff
    style CR fill:#999,stroke:#333,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style MinIOSDK fill:#999,stroke:#333,color:#fff
    style GoContainerReg fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff

    %% Internal ODH (green)
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style Ray fill:#7ed321,stroke:#333,color:#fff
    style Seldon fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Workbenches fill:#7ed321,stroke:#333,color:#fff

    %% Platform services (blue-gray)
    style ServiceCA fill:#6c8ebf,stroke:#333,color:#fff
    style CABundle fill:#6c8ebf,stroke:#333,color:#fff
    style Monitoring fill:#6c8ebf,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCI fill:#f5a623,stroke:#333,color:#fff
