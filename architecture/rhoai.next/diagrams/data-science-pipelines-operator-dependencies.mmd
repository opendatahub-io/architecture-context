graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (Required)
    DSPO -->|"workflow orchestration<br/>v3.6.12"| Argo["Argo Workflows<br/>3.6.12"]
    DSPO -->|"upstream pipeline framework<br/>v2.16.0"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"TLS cert provisioning<br/>pod-to-pod + routes"| ServiceCA["OpenShift<br/>service-ca"]
    DSPO -->|"MLMD gRPC proxy<br/>v2.6"| Envoy["Envoy Proxy<br/>(Istio proxyv2) 2.6"]
    DSPO -->|"SAR auth on Routes"| KRBP["kube-rbac-proxy"]

    %% External Dependencies (Optional)
    DSPO -.->|"metadata DB<br/>(managed or external)"| MariaDB["MariaDB 10.5<br/>(UBI)"]
    DSPO -.->|"artifact storage<br/>(managed or external)"| MinIO["MinIO /<br/>S3-Compatible Store"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize<br/>dspo-parameters ConfigMap"| DSPO
    DSPO -->|"global CA trust bundle<br/>(watch trigger)"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"service CA certs<br/>(pod-to-pod TLS)"| ServiceCACM["openshift-service-ca<br/>ConfigMap"]
    DSPO -->|"external endpoints<br/>TLS reencrypt routes"| RouteAPI["OpenShift Route API"]
    DSPO -->|"operator + API server<br/>metrics scraping"| Prometheus["Prometheus /<br/>ServiceMonitor"]

    %% Integration Points — consumers of DSPO
    Dashboard["ODH Dashboard /<br/>Workbenches"] -->|"pipeline mgmt<br/>REST/gRPC"| DSPO
    KFPsdk["KFP SDK"] -->|"pipeline CRUD,<br/>run submission"| DSPO

    %% Integration Points — DSPO creates CRs for
    DSPO -.->|"model deployment<br/>InferenceService CRs"| KServe["KServe"]
    DSPO -.->|"distributed compute<br/>RayCluster/Job CRs"| Ray["Ray"]
    DSPO -.->|"batch workloads<br/>AppWrapper CRs"| CodeFlare["CodeFlare"]

    %% External Services
    DSPO -->|"managed resources<br/>CRUD"| K8sAPI["Kubernetes API<br/>443/TCP"]
    DSPO -->|"managed pipelines<br/>OCI fetch"| OCIReg["OCI Registry<br/>443/TCP"]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Required
    style Argo fill:#999,stroke:#333,color:#fff
    style KFP fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style Envoy fill:#999,stroke:#333,color:#fff
    style KRBP fill:#999,stroke:#333,color:#fff

    %% External Optional
    style MariaDB fill:#bbb,stroke:#333,color:#fff
    style MinIO fill:#bbb,stroke:#333,color:#fff

    %% Internal Platform
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style ServiceCACM fill:#7ed321,stroke:#333,color:#fff
    style RouteAPI fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% Consumers
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KFPsdk fill:#7ed321,stroke:#333,color:#fff

    %% Integration Targets
    style KServe fill:#27ae60,stroke:#333,color:#fff
    style Ray fill:#27ae60,stroke:#333,color:#fff
    style CodeFlare fill:#27ae60,stroke:#333,color:#fff

