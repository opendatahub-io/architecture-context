graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies
    DSPO -->|"pipeline framework<br/>v2.16.0"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"workflow execution<br/>v3.6.12"| Argo["Argo Workflows<br/>3.6.12"]
    DSPO -->|"default database<br/>(optional)"| MariaDB["MariaDB 10.5<br/>(RHEL9)"]
    DSPO -->|"default object storage<br/>(optional)"| Minio["Minio<br/>(user-specified)"]
    DSPO -->|"MLMD proxy<br/>v2.6"| Envoy["OpenShift Service Mesh<br/>Envoy 2.6"]
    DSPO -->|"auth sidecar"| KubeRBACProxy["kube-rbac-proxy<br/>(RHEL9)"]
    DSPO -->|"TLS cert provisioning<br/>(when PodToPodTLS)"| ServiceCA["OpenShift<br/>service-ca"]

    %% Internal Platform Dependencies
    DSPO <-->|"CRD config<br/>(DSCInitialization)"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    DSPO -->|"CA cert injection"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"service-ca root cert"| ServiceCACert["openshift-service-ca.crt<br/>ConfigMap"]
    DSPO -->|"external access<br/>(Reencrypt Routes)"| RouteAPI["OpenShift Route API"]
    DSPO -->|"component metrics<br/>(ServiceMonitor)"| Prometheus["Prometheus /<br/>ServiceMonitor"]

    %% Integration Points (incoming)
    Dashboard["ODH Dashboard"] -->|"pipeline mgmt UI"| DSPO
    Workbenches["Workbenches<br/>(Notebooks)"] -->|"direct API access<br/>(NetworkPolicy)"| DSPO
    PipelinePods["Pipeline Runner<br/>Pods"] -->|"API + MLMD access<br/>(NetworkPolicy)"| DSPO

    %% Integration Points (outgoing)
    DSPO -->|"InferenceService CRUD"| KServe["KServe<br/>(serving.kserve.io)"]
    DSPO -->|"RayCluster/Job/Service"| Ray["Ray<br/>(ray.io)"]
    DSPO -->|"AppWrapper CRUD"| CodeFlare["CodeFlare<br/>(workload.codeflare.dev)"]
    DSPO -->|"full CRUD"| Kubeflow["Kubeflow<br/>(kubeflow.org)"]
    DSPO -->|"SeldonDeployment"| Seldon["Seldon<br/>(machinelearning.seldon.io)"]
    DSPO -->|"webhook configs"| AdmissionAPI["Kubernetes<br/>Admission API"]
    DSPO -->|"ImageStreamTag read"| ImageStreams["OpenShift<br/>Image Streams"]
    DSPO -->|"managed-pipelines.json"| OCIRegistry["OCI Container<br/>Registry"]
    DSPO -->|"resource CRUD"| K8sAPI["Kubernetes API"]

