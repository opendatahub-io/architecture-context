graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (required)
    DSPO -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    DSPO -->|"manifest templating"| Manifestival["manifestival<br/>v0.7.2"]
    DSPO -->|"OCI image extraction"| GoContainerReg["go-containerregistry<br/>v0.21.3"]
    DSPO -->|"pipeline execution"| ArgoWorkflows["Argo Workflows<br/>(CRD Watch/Create)"]
    DSPO -->|"upstream framework"| KFP["Kubeflow Pipelines<br/>v2.16.0"]

    %% Platform Dependencies (required)
    DSPO -->|"Route, ImageStream APIs"| OpenShiftAPI["OpenShift API<br/>v0.0.0-20260331"]
    DSPO -->|"auto TLS certificates"| ServiceCA["OpenShift<br/>Service CA"]
    DSPO -->|"external access"| Router["OpenShift<br/>Router"]
    DSPO -->|"CA trust chain"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"metrics collection"| Prometheus["Prometheus<br/>User Workload Monitoring"]

    %% Deployment Dependencies
    DSPO -->|"deployed by"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]

    %% Internal Data Dependencies
    DSPO -->|"S3 health checks"| MinioGo["minio-go<br/>v7.0.99"]
    DSPO -->|"DB health checks"| MySQLDriver["go-sql-driver/mysql<br/>v1.9.3"]
    DSPO -->|"config management"| Viper["viper<br/>v1.21.0"]

    %% Integration Points (outbound CRD interactions)
    DSPO -->|"model serving"| KServe["KServe<br/>(InferenceService CRs)"]
    DSPO -->|"model deployment"| Seldon["Seldon Core<br/>(SeldonDeployment CRs)"]
    DSPO -->|"distributed compute"| Ray["Ray<br/>(RayCluster/RayJob CRs)"]
    DSPO -->|"resource management"| CodeFlare["CodeFlare<br/>(AppWrapper CRs)"]
    DSPO -->|"pipeline CRDs"| KubeflowPipelines["Kubeflow Pipelines<br/>(Pipeline/PipelineVersion CRs)"]

    %% Components that integrate with DSPO
    Dashboard["ODH Dashboard"] -->|"pipeline UI"| DSPO
    Workbenches["OpenShift Workbenches"] -->|"API access<br/>(NetworkPolicy)"| DSPO
    Monitoring["redhat-ods-monitoring"] -->|"metrics scraping<br/>(NetworkPolicy)"| DSPO

    %% External Services
    DSPO -->|"managed pipelines"| OCIRegistries["OCI Registries<br/>(quay.io)"]
    DSPO -->|"resource CRUD"| K8sAPI["Kubernetes API"]
    DSPO -->|"optional ext. backend"| ExtDB["External MySQL DB"]
    DSPO -->|"optional ext. backend"| ExtS3["External S3 Storage"]

