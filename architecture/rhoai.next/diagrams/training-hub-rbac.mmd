graph TD
    subgraph Notice["training-hub: No Kubernetes RBAC"]
        direction TB
        Note["training-hub is a Python library (pip package)<br/>It does NOT define Kubernetes RBAC resources<br/>(no ClusterRoles, Roles, RoleBindings, or ServiceAccounts)"]
    end

    subgraph RuntimeContext["Runtime RBAC Context<br/>(Determined by execution environment)"]
        direction TB

        subgraph PodExecution["When running in a Kubernetes Pod"]
            SA["Pod ServiceAccount<br/><i>Inherited from pod spec</i>"]
            PodRole["Pod Role / ClusterRole<br/><i>Defined by orchestrator</i>"]
            SA -->|bound via| PodRole
        end

        subgraph Credentials["Credential Delegation via Environment Variables"]
            HFToken["HF_TOKEN<br/><i>HuggingFace Hub access</i><br/>Scope: gated model downloads"]
            WandBKey["WANDB_API_KEY<br/><i>WandB experiment tracking</i><br/>Scope: metrics write"]
            MLflowToken["MLFLOW_TRACKING_URI + Token<br/><i>MLflow tracking server</i><br/>Scope: metrics write"]
        end

        subgraph GPUAccess["GPU Resource Access"]
            NVIDIADevice["NVIDIA GPU Devices<br/><i>nvidia.com/gpu resource limits</i>"]
            NCCLNetwork["NCCL Network Access<br/><i>Inter-node GPU communication</i><br/>Ports: dynamic/TCP"]
        end
    end

    subgraph SupplyChain["Supply Chain Security"]
        direction TB
        LiteLLMWarning["⚠️ litellm version pinning<br/>>=1.82.0, <1.82.7<br/><i>Versions 1.82.7-1.82.8 compromised</i><br/><i>TeamPCP attack 2026-03-24</i>"]
    end

    %% Styling
    style Notice fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    style Note fill:#e3f2fd,stroke:#1976d2
    style RuntimeContext fill:#f5f5f5,stroke:#999,stroke-width:1px
    style PodExecution fill:#e8f5e9,stroke:#388e3c,stroke-width:1px
    style Credentials fill:#fff3e0,stroke:#f57c00,stroke-width:1px
    style GPUAccess fill:#fce4ec,stroke:#c62828,stroke-width:1px
    style SupplyChain fill:#ffebee,stroke:#c62828,stroke-width:2px

    style SA fill:#e8f5e9,stroke:#388e3c
    style PodRole fill:#e8f5e9,stroke:#388e3c
    style HFToken fill:#fff3e0,stroke:#f57c00
    style WandBKey fill:#fff3e0,stroke:#f57c00
    style MLflowToken fill:#fff3e0,stroke:#f57c00
    style NVIDIADevice fill:#fce4ec,stroke:#c62828
    style NCCLNetwork fill:#fce4ec,stroke:#c62828
    style LiteLLMWarning fill:#ffcdd2,stroke:#c62828
