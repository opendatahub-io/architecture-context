graph TD
    subgraph Notice["RBAC - Not Applicable"]
        direction TB
        Info["training-hub is a Python library (PyPI package)<br/>It has NO Kubernetes RBAC, NO service accounts,<br/>NO cluster roles, and NO role bindings.<br/><br/>RBAC is the responsibility of the consuming<br/>environment (e.g., notebook pod, training job)."]
    end

    subgraph RuntimeCredentials["Runtime Credentials (Managed by Consumer)"]
        direction TB
        HFToken["HF_TOKEN<br/>(Optional)<br/>HuggingFace access token<br/>for gated model downloads"]
        WandBKey["WANDB_API_KEY<br/>(Optional)<br/>Weights & Biases API key<br/>for experiment tracking"]
        MLflowURI["MLFLOW_TRACKING_URI<br/>(Optional)<br/>MLflow server URI<br/>for experiment tracking"]
    end

    subgraph SupplyChain["Supply Chain Security"]
        direction TB
        LiteLLMPin["litellm < 1.82.7<br/>Pinned due to supply chain attack<br/>(TeamPCP, 2026-03-24)"]
        SubprocessIsolation["Subprocess Isolation<br/>GRPO backends (ART, verl) run<br/>as isolated subprocesses to<br/>prevent GPU memory conflicts"]
    end

    Notice --- RuntimeCredentials
    RuntimeCredentials --- SupplyChain

    %% Styling
    style Notice fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Info fill:#fff,stroke:#ccc
    style RuntimeCredentials fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style HFToken fill:#ffe6cc,stroke:#d79b00
    style WandBKey fill:#ffe6cc,stroke:#d79b00
    style MLflowURI fill:#ffe6cc,stroke:#d79b00
    style SupplyChain fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style LiteLLMPin fill:#f8cecc,stroke:#b85450
    style SubprocessIsolation fill:#d5e8d4,stroke:#82b366
