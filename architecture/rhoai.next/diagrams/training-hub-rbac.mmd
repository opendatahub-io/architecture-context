graph TD
    subgraph Note["training-hub RBAC"]
        direction TB
        Info["training-hub is a Python library<br/>(not a deployed Kubernetes service)<br/><br/>No Kubernetes RBAC resources:<br/>• No ServiceAccounts<br/>• No ClusterRoles<br/>• No RoleBindings<br/>• No ClusterRoleBindings"]
    end

    subgraph RuntimeAuth["Runtime Authentication (User-Managed)"]
        direction TB

        subgraph HFAuth["HuggingFace Hub Access"]
            HFToken["HF_TOKEN<br/>(Environment Variable)"]
            HFBearer["Bearer Token Auth"]
            HFPurpose["Purpose: Download gated models<br/>Required: Only for gated models"]
        end

        subgraph WandBAuth["Weights & Biases Access (Optional)"]
            WandBKey["WANDB_API_KEY<br/>(Environment Variable)"]
            WandBAPIAuth["API Key Auth"]
            WandBPurpose["Purpose: Experiment tracking<br/>Required: No"]
        end

        subgraph MLflowAuth["MLflow Access (Optional)"]
            MLflowURI["MLFLOW_TRACKING_URI<br/>(Environment Variable)"]
            MLflowHTTP["URI-based Access"]
            MLflowPurpose["Purpose: Experiment tracking<br/>Required: No"]
        end
    end

    HFToken --> HFBearer
    HFBearer --> HFPurpose
    WandBKey --> WandBAPIAuth
    WandBAPIAuth --> WandBPurpose
    MLflowURI --> MLflowHTTP
    MLflowHTTP --> MLflowPurpose

    %% Styling
    style Note fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Info fill:#fff2cc,stroke:#d6b656
    style RuntimeAuth fill:#e8f4fd,stroke:#4a90e2
    style HFAuth fill:#d5e8d4,stroke:#82b366
    style WandBAuth fill:#e1d5e7,stroke:#9673a6
    style MLflowAuth fill:#e1d5e7,stroke:#9673a6
    style HFToken fill:#4a90e2,color:#fff
    style WandBKey fill:#4a90e2,color:#fff
    style MLflowURI fill:#4a90e2,color:#fff
