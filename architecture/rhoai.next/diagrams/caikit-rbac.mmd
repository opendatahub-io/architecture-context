graph TD
    subgraph Legend["RBAC & Security Model"]
        direction TB
        Note1["Caikit defines NO Kubernetes RBAC<br/>All RBAC is delegated to the platform<br/>(KServe, ModelMesh, Service Mesh)"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (Not Caikit)"]
        direction TB
        KServeSA["KServe Service Account<br/>(manages Caikit pods)"]
        ModelMeshSA["ModelMesh Service Account<br/>(manages model lifecycle)"]
        PlatformSA["Platform Operator SA<br/>(provisions TLS, storage)"]
    end

    subgraph CaikitAuth["Caikit Authentication Model"]
        direction TB

        subgraph TLSConfig["TLS / mTLS Configuration"]
            gRPCAuth["gRPC Server Auth<br/>grpc.ssl_server_credentials<br/>require_client_auth=True<br/>when client CA configured"]
            HTTPAuth["HTTP Server Auth<br/>ssl.SSLContext<br/>CERT_REQUIRED<br/>when client CA configured"]
            HealthAuth["/health Endpoint<br/>No auth required<br/>Always accessible"]
        end

        subgraph SocketAuth["Pod-Local Auth"]
            UnixAuth["ModelMesh Unix Socket<br/>unix:///tmp/mmesh/grpc.sock<br/>No auth (plaintext)<br/>Pod namespace isolation"]
        end
    end

    subgraph Secrets["Secrets Used by Caikit"]
        direction TB
        TLSKey["TLS Server Key<br/>kubernetes.io/tls<br/>Provisioned by: cert-manager<br/>Auto-rotate: No"]
        TLSCert["TLS Server Cert<br/>kubernetes.io/tls<br/>Provisioned by: cert-manager<br/>Auto-rotate: No"]
        ClientCA["TLS Client CA Cert<br/>kubernetes.io/tls<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
        S3Creds["S3 Credentials<br/>Opaque<br/>accessKey, secretKey<br/>IAM_id, IAM_api_key<br/>Provisioned by: user/platform<br/>Auto-rotate: No"]
        OTELCerts["OTEL TLS Certs<br/>Opaque<br/>CA, client key, client cert<br/>Provisioned by: platform operator<br/>Auto-rotate: No"]
    end

    %% Relationships
    KServeSA -->|manages pods| CaikitAuth
    ModelMeshSA -->|calls ModelRuntime API| UnixAuth
    PlatformSA -->|provisions| TLSKey
    PlatformSA -->|provisions| TLSCert
    PlatformSA -->|provisions| ClientCA
    PlatformSA -->|provisions| OTELCerts

    gRPCAuth -->|uses| TLSKey
    gRPCAuth -->|uses| TLSCert
    gRPCAuth -->|verifies clients| ClientCA
    HTTPAuth -->|uses| TLSKey
    HTTPAuth -->|uses| TLSCert
    HTTPAuth -->|verifies clients| ClientCA

    %% Styling
    style Legend fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Note1 fill:#fff3cd,stroke:#856404
    style PlatformRBAC fill:#e8e8e8,stroke:#999
    style CaikitAuth fill:#d5e8d4,stroke:#82b366
    style TLSConfig fill:#dae8fc,stroke:#6c8ebf
    style SocketAuth fill:#e1d5e7,stroke:#9673a6
    style Secrets fill:#f8cecc,stroke:#b85450
    style KServeSA fill:#999,stroke:#333,color:#fff
    style ModelMeshSA fill:#999,stroke:#333,color:#fff
    style PlatformSA fill:#999,stroke:#333,color:#fff
    style gRPCAuth fill:#4a90e2,stroke:#333,color:#fff
    style HTTPAuth fill:#4a90e2,stroke:#333,color:#fff
    style HealthAuth fill:#7ed321,stroke:#333
    style UnixAuth fill:#bd10e0,stroke:#333,color:#fff
    style TLSKey fill:#f5a623,stroke:#333
    style TLSCert fill:#f5a623,stroke:#333
    style ClientCA fill:#f5a623,stroke:#333
    style S3Creds fill:#e74c3c,stroke:#333,color:#fff
    style OTELCerts fill:#f5a623,stroke:#333
