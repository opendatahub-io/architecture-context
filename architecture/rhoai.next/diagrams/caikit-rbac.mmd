graph TD
    subgraph CaikitRBAC["Caikit RBAC Context"]
        direction TB

        Note["NOTE: Caikit is a Python library/runtime,<br/>not a Kubernetes operator.<br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined by Caikit itself."]

        subgraph PlatformManaged["Platform-Managed RBAC (by KServe/ModelMesh/ODH)"]
            direction TB

            subgraph ServiceAccounts["Service Accounts (Platform-Provisioned)"]
                SA["Pod ServiceAccount<br/>(defined by ServingRuntime CR)"]
            end

            subgraph PodSecurity["Pod Security Context"]
                PSC["Container runs as<br/>non-root user<br/>(per UBI base image)"]
            end

            subgraph TLSAuth["Application-Level Auth"]
                direction LR
                ServerTLS["Server TLS<br/>runtime.tls.server.key<br/>runtime.tls.server.cert"]
                ClientMTLS["Client mTLS<br/>runtime.tls.client.cert<br/>(optional verification)"]
                S3Auth["S3 Access<br/>HMAC keys or IAM<br/>(user-provisioned)"]
            end
        end

        subgraph AccessControl["Caikit Access Control Model"]
            direction TB

            subgraph GRPCAccess["gRPC Access"]
                GRPCAll["All gRPC Services<br/>Auth: mTLS (optional)<br/>Enforcement: gRPC server TLS config"]
            end

            subgraph HTTPAccess["HTTP Access"]
                HTTPAll["All HTTP Endpoints<br/>Auth: mTLS (optional)<br/>Enforcement: uvicorn TLS config"]
            end

            subgraph LocalAccess["Pod-Local Access"]
                UnixSocket["ModelRuntime Sidecar<br/>Auth: N/A (Unix socket)<br/>Enforcement: Pod-local only"]
            end
        end
    end

    SA -->|"bound to pod by"| PSC
    ServerTLS -->|"secures"| GRPCAccess
    ServerTLS -->|"secures"| HTTPAccess
    ClientMTLS -->|"authenticates clients for"| GRPCAccess
    ClientMTLS -->|"authenticates clients for"| HTTPAccess

    %% Styling
    style CaikitRBAC fill:#f0f4ff,stroke:#4a90e2,stroke-width:2px
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style PlatformManaged fill:#e8f5e9,stroke:#4caf50,stroke-width:2px
    style AccessControl fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    style ServiceAccounts fill:#f3e5f5,stroke:#9c27b0
    style PodSecurity fill:#f3e5f5,stroke:#9c27b0
    style TLSAuth fill:#fff8e1,stroke:#ff8f00
    style GRPCAccess fill:#e8eaf6,stroke:#3f51b5
    style HTTPAccess fill:#e8eaf6,stroke:#3f51b5
    style LocalAccess fill:#fce4ec,stroke:#e91e63
