graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["Caikit is a Python library/runtime,<br/>NOT a Kubernetes operator.<br/>It does not define its own RBAC.<br/><br/>RBAC is managed by the<br/>RHOAI platform operator."]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph TransportLayer["Transport-Layer Security (Caikit)"]
            TLS["TLS Configuration<br/>(Optional, configurable via YAML)"]
            mTLS["mTLS Client Verification<br/>(Optional, CA cert file path)"]
            ServerCert["Server Cert/Key<br/>(file path reference)"]
            ClientCA["Client CA Cert<br/>(file path reference)"]

            TLS --> ServerCert
            mTLS --> ClientCA
        end

        subgraph AppLayer["Application-Layer Auth (RHOAI Platform)"]
            KubeRBACProxy["kube-rbac-proxy Sidecar<br/>(injected by platform operator)"]
            BearerToken["Bearer Token Validation<br/>(Kubernetes RBAC)"]
            K8sRBAC["Kubernetes RBAC Policies<br/>(managed by RHOAI operator)"]

            KubeRBACProxy --> BearerToken
            BearerToken --> K8sRBAC
        end
    end

    subgraph Secrets["Secrets Used"]
        direction TB
        TLSServerCert["TLS Server Key/Cert<br/>Type: File path reference<br/>Purpose: gRPC + HTTP TLS<br/>Provisioned: cert-manager or manual<br/>Auto-rotate: No"]
        TLSClientCA["TLS Client CA Cert<br/>Type: File path reference<br/>Purpose: mTLS verification<br/>Provisioned: cert-manager or manual<br/>Auto-rotate: No"]
        S3Creds["S3 Credentials<br/>Type: Config / environment<br/>Purpose: Training data auth<br/>Provisioned: External<br/>Auto-rotate: No"]
        OTELCerts["OTEL TLS Certs<br/>Type: File path reference<br/>Purpose: Trace exporter mTLS<br/>Provisioned: External<br/>Auto-rotate: No"]
    end

    subgraph Endpoints["Protected Endpoints"]
        direction TB
        HTTPEndpoints["HTTP Endpoints (8080/TCP)<br/>/api/v1/health<br/>/api/v1/models<br/>/api/v1/{task}/...<br/>/api/v1/{module}/train"]
        gRPCEndpoints["gRPC Services (8085/TCP)<br/>{TaskName}Service<br/>ModelManagement<br/>TrainingManagement<br/>grpc.health.v1.Health"]
        MetricsEndpoint["Metrics (8086/TCP)<br/>Prometheus scrape<br/>No auth, plaintext"]
    end

    %% Flows
    TLS -.->|"protects"| HTTPEndpoints
    TLS -.->|"protects"| gRPCEndpoints
    KubeRBACProxy -->|"enforces auth on"| HTTPEndpoints
    KubeRBACProxy -->|"enforces auth on"| gRPCEndpoints
    ServerCert -.->|"used by"| TLSServerCert
    ClientCA -.->|"used by"| TLSClientCA

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style AuthModel fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style TransportLayer fill:#d1fae5,stroke:#059669,stroke-width:1px
    style AppLayer fill:#fce7f3,stroke:#db2777,stroke-width:1px
    style Secrets fill:#fef3c7,stroke:#d97706,stroke-width:1px
    style Endpoints fill:#e0e7ff,stroke:#4338ca,stroke-width:1px
    style TLSServerCert fill:#fef9c3,stroke:#ca8a04
    style TLSClientCA fill:#fef9c3,stroke:#ca8a04
    style S3Creds fill:#fef9c3,stroke:#ca8a04
    style OTELCerts fill:#fef9c3,stroke:#ca8a04
    style KubeRBACProxy fill:#f87171,stroke:#dc2626,color:#fff
    style MetricsEndpoint fill:#fed7aa,stroke:#ea580c
