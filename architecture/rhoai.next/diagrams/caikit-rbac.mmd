graph TD
    subgraph CaikitLevel["Caikit Runtime Level"]
        direction TB
        Note1["No Kubernetes RBAC defined<br/>(Python library, not an operator)<br/>RBAC managed by platform operator"]
    end

    subgraph PlatformLevel["RHOAI Platform Level (External to Caikit)"]
        direction TB

        subgraph AuthFlow["Authentication Flow"]
            Client["External Client"]
            Proxy["kube-rbac-proxy Sidecar<br/>(injected by platform operator)"]
            CaikitRT["Caikit Runtime<br/>8080/TCP HTTP<br/>8085/TCP gRPC"]
        end

        subgraph TransportAuth["Transport-Level Security (Caikit)"]
            TLSConfig["TLS Configuration"]
            ServerCert["Server Cert/Key<br/>(file path reference)<br/>Provisioned by cert-manager"]
            ClientCA["Client CA Cert<br/>(file path reference)<br/>mTLS verification"]
            TLSConfig --> ServerCert
            TLSConfig --> ClientCA
        end
    end

    subgraph Secrets["Secrets Managed"]
        direction TB
        TLSServerSecret["TLS Server Key/Cert<br/>Type: File path reference<br/>Purpose: gRPC + HTTP TLS termination<br/>Provisioned: External (cert-manager)<br/>Auto-Rotate: No"]
        TLSClientSecret["TLS Client CA Cert<br/>Type: File path reference<br/>Purpose: mTLS client verification<br/>Provisioned: External (cert-manager)<br/>Auto-Rotate: No"]
        S3Secret["S3 Credentials<br/>Type: Config / environment<br/>Purpose: S3 storage authentication<br/>Provisioned: External<br/>Auto-Rotate: No"]
        OTELSecret["OTEL TLS Certs<br/>Type: File path reference<br/>Purpose: Trace exporter mTLS<br/>Provisioned: External<br/>Auto-Rotate: No"]
    end

    Client -->|"Bearer Token<br/>(validated by proxy)"| Proxy
    Proxy -->|"Authenticated request<br/>(forwarded)"| CaikitRT

    CaikitRT -->|"uses"| TLSConfig

    %% Styling
    style CaikitLevel fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style PlatformLevel fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style AuthFlow fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    style TransportAuth fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Note1 fill:#fff2cc,stroke:#d6b656
    style Client fill:#f5f5f5,stroke:#666
    style Proxy fill:#ffe6cc,stroke:#d79b00
    style CaikitRT fill:#4a90e2,stroke:#333,color:#fff
    style TLSServerSecret fill:#f8cecc,stroke:#b85450
    style TLSClientSecret fill:#f8cecc,stroke:#b85450
    style S3Secret fill:#f8cecc,stroke:#b85450
    style OTELSecret fill:#f8cecc,stroke:#b85450
