graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["Caikit is a Python runtime library, not a Kubernetes operator.<br/>It does not define its own RBAC resources.<br/>RBAC is delegated to the platform operator and KServe."]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC (inherited)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts (managed by KServe/ModelMesh)"]
            SA_Runtime["Pod ServiceAccount<br/>(assigned by KServe deployment)"]
        end

        subgraph PodSecurity["Pod Security Context"]
            PSC["Container runs as<br/>non-root user<br/>(defined by container image)"]
        end
    end

    subgraph AuthMechanisms["Caikit Authentication Mechanisms"]
        direction TB

        subgraph mTLS["Mutual TLS (Application-Level)"]
            GRPCAuth["gRPC Server<br/>grpc.ssl_server_credentials<br/>require_client_auth=True<br/>when client CA configured"]
            HTTPAuth["HTTP Server<br/>ssl.SSLContext<br/>CERT_REQUIRED<br/>when client CA configured"]
        end

        subgraph NoAuth["Unauthenticated"]
            HealthEndpoint["/health endpoint<br/>Always accessible<br/>No auth required"]
            MetricsEndpoint["Metrics :8086<br/>No auth<br/>plaintext HTTP"]
            UnixSocket["Unix Domain Socket<br/>No auth<br/>Pod-local isolation"]
        end
    end

    subgraph SecretAccess["Secrets Accessed by Caikit"]
        TLSKey["TLS Server Key<br/>kubernetes.io/tls<br/>File-mounted"]
        TLSCert["TLS Server Cert<br/>kubernetes.io/tls<br/>File-mounted"]
        ClientCA["TLS Client CA<br/>kubernetes.io/tls<br/>File-mounted"]
        S3Creds["S3 Credentials<br/>Opaque<br/>accessKey/secretKey<br/>or IAM_id/IAM_api_key"]
        OTELCerts["OTEL TLS Certs<br/>Opaque<br/>CA + client key/cert"]
    end

    SA_Runtime -->|"mounts"| TLSKey
    SA_Runtime -->|"mounts"| TLSCert
    SA_Runtime -->|"mounts"| ClientCA
    SA_Runtime -->|"mounts"| S3Creds
    SA_Runtime -->|"mounts"| OTELCerts

    TLSKey -->|"used by"| GRPCAuth
    TLSCert -->|"used by"| GRPCAuth
    ClientCA -->|"used by"| GRPCAuth
    TLSKey -->|"used by"| HTTPAuth
    TLSCert -->|"used by"| HTTPAuth
    ClientCA -->|"used by"| HTTPAuth
    OTELCerts -->|"used by"| SA_Runtime

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style PlatformRBAC fill:#e3f2fd,stroke:#1565c0
    style AuthMechanisms fill:#f3e5f5,stroke:#7b1fa2
    style mTLS fill:#e8f5e9,stroke:#2e7d32
    style NoAuth fill:#fce4ec,stroke:#c62828
    style SecretAccess fill:#fff8e1,stroke:#f9a825
    style SA_Runtime fill:#4a90e2,color:#fff
    style GRPCAuth fill:#7ed321
    style HTTPAuth fill:#7ed321
    style HealthEndpoint fill:#f5a623
    style MetricsEndpoint fill:#f5a623
    style UnixSocket fill:#f5a623
