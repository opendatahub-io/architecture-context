graph TD
    subgraph Notice["RBAC Notice"]
        direction TB
        Note["Caikit is a Python library/runtime<br/>NOT a Kubernetes operator<br/><br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined by caikit"]
    end

    subgraph PlatformRBAC["Platform-Level RBAC (RHOAI)"]
        direction TB

        subgraph AuthFlow["Authentication Flow (RHOAI Deployment)"]
            Client["External Client"]
            KRBACProxy["kube-rbac-proxy sidecar<br/>(injected by platform operator)"]
            TokenReview["Kubernetes TokenReview API"]
        end

        subgraph TransportSecurity["Transport Security (Caikit-Managed)"]
            TLSConfig["TLS/mTLS Configuration"]
            ServerCert["Server Cert/Key<br/>(file path reference)"]
            ClientCA["Client CA Cert<br/>(file path reference, mTLS)"]
        end

        subgraph Secrets["Secrets Used"]
            TLSSecret["TLS server key/cert<br/>Type: File path reference<br/>Provisioned: cert-manager or manual<br/>Auto-Rotate: No"]
            TLSClientSecret["TLS client CA cert<br/>Type: File path reference<br/>Provisioned: cert-manager or manual<br/>Auto-Rotate: No"]
            S3Secret["S3 credentials<br/>Type: Config / environment<br/>Provisioned: External<br/>Auto-Rotate: No"]
            OTELSecret["OTEL TLS certs<br/>Type: File path reference<br/>Provisioned: External<br/>Auto-Rotate: No"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        HTTPEndpoints["HTTP Server (8080/TCP)<br/>/api/v1/{task}/...<br/>/api/v1/models<br/>/api/v1/training/..."]
        GRPCEndpoints["gRPC Server (8085/TCP)<br/>{TaskName}Service<br/>ModelManagement<br/>TrainingManagement"]
        MetricsEndpoint["Metrics (8086/TCP)<br/>Prometheus scrape<br/>No auth (plaintext)"]
    end

    %% Auth flow
    Client -->|"Bearer Token"| KRBACProxy
    KRBACProxy -->|"TokenReview"| TokenReview
    TokenReview -->|"Validated identity"| KRBACProxy
    KRBACProxy -->|"Authenticated request"| HTTPEndpoints
    KRBACProxy -->|"Authenticated request"| GRPCEndpoints

    %% Transport security
    TLSConfig -->|"configures"| ServerCert
    TLSConfig -->|"configures"| ClientCA
    ServerCert -->|"TLS termination"| HTTPEndpoints
    ServerCert -->|"TLS termination"| GRPCEndpoints
    ClientCA -->|"mTLS verification"| HTTPEndpoints
    ClientCA -->|"mTLS verification"| GRPCEndpoints

    %% Secrets to TLS
    TLSSecret -.->|"provides"| ServerCert
    TLSClientSecret -.->|"provides"| ClientCA

    %% Styling
    style Notice fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Note fill:#fff3cd,stroke:#ffc107
    style PlatformRBAC fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style AuthFlow fill:#ffe6cc,stroke:#d79b00
    style TransportSecurity fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#f8d7da,stroke:#dc3545
    style Client fill:#f9f9f9,stroke:#999
    style KRBACProxy fill:#f5a623,stroke:#333
    style TokenReview fill:#e8e8e8,stroke:#666
    style HTTPEndpoints fill:#4a90e2,stroke:#333,color:#fff
    style GRPCEndpoints fill:#4a90e2,stroke:#333,color:#fff
    style MetricsEndpoint fill:#6c757d,stroke:#333,color:#fff
    style TLSSecret fill:#f8d7da,stroke:#dc3545
    style TLSClientSecret fill:#f8d7da,stroke:#dc3545
    style S3Secret fill:#f8d7da,stroke:#dc3545
    style OTELSecret fill:#f8d7da,stroke:#dc3545
