graph TD
    subgraph Notice["RBAC Notice"]
        direction TB
        Info["Caikit is a Python library/runtime<br/>No Kubernetes RBAC resources defined<br/>in this repository"]
    end

    subgraph PlatformRBAC["Platform-Delegated RBAC"]
        direction TB

        subgraph AuthMechanisms["Authentication Mechanisms (External)"]
            KRBAC["kube-rbac-proxy<br/>Sidecar container"]
            IstioMTLS["Istio mTLS<br/>Service mesh mutual TLS"]
            IstioAuthZ["Istio AuthorizationPolicy<br/>Service-level access control"]
            KServeAuth["KServe Auth<br/>InferenceService auth config"]
        end

        subgraph Endpoints["Caikit Endpoints (Unauthenticated)"]
            HTTPEndpoints["HTTP Server (8080/TCP)<br/>/health, /api/v1/{task}/predict,<br/>/api/v1/{task}/predict-stream,<br/>/api/v1/info/*, /api/v1/trainings"]
            GRPCEndpoints["gRPC Server (8085/TCP)<br/>GlobalInferenceService,<br/>GlobalTrainingService,<br/>ModelManagement, InfoService"]
            MetricsEndpoint["Prometheus Metrics (8086/TCP)<br/>predict_rpc_count,<br/>loaded_models, durations"]
        end

        subgraph LocalOnly["Pod-Local Access (No Auth)"]
            MMeshSocket["ModelMesh Unix Socket<br/>/tmp/mmesh/grpc.sock<br/>mmesh.ModelRuntime service<br/>Protected by: Unix socket permissions"]
        end
    end

    subgraph TLSCerts["TLS/mTLS Certificates"]
        ServerKey["runtime.tls.server.key<br/>TLS private key<br/>Provisioned: cert-manager / manual"]
        ServerCert["runtime.tls.server.cert<br/>TLS certificate<br/>Provisioned: cert-manager / manual"]
        ClientCA["runtime.tls.client.cert<br/>Client CA certificate<br/>For mTLS verification"]
        TraceCA["runtime.trace.tls.ca<br/>OTel collector TLS CA"]
        TraceKey["runtime.trace.tls.client_key<br/>OTel collector mTLS key"]
        TraceCert["runtime.trace.tls.client_cert<br/>OTel collector mTLS cert"]
    end

    %% Auth flow
    KRBAC -->|"guards"| HTTPEndpoints
    KRBAC -->|"guards"| GRPCEndpoints
    IstioMTLS -->|"encrypts"| HTTPEndpoints
    IstioMTLS -->|"encrypts"| GRPCEndpoints
    IstioAuthZ -->|"authorizes"| HTTPEndpoints
    IstioAuthZ -->|"authorizes"| GRPCEndpoints

    %% TLS to endpoints
    ServerKey -->|"configures"| HTTPEndpoints
    ServerCert -->|"configures"| HTTPEndpoints
    ServerKey -->|"configures"| GRPCEndpoints
    ServerCert -->|"configures"| GRPCEndpoints
    ClientCA -->|"mTLS verification"| HTTPEndpoints
    ClientCA -->|"mTLS verification"| GRPCEndpoints

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KRBAC fill:#7ed321,stroke:#333,color:#fff
    style IstioMTLS fill:#7ed321,stroke:#333,color:#fff
    style IstioAuthZ fill:#7ed321,stroke:#333,color:#fff
    style KServeAuth fill:#7ed321,stroke:#333,color:#fff
    style HTTPEndpoints fill:#4a90e2,stroke:#333,color:#fff
    style GRPCEndpoints fill:#4a90e2,stroke:#333,color:#fff
    style MetricsEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style MMeshSocket fill:#e1d5e7,stroke:#9673a6
    style ServerKey fill:#f5a623,stroke:#333
    style ServerCert fill:#f5a623,stroke:#333
    style ClientCA fill:#f5a623,stroke:#333
    style TraceCA fill:#f5a623,stroke:#333
    style TraceKey fill:#f5a623,stroke:#333
    style TraceCert fill:#f5a623,stroke:#333
