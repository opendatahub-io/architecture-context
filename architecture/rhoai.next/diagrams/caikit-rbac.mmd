graph TD
    subgraph Note["Caikit RBAC Model"]
        direction TB
        Info["ℹ Caikit is a Python library, not a Kubernetes operator.<br/>It defines NO ClusterRoles, Roles, or RoleBindings.<br/>Access control is delegated to the consuming deployment."]
    end

    subgraph PlatformAuth["Platform-Level Authentication (External)"]
        direction TB
        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
        OAuthProxy["oauth-proxy<br/>(sidecar)"]
        IstioAuth["Istio RequestAuthentication<br/>(JWT validation)"]
    end

    subgraph CaikitAuth["Caikit Built-in Auth (Optional)"]
        direction TB
        mTLS_gRPC["gRPC mTLS<br/>ssl_server_credentials<br/>require_client_auth"]
        mTLS_HTTP["HTTP mTLS<br/>Uvicorn ssl_cert_reqs<br/>=CERT_REQUIRED"]
        NoAuth["No Auth (Default)<br/>All endpoints open"]
    end

    subgraph Endpoints["Caikit Endpoints"]
        direction TB
        HTTP_EP["HTTP Endpoints<br/>8080/TCP"]
        gRPC_EP["gRPC Endpoints<br/>8085/TCP"]
        Metrics_EP["Metrics Endpoint<br/>8086/TCP"]
        UnixSocket["Model Mesh Socket<br/>/tmp/mmesh/grpc.sock"]
    end

    subgraph Secrets["TLS Secrets"]
        direction TB
        ServerCert["TLS server key/cert<br/>(kubernetes.io/tls)<br/>Provisioner: cert-manager or manual"]
        ClientCA["TLS client CA cert<br/>(Opaque)<br/>For mTLS client verification"]
        OTLPCert["OTLP TLS CA/key/cert<br/>(Opaque)<br/>For trace exporter"]
    end

    %% Auth flow
    KubeRBACProxy -->|"protects"| HTTP_EP
    OAuthProxy -->|"protects"| HTTP_EP
    IstioAuth -->|"validates JWT"| gRPC_EP

    mTLS_gRPC -->|"client cert required"| gRPC_EP
    mTLS_HTTP -->|"client cert required"| HTTP_EP
    NoAuth -->|"no protection"| HTTP_EP
    NoAuth -->|"no protection"| gRPC_EP
    NoAuth -->|"no protection"| Metrics_EP

    %% Secrets
    ServerCert -->|"configures"| mTLS_gRPC
    ServerCert -->|"configures"| mTLS_HTTP
    ClientCA -->|"validates clients"| mTLS_gRPC
    ClientCA -->|"validates clients"| mTLS_HTTP

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style PlatformAuth fill:#d4edda,stroke:#155724,stroke-width:2px
    style CaikitAuth fill:#cce5ff,stroke:#004085,stroke-width:2px
    style Endpoints fill:#e2e3e5,stroke:#383d41,stroke-width:2px
    style Secrets fill:#f8d7da,stroke:#721c24,stroke-width:2px

    style KubeRBACProxy fill:#28a745,stroke:#333,color:#fff
    style OAuthProxy fill:#28a745,stroke:#333,color:#fff
    style IstioAuth fill:#28a745,stroke:#333,color:#fff
    style mTLS_gRPC fill:#007bff,stroke:#333,color:#fff
    style mTLS_HTTP fill:#007bff,stroke:#333,color:#fff
    style NoAuth fill:#6c757d,stroke:#333,color:#fff
    style ServerCert fill:#dc3545,stroke:#333,color:#fff
    style ClientCA fill:#dc3545,stroke:#333,color:#fff
    style OTLPCert fill:#dc3545,stroke:#333,color:#fff
