graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Frontends["API Frontends"]
            gRPCFrontend["gRPC Frontend<br/>PredictionService<br/>ModelService<br/>GRPCInferenceService"]
            HTTPFrontend["HTTP/REST Frontend<br/>(Drogon Framework)<br/>TFS v1 / KServe v2 / OpenAI / v3"]
            MetricsModule["Metrics Module<br/>/metrics (Prometheus)"]
        end

        subgraph Core["Core Engine"]
            ModelManager["Model Manager<br/>Loading, Versioning,<br/>Config Monitoring"]
            DAGScheduler["DAG Scheduler<br/>Multi-step Pipelines"]
            MediaPipe["MediaPipe Graph Executor<br/>Calculator Graphs"]
        end

        subgraph AIEngines["AI Engines"]
            LLMEngine["LLM Engine<br/>Continuous Batching<br/>+ Legacy Sequential"]
            EmbeddingsEngine["Embeddings Engine<br/>CLS/LAST/MEAN Pooling"]
            RerankEngine["Reranking Engine<br/>Cross-encoder Models"]
            ImageGenEngine["Image Generation<br/>Engine"]
            STTEngine["Speech-to-Text<br/>Engine"]
            TTSEngine["Text-to-Speech<br/>Engine"]
        end

        subgraph Extensions["Extensions"]
            PythonBackend["Python Backend<br/>(pybind11)"]
            CAPI["C API<br/>(libovms_shared.so)"]
            ModelPulling["Model Pulling Module<br/>HuggingFace Hub"]
        end

        subgraph Storage["Storage Backends"]
            LocalFS["Local Filesystem"]
            S3FS["S3 Backend"]
            GCSFS["GCS Backend"]
            AzureFS["Azure Blob/File<br/>Backend"]
        end
    end

    Client["External Client"] -->|"REST (HTTP)"| HTTPFrontend
    Client -->|"gRPC (HTTP/2)"| gRPCFrontend
    Prometheus["Prometheus"] -->|"HTTP scrape"| MetricsModule

    HTTPFrontend --> ModelManager
    gRPCFrontend --> ModelManager
    HTTPFrontend --> MediaPipe
    gRPCFrontend --> DAGScheduler

    ModelManager --> LocalFS
    ModelManager --> S3FS
    ModelManager --> GCSFS
    ModelManager --> AzureFS

    MediaPipe --> LLMEngine
    MediaPipe --> EmbeddingsEngine
    MediaPipe --> RerankEngine
    MediaPipe --> ImageGenEngine
    MediaPipe --> STTEngine
    MediaPipe --> TTSEngine
    MediaPipe --> PythonBackend

    DAGScheduler --> ModelManager

    LLMEngine --> OpenVINORuntime["OpenVINO Runtime<br/>+ GenAI"]
    EmbeddingsEngine --> OpenVINORuntime
    RerankEngine --> OpenVINORuntime
    ImageGenEngine --> OpenVINORuntime
    STTEngine --> OpenVINORuntime
    TTSEngine --> OpenVINORuntime
    ModelManager -->|"model compilation"| OpenVINORuntime

    ModelPulling -->|"git clone / curl"| HuggingFace["HuggingFace Hub"]

    KServe["KServe<br/>InferenceService"] -->|"runtime contract"| OVMS

    style OVMS fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style gRPCFrontend fill:#4a90e2,color:#fff
    style HTTPFrontend fill:#4a90e2,color:#fff
    style MetricsModule fill:#4a90e2,color:#fff
    style ModelManager fill:#5ba8f7,color:#fff
    style DAGScheduler fill:#5ba8f7,color:#fff
    style MediaPipe fill:#5ba8f7,color:#fff
    style LLMEngine fill:#7ed321,color:#fff
    style EmbeddingsEngine fill:#7ed321,color:#fff
    style RerankEngine fill:#7ed321,color:#fff
    style ImageGenEngine fill:#7ed321,color:#fff
    style STTEngine fill:#7ed321,color:#fff
    style TTSEngine fill:#7ed321,color:#fff
    style PythonBackend fill:#f5a623,color:#fff
    style CAPI fill:#f5a623,color:#fff
    style ModelPulling fill:#f5a623,color:#fff
    style OpenVINORuntime fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
