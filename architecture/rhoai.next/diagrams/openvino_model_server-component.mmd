graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Core["Core Server (C++/Bazel)"]
            Server["Server<br/>(singleton orchestrator)"]
            Config["CLI Parser / Config"]
            Server -->|reads| Config
        end

        subgraph APILayer["API Layer (Multi-Protocol)"]
            direction LR
            DrogonHTTP["Drogon HTTP Server<br/>(REST frontend)"]
            GRPCServer["gRPC Server<br/>(gRPC frontend)"]
        end

        subgraph Handlers["Request Handlers"]
            direction LR
            TFSHandler["TFS v1 Handler<br/>/v1/models/**"]
            KFSHandler["KServe v2 Handler<br/>/v2/models/**"]
            V3Handler["OpenAI v3 Handler<br/>/v3/v1/**"]
        end

        subgraph InferenceEngine["Inference Engine"]
            direction TB
            MediaPipe["MediaPipe Graph<br/>Executor"]
            CustomNodes["Custom Node<br/>System (C ABI)"]
            ServableManager["Servable Manager<br/>Module"]
        end

        subgraph RuntimeLibs["Runtime Libraries"]
            direction LR
            OVRuntime["OpenVINO Runtime<br/>2026.1"]
            OVGenAI["OpenVINO GenAI<br/>(LLM/VLM pipelines)"]
            OVTokenizers["OpenVINO Tokenizers"]
        end

        subgraph Extensions["Extensions"]
            direction LR
            PythonBinding["Python Binding<br/>(pybind11)"]
            CAPILib["libovms_shared.so<br/>(C API)"]
            HFPull["HuggingFace Pull<br/>Module"]
        end

        subgraph Metrics["Observability"]
            MetricsEndpoint["Prometheus Metrics<br/>/metrics"]
            Profiler["Profiler Module"]
        end

        Server -->|starts| DrogonHTTP
        Server -->|starts| GRPCServer
        Server -->|starts| ServableManager
        Server -->|starts| HFPull

        DrogonHTTP -->|routes| TFSHandler
        DrogonHTTP -->|routes| KFSHandler
        DrogonHTTP -->|routes| V3Handler
        DrogonHTTP -->|routes| MetricsEndpoint

        GRPCServer -->|dispatches| KFSHandler
        GRPCServer -->|dispatches| TFSHandler

        TFSHandler -->|executes| ServableManager
        KFSHandler -->|executes| ServableManager
        V3Handler -->|executes| MediaPipe

        MediaPipe -->|invokes| OVGenAI
        MediaPipe -->|invokes| CustomNodes
        ServableManager -->|loads models| OVRuntime
        OVGenAI -->|uses| OVTokenizers
        OVGenAI -->|uses| OVRuntime
    end

    %% External integrations
    Client["Client / Gateway"]
    KServe["KServe Controller"]
    KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]

    subgraph ModelStorage["Model Storage"]
        direction LR
        PVC["PVC / Local"]
        S3["AWS S3"]
        Azure["Azure Blob"]
        GCS["Google Cloud<br/>Storage"]
        HFHub["HuggingFace Hub"]
    end

    Client -->|REST/gRPC| KubeRBACProxy
    KubeRBACProxy -->|proxied requests| DrogonHTTP
    KubeRBACProxy -->|proxied requests| GRPCServer
    KServe -->|deploys pod with| OVMS

    HFPull -->|downloads models| HFHub
    ServableManager -->|loads from| PVC
    ServableManager -->|loads from| S3
    ServableManager -->|loads from| Azure
    ServableManager -->|loads from| GCS

    %% Styling
    style OVMS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Core fill:#bbdefb,stroke:#1565c0
    style APILayer fill:#c8e6c9,stroke:#2e7d32
    style Handlers fill:#fff9c4,stroke:#f9a825
    style InferenceEngine fill:#f3e5f5,stroke:#7b1fa2
    style RuntimeLibs fill:#ffe0b2,stroke:#e65100
    style Extensions fill:#f0f4c3,stroke:#827717
    style Metrics fill:#b2ebf2,stroke:#00838f
    style ModelStorage fill:#fff3e0,stroke:#e65100

    style Server fill:#1565c0,color:#fff
    style DrogonHTTP fill:#2e7d32,color:#fff
    style GRPCServer fill:#2e7d32,color:#fff
    style KubeRBACProxy fill:#c62828,color:#fff
    style KServe fill:#6a1b9a,color:#fff
    style Client fill:#37474f,color:#fff
