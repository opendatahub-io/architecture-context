graph TB
    subgraph OVMS["OpenVINO Model Server"]
        direction TB

        subgraph Frontends["API Frontends"]
            gRPCFrontend["gRPC Frontend<br/>(PredictionService, ModelService,<br/>GRPCInferenceService)"]
            HTTPFrontend["HTTP/REST Frontend<br/>(Drogon Framework)<br/>TFS v1 | KServe v2 | OpenAI | v3"]
            MetricsEndpoint["Metrics Module<br/>/metrics (Prometheus)"]
        end

        subgraph Core["Core Engine"]
            ModelManager["Model Manager<br/>(lifecycle, versioning,<br/>config watching, reloading)"]
            DAGScheduler["DAG Scheduler<br/>(multi-step pipelines,<br/>custom nodes)"]
            MediaPipeExec["MediaPipe Graph Executor<br/>(calculator graphs)"]
        end

        subgraph AIEngines["AI Engines"]
            LLMEngine["LLM Engine<br/>(continuous batching,<br/>speculative decoding,<br/>prefix caching)"]
            EmbeddingsEngine["Embeddings Engine<br/>(CLS/LAST/MEAN pooling)"]
            RerankEngine["Reranking Engine<br/>(cross-encoder)"]
            ImageGenEngine["Image Generation Engine"]
            STTEngine["Speech-to-Text Engine"]
            TTSEngine["Text-to-Speech Engine"]
        end

        subgraph Extensions["Extensions"]
            PythonBackend["Python Backend<br/>(pybind11 embedding)"]
            CAPI["C API<br/>(libovms_shared.so)"]
            ModelPulling["Model Pulling Module<br/>(HuggingFace Hub,<br/>GGUF downloads)"]
        end

        subgraph Storage["Storage Backends"]
            LocalFS["Local Filesystem"]
            S3FS["S3 Backend"]
            GCSFS["GCS Backend"]
            AzureFS["Azure Blob/File Backend"]
        end
    end

    %% External Dependencies
    OpenVINORT["OpenVINO Runtime 2026.0"]
    OpenVINOGenAI["OpenVINO GenAI"]
    OpenVINOTok["OpenVINO Tokenizers"]

    %% Platform Integration
    KServe["KServe<br/>(InferenceService)"]
    ServingRuntime["RHOAI ServingRuntime CR"]

    %% External Services
    S3["Amazon S3"]
    GCS["Google Cloud Storage"]
    AzureBlob["Azure Blob Storage"]
    HFHub["HuggingFace Hub"]

    %% Clients
    Client["Inference Client"]

    %% Client connections
    Client -->|"REST (OpenAI/TFS/KServe)"| HTTPFrontend
    Client -->|"gRPC (TFS/KServe v2)"| gRPCFrontend

    %% Frontend to Core
    HTTPFrontend --> ModelManager
    HTTPFrontend --> MediaPipeExec
    gRPCFrontend --> ModelManager
    gRPCFrontend --> MediaPipeExec

    %% Core to Engines
    MediaPipeExec --> LLMEngine
    MediaPipeExec --> EmbeddingsEngine
    MediaPipeExec --> RerankEngine
    MediaPipeExec --> ImageGenEngine
    MediaPipeExec --> STTEngine
    MediaPipeExec --> TTSEngine
    MediaPipeExec --> PythonBackend
    ModelManager --> DAGScheduler
    DAGScheduler --> CAPI

    %% Engine dependencies
    LLMEngine --> OpenVINOGenAI
    LLMEngine --> OpenVINOTok
    ModelManager --> OpenVINORT

    %% Storage connections
    ModelManager --> LocalFS
    ModelManager --> S3FS
    ModelManager --> GCSFS
    ModelManager --> AzureFS
    ModelPulling --> HFHub
    S3FS --> S3
    GCSFS --> GCS
    AzureFS --> AzureBlob

    %% Platform integration
    KServe -->|"deploys as runtime"| OVMS
    ServingRuntime -->|"configures"| OVMS

