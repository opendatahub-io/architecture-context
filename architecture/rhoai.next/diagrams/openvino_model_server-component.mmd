graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph CoreServer["Core Server"]
            Main["ovms<br/>(C++ Binary)"]
            GRPCServer["gRPC Server<br/>HTTP/2"]
            HTTPServer["HTTP/REST Server<br/>(Drogon Framework)"]
            ModelManager["Model Manager<br/>(Singleton)"]
            Main --> GRPCServer
            Main --> HTTPServer
            Main --> ModelManager
        end

        subgraph InferencePipelines["Inference Pipelines"]
            DirectInference["Direct Model Inference<br/>(KServe v2 / TFS)"]
            DAGScheduler["DAG Pipeline Scheduler<br/>(Multi-model chaining)"]
            MediaPipeEngine["MediaPipe Graph Engine"]
            ModelManager --> DirectInference
            ModelManager --> DAGScheduler
            ModelManager --> MediaPipeEngine
        end

        subgraph MediaPipeCalculators["MediaPipe Calculators"]
            LLMCalc["LLM Calculator<br/>(Chat/Completions)"]
            EmbeddingsCalc["Embeddings Calculator"]
            RerankCalc["Rerank Calculator"]
            S2TCalc["Speech-to-Text Calculator"]
            T2SCalc["Text-to-Speech Calculator"]
            ImageGenCalc["Image Generation Calculator<br/>(Stable Diffusion)"]
            MediaPipeEngine --> LLMCalc
            MediaPipeEngine --> EmbeddingsCalc
            MediaPipeEngine --> RerankCalc
            MediaPipeEngine --> S2TCalc
            MediaPipeEngine --> T2SCalc
            MediaPipeEngine --> ImageGenCalc
        end

        subgraph RuntimeLibs["Runtime Libraries"]
            OVRuntime["OpenVINO Runtime 2026.1<br/>(CPU/GPU/NPU)"]
            OVGenAI["OpenVINO GenAI 2026.1<br/>(Continuous Batching)"]
            OVTokenizers["OpenVINO Tokenizers 2026.1"]
            DirectInference --> OVRuntime
            LLMCalc --> OVGenAI
            OVGenAI --> OVRuntime
            LLMCalc --> OVTokenizers
            EmbeddingsCalc --> OVRuntime
        end

        subgraph StorageLayer["Storage & Model Loading"]
            FSFactory["FileSystem Factory"]
            S3FS["S3 FileSystem"]
            GCSFS["GCS FileSystem"]
            AzureFS["Azure FileSystem"]
            LocalFS["Local FileSystem"]
            HFPull["HuggingFace Pull Module<br/>(libgit2)"]
            FSFactory --> S3FS
            FSFactory --> GCSFS
            FSFactory --> AzureFS
            FSFactory --> LocalFS
            ModelManager --> FSFactory
            ModelManager --> HFPull
        end

        subgraph Extensions["Extensions"]
            PythonInterp["Python Interpreter Module<br/>(pybind11)"]
            CAPILib["libovms_shared.so<br/>(C API)"]
            MediaPipeEngine --> PythonInterp
        end
    end

    %% External API protocols
    subgraph APIProtocols["API Protocols"]
        KServeV2["KServe v2 API<br/>/v2/models/*/infer"]
        TFSAPI["TFS API<br/>/v1/models/*:predict"]
        OpenAIAPI["OpenAI-compat API<br/>/v3/chat/completions"]
        CohereAPI["Cohere-compat API<br/>/v3/rerank"]
        MetricsAPI["Prometheus Metrics<br/>/metrics"]
    end

    KServeV2 --> HTTPServer
    KServeV2 --> GRPCServer
    TFSAPI --> HTTPServer
    TFSAPI --> GRPCServer
    OpenAIAPI --> HTTPServer
    CohereAPI --> HTTPServer
    MetricsAPI --> HTTPServer

    %% Platform integration
    KServeRT["KServe ServingRuntime"] -->|deploys container| Main
    KRBAC["kube-rbac-proxy<br/>(Sidecar)"] -->|TLS + AuthN/AuthZ| HTTPServer
    KRBAC -->|TLS + AuthN/AuthZ| GRPCServer

    %% External storage
    S3FS -->|HTTPS/443| S3["Amazon S3"]
    GCSFS -->|HTTPS/443| GCS["Google Cloud Storage"]
    AzureFS -->|HTTPS/443| Azure["Azure Blob Storage"]
    HFPull -->|HTTPS/443| HFHub["HuggingFace Hub"]
    LocalFS -->|filesystem| PVC["PVC / NFS Volume"]

    %% Styles
    style Main fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style ModelManager fill:#4a90e2,stroke:#333,color:#fff
    style OVRuntime fill:#5b6abf,stroke:#333,color:#fff
    style OVGenAI fill:#5b6abf,stroke:#333,color:#fff
    style OVTokenizers fill:#5b6abf,stroke:#333,color:#fff
    style LLMCalc fill:#7ed321,stroke:#333
    style EmbeddingsCalc fill:#7ed321,stroke:#333
    style RerankCalc fill:#7ed321,stroke:#333
    style S2TCalc fill:#7ed321,stroke:#333
    style T2SCalc fill:#7ed321,stroke:#333
    style ImageGenCalc fill:#7ed321,stroke:#333
    style KServeRT fill:#f5a623,stroke:#333
    style KRBAC fill:#f5a623,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style GCS fill:#e8e8e8,stroke:#333
    style Azure fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style PVC fill:#e8e8e8,stroke:#333
