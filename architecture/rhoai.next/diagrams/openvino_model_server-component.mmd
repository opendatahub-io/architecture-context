graph TB
    subgraph OVMS["OpenVINO Model Server (ovms binary)"]
        direction TB

        subgraph Frontend["API Frontend Layer"]
            HTTPServer["HTTP Server Module<br/>(Drogon)<br/>Port 8080/TCP"]
            GRPCServer["gRPC Server Module<br/>Port 8443/TCP"]
        end

        subgraph APIHandlers["API Handlers"]
            TFSHandler["TFS REST Handler<br/>/v1/models/..."]
            KServeHandler["KServe v2 Handler<br/>/v2/models/..."]
            OpenAIHandler["OpenAI Handler<br/>/v3/.../chat/completions"]
            MetricsHandler["Metrics Handler<br/>/metrics"]
            TFSgRPC["TFS gRPC Service<br/>PredictionService"]
            KServegRPC["KServe v2 gRPC Service<br/>GRPCInferenceService"]
        end

        subgraph Servables["Inference Servables"]
            direction LR
            LLM["LLM Servable<br/>Chat/Completions"]
            Embeddings["Embeddings Servable<br/>OpenAI API"]
            Rerank["Rerank Servable<br/>Cohere API"]
            ImageGen["Image Gen Servable<br/>Text-to-Image"]
            S2T["Speech-to-Text<br/>Whisper"]
            T2S["Text-to-Speech<br/>Synthesis"]
        end

        subgraph Core["Core Engine"]
            MediaPipe["MediaPipe Graph<br/>Executor"]
            ModelMgr["Model Manager<br/>Lifecycle & Hot-Reload"]
            PythonBackend["Python Backend<br/>(pybind11/Jinja2)"]
            HFPull["HF Pull Module<br/>Model Downloading"]
            MetricsModule["Metrics Module<br/>Prometheus"]
        end

        HTTPServer --> TFSHandler
        HTTPServer --> KServeHandler
        HTTPServer --> OpenAIHandler
        HTTPServer --> MetricsHandler
        GRPCServer --> TFSgRPC
        GRPCServer --> KServegRPC

        TFSHandler --> ModelMgr
        KServeHandler --> ModelMgr
        TFSgRPC --> ModelMgr
        KServegRPC --> ModelMgr

        OpenAIHandler --> MediaPipe
        MediaPipe --> LLM
        MediaPipe --> Embeddings
        MediaPipe --> Rerank
        MediaPipe --> ImageGen
        MediaPipe --> S2T
        MediaPipe --> T2S

        LLM --> PythonBackend
        ModelMgr --> HFPull
        MetricsHandler --> MetricsModule
    end

    subgraph External["External Dependencies"]
        OVRuntime["OpenVINO Runtime<br/>Model Inference Engine"]
        OVGenAI["OpenVINO GenAI<br/>LLM Pipeline"]
    end

    subgraph Platform["Platform Integration"]
        KServe["KServe<br/>InferenceService CR"]
        RHOAIGateway["RHOAI Gateway<br/>(Envoy)"]
        KubeRBACProxy["kube-rbac-proxy<br/>Sidecar"]
    end

    subgraph Storage["Model Storage"]
        S3["S3-compatible<br/>Storage"]
        GCS["Google Cloud<br/>Storage"]
        Azure["Azure Blob/File<br/>Storage"]
        HFHub["Hugging Face<br/>Hub"]
        LocalFS["Local Filesystem<br/>/PVC"]
    end

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus"]
    end

    ModelMgr --> OVRuntime
    LLM --> OVGenAI
    Embeddings --> OVGenAI
    ImageGen --> OVGenAI
    S2T --> OVGenAI
    T2S --> OVGenAI

    ModelMgr --> S3
    ModelMgr --> GCS
    ModelMgr --> Azure
    HFPull --> HFHub
    ModelMgr --> LocalFS

    KServe -->|deploys| OVMS
    RHOAIGateway -->|443/TCP TLS| KubeRBACProxy
    KubeRBACProxy -->|8080/TCP HTTP| HTTPServer
    Prometheus -->|scrapes /metrics| HTTPServer

