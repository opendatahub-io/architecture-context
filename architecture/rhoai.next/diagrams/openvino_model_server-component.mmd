    style GRPCServer fill:#4a90e2,color:#fff
    style LLM fill:#7e57c2,color:#fff
    style Embeddings fill:#7e57c2,color:#fff
    style Rerank fill:#7e57c2,color:#fff
    style ImageGen fill:#7e57c2,color:#fff
    style S2T fill:#7e57c2,color:#fff
    style T2S fill:#7e57c2,color:#fff
    style ModelMgr fill:#2e7d32,color:#fff
    style MediaPipe fill:#2e7d32,color:#fff
    style OVRuntime fill:#ff8f00,color:#fff
    style OVGenAI fill:#ff8f00,color:#fff
    style KServe fill:#7ed321
    style RHOAIGateway fill:#7ed321
    style KubeRBACProxy fill:#7ed321
