graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Frontend["API Frontend"]
            REST["REST/HTTP Server<br/>(Drogon Framework)<br/>configurable/TCP"]
            GRPC["gRPC Server<br/>(HTTP/2)<br/>configurable/TCP"]
            Metrics["Metrics Endpoint<br/>/metrics<br/>Prometheus format"]
        end

        subgraph APILayer["Multi-Protocol API Layer"]
            TFSv1["TFS v1 API<br/>/v1/models/*<br/>Predict, Classify, Regress"]
            KServev2["KServe v2 API<br/>/v2/*<br/>ModelInfer, Health, Ready"]
            OpenAIv3["OpenAI v3 API<br/>/v3/*<br/>Chat, Completions, Embeddings"]
        end

        subgraph Core["Inference Core"]
            ModelMgr["ModelManager<br/>Model lifecycle, versioning,<br/>hot reload, config watcher"]
            ModelInst["ModelInstance<br/>Per-model inference<br/>execution context"]
            DAG["DAG Pipeline Scheduler<br/>Model chaining &<br/>custom processing"]
            MediaPipe["MediaPipe Graph Executor<br/>Complex inference pipelines<br/>(LLM, embeddings, rerank)"]
        end

        subgraph LLMSubsystem["LLM Subsystem (src/llm/)"]
            CBPipeline["ContinuousBatchingPipeline<br/>Overlapped prompt processing<br/>& token generation"]
            Embeddings["Embeddings Servable<br/>Text embeddings"]
            Rerank["Rerank Servable<br/>Document reranking"]
            S2T["Speech-to-Text<br/>(Whisper)"]
            T2S["Text-to-Speech"]
            ImageGen["Image Generation<br/>(Stable Diffusion)"]
        end

        subgraph Runtime["Inference Runtime"]
            OVRuntime["OpenVINO Runtime 2026.0<br/>Model compilation & execution<br/>CPU / GPU / NPU"]
            OVGenAI["OpenVINO GenAI 2026.0<br/>LLM continuous batching,<br/>Whisper, TTS, ImageGen"]
            OVTokenizers["OpenVINO Tokenizers 2026.0<br/>Tokenization for LLM<br/>& embedding models"]
        end

        subgraph CAPILib["C API Library"]
            CAPI["libovms_shared.so<br/>In-process inference<br/>embedding API"]
        end
    end

    subgraph Sidecar["Platform Sidecars"]
        KubeRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>K8s Bearer Token auth"]
        NginxMTLS["nginx-mtls-auth<br/>443/TCP HTTPS<br/>mTLS client certs<br/>(optional)"]
        IstioSidecar["Istio Envoy Sidecar<br/>mTLS encryption"]
    end

    Client[External Client] -->|"HTTPS/8443<br/>K8s Bearer Token"| KubeRBAC
    KubeRBAC -->|"HTTP (localhost)"| REST
    Client -.->|"gRPC (HTTP/2)"| GRPC

    REST --> TFSv1
    REST --> KServev2
    REST --> OpenAIv3
    GRPC --> TFSv1
    GRPC --> KServev2

    TFSv1 --> ModelMgr
    KServev2 --> ModelMgr
    OpenAIv3 --> MediaPipe
    MediaPipe --> CBPipeline
    MediaPipe --> Embeddings
    MediaPipe --> Rerank
    MediaPipe --> S2T
    MediaPipe --> T2S
    MediaPipe --> ImageGen

    ModelMgr --> ModelInst
    ModelMgr --> DAG
    ModelInst --> OVRuntime
    CBPipeline --> OVGenAI
    Embeddings --> OVGenAI
    S2T --> OVGenAI
    T2S --> OVGenAI
    ImageGen --> OVGenAI
    OVGenAI --> OVTokenizers

    CAPI -.->|"In-process"| ModelMgr

    style OVMS fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Frontend fill:#dbeafe,stroke:#3b82f6
    style APILayer fill:#ede9fe,stroke:#7c3aed
    style Core fill:#fef3c7,stroke:#f59e0b
    style LLMSubsystem fill:#fce7f3,stroke:#ec4899
    style Runtime fill:#d1fae5,stroke:#10b981
    style CAPILib fill:#f3f4f6,stroke:#6b7280
    style Sidecar fill:#fff7ed,stroke:#f97316,stroke-dasharray:5 5
    style Client fill:#f9fafb,stroke:#374151
    style KubeRBAC fill:#fed7aa,stroke:#ea580c
    style NginxMTLS fill:#fed7aa,stroke:#ea580c
    style IstioSidecar fill:#fed7aa,stroke:#ea580c
