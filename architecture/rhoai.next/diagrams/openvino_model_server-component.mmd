graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Frontends["API Frontends"]
            direction LR
            REST["Drogon HTTP Server<br/>REST API<br/>configurable/TCP"]
            GRPC["gRPC Server<br/>HTTP/2<br/>configurable/TCP"]
            Metrics["Metrics Endpoint<br/>/metrics<br/>Prometheus format"]
        end

        subgraph APIHandlers["API Protocol Handlers"]
            direction LR
            TFSv1["TFS v1 Handler<br/>/v1/models/*<br/>Predict, Classify, Regress"]
            KServev2["KServe v2 Handler<br/>/v2/*<br/>ModelInfer, Health, Ready"]
            OpenAIv3["OpenAI v3 Handler<br/>/v3/*<br/>Chat, Completions, Embeddings"]
        end

        subgraph Core["Inference Core"]
            direction TB
            ModelManager["ModelManager<br/>Model lifecycle, versioning,<br/>hot reload, config polling"]
            ModelInstance["ModelInstance<br/>Per-model inference execution"]
            DAGPipeline["DAG Pipeline Scheduler<br/>Multi-model chaining"]
        end

        subgraph LLMSubsystem["LLM Subsystem"]
            direction LR
            MediaPipe["MediaPipe Graph Executor<br/>Calculator pipelines"]
            ContinuousBatching["ContinuousBatchingPipeline<br/>Prompt + token generation overlap"]
            ToolParsers["Tool Parsers<br/>Llama3, Mistral, Hermes3,<br/>Devstral, Phi4, GPT-4o, Qwen3"]
        end

        subgraph Servables["Specialized Servables"]
            direction LR
            EmbeddingsServable["Embeddings Servable<br/>/v3/embeddings"]
            RerankServable["Rerank Servable<br/>/v3/rerank"]
            S2TServable["Speech-to-Text<br/>/v3 (Whisper)"]
            T2SServable["Text-to-Speech<br/>/v3/text-to-speech"]
            ImageGenServable["Image Generation<br/>/v3/image-generation"]
        end

        subgraph ModelLoading["Model Loading"]
            direction LR
            LocalFS["Local Filesystem"]
            S3Client["S3 Client"]
            GCSClient["GCS Client"]
            AzureClient["Azure Blob Client"]
            HFPull["HuggingFace Pull Module<br/>libgit2"]
        end
    end

    %% External runtime dependencies
    OpenVINORT["OpenVINO Runtime 2026.0<br/>Model compilation & execution"]
    OpenVINOGenAI["OpenVINO GenAI 2026.0<br/>LLM, Whisper, TTS, ImageGen"]
    OpenVINOTokenizers["OpenVINO Tokenizers 2026.0<br/>Token processing"]

    %% Platform components
    KServe["KServe<br/>InferenceService Pod"]
    KubeRBACProxy["kube-rbac-proxy<br/>Sidecar (RHOAI)"]
    IstioSidecar["Istio Envoy Sidecar<br/>mTLS"]

    %% Internal connections
    REST --> TFSv1
    REST --> KServev2
    REST --> OpenAIv3
    GRPC --> KServev2
    GRPC --> TFSv1

    TFSv1 --> ModelManager
    KServev2 --> ModelManager
    OpenAIv3 --> MediaPipe
    OpenAIv3 --> EmbeddingsServable
    OpenAIv3 --> RerankServable
    OpenAIv3 --> S2TServable
    OpenAIv3 --> T2SServable
    OpenAIv3 --> ImageGenServable

    ModelManager --> ModelInstance
    ModelManager --> DAGPipeline
    MediaPipe --> ContinuousBatching
    ContinuousBatching --> ToolParsers

    ModelInstance --> OpenVINORT
    ContinuousBatching --> OpenVINOGenAI
    EmbeddingsServable --> OpenVINOGenAI
    S2TServable --> OpenVINOGenAI
    T2SServable --> OpenVINOGenAI
    ImageGenServable --> OpenVINOGenAI
    ModelManager --> OpenVINOTokenizers

    ModelManager --> LocalFS
    ModelManager --> S3Client
    ModelManager --> GCSClient
    ModelManager --> AzureClient
    ModelManager --> HFPull

    %% Platform connections
    KServe -.->|deploys| OVMS
    KubeRBACProxy -.->|auth proxy| REST
    IstioSidecar -.->|mTLS| OVMS

    %% Styling
    style OVMS fill:#e8f4f8,stroke:#2196F3,stroke-width:2px
    style REST fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style OpenVINORT fill:#ff9800,stroke:#333,color:#fff
    style OpenVINOGenAI fill:#ff9800,stroke:#333,color:#fff
    style OpenVINOTokenizers fill:#ff9800,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style IstioSidecar fill:#7ed321,stroke:#333,color:#fff
    style ContinuousBatching fill:#9c27b0,stroke:#333,color:#fff
    style MediaPipe fill:#9c27b0,stroke:#333,color:#fff
