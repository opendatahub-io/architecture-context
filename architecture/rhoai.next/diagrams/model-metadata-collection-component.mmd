graph TB
    subgraph "model-metadata-collection Component"
        direction TB
        subgraph "CI/CD Tools (Build-Time Only)"
            Extractor["model-extractor<br/>Go CLI Tool<br/>Main enrichment pipeline"]
            Reporter["metadata-report<br/>Go CLI Tool<br/>Completeness reports"]
        end

        subgraph "Runtime Container"
            DataContainer["odh-model-metadata-collection<br/>Data-Only Container<br/>UBI9-minimal + YAML files<br/>Runs: sleep infinity"]
            CatalogFiles["/app/data/*.yaml<br/>Pre-generated catalogs"]
            BenchmarkFiles["/app/benchmarks/<br/>Benchmark data"]
            DataContainer --- CatalogFiles
            DataContainer --- BenchmarkFiles
        end
    end

    subgraph "Input Data"
        ModelsIndex["data/models-index.yaml<br/>Model definitions"]
        MCPIndex["data/redhat-mcp-servers-index.yaml<br/>MCP server definitions"]
        SupplementalCatalog["input/supplemental-catalog.yaml<br/>Static catalog entries"]
        VLLMConfigs["input/vllm-recommended-configs/<br/>Per-model serving configs"]
    end

    subgraph "External Services (Build-Time)"
        HuggingFace["HuggingFace API<br/>huggingface.co/api<br/>443/TCP HTTPS"]
        RedHatRegistry["registry.redhat.io<br/>OCI Registry v2<br/>443/TCP HTTPS"]
        QuayIO["quay.io<br/>OCI Registry v2<br/>443/TCP HTTPS"]
    end

    subgraph "Runtime Consumer"
        Dashboard["RHOAI Dashboard<br/>Volume mount reader"]
    end

    %% Build-time flows
    ModelsIndex -->|reads| Extractor
    MCPIndex -->|reads| Extractor
    SupplementalCatalog -->|reads| Extractor
    VLLMConfigs -->|reads| Extractor
    Extractor -->|fetches collections & model details| HuggingFace
    Extractor -->|pulls modelcar manifests & layers| RedHatRegistry
    Extractor -->|pulls MCP server images| QuayIO
    Extractor -->|generates| CatalogFiles

    Reporter -->|reads| CatalogFiles

    %% Runtime flow
    CatalogFiles -->|volume mount| Dashboard

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Reporter fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style CatalogFiles fill:#7ed321,stroke:#333
    style BenchmarkFiles fill:#7ed321,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style RedHatRegistry fill:#e8e8e8,stroke:#333
    style QuayIO fill:#e8e8e8,stroke:#333
    style Dashboard fill:#f5a623,stroke:#333,color:#fff
    style ModelsIndex fill:#dce6f0,stroke:#333
    style MCPIndex fill:#dce6f0,stroke:#333
    style SupplementalCatalog fill:#dce6f0,stroke:#333
    style VLLMConfigs fill:#dce6f0,stroke:#333
