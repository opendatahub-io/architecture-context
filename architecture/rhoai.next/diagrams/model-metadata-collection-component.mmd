graph TB
    subgraph "Model Metadata Collection"
        subgraph "Build-Time Tools (CI/CD Only)"
            Extractor["model-extractor<br/>(Go CLI)"]
            Reporter["metadata-report<br/>(Go CLI)"]
        end

        subgraph "Shipped Artifact"
            DataContainer["odh-model-metadata-collection<br/>(UBI9-minimal Data Container)<br/>sleep infinity"]
            subgraph "Data Files (/app/data)"
                ModelsCatalog["models-catalog.yaml"]
                ValidatedCatalog["validated-models-catalog.yaml"]
                OtherCatalog["other-models-catalog.yaml"]
                RHMCPCatalog["redhat-mcp-servers-catalog.yaml"]
                PartnerMCPCatalog["partner-mcp-servers-catalog.yaml"]
                CommunityMCPCatalog["community-mcp-servers-catalog.yaml"]
            end
        end
    end

    %% Build-time inputs
    ModelsIndex["data/models-index.yaml"] -->|input| Extractor
    ValidatedIndex["data/validated-models-index.yaml"] -->|input| Extractor
    OtherIndex["data/other-models-index.yaml"] -->|input| Extractor
    MCPIndex["data/*-mcp-servers-index.yaml"] -->|input| Extractor

    %% Extractor fetches external data
    Extractor -->|"HTTPS/443<br/>OCI v2 API"| RedHatRegistry["registry.redhat.io"]
    Extractor -->|"HTTPS/443<br/>OCI v2 API"| AccessRegistry["registry.access.redhat.com"]
    Extractor -->|"HTTPS/443<br/>Bearer Token"| HuggingFace["huggingface.co API"]

    %% Extractor produces catalogs
    Extractor -->|generates| ModelsCatalog
    Extractor -->|generates| ValidatedCatalog
    Extractor -->|generates| OtherCatalog
    Extractor -->|generates| RHMCPCatalog
    Extractor -->|generates| PartnerMCPCatalog
    Extractor -->|generates| CommunityMCPCatalog

    %% Reporter reads catalogs
    ModelsCatalog -->|analyzed by| Reporter
    Reporter -->|produces| Reports["Completeness Reports<br/>(Markdown + YAML)"]

    %% Runtime consumers
    DataContainer -->|"volume mount<br/>/app/data"| Dashboard["RHOAI Dashboard"]
    Operator["rhods-operator"] -->|deploys| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Reporter fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style ModelsCatalog fill:#f5a623,stroke:#333
    style ValidatedCatalog fill:#f5a623,stroke:#333
    style OtherCatalog fill:#f5a623,stroke:#333
    style RHMCPCatalog fill:#f5a623,stroke:#333
    style PartnerMCPCatalog fill:#f5a623,stroke:#333
    style CommunityMCPCatalog fill:#f5a623,stroke:#333
    style RedHatRegistry fill:#e8e8e8,stroke:#333
    style AccessRegistry fill:#e8e8e8,stroke:#333
    style HuggingFace fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style ModelsIndex fill:#d4e6f1,stroke:#333
    style ValidatedIndex fill:#d4e6f1,stroke:#333
    style OtherIndex fill:#d4e6f1,stroke:#333
    style MCPIndex fill:#d4e6f1,stroke:#333
    style Reports fill:#d5f5e3,stroke:#333
