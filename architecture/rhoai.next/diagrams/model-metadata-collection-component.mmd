    style MetadataReport fill:#4a90e2,stroke:#333,color:#fff
    style DataVolume fill:#7ed321,stroke:#333
    style BenchmarkVolume fill:#7ed321,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style OCIRegistry fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
