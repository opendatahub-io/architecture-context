graph TB
    subgraph BuildPipeline["Model Metadata Collection (Build-Time Pipeline)"]
        direction TB

        subgraph Extractor["model-extractor (Go CLI)"]
            Discovery["Discovery<br/>HuggingFace Collections"]
            Extraction["OCI Extraction<br/>Model Card Layers"]
            Enrichment["Enrichment Engine<br/>Multi-Source Priority"]
            CatalogGen["Catalog Generator<br/>YAML Output"]
            MCPPipeline["MCP Server Pipeline<br/>OCI Enrichment"]
            FamilyGuard["Model Family Guard<br/>Cross-Family Prevention"]

            Discovery --> Enrichment
            Extraction --> Enrichment
            FamilyGuard -.->|validates| Enrichment
            Enrichment --> CatalogGen
        end

        subgraph Report["metadata-report (Go CLI)"]
            ReportGen["Report Generator<br/>Completeness & Provenance"]
        end
    end

    subgraph DataContainer["odh-model-metadata-collection (ubi9-minimal)"]
        CatalogData["/app/data/<br/>models-catalog.yaml<br/>mcp-servers-catalog.yaml"]
        SleepInfinity["sleep infinity<br/>(data sidecar)"]
    end

    %% Inputs
    ModelsIndex["data/models-index.yaml"] -->|input| Discovery
    SupplementalCatalog["input/supplemental-catalog.yaml"] -->|static entries| CatalogGen
    VLLMConfig["input/models/vllm-config/*.yaml"] -->|serving configs| Enrichment
    MCPIndex["data/redhat-mcp-servers-index.yaml"] -->|input| MCPPipeline
    MCPServerYAML["input/mcp_servers/**/*.yaml"] -->|server definitions| MCPPipeline

    %% External Data Sources
    HuggingFace["HuggingFace API<br/>huggingface.co"] -->|collections, models,<br/>README content| Discovery
    HuggingFace -->|metadata enrichment| Enrichment
    OCIRegistry["OCI Registry<br/>registry.redhat.io"] -->|model card layers,<br/>manifests, blobs| Extraction
    OCIRegistry -->|architecture, timestamps| MCPPipeline

    %% Build outputs
    CatalogGen -->|YAML files| CatalogData
    MCPPipeline -->|MCP catalog| CatalogData
    CatalogGen -->|catalog input| ReportGen

    %% Consumer
    CatalogData -->|volume mount<br/>/app/data| Dashboard["RHOAI Dashboard<br/>Model Catalog UI"]

    %% CI/CD
    Konflux["Konflux / Tekton<br/>CI/CD Pipeline"] -->|builds & pushes| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Report fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333
    style Konflux fill:#e8e8e8,stroke:#333
    style ModelsIndex fill:#fff2cc,stroke:#d6b656
    style SupplementalCatalog fill:#fff2cc,stroke:#d6b656
    style VLLMConfig fill:#fff2cc,stroke:#d6b656
    style MCPIndex fill:#fff2cc,stroke:#d6b656
    style MCPServerYAML fill:#fff2cc,stroke:#d6b656
