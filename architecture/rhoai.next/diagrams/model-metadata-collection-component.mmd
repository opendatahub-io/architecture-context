graph TB
    subgraph CICD["CI/CD Build Pipeline"]
        direction TB
        subgraph ExtractorTool["model-extractor (Go CLI)"]
            Extractor[model-extractor<br/>Go CLI Binary]
            IndexParser[Index Parser<br/>YAML Processing]
            Enrichment[Enrichment Engine<br/>Multi-Source Merge]
            CatalogGen[Catalog Generator<br/>YAML Output]
            MCPEnrich[MCP Enrichment<br/>OCI Metadata]
            Extractor --> IndexParser
            IndexParser --> Enrichment
            Enrichment --> CatalogGen
            IndexParser --> MCPEnrich
            MCPEnrich --> CatalogGen
        end

        subgraph ReportTool["metadata-report (Go CLI)"]
            Reporter[metadata-report<br/>Quality Analysis]
        end
    end

    subgraph DataContainer["odh-model-metadata-collection (UBI9-minimal)"]
        direction TB
        DataVolume["/app/data<br/>Catalog YAML Files"]
        ModelsCatalog["models-catalog.yaml"]
        ValidatedCatalog["validated-models-catalog.yaml"]
        OtherCatalog["other-models-catalog.yaml"]
        MCPCatalogs["*-mcp-servers-catalog.yaml"]
        DataVolume --- ModelsCatalog
        DataVolume --- ValidatedCatalog
        DataVolume --- OtherCatalog
        DataVolume --- MCPCatalogs
    end

    %% Input files
    ModelsIndex["data/models-index.yaml<br/>Model Definitions"]
    ValidatedIndex["data/validated-models-index.yaml"]
    OtherIndex["data/other-models-index.yaml"]
    MCPIndex["data/*-mcp-servers-index.yaml<br/>MCP Server Definitions"]
    VLLMConfig["input/models/vllm-config/<br/>vLLM Serving Presets"]

    %% External services
    HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS"]
    RedHatRegistry["registry.redhat.io<br/>OCI Registry v2<br/>443/TCP HTTPS"]
    AccessRegistry["registry.access.redhat.com<br/>OCI Registry v2<br/>443/TCP HTTPS"]

    %% Consumers
    Dashboard["RHOAI Dashboard<br/>Volume Mount Consumer"]
    Operator["rhods-operator<br/>Deployment Orchestrator"]

    %% Flows
    ModelsIndex -->|input| Extractor
    ValidatedIndex -->|input| Extractor
    OtherIndex -->|input| Extractor
    MCPIndex -->|input| Extractor
    VLLMConfig -->|input| Extractor

    Extractor -->|"HTTPS/443<br/>Bearer Token"| HuggingFace
    Extractor -->|"HTTPS/443<br/>OCI v2 API"| RedHatRegistry
    Extractor -->|"HTTPS/443<br/>OCI v2 API"| AccessRegistry

    CatalogGen -->|"generates"| DataVolume
    CatalogGen -->|"input"| Reporter

    DataVolume -->|"volume mount<br/>/app/data"| Dashboard
    Operator -->|"deploys"| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Reporter fill:#4a90e2,stroke:#333,color:#fff
    style DataVolume fill:#7ed321,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style RedHatRegistry fill:#f5a623,stroke:#333,color:#fff
    style AccessRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style ModelsIndex fill:#e8e8e8,stroke:#999
    style ValidatedIndex fill:#e8e8e8,stroke:#999
    style OtherIndex fill:#e8e8e8,stroke:#999
    style MCPIndex fill:#e8e8e8,stroke:#999
    style VLLMConfig fill:#e8e8e8,stroke:#999
