graph TB
    subgraph "model-metadata-collection Pipeline"
        direction TB

        subgraph "CI/CD Build Tools (not shipped)"
            Extractor["model-extractor<br/>(Go CLI Tool)<br/>Main pipeline orchestrator"]
            Reporter["metadata-report<br/>(Go CLI Tool)<br/>Completeness reporting"]
        end

        subgraph "Shipped Artifact"
            DataContainer["odh-model-metadata-collection<br/>(Data Container)<br/>ubi9-minimal + YAML files<br/>CMD: sleep infinity"]
            CatalogFiles["/app/data/*.yaml<br/>Model & MCP Server Catalogs"]
            DataContainer --- CatalogFiles
        end
    end

    subgraph "Input Sources"
        ModelsIndex["data/models-index.yaml<br/>Model definitions"]
        MCPIndex["data/redhat-mcp-servers-index.yaml<br/>MCP server definitions"]
        SupplementalCatalog["input/supplemental-catalog.yaml<br/>Manual curated entries"]
        VLLMConfig["input/models/vllm-config/<br/>Per-model vLLM presets"]
    end

    subgraph "External Services"
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS"]
        OCIRegistry["OCI Container Registries<br/>registry.redhat.io<br/>443/TCP HTTPS"]
    end

    subgraph "Consumers"
        Dashboard["RHOAI Dashboard<br/>Volume mount consumer"]
    end

    subgraph "Build Infrastructure"
        Konflux["Konflux CI/CD<br/>Tekton Pipelines"]
        GitHubCI["GitHub Actions CI<br/>Lint + Test + Build"]
        Quay["quay.io/opendatahub/<br/>odh-model-metadata-collection"]
    end

    %% Input flows
    ModelsIndex -->|reads| Extractor
    MCPIndex -->|reads| Extractor
    SupplementalCatalog -->|merges| Extractor
    VLLMConfig -->|reads| Extractor

    %% External API calls
    Extractor -->|fetch collections,<br/>model details, READMEs| HuggingFace
    Extractor -->|fetch manifests,<br/>layer blobs, modelcards| OCIRegistry

    %% Output generation
    Extractor -->|generates| CatalogFiles
    Extractor -->|enrichment data| Reporter
    Reporter -->|reads catalog| CatalogFiles

    %% Build pipeline
    CatalogFiles -->|COPY into| DataContainer
    Konflux -->|builds & publishes| Quay
    GitHubCI -->|builds & pushes| Quay

    %% Consumer
    DataContainer -->|volume mount<br/>/app/data/| Dashboard

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Reporter fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style CatalogFiles fill:#b8e986,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333
    style GitHubCI fill:#e8e8e8,stroke:#333
    style Quay fill:#e8e8e8,stroke:#333
    style ModelsIndex fill:#ddd,stroke:#333
    style MCPIndex fill:#ddd,stroke:#333
    style SupplementalCatalog fill:#ddd,stroke:#333
    style VLLMConfig fill:#ddd,stroke:#333
