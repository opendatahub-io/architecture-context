graph TB
    subgraph BuildTime["Build-Time Pipeline (CI/CD)"]
        direction TB
        ModelExtractor["model-extractor<br/>(Go CLI)"]
        MetadataReport["metadata-report<br/>(Go CLI)"]
        ModelExtractor -->|generates| CatalogFiles["Catalog YAML Files<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>mcp-servers-catalog.yaml"]
        ModelExtractor -->|generates| ExtractionOutput["Extraction Output<br/>output/"]
        ExtractionOutput -->|read by| MetadataReport
        MetadataReport -->|generates| Reports["Completeness Reports<br/>(markdown + YAML)"]
    end

    subgraph InputFiles["Input Sources"]
        ModelsIndex["validated-models-index.yaml<br/>(OCI image references)"]
        MCPIndex["redhat-mcp-servers-index.yaml<br/>(MCP server definitions)"]
        SupplementalCatalog["supplemental-catalog.yaml<br/>(Static overrides)"]
        MCPInputFiles["input/mcp_servers/<br/>(MCP YAML definitions)"]
    end

    subgraph ExternalAPIs["External APIs"]
        HuggingFace["HuggingFace API<br/>huggingface.co:443"]
        OCIRegistry["OCI Registry<br/>registry.redhat.io:443"]
    end

    subgraph DataContainer["odh-model-metadata-collection<br/>(ubi9-minimal container)"]
        DataVolume["/app/data/<br/>Pre-generated YAML catalogs"]
        BenchmarkVolume["/app/benchmarks/<br/>Sample benchmark data"]
    end

    subgraph Consumers["Platform Consumers"]
        Dashboard["RHOAI Dashboard"]
    end

    ModelsIndex -->|read by| ModelExtractor
    MCPIndex -->|read by| ModelExtractor
    SupplementalCatalog -->|read by| ModelExtractor
    MCPInputFiles -->|read by| ModelExtractor

    ModelExtractor -->|"HTTPS/443<br/>Bearer Token (optional)"| HuggingFace
    ModelExtractor -->|"HTTPS/443<br/>OCI Distribution v2"| OCIRegistry

    CatalogFiles -->|"copied into<br/>Dockerfile.konflux"| DataVolume

    Dashboard -->|"volume mount<br/>/app/data/"| DataVolume

    subgraph CI["CI/CD Systems"]
        Konflux["Konflux Build<br/>(Tekton Pipelines)"]
        GitHubActions["GitHub Actions<br/>(quay.io push)"]
    end

    CatalogFiles -->|built by| Konflux
    CatalogFiles -->|built by| GitHubActions

