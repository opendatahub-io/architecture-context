graph TB
    subgraph "Model Metadata Collection"
        direction TB
        subgraph "Build-Time Tools (CI/CD only)"
            Extractor["model-extractor<br/>(Go CLI)"]
            Report["metadata-report<br/>(Go CLI)"]
        end

        subgraph "Shipped Artifact"
            DataContainer["odh-model-metadata-collection<br/>(UBI9-minimal Data Container)<br/>Runs: sleep infinity"]
            subgraph "Data Files (/app/data)"
                ModelsCatalog["models-catalog.yaml"]
                ValidatedCatalog["validated-models-catalog.yaml"]
                OtherCatalog["other-models-catalog.yaml"]
                RHMCPCatalog["redhat-mcp-servers-catalog.yaml"]
                PartnerMCPCatalog["partner-mcp-servers-catalog.yaml"]
                CommunityMCPCatalog["community-mcp-servers-catalog.yaml"]
            end
        end
    end

    %% Input Files
    ModelsIndex["data/models-index.yaml<br/>data/validated-models-index.yaml<br/>data/other-models-index.yaml"]
    MCPIndex["data/*-mcp-servers-index.yaml"]
    VLLMConfig["input/models/vllm-config/*.yaml"]

    %% External Services (Build-Time)
    HF["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS"]
    RHIO["registry.redhat.io<br/>OCI Registry v2<br/>443/TCP HTTPS"]
    RHACCESS["registry.access.redhat.com<br/>OCI Registry v2<br/>443/TCP HTTPS"]

    %% Consumers
    Dashboard["RHOAI Dashboard<br/>(Volume Mount Consumer)"]
    Operator["rhods-operator<br/>(Deployment Orchestrator)"]

    %% Build-Time Flows
    ModelsIndex -->|reads| Extractor
    MCPIndex -->|reads| Extractor
    VLLMConfig -->|reads| Extractor
    Extractor -->|"HTTPS/443<br/>Bearer Token (optional)"| HF
    Extractor -->|"HTTPS/443<br/>OCI v2"| RHIO
    Extractor -->|"HTTPS/443<br/>OCI v2"| RHACCESS
    Extractor -->|generates| ModelsCatalog
    Extractor -->|generates| ValidatedCatalog
    Extractor -->|generates| OtherCatalog
    Extractor -->|generates| RHMCPCatalog
    Extractor -->|generates| PartnerMCPCatalog
    Extractor -->|generates| CommunityMCPCatalog
    Report -->|analyzes| ModelsCatalog

    %% Runtime Flows
    Dashboard -->|"volume mount<br/>/app/data"| DataContainer
    Operator -->|deploys| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Report fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style HF fill:#e8e8e8,stroke:#999
    style RHIO fill:#e8e8e8,stroke:#999
    style RHACCESS fill:#e8e8e8,stroke:#999
    style Dashboard fill:#f5a623,stroke:#333
    style Operator fill:#f5a623,stroke:#333
    style ModelsCatalog fill:#d5e8d4,stroke:#82b366
    style ValidatedCatalog fill:#d5e8d4,stroke:#82b366
    style OtherCatalog fill:#d5e8d4,stroke:#82b366
    style RHMCPCatalog fill:#d5e8d4,stroke:#82b366
    style PartnerMCPCatalog fill:#d5e8d4,stroke:#82b366
    style CommunityMCPCatalog fill:#d5e8d4,stroke:#82b366
