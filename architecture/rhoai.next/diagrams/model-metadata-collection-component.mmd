graph TB
    subgraph "Model Metadata Collection"
        subgraph "Build-Time CLI Tools"
            Extractor["model-extractor<br/>(Go CLI)"]
            Report["metadata-report<br/>(Go CLI)"]
        end

        subgraph "Shippable Artifact"
            DataContainer["odh-model-metadata-collection<br/>(ubi9-minimal Data Container)<br/>Runs: sleep infinity"]
            DataVolume["/app/data/<br/>Catalog YAML Files"]
            BenchmarkVolume["/app/benchmarks/<br/>Benchmark Data"]
            DataContainer --- DataVolume
            DataContainer --- BenchmarkVolume
        end
    end

    subgraph "Input Sources"
        ModelsIndex["data/models-index.yaml<br/>(Models Index)"]
        MCPIndex["data/redhat-mcp-servers-index.yaml<br/>(MCP Servers Index)"]
        SupplementalCatalog["input/supplemental-catalog.yaml"]
        MCPInputFiles["input/mcp_servers/<br/>(MCP Server YAML files)"]
    end

    subgraph "External APIs"
        HuggingFace["HuggingFace API<br/>(huggingface.co)<br/>443/TCP HTTPS"]
        OCIRegistry["OCI Container Registry<br/>(registry.redhat.io)<br/>443/TCP HTTPS"]
    end

    subgraph "Outputs"
        ModelsCatalog["data/models-catalog.yaml"]
        ValidatedCatalog["data/validated-models-catalog.yaml"]
        MCPCatalog["data/redhat-mcp-servers-catalog.yaml"]
        CompletionReport["Metadata Completeness<br/>Reports (MD + YAML)"]
    end

    subgraph "Consumers"
        Dashboard["RHOAI Dashboard<br/>(Volume Mount)"]
    end

    subgraph "CI/CD"
        Konflux["Konflux Build System<br/>(Tekton PipelineRun)"]
        GitHubActions["GitHub Actions CI"]
    end

    %% Build-time data flows
    ModelsIndex -->|reads| Extractor
    MCPIndex -->|reads| Extractor
    SupplementalCatalog -->|reads| Extractor
    MCPInputFiles -->|reads| Extractor
    Extractor -->|fetches model metadata| HuggingFace
    Extractor -->|fetches manifests & layers| OCIRegistry
    Extractor -->|generates| ModelsCatalog
    Extractor -->|generates| ValidatedCatalog
    Extractor -->|generates| MCPCatalog

    Report -->|reads| ModelsCatalog
    Report -->|generates| CompletionReport

    %% Container build
    ModelsCatalog -->|copied into| DataVolume
    ValidatedCatalog -->|copied into| DataVolume
    MCPCatalog -->|copied into| DataVolume

    %% Runtime consumption
    DataVolume -->|volume mount| Dashboard

    %% CI/CD
    Konflux -->|builds container image| DataContainer
    GitHubActions -->|lint, test, push| DataContainer

    %% Styling
    style Extractor fill:#4a90e2,stroke:#333,color:#fff
    style Report fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style DataVolume fill:#7ed321,stroke:#333,color:#fff
    style BenchmarkVolume fill:#7ed321,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#333
    style GitHubActions fill:#e8e8e8,stroke:#333
    style ModelsCatalog fill:#3498db,stroke:#333,color:#fff
    style ValidatedCatalog fill:#3498db,stroke:#333,color:#fff
    style MCPCatalog fill:#3498db,stroke:#333,color:#fff
