graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Kubernetes Gateway<br/>(AgentGW / Istio / KGW / GKE)<br/>80/TCP or 443/TCP<br/>TLS: Configurable"]
        HTTPRoute["HTTPRoute<br/>→ InferencePool backend"]
        Gateway --> HTTPRoute
    end

    subgraph RoutingLayer["ROUTING (EPP)"]
        EPP["llm-d-inference-scheduler<br/>(Endpoint Picker)<br/>9002/TCP gRPC ext-proc<br/>No encryption"]
        LatencyPred["Latency Predictor<br/>(XGBoost sidecar)"]
        KVIdx["KV-Cache Indexer<br/>(ZMQ events)"]
        EPP --- LatencyPred
        EPP --- KVIdx
    end

    subgraph ModelServing["MODEL SERVING (In-Cluster, No Auth)"]
        direction TB

        InfPool["InferencePool CR<br/>(inference.networking.k8s.io/v1)<br/>Pod selector endpoint discovery"]

        subgraph DecodeSG["Decode Pods"]
            Decode["Decode Pod<br/>SA: automountToken=false<br/>UID: 2000 (non-root)<br/>:8000/TCP HTTP (vLLM API)<br/>:8200/TCP HTTP (P/D sidecar)"]
        end

        subgraph PrefillSG["Prefill Pods (P/D mode)"]
            Prefill["Prefill Pod<br/>SA: automountToken=false<br/>UID: 2000 (non-root)<br/>:8000/TCP HTTP (vLLM API)<br/>:5600/TCP RDMA (NIXL KV)"]
        end

        InfPool --> Decode
        InfPool --> Prefill
    end

    subgraph Monitoring["MONITORING (In-Cluster)"]
        Prometheus["Prometheus<br/>(PodMonitor)<br/>Scrape /metrics :8000<br/>30s interval"]
        OTel["OTel Collector<br/>4317/TCP gRPC OTLP<br/>No encryption"]
        Grafana["Grafana<br/>9090/TCP HTTP<br/>vLLM dashboards"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        PyPI["PyPI / Package Indexes<br/>443/TCP HTTPS<br/>(build-time only)"]
        GitHub["GitHub / GHCR<br/>443/TCP HTTPS<br/>(build-time only)"]
    end

    %% Traffic flows
    Client -->|"HTTP/HTTPS<br/>80 or 443/TCP<br/>TLS: Configurable<br/>Auth: Configurable"| Gateway
    Gateway -->|"gRPC ext-proc<br/>9002/TCP<br/>No encryption<br/>No auth"| EPP
    EPP -->|"HTTP /metrics<br/>8000/TCP<br/>No encryption"| Decode
    HTTPRoute -->|"backend ref"| InfPool
    Gateway -->|"HTTP<br/>8000/TCP<br/>No encryption<br/>No auth"| Decode

    %% P/D disaggregation
    Decode <-->|"RDMA (IB/RoCE/EFA)<br/>5600/TCP<br/>No encryption (fabric)<br/>GPU-Direct KV transfer"| Prefill

    %% Monitoring
    Prometheus -->|"HTTP /metrics<br/>8000/TCP"| Decode
    Prometheus -->|"HTTP /metrics<br/>8000/TCP"| Prefill
    Decode -->|"gRPC OTLP<br/>4317/TCP"| OTel
    Prefill -->|"gRPC OTLP<br/>4317/TCP"| OTel
    Grafana -->|"HTTP<br/>9090/TCP"| Prometheus

    %% Egress
    Decode -->|"HTTPS<br/>443/TCP TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Prefill -->|"HTTPS<br/>443/TCP TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef routing fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef serving fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef crd fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway,HTTPRoute ingress
    class EPP,LatencyPred,KVIdx routing
    class Decode,Prefill,InfPool serving
    class Prometheus,OTel,Grafana monitoring
    class HFHub,PyPI,GitHub externalservice
