graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Kubernetes Gateway<br/>gateway.networking.k8s.io/v1<br/>80/TCP (HTTP) or 443/TCP (HTTPS)<br/>TLS varies by implementation<br/>Auth: None by default"]
        HTTPRoute["HTTPRoute<br/>Routes to InferencePool backends"]
    end

    subgraph Routing["ROUTING LAYER (Cluster-Internal)"]
        EPP["llm-d-router EPP<br/>Endpoint Picker<br/>ext-proc gRPC<br/>KV-cache-aware routing"]
    end

    subgraph ModelServing["MODEL SERVING (Cluster-Internal, No TLS, No Auth)"]
        direction TB

        subgraph PrefillPool["Prefill Pool (P/D Mode)"]
            PrefillServer["Prefill Model Server<br/>8000/TCP HTTP plaintext<br/>SA: automountToken=false"]
        end

        subgraph DecodePool["Decode Pool"]
            DecodeServer["Decode Model Server<br/>8000/TCP HTTP plaintext<br/>Endpoints: /v1/completions,<br/>/v1/chat/completions, /v1/models,<br/>/health, /metrics"]
        end

        NIXLTransfer["NIXL KV Transfer<br/>5600/TCP gRPC<br/>No TLS, No Auth<br/>+ RDMA data plane"]
    end

    subgraph KVCache["KV-CACHE OFFLOADING (Cluster-Internal, No TLS, No Auth)"]
        direction TB
        MooncakeMaster["Mooncake Master Store<br/>50051/TCP gRPC (metadata)<br/>8080/TCP HTTP (API)<br/>9003/TCP HTTP (metrics)<br/>All plaintext, no auth"]
        MooncakeClient["Mooncake Client DaemonSet<br/>50052/TCP gRPC<br/>+ RDMA inter-node<br/>Requires: rdma/ib devices"]
    end

    subgraph Observability["OBSERVABILITY (Cluster-Internal)"]
        Prometheus["Prometheus<br/>Scrapes 8000/TCP, 9003/TCP<br/>HTTP, no auth"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>No TLS"]
        Grafana["Grafana Dashboards"]
        Jaeger["Jaeger Trace UI"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF_TOKEN Bearer<br/>Secret: llm-d-hf-token"]
    end

    %% Flows with security annotations
    Client -->|"HTTP/HTTPS<br/>80 or 443/TCP<br/>TLS varies"| Gateway
    Gateway --> HTTPRoute
    HTTPRoute -->|"ext-proc gRPC<br/>No TLS (cluster-internal)"| EPP
    EPP -->|"HTTP 8000/TCP<br/>Plaintext, No Auth<br/>Metrics scrape + routing"| DecodeServer
    EPP -->|"HTTP 8000/TCP<br/>Plaintext, No Auth"| PrefillServer

    PrefillServer -->|"gRPC/RDMA 5600/TCP<br/>No TLS, No Auth"| NIXLTransfer
    NIXLTransfer -->|"gRPC/RDMA 5600/TCP<br/>No TLS, No Auth"| DecodeServer

    DecodeServer -->|"gRPC 50052/TCP<br/>No TLS, No Auth"| MooncakeClient
    MooncakeClient -->|"gRPC 50051/TCP<br/>No TLS, No Auth"| MooncakeMaster
    MooncakeClient -->|"RDMA<br/>No encryption"| MooncakeClient

    DecodeServer -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>HF_TOKEN Bearer"| HFHub
    PrefillServer -->|"HTTPS 443/TCP<br/>TLS 1.2+"| HFHub

    Prometheus -->|"HTTP 8000/TCP"| DecodeServer
    Prometheus -->|"HTTP 9003/TCP"| MooncakeMaster
    DecodeServer -->|"gRPC 4317/TCP"| OTEL
    OTEL --> Jaeger

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef routing fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef serving fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#000
    classDef kvcache fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000
    classDef observability fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class Client external
    class Gateway,HTTPRoute ingress
    class EPP routing
    class PrefillServer,DecodeServer,NIXLTransfer serving
    class MooncakeMaster,MooncakeClient kvcache
    class Prometheus,OTEL,Grafana,Jaeger observability
    class HFHub externalservice
