graph LR
    MLflow["MLflow Server<br/>(Flask + FastAPI)"]

    %% Internal RHOAI Dependencies
    MLflow -->|"deployed by<br/>Helm chart"| MLflowOperator["MLflow Operator"]
    MLflow -->|"HTTPRoute /mlflow<br/>443/TCP"| ODHGateway["ODH Data Science<br/>Gateway"]
    ODHDashboard["ODH Dashboard"] -->|"embeds UI<br/>iframe"| MLflow
    DSC["DataScienceCluster"] -->|"enables component<br/>CRD toggle"| MLflowOperator

    %% Kubernetes Platform Dependencies
    MLflow -->|"SelfSubjectAccessReview<br/>RBAC enforcement"| K8sAPI["Kubernetes API Server"]
    MLflow -->|"namespace list/watch<br/>workspace discovery"| K8sAPI
    MLflow -->|"MLflowConfig watch<br/>per-ns artifact config"| K8sAPI

    %% Data Store Dependencies
    MLflow -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL 13+"]
    MLflow -->|"artifact storage<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]

    %% AI Gateway Provider Dependencies
    MLflow -->|"chat completions<br/>443/TCP HTTPS"| OpenAI["OpenAI API"]
    MLflow -->|"messages API<br/>443/TCP HTTPS"| Anthropic["Anthropic API"]
    MLflow -->|"content generation<br/>443/TCP HTTPS"| Gemini["Google Gemini API"]
    MLflow -->|"chat completions<br/>443/TCP HTTPS"| Mistral["Mistral API"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrapes /metrics<br/>5000/TCP"| MLflow

    %% Client Integration
    MLflowSDK["MLflow SDK<br/>(Python client)"] -->|"REST API<br/>tracking & registry"| MLflow
    OTelCollector["OpenTelemetry<br/>Collectors"] -->|"OTLP/HTTP<br/>/v1/traces"| MLflow

    %% Build Dependencies (not runtime)
    MLflow -.->|"build-only"| Python["Python 3.12"]
    MLflow -.->|"build-only"| NodeJS["Node.js 20"]

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style MLflowOperator fill:#7ed321,stroke:#333,color:#fff
    style ODHGateway fill:#7ed321,stroke:#333,color:#fff
    style ODHDashboard fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff

    %% Platform
    style K8sAPI fill:#6c8ebf,stroke:#333,color:#fff

    %% External Services
    style PostgreSQL fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OpenAI fill:#f5a623,stroke:#333
    style Anthropic fill:#f5a623,stroke:#333
    style Gemini fill:#f5a623,stroke:#333
    style Mistral fill:#f5a623,stroke:#333

    %% Clients
    style MLflowSDK fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333

    %% Build
    style Python fill:#ddd,stroke:#999,stroke-dasharray: 5 5
    style NodeJS fill:#ddd,stroke:#999,stroke-dasharray: 5 5
