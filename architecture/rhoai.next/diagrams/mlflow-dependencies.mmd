graph LR
    MLflow["MLflow Server<br/>(Flask + FastAPI)"]

    %% Internal RHOAI Dependencies
    MLflow -->|"deploys via Helm"| MLflowOperator["MLflow Operator"]
    MLflow -->|"HTTPRoute /mlflow"| ODHGateway["ODH Gateway<br/>(Gateway API)"]
    MLflow -->|"iframe embed"| ODHDashboard["ODH Dashboard"]
    MLflow -->|"component toggle"| DSC["DataScienceCluster"]

    %% Kubernetes Platform Dependencies
    MLflow -->|"SelfSubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    MLflow -->|"namespace list/watch<br/>HTTPS/443"| K8sAPI
    MLflow -->|"MLflowConfig watch<br/>HTTPS/443"| K8sAPI

    %% Data Dependencies
    MLflow -->|"metadata store<br/>TCP/5432"| PostgreSQL["PostgreSQL 13+"]
    MLflow -->|"artifact storage<br/>HTTPS/443"| S3["S3-compatible Storage"]
    MLflow -.->|"alternative backend<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    MLflow -.->|"alternative backend<br/>HTTPS/443"| Azure["Azure Blob Storage"]

    %% AI Gateway LLM Providers
    MLflow -->|"chat completions<br/>HTTPS/443"| OpenAI["OpenAI API"]
    MLflow -->|"messages API<br/>HTTPS/443"| Anthropic["Anthropic API"]
    MLflow -->|"content generation<br/>HTTPS/443"| Gemini["Google Gemini API"]
    MLflow -->|"chat completions<br/>HTTPS/443"| Mistral["Mistral API"]

    %% Runtime Dependencies
    MLflow -->|"runtime"| Python["Python 3.12"]
    MLflow -->|"ORM"| SQLAlchemy["SQLAlchemy >=1.4, <3"]
    MLflow -->|"WSGI"| Flask["Flask <4"]
    MLflow -->|"ASGI"| FastAPI["FastAPI <1"]
    MLflow -->|"server"| Gunicorn["Gunicorn <26"]
    MLflow -->|"tracing"| OTelSDK["OpenTelemetry SDK"]
    MLflow -->|"crypto"| Cryptography["cryptography >=43, <47<br/>AES-256-GCM KEK"]
    MLflow -->|"migrations"| Alembic["Alembic <2"]

    %% Integration Points (reverse direction)
    MLflowSDK["MLflow SDK<br/>(Python/TS clients)"] -->|"REST API<br/>HTTP/5000"| MLflow
    OTelApp["OTel Instrumented Apps"] -->|"OTLP/HTTP<br/>HTTP/5000"| MLflow
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/5000"| MLflow

    %% CRD
    MLflowConfigCR["MLflowConfig CRD<br/>mlflow.kubeflow.org/v1alpha1"] -.->|"watched by"| MLflow

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style MLflowOperator fill:#7ed321,stroke:#333
    style ODHGateway fill:#7ed321,stroke:#333
    style ODHDashboard fill:#7ed321,stroke:#333
    style DSC fill:#7ed321,stroke:#333

    %% Kubernetes Platform
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff

    %% Data stores
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style S3 fill:#e8a838,stroke:#333
    style GCS fill:#e8a838,stroke:#333
    style Azure fill:#e8a838,stroke:#333

    %% LLM Providers
    style OpenAI fill:#d4a017,stroke:#333,color:#fff
    style Anthropic fill:#d4a017,stroke:#333,color:#fff
    style Gemini fill:#d4a017,stroke:#333,color:#fff
    style Mistral fill:#d4a017,stroke:#333,color:#fff

    %% Runtime
    style Python fill:#999,stroke:#333,color:#fff
    style SQLAlchemy fill:#999,stroke:#333,color:#fff
    style Flask fill:#999,stroke:#333,color:#fff
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Gunicorn fill:#999,stroke:#333,color:#fff
    style OTelSDK fill:#999,stroke:#333,color:#fff
    style Cryptography fill:#999,stroke:#333,color:#fff
    style Alembic fill:#999,stroke:#333,color:#fff

    %% Clients
    style MLflowSDK fill:#f5a623,stroke:#333
    style OTelApp fill:#f5a623,stroke:#333
    style Prometheus fill:#e6522c,stroke:#333,color:#fff

    %% CRD
    style MLflowConfigCR fill:#f5a623,stroke:#333
