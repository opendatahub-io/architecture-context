graph LR
    MLflow["MLflow Server<br/>(v3.10.1+rhaiv.3)"]

    %% External Dependencies (Required)
    MLflow -->|"REST framework"| Flask["Flask &lt;4"]
    MLflow -->|"async API"| FastAPI["FastAPI &lt;1"]
    MLflow -->|"database ORM"| SQLAlchemy["SQLAlchemy &ge;1.4, &lt;3"]
    MLflow -->|"schema migration"| Alembic["Alembic &lt;2"]
    MLflow -->|"WSGI server"| Gunicorn["Gunicorn &lt;26"]
    MLflow -->|"ASGI server"| Uvicorn["Uvicorn &lt;1"]
    MLflow -->|"task queue"| Huey["Huey &ge;2.5.4, &lt;3"]
    MLflow -->|"tracing"| OpenTelemetry["OpenTelemetry SDK &ge;1.9, &lt;3"]
    MLflow -->|"encryption"| Cryptography["cryptography &ge;43, &lt;47"]

    %% Database Backends
    MLflow -->|"metadata store<br/>5432/TCP"| PostgreSQL["PostgreSQL 9.6+"]
    MLflow -->|"PG driver"| Psycopg2["psycopg2"]

    %% Artifact Storage Backends
    MLflow -->|"artifact storage<br/>443/TCP"| S3["S3 / MinIO"]
    MLflow -->|"artifact storage<br/>443/TCP"| AzureBlob["Azure Blob Storage"]
    MLflow -->|"artifact storage<br/>443/TCP"| GCS["Google Cloud Storage"]

    %% Internal RHOAI Dependencies
    MLflow -->|"auth proxy<br/>8443 → 5000"| KubeRBACProxy["kube-rbac-proxy"]
    MLflow -->|"K8s auth + jobs<br/>443/TCP"| K8sAPI["Kubernetes API"]

    %% Integration Points (inbound)
    Dashboard["RHOAI Dashboard"] -->|"Module Federation<br/>loads remoteEntry.js"| MLflow
    Prometheus["Prometheus"] -->|"metrics scrape<br/>5000/TCP"| MLflow
    OTelSDK["OpenTelemetry SDK<br/>(applications)"] -->|"OTLP traces<br/>5000/TCP"| MLflow

    %% AI Gateway Providers
    MLflow -->|"LLM proxy<br/>443/TCP"| OpenAI["OpenAI API"]
    MLflow -->|"LLM proxy<br/>443/TCP"| Anthropic["Anthropic API"]
    MLflow -->|"LLM proxy<br/>443/TCP"| Gemini["Google Gemini API"]
    MLflow -->|"LLM proxy<br/>443/TCP"| Mistral["Mistral API"]
    MLflow -.->|"LLM fallback<br/>443/TCP"| LiteLLM["LiteLLM"]

