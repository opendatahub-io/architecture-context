graph LR
    MLflow["MLflow Server<br/>v3.10.1+rhaiv.3"]

    %% Internal RHOAI Dependencies
    MLflow -->|"deployed by<br/>Helm chart"| MLflowOperator["MLflow Operator"]
    MLflow -->|"HTTPRoute /mlflow<br/>HTTPS/443"| ODHGateway["ODH Gateway"]
    MLflow -->|"embedded iframe<br/>HTTPS/443"| ODHDashboard["ODH Dashboard"]
    MLflow -.->|"enabled via<br/>component toggle"| DSC["DataScienceCluster"]

    %% Kubernetes Dependencies
    MLflow -->|"SelfSubjectAccessReview<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    MLflow -->|"namespace list/watch<br/>HTTPS/443"| K8sAPI
    MLflow -->|"MLflowConfig CRD<br/>get/watch"| K8sAPI

    %% Data Store Dependencies
    MLflow -->|"metadata persistence<br/>TCP/5432"| PostgreSQL["PostgreSQL 13+"]
    MLflow -->|"artifact storage<br/>HTTPS/443"| S3["S3-compatible Storage"]
    MLflow -.->|"alternative backend"| GCS["Google Cloud Storage"]
    MLflow -.->|"alternative backend"| Azure["Azure Blob Storage"]

    %% AI Gateway Provider Dependencies
    MLflow -->|"chat completions<br/>HTTPS/443"| OpenAI["OpenAI API"]
    MLflow -->|"messages API<br/>HTTPS/443"| Anthropic["Anthropic API"]
    MLflow -->|"content generation<br/>HTTPS/443"| Gemini["Google Gemini API"]
    MLflow -->|"chat completions<br/>HTTPS/443"| Mistral["Mistral API"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>HTTP/5000"| MLflow

    %% Client integrations
    MLflowSDK["MLflow SDK<br/>(Python client)"] -->|"REST API<br/>HTTP/5000"| MLflow
    OTELCollector["OpenTelemetry<br/>Collectors"] -->|"OTLP/HTTP<br/>HTTP/5000"| MLflow

    %% Runtime Dependencies
    MLflow -->|"WSGI framework"| Flask["Flask <4"]
    MLflow -->|"ASGI framework"| FastAPI["FastAPI <1"]
    MLflow -->|"ORM"| SQLAlchemy["SQLAlchemy >=1.4, <3"]
    MLflow -->|"crypto (KEK)"| Cryptography["cryptography >=43, <47"]
    MLflow -->|"tracing"| OpenTelemetry["OpenTelemetry SDK >=1.9, <3"]

    %% CRD
    MLflowConfigCR["MLflowConfig CRD<br/>mlflow.kubeflow.org/v1alpha1"] -.->|"per-namespace<br/>artifact overrides"| MLflow

