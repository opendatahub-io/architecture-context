graph LR
    MLflow["MLflow<br/>v3.13.0<br/>Python Service"]

    %% External Runtime Dependencies
    subgraph ExternalDeps["External Dependencies"]
        PostgreSQL["PostgreSQL 13+<br/>(recommended)"]
        SQLite["SQLite 3.34+<br/>(default)"]
        S3["S3-Compatible Storage<br/>(AWS S3 / MinIO / Ceph)"]
        Python["Python 3.12"]
        OpenSSL["OpenSSL<br/>(from UBI9)"]
    end

    MLflow -->|"SQL/5432/TCP<br/>metadata store"| PostgreSQL
    MLflow -->|"file I/O<br/>default backend"| SQLite
    MLflow -->|"HTTPS/443<br/>artifact storage"| S3
    MLflow -->|"runtime"| Python
    MLflow -->|"crypto backend"| OpenSSL

    %% Python Framework Dependencies
    subgraph Frameworks["Python Frameworks"]
        Flask["Flask <4<br/>WSGI framework"]
        FastAPI["FastAPI <1<br/>ASGI framework"]
        Uvicorn["Uvicorn <1<br/>ASGI server"]
        SQLAlchemy["SQLAlchemy >=1.4, <3<br/>ORM"]
        Alembic["Alembic <2<br/>DB migrations"]
    end

    MLflow -->|"web server"| Flask
    MLflow -->|"async routes"| FastAPI
    MLflow -->|"ASGI server<br/>4 workers"| Uvicorn
    MLflow -->|"DB access"| SQLAlchemy
    MLflow -->|"schema mgmt"| Alembic

    %% Security Dependencies
    subgraph SecurityDeps["Security Libraries"]
        Cryptography["pyca/cryptography >=43, <49<br/>AES-256-GCM, PBKDF2"]
        OTelSDK["OpenTelemetry SDK >=1.9, <3<br/>distributed tracing"]
        PromExporter["prometheus-flask-exporter 0.23.2<br/>metrics"]
    end

    MLflow -->|"envelope encryption"| Cryptography
    MLflow -->|"trace ingestion"| OTelSDK
    MLflow -->|"metrics endpoint"| PromExporter

    %% Internal Platform Dependencies
    subgraph InternalDeps["Internal Platform Dependencies"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
        RHOAIPlatform["RHOAI Platform<br/>Helm deployment"]
        Cachi2["Cachi2 / Hermeto<br/>build-time prefetch"]
        AIPCCIndex["AIPCC Python Index<br/>rhoai/3.4/cpu-ubi9"]
    end

    MLflow -->|"SA token<br/>workspace resolution"| K8sAPI
    RHOAIPlatform -->|"deploys via Helm"| MLflow
    Cachi2 -.->|"hermetic builds"| MLflow
    AIPCCIndex -.->|"~150+ packages"| MLflow

    %% LLM Provider Dependencies (AI Gateway)
    subgraph LLMProviders["LLM Providers (AI Gateway)"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS"]
        Anthropic["Anthropic API<br/>443/TCP HTTPS"]
        Bedrock["Amazon Bedrock<br/>443/TCP HTTPS"]
        Gemini["Google Gemini/Vertex AI<br/>443/TCP HTTPS"]
        Mistral["Mistral API<br/>443/TCP HTTPS"]
        LiteLLM["LiteLLM<br/>API standardization"]
    end

    MLflow -->|"proxy calls"| OpenAI
    MLflow -->|"proxy calls"| Anthropic
    MLflow -->|"proxy calls"| Bedrock
    MLflow -->|"proxy calls"| Gemini
    MLflow -->|"proxy calls"| Mistral
    MLflow -->|"abstraction layer"| LiteLLM

    %% Integration Points (consumers)
    subgraph Consumers["Consumers / Integrations"]
        Prometheus["Prometheus<br/>HTTP scrape /metrics"]
        Konflux["Konflux / Tekton<br/>CI/CD pipeline"]
    end

    Prometheus -.->|"scrapes metrics"| MLflow
    Konflux -.->|"builds image"| MLflow

