graph LR
    MLflow["MLflow Server<br/>(v3.10.1+rhaiv.3)"]

    %% Runtime Dependencies
    MLflow -->|"runtime"| Python["Python >=3.10"]
    MLflow -->|"WSGI server"| Flask["Flask <4"]
    MLflow -->|"ASGI server"| FastAPI["FastAPI <1"]
    MLflow -->|"production server"| Gunicorn["Gunicorn <26"]
    MLflow -->|"ASGI server"| Uvicorn["Uvicorn <1"]
    MLflow -->|"ORM"| SQLAlchemy["SQLAlchemy >=1.4, <3"]
    MLflow -->|"migrations"| Alembic["Alembic <2"]
    MLflow -->|"task queue"| Huey["Huey >=2.5.4, <3"]
    MLflow -->|"tracing"| OTEL["OpenTelemetry SDK<br/>>=1.9.0, <3"]
    MLflow -->|"encryption"| Crypto["cryptography<br/>>=43.0.0, <47"]

    %% Database Backend (required)
    MLflow -->|"metadata store<br/>5432/TCP TLS 1.2+"| PostgreSQL["PostgreSQL 9.6+"]
    MLflow -->|"DB driver"| Psycopg2["psycopg2"]

    %% Alternative Databases (optional)
    MLflow -.->|"dev only"| SQLite["SQLite 3.31.0+"]
    MLflow -.->|"alternative"| MySQL["MySQL 5.7+"]

    %% Artifact Storage
    MLflow -->|"artifact storage<br/>443/TCP HTTPS"| S3["S3 / MinIO"]
    MLflow -.->|"artifact storage<br/>443/TCP HTTPS"| Azure["Azure Blob Storage"]
    MLflow -.->|"artifact storage<br/>443/TCP HTTPS"| GCS["Google Cloud Storage<br/>>=1.30.0"]

    %% Internal Platform Dependencies
    MLflow -->|"auth proxy<br/>8443→5000/TCP"| KubeRBAC["kube-rbac-proxy<br/>(Sidecar)"]
    MLflow -->|"K8s integration<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    MLflow -.->|"K8s client"| K8sClient["Kubernetes Python Client"]

    %% AI Gateway Providers
    MLflow -.->|"LLM proxy<br/>443/TCP HTTPS"| OpenAI["OpenAI API"]
    MLflow -.->|"LLM proxy<br/>443/TCP HTTPS"| Anthropic["Anthropic API"]
    MLflow -.->|"LLM proxy<br/>443/TCP HTTPS"| Gemini["Google Gemini API"]
    MLflow -.->|"LLM proxy<br/>443/TCP HTTPS"| Mistral["Mistral API"]
    MLflow -.->|"LLM proxy<br/>443/TCP HTTPS"| LiteLLM["LiteLLM"]

    %% Integration Points (inbound)
    Dashboard["RHOAI Dashboard"] -->|"Module Federation<br/>loads remoteEntry.js"| MLflow
    OTELApps["OTEL-instrumented Apps"] -->|"OTLP traces<br/>/v1/traces"| MLflow
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP/5000"| MLflow

    %% Monitoring (optional)
    MLflow -.->|"metrics"| PromExporter["prometheus-flask-exporter"]

