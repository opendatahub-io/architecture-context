graph LR
    MLflow["MLflow Server<br/>(FastAPI + Flask)"]

    %% Internal RHOAI Dependencies
    MLflow -->|"deploys via Helm chart"| MLflowOperator["MLflow Operator"]
    MLflow -->|"HTTPRoute /mlflow ingress"| ODHGateway["ODH Data Science<br/>Gateway"]
    ODHDashboard["ODH Dashboard"] -->|"Module Federation<br/>embeds UI"| MLflow

    %% Platform Dependencies
    MLflow -->|"SelfSubjectAccessReview<br/>Namespace list/watch<br/>MLflowConfig get"| K8sAPI["Kubernetes<br/>API Server"]
    MLflow -->|"metadata storage<br/>SQL/5432"| PostgreSQL["PostgreSQL"]

    %% External Dependencies
    MLflow -->|"artifact storage<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]

    %% AI Gateway Dependencies (disabled by default)
    MLflow -.->|"LLM routing<br/>HTTPS/443"| OpenAI["OpenAI API"]
    MLflow -.->|"LLM routing<br/>HTTPS/443"| Anthropic["Anthropic API"]
    MLflow -.->|"LLM routing<br/>HTTPS/443"| Gemini["Google Gemini API"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrapes /metrics<br/>HTTP/5000"| MLflow

    %% Runtime Dependencies (Libraries)
    subgraph RuntimeDeps["Key Runtime Dependencies"]
        Python312["Python 3.12"]
        FastAPI_Lib["FastAPI <1"]
        Flask_Lib["Flask <4"]
        SQLAlchemy_Lib["SQLAlchemy <3"]
        Alembic_Lib["Alembic <2"]
        Crypto_Lib["cryptography >=43"]
        K8sPlugins["mlflow-kubernetes-<br/>plugins 1.1.1"]
        OTelSDK["OpenTelemetry<br/>SDK <3"]
    end

    MLflow -->|"runtime"| Python312
    MLflow -->|"ASGI framework"| FastAPI_Lib
    MLflow -->|"WSGI framework"| Flask_Lib
    MLflow -->|"ORM"| SQLAlchemy_Lib
    MLflow -->|"migrations"| Alembic_Lib
    MLflow -->|"AES-256-GCM"| Crypto_Lib
    MLflow -->|"auth + workspace"| K8sPlugins
    MLflow -->|"tracing"| OTelSDK

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style MLflowOperator fill:#7ed321,stroke:#333,color:#fff
    style ODHGateway fill:#7ed321,stroke:#333,color:#fff
    style ODHDashboard fill:#7ed321,stroke:#333,color:#fff

    style K8sAPI fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#4a90e2,stroke:#333,color:#fff

    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OpenAI fill:#f5a623,stroke:#333,color:#fff
    style Anthropic fill:#f5a623,stroke:#333,color:#fff
    style Gemini fill:#f5a623,stroke:#333,color:#fff

    style Prometheus fill:#9673a6,stroke:#333,color:#fff

    style RuntimeDeps fill:#f0f0f0,stroke:#ccc
    style Python312 fill:#fff,stroke:#666
    style FastAPI_Lib fill:#fff,stroke:#666
    style Flask_Lib fill:#fff,stroke:#666
    style SQLAlchemy_Lib fill:#fff,stroke:#666
    style Alembic_Lib fill:#fff,stroke:#666
    style Crypto_Lib fill:#fff,stroke:#666
    style K8sPlugins fill:#fff,stroke:#666
    style OTelSDK fill:#fff,stroke:#666
