graph LR
    MLflow[MLflow Server]

    %% External Dependencies (Required)
    MLflow -->|"metadata store<br/>5432/TCP"| PostgreSQL[PostgreSQL 13+<br/>Required]

    %% External Dependencies (Optional)
    MLflow -.->|"alt metadata store<br/>3306/TCP"| MySQL[MySQL 5.7+]
    MLflow -.->|"dev only"| SQLite[SQLite 3.x]
    MLflow -->|"artifact storage<br/>443/9000 TCP"| S3[S3/MinIO Storage]
    MLflow -.->|"artifact storage"| GCS[Google Cloud Storage]
    MLflow -.->|"artifact storage"| AzureBlob[Azure Blob Storage]
    MLflow -.->|"artifact storage"| HDFS[HDFS]
    MLflow -.->|"trace export"| OTelCollector[OpenTelemetry Collector]

    %% Internal Platform Dependencies
    MLflow -->|"RBAC + namespaces<br/>6443/TCP HTTPS"| K8sAPI[Kubernetes API Server]
    Operator[MLflow Operator] -->|"deploys via Helm"| MLflow
    DSC[DataScienceCluster] -->|"enables component"| Operator
    Gateway[ODH Data Science Gateway] -->|"HTTPRoute /mlflow<br/>443/TCP HTTPS"| MLflow

    %% Integration Points (consumers of MLflow)
    Dashboard[ODH Dashboard] -->|"embeds UI views<br/>443/TCP HTTPS"| MLflow
    Prometheus[Prometheus] -->|"scrapes /metrics<br/>5000/TCP"| MLflow

    %% External Service Integrations
    MLflow -->|"AI gateway proxy<br/>443/TCP HTTPS"| LLMProviders[External LLM Providers<br/>OpenAI, Anthropic, etc.]
    MLflow -->|"model download<br/>443/TCP HTTPS"| HuggingFace[HuggingFace Hub]

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style PostgreSQL fill:#336791,stroke:#333,color:#fff

    %% Optional external
    style MySQL fill:#999,stroke:#333,color:#fff
    style SQLite fill:#999,stroke:#333,color:#fff
    style S3 fill:#e47911,stroke:#333,color:#fff
    style GCS fill:#999,stroke:#333,color:#fff
    style AzureBlob fill:#999,stroke:#333,color:#fff
    style HDFS fill:#999,stroke:#333,color:#fff
    style OTelCollector fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
    style DSC fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#e6522c,stroke:#333,color:#fff

    %% External services
    style LLMProviders fill:#f5a623,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
