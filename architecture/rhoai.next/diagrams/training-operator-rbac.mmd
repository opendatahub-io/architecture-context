graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op["training-operator<br/>(opendatahub namespace)"]
        SA_MPI["{jobName}-launcher<br/>(per MPI job, job namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Op["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Webhook["training-operator-webhook<br/>(operator namespace)"]
        RB_MPI["{jobName}-launcher<br/>(per MPI job, job namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Op["training-operator<br/>(ClusterRole)"]
        CR_Edit["training-edit<br/>(aggregate-to-edit/admin, RHOAI)"]
        CR_View["training-view<br/>(aggregate-to-view, RHOAI)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Webhook["training-operator-webhook<br/>(operator namespace)"]
        R_MPI["{jobName}-launcher<br/>(job namespace)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods"]
        PodsExec["core<br/>pods/exec"]
        Services["core<br/>services"]
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        SvcAccounts["core<br/>serviceaccounts"]
        Events["core<br/>events"]
    end

    subgraph TrainingCRDs["kubeflow.org Resources"]
        PyTorchJobs["pytorchjobs<br/>+ /finalizers + /status"]
        TFJobs["tfjobs<br/>+ /finalizers + /status"]
        MPIJobs["mpijobs<br/>+ /finalizers + /status"]
        JAXJobs["jaxjobs<br/>+ /finalizers + /status"]
        XGBoostJobs["xgboostjobs<br/>+ /finalizers + /status"]
        PaddleJobs["paddlejobs<br/>+ /finalizers + /status"]
    end

    subgraph OtherResources["Other API Resources"]
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
        HPA["autoscaling<br/>horizontalpodautoscalers"]
        RBACRes["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        SchedPluginsPG["scheduling.x-k8s.io<br/>podgroups"]
        NetPol["networking.k8s.io<br/>networkpolicies"]
    end

    %% Operator SA bindings
    SA_Op -->|"bound via"| CRB_Op
    CRB_Op -->|"grants"| CR_Op
    SA_Op -->|"bound via"| RB_Webhook
    RB_Webhook -->|"grants"| R_Webhook

    %% MPI SA bindings
    SA_MPI -->|"bound via"| RB_MPI
    RB_MPI -->|"grants"| R_MPI

    %% ClusterRole permissions - core
    CR_Op -->|"create,list,update,watch"| ConfigMaps
    CR_Op -->|"all verbs"| Events
    CR_Op -->|"all verbs"| Pods
    CR_Op -->|"create"| PodsExec
    CR_Op -->|"create,get,list,watch"| SvcAccounts
    CR_Op -->|"create,delete,get,list,watch"| Services
    CR_Op -->|"get,list,update,watch"| Secrets

    %% ClusterRole permissions - training CRDs
    CR_Op -->|"all verbs"| PyTorchJobs
    CR_Op -->|"all verbs"| TFJobs
    CR_Op -->|"all verbs"| MPIJobs
    CR_Op -->|"all verbs"| JAXJobs
    CR_Op -->|"all verbs"| XGBoostJobs
    CR_Op -->|"all verbs"| PaddleJobs

    %% ClusterRole permissions - other
    CR_Op -->|"get,list,update,watch"| Webhooks
    CR_Op -->|"all verbs"| HPA
    CR_Op -->|"create,list,update,watch"| RBACRes
    CR_Op -->|"all verbs"| VolcanoPG
    CR_Op -->|"all verbs"| SchedPluginsPG
    CR_Op -->|"all verbs"| NetPol

    %% Aggregate roles
    CR_Edit -->|"all verbs"| TrainingCRDs
    CR_View -->|"get,list,watch"| TrainingCRDs

    %% MPI role
    R_MPI -->|"create (pods/exec)<br/>on specific pod names"| PodsExec

    %% Webhook role
    R_Webhook -->|"get,update"| Secrets

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,color:#fff
    style SA_MPI fill:#4a90e2,stroke:#333,color:#fff
    style CR_Op fill:#f5a623,stroke:#333,color:#000
    style CR_Edit fill:#f5a623,stroke:#333,color:#000
    style CR_View fill:#f5a623,stroke:#333,color:#000
