graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["training-operator<br/>(opendatahub namespace)"]
        SA_Launcher["{mpiJob}-launcher<br/>(job namespace, dynamic)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Operator["training-operator<br/>(Cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Webhook["training-operator-webhook<br/>(operator namespace)"]
        RB_Launcher["{mpiJob}-launcher<br/>(job namespace, dynamic)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Operator["training-operator"]
        CR_Edit["training-edit<br/>(aggregated → admin/edit)"]
        CR_View["training-view<br/>(aggregated → view)"]
    end

    subgraph Roles["Roles"]
        R_Webhook["training-operator-webhook<br/>(operator namespace)"]
        R_Launcher["{mpiJob}-launcher<br/>(job namespace, dynamic)"]
    end

    %% Bindings
    SA_Operator -->|"bound via"| CRB_Operator
    CRB_Operator -->|"grants"| CR_Operator

    SA_Operator -->|"bound via"| RB_Webhook
    RB_Webhook -->|"grants"| R_Webhook

    SA_Launcher -->|"bound via"| RB_Launcher
    RB_Launcher -->|"grants"| R_Launcher

    %% ClusterRole: training-operator → Resources
    subgraph CoreResources["Core API Resources"]
        Pods["pods<br/>get,list,watch,<br/>create,update,patch,delete"]
        PodsExec["pods/exec<br/>create"]
        Services["services<br/>get,list,watch,<br/>create,delete"]
        Events["events<br/>get,list,watch,<br/>create,update,patch,delete"]
        ConfigMaps["configmaps<br/>create,list,update,watch"]
        ServiceAccounts["serviceaccounts<br/>get,list,watch,create"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        PyTorchJobs["pytorchjobs<br/>/status /finalizers<br/>full CRUD"]
        TFJobs["tfjobs<br/>/status /finalizers<br/>full CRUD"]
        XGBoostJobs["xgboostjobs<br/>/status /finalizers<br/>full CRUD"]
        MPIJobs["mpijobs<br/>/status /finalizers<br/>full CRUD"]
        PaddleJobs["paddlejobs<br/>/status /finalizers<br/>full CRUD"]
        JAXJobs["jaxjobs<br/>/status /finalizers<br/>full CRUD"]
    end

    subgraph OtherResources["Other API Resources"]
        RBAC_Res["roles, rolebindings<br/>(rbac.authorization.k8s.io)<br/>create,list,update,watch"]
        HPA["horizontalpodautoscalers<br/>(autoscaling)<br/>full CRUD"]
        VolcanoPG["podgroups<br/>(scheduling.volcano.sh)<br/>full CRUD"]
        SchedPG["podgroups<br/>(scheduling.x-k8s.io)<br/>full CRUD"]
        WebhookCfg["validatingwebhookconfigurations<br/>(admissionregistration)<br/>get,list,watch,update"]
        NetPol["networkpolicies<br/>(networking.k8s.io)<br/>full CRUD"]
    end

    CR_Operator -->|"grants access to"| CoreResources
    CR_Operator -->|"grants access to"| KubeflowResources
    CR_Operator -->|"grants access to"| OtherResources

    %% Aggregated roles
    subgraph AggregatedResources["Aggregated Training Resources"]
        TrainingCRDs["mpijobs, tfjobs, pytorchjobs,<br/>mxjobs, xgboostjobs, paddlejobs"]
    end

    CR_Edit -->|"create,delete,get,list,<br/>patch,update,watch"| TrainingCRDs
    CR_View -->|"get,list,watch"| TrainingCRDs

    %% Webhook role
    subgraph WebhookResources["Webhook Secret Access"]
        WebhookSecret["secrets<br/>(training-operator-webhook-cert)<br/>get,list,watch,update,create"]
    end

    R_Webhook -->|"grants access to"| WebhookResources

    %% MPI Launcher role
    subgraph LauncherResources["MPI Launcher Access"]
        LauncherPods["pods<br/>get,list,watch"]
        LauncherExec["pods/exec<br/>create"]
    end

    R_Launcher -->|"grants access to"| LauncherResources

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_Launcher fill:#4a90e2,stroke:#333,color:#fff
    style CR_Operator fill:#f5a623,stroke:#333
    style CR_Edit fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style R_Webhook fill:#e8a838,stroke:#333
    style R_Launcher fill:#e8a838,stroke:#333
    style CRB_Operator fill:#9b59b6,stroke:#333,color:#fff
    style RB_Webhook fill:#9b59b6,stroke:#333,color:#fff
    style RB_Launcher fill:#9b59b6,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style PyTorchJobs fill:#7ed321,stroke:#333
    style TFJobs fill:#7ed321,stroke:#333
    style XGBoostJobs fill:#7ed321,stroke:#333
    style MPIJobs fill:#7ed321,stroke:#333
    style PaddleJobs fill:#7ed321,stroke:#333
    style JAXJobs fill:#7ed321,stroke:#333
    style RBAC_Res fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style VolcanoPG fill:#7ed321,stroke:#333
    style SchedPG fill:#7ed321,stroke:#333
    style WebhookCfg fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style TrainingCRDs fill:#7ed321,stroke:#333
