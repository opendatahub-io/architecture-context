graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>Namespace: opendatahub"]
        MPIJobSA["Per-MPIJob SA<br/>Namespace: {user-ns}<br/>(dynamically created)"]
    end

    subgraph ClusterBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph NamespaceBindings["Namespace Role Bindings"]
        WebhookRB["training-operator-webhook<br/>(RoleBinding, operator namespace)"]
        MPIJobRB["Per-MPIJob RoleBinding<br/>(user namespace, dynamic)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["training-operator<br/>(ClusterRole)"]
        CR_Edit["kubeflow-training-edit<br/>(aggregates to admin/edit)"]
        CR_View["kubeflow-training-view<br/>(aggregates to view)"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        WebhookRole["training-operator-webhook<br/>(Role, operator namespace)"]
        MPIJobRole["Per-MPIJob Role<br/>(user namespace, dynamic)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods<br/>create, delete, get, list,<br/>patch, update, watch"]
        PodsExec["core<br/>pods/exec<br/>create"]
        Services["core<br/>services<br/>create, delete, get,<br/>list, watch"]
        ConfigMaps["core<br/>configmaps<br/>create, list,<br/>update, watch"]
        Events["core<br/>events<br/>create, delete, get, list,<br/>patch, update, watch"]
        ServiceAccounts_R["core<br/>serviceaccounts<br/>create, get,<br/>list, watch"]
    end

    subgraph KubeflowResources["Kubeflow API Resources (kubeflow.org)"]
        TrainingJobs["pytorchjobs, tfjobs,<br/>mpijobs, xgboostjobs,<br/>paddlejobs, jaxjobs<br/>create, delete, get, list,<br/>patch, update, watch"]
        Finalizers["*/finalizers<br/>update"]
        Status["*/status<br/>get, patch, update"]
    end

    subgraph AdmissionResources["Admission Resources"]
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get, list, update, watch"]
    end

    subgraph AutoscalingResources["Autoscaling Resources"]
        HPA["autoscaling<br/>horizontalpodautoscalers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph RBACResources["RBAC Resources"]
        Roles["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>create, list,<br/>update, watch"]
    end

    subgraph SchedulingResources["Scheduling Resources"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups<br/>create, delete, get, list,<br/>patch, update, watch"]
        SchedPG["scheduling.x-k8s.io<br/>podgroups<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph NetworkResources["Network Resources"]
        NetPol["networking.k8s.io<br/>networkpolicies<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph SecretResources["Secret Resources (Namespace-scoped)"]
        WebhookSecrets["core<br/>secrets<br/>get, list, update, watch<br/>(webhook cert only)"]
    end

    subgraph MPIResources["MPI Per-Job Resources"]
        MPIPodExec["core<br/>pods/exec<br/>create<br/>(launcher → workers)"]
    end

    %% SA → Binding → Role → Resources
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR_Main
    SA -->|"bound via"| WebhookRB
    WebhookRB -->|"grants"| WebhookRole

    CR_Main -->|"allows"| Pods
    CR_Main -->|"allows"| PodsExec
    CR_Main -->|"allows"| Services
    CR_Main -->|"allows"| ConfigMaps
    CR_Main -->|"allows"| Events
    CR_Main -->|"allows"| ServiceAccounts_R
    CR_Main -->|"allows"| TrainingJobs
    CR_Main -->|"allows"| Finalizers
    CR_Main -->|"allows"| Status
    CR_Main -->|"allows"| Webhooks
    CR_Main -->|"allows"| HPA
    CR_Main -->|"allows"| Roles
    CR_Main -->|"allows"| VolcanoPG
    CR_Main -->|"allows"| SchedPG
    CR_Main -->|"allows"| NetPol

    WebhookRole -->|"allows"| WebhookSecrets

    %% MPI per-job RBAC
    MPIJobSA -->|"bound via"| MPIJobRB
    MPIJobRB -->|"grants"| MPIJobRole
    MPIJobRole -->|"allows"| MPIPodExec

    %% Aggregated roles (RHOAI)
    CR_Edit -->|"kubeflow.org all jobs<br/>full CRUD"| TrainingJobs
    CR_View -->|"kubeflow.org all jobs<br/>get, list, watch"| TrainingJobs

