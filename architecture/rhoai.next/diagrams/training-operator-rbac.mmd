graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["training-operator<br/>(opendatahub namespace)"]
        SA_MPILauncher["{jobName}-launcher<br/>(per MPIJob, job namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Operator["training-operator<br/>(ClusterRoleBinding)"]
        CRB_Edit["training-edit<br/>(aggregate-to-edit/admin)"]
        CRB_View["training-view<br/>(aggregate-to-view)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Webhook["training-operator-webhook<br/>(operator namespace)"]
        RB_MPILauncher["{jobName}-launcher<br/>(per MPIJob, job namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Operator["training-operator<br/>(ClusterRole)"]
        CR_Edit["training-edit<br/>(ClusterRole)"]
        CR_View["training-view<br/>(ClusterRole)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Webhook["training-operator-webhook<br/>(Role)"]
        R_MPILauncher["{jobName}-launcher<br/>(Role)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/exec"]
        Services["core<br/>services"]
        ConfigMaps["core<br/>configmaps"]
        SAs["core<br/>serviceaccounts"]
        Secrets["core<br/>secrets"]
        Events["core<br/>events"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        PyTorchJobs["pytorchjobs<br/>+ /finalizers + /status"]
        TFJobs["tfjobs<br/>+ /finalizers + /status"]
        MPIJobs["mpijobs<br/>+ /finalizers + /status"]
        JAXJobs["jaxjobs<br/>+ /finalizers + /status"]
        XGBoostJobs["xgboostjobs<br/>+ /finalizers + /status"]
        PaddleJobs["paddlejobs<br/>+ /finalizers + /status"]
    end

    subgraph SchedulingResources["Scheduling Resources"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        SchedPG["scheduling.x-k8s.io<br/>podgroups"]
        HPA["autoscaling<br/>horizontalpodautoscalers"]
    end

    subgraph OtherResources["Other Resources"]
        Webhooks["admissionregistration<br/>validatingwebhookconfigurations"]
        RBAC_Res["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        NetPol["networking.k8s.io<br/>networkpolicies"]
    end

    %% Operator bindings
    SA_Operator -->|"bound via"| CRB_Operator
    CRB_Operator -->|"grants"| CR_Operator
    SA_Operator -->|"bound via"| RB_Webhook
    RB_Webhook -->|"grants"| R_Webhook

    %% MPI launcher bindings
    SA_MPILauncher -->|"bound via"| RB_MPILauncher
    RB_MPILauncher -->|"grants"| R_MPILauncher

    %% ClusterRole permissions
    CR_Operator -->|"full CRUD"| Pods
    CR_Operator -->|"create,delete,get,list,watch"| Services
    CR_Operator -->|"create,list,update,watch"| ConfigMaps
    CR_Operator -->|"create,get,list,watch"| SAs
    CR_Operator -->|"get,list,update,watch"| Secrets
    CR_Operator -->|"full CRUD"| Events
    CR_Operator -->|"full CRUD"| PyTorchJobs
    CR_Operator -->|"full CRUD"| TFJobs
    CR_Operator -->|"full CRUD"| MPIJobs
    CR_Operator -->|"full CRUD"| JAXJobs
    CR_Operator -->|"full CRUD"| XGBoostJobs
    CR_Operator -->|"full CRUD"| PaddleJobs
    CR_Operator -->|"full CRUD"| VolcanoPG
    CR_Operator -->|"full CRUD"| SchedPG
    CR_Operator -->|"full CRUD"| HPA
    CR_Operator -->|"get,list,update,watch"| Webhooks
    CR_Operator -->|"create,list,update,watch"| RBAC_Res
    CR_Operator -->|"full CRUD"| NetPol

    %% Aggregate roles
    CR_Edit -->|"full CRUD"| KubeflowResources
    CR_View -->|"get,list,watch"| KubeflowResources

    %% MPI launcher permissions
    R_MPILauncher -->|"create (pods/exec)<br/>on specific pod names"| Pods

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_MPILauncher fill:#4a90e2,stroke:#333,color:#fff
    style CR_Operator fill:#f5a623,stroke:#333
    style CR_Edit fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style R_Webhook fill:#f5a623,stroke:#333
    style R_MPILauncher fill:#f5a623,stroke:#333
    style PyTorchJobs fill:#7ed321,stroke:#333
    style TFJobs fill:#7ed321,stroke:#333
    style MPIJobs fill:#7ed321,stroke:#333
    style JAXJobs fill:#7ed321,stroke:#333
    style XGBoostJobs fill:#7ed321,stroke:#333
    style PaddleJobs fill:#7ed321,stroke:#333
