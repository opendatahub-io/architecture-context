graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>(opendatahub namespace)"]
        MPIJobSA["{jobName}-launcher<br/>(per MPI job, job namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Webhook["training-operator-webhook<br/>(RoleBinding, operator namespace)"]
        RB_MPI["{jobName}-launcher<br/>(RoleBinding, per MPI job)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["training-operator<br/>(ClusterRole)"]
        CR_Edit["training-edit<br/>(RHOAI, aggregate-to-edit/admin)"]
        CR_View["training-view<br/>(RHOAI, aggregate-to-view)"]
    end

    subgraph Roles["Roles"]
        R_Webhook["training-operator-webhook<br/>(Role, operator namespace)"]
        R_MPI["{jobName}-launcher<br/>(Role, per MPI job)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods"]
        PodsExec["core<br/>pods/exec"]
        Services["core<br/>services"]
        ConfigMaps["core<br/>configmaps"]
        Events["core<br/>events"]
        ServiceAccts["core<br/>serviceaccounts"]
        Secrets["core<br/>secrets"]
    end

    subgraph CRDResources["kubeflow.org Resources"]
        PTJobs["pytorchjobs<br/>+ /finalizers, /status"]
        TFJobs["tfjobs<br/>+ /finalizers, /status"]
        MPIJobs["mpijobs<br/>+ /finalizers, /status"]
        JAXJobs["jaxjobs<br/>+ /finalizers, /status"]
        XGBJobs["xgboostjobs<br/>+ /finalizers, /status"]
        PaddleJobs["paddlejobs<br/>+ /finalizers, /status"]
    end

    subgraph OtherResources["Other API Resources"]
        VWC["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
        HPA["autoscaling<br/>horizontalpodautoscalers"]
        RBACRoles["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        SchedPG["scheduling.x-k8s.io<br/>podgroups"]
        NetPol["networking.k8s.io<br/>networkpolicies"]
    end

    %% Main SA bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR_Main

    %% Webhook role binding
    SA -->|"bound via"| RB_Webhook
    RB_Webhook -->|"grants"| R_Webhook

    %% MPI per-job bindings
    MPIJobSA -->|"bound via"| RB_MPI
    RB_MPI -->|"grants"| R_MPI

    %% ClusterRole permissions - Core
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| Pods
    CR_Main -->|"create"| PodsExec
    CR_Main -->|"create,delete,get,<br/>list,watch"| Services
    CR_Main -->|"create,list,<br/>update,watch"| ConfigMaps
    CR_Main -->|"create,delete,get,list,<br/>patch,update,watch"| Events
    CR_Main -->|"create,get,<br/>list,watch"| ServiceAccts
    CR_Main -->|"get,list,<br/>update,watch"| Secrets

    %% ClusterRole permissions - CRDs
    CR_Main -->|"full CRUD"| PTJobs
    CR_Main -->|"full CRUD"| TFJobs
    CR_Main -->|"full CRUD"| MPIJobs
    CR_Main -->|"full CRUD"| JAXJobs
    CR_Main -->|"full CRUD"| XGBJobs
    CR_Main -->|"full CRUD"| PaddleJobs

    %% ClusterRole permissions - Other
    CR_Main -->|"get,list,<br/>update,watch"| VWC
    CR_Main -->|"full CRUD"| HPA
    CR_Main -->|"create,list,<br/>update,watch"| RBACRoles
    CR_Main -->|"full CRUD"| VolcanoPG
    CR_Main -->|"full CRUD"| SchedPG
    CR_Main -->|"full CRUD"| NetPol

    %% RHOAI aggregate roles
    CR_Edit -->|"full CRUD<br/>(aggregated to edit/admin)"| CRDResources
    CR_View -->|"get,list,watch<br/>(aggregated to view)"| CRDResources

    %% Webhook role
    R_Webhook -->|"get,update"| Secrets

    %% MPI role
    R_MPI -->|"create (pods/exec)<br/>on specific pod names"| PodsExec

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style MPIJobSA fill:#4a90e2,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style CR_Edit fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style R_Webhook fill:#e8a623,stroke:#333
    style R_MPI fill:#e8a623,stroke:#333
    style CRB fill:#b8d4f0,stroke:#333
    style RB_Webhook fill:#b8d4f0,stroke:#333
    style RB_MPI fill:#b8d4f0,stroke:#333
    style PTJobs fill:#7ed321,stroke:#333
    style TFJobs fill:#7ed321,stroke:#333
    style MPIJobs fill:#7ed321,stroke:#333
    style JAXJobs fill:#7ed321,stroke:#333
    style XGBJobs fill:#7ed321,stroke:#333
    style PaddleJobs fill:#7ed321,stroke:#333
    style Pods fill:#ddd,stroke:#333
    style PodsExec fill:#ddd,stroke:#333
    style Services fill:#ddd,stroke:#333
    style ConfigMaps fill:#ddd,stroke:#333
    style Events fill:#ddd,stroke:#333
    style ServiceAccts fill:#ddd,stroke:#333
    style Secrets fill:#ddd,stroke:#333
    style VWC fill:#ddd,stroke:#333
    style HPA fill:#ddd,stroke:#333
    style RBACRoles fill:#ddd,stroke:#333
    style VolcanoPG fill:#ddd,stroke:#333
    style SchedPG fill:#ddd,stroke:#333
    style NetPol fill:#ddd,stroke:#333
