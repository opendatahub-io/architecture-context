graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>(opendatahub namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["training-operator<br/>(Cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Webhook["training-operator-webhook<br/>(Deployment namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR["training-operator"]
        CR_Edit["training-edit<br/>(RHOAI aggregated)"]
        CR_View["training-view<br/>(RHOAI aggregated)"]
    end

    subgraph Roles["Namespace Roles"]
        R_Webhook["training-operator-webhook"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB_Webhook
    CRB -->|"grants"| CR
    RB_Webhook -->|"grants"| R_Webhook

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps<br/>create, list, update, watch"]
        Events["events<br/>CRUD + patch"]
        Pods["pods<br/>CRUD + patch"]
        PodsExec["pods/exec<br/>create"]
        ServiceAccounts_R["serviceaccounts<br/>create, get, list, watch"]
        Services_R["services<br/>create, delete, get, list, watch"]
    end

    subgraph KubeflowResources["kubeflow.org Resources"]
        TrainingJobs["pytorchjobs, tfjobs,<br/>xgboostjobs, mpijobs,<br/>jaxjobs, paddlejobs<br/>CRUD + patch"]
        TrainingFinalizers["*/finalizers<br/>update"]
        TrainingStatus["*/status<br/>get, patch, update"]
    end

    subgraph AdmissionResources["admissionregistration.k8s.io"]
        VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
    end

    subgraph AutoscalingResources["autoscaling"]
        HPA["horizontalpodautoscalers<br/>CRUD + patch"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        NetPol["networkpolicies<br/>CRUD + patch"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        RolesR["roles<br/>create, list, update, watch"]
        RoleBindingsR["rolebindings<br/>create, list, update, watch"]
    end

    subgraph SchedulingResources["Scheduling Resources"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups<br/>CRUD + patch"]
        SchedPluginsPG["scheduling.x-k8s.io<br/>podgroups<br/>CRUD + patch"]
    end

    CR -->|"manages"| CoreResources
    CR -->|"manages"| KubeflowResources
    CR -->|"manages"| AdmissionResources
    CR -->|"manages"| AutoscalingResources
    CR -->|"manages"| NetworkResources
    CR -->|"manages"| RBACResources
    CR -->|"manages"| SchedulingResources

    subgraph AggregatedPerms["Aggregated Permissions (RHOAI)"]
        EditPerms["training-edit → edit role<br/>CRUD + patch on all training jobs"]
        ViewPerms["training-view → view role<br/>get, list, watch on all training jobs"]
    end

    CR_Edit -->|"grants"| EditPerms
    CR_View -->|"grants"| ViewPerms

    subgraph WebhookPerms["Webhook Role Permissions"]
        SecretAccess["secrets<br/>(webhook cert secret)<br/>get, create, update"]
    end

    R_Webhook -->|"manages"| WebhookPerms

