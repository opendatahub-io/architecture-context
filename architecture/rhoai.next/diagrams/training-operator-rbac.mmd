graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>(opendatahub namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (operator namespace)"]
        RB["training-operator-webhook<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["training-operator<br/>(ClusterRole)"]
        CR_Edit["kubeflow-training-edit<br/>(aggregates to admin, edit)"]
        CR_View["kubeflow-training-view<br/>(aggregates to view)"]
    end

    subgraph Roles["Roles (operator namespace)"]
        R_Webhook["training-operator-webhook<br/>(Role)"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["core<br/>configmaps"]
        Events["core<br/>events"]
        Pods["core<br/>pods"]
        PodsExec["core<br/>pods/exec"]
        SvcAccts["core<br/>serviceaccounts"]
        Services["core<br/>services"]
    end

    subgraph KubeflowResources["Kubeflow API Resources"]
        AllJobs["kubeflow.org<br/>pytorchjobs, tfjobs,<br/>mpijobs, xgboostjobs,<br/>paddlejobs, jaxjobs"]
        Finalizers["kubeflow.org<br/>*/finalizers"]
        Status["kubeflow.org<br/>*/status"]
    end

    subgraph K8sExtResources["K8s Extension Resources"]
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
        HPA["autoscaling<br/>horizontalpodautoscalers"]
        RolesRes["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        NetPol["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph SchedulingResources["Scheduling Resources"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        K8sPG["scheduling.x-k8s.io<br/>podgroups"]
    end

    subgraph SecretResources["Secrets (namespace-scoped)"]
        WebhookSecret["Secret: webhook-cert<br/>(TLS certificate)"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| RB
    CRB -->|grants| CR_Main
    RB -->|grants| R_Webhook

    %% ClusterRole permissions
    CR_Main -->|"create, list,<br/>update, watch"| ConfigMaps
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| Events
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| Pods
    CR_Main -->|"create"| PodsExec
    CR_Main -->|"create, get,<br/>list, watch"| SvcAccts
    CR_Main -->|"create, delete,<br/>get, list, watch"| Services
    CR_Main -->|"create, delete, get, list,<br/>patch, update, watch"| AllJobs
    CR_Main -->|"update"| Finalizers
    CR_Main -->|"get, patch, update"| Status
    CR_Main -->|"get, list,<br/>update, watch"| Webhooks
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| HPA
    CR_Main -->|"create, list,<br/>update, watch"| RolesRes
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| NetPol
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| VolcanoPG
    CR_Main -->|"create, delete, get,<br/>list, patch, update, watch"| K8sPG

    %% Namespace Role permissions
    R_Webhook -->|"get, update"| WebhookSecret

    %% Aggregated roles
    CR_Edit -->|"create, delete, get, list,<br/>patch, update, watch"| AllJobs
    CR_Edit -->|"get"| Status
    CR_View -->|"get, list, watch"| AllJobs
    CR_View -->|"get"| Status

