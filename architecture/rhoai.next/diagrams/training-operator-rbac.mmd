graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>Namespace: opendatahub"]
        MPIJobSA["mpi-job-{name}<br/>Namespace: {job-namespace}<br/>(created per MPIJob)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings (per namespace)"]
        WebhookRB["training-operator-webhook<br/>Namespace: opendatahub"]
        MPIRB["mpi-job-{name}<br/>Namespace: {job-namespace}<br/>(created per MPIJob)"]
    end

    subgraph ClusterRole["ClusterRole: training-operator"]
        direction TB
        subgraph CoreAPI["Core API ('')"]
            Pods["pods<br/>create, delete, get, list,<br/>patch, update, watch"]
            PodsExec["pods/exec<br/>create"]
            Services["services<br/>create, delete, get,<br/>list, watch"]
            ConfigMaps["configmaps<br/>create, list, update, watch"]
            Events["events<br/>create, delete, get, list,<br/>patch, update, watch"]
            ServiceAccounts_res["serviceaccounts<br/>create, get, list, watch"]
        end

        subgraph KubeflowAPI["kubeflow.org"]
            PyTorchJobs["pytorchjobs<br/>+ /finalizers, /status<br/>full CRUD"]
            TFJobs["tfjobs<br/>+ /finalizers, /status<br/>full CRUD"]
            XGBoostJobs["xgboostjobs<br/>+ /finalizers, /status<br/>full CRUD"]
            JAXJobs["jaxjobs<br/>+ /finalizers, /status<br/>full CRUD"]
            MPIJobs["mpijobs<br/>+ /finalizers, /status<br/>full CRUD"]
            PaddleJobs["paddlejobs<br/>+ /finalizers, /status<br/>full CRUD"]
        end

        subgraph NetworkingAPI["networking.k8s.io"]
            NetworkPolicies["networkpolicies<br/>full CRUD"]
        end

        subgraph AutoscalingAPI["autoscaling"]
            HPA["horizontalpodautoscalers<br/>full CRUD"]
        end

        subgraph AdmissionAPI["admissionregistration.k8s.io"]
            VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            Roles_res["roles<br/>create, list, update, watch"]
            RoleBindings_res["rolebindings<br/>create, list, update, watch"]
        end

        subgraph GangScheduling["Gang Scheduling (optional)"]
            VolcanoPG["scheduling.volcano.sh<br/>podgroups<br/>full CRUD"]
            SchedPluginsPG["scheduling.x-k8s.io<br/>podgroups<br/>full CRUD"]
        end
    end

    subgraph WebhookRole["Role: training-operator-webhook<br/>Namespace: opendatahub"]
        WebhookSecret["secrets<br/>(webhook cert secret)<br/>get, update, create"]
    end

    subgraph MPIRole["Role: mpi-job-{name}<br/>Namespace: {job-namespace}"]
        MPIPodExec["pods/exec<br/>create<br/>(for kubectl exec to workers)"]
    end

    subgraph AggregatedRoles["RHOAI Aggregated ClusterRoles"]
        EditRole["training-edit<br/>aggregates-to: edit, admin<br/>kubeflow.org: all 6 job types + mxjobs<br/>Verbs: full CRUD"]
        ViewRole["training-view<br/>aggregates-to: view<br/>kubeflow.org: all 6 job types + mxjobs<br/>Verbs: get, list, watch"]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| ClusterRole

    SA -->|bound via| WebhookRB
    WebhookRB -->|grants| WebhookRole

    MPIJobSA -->|bound via| MPIRB
    MPIRB -->|grants| MPIRole

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style MPIJobSA fill:#4a90e2,color:#fff
    style CRB fill:#9b59b6,color:#fff
    style WebhookRB fill:#9b59b6,color:#fff
    style MPIRB fill:#9b59b6,color:#fff

    style Pods fill:#7ed321,color:#fff
    style PodsExec fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Events fill:#7ed321,color:#fff
    style ServiceAccounts_res fill:#7ed321,color:#fff

    style PyTorchJobs fill:#f5a623,color:#fff
    style TFJobs fill:#f5a623,color:#fff
    style XGBoostJobs fill:#f5a623,color:#fff
    style JAXJobs fill:#f5a623,color:#fff
    style MPIJobs fill:#f5a623,color:#fff
    style PaddleJobs fill:#f5a623,color:#fff

    style NetworkPolicies fill:#e74c3c,color:#fff
    style HPA fill:#e74c3c,color:#fff
    style VWC fill:#e74c3c,color:#fff
    style Roles_res fill:#e74c3c,color:#fff
    style RoleBindings_res fill:#e74c3c,color:#fff
    style VolcanoPG fill:#bbb,color:#fff
    style SchedPluginsPG fill:#bbb,color:#fff

    style WebhookSecret fill:#f39c12,color:#fff
    style MPIPodExec fill:#f39c12,color:#fff

    style EditRole fill:#2ecc71,color:#fff
    style ViewRole fill:#2ecc71,color:#fff
