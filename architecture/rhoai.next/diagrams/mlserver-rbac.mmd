graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC: None"]
            Note1["MLServer is a userspace process<br/>No Kubernetes API interaction<br/>No ClusterRoles, Roles, or RoleBindings"]
        end

        subgraph PlatformAuth["Platform-Level Auth (Sidecar)"]
            direction LR
            KubeRBAC["kube-rbac-proxy<br/>(RHOAI 3.x)"]
            OAuthProxy["oauth-proxy<br/>(RHOAI 2.x)"]
        end

        subgraph AppSecurity["Application-Level Security"]
            direction TB

            TrustedRT["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]

            subgraph ProdMode["Production Mode (file exists)"]
                Allowed["Allowed Runtimes:<br/>mlserver_sklearn.SKLearnModel<br/>mlserver_xgboost.XGBoostModel<br/>mlserver_lightgbm.LightGBMModel<br/>mlserver_onnx.ONNXModel"]
                Blocked["Blocked Actions:<br/>- Unlisted runtime imports<br/>- Custom environment_tarball<br/>- Custom environment_path<br/>- Wildcard CORS origins<br/>- CORS regex patterns"]
            end

            subgraph DevMode["Development Mode (file absent)"]
                DevAllowed["Allowed:<br/>- Any runtime can load dynamically<br/>- Custom environments supported<br/>- Wildcard CORS permitted"]
            end

            TrustedRT -->|"exists"| ProdMode
            TrustedRT -->|"absent"| DevMode
        end

        subgraph NetworkSecurity["Network Security (No App-Level TLS)"]
            REST8080["REST :8080<br/>HTTP Plaintext<br/>No Auth"]
            GRPC8081["gRPC :8081<br/>Insecure Port<br/>No Auth"]
            Metrics8082["Metrics :8082<br/>HTTP Plaintext<br/>No Auth"]
        end
    end

    %% Auth flow
    Client["External Client"] -->|"HTTPS + Bearer Token"| KubeRBAC
    Client -->|"HTTPS + OAuth"| OAuthProxy
    KubeRBAC -->|"Authenticated<br/>HTTP plaintext"| REST8080
    KubeRBAC -->|"Authenticated<br/>gRPC plaintext"| GRPC8081
    OAuthProxy -->|"Authenticated<br/>HTTP plaintext"| REST8080

    %% Prometheus
    Prometheus["Prometheus"] -->|"HTTP scrape"| Metrics8082

    %% Styling
    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style TrustedRT fill:#e74c3c,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff
    style Allowed fill:#d4edda,stroke:#155724,color:#155724
    style Blocked fill:#f8d7da,stroke:#721c24,color:#721c24
    style DevAllowed fill:#fff3cd,stroke:#856404,color:#856404
    style REST8080 fill:#ffc107,stroke:#333
    style GRPC8081 fill:#ffc107,stroke:#333
    style Metrics8082 fill:#ffc107,stroke:#333
    style Client fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
