graph TD
    subgraph "MLServer RBAC Model"
        direction TB

        Note["MLServer is a service workload, NOT an operator.<br/>No Kubernetes RBAC (ClusterRoles/RoleBindings) defined.<br/>Pod-level RBAC is managed by KServe and rhods-operator."]

        subgraph PodAccess["Pod-Level Access"]
            SA["Pod ServiceAccount<br/>(managed by KServe)"]
            SAMount["/var/run/secrets/kubernetes.io/<br/>serviceaccount/namespace<br/>Read-only filesystem access"]
        end

        subgraph AppSecurity["Application-Level Security (Production Mode)"]
            TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>Baked into image at build time"]

            subgraph AllowedRuntimes["Allowed Runtime Implementations"]
                SKLearn["mlserver_sklearn.SKLearnModel"]
                XGBoost["mlserver_xgboost.XGBoostModel"]
                LightGBM["mlserver_lightgbm.LightGBMModel"]
                OnnxRT["mlserver_onnx.ONNXModel"]
            end

            subgraph BlockedActions["Blocked in Production Mode"]
                UntrustedRuntime["Untrusted model implementations<br/>→ ValueError on load"]
                EnvTarball["environment_tarball parameter<br/>→ Rejected (sys.path injection)"]
                EnvPath["environment_path parameter<br/>→ Rejected (sys.path injection)"]
                WildcardCORS["Wildcard CORS origins<br/>→ Blocked"]
                RegexCORS["Regex-based CORS origins<br/>→ Blocked"]
            end
        end

        subgraph ExternalRBAC["External RBAC (Managed by Platform)"]
            KServeSA["KServe Controller SA<br/>Manages InferenceService pods"]
            RhodsOperator["rhods-operator SA<br/>Platform-level RBAC"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>External auth enforcement"]
            OAuthProxy["oauth-proxy sidecar<br/>OAuth authentication"]
        end

        SA --> SAMount
        TrustedRuntimes -->|"allows"| AllowedRuntimes
        TrustedRuntimes -->|"blocks"| BlockedActions
        KServeSA -->|"creates/manages"| SA
        RhodsOperator -->|"configures"| KServeSA
        KubeRBACProxy -->|"authenticates<br/>external requests"| SA
        OAuthProxy -->|"authenticates<br/>external requests"| SA
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style SAMount fill:#dae8fc,stroke:#6c8ebf
    style TrustedRuntimes fill:#e74c3c,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style OnnxRT fill:#7ed321,stroke:#333,color:#fff
    style UntrustedRuntime fill:#f8cecc,stroke:#b85450
    style EnvTarball fill:#f8cecc,stroke:#b85450
    style EnvPath fill:#f8cecc,stroke:#b85450
    style WildcardCORS fill:#f8cecc,stroke:#b85450
    style RegexCORS fill:#f8cecc,stroke:#b85450
    style KServeSA fill:#f5a623,stroke:#333,color:#fff
    style RhodsOperator fill:#f5a623,stroke:#333,color:#fff
    style KubeRBACProxy fill:#f5a623,stroke:#333,color:#fff
    style OAuthProxy fill:#f5a623,stroke:#333,color:#fff
