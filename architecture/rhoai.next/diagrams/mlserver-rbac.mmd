graph TD
    subgraph MLServerPod["MLServer Pod (No K8s RBAC)"]
        direction TB
        Container["MLServer Container<br/>Runs as UID 1000 (non-root)"]
    end

    subgraph RuntimeSecurity["Runtime Security Model"]
        direction TB

        subgraph ProdMode["PRODUCTION Mode"]
            TrustedFile["/etc/mlserver/trusted-runtimes.json<br/>(baked into container image)"]
            Allowlist["Allowed Runtimes:<br/>- mlserver_lightgbm (LightGBM)<br/>- mlserver_onnx (ONNX Runtime)<br/>- mlserver_sklearn (scikit-learn)<br/>- mlserver_xgboost (XGBoost)"]
            CORSBlock["CORS: Restricted<br/>(no wildcard origins)"]
            EnvBlock["Custom Environments: Blocked"]
        end

        subgraph DevMode["DEVELOPMENT Mode"]
            NoFile["No trusted-runtimes.json"]
            AnyRuntime["Any Runtime Import Path: Allowed"]
            CORSAllow["CORS: Wildcard Origins Allowed"]
            EnvAllow["Custom Environments: Allowed"]
        end
    end

    subgraph AuthModel["Authentication & Authorization"]
        direction TB
        AppAuth["Application-Level Auth: None<br/>(all REST/gRPC endpoints)"]
        PlatformAuth["Platform-Level Auth:<br/>KServe / Istio / kube-rbac-proxy<br/>(enforced at ingress layer)"]
        RuntimeEndpoint["/v2/runtimes Endpoint<br/>Exposes security mode & allowlist"]
    end

    subgraph KServeRBAC["KServe-Managed RBAC"]
        KServeSA["KServe Controller<br/>ServiceAccount"]
        KServeRole["KServe ClusterRole<br/>- manages InferenceService<br/>- creates Deployments<br/>- creates Services"]
        KServeSA -->|"ClusterRoleBinding"| KServeRole
    end

    %% Relationships
    Container -->|"validates runtimes"| ProdMode
    TrustedFile -->|"populates"| Allowlist
    Container -->|"no auth"| AppAuth
    PlatformAuth -->|"protects"| Container
    KServeRBAC -->|"deploys & manages"| MLServerPod

    %% Styling
    style MLServerPod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Container fill:#4a90e2,color:#fff
    style ProdMode fill:#d1fae5,stroke:#10b981,stroke-width:2px
    style DevMode fill:#fee2e2,stroke:#ef4444,stroke-width:2px
    style TrustedFile fill:#fef3c7,stroke:#f59e0b
    style Allowlist fill:#d1fae5,stroke:#10b981
    style CORSBlock fill:#d1fae5,stroke:#10b981
    style EnvBlock fill:#d1fae5,stroke:#10b981
    style NoFile fill:#fee2e2,stroke:#ef4444
    style AnyRuntime fill:#fee2e2,stroke:#ef4444
    style CORSAllow fill:#fee2e2,stroke:#ef4444
    style EnvAllow fill:#fee2e2,stroke:#ef4444
    style AppAuth fill:#fef3c7,stroke:#f59e0b
    style PlatformAuth fill:#d5e8d4,stroke:#82b366
    style RuntimeEndpoint fill:#dbeafe,stroke:#3b82f6
    style KServeSA fill:#e1d5e7,stroke:#9673a6
    style KServeRole fill:#e1d5e7,stroke:#9673a6
