graph TD
    subgraph KServeManaged["RBAC Managed by KServe / Platform Operator"]
        direction TB

        subgraph PodIdentity["Pod Identity (KServe InferenceService)"]
            SA["ServiceAccount<br/>(managed by KServe)<br/>Namespace: {user-namespace}"]
        end

        subgraph PlatformRBAC["Platform RBAC (rhods-operator)"]
            KServeRBAC["KServe Controller RBAC<br/>Manages pod lifecycle,<br/>service creation, routing"]
        end
    end

    subgraph MLServerApp["MLServer Application-Level Security"]
        direction TB

        subgraph TrustedRuntimes["Trusted Runtimes Allowlist"]
            AllowlistFile["/etc/mlserver/trusted-runtimes.json<br/>(baked into image at build time)"]
            ValidationPoints["Validation Points:<br/>1. ModelSettings Pydantic validator<br/>2. implementation property accessor<br/>3. Startup security check"]
        end

        subgraph AllowedRuntimes["Allowed Runtime Implementations"]
            SKLearn["mlserver_sklearn.SKLearnModel"]
            XGBoost["mlserver_xgboost.XGBoostModel"]
            LightGBM["mlserver_lightgbm.LightGBMModel"]
            ONNX["mlserver_onnx.ONNXModel"]
        end

        subgraph BlockedActions["Blocked in Production Mode"]
            UntrustedRT["Untrusted Runtime Loading<br/>❌ REJECTED"]
            EnvTarball["environment_tarball parameter<br/>❌ REJECTED (sys.path injection)"]
            EnvPath["environment_path parameter<br/>❌ REJECTED (sys.path injection)"]
            WildcardCORS["Wildcard CORS origins<br/>❌ BLOCKED"]
            RegexCORS["Regex CORS origins<br/>❌ BLOCKED"]
        end
    end

    subgraph FilesystemAccess["Filesystem Access"]
        ModelDir["/mnt/models<br/>Model artifacts<br/>Read-only"]
        SAMount["/var/run/secrets/<br/>kubernetes.io/serviceaccount/<br/>Namespace read only"]
        TrustedRTFile["/etc/mlserver/<br/>trusted-runtimes.json<br/>Read-only (image-baked)"]
    end

    %% Connections
    SA -->|"mounts"| SAMount
    SA -->|"pod runs as"| MLServerApp

    AllowlistFile -->|"validates against"| ValidationPoints
    ValidationPoints -->|"allows"| AllowedRuntimes
    ValidationPoints -->|"blocks"| BlockedActions

    KServeRBAC -->|"creates & manages"| SA

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style KServeRBAC fill:#4a90e2,stroke:#333,color:#fff

    style AllowlistFile fill:#f5a623,stroke:#333,color:#fff
    style ValidationPoints fill:#f5a623,stroke:#333,color:#fff

    style SKLearn fill:#7ed321,stroke:#333,color:#fff
    style XGBoost fill:#7ed321,stroke:#333,color:#fff
    style LightGBM fill:#7ed321,stroke:#333,color:#fff
    style ONNX fill:#7ed321,stroke:#333,color:#fff

    style UntrustedRT fill:#d0021b,stroke:#333,color:#fff
    style EnvTarball fill:#d0021b,stroke:#333,color:#fff
    style EnvPath fill:#d0021b,stroke:#333,color:#fff
    style WildcardCORS fill:#d0021b,stroke:#333,color:#fff
    style RegexCORS fill:#d0021b,stroke:#333,color:#fff

    style ModelDir fill:#e8e8e8,stroke:#333
    style SAMount fill:#e8e8e8,stroke:#333
    style TrustedRTFile fill:#e8e8e8,stroke:#333
