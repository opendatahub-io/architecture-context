graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        subgraph PodIdentity["Pod Identity (Managed by KServe)"]
            SA["ServiceAccount<br/>(KServe-managed)<br/>per InferenceService"]
            NS["Namespace Read<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/namespace<br/>(read-only, CloudEvents headers)"]
        end

        subgraph TrustedRuntimes["Trusted Runtimes Allowlist (Application-Level RBAC)"]
            direction TB
            TRFile["/etc/mlserver/trusted-runtimes.json<br/>(baked into image at build time)"]
            ProdMode["PRODUCTION Mode<br/>(auto-enabled when file exists)"]

            subgraph AllowedRuntimes["Allowed Model Implementations"]
                RT1["mlserver_sklearn.SKLearnModel"]
                RT2["mlserver_xgboost.XGBoostModel"]
                RT3["mlserver_lightgbm.LightGBMModel"]
                RT4["mlserver_onnx.ONNXModel"]
            end

            subgraph BlockedActions["Blocked in Production Mode"]
                B1["❌ Untrusted model implementations"]
                B2["❌ environment_tarball parameter"]
                B3["❌ environment_path parameter"]
                B4["❌ Wildcard CORS origins"]
                B5["❌ Regex-based CORS origins"]
            end

            subgraph ValidationPoints["Validation Enforcement Points"]
                V1["1. ModelSettings Pydantic<br/>model_validator"]
                V2["2. implementation property<br/>accessor (defense-in-depth)"]
                V3["3. Startup security check<br/>log_runtime_security_mode"]
                V4["4. Import path regex<br/>dotted module + capitalized class"]
            end
        end

        subgraph PlatformRBAC["Platform RBAC (External to MLServer)"]
            KServeRBAC["KServe Controller<br/>Manages pod RBAC"]
            OperatorRBAC["rhods-operator<br/>Manages serving runtime RBAC"]
            IngressAuth["Ingress Auth<br/>kube-rbac-proxy / oauth-proxy<br/>(sidecar in KServe pod)"]
        end
    end

    %% Relationships
    SA -->|"reads"| NS
    TRFile -->|"enables"| ProdMode
    ProdMode -->|"allows"| AllowedRuntimes
    ProdMode -->|"blocks"| BlockedActions
    ProdMode -->|"enforced at"| ValidationPoints

    KServeRBAC -->|"creates"| SA
    OperatorRBAC -->|"configures"| KServeRBAC
    IngressAuth -->|"protects"| SA

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style NS fill:#4a90e2,stroke:#333,color:#fff
    style TRFile fill:#e74c3c,stroke:#333,color:#fff
    style ProdMode fill:#e74c3c,stroke:#333,color:#fff
    style RT1 fill:#7ed321,stroke:#333,color:#fff
    style RT2 fill:#7ed321,stroke:#333,color:#fff
    style RT3 fill:#7ed321,stroke:#333,color:#fff
    style RT4 fill:#7ed321,stroke:#333,color:#fff
    style B1 fill:#ffcccc,stroke:#cc0000
    style B2 fill:#ffcccc,stroke:#cc0000
    style B3 fill:#ffcccc,stroke:#cc0000
    style B4 fill:#ffcccc,stroke:#cc0000
    style B5 fill:#ffcccc,stroke:#cc0000
    style V1 fill:#f5a623,stroke:#333,color:#fff
    style V2 fill:#f5a623,stroke:#333,color:#fff
    style V3 fill:#f5a623,stroke:#333,color:#fff
    style V4 fill:#f5a623,stroke:#333,color:#fff
    style KServeRBAC fill:#999,stroke:#333,color:#fff
    style OperatorRBAC fill:#999,stroke:#333,color:#fff
    style IngressAuth fill:#999,stroke:#333,color:#fff
