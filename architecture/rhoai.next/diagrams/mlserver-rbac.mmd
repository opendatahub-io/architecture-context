graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        Note["MLServer does not define Kubernetes RBAC resources.<br/>It runs as a container within KServe-managed pods<br/>and does not interact with the Kubernetes API<br/>(except reading namespace from service account mount)."]
    end

    subgraph PlatformAuth["Platform-Level Authentication (kube-rbac-proxy)"]
        direction TB

        Client["External Client"]
        Proxy["kube-rbac-proxy Sidecar<br/>Port: 8443/TCP HTTPS"]
        REST["MLServer REST<br/>Port: 8080/TCP HTTP"]
        GRPC["MLServer gRPC<br/>Port: 8081/TCP gRPC"]

        Client -->|"Bearer Token<br/>TLS 1.2+"| Proxy
        Proxy -->|"Token validated<br/>AuthZ enforced"| REST
        Proxy -->|"Token validated<br/>AuthZ enforced"| GRPC
    end

    subgraph RuntimeSecurity["Application-Level Security Controls"]
        direction TB

        TrustedRuntimes["Trusted Runtime Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
        ProdMode["Production Mode Restrictions"]

        subgraph AllowedRuntimes["Allowed Runtime Import Paths (RHOAI)"]
            direction LR
            RT1["mlserver_sklearn.SKLearnModel"]
            RT2["mlserver_xgboost.XGBoostModel"]
            RT3["mlserver_lightgbm.LightGBMModel"]
            RT4["mlserver_onnx.OnnxModel"]
        end

        subgraph BlockedActions["Blocked in Production Mode"]
            direction LR
            B1["environment_tarball<br/>(dynamic env injection)"]
            B2["environment_path<br/>(sys.path manipulation)"]
            B3["Wildcard CORS origins<br/>(* or regex patterns)"]
            B4["Untrusted runtime<br/>import paths"]
        end

        TrustedRuntimes -->|"allows"| AllowedRuntimes
        ProdMode -->|"blocks"| BlockedActions
    end

    subgraph ServiceAccountUsage["Kubernetes Service Account Usage"]
        direction TB
        SA["Pod Service Account"]
        NSFile["/var/run/secrets/kubernetes.io/<br/>serviceaccount/namespace"]
        CloudEvents["CloudEvents Headers<br/>(ce-source metadata)"]

        SA -->|"mounts"| NSFile
        NSFile -->|"read by MLServer for"| CloudEvents
    end

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style Proxy fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style REST fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style GRPC fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style TrustedRuntimes fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ProdMode fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RT1 fill:#7ed321,stroke:#333
    style RT2 fill:#7ed321,stroke:#333
    style RT3 fill:#7ed321,stroke:#333
    style RT4 fill:#7ed321,stroke:#333
    style B1 fill:#f8cecc,stroke:#b85450
    style B2 fill:#f8cecc,stroke:#b85450
    style B3 fill:#f8cecc,stroke:#b85450
    style B4 fill:#f8cecc,stroke:#b85450
    style SA fill:#e1d5e7,stroke:#9673a6
    style NSFile fill:#e1d5e7,stroke:#9673a6
    style CloudEvents fill:#e1d5e7,stroke:#9673a6
