graph TD
    subgraph PlatformManaged["Platform-Managed Security (KServe / ModelMesh)"]
        direction TB
        Note1["MLServer does NOT define Kubernetes RBAC resources.<br/>All RBAC is managed by the deploying platform."]
    end

    subgraph ApplicationSecurity["MLServer Application-Level Security"]
        direction TB

        subgraph TrustedRuntimesSystem["Trusted Runtimes Enforcement"]
            TrustedFile["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>(baked at image build time)"]

            subgraph AllowedRuntimes["Allowed Runtime Import Paths (RHOAI)"]
                RT_SKLearn["mlserver_sklearn.SKLearnModel"]
                RT_XGBoost["mlserver_xgboost.XGBoostModel"]
                RT_LightGBM["mlserver_lightgbm.LightGBMModel"]
                RT_ONNX["mlserver_onnx.ONNXModel"]
            end

            subgraph Blocked["Blocked in Production Mode"]
                BlockArbitrary["Arbitrary Python import paths"]
                BlockEnvTarball["environment_tarball<br/>(sys.path injection)"]
                BlockEnvPath["environment_path<br/>(arbitrary tarball extraction)"]
                BlockWildcardCORS["Wildcard CORS origins"]
            end
        end

        subgraph ValidationRules["Import Path Validation"]
            Rule1["Must be dotted path"]
            Rule2["Uppercase class name required"]
            Rule3["No leading underscores"]
        end

        subgraph AuthDelegation["Authentication & Authorization"]
            NoBuiltInAuth["No built-in auth<br/>(REST & gRPC)"]
            KubeRbacProxy["Delegated to:<br/>kube-rbac-proxy sidecar"]
            IstioAuth["Delegated to:<br/>Istio RequestAuthentication"]
            KServeAuth["Delegated to:<br/>KServe Gateway"]
        end
    end

    %% Connections
    TrustedFile -->|"permits"| RT_SKLearn
    TrustedFile -->|"permits"| RT_XGBoost
    TrustedFile -->|"permits"| RT_LightGBM
    TrustedFile -->|"permits"| RT_ONNX
    TrustedFile -->|"blocks"| BlockArbitrary
    TrustedFile -->|"blocks"| BlockEnvTarball
    TrustedFile -->|"blocks"| BlockEnvPath
    TrustedFile -->|"blocks"| BlockWildcardCORS
    TrustedFile -.->|"uses"| Rule1
    TrustedFile -.->|"uses"| Rule2
    TrustedFile -.->|"uses"| Rule3

    NoBuiltInAuth -->|"delegates to"| KubeRbacProxy
    NoBuiltInAuth -->|"delegates to"| IstioAuth
    NoBuiltInAuth -->|"delegates to"| KServeAuth

    %% Styling
    style Note1 fill:#e0e0e0,stroke:#999,color:#333
    style TrustedFile fill:#f5a623,stroke:#d79b00,color:#fff
    style RT_SKLearn fill:#7ed321,stroke:#333,color:#fff
    style RT_XGBoost fill:#7ed321,stroke:#333,color:#fff
    style RT_LightGBM fill:#7ed321,stroke:#333,color:#fff
    style RT_ONNX fill:#7ed321,stroke:#333,color:#fff
    style BlockArbitrary fill:#e74c3c,stroke:#c0392b,color:#fff
    style BlockEnvTarball fill:#e74c3c,stroke:#c0392b,color:#fff
    style BlockEnvPath fill:#e74c3c,stroke:#c0392b,color:#fff
    style BlockWildcardCORS fill:#e74c3c,stroke:#c0392b,color:#fff
    style Rule1 fill:#dae8fc,stroke:#6c8ebf,color:#333
    style Rule2 fill:#dae8fc,stroke:#6c8ebf,color:#333
    style Rule3 fill:#dae8fc,stroke:#6c8ebf,color:#333
    style NoBuiltInAuth fill:#ff9800,stroke:#e65100,color:#fff
    style KubeRbacProxy fill:#5c6bc0,stroke:#333,color:#fff
    style IstioAuth fill:#5c6bc0,stroke:#333,color:#fff
    style KServeAuth fill:#5c6bc0,stroke:#333,color:#fff
