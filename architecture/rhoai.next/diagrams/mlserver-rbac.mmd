graph TD
    subgraph Container["MLServer Container Security"]
        direction TB

        subgraph Identity["Container Identity"]
            UID["Non-root User<br/>UID 1000"]
            NoSA["No Kubernetes RBAC<br/>(no API server access)"]
            NoSecrets["No Secrets Consumed<br/>(managed by KServe)"]
        end

        subgraph RuntimeSecurity["Runtime Security Model"]
            direction TB

            ProdMode["PRODUCTION Mode"]
            DevMode["DEVELOPMENT Mode"]

            TrustedFile["/etc/mlserver/trusted-runtimes.json<br/>(baked into image at build time)"]

            subgraph AllowedRuntimes["Allowed Runtimes (PRODUCTION)"]
                RT1["mlserver_lightgbm<br/>LightGBM"]
                RT2["mlserver_onnx<br/>ONNX Runtime"]
                RT3["mlserver_sklearn<br/>scikit-learn"]
                RT4["mlserver_xgboost<br/>XGBoost"]
            end

            subgraph Blocked["Blocked in PRODUCTION"]
                B1["Arbitrary Python imports"]
                B2["Wildcard CORS origins"]
                B3["Custom Python environments"]
            end
        end

        subgraph AuthModel["Authentication & Authorization"]
            direction TB

            AppAuth["Application Level<br/>Auth: None<br/>(all endpoints unauthenticated)"]

            PlatformAuth["Platform Level<br/>Auth: KServe / Istio / kube-rbac-proxy<br/>(enforced at ingress)"]

            SecurityEP["Security Endpoints<br/>GET /v2/runtimes (REST)<br/>RuntimeSecurity RPC (gRPC)<br/>Exposes mode + allowlist"]
        end
    end

    %% Relationships
    ProdMode -->|"detected by"| TrustedFile
    TrustedFile -->|"restricts to"| AllowedRuntimes
    ProdMode -->|"prevents"| Blocked

    DevMode -->|"allows ALL runtimes"| AllowedRuntimes
    DevMode -->|"permits"| Blocked

    %% External enforcement
    KServe["KServe Platform"] -->|"manages"| PlatformAuth
    KServe -->|"provisions"| NoSecrets

    style UID fill:#4a90e2,stroke:#333,color:#fff
    style NoSA fill:#4a90e2,stroke:#333,color:#fff
    style NoSecrets fill:#4a90e2,stroke:#333,color:#fff
    style ProdMode fill:#27ae60,stroke:#333,color:#fff
    style DevMode fill:#e67e22,stroke:#333,color:#fff
    style TrustedFile fill:#f5a623,stroke:#333
    style RT1 fill:#7ed321,stroke:#333
    style RT2 fill:#7ed321,stroke:#333
    style RT3 fill:#7ed321,stroke:#333
    style RT4 fill:#7ed321,stroke:#333
    style B1 fill:#e74c3c,stroke:#333,color:#fff
    style B2 fill:#e74c3c,stroke:#333,color:#fff
    style B3 fill:#e74c3c,stroke:#333,color:#fff
    style AppAuth fill:#dae8fc,stroke:#6c8ebf
    style PlatformAuth fill:#d5e8d4,stroke:#82b366
    style SecurityEP fill:#fff2cc,stroke:#d6b656
    style KServe fill:#f5a623,stroke:#333
