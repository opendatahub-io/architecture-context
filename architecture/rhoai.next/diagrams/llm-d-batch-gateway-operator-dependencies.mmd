graph LR
    Operator["LLM-D Batch Gateway<br/>Operator"]

    %% External Dependencies (Required)
    Operator -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    Operator -->|"chart rendering"| Helm["Helm v3<br/>v3.20.2"]

    %% External Dependencies (Optional)
    Operator -.->|"HTTPRoute ingress +<br/>ReferenceGrant secrets"| GatewayAPI["Gateway API<br/>v1.5.1"]
    Operator -.->|"TLS certificates"| CertManager["cert-manager<br/>v1.20.2"]
    Operator -.->|"ServiceMonitor +<br/>PrometheusRule"| PromOperator["Prometheus Operator<br/>v0.91.0"]

    %% Embedded Chart
    Operator -->|"embedded chart<br/>(Helm-as-library)"| BatchChart["batch-gateway<br/>Helm chart v0.1.0"]

    %% Internal Platform Dependencies
    PlatformOp["opendatahub-operator /<br/>rhods-operator"] -->|"deploys via kustomize<br/>+ params.env images"| Operator

    %% Managed Workloads
    Operator -->|"creates/manages"| APIServer["batch-gateway-apiserver"]
    Operator -->|"creates/manages"| Processor["batch-gateway-processor"]
    Operator -->|"creates/manages"| GC["batch-gateway-gc"]

    %% External Services (Egress)
    APIServer -->|"job state<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    APIServer -->|"file storage<br/>443/TCP"| S3["S3 / MinIO"]
    Processor -->|"inference dispatch<br/>configurable port"| InferenceGW["Inference Gateway<br/>(vLLM / GIE/EPP)"]
    Processor -->|"job polling<br/>5432/TCP"| PostgreSQL
    Processor -->|"result storage<br/>443/TCP"| S3
    GC -->|"cleanup queries<br/>5432/TCP"| PostgreSQL

    %% Alternative DB
    APIServer -.->|"alt: job state<br/>6379/TCP"| Redis["Redis / Valkey"]
    Processor -.->|"alt: job polling<br/>6379/TCP"| Redis

    %% Infrastructure
    Operator -->|"CRD watch, CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Helm fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style PromOperator fill:#999,stroke:#333,color:#fff
    style BatchChart fill:#999,stroke:#333,color:#fff
    style PlatformOp fill:#9b59b6,stroke:#333,color:#fff
    style APIServer fill:#7ed321,stroke:#333,color:#fff
    style Processor fill:#7ed321,stroke:#333,color:#fff
    style GC fill:#7ed321,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style Redis fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style InferenceGW fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
