graph TD
    subgraph AuthFlow["Authentication Flow"]
        direction TB
        Client["API Client<br/>(Bearer Token)"]
        AuthMW["Authentication Middleware"]
        Client -->|"Bearer Token<br/>(JWT or Custom)"| AuthMW
    end

    subgraph AuthProviders["Authentication Providers"]
        direction TB
        OAuth2["OAuth2 JWT Provider"]
        CustomAuth["Custom Auth Provider"]
        AuthMW -->|"JWT Token"| OAuth2
        AuthMW -->|"Custom Token"| CustomAuth
    end

    subgraph TokenValidation["Token Validation"]
        JWKS["JWKS URI<br/>(Public key fetch)"]
        Introspection["RFC 7662<br/>Token Introspection"]
        ExternalEndpoint["External Auth<br/>Endpoint"]
        OAuth2 -->|"HTTPS/443"| JWKS
        OAuth2 -->|"HTTPS/443<br/>Client Credentials"| Introspection
        CustomAuth -->|"HTTPS"| ExternalEndpoint
    end

    subgraph ClaimsExtraction["Claims Extraction & Mapping"]
        Claims["Extracted Claims:<br/>sub, groups, team,<br/>project, tenant, namespace"]
        Attributes["Mapped Attributes:<br/>roles, teams, projects,<br/>namespaces"]
        OAuth2 -->|"JWT claims"| Claims
        ExternalEndpoint -->|"response"| Claims
        Claims -->|"configurable mapping"| Attributes
    end

    subgraph RateLimiting["Rate Limiting (QuotaMiddleware)"]
        QuotaCheck["Quota Check"]
        AuthQuota["Authenticated<br/>1000 req/day<br/>(by token hash)"]
        AnonQuota["Anonymous<br/>100 req/day<br/>(by IP address)"]
        Attributes --> QuotaCheck
        QuotaCheck --> AuthQuota
        QuotaCheck --> AnonQuota
    end

    subgraph AccessControl["Access Control (Cedar-inspired ABAC)"]
        direction TB
        PolicyEngine["Policy Evaluation Engine<br/>(First match wins, default deny)"]

        subgraph Rules["Policy Rules"]
            PermitRule["PERMIT Rules"]
            ForbidRule["FORBID Rules"]
        end

        subgraph Matching["Match Criteria"]
            Principal["Principal<br/>(user identity)"]
            Actions["Actions<br/>create, read,<br/>update, delete"]
            Resources["Resources<br/>model::*, shield::*,<br/>vector-db::*, agent::*"]
        end

        subgraph Conditions["Conditions (when/unless)"]
            RoleMatch["Role Matching<br/>(user with X in roles)"]
            OwnerCheck["Ownership Check<br/>(user is owner)"]
            GroupMembership["Group Membership<br/>(user in owners teams)"]
        end

        QuotaCheck --> PolicyEngine
        PolicyEngine --> Rules
        Rules --> Matching
        Matching --> Conditions
    end

    subgraph Outcome["Access Decision"]
        Allow["ALLOW<br/>(permit matched)"]
        Deny["DENY<br/>(forbid matched<br/>or no match)"]
        Conditions --> Allow
        Conditions --> Deny
    end

    subgraph UnauthEndpoints["Unauthenticated Endpoints (Bypass)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc,<br/>/openapi.json"]
    end

    %% Styling
    style Client fill:#ecf0f1,stroke:#333
    style AuthMW fill:#e74c3c,color:#fff
    style OAuth2 fill:#3498db,color:#fff
    style CustomAuth fill:#3498db,color:#fff
    style JWKS fill:#f39c12,color:#fff
    style Introspection fill:#f39c12,color:#fff
    style ExternalEndpoint fill:#f39c12,color:#fff
    style Claims fill:#9b59b6,color:#fff
    style Attributes fill:#9b59b6,color:#fff
    style QuotaCheck fill:#e67e22,color:#fff
    style AuthQuota fill:#e67e22,color:#fff
    style AnonQuota fill:#e67e22,color:#fff
    style PolicyEngine fill:#2c3e50,color:#fff
    style PermitRule fill:#27ae60,color:#fff
    style ForbidRule fill:#c0392b,color:#fff
    style Principal fill:#7f8c8d,color:#fff
    style Actions fill:#7f8c8d,color:#fff
    style Resources fill:#7f8c8d,color:#fff
    style RoleMatch fill:#8e44ad,color:#fff
    style OwnerCheck fill:#8e44ad,color:#fff
    style GroupMembership fill:#8e44ad,color:#fff
    style Allow fill:#27ae60,color:#fff
    style Deny fill:#c0392b,color:#fff
    style Health fill:#bdc3c7,stroke:#333
    style Version fill:#bdc3c7,stroke:#333
    style Docs fill:#bdc3c7,stroke:#333
