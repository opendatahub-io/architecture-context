graph TD
    subgraph AuthN["Authentication (Token Validation)"]
        JWT["OAuth2 JWT (JWKS)<br/>Signature validation<br/>Claims extraction"]
        Introspect["Token Introspection (RFC 7662)<br/>HTTP Basic Auth to IdP"]
        CustomAuth["Custom Auth Provider<br/>External endpoint delegation"]
    end

    subgraph Principals["Principals (Extracted from Token)"]
        AuthUser["Authenticated User<br/>principal: subject claim<br/>attributes: roles, teams, etc."]
        AnonUser["Anonymous User<br/>principal: _anonymous<br/>no attributes"]
    end

    subgraph QuotaLayer["Rate Limiting (Quota Middleware)"]
        QuotaAuth["Authenticated Quota<br/>1000 requests/day<br/>(configurable)"]
        QuotaAnon["Anonymous Quota<br/>100 requests/day<br/>(configurable)"]
    end

    subgraph ABAC["Access Control Engine (Cedar-inspired ABAC)"]
        direction TB
        PolicyEngine["Policy Engine<br/>Evaluates rules in order<br/>First match wins"]

        subgraph Actions["Actions"]
            Create["CREATE"]
            Read["READ"]
            Update["UPDATE"]
            Delete["DELETE"]
        end

        subgraph Conditions["Conditions"]
            IsOwner["user is owner<br/>(resource creator)"]
            HasAttr["user with &lt;value&gt;<br/>in &lt;attribute&gt;"]
            InOwners["user in owners<br/>&lt;attribute&gt;"]
        end

        subgraph Decisions["Decisions"]
            Permit["PERMIT<br/>(allow action)"]
            Forbid["FORBID<br/>(deny action)"]
        end

        PolicyEngine --> Actions
        Actions --> Conditions
        Conditions --> Decisions
    end

    subgraph Resources["Protected Resources (type::identifier)"]
        Models["model::*<br/>e.g., model::llama-3"]
        Shields["shield::*<br/>e.g., shield::llama-guard"]
        VectorDBs["vector_db::*<br/>e.g., vector_db::my-docs"]
        Datasets["dataset::*<br/>e.g., dataset::eval-data"]
        ToolGroups["toolgroup::*<br/>e.g., toolgroup::search"]
        ScoringFns["scoring_fn::*<br/>e.g., scoring_fn::bleu"]
        Benchmarks["benchmark::*<br/>e.g., benchmark::mmlu"]
    end

    subgraph Endpoints["API Endpoints"]
        Public["Public (No Auth)<br/>/v1/health<br/>/v1/version<br/>/docs · /redoc · /openapi.json"]
        Protected["Protected (Bearer Required)<br/>All /v1/* API endpoints<br/>(inference, agents, safety, etc.)"]
    end

    %% Flows
    JWT --> AuthUser
    Introspect --> AuthUser
    CustomAuth --> AuthUser
    Public -.->|"no auth required"| AnonUser
    Protected -->|"Bearer token required"| JWT
    Protected -->|"Bearer token required"| Introspect
    Protected -->|"Bearer token required"| CustomAuth

    AuthUser --> QuotaAuth
    AnonUser --> QuotaAnon

    QuotaAuth --> PolicyEngine
    QuotaAnon --> PolicyEngine

    PolicyEngine -->|"evaluate per-resource"| Models
    PolicyEngine -->|"evaluate per-resource"| Shields
    PolicyEngine -->|"evaluate per-resource"| VectorDBs
    PolicyEngine -->|"evaluate per-resource"| Datasets
    PolicyEngine -->|"evaluate per-resource"| ToolGroups
    PolicyEngine -->|"evaluate per-resource"| ScoringFns
    PolicyEngine -->|"evaluate per-resource"| Benchmarks

