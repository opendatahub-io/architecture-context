graph TD
    subgraph AuthLayer["Authentication Layer (ASGI Middleware)"]
        direction TB
        AuthMW["AuthenticationMiddleware"]

        subgraph Strategies["Authentication Strategies"]
            JWKS["JWT/JWKS Validation<br/>Periodic key refresh<br/>from JWKS endpoint"]
            Introspection["Token Introspection<br/>RFC 7662<br/>Client credentials"]
            CustomAuth["Custom Auth Endpoint<br/>Forward token for<br/>external validation"]
        end

        AuthMW --> JWKS
        AuthMW --> Introspection
        AuthMW --> CustomAuth
    end

    subgraph UserAttributes["User Attributes (from JWT Claims)"]
        direction LR
        Roles["roles<br/>(e.g., admin, user)"]
        Teams["teams<br/>(e.g., ml-team)"]
        Projects["projects<br/>(e.g., project-alpha)"]
        Namespaces["namespaces"]
    end

    subgraph RateLimiting["Rate Limiting (QuotaMiddleware)"]
        AnonQuota["Anonymous<br/>100 req/day"]
        AuthQuota["Authenticated<br/>1000 req/day"]
    end

    subgraph ABACSystem["ABAC Engine (Cedar-like Policy Rules)"]
        direction TB
        PolicyEval["Policy Evaluator"]

        subgraph Rules["Access Rules"]
            PermitRule["PERMIT<br/>when: user in owners<br/>when: user with admin in roles"]
            ForbidRule["FORBID<br/>unless: user in team<br/>unless: namespace matches"]
        end

        PolicyEval --> PermitRule
        PolicyEval --> ForbidRule
    end

    subgraph ProtectedResources["Protected API Resources"]
        direction TB
        Models["/v1/models<br/>Model Registry"]
        Shields["/v1/shields<br/>Safety Shields"]
        Datasets["/v1/datasets<br/>Dataset Registry"]
        VectorDBs["/v1/vector-dbs<br/>Vector DB Registry"]
        Inference["/v1/inference/*<br/>Chat, Completion, Embeddings"]
        Agents["/v1/agents/*<br/>Agent Creation & Turns"]
        Safety["/v1/safety/*<br/>Shield Execution"]
        VectorIO["/v1/vector-io/*<br/>Insert & Query"]
        Eval["/v1/eval/*<br/>Benchmark Jobs"]
        Tools["/v1/tool-runtime/*<br/>Tool Invocation"]
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /openapi.json"]
    end

    %% Flow
    AuthMW -->|extracts| UserAttributes
    UserAttributes -->|fed into| PolicyEval
    AuthMW -->|determines| RateLimiting

    PolicyEval -->|"per-resource<br/>permit/forbid"| ProtectedResources

    %% Public bypass
    PublicEndpoints -.->|"bypasses auth"| AuthMW

    %% Styling
    style AuthMW fill:#4a90e2,stroke:#333,color:#fff
    style JWKS fill:#fff3e0,stroke:#f5a623
    style Introspection fill:#fff3e0,stroke:#f5a623
    style CustomAuth fill:#fff3e0,stroke:#f5a623

    style PolicyEval fill:#f5a623,stroke:#333,color:#fff
    style PermitRule fill:#d5e8d4,stroke:#82b366
    style ForbidRule fill:#f8cecc,stroke:#b85450

    style AnonQuota fill:#f8cecc,stroke:#b85450
    style AuthQuota fill:#d5e8d4,stroke:#82b366

    style Models fill:#e8f5e9,stroke:#4caf50
    style Shields fill:#e8f5e9,stroke:#4caf50
    style Datasets fill:#e8f5e9,stroke:#4caf50
    style VectorDBs fill:#e8f5e9,stroke:#4caf50
    style Inference fill:#e8f5e9,stroke:#4caf50
    style Agents fill:#e8f5e9,stroke:#4caf50
    style Safety fill:#e8f5e9,stroke:#4caf50
    style VectorIO fill:#e8f5e9,stroke:#4caf50
    style Eval fill:#e8f5e9,stroke:#4caf50
