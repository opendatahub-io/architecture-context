graph TD
    subgraph ClientAuth["Client Authentication"]
        Client["Client / Application<br/>Bearer Token (JWT)"]
    end

    subgraph AuthStrategies["Authentication Strategies (Middleware)"]
        direction LR
        JWKSAuth["JWKS Validation<br/>Fetches public keys<br/>from OAuth2 provider<br/>Periodic key refresh"]
        IntrospectionAuth["Token Introspection<br/>RFC 7662<br/>Client credentials<br/>Custom CA support"]
        CustomAuthEP["Custom Auth Endpoint<br/>Sends token in body<br/>External validation"]
    end

    subgraph ABACSystem["ABAC Engine (Cedar-like Policy Language)"]
        direction TB

        subgraph PolicyRules["Access Rules"]
            PermitRule["PERMIT Rules<br/>when: user in owners roles<br/>when: user with admin in roles"]
            ForbidRule["FORBID Rules<br/>unless: user has required attribute<br/>unless: resource.owner == user"]
        end

        subgraph UserAttributes["User Attributes (from JWT Claims)"]
            UserID["user_id"]
            Roles["roles[]"]
            Teams["teams[]"]
            Projects["projects[]"]
            CustomAttrs["custom attributes"]
        end
    end

    subgraph RateLimiting["Rate Limiting (QuotaMiddleware)"]
        AnonQuota["Anonymous<br/>100 req/day"]
        AuthQuota["Authenticated<br/>1000 req/day"]
    end

    subgraph ProtectedResources["Protected API Resources"]
        direction LR
        InferenceRes["Inference API<br/>/v1/inference/*<br/>/v1/openai/v1/*"]
        AgentsRes["Agents API<br/>/v1/agents/*"]
        SafetyRes["Safety API<br/>/v1/safety/*"]
        VectorRes["Vector IO API<br/>/v1/vector-io/*"]
        RegistryRes["Registry APIs<br/>/v1/models<br/>/v1/shields<br/>/v1/datasets"]
        EvalRes["Eval / Scoring<br/>/v1/eval/*<br/>/v1/scoring/*"]
        TelemetryRes["Telemetry API<br/>/v1/telemetry/*"]
        ToolRes["Tool Runtime<br/>/v1/tool-runtime/*"]
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc<br/>/openapi.json"]
    end

    %% Flow
    Client -->|"Bearer Token"| JWKSAuth
    Client -->|"Bearer Token"| IntrospectionAuth
    Client -->|"Bearer Token"| CustomAuthEP

    JWKSAuth -->|"extracts claims"| UserAttributes
    IntrospectionAuth -->|"extracts claims"| UserAttributes
    CustomAuthEP -->|"extracts claims"| UserAttributes

    UserAttributes -->|"evaluated against"| PolicyRules

    PolicyRules -->|"PERMIT"| RateLimiting
    PolicyRules -->|"FORBID → 403"| Denied["Request Denied<br/>403 Forbidden"]

    AnonQuota -->|"within limit"| ProtectedResources
    AuthQuota -->|"within limit"| ProtectedResources
    AnonQuota -->|"exceeded"| RateDenied["Rate Limited<br/>429 Too Many Requests"]
    AuthQuota -->|"exceeded"| RateDenied

    Client -.->|"no auth required"| PublicEndpoints

    %% Styling
    style Client fill:#4a90e2,stroke:#333,color:#fff
    style JWKSAuth fill:#fff3e0,stroke:#ef6c00
    style IntrospectionAuth fill:#fff3e0,stroke:#ef6c00
    style CustomAuthEP fill:#fff3e0,stroke:#ef6c00
    style PermitRule fill:#c8e6c9,stroke:#2e7d32
    style ForbidRule fill:#ffcdd2,stroke:#c62828
    style AnonQuota fill:#fff9c4,stroke:#f57f17
    style AuthQuota fill:#fff9c4,stroke:#f57f17
    style Denied fill:#ef5350,stroke:#333,color:#fff
    style RateDenied fill:#ef5350,stroke:#333,color:#fff
    style InferenceRes fill:#e8f5e9,stroke:#2e7d32
    style AgentsRes fill:#e8f5e9,stroke:#2e7d32
    style SafetyRes fill:#e8f5e9,stroke:#2e7d32
    style VectorRes fill:#e8f5e9,stroke:#2e7d32
    style RegistryRes fill:#e8f5e9,stroke:#2e7d32
    style EvalRes fill:#e8f5e9,stroke:#2e7d32
    style TelemetryRes fill:#e8f5e9,stroke:#2e7d32
    style ToolRes fill:#e8f5e9,stroke:#2e7d32
    style Health fill:#e0f2f1,stroke:#00695c
    style Version fill:#e0f2f1,stroke:#00695c
    style Docs fill:#e0f2f1,stroke:#00695c
