graph TD
    subgraph AuthProviders["Authentication Providers"]
        OAuth2["OAuth2 JWT Provider<br/>(JWKS / RFC 7662 Introspection)"]
        CustomProv["Custom Auth Provider<br/>(External HTTP endpoint)"]
    end

    subgraph ClaimExtraction["Claim Extraction & Attribute Mapping"]
        Claims["JWT Claims Extracted:<br/>sub, groups, team,<br/>project, tenant, namespace"]
        AttrMap["Attribute Mapping:<br/>claims → roles, teams,<br/>projects, namespaces"]
    end

    subgraph AccessControlEngine["Access Control Engine (Cedar-inspired ABAC)"]
        direction TB

        subgraph PolicyEval["Policy Evaluation (first match wins)"]
            Rule1["Rule 1: permit<br/>principal: admin role<br/>actions: create, read, update, delete<br/>resource: *"]
            Rule2["Rule 2: permit<br/>principal: user role<br/>actions: read<br/>resource: model::*"]
            Rule3["Rule 3: permit<br/>principal: any<br/>actions: create, read, update, delete<br/>resource: owned<br/>when: user is owner"]
            Rule4["Rule 4: forbid<br/>principal: any<br/>actions: delete<br/>resource: model::*<br/>unless: user with admin in roles"]
            DefaultDeny["Default: DENY<br/>(no matching rule)"]
        end

        subgraph Conditions["Condition Types"]
            AttrMatch["Attribute Matching<br/>user with X in roles"]
            OwnerCheck["Ownership Check<br/>user is owner"]
            GroupMember["Group Membership<br/>user in owners teams"]
        end
    end

    subgraph Resources["Protected Resources (type-qualified)"]
        Models["model::*<br/>(LLM models)"]
        Shields["shield::*<br/>(safety shields)"]
        VectorDBs["vector_db::*<br/>(vector databases)"]
        Datasets["dataset::*<br/>(datasets)"]
        Agents["agent::*<br/>(agents)"]
        Benchmarks["benchmark::*<br/>(eval benchmarks)"]
        ScoringFns["scoring_fn::*<br/>(scoring functions)"]
        ToolGroups["toolgroup::*<br/>(tool groups)"]
    end

    subgraph Actions["Actions (CRUD)"]
        Create["create"]
        Read["read"]
        Update["update"]
        Delete["delete"]
    end

    subgraph RateLimiting["Rate Limiting (Quota Middleware)"]
        AuthQuota["Authenticated Clients<br/>1000 req/day (default)<br/>Identified by: token"]
        AnonQuota["Anonymous Clients<br/>100 req/day (default)<br/>Identified by: IP address"]
        QuotaStore["Counter Storage:<br/>SQLite KV backend"]
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth Required)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc<br/>/openapi.json"]
    end

    %% Flows
    OAuth2 -->|"validates token"| Claims
    CustomProv -->|"delegates validation"| Claims
    Claims -->|"maps to"| AttrMap
    AttrMap -->|"feeds attributes"| PolicyEval

    PolicyEval -->|"evaluates against"| Resources
    PolicyEval -->|"checks"| Actions
    PolicyEval -->|"uses"| Conditions

    Rule1 --> Rule2
    Rule2 --> Rule3
    Rule3 --> Rule4
    Rule4 --> DefaultDeny

    AttrMap -->|"client identity"| RateLimiting
    AuthQuota --> QuotaStore
    AnonQuota --> QuotaStore

