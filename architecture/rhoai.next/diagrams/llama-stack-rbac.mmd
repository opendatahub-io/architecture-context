graph TD
    subgraph AuthLayer["Authentication Layer"]
        direction LR
        OAuth2["OAuth2 JWT Provider<br/>(JWKS / Token Introspection)"]
        CustomAuth["Custom Auth Provider<br/>(External HTTP Endpoint)"]
    end

    subgraph MiddlewareChain["ASGI Middleware Chain"]
        direction TB
        AuthMW["AuthenticationMiddleware<br/>Validates Bearer Token<br/>Extracts Principal + Attributes"]
        QuotaMW["QuotaMiddleware<br/>Per-Client Rate Limiting"]
        ABACMW["AccessControlMiddleware<br/>Cedar-inspired Policy Engine"]
    end

    subgraph PrincipalAttrs["Principal Attributes (from Token Claims)"]
        direction LR
        Sub["sub → User Identity"]
        Roles["groups → Roles"]
        Teams["team → Team Membership"]
        Projects["project → Project Scope"]
        Namespaces["namespace → Namespace Scope"]
    end

    subgraph PolicyEngine["Cedar-Inspired Policy Engine"]
        direction TB

        subgraph PolicyRules["Policy Rules (First Match Wins)"]
            Rule1["permit<br/>principal: admin role<br/>actions: ALL<br/>resource: ALL"]
            Rule2["permit<br/>principal: ANY<br/>actions: read<br/>resource: model::*<br/>when: user has 'viewer' in roles"]
            Rule3["permit<br/>principal: ANY<br/>actions: create, read, update, delete<br/>resource: *<br/>when: user is owner"]
            Rule4["forbid<br/>principal: ANY<br/>actions: delete<br/>resource: shield::*<br/>unless: user has 'admin' in roles"]
            DefaultDeny["DEFAULT: DENY<br/>(no matching rule)"]
        end
    end

    subgraph Actions["Supported Actions"]
        direction LR
        Create["create"]
        Read["read"]
        Update["update"]
        Delete["delete"]
    end

    subgraph Resources["Resource Types (type-qualified)"]
        direction TB
        Models["model::*<br/>(Registered Models)"]
        Shields["shield::*<br/>(Safety Shields)"]
        VectorDBs["vector_db::*<br/>(Vector Databases)"]
        Datasets["dataset::*<br/>(Datasets)"]
        Agents["agent::*<br/>(Agents)"]
        Benchmarks["benchmark::*<br/>(Eval Benchmarks)"]
        ScoringFns["scoring_fn::*<br/>(Scoring Functions)"]
        ToolGroups["toolgroup::*<br/>(Tool Groups)"]
    end

    subgraph RateLimiting["Rate Limiting (QuotaMiddleware)"]
        direction LR
        AuthQuota["Authenticated Client<br/>1000 requests/day<br/>Identity: Token Hash"]
        AnonQuota["Anonymous Client<br/>100 requests/day<br/>Identity: IP Address"]
        QuotaStore["SQLite KV Store<br/>Counter Persistence"]
    end

    %% Auth flow
    OAuth2 -->|"JWT claims"| AuthMW
    CustomAuth -->|"principal + attributes"| AuthMW

    %% Middleware chain
    AuthMW -->|"extracts"| PrincipalAttrs
    AuthMW --> QuotaMW
    QuotaMW --> ABACMW

    %% Policy evaluation
    PrincipalAttrs -->|"principal"| PolicyEngine
    Actions -->|"action"| PolicyEngine
    Resources -->|"resource"| PolicyEngine
    ABACMW -->|"evaluates"| PolicyEngine

    %% Rate limiting
    QuotaMW -->|"checks"| AuthQuota
    QuotaMW -->|"checks"| AnonQuota
    AuthQuota --> QuotaStore
    AnonQuota --> QuotaStore

    %% Public endpoints (bypass)
    subgraph PublicEndpoints["Public Endpoints (No Auth Required)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc, /openapi.json"]
    end

    %% Styling
    style AuthMW fill:#f5a623,stroke:#333,stroke-width:2px
    style QuotaMW fill:#f5a623,stroke:#333,stroke-width:2px
    style ABACMW fill:#f5a623,stroke:#333,stroke-width:2px
    style OAuth2 fill:#4a90e2,stroke:#333,color:#fff
    style CustomAuth fill:#4a90e2,stroke:#333,color:#fff
    style Rule1 fill:#7ed321,stroke:#333
    style Rule2 fill:#7ed321,stroke:#333
    style Rule3 fill:#7ed321,stroke:#333
    style Rule4 fill:#d32f2f,stroke:#333,color:#fff
    style DefaultDeny fill:#d32f2f,stroke:#333,color:#fff
    style Models fill:#e3f2fd,stroke:#1565c0
    style Shields fill:#e3f2fd,stroke:#1565c0
    style VectorDBs fill:#e3f2fd,stroke:#1565c0
    style Datasets fill:#e3f2fd,stroke:#1565c0
    style Agents fill:#e3f2fd,stroke:#1565c0
    style Benchmarks fill:#e3f2fd,stroke:#1565c0
    style ScoringFns fill:#e3f2fd,stroke:#1565c0
    style ToolGroups fill:#e3f2fd,stroke:#1565c0
    style Health fill:#c8e6c9,stroke:#333
    style Version fill:#c8e6c9,stroke:#333
    style Docs fill:#c8e6c9,stroke:#333
