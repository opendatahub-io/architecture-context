graph TD
    subgraph AuthLayer["Authentication Layer"]
        JWT["Bearer JWT Token<br/>(OAuth2 JWKS / Introspection)"]
        CustomAuth["Custom Auth Provider<br/>(External endpoint)"]
    end

    subgraph UserAttrs["Extracted User Attributes"]
        Principal["Principal<br/>(sub / username)"]
        Roles["Roles<br/>(from JWT claims)"]
        Teams["Teams<br/>(from JWT claims)"]
        Projects["Projects<br/>(from JWT claims)"]
    end

    subgraph QuotaLayer["Quota Enforcement"]
        QuotaMW["Quota Middleware"]
        AnonQuota["Anonymous Quota<br/>100 requests/day"]
        AuthQuota["Authenticated Quota<br/>1000 requests/day"]
        QuotaStore["SQLite KV Store<br/>(persistent counters)"]
    end

    subgraph ABACEngine["Cedar-Inspired ABAC Engine"]
        PolicyEval["Policy Evaluator"]

        subgraph Rules["Policy Rules"]
            PermitRule["permit(<br/>  principal: user,<br/>  action: [CREATE, READ,<br/>    UPDATE, DELETE],<br/>  resource: type::id<br/>)<br/>when { conditions }"]
            ForbidRule["forbid(<br/>  principal: user,<br/>  action: [CREATE, READ,<br/>    UPDATE, DELETE],<br/>  resource: type::id<br/>)<br/>when { conditions }"]
        end

        subgraph Conditions["Condition Types"]
            IsOwner["user is owner<br/>(resource creator)"]
            InAttribute["user with value<br/>in attribute<br/>(role/team match)"]
            InOwners["user in owners<br/>attribute<br/>(shared ownership)"]
        end
    end

    subgraph Resources["Protected Resources"]
        Models["Models<br/>model::llama-3<br/>model::mistral-7b"]
        Shields["Shields<br/>shield::llama-guard"]
        VectorDBs["Vector DBs<br/>vector_db::my-rag-store"]
        Agents["Agents<br/>agent::my-assistant"]
        Datasets["Datasets<br/>dataset::eval-set"]
        ToolGroups["Tool Groups<br/>toolgroup::search-tools"]
        ScoringFns["Scoring Functions<br/>scoring_fn::accuracy"]
        Benchmarks["Benchmarks<br/>benchmark::mmlu"]
    end

    subgraph Actions["API Actions"]
        Create["CREATE<br/>(POST register/create)"]
        Read["READ<br/>(GET list/get)"]
        Update["UPDATE<br/>(POST update)"]
        Delete["DELETE<br/>(DELETE unregister)"]
    end

    %% Flows
    JWT --> Principal
    JWT --> Roles
    JWT --> Teams
    JWT --> Projects
    CustomAuth --> Principal

    Principal --> QuotaMW
    QuotaMW --> AnonQuota
    QuotaMW --> AuthQuota
    QuotaMW --> QuotaStore

    Principal --> PolicyEval
    Roles --> PolicyEval
    Teams --> PolicyEval
    Projects --> PolicyEval

    PolicyEval --> PermitRule
    PolicyEval --> ForbidRule

    PermitRule --> IsOwner
    PermitRule --> InAttribute
    PermitRule --> InOwners
    ForbidRule --> IsOwner
    ForbidRule --> InAttribute

    PolicyEval -->|"evaluates against"| Create
    PolicyEval -->|"evaluates against"| Read
    PolicyEval -->|"evaluates against"| Update
    PolicyEval -->|"evaluates against"| Delete

    Create --> Models
    Create --> Shields
    Create --> VectorDBs
    Create --> Agents
    Create --> Datasets
    Create --> ToolGroups
    Read --> Models
    Read --> Shields
    Read --> VectorDBs
    Read --> Agents
    Read --> Datasets
    Read --> ScoringFns
    Read --> Benchmarks
    Delete --> Models
    Delete --> Shields
    Delete --> VectorDBs
    Delete --> Agents
    Delete --> Datasets
    Delete --> ToolGroups

    %% Unauthenticated endpoints
    subgraph OpenEndpoints["Open Endpoints (No Auth)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc,<br/>/openapi.json"]
    end

    %% Styling
    style JWT fill:#4a90e2,stroke:#333,color:#fff
    style CustomAuth fill:#4a90e2,stroke:#333,color:#fff
    style Principal fill:#f5a623,stroke:#333
    style Roles fill:#f5a623,stroke:#333
    style Teams fill:#f5a623,stroke:#333
    style Projects fill:#f5a623,stroke:#333
    style PolicyEval fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PermitRule fill:#d5e8d4,stroke:#82b366
    style ForbidRule fill:#f8cecc,stroke:#b85450
    style IsOwner fill:#fff2cc,stroke:#d6b656
    style InAttribute fill:#fff2cc,stroke:#d6b656
    style InOwners fill:#fff2cc,stroke:#d6b656
    style QuotaMW fill:#e1d5e7,stroke:#9673a6
    style AnonQuota fill:#e1d5e7,stroke:#9673a6
    style AuthQuota fill:#e1d5e7,stroke:#9673a6
    style QuotaStore fill:#d5e8d4,stroke:#82b366
    style Models fill:#7ed321,stroke:#333
    style Shields fill:#7ed321,stroke:#333
    style VectorDBs fill:#7ed321,stroke:#333
    style Agents fill:#7ed321,stroke:#333
    style Datasets fill:#7ed321,stroke:#333
    style ToolGroups fill:#7ed321,stroke:#333
    style ScoringFns fill:#7ed321,stroke:#333
    style Benchmarks fill:#7ed321,stroke:#333
    style Create fill:#dae8fc,stroke:#6c8ebf
    style Read fill:#dae8fc,stroke:#6c8ebf
    style Update fill:#dae8fc,stroke:#6c8ebf
    style Delete fill:#dae8fc,stroke:#6c8ebf
