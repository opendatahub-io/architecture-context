    style AuthMiddleware fill:#e74c3c,stroke:#333,color:#fff
    style AccessControl fill:#e74c3c,stroke:#333,color:#fff
    style JWKS fill:#f39c12,stroke:#333,color:#fff
    style Introspection fill:#f39c12,stroke:#333,color:#fff
    style CustomEndpoint fill:#f39c12,stroke:#333,color:#fff
