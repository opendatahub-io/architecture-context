graph TD
    subgraph ClientLayer["Client Layer"]
        AnonClient["Anonymous Client<br/>(no token)"]
        AuthClient["Authenticated Client<br/>(JWT Bearer Token)"]
    end

    subgraph AuthenticationLayer["Authentication Layer (ASGI Middleware)"]
        direction TB

        subgraph AuthStrategies["Authentication Strategies"]
            JWKS["JWT via JWKS<br/>Validates token signature<br/>Periodic key refresh"]
            Introspection["Token Introspection<br/>RFC 7662<br/>Client credentials"]
            CustomEndpoint["Custom Auth Endpoint<br/>External token validation"]
        end

        AuthMiddleware["AuthenticationMiddleware<br/>Extracts user attributes<br/>from JWT claims"]
    end

    subgraph QuotaLayer["Rate Limiting (QuotaMiddleware)"]
        AnonQuota["Anonymous<br/>100 req/day"]
        AuthQuota["Authenticated<br/>1000 req/day<br/>(configurable)"]
    end

    subgraph ABACLayer["ABAC Access Control (Cedar-like)"]
        direction TB

        subgraph PolicyEngine["Policy Engine"]
            AccessControl["AccessControl Module"]
        end

        subgraph Rules["Access Rules"]
            OwnerRule["Rule: permit<br/>when: user in owners roles"]
            AdminRule["Rule: permit<br/>when: user with admin in roles"]
            ForbidRule["Rule: forbid<br/>unless: user in allowed_namespaces"]
            CustomRule["Rule: permit/forbid<br/>with when/unless conditions"]
        end

        subgraph Attributes["User Attributes (from JWT)"]
            Roles["roles: [admin, user, ...]"]
            Namespaces["namespaces: [ns1, ns2, ...]"]
            Teams["teams: [team1, team2, ...]"]
        end

        AccessControl --> Rules
        AuthMiddleware --> Attributes
        Attributes --> AccessControl
    end

    subgraph Resources["Protected API Resources"]
        direction LR
        Models["Models<br/>/v1/models"]
        Shields["Shields<br/>/v1/shields"]
        Datasets["Datasets<br/>/v1/datasets"]
        VectorDBs["Vector DBs<br/>/v1/vector-dbs"]
        Benchmarks["Benchmarks<br/>/v1/eval/benchmarks"]
        Inference["Inference<br/>/v1/inference/*"]
        Agents["Agents<br/>/v1/agents/*"]
        Safety["Safety<br/>/v1/safety/*"]
        VectorIO["Vector IO<br/>/v1/vector-io/*"]
    end

    subgraph PublicEndpoints["Public Endpoints (No Auth Required)"]
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc"]
        OpenAPI["/openapi.json"]
    end

    %% Flow
    AnonClient -->|"No token"| AnonQuota
    AnonClient -->|"Direct access"| PublicEndpoints
    AuthClient -->|"Bearer Token"| AuthMiddleware
    AuthMiddleware --> JWKS
    AuthMiddleware --> Introspection
    AuthMiddleware --> CustomEndpoint
    AuthMiddleware -->|"User attributes"| AuthQuota
    AnonQuota -->|"100/day limit"| Resources
    AuthQuota -->|"1000/day limit"| AccessControl
    AccessControl -->|"permit/forbid"| Resources

