    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333,color:#fff
    style YuniKorn fill:#999,stroke:#333,color:#fff
    style SchedulerPlugins fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff

    %% Internal platform
    style RHODSOperator fill:#7ed321,stroke:#333,color:#fff
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style OAuthProxy fill:#7ed321,stroke:#333,color:#fff

