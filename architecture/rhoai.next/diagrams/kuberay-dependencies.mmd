graph LR
    KubeRay["KubeRay Operator"]

    %% External Dependencies (required)
    KubeRay -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.1"]
    KubeRay -->|"version parsing"| Semver["Masterminds/semver<br/>v3.3.1"]

    %% External Dependencies (optional)
    KubeRay -.->|"mTLS certs<br/>(when mTLS enabled)"| CertManager["cert-manager<br/>v1.18.2"]
    KubeRay -.->|"OpenShift APIs<br/>(on OpenShift)"| OpenshiftAPI["openshift/api<br/>v0.0.0-20250602"]
    KubeRay -.->|"HTTPRoute/ReferenceGrant<br/>(OIDC auth on OpenShift)"| GatewayAPI["gateway-api<br/>v1.4.0"]
    KubeRay -.->|"gang scheduling<br/>(optional)"| SchedulerPlugins["scheduler-plugins<br/>v0.31.8"]
    KubeRay -.->|"gang scheduling<br/>(optional)"| Volcano["volcano.sh/apis<br/>v1.12.1"]

    %% Internal Platform Dependencies
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize"| KubeRay
    KubeRay -->|"HTTPRoute parentRef<br/>for dashboard access"| DSGateway["data-science-gateway<br/>(Gateway CR)"]
    KubeRay -->|"sidecar injection<br/>for OIDC auth"| KRBProxy["kube-rbac-proxy<br/>(sidecar image)"]
    KubeRay -->|"webhook TLS cert<br/>provisioning"| ServiceCA["OpenShift<br/>service-ca"]
    KubeRay -->|"REST API calls<br/>8265/TCP"| RayDashboard["Ray Dashboard<br/>(per-cluster)"]

    %% Peer component integrations
    CodeFlare["CodeFlare<br/>Operator"] -->|"mutating/validating<br/>webhooks"| KubeRay
    Kueue["Kueue"] -->|"mutating/validating<br/>webhooks + managedBy"| KubeRay

    %% External Services
    KubeRay -->|"resource CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    KubeRay -.->|"GCS persistence<br/>6379/TCP (optional)"| Redis["External Redis"]

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Semver fill:#999,stroke:#333,color:#fff

    %% Optional external deps
    style CertManager fill:#bbb,stroke:#333,color:#333
    style OpenshiftAPI fill:#bbb,stroke:#333,color:#333
    style GatewayAPI fill:#bbb,stroke:#333,color:#333
    style SchedulerPlugins fill:#bbb,stroke:#333,color:#333
    style Volcano fill:#bbb,stroke:#333,color:#333

    %% Internal RHOAI deps
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style KRBProxy fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style RayDashboard fill:#7ed321,stroke:#333,color:#fff

    %% Peer components
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Redis fill:#f5a623,stroke:#333,color:#fff
