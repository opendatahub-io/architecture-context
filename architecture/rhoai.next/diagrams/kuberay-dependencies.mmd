graph LR
    KubeRay["KubeRay Operator"]

    %% Required External Dependencies
    KubeRay -->|"controller framework<br/>v0.22.1 (required)"| ControllerRuntime["controller-runtime"]

    %% Optional External Dependencies
    KubeRay -->|"mTLS certs<br/>v1.18.2 (optional)"| CertManager["cert-manager"]
    KubeRay -->|"HTTPRoute ingress<br/>v1.4.0 (optional)"| GatewayAPI["Gateway API"]
    KubeRay -->|"Route detection<br/>(optional)"| OpenShiftAPI["openshift/api"]
    KubeRay -->|"gang scheduling<br/>v1.12.1 (optional)"| Volcano["Volcano"]
    KubeRay -->|"batch scheduling<br/>(optional)"| YuniKorn["YuniKorn"]
    KubeRay -->|"scheduler framework<br/>v0.31.8 (optional)"| SchedulerPlugins["scheduler-plugins"]
    KubeRay -->|"GCS fault tolerance<br/>(optional)"| Redis["Redis"]

    %% Internal Platform Dependencies
    RHODSOperator["rhods-operator /<br/>opendatahub-operator"] -->|"kustomize deploy"| KubeRay
    KubeRay -->|"HTTPRoute parent"| DSGateway["data-science-gateway<br/>(Gateway CR)"]
    KubeRay -->|"auth sidecar inject"| KubeRBACProxy["ose-kube-rbac-proxy"]
    KubeRay -.->|"alt auth proxy"| OAuthProxy["ose-oauth-proxy"]

    %% Core K8s
    KubeRay -->|"CRD watches<br/>CRUD operations<br/>HTTPS/443"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumers)
    KubeRay -->|"job submit/status<br/>serve config<br/>HTTP/8265"| RayDashboard["Ray Dashboard API"]
    KubeRay -->|"health check<br/>HTTP/8265"| RayProxy["Ray HTTP Proxy"]
    KubeRay -.->|"RayCluster/RayJob<br/>delegation"| Kueue["Kueue (MultiKueue)"]

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required
