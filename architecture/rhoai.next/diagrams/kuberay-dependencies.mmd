graph LR
    KubeRay["KubeRay Operator<br/>(ray-operator v1.4.2)"]

    %% External Dependencies (Required)
    KubeRay -->|"operator framework<br/>v0.22.1"| ControllerRuntime["controller-runtime<br/>v0.22.1"]
    KubeRay -->|"runtime in user images<br/>>= 2.0"| Ray["Ray Runtime<br/>(user-provided images)"]

    %% External Dependencies (Optional)
    KubeRay -.->|"mTLS certs<br/>v1.18.2"| CertManager["cert-manager<br/>v1.18.2"]
    KubeRay -.->|"HTTPRoute ingress<br/>v1.4.0"| GatewayAPI["Gateway API<br/>v1.4.0"]
    KubeRay -.->|"Route, SCC<br/>v0.0.0-20250602"| OpenShiftAPI["openshift/api"]
    KubeRay -.->|"gang scheduling<br/>v1.12.1"| Volcano["Volcano<br/>v1.12.1"]
    KubeRay -.->|"coscheduling<br/>v0.31.8"| SchedulerPlugins["scheduler-plugins<br/>v0.31.8"]

    %% Internal RHOAI Dependencies
    KubeRay -->|"parent ref for HTTPRoutes<br/>(watched, not created)"| DSGateway["data-science-gateway<br/>(shared Gateway)"]
    KubeRay -->|"Issuer, Certificate CRDs"| CertMgrInt["cert-manager<br/>(certificate lifecycle)"]

    %% Platform integration (who deploys KubeRay)
    RHOAIOp["RHOAI/ODH Operator"] -->|"deploys via kustomize"| KubeRay

    %% Integration Points (who integrates WITH KubeRay)
    KubeRay -->|"CRD watches, CRUD<br/>443/TCP"| K8sAPI["Kubernetes API Server"]
    KubeRay -->|"OAuth config<br/>443/TCP"| OpenShiftOAuth["OpenShift OAuth<br/>config.openshift.io"]
    KubeRay -->|"KubeAPIServer status<br/>443/TCP"| OpenShiftKAS["OpenShift KubeAPIServer<br/>operator.openshift.io"]
    KubeRay -->|"job submission<br/>8265/TCP"| RayDashboard["Ray Dashboard API"]
    KubeRay -->|"health checks<br/>8000/TCP"| RayHTTPProxy["Ray HTTP Proxy"]
    KubeRay -->|"legacy ingress"| RouteAPI["OpenShift Route API"]
    KubeRay -->|"K8s Jobs for<br/>submitter + cleanup"| BatchAPI["Kubernetes Batch API"]
    KubeRay -->|"cross-ns auth<br/>for HTTPRoutes"| RefGrant["ReferenceGrant<br/>(Gateway API)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape metrics<br/>8080/TCP"| KubeRay

    %% Batch scheduler plugins
    KubeRay -.->|"PodGroup CRD"| VolcanoPG["Volcano PodGroup"]
    KubeRay -.->|"pod annotations<br/>taskGroups"| YunikornPG["Yunikorn Gang Scheduling"]
    KubeRay -.->|"PodGroup CRD"| SPCoscheduling["scheduler-plugins<br/>Coscheduling PodGroup"]

