graph LR
    KubeRay["KubeRay Operator<br/>(6 controllers + webhooks)"]

    %% External Dependencies (Required)
    KubeRay -->|"controller framework<br/>reconciliation, webhooks,<br/>leader election"| ControllerRuntime["controller-runtime<br/>v0.22.1"]

    %% External Dependencies (Optional)
    KubeRay -->|"TLS certificate issuance<br/>mTLS chain management"| CertManager["cert-manager<br/>v1.x"]
    KubeRay -->|"HTTPRoute, ReferenceGrant<br/>for dashboard access"| GatewayAPI["Gateway API<br/>v1/v1beta1"]
    KubeRay -->|"Route CRD, platform<br/>detection"| OpenShiftAPI["OpenShift API<br/>(route.openshift.io)"]
    KubeRay -.->|"GCS fault tolerance<br/>state storage"| Redis["Redis"]
    KubeRay -.->|"gang scheduling<br/>PodGroup CR"| Volcano["Volcano"]
    KubeRay -.->|"resource queue<br/>scheduling"| Yunikorn["Yunikorn"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize<br/>configures namespace/image"| KubeRay
    KubeRay -->|"HTTPRoute parent<br/>reference for dashboard"| PlatformGW["Platform Gateway<br/>(data-science-gateway)"]
    KubeRay -->|"OIDC auth proxy<br/>sidecar injection"| KubeRBACProxy["kube-rbac-proxy<br/>(sidecar image)"]
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"PodMonitor, PrometheusRule<br/>metrics + GCS alerting"| KubeRay

    %% Integration Points (consumers)
    CodeFlare["CodeFlare Operator"] -->|"external webhooks<br/>mraycluster/vraycluster<br/>.ray.openshift.ai"| KubeRay
    Kueue["Kueue"] -->|"workload delegation<br/>managedBy field +<br/>external webhooks"| KubeRay

    %% Core dependencies
    KubeRay -->|"CRD CRUD, Pod mgmt<br/>RBAC, leader election"| K8sAPI["Kubernetes API<br/>Server"]
    KubeRay -->|"OAuth config for<br/>OIDC proxy setup"| OAuthAPI["OpenShift OAuth /<br/>Authentication API"]

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ControllerRuntime fill:#999,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style Redis fill:#999,stroke:#333,color:#fff
    style Volcano fill:#999,stroke:#333,color:#fff
    style Yunikorn fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OAuthAPI fill:#f5a623,stroke:#333,color:#fff

    %% Internal RHOAI
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style PlatformGW fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style CodeFlare fill:#7ed321,stroke:#333,color:#fff
