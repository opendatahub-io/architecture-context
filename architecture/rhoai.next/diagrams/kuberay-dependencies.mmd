graph LR
    KubeRay["KubeRay Operator<br/>(ray-operator v1.4.2)"]

    %% External Dependencies (Required)
    KubeRay -->|"operator framework<br/>v0.22.1 (required)"| ControllerRuntime["controller-runtime"]
    KubeRay -->|"head/worker runtime<br/>>= 2.0 (required)"| Ray["Ray Runtime"]

    %% External Dependencies (Optional)
    KubeRay -->|"mTLS certs<br/>v1.18.2 (optional)"| CertManager["cert-manager"]
    KubeRay -->|"HTTPRoute ingress<br/>v1.4.0 (OpenShift only)"| GatewayAPI["gateway-api"]
    KubeRay -->|"Route, SCC<br/>(OpenShift only)"| OpenShiftAPI["openshift/api"]
    KubeRay -->|"gang scheduling<br/>v1.12.1 (optional)"| Volcano["Volcano"]
    KubeRay -->|"coscheduling<br/>v0.31.8 (optional)"| SchedulerPlugins["scheduler-plugins"]

    %% Internal Platform Dependencies
    KubeRay -->|"shared ingress<br/>Gateway parent ref"| Gateway["data-science-gateway<br/>(Gateway)"]
    KubeRay -->|"deployment<br/>kustomize manifests"| RHOAIOp["RHOAI/ODH Operator"]
    KubeRay -->|"auth config<br/>config.openshift.io"| OpenShiftOAuth["OpenShift OAuth"]

    %% Integration Points — components that use KubeRay
    KubeRay -->|"metrics scrape<br/>8080/TCP HTTP"| Prometheus["Prometheus"]
    KubeRay -->|"CRD CRUD, RBAC<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Batch Schedulers (plugin interface)
    KubeRay -.->|"annotations"| Yunikorn["Yunikorn Scheduler"]

