graph LR
    KubeRay["KubeRay Operator<br/>(ray-operator)"]

    %% External Dependencies (Required)
    KubeRay -->|"operator framework<br/>v0.22.1"| ControllerRuntime["controller-runtime<br/>v0.22.1"]
    KubeRay -->|"runtime<br/>>= 2.0"| Ray["Ray Runtime<br/>(user images)"]

    %% External Dependencies (Optional)
    KubeRay -.->|"mTLS certs<br/>v1.18.2"| CertManager["cert-manager<br/>v1.18.2"]
    KubeRay -.->|"HTTPRoute ingress<br/>v1.4.0"| GatewayAPI["gateway-api<br/>v1.4.0"]
    KubeRay -.->|"Route, SCC<br/>OpenShift only"| OpenShiftAPI["openshift/api"]
    KubeRay -.->|"gang scheduling<br/>v1.12.1"| Volcano["Volcano<br/>v1.12.1"]
    KubeRay -.->|"coscheduling<br/>v0.31.8"| SchedulerPlugins["scheduler-plugins<br/>v0.31.8"]

    %% Internal Platform Dependencies
    KubeRay -->|"HTTPRoute parent ref<br/>watches Gateway"| DSGateway["data-science-gateway<br/>(Gateway)"]
    KubeRay -->|"deployment<br/>kustomize manifests"| RHOAIOp["RHOAI/ODH Operator"]
    KubeRay -->|"OAuth config<br/>proxy setup"| OAuthConfig["OpenShift OAuth<br/>config.openshift.io"]
    KubeRay -->|"metrics scrape<br/>8080/TCP"| Prometheus["Prometheus"]

