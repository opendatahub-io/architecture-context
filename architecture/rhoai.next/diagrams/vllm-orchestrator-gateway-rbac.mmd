graph TD
    subgraph GatewayService["vLLM Orchestrator Gateway"]
        Note["This is a standalone HTTP service,<br/>NOT a Kubernetes operator.<br/>No RBAC resources are defined."]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB
        ClientAuth["Client Authentication<br/>─────────────────────<br/>Mechanism: Passthrough<br/>Authorization header forwarded<br/>to orchestrator as-is<br/>No local enforcement"]

        TransportAuth["Transport Authentication (Optional)<br/>─────────────────────────────────<br/>Mechanism: mTLS<br/>Client cert: /etc/tls/private/tls.crt<br/>Client key: /etc/tls/private/tls.key<br/>CA cert: /etc/tls/ca/service-ca.crt<br/>Provisioned by: cert-manager + service-ca-operator"]
    end

    subgraph SecretAccess["Secrets Accessed (Volume Mounts)"]
        TLSSecret["kubernetes.io/tls<br/>─────────────────<br/>tls.crt + tls.key<br/>Path: /etc/tls/private/<br/>Provisioner: cert-manager"]
        CASecret["Opaque<br/>─────────<br/>service-ca.crt<br/>Path: /etc/tls/ca/<br/>Provisioner: service-ca-operator"]
    end

    subgraph Endpoints["Endpoint Authorization"]
        RouteEndpoint["POST /{route_name}/v1/chat/completions<br/>──────────────────────────────────────<br/>Auth: None enforced locally<br/>Headers forwarded:<br/>• Authorization<br/>• x-forwarded-for<br/>• x-forwarded-host<br/>• x-forwarded-proto"]
    end

    GatewayService --> AuthModel
    GatewayService --> SecretAccess
    GatewayService --> Endpoints

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style ClientAuth fill:#d4edda,stroke:#155724
    style TransportAuth fill:#d4edda,stroke:#155724
    style TLSSecret fill:#fff2cc,stroke:#d6b656
    style CASecret fill:#fff2cc,stroke:#d6b656
    style RouteEndpoint fill:#cce5ff,stroke:#004085
