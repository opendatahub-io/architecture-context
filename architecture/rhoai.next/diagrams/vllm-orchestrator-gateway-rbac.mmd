graph TD
    subgraph GatewayService["vllm-orchestrator-gateway"]
        Gateway["Stateless HTTP Service<br/>(No Kubernetes Operator Logic)"]
    end

    subgraph RBACStatus["RBAC Status"]
        NoRBAC["No RBAC Resources Defined<br/>━━━━━━━━━━━━━━━━━━━━━━━<br/>No ClusterRoles<br/>No Roles<br/>No RoleBindings<br/>No ClusterRoleBindings"]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB
        Endpoint["POST /{route_name}/v1/chat/completions"]
        AuthMech["Auth Mechanism:<br/>Passthrough Only<br/>━━━━━━━━━━━━━━━━━━━━━━━<br/>Authorization header forwarded<br/>verbatim to orchestrator"]
        Enforcement["Enforcement Point:<br/>FMS Guardrails Orchestrator<br/>━━━━━━━━━━━━━━━━━━━━━━━<br/>Gateway performs NO<br/>authentication or authorization"]

        Endpoint --> AuthMech
        AuthMech --> Enforcement
    end

    subgraph TLSAuth["mTLS Authentication (Outbound)"]
        direction TB
        ClientCert["/etc/tls/private/tls.crt<br/>Client TLS Certificate"]
        ClientKey["/etc/tls/private/tls.key<br/>Client TLS Private Key"]
        CACert["/etc/tls/ca/service-ca.crt<br/>CA Certificate"]
        Note["Opportunistic:<br/>mTLS activated only<br/>when cert files exist"]

        ClientCert --> Note
        ClientKey --> Note
        CACert --> Note
    end

    Gateway --> NoRBAC
    Gateway --> Endpoint
    Gateway -.-> ClientCert

    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#f9f9f9,stroke:#999
    style Endpoint fill:#ffe6cc,stroke:#d79b00
    style AuthMech fill:#fff2cc,stroke:#d6b656
    style Enforcement fill:#f8cecc,stroke:#b85450
    style ClientCert fill:#d5e8d4,stroke:#82b366
    style ClientKey fill:#d5e8d4,stroke:#82b366
    style CACert fill:#d5e8d4,stroke:#82b366
    style Note fill:#e8e8e8,stroke:#666
