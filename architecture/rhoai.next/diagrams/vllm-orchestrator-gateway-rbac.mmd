graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB

        Note["This component has NO Kubernetes RBAC resources.<br/>It is a stateless HTTP service that does not<br/>interact with the Kubernetes API server."]

        subgraph "Authentication Model"
            direction TB
            NoAuth["Gateway AuthN: None<br/>(pass-through only)"]
            Upstream["Upstream AuthN: Platform-managed<br/>(kube-rbac-proxy / Gateway API)"]
            Backend["Backend AuthN: Orchestrator-managed<br/>(Authorization header forwarded)"]
        end

        subgraph "TLS Credentials (Volume Mounts)"
            direction TB
            ClientCert["Client Certificate<br/>/etc/tls/private/tls.crt<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager"]
            ClientKey["Private Key<br/>/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager"]
            CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Type: Opaque<br/>Provisioned by: OpenShift Service CA"]
        end

        subgraph "Header Forwarding"
            direction TB
            AuthHeader["Authorization: Bearer {token}<br/>(forwarded to orchestrator)"]
            XForwarded["x-forwarded-* headers<br/>(forwarded to orchestrator)"]
        end

        NoAuth -->|"delegates to"| Upstream
        NoAuth -->|"forwards to"| Backend
        ClientCert -->|"used for"| mTLS["mTLS with Orchestrator<br/>(conditional — when certs present)"]
        ClientKey -->|"used for"| mTLS
        CACert -->|"validates"| OrchestratorCert["Orchestrator Server<br/>Certificate"]
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style NoAuth fill:#f8d7da,stroke:#721c24
    style Upstream fill:#d4edda,stroke:#155724
    style Backend fill:#d4edda,stroke:#155724
    style ClientCert fill:#fff2cc,stroke:#d6b656
    style ClientKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
    style mTLS fill:#cce5ff,stroke:#004085
    style OrchestratorCert fill:#cce5ff,stroke:#004085
    style AuthHeader fill:#e2e3e5,stroke:#383d41
    style XForwarded fill:#e2e3e5,stroke:#383d41
