graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB
        Note["ℹ No Kubernetes RBAC resources defined<br/><br/>This component is a stateless HTTP service<br/>with no Kubernetes operator logic.<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are created by this component."]
    end

    subgraph "Authentication Model"
        direction TB
        AuthNote["Authentication: Passthrough Only<br/><br/>• Gateway performs NO authentication itself<br/>• Authorization header forwarded to orchestrator<br/>• X-Forwarded-* headers forwarded<br/>• Auth enforcement delegated to<br/>  FMS Guardrails Orchestrator"]
    end

    subgraph "TLS / Secrets"
        direction TB
        TLSCert["TLS Client Cert<br/>/etc/tls/private/tls.crt<br/>Type: kubernetes.io/tls (inferred)<br/>Provisioned: cert-manager"]
        TLSKey["TLS Client Key<br/>/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls (inferred)<br/>Provisioned: cert-manager"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Type: Opaque (inferred)<br/>Provisioned: OpenShift service-ca"]
    end

    TLSCert -->|"mTLS client identity"| mTLS["Optional mTLS to<br/>FMS Guardrails Orchestrator"]
    TLSKey -->|"mTLS client identity"| mTLS
    CACert -->|"server verification"| mTLS

    style Note fill:#f0f0f0,stroke:#999,stroke-width:1px
    style AuthNote fill:#fff3cd,stroke:#ffc107,stroke-width:1px
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style TLSKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
    style mTLS fill:#d5e8d4,stroke:#82b366
