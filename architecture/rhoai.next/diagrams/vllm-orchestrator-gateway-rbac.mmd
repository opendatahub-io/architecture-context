graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB
        Note["This component defines NO RBAC resources.<br/>It is a stateless HTTP service binary,<br/>not a Kubernetes operator.<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are present in the repository."]
    end

    subgraph "Authentication & Authorization Model"
        direction TB

        Client["Client"] -->|"Authorization header"| Gateway["vllm-orchestrator-gateway<br/>Port 8090/TCP"]
        Gateway -->|"Forwards Authorization header<br/>+ optional mTLS client cert"| Orchestrator["FMS Guardrails Orchestrator<br/>Port 8085/TCP"]

        AuthNote["Gateway does NOT enforce auth.<br/>Authorization is delegated to<br/>the orchestrator (enforcement point)."]
    end

    subgraph "TLS Identity (Service-Level Auth)"
        direction TB

        TLSCert["tls.crt<br/>/etc/tls/private/tls.crt<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager /<br/>service-serving-signer"]
        TLSKey["tls.key<br/>/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls<br/>Provisioned by: cert-manager /<br/>service-serving-signer"]
        CACert["service-ca.crt<br/>/etc/tls/ca/service-ca.crt<br/>Type: Opaque<br/>Provisioned by: service-ca-operator"]

        TLSCert -->|"client identity"| mTLS["mTLS Client Certificate<br/>(PKCS#12 via openssl crate)"]
        TLSKey -->|"private key"| mTLS
        CACert -->|"server validation"| CAValidation["Custom CA Validation<br/>(orchestrator server cert)"]
    end

    style Note fill:#f9f9f9,stroke:#999,stroke-width:1px
    style AuthNote fill:#f9f9f9,stroke:#999,stroke-width:1px
    style Client fill:#e8e8e8,stroke:#333
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style TLSKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
    style mTLS fill:#dae8fc,stroke:#6c8ebf
    style CAValidation fill:#dae8fc,stroke:#6c8ebf
