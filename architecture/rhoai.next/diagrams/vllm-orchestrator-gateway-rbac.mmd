graph TD
    subgraph "vLLM Orchestrator Gateway - RBAC / Auth Model"
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRoles["No ClusterRoles defined"]
            NoBindings["No RoleBindings defined"]
            NoSA["No ServiceAccount defined<br/>(uses pod default)"]
        end

        subgraph AuthModel["Authentication & Authorization Model"]
            direction TB

            subgraph ClientAuth["Client → Gateway (Inbound)"]
                InboundPort["Port: 8090/TCP"]
                InboundProto["Protocol: HTTP (plaintext)"]
                InboundAuth["Auth: None enforced at gateway<br/>Authorization header accepted<br/>but passed through transparently"]
            end

            subgraph GatewayToOrch["Gateway → Orchestrator (Outbound)"]
                OutboundPort["Port: 8085/TCP (configurable)"]
                OutboundProto["Protocol: HTTP or HTTPS"]
                OutboundAuth["Auth Mechanisms:"]
                PassThrough["1. Authorization header forwarded<br/>(Bearer token pass-through)"]
                MTLSAuth["2. mTLS client certificate<br/>(when TLS certs present)"]
            end
        end

        subgraph TLSIdentity["TLS / mTLS Identity"]
            ClientCert["/etc/tls/private/tls.crt<br/>X.509 Client Certificate"]
            ClientKey["/etc/tls/private/tls.key<br/>PEM Private Key"]
            CACert["/etc/tls/ca/service-ca.crt<br/>CA Certificate (custom trust)"]
            Identity["PKCS#12 Identity<br/>(constructed at startup)"]

            ClientCert -->|"converted to"| Identity
            ClientKey -->|"converted to"| Identity
            CACert -->|"added to trust store"| Identity
        end

        OutboundAuth --> PassThrough
        OutboundAuth --> MTLSAuth
        MTLSAuth -->|"uses"| Identity
    end

    Note["Note: This component has NO Kubernetes RBAC.<br/>It is a stateless HTTP proxy service.<br/>Auth is delegated to the orchestrator<br/>or upstream infrastructure (e.g., Istio, ingress)."]

    style NoRoles fill:#f9f9f9,stroke:#999
    style NoBindings fill:#f9f9f9,stroke:#999
    style NoSA fill:#f9f9f9,stroke:#999
    style InboundAuth fill:#ffe6cc,stroke:#d79b00
    style PassThrough fill:#d5e8d4,stroke:#82b366
    style MTLSAuth fill:#d5e8d4,stroke:#82b366
    style ClientCert fill:#fff2cc,stroke:#d6b656
    style ClientKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
    style Identity fill:#dae8fc,stroke:#6c8ebf
    style Note fill:#f8cecc,stroke:#b85450
