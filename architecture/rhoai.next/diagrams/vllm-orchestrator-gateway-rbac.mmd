graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB
        Note["This component is a standalone HTTP service,<br/>not a Kubernetes operator.<br/><br/>No ClusterRoles, ClusterRoleBindings,<br/>Roles, or RoleBindings are defined."]
    end

    subgraph "Authentication Model"
        direction TB
        AuthNote["Passthrough Authentication"]
        Endpoint["/{route_name}/v1/chat/completions<br/>POST"]
        AuthMech["Authorization header<br/>forwarded to orchestrator<br/>(no local validation)"]
        Headers["x-forwarded-* headers<br/>forwarded to orchestrator"]

        Endpoint --> AuthMech
        Endpoint --> Headers
    end

    subgraph "TLS Identity (mTLS to Orchestrator)"
        direction TB
        ClientCert["Client Certificate<br/>/etc/tls/private/tls.crt<br/>Provisioned by: cert-manager"]
        ClientKey["Client Key<br/>/etc/tls/private/tls.key<br/>Provisioned by: cert-manager"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Provisioned by: service-ca-operator"]
        PKCS12["PKCS#12 Identity<br/>(PEM → PKCS#12 via openssl crate)"]

        ClientCert --> PKCS12
        ClientKey --> PKCS12
        CACert -->|"trust bundle"| OrchestratorTrust["Orchestrator Server<br/>Certificate Validation"]
    end

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AuthNote fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Endpoint fill:#d5e8d4,stroke:#82b366
    style AuthMech fill:#e8e8e8,stroke:#333
    style Headers fill:#e8e8e8,stroke:#333
    style ClientCert fill:#f8cecc,stroke:#b85450
    style ClientKey fill:#f8cecc,stroke:#b85450
    style CACert fill:#f8cecc,stroke:#b85450
    style PKCS12 fill:#f8cecc,stroke:#b85450
    style OrchestratorTrust fill:#d5e8d4,stroke:#82b366
