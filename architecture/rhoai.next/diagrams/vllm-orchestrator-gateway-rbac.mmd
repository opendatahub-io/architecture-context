graph TD
    subgraph "vllm-orchestrator-gateway RBAC Model"
        direction TB

        Note["NOTE: No RBAC resources defined<br/>This is a standalone service, not a Kubernetes operator<br/>RBAC is managed by the deploying operator"]

        subgraph "Authentication Flow"
            Client["API Client"]
            Gateway["vllm-orchestrator-gateway<br/>(no local auth enforcement)"]
            Orchestrator["FMS Guardrails Orchestrator<br/>(auth enforcement point)"]

            Client -->|"Authorization: Bearer token<br/>(passthrough)"| Gateway
            Gateway -->|"Authorization header forwarded<br/>x-forwarded-* headers forwarded<br/>+ optional mTLS client cert"| Orchestrator
        end

        subgraph "TLS Identity (mTLS)"
            TLSCert["TLS Certificate<br/>/etc/tls/private/tls.crt<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager"]
            TLSKey["TLS Private Key<br/>/etc/tls/private/tls.key<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager"]
            CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Type: Opaque<br/>Provisioned: service-ca-operator"]
            PKCS12["PKCS#12 Identity<br/>(constructed at runtime<br/>via openssl crate)"]

            TLSCert -->|"PEM input"| PKCS12
            TLSKey -->|"PEM input"| PKCS12
            CACert -->|"trusted CA"| Gateway
            PKCS12 -->|"client identity"| Gateway
        end
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Client fill:#e8e8e8,stroke:#333
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style TLSCert fill:#f8cecc,stroke:#b85450
    style TLSKey fill:#f8cecc,stroke:#b85450
    style CACert fill:#f8cecc,stroke:#b85450
    style PKCS12 fill:#dae8fc,stroke:#6c8ebf
