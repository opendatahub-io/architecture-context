graph TB
    subgraph "vllm-spyre Container Image"
        direction TB
        subgraph "Application Layer (from RHAIIS base)"
            vLLM["vLLM Engine<br/>Inference Runtime"]
            TGISAdapter["vllm_tgis_adapter<br/>Dual-Protocol Adapter"]
            SpyreRuntime["IBM Spyre Runtime<br/>Accelerator Libraries"]
        end

        subgraph "Configuration Layer (this repo)"
            Entrypoint["Entrypoint<br/>python -m vllm_tgis_adapter"]
            EnvVars["Environment Variables<br/>GRPC_PORT=8033<br/>PORT=8000<br/>DISABLE_LOGPROBS_DURING_SPEC_DECODING=false"]
            NonRoot["Non-Root User<br/>UID 2000"]
        end

        Entrypoint -->|launches| TGISAdapter
        TGISAdapter -->|wraps| vLLM
        vLLM -->|accelerated by| SpyreRuntime
        EnvVars -.->|configures| TGISAdapter
    end

    subgraph "Base Image Chain"
        RHAIISImage["RHAIIS vllm-spyre-rhel9:3.2.2<br/>Product Base Image"]
        AIPCCBase["AIPCC Spyre Base Image<br/>quay.io/aipcc/base-images/spyre"]
        UBI9["UBI9 / RHEL9<br/>OS Foundation"]
        AIPCCBase --> RHAIISImage
        UBI9 --> AIPCCBase
    end

    RHAIISImage -->|FROM| Entrypoint

    subgraph "Exposed APIs"
        HTTP["OpenAI-Compatible HTTP API<br/>Port 8000/TCP"]
        gRPC["TGIS gRPC API<br/>Port 8033/TCP"]
        Health["Health Check<br/>/health"]
    end

    TGISAdapter -->|serves| HTTP
    TGISAdapter -->|serves| gRPC
    TGISAdapter -->|serves| Health

    subgraph "Runtime Dependencies"
        KServe["KServe<br/>ServingRuntime / InferenceService"]
        KubeRBACProxy["kube-rbac-proxy<br/>Auth Sidecar (8443/TCP)"]
        ModelStorage["Model Storage<br/>PVC or S3"]
        SpyreHW["IBM Spyre Accelerator<br/>Hardware"]
    end

    KServe -->|deploys| vLLM
    KubeRBACProxy -->|fronts| HTTP
    KubeRBACProxy -->|fronts| gRPC
    vLLM -->|loads models from| ModelStorage
    SpyreRuntime -->|uses| SpyreHW

    style vLLM fill:#4a90e2,stroke:#333,color:#fff
    style TGISAdapter fill:#4a90e2,stroke:#333,color:#fff
    style SpyreRuntime fill:#4a90e2,stroke:#333,color:#fff
    style Entrypoint fill:#50c878,stroke:#333,color:#fff
    style EnvVars fill:#50c878,stroke:#333,color:#fff
    style NonRoot fill:#50c878,stroke:#333,color:#fff
    style HTTP fill:#f5a623,stroke:#333,color:#fff
    style gRPC fill:#f5a623,stroke:#333,color:#fff
    style Health fill:#f5a623,stroke:#333,color:#fff
    style RHAIISImage fill:#999,stroke:#333,color:#fff
    style AIPCCBase fill:#999,stroke:#333,color:#fff
    style UBI9 fill:#999,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style ModelStorage fill:#e8e8e8,stroke:#333
    style SpyreHW fill:#e8e8e8,stroke:#333
