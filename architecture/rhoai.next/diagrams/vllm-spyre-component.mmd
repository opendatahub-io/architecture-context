graph TB
    subgraph "vLLM Spyre Container (odh-vllm-spyre-rhel9)"
        direction TB
        Adapter["vllm_tgis_adapter<br/>(Python entrypoint)"]
        VLLMEngine["vLLM Inference Engine"]
        HTTPServer["HTTP API Server<br/>(uvicorn)"]
        GRPCServer["gRPC TGIS Server"]

        Adapter -->|manages| HTTPServer
        Adapter -->|manages| GRPCServer
        Adapter -->|delegates inference| VLLMEngine
    end

    subgraph "IBM Spyre Hardware"
        SpyreCard["IBM Spyre AI<br/>Accelerator Card"]
    end

    subgraph "Platform Infrastructure"
        KServe["KServe<br/>(InferenceService)"]
        ServingRuntime["ServingRuntime CR"]
        RHODSOp["rhods-operator"]
    end

    subgraph "Model Storage"
        S3["S3 / PVC"]
        HFHub["Hugging Face Hub"]
    end

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>8000/TCP HTTP"| HTTPServer
    Client -->|"gRPC GenerationService<br/>8033/TCP"| GRPCServer

    VLLMEngine -->|"Hardware interface"| SpyreCard

    VLLMEngine -->|"Model loading<br/>HTTPS/filesystem"| S3
    VLLMEngine -->|"Model loading<br/>HTTPS/443"| HFHub

    RHODSOp -->|manages| ServingRuntime
    ServingRuntime -->|"image reference"| Adapter
    KServe -->|"deploys as runtime"| Adapter

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style SpyreCard fill:#e8563a,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style RHODSOp fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
