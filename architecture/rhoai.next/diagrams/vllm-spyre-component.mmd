graph TB
    subgraph External["External Clients"]
        Client[Client / KServe Router]
    end

    subgraph VllmSpyre["vLLM Spyre Container (odh-vllm-spyre-rhel9)"]
        direction TB
        TGIS["vllm_tgis_adapter<br/>Python Entrypoint"]
        VllmEngine["vLLM Inference Engine"]
        HTTPServer["HTTP API Server<br/>(uvicorn)<br/>Port 8000/TCP"]
        GRPCServer["gRPC TGIS Server<br/>Port 8033/TCP"]

        TGIS --> VllmEngine
        TGIS --> HTTPServer
        TGIS --> GRPCServer
    end

    subgraph Hardware["Hardware Accelerator"]
        Spyre["IBM Spyre<br/>AI Accelerator Card"]
    end

    subgraph Platform["RHOAI Platform"]
        KServe["KServe<br/>InferenceService"]
        ServingRuntime["ServingRuntime /<br/>ClusterServingRuntime CR"]
        Operator["rhods-operator /<br/>opendatahub-operator"]
    end

    subgraph Storage["Model Storage"]
        S3["S3 / PVC"]
        HuggingFace["Hugging Face Hub"]
    end

    subgraph BaseImage["Base Image"]
        RHAIIS["RHAIIS<br/>vllm-spyre-rhel9:3.2.2<br/>(UBI9 / FIPS)"]
    end

    %% Client flows
    Client -->|"HTTP POST<br/>8000/TCP"| HTTPServer
    Client -->|"gRPC<br/>8033/TCP"| GRPCServer

    %% Hardware acceleration
    VllmEngine -->|"Hardware Interface"| Spyre

    %% Platform management
    Operator -->|"manages"| ServingRuntime
    ServingRuntime -->|"references image"| VllmSpyre
    KServe -->|"deploys as runtime"| VllmSpyre

    %% Model loading
    VllmEngine -->|"HTTPS/443<br/>TLS 1.2+"| S3
    VllmEngine -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace

    %% Base image
    RHAIIS -.->|"base layer"| VllmSpyre

    %% Styling
    style VllmSpyre fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style TGIS fill:#5ba3f5,stroke:#333,color:#fff
    style VllmEngine fill:#5ba3f5,stroke:#333,color:#fff
    style HTTPServer fill:#5ba3f5,stroke:#333,color:#fff
    style GRPCServer fill:#5ba3f5,stroke:#333,color:#fff
    style Spyre fill:#e74c3c,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style HuggingFace fill:#f5a623,stroke:#333
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
