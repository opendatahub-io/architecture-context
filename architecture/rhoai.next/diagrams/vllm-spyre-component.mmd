graph TB
    subgraph "vllm-spyre Container Image"
        direction TB
        subgraph "vllm-tgis-adapter"
            HTTPServer["OpenAI-Compatible HTTP Server<br/>Port 8000/TCP"]
            GRPCServer["TGIS gRPC Server<br/>Port 8033/TCP"]
        end

        subgraph "vLLM Engine"
            Engine["vLLM Inference Engine<br/>(Python)"]
            SpyrePlugin["vllm-spyre Plugin"]
        end

        HTTPServer -->|"Python call"| Engine
        GRPCServer -->|"Python call"| Engine
        Engine -->|"plugin dispatch"| SpyrePlugin
    end

    subgraph "Platform-Injected Sidecar"
        RBAC["kube-rbac-proxy<br/>Port 8443/TCP<br/>TLS 1.2+ / Bearer Token"]
    end

    Client["External Client"] -->|"HTTPS/8443<br/>Bearer Token"| RBAC
    KServeMMesh["KServe / ModelMesh"] -->|"HTTPS/8443<br/>Bearer Token"| RBAC
    RBAC -->|"HTTP/8000<br/>localhost"| HTTPServer
    RBAC -->|"gRPC/8033<br/>localhost"| GRPCServer

    SpyrePlugin -->|"VFIO passthrough"| Spyre["IBM Spyre<br/>AI Accelerator<br/>(Hardware)"]

    ModelPVC["HuggingFace Model Weights<br/>(PVC / Volume Mount)"] -.->|"filesystem mount<br/>HF_HUB_OFFLINE=1"| Engine

    subgraph "Build Pipeline"
        BaseImage["rhaiis/vllm-spyre-rhel9<br/>(Pre-built Base Image)"]
        Konflux["Konflux Pipeline<br/>(Supply Chain Attestation)"]
        BaseImage -->|"FROM"| Konflux
    end

    Konflux -.->|"produces"| HTTPServer

    style HTTPServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style Engine fill:#4a90e2,stroke:#333,color:#fff
    style SpyrePlugin fill:#4a90e2,stroke:#333,color:#fff
    style RBAC fill:#f5a623,stroke:#333,color:#fff
    style Spyre fill:#e74c3c,stroke:#333,color:#fff
    style ModelPVC fill:#7ed321,stroke:#333,color:#fff
    style BaseImage fill:#999,stroke:#333,color:#fff
    style Konflux fill:#999,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style KServeMMesh fill:#f9f9f9,stroke:#999
