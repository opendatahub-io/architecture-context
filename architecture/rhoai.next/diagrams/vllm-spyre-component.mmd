graph TB
    subgraph "vllm-spyre Container Image"
        direction TB
        TGIS["vllm_tgis_adapter<br/>(Entrypoint)"]
        HTTP["OpenAI-Compatible HTTP Server<br/>Port 8000/TCP"]
        GRPC["TGIS gRPC Server<br/>Port 8033/TCP"]
        Engine["vLLM Inference Engine"]
        SpyreDriver["IBM Spyre Device Driver"]

        TGIS -->|starts| HTTP
        TGIS -->|starts| GRPC
        HTTP -->|inference requests| Engine
        GRPC -->|inference requests| Engine
        Engine -->|accelerated compute| SpyreDriver
    end

    subgraph "Platform Infrastructure (KServe)"
        KServe["KServe Controller"]
        ServingRuntime["ServingRuntime CR"]
        InferenceService["InferenceService CR"]
        Gateway["RHOAI Gateway<br/>443/TCP HTTPS"]
    end

    subgraph "External Services"
        S3["Model Storage<br/>(S3 / PVC)"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
        Prometheus["Prometheus<br/>(Metrics Scrape)"]
    end

    subgraph "Hardware"
        SpyreCard["IBM Spyre<br/>Accelerator Card"]
    end

    Client["External Client"] -->|HTTPS/443| Gateway
    Gateway -->|HTTP/8000| HTTP
    KServe -->|creates pods using| ServingRuntime
    ServingRuntime -->|references image| TGIS
    InferenceService -->|watched by| KServe
    KServe -->|"routes via"| GRPC

    Engine -->|loads models| S3
    Engine -->|downloads tokenizer| HFHub
    Prometheus -->|scrapes /metrics| HTTP
    SpyreDriver -->|PCIe| SpyreCard

    style TGIS fill:#4a90e2,stroke:#333,color:#fff
    style HTTP fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style Engine fill:#4a90e2,stroke:#333,color:#fff
    style SpyreDriver fill:#4a90e2,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style ServingRuntime fill:#7ed321,stroke:#333,color:#fff
    style InferenceService fill:#f5a623,stroke:#333
    style Gateway fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style SpyreCard fill:#d4380d,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
