graph TB
    subgraph "vllm-spyre Container Image"
        direction TB
        Adapter["vllm_tgis_adapter<br/>(Entrypoint)"]
        VLLMEngine["vLLM Engine<br/>(Inference Runtime)"]
        SpyreDriver["IBM Spyre Driver<br/>(Hardware Accelerator)"]

        Adapter -->|"dispatches inference"| VLLMEngine
        VLLMEngine -->|"accelerated compute"| SpyreDriver
    end

    subgraph "APIs Exposed"
        HTTP["OpenAI HTTP API<br/>:8000/TCP"]
        GRPC["TGIS gRPC API<br/>:8033/TCP"]
    end

    Client["Client / KServe Router"] -->|"POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /health"| HTTP
    Client -->|"GenerationService RPC"| GRPC

    HTTP --> Adapter
    GRPC --> Adapter

    subgraph "Base Image Layer"
        RHAIIS["RHAIIS vllm-spyre-rhel9:3.2.2<br/>(All runtime deps)"]
    end

    RHAIIS -.->|"provides runtime"| Adapter
    RHAIIS -.->|"provides engine"| VLLMEngine
    RHAIIS -.->|"provides drivers"| SpyreDriver

    SpyreHW["IBM Spyre Hardware<br/>(s390x / ppc64le / x86_64)"]
    SpyreDriver -->|"hardware interface"| SpyreHW

    ModelStorage["Model Storage<br/>(PVC / S3)"]
    VLLMEngine -->|"loads model weights<br/>at startup"| ModelStorage

    KServe["KServe InferenceService"]
    KServe -->|"deploys & manages"| Adapter

    KubeRBAC["kube-rbac-proxy Sidecar<br/>:8443/TCP HTTPS"]
    KubeRBAC -->|"fronts ports<br/>8000 & 8033"| HTTP
    KubeRBAC -->|"fronts ports<br/>8000 & 8033"| GRPC

    style Adapter fill:#4a90e2,stroke:#333,color:#fff
    style VLLMEngine fill:#4a90e2,stroke:#333,color:#fff
    style SpyreDriver fill:#4a90e2,stroke:#333,color:#fff
    style HTTP fill:#f5a623,stroke:#333,color:#fff
    style GRPC fill:#f5a623,stroke:#333,color:#fff
    style RHAIIS fill:#999,stroke:#333,color:#fff
    style SpyreHW fill:#999,stroke:#333,color:#fff
    style ModelStorage fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style KubeRBAC fill:#7ed321,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
