graph TB
    subgraph External["External Clients"]
        Client[API Client]
        KServeTransformer[KServe Transformer/<br/>Predictor]
    end

    subgraph KServePlatform["KServe Platform Layer"]
        Gateway["RHOAI Gateway<br/>443/TCP HTTPS"]
        KServeService["KServe Service<br/>(ClusterIP)"]
    end

    subgraph VllmSpyre["vllm-spyre Container (odh-vllm-spyre-rhel9)"]
        direction TB
        Entrypoint["vllm_tgis_adapter<br/>(uvicorn ASGI)"]

        subgraph HTTPServer["OpenAI-Compatible HTTP API"]
            Completions["/v1/completions<br/>POST 8000/TCP"]
            ChatCompletions["/v1/chat/completions<br/>POST 8000/TCP"]
            Models["/v1/models<br/>GET 8000/TCP"]
            Health["/health<br/>GET 8000/TCP"]
            Metrics["/metrics<br/>GET 8000/TCP"]
        end

        subgraph GRPCServer["TGIS gRPC API"]
            TGISService["GenerationService<br/>gRPC 8033/TCP"]
        end

        Entrypoint --> HTTPServer
        Entrypoint --> GRPCServer
    end

    subgraph Hardware["Hardware Layer"]
        Spyre["IBM Spyre Accelerator<br/>PCIe Device"]
    end

    subgraph Storage["Model Storage"]
        S3["S3 / PVC<br/>Model Weights"]
        HuggingFace["Hugging Face Hub<br/>443/TCP HTTPS"]
    end

    subgraph Monitoring["Monitoring"]
        Prometheus["Prometheus<br/>Metric Scraper"]
    end

    %% Client flows
    Client -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8000"| KServeService
    KServeService -->|"HTTP/8000"| Completions
    KServeService -->|"HTTP/8000"| ChatCompletions

    %% TGIS flow
    KServeTransformer -->|"gRPC/8033"| TGISService

    %% Hardware interaction
    Entrypoint -->|"PCIe/device driver"| Spyre

    %% Storage
    Entrypoint -->|"HTTPS/443 or Volume"| S3
    Entrypoint -->|"HTTPS/443"| HuggingFace

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>scrape /metrics"| Metrics

    %% Styling
    style VllmSpyre fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style Entrypoint fill:#2c6cb0,stroke:#333,color:#fff
    style HTTPServer fill:#5ba3e6,stroke:#333,color:#fff
    style GRPCServer fill:#5ba3e6,stroke:#333,color:#fff
    style Completions fill:#7bb8ed,stroke:#333
    style ChatCompletions fill:#7bb8ed,stroke:#333
    style Models fill:#7bb8ed,stroke:#333
    style Health fill:#7bb8ed,stroke:#333
    style Metrics fill:#7bb8ed,stroke:#333
    style TGISService fill:#7bb8ed,stroke:#333
    style Spyre fill:#e8563a,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333
    style KServeService fill:#f5a623,stroke:#333
    style S3 fill:#7ed321,stroke:#333
    style HuggingFace fill:#7ed321,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style KServeTransformer fill:#f9f9f9,stroke:#999
