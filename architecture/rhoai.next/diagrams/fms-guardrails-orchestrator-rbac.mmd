graph TD
    subgraph Note["RBAC Overview"]
        direction TB
        Info["FMS Guardrails Orchestrator is a standalone<br/>service binary, NOT a Kubernetes operator.<br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined in this repository."]
    end

    subgraph PlatformManaged["Platform-Managed RBAC"]
        direction TB
        Operator["Deploying Platform Operator<br/>(TrustyAI / KServe)"]
        SA["Pod ServiceAccount<br/>(assigned by operator)"]
        Operator -->|"creates and manages"| SA
    end

    subgraph AppLevelAuth["Application-Level Authentication"]
        direction TB

        subgraph APIEndpoints["API Endpoints (8033/TCP)"]
            APIv1["/api/v1/* endpoints"]
            APIv2["/api/v2/* endpoints"]
        end

        subgraph AuthMechanisms["Auth Mechanisms"]
            PassthroughHdrs["Passthrough Headers<br/>Configurable allowed list<br/>forwarded to downstream"]
            XForwarded["X-Forwarded-Access-Token<br/>→ Authorization: Bearer<br/>(optional rewrite)"]
            TLSAuth["TLS / mTLS<br/>rustls acceptor<br/>WebPKI client cert verify"]
        end

        subgraph HealthEndpoints["Health Endpoints (8034/TCP)"]
            Health["/health - liveness"]
            HealthInfo["/info - downstream status"]
            NoAuth["No Authentication Required"]
        end

        APIv1 --> PassthroughHdrs
        APIv1 --> XForwarded
        APIv1 --> TLSAuth
        APIv2 --> PassthroughHdrs
        APIv2 --> XForwarded
        APIv2 --> TLSAuth
        Health --> NoAuth
        HealthInfo --> NoAuth
    end

    subgraph Secrets["Secrets"]
        TLSCert["TLS server cert/key<br/>(kubernetes.io/tls)<br/>--tls-cert-path<br/>--tls-key-path"]
        ClientCA["TLS client CA cert<br/>(Opaque)<br/>--tls-client-ca-cert-path"]
        DownstreamCerts["Downstream TLS certs<br/>(Opaque)<br/>Per-service config"]
        APITokens["API tokens<br/>(Opaque, env var)<br/>Bearer tokens for<br/>downstream services"]
    end

    SA -.->|"mounts"| TLSCert
    SA -.->|"mounts"| ClientCA
    SA -.->|"mounts"| DownstreamCerts
    SA -.->|"reads env"| APITokens

    style Info fill:#fff3cd,stroke:#856404,color:#856404
    style Operator fill:#7ed321,color:#fff
    style SA fill:#4a90e2,color:#fff
    style PassthroughHdrs fill:#6c5ce7,color:#fff
    style XForwarded fill:#6c5ce7,color:#fff
    style TLSAuth fill:#6c5ce7,color:#fff
    style NoAuth fill:#00b894,color:#fff
    style TLSCert fill:#e17055,color:#fff
    style ClientCA fill:#e17055,color:#fff
    style DownstreamCerts fill:#e17055,color:#fff
    style APITokens fill:#e17055,color:#fff
