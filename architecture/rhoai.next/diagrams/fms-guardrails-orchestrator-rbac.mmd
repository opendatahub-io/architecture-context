graph TD
    subgraph "FMS Guardrails Orchestrator - RBAC & Security Model"
        direction TB

        subgraph "Note"
            Note["No RBAC resources defined in this repository.<br/>RBAC is managed by the platform deployment (rhods-operator).<br/>This diagram shows the authentication and secret model instead."]
        end

        subgraph "Authentication Model"
            direction TB
            NoAuth["No Built-in Auth<br/>All /api/* endpoints"]
            HeaderPass["Header Passthrough<br/>passthrough_headers config<br/>forwarded to downstream"]
            TokenRewrite["X-Forwarded-Access-Token<br/>→ Authorization: Bearer<br/>(rewritten in routes.rs)"]
            HealthNoAuth["/health, /info<br/>Unauthenticated<br/>Plaintext HTTP 8034/TCP"]
        end

        subgraph "TLS Configuration"
            direction TB
            ServerTLS["Server TLS (Optional)<br/>--tls-cert-path<br/>--tls-key-path<br/>rustls + ring (TLS 1.2+)"]
            ServerMTLS["Server mTLS (Optional)<br/>--tls-client-ca-cert-path<br/>Client cert verification"]
            ClientTLS["Client TLS (Per-service)<br/>cert + key + CA cert<br/>Paths in config YAML"]
            InsecureMode["NoVerifier (RISK)<br/>insecure: true<br/>Disables ALL cert verification"]
        end

        subgraph "Secrets"
            direction TB
            TLSCertKey["TLS cert/key pair<br/>Type: TLS certificate + key<br/>Provisioned: External (file mount)<br/>Rotate: Manual"]
            ClientCACert["TLS client CA cert<br/>Type: CA certificate<br/>Provisioned: External (file mount)<br/>Rotate: Manual"]
            PerServiceTLS["Per-service TLS configs<br/>Type: cert + key + CA per service<br/>Provisioned: External (config YAML paths)<br/>Rotate: Manual"]
            APIToken["API token (OpenAI backends)<br/>Type: Bearer token (env var)<br/>Provisioned: External<br/>Rotate: Manual"]
        end

        subgraph "FIPS Status"
            direction TB
            ContainerFIPS["Container Level: PASS<br/>openssl-libs installed<br/>Satisfies check-payload"]
            AppFIPS["Application Level: GAP<br/>rustls + ring backend<br/>NOT FIPS-validated<br/>Does NOT use system OpenSSL"]
        end
    end

    NoAuth --> HeaderPass
    HeaderPass --> TokenRewrite
    ServerTLS --> ServerMTLS
    ServerMTLS --> ClientTLS
    ClientTLS -.->|"when insecure: true"| InsecureMode
    ServerTLS --> TLSCertKey
    ServerMTLS --> ClientCACert
    ClientTLS --> PerServiceTLS

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style NoAuth fill:#f9f9f9,stroke:#999
    style HeaderPass fill:#4a90e2,stroke:#333,color:#fff
    style TokenRewrite fill:#f5a623,stroke:#333,color:#fff
    style HealthNoAuth fill:#7ed321,stroke:#333,color:#fff
    style ServerTLS fill:#4a90e2,stroke:#333,color:#fff
    style ServerMTLS fill:#4a90e2,stroke:#333,color:#fff
    style ClientTLS fill:#4a90e2,stroke:#333,color:#fff
    style InsecureMode fill:#d0021b,stroke:#333,color:#fff
    style TLSCertKey fill:#bd10e0,stroke:#333,color:#fff
    style ClientCACert fill:#bd10e0,stroke:#333,color:#fff
    style PerServiceTLS fill:#bd10e0,stroke:#333,color:#fff
    style APIToken fill:#bd10e0,stroke:#333,color:#fff
    style ContainerFIPS fill:#7ed321,stroke:#333,color:#fff
    style AppFIPS fill:#d0021b,stroke:#333,color:#fff
