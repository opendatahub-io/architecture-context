graph TD
    subgraph OrchestratorAuth["FMS Guardrails Orchestrator - Authentication & Authorization Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRBAC["No RBAC Resources<br/>(Not a Kubernetes operator)<br/>No ClusterRoles, Roles,<br/>or RoleBindings defined"]
        end

        subgraph ClientAuth["Client → Orchestrator Authentication"]
            direction LR
            ClientHeaders["Client Request<br/>with Headers"]
            PassthroughFilter["Passthrough Header<br/>Filter (configurable)"]
            TokenRewrite["X-Forwarded-Access-Token<br/>→ Bearer Token Rewrite<br/>(optional)"]
            ClientHeaders --> PassthroughFilter
            PassthroughFilter --> TokenRewrite
        end

        subgraph DownstreamAuth["Orchestrator → Downstream Authentication"]
            direction TB

            subgraph gRPCAuth["gRPC Services (TGIS, Caikit NLP, Chunker)"]
                gRPCmTLS["mTLS Client Certificates<br/>(per-service TLS profile)"]
                gRPCBearer["Bearer Token<br/>(api_token env var, optional)"]
            end

            subgraph HTTPAuth["HTTP Services (Detector, OpenAI)"]
                HTTPtls["TLS<br/>(per-service TLS profile)"]
                HTTPBearer["Bearer Token<br/>(api_token env var, optional)"]
                HTTPPassthrough["Passthrough Headers<br/>(forwarded from client)"]
            end
        end

        subgraph TLSConfig["TLS Configuration Pattern"]
            direction LR
            TLSProfiles["Named TLS Profiles<br/>(config.yaml tls section)"]
            ServiceRef["Service Config<br/>references profile by name"]
            TLSProfiles -->|"referenced by"| ServiceRef

            subgraph TLSDetails["Profile Contents"]
                CertPath["cert_path"]
                KeyPath["key_path"]
                CACertPath["client_ca_cert_path"]
                Insecure["insecure (dev only)"]
            end
        end

        subgraph Secrets["Managed Secrets"]
            ServerCert["TLS Server Certificate<br/>kubernetes.io/tls<br/>--tls-cert-path, --tls-key-path<br/>Provisioned: Platform operator / cert-manager"]
            ClientCA["TLS Client CA Certificate<br/>Opaque<br/>--tls-client-ca-cert-path<br/>Provisioned: Platform operator / cert-manager"]
            ServiceCerts["Per-service TLS Certificates<br/>Opaque<br/>config.yaml references<br/>Provisioned: Platform operator"]
            APITokens["API Tokens<br/>Opaque (env vars)<br/>api_token field per service<br/>Provisioned: Platform operator"]
        end

        subgraph HealthAuth["Health Endpoint Policy"]
            HealthEndpoints["/health, /info endpoints<br/>Port 8034/TCP<br/>Auth: None required<br/>Public access"]
        end
    end

    style NoRBAC fill:#f0f0f0,stroke:#999,stroke-dasharray: 5 5
    style ClientHeaders fill:#f5a623,stroke:#333
    style PassthroughFilter fill:#4a90e2,stroke:#333,color:#fff
    style TokenRewrite fill:#4a90e2,stroke:#333,color:#fff
    style gRPCmTLS fill:#7ed321,stroke:#333
    style gRPCBearer fill:#7ed321,stroke:#333
    style HTTPtls fill:#7ed321,stroke:#333
    style HTTPBearer fill:#7ed321,stroke:#333
    style HTTPPassthrough fill:#7ed321,stroke:#333
    style TLSProfiles fill:#9b59b6,stroke:#333,color:#fff
    style ServiceRef fill:#9b59b6,stroke:#333,color:#fff
    style ServerCert fill:#e74c3c,stroke:#333,color:#fff
    style ClientCA fill:#e74c3c,stroke:#333,color:#fff
    style ServiceCerts fill:#e74c3c,stroke:#333,color:#fff
    style APITokens fill:#e74c3c,stroke:#333,color:#fff
    style HealthEndpoints fill:#f0f0f0,stroke:#999
