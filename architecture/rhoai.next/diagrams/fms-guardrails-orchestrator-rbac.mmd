graph TD
    subgraph "FMS Guardrails Orchestrator - RBAC & Auth Model"
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRBAC["No RBAC defined<br/><i>This service does not interact<br/>with the Kubernetes API</i>"]
        end

        subgraph AuthModel["Authentication Model"]
            direction TB

            subgraph Inbound["Inbound Authentication (8033/TCP)"]
                InboundAuth["No direct authentication<br/>Header passthrough only"]
                PassthroughHeaders["passthrough_headers config<br/>X-Forwarded-Access-Token → Bearer"]
                InboundAuth --> PassthroughHeaders
            end

            subgraph OutboundGRPC["Outbound Auth - gRPC Services"]
                TGISAuth["TGIS: No auth<br/>TLS optional (per config)"]
                NLPAuth["Caikit NLP: No auth<br/>TLS optional (per config)"]
                ChunkerAuth["Chunkers: No auth<br/>TLS optional (per config)"]
            end

            subgraph OutboundHTTP["Outbound Auth - HTTP Services"]
                DetectorAuth["Detectors: Bearer token<br/>(optional, from env var<br/>via api_token config)"]
                OpenAIAuth["OpenAI server: Bearer token<br/>(optional, from env var<br/>via api_token config)"]
            end
        end

        subgraph TLSConfig["TLS Configuration"]
            direction TB
            ServerTLS["Server TLS (inbound)<br/>rustls + ring<br/>Cert: --tls-cert-path<br/>Key: --tls-key-path<br/>mTLS CA: --tls-client-ca-cert-path"]
            ClientTLS["Client TLS (outbound)<br/>Named profiles in YAML<br/>cert_path, key_path, ca_cert_path<br/>per-service configuration"]
            InsecureMode["⚠ Insecure Mode<br/>NoVerifier disables cert verification<br/>Supports legacy SHA1 schemes<br/>Development only"]
        end

        subgraph Secrets["Secrets Management"]
            direction TB
            TLSServerSecret["TLS server cert/key<br/>(kubernetes.io/tls)<br/>Manual provisioning<br/>No auto-rotation"]
            TLSClientCA["TLS client CA cert<br/>(Opaque)<br/>Manual provisioning<br/>No auto-rotation"]
            PerServiceTLS["Per-service TLS certs<br/>(Opaque)<br/>Manual via YAML config<br/>No auto-rotation"]
            APITokens["API tokens<br/>(Opaque)<br/>Env var indirection<br/>No auto-rotation"]
        end
    end

    style NoK8sRBAC fill:#e8e8e8,stroke:#999,stroke-dasharray: 5 5
    style NoRBAC fill:#f9f9f9,stroke:#ccc,color:#999
    style Inbound fill:#4a90e2,stroke:#2c5aa0,color:#fff
    style InboundAuth fill:#6ba3d6,stroke:#2c5aa0,color:#fff
    style PassthroughHeaders fill:#6ba3d6,stroke:#2c5aa0,color:#fff
    style OutboundGRPC fill:#d5e8d4,stroke:#82b366
    style OutboundHTTP fill:#fff2cc,stroke:#d6b656
    style TLSConfig fill:#dae8fc,stroke:#6c8ebf
    style InsecureMode fill:#f8cecc,stroke:#b85450
    style Secrets fill:#e1d5e7,stroke:#9673a6
    style TLSServerSecret fill:#d4c4e0,stroke:#9673a6
    style TLSClientCA fill:#d4c4e0,stroke:#9673a6
    style PerServiceTLS fill:#d4c4e0,stroke:#9673a6
    style APITokens fill:#d4c4e0,stroke:#9673a6
