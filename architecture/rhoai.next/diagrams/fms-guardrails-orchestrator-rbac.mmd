graph TD
    subgraph "FMS Guardrails Orchestrator — RBAC Overview"
        direction TB

        Note["ℹ️ No RBAC manifests in this repository<br/>RBAC is managed externally by rhods-operator"]

        subgraph "Deployment Context"
            direction LR
            RHODSOp["rhods-operator<br/>(manages RBAC externally)"]
            Orchestrator["fms-guardrails-orchestr8<br/>(stateless service)"]
            RHODSOp -->|"deploys & configures<br/>RBAC, NetworkPolicies,<br/>ServiceAccounts"| Orchestrator
        end

        subgraph "Authentication Model"
            direction TB
            ClientAuth["Client Authentication"]
            mTLSAuth["mTLS (Optional)<br/>WebPkiClientVerifier<br/>Requires valid client cert<br/>signed by configured CA"]
            HeaderAuth["Header Passthrough<br/>X-Forwarded-Access-Token<br/>→ Bearer rewrite<br/>(not enforced by orchestrator)"]
            NoAuth["Health Endpoints<br/>/health, /info<br/>No authentication<br/>Open for K8s probes"]

            ClientAuth --> mTLSAuth
            ClientAuth --> HeaderAuth
            ClientAuth --> NoAuth
        end

        subgraph "Upstream Auth (Outbound)"
            direction TB
            gRPCAuth["gRPC Services<br/>(TGIS, Caikit NLP, Chunkers)<br/>Auth: None<br/>TLS: Optional per-service"]
            HTTPAuth["HTTP Services<br/>(Detectors, OpenAI/vLLM)<br/>Auth: Optional Bearer (api_token)<br/>TLS: Optional per-service"]
        end

        subgraph "Secrets Required"
            direction TB
            TLSCert["TLS Server Cert<br/>kubernetes.io/tls<br/>cert-manager (external)"]
            TLSKey["TLS Server Key<br/>kubernetes.io/tls<br/>cert-manager (external)"]
            ClientCA["TLS Client CA Cert<br/>Opaque<br/>For mTLS verification"]
            PerServiceTLS["Per-Service TLS Certs<br/>Opaque<br/>Client certs for upstream"]
            APITokens["API Tokens<br/>Opaque<br/>Bearer tokens for HTTP upstreams"]
        end

        Orchestrator -->|"authenticates clients via"| ClientAuth
        Orchestrator -->|"authenticates to upstreams"| gRPCAuth
        Orchestrator -->|"authenticates to upstreams"| HTTPAuth
        Orchestrator -->|"uses"| TLSCert
        Orchestrator -->|"uses"| TLSKey
        Orchestrator -->|"uses"| ClientCA
        Orchestrator -->|"uses"| PerServiceTLS
        Orchestrator -->|"uses"| APITokens
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style Orchestrator fill:#4a90e2,stroke:#333,color:#fff
    style mTLSAuth fill:#d4edda,stroke:#28a745
    style HeaderAuth fill:#d4edda,stroke:#28a745
    style NoAuth fill:#f8d7da,stroke:#dc3545
    style gRPCAuth fill:#d1ecf1,stroke:#17a2b8
    style HTTPAuth fill:#d1ecf1,stroke:#17a2b8
    style TLSCert fill:#e2e3e5,stroke:#6c757d
    style TLSKey fill:#e2e3e5,stroke:#6c757d
    style ClientCA fill:#e2e3e5,stroke:#6c757d
    style PerServiceTLS fill:#e2e3e5,stroke:#6c757d
    style APITokens fill:#e2e3e5,stroke:#6c757d
