graph TD
    subgraph "FMS Guardrails Orchestrator - Authentication Model"
        direction TB

        subgraph "Client Authentication"
            ClientAuth["Client → Orchestrator<br/>Passthrough Headers"]
            HeaderRewrite["X-Forwarded-Access-Token<br/>→ Bearer Header Rewrite<br/>(optional)"]
            ClientAuth --> HeaderRewrite
        end

        subgraph "Downstream gRPC Authentication"
            gRPCmTLS["mTLS Client Certificates<br/>(per-service TLS profile)"]
            gRPCBearer["Bearer Token<br/>(api_token env var, optional)"]
        end

        subgraph "Downstream HTTP Authentication"
            HTTPtls["TLS Connection<br/>(per-service TLS profile)"]
            HTTPBearer["Bearer Token<br/>(api_token env var, optional)"]
            HTTPPassthrough["Passthrough Headers<br/>(forwarded from client)"]
        end

        subgraph "Health Endpoints"
            NoAuth["No Authentication<br/>Port 8034/TCP<br/>/health, /info"]
        end
    end

    subgraph "TLS Configuration (config.yaml)"
        direction TB
        TLSProfiles["Named TLS Profiles"]
        Profile1["Profile: 'caikit'<br/>cert_path, key_path,<br/>client_ca_cert_path"]
        Profile2["Profile: 'detector'<br/>cert_path, key_path,<br/>client_ca_cert_path"]
        ProfileN["Profile: 'custom'<br/>cert_path, key_path,<br/>insecure: true (dev only)"]
        TLSProfiles --> Profile1
        TLSProfiles --> Profile2
        TLSProfiles --> ProfileN
    end

    subgraph "Secrets"
        ServerTLS["TLS Server Certificate<br/>kubernetes.io/tls<br/>--tls-cert-path, --tls-key-path<br/>Provisioned: platform operator/cert-manager"]
        ClientCA["TLS Client CA Certificate<br/>Opaque<br/>--tls-client-ca-cert-path<br/>Provisioned: platform operator/cert-manager"]
        ServiceTLS["Per-service TLS Certificates<br/>Opaque<br/>cert_path, key_path in config.yaml<br/>Provisioned: platform operator"]
        APITokens["API Tokens<br/>Opaque (env vars)<br/>api_token field → env var reference<br/>Provisioned: platform operator"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No RBAC Resources<br/>No ClusterRoles<br/>No Roles<br/>No RoleBindings<br/>(Service has no K8s API access)"]
    end

    %% Connections
    gRPCmTLS -.->|"references"| TLSProfiles
    HTTPtls -.->|"references"| TLSProfiles
    Profile1 -.->|"uses"| ServiceTLS
    Profile2 -.->|"uses"| ServiceTLS
    gRPCBearer -.->|"reads"| APITokens
    HTTPBearer -.->|"reads"| APITokens

    style ClientAuth fill:#4a90e2,stroke:#333,color:#fff
    style HeaderRewrite fill:#6baed6,stroke:#333
    style gRPCmTLS fill:#7ed321,stroke:#333
    style gRPCBearer fill:#7ed321,stroke:#333
    style HTTPtls fill:#f5a623,stroke:#333
    style HTTPBearer fill:#f5a623,stroke:#333
    style HTTPPassthrough fill:#f5a623,stroke:#333
    style NoAuth fill:#e8e8e8,stroke:#333
    style NoRBAC fill:#e8e8e8,stroke:#333
    style TLSProfiles fill:#9ecae1,stroke:#333
    style ServerTLS fill:#ffcccc,stroke:#cc0000
    style ClientCA fill:#ffcccc,stroke:#cc0000
    style ServiceTLS fill:#ffcccc,stroke:#cc0000
    style APITokens fill:#ffcccc,stroke:#cc0000
