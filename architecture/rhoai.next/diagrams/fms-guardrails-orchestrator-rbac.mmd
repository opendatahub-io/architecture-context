graph TD
    subgraph Note["RBAC Configuration"]
        direction TB
        Info["No RBAC manifests in this repository<br/><br/>RBAC is managed externally by the<br/>deploying operator (rhods-operator)"]
    end

    subgraph AuthModel["Authentication & Authorization Model"]
        direction TB

        subgraph ServerAuth["Server-Side Auth"]
            TLSConfig["TLS Configuration<br/>rustls + ring backend<br/>TLS 1.2+"]
            mTLS["Optional mTLS<br/>WebPkiClientVerifier<br/>Client CA cert validation"]
        end

        subgraph HeaderPassthrough["Header Passthrough (No Enforcement)"]
            XForwarded["X-Forwarded-Access-Token<br/>→ Authorization: Bearer<br/>(rewrite)"]
            PassHeaders["passthrough_headers<br/>(configurable list)"]
        end

        subgraph UpstreamAuth["Upstream Service Auth"]
            DetectorAuth["Detector Services<br/>Optional Bearer token<br/>(api_token config)"]
            OpenAIAuth["OpenAI / vLLM<br/>Optional Bearer token<br/>(api_token config)"]
            GRPCAuth["gRPC Services<br/>(TGIS, Caikit)<br/>No auth (TLS only)"]
        end
    end

    subgraph Secrets["Secrets Managed"]
        TLSCert["TLS Server Cert<br/>kubernetes.io/tls<br/>Manual / cert-manager"]
        TLSKey["TLS Server Key<br/>kubernetes.io/tls<br/>Manual / cert-manager"]
        ClientCA["TLS Client CA Cert<br/>Opaque<br/>For mTLS verification"]
        PerServiceCerts["Per-Service TLS Certs<br/>Opaque<br/>Upstream connections"]
        APITokens["API Tokens<br/>Opaque<br/>Bearer tokens for HTTP services"]
    end

    TLSConfig --> mTLS
    mTLS -->|"validates client certs"| HeaderPassthrough
    HeaderPassthrough -->|"forwards to"| UpstreamAuth

    TLSCert -.-> TLSConfig
    TLSKey -.-> TLSConfig
    ClientCA -.-> mTLS
    PerServiceCerts -.-> GRPCAuth
    PerServiceCerts -.-> DetectorAuth
    APITokens -.-> DetectorAuth
    APITokens -.-> OpenAIAuth

    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Info fill:#fff3cd,stroke:#856404
    style ServerAuth fill:#d5e8d4,stroke:#82b366
    style HeaderPassthrough fill:#fff2cc,stroke:#d6b656
    style UpstreamAuth fill:#e8f0fe,stroke:#4a90e2
    style Secrets fill:#f8cecc,stroke:#b85450
    style TLSCert fill:#f8cecc,stroke:#b85450
    style TLSKey fill:#f8cecc,stroke:#b85450
    style ClientCA fill:#f8cecc,stroke:#b85450
    style PerServiceCerts fill:#f8cecc,stroke:#b85450
    style APITokens fill:#f8cecc,stroke:#b85450
