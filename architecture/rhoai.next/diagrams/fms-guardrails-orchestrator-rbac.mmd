graph TD
    subgraph Deployment["Deployment Model"]
        Orch["FMS Guardrails Orchestrator<br/>(Stateless Service)"]
    end

    subgraph RBACManagement["RBAC Management (External)"]
        direction TB
        RHODSOp["RHODS Operator<br/>(manages all RBAC)"]
        SA["ServiceAccount<br/>(operator-created)"]
    end

    subgraph AuthModel["Authentication Model"]
        direction TB
        NoAuth["No Self-Enforced Auth<br/>Designed for auth proxy placement"]
        HeaderPassthrough["Header Passthrough<br/>passthrough_headers config"]
        TokenRewrite["Token Rewrite<br/>X-Forwarded-Access-Token<br/>→ Authorization: Bearer"]
        mTLSOption["Optional mTLS<br/>WebPkiClientVerifier<br/>tls_client_ca_cert_path"]
    end

    subgraph UpstreamAuth["Upstream Service Auth"]
        direction TB
        DetectorAuth["Detector Services<br/>Optional Bearer (api_token)"]
        OpenAIAuth["OpenAI / vLLM<br/>Optional Bearer (api_token)"]
        gRPCAuth["TGIS / Caikit<br/>No Auth (TLS only)"]
    end

    subgraph TLSConfig["TLS Configuration"]
        direction TB
        ServerTLS["Server TLS<br/>rustls 0.23.36 + ring<br/>TLS 1.2+<br/>⚠ NOT FIPS-validated"]
        ClientTLS["Client TLS<br/>Per-service named configs<br/>Optional per upstream"]
        InsecureMode["⚠ Insecure Mode<br/>NoVerifier bypasses ALL<br/>cert verification<br/>(insecure: true)"]
    end

    subgraph Secrets["Secrets (File-Based)"]
        direction TB
        ServerCert["TLS Server Cert<br/>kubernetes.io/tls<br/>No auto-rotate"]
        ServerKey["TLS Server Key<br/>kubernetes.io/tls<br/>No auto-rotate"]
        ClientCA["TLS Client CA<br/>Opaque<br/>For mTLS verification"]
        PerServiceCerts["Per-Service TLS Certs<br/>Opaque<br/>For upstream connections"]
        APITokens["API Tokens<br/>Opaque (env var refs)<br/>For HTTP upstreams"]
    end

    RHODSOp -->|"creates & manages"| SA
    SA -->|"assigned to"| Orch
    Orch --> NoAuth
    NoAuth --> HeaderPassthrough
    HeaderPassthrough --> TokenRewrite
    Orch --> mTLSOption
    TokenRewrite --> DetectorAuth
    TokenRewrite --> OpenAIAuth
    Orch --> gRPCAuth

    Orch --> ServerTLS
    Orch --> ClientTLS
    ClientTLS -.->|"when insecure: true"| InsecureMode

    ServerTLS --- ServerCert
    ServerTLS --- ServerKey
    mTLSOption --- ClientCA
    ClientTLS --- PerServiceCerts
    DetectorAuth --- APITokens
    OpenAIAuth --- APITokens

    style Orch fill:#4a90e2,stroke:#333,color:#fff,stroke-width:3px
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style SA fill:#d5e8d4,stroke:#82b366
    style NoAuth fill:#dae8fc,stroke:#6c8ebf
    style HeaderPassthrough fill:#dae8fc,stroke:#6c8ebf
    style TokenRewrite fill:#dae8fc,stroke:#6c8ebf
    style mTLSOption fill:#dae8fc,stroke:#6c8ebf
    style DetectorAuth fill:#fff2cc,stroke:#d6b656
    style OpenAIAuth fill:#fff2cc,stroke:#d6b656
    style gRPCAuth fill:#e1d5e7,stroke:#9673a6
    style ServerTLS fill:#fdd0a2,stroke:#e6550d
    style ClientTLS fill:#fdd0a2,stroke:#e6550d
    style InsecureMode fill:#f8cecc,stroke:#b85450,stroke-width:3px
    style ServerCert fill:#f5f5f5,stroke:#999
    style ServerKey fill:#f5f5f5,stroke:#999
    style ClientCA fill:#f5f5f5,stroke:#999
    style PerServiceCerts fill:#f5f5f5,stroke:#999
    style APITokens fill:#f5f5f5,stroke:#999
