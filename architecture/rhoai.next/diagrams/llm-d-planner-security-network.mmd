graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Browser"]
    end

    subgraph Ingress["INGRESS (OpenShift Router - TLS Edge)"]
        RouteUI["Route: planner<br/>443/TCP → 8501/TCP<br/>TLS Edge Termination<br/>Auth: None"]
        RouteBackend["Route: planner-backend<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination<br/>Auth: None"]
    end

    subgraph PlannerNS["NAMESPACE: planner (No Service Mesh - Plaintext)"]
        direction TB

        UI["Streamlit UI<br/>Service: ui (ClusterIP)<br/>8501/TCP HTTP<br/>SA: default"]

        Backend["Backend API (FastAPI)<br/>Service: backend (ClusterIP)<br/>8000/TCP HTTP<br/>SA: planner-backend<br/>CORS: * (ALL ORIGINS)<br/>27 endpoints, ALL UNAUTHENTICATED"]

        Ollama["Ollama LLM<br/>Service: ollama (ClusterIP)<br/>11434/TCP HTTP<br/>Model: granite3.3:2b"]

        PostgreSQL["PostgreSQL<br/>Service: postgres (ClusterIP)<br/>5432/TCP<br/>Auth: Password<br/>PVC: 10Gi"]
    end

    subgraph CrossNS["CROSS-NAMESPACE (NetworkPolicy)"]
        ModelCatalog["RHOAI Model Catalog<br/>NS: rhoai-model-registries<br/>8443/TCP HTTPS<br/>TLS: service-serving CA<br/>Auth: Bearer / SA Token<br/>Access: Read-only (GET)"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (optional)"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA Token<br/>RBAC: planner-gpu-reader"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| RouteUI
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| RouteBackend

    %% Ingress to Services
    RouteUI -->|"HTTP/8501<br/>Plaintext<br/>No Auth"| UI
    RouteBackend -->|"HTTP/8000<br/>Plaintext<br/>No Auth"| Backend

    %% Internal flows
    UI -->|"HTTP/8000<br/>Plaintext<br/>No Auth"| Backend
    Backend -->|"HTTP/11434<br/>Plaintext<br/>No Auth"| Ollama
    Backend -->|"PostgreSQL/5432<br/>Plaintext<br/>Password Auth"| PostgreSQL

    %% Cross-namespace
    Backend -->|"HTTPS/8443<br/>TLS (service-CA)<br/>Bearer / SA Token<br/>NetworkPolicy"| ModelCatalog

    %% External egress
    Backend -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (opt)"| HFHub
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>nodes: list"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef crossns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:3px

    class User external
    class RouteUI,RouteBackend ingress
    class UI,Ollama,PostgreSQL internal
    class Backend warning
    class ModelCatalog crossns
    class HFHub,K8sAPI externalsvc
