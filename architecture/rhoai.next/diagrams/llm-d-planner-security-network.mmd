graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User (Browser / CLI)"]
    end

    subgraph Ingress["INGRESS (OpenShift Router - TLS Edge)"]
        UIRoute["planner Route<br/>443/TCP → 8501/TCP<br/>TLS Edge Termination<br/>Auth: None"]
        BackendRoute["planner-backend Route<br/>443/TCP → 8000/TCP<br/>TLS Edge Termination<br/>Auth: None"]
    end

    subgraph AppTier["APPLICATION TIER (Namespace: planner)<br/>⚠ No Service Mesh / No mTLS"]
        direction TB

        UI["Streamlit UI<br/>Service: ui (ClusterIP)<br/>8501/TCP HTTP<br/>Auth: None"]

        Backend["Backend API (FastAPI)<br/>Service: backend (ClusterIP)<br/>8000/TCP HTTP<br/>SA: planner-backend<br/>⚠ No Auth (29 endpoints)"]

        PG["PostgreSQL<br/>Service: postgres (ClusterIP)<br/>5432/TCP PostgreSQL<br/>Auth: Password<br/>5Gi PVC"]

        OllamaSvc["Ollama LLM<br/>Service: ollama (ClusterIP)<br/>11434/TCP HTTP<br/>Auth: None<br/>1x GPU, 20Gi PVC"]

        Sim["vLLM Simulator<br/>8080/TCP HTTP<br/>Auth: None<br/>(dev/test only)"]

        DBInit["db-init Job<br/>(one-shot)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer HF_TOKEN (optional)"]

        MCat["RHOAI Model Catalog<br/>model-catalog.rhoai-model-registries.svc<br/>8443/TCP HTTPS<br/>TLS 1.2+ (service CA)<br/>Auth: Bearer token<br/>NetworkPolicy: allowed"]

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount token"]

        KServe["KServe InferenceServices<br/>8080/TCP HTTP<br/>Auth: None<br/>(via port-forward)"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| UIRoute
    User -->|"HTTPS/443<br/>TLS Edge<br/>No Auth"| BackendRoute

    %% Ingress to App
    UIRoute -->|"HTTP/8501<br/>No Encryption<br/>No Auth"| UI
    BackendRoute -->|"HTTP/8000<br/>No Encryption<br/>No Auth"| Backend

    %% Internal flows
    UI -->|"HTTP/8000<br/>No Encryption<br/>No Auth"| Backend
    Backend -->|"HTTP/11434<br/>No Encryption<br/>No Auth"| OllamaSvc
    Backend -->|"PostgreSQL/5432<br/>No Encryption<br/>Password Auth"| PG
    DBInit -->|"PostgreSQL/5432<br/>No Encryption<br/>Password Auth"| PG

    %% External flows
    Backend -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HF
    Backend -->|"HTTPS/8443<br/>TLS 1.2+ (service CA)<br/>Bearer token<br/>NetworkPolicy"| MCat
    Backend -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Backend -.->|"HTTP/8080<br/>No Encryption<br/>No Auth"| KServe

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef appWarn fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray:5
    classDef infra fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef dev fill:#e8e8e8,stroke:#666,stroke-width:1px,stroke-dasharray:3

    class User external
    class UIRoute,BackendRoute ingress
    class UI app
    class Backend appWarn
    class PG,OllamaSvc infra
    class Sim dev
    class DBInit dev
    class HF,MCat,K8sAPI,KServe externalservice
