graph LR
    EvalHub["Eval Hub<br/>REST API Service"]

    %% External Dependencies
    EvalHub -->|"auth (TokenReview + SAR)<br/>Job/ConfigMap CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    EvalHub -->|"experiment tracking<br/>run logging<br/>HTTPS"| MLflow["MLflow Tracking Server 2.0+"]
    EvalHub -->|"persistent storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 15+<br/>(optional, SQLite fallback)"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["S3-compatible Storage"]
    EvalHub -->|"artifact export<br/>HTTPS/443"| OCI["OCI Registry<br/>Distribution v2"]
    EvalHub -->|"tracing + metrics<br/>gRPC/4317"| OTEL["OTEL Collector<br/>(OTLP-compatible)"]
    EvalHub -.->|"job queue scheduling<br/>Job labels"| Kueue["Kueue 0.6+<br/>(optional)"]

    %% Internal RHOAI Dependencies
    EvalHub -->|"TLS CA certs<br/>ConfigMap"| ServiceCA["OpenShift Service CA"]
    PlatformOp["RHOAI Platform Operator<br/>(rhods-operator)"] -->|"deploy + configure<br/>Operator CR"| EvalHub

    %% Evaluation Providers (downstream)
    EvalHub -->|"adapter containers<br/>Container Image"| Lighteval["Lighteval"]
    EvalHub -->|"adapter containers<br/>Container Image"| LmEval["lm-evaluation-harness"]
    EvalHub -->|"adapter containers<br/>Container Image"| Garak["Garak"]
    EvalHub -->|"adapter containers<br/>Container Image"| GuideLLM["GuideLLM"]
    EvalHub -->|"adapter containers<br/>Container Image"| IBMCLEAR["IBM CLEAR"]

    %% Consumers (integration points)
    MCP["evalhub-mcp<br/>MCP Server"] -->|"REST API client<br/>HTTPS/8080"| EvalHub
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/8080"| EvalHub

