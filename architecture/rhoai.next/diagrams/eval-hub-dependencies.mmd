graph LR
    EvalHub["eval-hub<br/>Go REST API Service"]

    %% External Dependencies (Required)
    EvalHub -->|"AuthN/AuthZ + Job CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% External Dependencies (Optional)
    EvalHub -->|"experiment tracking<br/>HTTPS"| MLflow["MLflow Tracking Server 2.0+"]
    EvalHub -->|"persistent storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 15+<br/>(SQLite fallback)"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["S3-compatible Storage"]
    EvalHub -->|"artifact export<br/>HTTPS/443"| OCIReg["OCI Registry<br/>Distribution v2"]
    EvalHub -->|"traces + metrics<br/>gRPC/4317"| OTEL["OTEL Collector<br/>OTLP-compatible"]
    EvalHub -->|"job queue scheduling<br/>Job labels"| Kueue["Kueue 0.6+"]

    %% Internal Platform Dependencies
    EvalHub -->|"TLS cert bundle"| ServiceCA["OpenShift Service CA"]
    RHOAI["RHOAI Platform Operator<br/>(rhods-operator)"] -->|"deploys + configures"| EvalHub

    %% Evaluation Providers (downstream)
    EvalHub -->|"spawns Job pods"| Lighteval["Lighteval"]
    EvalHub -->|"spawns Job pods"| LMEval["lm-evaluation-harness"]
    EvalHub -->|"spawns Job pods"| Garak["Garak"]
    EvalHub -->|"spawns Job pods"| GuideLLM["GuideLLM"]
    EvalHub -->|"spawns Job pods"| IBMCLEAR["IBM CLEAR"]

    %% MCP integration (upstream consumer)
    MCPServer["evalhub-mcp<br/>MCP Server"] -->|"REST client<br/>HTTPS/8080"| EvalHub

    %% Monitoring integration (upstream consumer)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8080"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#326ce5,stroke:#333,color:#fff
    style MLflow fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCIReg fill:#f5a623,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff
    style Kueue fill:#326ce5,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style RHOAI fill:#7ed321,stroke:#333,color:#fff
    style Lighteval fill:#e74c3c,stroke:#333,color:#fff
    style LMEval fill:#e74c3c,stroke:#333,color:#fff
    style Garak fill:#e74c3c,stroke:#333,color:#fff
    style GuideLLM fill:#e74c3c,stroke:#333,color:#fff
    style IBMCLEAR fill:#e74c3c,stroke:#333,color:#fff
    style MCPServer fill:#9b59b6,stroke:#333,color:#fff
