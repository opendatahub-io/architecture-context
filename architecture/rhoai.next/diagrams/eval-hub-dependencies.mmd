graph LR
    EvalHub["Eval Hub<br/>Evaluation Orchestration Service"]

    %% External Dependencies (Required)
    EvalHub -->|"REST API<br/>443/TCP HTTPS<br/>SA token"| K8sAPI["Kubernetes API<br/>Server"]
    EvalHub -->|"SQL<br/>5432/TCP<br/>Password"| PostgreSQL["PostgreSQL<br/>(or SQLite)"]

    %% External Dependencies (Optional)
    EvalHub -->|"REST API<br/>HTTPS<br/>Bearer token"| MLflow["MLflow Tracking<br/>Server"]
    EvalHub -->|"HTTPS 443<br/>AWS creds"| S3["S3-compatible<br/>Storage"]
    EvalHub -->|"OCI API<br/>443/TCP HTTPS<br/>Docker config"| OCI["OCI Registry<br/>(Quay)"]
    EvalHub -->|"OTLP<br/>4317/4318"| OTEL["OTEL Collector"]

    %% Internal ODH/RHOAI Dependencies
    EvalHub -.->|"Job queue labels"| Kueue["Kueue"]
    EvalHub -.->|"CA ConfigMap mount"| ServiceCA["OpenShift<br/>Service CA"]
    RHOAIOperator["RHOAI Operator<br/>(rhods-operator)"] -->|"deploys & manages"| EvalHub

    %% Evaluation Runtimes (created as Jobs)
    EvalHub -->|"creates K8s Jobs"| LMEval["lm-eval<br/>(LM Evaluation Harness)"]
    EvalHub -->|"creates K8s Jobs"| Lighteval["Lighteval"]
    EvalHub -->|"creates K8s Jobs"| Garak["Garak<br/>(Security Eval)"]
    EvalHub -->|"creates K8s Jobs"| GuideLLM["GuideLLM<br/>(Performance Eval)"]

    %% Integration Points (consumers)
    Dashboard["ODH Dashboard"] -.->|"REST API<br/>8080/TCP"| EvalHub
    MCPClient["MCP Client<br/>(AI Agents)"] -.->|"MCP Protocol<br/>3001/TCP"| EvalHub

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrape /metrics<br/>8080/TCP"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333
    style S3 fill:#999,stroke:#333,color:#fff
    style OCI fill:#999,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333
    style ServiceCA fill:#7ed321,stroke:#333
    style RHOAIOperator fill:#7ed321,stroke:#333
    style LMEval fill:#e8e8e8,stroke:#333
    style Lighteval fill:#e8e8e8,stroke:#333
    style Garak fill:#e8e8e8,stroke:#333
    style GuideLLM fill:#e8e8e8,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
    style MCPClient fill:#f5a623,stroke:#333
    style Prometheus fill:#999,stroke:#333,color:#fff
