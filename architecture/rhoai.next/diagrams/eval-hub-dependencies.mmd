graph LR
    EvalHub["EvalHub<br/>(eval-hub + sidecar + init + mcp)"]

    %% Internal RHOAI Dependencies
    EvalHub -->|"managed by<br/>EvalHub CR"| TrustyAIOp["TrustyAI Service<br/>Operator"]
    EvalHub -->|"auth proxy<br/>8443/TCP"| KubeRBACProxy["kube-rbac-proxy"]
    EvalHub -->|"GPU profiles<br/>HardwareProfile CR"| HardwareProfile["HardwareProfile CRD<br/>infrastructure.opendatahub.io/v1"]
    Dashboard["RHOAI Dashboard"] -->|"API consumer<br/>job submission"| EvalHub

    %% External Dependencies (Required)
    EvalHub -->|"Job/CM/Secret CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% External Dependencies (Optional)
    EvalHub -.->|"experiment tracking<br/>HTTP/HTTPS"| MLflow["MLflow Tracking<br/>Server 2.0+/3.0+"]
    EvalHub -.->|"test data download<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    EvalHub -.->|"artifact push<br/>443/TCP HTTPS"| OCI["OCI Registry<br/>(v2)"]
    EvalHub -.->|"model evaluation<br/>HTTP/HTTPS"| ModelEP["Model Inference<br/>Endpoints"]
    EvalHub -.->|"workload queuing<br/>Kueue labels"| Kueue["Kueue"]
    EvalHub -.->|"tracing/metrics<br/>gRPC/HTTP"| OTEL["OTEL Collector"]
    EvalHub -.->|"CA cert<br/>ConfigMap"| ServiceCA["OpenShift<br/>service-ca Operator"]

    %% Metrics integration
    Prometheus["Prometheus"] -->|"scrapes 8081/TCP<br/>HTTP plaintext"| EvalHub

    %% MCP consumers
    AIAgents["AI Agents<br/>(Claude / Cursor)"] -.->|"MCP protocol<br/>3001/TCP or stdio"| EvalHub

    %% Python SDK
    PythonSDK["eval-hub-sdk<br/>(Python)"] -.->|"FrameworkAdapter<br/>development"| EvalHub

    %% Build dependencies
    subgraph BuildDeps["Build Dependencies"]
        Go["Go 1.26.3"]
        UBI9["UBI9 ubi-minimal"]
    end
    EvalHub -.->|"runtime"| Go
    EvalHub -.->|"base image"| UBI9

    %% Storage backends
    subgraph StorageBackends["Storage Backends"]
        SQLite["SQLite<br/>(embedded, default)"]
        PostgreSQL["PostgreSQL<br/>(production)"]
    end
    EvalHub -->|"default DB"| SQLite
    EvalHub -.->|"production DB"| PostgreSQL

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style HardwareProfile fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style MLflow fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style OCI fill:#999,stroke:#333,color:#fff
    style ModelEP fill:#999,stroke:#333,color:#fff
    style Kueue fill:#50e3c2,stroke:#333,color:#333
    style OTEL fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e8744f,stroke:#333,color:#fff
    style AIAgents fill:#9b59b6,stroke:#333,color:#fff
    style PythonSDK fill:#9b59b6,stroke:#333,color:#fff
    style Go fill:#ddd,stroke:#333
    style UBI9 fill:#ddd,stroke:#333
    style SQLite fill:#ddd,stroke:#333
    style PostgreSQL fill:#ddd,stroke:#333
