graph LR
    EvalHub["Eval Hub<br/>REST API Service"]

    %% External Dependencies
    EvalHub -->|"AuthN/AuthZ<br/>TokenReview + SAR<br/>Job/ConfigMap CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]
    EvalHub -->|"experiment tracking<br/>run logging, artifacts<br/>HTTPS (configurable)"| MLflow["MLflow Tracking Server 2.0+"]
    EvalHub -->|"persistent storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 15+<br/>(optional, SQLite fallback)"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["S3-compatible<br/>Object Storage"]
    EvalHub -->|"artifact export<br/>HTTPS/443"| OCI["OCI Registry<br/>(Distribution Spec v2)"]
    EvalHub -->|"tracing + metrics<br/>gRPC/4317 or HTTP/4318"| OTEL["OpenTelemetry<br/>Collector"]
    EvalHub -.->|"job queue scheduling<br/>Job labels"| Kueue["Kueue 0.6+<br/>(optional)"]

    %% Internal RHOAI Dependencies
    EvalHub -->|"TLS certificates<br/>ConfigMap"| ServiceCA["OpenShift<br/>Service CA"]
    PlatformOp["RHOAI Platform<br/>Operator"] -->|"deploys + configures<br/>Operator CR"| EvalHub

    %% Evaluation Provider Images
    EvalHub -->|"pulls adapter images"| Lighteval["Lighteval"]
    EvalHub -->|"pulls adapter images"| LMEval["lm-evaluation-harness"]
    EvalHub -->|"pulls adapter images"| Garak["Garak"]
    EvalHub -->|"pulls adapter images"| GuideLLM["GuideLLM"]
    EvalHub -->|"pulls adapter images"| IBMCLEAR["IBM CLEAR"]

    %% MCP Integration
    MCPServer["evalhub-mcp<br/>MCP Server"] -->|"REST API client<br/>HTTPS/8080"| EvalHub

    %% Prometheus scrape
    Prometheus["Prometheus"] -->|"scrape /metrics<br/>HTTP/8080"| EvalHub

