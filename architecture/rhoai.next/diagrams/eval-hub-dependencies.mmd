graph LR
    EvalHub["EvalHub<br/>(eval-hub API +<br/>evalhub-mcp +<br/>sidecar + init)"]

    %% Operator (manages EvalHub)
    TrustyAIOp["TrustyAI Service<br/>Operator"] -->|"manages via<br/>EvalHub CR"| EvalHub

    %% External Dependencies
    EvalHub -->|"Job scheduling<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>Server 1.29+"]
    EvalHub -->|"data storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 5.x<br/>(pgx driver)"]
    EvalHub -->|"experiment tracking<br/>HTTPS"| MLflow["MLflow 2.x+"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["S3-compatible<br/>Storage (AWS SDK v2)"]
    EvalHub -->|"artifact push/pull<br/>HTTPS/443"| OCIReg["OCI Registry<br/>(Distribution v2)"]
    EvalHub -->|"model inference<br/>HTTP/HTTPS"| ModelEP["Model Endpoints"]
    EvalHub -->|"tracing/metrics/logs<br/>gRPC/4317"| OTEL["OpenTelemetry<br/>Collector (OTLP)"]
    EvalHub -->|"fallback storage"| SQLite["SQLite<br/>(modernc.org,<br/>embedded)"]

    %% Internal ODH Dependencies
    EvalHub -->|"auth enforcement<br/>8443→upstream"| RBAC["kube-rbac-proxy<br/>(sidecar)"]
    EvalHub -->|"GPU/resource resolve<br/>HTTPS/443"| HWProfile["HardwareProfile CR<br/>infrastructure.opendatahub.io/v1"]
    EvalHub -.->|"workload queuing<br/>(optional)"| Kueue["Kueue"]

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -->|"metrics scrape<br/>HTTP/8081"| EvalHub
    AIAssistant["AI Assistants<br/>(Cursor, VS Code,<br/>Claude Code)"] -->|"MCP protocol<br/>HTTPS/8443"| EvalHub

    %% Evaluation Providers (container images)
    EvalHub -->|"benchmark adapter"| LMEval["lm-evaluation-harness<br/>(167+ benchmarks)"]
    EvalHub -->|"benchmark adapter"| RAGAS["RAGAS<br/>(RAG evaluation)"]
    EvalHub -->|"benchmark adapter"| Garak["Garak<br/>(9 security benchmarks)"]
    EvalHub -->|"benchmark adapter"| GuideLLM["GuideLLM<br/>(performance eval)"]
    EvalHub -->|"benchmark adapter"| LightEval["LightEval<br/>(lightweight eval)"]

    %% Python SDK
    EvalHubSDK["eval-hub-sdk<br/>(Python)"] -.->|"framework adapter<br/>interface"| EvalHub

