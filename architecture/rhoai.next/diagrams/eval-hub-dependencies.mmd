graph LR
    EvalHub["eval-hub<br/>REST API Service"]

    %% External Dependencies (Required)
    EvalHub -->|"TokenReview, SAR<br/>Job CRUD, ConfigMaps<br/>HTTPS/443"| K8sAPI["Kubernetes API<br/>1.27+"]

    %% External Dependencies (Optional)
    EvalHub -->|"persistent storage<br/>pgx/5432"| PostgreSQL["PostgreSQL<br/>14+"]
    EvalHub -.->|"experiment tracking<br/>HTTPS"| MLflow["MLflow Tracking<br/>2.0+"]
    EvalHub -.->|"test data download<br/>HTTPS/443"| S3["S3-compatible<br/>Storage"]
    EvalHub -.->|"result artifact export<br/>HTTPS/443"| OCIRegistry["OCI Registry<br/>v2 Distribution"]
    EvalHub -.->|"priority scheduling<br/>Job labels"| Kueue["Kueue<br/>0.5+"]

    %% Internal Platform Dependencies
    RHOAIOp["RHOAI Operator"] -->|"deploys & manages"| EvalHub
    EvalHub -->|"CA certificates<br/>ConfigMap mount"| ServiceCA["OpenShift<br/>Service CA"]

    %% Adapter Dependencies (K8s Job containers)
    EvalHub -->|"K8s Job<br/>180+ benchmarks"| LMEval["LM Evaluation<br/>Harness"]
    EvalHub -->|"K8s Job<br/>8 benchmarks"| Garak["Garak<br/>Security/Red-team"]
    EvalHub -->|"K8s Job<br/>30+ benchmarks"| Lighteval["Lighteval<br/>Framework"]
    EvalHub -->|"K8s Job<br/>performance"| GuideLLM["GuideLLM<br/>Performance"]
    EvalHub -->|"K8s Job"| IBMCLEAR["IBM CLEAR<br/>Evaluation"]

    %% Embedded
    EvalHub -->|"fallback storage<br/>embedded"| SQLite["SQLite<br/>modernc.org"]

