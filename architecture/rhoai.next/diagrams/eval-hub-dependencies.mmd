graph LR
    EvalHub["eval-hub<br/>REST API Service"]

    %% External Dependencies
    EvalHub -->|"auth delegation<br/>HTTPS 443/TCP"| K8sAPI["Kubernetes API 1.27+<br/>(Required)"]
    EvalHub -->|"data persistence<br/>pgx 5432/TCP"| PostgreSQL["PostgreSQL 14+<br/>(Optional - SQLite fallback)"]
    EvalHub -->|"embedded default<br/>in-process"| SQLite["SQLite<br/>(Default backend)"]
    EvalHub -->|"experiment tracking<br/>HTTPS"| MLflow["MLflow 2.0+<br/>(Optional)"]
    EvalHub -->|"test data download<br/>HTTPS 443/TCP"| S3["S3 / MinIO<br/>(Optional)"]
    EvalHub -->|"result export<br/>HTTPS 443/TCP"| OCI["OCI Registry<br/>(Optional)"]
    EvalHub -->|"job scheduling<br/>K8s labels"| Kueue["Kueue 0.5+<br/>(Optional)"]

    %% Internal RHOAI Dependencies
    RHOAIOp["RHOAI Operator"] -->|"deploys & manages"| EvalHub
    EvalHub -.->|"CA certificates<br/>ConfigMap mount"| ServiceCA["OpenShift Service CA"]

    %% Adapter Dependencies (Job containers)
    EvalHub -->|"creates Job<br/>180+ benchmarks"| LMEval["LM Evaluation Harness<br/>Adapter"]
    EvalHub -->|"creates Job<br/>8 benchmarks"| Garak["Garak<br/>Adapter"]
    EvalHub -->|"creates Job<br/>30+ benchmarks"| Lighteval["Lighteval<br/>Adapter"]
    EvalHub -->|"creates Job<br/>perf benchmarks"| GuideLLM["GuideLLM<br/>Adapter"]
    EvalHub -->|"creates Job"| IBMCLEAR["IBM CLEAR<br/>Adapter"]

    %% Integration Points (incoming)
    Dashboard["RHOAI Dashboard"] -->|"UI management<br/>HTTPS"| EvalHub
    CLI["CLI / SDK"] -->|"API calls<br/>HTTPS"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
