graph TB
    subgraph Operator["MLflow Operator (redhat-ods-applications)"]
        Controller["MLflow Controller<br/>(controller-runtime)<br/>Go Operator"]
        HelmEngine["Embedded Helm Engine<br/>(helm.sh/helm/v3)"]
        Controller -->|renders chart| HelmEngine
        Controller -->|Server-Side Apply| K8sResources["Managed Resources"]
    end

    subgraph ManagedResources["Helm-Rendered Resources"]
        direction TB
        MLflowDeploy["MLflow Server Deployment<br/>(Python/uvicorn)<br/>Port: 8443/TCP HTTPS"]
        CABundleSidecar["CA Bundle Sidecar<br/>Watches ConfigMap changes<br/>Regenerates CA bundle"]
        MLflowSvc["mlflow Service<br/>ClusterIP 8443/TCP"]
        NP["NetworkPolicy<br/>Ingress: 8443 from any NS<br/>Egress: DNS, HTTPS, DB, S3"]
        PVC["PersistentVolumeClaim<br/>(local artifact storage)"]
        SA["ServiceAccount<br/>mlflow-sa"]
        RBAC_CR["ClusterRole / Binding<br/>mlflow + aggregates"]
        SM["ServiceMonitor<br/>Prometheus metrics"]
        MLflowDeploy --- CABundleSidecar
    end

    subgraph CRDs["Custom Resources"]
        MLflowCR["MLflow CR<br/>mlflow.opendatahub.io/v1<br/>Cluster-scoped"]
        MLflowConfigCR["MLflowConfig CR<br/>mlflow.kubeflow.org/v1<br/>Namespace-scoped"]
    end

    User["Data Scientist / Admin"] -->|creates| MLflowCR
    NSOwner["Namespace Owner"] -->|creates| MLflowConfigCR
    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller

    HelmEngine -->|creates| MLflowDeploy
    HelmEngine -->|creates| MLflowSvc
    HelmEngine -->|creates| NP
    HelmEngine -->|creates| PVC
    HelmEngine -->|creates| SA
    HelmEngine -->|creates| RBAC_CR
    HelmEngine -->|creates| SM

    Controller -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)<br/>→ data-science-gateway"]
    Controller -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift Console)"]

    MLflowDeploy -->|depends on| ServiceCA["OpenShift service-ca<br/>(TLS cert provisioning)"]
    MLflowDeploy -->|reads| CABundle["odh-trusted-ca-bundle<br/>(Platform CAs)"]
    MLflowDeploy -->|reads| ArtifactSecret["mlflow-artifact-connection<br/>(S3 credentials)"]
    MLflowDeploy -->|authz via| K8sAPI["Kubernetes API<br/>(SelfSubjectAccessReview)"]

    MLflowDeploy -->|stores metadata| DB["PostgreSQL / MySQL"]
    MLflowDeploy -->|stores artifacts| S3["S3-compatible Storage<br/>(MinIO / SeaweedFS / AWS)"]

    style Controller fill:#4a90e2,color:#fff
    style HelmEngine fill:#4a90e2,color:#fff
    style MLflowDeploy fill:#7ed321,color:#fff
    style CABundleSidecar fill:#7ed321,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style HTTPRoute fill:#9b59b6,color:#fff
    style ConsoleLink fill:#9b59b6,color:#fff
    style ServiceCA fill:#e8e8e8
    style DB fill:#e8e8e8
    style S3 fill:#e8e8e8
    style K8sAPI fill:#e8e8e8
