graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["mlflow-operator<br/>(Go Operator)<br/>controller-runtime"]
        HelmRenderer["Helm Renderer<br/>(embedded chart)"]
        Controller -->|"renders manifests via"| HelmRenderer
    end

    subgraph MLflowPod["MLflow Tracking Server Pod"]
        InitCA["combine-ca-bundles<br/>(Init Container)<br/>Combines system + platform + custom CAs"]
        MLflow["MLflow Server<br/>(Python/Uvicorn)<br/>8443/TCP HTTPS"]
        CAWatcher["ca-bundle-watcher<br/>(Sidecar)<br/>Watches CA ConfigMap changes"]
        InitCA -->|"creates initial<br/>combined CA bundle"| MLflow
        CAWatcher -->|"regenerates CA bundle<br/>on ConfigMap change"| MLflow
    end

    %% CRDs
    MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespaced"]

    %% External Resources Created
    HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    ConsoleLink["ConsoleLink<br/>(OpenShift Console)"]
    ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    NetworkPolicy["NetworkPolicy"]
    RBAC["ClusterRole &<br/>ClusterRoleBinding"]

    %% Flow
    User["Platform Admin"] -->|"creates"| MLflowCR
    WSOwner["Workspace Owner"] -->|"creates"| MLflowConfigCR
    MLflowCR -->|"watched by"| Controller
    MLflowConfigCR -->|"watched by"| MLflow

    Controller -->|"creates/manages"| MLflowPod
    Controller -->|"creates"| HTTPRoute
    Controller -->|"creates"| ConsoleLink
    Controller -->|"creates"| ServiceMonitor
    Controller -->|"creates"| NetworkPolicy
    Controller -->|"creates"| RBAC

    %% External Dependencies
    Controller -->|"Server-Side Apply"| K8sAPI["Kubernetes API<br/>6443/TCP"]
    MLflow -->|"SelfSubjectAccessReview"| K8sAPI
    MLflow -->|"artifact storage"| S3["S3-compatible Storage<br/>443/9000/TCP"]
    MLflow -->|"metadata store"| DB["PostgreSQL/MySQL<br/>5432/3306/TCP"]

    %% Platform Integration
    HTTPRoute -->|"parent ref"| Gateway["data-science-gateway<br/>(Platform Gateway)"]
    CABundle["odh-trusted-ca-bundle<br/>(ConfigMap)"] -->|"mounted into"| MLflowPod
    ServiceCA["openshift-service-ca"] -->|"provisions TLS cert"| MLflowPod

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style HelmRenderer fill:#4a90e2,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style InitCA fill:#7ed321,stroke:#333,color:#fff
    style CAWatcher fill:#7ed321,stroke:#333,color:#fff
    style MLflowCR fill:#f5a623,stroke:#333,color:#fff
    style MLflowConfigCR fill:#f5a623,stroke:#333,color:#fff
    style HTTPRoute fill:#d0e8ff,stroke:#4a90e2
    style ConsoleLink fill:#d0e8ff,stroke:#4a90e2
    style ServiceMonitor fill:#d0e8ff,stroke:#4a90e2
    style NetworkPolicy fill:#d0e8ff,stroke:#4a90e2
    style RBAC fill:#d0e8ff,stroke:#4a90e2
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style DB fill:#e8e8e8,stroke:#333
    style CABundle fill:#fff2cc,stroke:#d6b656
    style ServiceCA fill:#fff2cc,stroke:#d6b656
