graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["mlflow-operator<br/>(Go Operator)<br/>controller-runtime v0.22.4"]
        HelmRenderer["HelmRenderer<br/>(embedded Helm chart)"]
        Controller -->|"renders manifests"| HelmRenderer
    end

    subgraph MLflowPod["MLflow Tracking Server Pod"]
        InitCA["combine-ca-bundles<br/>(Init Container)"]
        MLflow["mlflow<br/>(Python Service)<br/>8443/TCP HTTPS"]
        CAWatcher["ca-bundle-watcher<br/>(Sidecar)<br/>30s checksum polling"]
        InitCA -->|"creates combined CA bundle"| MLflow
        CAWatcher -->|"regenerates CA bundle<br/>on ConfigMap change"| MLflow
    end

    %% CRDs
    MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespaced"]

    %% User interaction
    User["Data Scientist / Admin"] -->|"creates/updates"| MLflowCR

    %% Operator reconciliation
    MLflowCR -->|"watched by"| Controller
    MLflowConfigCR -->|"watched by"| Controller
    Controller -->|"Server-Side Apply"| MLflowPod
    Controller -->|"creates"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -->|"creates"| ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    Controller -->|"creates"| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    Controller -->|"creates"| NetworkPolicy["NetworkPolicy"]
    Controller -->|"manages"| ClusterRole["ClusterRole<br/>(mlflow, aggregates)"]

    %% Platform integration
    HTTPRoute -->|"references"| Gateway["data-science-gateway<br/>(Platform Gateway)"]
    Gateway -->|"routes to"| MLflow

    %% External dependencies
    MLflow -->|"metadata store"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflow -->|"artifact storage"| S3["S3-compatible Storage<br/>443/TCP, 9000/TCP"]
    MLflow -->|"auth check"| K8sAPI["Kubernetes API<br/>6443/TCP<br/>SelfSubjectAccessReview"]
    Controller -->|"reconcile"| K8sAPI

    %% CA sources
    SystemCA["System CAs<br/>/etc/pki/tls/certs/ca-bundle.crt"] -->|"input"| InitCA
    PlatformCA["odh-trusted-ca-bundle<br/>(ConfigMap)"] -->|"input"| InitCA
    CustomCA["User CA ConfigMaps"] -->|"input"| InitCA

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style MLflow fill:#7ed321,color:#fff
    style InitCA fill:#7ed321,color:#fff
    style CAWatcher fill:#7ed321,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style HTTPRoute fill:#f5a623,color:#fff
    style ConsoleLink fill:#f5a623,color:#fff
    style ServiceMonitor fill:#f5a623,color:#fff
    style NetworkPolicy fill:#f5a623,color:#fff
    style ClusterRole fill:#f5a623,color:#fff
    style Gateway fill:#e8e8e8,color:#333
    style PostgreSQL fill:#e8e8e8,color:#333
    style S3 fill:#e8e8e8,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style SystemCA fill:#ddd,color:#333
    style PlatformCA fill:#ddd,color:#333
    style CustomCA fill:#ddd,color:#333
