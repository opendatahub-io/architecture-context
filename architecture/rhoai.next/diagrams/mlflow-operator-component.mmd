graph TB
    subgraph "MLflow Operator Component"
        direction TB
        Operator["mlflow-operator<br/>(controller-runtime)<br/>Go 1.24.6"]
        HelmRenderer["HelmRenderer<br/>Embedded Helm Chart<br/>In-process rendering"]
        Operator -->|"renders manifests via"| HelmRenderer
    end

    subgraph "MLflow Tracking Server (deployed by operator)"
        direction TB
        MLflow["MLflow Server<br/>Python Service<br/>8443/TCP HTTPS"]
        InitCA["combine-ca-bundles<br/>Init Container<br/>Creates initial CA bundle"]
        SidecarCA["ca-bundle-watcher<br/>Sidecar Container<br/>Watches CA changes"]
        InitCA -->|"creates initial bundle"| MLflow
        SidecarCA -->|"regenerates bundle<br/>on change (30s poll)"| MLflow
    end

    %% CRDs
    MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    %% Operator watches and creates
    MLflowCR -->|"watched by"| Operator
    MLflowConfigCR -->|"watched by"| MLflow
    Operator -->|"creates via SSA"| MLflow
    Operator -->|"creates via SSA"| InitCA
    Operator -->|"creates via SSA"| SidecarCA

    %% Platform resources created by operator
    Operator -->|"creates"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Operator -->|"creates"| ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    Operator -->|"creates"| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]
    Operator -->|"creates"| NetworkPolicy["NetworkPolicy"]
    Operator -->|"creates"| ClusterRole["ClusterRole<br/>mlflow"]

    %% External dependencies
    HTTPRoute -->|"parent ref"| Gateway["data-science-gateway<br/>(Platform Gateway)"]
    MLflow -->|"TLS cert"| ServiceCA["openshift-service-ca"]
    MLflow -->|"CA bundle"| TrustedCA["odh-trusted-ca-bundle<br/>(ConfigMap)"]

    %% Backend connections
    MLflow -->|"metadata store"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflow -->|"artifact storage"| S3["S3-compatible Storage<br/>443/TCP"]
    MLflow -->|"authz checks"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style HelmRenderer fill:#4a90e2,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,stroke-width:2px
    style InitCA fill:#7ed321,stroke:#333
    style SidecarCA fill:#7ed321,stroke:#333
    style MLflowCR fill:#f5a623,stroke:#333
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style HTTPRoute fill:#b8e986,stroke:#333
    style ConsoleLink fill:#b8e986,stroke:#333
    style ServiceMonitor fill:#b8e986,stroke:#333
    style NetworkPolicy fill:#b8e986,stroke:#333
    style ClusterRole fill:#b8e986,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style TrustedCA fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
