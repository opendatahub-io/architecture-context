graph TB
    subgraph Operator["MLflow Operator (Go, controller-runtime)"]
        direction TB
        Controller["MLflow Controller<br/>Reconciles MLflow CRs"]
        HelmRenderer["Helm Chart Renderer<br/>(helm/v3 library)"]
        MigrationMgr["Migration Manager<br/>Version-aware DB migrations"]
        CapDetect["Capability Detector<br/>Discovery API checks"]
        Controller -->|renders via| HelmRenderer
        Controller -->|triggers| MigrationMgr
        Controller -->|checks CRDs| CapDetect
    end

    subgraph ManagedWorkloads["Managed Workloads (rendered by Helm)"]
        direction TB
        MLflowServer["MLflow Server<br/>Python/uvicorn<br/>8443/TCP HTTPS"]
        MLflowSA["mlflow-sa<br/>ServiceAccount"]
        GCCronJob["GC CronJob<br/>Artifact garbage collection"]
        GCSA["mlflow-gc-sa<br/>ServiceAccount"]
        MigrationJob["Migration Job<br/>Alembic DB migration"]
        NetworkPolicy["NetworkPolicy<br/>Ingress/Egress rules"]
        PVC["PersistentVolumeClaim<br/>Artifact storage"]
    end

    %% CRDs
    User["User / Platform"] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowCR -->|watched by| Controller
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]
    MLflowConfigCR -.->|read by| MLflowServer

    %% Helm rendered resources
    HelmRenderer -->|creates via SSA| MLflowServer
    HelmRenderer -->|creates| MLflowSA
    HelmRenderer -->|creates| GCCronJob
    HelmRenderer -->|creates| GCSA
    HelmRenderer -->|creates| NetworkPolicy
    HelmRenderer -->|creates| PVC
    MigrationMgr -->|creates| MigrationJob

    %% Conditional resources
    CapDetect -->|if present| HTTPRouteCR["HTTPRoute<br/>(Gateway API)"]
    CapDetect -->|if present| ConsoleLinkCR["ConsoleLink<br/>(OpenShift)"]
    CapDetect -->|if present| ServiceMonitorCR["ServiceMonitor<br/>(Prometheus)"]

    %% External integrations
    HTTPRouteCR -->|parent ref| Gateway["data-science-gateway<br/>Gateway CR"]
    MLflowServer -->|auth via| K8sAPI["Kubernetes API<br/>SelfSubjectAccessReview"]
    MLflowServer -->|stores metadata| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflowServer -->|stores artifacts| S3["S3-compatible Storage<br/>443/TCP"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style MigrationMgr fill:#4a90e2,color:#fff
    style CapDetect fill:#4a90e2,color:#fff
    style MLflowServer fill:#7ed321,color:#fff
    style GCCronJob fill:#7ed321,color:#fff
    style MigrationJob fill:#7ed321,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style HTTPRouteCR fill:#f5a623,color:#fff
    style ConsoleLinkCR fill:#f5a623,color:#fff
    style ServiceMonitorCR fill:#f5a623,color:#fff
    style Gateway fill:#e8e8e8,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style PostgreSQL fill:#e8e8e8,color:#333
    style S3 fill:#e8e8e8,color:#333
