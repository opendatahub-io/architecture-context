graph TB
    subgraph Operator["MLflow Operator (redhat-ods-applications)"]
        Controller["MLflow Controller<br/>(controller-runtime)"]
        HelmRenderer["Helm Chart Renderer<br/>(helm.sh/helm/v3)"]
        RoutingMgr["Routing Manager<br/>(HTTPRoute + ConsoleLink)"]
        Controller -->|renders values| HelmRenderer
        Controller -->|manages routes| RoutingMgr
    end

    subgraph ManagedResources["Managed Resources (redhat-ods-applications)"]
        direction TB
        MLflowDeploy["MLflow Server Deployment<br/>(Python/uvicorn, 8443/TCP)"]
        CASidecar["CA Bundle Sidecar<br/>(watches ConfigMap changes)"]
        MLflowSvc["mlflow Service<br/>(ClusterIP, 8443/TCP HTTPS)"]
        NetPol["NetworkPolicy<br/>(ingress/egress rules)"]
        PVC["PersistentVolumeClaim<br/>(local artifact storage)"]
        SvcMon["ServiceMonitor<br/>(Prometheus metrics)"]
        MLflowSA["ServiceAccount<br/>(mlflow-sa)"]
        MLflowDeploy --- CASidecar
    end

    User["Data Scientist / Client"] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    NSOwner["Namespace Owner"] -->|creates| MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller
    HelmRenderer -->|SSA applies| MLflowDeploy
    HelmRenderer -->|SSA applies| MLflowSvc
    HelmRenderer -->|SSA applies| NetPol
    HelmRenderer -->|SSA applies| PVC
    HelmRenderer -->|SSA applies| SvcMon
    HelmRenderer -->|SSA applies| MLflowSA
    RoutingMgr -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    RoutingMgr -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift)"]

    HTTPRoute -->|parent ref| Gateway["data-science-gateway"]
    MLflowDeploy -->|auth via| K8sAPI["Kubernetes API<br/>(SelfSubjectAccessReview)"]
    MLflowDeploy -->|stores metadata| DB["PostgreSQL / MySQL"]
    MLflowDeploy -->|stores artifacts| S3["S3-compatible Storage"]

    ServiceCA["OpenShift service-ca"] -->|provisions certs| TLSSecret["mlflow-tls Secret"]
    TLSSecret -->|mounted by| MLflowDeploy
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -->|watched by| CASidecar

    style Controller fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style RoutingMgr fill:#4a90e2,color:#fff
    style MLflowDeploy fill:#50a14f,color:#fff
    style CASidecar fill:#50a14f,color:#fff
    style MLflowSvc fill:#50a14f,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style HTTPRoute fill:#f5a623,color:#fff
    style ConsoleLink fill:#f5a623,color:#fff
    style Gateway fill:#999,color:#fff
    style K8sAPI fill:#999,color:#fff
    style DB fill:#999,color:#fff
    style S3 fill:#999,color:#fff
    style ServiceCA fill:#999,color:#fff
