graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        direction TB
        Controller["MLflow Controller<br/>(controller-runtime)"]
        HelmRenderer["Helm Renderer<br/>(embedded chart engine)"]
        MigrationMgr["Migration Manager<br/>(Job orchestration)"]
        RoutingMgr["Routing Manager<br/>(HTTPRoute, ConsoleLink)"]
        Webhook["Health/Metrics Server<br/>8081/TCP health, 8443/TCP metrics"]

        Controller -->|"renders manifests via"| HelmRenderer
        Controller -->|"orchestrates"| MigrationMgr
        Controller -->|"manages"| RoutingMgr
    end

    %% CRDs
    User["Data Scientist / Admin"] -->|"creates/updates"| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    NSOwner["Namespace Owner"] -->|"creates"| MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    MLflowCR -->|"watched by"| Controller

    %% Rendered Resources
    Controller -->|"creates via SSA"| MLflowDeploy["MLflow Deployment<br/>(tracking server)"]
    Controller -->|"creates"| MLflowSvc["MLflow Service<br/>8443/TCP HTTPS"]
    Controller -->|"creates"| NetPol["NetworkPolicy<br/>(ingress + egress rules)"]
    Controller -->|"creates"| RBAC["ClusterRole/Bindings<br/>(mlflow, mlflow-gc)"]
    Controller -->|"creates"| ServiceAccounts["ServiceAccounts<br/>(mlflow-sa, mlflow-gc-sa)"]

    MigrationMgr -->|"creates"| MigrationJob["Migration Job<br/>(mlflow db upgrade)"]
    Controller -->|"creates (optional)"| GCCronJob["GC CronJob<br/>(soft-delete cleanup)"]

    RoutingMgr -->|"creates (optional)"| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    RoutingMgr -->|"creates (optional)"| ConsoleLink["ConsoleLink<br/>(OpenShift menu)"]
    Controller -->|"creates (optional)"| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]

    %% MLflow server reads
    MLflowDeploy -->|"reads"| MLflowConfigCR
    MLflowDeploy -->|"reads"| ArtifactSecret["mlflow-artifact-connection<br/>Secret"]

    %% External dependencies
    HTTPRoute -->|"references parent"| Gateway["data-science-gateway<br/>(openshift-ingress)"]
    MLflowSvc -->|"TLS cert from"| ServiceCA["OpenShift service-ca"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style HelmRenderer fill:#4a90e2,color:#fff
    style MigrationMgr fill:#4a90e2,color:#fff
    style RoutingMgr fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style MLflowCR fill:#f5a623,color:#fff
    style MLflowConfigCR fill:#f5a623,color:#fff
    style MLflowDeploy fill:#7ed321,color:#fff
    style MLflowSvc fill:#7ed321,color:#fff
    style NetPol fill:#7ed321,color:#fff
    style RBAC fill:#7ed321,color:#fff
    style ServiceAccounts fill:#7ed321,color:#fff
    style MigrationJob fill:#bd10e0,color:#fff
    style GCCronJob fill:#bd10e0,color:#fff
    style HTTPRoute fill:#50e3c2
    style ConsoleLink fill:#50e3c2
    style ServiceMonitor fill:#50e3c2
    style Gateway fill:#e8e8e8
    style ServiceCA fill:#e8e8e8
    style ArtifactSecret fill:#e8e8e8
