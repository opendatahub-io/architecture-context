graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC backends)
    Orch -->|"gRPC/HTTP2<br/>8033/TCP<br/>Generate, Tokenize"| TGIS["TGIS<br/>(Text Generation)"]
    Orch -->|"gRPC/HTTP2<br/>8085/TCP<br/>TextGeneration, Tokenize"| CaikitNLP["Caikit NLP"]
    Orch -->|"gRPC/HTTP2<br/>8085/TCP<br/>Chunking, BidiStreaming"| CaikitChunkers["Caikit Chunkers"]

    %% Internal Platform Dependencies (HTTP backends)
    Orch -->|"HTTP/HTTPS<br/>8080/TCP<br/>Content safety detection"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orch -->|"HTTP/HTTPS<br/>8080/TCP<br/>Chat/text completions"| OpenAISvr["OpenAI-compatible<br/>(e.g., vLLM)"]

    %% Observability
    Orch -.->|"OTLP<br/>4317/4318 TCP<br/>Traces + Metrics"| OTLP["OTLP Collector"]

    %% Key Library Dependencies
    subgraph RustDeps["Key Rust Dependencies"]
        direction TB
        Axum["axum 0.8.8<br/>(HTTP server)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Prost["prost 0.14.1<br/>(protobuf)"]
        OTel["opentelemetry 0.31.0<br/>(tracing/metrics)"]
        Ginepro["ginepro<br/>(gRPC load balancing)"]
    end

    Orch -->|"framework"| RustDeps

    %% Styling
    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style CaikitChunkers fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style OpenAISvr fill:#7ed321,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff
    style Axum fill:#f5a623,stroke:#333
    style Tonic fill:#f5a623,stroke:#333
    style Tokio fill:#f5a623,stroke:#333
    style Rustls fill:#f5a623,stroke:#333
    style Reqwest fill:#f5a623,stroke:#333
    style Prost fill:#f5a623,stroke:#333
    style OTel fill:#f5a623,stroke:#333
    style Ginepro fill:#f5a623,stroke:#333
