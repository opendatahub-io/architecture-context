graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC upstreams)
    Orchestrator -->|"gRPC/8033<br/>Generate, Tokenize"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    Orchestrator -->|"gRPC/8085<br/>TextGen, Tokenize,<br/>TokenClassify"| CaikitNLP["Caikit NLP"]
    Orchestrator -->|"gRPC/8085<br/>Chunking (unary +<br/>bidi streaming)"| CaikitChunkers["Caikit Chunkers"]

    %% Internal Platform Dependencies (HTTP upstreams)
    Orchestrator -->|"HTTP(S)/8080<br/>Content detection"| DetectorServices["Detector Services<br/>(HAP, PII, etc.)"]
    Orchestrator -->|"HTTP(S)/8080<br/>Chat/Text completions"| OpenAIvLLM["OpenAI / vLLM"]

    %% Observability
    Orchestrator -.->|"gRPC/4317 or<br/>HTTP/4318<br/>Traces + Metrics"| OTLP["OTLP Collector"]

    %% Platform Operator
    RHODSOp["rhods-operator"] -->|"deploys &<br/>manages"| Orchestrator

    %% Certificate Management
    CertManager["cert-manager"] -.->|"provisions<br/>TLS certs"| Orchestrator

    %% Key Library Dependencies
    subgraph "Runtime Libraries"
        direction TB
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Ginepro["ginepro<br/>(gRPC LB)"]
        OTel["opentelemetry 0.31.0<br/>(tracing/metrics)"]
    end

    Orchestrator -->|"built on"| Axum
    Orchestrator -->|"built on"| Tokio

    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style CaikitChunkers fill:#7ed321,stroke:#333,color:#fff
    style DetectorServices fill:#7ed321,stroke:#333,color:#fff
    style OpenAIvLLM fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style OTLP fill:#f5a623,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style Axum fill:#dae8fc,stroke:#6c8ebf
    style Tokio fill:#dae8fc,stroke:#6c8ebf
    style Tonic fill:#dae8fc,stroke:#6c8ebf
    style Rustls fill:#dae8fc,stroke:#6c8ebf
    style Reqwest fill:#dae8fc,stroke:#6c8ebf
    style Ginepro fill:#dae8fc,stroke:#6c8ebf
    style OTel fill:#dae8fc,stroke:#6c8ebf
