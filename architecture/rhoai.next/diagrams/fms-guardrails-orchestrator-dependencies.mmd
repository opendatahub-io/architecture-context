graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC backends)
    Orch -->|"gRPC/HTTP2 8033/TCP<br/>Generate, Tokenize<br/>Optional TLS/mTLS"| TGIS["TGIS<br/>Generation Server"]
    Orch -->|"gRPC/HTTP2 8085/TCP<br/>TextGeneration, Tokenization<br/>Optional TLS/mTLS"| CaikitNLP["caikit-nlp<br/>Generation Server"]
    Orch -->|"gRPC/HTTP2 8085/TCP<br/>ChunkerTokenization<br/>Optional TLS/mTLS"| Chunkers["caikit Chunkers"]

    %% Internal Platform Dependencies (HTTP backends)
    Orch -->|"HTTP/HTTPS 8080/TCP<br/>/api/v1/text/*<br/>Optional TLS/mTLS"| Detectors["Detector Services<br/>(content safety)"]
    Orch -->|"HTTP/HTTPS 8080/TCP<br/>/v1/chat/completions<br/>Optional TLS + Bearer"| OpenAI["OpenAI-compatible<br/>Server (vLLM)"]

    %% Observability
    Orch -->|"gRPC 4317 / HTTP 4318<br/>OTLP traces + metrics"| OTLPCol["OTLP Collector"]

    %% Platform Management
    RHODSOp["rhods-operator"] -->|"deploys & manages<br/>K8s resources"| Orch

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        direction TB
        Rust["Rust 1.92.0"]
        Axum["axum 0.8.8"]
        Tonic["tonic 0.14.2"]
        Hyper["hyper 1.8.1"]
        Rustls["rustls 0.23.36"]
        Tokio["tokio 1.49.0"]
        OTelLib["opentelemetry 0.31.0"]
        Reqwest["reqwest 0.12.28"]
        Ginepro["ginepro (gRPC LB)"]
    end

    Orch -.-|"built with"| BuildDeps

    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style Chunkers fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style OpenAI fill:#7ed321,stroke:#333,color:#fff
    style OTLPCol fill:#f5a623,stroke:#333,color:#fff
    style RHODSOp fill:#bd10e0,stroke:#333,color:#fff
    style Rust fill:#e8e8e8,stroke:#333
    style Axum fill:#e8e8e8,stroke:#333
    style Tonic fill:#e8e8e8,stroke:#333
    style Hyper fill:#e8e8e8,stroke:#333
    style Rustls fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style OTelLib fill:#e8e8e8,stroke:#333
    style Reqwest fill:#e8e8e8,stroke:#333
    style Ginepro fill:#e8e8e8,stroke:#333
