graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator<br/>(Rust Service)"]

    %% gRPC Dependencies (Generation Backends)
    Orchestrator -->|"gRPC 8033/TCP<br/>mTLS optional<br/>Generate, GenerateStream,<br/>Tokenize, ModelInfo"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    Orchestrator -->|"gRPC 8085/TCP<br/>mTLS optional<br/>TextGeneration,<br/>Tokenization,<br/>TokenClassification"| CaikitNLP["Caikit NLP<br/>(NlpService)"]

    %% gRPC Dependencies (Chunker)
    Orchestrator -->|"gRPC 8085/TCP<br/>mTLS optional<br/>Unary + BidiStreaming<br/>Tokenization"| Chunker["Chunker Service(s)<br/>(ChunkersService)"]

    %% HTTP Dependencies (Detection)
    Orchestrator -->|"HTTP 8080/TCP<br/>TLS optional<br/>text/contents, text/generation,<br/>text/chat, text/context"| Detector["Detector Service(s)<br/>(Content Safety)"]

    %% HTTP Dependencies (OpenAI)
    Orchestrator -->|"HTTP 8080/TCP<br/>TLS optional<br/>SSE streaming<br/>/v1/chat/completions,<br/>/v1/completions"| vLLM["OpenAI-compatible API<br/>(vLLM)"]

    %% Observability
    Orchestrator -.->|"gRPC 4317/TCP<br/>HTTP 4318/TCP<br/>OTLP traces + metrics"| OTLP["OpenTelemetry<br/>Collector"]

    %% Runtime Dependencies
    Orchestrator -.->|"DNS resolution<br/>gRPC load balancing"| DNS["DNS<br/>(ginepro)"]

    %% Rust Framework Dependencies (internal)
    subgraph RuntimeStack["Rust Runtime Stack"]
        direction TB
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tokio["tokio 1.49.0<br/>(Async runtime)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS - ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Hyper["hyper 1.8.1<br/>(HTTP/1.1 + HTTP/2)"]
    end

    Orchestrator -.->|"built on"| RuntimeStack

    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333
    style CaikitNLP fill:#7ed321,stroke:#333
    style Chunker fill:#7ed321,stroke:#333
    style Detector fill:#7ed321,stroke:#333
    style vLLM fill:#7ed321,stroke:#333
    style OTLP fill:#999,stroke:#333,color:#fff
    style DNS fill:#999,stroke:#333,color:#fff
    style Axum fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style Tonic fill:#e8e8e8,stroke:#333
    style Rustls fill:#e8e8e8,stroke:#333
    style Reqwest fill:#e8e8e8,stroke:#333
    style Hyper fill:#e8e8e8,stroke:#333
