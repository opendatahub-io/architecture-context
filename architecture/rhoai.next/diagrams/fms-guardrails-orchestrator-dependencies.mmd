graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC)
    Orchestrator -->|"gRPC/8033<br/>Generate, GenerateStream,<br/>Tokenize, ModelInfo"| TGIS["TGIS<br/>(Text Generation<br/>Inference Server)"]
    Orchestrator -->|"gRPC/8085<br/>TextGeneration,<br/>Tokenization,<br/>TokenClassification"| CaikitNLP["Caikit NLP<br/>Server"]
    Orchestrator -->|"gRPC/8085<br/>ChunkerTokenization,<br/>BidiStreaming"| Chunker["Chunker<br/>Service(s)"]

    %% Internal Platform Dependencies (HTTP)
    Orchestrator -->|"HTTP/8080<br/>text/contents, text/generation,<br/>text/chat, text/context"| Detectors["Detector<br/>Service(s)<br/>(HAP, toxicity)"]
    Orchestrator -->|"HTTP/8080 (SSE)<br/>/v1/chat/completions,<br/>/v1/completions, /tokenize"| OpenAI["OpenAI-compatible<br/>API (vLLM)"]

    %% Observability
    Orchestrator -->|"OTLP gRPC/4317<br/>or HTTP/4318<br/>traces + metrics"| OTEL["OpenTelemetry<br/>Collector"]

    %% Key Rust Dependencies
    subgraph "Rust Runtime Dependencies"
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        OTelSDK["opentelemetry 0.31.0<br/>(tracing + metrics)"]
        Ginepro["ginepro<br/>(DNS gRPC LB)"]
    end

    Orchestrator -.->|"HTTP server"| Axum
    Orchestrator -.->|"gRPC client"| Tonic
    Orchestrator -.->|"async runtime"| Tokio
    Orchestrator -.->|"TLS"| Rustls
    Orchestrator -.->|"HTTP client"| Reqwest
    Orchestrator -.->|"observability"| OTelSDK
    Orchestrator -.->|"gRPC load balancing"| Ginepro

    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style Chunker fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style OpenAI fill:#7ed321,stroke:#333,color:#fff
    style OTEL fill:#999,stroke:#333,color:#fff
    style Axum fill:#f5a623,stroke:#333
    style Tonic fill:#f5a623,stroke:#333
    style Tokio fill:#f5a623,stroke:#333
    style Rustls fill:#f5a623,stroke:#333
    style Reqwest fill:#f5a623,stroke:#333
    style OTelSDK fill:#f5a623,stroke:#333
    style Ginepro fill:#f5a623,stroke:#333
