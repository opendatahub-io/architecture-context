graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies
    Orchestrator -->|"REST 8080/TCP<br/>content detection"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orchestrator -->|"gRPC 8085/TCP<br/>tokenization/chunking"| Chunkers["Chunker Services<br/>(caikit-based)"]
    Orchestrator -->|"gRPC 8033/TCP<br/>text generation"| TGIS["TGIS"]
    Orchestrator -->|"gRPC 8085/TCP<br/>text generation"| CaikitNLP["caikit-nlp"]
    Orchestrator -->|"REST 8080/TCP<br/>chat/text completions"| OpenAISvc["OpenAI-compatible<br/>(vLLM, etc.)"]

    %% Infrastructure Dependencies
    Orchestrator -.->|"OTLP 4317/4318<br/>traces + metrics"| OTel["OpenTelemetry<br/>Collector"]
    Orchestrator -.->|"TLS certs"| CertManager["cert-manager"]

    %% Key Library Dependencies
    subgraph RuntimeDeps["Key Runtime Libraries"]
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Ginepro["ginepro<br/>(gRPC LB)"]
    end

    Orchestrator -.->|"built with"| RuntimeDeps

    %% Integration Points (consumers)
    TrustyAI["TrustyAI Operator"] -->|"deploys as pod"| Orchestrator
    KServe["KServe<br/>InferenceService"] -->|"sidecar/co-deploy"| Orchestrator

    %% Styling
    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Detectors fill:#e17055,stroke:#333,color:#fff
    style Chunkers fill:#e17055,stroke:#333,color:#fff
    style TGIS fill:#e17055,stroke:#333,color:#fff
    style CaikitNLP fill:#e17055,stroke:#333,color:#fff
    style OpenAISvc fill:#e17055,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Axum fill:#dfe6e9,stroke:#333
    style Tonic fill:#dfe6e9,stroke:#333
    style Rustls fill:#dfe6e9,stroke:#333
    style Reqwest fill:#dfe6e9,stroke:#333
    style Tokio fill:#dfe6e9,stroke:#333
    style Ginepro fill:#dfe6e9,stroke:#333
