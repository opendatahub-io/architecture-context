graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC)
    Orch -->|"gRPC 8033/TCP<br/>Generate, Tokenize"| TGIS["TGIS<br/>Text Generation<br/>Inference Server"]
    Orch -->|"gRPC 8085/TCP<br/>TextGen, Tokenize<br/>TokenClassify"| CaikitNLP["Caikit NLP"]
    Orch -->|"gRPC 8085/TCP<br/>Chunking (unary + bidi)"| Chunkers["Caikit Chunkers"]

    %% Internal Platform Dependencies (HTTP)
    Orch -->|"HTTP/HTTPS 8080/TCP<br/>Content Detection"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orch -->|"HTTP/HTTPS 8080/TCP<br/>Chat/Text Completions"| OpenAI["OpenAI / vLLM<br/>Server"]

    %% Infrastructure Dependencies
    Orch -.->|"gRPC 4317/TCP<br/>or HTTP 4318/TCP<br/>traces + metrics"| OTLPCollector["OTLP Collector"]

    %% Platform Operator (manages this component)
    RHODSOp["RHODS Operator"] -->|"deploys,<br/>manages RBAC,<br/>creates Routes"| Orch

    %% Build/Runtime Dependencies (libraries)
    subgraph RuntimeLibs["Key Runtime Libraries"]
        direction TB
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Ginepro["ginepro<br/>(gRPC DNS LB)"]
        OTel["opentelemetry 0.31.0<br/>(tracing + metrics)"]
    end

    Orch -.-|"runtime"| RuntimeLibs

    %% Styling
    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#e1d5e7,stroke:#9673a6
    style CaikitNLP fill:#e1d5e7,stroke:#9673a6
    style Chunkers fill:#e1d5e7,stroke:#9673a6
    style Detectors fill:#fff2cc,stroke:#d6b656
    style OpenAI fill:#fff2cc,stroke:#d6b656
    style OTLPCollector fill:#f8cecc,stroke:#b85450
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style Axum fill:#dae8fc,stroke:#6c8ebf
    style Tokio fill:#dae8fc,stroke:#6c8ebf
    style Tonic fill:#dae8fc,stroke:#6c8ebf
    style Reqwest fill:#dae8fc,stroke:#6c8ebf
    style Rustls fill:#dae8fc,stroke:#6c8ebf
    style Ginepro fill:#dae8fc,stroke:#6c8ebf
    style OTel fill:#dae8fc,stroke:#6c8ebf
