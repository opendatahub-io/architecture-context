graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (gRPC)
    Orchestrator -->|"gRPC 8033/TCP<br/>Generation RPCs"| TGIS["TGIS<br/>Generation Server"]
    Orchestrator -->|"gRPC 8085/TCP<br/>NLP RPCs + Retry"| CaikitNLP["Caikit NLP"]
    Orchestrator -->|"gRPC 8085/TCP<br/>Chunking RPCs<br/>(unary + bidi streaming)"| CaikitChunker["Caikit Chunkers"]

    %% Internal Platform Dependencies (HTTP)
    Orchestrator -->|"HTTP 8080/TCP<br/>Detection APIs"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orchestrator -->|"HTTP 8080/TCP<br/>Chat/Text Completions"| OpenAI["OpenAI / vLLM"]

    %% Infrastructure Dependencies
    Orchestrator -.->|"gRPC 4317/TCP<br/>or HTTP 4318/TCP"| OTLP["OTLP Collector"]

    %% External Dependencies (Libraries)
    subgraph RuntimeDeps["Key Runtime Dependencies"]
        direction TB
        Axum["axum 0.8.8<br/>(HTTP framework)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS - ring backend)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Ginepro["ginepro<br/>(gRPC load balancing)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
        OTelLib["opentelemetry 0.31.0<br/>(tracing + metrics)"]
    end

    Orchestrator -.->|"uses"| RuntimeDeps

    %% Platform integration (consumers of this service)
    AuthProxy["Auth Proxy<br/>(kube-rbac-proxy /<br/>oauth-proxy)"] -->|"forwards requests"| Orchestrator
    RhodsOperator["rhods-operator"] -->|"deploys &<br/>configures"| Orchestrator

    %% Styling
    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style CaikitChunker fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style OpenAI fill:#7ed321,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff
    style AuthProxy fill:#f5a623,stroke:#333,color:#fff
    style RhodsOperator fill:#f5a623,stroke:#333,color:#fff
    style RuntimeDeps fill:#f9f9f9,stroke:#ccc
    style Axum fill:#fff2cc,stroke:#d6b656
    style Tonic fill:#fff2cc,stroke:#d6b656
    style Rustls fill:#fff2cc,stroke:#d6b656
    style Tokio fill:#fff2cc,stroke:#d6b656
    style Ginepro fill:#fff2cc,stroke:#d6b656
    style Reqwest fill:#fff2cc,stroke:#d6b656
    style OTelLib fill:#fff2cc,stroke:#d6b656
