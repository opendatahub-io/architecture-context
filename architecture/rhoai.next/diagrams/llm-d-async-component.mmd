graph TB
    subgraph AP["Async Processor (llm-d-async)"]
        direction TB
        Main["cmd/main.go<br/>CLI Entry Point"]
        Worker["AsyncWorker<br/>pkg/asyncworker"]
        HTTPClient["HTTP Inference Client<br/>pkg/asyncworker/http_client.go"]
        MergePolicy["RandomRobinPolicy<br/>pkg/async/random_robin_policy.go"]
        Metrics["Prometheus Metrics<br/>pkg/metrics (port 9090)"]

        subgraph FlowControl["Flow Control Gates (pkg/async/inference/flowcontrol)"]
            GateFactory["GateFactory"]
            PromSatGate["Prometheus Saturation Gate"]
            PromBudgetGate["Prometheus Budget Gate"]
            PromQueryGate["Prometheus Query Gate"]
            RedisGate["Redis Gate"]
            RedisQuotaGate["Redis Quota Gate<br/>(rate-limit + concurrency)"]
            CompositeGate["Composite Gate"]
            ConstGate["Constant Gate"]
            CachedMetric["CachedMetricSource<br/>(5s TTL)"]
            CascadeMetric["CascadeMetricSource<br/>(EPP -> vLLM fallback)"]
        end

        subgraph QueueImpls["Queue Implementations"]
            RedisPubSub["Redis Pub/Sub Flow<br/>pkg/redis/redisimpl.go"]
            RedisSortedSet["Redis Sorted Set Flow<br/>pkg/redis/sortedset_impl.go"]
            GCPPubSub["GCP Pub/Sub Flow<br/>pkg/pubsub/pubsubimpl.go"]
        end

        Main --> Worker
        Main --> MergePolicy
        Main --> GateFactory
        Worker --> HTTPClient
        Worker --> MergePolicy
        MergePolicy --> RedisPubSub
        MergePolicy --> RedisSortedSet
        MergePolicy --> GCPPubSub
        GateFactory --> PromSatGate
        GateFactory --> PromBudgetGate
        GateFactory --> PromQueryGate
        GateFactory --> RedisGate
        GateFactory --> RedisQuotaGate
        GateFactory --> CompositeGate
        GateFactory --> ConstGate
        PromBudgetGate --> CascadeMetric
        PromSatGate --> CachedMetric
        PromQueryGate --> CachedMetric
    end

    subgraph ProducerSDK["Producer SDK (producer/)"]
        ProducerIface["Producer Interface"]
        RedisSortedSetProducer["Redis Sorted Set Producer<br/>producer/redis_sortedset_producer.go"]
        ProducerIface --> RedisSortedSetProducer
    end

    %% External Systems
    Producer["External Producer<br/>(submits jobs)"] -->|submit requests| ProducerIface
    Consumer["External Consumer<br/>(retrieves results)"]

    %% Queue Backends
    Redis["Redis<br/>6379/TCP"]
    GCP["GCP Pub/Sub<br/>443/TCP"]
    Prom["Prometheus<br/>9090/TCP"]
    IGW["Inference Gateway (IGW)<br/>80/443 TCP"]

    %% Connections
    RedisPubSub -->|poll/push| Redis
    RedisSortedSet -->|ZPOPMIN/ZADD/LPUSH| Redis
    RedisSortedSetProducer -->|ZADD/BRPOP| Redis
    GCPPubSub -->|subscribe/publish| GCP
    HTTPClient -->|POST inference| IGW
    CachedMetric -->|PromQL queries| Prom
    CascadeMetric -->|PromQL queries| Prom
    RedisGate -->|budget keys| Redis
    RedisQuotaGate -->|quota tracking| Redis
    Consumer -->|BRPOP results| Redis

    %% Styling
    style AP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style FlowControl fill:#e8d5f5,stroke:#9b59b6,stroke-width:1px
    style QueueImpls fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style ProducerSDK fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style Redis fill:#d9534f,stroke:#333,color:#fff
    style GCP fill:#4285f4,stroke:#333,color:#fff
    style Prom fill:#e6522c,stroke:#333,color:#fff
    style IGW fill:#5cb85c,stroke:#333,color:#fff
    style Producer fill:#f5f5f5,stroke:#999
    style Consumer fill:#f5f5f5,stroke:#999
