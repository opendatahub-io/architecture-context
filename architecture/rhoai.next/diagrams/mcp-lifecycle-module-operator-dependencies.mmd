graph LR
    MCPModuleOp["MCP Lifecycle<br/>Module Operator"]

    %% External Dependencies (compile-time libraries)
    MCPModuleOp -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.24.1"]
    MCPModuleOp -->|"manifest loading<br/>& transformation"| Manifestival["manifestival<br/>v0.7.2"]
    MCPModuleOp -->|"SSA deployer, GC,<br/>labels, platform API"| PlatformUtils["odh-platform-utilities<br/>v0.1.0"]
    PlatformUtils -.->|"uses"| ManifestKitEngine["k8s-manifest-kit/engine<br/>v0.2.1"]
    PlatformUtils -.->|"uses"| ManifestKitPkg["k8s-manifest-kit/pkg<br/>v0.2.1"]

    %% Internal Platform Dependencies (runtime)
    PlatformOperator["ODH Platform Operator<br/><i>rhods-operator</i>"] -->|"creates CR<br/>MCPLifecycleOperator"| MCPModuleOp
    MCPModuleOp -->|"deploys operand<br/>via SSA"| MCPLifecycleOp["MCP Lifecycle Operator<br/><i>(operand)</i>"]

    %% External Services (runtime)
    MCPModuleOp -->|"all CRUD operations<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    MCPLifecycleOp -->|"MCPServer management<br/>443/TCP HTTPS"| K8sAPI

    %% CRDs managed
    MCPLifecycleOp -->|"reconciles"| MCPServerCRD["MCPServer CRD<br/><i>mcp.x-k8s.io</i>"]

