graph TB
    subgraph TrainingHub["training-hub Library"]
        direction TB

        subgraph PublicAPI["Public API (training_hub.__init__)"]
            sft_fn["sft()"]
            osft_fn["osft()"]
            lora_sft_fn["lora_sft()"]
            lora_grpo_fn["lora_grpo()"]
            grpo_fn["grpo()"]
            estimate_fn["estimate()"]
            plot_loss_fn["plot_loss()"]
        end

        subgraph AlgorithmFramework["Algorithm Framework"]
            Registry["AlgorithmRegistry<br/>register_algorithm()<br/>register_backend()<br/>create_algorithm()"]
            AlgorithmBase["Algorithm (ABC)"]
            BackendBase["Backend (ABC)"]
            Registry -->|factory creates| AlgorithmBase
            Registry -->|factory creates| BackendBase
        end

        subgraph Algorithms["Training Algorithms"]
            SFT["SFT Algorithm<br/>Full-parameter SFT"]
            OSFT["OSFT Algorithm<br/>Orthogonal Subspace FT"]
            LoRASFT["LoRA+SFT Algorithm<br/>Parameter-efficient FT"]
            LoRAGRPO["LoRA+GRPO Algorithm<br/>RL with LoRA"]
            GRPO["GRPO Algorithm<br/>Full FT GRPO (lora_r=0)"]
        end

        subgraph Backends["Backend Implementations"]
            ILabBackend["instructlab-training<br/>Backend"]
            MiniTrainerBackend["mini-trainer<br/>Backend"]
            UnslothBackend["Unsloth<br/>Backend"]
            ARTBackend["OpenPipe ART<br/>Backend (subprocess)"]
            VeRLBackend["verl<br/>Backend (subprocess)"]
        end

        subgraph Utilities["Supporting Modules"]
            MemoryEstimator["Memory Estimator<br/>BasicEstimator, OSFTEstimator<br/>LoRAEstimator, QLoRAEstimator"]
            TimingEstimator["Timing Estimator<br/>(Experimental)"]
            Visualization["Visualization<br/>Loss curves, EMA smoothing"]
            Rewards["Reward Functions<br/>tool_call_reward()<br/>binary_reward()"]
            TorchrunUtils["Distributed Training Utils<br/>get_torchrun_params()"]
        end
    end

    %% Algorithm to Backend mappings
    SFT -->|executes via| ILabBackend
    OSFT -->|executes via| MiniTrainerBackend
    LoRASFT -->|executes via| UnslothBackend
    LoRAGRPO -->|executes via| ARTBackend
    LoRAGRPO -->|executes via| VeRLBackend
    GRPO -->|executes via| VeRLBackend

    %% Public API to Algorithm mappings
    sft_fn --> SFT
    osft_fn --> OSFT
    lora_sft_fn --> LoRASFT
    lora_grpo_fn --> LoRAGRPO
    grpo_fn --> GRPO
    estimate_fn --> MemoryEstimator
    plot_loss_fn --> Visualization

    %% SFT/OSFT use torchrun
    SFT -->|orchestrates| TorchrunUtils
    OSFT -->|orchestrates| TorchrunUtils

    %% GRPO uses rewards
    LoRAGRPO -->|uses| Rewards
    GRPO -->|uses| Rewards

    %% External user
    User["Data Scientist / ML Engineer"] -->|pip install training-hub<br/>Python API calls| PublicAPI

    %% Styling
    style TrainingHub fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PublicAPI fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style AlgorithmFramework fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Algorithms fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Backends fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Utilities fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style User fill:#f5f5f5,stroke:#666,stroke-width:2px
    style Registry fill:#fff2cc,stroke:#d6b656
    style SFT fill:#dae8fc,stroke:#6c8ebf
    style OSFT fill:#dae8fc,stroke:#6c8ebf
    style LoRASFT fill:#dae8fc,stroke:#6c8ebf
    style LoRAGRPO fill:#dae8fc,stroke:#6c8ebf
    style GRPO fill:#dae8fc,stroke:#6c8ebf
    style ILabBackend fill:#f8cecc,stroke:#b85450
    style MiniTrainerBackend fill:#f8cecc,stroke:#b85450
    style UnslothBackend fill:#f8cecc,stroke:#b85450
    style ARTBackend fill:#f8cecc,stroke:#b85450
    style VeRLBackend fill:#f8cecc,stroke:#b85450
