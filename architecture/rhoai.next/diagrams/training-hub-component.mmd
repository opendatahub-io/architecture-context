graph TB
    subgraph TrainingHub["training-hub Python SDK"]
        direction TB

        subgraph CoreFramework["Algorithm-Backend Framework"]
            AlgorithmABC["Algorithm ABC<br/><i>train(), get_required_params(),<br/>get_optional_params()</i>"]
            BackendABC["Backend ABC<br/><i>execute_training()</i>"]
            Registry["AlgorithmRegistry<br/><i>register_algorithm(),<br/>register_backend(),<br/>create_algorithm()</i>"]
            PEFTExtender["PEFTExtender ABC<br/><i>LoRAPEFTExtender</i><br/>LoRA/QLoRA/DoRA params"]

            Registry -->|instantiates| AlgorithmABC
            Registry -->|wires| BackendABC
            PEFTExtender -.->|composes with| AlgorithmABC
        end

        subgraph Algorithms["Training Algorithms"]
            SFT["SFT Algorithm<br/><i>sft()</i>"]
            OSFT["OSFT Algorithm<br/><i>osft()</i><br/>SVD weight decomposition"]
            LoRASFT["LoRA+SFT Algorithm<br/><i>lora_sft()</i><br/>QLoRA/DoRA/RSLoRA"]
            LoRAGRPO["LoRA+GRPO Algorithm<br/><i>lora_grpo()</i><br/>RL from verifiable rewards"]
            GRPO["GRPO Algorithm<br/><i>grpo()</i><br/>Full fine-tuning (lora_r=0)"]
        end

        subgraph Backends["Execution Backends"]
            ILabBackend["instructlab-training<br/>Backend"]
            MiniTrainerBackend["mini-trainer<br/>Backend"]
            UnslothBackend["Unsloth<br/>Backend"]
            ARTBackend["OpenPipe ART<br/>Backend<br/><i>(single-GPU)</i>"]
            VeRLBackend["verl<br/>Backend<br/><i>(multi-GPU FSDP)</i>"]
        end

        subgraph Profiling["Profiling & Visualization"]
            MemEstimator["Memory Estimator<br/><i>BasicEstimator, OSFTEstimator,<br/>LoRAEstimator, QLoRAEstimator</i>"]
            TimingEstimator["Timing Estimator<br/><i>Subset training extrapolation</i>"]
            Visualization["Visualization<br/><i>plot_loss() with EMA</i>"]
        end

        subgraph Utilities["Utilities"]
            TorchrunUtils["torchrun Utilities<br/><i>get_torchrun_params()</i>"]
            RewardFunctions["Reward Functions<br/><i>tool_call_reward,<br/>binary_reward</i>"]
            VeRLAgentLoop["verl Tool Agent Loop<br/><i>SingleTurnToolAgentLoop</i>"]
        end

        %% Algorithm-Backend Wiring
        SFT -->|delegates to| ILabBackend
        OSFT -->|delegates to| MiniTrainerBackend
        LoRASFT -->|delegates to| UnslothBackend
        LoRAGRPO -->|delegates to| ARTBackend
        LoRAGRPO -->|delegates to| VeRLBackend
        GRPO -->|delegates to| VeRLBackend

        %% Utility connections
        LoRAGRPO -.->|uses| RewardFunctions
        GRPO -.->|uses| RewardFunctions
        VeRLBackend -.->|uses| VeRLAgentLoop
        ILabBackend -.->|uses| TorchrunUtils
    end

    %% External Interactions
    UserScript["User Script / Notebook"]
    UserScript -->|"from training_hub import sft, lora_grpo"| Registry

    HFHub["HuggingFace Hub<br/><i>Model & tokenizer downloads</i>"]
    WandB["WandB<br/><i>Experiment tracking</i>"]
    MLflow["MLflow<br/><i>Experiment tracking</i>"]
    GPUCluster["GPU Cluster<br/><i>NCCL / DDP / FSDP</i>"]
    Filesystem["Filesystem<br/><i>Checkpoints, metrics,<br/>training logs</i>"]

    ILabBackend -->|downloads models| HFHub
    UnslothBackend -->|downloads models| HFHub
    ILabBackend -->|distributed training| GPUCluster
    VeRLBackend -->|distributed training| GPUCluster
    Algorithms -->|optional metrics| WandB
    Algorithms -->|optional metrics| MLflow
    Algorithms -->|writes| Filesystem

    %% Styling
    style TrainingHub fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    style CoreFramework fill:#fff3e0,stroke:#f5a623,stroke-width:2px
    style Algorithms fill:#e8f5e9,stroke:#7ed321,stroke-width:2px
    style Backends fill:#fce4ec,stroke:#e57373,stroke-width:2px
    style Profiling fill:#f3e5f5,stroke:#ab47bc,stroke-width:2px
    style Utilities fill:#e0f2f1,stroke:#26a69a,stroke-width:2px

    style AlgorithmABC fill:#fff3e0,stroke:#f5a623
    style BackendABC fill:#fff3e0,stroke:#f5a623
    style Registry fill:#fff3e0,stroke:#f5a623
    style PEFTExtender fill:#fff3e0,stroke:#f5a623

    style SFT fill:#e8f5e9,stroke:#7ed321
    style OSFT fill:#e8f5e9,stroke:#7ed321
    style LoRASFT fill:#e8f5e9,stroke:#7ed321
    style LoRAGRPO fill:#e8f5e9,stroke:#7ed321
    style GRPO fill:#e8f5e9,stroke:#7ed321

    style ILabBackend fill:#fce4ec,stroke:#e57373
    style MiniTrainerBackend fill:#fce4ec,stroke:#e57373
    style UnslothBackend fill:#fce4ec,stroke:#e57373
    style ARTBackend fill:#fce4ec,stroke:#e57373
    style VeRLBackend fill:#fce4ec,stroke:#e57373

    style UserScript fill:#f9f9f9,stroke:#999
