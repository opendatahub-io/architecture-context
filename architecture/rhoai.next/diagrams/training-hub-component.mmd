graph TB
    subgraph TrainingHub["training-hub SDK"]
        direction TB

        subgraph PublicAPI["Public API Layer"]
            sft_fn["sft()"]
            osft_fn["osft()"]
            lora_sft_fn["lora_sft()"]
            lora_grpo_fn["lora_grpo()"]
            grpo_fn["grpo()"]
            estimate_fn["estimate()"]
            plot_loss_fn["plot_loss()"]
        end

        subgraph Core["Core Architecture"]
            Registry["AlgorithmRegistry<br/>(Strategy + Registry Pattern)"]
            Factory["create_algorithm()<br/>(Factory Function)"]
            AlgoBase["Algorithm<br/>(Abstract Base Class)<br/>validate() + run()"]
            BackendBase["Backend<br/>(Abstract Base Class)<br/>train()"]
        end

        subgraph Algorithms["Algorithm Implementations"]
            SFTAlgo["SFTAlgorithm<br/>Full-parameter SFT"]
            OSFTAlgo["OSFTAlgorithm<br/>Orthogonal Subspace FT"]
            LoRASFTAlgo["LoRASFTAlgorithm<br/>LoRA / QLoRA / DoRA SFT"]
            LoRAGRPOAlgo["LoRAGRPOAlgorithm<br/>GRPO Reinforcement Learning"]
        end

        subgraph Backends["Backend Implementations"]
            ILabBackend["InstructLabTraining<br/>SFTBackend"]
            MiniTrainerBackend["MiniTrainer<br/>OSFTBackend"]
            UnslothBackend["Unsloth<br/>LoRABackend"]
            ARTBackend["ART<br/>LoRAGRPOBackend<br/>(single-GPU)"]
            VeRLBackend["VeRL<br/>LoRAGRPOBackend<br/>(multi-GPU)"]
        end

        subgraph Profiling["Profiling Module"]
            BasicEst["BasicEstimator<br/>(SFT VRAM)"]
            OSFTEst["OSFTEstimator<br/>(OSFT VRAM)"]
            LoRAEst["LoRAEstimator<br/>(LoRA VRAM)"]
            QLoRAEst["QLoRAEstimator<br/>(QLoRA VRAM)"]
            TimingEst["TimingEstimator<br/>(Experimental)"]
        end

        subgraph Utilities["Utilities"]
            Rewards["Reward Functions<br/>tool_call_reward()<br/>binary_reward()"]
            Viz["Visualization<br/>Loss Curve Plotting"]
            PEFTExt["LoRAPEFTExtender"]
        end
    end

    %% Public API to Core
    sft_fn --> Factory
    osft_fn --> Factory
    lora_sft_fn --> Factory
    lora_grpo_fn --> Factory
    grpo_fn --> Factory
    estimate_fn --> Profiling
    plot_loss_fn --> Viz

    %% Core relationships
    Factory --> Registry
    Registry --> AlgoBase
    Registry --> BackendBase
    AlgoBase --> Algorithms
    BackendBase --> Backends

    %% Algorithm-Backend mappings
    SFTAlgo -.->|delegates to| ILabBackend
    OSFTAlgo -.->|delegates to| MiniTrainerBackend
    LoRASFTAlgo -.->|delegates to| UnslothBackend
    LoRAGRPOAlgo -.->|delegates to| ARTBackend
    LoRAGRPOAlgo -.->|delegates to| VeRLBackend

    %% External framework dependencies
    ILabBackend -->|calls| ILab["instructlab-training<br/>run_training()"]
    MiniTrainerBackend -->|calls| MiniTrainer["mini-trainer<br/>run_training()"]
    UnslothBackend -->|calls| Unsloth["Unsloth FastModel<br/>+ TRL SFTTrainer"]
    ARTBackend -->|subprocess| ART["OpenPipe ART<br/>+ vLLM Engine"]
    VeRLBackend -->|subprocess| VeRL["verl CLI<br/>+ Hydra Config"]

    %% GRPO reward integration
    ARTBackend -.->|evaluates| Rewards
    VeRLBackend -.->|evaluates| Rewards

    %% Styling
    style TrainingHub fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PublicAPI fill:#d5e8d4,stroke:#82b366
    style Core fill:#fff2cc,stroke:#d6b656
    style Algorithms fill:#dae8fc,stroke:#6c8ebf
    style Backends fill:#f8cecc,stroke:#b85450
    style Profiling fill:#e1d5e7,stroke:#9673a6
    style Utilities fill:#d5e8d4,stroke:#82b366

    style ILab fill:#f9f9f9,stroke:#999
    style MiniTrainer fill:#f9f9f9,stroke:#999
    style Unsloth fill:#f9f9f9,stroke:#999
    style ART fill:#f9f9f9,stroke:#999
    style VeRL fill:#f9f9f9,stroke:#999
