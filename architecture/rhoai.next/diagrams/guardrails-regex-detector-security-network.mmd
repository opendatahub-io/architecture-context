graph TB
    subgraph Internal["INTERNAL CLUSTER NETWORK (Network-Level Isolation)"]
        direction TB

        subgraph Caller["UPSTREAM CALLER"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Sends text inspection requests"]
        end

        subgraph Service["GUARDRAILS REGEX DETECTOR"]
            Detector["regex-detector<br/>ClusterIP Service<br/>0.0.0.0:8080<br/>UBI 9 minimal container"]
            EP1["POST /api/v1/text/contents<br/>8080/TCP HTTP No TLS"]
            EP2["GET /health<br/>8080/TCP HTTP No TLS"]
            Detector --- EP1
            Detector --- EP2
        end

        subgraph Probes["HEALTH PROBES"]
            Kubelet["Kubernetes Kubelet"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        None["None<br/>No outbound connections<br/>Pure computation service"]
    end

    %% Flows
    Orchestrator -->|"HTTP POST /api/v1/text/contents<br/>8080/TCP<br/>No TLS, No Auth<br/>Plaintext"| Detector
    Kubelet -->|"HTTP GET /health<br/>8080/TCP<br/>No TLS, No Auth"| Detector

    %% Styling
    classDef caller fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef probe fill:#f9f9f9,stroke:#999,stroke-width:1px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef endpoint fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class Orchestrator caller
    class Detector service
    class EP1,EP2 endpoint
    class Kubelet probe
    class None external
