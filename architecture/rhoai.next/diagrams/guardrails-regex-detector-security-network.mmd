graph TB
    subgraph ClusterNetwork["CLUSTER NETWORK (Internal Only)"]
        direction TB

        subgraph NS_Guardrails["Namespace: guardrails"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Role: Upstream Caller"]
            Detector["Regex Detector<br/>ClusterIP Service<br/>8080/TCP HTTP<br/>UBI 9 Minimal + Rust Binary<br/>No Auth / No TLS"]
            HealthProbe["Kubernetes<br/>Health Probes"]
        end
    end

    %% Flows
    Orchestrator -->|"POST /api/v1/text/contents<br/>HTTP/8080<br/>Plaintext<br/>No Auth"| Detector
    Detector -->|"HTTP Response<br/>Detection Results (JSON)"| Orchestrator
    HealthProbe -->|"GET /health<br/>HTTP/8080<br/>No Auth"| Detector

    %% No external ingress or egress
    NoIngress["No External<br/>Ingress"] -.-x Detector
    Detector -.-x NoEgress["No Outbound<br/>Connections"]

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef probe fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef blocked fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Orchestrator internal
    class Detector service
    class HealthProbe probe
    class NoIngress,NoEgress blocked
