graph TB
    subgraph ClusterNetwork["CLUSTER NETWORK (Internal Only — No External Ingress)"]
        direction TB

        subgraph PlatformNS["Namespace: platform namespace"]
            Orchestrator["FMS Guardrails Orchestrator<br/>(upstream caller)"]
            Detector["Guardrails Regex Detector<br/>ClusterIP: 8080/TCP<br/>HTTP plaintext<br/>No Auth<br/>UBI9 minimal + Rust binary"]
        end
    end

    subgraph SecurityNotes["SECURITY POSTURE"]
        direction LR
        Note1["No TLS (plaintext HTTP)<br/>No crypto libraries<br/>No secrets/credentials"]
        Note2["No RBAC (no K8s API access)<br/>No ServiceAccount requirements<br/>No ingress/egress policies in repo"]
        Note3["Network isolation assumed<br/>Platform operator provides:<br/>• Pod network policies<br/>• Service mesh mTLS<br/>• Authorization policies"]
    end

    %% Flows
    Orchestrator -->|"POST /api/v1/text/contents<br/>HTTP/8080 plaintext<br/>No Auth"| Detector
    Detector -->|"DetectionResponse JSON<br/>HTTP response"| Orchestrator

    %% No external egress
    NoEgress["No External Egress<br/>(zero outbound connections)"]

    Detector -.-|"none"| NoEgress

    %% Styling
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef orchestrator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secnote fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    classDef noegress fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Orchestrator orchestrator
    class Detector service
    class Note1,Note2,Note3 secnote
    class NoEgress noegress
