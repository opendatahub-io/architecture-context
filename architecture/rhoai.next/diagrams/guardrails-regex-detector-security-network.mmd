graph TB
    subgraph ClusterNetwork["INTERNAL CLUSTER NETWORK (Network Isolation)"]
        direction TB

        subgraph OrchestratorNS["Namespace: guardrails"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Routes text to detectors<br/>Merges detection results"]
        end

        subgraph DetectorNS["Namespace: guardrails"]
            Detector["Regex Detector Service<br/>ClusterIP 8080/TCP<br/>HTTP (plaintext)<br/>No Auth<br/>UBI9 minimal + Rust"]
        end
    end

    subgraph ExternalNetwork["EXTERNAL NETWORK"]
        NoExternal["No external connections<br/>No ingress / No egress"]
    end

    %% Flows
    Orchestrator -->|"HTTP/8080<br/>POST /api/v1/text/contents<br/>No TLS · No Auth<br/>Network isolation only"| Detector

    Detector -.->|"HTTP Response<br/>DetectionResponse JSON<br/>(offsets, type, score)"| Orchestrator

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef detector fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef noconn fill:#f9f9f9,stroke:#ccc,stroke-width:1px,stroke-dasharray: 5 5

    class Orchestrator internal
    class Detector detector
    class NoExternal noconn
