graph TB
    subgraph ClusterNetwork["INTERNAL CLUSTER NETWORK (No external exposure)"]
        direction TB

        subgraph OrchestratorZone["Orchestrator Namespace"]
            Orchestrator["FMS Guardrails Orchestrator<br/>Handles client auth & routing<br/>Dispatches to detector backends"]
        end

        subgraph DetectorZone["Detector Namespace"]
            Detector["Guardrails Regex Detector<br/>ClusterIP Service<br/>8080/TCP HTTP<br/>⚠ Plaintext only<br/>⚠ No auth<br/>⚠ Runs as root"]
        end

        subgraph K8sZone["Kubernetes Control Plane"]
            Kubelet["kubelet<br/>Health probes"]
        end
    end

    %% Flows
    Orchestrator -->|"POST /api/v1/text/contents<br/>8080/TCP HTTP<br/>Encryption: None<br/>Auth: None<br/>⚠ PII data in plaintext"| Detector

    Detector -->|"Response: Detection Results<br/>HTTP 200<br/>JSON [[...]]"| Orchestrator

    Kubelet -->|"GET /health<br/>8080/TCP HTTP<br/>Encryption: None<br/>Auth: None"| Detector

    %% No egress
    NoEgress["No Egress Traffic<br/>Service makes zero<br/>outbound connections"]

    %% Styling
    classDef detector fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef orchestrator fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef k8s fill:#e8e8e8,stroke:#999,stroke-width:1px
    classDef warning fill:#ff6b6b,stroke:#c0392b,stroke-width:2px,color:#fff
    classDef zone fill:#f9f9f9,stroke:#ccc,stroke-width:1px

    class Detector detector
    class Orchestrator orchestrator
    class Kubelet k8s
    class NoEgress warning
