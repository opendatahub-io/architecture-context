graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(install namespace)"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["argo-binding<br/>(ClusterRoleBinding)"]
        RB["argo-binding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["argo-cluster-role<br/>(ClusterRole)"]
        CR_Role["argo-role<br/>(Role - namespace-scoped)"]
    end

    subgraph AggregateRoles["Aggregate Roles"]
        CR_View["argo-aggregate-to-view"]
        CR_Edit["argo-aggregate-to-edit"]
        CR_Admin["argo-aggregate-to-admin"]
    end

    subgraph CoreAPI["Core API Resources ('')"]
        Pods["pods, pods/exec"]
        ConfigMaps["configmaps"]
        PVCs["persistentvolumeclaims<br/>(+ /finalizers)"]
        ServiceAccts["serviceaccounts"]
        Secrets_Restricted["secrets<br/>(resourceName: argo-workflows-<br/>agent-ca-certificates)"]
        Events["events"]
        Secrets_NS["secrets<br/>(namespace-scoped)"]
    end

    subgraph ArgoAPI["argoproj.io Resources"]
        Workflows["workflows<br/>(+ /finalizers)"]
        WorkflowTemplates["workflowtemplates<br/>(+ /finalizers)"]
        ClusterWFTemplates["clusterworkflowtemplates<br/>(+ /finalizers)"]
        CronWorkflows["cronworkflows<br/>(+ /finalizers)"]
        WFTaskSets["workflowtasksets<br/>(+ /finalizers)"]
        WFTaskResults["workflowtaskresults"]
        WFArtifactGCTasks["workflowartifactgctasks"]
        WFEventBindings["workfloweventbindings"]
    end

    subgraph CoordinationAPI["coordination.k8s.io"]
        Leases["leases"]
    end

    subgraph PolicyAPI["policy"]
        PDBs["poddisruptionbudgets"]
    end

    %% SA to Binding
    SA_Argo -->|bound via| CRB
    SA_Argo -->|bound via| RB

    %% Binding to Role
    CRB -->|grants| CR_Main
    RB -->|grants| CR_Role

    %% ClusterRole permissions - Core API
    CR_Main -->|"create, get, list, watch,<br/>update, patch, delete"| Pods
    CR_Main -->|"get, watch, list"| ConfigMaps
    CR_Main -->|"create, update, delete, get"| PVCs
    CR_Main -->|"get, list"| ServiceAccts
    CR_Main -->|"get (restricted)"| Secrets_Restricted
    CR_Main -->|"create, patch"| Events

    %% ClusterRole permissions - argoproj.io
    CR_Main -->|"full CRUD"| Workflows
    CR_Main -->|"get, list, watch"| WorkflowTemplates
    CR_Main -->|"get, list, watch"| ClusterWFTemplates
    CR_Main -->|"get, list, watch,<br/>update, patch, delete"| CronWorkflows
    CR_Main -->|"full CRUD"| WFTaskSets
    CR_Main -->|"list, watch,<br/>deletecollection"| WFTaskResults
    CR_Main -->|"full CRUD"| WFArtifactGCTasks

    %% ClusterRole permissions - policy
    CR_Main -->|"create, get, delete"| PDBs

    %% Namespace Role permissions
    CR_Role -->|"create, get, update"| Leases
    CR_Role -->|"get"| Secrets_NS

    %% Aggregate Roles
    CR_View -->|"get, list, watch"| Workflows
    CR_View -->|"get, list, watch"| WorkflowTemplates
    CR_View -->|"get, list, watch"| CronWorkflows
    CR_View -->|"get, list, watch"| WFEventBindings

    CR_Edit -->|"full CRUD"| Workflows
    CR_Edit -->|"full CRUD"| WorkflowTemplates
    CR_Edit -->|"full CRUD"| CronWorkflows
    CR_Edit -->|"full CRUD"| WFEventBindings

    CR_Admin -->|"full CRUD<br/>(+ tasksets)"| Workflows
    CR_Admin -->|"full CRUD"| WFTaskSets
    CR_Admin -->|"full CRUD"| WFTaskResults

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style RB fill:#9b59b6,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style CR_Role fill:#f5a623,stroke:#333
    style CR_View fill:#e8d44d,stroke:#333
    style CR_Edit fill:#e8d44d,stroke:#333
    style CR_Admin fill:#e8d44d,stroke:#333
    style Workflows fill:#7ed321,stroke:#333
    style WorkflowTemplates fill:#7ed321,stroke:#333
    style ClusterWFTemplates fill:#7ed321,stroke:#333
    style CronWorkflows fill:#7ed321,stroke:#333
    style WFTaskSets fill:#7ed321,stroke:#333
    style WFTaskResults fill:#7ed321,stroke:#333
    style WFArtifactGCTasks fill:#7ed321,stroke:#333
    style WFEventBindings fill:#7ed321,stroke:#333
    style Pods fill:#ddd,stroke:#333
    style ConfigMaps fill:#ddd,stroke:#333
    style PVCs fill:#ddd,stroke:#333
    style ServiceAccts fill:#ddd,stroke:#333
    style Secrets_Restricted fill:#ddd,stroke:#333
    style Events fill:#ddd,stroke:#333
    style Secrets_NS fill:#ddd,stroke:#333
    style Leases fill:#ddd,stroke:#333
    style PDBs fill:#ddd,stroke:#333
