graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(upstream only, not in RHOAI)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>Namespace: argo"]
        CRB_Server["argo-server-binding<br/>Namespace: argo"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/>(upstream only)"]
    end

    subgraph CoreAPI["Core API Resources ('')"]
        Pods["pods, pods/exec"]
        ConfigMaps["configmaps"]
        PVCs["persistentvolumeclaims<br/>persistentvolumeclaims/finalizers"]
        ServiceAccounts["serviceaccounts"]
        Events["events"]
        Secrets_Res["secrets<br/>(only: argo-workflows-agent-ca-certificates)"]
        PodsLog["pods/log"]
        Secrets_Full["secrets<br/>(get, create)"]
    end

    subgraph ArgoAPI["argoproj.io API Resources"]
        Workflows["workflows<br/>workflows/finalizers"]
        WFTaskSets["workflowtasksets<br/>workflowtasksets/finalizers"]
        WFArtifactGC["workflowartifactgctasks"]
        WFTemplates["workflowtemplates<br/>workflowtemplates/finalizers"]
        ClusterWFT["clusterworkflowtemplates<br/>clusterworkflowtemplates/finalizers"]
        WFTaskResults["workflowtaskresults"]
        CronWFs["cronworkflows<br/>cronworkflows/finalizers"]
        EventSources["eventsources, sensors"]
        WFEventBindings["workfloweventbindings"]
    end

    subgraph PolicyAPI["policy API Resources"]
        PDBs["poddisruptionbudgets"]
    end

    %% argo-cluster-role bindings
    SA_Argo -->|bound via| CRB_Argo
    CRB_Argo -->|grants| CR_Argo

    CR_Argo -->|"create, get, list, watch,<br/>update, patch, delete"| Pods
    CR_Argo -->|"get, watch, list"| ConfigMaps
    CR_Argo -->|"create, update,<br/>delete, get"| PVCs
    CR_Argo -->|"get, list"| ServiceAccounts
    CR_Argo -->|"create, patch"| Events
    CR_Argo -->|"get<br/>(resourceName restricted)"| Secrets_Res
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| Workflows
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| WFTaskSets
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| WFArtifactGC
    CR_Argo -->|"get, list, watch"| WFTemplates
    CR_Argo -->|"get, list, watch"| ClusterWFT
    CR_Argo -->|"list, watch,<br/>deletecollection"| WFTaskResults
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete"| CronWFs
    CR_Argo -->|"create, get, delete"| PDBs

    %% argo-server-cluster-role bindings (upstream only)
    SA_Server -->|bound via| CRB_Server
    CRB_Server -->|grants| CR_Server

    CR_Server -->|"get, watch, list"| ConfigMaps
    CR_Server -->|"get, create"| Secrets_Full
    CR_Server -->|"get, list, watch, delete"| Pods
    CR_Server -->|"get, list, watch, delete"| PodsLog
    CR_Server -->|"watch, create, patch"| Events
    CR_Server -->|"get, list, watch"| ServiceAccounts
    CR_Server -->|"CRUD + watch"| EventSources
    CR_Server -->|"CRUD + watch"| Workflows
    CR_Server -->|"CRUD + watch"| WFEventBindings
    CR_Server -->|"CRUD + watch"| WFTemplates
    CR_Server -->|"CRUD + watch"| CronWFs
    CR_Server -->|"CRUD + watch"| ClusterWFT

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#4a90e2,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style CRB_Argo fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Server fill:#9b59b6,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style CR_Argo fill:#f5a623,stroke:#333,color:#fff
    style CR_Server fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style PVCs fill:#7ed321,stroke:#333,color:#fff
    style ServiceAccounts fill:#7ed321,stroke:#333,color:#fff
    style Events fill:#7ed321,stroke:#333,color:#fff
    style Secrets_Res fill:#e74c3c,stroke:#333,color:#fff
    style Secrets_Full fill:#e74c3c,stroke:#333,color:#fff
    style PodsLog fill:#7ed321,stroke:#333,color:#fff
    style Workflows fill:#3498db,stroke:#333,color:#fff
    style WFTaskSets fill:#3498db,stroke:#333,color:#fff
    style WFArtifactGC fill:#3498db,stroke:#333,color:#fff
    style WFTemplates fill:#3498db,stroke:#333,color:#fff
    style ClusterWFT fill:#3498db,stroke:#333,color:#fff
    style WFTaskResults fill:#3498db,stroke:#333,color:#fff
    style CronWFs fill:#3498db,stroke:#333,color:#fff
    style EventSources fill:#3498db,stroke:#333,color:#fff
    style WFEventBindings fill:#3498db,stroke:#333,color:#fff
    style PDBs fill:#95a5a6,stroke:#333,color:#fff
