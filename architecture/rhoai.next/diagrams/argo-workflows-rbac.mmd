graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["SA: argo<br/>(workflow-controller)"]
        SA_ArgoServer["SA: argo-server<br/>(Not shipped in RHOAI)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>Namespace: argo"]
        CRB_Server["argo-server-binding<br/>Namespace: argo"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role"]
    end

    subgraph AggregateRoles["Aggregate Roles"]
        CR_View["argo-aggregate-to-view"]
        CR_Edit["argo-aggregate-to-edit"]
        CR_Admin["argo-aggregate-to-admin"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/exec"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims<br/>+ finalizers"]
        SAs["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Secrets["core<br/>secrets<br/>(resourceName: argo-workflows-<br/>agent-ca-certificates)"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph ArgoResources["Argo CRD Resources (argoproj.io)"]
        WF["workflows<br/>+ finalizers"]
        WFTaskSets["workflowtasksets<br/>+ finalizers"]
        WFArtifactGC["workflowartifact<br/>gctasks"]
        WFTemplates["workflowtemplates<br/>+ finalizers"]
        ClusterWFT["clusterworkflow<br/>templates + finalizers"]
        WFTaskResults["workflowtaskresults"]
        CronWF["cronworkflows<br/>+ finalizers"]
        WFEventBindings["workflowevent<br/>bindings"]
    end

    subgraph ServerResources["Argo Server Resources (Not in RHOAI)"]
        EventSources["eventsources"]
        Sensors["sensors"]
        PodsLog["pods/log"]
    end

    %% Controller bindings
    SA_Argo -->|"bound via"| CRB_Argo
    CRB_Argo -->|"grants"| CR_Argo

    %% Controller permissions - Core
    CR_Argo -->|"create,get,list,watch,<br/>update,patch,delete"| Pods
    CR_Argo -->|"get,watch,list"| ConfigMaps
    CR_Argo -->|"create,update,<br/>delete,get"| PVCs
    CR_Argo -->|"get,list"| SAs
    CR_Argo -->|"create,patch"| Events
    CR_Argo -->|"get"| Secrets
    CR_Argo -->|"create,get,delete"| PDBs

    %% Controller permissions - Argo CRDs
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| WF
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| WFTaskSets
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| WFArtifactGC
    CR_Argo -->|"get,list,watch"| WFTemplates
    CR_Argo -->|"get,list,watch"| ClusterWFT
    CR_Argo -->|"list,watch,<br/>deletecollection"| WFTaskResults
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete"| CronWF

    %% Server bindings (not shipped)
    SA_ArgoServer -->|"bound via"| CRB_Server
    CRB_Server -->|"grants"| CR_Server
    CR_Server -->|"full CRUD"| ServerResources

    %% Aggregate roles
    CR_View -->|"get,list,watch"| ArgoResources
    CR_Edit -->|"full CRUD"| ArgoResources
    CR_Admin -->|"full CRUD +<br/>TaskSets/TaskResults"| ArgoResources

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_ArgoServer fill:#cccccc,stroke:#999,stroke-dasharray: 5 5
    style CRB_Argo fill:#b8d4f0,stroke:#333
    style CRB_Server fill:#e0e0e0,stroke:#999,stroke-dasharray: 5 5
    style CR_Argo fill:#f5a623,stroke:#333
    style CR_Server fill:#e0e0e0,stroke:#999,stroke-dasharray: 5 5
    style CR_View fill:#7ed321,stroke:#333,color:#fff
    style CR_Edit fill:#f5a623,stroke:#333
    style CR_Admin fill:#e74c3c,stroke:#333,color:#fff
    style Pods fill:#d5e8d4,stroke:#82b366
    style ConfigMaps fill:#d5e8d4,stroke:#82b366
    style PVCs fill:#d5e8d4,stroke:#82b366
    style SAs fill:#d5e8d4,stroke:#82b366
    style Events fill:#d5e8d4,stroke:#82b366
    style Secrets fill:#d5e8d4,stroke:#82b366
    style PDBs fill:#d5e8d4,stroke:#82b366
    style WF fill:#f5d623,stroke:#333
    style WFTaskSets fill:#f5d623,stroke:#333
    style WFArtifactGC fill:#f5d623,stroke:#333
    style WFTemplates fill:#f5d623,stroke:#333
    style ClusterWFT fill:#f5d623,stroke:#333
    style WFTaskResults fill:#f5d623,stroke:#333
    style CronWF fill:#f5d623,stroke:#333
    style WFEventBindings fill:#f5d623,stroke:#333
    style EventSources fill:#e0e0e0,stroke:#999
    style Sensors fill:#e0e0e0,stroke:#999
    style PodsLog fill:#e0e0e0,stroke:#999
