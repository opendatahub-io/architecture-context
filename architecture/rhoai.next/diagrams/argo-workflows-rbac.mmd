graph TD
    subgraph "Service Accounts"
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(upstream only)"]
    end

    subgraph "ClusterRoleBindings"
        CRB_Argo["argo-binding<br/>(ClusterRoleBinding)<br/>cluster-wide"]
        CRB_Server["argo-server-binding<br/>(ClusterRoleBinding)<br/>cluster-wide"]
    end

    subgraph "RoleBindings"
        RB_Argo["argo-binding<br/>(RoleBinding)<br/>installation namespace"]
    end

    subgraph "ClusterRole: argo-cluster-role"
        direction TB
        CR_Core["Core API Resources"]
        CR_Argo["Argo CRD Resources"]
        CR_Policy["Policy Resources"]
    end

    subgraph "ClusterRole: argo-server-cluster-role"
        direction TB
        CSR_Core["Core API Resources"]
        CSR_Argo["Argo CRD Resources"]
    end

    subgraph "Namespace Role: argo-role"
        NR_Resources["Namespace Resources"]
    end

    subgraph "Core API Resources (argo-cluster-role)"
        Pods["pods, pods/exec<br/>create, get, list, watch,<br/>update, patch, delete"]
        ConfigMaps["configmaps<br/>get, watch, list"]
        PVCs["persistentvolumeclaims<br/>persistentvolumeclaims/finalizers<br/>create, update, delete, get"]
        ServiceAccounts["serviceaccounts<br/>get, list"]
        Events["events<br/>create, patch"]
        Secrets_Restricted["secrets<br/>get<br/>(ONLY: argo-workflows-<br/>agent-ca-certificates)"]
    end

    subgraph "Argo CRD Resources (argo-cluster-role)"
        Workflows["workflows, workflows/finalizers<br/>workflowtasksets, workflowtasksets/finalizers<br/>workflowartifactgctasks<br/>get, list, watch, update,<br/>patch, delete, create"]
        Templates["workflowtemplates, workflowtemplates/finalizers<br/>clusterworkflowtemplates,<br/>clusterworkflowtemplates/finalizers<br/>get, list, watch"]
        TaskResults["workflowtaskresults<br/>list, watch, deletecollection"]
        CronWorkflows["cronworkflows, cronworkflows/finalizers<br/>get, list, watch, update,<br/>patch, delete"]
    end

    subgraph "Policy Resources (argo-cluster-role)"
        PDBs["poddisruptionbudgets<br/>create, get, delete"]
    end

    subgraph "Namespace Resources (argo-role)"
        Leases["coordination.k8s.io leases<br/>create, get, update<br/>(leader election)"]
        NS_Secrets["secrets<br/>get"]
    end

    %% Bindings
    SA_Argo -->|bound via| CRB_Argo
    SA_Argo -->|bound via| RB_Argo
    SA_Server -->|bound via| CRB_Server

    CRB_Argo -->|grants| CR_Core
    CRB_Argo -->|grants| CR_Argo
    CRB_Argo -->|grants| CR_Policy

    CRB_Server -->|grants| CSR_Core
    CRB_Server -->|grants| CSR_Argo

    RB_Argo -->|grants| NR_Resources

    CR_Core --- Pods
    CR_Core --- ConfigMaps
    CR_Core --- PVCs
    CR_Core --- ServiceAccounts
    CR_Core --- Events
    CR_Core --- Secrets_Restricted

    CR_Argo --- Workflows
    CR_Argo --- Templates
    CR_Argo --- TaskResults
    CR_Argo --- CronWorkflows

    CR_Policy --- PDBs

    NR_Resources --- Leases
    NR_Resources --- NS_Secrets

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#999,stroke:#333,color:#fff
    style CRB_Argo fill:#f5a623,stroke:#333
    style CRB_Server fill:#999,stroke:#333,color:#fff
    style RB_Argo fill:#f5a623,stroke:#333
    style CR_Core fill:#d5e8d4,stroke:#82b366
    style CR_Argo fill:#d5e8d4,stroke:#82b366
    style CR_Policy fill:#d5e8d4,stroke:#82b366
    style CSR_Core fill:#e8e8e8,stroke:#333
    style CSR_Argo fill:#e8e8e8,stroke:#333
    style NR_Resources fill:#dae8fc,stroke:#6c8ebf
    style Secrets_Restricted fill:#ffcccc,stroke:#cc0000
    style Pods fill:#7ed321,stroke:#333
    style Workflows fill:#7ed321,stroke:#333
    style Templates fill:#7ed321,stroke:#333
    style TaskResults fill:#7ed321,stroke:#333
    style CronWorkflows fill:#7ed321,stroke:#333
    style PDBs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style ServiceAccounts fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style Leases fill:#b3cde3,stroke:#333
    style NS_Secrets fill:#b3cde3,stroke:#333
