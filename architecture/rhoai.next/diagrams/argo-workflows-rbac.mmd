graph TD
    subgraph "Service Accounts"
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(upstream only)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Argo["argo-binding<br/>ClusterRoleBinding<br/>Namespace: argo"]
        CRB_Server["argo-server-binding<br/>ClusterRoleBinding<br/>Namespace: argo"]
    end

    subgraph "ClusterRoles"
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/>(upstream only)"]
    end

    subgraph "Core API Resources"
        Pods["core<br/>pods, pods/exec"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims<br/>+ finalizers"]
        ServiceAccounts["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Secrets["core<br/>secrets<br/>⚠ resourceName:<br/>argo-workflows-agent-<br/>ca-certificates"]
    end

    subgraph "Argo CRD Resources (argoproj.io)"
        Workflows["argoproj.io<br/>workflows<br/>+ finalizers"]
        WFTaskSets["argoproj.io<br/>workflowtasksets<br/>+ finalizers"]
        WFArtGCTasks["argoproj.io<br/>workflowartifactgctasks"]
        WFTemplates["argoproj.io<br/>workflowtemplates<br/>+ finalizers"]
        ClusterWFTemplates["argoproj.io<br/>clusterworkflowtemplates<br/>+ finalizers"]
        WFTaskResults["argoproj.io<br/>workflowtaskresults"]
        CronWorkflows["argoproj.io<br/>cronworkflows<br/>+ finalizers"]
    end

    subgraph "Policy Resources"
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    %% argo-cluster-role bindings
    SA_Argo -->|bound via| CRB_Argo
    CRB_Argo -->|grants| CR_Argo

    %% argo-cluster-role permissions
    CR_Argo -->|"create,get,list,watch,<br/>update,patch,delete"| Pods
    CR_Argo -->|"get,watch,list"| ConfigMaps
    CR_Argo -->|"create,update,<br/>delete,get"| PVCs
    CR_Argo -->|"get,list"| ServiceAccounts
    CR_Argo -->|"create,patch"| Events
    CR_Argo -->|"get (restricted)"| Secrets
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| Workflows
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| WFTaskSets
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete,create"| WFArtGCTasks
    CR_Argo -->|"get,list,watch"| WFTemplates
    CR_Argo -->|"get,list,watch"| ClusterWFTemplates
    CR_Argo -->|"list,watch,<br/>deletecollection"| WFTaskResults
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete"| CronWorkflows
    CR_Argo -->|"create,get,delete"| PDBs

    %% argo-server-cluster-role bindings
    SA_Server -->|bound via| CRB_Server
    CRB_Server -->|grants| CR_Server

    %% argo-server permissions (upstream only)
    CR_Server -->|"get,list,watch,delete"| Pods
    CR_Server -->|"get,watch,list"| ConfigMaps
    CR_Server -->|"get,create"| Secrets
    CR_Server -->|"watch,create,patch"| Events
    CR_Server -->|"get,list,watch"| ServiceAccounts

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#999,stroke:#333,color:#fff
    style CRB_Argo fill:#b8d4e3,stroke:#333
    style CRB_Server fill:#ccc,stroke:#333
    style CR_Argo fill:#f5a623,stroke:#333,color:#fff
    style CR_Server fill:#ccc,stroke:#333
    style Workflows fill:#7ed321,stroke:#333,color:#fff
    style WFTaskSets fill:#7ed321,stroke:#333,color:#fff
    style WFArtGCTasks fill:#7ed321,stroke:#333,color:#fff
    style WFTemplates fill:#7ed321,stroke:#333,color:#fff
    style ClusterWFTemplates fill:#7ed321,stroke:#333,color:#fff
    style WFTaskResults fill:#7ed321,stroke:#333,color:#fff
    style CronWorkflows fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#d4edda,stroke:#333
    style ConfigMaps fill:#d4edda,stroke:#333
    style PVCs fill:#d4edda,stroke:#333
    style ServiceAccounts fill:#d4edda,stroke:#333
    style Events fill:#d4edda,stroke:#333
    style Secrets fill:#fff3cd,stroke:#333
    style PDBs fill:#d4edda,stroke:#333
