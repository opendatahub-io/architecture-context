graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(namespace: argo)"]
        SA_Server["argo-server<br/>(namespace: argo)<br/><i>upstream only</i>"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>(ClusterRoleBinding)"]
        CRB_Server["argo-server-binding<br/>(ClusterRoleBinding)<br/><i>upstream only</i>"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/><i>upstream only</i>"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        Pods["pods, pods/exec"]
        ConfigMaps["configmaps"]
        PVCs["persistentvolumeclaims<br/>+ finalizers"]
        ServiceAccs["serviceaccounts"]
        Events["events"]
        Secrets["secrets<br/><i>restricted: agent-ca-certs</i>"]
    end

    subgraph ArgoResources["Argo API Resources (argoproj.io)"]
        Workflows["workflows<br/>+ finalizers"]
        TaskSets["workflowtasksets<br/>+ finalizers"]
        GCTasks["workflowartifactgctasks"]
        TaskResults["workflowtaskresults"]
        WFTemplates["workflowtemplates<br/>+ finalizers"]
        CWFTemplates["clusterworkflowtemplates<br/>+ finalizers"]
        CronWFs["cronworkflows<br/>+ finalizers"]
    end

    subgraph PolicyResources["Policy API Resources"]
        PDBs["poddisruptionbudgets"]
    end

    subgraph ServerOnlyResources["Server-Only Resources (upstream)"]
        EventSources["eventsources"]
        Sensors["sensors"]
        EventBindings["workfloweventbindings"]
        PodsLog["pods/log"]
        ServerSecrets["secrets<br/><i>unrestricted</i>"]
    end

    %% Bindings
    SA_Argo -->|bound via| CRB_Argo
    SA_Server -->|bound via| CRB_Server
    CRB_Argo -->|grants| CR_Argo
    CRB_Server -->|grants| CR_Server

    %% argo-cluster-role permissions
    CR_Argo -->|"create, get, list, watch,<br/>update, patch, delete"| Pods
    CR_Argo -->|"get, watch, list"| ConfigMaps
    CR_Argo -->|"create, update, delete, get"| PVCs
    CR_Argo -->|"get, list"| ServiceAccs
    CR_Argo -->|"create, patch"| Events
    CR_Argo -->|"get (resourceNames:<br/>argo-workflows-agent-ca-certificates)"| Secrets
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| Workflows
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| TaskSets
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete, create"| GCTasks
    CR_Argo -->|"list, watch, deletecollection"| TaskResults
    CR_Argo -->|"get, list, watch"| WFTemplates
    CR_Argo -->|"get, list, watch"| CWFTemplates
    CR_Argo -->|"get, list, watch, update,<br/>patch, delete"| CronWFs
    CR_Argo -->|"create, get, delete"| PDBs

    %% argo-server-cluster-role permissions (upstream only)
    CR_Server -.->|"create, get, list, watch,<br/>update, patch, delete"| EventSources
    CR_Server -.->|"create, get, list, watch,<br/>update, patch, delete"| Sensors
    CR_Server -.->|"create, get, list, watch,<br/>update, patch, delete"| EventBindings
    CR_Server -.->|"get, list, watch, delete"| PodsLog
    CR_Server -.->|"get, create"| ServerSecrets

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#4a90e2,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style CRB_Argo fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Server fill:#9b59b6,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style CR_Argo fill:#f5a623,stroke:#333,color:#fff
    style CR_Server fill:#f5a623,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style PVCs fill:#7ed321,stroke:#333,color:#fff
    style ServiceAccs fill:#7ed321,stroke:#333,color:#fff
    style Events fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#e74c3c,stroke:#333,color:#fff
    style Workflows fill:#2ecc71,stroke:#333,color:#fff
    style TaskSets fill:#2ecc71,stroke:#333,color:#fff
    style GCTasks fill:#2ecc71,stroke:#333,color:#fff
    style TaskResults fill:#2ecc71,stroke:#333,color:#fff
    style WFTemplates fill:#2ecc71,stroke:#333,color:#fff
    style CWFTemplates fill:#2ecc71,stroke:#333,color:#fff
    style CronWFs fill:#2ecc71,stroke:#333,color:#fff
    style PDBs fill:#3498db,stroke:#333,color:#fff
    style EventSources fill:#95a5a6,stroke:#333,color:#fff
    style Sensors fill:#95a5a6,stroke:#333,color:#fff
    style EventBindings fill:#95a5a6,stroke:#333,color:#fff
    style PodsLog fill:#95a5a6,stroke:#333,color:#fff
    style ServerSecrets fill:#95a5a6,stroke:#333,color:#fff
