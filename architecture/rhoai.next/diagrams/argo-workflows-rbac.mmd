graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(API server)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-cluster-role<br/>(ClusterRoleBinding)"]
        CRB_Server["argo-server-cluster-role<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles"]
        CR_View["argo-aggregate-to-view<br/>(read-only)"]
        CR_Edit["argo-aggregate-to-edit<br/>(read-write)"]
        CR_Admin["argo-aggregate-to-admin<br/>(full access)"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/exec"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims"]
        SvcAccts["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Secrets["core<br/>secrets"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph ArgoResources["argoproj.io Resources"]
        Workflows["argoproj.io<br/>workflows"]
        WFTemplates["argoproj.io<br/>workflowtemplates"]
        ClusterWFT["argoproj.io<br/>clusterworkflowtemplates"]
        CronWF["argoproj.io<br/>cronworkflows"]
        TaskSets["argoproj.io<br/>workflowtasksets"]
        TaskResults["argoproj.io<br/>workflowtaskresults"]
        ArtifactGC["argoproj.io<br/>workflowartifactgctasks"]
        EventBindings["argoproj.io<br/>workfloweventbindings"]
        EventSources["argoproj.io<br/>eventsources"]
        Sensors["argoproj.io<br/>sensors"]
    end

    subgraph ServerResources["Server-Specific Resources"]
        PodsLog["core<br/>pods/log"]
    end

    %% Service Account → ClusterRoleBinding
    SA_Argo -->|"bound via"| CRB_Argo
    SA_Server -->|"bound via"| CRB_Server

    %% ClusterRoleBinding → ClusterRole
    CRB_Argo -->|"grants"| CR_Argo
    CRB_Server -->|"grants"| CR_Server

    %% argo-cluster-role permissions
    CR_Argo -->|"create,get,list,watch,<br/>update,patch,delete"| Pods
    CR_Argo -->|"get,watch,list"| ConfigMaps
    CR_Argo -->|"create,update,<br/>delete,get"| PVCs
    CR_Argo -->|"get,list"| SvcAccts
    CR_Argo -->|"create,patch"| Events
    CR_Argo -->|"get (named)"| Secrets
    CR_Argo -->|"create,get,delete"| PDBs
    CR_Argo -->|"get,list,watch,create,<br/>update,patch,delete"| Workflows
    CR_Argo -->|"get,list,watch"| WFTemplates
    CR_Argo -->|"get,list,watch"| ClusterWFT
    CR_Argo -->|"get,list,watch,update,<br/>patch,delete"| CronWF
    CR_Argo -->|"get,list,watch,create,<br/>update,patch,delete"| TaskSets
    CR_Argo -->|"list,watch,<br/>deletecollection"| TaskResults
    CR_Argo -->|"get,list,watch,create,<br/>update,patch,delete"| ArtifactGC

    %% argo-server-cluster-role permissions
    CR_Server -->|"get,watch,list"| ConfigMaps
    CR_Server -->|"get,create"| Secrets
    CR_Server -->|"get,list,watch,delete"| Pods
    CR_Server -->|"get,list,watch,delete"| PodsLog
    CR_Server -->|"watch,create,patch"| Events
    CR_Server -->|"get,list,watch"| SvcAccts
    CR_Server -->|"create,get,list,watch,<br/>update,patch,delete"| Workflows
    CR_Server -->|"CRUD"| EventBindings
    CR_Server -->|"CRUD"| EventSources
    CR_Server -->|"CRUD"| Sensors
    CR_Server -->|"CRUD"| WFTemplates
    CR_Server -->|"CRUD"| CronWF
    CR_Server -->|"CRUD"| ClusterWFT

    %% Aggregate roles
    CR_View -.->|"get,list,watch"| Workflows
    CR_View -.->|"get,list,watch"| WFTemplates
    CR_View -.->|"get,list,watch"| CronWF
    CR_View -.->|"get,list,watch"| ClusterWFT
    CR_Edit -.->|"extends view +<br/>create,delete,patch,update"| Workflows
    CR_Admin -.->|"extends edit +<br/>workflowtasksets"| TaskSets

    %% Styling
    style SA_Argo fill:#4a90e2,color:#fff
    style SA_Server fill:#4a90e2,color:#fff
    style CRB_Argo fill:#b4a7d6,color:#000
    style CRB_Server fill:#b4a7d6,color:#000
    style CR_Argo fill:#f5a623,color:#fff
    style CR_Server fill:#f5a623,color:#fff
    style CR_View fill:#d5e8d4,color:#000
    style CR_Edit fill:#fff2cc,color:#000
    style CR_Admin fill:#f8cecc,color:#000
    style Workflows fill:#7ed321,color:#fff
    style WFTemplates fill:#7ed321,color:#fff
    style ClusterWFT fill:#7ed321,color:#fff
    style CronWF fill:#7ed321,color:#fff
    style TaskSets fill:#7ed321,color:#fff
    style TaskResults fill:#7ed321,color:#fff
    style ArtifactGC fill:#7ed321,color:#fff
    style EventBindings fill:#7ed321,color:#fff
    style EventSources fill:#7ed321,color:#fff
    style Sensors fill:#7ed321,color:#fff
