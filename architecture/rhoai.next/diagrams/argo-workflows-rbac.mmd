graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo["argo<br/>(workflow-controller)"]
        SA_Server["argo-server<br/>(upstream only)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Argo["argo-binding<br/>(ClusterRoleBinding)"]
        CRB_Server["argo-server-binding<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Argo["argo-binding<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Argo["argo-cluster-role"]
        CR_Server["argo-server-cluster-role<br/>(upstream only)"]
    end

    subgraph NamespaceRoles["Namespace Roles"]
        R_Argo["argo-role"]
    end

    subgraph ArgoClusterRoleResources["argo-cluster-role Resources"]
        Pods["core: pods, pods/exec<br/>create, get, list, watch,<br/>update, patch, delete"]
        ConfigMaps["core: configmaps<br/>get, watch, list"]
        PVCs["core: persistentvolumeclaims<br/>+ finalizers<br/>create, update, delete, get"]
        ServiceAccs["core: serviceaccounts<br/>get, list"]
        Events["core: events<br/>create, patch"]
        Secrets_Restricted["core: secrets<br/>get (argo-workflows-agent-<br/>ca-certificates ONLY)"]
        Workflows["argoproj.io: workflows,<br/>workflows/finalizers,<br/>workflowtasksets + finalizers,<br/>workflowartifactgctasks<br/>full CRUD"]
        Templates["argoproj.io: workflowtemplates,<br/>clusterworkflowtemplates<br/>+ finalizers<br/>get, list, watch"]
        TaskResults["argoproj.io: workflowtaskresults<br/>list, watch, deletecollection"]
        CronWFs["argoproj.io: cronworkflows<br/>+ finalizers<br/>get, list, watch, update,<br/>patch, delete"]
        PDBs["policy: poddisruptionbudgets<br/>create, get, delete"]
    end

    subgraph ArgoRoleResources["argo-role Resources (namespace)"]
        Leases["coordination.k8s.io: leases<br/>create, get, update"]
        SecretsNS["core: secrets<br/>get"]
    end

    %% Service Account → Bindings
    SA_Argo -->|bound via| CRB_Argo
    SA_Argo -->|bound via| RB_Argo
    SA_Server -->|bound via| CRB_Server

    %% Bindings → Roles
    CRB_Argo -->|grants| CR_Argo
    RB_Argo -->|grants| R_Argo
    CRB_Server -->|grants| CR_Server

    %% Cluster Role → Resources
    CR_Argo -->|"full CRUD"| Pods
    CR_Argo -->|"read"| ConfigMaps
    CR_Argo -->|"manage"| PVCs
    CR_Argo -->|"read"| ServiceAccs
    CR_Argo -->|"create"| Events
    CR_Argo -->|"get (restricted)"| Secrets_Restricted
    CR_Argo -->|"full CRUD"| Workflows
    CR_Argo -->|"read-only"| Templates
    CR_Argo -->|"list, cleanup"| TaskResults
    CR_Argo -->|"manage"| CronWFs
    CR_Argo -->|"manage"| PDBs

    %% Namespace Role → Resources
    R_Argo -->|"manage"| Leases
    R_Argo -->|"read"| SecretsNS

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#999,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333
    style CR_Server fill:#999,stroke:#333,color:#fff
    style R_Argo fill:#f5a623,stroke:#333
    style CRB_Argo fill:#dae8fc,stroke:#6c8ebf
    style CRB_Server fill:#e8e8e8,stroke:#999
    style RB_Argo fill:#dae8fc,stroke:#6c8ebf
    style Workflows fill:#7ed321,stroke:#333
    style CronWFs fill:#7ed321,stroke:#333
    style Templates fill:#7ed321,stroke:#333
    style TaskResults fill:#7ed321,stroke:#333
    style Pods fill:#d5e8d4,stroke:#82b366
    style Secrets_Restricted fill:#f8cecc,stroke:#b85450
    style Leases fill:#d5e8d4,stroke:#82b366
