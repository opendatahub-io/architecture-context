graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(ClusterRoleBinding, cluster-wide)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB

        subgraph CoreAPI["API Group: core (\"\")"]
            ConfigMaps["configmaps, secrets<br/>create, get, list, patch, update, watch"]
            Events["events<br/>create, patch, update, watch"]
            LimitRanges["limitranges<br/>get, list, watch"]
            Pods["pods (RHOAI only)<br/>get, list"]
        end

        subgraph AdmissionAPI["API Group: admissionregistration.k8s.io"]
            Webhooks["validatingwebhookconfigurations<br/>get, list, update, watch"]
        end

        subgraph CoordinationAPI["API Group: coordination.k8s.io"]
            Leases["leases<br/>create, get, list, update"]
        end

        subgraph JobSetAPI["API Group: jobset.x-k8s.io"]
            JobSets["jobsets<br/>create, get, list, patch, update, watch"]
        end

        subgraph NetworkingAPI["API Group: networking.k8s.io"]
            NetPolicies["networkpolicies (RHOAI only)<br/>get, list, watch, create, update, patch"]
        end

        subgraph NodeAPI["API Group: node.k8s.io"]
            RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        end

        subgraph SchedulingAPI["API Groups: scheduling.volcano.sh,<br/>scheduling.x-k8s.io"]
            PodGroups["podgroups<br/>create, get, list, patch, update, watch"]
        end

        subgraph TrainerAPI["API Group: trainer.kubeflow.org"]
            TrainerResources["clustertrainingruntimes,<br/>trainingruntimes, trainjobs<br/>get, list, patch, update, watch"]
            TrainerSubresources["*/finalizers, trainjobs/status<br/>get, patch, update"]
        end
    end

    subgraph UserRoles["User-Facing Roles"]
        direction TB

        subgraph AdminRole["ClusterRole: training-admin"]
            AdminPerms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph EditRole["ClusterRole: training-edit"]
            EditTrainJobs["trainjobs<br/>create, delete, get, list,<br/>patch, update, watch"]
            EditRuntimes["trainingruntimes,<br/>clustertrainingruntimes<br/>get, list, watch"]
        end

        subgraph ViewRole["ClusterRole: training-view"]
            ViewPerms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>get, list, watch"]
        end
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| ControllerRole

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#74b9ff,color:#333

    style ConfigMaps fill:#7ed321,color:#333
    style Events fill:#7ed321,color:#333
    style LimitRanges fill:#7ed321,color:#333
    style Pods fill:#e17055,color:#fff
    style Webhooks fill:#7ed321,color:#333
    style Leases fill:#7ed321,color:#333
    style JobSets fill:#7ed321,color:#333
    style NetPolicies fill:#e17055,color:#fff
    style RuntimeClasses fill:#7ed321,color:#333
    style PodGroups fill:#7ed321,color:#333
    style TrainerResources fill:#f5a623,color:#333
    style TrainerSubresources fill:#f5a623,color:#333

    style AdminPerms fill:#fdcb6e,color:#333
    style EditTrainJobs fill:#fdcb6e,color:#333
    style EditRuntimes fill:#dfe6e9,color:#333
    style ViewPerms fill:#dfe6e9,color:#333
