graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["kubeflow-trainer-controller-manager"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["kubeflow-trainer-controller-manager<br/><i>(cluster-scoped)</i>"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        CR_Core["<b>Core API</b><br/>configmaps, secrets<br/><i>create, get, list, patch, update, watch</i>"]
        CR_Events["<b>Core API</b><br/>events<br/><i>create, patch, update, watch</i>"]
        CR_LimitRanges["<b>Core API</b><br/>limitranges<br/><i>get, list, watch</i>"]
        CR_Pods["<b>Core API (RHAI)</b><br/>pods<br/><i>get, list</i>"]
        CR_Webhooks["<b>admissionregistration.k8s.io</b><br/>validatingwebhookconfigurations<br/><i>get, list, update, watch</i>"]
        CR_Leases["<b>coordination.k8s.io</b><br/>leases<br/><i>create, get, list, update</i>"]
        CR_JobSets["<b>jobset.x-k8s.io</b><br/>jobsets<br/><i>create, get, list, patch, update, watch</i>"]
        CR_RuntimeClasses["<b>node.k8s.io</b><br/>runtimeclasses<br/><i>get, list, watch</i>"]
        CR_PodGroups["<b>scheduling.volcano.sh<br/>scheduling.x-k8s.io</b><br/>podgroups<br/><i>create, get, list, patch, update, watch</i>"]
        CR_TrainerCRDs["<b>trainer.kubeflow.org</b><br/>trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/><i>get, list, patch, update, watch</i>"]
        CR_TrainerStatus["<b>trainer.kubeflow.org</b><br/>*/finalizers, trainjobs/status<br/><i>get, patch, update</i>"]
        CR_NetPol["<b>networking.k8s.io (RHAI)</b><br/>networkpolicies<br/><i>get, list, watch, create, update, patch</i>"]
    end

    subgraph AggregatedRoles["Aggregated User-Facing Roles"]
        direction TB

        subgraph AdminRole["ClusterRole: training-admin"]
            Admin_Perms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/><i>create, delete, get, list,<br/>patch, update, watch</i>"]
        end

        subgraph EditRole["ClusterRole: training-edit"]
            Edit_TrainJobs["trainjobs<br/><i>create, delete, get, list,<br/>patch, update, watch</i>"]
            Edit_Runtimes["trainingruntimes,<br/>clustertrainingruntimes<br/><i>get, list, watch</i>"]
            Edit_Status["trainjobs/status<br/><i>get</i>"]
        end

        subgraph ViewRole["ClusterRole: training-view"]
            View_Perms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/><i>get, list, watch</i>"]
        end
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Core
    CRB_Controller -->|grants| CR_Events
    CRB_Controller -->|grants| CR_LimitRanges
    CRB_Controller -->|grants| CR_Pods
    CRB_Controller -->|grants| CR_Webhooks
    CRB_Controller -->|grants| CR_Leases
    CRB_Controller -->|grants| CR_JobSets
    CRB_Controller -->|grants| CR_RuntimeClasses
    CRB_Controller -->|grants| CR_PodGroups
    CRB_Controller -->|grants| CR_TrainerCRDs
    CRB_Controller -->|grants| CR_TrainerStatus
    CRB_Controller -->|grants| CR_NetPol

