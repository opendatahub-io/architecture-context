graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>ClusterRoleBinding"]
    end

    subgraph OperatorRoles["Operator ClusterRoles"]
        CR["kubeflow-trainer-controller-manager<br/>ClusterRole"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles (User-facing)"]
        AdminRole["training-admin"]
        EditRole["training-edit"]
        ViewRole["training-view"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps<br/>create,get,list,patch,update,watch"]
        Secrets["secrets<br/>create,get,list,patch,update,watch"]
        Events["events<br/>create,patch,update,watch"]
        LimitRanges["limitranges<br/>get,list,watch"]
        Pods["pods<br/>get,list (RHOAI only)"]
    end

    subgraph TrainerResources["trainer.kubeflow.org Resources"]
        TrainJobs["trainjobs<br/>get,list,patch,update,watch"]
        TrainJobStatus["trainjobs/status<br/>get,patch,update"]
        TrainJobFinalizers["trainjobs/finalizers<br/>get,patch,update"]
        TrainingRuntimes["trainingruntimes<br/>get,list,patch,update,watch"]
        ClusterRuntimes["clustertrainingruntimes<br/>get,list,patch,update,watch"]
        RuntimeFinalizers["*runtimes/finalizers<br/>get,patch,update"]
    end

    subgraph ExtResources["External API Resources"]
        JobSets["jobset.x-k8s.io/jobsets<br/>create,get,list,patch,update,watch"]
        PodGroupsV["scheduling.volcano.sh/podgroups<br/>create,get,list,patch,update,watch"]
        PodGroupsCS["scheduling.x-k8s.io/podgroups<br/>create,get,list,patch,update,watch"]
        NetworkPolicies["networking.k8s.io/networkpolicies<br/>get,list,watch,create,update,patch<br/>(RHOAI only)"]
        RuntimeClasses["node.k8s.io/runtimeclasses<br/>get,list,watch"]
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get,list,update,watch"]
        Leases["coordination.k8s.io/leases<br/>create,get,list,update"]
    end

    subgraph UserResources["User-facing Resources"]
        UserTrainJobs["trainjobs<br/>CRUD + watch"]
        UserRuntimes["trainingruntimes<br/>clustertrainingruntimes"]
        UserStatus["*/status<br/>get"]
    end

    %% Operator bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Operator permissions
    CR --> ConfigMaps
    CR --> Secrets
    CR --> Events
    CR --> LimitRanges
    CR --> Pods
    CR --> TrainJobs
    CR --> TrainJobStatus
    CR --> TrainJobFinalizers
    CR --> TrainingRuntimes
    CR --> ClusterRuntimes
    CR --> RuntimeFinalizers
    CR --> JobSets
    CR --> PodGroupsV
    CR --> PodGroupsCS
    CR --> NetworkPolicies
    CR --> RuntimeClasses
    CR --> Webhooks
    CR --> Leases

    %% User-facing roles
    AdminRole -->|"full CRUD"| UserTrainJobs
    AdminRole -->|"full CRUD"| UserRuntimes
    AdminRole -->|"get"| UserStatus
    EditRole -->|"CRUD"| UserTrainJobs
    EditRole -->|"get,list,watch"| UserRuntimes
    EditRole -->|"get"| UserStatus
    ViewRole -->|"get,list,watch"| UserTrainJobs
    ViewRole -->|"get,list,watch"| UserRuntimes
    ViewRole -->|"get"| UserStatus

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style AdminRole fill:#e74c3c,stroke:#333,color:#fff
    style EditRole fill:#e67e22,stroke:#333,color:#fff
    style ViewRole fill:#27ae60,stroke:#333,color:#fff
    style Pods fill:#ffe6cc,stroke:#d79b00
    style NetworkPolicies fill:#ffe6cc,stroke:#d79b00
