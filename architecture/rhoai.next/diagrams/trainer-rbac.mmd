graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/><i>Namespace: opendatahub</i>"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Main["kubeflow-trainer-controller-manager<br/><i>cluster-wide</i>"]
        CRB_Edit["training-edit<br/><i>aggregated to edit role</i>"]
        CRB_Admin["training-admin<br/><i>aggregated to admin role</i>"]
        CRB_View["training-view<br/><i>aggregated to view role</i>"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["kubeflow-trainer-controller-manager"]
        CR_Edit["training-edit"]
        CR_Admin["training-admin"]
        CR_View["training-view"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps<br/><i>create, get, list,<br/>patch, update, watch</i>"]
        Secrets["secrets<br/><i>create, get, list,<br/>patch, update, watch</i>"]
        Events["events<br/><i>create, patch,<br/>update, watch</i>"]
        LimitRanges["limitranges<br/><i>get, list, watch</i>"]
        Pods["pods<br/><i>get, list</i><br/>(RHAI patch)"]
    end

    subgraph AdmissionResources["admissionregistration.k8s.io"]
        VWC["validatingwebhookconfigurations<br/><i>get, list, update, watch</i>"]
    end

    subgraph CoordinationResources["coordination.k8s.io"]
        Leases["leases<br/><i>create, get, list, update</i>"]
    end

    subgraph JobSetResources["jobset.x-k8s.io"]
        JobSets["jobsets<br/><i>create, get, list,<br/>patch, update, watch</i>"]
    end

    subgraph NodeResources["node.k8s.io"]
        RuntimeClasses["runtimeclasses<br/><i>get, list, watch</i>"]
    end

    subgraph SchedulingResources["scheduling.volcano.sh /<br/>scheduling.x-k8s.io"]
        PodGroups["podgroups<br/><i>create, get, list,<br/>patch, update, watch</i>"]
    end

    subgraph TrainerResources["trainer.kubeflow.org"]
        TrainJobs["trainjobs<br/><i>get, list, patch,<br/>update, watch</i>"]
        TrainingRuntimes["trainingruntimes<br/><i>get, list, patch,<br/>update, watch</i>"]
        ClusterTrainingRuntimes["clustertrainingruntimes<br/><i>get, list, patch,<br/>update, watch</i>"]
        Finalizers["*/finalizers<br/><i>get, patch, update</i>"]
        Status["trainjobs/status<br/><i>get, patch, update</i>"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        NetworkPolicies["networkpolicies<br/><i>get, list, watch,<br/>create, update, patch</i><br/>(RHAI patch)"]
    end

    subgraph AggregateTrainerResources["trainer.kubeflow.org (Aggregate Roles)"]
        EditTrainJobs["trainjobs<br/><i>create, delete, get, list,<br/>patch, update, watch</i>"]
        EditReadOnly["trainjobs/status,<br/>trainingruntimes,<br/>clustertrainingruntimes<br/><i>get, list, watch</i>"]
        AdminAll["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/><i>create, delete, get, list,<br/>patch, update, watch</i>"]
        ViewAll["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/><i>get, list, watch</i>"]
    end

    %% Main controller role chain
    SA -->|"bound via"| CRB_Main
    CRB_Main -->|"grants"| CR_Main

    CR_Main -->|"core"| ConfigMaps
    CR_Main -->|"core"| Secrets
    CR_Main -->|"core"| Events
    CR_Main -->|"core"| LimitRanges
    CR_Main -->|"core (RHAI)"| Pods
    CR_Main -->|"admission"| VWC
    CR_Main -->|"coordination"| Leases
    CR_Main -->|"jobset"| JobSets
    CR_Main -->|"node"| RuntimeClasses
    CR_Main -->|"scheduling"| PodGroups
    CR_Main -->|"trainer"| TrainJobs
    CR_Main -->|"trainer"| TrainingRuntimes
    CR_Main -->|"trainer"| ClusterTrainingRuntimes
    CR_Main -->|"trainer"| Finalizers
    CR_Main -->|"trainer"| Status
    CR_Main -->|"networking (RHAI)"| NetworkPolicies

    %% Aggregate roles
    CRB_Edit -->|"grants"| CR_Edit
    CR_Edit --> EditTrainJobs
    CR_Edit --> EditReadOnly

    CRB_Admin -->|"grants"| CR_Admin
    CR_Admin --> AdminAll

    CRB_View -->|"grants"| CR_View
    CR_View --> ViewAll

