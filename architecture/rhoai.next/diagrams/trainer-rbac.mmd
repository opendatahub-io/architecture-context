graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-scoped)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        CoreResources["Core API Resources<br/>configmaps, secrets: create, get, list, patch, update, watch<br/>events: create, patch, update, watch<br/>limitranges: get, list, watch<br/>pods: get, list (RHOAI only)"]
        AdmissionResources["admissionregistration.k8s.io<br/>validatingwebhookconfigurations:<br/>get, list, update, watch"]
        CoordinationResources["coordination.k8s.io<br/>leases: create, get, list, update"]
        JobSetResources["jobset.x-k8s.io<br/>jobsets: create, get, list, patch, update, watch"]
        NetworkResources["networking.k8s.io<br/>networkpolicies: get, list, watch,<br/>create, update, patch (RHOAI only)"]
        NodeResources["node.k8s.io<br/>runtimeclasses: get, list, watch"]
        SchedulingResources["scheduling.volcano.sh &<br/>scheduling.x-k8s.io<br/>podgroups: create, get, list, patch, update, watch"]
        TrainerResources["trainer.kubeflow.org<br/>clustertrainingruntimes, trainingruntimes, trainjobs:<br/>get, list, patch, update, watch<br/>+ finalizers, status: get, patch, update"]
    end

    subgraph UserRoles["User-Facing ClusterRoles"]
        direction TB
        AdminRole["training-admin<br/>Full CRUD on trainjobs,<br/>trainingruntimes, clustertrainingruntimes<br/>+ status: get"]
        EditRole["training-edit<br/>Full CRUD on trainjobs<br/>Read-only on runtimes<br/>+ trainjobs/status: get"]
        ViewRole["training-view<br/>Read-only (get, list, watch)<br/>on all trainer resources<br/>+ status: get"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| ControllerRole

    %% Controller role to resources
    ControllerRole --- CoreResources
    ControllerRole --- AdmissionResources
    ControllerRole --- CoordinationResources
    ControllerRole --- JobSetResources
    ControllerRole --- NetworkResources
    ControllerRole --- NodeResources
    ControllerRole --- SchedulingResources
    ControllerRole --- TrainerResources

    subgraph Secrets["Managed Secrets"]
        WebhookCert["kubeflow-trainer-webhook-cert<br/>Type: Opaque<br/>Provisioner: cert-controller<br/>Auto-rotate: Yes"]
        SSHSecret["{trainjob-name}-mpi-ssh-auth<br/>Type: kubernetes.io/ssh-auth<br/>ECDSA P521 key pair<br/>Immutable, per-TrainJob"]
    end

    SA -.->|"creates/manages"| SSHSecret
    SA -.->|"uses (mounted)"| WebhookCert

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#6cb4ee,stroke:#333
    style ControllerRole fill:#f5a623,stroke:#333
    style CoreResources fill:#fff3cd,stroke:#d6b656
    style AdmissionResources fill:#fff3cd,stroke:#d6b656
    style CoordinationResources fill:#fff3cd,stroke:#d6b656
    style JobSetResources fill:#fff3cd,stroke:#d6b656
    style NetworkResources fill:#fff3cd,stroke:#d6b656
    style NodeResources fill:#fff3cd,stroke:#d6b656
    style SchedulingResources fill:#fff3cd,stroke:#d6b656
    style TrainerResources fill:#fff3cd,stroke:#d6b656
    style AdminRole fill:#d4edda,stroke:#82b366
    style EditRole fill:#d4edda,stroke:#82b366
    style ViewRole fill:#d4edda,stroke:#82b366
    style WebhookCert fill:#f8d7da,stroke:#c0392b
    style SSHSecret fill:#f8d7da,stroke:#c0392b
