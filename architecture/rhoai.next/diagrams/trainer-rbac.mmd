graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>(Namespace: opendatahub)"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles"]
        EditRole["training-edit<br/>(aggregated to edit)"]
        AdminRole["training-admin<br/>(aggregated to admin)"]
        ViewRole["training-view<br/>(aggregated to view)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRole"]
        CR["kubeflow-trainer-controller-manager"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps<br/>create, get, list, patch,<br/>update, watch"]
        Secrets["secrets<br/>create, get, list, patch,<br/>update, watch"]
        Events["events<br/>create, patch, update, watch"]
        LimitRanges["limitranges<br/>get, list, watch"]
        Pods["pods<br/>get, list (RHAI)"]
    end

    subgraph AdmissionResources["admissionregistration.k8s.io"]
        VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
    end

    subgraph CoordinationResources["coordination.k8s.io"]
        Leases["leases<br/>create, get, list, update"]
    end

    subgraph JobSetResources["jobset.x-k8s.io"]
        JobSets["jobsets<br/>create, get, list, patch,<br/>update, watch"]
    end

    subgraph NodeResources["node.k8s.io"]
        RuntimeClasses["runtimeclasses<br/>get, list, watch"]
    end

    subgraph SchedulingResources["scheduling.volcano.sh /<br/>scheduling.x-k8s.io"]
        PodGroups["podgroups<br/>create, get, list, patch,<br/>update, watch"]
    end

    subgraph TrainerResources["trainer.kubeflow.org"]
        TrainJobs["trainjobs<br/>get, list, patch, update, watch"]
        TrainingRuntimes["trainingruntimes<br/>get, list, patch, update, watch"]
        ClusterTrainingRuntimes["clustertrainingruntimes<br/>get, list, patch, update, watch"]
        Finalizers["*/finalizers<br/>get, patch, update"]
        TrainJobStatus["trainjobs/status<br/>get, patch, update"]
    end

    subgraph NetworkResources["networking.k8s.io"]
        NetworkPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch (RHAI)"]
    end

    %% Controller SA bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% ClusterRole → Resources
    CR -->|"manages"| ConfigMaps
    CR -->|"manages"| Secrets
    CR -->|"manages"| Events
    CR -->|"reads"| LimitRanges
    CR -->|"reads (RHAI)"| Pods
    CR -->|"manages"| VWC
    CR -->|"manages"| Leases
    CR -->|"manages"| JobSets
    CR -->|"reads"| RuntimeClasses
    CR -->|"manages"| PodGroups
    CR -->|"manages"| TrainJobs
    CR -->|"manages"| TrainingRuntimes
    CR -->|"manages"| ClusterTrainingRuntimes
    CR -->|"manages"| Finalizers
    CR -->|"manages"| TrainJobStatus
    CR -->|"manages (RHAI)"| NetworkPolicies

    %% Aggregate roles
    EditRole -->|"trainjobs: full CRUD<br/>status/runtimes: read"| TrainJobs
    AdminRole -->|"all trainer: full CRUD"| TrainJobs
    AdminRole -->|"all trainer: full CRUD"| TrainingRuntimes
    AdminRole -->|"all trainer: full CRUD"| ClusterTrainingRuntimes
    ViewRole -->|"all trainer: read-only"| TrainJobs

