graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>(namespace: opendatahub)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(ClusterRoleBinding)"]
    end

    subgraph ControllerClusterRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        CR_Main["Controller Manager Role"]
    end

    subgraph CoreResources["Core API Resources ('')"]
        direction TB
        ConfigMaps["configmaps<br/>create, get, list,<br/>patch, update, watch"]
        Secrets["secrets<br/>create, get, list,<br/>patch, update, watch"]
        Events["events<br/>create, patch,<br/>update, watch"]
        LimitRanges["limitranges<br/>get, list, watch"]
        Pods["pods (RHOAI)<br/>get, list"]
    end

    subgraph TrainerResources["trainer.kubeflow.org"]
        direction TB
        TrainJobs["trainjobs<br/>get, list, patch,<br/>update, watch"]
        TrainingRuntimes["trainingruntimes<br/>get, list, patch,<br/>update, watch"]
        ClusterTrainingRuntimes["clustertrainingruntimes<br/>get, list, patch,<br/>update, watch"]
        Finalizers["*/finalizers<br/>trainjobs/status<br/>get, patch, update"]
    end

    subgraph WorkloadResources["Workload API Resources"]
        direction TB
        JobSets["jobset.x-k8s.io<br/>jobsets<br/>create, get, list,<br/>patch, update, watch"]
        PodGroupsSched["scheduling.x-k8s.io<br/>podgroups<br/>create, get, list,<br/>patch, update, watch"]
        PodGroupsVolcano["scheduling.volcano.sh<br/>podgroups<br/>create, get, list,<br/>patch, update, watch"]
    end

    subgraph InfraResources["Infrastructure Resources"]
        direction TB
        Webhooks["admissionregistration.k8s.io<br/>validatingwebhookconfigurations<br/>get, list, update, watch"]
        Leases["coordination.k8s.io<br/>leases<br/>create, get, list, update"]
        RuntimeClasses["node.k8s.io<br/>runtimeclasses<br/>get, list, watch"]
        NetworkPolicies["networking.k8s.io (RHOAI)<br/>networkpolicies<br/>get, list, watch,<br/>create, update, patch"]
    end

    %% Controller SA bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR_Main

    CR_Main -->|"core API"| CoreResources
    CR_Main -->|"trainer CRDs"| TrainerResources
    CR_Main -->|"workload mgmt"| WorkloadResources
    CR_Main -->|"infrastructure"| InfraResources

    %% Aggregate Roles
    subgraph AggregateRoles["Aggregate ClusterRoles (user-facing)"]
        direction TB
        TrainingAdmin["training-admin<br/>trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>FULL CRUD"]
        TrainingEdit["training-edit<br/>trainjobs: CRUD<br/>runtimes: read-only"]
        TrainingView["training-view<br/>all trainer CRDs:<br/>read-only"]
    end

    TrainingAdmin -.->|"aggregates"| TrainingEdit
    TrainingEdit -.->|"aggregates"| TrainingView

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333,stroke-width:2px
    style ConfigMaps fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style LimitRanges fill:#7ed321,stroke:#333
    style Pods fill:#e8a838,stroke:#333
    style TrainJobs fill:#7ed321,stroke:#333
    style TrainingRuntimes fill:#7ed321,stroke:#333
    style ClusterTrainingRuntimes fill:#7ed321,stroke:#333
    style Finalizers fill:#7ed321,stroke:#333
    style JobSets fill:#7ed321,stroke:#333
    style PodGroupsSched fill:#7ed321,stroke:#333
    style PodGroupsVolcano fill:#7ed321,stroke:#333
    style Webhooks fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style RuntimeClasses fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#e8a838,stroke:#333
    style TrainingAdmin fill:#e74c3c,stroke:#333,color:#fff
    style TrainingEdit fill:#e67e22,stroke:#333,color:#fff
    style TrainingView fill:#3498db,stroke:#333,color:#fff
