graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>Namespace: opendatahub"]
    end

    subgraph AggregateRoles["Aggregate ClusterRoles (User-Facing)"]
        EditRole["training-edit<br/>(aggregates to: edit)"]
        AdminRole["training-admin<br/>(aggregates to: admin)"]
        ViewRole["training-view<br/>(aggregates to: view)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-wide)"]
    end

    subgraph ControllerClusterRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        CorePerms["Core API Group ('')"]
        AdmissionPerms["admissionregistration.k8s.io"]
        CoordPerms["coordination.k8s.io"]
        JobSetPerms["jobset.x-k8s.io"]
        NodePerms["node.k8s.io"]
        SchedulingPerms["scheduling.volcano.sh<br/>scheduling.x-k8s.io"]
        TrainerPerms["trainer.kubeflow.org"]
        NetworkPerms["networking.k8s.io<br/>(RHAI)"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["configmaps, secrets<br/>create, get, list, patch,<br/>update, watch"]
        Events["events<br/>create, patch, update, watch"]
        LimitRanges["limitranges<br/>get, list, watch"]
        Pods["pods<br/>get, list (RHAI)"]
    end

    subgraph ExtResources["Extension API Resources"]
        Webhooks["validatingwebhookconfigurations<br/>get, list, update, watch"]
        Leases["leases<br/>create, get, list, update"]
        JobSets["jobsets<br/>create, get, list, patch,<br/>update, watch"]
        RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        PodGroups["podgroups<br/>create, get, list, patch,<br/>update, watch"]
        NetPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch"]
    end

    subgraph TrainerResources["Trainer CRD Resources"]
        TrainJobs["trainjobs<br/>get, list, patch, update, watch"]
        TrainJobStatus["trainjobs/status<br/>get, patch, update"]
        TrainJobFinalizers["trainjobs/finalizers<br/>get, patch, update"]
        Runtimes["trainingruntimes<br/>clustertrainingruntimes<br/>get, list, patch, update, watch"]
        RuntimeFinalizers["*/finalizers<br/>get, patch, update"]
    end

    subgraph UserResources["User-Facing Permissions"]
        EditTrainJobs["trainjobs<br/>create, delete, get, list,<br/>patch, update, watch"]
        EditReadOnly["trainjobs/status,<br/>trainingruntimes,<br/>clustertrainingruntimes<br/>get, list, watch"]
        AdminAll["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>create, delete, get, list,<br/>patch, update, watch"]
        ViewAll["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>get, list, watch"]
    end

    %% Controller SA bindings
    SA -->|bound via| CRB
    CRB -->|grants| ControllerClusterRole

    %% Controller role → resources
    CorePerms -->|manages| ConfigMaps
    CorePerms -->|manages| Events
    CorePerms -->|reads| LimitRanges
    CorePerms -->|reads| Pods
    AdmissionPerms -->|manages| Webhooks
    CoordPerms -->|manages| Leases
    JobSetPerms -->|manages| JobSets
    NodePerms -->|reads| RuntimeClasses
    SchedulingPerms -->|manages| PodGroups
    TrainerPerms -->|manages| TrainJobs
    TrainerPerms -->|manages| TrainJobStatus
    TrainerPerms -->|manages| TrainJobFinalizers
    TrainerPerms -->|manages| Runtimes
    TrainerPerms -->|manages| RuntimeFinalizers
    NetworkPerms -->|manages| NetPolicies

    %% Aggregate roles → permissions
    EditRole -->|grants| EditTrainJobs
    EditRole -->|grants| EditReadOnly
    AdminRole -->|grants| AdminAll
    ViewRole -->|grants| ViewAll

