    style Routes fill:#7ed321,stroke:#333,color:#fff
    style NetPol fill:#7ed321,stroke:#333,color:#fff
    style ArgoWF fill:#7ed321,stroke:#333,color:#fff
    style KFPipelines fill:#7ed321,stroke:#333,color:#fff
    style KFAll fill:#7ed321,stroke:#333,color:#fff
    style WebhookCfg fill:#7ed321,stroke:#333,color:#fff
    style ServiceMonitors fill:#7ed321,stroke:#333,color:#fff
    style KServeRes fill:#7ed321,stroke:#333,color:#fff
    style RayRes fill:#7ed321,stroke:#333,color:#fff
    style CFRes fill:#7ed321,stroke:#333,color:#fff
