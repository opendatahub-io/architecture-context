    style RES_TOKEN fill:#7ed321,stroke:#333,color:#fff
    style RES_CF fill:#7ed321,stroke:#333,color:#fff
    style RES_MLF fill:#7ed321,stroke:#333,color:#fff

    style PR_KSERVE fill:#7ed321,stroke:#333,color:#fff
    style PR_CF fill:#7ed321,stroke:#333,color:#fff
    style PR_RAY fill:#7ed321,stroke:#333,color:#fff
