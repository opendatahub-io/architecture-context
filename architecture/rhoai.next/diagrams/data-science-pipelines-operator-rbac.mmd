graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(Operator NS)"]
        SA_DSP["ds-pipeline-{name}<br/>(DSPA NS)"]
        SA_PR["pipeline-runner-{name}<br/>(DSPA NS)"]
        SA_PA["ds-pipeline-persistenceagent-{name}<br/>(DSPA NS)"]
        SA_SWF["ds-pipeline-scheduledworkflow-{name}<br/>(DSPA NS)"]
        SA_WFC["ds-pipeline-workflow-controller-{name}<br/>(DSPA NS)"]
        SA_WH["ds-pipeline-webhook<br/>(Operator NS)"]
        SA_MDENV["ds-pipeline-metadata-envoy-{name}<br/>(DSPA NS)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_MGR["manager-rolebinding"]
        CRB_ARGO["manager-argo-rolebinding"]
        CRB_WH["ds-pipeline-webhook"]
        CRB_AUTH["ds-pipeline-ui-auth-delegator<br/>(per NS/name)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_MGR["manager-role"]
        CR_ARGO["manager-argo-role"]
        CR_WH["ds-pipeline-webhook"]
        CR_AUTH["system:auth-delegator"]
        CR_EDIT["aggregate-dspa-admin-edit<br/>(aggregated to admin/edit)"]
        CR_VIEW["aggregate-dspa-admin-view<br/>(aggregated to view)"]
    end

    subgraph RoleBindings["Role Bindings (per DSPA NS)"]
        RB_DSP["ds-pipeline-{name}"]
        RB_PR["pipeline-runner-{name}"]
        RB_PA["ds-pipeline-persistenceagent-{name}"]
        RB_SWF["ds-pipeline-scheduledworkflow-{name}"]
        RB_WFC["ds-pipeline-workflow-controller-rolebinding-{name}"]
        RB_LE["leader-election-rolebinding"]
    end

    subgraph Roles["Roles (per DSPA NS)"]
        R_DSP["ds-pipeline-{name}"]
        R_PR["pipeline-runner-{name}"]
        R_PA["ds-pipeline-persistenceagent-{name}"]
        R_SWF["ds-pipeline-scheduledworkflow-{name}"]
        R_WFC["ds-pipeline-workflow-controller-role-{name}"]
        R_LE["leader-election-role"]
    end

    subgraph ManagerResources["manager-role Resources"]
        RES_DSPA["dspa.opendatahub.io<br/>DSPA, /status, /finalizers<br/>[CRUD]"]
        RES_PIPE["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>[CRUD]"]
        RES_CORE["core<br/>deployments, services, SAs,<br/>secrets, configmaps, pods,<br/>PVCs, PVs [CRUD]"]
        RES_NET["networking.k8s.io<br/>networkpolicies, ingresses<br/>[CRUD]"]
        RES_RBAC_R["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>[CRUD]"]
        RES_ROUTE["route.openshift.io<br/>routes [CRUD]"]
        RES_ADMIT["admissionregistration.k8s.io<br/>webhook configs [CRUD]"]
        RES_ARGO_W["argoproj.io<br/>workflows [*]"]
        RES_KF["kubeflow.org<br/>* [*]"]
        RES_BATCH["batch<br/>jobs [*]"]
        RES_MON["monitoring.coreos.com<br/>servicemonitors [CRUD]"]
        RES_SAR["authorization.k8s.io<br/>subjectaccessreviews [create]"]
        RES_TOKEN["authentication.k8s.io<br/>tokenreviews [create]"]
        RES_CF["workload.codeflare.dev<br/>appwrappers [CRUD]"]
        RES_MLF["mlflow.opendatahub.io<br/>mlflows [get,list,watch]"]
    end

    subgraph PipelineRunnerResources["pipeline-runner-{name} Resources"]
        PR_KSERVE["serving.kserve.io<br/>inferenceservices [CRUD]"]
        PR_CF["workload.codeflare.dev<br/>appwrappers [CRUD]"]
        PR_RAY["ray.io<br/>rayclusters, rayjobs,<br/>rayservices [CRUD]"]
        PR_SELDON["machinelearning.seldon.io<br/>seldondeployments [create]"]
    end

    %% Service Account to ClusterRoleBinding
    SA_CM -->|"bound via"| CRB_MGR
    SA_CM -->|"bound via"| CRB_ARGO
    SA_WH -->|"bound via"| CRB_WH
    SA_DSP -->|"bound via"| CRB_AUTH
    SA_MDENV -->|"bound via"| CRB_AUTH

    %% ClusterRoleBinding to ClusterRole
    CRB_MGR -->|"grants"| CR_MGR
    CRB_ARGO -->|"grants"| CR_ARGO
    CRB_WH -->|"grants"| CR_WH
    CRB_AUTH -->|"grants"| CR_AUTH

    %% Service Account to RoleBinding
    SA_CM -->|"bound via"| RB_LE
    SA_DSP -->|"bound via"| RB_DSP
    SA_PR -->|"bound via"| RB_PR
    SA_PA -->|"bound via"| RB_PA
    SA_SWF -->|"bound via"| RB_SWF
    SA_WFC -->|"bound via"| RB_WFC

    %% RoleBinding to Role
    RB_LE -->|"grants"| R_LE
    RB_DSP -->|"grants"| R_DSP
    RB_PR -->|"grants"| R_PR
    RB_PA -->|"grants"| R_PA
    RB_SWF -->|"grants"| R_SWF
    RB_WFC -->|"grants"| R_WFC

    %% ClusterRole to Resources
    CR_MGR -->|"access"| ManagerResources
    R_PR -->|"access"| PipelineRunnerResources

