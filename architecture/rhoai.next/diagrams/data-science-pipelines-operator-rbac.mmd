graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_DSPO["data-science-pipelines-operator-<br/>controller-manager"]
        SA_Pipeline["ds-pipeline-{name}"]
        SA_Envoy["ds-pipeline-metadata-<br/>envoy-{name}"]
        SA_Runner["pipeline-runner-{name}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDeleg["ds-pipeline-ui-auth-<br/>delegator-{ns}-{name}"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Pipeline["ds-pipeline-{name}"]
        RB_Runner["pipeline-runner-{name}"]
    end

    subgraph ClusterRoles["ClusterRole: manager-role"]
        direction TB
        CR_DSPA["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>+ /api, /status, /finalizers<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_Core["core (pods, services, secrets,<br/>configmaps, serviceaccounts,<br/>PVs, PVCs, events)<br/><b>*, get/list/watch/create/update/patch/delete</b>"]
        CR_Apps["apps (deployments)<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_Routes["route.openshift.io (routes)<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_NetPol["networking.k8s.io (networkpolicies)<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_Argo["argoproj.io (workflows,<br/>workflowartifactgctasks)<br/><b>* (all verbs)</b>"]
        CR_KFP["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/><b>get,list,watch,create,update,patch,delete</b>"]
        CR_KF["kubeflow.org (* all resources)<br/><b>* (all verbs)</b>"]
        CR_Webhook["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigs<br/><b>create, CRUD (named)</b>"]
        CR_Monitor["monitoring.coreos.com<br/>servicemonitors<br/><b>get,list,watch,create,update,patch,delete</b>"]
    end

    subgraph IntegrationRoles["Integration RBAC (pipeline-runner)"]
        IR_KServe["serving.kserve.io<br/>inferenceservices<br/><b>create,get,list,patch,delete</b>"]
        IR_Ray["ray.io<br/>rayclusters, rayjobs, rayservices<br/><b>create,get,list,patch,delete</b>"]
        IR_CF["workload.codeflare.dev<br/>appwrappers<br/><b>create,delete,get,list,<br/>patch,update,watch</b>"]
    end

    subgraph AuthDelegation["ClusterRole: system:auth-delegator"]
        AD_Auth["authentication.k8s.io (tokenreviews)<br/>authorization.k8s.io (subjectaccessreviews)<br/><b>create</b>"]
    end

    %% Operator SA bindings
    SA_DSPO -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_DSPA
    CRB_Manager -->|"grants"| CR_Core
    CRB_Manager -->|"grants"| CR_Apps
    CRB_Manager -->|"grants"| CR_RBAC
    CRB_Manager -->|"grants"| CR_Routes
    CRB_Manager -->|"grants"| CR_NetPol
    CRB_Manager -->|"grants"| CR_Argo
    CRB_Manager -->|"grants"| CR_KFP
    CRB_Manager -->|"grants"| CR_KF
    CRB_Manager -->|"grants"| CR_Webhook
    CRB_Manager -->|"grants"| CR_Monitor

    %% Auth delegator bindings
    SA_Pipeline -->|"bound via"| CRB_AuthDeleg
    SA_Envoy -->|"bound via"| CRB_AuthDeleg
    CRB_AuthDeleg -->|"grants"| AD_Auth

    %% Namespace-scoped bindings
    SA_Pipeline -->|"bound via"| RB_Pipeline
    SA_Runner -->|"bound via"| RB_Runner
    RB_Runner -->|"grants"| IR_KServe
    RB_Runner -->|"grants"| IR_Ray
    RB_Runner -->|"grants"| IR_CF

    style SA_DSPO fill:#4a90e2,color:#fff
    style SA_Pipeline fill:#4a90e2,color:#fff
    style SA_Envoy fill:#4a90e2,color:#fff
