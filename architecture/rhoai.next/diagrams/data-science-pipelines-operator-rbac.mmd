graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_API["ds-pipeline-{name}<br/>(DSPA namespace)"]
        SA_PA["ds-pipeline-persistenceagent-{name}<br/>(DSPA namespace)"]
        SA_SW["ds-pipeline-scheduledworkflow-{name}<br/>(DSPA namespace)"]
        SA_WFC["ds-pipeline-workflow-controller-{name}<br/>(DSPA namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_MGR["manager-rolebinding<br/>(cluster-wide)"]
        CRB_LE["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_MGR["manager-role"]
        CR_LE["leader-election-role"]
        CR_EDIT["aggregate-dspa-admin-edit<br/>(aggregated to admin/edit)"]
        CR_VIEW["aggregate-dspa-admin-view<br/>(aggregated to view)"]
    end

    subgraph NamespaceRoles["Namespace Roles (per DSPA)"]
        R_API["ds-pipeline-{name}"]
        R_PA["ds-pipeline-persistenceagent-{name}"]
        R_SW["ds-pipeline-scheduledworkflow-{name}"]
        R_WFC["ds-pipeline-workflow-controller-{name}"]
    end

    subgraph ManagerRoleResources["manager-role API Resources"]
        direction LR

        subgraph DSPAResources["DSPA Resources"]
            DSPA_CR["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>+ /api, /finalizers, /status"]
        end

        subgraph CoreResources["Core Resources"]
            Core["core<br/>configmaps, secrets,<br/>serviceaccounts, pvcs, pvs,<br/>services, pods, pods/exec,<br/>pods/log, events"]
        end

        subgraph AppsResources["Apps Resources"]
            Apps["apps, extensions<br/>deployments,<br/>deployments/finalizers,<br/>replicasets"]
        end

        subgraph NetworkResources["Network Resources"]
            Net["networking.k8s.io<br/>networkpolicies, ingresses"]
        end

        subgraph RBACResources["RBAC Resources"]
            RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles,<br/>clusterrolebindings"]
        end

        subgraph ArgoResources["Argo Resources"]
            Argo["argoproj.io<br/>workflows,<br/>workflowartifactgctasks,<br/>workflowtaskresults"]
        end

        subgraph KFPResources["KFP Resources"]
            KFP["kubeflow.org: */*<br/>pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>+ /finalizers, /status"]
        end

        subgraph MLResources["ML Integration Resources"]
            ML["serving.kserve.io: inferenceservices<br/>machinelearning.seldon.io: seldondeployments<br/>ray.io: rayclusters, rayjobs, rayservices<br/>workload.codeflare.dev: appwrappers"]
        end

        subgraph InfraResources["Infrastructure Resources"]
            Infra["route.openshift.io: routes<br/>image.openshift.io: imagestreamtags<br/>monitoring.coreos.com: servicemonitors<br/>batch: jobs<br/>snapshot.storage.k8s.io: volumesnapshots<br/>admissionregistration.k8s.io: webhooks"]
        end

        subgraph AuthResources["Auth Resources"]
            Auth["authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews"]
        end
    end

    subgraph AggregateResources["Aggregate Role Resources"]
        AggRes["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications, /api<br/>pipelines.kubeflow.org<br/>pipelines, pipelineversions"]
    end

    %% Bindings
    SA_CM -->|"bound via"| CRB_MGR
    SA_CM -->|"bound via"| CRB_LE
    CRB_MGR -->|"grants"| CR_MGR
    CRB_LE -->|"grants"| CR_LE

    SA_API -->|"bound via RoleBinding"| R_API
    SA_PA -->|"bound via RoleBinding"| R_PA
    SA_SW -->|"bound via RoleBinding"| R_SW
    SA_WFC -->|"bound via RoleBinding"| R_WFC

    %% ClusterRole permissions
    CR_MGR -->|"full CRUD"| DSPA_CR
    CR_MGR -->|"full CRUD"| Core
    CR_MGR -->|"full CRUD"| Apps
    CR_MGR -->|"CRUD"| Net
    CR_MGR -->|"CRUD"| RBAC
    CR_MGR -->|"full CRUD"| Argo
    CR_MGR -->|"full CRUD"| KFP
    CR_MGR -->|"create/delete/get/list/patch"| ML
    CR_MGR -->|"CRUD"| Infra
    CR_MGR -->|"create"| Auth

    %% Aggregate roles
    CR_EDIT -->|"get,list,watch,create,update,patch,delete"| AggRes
    CR_VIEW -->|"get,list,watch"| AggRes

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PA fill:#4a90e2,stroke:#333,color:#fff
    style SA_SW fill:#4a90e2,stroke:#333,color:#fff
    style SA_WFC fill:#4a90e2,stroke:#333,color:#fff

    style CR_MGR fill:#f5a623,stroke:#333,color:#fff
    style CR_LE fill:#f5a623,stroke:#333,color:#fff
    style CR_EDIT fill:#f5a623,stroke:#333
    style CR_VIEW fill:#f5a623,stroke:#333

    style R_API fill:#dda0dd,stroke:#333
    style R_PA fill:#dda0dd,stroke:#333
    style R_SW fill:#dda0dd,stroke:#333
    style R_WFC fill:#dda0dd,stroke:#333

    style DSPA_CR fill:#7ed321,stroke:#333,color:#fff
    style Core fill:#7ed321,stroke:#333,color:#fff
    style Apps fill:#7ed321,stroke:#333,color:#fff
    style Net fill:#7ed321,stroke:#333,color:#fff
    style RBAC fill:#7ed321,stroke:#333,color:#fff
    style Argo fill:#7ed321,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff
    style ML fill:#7ed321,stroke:#333,color:#fff
    style Infra fill:#7ed321,stroke:#333,color:#fff
    style Auth fill:#7ed321,stroke:#333,color:#fff
    style AggRes fill:#87ceeb,stroke:#333
