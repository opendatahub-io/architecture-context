graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_DSPO["data-science-pipelines-operator<br/>-controller-manager"]
        SA_Pipeline["ds-pipeline-{name}"]
        SA_Envoy["ds-pipeline-metadata<br/>-envoy-{name}"]
        SA_Runner["pipeline-runner-{name}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDel["ds-pipeline-ui-auth-delegator<br/>-{ns}-{name}"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Pipeline["ds-pipeline-{name}"]
        RB_Runner["pipeline-runner-{name}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Pipeline["ds-pipeline-{name}"]
        R_Runner["pipeline-runner-{name}"]
    end

    subgraph DSPAResources["DSPA API Resources"]
        DSPA["datasciencepipelinesapplications<br/>.opendatahub.io<br/>DSPA, DSPA/api,<br/>DSPA/status, DSPA/finalizers"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods, pods/exec,<br/>pods/log, services<br/>(*)"]
        Secrets["core<br/>secrets, configmaps,<br/>serviceaccounts<br/>(CRUD)"]
        PVs["core<br/>persistentvolumes,<br/>persistentvolumeclaims<br/>(*)"]
        Events["core<br/>events<br/>(create, list, patch)"]
    end

    subgraph AppsResources["Apps Resources"]
        Deployments["apps<br/>deployments<br/>(CRUD)"]
    end

    subgraph RBACResources["RBAC Resources"]
        RolesRes["rbac.authorization.k8s.io<br/>roles, rolebindings<br/>(CRUD)"]
        ClusterRolesRes["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings<br/>(CRUD)"]
    end

    subgraph NetworkResources["Network & Route Resources"]
        Routes["route.openshift.io<br/>routes<br/>(CRUD)"]
        NetPol["networking.k8s.io<br/>networkpolicies<br/>(CRUD)"]
    end

    subgraph WorkflowResources["Workflow Resources"]
        ArgoWF["argoproj.io<br/>workflows,<br/>workflowartifactgctasks<br/>(*)"]
        KFPipelines["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>+ finalizers/status<br/>(CRUD)"]
        KFAll["kubeflow.org<br/>* (*)"]
    end

    subgraph IntegrationResources["Integration Resources"]
        KServeRes["serving.kserve.io<br/>inferenceservices<br/>(create,get,list,patch,delete)"]
        RayRes["ray.io<br/>rayclusters, rayjobs,<br/>rayservices<br/>(create,get,list,patch,delete)"]
        CFRes["workload.codeflare.dev<br/>appwrappers<br/>(full CRUD)"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>(create)"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>(create)"]
    end

    subgraph WebhookResources["Webhook Resources"]
        WebhookCfg["admissionregistration.k8s.io<br/>mutating/validating<br/>webhookconfigurations<br/>(create/CRUD)"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>(CRUD)"]
    end

    %% SA → Binding → Role → Resources
    SA_DSPO -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_Pipeline -->|bound via| CRB_AuthDel
    SA_Envoy -->|bound via| CRB_AuthDel
    CRB_AuthDel -->|grants| CR_AuthDel

    SA_Pipeline -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| R_Pipeline

    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner

    %% manager-role permissions
    CR_Manager -->|CRUD| DSPA
    CR_Manager -->|*| Pods
    CR_Manager -->|CRUD| Secrets
    CR_Manager -->|*| PVs
    CR_Manager -->|create,list,patch| Events
    CR_Manager -->|CRUD| Deployments
    CR_Manager -->|CRUD| RolesRes
    CR_Manager -->|CRUD| ClusterRolesRes
    CR_Manager -->|CRUD| Routes
    CR_Manager -->|CRUD| NetPol
    CR_Manager -->|*| ArgoWF
    CR_Manager -->|CRUD| KFPipelines
    CR_Manager -->|*| KFAll
    CR_Manager -->|create/CRUD| WebhookCfg
    CR_Manager -->|CRUD| ServiceMonitors
    CR_Manager -->|CRUD subset| KServeRes
    CR_Manager -->|CRUD subset| RayRes
    CR_Manager -->|full CRUD| CFRes
    CR_Manager -->|create| TokenReview
    CR_Manager -->|create| SAR

    %% auth-delegator permissions
    CR_AuthDel -->|create| TokenReview
    CR_AuthDel -->|create| SAR

    %% pipeline-runner permissions (via namespace Role)
    R_Runner -.->|pipeline execution| ArgoWF
    R_Runner -.->|model deployment| KServeRes
    R_Runner -.->|distributed compute| RayRes
    R_Runner -.->|batch workloads| CFRes

    %% Styling
    style SA_DSPO fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_Envoy fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDel fill:#f5a623,stroke:#333,color:#fff
    style R_Pipeline fill:#f5a623,stroke:#333,color:#fff
    style R_Runner fill:#f5a623,stroke:#333,color:#fff

    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Secrets fill:#7ed321,stroke:#333,color:#fff
    style PVs fill:#7ed321,stroke:#333,color:#fff
    style Events fill:#7ed321,stroke:#333,color:#fff
