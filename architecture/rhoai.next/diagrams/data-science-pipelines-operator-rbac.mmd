    style RES_ROUTE fill:#7ed321,stroke:#333,color:#fff
    style RES_ADMIT fill:#7ed321,stroke:#333,color:#fff
    style RES_ARGO_W fill:#7ed321,stroke:#333,color:#fff
    style RES_KF fill:#7ed321,stroke:#333,color:#fff
    style RES_BATCH fill:#7ed321,stroke:#333,color:#fff
    style RES_MON fill:#7ed321,stroke:#333,color:#fff
