graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(Operator namespace)"]
        SA_DSP["ds-pipeline-{name}<br/>(DSPA namespace)"]
        SA_PR["pipeline-runner-{name}<br/>(DSPA namespace)"]
        SA_PA["ds-pipeline-persistenceagent-{name}<br/>(DSPA namespace)"]
        SA_SW["ds-pipeline-scheduledworkflow-{name}<br/>(DSPA namespace)"]
        SA_WC["ds-pipeline-workflow-controller-{name}<br/>(DSPA namespace)"]
        SA_WH["ds-pipelines-webhook<br/>(Operator namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_MGR["manager-rolebinding<br/>(Cluster)"]
        CRB_ARGO["manager-argo-rolebinding<br/>(Cluster)"]
        CRB_WH["ds-pipelines-webhook<br/>(Cluster)"]
    end

    subgraph RoleBindings["Namespace Role Bindings (per DSPA)"]
        RB_LE["leader-election-rolebinding"]
        RB_DSP["ds-pipeline-{name}"]
        RB_PR["pipeline-runner-{name}"]
        RB_PA["ds-pipeline-persistenceagent-{name}"]
        RB_SW["ds-pipeline-scheduledworkflow-{name}"]
        RB_WC["ds-pipeline-workflow-controller-{name}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_MGR["manager-role"]
        CR_ARGO["manager-argo-role"]
        CR_EDIT["aggregate-dspa-admin-edit<br/>(aggregated to admin/edit)"]
        CR_VIEW["aggregate-dspa-admin-view<br/>(aggregated to view)"]
        CR_WH["ds-pipelines-webhook"]
    end

    subgraph ManagerResources["manager-role Permissions"]
        DSPA_RES["datasciencepipelinesapplications.opendatahub.io<br/>DSPA, DSPA/api, DSPA/status, DSPA/finalizers<br/>get,list,watch,create,update,patch,delete"]
        CORE_RES["core (v1)<br/>secrets, configmaps, services,<br/>serviceaccounts, persistentvolumeclaims<br/>get,list,watch,create,update,patch,delete"]
        APPS_RES["apps<br/>deployments<br/>get,list,watch,create,update,patch,delete"]
        RBAC_RES["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>get,list,watch,create,update,patch,delete"]
        ROUTE_RES["route.openshift.io<br/>routes<br/>get,list,watch,create,update,patch,delete"]
        NETPOL_RES["networking.k8s.io<br/>networkpolicies<br/>get,list,watch,create,update,patch,delete"]
        ARGO_RES["argoproj.io<br/>workflows: *<br/>workflowtaskresults: create,patch<br/>workflowartifactgctasks: *"]
        KF_RES["kubeflow.org<br/>* (all resources): * (all verbs)"]
        PIPE_RES["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>create,get,list,watch,update,patch,delete"]
        MON_RES["monitoring.coreos.com<br/>servicemonitors<br/>get,list,watch,create,update,patch,delete"]
        WEBHOOK_RES["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>create,delete,get,list,patch,update,watch"]
        ML_RES["ML Framework CRDs<br/>serving.kserve.io/inferenceservices<br/>ray.io/rayclusters,rayjobs,rayservices<br/>machinelearning.seldon.io/seldondeployments<br/>workload.codeflare.dev/appwrappers<br/>create,delete,get,list,patch"]
        MLFLOW_RES["mlflow.opendatahub.io<br/>mlflows: get,list,watch<br/>mlflow.kubeflow.org<br/>experiments,runs: create,get,list,update"]
        AUTH_RES["authentication.k8s.io/tokenreviews: create<br/>authorization.k8s.io/subjectaccessreviews: create"]
    end

    subgraph ArgoResources["manager-argo-role Permissions"]
        ARGO_WF["argoproj.io<br/>workflows, workflowtasksets,<br/>workflowartifactgctasks<br/>get,list,watch,update,patch,delete,create"]
        ARGO_PODS["core (v1)<br/>pods, pods/exec<br/>create,get,list,watch,update,patch,delete"]
        ARGO_LEASE["coordination.k8s.io<br/>leases: create,get,update"]
    end

    subgraph WebhookResources["ds-pipelines-webhook Permissions"]
        WH_PIPE["pipelines.kubeflow.org<br/>pipelines: get,list,watch"]
    end

    subgraph AggregateResources["Aggregate Role Permissions"]
        AGG_EDIT["DSPA + Pipelines + PipelineVersions<br/>get,list,watch,create,update,patch,delete"]
        AGG_VIEW["DSPA + Pipelines + PipelineVersions<br/>get,list,watch"]
    end

