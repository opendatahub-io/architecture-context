graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_DSPO["dspo-controller-manager<br/>(operator namespace)"]
        SA_Pipeline["ds-pipeline-{name}<br/>(DSPA namespace)"]
        SA_Envoy["ds-pipeline-metadata-envoy-{name}<br/>(DSPA namespace)"]
        SA_Runner["pipeline-runner-{name}<br/>(DSPA namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDeleg["ds-pipeline-ui-auth-delegator-{ns}-{name}"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Pipeline["ds-pipeline-{name}"]
        RB_Runner["pipeline-runner-{name}"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Pipeline["ds-pipeline-{name}"]
        R_Runner["pipeline-runner-{name}"]
    end

    %% SA → Binding → Role chains
    SA_DSPO -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_Pipeline -->|bound via| CRB_AuthDeleg
    SA_Envoy -->|bound via| CRB_AuthDeleg
    CRB_AuthDeleg -->|grants| CR_AuthDeleg

    SA_Pipeline -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| R_Pipeline

    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner

    subgraph ManagerResources["manager-role Permissions"]
        direction TB
        DSPA_Res["datasciencepipelinesapplications.opendatahub.io<br/>datasciencepipelinesapplications<br/>/api, /status, /finalizers<br/>Verbs: get,list,watch,create,update,patch,delete"]
        Core_Res["core (v1)<br/>pods, pods/exec, pods/log, services: *<br/>secrets, configmaps, serviceaccounts: CRUD<br/>persistentvolumes, persistentvolumeclaims: *<br/>events: create,list,patch"]
        Apps_Res["apps<br/>deployments<br/>Verbs: get,list,watch,create,update,patch,delete"]
        RBAC_Res["rbac.authorization.k8s.io<br/>roles, rolebindings: CRUD<br/>clusterroles, clusterrolebindings: CRUD"]
        Route_Res["route.openshift.io<br/>routes<br/>Verbs: get,list,watch,create,update,patch,delete"]
        NetPol_Res["networking.k8s.io<br/>networkpolicies<br/>Verbs: get,list,watch,create,update,patch,delete"]
        Argo_Res["argoproj.io<br/>workflows, workflowartifactgctasks<br/>Verbs: *"]
        KFP_Res["pipelines.kubeflow.org<br/>pipelines, pipelineversions<br/>+ finalizers, status<br/>Verbs: get,list,watch,create,update,patch,delete"]
        KF_Res["kubeflow.org<br/>* (all resources)<br/>Verbs: *"]
        Webhook_Res["admissionregistration.k8s.io<br/>mutating/validatingwebhookconfigurations<br/>Verbs: create, CRUD (resourceName-scoped)"]
        Monitor_Res["monitoring.coreos.com<br/>servicemonitors<br/>Verbs: get,list,watch,create,update,patch,delete"]
        Auth_Res["authentication/authorization.k8s.io<br/>tokenreviews, subjectaccessreviews<br/>Verbs: create"]
    end

    CR_Manager -->|grants access to| DSPA_Res
    CR_Manager -->|grants access to| Core_Res
    CR_Manager -->|grants access to| Apps_Res
    CR_Manager -->|grants access to| RBAC_Res
    CR_Manager -->|grants access to| Route_Res
    CR_Manager -->|grants access to| NetPol_Res
    CR_Manager -->|grants access to| Argo_Res
    CR_Manager -->|grants access to| KFP_Res
    CR_Manager -->|grants access to| KF_Res
    CR_Manager -->|grants access to| Webhook_Res
    CR_Manager -->|grants access to| Monitor_Res
    CR_Manager -->|grants access to| Auth_Res

    subgraph RunnerResources["pipeline-runner-{name} Permissions"]
        direction TB
        Runner_KServe["serving.kserve.io<br/>inferenceservices<br/>Verbs: create,get,list,patch,delete"]
        Runner_Ray["ray.io<br/>rayclusters, rayjobs, rayservices<br/>Verbs: create,get,list,patch,delete"]
        Runner_CF["workload.codeflare.dev<br/>appwrappers (+finalizers, status)<br/>Verbs: full CRUD + watch"]
        Runner_Argo["argoproj.io<br/>workflows, workflowtaskresults<br/>Verbs: get,list,watch,create,patch"]
        Runner_Core["core<br/>pods, pods/log: get,list,watch<br/>secrets, configmaps: get,create<br/>events: create,patch"]
    end

    R_Runner -->|grants access to| Runner_KServe
    R_Runner -->|grants access to| Runner_Ray
    R_Runner -->|grants access to| Runner_CF
    R_Runner -->|grants access to| Runner_Argo
    R_Runner -->|grants access to| Runner_Core

    subgraph AuthDelegResources["system:auth-delegator Permissions"]
        AuthDeleg_Res["authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews<br/>Verbs: create"]
    end

    CR_AuthDeleg -->|grants access to| AuthDeleg_Res

    %% Styling
    style SA_DSPO fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_Envoy fill:#4a90e2,stroke:#333,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,color:#fff

    style CR_Manager fill:#f5a623,stroke:#333
    style CR_AuthDeleg fill:#f5a623,stroke:#333
    style R_Pipeline fill:#f5a623,stroke:#333
    style R_Runner fill:#f5a623,stroke:#333

    style CRB_Manager fill:#9b59b6,stroke:#333,color:#fff
    style CRB_AuthDeleg fill:#9b59b6,stroke:#333,color:#fff
    style RB_Pipeline fill:#9b59b6,stroke:#333,color:#fff
    style RB_Runner fill:#9b59b6,stroke:#333,color:#fff

    style DSPA_Res fill:#7ed321,stroke:#333
    style Core_Res fill:#7ed321,stroke:#333
    style Apps_Res fill:#7ed321,stroke:#333
    style RBAC_Res fill:#7ed321,stroke:#333
    style Route_Res fill:#7ed321,stroke:#333
    style NetPol_Res fill:#7ed321,stroke:#333
    style Argo_Res fill:#7ed321,stroke:#333
    style KFP_Res fill:#7ed321,stroke:#333
    style KF_Res fill:#7ed321,stroke:#333
    style Webhook_Res fill:#7ed321,stroke:#333
    style Monitor_Res fill:#7ed321,stroke:#333
    style Auth_Res fill:#7ed321,stroke:#333

    style Runner_KServe fill:#1abc9c,stroke:#333
    style Runner_Ray fill:#1abc9c,stroke:#333
    style Runner_CF fill:#1abc9c,stroke:#333
    style Runner_Argo fill:#1abc9c,stroke:#333
    style Runner_Core fill:#1abc9c,stroke:#333

    style AuthDeleg_Res fill:#e67e22,stroke:#333,color:#fff
