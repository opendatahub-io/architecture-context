/*
 * C4 Context Diagram: llama-stack-provider-ragas
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/llama-stack-provider-ragas.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits LLM evaluation jobs via Llama Stack eval API"

        ragasProvider = softwareSystem "llama-stack-provider-ragas" "Ragas evaluation provider for Llama Stack, supporting inline and remote (KFP) execution modes" {
            inlineProvider = container "RagasEvaluatorInline" "Executes Ragas evaluation in-process within the Llama Stack server" "Python Plugin"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluation as Kubeflow Pipeline runs" "Python Plugin"
            inlineLLMWrapper = container "LlamaStackInlineLLM" "Adapts Llama Stack async inference API to Ragas BaseRagasLLM interface" "Python Wrapper"
            inlineEmbedWrapper = container "LlamaStackInlineEmbeddings" "Adapts Llama Stack async embeddings API to Ragas BaseRagasEmbeddings" "Python Wrapper"
            remoteLLMWrapper = container "LlamaStackRemoteLLM" "Adapts Llama Stack client to Ragas BaseRagasLLM for KFP pods" "Python Wrapper"
            remoteEmbedWrapper = container "LlamaStackRemoteEmbeddings" "Adapts Llama Stack client to Ragas BaseRagasEmbeddings for KFP pods" "Python Wrapper"
            kfpPipeline = container "ragas_evaluation_pipeline" "Two-step KFP pipeline: retrieve data, run evaluation" "KFP Pipeline"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts eval, inference, datasetio, and embeddings APIs" "Internal RHOAI" {
            tags "Internal"
        }

        llamaStackOperator = softwareSystem "llama-stack-k8s-operator" "Deploys and manages Llama Stack distributions via CRDs" "Internal RHOAI" {
            tags "Internal"
        }

        kfp = softwareSystem "Data Science Pipelines (Kubeflow Pipelines)" "Executes ML pipeline runs on OpenShift" "Internal RHOAI" {
            tags "Internal"
        }

        trustyaiOperator = softwareSystem "trustyai-service-operator" "Provides ConfigMap with KFP component base image name" "Internal RHOAI" {
            tags "Internal"
        }

        inferenceBackend = softwareSystem "Inference Backend (Ollama/vLLM)" "Provides LLM completions and embeddings" "External" {
            tags "External"
        }

        s3 = softwareSystem "S3-compatible Storage" "Stores evaluation results" "External" {
            tags "External"
        }

        k8sAPI = softwareSystem "Kubernetes API" "Provides ConfigMap and service account access" "External" {
            tags "External"
        }

        /* Relationships */
        user -> ragasProvider "Submits eval jobs via" "HTTP/8321"
        ragasProvider -> llamaStackServer "Plugin hosted within" "In-process"
        llamaStackOperator -> llamaStackServer "Deploys and manages" "LlamaStackDistribution CR"
        ragasProvider -> kfp "Submits pipeline runs" "HTTPS/443, Bearer Token"
        ragasProvider -> inferenceBackend "LLM completions and embeddings" "HTTP/11434"
        ragasProvider -> s3 "Stores/retrieves evaluation results" "HTTPS/443, AWS IAM"
        ragasProvider -> k8sAPI "Reads ConfigMaps, kube config" "HTTPS/6443, SA Token"
        ragasProvider -> trustyaiOperator "Reads ConfigMap for base image" "HTTPS/6443 via K8s API"
        kfp -> llamaStackServer "KFP pods call back for data/inference" "HTTP/8321"
        kfp -> s3 "KFP pods write results" "HTTPS/443, AWS IAM"

        inlineProvider -> inlineLLMWrapper "Uses for LLM calls"
        inlineProvider -> inlineEmbedWrapper "Uses for embeddings"
        remoteProvider -> kfpPipeline "Submits pipeline"
        kfpPipeline -> remoteLLMWrapper "Uses in KFP pods"
        kfpPipeline -> remoteEmbedWrapper "Uses in KFP pods"
    }

    views {
        systemContext ragasProvider "SystemContext" {
            include *
            autoLayout
        }

        container ragasProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
