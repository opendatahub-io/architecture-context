%% TrustyAI Service Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        TASRoute["TrustyAI Route<br/>443/TCP → 8443/TCP<br/>TLS Edge"]
        GORCHRoute["GuardrailsOrchestrator Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        GORCHHealth["GORCH Health Route<br/>443/TCP → 8034/TCP<br/>TLS Edge"]
        GORCHGateway["GORCH Gateway Route<br/>443/TCP → 8033/TCP<br/>TLS Edge/Reencrypt"]
        NEMORoute["NemoGuardrails Route<br/>443/TCP → 8443/8080<br/>TLS Edge/Reencrypt"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>TLS Edge"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph AuthProxy["kube-rbac-proxy Sidecars"]
            KRBAC_TAS["kube-rbac-proxy (TAS)<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
            KRBAC_GORCH["kube-rbac-proxy (GORCH)<br/>8443/TCP HTTPS<br/>Conditional auth"]
            KRBAC_NEMO["kube-rbac-proxy (NEMO)<br/>8443/TCP HTTPS<br/>Conditional auth"]
            KRBAC_EVAL["kube-rbac-proxy (EvalHub)<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        end

        subgraph Apps["Application Containers"]
            TAS["TrustyAI Service<br/>8080/TCP HTTP"]
            GORCH["GuardrailsOrchestrator<br/>8080/TCP HTTP<br/>8034 health, 8033 gw, 8032 detector"]
            NEMO["NeMo Guardrails Server<br/>8080/TCP HTTP"]
            EvalHub["EvalHub<br/>8080/TCP HTTP<br/>127.0.0.1 only"]
            LMEval["LMEval Pod + Driver<br/>Ephemeral Job"]
        end

        subgraph Operator["Operator Manager"]
            OpMgr["Controller Manager<br/>SA: controller-manager<br/>8081/TCP health, 8080/TCP metrics"]
        end
    end

    subgraph PlatformServices["INTERNAL PLATFORM SERVICES"]
        KServe["KServe InferenceServices<br/>HTTP/HTTPS<br/>TLS configurable"]
        Istio["Istio Service Mesh<br/>DestinationRules<br/>VirtualServices"]
        Kueue["Kueue<br/>Workload scheduling"]
        Prometheus["Prometheus<br/>ServiceMonitors<br/>8080/TCP HTTP"]
        MLFlow["MLFlow Server<br/>HTTPS<br/>TLS (Service CA)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>DB credentials"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>DockerConfig"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS"| TASRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS"| NEMORoute
    Client -->|"HTTPS/443<br/>TLS"| EvalHubRoute

    %% Ingress to Auth Proxy
    TASRoute -->|"HTTPS/8443<br/>service-serving-cert<br/>Bearer Token"| KRBAC_TAS
    GORCHRoute -->|"HTTPS/8443<br/>service-serving-cert<br/>Bearer Token"| KRBAC_GORCH
    NEMORoute -->|"HTTPS/8443<br/>service-serving-cert"| KRBAC_NEMO
    EvalHubRoute -->|"HTTPS/8443<br/>service-serving-cert<br/>Bearer Token"| KRBAC_EVAL

    %% Auth Proxy to Apps
    KRBAC_TAS -->|"HTTP/8080<br/>localhost"| TAS
    KRBAC_GORCH -->|"HTTP/8080<br/>localhost"| GORCH
    KRBAC_NEMO -->|"HTTP/8080<br/>localhost"| NEMO
    KRBAC_EVAL -->|"HTTP/8080<br/>127.0.0.1"| EvalHub

    %% Apps to Platform
    TAS -->|"HTTP/HTTPS<br/>TLS configurable"| KServe
    GORCH -->|"HTTP/HTTPS<br/>auto-detected TLS"| KServe
    EvalHub -->|"HTTPS<br/>SA projected token"| MLFlow
    OpMgr -->|"HTTPS/6443<br/>SA Token"| K8sAPI

    %% Apps to External
    TAS -->|"TCP/5432<br/>TLS optional<br/>DB credentials"| PostgreSQL
    EvalHub -->|"TCP/5432<br/>TLS Service CA<br/>DB credentials"| PostgreSQL
    LMEval -->|"HTTPS/443<br/>TLS 1.2+<br/>Access Key"| S3
    LMEval -->|"HTTPS/443<br/>TLS 1.2+<br/>DockerConfig"| OCI
    LMEval -->|"HTTP/HTTPS<br/>API Key"| KServe

