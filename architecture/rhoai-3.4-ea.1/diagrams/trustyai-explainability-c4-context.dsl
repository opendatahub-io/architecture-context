// TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Configures fairness metrics and monitors model bias/drift"
        sre = person "SRE / Platform Admin" "Monitors TrustyAI metrics via Prometheus dashboards"

        trustyai = softwareSystem "TrustyAI Explainability" "AI fairness, bias tracking, drift detection, and explainability service" {
            service = container "explainability-service" "Quarkus REST microservice exposing fairness, drift, and explainability APIs" "Java 17 / Quarkus 3.8.5"
            core = container "explainability-core" "Core XAI algorithms: LIME, SHAP, Counterfactual, SPD, DIR, KS Test, Meanshift, Fourier MMD" "Java Library"
            connectors = container "explainability-connectors" "KServe V2 gRPC inference protocol client" "Java Library / gRPC"
            arrow = container "explainability-arrow" "Apache Arrow bridge for Java-Python interoperability" "Java Library"
            scheduler = container "PrometheusScheduler" "Periodically computes scheduled metrics and publishes Prometheus gauges" "Internal Component"

            service -> core "Uses algorithms from"
            service -> connectors "Uses gRPC client from"
            service -> arrow "Uses Arrow bridge from"
            service -> scheduler "Triggers scheduled computation"
        }

        modelmesh = softwareSystem "ModelMesh Serving" "Model serving platform with payload processing" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Kubernetes-native model inference platform" "Internal RHOAI"
        inferenceServer = softwareSystem "KServe/ModelMesh Inference Server" "Serves ML model predictions" "Internal RHOAI"
        operator = softwareSystem "TrustyAI Service Operator" "Manages TrustyAI service lifecycle and deployment" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        knative = softwareSystem "Knative Eventing" "CloudEvent-based event delivery" "External"
        minio = softwareSystem "MinIO / S3" "Object storage for inference data" "External"
        mariadb = softwareSystem "MariaDB / MySQL" "Relational database for inference data" "External"
        pvc = softwareSystem "PersistentVolumeClaim" "Default CSV flat-file storage" "Infrastructure"

        // User interactions
        datascientist -> trustyai "Configures fairness/drift metrics, uploads ground truths" "REST API / HTTPS 8443"
        sre -> prometheus "Views TrustyAI dashboards"

        // Inbound data flows
        modelmesh -> trustyai "Sends inference payloads" "HTTP/80 (payload processor callback)"
        kserve -> knative "Emits inference events" "CloudEvents"
        knative -> trustyai "Delivers inference events" "HTTP/8080 CloudEvents"

        // Outbound flows
        trustyai -> inferenceServer "Calls model for explainability" "gRPC KServe V2"
        trustyai -> pvc "Stores/reads inference data" "File I/O"
        trustyai -> minio "Stores/reads inference data" "HTTPS/443 S3 API"
        trustyai -> mariadb "Stores/reads inference data" "MySQL/3306"
        prometheus -> trustyai "Scrapes metrics" "HTTP/8080 GET /q/metrics"

        // Operator management
        operator -> trustyai "Manages lifecycle, injects auth sidecars" "Kubernetes API"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
