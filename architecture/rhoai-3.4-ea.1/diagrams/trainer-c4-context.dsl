// C4 Context Diagram - Kubeflow Trainer
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/trainer.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits and manages distributed training jobs"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes-native operator for distributed ML training job orchestration (PyTorch, MPI, DeepSpeed)" {
            controllerManager = container "trainer-controller-manager" "Reconciles TrainJob CRs, creates JobSets, manages NetworkPolicies, tracks progression" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates TrainJob, TrainingRuntime, ClusterTrainingRuntime on CREATE/UPDATE" "Admission Webhook (9443/TCP)"
            certManager = container "Certificate Manager" "Auto-generates and rotates TLS certificates for webhook server" "cert-controller (OPA)"
            progressionTracker = container "Progression Tracker" "Polls training pod metrics, writes progress annotations (RHAI feature)" "Go Component"
            networkPolicyMgr = container "NetworkPolicy Manager" "Creates per-TrainJob NetworkPolicy for pod isolation (RHAI feature)" "Go Component"
            runtimePlugins = container "Runtime Framework" "JobSet, Coscheduling, Volcano plugins for translating runtime specs" "Go Plugins"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        jobsetCtrl = softwareSystem "JobSet Controller" "Manages JobSet lifecycle and training pod groups (sigs.k8s.io/jobset v0.10.1)" "External"
        schedulerPlugins = softwareSystem "Scheduler-Plugins" "Coscheduling PodGroup support for gang-scheduling (optional)" "External"
        volcano = softwareSystem "Volcano" "Volcano PodGroup support for gang-scheduling (optional)" "External"
        kueue = softwareSystem "Kueue" "Multi-cluster job management (optional, via managedBy field)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys trainer manifests from manifests/rhoai/" "Internal RHOAI"

        // User interactions
        user -> trainer "Creates TrainJob CRs via kubectl/SDK"

        // Internal container relationships
        controllerManager -> webhookServer "Validates resources"
        controllerManager -> certManager "Manages webhook TLS certs"
        controllerManager -> progressionTracker "Polls training metrics"
        controllerManager -> networkPolicyMgr "Creates NetworkPolicies"
        controllerManager -> runtimePlugins "Translates runtime specs"

        // External dependencies
        trainer -> k8sAPI "CRUD operations on JobSets, PodGroups, NetworkPolicies, Secrets, ConfigMaps" "HTTPS/443, TLS 1.2+, ServiceAccount Token"
        trainer -> jobsetCtrl "Creates JobSet CRs to manage training pod groups" "CRD"
        trainer -> schedulerPlugins "Creates PodGroup for gang-scheduling" "CRD (optional)"
        trainer -> volcano "Creates PodGroup for Volcano gang-scheduling" "CRD (optional)"
        trainer -> kueue "Delegates job management via managedBy field" "CRD (optional)"

        // Internal RHOAI integrations
        prometheus -> trainer "Scrapes controller metrics" "HTTPS/8443, TLS (self-signed), PodMonitor"
        rhoaiOperator -> trainer "Deploys manifests" "Kustomize"

        // Webhook flow
        k8sAPI -> trainer "Sends admission review requests" "HTTPS/9443, TLS (self-signed)"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
