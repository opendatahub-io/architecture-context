/*
 * C4 Context Diagram - Kubeflow Trainer
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/trainer.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages distributed training jobs"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes-native operator for distributed ML training (PyTorch, JAX, TensorFlow, DeepSpeed, Megatron-LM)" {
            controller = container "Trainer Controller Manager" "Reconciles TrainJob, TrainingRuntime, ClusterTrainingRuntime CRDs; creates JobSet resources, NetworkPolicies; polls progression metrics" "Go Operator (controller-runtime)"
            webhook = container "Validating Webhooks" "Validates TrainJob, TrainingRuntime, ClusterTrainingRuntime on CREATE/UPDATE" "HTTPS/9443"
            progressionTracker = container "RHAI Progression Tracking" "Polls HTTP metrics from training pods, stores progress in TrainJob annotations" "Go Module"
            networkPolicyMgr = container "RHAI NetworkPolicy Manager" "Creates per-TrainJob NetworkPolicies for pod isolation and controller-only metrics access" "Go Module"
        }

        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (v4.19-v4.21)" "External"
        jobset = softwareSystem "JobSet Controller" "Manages replicated job groups for distributed training (v0.10.1)" "External"
        schedulerPlugins = softwareSystem "Scheduler Plugins" "Co-scheduling via PodGroup for gang scheduling (v0.34.1)" "External"
        volcano = softwareSystem "Volcano" "Alternative co-scheduling via Volcano PodGroup (v1.13.1)" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and monitoring" "External"

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys trainer manifests via kustomize overlay" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "User interface for managing ML workloads" "Internal RHOAI"
        trainingImages = softwareSystem "Training Runtime Images" "CUDA 12.8 / ROCm 6.4 + PyTorch 2.9 container images" "Internal RHOAI"

        # Relationships
        user -> trainer "Creates TrainJob CRs via kubectl / dashboard"
        user -> odhDashboard "Manages training jobs via UI"
        odhDashboard -> trainer "Creates TrainJob CRs" "HTTPS/443 via K8s API"

        trainer -> kubernetes "CRUD on TrainJob, JobSet, NetworkPolicy, PodGroup resources" "HTTPS/443"
        trainer -> jobset "Creates JobSet CRs for workload execution" "Kubernetes API"
        trainer -> schedulerPlugins "Creates PodGroup CRs for gang scheduling" "Kubernetes API"
        trainer -> volcano "Creates Volcano PodGroup CRs (alternative)" "Kubernetes API"
        prometheus -> trainer "Scrapes controller metrics" "HTTPS/8443"

        rhodsOperator -> trainer "Deploys CRDs, RBAC, controller, runtimes" "Kustomize"
        trainer -> trainingImages "References in ClusterTrainingRuntimes" "Container Registry"

        # Container relationships
        controller -> webhook "Validates CRs via" "HTTPS/9443"
        controller -> progressionTracker "Polls training metrics" "Internal"
        controller -> networkPolicyMgr "Creates NetworkPolicies" "Internal"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
