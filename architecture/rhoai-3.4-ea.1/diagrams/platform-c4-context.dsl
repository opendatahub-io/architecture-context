// C4 Context Diagram - Red Hat OpenShift AI 3.4.0-ea.1
// Generated by Claude Opus 4.6

workspace {
    model {
        // Personas
        dataScientist = person "Data Scientist" "Develops ML models, runs experiments, creates pipelines"
        mlEngineer = person "ML Engineer" "Deploys and manages models in production, configures serving"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform, configures components"
        apiClient = person "API Client" "Consumes model inference endpoints"

        // Core Platform
        rhoai = softwareSystem "Red Hat OpenShift AI" "Comprehensive AI/ML platform on OpenShift for the complete ML lifecycle" {
            rhodsOperator = container "rhods-operator" "Platform lifecycle operator; deploys 17+ sub-components via kustomize" "Go Operator (OLM)"
            dashboard = container "odh-dashboard" "Primary web UI for RHOAI" "React + Fastify BFF"

            // Model Serving
            kserve = container "KServe" "Model serving operator (InferenceService, LLMInferenceService)" "Go Operator"
            odhModelController = container "odh-model-controller" "Reconciles auth, monitoring, networking for InferenceServices" "Go Operator"
            llmdScheduler = container "llm-d Inference Scheduler" "KV-cache-aware inference request routing (EPP + ext-proc)" "Go Service"
            vllm = container "vLLM Runtimes" "CPU and Gaudi HPU-optimized LLM inference (OpenAI-compatible)" "Python Runtime"
            openvino = container "OpenVINO Model Server" "Intel OpenVINO model serving" "C++ Runtime"
            mlserver = container "MLServer" "Python inference server (KServe V2)" "Python Runtime"

            // ML Pipelines
            dspo = container "DSP Operator" "Deploys DSP stack (API server, Argo, MLMD, MariaDB, MinIO)" "Go Operator"
            dspApi = container "DSP API Server" "Kubeflow Pipelines v2 API" "Go Service"
            argoWorkflows = container "Argo Workflows" "Container-native workflow execution" "Go Service"
            mlMetadata = container "ml-metadata" "ML metadata store for artifact lineage" "C++ gRPC Service"

            // Model Management
            modelRegistryOp = container "Model Registry Operator" "Deploys Model Registry instances" "Go Operator"
            modelRegistry = container "Model Registry" "Central REST API for ML model metadata" "Go Service"
            mlflowOp = container "MLflow Operator" "Deploys MLflow tracking server instances" "Go Operator"
            mlflow = container "MLflow" "ML experiment tracking and model registry" "Python Service"

            // Workbenches
            odhNotebookController = container "ODH Notebook Controller" "Gateway API ingress, auth sidecars for notebooks" "Go Operator"
            notebooks = container "Notebook Workbenches" "Jupyter, Code Server, RStudio (18 images)" "Container Images"
            kubeAuthProxy = container "kube-auth-proxy" "FIPS-compliant OAuth2/OIDC + RBAC auth proxy" "Go Sidecar"

            // Distributed Training
            trainingOperator = container "Training Operator" "PyTorchJob, TFJob, MPIJob, etc." "Go Operator"
            trainer = container "Trainer v2" "TrainJob, ClusterTrainingRuntime" "Go Operator"
            kuberay = container "KubeRay" "RayCluster, RayJob, RayService" "Go Operator"
            sparkOperator = container "Spark Operator" "SparkApplication management" "Go Operator"

            // AI Safety
            trustyaiOp = container "TrustyAI Service Operator" "Multi-controller operator (5 services)" "Go Operator"
            trustyai = container "TrustyAI Explainability" "Fairness, bias, drift detection (LIME, SHAP)" "Java Service"
            fmsOrchestrator = container "FMS Guardrails Orchestrator" "Content safety orchestrator for LLM guardrails" "Rust Service"
            nemoGuardrails = container "NeMo Guardrails" "Programmable guardrails (Colang)" "Python Service"
            evalHub = container "Eval Hub" "Unified REST API for LLM evaluations" "Go Service"

            // New in 3.4
            feastOp = container "Feast Operator" "Feature store operator" "Go Operator"
            llamaStackOp = container "Llama Stack Operator" "Deploys Llama Stack distributions" "Go Operator"
            batchGateway = container "Batch Gateway" "OpenAI Batch API with multi-tenancy" "Go Service"
            maas = container "Models-as-a-Service" "Tiered LLM access with API key lifecycle" "Go Service"
            wva = container "Workload Variant Autoscaler" "LLM-aware autoscaling" "Go Operator"
        }

        // External Systems
        ocp = softwareSystem "OpenShift Container Platform" "Kubernetes platform (v4.19-4.21)" "External"
        gatewayApi = softwareSystem "Gateway API" "data-science-gateway for HTTPRoute-based ingress" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Manages operator installation and upgrades" "External"
        prometheus = softwareSystem "Prometheus / Thanos" "Metrics collection and querying" "External"
        kueue = softwareSystem "Kueue" "Job queuing and resource quota management" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Auth policies and rate limiting" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "MinIO, AWS S3, GCS for artifacts and models" "External"
        databases = softwareSystem "Databases" "PostgreSQL, MariaDB, MySQL for metadata" "External"
        redis = softwareSystem "Redis" "Job queue and feature store backend" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model downloads and catalog" "External"
        containerRegistries = softwareSystem "Container Registries" "quay.io, registry.redhat.io (84 images)" "External"

        // Relationships - Users
        dataScientist -> rhoai "Develops models, runs pipelines, creates notebooks"
        mlEngineer -> rhoai "Deploys and manages model serving"
        platformAdmin -> rhoai "Configures platform via DataScienceCluster CR"
        apiClient -> rhoai "Sends inference requests"

        // Relationships - User to containers
        dataScientist -> dashboard "Manages projects via web UI" "HTTPS/443"
        dataScientist -> notebooks "Develops models" "HTTPS/443"
        dataScientist -> dspApi "Creates pipelines" "HTTPS/8443"
        mlEngineer -> kserve "Deploys InferenceService CRs" "kubectl"
        mlEngineer -> modelRegistry "Registers model versions" "HTTPS/8443"
        apiClient -> vllm "Model inference" "HTTP/8000"

        // Relationships - Internal
        rhodsOperator -> kserve "Deploys" "kustomize"
        rhodsOperator -> dspo "Deploys" "kustomize"
        rhodsOperator -> odhNotebookController "Deploys" "kustomize"
        rhodsOperator -> trainingOperator "Deploys" "kustomize"
        rhodsOperator -> trustyaiOp "Deploys" "kustomize"
        rhodsOperator -> feastOp "Deploys" "kustomize"
        rhodsOperator -> llamaStackOp "Deploys" "kustomize"
        rhodsOperator -> mlflowOp "Deploys" "kustomize"
        rhodsOperator -> dashboard "Deploys" "kustomize"

        kserve -> vllm "Deploys serving runtime"
        kserve -> openvino "Deploys serving runtime"
        kserve -> mlserver "Deploys serving runtime"
        kserve -> llmdScheduler "LLM request routing" "gRPC ext-proc"
        kserve -> odhModelController "Co-manages InferenceServices"

        dspo -> dspApi "Deploys"
        dspo -> argoWorkflows "Deploys"
        dspo -> mlMetadata "Deploys"
        dspApi -> modelRegistry "Artifact tracking" "REST/8443"
        dspApi -> kserve "Model deployment" "K8s API"

        trustyaiOp -> trustyai "Deploys"
        trustyaiOp -> fmsOrchestrator "Deploys"
        trustyaiOp -> nemoGuardrails "Deploys"
        trustyaiOp -> evalHub "Deploys"

        fmsOrchestrator -> vllm "Guardrailed inference" "HTTP/8000"

        dashboard -> kserve "Model serving management" "K8s API"
        dashboard -> modelRegistry "Model catalog" "REST/8443"
        dashboard -> mlflow "Experiment tracking" "REST/8443"
        dashboard -> dspApi "Pipeline management" "REST/8443"

        maas -> kserve "LLM discovery" "K8s API"
        batchGateway -> llmdScheduler "Batch inference" "HTTP"
        wva -> prometheus "LLM metrics query" "PromQL"
        evalHub -> mlflow "Logs evaluation metrics" "REST"

        // Relationships - External
        rhoai -> gatewayApi "Ingress for all HTTP services" "HTTPRoute/443"
        rhoai -> ocp "Runs on" "K8s API"
        rhodsOperator -> olm "Managed by" "OLM lifecycle"
        rhoai -> s3Storage "Model/artifact storage" "HTTPS/443"
        rhoai -> databases "Metadata persistence" "SQL/5432,3306"
        batchGateway -> redis "Job queue" "Redis/6379"
        rhoai -> huggingface "Model downloads" "HTTPS/443"
        rhoai -> containerRegistries "Image pull (84 images)" "HTTPS/443"
        rhoai -> prometheus "Metrics export" "HTTP/8080,8443"
        trainingOperator -> kueue "Job queuing" "K8s API"
        maas -> kuadrant "Auth policies" "K8s API"
        odhNotebookController -> kubeAuthProxy "Auth sidecar injection"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Go Operator" {
                background #4a90e2
            }
            element "Go Service" {
                background #3498db
            }
            element "Python Service" {
                background #2ecc71
            }
            element "Python Runtime" {
                background #27ae60
            }
            element "Rust Service" {
                background #e74c3c
            }
            element "Go Sidecar" {
                background #f39c12
            }
        }
    }
}
