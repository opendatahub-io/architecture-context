/*
 * C4 Context Diagram - Red Hat OpenShift AI 3.4-ea.1 Platform
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-16
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Develops, trains, and deploys ML models using RHOAI platform"
        mlEngineer = person "ML Engineer" "Builds pipelines, manages model serving, and monitors model performance"
        platformAdmin = person "Platform Admin" "Configures and manages the RHOAI platform components"

        rhoai = softwareSystem "Red Hat OpenShift AI" "Comprehensive AI/ML platform on OpenShift for end-to-end ML lifecycle" {

            rhodsOperator = container "RHODS Operator" "Central orchestrator managing lifecycle of all RHOAI components, gateway, auth, and monitoring" "Go Operator (OLM)" "Platform Operator"
            gateway = container "data-science-gateway" "Central Gateway API ingress for all RHOAI services with TLS termination" "Gateway API + EnvoyFilter" "Ingress"
            kubeAuthProxy = container "kube-auth-proxy" "Centralized OAuth2/OIDC authentication for gateway-routed services" "Go Service" "Auth"

            dashboard = container "ODH Dashboard" "Primary web UI with federated module architecture (Model Registry, Gen AI, MaaS)" "React + Node.js BFF" "Web App"
            notebookCtrl = container "ODH Notebook Controller" "Extends Kubeflow Notebooks with Gateway API ingress, kube-rbac-proxy, CA bundles" "Go Operator" "Controller"
            kserve = container "KServe" "Model serving controller for InferenceService and LLMInferenceService workloads" "Go Operator" "Core"
            modelCtrl = container "odh-model-controller" "Bridges KServe with RHOAI platform features (Routes, NetworkPolicies, NIM, AuthPolicies)" "Go Operator" "Controller"
            dspo = container "Data Science Pipelines Operator" "Manages Kubeflow Pipelines V2 stack (API server, Argo, MLMD, storage) per namespace" "Go Operator" "Pipelines"
            modelRegOp = container "Model Registry Operator" "Manages Model Registry and Model Catalog instances with PostgreSQL/MySQL backends" "Go Operator" "Registry"
            kuberay = container "KubeRay Operator" "Manages Ray distributed computing clusters (RayCluster, RayJob, RayService)" "Go Operator" "Compute"
            trainingOp = container "Training Operator" "Distributed ML training jobs (PyTorch, TensorFlow, MPI, XGBoost, Paddle, JAX)" "Go Operator" "Training"
            trainer = container "Trainer" "Next-gen training orchestration with TrainJob, JobSet integration" "Go Operator" "Training"
            feast = container "Feast Operator" "Manages Feast feature store deployments for ML feature serving" "Go Operator" "Feature Store"
            trustyai = container "TrustyAI Operator" "AI trustworthiness: explainability, LLM eval, guardrails, NeMo, EvalHub" "Go Operator" "AI Safety"
            sparkOp = container "Spark Operator" "Apache Spark application lifecycle management on Kubernetes" "Go Operator" "Compute"
            llamastack = container "LlamaStack Operator" "Manages LlamaStack AI server distributions for unified inference APIs" "Go Operator" "AI Infrastructure"
        }

        /* External Dependencies */
        ocp = softwareSystem "OpenShift Container Platform" "Kubernetes platform with Routes, OAuth, service-ca, monitoring" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS, traffic management, VirtualService routing" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform for KServe serverless mode" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate lifecycle management" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling with OpenTelemetry metrics" "External"
        kueue = softwareSystem "Kueue" "Job queuing and scheduling for ML workloads" "External"
        volcano = softwareSystem "Volcano" "Gang scheduling for distributed training" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "API authentication and authorization for Gateway API" "External"

        /* External Storage */
        s3 = softwareSystem "S3-Compatible Storage" "Object storage for model artifacts, pipeline data, feature data" "External Storage"
        postgresql = softwareSystem "PostgreSQL" "Relational database for model registry and evaluation data" "External Storage"
        mariadb = softwareSystem "MariaDB" "Relational database for pipeline metadata" "External Storage"
        ociRegistry = softwareSystem "OCI Container Registry" "Container image and Modelcar OCI artifact storage" "External Storage"

        /* External APIs */
        nimApi = softwareSystem "NVIDIA NIM API" "NVIDIA NGC API for NIM model catalog and API key validation" "External API"
        oauthProvider = softwareSystem "OAuth/OIDC Provider" "External identity provider for user authentication" "External API"

        /* User relationships */
        dataScientist -> rhoai "Develops models, runs experiments, creates inference endpoints"
        mlEngineer -> rhoai "Builds pipelines, manages serving, monitors models"
        platformAdmin -> rhoai "Configures platform, manages components"

        dataScientist -> dashboard "Accesses via browser" "HTTPS/443"
        mlEngineer -> dspo "Submits pipelines" "HTTPS/443"
        mlEngineer -> kserve "Creates InferenceService" "kubectl/API"

        /* Internal relationships */
        rhodsOperator -> gateway "Creates and manages" "Gateway API"
        rhodsOperator -> kubeAuthProxy "Creates and manages"
        rhodsOperator -> dashboard "Deploys via kustomize"
        rhodsOperator -> notebookCtrl "Deploys via kustomize"
        rhodsOperator -> kserve "Deploys via kustomize"
        rhodsOperator -> modelCtrl "Deploys via kustomize"
        rhodsOperator -> dspo "Deploys via kustomize"
        rhodsOperator -> modelRegOp "Deploys via kustomize"
        rhodsOperator -> kuberay "Deploys via kustomize"
        rhodsOperator -> trainingOp "Deploys via kustomize"
        rhodsOperator -> trainer "Deploys via kustomize"
        rhodsOperator -> feast "Deploys via kustomize"
        rhodsOperator -> trustyai "Deploys via kustomize"
        rhodsOperator -> sparkOp "Deploys via kustomize"
        rhodsOperator -> llamastack "Deploys via kustomize"

        dashboard -> modelRegOp "Queries model metadata" "REST/HTTPS"
        dashboard -> kserve "Reads InferenceService CRDs"
        dashboard -> dspo "Reads Pipeline CRDs"
        dashboard -> notebookCtrl "CRUD Notebook CRDs"

        kserve -> istio "Traffic routing, mTLS" "VirtualService"
        kserve -> knative "Serverless autoscaling" "Knative Service"
        kserve -> certManager "Webhook TLS certificates"
        kserve -> keda "Custom autoscaling" "OpenTelemetry/4317"
        kserve -> s3 "Downloads model artifacts" "HTTPS/443"
        kserve -> ociRegistry "Pulls Modelcar OCI images" "HTTPS/443"

        modelCtrl -> kserve "Watches InferenceService CRDs"
        modelCtrl -> modelRegOp "Syncs model metadata" "REST/HTTPS"
        modelCtrl -> kuadrant "AuthPolicy for LLMInferenceService"
        modelCtrl -> nimApi "NIM API key validation" "HTTPS/443"

        dspo -> s3 "Stores pipeline artifacts" "HTTPS/443"
        dspo -> mariadb "Pipeline metadata" "TCP/3306"

        modelRegOp -> postgresql "Model metadata storage" "TCP/5432"

        kuberay -> certManager "mTLS certificates for Ray clusters"
        kuberay -> gateway "Ray Dashboard HTTPRoute" "Gateway API"

        trainingOp -> volcano "Gang scheduling"
        trainer -> volcano "Gang scheduling"
        trustyai -> kueue "LMEval workload scheduling"
        trustyai -> kserve "Watches/patches InferenceServices"
        trustyai -> s3 "Evaluation data and results" "HTTPS/443"
        trustyai -> postgresql "EvalHub database" "TCP/5432"

        feast -> postgresql "Feature store persistence" "TCP/5432"
        feast -> s3 "Registry file persistence" "HTTPS/443"

        kubeAuthProxy -> oauthProvider "User authentication" "HTTPS/443"

        notebookCtrl -> gateway "Notebook HTTPRoute" "Gateway API"
        feast -> notebookCtrl "ConfigMap integration"
    }

    views {
        systemContext rhoai "PlatformContext" {
            include *
            autoLayout
        }

        container rhoai "PlatformContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Storage" {
                background #e67e22
                color #ffffff
            }
            element "External API" {
                background #8e44ad
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Platform Operator" {
                background #e74c3c
                color #ffffff
            }
            element "Ingress" {
                background #f39c12
                color #ffffff
            }
            element "Auth" {
                background #f39c12
                color #ffffff
            }
            element "Web App" {
                background #3498db
                color #ffffff
            }
            element "Core" {
                background #2ecc71
                color #ffffff
            }
            element "Controller" {
                background #3498db
                color #ffffff
            }
            element "Training" {
                background #9b59b6
                color #ffffff
            }
            element "Compute" {
                background #1abc9c
                color #ffffff
            }
            element "AI Safety" {
                background #e74c3c
                color #ffffff
            }
        }
    }
}
