/*
 * C4 Context Diagram: model-metadata-collection
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/model-metadata-collection.md
 */

workspace {
    model {
        cicdEngineer = person "CI/CD Engineer" "Configures and triggers catalog build pipelines"
        dataScientist = person "Data Scientist" "Browses AI model catalog in Dashboard"

        modelMetadataCollection = softwareSystem "Model Metadata Collection" "Build-time tool that extracts, enriches, and catalogs metadata from Red Hat AI ModelCar images, producing static YAML catalog files in a data container" {
            modelExtractor = container "model-extractor" "Main metadata extraction pipeline - discovers models, fetches OCI layers, parses model cards, enriches with HuggingFace data, generates catalogs" "Go CLI"
            metadataReport = container "metadata-report" "Generates metadata completeness and quality reports" "Go CLI"
            catalogPackage = container "internal/catalog" "Catalog generation, deduplication, merging, tag conversion" "Go Package"
            enrichmentPackage = container "internal/enrichment" "HuggingFace metadata enrichment" "Go Package"
            huggingfacePackage = container "internal/huggingface" "HuggingFace API client" "Go Package"
            registryPackage = container "internal/registry" "OCI container registry interaction" "Go Package"
            metadataPackage = container "internal/metadata" "Model card parsing and format migration" "Go Package"
            dataContainer = container "Data Container" "UBI9-minimal container serving static catalog YAML files at /app/data via volume mount" "Container Image"
        }

        huggingFaceAPI = softwareSystem "HuggingFace API" "Public API for model discovery, metadata, and README content" "External"
        redHatRegistry = softwareSystem "Red Hat Container Registry" "OCI registry hosting ModelCar images with model cards" "External"
        quayRegistry = softwareSystem "Quay.io Registry" "Container image registry for publishing data container" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI displaying AI model catalog to users" "Internal RHOAI"
        modelsAsAService = softwareSystem "Models as a Service" "Model serving configuration" "Internal RHOAI"
        konfluxCI = softwareSystem "Konflux CI/CD" "Tekton-based CI/CD pipeline" "External"
        githubActions = softwareSystem "GitHub Actions" "CI workflow for static catalog builds" "External"

        # Build-time relationships
        cicdEngineer -> modelMetadataCollection "Triggers catalog build"
        modelMetadataCollection -> huggingFaceAPI "Discovers model collections, fetches metadata" "HTTPS/443"
        modelMetadataCollection -> redHatRegistry "Inspects OCI images, extracts model cards" "HTTPS/443"
        modelMetadataCollection -> quayRegistry "Pushes built data container image" "HTTPS/443"
        konfluxCI -> modelMetadataCollection "Builds container via Tekton pipelines"
        githubActions -> modelMetadataCollection "Builds static catalog data image"

        # Runtime relationships
        odhDashboard -> modelMetadataCollection "Mounts /app/data volume for catalog files" "Volume mount"
        modelsAsAService -> modelMetadataCollection "Consumes catalog data" "Volume mount"
        dataScientist -> odhDashboard "Browses model catalog"

        # Internal container relationships
        modelExtractor -> huggingfacePackage "Uses"
        modelExtractor -> registryPackage "Uses"
        modelExtractor -> metadataPackage "Uses"
        modelExtractor -> enrichmentPackage "Uses"
        modelExtractor -> catalogPackage "Uses"
        enrichmentPackage -> huggingfacePackage "Uses"
        metadataReport -> catalogPackage "Uses"
    }

    views {
        systemContext modelMetadataCollection "SystemContext" {
            include *
            autoLayout
        }

        container modelMetadataCollection "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
