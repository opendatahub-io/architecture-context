%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "KubeRay Operator"
        RayClusterCtrl["RayCluster Controller"]
        RayJobCtrl["RayJob Controller"]
        RayServiceCtrl["RayService Controller"]
        AuthCtrl["Authentication Controller<br/>(RHOAI-specific)"]
        NetPolCtrl["NetworkPolicy Controller<br/>(RHOAI-specific)"]
        mTLSCtrl["mTLS Controller<br/>(RHOAI-specific)"]
        MutWebhook["Mutating Webhook"]
        ValWebhook["Validating Webhook"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% Created Resources
    HeadPod["Head Pod<br/>(6379, 8265, 8000, 10001)"]
    WorkerPods["Worker Pods"]
    HeadSvc["{cluster}-head-svc<br/>ClusterIP"]
    ServeSvc["{cluster}-serve-svc<br/>ClusterIP (8000)"]
    HeadlessSvc["{cluster}-headless<br/>Headless ClusterIP"]
    HTTPRouteCR["HTTPRoute CR<br/>(Gateway API)"]
    KubeRBACProxy["kube-rbac-proxy<br/>sidecar (8443)"]
    NetPols["NetworkPolicies<br/>(head + worker)"]
    Certs["cert-manager<br/>Certificates & Issuers"]

    %% User interaction
    User["User / Data Scientist"] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% Controller watches
    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl
    RayClusterCR -->|watched by| AuthCtrl
    RayClusterCR -->|watched by| NetPolCtrl
    RayClusterCR -->|watched by| mTLSCtrl

    %% RayCluster Controller creates
    RayClusterCtrl -->|creates| HeadPod
    RayClusterCtrl -->|creates| WorkerPods
    RayClusterCtrl -->|creates| HeadSvc
    RayClusterCtrl -->|creates| ServeSvc
    RayClusterCtrl -->|creates| HeadlessSvc

    %% RayJob Controller
    RayJobCtrl -->|creates| RayClusterCR
    RayJobCtrl -->|submits job via| HeadPod

    %% RayService Controller
    RayServiceCtrl -->|manages| RayClusterCR
    RayServiceCtrl -->|configures serve via| HeadPod

    %% RHOAI-specific controllers
    AuthCtrl -->|creates| HTTPRouteCR
    AuthCtrl -->|injects| KubeRBACProxy
    NetPolCtrl -->|creates| NetPols
    mTLSCtrl -->|creates| Certs

    %% Webhooks
    MutWebhook -->|mutates| RayClusterCR
    ValWebhook -->|validates| RayClusterCR

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    CertManager["cert-manager"]
    GatewayAPI["Data Science Gateway<br/>(Gateway API)"]
    Prometheus["Prometheus<br/>8080/TCP"]

    RayClusterCtrl -->|CRUD| K8sAPI
    mTLSCtrl -->|manages| CertManager
    HTTPRouteCR -->|references| GatewayAPI
    HeadPod -->|scraped by| Prometheus

