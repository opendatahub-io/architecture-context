    %% CRDs
    User["User / Data Scientist"] -->|creates| RayClusterCR["RayCluster CR"]
    User -->|creates| RayJobCR["RayJob CR"]
    User -->|creates| RayServiceCR["RayService CR"]

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl
    RayClusterCR -->|watched by| AuthCtrl
    RayClusterCR -->|watched by| NetPolCtrl
    RayClusterCR -->|watched by| mTLSCtrl

    %% Created resources
    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["{cluster}-head-svc<br/>8265, 10001, 6379"]
    RayJobCtrl -->|creates| SubmitterJob["Submitter Job Pod"]

    AuthCtrl -->|creates| HTTPRoute["HTTPRoute CR"]
    AuthCtrl -->|creates| RefGrant["ReferenceGrant CR"]
    AuthCtrl -->|injects| KubeRBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP"]

    NetPolCtrl -->|creates| HeadNetPol["Head NetworkPolicy"]
    NetPolCtrl -->|creates| WorkerNetPol["Worker NetworkPolicy"]

    mTLSCtrl -->|creates| Issuer["cert-manager Issuer"]
    mTLSCtrl -->|creates| Certs["cert-manager Certificates"]

    %% External dependencies
    RayClusterCtrl -->|depends on| K8sAPI["Kubernetes API"]
    AuthCtrl -->|references| DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    mTLSCtrl -->|depends on| CertManager["cert-manager"]

    %% Integration points
    Prometheus["Prometheus"] -->|scrapes| Metrics
    RhodsOp["rhods-operator"] -->|deploys via kustomize| KubeRayOperator

    Webhook -->|validates| RayClusterCR

