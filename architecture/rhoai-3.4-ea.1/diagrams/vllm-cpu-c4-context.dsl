/*
 * vllm-cpu C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/vllm-cpu.md
 */

workspace {
    model {
        user = person "Data Scientist / Application" "Sends inference requests to vLLM"

        vllmCpu = softwareSystem "vLLM-CPU" "CPU-optimized LLM inference engine with OpenAI-compatible API" {
            apiServer = container "OpenAI API Server" "FastAPI/Uvicorn HTTP server providing OpenAI-compatible REST API" "Python FastAPI" "Application"
            grpcServer = container "gRPC Server" "Binary protocol server for efficient communication with llm-d router" "Python gRPC" "Application"
            engine = container "AsyncLLM Engine" "Core inference engine with PagedAttention, continuous batching, and model execution" "Python" "Application"
            cpuKernels = container "CPU Kernels" "Optimized C++ compute kernels for attention, sampling, and tensor operations" "C++/CMake" "Application"
            authMiddleware = container "Auth Middleware" "Bearer token authentication for /v1/* endpoints (SHA-256 comparison)" "Python ASGI" "Security"
            tlsSupport = container "SSL/TLS Support" "TLS termination with certificate hot-reload via file watching" "Python" "Security"
            metrics = container "Prometheus Metrics" "Exposes /metrics endpoint for monitoring" "Python" "Monitoring"
        }

        kserve = softwareSystem "KServe" "Deploys and manages vLLM container as InferenceService" "Internal RHOAI"
        llmd = softwareSystem "llm-d Inference Scheduler" "High-performance request routing to vLLM instances" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal Platform"
        hfHub = softwareSystem "HuggingFace Hub" "Model weight storage and download" "External"
        statsServer = softwareSystem "Red Hat Stats Server" "Usage statistics collection" "External"
        storage = softwareSystem "Model Storage (PVC)" "Pre-loaded model weights on persistent volume" "Internal Platform"

        # External relationships
        user -> vllmCpu "Sends inference requests" "HTTP/HTTPS 8000/TCP"
        llmd -> vllmCpu "Routes requests via gRPC" "gRPC/HTTP2 50051/TCP"
        prometheus -> vllmCpu "Scrapes metrics" "HTTP 8000/TCP"
        kserve -> vllmCpu "Manages container lifecycle"
        vllmCpu -> hfHub "Downloads model weights" "HTTPS/443"
        vllmCpu -> statsServer "Reports usage statistics" "HTTPS/443"
        vllmCpu -> storage "Loads model weights" "File I/O"

        # Internal container relationships
        user -> apiServer "POST /v1/chat/completions" "HTTP/HTTPS 8000/TCP"
        llmd -> grpcServer "VllmEngine.Generate" "gRPC/HTTP2 50051/TCP"
        apiServer -> authMiddleware "Validates Bearer Token"
        apiServer -> tlsSupport "TLS termination"
        apiServer -> engine "Process inference" "in-process"
        grpcServer -> engine "Process inference" "in-process"
        engine -> cpuKernels "Tensor computation" "in-process C++ FFI"
        apiServer -> metrics "Expose /metrics"
        prometheus -> metrics "GET /metrics" "HTTP 8000/TCP"
        engine -> hfHub "Download models" "HTTPS/443 TLS 1.2+"
        engine -> storage "Load model weights" "File I/O"
    }

    views {
        systemContext vllmCpu "SystemContext" {
            include *
            autoLayout
        }

        container vllmCpu "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal Platform" {
                background #4a90e2
                color #ffffff
            }
            element "Application" {
                background #4a90e2
                color #ffffff
            }
            element "Security" {
                background #e8543e
                color #ffffff
            }
            element "Monitoring" {
                background #50c878
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
