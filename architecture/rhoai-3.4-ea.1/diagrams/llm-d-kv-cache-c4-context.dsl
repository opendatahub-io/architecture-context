// C4 Context Diagram: llm-d-kv-cache
// Generated by: Claude Opus 4.6

workspace {
    model {
        scheduler = person "Inference Scheduler" "llm-d-inference-scheduler: routes inference requests to optimal vLLM pods"

        kvCache = softwareSystem "llm-d-kv-cache" "Pluggable KV-Cache indexing library and service for KV-Cache-aware routing and scheduling in vLLM-based LLM inference platforms" {
            indexer = container "kvcache.Indexer" "Main orchestrator for scoring requests; coordinates tokenization, key generation, index lookup, and scoring" "Go Library"
            blockIndex = container "kvblock.Index" "Core data store mapping KV-block hashes to pod locations; supports LRU, Ristretto, Redis, Valkey backends" "Go Library"
            tokenProcessor = container "kvblock.TokenProcessor" "Converts token sequences into KV-block keys using FNV-64a chained hashing" "Go Library"
            scorer = container "kvblock.Scorer" "Scores pods based on longest consecutive prefix matching with device-tier weighting" "Go Library"
            eventPool = container "kvevents.Pool" "Sharded worker pool processing KV-cache events from ZMQ subscribers" "Go Library"
            subscriberManager = container "kvevents.SubscriberManager" "Manages per-pod ZMQ subscriber lifecycle dynamically" "Go Library"
            zmqSubscriber = container "kvevents.zmqSubscriber" "Connects to vLLM pods ZMQ PUB sockets, receives msgpack-encoded events" "Go Library"
            udsTokenizerService = container "UDS Tokenizer Service" "Sidecar providing tokenization and chat template rendering via Unix Domain Socket" "Python gRPC Server"
            podReconciler = container "Pod Reconciler" "Kubernetes pod watcher for auto-discovering vLLM pods" "Go controller-runtime"
            indexerGrpc = container "IndexerService gRPC" "gRPC service wrapping Indexer for remote access" "Go gRPC Server"
            metrics = container "Prometheus Metrics" "Collects kvcache index and tokenization metrics" "Go Library"
        }

        vllm = softwareSystem "vLLM Pods" "LLM inference engine pods publishing KV-cache events via ZMQ" "External"
        k8sApi = softwareSystem "Kubernetes API" "Kubernetes control plane API server" "External"
        redis = softwareSystem "Redis/Valkey" "Optional distributed cache backend for KV-block index" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model and tokenizer hosting platform" "External"

        // System-level relationships
        scheduler -> kvCache "Queries for KV-cache-aware pod scores" "Go API / gRPC"
        kvCache -> vllm "Subscribes to KV-cache events" "ZMQ PUB/SUB 5557/TCP"
        kvCache -> k8sApi "Watches for pod discovery" "HTTPS/443"
        kvCache -> redis "Stores/retrieves block index (optional)" "Redis/6379"
        kvCache -> huggingface "Downloads tokenizer models (optional)" "HTTPS/443"

        // Container-level relationships
        indexer -> udsTokenizerService "Tokenize prompts" "gRPC over UDS"
        indexer -> tokenProcessor "Generate block keys" "Go API"
        indexer -> blockIndex "Lookup block locations" "Go API"
        indexer -> scorer "Score pod matches" "Go API"
        zmqSubscriber -> eventPool "Forward events" "Go channel"
        eventPool -> blockIndex "Update block index" "Go API"
        subscriberManager -> zmqSubscriber "Manage lifecycle" "Go API"
        podReconciler -> subscriberManager "Notify pod changes" "Go API"
        podReconciler -> k8sApi "Watch pods" "HTTPS/443 TLS SA Token"
        zmqSubscriber -> vllm "Subscribe to events" "ZMQ SUB 5557/TCP"
        blockIndex -> redis "Distributed backend" "Redis/6379 Optional TLS"
        indexerGrpc -> indexer "Delegate scoring" "Go API"
        scheduler -> indexerGrpc "Remote scoring" "gRPC"
    }

    views {
        systemContext kvCache "SystemContext" {
            include *
            autoLayout
        }

        container kvCache "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
