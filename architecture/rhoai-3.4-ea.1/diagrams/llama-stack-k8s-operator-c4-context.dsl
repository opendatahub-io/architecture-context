// C4 Context Diagram: LlamaStack K8s Operator
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/llama-stack-k8s-operator.md

workspace {
    model {
        user = person "User / Admin" "Creates and manages LlamaStackDistribution custom resources"

        llamaStackOperator = softwareSystem "LlamaStack K8s Operator" "Kubernetes operator managing lifecycle of LlamaStack AI server distributions" {
            controller = container "LlamaStackDistribution Controller" "Reconciles LlamaStackDistribution CRs; manages Deployments, Services, PVCs, NetworkPolicies, Ingresses, HPAs, PDBs" "Go Operator (controller-runtime)"
            kustomizeRenderer = container "Kustomize Renderer" "Renders base manifests from embedded kustomize templates with field transformations" "Go Library (pkg/deploy)"
            clusterInfo = container "Cluster Info" "Detects operator namespace, resolves distribution images, upgrade cleanup" "Go Library (pkg/cluster)"
            featureFlags = container "Feature Flags" "Controls feature toggles via operator ConfigMap" "Go Library (pkg/featureflags)"
            npTransformer = container "NetworkPolicy Transformer" "Generates NetworkPolicy ingress rules from CR spec" "Kustomize Plugin"
            kubeRBACProxy = container "kube-rbac-proxy" "Secures metrics endpoint with RBAC authentication" "Sidecar v0.15.0"
        }

        llamaStackServer = softwareSystem "LlamaStack Server" "AI/ML inference server providing unified API for model serving, agents, and tool integration" "Managed Workload"
        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane API" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        containerRegistry = softwareSystem "Container Registry" "Stores LlamaStack distribution container images" "External"
        odhPlatform = softwareSystem "ODH/RHOAI Platform" "OpenShift AI platform providing trusted CA bundles and operator deployment" "Internal RHOAI"
        openshift = softwareSystem "OpenShift" "Container platform with SecurityContextConstraints" "External"

        // External relationships
        user -> llamaStackOperator "Creates LlamaStackDistribution CR via kubectl" "HTTPS/443"
        llamaStackOperator -> k8sAPI "CRUD operations on managed resources" "HTTPS/443, TLS 1.2+, SA Token"
        llamaStackOperator -> llamaStackServer "Health checks, provider info, version queries" "HTTP/8321"
        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTPS/8443, TLS, Bearer Token"
        llamaStackServer -> containerRegistry "Pulls distribution container images" "HTTPS/443, TLS 1.2+"
        odhPlatform -> llamaStackOperator "Deploys operator, provides CA bundle ConfigMap" "Kustomize"
        llamaStackOperator -> openshift "Uses anyuid SCC for server pods" "API"

        // Internal container relationships
        controller -> kustomizeRenderer "Renders manifests"
        controller -> clusterInfo "Detects cluster info"
        controller -> featureFlags "Reads feature toggles"
        kustomizeRenderer -> npTransformer "Applies NetworkPolicy plugin"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed Workload" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
