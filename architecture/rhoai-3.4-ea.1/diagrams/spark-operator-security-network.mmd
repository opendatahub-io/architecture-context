    %% External flows
    User -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| K8sAPI
    ClientApp -->|"gRPC/15002<br/>plaintext<br/>No Auth"| SCServer

    %% Control plane to webhook
    K8sAPI -->|"HTTPS/443→9443<br/>TLS (self-signed)<br/>API Server CA"| Webhook

    %% Controller to API server
    Controller -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Controller creates workloads
    Controller -.->|"creates via<br/>spark-submit"| Driver
    Controller -.->|"creates"| SCServer
    Controller -.->|"creates"| UISvc
    Controller -.->|"creates"| UIIngress

    %% Driver creates executors
    Driver -.->|"creates"| Executor

    %% Webhook reads secret
    WebhookSecret -.->|"mounted"| Webhook

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>No Auth"| Controller
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>No Auth"| Webhook

    %% Deployment
    RhodsOp -.->|"deploys"| Controller
    RhodsOp -.->|"deploys"| Webhook

    %% Ingress exposure
    UIIngress -->|"HTTP/4040<br/>plaintext"| UISvc
    UISvc -->|"4040/TCP"| Driver

