    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI
    Controller -->|"spark-submit<br/>creates pods"| Driver
    Driver -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Driver -->|"TCP/various<br/>No encryption"| Executors
    User -->|"gRPC/15002<br/>No encryption<br/>No auth"| ConnectServer
    ConnectServer -->|"TCP/7078-7079<br/>No encryption"| Executors
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| Controller
    Controller -.->|"CRD API"| Volcano

