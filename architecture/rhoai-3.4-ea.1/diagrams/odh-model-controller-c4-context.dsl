// C4 Context Diagram for odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and deploys ML models via InferenceService CRs"
        admin = person "Platform Admin" "Configures NIM accounts, data connections, and platform settings"

        odhModelController = softwareSystem "odh-model-controller" "Manages lifecycle and platform integration of KServe model serving deployments on OpenShift AI" {
            isvcController = container "InferenceService Controller" "Reconciles InferenceService CRs; creates Routes, NetworkPolicies, ServiceMonitors, KEDA TriggerAuthentications" "Go Controller"
            llmController = container "LLMInferenceService Controller" "Reconciles LLMInferenceService CRs; creates AuthPolicy and EnvoyFilter for Gateway API auth" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages monitoring RoleBindings and Ray TLS certificates for multi-node serving" "Go Controller"
            cmController = container "ConfigMap Controller" "Aggregates CA certificates into odh-kserve-custom-ca-bundle ConfigMap" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into storage-config Secret" "Go Controller"
            podController = container "Pod Controller" "Manages per-pod Ray TLS server certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM API key validation, model lists, and runtime templates" "Go Controller"
            igController = container "InferenceGraph Controller" "Watches InferenceGraph CRs" "Go Controller"
            webhooks = container "Admission Webhooks" "Mutating and validating webhooks for Pod, InferenceService, InferenceGraph, ConfigMap, NIM Account, LLMInferenceService" "Go Webhook Server"
            runtimeTemplates = container "ServingRuntime Templates" "Pre-configured templates for vLLM, OVMS, MLServer, HF Guardrails" "Kustomize Resources"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys odh-model-controller via kustomize; injects image references" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "UI for managing model serving, data connections, and runtime templates" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata for InferenceService sync" "Internal ODH"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Authentication and authorization via AuthPolicy for Gateway API" "External"
        istio = softwareSystem "Istio" "Service mesh; EnvoyFilter management for Authorino TLS bootstrap" "External"
        gatewayAPI = softwareSystem "Gateway API" "Gateway and HTTPRoute for LLMInferenceService auth targets" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "ServiceMonitor and PodMonitor CRDs for metrics collection" "External"
        keda = softwareSystem "KEDA" "TriggerAuthentication for autoscaling InferenceServices" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Exposes model serving endpoints via Routes" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Provisions webhook TLS certificates" "External"
        nvidiaNGC = softwareSystem "NVIDIA NGC API" "NIM model catalog and API key validation" "External"
        dsc = softwareSystem "DataScienceCluster" "Platform configuration CRD" "Internal ODH"

        // User interactions
        user -> odhModelController "Creates InferenceService, LLMInferenceService via kubectl"
        admin -> odhModelController "Creates NIM Account, data connection secrets"

        // Internal ODH interactions
        rhodsOperator -> odhModelController "Deploys controller and injects image references"
        odhDashboard -> odhModelController "ServingRuntime templates labeled for dashboard integration"
        odhModelController -> modelRegistry "Syncs InferenceService metadata" "REST/HTTPS 443"
        odhModelController -> dsc "Reads platform configuration"

        // External dependencies
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph, LLMInferenceService CRDs"
        odhModelController -> kuadrant "Creates AuthPolicy for LLMInferenceService auth"
        odhModelController -> istio "Creates EnvoyFilter for Authorino TLS bootstrap"
        odhModelController -> gatewayAPI "Watches Gateway and HTTPRoute resources"
        odhModelController -> prometheusOp "Creates ServiceMonitor and PodMonitor"
        odhModelController -> keda "Creates TriggerAuthentication"
        odhModelController -> openshiftRouter "Creates Routes for model exposure"
        odhModelController -> openshiftServiceCA "Uses annotation-based cert provisioning"
        odhModelController -> nvidiaNGC "Validates API keys, fetches model catalog" "HTTPS/443"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
