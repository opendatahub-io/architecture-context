// C4 Context Diagram: odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and deploys ML models using InferenceService and LLMInferenceService CRs"
        admin = person "Platform Admin" "Manages NIM accounts and platform configuration"

        odhModelController = softwareSystem "odh-model-controller" "Kubernetes operator managing KServe model serving integration with OpenShift AI platform" {
            isvcController = container "InferenceService Controller" "Reconciles KServe InferenceServices; creates Routes, NetworkPolicies, ServiceMonitors" "Go Controller"
            llmisController = container "LLMInferenceService Controller" "Reconciles LLMInferenceService CRs; creates AuthPolicies, EnvoyFilters, RBAC" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages Prometheus RoleBindings, Ray TLS CA certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM integration: API key validation, model catalog, pull secrets" "Go Controller"
            configmapController = container "ConfigMap Controller" "Aggregates CA cert bundles for KServe TLS trust" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into storage-config" "Go Controller"
            podController = container "Pod Controller" "Generates per-pod TLS certificates for Ray multi-node serving" "Go Controller"
            webhooks = container "Admission Webhooks" "Mutating and validating webhooks for Pods, InferenceServices, NIM Accounts" "Go Webhook Server"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, LLMInferenceService, InferenceGraph CRDs" "External"
        openshift = softwareSystem "OpenShift" "Container platform providing Routes, Templates, service-ca, authentication config" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Gateway API authentication and authorization via AuthPolicy CRDs" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh providing EnvoyFilter for TLS bootstrap" "External"
        prometheus = softwareSystem "Prometheus Operator" "Metrics collection via ServiceMonitor and PodMonitor CRDs" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling via TriggerAuthentication CRDs" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway and HTTPRoute resources for ingress" "External"
        modelRegistry = softwareSystem "Model Registry" "Stores and syncs model metadata bidirectionally" "Internal ODH"
        nimAPI = softwareSystem "NVIDIA NIM API" "API key validation and model catalog for NIM integration" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for all controller CRUD operations" "External"

        // User interactions
        user -> odhModelController "Creates InferenceService / LLMInferenceService via kubectl or Dashboard"
        admin -> odhModelController "Creates NIM Account CRs for NVIDIA integration"

        // System dependencies
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, LLMInferenceService, InferenceGraph CRs" "HTTPS/443"
        odhModelController -> openshift "Creates Routes, reads service-ca, authentication config" "HTTPS/443"
        odhModelController -> kuadrant "Creates AuthPolicy CRs for Gateway API auth" "HTTPS/443"
        odhModelController -> istio "Creates EnvoyFilter CRs for Authorino TLS bootstrap" "HTTPS/443"
        odhModelController -> prometheus "Creates ServiceMonitor/PodMonitor for metrics scraping" "HTTPS/443"
        odhModelController -> keda "Creates TriggerAuthentication for autoscaling" "HTTPS/443"
        odhModelController -> gatewayAPI "Watches Gateway and HTTPRoute resources" "HTTPS/443"
        odhModelController -> modelRegistry "Syncs InferenceService metadata bidirectionally" "HTTPS/443"
        odhModelController -> nimAPI "Validates API keys and fetches model catalog" "HTTPS/443"
        odhModelController -> k8sAPI "All controller-runtime API operations" "HTTPS/443"

        // Webhook interaction
        k8sAPI -> odhModelController "Sends admission webhook requests" "HTTPS/9443"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
