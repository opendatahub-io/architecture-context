/*
 * Feast Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/feast.md
 */

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Feast FeatureStore deployments for ML feature serving"

        feastOperator = softwareSystem "Feast Operator" "Kubernetes operator managing the lifecycle of Feast feature store deployments" {
            controller = container "FeatureStore Controller" "Reconciles FeatureStore CRs; creates Deployments, Services, PVCs, ConfigMaps, RBAC, CronJobs, Routes" "Go Operator (controller-runtime)"
            notebookController = container "NotebookConfigMap Controller" "Watches Kubeflow Notebooks with feast-integration label; creates per-notebook ConfigMaps" "Go Reconciler"
            authModule = container "Authorization Module" "Deploys Kubernetes RBAC or OIDC authorization for Feast services" "Go Controller Logic"
            namespaceRegistry = container "Namespace Registry" "Maintains central ConfigMap tracking all FeatureStore deployments" "Go Controller Logic"
        }

        featureServer = softwareSystem "Feast Feature Server" "Python-based feature serving for online/offline/registry endpoints" "Dynamically Created" {
            onlineStore = container "Online Store" "Serves online feature values" "Python 3.11, Port 6566/6567"
            offlineStore = container "Offline Store" "Serves historical feature values" "Python 3.11, Port 8815/8816"
            registry = container "Registry" "Feature metadata store (gRPC + REST)" "Python 3.11, Port 6570-6573"
            uiServer = container "UI Server" "Feast web UI" "Python 3.11, Port 8888/8443"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane API" "External"
        kubeflowNotebooks = softwareSystem "Kubeflow Notebooks" "Interactive ML development notebooks" "Internal RHOAI"
        openShiftServiceCA = softwareSystem "OpenShift Service CA" "Automatic TLS certificate provisioning" "External (OpenShift)"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        externalDB = softwareSystem "External Databases" "PostgreSQL, Redis, Snowflake, Cassandra persistence backends" "External"
        objectStores = softwareSystem "S3/GCS Object Stores" "Registry file persistence on object stores" "External"
        gitRepos = softwareSystem "Git Repositories" "Source for feast project directories" "External"

        # User interactions
        user -> feastOperator "Creates FeatureStore CR via kubectl/oc" "HTTPS/443"
        user -> featureServer "Retrieves features for ML training/serving" "HTTP(S)/80-443"

        # Operator interactions
        feastOperator -> k8sAPI "Manages Kubernetes resources (CRUD)" "HTTPS/443, TLS 1.2+, SA Token"
        feastOperator -> featureServer "Creates and configures feature server deployments"
        feastOperator -> kubeflowNotebooks "Watches Notebooks, creates Feast client ConfigMaps" "K8s API Watch"
        feastOperator -> openShiftServiceCA "Requests TLS certificates via annotations" "Annotation-based"
        feastOperator -> gitRepos "Clones feast project directories" "HTTPS/443 or SSH/22"

        # Feature Server interactions
        featureServer -> externalDB "Reads/writes feature data" "TLS configurable, Secret credentials"
        featureServer -> objectStores "Registry persistence" "HTTPS/443, TLS 1.2+"

        # Monitoring
        prometheus -> feastOperator "Scrapes operator metrics" "HTTPS/8443, Bearer Token"
        prometheus -> featureServer "Scrapes feature server metrics" "HTTP/8000"
    }

    views {
        systemContext feastOperator "SystemContext" {
            include *
            autoLayout
        }

        container feastOperator "OperatorContainers" {
            include *
            autoLayout
        }

        container featureServer "FeatureServerContainers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Dynamically Created" {
                background #45B7D1
                color #ffffff
            }
        }
    }
}
