%% RBAC Visualization: llama-stack-provider-trustyai-garak
%% Generated by: Claude Opus 4.6
%% Note: This component does not define its own RBAC resources.
%% It relies on service accounts and tokens from other components.

graph TD
    subgraph "Llama Stack Server Context"
        SA_LLS["Service Account<br/>Llama Stack Server SA<br/>(from llama-stack-k8s-operator)"]
    end

    subgraph "KFP Pipeline Context"
        SA_KFP["Service Account<br/>KFP Pipeline Pod SA<br/>(from Data Science Pipelines)"]
    end

    subgraph "User-Provided Credentials"
        Token_KFP["kubeflow-pipelines-token<br/>(Opaque Secret)<br/>KUBEFLOW_PIPELINES_TOKEN"]
        Secret_Model["llama-stack-inference-model-secret<br/>(Opaque Secret)<br/>INFERENCE_MODEL, VLLM_URL, VLLM_API_TOKEN"]
    end

    subgraph "Access Targets"
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        KFPApi["Kubeflow Pipelines API<br/>443/TCP HTTPS"]
        vLLMEndpoint["vLLM Inference Endpoint<br/>HTTP/HTTPS"]
        LLSServer["Llama Stack Server<br/>8321/TCP HTTP"]
        ConfigMap["trustyai-service-operator-config<br/>ConfigMap"]
    end

    %% Llama Stack Server SA access
    SA_LLS -->|"SA Token<br/>read ConfigMaps"| K8sAPI
    SA_LLS -->|"load kubeconfig"| K8sAPI
    K8sAPI -->|"get"| ConfigMap

    %% KFP Pipeline Pod access
    SA_KFP -->|"SA Token<br/>pipeline execution"| K8sAPI

    %% User-provided credentials
    Token_KFP -->|"Bearer Token<br/>submit/poll/cancel pipelines"| KFPApi
    Secret_Model -->|"API Token<br/>OPENAICOMPATIBLE_API_KEY"| vLLMEndpoint
    Secret_Model -->|"VLLM_URL<br/>model endpoint"| vLLMEndpoint

    %% KFP pod to Llama Stack (no auth)
    SA_KFP -.->|"No Auth<br/>cluster internal"| LLSServer

    style SA_LLS fill:#4a90e2,color:#fff
