%% Security Network Diagram: Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.1/notebooks.md

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Platform["PLATFORM SERVICES (Cluster Internal)"]
        direction TB

        subgraph NS_RODS["Namespace: redhat-ods-applications"]
            Dashboard["ODH Dashboard<br/>443/TCP HTTPS"]
            RHODSOp["rhods-operator<br/>Deploys ImageStream manifests"]
            NotebookCtrl["ODH Notebook Controller<br/>Creates Pods, injects auth sidecars"]
        end

        K8sAPI["OpenShift API Server<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB

        AuthProxy["kube-rbac-proxy Sidecar<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token"]

        subgraph JupyterVariant["Jupyter Variant"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP plaintext<br/>UID: 1001 (non-root)"]
        end

        subgraph CodeServerVariant["Code Server Variant"]
            Nginx["nginx reverse proxy<br/>8080/TCP HTTP plaintext"]
            CodeSrv["code-server<br/>8787/TCP HTTP plaintext"]
            Httpd["httpd CGI<br/>/api/kernels/ activity"]
        end

        subgraph RStudioVariant["RStudio Variant"]
            RServer["RStudio Server (rserver)<br/>8787/TCP HTTP plaintext"]
        end
    end

    subgraph ExternalServices["EGRESS DESTINATIONS (External)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS credentials"]
        Registry["Container Registries<br/>registry.redhat.io / quay.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull secret"]
        Kafka["Kafka Brokers<br/>9092/TCP<br/>Auth: Configurable"]
        Databases["Database Servers<br/>MySQL/PostgreSQL/MSSQL/MongoDB<br/>Various ports<br/>Auth: Credentials"]
    end

    %% External access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Dashboard
    Dashboard -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| AuthProxy

    %% Platform operations
    RHODSOp -->|"HTTPS/443<br/>SA token<br/>Apply ImageStreams"| K8sAPI
    NotebookCtrl -->|"HTTPS/443<br/>SA token<br/>Create Pods"| K8sAPI

    %% Internal pod routing
    AuthProxy -->|"HTTP/8888<br/>plaintext<br/>localhost (no auth)"| JupyterLab
    AuthProxy -->|"HTTP/8080<br/>plaintext<br/>localhost (no auth)"| Nginx
    AuthProxy -->|"HTTP/8787<br/>plaintext<br/>localhost (no auth)"| RServer
    Nginx -->|"HTTP/8787<br/>plaintext"| CodeSrv
    Nginx -->|"CGI<br/>plaintext"| Httpd

    %% Egress from workbench
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds (Boto3)"| S3
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    JupyterLab -->|"9092/TCP<br/>Configurable"| Kafka
    JupyterLab -->|"Various ports<br/>Credentials"| Databases
    CodeSrv -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3
    RServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3

    %% Image pull
    K8sAPI -.->|"Image pull<br/>HTTPS/443"| Registry

