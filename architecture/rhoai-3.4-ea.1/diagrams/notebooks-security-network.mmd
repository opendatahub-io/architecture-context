    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef apiserver fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Dashboard,RHODSOp,NotebookCtrl platform
