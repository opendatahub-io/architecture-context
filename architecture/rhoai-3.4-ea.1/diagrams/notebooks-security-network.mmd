%% Security Network Diagram for Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE<br/>HTTPRoute per notebook"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace)"]
        direction TB
        KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>Kubernetes RBAC<br/>Injected by Notebook Controller"]
        NotebookContainer["Notebook Container<br/>UID 1001 (non-root)<br/>UBI9 / Python 3.12<br/>JupyterLab: 8888/TCP<br/>RStudio/VS Code: 8787/TCP"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        NotebookCtrl["ODH Notebook Controller<br/>Creates Pod + Service + HTTPRoute<br/>Injects kube-rbac-proxy"]
        Operator["rhods-operator<br/>Deploys ImageStreams<br/>RELATED_IMAGE refs"]
        Dashboard["ODH Dashboard<br/>443/TCP HTTPS<br/>Reads ImageStream annotations"]
    end

    subgraph BuildPipeline["BUILD PIPELINE (Konflux)"]
        Konflux["Konflux Pipeline<br/>(Tekton, Hermetic)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        RegistryRH["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
        Quay["quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Auth"]
        PyPI["pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% User access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OpenShift OAuth"| Dashboard
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>kube-rbac-proxy"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Kubernetes RBAC"| KubeRBAC
    KubeRBAC -->|"HTTP/8888<br/>plaintext (localhost)<br/>No auth (delegated)"| NotebookContainer
    NotebookContainer -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token (oc CLI)"| K8sAPI

    %% Controller flow
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount"| NotebookCtrl
    NotebookCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount"| K8sAPI

    %% Operator flow
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>RELATED_IMAGE refs"| Quay

    %% Build flow
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| RegistryRH
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>Push creds"| Quay
    Konflux -->|"HTTPS/443<br/>TLS 1.2+<br/>Hash-verified"| PyPI
    Konflux -->|"HTTPS/443<br/>TLS 1.2+"| Mirror

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC,NotebookContainer workbench
    class K8sAPI,NotebookCtrl,Operator,Dashboard cluster
    class Konflux build
    class RegistryRH,Quay,PyPI,Mirror externalservice
