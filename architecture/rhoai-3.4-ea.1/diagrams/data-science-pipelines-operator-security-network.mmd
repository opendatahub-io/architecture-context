%% Security Network Diagram - Data Science Pipelines Operator
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Dashboard<br/>External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - OpenShift Routes"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS"]
        RouteAPI["Route: ds-pipeline-{name}<br/>443 &rarr; 8443/TCP<br/>TLS Reencrypt"]
        RouteMD["Route: ds-pipeline-md-{name}<br/>443 &rarr; 8443/TCP<br/>TLS Reencrypt"]
        Router --> RouteAPI
        Router --> RouteMD
    end

    subgraph AuthLayer["AUTH LAYER - kube-rbac-proxy"]
        ProxyAPI["kube-rbac-proxy<br/>(API Server sidecar)<br/>8443/TCP TLS<br/>SubjectAccessReview"]
        ProxyMLMD["kube-rbac-proxy<br/>(MLMD Envoy sidecar)<br/>8443/TCP TLS<br/>SubjectAccessReview"]
    end

    subgraph AppLayer["APPLICATION LAYER (per namespace)"]
        direction TB

        subgraph APIGroup["API Services"]
            APIServer["DS Pipeline API Server<br/>8888/TCP HTTP(S)<br/>8887/TCP gRPC<br/>PodToPodTLS"]
        end

        subgraph OrchGroup["Pipeline Orchestration"]
            Argo["Argo Workflow Controller"]
            Persistence["Persistence Agent"]
            Scheduled["Scheduled Workflow"]
        end

        subgraph MetadataGroup["ML Metadata"]
            Envoy["MLMD Envoy Proxy<br/>9090/TCP gRPC"]
            MLMDServer["MLMD gRPC Server<br/>8080/TCP gRPC<br/>PodToPodTLS"]
        end

        PipelinePod["Pipeline Pods<br/>(launcher/driver)<br/>Dynamic"]
    end

    subgraph DataLayer["DATA LAYER - Backing Storage"]
        MariaDB["MariaDB<br/>3306/TCP MySQL<br/>PodToPodTLS<br/>Password Auth"]
        MinIO["MinIO<br/>9000/TCP HTTP<br/>S3 Credentials"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Token"]
        ExtS3["External S3<br/>443/TCP HTTPS<br/>S3 Credentials"]
        ServiceCA["OpenShift service-ca<br/>TLS Cert Provisioning"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>ServiceMonitor"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>OpenShift Auth"| Router

    %% Ingress to Auth
    RouteAPI -->|"HTTPS/8443<br/>TLS Reencrypt"| ProxyAPI
    RouteMD -->|"HTTPS/8443<br/>TLS Reencrypt"| ProxyMLMD

    %% Auth to K8s API for SAR
    ProxyAPI -.->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI
    ProxyMLMD -.->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI

    %% Auth to App
    ProxyAPI -->|"HTTP(S)/8888<br/>PodToPodTLS"| APIServer
    ProxyMLMD -->|"gRPC/9090<br/>Internal"| Envoy

    %% App internal flows
    Envoy -->|"gRPC/8080<br/>PodToPodTLS"| MLMDServer
    Persistence -->|"HTTP(S)/8888<br/>PodToPodTLS"| APIServer
    PipelinePod -->|"HTTP(S)/8888<br/>gRPC/8887"| APIServer
    PipelinePod -->|"gRPC/8080<br/>PodToPodTLS"| MLMDServer

    %% App to Data
    APIServer -->|"MySQL/3306<br/>PodToPodTLS<br/>Password"| MariaDB
    MLMDServer -->|"MySQL/3306<br/>PodToPodTLS<br/>Password"| MariaDB
    APIServer -->|"HTTP/9000<br/>S3 Credentials"| MinIO
    PipelinePod -->|"HTTP/9000<br/>S3 Credentials"| MinIO

    %% App to External
    APIServer -->|"HTTPS/443<br/>SA Token"| K8sAPI
    Argo -->|"HTTPS/443<br/>SA Token"| K8sAPI
    PipelinePod -->|"HTTPS/443<br/>S3 Credentials"| ExtS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef app fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router,RouteAPI,RouteMD ingress
    class ProxyAPI,ProxyMLMD auth
    class APIServer,Argo,Persistence,Scheduled,Envoy,MLMDServer,PipelinePod app
