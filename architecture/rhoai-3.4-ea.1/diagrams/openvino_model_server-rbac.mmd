    %% Auth flows
    APIKeyFile -->|"loaded at startup"| AuthHandler
    APIKeyEnv -->|"fallback source"| AuthHandler
    AuthHandler -->|"Bearer token required"| V3Endpoints
    V1V2Endpoints -->|"No OVMS auth<br/>delegated to platform"| KubeRBACProxy
    MetricsEndpoint -->|"Opt-in via<br/>--metrics_enable"| MetricsEndpoint
    GRPCEndpoints -->|"No built-in auth"| KubeRBACProxy

    KServeRBAC -->|"manages pod lifecycle"| ContainerUser
    KubeRBACProxy -->|"protects endpoints<br/>at platform level"| V1V2Endpoints
    IstioAuth -.->|"optional mTLS<br/>enforcement"| V1V2Endpoints

