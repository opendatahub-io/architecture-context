// C4 Context Diagram: Notebooks (Workbench Images)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/notebooks.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and uses workbench environments for data science, ML training, and model development"

        notebooks = softwareSystem "Notebooks (Workbench Images)" "Pre-built container images providing interactive IDEs (JupyterLab, Code Server, RStudio) and pipeline runtime images for data science workflows on OpenShift AI" {
            jupyterImages = container "Jupyter Workbench Images" "JupyterLab-based IDE images with variants for CPU, CUDA, ROCm, and specialized frameworks (PyTorch, TensorFlow, TrustyAI, LLM Compressor)" "Container Images"
            codeServerImage = container "Code Server Workbench Image" "VS Code-based IDE with nginx reverse proxy and data science libraries" "Container Image"
            rstudioImages = container "RStudio Workbench Images" "RStudio Server IDE with R 4.5 and Python 3.12, CPU and CUDA variants" "Container Images (BuildConfig)"
            runtimeImages = container "Pipeline Runtime Images" "Headless Elyra pipeline runtime images for executing pipeline nodes without IDE components" "Container Images"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream and ConfigMap definitions that register workbench images in OpenShift" "YAML Manifests"
            tektonPipelines = container "Tekton Pipelines" "95 PipelineRun definitions for Konflux-based hermetic container image builds" "CI/CD"
        }

        // Internal ODH Systems
        rhodsOperator = softwareSystem "rhods-operator" "Deploys ImageStream manifests via kustomize overlays" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI that reads ImageStream annotations to display available workbench images" "Internal ODH"
        notebookController = softwareSystem "ODH Notebook Controller" "Creates workbench Pods from ImageStream refs and injects auth sidecars (kube-rbac-proxy)" "Internal ODH"
        dsPipelines = softwareSystem "Data Science Pipelines" "Orchestrates ML pipeline execution using runtime images from this component" "Internal ODH"
        elyra = softwareSystem "Elyra" "Pipeline runtime that uses runtime images for executing pipeline nodes" "Internal ODH"

        // External Systems
        openshift = softwareSystem "OpenShift Container Platform" "Kubernetes platform providing ImageStream API, pod scheduling, and cluster services" "External"
        containerRegistry = softwareSystem "Container Registries" "registry.redhat.io and quay.io/modh - source of released workbench images" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Object storage for data science data and pipeline artifacts" "External"
        konflux = softwareSystem "Konflux (Tekton)" "CI/CD build system for hermetic container image builds" "External"
        nvidiaGPU = softwareSystem "NVIDIA CUDA Toolkit" "GPU acceleration for CUDA-based workbench images (v12.9/13.0)" "External"
        amdGPU = softwareSystem "AMD ROCm" "GPU acceleration for ROCm-based workbench images (v6.2-6.4)" "External"

        // Relationships
        dataScientist -> odhDashboard "Selects workbench image" "HTTPS/443"
        dataScientist -> notebooks "Uses IDE for data science workflows" "HTTPS/443 via kube-rbac-proxy"

        rhodsOperator -> kustomizeManifests "Deploys to cluster" "kubectl apply"
        odhDashboard -> openshift "Reads ImageStream metadata" "HTTPS/443"
        notebookController -> openshift "Creates Pods with auth sidecars" "HTTPS/443"
        notebookController -> jupyterImages "Launches workbench Pods using" "Container image ref"
        notebookController -> codeServerImage "Launches workbench Pods using" "Container image ref"
        notebookController -> rstudioImages "Launches workbench Pods using" "Container image ref"

        dsPipelines -> runtimeImages "Executes pipeline nodes in" "Container image ref"
        elyra -> runtimeImages "Runs pipeline tasks in" "Container image ref"

        notebooks -> openshift "Runs on, uses ImageStream API" "HTTPS/443"
        notebooks -> s3Storage "Accesses data via Boto3" "HTTPS/443"
        notebooks -> containerRegistry "Images pulled from" "HTTPS/443"

        jupyterImages -> nvidiaGPU "Uses for CUDA workloads" "Device plugin"
        jupyterImages -> amdGPU "Uses for ROCm workloads" "Device plugin"

        tektonPipelines -> konflux "Builds images hermetially" "Tekton API"
        konflux -> containerRegistry "Pushes built images to" "HTTPS/443"
    }

    views {
        systemContext notebooks "SystemContext" {
            include *
            autoLayout
        }

        container notebooks "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
