%% RBAC Visualization: vllm-orchestrator-gateway
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "vllm-orchestrator-gateway Security Model"
        direction TB

        subgraph "Authentication"
            NoAuth["No Local Auth Enforcement<br/>Gateway does NOT validate tokens"]
            PassThrough["Pass-Through Auth<br/>Authorization header forwarded<br/>to orchestrator as-is"]
            XForwarded["X-Forwarded-* Headers<br/>Forwarded for proxy chain context"]
        end

        subgraph "RBAC"
            NoRBAC["No Kubernetes RBAC<br/>No ClusterRoles defined<br/>No RoleBindings defined<br/>Stateless HTTP service<br/>No K8s API interactions"]
        end

        subgraph "Transport Security"
            direction TB

            Plaintext["Inbound: Plaintext HTTP<br/>Port 8090/TCP<br/>No TLS termination"]

            subgraph "Outbound mTLS (Optional)"
                direction TB
                mTLSAuto["Auto-detection based on file presence"]
                Mode1["Mode 1: mTLS<br/>cert + key present<br/>HTTPS with client certificate"]
                Mode2["Mode 2: One-way TLS<br/>CA cert only<br/>Server cert verification"]
                Mode3["Mode 3: Plaintext<br/>No TLS files<br/>HTTP (no encryption)"]

                mTLSAuto --> Mode1
                mTLSAuto --> Mode2
                mTLSAuto --> Mode3
            end
        end

        subgraph "Secrets & Certificates"
            TLSCert["tls.crt<br/>Type: kubernetes.io/tls<br/>Path: /etc/tls/private/tls.crt<br/>Purpose: mTLS client cert<br/>Provisioner: service-ca / cert-manager"]
            TLSKey["tls.key<br/>Type: kubernetes.io/tls<br/>Path: /etc/tls/private/tls.key<br/>Purpose: mTLS private key<br/>Provisioner: service-ca / cert-manager"]
            CACert["service-ca.crt<br/>Type: ConfigMap/Secret<br/>Path: /etc/tls/ca/service-ca.crt<br/>Purpose: CA cert for server verification<br/>Provisioner: service-ca operator"]
        end
    end

    Client["Client"] -->|"POST /{route}/v1/chat/completions<br/>Auth: Authorization header"| Plaintext
    Plaintext -->|"delegates auth"| PassThrough
    PassThrough -->|"forwards to"| Orchestrator["FMS Guardrails Orchestrator<br/>(enforces auth)"]

    TLSCert -->|"PKCS#12 identity"| Mode1
    TLSKey -->|"PKCS#12 identity"| Mode1
    CACert -->|"server verification"| Mode2

    style NoAuth fill:#ff6b6b,stroke:#333,color:#fff
    style NoRBAC fill:#ff6b6b,stroke:#333,color:#fff
    style PassThrough fill:#ffd93d,stroke:#333
    style Plaintext fill:#ffd93d,stroke:#333
    style Mode1 fill:#6bcb77,stroke:#333,color:#fff
    style Mode2 fill:#6bcb77,stroke:#333,color:#fff
    style Mode3 fill:#ff6b6b,stroke:#333,color:#fff
    style TLSCert fill:#4d96ff,stroke:#333,color:#fff
    style TLSKey fill:#4d96ff,stroke:#333,color:#fff
    style CACert fill:#4d96ff,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
