// ML Metadata - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/ml-metadata.md

workspace {
    model {
        dspUser = person "Data Scientist" "Runs ML pipelines that produce metadata artifacts"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving metadata associated with ML workflows" {
            server = container "metadata_store_server" "C++ gRPC server binary exposing MetadataStoreService (52 RPCs) on port 8080" "C++ / gRPC"
            coreLib = container "MetadataStore Library" "Core metadata store logic with transaction support and database abstraction" "C++ Library"
            pythonClient = container "Python Client Library" "Python client wrapping gRPC stubs for programmatic metadata access" "Python / grpcio"
            goBindings = container "Go SWIG Bindings" "Go language bindings via SWIG for metadata store access" "Go / SWIG"
        }

        dsp = softwareSystem "Data Science Pipelines" "Pipeline orchestration platform (Kubeflow Pipelines)" "Internal RHOAI"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and configures MLMD gRPC server instance" "Internal RHOAI"
        mysql = softwareSystem "MySQL/MariaDB" "Relational database for persistent metadata storage" "External Database"
        postgresql = softwareSystem "PostgreSQL" "Relational database for persistent metadata storage" "External Database"

        // Relationships
        dspUser -> dsp "Submits ML pipelines"
        dsp -> mlmd "Stores/retrieves pipeline metadata" "gRPC/8080"
        dspOperator -> mlmd "Deploys and configures"
        mlmd -> mysql "Stores metadata" "MySQL/3306 Optional TLS"
        mlmd -> postgresql "Stores metadata" "PostgreSQL/5432 Optional TLS"

        // Internal container relationships
        server -> coreLib "Delegates metadata operations"
        pythonClient -> server "gRPC calls" "gRPC/8080"
        goBindings -> server "gRPC calls" "gRPC/8080"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Database" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
