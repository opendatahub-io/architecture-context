%% Models as a Service - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User/Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["maas-default-gateway<br/>Host: maas.CLUSTER_DOMAIN<br/>80/TCP, 443/TCP<br/>TLS Terminate<br/>GatewayClass: openshift-default"]
        Route["maas-api-route<br/>HTTPRoute<br/>/v1/models, /maas-api/*"]
        Gateway --> Route
    end

    subgraph AuthLayer["AUTH LAYER (Kuadrant)"]
        direction TB
        GWAuth["gateway-auth-policy<br/>TokenReview (audience: maas-default-gateway-sa)<br/>SAR: post on llminferenceservices<br/>Cache: 600s"]
        APIAuth["maas-api-auth-policy<br/>TokenReview<br/>Injects X-MaaS-Username/Group"]
        RateLimit["gateway-token-rate-limits<br/>free: 100 tok/min<br/>premium: 50k tok/min<br/>enterprise: 100k tok/min"]
        Limitador["Limitador<br/>Rate Limit Enforcement"]
        RateLimit --> Limitador
    end

    subgraph Application["APPLICATION (Cluster-Internal)"]
        direction TB

        subgraph NS_MaaS["Namespace: maas-api"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP (HTTP) | 8443/TCP (HTTPS)<br/>ClusterIP Service"]
        end

        subgraph NS_Controller["Namespace: maas-api"]
            Controller["maas-controller<br/>(Placeholder - No-op)"]
        end
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>TokenReview, SAR,<br/>TokenRequest, CRUD"]
    end

    subgraph ModelLayer["MODEL ENDPOINTS"]
        LLMSvc["LLMInferenceService Backends<br/>443/TCP or 80/TCP<br/>HTTPS/HTTP<br/>TLS (InsecureSkipVerify)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Optional)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Connection URL credentials"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS Terminate<br/>Bearer Token (SA or API key)"| Gateway
    Route -->|"auth evaluation"| GWAuth
    Route -->|"auth evaluation"| APIAuth
    GWAuth -->|"HTTPS/443<br/>TLS<br/>ServiceAccount"| K8sAPI
    GWAuth -->|"HTTP/8080<br/>plaintext<br/>/v1/tiers/lookup"| MaaSAPI
    Route -->|"rate limit check"| RateLimit
    Route -->|"HTTP/8080<br/>X-MaaS-Username<br/>X-MaaS-Group headers"| MaaSAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS (InsecureSkipVerify)<br/>Bearer Token"| LLMSvc
    MaaSAPI -.->|"TCP/5432<br/>TLS (configurable)<br/>Credentials"| PostgreSQL

    %% Network Policy
    subgraph NetPol["Network Policy: maas-authorino-allow"]
        AuthorinoNS["Authorino pods<br/>kuadrant-system /<br/>openshift-operators"]
    end
    AuthorinoNS -->|"allowed ingress<br/>to MaaS API"| MaaSAPI

