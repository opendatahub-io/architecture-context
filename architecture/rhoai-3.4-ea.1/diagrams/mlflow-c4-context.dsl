/*
 * MLflow Tracking Server - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/mlflow.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Logs experiments, registers models, uploads artifacts using MLflow SDK"
        webUser = person "Web User" "Views experiments and models via MLflow UI"

        mlflow = softwareSystem "MLflow Tracking Server" "ML lifecycle tracking server managing experiments, model registry, artifact storage, and LLM tracing" {
            flaskApp = container "Flask App" "Core REST API handler serving experiment, run, model, and artifact endpoints" "Python Flask"
            fastApiApp = container "FastAPI/Uvicorn" "Handles OTLP trace ingestion and Gateway API routes" "Python FastAPI"
            reactUI = container "React UI" "Single-page application for experiment visualization and model management" "TypeScript/React"
            kubeAuth = container "Kubernetes Auth Plugin" "Authorization middleware enforcing K8s RBAC via SubjectAccessReview" "Python Middleware"
            workspaceProvider = container "Kubernetes Workspace Provider" "Maps MLflow workspaces to K8s namespaces, watches Namespace and MLflowConfig resources" "Python Plugin"
            prometheusExporter = container "Prometheus Exporter" "Exposes /metrics endpoint for Prometheus scraping" "Python Module"
        }

        mlflowOperator = softwareSystem "MLflow Operator" "Deploys and manages MLflow server instances, creates Services and Ingress" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Platform UI for launching and managing MLflow tracking servers" "Internal RHOAI"

        k8sAPI = softwareSystem "Kubernetes API Server" "Provides namespace listing, RBAC authorization, Secret and CRD reads" "External"
        postgresql = softwareSystem "PostgreSQL" "Backend metadata store for experiments, runs, model registry, and traces" "External"
        s3Storage = softwareSystem "S3-compatible Object Storage" "Artifact storage (MinIO, AWS S3, Ceph)" "External"
        llmProviders = softwareSystem "LLM Providers" "External AI providers (OpenAI, Anthropic) for AI Gateway proxying (disabled by default)" "External"

        # Relationships - Users
        dataScientist -> mlflow "Logs experiments, registers models, uploads artifacts" "REST API HTTP/5000, Bearer Token"
        webUser -> mlflow "Views experiments, models, and traces" "HTTP/5000"

        # Relationships - Internal containers
        flaskApp -> kubeAuth "Delegates authorization"
        flaskApp -> workspaceProvider "Resolves workspace context"
        flaskApp -> reactUI "Serves static files"
        fastApiApp -> kubeAuth "Delegates authorization"

        # Relationships - External systems
        kubeAuth -> k8sAPI "SelfSubjectAccessReview / SubjectAccessReview" "HTTPS/443, TLS 1.2+, SA Token"
        workspaceProvider -> k8sAPI "Watches namespaces, MLflowConfig CRs, reads Secrets" "HTTPS/443, TLS 1.2+, SA Token"
        flaskApp -> postgresql "Stores experiment metadata, runs, models, traces" "PostgreSQL/5432, TLS"
        flaskApp -> s3Storage "Stores and retrieves artifacts" "HTTPS/443, AWS credentials"
        fastApiApp -> llmProviders "Proxies LLM requests (disabled by default)" "HTTPS/443, API Key"

        # Relationships - Internal RHOAI
        mlflowOperator -> mlflow "Creates and manages Deployments, Services, Ingress" "Kubernetes API"
        rhoaiDashboard -> mlflow "UI integration for managing tracking servers" "HTTP API"
    }

    views {
        systemContext mlflow "SystemContext" {
            include *
            autoLayout
        }

        container mlflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
