%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4-ea.1/mlflow-operator.md

graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["MLflow Operator<br/>Controller Manager<br/>(controller-runtime)"]
        HelmRenderer["Helm Chart Renderer<br/>(helm/v3)"]
        Controller -->|renders manifests via| HelmRenderer
    end

    subgraph MLflowPod["MLflow Tracking Server Pod"]
        MLflowServer["MLflow Tracking Server<br/>8443/TCP HTTPS<br/>Kubernetes Auth"]
        CAInit["CA Bundle<br/>Init Container"]
        CAWatcher["CA Bundle<br/>Watcher Sidecar"]
        CAInit -->|initializes certs| MLflowServer
        CAWatcher -->|updates certs| MLflowServer
    end

    %% CRDs
    MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    %% Operator watches CRDs
    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller

    %% Operator creates resources
    Controller -->|creates| Deployment["Deployment"]
    Controller -->|creates| Service["Service<br/>ClusterIP:8443"]
    Controller -->|creates| SA["ServiceAccount"]
    Controller -->|creates| PVC["PersistentVolumeClaim"]
    Controller -->|creates| NP["NetworkPolicy"]
    Controller -->|creates| CR_RBAC["ClusterRole/<br/>ClusterRoleBinding"]
    Controller -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift)"]

    Deployment -->|runs| MLflowPod

    %% External dependencies
    Controller -->|depends on| K8sAPI["Kubernetes API<br/>443/TCP"]
    HTTPRoute -->|references| DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    MLflowServer -->|auth via| K8sAPI
    MLflowServer -->|stores artifacts| S3["S3 Storage<br/>443/TCP"]
    MLflowServer -->|backend store| DB["PostgreSQL/MySQL<br/>5432/3306"]

    %% Internal integrations
    Controller -->|deployed by| RHODSOp["rhods-operator"]
    MLflowServer -->|TLS from| ServiceCA["OpenShift service-ca"]
    MLflowServer -->|CA certs from| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

