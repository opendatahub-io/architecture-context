/*
 * KubeRay Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Ray clusters, jobs, and services for distributed AI/ML workloads"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and services on Kubernetes/OpenShift" {
            rayClusterCtrl = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker pods, services, ingresses" "Go Controller"
            rayJobCtrl = container "RayJob Controller" "Manages RayJob CRs: creates clusters, submits jobs via K8s Job or HTTP" "Go Controller"
            rayServiceCtrl = container "RayService Controller" "Manages RayService CRs: zero-downtime upgrades of Ray Serve deployments" "Go Controller"
            authCtrl = container "Authentication Controller" "Creates HTTPRoute, ReferenceGrant, injects kube-rbac-proxy sidecars" "Go Controller"
            netpolCtrl = container "NetworkPolicy Controller" "Creates NetworkPolicy resources for Ray cluster isolation" "Go Controller"
            mtlsCtrl = container "mTLS Controller" "Manages cert-manager Issuer and Certificate resources for mTLS" "Go Controller"
            webhook = container "Webhook Server" "Mutating webhook for RayCluster defaulting and validation" "Go, 9443/TCP"
            metricsServer = container "Metrics Server" "Prometheus metrics endpoint" "HTTP, 8080/TCP"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys KubeRay operator via kustomize openshift overlay" "Internal RHOAI"
        dsgw = softwareSystem "data-science-gateway" "Platform ingress gateway for Ray dashboard access" "Internal RHOAI"
        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "OIDC/OAuth authentication sidecar for Ray dashboard" "Internal RHOAI"

        k8sAPI = softwareSystem "Kubernetes API" "Container orchestration platform" "External"
        certManager = softwareSystem "cert-manager" "Certificate and Issuer management for mTLS" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute and ReferenceGrant for ingress" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano" "Gang scheduling for Ray workloads" "External"
        redis = softwareSystem "Redis" "GCS fault tolerance external storage" "External"

        user -> kuberay "Creates RayCluster/RayJob/RayService via kubectl"
        user -> dsgw "Accesses Ray dashboard via browser" "HTTPS/443"

        rhodsOperator -> kuberay "Deploys via kustomize" "Kustomize overlay"
        kuberay -> k8sAPI "CRD reconciliation, pod/service management" "HTTPS/443"
        kuberay -> certManager "Provisions mTLS certificates" "HTTPS/443 (Certificate, Issuer CRs)"
        kuberay -> gatewayAPI "Creates HTTPRoute, ReferenceGrant" "CRD API"
        prometheus -> kuberay "Scrapes operator metrics" "HTTP/8080"
        kuberay -> volcano "Gang scheduling integration" "Scheduler plugin"
        kuberay -> redis "GCS fault tolerance storage" "TCP/configurable"

        dsgw -> kubeRbacProxy "Routes dashboard traffic" "HTTPS/8443"
        kubeRbacProxy -> kuberay "Forwards to Ray dashboard" "HTTP/8265"
        kubeRbacProxy -> k8sAPI "SubjectAccessReview" "HTTPS/443"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
