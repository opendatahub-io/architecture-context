// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/model-registry.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Registers, versions, and tracks ML models"
        mlEngineer = person "ML Engineer" "Deploys models and manages inference services"

        modelRegistry = softwareSystem "Model Registry" "Central repository for ML model metadata - registered models, versions, artifacts, inference services, serving environments, and experiments" {
            proxyServer = container "Model Registry Proxy Server" "OpenAPI REST API (v1alpha3) for ML model metadata CRUD operations" "Go, go-chi v5.2.3" "Service"
            embedMD = container "EmbedMD Datastore" "Embedded metadata storage layer with schema migrations" "Go, GORM v1.31.1" "Library"
            controller = container "InferenceService Controller" "Watches KServe InferenceService CRs and syncs state with Model Registry" "Go, controller-runtime v0.21.0" "Controller"
            csiInitializer = container "CSI Storage Initializer" "KServe storage initializer for model-registry:// URIs" "Go" "CLI"
            catalogServer = container "Model Catalog Server" "Catalog API (v1alpha1) for curated model browsing and MCP server catalog" "Go, pglock" "Service"
            asyncUploadJob = container "Async Upload Job" "Copies models between storage backends and registers in Model Registry" "Python 3.11+" "Job"
            ui = container "Model Registry UI" "Frontend for browsing and managing model registry entries" "Web Application" "UI"
        }

        // External Dependencies
        mysql = softwareSystem "MySQL 8.3+" "Backend metadata store" "External"
        postgresql = softwareSystem "PostgreSQL 16+" "Backend metadata store; required for Catalog" "External"
        kserve = softwareSystem "KServe v0.16.0" "Inference service platform - InferenceService CRD and ClusterStorageContainer" "External"
        istio = softwareSystem "Istio" "Service mesh for mTLS and authorization policies" "External"
        s3Storage = softwareSystem "Model Storage (S3/OCI)" "Model artifact storage" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Source for model downloads" "External"

        // Internal ODH Dependencies
        modelRegistryOperator = softwareSystem "Model Registry Operator" "Deploys and manages Model Registry instances" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Platform UI consuming Model Registry API" "Internal ODH"
        dsPipelines = softwareSystem "Data Science Pipelines" "Tracks model artifacts from pipeline runs" "Internal ODH"

        // Relationships - Users
        dataScientist -> modelRegistry "Registers models, creates versions, tracks experiments"
        mlEngineer -> modelRegistry "Manages inference services and serving environments"

        // Relationships - Internal
        proxyServer -> embedMD "Uses for metadata persistence"
        catalogServer -> embedMD "Uses for catalog data persistence"
        controller -> proxyServer "Syncs InferenceService state" "HTTP/8080"
        csiInitializer -> proxyServer "Fetches model artifact URIs" "HTTP/8080"
        asyncUploadJob -> proxyServer "Registers uploaded models" "HTTP/8080"
        ui -> proxyServer "Browses and manages entries" "HTTP/8080"

        // Relationships - External
        embedMD -> mysql "Stores metadata" "MySQL/3306"
        embedMD -> postgresql "Stores metadata" "PostgreSQL/5432"
        controller -> kserve "Watches InferenceService CRs" "HTTPS/443"
        csiInitializer -> s3Storage "Downloads model artifacts" "HTTPS/443"
        asyncUploadJob -> huggingFace "Downloads models" "HTTPS/443"
        asyncUploadJob -> s3Storage "Uploads model artifacts" "HTTPS/443"
        modelRegistry -> istio "Uses for mTLS and authorization"

        // Relationships - Internal ODH
        modelRegistryOperator -> modelRegistry "Deploys and manages"
        odhDashboard -> modelRegistry "Consumes REST API for model management" "HTTP/8080"
        dsPipelines -> modelRegistry "Tracks model artifacts from pipelines" "HTTP/8080"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Service" {
                shape RoundedBox
            }
            element "Controller" {
                shape Hexagon
            }
            element "Job" {
                shape Circle
            }
            element "UI" {
                shape WebBrowser
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
        }
    }
}
