// C4 Context Diagram: llama-stack-provider-trustyai-garak
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / Security Engineer" "Runs LLM vulnerability scans and red-teaming assessments"

        garakProvider = softwareSystem "Llama Stack Provider: TrustyAI Garak" "Out-of-tree Llama Stack evaluation provider integrating NVIDIA Garak for automated LLM vulnerability scanning" {
            baseEval = container "GarakEvalBase" "Common evaluation logic: benchmark management, command building, result parsing" "Python"
            inlineAdapter = container "GarakInlineEvalAdapter" "Runs Garak scans locally as subprocess with asyncio concurrency control" "Python"
            remoteAdapter = container "GarakRemoteEvalAdapter" "Submits Garak scans as Kubeflow Pipeline runs via KFP SDK" "Python"
            shieldOrchestrator = container "SimpleShieldOrchestrator" "Orchestrates input/output shield checking around LLM calls" "Python"
            kfpPipeline = container "garak_scan_pipeline" "3-step KFP pipeline: validate_inputs -> garak_scan -> parse_results" "KFP Pipeline"
            scanConfig = container "GarakScanConfig" "Pre-defined benchmark profiles (OWASP, AVID, CWE, Quality)" "Pydantic Model"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Hosts provider plugins, serves Eval/Files/Safety APIs on port 8321" "Internal"
        llamaStackOperator = softwareSystem "Llama Stack K8s Operator" "Deploys LlamaStackDistribution CRs that include this provider" "Internal"
        kfp = softwareSystem "Kubeflow Pipelines (Data Science Pipelines)" "Pipeline orchestration for remote scan execution" "Internal ODH"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides ConfigMap for base image resolution" "Internal ODH"
        vllm = softwareSystem "vLLM Inference Runtime" "Target LLM model for vulnerability scanning (OpenAI-compatible)" "Internal"
        promptGuard = softwareSystem "Prompt Guard (Shields)" "Optional guardrail for shield effectiveness testing" "Internal"
        kubernetesAPI = softwareSystem "Kubernetes API" "ConfigMap access, kubeconfig loading" "External"
        garak = softwareSystem "NVIDIA Garak" "LLM vulnerability scanning engine (v0.14.0)" "External"

        // User interactions
        user -> garakProvider "Triggers vulnerability scans via Llama Stack Eval API"

        // Provider relationships
        garakProvider -> llamaStackServer "Runs as plugin within server, accesses Files/Safety/Shields APIs" "HTTP/8321"
        garakProvider -> kfp "Submits and manages scan pipeline runs (remote mode)" "HTTPS/443"
        garakProvider -> vllm "Targets LLM for Garak vulnerability probes" "HTTP(S)/varies"
        garakProvider -> kubernetesAPI "Reads ConfigMaps, loads kubeconfig for KFP token" "HTTPS/6443"
        garakProvider -> trustyaiOperator "Reads trustyai-service-operator-config ConfigMap" "HTTPS/6443"
        garakProvider -> promptGuard "Shield testing for guardrail effectiveness measurement" "HTTP/8321"
        garakProvider -> garak "Executes vulnerability probes and scans" "In-process/subprocess"

        // Deployment relationships
        llamaStackOperator -> llamaStackServer "Deploys LlamaStackDistribution CR" "Kubernetes API"
        llamaStackServer -> garakProvider "Loads as eval provider plugin" "In-process"
    }

    views {
        systemContext garakProvider "SystemContext" {
            include *
            autoLayout
        }

        container garakProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Internal ODH" {
                background #4caf50
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
