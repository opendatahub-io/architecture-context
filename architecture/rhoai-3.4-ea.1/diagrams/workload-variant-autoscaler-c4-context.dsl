/* C4 Context Diagram: Workload-Variant-Autoscaler (WVA) */
/* Generated by: Claude Opus 4.6 */

workspace {
    model {
        platformEngineer = person "Platform Engineer" "Configures autoscaling policies for LLM inference workloads"
        dataScientist = person "Data Scientist" "Deploys models and creates VariantAutoscaling resources"

        wva = softwareSystem "Workload Variant Autoscaler (WVA)" "Intelligent autoscaler for LLM inference model servers based on KV cache saturation and queue depth analysis" {
            vaController = container "VariantAutoscaling Controller" "Reconciles VariantAutoscaling CRs, reads optimization decisions from shared cache, updates CR status" "Go Controller (controller-runtime)"
            ipController = container "InferencePool Controller" "Watches InferencePool resources (v1, v1alpha2) and populates datastore with pool endpoint data" "Go Controller (controller-runtime)"
            cmController = container "ConfigMap Controller" "Watches ConfigMaps for scaling config with hot-reload support" "Go Controller (controller-runtime)"
            saturationEngine = container "Saturation Engine" "Collects vLLM saturation metrics from Prometheus, runs per-model saturation analysis (30s interval)" "Go Background Loop"
            scaleFromZeroEngine = container "Scale-from-Zero Engine" "Detects pending requests via EPP flow control queue metrics, scales 0 to 1 (100ms interval)" "Go Background Loop"
            actuator = container "Metrics Actuator" "Emits Prometheus gauges: wva_desired_replicas, wva_current_replicas, wva_desired_ratio" "Prometheus Client"
            directActuator = container "Direct Actuator" "Scales target objects via Kubernetes scale subresource" "Kubernetes Client"
            decisionCache = container "Decision Cache" "Thread-safe in-memory cache for Engine-to-Controller communication" "Go In-Memory Store"
        }

        prometheus = softwareSystem "Prometheus / Thanos Querier" "Metrics aggregation and querying platform" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster control plane API" "External"
        vllm = softwareSystem "vLLM Inference Servers" "LLM inference model servers emitting KV cache and queue metrics" "External"
        gatewayApiExt = softwareSystem "Gateway API Inference Extension (EPP)" "Endpoint picker providing flow control queue metrics" "Internal ODH"
        hpaKeda = softwareSystem "HPA / KEDA" "Horizontal Pod Autoscaler or KEDA external scaler" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management" "External"

        /* User interactions */
        dataScientist -> wva "Creates VariantAutoscaling CR via kubectl" "kubectl / YAML"
        platformEngineer -> wva "Configures scaling policies via ConfigMaps" "kubectl / Helm"

        /* WVA to external systems */
        wva -> prometheus "Queries vLLM metrics (kv_cache_usage_perc, num_requests_waiting)" "HTTPS/9091, TLS 1.2+, Bearer Token"
        wva -> k8sApi "CRUD on VariantAutoscaling, Deployments, scale subresource" "HTTPS/443, TLS 1.2+, SA Token"
        wva -> gatewayApiExt "Reads flow control queue metrics for scale-from-zero" "HTTP(S)/varies"

        /* External to WVA */
        prometheus -> wva "Scrapes /metrics endpoint" "HTTPS/8443, TLS, Bearer Token"

        /* Indirect dependencies */
        vllm -> prometheus "Emits vLLM metrics" "Prometheus scraping"
        hpaKeda -> prometheus "Reads wva_desired_replicas, wva_desired_ratio" "HTTPS/9091"
        hpaKeda -> k8sApi "Scales target Deployments" "HTTPS/443, scale subresource"

        /* Internal container relationships */
        saturationEngine -> decisionCache "Writes VariantDecisions"
        scaleFromZeroEngine -> decisionCache "Writes decisions"
        decisionCache -> vaController "Decisions read via Go channel"
        vaController -> actuator "Emits scaling metrics"
        scaleFromZeroEngine -> directActuator "Scales 0 to 1 replica"
        saturationEngine -> prometheus "PromQL queries" "HTTPS/9091"
        ipController -> gatewayApiExt "Watches InferencePool CRs"
    }

    views {
        systemContext wva "SystemContext" {
            include *
            autoLayout
        }

        container wva "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
