/*
 * Models as a Service - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "User/Data Scientist" "Accesses LLM models for inference, manages tokens and API keys"
        platformAdmin = person "Platform Admin" "Configures tier policies, monitors usage"

        maas = softwareSystem "Models as a Service (MaaS)" "Tiered, policy-managed access to LLM inference models via OpenAI-compatible interface with token management and rate limiting" {
            maasApi = container "maas-api" "REST API for model discovery, token issuance, API key management, tier lookup" "Go HTTP Server (Gin framework)"
            maasController = container "maas-controller" "Future controller for MaaS resource reconciliation (placeholder)" "Go Container (No-op)"
            tierConfig = container "tier-to-group-mapping" "Maps OpenShift groups to tier levels (free/premium/enterprise)" "ConfigMap"
        }

        gateway = softwareSystem "MaaS Default Gateway" "Gateway API ingress for all MaaS traffic; TLS termination, HTTPRoute routing" "Infrastructure"
        kuadrantAuthorino = softwareSystem "Kuadrant/Authorino" "Authentication (TokenReview), authorization (SAR), tier enrichment via HTTP callback" "Infrastructure"
        kuadrantLimitador = softwareSystem "Kuadrant/Limitador" "Token-based rate limit enforcement per tier" "Infrastructure"
        kserve = softwareSystem "KServe" "Provides LLMInferenceService CRDs for model serving" "Internal ODH"
        k8sApi = softwareSystem "Kubernetes API Server" "TokenReview, SubjectAccessReview, TokenRequest, resource CRUD and watch" "Infrastructure"
        istio = softwareSystem "Istio Service Mesh" "Telemetry enrichment, DestinationRule for backend TLS" "Infrastructure"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning for gateway" "Infrastructure"
        postgresql = softwareSystem "PostgreSQL" "Persistent API key metadata storage for HA deployments" "External"
        grafana = softwareSystem "Grafana" "Observability dashboards for AI engineer and platform admin views" "Infrastructure"

        llmEndpoints = softwareSystem "LLM Inference Endpoints" "Model serving backends (vLLM, etc.) via LLMInferenceService" "Internal ODH"

        # User interactions
        user -> gateway "Sends inference/API requests" "HTTPS/443, Bearer Token"
        platformAdmin -> grafana "Monitors usage per tier/user/model"

        # Gateway flows
        gateway -> kuadrantAuthorino "Auth evaluation (TokenReview, SAR)" "HTTPS/443"
        gateway -> kuadrantLimitador "Rate limit check" "Internal"
        gateway -> maas "Routes API requests via HTTPRoute" "HTTP/8080"
        gateway -> llmEndpoints "Routes model inference requests" "HTTPS/HTTP"

        # Authorino flows
        kuadrantAuthorino -> k8sApi "TokenReview, SubjectAccessReview" "HTTPS/443"
        kuadrantAuthorino -> maas "Tier lookup callback" "HTTP/8080, /v1/tiers/lookup"

        # MaaS internal flows
        maas -> kserve "Watches LLMInferenceService CRDs" "HTTPS/443, Kubernetes API"
        maas -> k8sApi "TokenRequest, Namespace/SA CRUD, ConfigMap watch" "HTTPS/443"
        maas -> llmEndpoints "Discovers models via /v1/models" "HTTPS/443, Bearer Token"
        maas -> postgresql "Stores API key metadata (HA mode)" "TCP/5432, TLS"

        # Observability
        maas -> istio "Telemetry enrichment (tier labels)" "Internal"
        istio -> grafana "Metrics pipeline" "Internal"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
