/* Training Operator - C4 Context Diagram (Structurizr DSL)
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or API"

        trainingOperator = softwareSystem "Kubeflow Training Operator (KFTO)" "Kubernetes-native operator managing distributed training jobs across PyTorch, TensorFlow, XGBoost, MPI, Paddle, and JAX frameworks" {
            controllerManager = container "Controller Manager" "Main controller binary with 6 training job controllers" "Go (controller-runtime v0.19.1)"
            pytorchController = container "PyTorchJob Controller" "Reconciles PyTorchJob CRs; creates Pods, Services, NetworkPolicies, HPAs" "Go Controller"
            tfController = container "TFJob Controller" "Reconciles TFJob CRs; creates Pods and Services" "Go Controller"
            xgboostController = container "XGBoostJob Controller" "Reconciles XGBoostJob CRs; creates Pods and Services" "Go Controller"
            mpiController = container "MPIJob Controller" "Reconciles MPIJob CRs; creates launcher/worker Pods and Services" "Go Controller"
            paddleController = container "PaddleJob Controller" "Reconciles PaddleJob CRs; creates Pods and Services" "Go Controller"
            jaxController = container "JAXJob Controller" "Reconciles JAXJob CRs; creates Pods and Services" "Go Controller"
            webhookServer = container "Webhook Server" "Validates CREATE/UPDATE operations on training job CRDs" "Go, 9443/TCP HTTPS"
            certRotator = container "Cert Rotator" "Self-managed TLS certificate rotation for webhook" "OPA cert-controller v0.12.0"
            metricsServer = container "Metrics Server" "Prometheus metrics endpoint" "8080/TCP HTTP"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Container orchestration control plane" "External"
        prometheus = softwareSystem "Prometheus (openshift-monitoring)" "Metrics collection and alerting" "Internal Platform"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and configures Training Operator via kustomize" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling via PodGroups (optional)" "External Optional"
        kueue = softwareSystem "Kueue" "Multi-cluster queue management (optional)" "External Optional"

        # Relationships
        user -> trainingOperator "Submits training jobs (PyTorchJob, TFJob, etc.) via kubectl" "HTTPS/443"
        trainingOperator -> k8sAPI "CRUD on Pods, Services, NetworkPolicies, CRDs" "HTTPS/443, SA Token"
        k8sAPI -> trainingOperator "Webhook validation requests" "HTTPS 443->9443, TLS self-signed"
        prometheus -> trainingOperator "Scrapes metrics via PodMonitor" "HTTP/8080"
        rhodsOperator -> trainingOperator "Deploys via kustomize overlay" "Kustomize"
        trainingOperator -> volcano "Creates PodGroups for gang scheduling" "CRD API"
        trainingOperator -> kueue "ManagedBy field for queue management" "CRD API"

        # Container relationships
        controllerManager -> pytorchController "manages"
        controllerManager -> tfController "manages"
        controllerManager -> xgboostController "manages"
        controllerManager -> mpiController "manages"
        controllerManager -> paddleController "manages"
        controllerManager -> jaxController "manages"
        certRotator -> webhookServer "provides TLS certificates"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #cccccc
                color #333333
            }
            element "Internal Platform" {
                background #85bbf0
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
