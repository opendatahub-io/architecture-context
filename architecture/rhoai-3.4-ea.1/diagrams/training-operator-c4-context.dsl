// Training Operator - C4 Context Diagram
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or automation"

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Kubernetes operator for managing distributed ML training jobs across PyTorch, TensorFlow, MPI, XGBoost, PaddlePaddle, and JAX" {
            controller = container "Training Operator Controller" "Reconciles all training job CRDs, manages pod lifecycle, services, and network policies" "Go Operator (controller-runtime)"
            webhook = container "Validating Webhook" "Validates CRD create/update operations for all job types" "HTTPS 9443/TCP"
            certRotator = container "Cert Rotator" "Auto-generates and rotates TLS certificates for webhook server" "OPA cert-controller"
        }

        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"
        prometheus = softwareSystem "Prometheus (OpenShift Monitoring)" "Metrics collection and monitoring" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys and manages training-operator via kustomize" "Internal RHOAI"
        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduling via PodGroups" "External"
        schedulerPlugins = softwareSystem "Scheduler Plugins" "Optional gang scheduling via PodGroups" "External"

        // Relationships
        user -> trainingOperator "Submits training jobs (PyTorchJob, TFJob, MPIJob, etc.) via kubectl" "HTTPS/443"
        trainingOperator -> k8sApi "CRUD operations on Pods, Services, NetworkPolicies, CRDs" "HTTPS/443"
        prometheus -> trainingOperator "Scrapes metrics" "HTTP/8080"
        rhoaiOperator -> trainingOperator "Deploys via kustomize manifests"
        trainingOperator -> volcano "Creates PodGroup CRs for gang scheduling" "CRD"
        trainingOperator -> schedulerPlugins "Creates PodGroup CRs for gang scheduling" "CRD"
        k8sApi -> trainingOperator "Sends webhook validation requests" "HTTPS/9443"

        // Internal container relationships
        controller -> webhook "Validates CRs via"
        certRotator -> webhook "Rotates TLS certificates"
        controller -> k8sApi "Watches CRDs, creates Pods/Services/NetworkPolicies" "HTTPS/443"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
