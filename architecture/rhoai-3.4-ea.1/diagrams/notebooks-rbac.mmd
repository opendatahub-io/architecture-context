%% RBAC Visualization for Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Authentication Architecture"
        direction TB

        subgraph "External Access"
            User["User (Browser)"]
        end

        subgraph "Gateway Layer"
            Gateway["data-science-gateway<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE"]
        end

        subgraph "Auth Enforcement (kube-rbac-proxy)"
            KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>Injected by ODH Notebook Controller"]
        end

        subgraph "Kubernetes RBAC"
            RBAC["Kubernetes RBAC Policy<br/>Validates user identity<br/>via ServiceAccount / OAuth"]
        end

        subgraph "Protected Endpoints"
            JupyterEndpoint["JupyterLab UI<br/>8888/TCP HTTP<br/>Methods: GET, POST, WebSocket"]
            RStudioEndpoint["RStudio Server UI<br/>8787/TCP HTTP<br/>Methods: GET, POST, WebSocket"]
            CodeServerEndpoint["VS Code Server UI<br/>8787/TCP HTTP<br/>Methods: GET, POST, WebSocket"]
        end
    end

    subgraph "Operator RBAC"
        direction TB

        subgraph "Service Accounts"
            OperatorSA["rhods-operator SA"]
            ControllerSA["notebook-controller SA"]
        end

        subgraph "Operator Permissions"
            ISPerms["ImageStream Resources<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
            PodPerms["Pod/Service/HTTPRoute Resources<br/>Verbs: get, list, watch,<br/>create, update, patch, delete"]
        end
    end

    subgraph "Container Security"
        direction TB
        NonRoot["Non-root UID 1001"]
        UBI9["UBI9 Base Image<br/>Security updates"]
        HashVerified["Hash-verified dependencies<br/>pylock.toml + --require-hashes"]
        HermeticBuild["Hermetic Konflux builds<br/>Prefetched dependencies"]
        CVEConstraints["CVE Constraints<br/>dependencies/cve-constraints.txt"]
    end

    subgraph "Secrets"
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription<br/>for RStudio BuildConfig<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    %% Access flow
    User -->|"HTTPS/443<br/>OpenShift OAuth"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS"| KubeRBAC
    KubeRBAC -->|"validates"| RBAC
    RBAC -->|"authorized"| KubeRBAC
    KubeRBAC -->|"HTTP/8888<br/>plaintext (localhost)"| JupyterEndpoint
    KubeRBAC -->|"HTTP/8787<br/>plaintext (localhost)"| RStudioEndpoint
    KubeRBAC -->|"HTTP/8787<br/>plaintext (localhost)"| CodeServerEndpoint

    %% Operator RBAC
    OperatorSA -->|"manages"| ISPerms
    ControllerSA -->|"manages"| PodPerms

    %% Styling
    style User fill:#f9f9f9,stroke:#999
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KubeRBAC fill:#f8cecc,stroke:#b85450
    style RBAC fill:#f8cecc,stroke:#b85450
    style JupyterEndpoint fill:#dae8fc,stroke:#6c8ebf
    style RStudioEndpoint fill:#dae8fc,stroke:#6c8ebf
    style CodeServerEndpoint fill:#dae8fc,stroke:#6c8ebf
    style OperatorSA fill:#4a90e2,color:#fff
    style ControllerSA fill:#4a90e2,color:#fff
    style ISPerms fill:#f5a623
    style PodPerms fill:#f5a623
    style NonRoot fill:#d5e8d4,stroke:#82b366
    style UBI9 fill:#d5e8d4,stroke:#82b366
    style HashVerified fill:#d5e8d4,stroke:#82b366
    style HermeticBuild fill:#d5e8d4,stroke:#82b366
    style CVEConstraints fill:#d5e8d4,stroke:#82b366
    style RHELSecret fill:#fff2cc,stroke:#d6b656
