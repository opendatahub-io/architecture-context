    subgraph "Authentication Flow (RHOAI 3.x)"
        UserBrowser["User Browser"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>(injected by ODH Notebook Controller)"]
        WorkbenchContainer["Workbench Container<br/>(JupyterLab / Code Server / RStudio)"]
    end

    subgraph "RBAC Managed by ODH Notebook Controller"
        SA_Controller["ServiceAccount<br/>notebook-controller-manager"]
        CR_Controller["ClusterRole<br/>(managed externally)"]
        NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]
        PodResource["Pod<br/>(workbench instance)"]
    end

    subgraph "RBAC Managed by rhods-operator"
        SA_Operator["ServiceAccount<br/>rhods-operator"]
        CR_Operator["ClusterRole<br/>(managed externally)"]
        ImageStreamRes["ImageStream<br/>(image.openshift.io/v1)"]
        ConfigMapRes["ConfigMap<br/>(notebook-image-params)"]
    end

    subgraph "Resources Produced by Notebooks"
        IS1["11 Notebook ImageStreams"]
        IS2["7 Runtime ImageStreams"]
        BC["2 BuildConfigs (RStudio)"]
        CM1["ConfigMap: notebook-image-params"]
        CM2["ConfigMap: notebook-image-commithash"]
    end

    %% Authentication flow
    UserBrowser -->|"HTTPS/443<br/>Bearer token"| KubeRBACProxy
    KubeRBACProxy -->|"Validates against<br/>K8s API (SAR)"| K8sAPI["OpenShift API Server"]
    KubeRBACProxy -->|"HTTP/8888 or 8080 or 8787<br/>plaintext (localhost)"| WorkbenchContainer

    %% Controller RBAC
    SA_Controller -->|"bound to"| CR_Controller
    CR_Controller -->|"get,list,watch,create,update,delete"| NotebookCR
    CR_Controller -->|"get,list,watch,create,update,delete"| PodResource

    %% Operator RBAC
    SA_Operator -->|"bound to"| CR_Operator
    CR_Operator -->|"get,list,watch,create,update"| ImageStreamRes
    CR_Operator -->|"get,list,watch,create,update"| ConfigMapRes

    %% Notebooks produces resources
    IS1 ---|"defined in"| ImageStreamRes
    IS2 ---|"defined in"| ImageStreamRes
    CM1 ---|"defined in"| ConfigMapRes
    CM2 ---|"defined in"| ConfigMapRes

