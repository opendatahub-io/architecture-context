    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (initial)"| Router
    Router -->|"HTTPS/443<br/>TLS terminate/reencrypt"| Gateway

    %% Gateway to Auth
    Gateway -->|"HTTPS/8443<br/>TLS (service-CA)<br/>ext_authz"| KAP
    Gateway -.->|"EnvoyFilter config"| EnvoyFilter

    %% Auth to External
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 Client Creds"| OAuthServer
    KAP -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC Client Creds"| OIDCProvider

    %% Gateway to Upstream (after auth)
    Gateway -->|"HTTPS/varies<br/>TLS<br/>Bearer Token forwarded"| Dashboard
    Gateway -->|"HTTPS/varies<br/>TLS<br/>Bearer Token forwarded"| KServe
    Gateway -->|"HTTPS/varies<br/>TLS<br/>Bearer Token forwarded"| Pipelines
    Gateway -->|"HTTPS/varies<br/>TLS<br/>Bearer Token forwarded"| OtherComps

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/9000<br/>No encryption<br/>Metrics scrape"| KAP

    %% Network Policies
    Gateway -.->|"NP: 8443/TCP<br/>allowed"| KAP
    Prometheus -.->|"NP: 9000/TCP<br/>allowed"| KAP

