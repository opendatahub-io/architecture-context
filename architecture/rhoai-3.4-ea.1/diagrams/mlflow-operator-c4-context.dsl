// MLflow Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/mlflow-operator.md

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and tracks ML experiments, logs models and artifacts"
        platformadmin = person "Platform Admin" "Deploys and configures MLflow instances via MLflow CR"

        mlflowOperator = softwareSystem "MLflow Operator" "Kubernetes operator that manages MLflow tracking server deployments using CRDs and embedded Helm chart rendering" {
            controller = container "MLflow Operator Controller Manager" "Reconciles MLflow CRs; renders Helm chart; creates K8s resources via Server-Side Apply" "Go (controller-runtime)"
            helmRenderer = container "Helm Chart Renderer" "Renders embedded charts/mlflow Helm chart with values from MLflow CR spec" "Go (helm/v3)"
            mlflowServer = container "MLflow Tracking Server" "MLflow server with TLS, Kubernetes auth, workspace support, artifact serving" "Python"
            caInit = container "CA Bundle Init Container" "Combines system + platform + custom CA certificates" "Shell"
            caWatcher = container "CA Bundle Watcher Sidecar" "Watches ConfigMap changes and regenerates CA bundle" "Shell"
        }

        // External Dependencies
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management and auth" "External"
        dsGateway = softwareSystem "data-science-gateway" "Gateway API Gateway (Envoy) in openshift-ingress namespace" "External"
        serviceCa = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning" "External"

        // Internal RHOAI Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys mlflow-operator via kustomize overlays" "Internal RHOAI"
        caBundle = softwareSystem "odh-trusted-ca-bundle" "Platform-provided CA bundle ConfigMap" "Internal RHOAI"
        openshiftConsole = softwareSystem "OpenShift Console" "Web console with application menu" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"

        // External Services
        database = softwareSystem "PostgreSQL / MySQL" "Backend store for experiment and model metadata" "External Service"
        s3Storage = softwareSystem "S3-Compatible Storage" "Artifact storage for ML models and data" "External Service"
        gcs = softwareSystem "Google Cloud Storage" "Alternative artifact storage" "External Service"

        // Relationships - Users
        datascientist -> mlflowOperator "Logs experiments, models, artifacts via REST API" "HTTPS/443"
        platformadmin -> mlflowOperator "Creates/configures MLflow CR via kubectl" "HTTPS/443"

        // Relationships - Internal
        controller -> helmRenderer "Renders manifests" "In-process"
        controller -> k8sAPI "Watch CRs, Server-Side Apply resources" "HTTPS/443"
        mlflowServer -> k8sAPI "SubjectAccessReview for auth" "HTTPS/443"
        mlflowServer -> database "Backend store queries" "TCP/5432 or 3306"
        mlflowServer -> s3Storage "Artifact storage" "HTTPS/443"
        mlflowServer -> gcs "Artifact storage (alternative)" "HTTPS/443"

        // Relationships - Platform
        rhodsOperator -> mlflowOperator "Deploys via kustomize"
        dsGateway -> mlflowServer "Routes external traffic via HTTPRoute" "HTTPS/8443"
        serviceCa -> mlflowServer "Provisions TLS certificates"
        caBundle -> mlflowServer "Provides trusted CA certificates"
        mlflowOperator -> openshiftConsole "Creates ConsoleLink CR"
        prometheus -> mlflowOperator "Scrapes operator metrics" "HTTPS/8443"

        // Relationships - External flows
        datascientist -> dsGateway "HTTPS requests" "HTTPS/443 TLS 1.2+"
        dsGateway -> mlflowServer "Forward with path rewrite" "HTTPS/8443 TLS (service-ca)"
    }

    views {
        systemContext mlflowOperator "SystemContext" {
            include *
            autoLayout
        }

        container mlflowOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
