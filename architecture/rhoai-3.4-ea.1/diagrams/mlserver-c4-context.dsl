/*
 * MLServer C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/MLServer.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries ML models for inference"
        mlEngineer = person "ML Engineer" "Manages model serving configurations"

        mlserver = softwareSystem "MLServer" "Python-based ML inference server implementing V2 Inference Protocol (KFServing V2 Dataplane) with REST and gRPC interfaces" {
            restServer = container "RESTServer" "Serves V2 Inference Protocol REST endpoints" "FastAPI/Uvicorn, 8080/TCP"
            grpcServer = container "GRPCServer" "Serves V2 Inference Protocol gRPC endpoints" "gRPC Async, 8081/TCP"
            metricsServer = container "MetricsServer" "Exposes Prometheus metrics" "FastAPI/Uvicorn, 8082/TCP"
            kafkaServer = container "KafkaServer" "Optional async inference via Kafka topics" "aiokafka, 9092/TCP" "Optional"
            dataPlane = container "DataPlane" "Core inference logic shared across all interfaces" "Python"
            multiModelRegistry = container "MultiModelRegistry" "Manages loading, unloading, and routing to multiple models" "Python"
            inferencePoolRegistry = container "InferencePoolRegistry" "Manages parallel inference workers" "Python"
            modelRepository = container "ModelRepository" "Discovers and loads model artifacts from /mnt/models" "Python"
            sklearnRuntime = container "scikit-learn Runtime" "Serves sklearn models" "mlserver-sklearn"
            xgboostRuntime = container "XGBoost Runtime" "Serves XGBoost models" "mlserver-xgboost"
            lightgbmRuntime = container "LightGBM Runtime" "Serves LightGBM models" "mlserver-lightgbm"
        }

        kserve = softwareSystem "KServe" "Manages InferenceService pods and routes traffic to MLServer" "Internal RHOAI"
        rhoaiGateway = softwareSystem "RHOAI Gateway" "Platform-level Gateway API for external access with TLS and auth" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"
        kafkaBrokers = softwareSystem "Kafka Brokers" "Message queue for async inference" "External"
        modelStorage = softwareSystem "Model Storage (PVC/S3)" "Model artifact storage mounted at /mnt/models" "External"

        # User interactions
        datascientist -> rhoaiGateway "Sends inference requests" "HTTPS/443"
        mlEngineer -> kserve "Creates InferenceService via kubectl"

        # Platform interactions
        rhoaiGateway -> mlserver "Routes inference traffic" "HTTP/8080, gRPC/8081"
        kserve -> mlserver "Manages pod lifecycle, mounts model storage"

        # Internal container interactions
        restServer -> dataPlane "Routes REST requests"
        grpcServer -> dataPlane "Routes gRPC requests"
        kafkaServer -> dataPlane "Routes Kafka messages"
        dataPlane -> multiModelRegistry "Dispatches to correct model"
        multiModelRegistry -> inferencePoolRegistry "Manages worker pools"
        multiModelRegistry -> modelRepository "Loads model artifacts"

        # Egress
        mlserver -> otelCollector "Exports traces" "gRPC OTLP"
        mlserver -> kafkaBrokers "Consumes/produces async inference messages" "Kafka/9092"
        prometheus -> mlserver "Scrapes metrics" "HTTP/8082"
        modelStorage -> modelRepository "Model artifacts" "Filesystem /mnt/models"
    }

    views {
        systemContext mlserver "SystemContext" {
            include *
            autoLayout
        }

        container mlserver "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Optional" {
                background #cccccc
                color #333333
                border dashed
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
