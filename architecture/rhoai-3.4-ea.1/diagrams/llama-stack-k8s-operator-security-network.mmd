    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI

    %% Control plane to operator
    K8sAPI -->|"In-process watch<br/>SA Token"| OperatorPod

    %% Operator to K8s API
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator to Llama Stack
    OperatorPod -->|"HTTP/8321<br/>plaintext<br/>No Auth"| LlamaServer

    %% Llama Stack internal
    LlamaSvc --> LlamaServer
    NetPol -.->|"controls access"| LlamaSvc
    LlamaServer --> PVC

    %% Optional external access
    IngressRes -->|"HTTP/8321<br/>plaintext"| LlamaSvc

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>kube-rbac-proxy"| MetricsSvc

