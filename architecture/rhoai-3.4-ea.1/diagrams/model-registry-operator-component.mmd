graph TB
    subgraph Operator["Model Registry Operator"]
        MRReconciler[ModelRegistryReconciler<br/>Go Controller]
        MCReconciler[ModelCatalogReconciler<br/>Go Controller]
    end

    subgraph RegistryInstance["Model Registry Instance (per CR)"]
        RegistryContainer[model-registry container<br/>REST API :8080]
        KRBPRegistry[kube-rbac-proxy sidecar<br/>HTTPS :8443]
        KRBPRegistry -->|proxy to| RegistryContainer
    end

    subgraph CatalogInstance["Model Catalog (Singleton)"]
        CatalogDataInit[catalog-data-init<br/>Init Container]
        BenchmarkDataInit[benchmark-data-init<br/>Init Container]
        CatalogContainer[catalog container<br/>REST API :8080]
        KRBPCatalog[kube-rbac-proxy sidecar<br/>HTTPS :8443]
        CatalogDataInit -->|copies data| CatalogContainer
        BenchmarkDataInit -->|copies benchmarks| CatalogContainer
        KRBPCatalog -->|proxy to| CatalogContainer
    end

    %% CRDs
    ModelRegistryCR[ModelRegistry CR<br/>modelregistry.opendatahub.io/v1beta1]
    ModelRegistryCRAlpha[ModelRegistry CR<br/>v1alpha1 - legacy]

    %% Created Resources
    Deployments[Deployments]
    Services[Services<br/>ClusterIP :8443, :8080]
    Routes[OpenShift Routes<br/>TLS reencrypt :443]
    NetworkPolicies[NetworkPolicies]
    RBAC[ServiceAccounts<br/>Roles / RoleBindings]
    Groups[OpenShift Groups]

    %% Databases
    PostgreSQL[(PostgreSQL 16<br/>:5432)]
    MySQL[(MySQL<br/>:3306)]

    %% User interaction
    User[User / Client] -->|creates| ModelRegistryCR
    ModelRegistryCRAlpha -.->|conversion webhook| ModelRegistryCR

    %% Reconciler flows
    ModelRegistryCR -->|watched by| MRReconciler
    MRReconciler -->|creates| RegistryInstance
    MRReconciler -->|creates| Deployments
    MRReconciler -->|creates| Services
    MRReconciler -->|creates| Routes
    MRReconciler -->|creates| NetworkPolicies
    MRReconciler -->|creates| RBAC
    MRReconciler -->|creates| Groups

    MCReconciler -->|creates| CatalogInstance

    %% Data storage
    RegistryContainer -->|stores metadata| PostgreSQL
    RegistryContainer -.->|alternative| MySQL
    CatalogContainer -->|stores metadata| PostgreSQL

    %% External dependencies
    MRReconciler -->|reads config| OSConfig[OpenShift Config API]
    MRReconciler -->|manages| OSRoutes[OpenShift Route API]
    MCReconciler -->|reads| PlatformCR[components.platform.opendatahub.io<br/>ModelRegistry]
    MCReconciler -->|reads| AuthCR[services.platform.opendatahub.io<br/>Auth]

