graph TB
    subgraph "Argo Workflows Component"
        Controller["workflow-controller<br/>(Go Controller)<br/>Leader Election via Leases"]
        Executor["argoexec<br/>(Go Executor/Sidecar)<br/>Artifact & Output Management"]
    end

    subgraph "CRDs (argoproj.io/v1alpha1)"
        WorkflowCR["Workflow CR"]
        WorkflowTemplateCR["WorkflowTemplate CR"]
        ClusterWFTemplateCR["ClusterWorkflowTemplate CR"]
        CronWorkflowCR["CronWorkflow CR"]
        TaskSetCR["WorkflowTaskSet CR"]
        TaskResultCR["WorkflowTaskResult CR"]
        ArtifactGCCR["WorkflowArtifactGCTask CR"]
        EventBindingCR["WorkflowEventBinding CR"]
    end

    subgraph "Upstream Only (not shipped in RHOAI)"
        ArgoServer["argo-server<br/>(API Server + UI)<br/>Port 2746"]
        ArgoCLI["argo CLI"]
        WorkflowUI["Workflow UI<br/>(React/TypeScript)"]
        ArgoServer --- WorkflowUI
    end

    DSP["DSP API Server"] -->|"creates via K8s API"| WorkflowCR
    WorkflowCR -->|"watched by"| Controller
    CronWorkflowCR -->|"watched by"| Controller
    WorkflowTemplateCR -->|"referenced by"| Controller
    ClusterWFTemplateCR -->|"referenced by"| Controller

    Controller -->|"creates Pods with"| Executor
    Controller -->|"creates/updates"| TaskSetCR
    Controller -->|"watches"| TaskResultCR
    Controller -->|"creates"| ArtifactGCCR

    Executor -->|"reports results via"| TaskResultCR

    Controller -->|"Pod CRUD"| K8sAPI["Kubernetes API<br/>443/TCP"]
    Executor -->|"artifact upload/download"| S3["S3/MinIO Storage"]
    Controller -.->|"optional archive"| DB["PostgreSQL/MySQL"]

    DSPOp["DSP Operator"] -->|"deploys & configures"| Controller
    DSPOp -->|"configures image"| Executor

