// Spark Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/spark-operator.md

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Spark applications on OpenShift/Kubernetes"

        sparkOperator = softwareSystem "Spark Operator" "Kubernetes operator that automates lifecycle management of Apache Spark applications and Spark Connect servers" {
            controller = container "spark-operator-controller" "Watches SparkApplication, ScheduledSparkApplication, SparkConnect CRDs; manages Spark driver/executor pod lifecycles via spark-submit" "Go Operator"
            webhook = container "spark-operator-webhook" "Mutating and validating admission webhooks for Spark resources and pods; self-manages TLS certificates" "Go Webhook Server"
        }

        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"
        k8sScheduler = softwareSystem "Kubernetes Scheduler" "Pod scheduling (default, Volcano, YuniKorn)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages Spark Operator via kustomize overlays" "Internal RHOAI"

        // Relationships - User
        user -> sparkOperator "Creates SparkApplication, ScheduledSparkApplication, SparkConnect CRs" "kubectl / HTTPS 443"

        // Relationships - Internal
        controller -> k8sApi "CRD watches, pod management, service/ingress creation" "HTTPS/443 TLS"
        controller -> k8sScheduler "Scheduler integration for driver/executor pods" "Kubernetes scheduling API"
        webhook -> k8sApi "Webhook registration, secret management" "HTTPS/443 TLS"
        k8sApi -> webhook "Admission webhook calls" "HTTPS/9443 TLS (self-signed)"

        // Relationships - Monitoring
        prometheus -> controller "Scrapes operator metrics" "HTTP/8080 plaintext"
        prometheus -> webhook "Scrapes webhook metrics" "HTTP/8080 plaintext"

        // Relationships - Deployment
        rhodsOperator -> sparkOperator "Deploys via kustomize overlay" "Kustomize"
    }

    views {
        systemContext sparkOperator "SystemContext" {
            include *
            autoLayout
        }

        container sparkOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #9b59b6
                color #ffffff
            }
            element "Container" {
                background #5ba3f5
                color #ffffff
            }
        }
    }
}
