/*
 * Spark Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/spark-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / Engineer" "Submits and manages Spark applications on Kubernetes"

        sparkOperator = softwareSystem "Spark Operator" "Kubernetes operator for managing Apache Spark application lifecycle (Kubeflow Spark Operator v2)" {
            controller = container "Controller Deployment" "Watches SparkApplication/ScheduledSparkApplication/SparkConnect CRs; manages Spark driver pods via spark-submit" "Go Operator (controller-runtime)"
            webhook = container "Webhook Deployment" "Mutates pods (injects Spark config, volumes), validates SparkApplication resources" "Admission Webhook Server"
            sparkAppController = container "SparkApplication Controller" "Manages lifecycle state machine: New -> Submitted -> Running -> Completed/Failed" "Reconciler"
            scheduledController = container "ScheduledSparkApplication Controller" "Cron-based scheduling with concurrency policies (Allow/Forbid/Replace)" "Reconciler"
            connectController = container "SparkConnect Controller" "Manages Spark Connect server pods, services, and executor pod templates" "Reconciler"
            schedulerRegistry = container "Scheduler Registry" "Pluggable batch scheduler framework supporting kube-scheduler, Volcano, YuniKorn" "Internal"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management (optional)" "External"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Deploys Spark Operator via kustomize overlays" "Internal RHOAI"

        volcanoScheduler = softwareSystem "Volcano Scheduler" "Optional batch scheduling via PodGroup CRs" "External"
        yunikornScheduler = softwareSystem "YuniKorn Scheduler" "Optional batch scheduling via pod annotations" "External"
        kueue = softwareSystem "Kueue" "Optional workload management via pod labels" "External"

        sparkDriver = softwareSystem "Spark Driver Pod" "Executes spark-submit and manages executors" "Workload"
        sparkExecutors = softwareSystem "Spark Executor Pods" "Execute Spark tasks" "Workload"

        # Relationships
        user -> sparkOperator "Creates SparkApplication/ScheduledSparkApplication/SparkConnect CRs via kubectl"
        user -> sparkDriver "Connects to Spark UI (4040/TCP HTTP)"

        sparkOperator -> k8sAPI "Watches CRDs, manages pods/services/ingresses" "HTTPS/443"
        sparkOperator -> sparkDriver "Creates driver pods via spark-submit"

        k8sAPI -> webhook "Sends admission reviews" "HTTPS/443→9443"

        sparkDriver -> k8sAPI "Creates executor pods, configmaps, PVCs" "HTTPS/443"
        sparkDriver -> sparkExecutors "Distributes Spark tasks" "TCP"

        prometheus -> sparkOperator "Scrapes metrics" "HTTP/8080"

        rhoaiOperator -> sparkOperator "Deploys and configures" "Kustomize overlay"
        certManager -> sparkOperator "Provides webhook TLS certificates (optional)" "Certificate CR"

        sparkOperator -> volcanoScheduler "Creates PodGroup CRs for batch scheduling" "HTTPS/443"
        sparkOperator -> yunikornScheduler "Adds scheduling annotations to pods"
        sparkOperator -> kueue "Adds workload labels to pods"

        controller -> sparkAppController "Contains"
        controller -> scheduledController "Contains"
        controller -> connectController "Contains"
        controller -> schedulerRegistry "Uses"
    }

    views {
        systemContext sparkOperator "SystemContext" {
            include *
            autoLayout
        }

        container sparkOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Workload" {
                background #f5a623
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
