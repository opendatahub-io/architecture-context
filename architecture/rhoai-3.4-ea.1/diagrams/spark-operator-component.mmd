graph TB
    subgraph SparkOperator["Spark Operator (redhat-ods-applications)"]
        direction TB
        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>Go Operator"]
            SAReconciler["SparkApplication<br/>Reconciler"]
            SSAReconciler["ScheduledSparkApplication<br/>Reconciler"]
            SCReconciler["SparkConnect<br/>Reconciler"]
            Controller --> SAReconciler
            Controller --> SSAReconciler
            Controller --> SCReconciler
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>Port: 9443/TCP TLS"]
            MutatingCtrl["MutatingWebhookConfig<br/>Controller"]
            ValidatingCtrl["ValidatingWebhookConfig<br/>Controller"]
            Webhook --> MutatingCtrl
            Webhook --> ValidatingCtrl
        end
    end

    %% CRDs
    User["User / Data Scientist"] -->|"kubectl apply"| SparkAppCR["SparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    User -->|"kubectl apply"| ScheduledCR["ScheduledSparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    User -->|"kubectl apply"| SparkConnectCR["SparkConnect CR<br/>sparkoperator.k8s.io/v1alpha1"]

    %% Webhook intercepts
    SparkAppCR -->|"admission webhook"| Webhook
    ScheduledCR -->|"admission webhook"| Webhook

    %% Controller watches
    SparkAppCR -->|"watched by"| SAReconciler
    ScheduledCR -->|"watched by"| SSAReconciler
    SparkConnectCR -->|"watched by"| SCReconciler

    %% Created resources
    SAReconciler -->|"creates via spark-submit"| DriverPod["Spark Driver Pod"]
    SAReconciler -->|"creates"| UISvc["Web UI Service<br/>4040/TCP"]
    SAReconciler -->|"creates"| UIIngress["Web UI Ingress<br/>80/TCP"]
    SAReconciler -->|"creates"| MonitorCM["Prometheus ConfigMap"]

    SSAReconciler -->|"creates on schedule"| SparkAppCR

    SCReconciler -->|"creates"| SCServer["SparkConnect Server Pod"]
    SCReconciler -->|"creates"| SCSvc["SparkConnect Service<br/>7078, 7079, 4040, 15002"]

    DriverPod -->|"creates"| ExecutorPod["Spark Executor Pods"]

    %% External dependencies
    Controller -->|"REST API 443/TCP"| K8sAPI["Kubernetes API Server"]
    Webhook -->|"REST API 443/TCP"| K8sAPI
    Controller -.->|"scheduler integration"| Scheduler["Kubernetes Scheduler<br/>(default/Volcano/YuniKorn)"]

    %% Deployment management
    RhodsOp["rhods-operator"] -->|"kustomize deploy"| SparkOperator

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape 8080/TCP HTTP"| Controller
    Prometheus -->|"scrape 8080/TCP HTTP"| Webhook

