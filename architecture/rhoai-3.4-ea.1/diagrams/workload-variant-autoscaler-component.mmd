        end

        subgraph Engines["Optimization Engines"]
            SatEngine["Saturation Engine<br/>(30s polling loop)"]
            SFZEngine["Scale-from-Zero Engine<br/>(100ms polling loop)"]
        end

        subgraph Analysis["Analysis & Policy"]
            SatAnalyzer["Saturation Analyzer<br/>(KV cache + queue depth)"]
            GPULimiter["GPU Limiter<br/>(nvidia/amd/intel)"]
            STZEnforcer["Scale-to-Zero Enforcer"]
        end

        subgraph DataSources["Data Sources"]
            PromSource["Prometheus Source<br/>(TLS + caching)"]
            PodScraper["Pod Scraping Source"]
        end

        subgraph SharedState["Shared State"]
            DecisionCache["Decision Cache<br/>(thread-safe in-memory)"]
        end

        subgraph Actuators["Actuators"]
            MetricsActuator["Metrics Actuator<br/>(Prometheus gauges)"]
            DirectActuator["Direct Actuator<br/>(scale subresource)"]
        end
    end

    %% CRD
    VACR["VariantAutoscaling CR<br/>(llmd.ai/v1alpha1)"]
    InferencePoolCR["InferencePool CR<br/>(gateway-api-inference-extension)"]
    ConfigMapRes["ConfigMap<br/>(scaling config)"]

    %% External
    Prometheus["Prometheus/Thanos Querier"]
    K8sAPI["Kubernetes API Server"]
    HPA["HPA / KEDA"]
    vLLM["vLLM Inference Servers"]
    EPP["EPP Service<br/>(Gateway API Inference Extension)"]

    %% Internal flows
    SatEngine -->|queries| PromSource
    SatEngine -->|uses| SatAnalyzer
    SatEngine -->|constrained by| GPULimiter
    SatEngine -->|writes decisions| DecisionCache
    SFZEngine -->|reads EPP metrics| EPP
    SFZEngine -->|writes decisions| DecisionCache
    SFZEngine -->|direct scale 0→1| DirectActuator

    DecisionCache -->|read by| VAController
    VAController -->|emits metrics via| MetricsActuator
    VAController -->|updates status| K8sAPI

    IPController -->|watches| InferencePoolCR
    CMController -->|watches| ConfigMapRes
    STZEnforcer -->|applies policy| SatEngine

    %% External flows
    VACR -->|watched by| VAController
    PromSource -->|queries| Prometheus
    PodScraper -->|scrapes| vLLM
    vLLM -->|emits metrics to| Prometheus
    DirectActuator -->|scale subresource| K8sAPI
    MetricsActuator -->|wva_desired_replicas<br/>wva_desired_ratio| HPA

