    CR -->|"get,list,patch,<br/>update,watch"| Notebooks
    CR -->|"patch,update"| NotebooksFinalizers
    CR -->|"get"| NotebooksStatus
    CR -->|"get,list,watch"| Gateways
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| HTTPRoutes
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| ReferenceGrants
    CR -->|"create,get,list,<br/>patch,update,watch"| NetworkPolicies
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| CRBResource
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RoleBindings
    CR -->|"create,get,list,<br/>patch,update,watch"| Roles
    CR -->|"create"| TokenReviews
    CR -->|"create"| SAR
    CR -->|"get,list,watch"| Proxies
    CR -->|"get,list,watch"| ImageStreams
    CR -->|"delete,get,list,<br/>patch,update,watch"| OAuthClients
