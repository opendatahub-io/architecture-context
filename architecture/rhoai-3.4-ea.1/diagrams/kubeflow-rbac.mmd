        Roles["rbac.authorization.k8s.io<br/>roles"]
    end

    subgraph "Auth Resources"
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "OpenShift Resources"
        Proxies["config.openshift.io<br/>proxies"]
        ImageStreams["image.openshift.io<br/>imagestreams"]
        OAuthClients["oauth.openshift.io<br/>oauthclients"]
        DSPAs["datasciencepipelinesapplications.<br/>opendatahub.io<br/>datasciencepipelinesapplications"]
    end

    %% Controller SA bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% Notebook SA bindings
    NotebookSA -->|"bound via"| AuthDelegator
    AuthDelegator -->|"grants"| SystemAuthDelegator

    %% CR permissions
    CR -->|"create,get,list,<br/>patch,update,watch"| ConfigMaps
    CR -->|"create,get,list,<br/>patch,update,watch"| Secrets
