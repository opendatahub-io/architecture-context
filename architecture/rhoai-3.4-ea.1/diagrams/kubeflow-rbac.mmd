%% RBAC Visualization - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA_Manager["manager<br/>(controller namespace)"]
        SA_Notebook["{notebook} SA<br/>(user namespace,<br/>per notebook)"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_AuthDeleg["{notebook}-rbac-{ns}-<br/>auth-delegator<br/>(Cluster-scoped, dynamic)"]
    end

    subgraph "Role Bindings"
        RB_Leader["leader-election-rolebinding<br/>(controller namespace)"]
        RB_Elyra["elyra-pipelines-{notebook}<br/>(user namespace, dynamic)"]
    end

    subgraph "Cluster Roles"
        CR_Manager["manager-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_Edit["notebooks-edit"]
        CR_View["notebooks-view"]
        CR_Admin["notebooks-admin<br/>(aggregates notebooks-edit)"]
    end

    subgraph "Roles"
        R_Leader["leader-election-role<br/>(controller namespace)"]
        R_Pipeline["ds-pipeline-user-access-dspa<br/>(user namespace)"]
    end

    subgraph "API Resources - manager-role"
        Res_Core["Core API<br/>configmaps, secrets,<br/>serviceaccounts, services<br/>[get,list,watch,create,<br/>update,patch]"]
        Res_Auth["authentication.k8s.io<br/>tokenreviews<br/>[create]"]
        Res_Authz["authorization.k8s.io<br/>subjectaccessreviews<br/>[create]"]
        Res_GW["gateway.networking.k8s.io<br/>gateways [get,list,watch]<br/>httproutes, referencegrants<br/>[create,delete,get,list,<br/>patch,update,watch]"]
        Res_KF["kubeflow.org<br/>notebooks [get,list,watch,<br/>patch,update]<br/>notebooks/finalizers [patch,update]<br/>notebooks/status [get]"]
        Res_Net["networking.k8s.io<br/>networkpolicies<br/>[create,get,list,patch,<br/>update,watch]"]
        Res_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/>[create,delete,get,list,<br/>patch,update,watch]"]
        Res_OCP["OpenShift APIs<br/>proxies [get,list,watch]<br/>imagestreams [get,list,watch]<br/>oauthclients [delete,get,list,<br/>patch,update,watch]<br/>routes [get,list,watch]"]
        Res_DSPA["DSPA API<br/>dspa [get,list,watch]<br/>dspa/api [create,delete,<br/>get,patch,update]"]
    end

    subgraph "API Resources - User Roles"
        Res_NB_View["kubeflow.org<br/>notebooks, notebooks/status<br/>[get,list,watch]"]
        Res_NB_Edit["kubeflow.org<br/>notebooks, notebooks/status<br/>[get,list,watch,create,delete,<br/>deletecollection,patch,update]"]
    end

    %% Manager SA bindings
    SA_Manager -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    SA_Manager -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% Manager role permissions
    CR_Manager -->|permissions| Res_Core
    CR_Manager -->|permissions| Res_Auth
    CR_Manager -->|permissions| Res_Authz
    CR_Manager -->|permissions| Res_GW
    CR_Manager -->|permissions| Res_KF
    CR_Manager -->|permissions| Res_Net
    CR_Manager -->|permissions| Res_RBAC
    CR_Manager -->|permissions| Res_OCP
    CR_Manager -->|permissions| Res_DSPA

    %% Notebook SA bindings (dynamic)
    SA_Notebook -->|bound via| CRB_AuthDeleg
    CRB_AuthDeleg -->|grants| CR_AuthDeleg
    SA_Notebook -->|bound via| RB_Elyra
    RB_Elyra -->|grants| R_Pipeline

    %% User-facing roles
    CR_View -->|permissions| Res_NB_View
    CR_Edit -->|permissions| Res_NB_Edit
    CR_Admin -->|aggregates| CR_Edit

