%% RBAC Matrix Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA["odh-notebook-controller-manager<br/>(opendatahub namespace)"]
        NotebookSA["{notebook-name}<br/>({notebook-namespace})"]
    end

    subgraph "ClusterRole Bindings"
        CRB["odh-notebook-controller-<br/>manager-rolebinding"]
        AuthDelegator["{notebook}-rbac-{ns}-<br/>auth-delegator"]
    end

    subgraph "ClusterRoles"
        CR["odh-notebook-controller-<br/>manager-role"]
        SystemAuthDelegator["system:auth-delegator"]
        NotebooksEdit["notebooks-edit"]
        NotebooksView["notebooks-view"]
        NotebooksAdmin["notebooks-admin<br/>(aggregates notebooks-edit)"]
    end

    subgraph "Core API Resources"
        ConfigMaps["core<br/>configmaps"]
        Secrets["core<br/>secrets"]
        ServiceAccounts["core<br/>serviceaccounts"]
        Services["core<br/>services"]
    end

    subgraph "Kubeflow Resources"
        Notebooks["kubeflow.org<br/>notebooks"]
        NotebooksFinalizers["kubeflow.org<br/>notebooks/finalizers"]
        NotebooksStatus["kubeflow.org<br/>notebooks/status"]
    end

    subgraph "Gateway API Resources"
        Gateways["gateway.networking.k8s.io<br/>gateways"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes"]
        ReferenceGrants["gateway.networking.k8s.io<br/>referencegrants"]
    end

    subgraph "Network & RBAC Resources"
        NetworkPolicies["networking.k8s.io<br/>networkpolicies"]
