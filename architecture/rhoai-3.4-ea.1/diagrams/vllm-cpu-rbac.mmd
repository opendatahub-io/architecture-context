    end

    %% Auth flows
    BearerAuth -->|"401 if invalid"| ChatAPI
    BearerAuth -->|"401 if invalid"| CompAPI
    BearerAuth -->|"401 if invalid"| EmbedAPI
    BearerAuth -->|"401 if invalid"| ResponsesAPI
    BearerAuth -->|"401 if invalid"| AudioAPI
    BearerAuth -->|"401 if invalid"| MessagesAPI

    NoAuth --> Health
    NoAuth --> Metrics
    NoAuth --> Version
    NoAuth --> Load
    NoAuth --> Models
    NoAuth --> Tokenize
    NoAuth --> Detokenize

    GRPCNoAuth --> Generate
    GRPCNoAuth --> HealthGRPC
    GRPCNoAuth --> Abort
    GRPCNoAuth --> ModelInfo

    %% Secret bindings
    APIKey -->|"configures"| BearerAuth
    SSLKey -->|"TLS termination"| Container
    SSLCert -->|"TLS termination"| Container
    SSLCACert -->|"client cert validation"| Container

    KServeRBAC -->|"manages"| Container
    KubeRBACProxy -->|"additional auth layer"| Container

