/*
 * C4 Context Diagram - kube-auth-proxy
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/kube-auth-proxy.md
 */

workspace {
    model {
        user = person "User / Client" "End user or service accessing RHOAI platform components"
        serviceAccount = person "Service Account" "Kubernetes service account authenticating via TokenReview"

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "FIPS-compliant authentication and authorization reverse proxy combining OAuth2/OIDC authn and Kubernetes RBAC authz" {
            entrypoint = container "Entrypoint Dispatcher" "Selects between auth and rbac mode based on PROXY_MODE env var; defaults to rbac mode" "Go Binary"
            authProxy = container "kube-auth-proxy" "OAuth2/OIDC authentication reverse proxy supporting OpenShift OAuth and generic OIDC providers" "Go Binary" {
                tags "AuthMode"
            }
            rbacProxy = container "kube-rbac-proxy" "Kubernetes RBAC authorization proxy using SubjectAccessReview API" "Go Binary" {
                tags "RBACMode"
            }
            oidcProvider = container "OIDC Provider Module" "Standards-compliant OIDC authentication with discovery, JWKS, PKCE" "Go Package"
            openshiftProvider = container "OpenShift Provider Module" "OpenShift OAuth with SA auto-detection and endpoint discovery" "Go Package"
            tokenReviewValidator = container "K8s TokenReview Validator" "Validates Kubernetes service account tokens via TokenReview API" "Go Package"
            sessionManager = container "Session Management" "Cookie and Redis-based session storage" "Go Package"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Provides TokenReview and SubjectAccessReview APIs" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "OpenShift internal OAuth2 authentication service" "External"
        oidcProviderExt = softwareSystem "OIDC Provider" "External OpenID Connect identity provider" "External"
        redis = softwareSystem "Redis" "Optional external session storage backend" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        upstreamApp = softwareSystem "Upstream Application" "RHOAI platform component being protected (Dashboard, Model Registry, etc.)" "Internal RHOAI"
        gatewayAPI = softwareSystem "Envoy / Gateway API" "Ingress gateway with ext_authz integration" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHODS Operator" "Deploys and configures kube-auth-proxy sidecars" "Internal RHOAI"

        /* Relationships */
        user -> kubeAuthProxy "Authenticates via OAuth2/OIDC or Bearer Token" "HTTPS/443"
        serviceAccount -> kubeAuthProxy "Authenticates via SA Token" "HTTP/4180 or HTTPS/8443"

        gatewayAPI -> kubeAuthProxy "ext_authz integration, forwards requests" "HTTP/4180 or HTTPS/8443"
        rhoaiOperator -> kubeAuthProxy "Deploys as sidecar container" "Kubernetes API"

        kubeAuthProxy -> k8sAPI "TokenReview and SubjectAccessReview API calls" "HTTPS/443"
        kubeAuthProxy -> openshiftOAuth "OAuth2 Authorization Code flow" "HTTPS/443"
        kubeAuthProxy -> oidcProviderExt "OIDC discovery, token exchange, JWKS retrieval" "HTTPS/443"
        kubeAuthProxy -> redis "Session storage (optional)" "Redis/6379"
        kubeAuthProxy -> upstreamApp "Forwards authenticated/authorized requests with identity headers" "HTTP/HTTPS/h2c"
        kubeAuthProxy -> prometheus "Exposes /metrics endpoint" "HTTP"

        /* Internal container relationships */
        entrypoint -> authProxy "Starts in auth mode"
        entrypoint -> rbacProxy "Starts in rbac mode (default)"
        authProxy -> oidcProvider "Uses for OIDC authentication"
        authProxy -> openshiftProvider "Uses for OpenShift OAuth"
        authProxy -> tokenReviewValidator "Uses for SA token validation"
        authProxy -> sessionManager "Uses for session persistence"
    }

    views {
        systemContext kubeAuthProxy "SystemContext" {
            include *
            autoLayout
        }

        container kubeAuthProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #f5a623
                color #ffffff
                shape Person
            }
            element "Container" {
                background #5ba3d9
                color #ffffff
            }
            element "AuthMode" {
                background #4a90e2
            }
            element "RBACMode" {
                background #4a90e2
            }
        }
    }
}
