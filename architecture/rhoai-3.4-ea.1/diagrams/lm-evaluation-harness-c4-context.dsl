/*
 * C4 Context Diagram: lm-evaluation-harness
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/lm-evaluation-harness.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Defines evaluation jobs via LMEvalJob CRDs"

        lmEvalHarness = softwareSystem "lm-evaluation-harness" "Batch-oriented containerized runtime for language model evaluation using EleutherAI lm-evaluation-harness framework" {
            adapter = container "LMEvalAdapter" "EvalHub adapter orchestrating evaluation runs with lifecycle callbacks" "Python (FrameworkAdapter)"
            lmEvalCore = container "lm_eval Core Library" "EleutherAI evaluation framework: task management, model abstraction, metric computation" "Python Library"
            localCompletions = container "LocalCompletionsAPI" "Sends inference requests to OpenAI-compatible /v1/completions endpoints" "Python Model Backend"
            ociPublisher = container "OCI Artifact Publisher" "Packages results into OCI artifacts and pushes via skopeo" "Python Script"
            taskManager = container "Task Manager" "Loads and manages hundreds of YAML-defined benchmark tasks" "Python Module"
            unitxt = container "Unitxt Integration" "Structured evaluation via Unitxt framework" "Python Module"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Creates Kubernetes Jobs using lm-evaluation-harness image; manages LMEvalJob CRD lifecycle" "Internal RHOAI"
        evalHub = softwareSystem "EvalHub Service" "Evaluation orchestration service receiving status callbacks and results" "Internal RHOAI"
        modelEndpoint = softwareSystem "Model Serving Endpoint" "KServe/vLLM model inference endpoint (OpenAI-compatible)" "Internal RHOAI"
        ociRegistry = softwareSystem "OCI Container Registry" "Stores evaluation result artifacts as OCI artifacts" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Public model/dataset/tokenizer repository" "External"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster API server for Job creation and management" "Infrastructure"

        datascientist -> trustyaiOperator "Creates LMEvalJob CR via kubectl/Dashboard"
        trustyaiOperator -> lmEvalHarness "Creates K8s Job using container image"
        trustyaiOperator -> kubernetesAPI "Creates Job resources" "HTTPS/6443"

        lmEvalHarness -> evalHub "Reports job status and results" "HTTPS/443"
        lmEvalHarness -> modelEndpoint "Sends inference requests" "HTTP(S)/8080 or 443"
        lmEvalHarness -> ociRegistry "Pushes evaluation result OCI artifacts" "HTTPS/443"
        lmEvalHarness -> huggingfaceHub "Downloads tokenizers, datasets, model configs" "HTTPS/443"

        adapter -> lmEvalCore "Orchestrates evaluation run"
        lmEvalCore -> localCompletions "Sends inference requests"
        lmEvalCore -> taskManager "Loads benchmark tasks"
        lmEvalCore -> unitxt "Uses structured evaluation"
        adapter -> ociPublisher "Publishes result artifacts"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
