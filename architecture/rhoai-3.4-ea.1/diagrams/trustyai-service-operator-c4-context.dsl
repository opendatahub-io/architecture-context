// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates TrustyAI resources for model explainability, evaluation, and guardrails"
        admin = person "Platform Admin" "Deploys and configures the TrustyAI operator"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller Kubernetes operator managing AI/ML trustworthiness services" {
            operatorManager = container "Operator Manager" "Main entrypoint with leader election, starts all controllers" "Go Binary"
            tasController = container "TrustyAIService Controller" "Manages TrustyAI explainability service deployments" "Go Controller (controller-runtime)"
            lmevalController = container "LMEvalJob Controller" "Creates pods for LLM evaluation benchmark jobs" "Go Controller (controller-runtime)"
            kueueIntegration = container "LMEvalJob Kueue Integration" "Integrates LMEvalJob with Kueue workload scheduling" "Go Controller (Kueue JobFramework)"
            gorchController = container "GuardrailsOrchestrator Controller" "Deploys guardrails orchestrator with detectors" "Go Controller (controller-runtime)"
            nemoController = container "NemoGuardrails Controller" "Deploys NeMo Guardrails server instances" "Go Controller (controller-runtime)"
            evalhubController = container "EvalHub Controller" "Deploys evaluation hub API service" "Go Controller (controller-runtime)"
        }

        kserve = softwareSystem "KServe / ModelMesh" "ML model serving platform with InferenceService CRD" "Internal ODH"
        kueue = softwareSystem "Kueue" "Workload scheduling and resource management" "External"
        istio = softwareSystem "Istio Service Mesh" "Traffic management with DestinationRules and VirtualServices" "External"
        prometheus = softwareSystem "Prometheus / Monitoring Stack" "Metrics collection via ServiceMonitors" "Internal ODH"
        openshift = softwareSystem "OpenShift Platform" "Routes, service-serving-certs, RBAC" "External"
        mlflow = softwareSystem "MLFlow Server" "Experiment tracking and run management" "Internal ODH"
        postgresql = softwareSystem "PostgreSQL" "Persistent database storage for TrustyAI and EvalHub" "External"
        s3 = softwareSystem "S3-Compatible Storage" "Model data and evaluation results storage" "External"
        ociRegistry = softwareSystem "OCI Registry" "Container/artifact registry for evaluation results" "External"

        // User interactions
        user -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator, NemoGuardrails, EvalHub CRs via kubectl"
        admin -> trustyaiOperator "Deploys and configures operator"

        // Internal container relationships
        operatorManager -> tasController "Starts"
        operatorManager -> lmevalController "Starts"
        operatorManager -> kueueIntegration "Starts"
        operatorManager -> gorchController "Starts"
        operatorManager -> nemoController "Starts"
        operatorManager -> evalhubController "Starts"

        // External dependencies
        trustyaiOperator -> kserve "Watches InferenceServices; patches for payload processing; auto-discovers for guardrails" "HTTP/HTTPS"
        trustyaiOperator -> kueue "Creates Workloads for LMEvalJob scheduling" "CRD"
        trustyaiOperator -> istio "Creates DestinationRules and VirtualServices" "CRD"
        trustyaiOperator -> prometheus "Creates ServiceMonitors for metrics" "CRD"
        trustyaiOperator -> openshift "Creates Routes for external access; uses service-serving-certs" "HTTPS/443"
        trustyaiOperator -> mlflow "EvalHub experiment tracking integration" "HTTPS"
        trustyaiOperator -> postgresql "TrustyAI and EvalHub persistent storage" "TCP/5432"
        trustyaiOperator -> s3 "LMEvalJob offline data and results" "HTTPS/443"
        trustyaiOperator -> ociRegistry "LMEvalJob results upload" "HTTPS/443"

        // Reverse dependencies
        kserve -> trustyaiOperator "InferenceService watched by TAS and GORCH controllers"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
