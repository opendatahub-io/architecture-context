/*
 * FMS Guardrails Orchestrator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/fms-guardrails-orchestrator.md
 */

workspace {
    model {
        client = person "Client / Platform Gateway" "Sends text generation and detection requests"

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Rust-based middleware that coordinates AI text generation with content safety guardrails" {
            guardrailsServer = container "Guardrails Server" "Serves guardrails API endpoints for detection and generation" "Rust/axum, Port 8033/TCP"
            healthServer = container "Health Server" "Serves health and info endpoints" "Rust/axum, Port 8034/TCP"
            orchestratorCore = container "Orchestrator Core" "Coordinates detection, generation, and chunking workflows" "Rust"
            generationClient = container "Generation Client" "Abstraction over TGIS and NLP clients with retry logic" "Rust"
            detectorClient = container "Detector Client" "HTTP client for content safety detector services" "Rust/reqwest"
            chunkerClient = container "Chunker Client" "gRPC client for text chunking services" "Rust/tonic"
            tlsModule = container "TLS Module" "Server and client TLS/mTLS via rustls" "Rust/rustls"
            otelExporter = container "OpenTelemetry Exporter" "Distributed tracing and metrics export" "Rust/opentelemetry-otlp"
        }

        tgis = softwareSystem "TGIS Generation Server" "Text Generation Inference Server for LLM generation" "Internal"
        caikitNlp = softwareSystem "caikit-nlp Server" "caikit-nlp text generation backend" "Internal"
        openaiServer = softwareSystem "OpenAI-compatible Server" "vLLM or similar OpenAI API-compatible server" "Internal"
        detectors = softwareSystem "Guardrails Detector Services" "Content safety detection services" "Internal"
        chunkers = softwareSystem "Caikit Chunker Services" "Text tokenization and chunking services" "Internal"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry trace and metrics collector" "External"

        # External relationships
        client -> orchestrator "Sends detection/generation requests" "HTTP/HTTPS 8033/TCP"
        orchestrator -> tgis "Text generation via gRPC" "gRPC/8033, TLS/mTLS"
        orchestrator -> caikitNlp "Text generation via gRPC" "gRPC/8085, TLS/mTLS"
        orchestrator -> openaiServer "Chat/text completions" "HTTP/HTTPS 8080, Bearer token"
        orchestrator -> detectors "Content safety detection" "HTTP/HTTPS 8080, Header passthrough"
        orchestrator -> chunkers "Text chunking/tokenization" "gRPC/8085, TLS/mTLS"
        orchestrator -> otlpCollector "Exports traces and metrics" "gRPC/4317 or HTTP/4318"

        # Internal container relationships
        guardrailsServer -> orchestratorCore "Routes requests"
        healthServer -> orchestratorCore "Reports health status"
        orchestratorCore -> generationClient "Delegates generation"
        orchestratorCore -> detectorClient "Delegates detection"
        orchestratorCore -> chunkerClient "Delegates chunking"
        tlsModule -> guardrailsServer "Provides server TLS"
        tlsModule -> generationClient "Provides client TLS"
        tlsModule -> detectorClient "Provides client TLS"
        tlsModule -> chunkerClient "Provides client TLS"
        otelExporter -> otlpCollector "Exports telemetry"
    }

    views {
        systemContext orchestrator "SystemContext" {
            include *
            autoLayout
        }

        container orchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #f9f9f9
                shape Person
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
