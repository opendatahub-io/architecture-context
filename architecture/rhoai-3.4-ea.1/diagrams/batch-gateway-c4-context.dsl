/* C4 Context Diagram - batch-gateway
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/batch-gateway.md
 */

workspace {
    model {
        user = person "API Client" "Submits batch inference jobs and manages files via OpenAI-compatible API"

        batchGateway = softwareSystem "Batch Gateway" "OpenAI-compatible batch inference gateway for the llm-d platform" {
            apiserver = container "API Server" "Exposes /v1/files and /v1/batches REST endpoints for file management and batch job lifecycle" "Go HTTP Service, Port 8000"
            processor = container "Batch Processor" "Polls priority queue, fans out inference requests to downstream gateway, manages job lifecycle" "Go Worker Service, Port 9090"
        }

        redis = softwareSystem "Redis" "Metadata store, priority queue, event channels, and status tracking" "External"
        inferenceGW = softwareSystem "Inference Gateway (llm-d/GAIE)" "Downstream service that processes individual inference requests" "Internal ODH"
        vllmOrchGW = softwareSystem "vllm-orchestrator-gateway" "Alternative downstream inference endpoint" "Internal ODH"
        s3 = softwareSystem "S3-compatible Storage" "Batch input/output JSONL file storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection via scraping" "External"
        certManager = softwareSystem "cert-manager" "Optional TLS certificate management" "External"

        # External relationships
        user -> batchGateway "Submits batch jobs, uploads files" "HTTP/HTTPS 8000/TCP"
        batchGateway -> redis "Stores metadata, queues jobs, publishes events" "Redis 6379/TCP"
        batchGateway -> inferenceGW "Forwards individual inference requests" "HTTP/HTTPS, TLS 1.2+ / mTLS"
        batchGateway -> vllmOrchGW "Alternative inference endpoint" "HTTP/HTTPS"
        batchGateway -> s3 "Stores/retrieves batch JSONL files" "HTTPS/443"
        prometheus -> batchGateway "Scrapes metrics" "HTTP :8000, :9090"
        certManager -> batchGateway "Provisions TLS certificates" "Kubernetes API"

        # Container relationships
        user -> apiserver "POST /v1/batches, POST /v1/files" "HTTP/HTTPS 8000/TCP, X-MaaS-User header"
        apiserver -> redis "Store job metadata, enqueue to priority queue" "Redis 6379/TCP, Password"
        apiserver -> s3 "Store uploaded files" "HTTPS/443, AWS IAM"
        processor -> redis "Dequeue jobs, update status" "Redis 6379/TCP, Password"
        processor -> s3 "Read input files, write output files" "HTTPS/443, AWS IAM"
        processor -> inferenceGW "POST /v1/chat/completions (per line)" "HTTP/HTTPS, Bearer Token, mTLS"
    }

    views {
        systemContext batchGateway "SystemContext" {
            include *
            autoLayout
        }

        container batchGateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
