    subgraph ServiceAccounts["Service Accounts"]
        SA_Auth["ServiceAccount<br/>(auth mode pod)<br/>Provisioned by deploying operator"]
        SA_RBAC["ServiceAccount<br/>(rbac mode pod)<br/>Provisioned by deploying operator"]
    end

    subgraph AuthModePerms["Auth Mode Permissions"]
        CR_Auth["ClusterRole<br/>(provisioned by operator)"]

        subgraph AuthResources["API Resources (auth mode)"]
            TokenReview_Auth["authentication.k8s.io<br/>tokenreviews"]
        end
    end

    subgraph RBACModePerms["RBAC Mode Permissions"]
        CR_RBAC["ClusterRole<br/>(provisioned by operator)"]

        subgraph RBACResources["API Resources (rbac mode)"]
            TokenReview_RBAC["authentication.k8s.io<br/>tokenreviews"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        end
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        OAuth2Cookie["OAuth2 Cookie Session<br/>(auth mode)"]
        BearerJWT["Bearer Token / JWT<br/>(auth + rbac mode)"]
        K8sSAToken["K8s SA Token<br/>via TokenReview<br/>(auth mode)"]
        ClientCert["Client Certificate X.509<br/>(rbac mode)"]
        OIDCJWT["OIDC JWT<br/>(rbac mode)"]
    end

    subgraph AuthzPolicies["Authorization Policies"]
        direction TB
        EmailDomain["Email Domain Validation<br/>(auth mode)"]
        Htpasswd["htpasswd File<br/>(auth mode)"]
        AuthEmails["authenticated-emails-file<br/>(auth mode)"]
        SARPolicy["SubjectAccessReview<br/>(rbac mode)"]
        StaticAuth["Static Authorization Config<br/>(rbac mode)"]
    end

    subgraph Secrets["Secrets"]
        CookieSecret["cookie-secret<br/>(Opaque)<br/>Cookie encryption key"]
        ClientSecret["client-secret<br/>(Opaque)<br/>OAuth2 client secret"]
        TLSSecret["tls-cert/key<br/>(kubernetes.io/tls)<br/>HTTPS listener cert"]
        SAToken["SA Token<br/>(auto-mounted)<br/>K8s API auth"]
    end

    %% Auth mode bindings
    SA_Auth -->|"bound via ClusterRoleBinding<br/>(provisioned by operator)"| CR_Auth
    CR_Auth -->|"create"| TokenReview_Auth

    %% RBAC mode bindings
    SA_RBAC -->|"bound via ClusterRoleBinding<br/>(provisioned by operator)"| CR_RBAC
    CR_RBAC -->|"create"| TokenReview_RBAC
    CR_RBAC -->|"create"| SAR

    %% Auth mechanisms flow
    OAuth2Cookie -.->|"validates"| EmailDomain
    OAuth2Cookie -.->|"validates"| AuthEmails
    BearerJWT -.->|"validates via"| TokenReview_Auth
    BearerJWT -.->|"validates via"| TokenReview_RBAC
    K8sSAToken -.->|"validates via"| TokenReview_Auth
    ClientCert -.->|"authorizes via"| SARPolicy
    OIDCJWT -.->|"authorizes via"| SARPolicy

