/*
 * EvalHub C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/eval-hub.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages LLM evaluation jobs"

        evalhub = softwareSystem "EvalHub" "Lightweight REST API service for orchestrating LLM evaluations across multiple backends" {
            server = container "EvalHub Server" "Go REST API handling evaluation orchestration via net/http router" "Go 1.25, UBI9"
            kubeRbacProxy = container "kube-rbac-proxy" "HTTPS sidecar providing TLS termination and RBAC-based auth" "Go sidecar"
            storage = container "Storage Layer" "Pluggable database abstraction for evaluation data" "SQLite / PostgreSQL"
            k8sRuntime = container "K8s Runtime" "Creates Kubernetes batch/v1 Jobs and ConfigMaps for evaluations" "Go, client-go"
            mlflowClient = container "MLflow Client" "HTTP client for experiment tracking with TLS and SA token auth" "Go"
            metrics = container "Prometheus Metrics" "Request duration, total requests, in-flight instrumentation" "Go"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages EvalHub instances via EvalHub CR" "Internal ODH"
        mlflow = softwareSystem "MLflow Tracking Server" "Experiment tracking and metric/artifact logging" "Internal ODH"
        lmEval = softwareSystem "lm-evaluation-harness" "Evaluation backend for 167+ LLM benchmarks (adapter Job)" "Internal ODH"
        guidellm = softwareSystem "GuideLLM" "Performance benchmarking for LLM inference servers (adapter Job)" "Internal ODH"
        lighteval = softwareSystem "LightEval" "Lightweight evaluation framework for language models (adapter Job)" "Internal ODH"

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for managing Jobs and ConfigMaps" "External"
        postgresql = softwareSystem "PostgreSQL" "Production database for evaluation data persistence" "External"
        ociRegistry = softwareSystem "OCI Registry" "Container/artifact registry for evaluation artifact export" "External"
        modelEndpoints = softwareSystem "Model Inference Endpoints" "Target LLM endpoints for evaluation" "External"

        # Relationships
        user -> evalhub "Creates evaluation jobs, queries results" "HTTPS/8443, Bearer Token"
        trustyaiOperator -> evalhub "Deploys and manages" "EvalHub CR (trustyai.opendatahub.io/v1alpha1)"
        evalhub -> mlflow "Creates experiments, logs metrics" "HTTP(S)/5000 or 443, SA projected token"
        evalhub -> k8sAPI "Creates/deletes Jobs and ConfigMaps" "HTTPS/443, SA token"
        evalhub -> postgresql "Stores evaluation data (production)" "TCP/5432, DB credentials"
        evalhub -> lmEval "Dispatches evaluation benchmarks" "K8s batch/v1 Job"
        evalhub -> guidellm "Dispatches performance benchmarks" "K8s batch/v1 Job"
        evalhub -> lighteval "Dispatches lightweight evaluations" "K8s batch/v1 Job"
        lmEval -> evalhub "Reports benchmark results" "HTTPS/8443, projected SA token"
        guidellm -> evalhub "Reports benchmark results" "HTTPS/8443, projected SA token"
        lighteval -> evalhub "Reports benchmark results" "HTTPS/8443, projected SA token"
        lmEval -> mlflow "Logs metrics and artifacts" "HTTP(S), SA token (1h TTL)"
        lmEval -> ociRegistry "Exports evaluation artifacts" "HTTPS/443, Docker creds"
        lmEval -> modelEndpoints "Runs inference for evaluation" "HTTP(S), variable"
        guidellm -> modelEndpoints "Runs performance benchmarks" "HTTP(S), variable"

        # Container-level relationships
        user -> kubeRbacProxy "HTTPS requests" "HTTPS/8443, TLS 1.2+, Bearer Token"
        kubeRbacProxy -> server "Authenticated requests" "HTTP/8080, localhost"
        server -> k8sRuntime "Dispatches evaluation jobs"
        server -> mlflowClient "Tracks experiments"
        server -> storage "Persists evaluation data"
        server -> metrics "Records request metrics"
        k8sRuntime -> k8sAPI "Creates Jobs/ConfigMaps" "HTTPS/443"
        mlflowClient -> mlflow "REST API calls" "HTTP(S)/5000 or 443"
    }

    views {
        systemContext evalhub "SystemContext" {
            include *
            autoLayout
        }

        container evalhub "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
