// C4 Context Diagram - Llama Stack Distribution
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "AI Application Developer" "Builds AI applications using Llama Stack APIs"

        llamaStackDist = softwareSystem "Llama Stack Distribution" "Unified API server for AI inference, agents, evaluation, safety, and tool orchestration" {
            server = container "Llama Stack Server" "FastAPI/Uvicorn HTTP server exposing all Llama Stack APIs on port 8321" "Python 3.12"
            config = container "config.yaml" "Defines APIs, providers, storage backends, registered resources, and telemetry" "YAML Configuration"
            entrypoint = container "entrypoint.sh" "Container entrypoint that resolves config and optionally wraps with OpenTelemetry instrumentation" "Shell Script"
        }

        // Internal RHOAI Components
        operator = softwareSystem "llama-stack-k8s-operator" "Kubernetes operator that deploys and manages Llama Stack instances" "Internal RHOAI"
        vllm = softwareSystem "vLLM" "LLM inference server for model serving and embeddings" "Internal RHOAI"
        fmsGuardrails = softwareSystem "FMS Guardrails Orchestrator" "Content safety and moderation service" "Internal RHOAI"
        trustyaiLMEval = softwareSystem "TrustyAI LM-Eval" "Model evaluation harness" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "Pipeline execution for RAGAS and Garak evaluations" "Internal RHOAI"
        postgresql = softwareSystem "PostgreSQL" "Persistent KV store and SQL storage backend" "Internal RHOAI"
        milvus = softwareSystem "Milvus" "Remote vector database for embeddings storage and retrieval" "Internal RHOAI"

        // External Cloud Providers
        awsBedrock = softwareSystem "AWS Bedrock" "Cloud LLM inference provider" "External Cloud"
        ibmWatsonx = softwareSystem "IBM watsonx" "Cloud LLM inference provider" "External Cloud"
        azureOpenAI = softwareSystem "Azure OpenAI" "Cloud LLM inference provider" "External Cloud"
        googleVertex = softwareSystem "Google Vertex AI" "Cloud LLM inference provider" "External Cloud"
        openAI = softwareSystem "OpenAI API" "Cloud LLM inference provider" "External Cloud"

        // External Services
        huggingFace = softwareSystem "HuggingFace Hub" "Dataset and model artifact downloads" "External Service"
        awsS3 = softwareSystem "AWS S3" "File and model artifact storage" "External Service"
        braveSearch = softwareSystem "Brave Search API" "Web search tool runtime" "External Service"
        tavilySearch = softwareSystem "Tavily Search API" "Web search tool runtime" "External Service"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Telemetry export for traces and metrics" "External Service"

        // Relationships
        user -> llamaStackDist "Sends AI API requests via HTTP/8321"
        operator -> llamaStackDist "Deploys and manages lifecycle"

        llamaStackDist -> vllm "LLM inference and embeddings" "HTTP/HTTPS, Bearer Token"
        llamaStackDist -> fmsGuardrails "Content safety moderation" "HTTP/HTTPS"
        llamaStackDist -> trustyaiLMEval "Model evaluation" "HTTP/HTTPS, TLS 1.2+"
        llamaStackDist -> kubeflowPipelines "Pipeline execution" "HTTP/HTTPS, TLS 1.2+, API Token"
        llamaStackDist -> postgresql "Persistent storage" "PostgreSQL/5432, Username/Password"
        llamaStackDist -> milvus "Vector database" "gRPC/HTTP, Optional TLS, Token"

        llamaStackDist -> awsBedrock "Cloud inference" "HTTPS/443, AWS IAM"
        llamaStackDist -> ibmWatsonx "Cloud inference" "HTTPS/443, API Key"
        llamaStackDist -> azureOpenAI "Cloud inference" "HTTPS/443, API Key"
        llamaStackDist -> googleVertex "Cloud inference" "HTTPS/443, Service Account"
        llamaStackDist -> openAI "Cloud inference" "HTTPS/443, API Key Bearer"

        llamaStackDist -> huggingFace "Downloads datasets and models" "HTTPS/443"
        llamaStackDist -> awsS3 "File storage" "HTTPS/443, AWS Access Key"
        llamaStackDist -> braveSearch "Web search" "HTTPS/443, API Key"
        llamaStackDist -> tavilySearch "Web search" "HTTPS/443, API Key"
        llamaStackDist -> otelCollector "Telemetry export" "HTTP OTLP"

        // Container-level relationships
        entrypoint -> server "Launches with config"
        config -> server "Configures providers and APIs"
    }

    views {
        systemContext llamaStackDist "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackDist "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Cloud" {
                background #f5a623
                color #ffffff
            }
            element "External Service" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
