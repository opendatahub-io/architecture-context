/*
 * C4 Context Diagram - OpenVINO Model Server (OVMS)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys models and sends inference requests"
        appClient = person "Application Client" "Sends inference requests via REST/gRPC APIs"

        ovms = softwareSystem "OpenVINO Model Server (OVMS)" "High-performance model inference server built on Intel OpenVINO, serving AI/ML models via gRPC and REST APIs" {
            grpcServer = container "gRPC Server" "Hosts TFS PredictionService, ModelService, and KFS GRPCInferenceService" "C++ (gRPC framework)"
            httpServer = container "HTTP/REST Server" "Hosts TFS v1, KServe v2, OpenAI v3, and metrics endpoints" "C++ (Drogon framework)"
            modelManager = container "Model Manager" "Core model registry managing model instances, DAG pipelines, and MediaPipe graphs" "C++"
            mediaPipeEngine = container "MediaPipe Engine" "Graph-based pipeline execution for generative AI workloads" "C++ (MediaPipe)"
            openvinoRuntime = container "OpenVINO Runtime" "Core inference engine for model execution" "C++ (OpenVINO 2025.4)"
            storageBackends = container "Storage Backends" "S3, GCS, Azure, Local filesystem access" "C++ (Cloud SDKs)"
            metricModule = container "Metric Module" "Prometheus-compatible metrics collection" "C++"
            hfPullModule = container "HuggingFace Pull Module" "Downloads models from HuggingFace Hub" "C++"
        }

        kserve = softwareSystem "KServe" "Manages OVMS pod lifecycle and routing via InferenceService CRD" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "UI for deploying OVMS-based inference services" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"

        awsS3 = softwareSystem "AWS S3" "Model artifact storage" "External"
        gcs = softwareSystem "Google Cloud Storage" "Model artifact storage" "External"
        azureBlob = softwareSystem "Azure Blob Storage" "Model artifact storage" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model download hub" "External"

        /* Relationships */
        appClient -> ovms "Sends inference requests" "gRPC/HTTP plaintext"
        user -> kserve "Creates InferenceService via kubectl/Dashboard"
        user -> odhDashboard "Deploys models via UI"

        kserve -> ovms "Deploys and manages OVMS pods"
        odhDashboard -> kserve "Creates InferenceService resources"
        prometheus -> ovms "Scrapes metrics" "HTTP/rest_port"

        ovms -> awsS3 "Downloads model artifacts" "HTTPS/443"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443"
        ovms -> azureBlob "Downloads model artifacts" "HTTPS/443"
        ovms -> huggingface "Downloads models" "HTTPS/443"

        /* Container relationships */
        appClient -> grpcServer "TFS/KServe inference" "gRPC plaintext"
        appClient -> httpServer "REST inference / OpenAI API" "HTTP plaintext"

        httpServer -> modelManager "Routes inference requests"
        grpcServer -> modelManager "Routes inference requests"
        httpServer -> mediaPipeEngine "Routes v3 GenAI requests"
        mediaPipeEngine -> modelManager "Executes model inference"
        modelManager -> openvinoRuntime "Executes inference"
        modelManager -> storageBackends "Loads models from storage"
        storageBackends -> awsS3 "S3 access" "HTTPS/443 TLS 1.2+"
        storageBackends -> gcs "GCS access" "HTTPS/443 TLS 1.2+"
        storageBackends -> azureBlob "Azure access" "HTTPS/443 TLS 1.2+"
        hfPullModule -> huggingface "Downloads models" "HTTPS/443 TLS 1.2+"
        prometheus -> metricModule "Scrapes /metrics" "HTTP plaintext"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #85bbf0
                color #000000
            }
        }
    }
}
