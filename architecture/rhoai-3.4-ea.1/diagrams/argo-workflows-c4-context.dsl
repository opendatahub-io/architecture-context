// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines via DSP"

        argoWorkflows = softwareSystem "Argo Workflows" "Container-native workflow engine for orchestrating parallel jobs on Kubernetes" {
            workflowController = container "workflow-controller" "Watches Workflow CRs, creates/manages pods, handles scheduling, retries, artifact GC, cron workflows, TTL cleanup. Leader election via Leases." "Go Controller"
            argoexec = container "argoexec" "Runs inside workflow step pods as sidecar/init container. Manages artifacts, waits for completion, captures outputs, reports results." "Go Executor (sidecar)"
        }

        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and configures Argo Workflows components" "Internal RHOAI"
        dspApiServer = softwareSystem "Data Science Pipelines API Server" "Submits workflows via Kubernetes API" "Internal RHOAI"
        mlMetadata = softwareSystem "ML Metadata" "Metadata tracking for ML workflows" "Internal RHOAI"

        kubernetesApi = softwareSystem "Kubernetes API" "Core API for pod management, CRD operations, leader election" "External"
        s3Storage = softwareSystem "S3/MinIO Storage" "Artifact storage for workflow inputs/outputs" "External"
        postgresql = softwareSystem "PostgreSQL" "Optional workflow archive persistence" "External"
        mysql = softwareSystem "MySQL" "Optional workflow archive persistence (alternative)" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for argo-server (upstream)" "External"
        containerRegistry = softwareSystem "Container Registries" "Image pull for workflow step containers" "External"

        // Relationships
        datascientist -> dspApiServer "Creates and monitors pipelines"
        dspApiServer -> kubernetesApi "Creates Workflow CRs" "HTTPS/443"
        dspOperator -> argoWorkflows "Deploys and configures"

        workflowController -> kubernetesApi "Watch CRs, Pod CRUD, status updates" "HTTPS/443 TLS 1.2+"
        argoexec -> kubernetesApi "Report task results" "HTTPS/443 TLS 1.2+"
        argoexec -> s3Storage "Upload/download artifacts" "HTTPS/443 TLS"
        workflowController -> postgresql "Archive workflows (optional)" "TCP/5432 TLS"
        workflowController -> mysql "Archive workflows (optional)" "TCP/3306 TLS"
        kubernetesApi -> containerRegistry "Pull workflow step images" "HTTPS/443"

        mlMetadata -> argoWorkflows "Sidecar integration for metadata tracking"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
