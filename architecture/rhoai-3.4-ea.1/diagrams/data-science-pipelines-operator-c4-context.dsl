// C4 Context Diagram - Data Science Pipelines Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages ML pipelines via DSPA CRs"
        admin = person "Platform Admin" "Configures DSPA instances and manages operator"

        dspo = softwareSystem "Data Science Pipelines Operator" "Manages lifecycle of Data Science Pipelines infrastructure by reconciling DSPA custom resources" {
            controller = container "DSPO Controller Manager" "Reconciles DSPA CRs, deploys all sub-components via Go templates" "Go Operator (controller-runtime)"
            apiServer = container "DS Pipeline API Server" "KFP V2 API for pipeline CRUD, execution, and artifact management" "Deployment (8888/TCP, 8887/TCP)"
            kubeRBACProxy = container "kube-rbac-proxy" "Authenticates/authorizes API requests via SubjectAccessReview" "Sidecar (8443/TCP)"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo to API server" "Deployment"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages cron-scheduled pipeline runs" "Deployment"
            argoController = container "Argo Workflow Controller" "Orchestrates pipeline step execution via Workflow CRs" "Deployment"
            mlmdServer = container "MLMD gRPC Server" "ML Metadata store for artifact lineage tracking" "Deployment (8080/TCP)"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Proxied MLMD gRPC access with auth" "Deployment (9090/TCP, 8443/TCP)"
            webhook = container "DS Pipelines Webhook" "Validates/mutates Pipeline and PipelineVersion CRs" "Deployment"
            mariaDB = container "MariaDB" "Pipeline metadata storage" "Database (3306/TCP)"
            minIO = container "MinIO" "Pipeline artifact object storage" "Object Store (9000/TCP)"
        }

        openshiftRouter = softwareSystem "OpenShift Router" "Provides external access via Routes" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for CR management and RBAC" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        externalS3 = softwareSystem "External S3 Storage" "External object storage for artifacts" "External"
        externalDB = softwareSystem "External Database" "External database for metadata" "External"
        kserve = softwareSystem "KServe" "Model serving - pipeline steps can create InferenceServices" "Internal ODH"
        codeflare = softwareSystem "CodeFlare / Ray" "Distributed computing - pipeline steps can create AppWrappers/RayClusters" "Internal ODH"
        odhCABundle = softwareSystem "odh-trusted-ca-bundle" "Global CA bundle for TLS connections" "Internal ODH"

        // User interactions
        user -> dspo "Creates DSPA CRs, submits pipelines via kubectl/Dashboard"
        admin -> dspo "Configures DSPA instances, manages operator"

        // Operator interactions
        dspo -> k8sAPI "Manages CRs, leader election, RBAC checks" "HTTPS/443"
        dspo -> openshiftRouter "Creates Routes for external access" "Route API"
        dspo -> openshiftServiceCA "Requests TLS certificates via annotations"
        dspo -> prometheus "Exposes metrics via ServiceMonitor" "HTTP/8080"

        // Data storage
        dspo -> externalS3 "Stores pipeline artifacts" "HTTPS/443"
        dspo -> externalDB "Stores pipeline metadata" "MySQL/3306"

        // Internal ODH integrations
        dspo -> kserve "Pipeline steps deploy InferenceServices" "RBAC"
        dspo -> codeflare "Pipeline steps create distributed workloads" "RBAC"
        dspo -> odhCABundle "Watches for CA bundle updates" "ConfigMap"

        // External access
        openshiftRouter -> dspo "Routes traffic to API Server and MLMD" "HTTPS/8443 Reencrypt"

        // Container-level relationships
        controller -> apiServer "Deploys and manages"
        controller -> argoController "Deploys and manages"
        controller -> persistenceAgent "Deploys and manages"
        controller -> scheduledWorkflow "Deploys and manages"
        controller -> mlmdServer "Deploys and manages"
        controller -> mlmdEnvoy "Deploys and manages"
        controller -> mariaDB "Deploys and manages"
        controller -> minIO "Deploys and manages"
        controller -> webhook "Deploys and manages"
        kubeRBACProxy -> apiServer "Proxies authenticated requests" "HTTP(S)/8888"
        apiServer -> mariaDB "Stores metadata" "MySQL/3306"
        apiServer -> minIO "Stores artifacts" "HTTP/9000"
        mlmdServer -> mariaDB "Stores lineage data" "MySQL/3306"
        mlmdEnvoy -> mlmdServer "Forwards gRPC" "gRPC/8080"
        persistenceAgent -> apiServer "Syncs run status" "HTTP(S)/8888"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Database" {
                shape Cylinder
            }
            element "Object Store" {
                shape Cylinder
            }
        }
    }
}
