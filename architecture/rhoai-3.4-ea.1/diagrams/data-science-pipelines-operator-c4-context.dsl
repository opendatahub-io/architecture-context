// C4 Context Diagram - Data Science Pipelines Operator (DSPO)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/data-science-pipelines-operator.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs ML pipelines via dashboard or notebooks"
        admin = person "Platform Admin" "Manages DSPA custom resources to provision pipeline infrastructure"

        dspo = softwareSystem "Data Science Pipelines Operator" "Manages lifecycle of DSP infrastructure via DSPA custom resources" {
            controller = container "DSPO Controller Manager" "Reconciles DSPA CRs, deploys pipeline sub-components via template rendering" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates and mutates Pipeline and PipelineVersion CRs" "Go Service"
            apiServer = container "DSP API Server" "Kubeflow Pipelines V2 REST (8888) and gRPC (8887) API" "Go Service (dynamically created)"
            kubeRBACProxy = container "kube-rbac-proxy" "RBAC-based auth proxy (8443) enforcing SubjectAccessReview" "Sidecar"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo to pipeline DB" "Go Service (dynamically created)"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages cron-scheduled pipeline runs" "Go Service (dynamically created)"
            argoController = container "Argo Workflow Controller" "Orchestrates pipeline execution via Workflow CRDs" "Go Service (dynamically created)"
            mlmdServer = container "MLMD gRPC Server" "ML Metadata storage backend" "gRPC Service (dynamically created)"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy with kube-rbac-proxy for authenticated MLMD access" "Envoy (dynamically created)"
            mariaDB = container "MariaDB" "Default database backend for pipeline metadata" "MariaDB 10.5 (dynamically created, optional)"
        }

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys DSPO via kustomize overlay with RELATED_IMAGE env vars" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Pipeline management UI for data scientists" "Internal RHOAI"
        notebooks = softwareSystem "Notebook Workbenches" "Jupyter notebooks for pipeline submission" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving - InferenceService creation from pipeline tasks" "Internal RHOAI"
        ray = softwareSystem "Ray" "Distributed computing - RayCluster/RayJob from pipeline tasks" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare" "Workload management - AppWrapper from pipeline tasks" "Internal RHOAI"

        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for CR management" "External"
        s3 = softwareSystem "S3 Object Store" "Pipeline artifact storage (Minio default or external)" "External"
        serviceCA = softwareSystem "OpenShift Service CA" "Auto-provisions TLS certificates for services" "External"
        monitoring = softwareSystem "OpenShift Monitoring" "Prometheus metrics collection via ServiceMonitor" "External"

        // User interactions
        admin -> dspo "Creates DSPA CRs via kubectl/oc"
        dataScientist -> odhDashboard "Manages pipelines via UI"
        dataScientist -> notebooks "Submits pipelines from notebooks"

        // Internal RHOAI integrations
        rhodsOperator -> dspo "Deploys via kustomize overlay" "Kustomize"
        odhDashboard -> dspo "Pipeline management REST API" "HTTPS/443 (Route)"
        notebooks -> dspo "Pipeline submission" "HTTPS/8443"

        // DSPO internal flows
        controller -> apiServer "Deploys via manifestival templates"
        controller -> mariaDB "Health check" "MySQL/3306"
        controller -> s3 "Health check" "HTTPS/443"
        kubeRBACProxy -> apiServer "Proxies authenticated requests" "HTTP(S)/8888"
        apiServer -> mariaDB "Pipeline metadata" "MySQL/3306 TLS"
        apiServer -> s3 "Pipeline artifacts" "HTTPS/443"
        apiServer -> k8sAPI "Create Workflow CRs" "HTTPS/6443"
        persistenceAgent -> apiServer "Sync run status" "HTTP(S)/8888"
        argoController -> k8sAPI "Watch/manage Workflows" "HTTPS/6443"
        mlmdEnvoy -> mlmdServer "Proxy gRPC" "gRPC/8080"

        // External service integrations
        dspo -> k8sAPI "CR management, SubjectAccessReview" "HTTPS/6443"
        dspo -> s3 "Artifact storage" "HTTPS/443"
        dspo -> kserve "InferenceService creation" "HTTPS/6443 (via K8s API)"
        dspo -> ray "RayCluster/RayJob creation" "HTTPS/6443 (via K8s API)"
        dspo -> codeflare "AppWrapper creation" "HTTPS/6443 (via K8s API)"
        serviceCA -> dspo "Provisions TLS serving certificates"
        monitoring -> dspo "Scrapes Prometheus metrics" "HTTP/8080"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #85bbf0
                color #000000
            }
        }
    }
}
