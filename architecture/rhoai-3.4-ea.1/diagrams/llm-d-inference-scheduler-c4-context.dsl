// C4 Context Diagram: llm-d-inference-scheduler
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4-ea.1/llm-d-inference-scheduler.md

workspace {
    model {
        user = person "Client Application" "Sends LLM inference requests (chat completions, completions)"

        llmdScheduler = softwareSystem "llm-d-inference-scheduler" "Optimized inference request routing scheduler for llm-d framework with P/D disaggregation support" {
            epp = container "EPP (Endpoint Picker)" "Receives inference requests from Envoy via ext-proc, applies scheduling plugins, selects optimal backend pod" "Go Service (gRPC ext-proc)"
            pdSidecar = container "P/D Routing Sidecar" "Orchestrates Prefill/Decode disaggregation, SSRF protection, data-parallel routing" "Go HTTP Reverse Proxy"
            filterPlugins = container "Filter Plugins" "Exclude candidate pods: decode-filter, prefill-filter, by-label, by-label-selector" "Go Plugin Framework"
            scorerPlugins = container "Scorer Plugins" "Score candidate pods: prefix-cache, load-aware, active-request, session-affinity, no-hit-lru" "Go Plugin Framework"
            profileHandlers = container "Profile Handlers" "Select scheduling profiles: pd-profile, data-parallel-profile, single-profile" "Go Plugin Framework"
            ssrfValidator = container "SSRF AllowlistValidator" "Watches InferencePool/Pod resources to build dynamic allowlist for prefill target validation" "Go Informer"
        }

        envoy = softwareSystem "Envoy Gateway" "Data plane gateway with ext-proc filter support" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API for routing infrastructure (Gateway, HTTPRoute CRs)" "External"
        gie = softwareSystem "Gateway API Inference Extension (GIE)" "Core EPP framework, scheduling types, and plugin registry" "External"
        vllm = softwareSystem "vLLM" "LLM inference engine (decoder and prefill workers)" "External"
        kvCacheMgr = softwareSystem "llm-d-kv-cache-manager" "KV cache state tracking for precise prefix cache scoring" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server for watching CRs and Pods" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        kserve = softwareSystem "KServe" "InferencePool and Gateway API resources for serving infrastructure" "Internal RHOAI"

        // User interactions
        user -> envoy "Sends inference requests" "HTTP/80"
        envoy -> epp "ext-proc routing callbacks" "gRPC/9002"
        envoy -> vllm "Forwards inference requests (non-P/D)" "HTTP/8000"
        envoy -> pdSidecar "Forwards inference requests (P/D mode)" "HTTPS/8000"

        // EPP internals
        epp -> filterPlugins "Applies filters to candidate pods"
        epp -> scorerPlugins "Scores filtered candidates"
        epp -> profileHandlers "Selects scheduling profile"

        // EPP external
        epp -> k8sAPI "Watches InferencePool CRs and Pods" "HTTPS/443"
        epp -> kvCacheMgr "Subscribes to KV cache state" "ZMQ/5557"

        // P/D Sidecar
        pdSidecar -> ssrfValidator "Validates prefill targets"
        pdSidecar -> vllm "Forwards to local decoder" "HTTP(S)/8001"
        pdSidecar -> vllm "Forwards to remote prefill workers" "HTTP(S)/varies"
        ssrfValidator -> k8sAPI "Watches InferencePool/Pods for allowlist" "HTTPS/443"

        // Monitoring
        prometheus -> epp "Scrapes metrics" "HTTP/9090"

        // Platform dependencies
        llmdScheduler -> gie "Extends with custom plugins" "Go library"
        llmdScheduler -> kserve "Consumes InferencePool CRDs"
        llmdScheduler -> gatewayAPI "Uses Gateway and HTTPRoute CRDs"
    }

    views {
        systemContext llmdScheduler "SystemContext" {
            include *
            autoLayout
        }

        container llmdScheduler "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
