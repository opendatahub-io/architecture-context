// C4 Context Diagram - vllm-gaudi
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM inference endpoints on Intel Gaudi hardware"

        vllmGaudi = softwareSystem "vllm-gaudi" "vLLM hardware plugin for Intel Gaudi HPU accelerators - provides optimized LLM inference serving" {
            openaiServer = container "OpenAI API Server" "OpenAI-compatible HTTP API endpoint (port 8000)" "Python / vLLM"
            hpuPlatform = container "HpuPlatform Plugin" "Registers HPU device support, attention backends, quantization, and worker config" "Python Plugin"
            hpuWorker = container "HPU Worker" "Manages HPU device lifecycle, model loading, KV-cache, distributed inference" "Python"
            hpuModelRunner = container "HPU Model Runner" "Executes model forward passes with bucketing, graph compilation, memory profiling" "Python"
            hpuCommunicator = container "HPU Communicator" "HCCL-based distributed communication for tensor/data parallelism" "Python / HCCL"
            attentionBackends = container "HPU Attention Backends" "V1, Unified, and MLA attention implementations for HPU" "Python"
            customOps = container "HPU Custom Ops" "Fused MoE, LayerNorm, RoPE, FP8, AWQ, GPTQ, LoRA optimizations" "Python / HPU"
            nixlConnector = container "NIXL Connector" "KV-cache transfer for disaggregated prefill/decode" "Python / NIXL"
        }

        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle and traffic routing" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and versioning" "Internal RHOAI"
        vllmCore = softwareSystem "vLLM Core" "Core LLM inference engine (v0.14.1)" "External"
        synapseAI = softwareSystem "Intel Synapse AI" "Habana Gaudi driver stack and runtime (1.23.0)" "External"
        pytorch = softwareSystem "PyTorch" "Deep learning framework with HPU support (2.9.0)" "External"
        ray = softwareSystem "Ray" "Distributed computing framework for multi-HPU inference" "External"
        s3 = softwareSystem "Model Storage (S3/PVC)" "Model artifact and weight storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"

        // User interactions
        user -> kserve "Creates InferenceService CR" "kubectl / Dashboard"
        user -> vllmGaudi "Sends inference requests" "HTTPS/443 via Gateway"

        // Platform interactions
        kserve -> vllmGaudi "Deploys as serving runtime, routes traffic" "HTTP/8000"
        vllmGaudi -> modelRegistry "Model references tracked" "API"
        prometheus -> vllmGaudi "Scrapes metrics" "HTTP/8000 GET /metrics"

        // External dependencies
        vllmGaudi -> vllmCore "Extends via platform plugin entry points" "In-process Python"
        vllmGaudi -> synapseAI "HPU device access via driver and runtime" "Kernel/Device API"
        vllmGaudi -> pytorch "Deep learning ops via HPU-enabled PyTorch" "In-process Python"
        vllmGaudi -> ray "Multi-node distributed inference coordination" "TCP/6379"
        vllmGaudi -> s3 "Downloads model weights at startup" "HTTPS/443"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
