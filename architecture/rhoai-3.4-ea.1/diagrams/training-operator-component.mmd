%% Training Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "Training Operator"
        direction TB
        Controller["training-operator<br/>(controller-runtime)"]
        Webhook["Validating Webhook<br/>9443/TCP HTTPS"]
        CertRotator["Cert Rotator<br/>(OPA cert-controller)"]

        subgraph "Job Controllers"
            PyTorchCtrl["PyTorchJob Controller"]
            TFCtrl["TFJob Controller"]
            MPICtrl["MPIJob Controller"]
            XGBoostCtrl["XGBoostJob Controller"]
            PaddleCtrl["PaddleJob Controller"]
            JAXCtrl["JAXJob Controller"]
        end

        Controller --> PyTorchCtrl
        Controller --> TFCtrl
        Controller --> MPICtrl
        Controller --> XGBoostCtrl
        Controller --> PaddleCtrl
        Controller --> JAXCtrl
        Controller -->|validates via| Webhook
        CertRotator -->|rotates TLS certs| Webhook
    end

    %% CRDs
    User[User / Client] -->|creates| PyTorchJobCR["PyTorchJob CR"]
    User -->|creates| TFJobCR["TFJob CR"]
    User -->|creates| MPIJobCR["MPIJob CR"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR"]
    User -->|creates| PaddleJobCR["PaddleJob CR"]
    User -->|creates| JAXJobCR["JAXJob CR"]

    PyTorchJobCR -->|watched by| PyTorchCtrl
    TFJobCR -->|watched by| TFCtrl
    MPIJobCR -->|watched by| MPICtrl
    XGBoostJobCR -->|watched by| XGBoostCtrl
    PaddleJobCR -->|watched by| PaddleCtrl
    JAXJobCR -->|watched by| JAXCtrl

    %% Created Resources
    PyTorchCtrl -->|creates| Pods["Training Pods"]
    PyTorchCtrl -->|creates| HeadlessSvc["Headless Services"]
    PyTorchCtrl -->|creates| NetPol["NetworkPolicies"]
    PyTorchCtrl -->|creates| HPA["HorizontalPodAutoscaler"]
    TFCtrl -->|creates| Pods
    TFCtrl -->|creates| HeadlessSvc
    MPICtrl -->|creates| Pods
    MPICtrl -->|creates| HeadlessSvc

    %% Dependencies
    Controller -->|API calls| K8sAPI["Kubernetes API Server"]
    Controller -.->|optional| Volcano["Volcano Scheduler"]
    Controller -.->|optional| SchedPlugins["Scheduler Plugins"]

    %% Monitoring
    Prometheus["Prometheus<br/>(OpenShift Monitoring)"] -->|scrapes 8080/TCP| Controller

    %% RHOAI
    RHOAIOp["RHOAI Operator"] -->|deploys via kustomize| Controller

