graph TD
    subgraph "Application-Level Security"
        subgraph "Authentication"
            NoAuth["No Authentication<br/>(at detector level)"]
            NetworkIsolation["Network-Level Isolation<br/>(cluster-internal services)"]
            OrchestratorAuth["Orchestrator handles<br/>upstream authentication"]
        end

        subgraph "Custom Detector Security - Built-in"
            StaticAnalysis["Static Code Analysis<br/>(CustomDetectorRegistry)"]

            subgraph "Forbidden Imports"
                ForbidImport1["os (except os.environ/os.getenv)"]
                ForbidImport2["subprocess"]
                ForbidImport3["sys"]
                ForbidImport4["shutil"]
            end

            subgraph "Forbidden Calls"
                ForbidCall1["eval"]
                ForbidCall2["exec"]
                ForbidCall3["open"]
                ForbidCall4["compile"]
                ForbidCall5["input"]
            end

            StaticAnalysis -->|"checks for"| ForbidImport1
            StaticAnalysis -->|"checks for"| ForbidImport2
            StaticAnalysis -->|"checks for"| ForbidImport3
            StaticAnalysis -->|"checks for"| ForbidImport4
            StaticAnalysis -->|"checks for"| ForbidCall1
            StaticAnalysis -->|"checks for"| ForbidCall2
            StaticAnalysis -->|"checks for"| ForbidCall3
            StaticAnalysis -->|"checks for"| ForbidCall4
            StaticAnalysis -->|"checks for"| ForbidCall5

            Violation["Violation Detected"] -->|"raises"| ImportError["ImportError<br/>(module rejected)"]
        end

        subgraph "SSL/TLS Configuration - Optional"
            SSLConfig["config.yaml"]
            SSLCACerts["ssl_ca_certs<br/>(CA certificate bundle)"]
            ServerSSL["SERVER_* env vars<br/>(server-level SSL)"]
            SSLConfig --> SSLCACerts
            SSLConfig --> ServerSSL
            SSLCACerts -->|"enables"| CertRequired["ssl.CERT_REQUIRED"]
        end

        subgraph "Secrets"
            GitAuth["git_auth_secret<br/>(Opaque)<br/>Provisioned by: Konflux/PaC<br/>Auto-rotate: No"]
        end
    end

    subgraph "RBAC - External"
        ExternalRBAC["No RBAC defined by component<br/>Managed by deploying operator:<br/>- KServe<br/>- Guardrails Orchestrator operator<br/>- Manual deployment"]
    end

    style NoAuth fill:#ff6b6b,color:#fff
    style NetworkIsolation fill:#51cf66,color:#fff
    style OrchestratorAuth fill:#51cf66,color:#fff
    style StaticAnalysis fill:#4a90e2,color:#fff
    style ImportError fill:#ff6b6b,color:#fff
    style ExternalRBAC fill:#e8e8e8
    style GitAuth fill:#f5a623,color:#fff
