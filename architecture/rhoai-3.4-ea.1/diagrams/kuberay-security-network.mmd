    Worker1 -->|"gRPC/6379<br/>mTLS (if enabled)<br/>Client Cert"| GCS
    Worker2 -->|"gRPC/6379<br/>mTLS (if enabled)<br/>Client Cert"| GCS

    KubeRayOp -->|"HTTP/8265<br/>plaintext<br/>No Auth"| Dashboard
    KubeRayOp -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    KubeRayOp -->|"via K8s API<br/>Certificate CRs"| CertMgr

    Prom -->|"HTTP/8080<br/>No Auth"| Metrics
    Prom -->|"HTTP/8080<br/>No Auth"| KubeRayOp

    GCS -.->|"TCP<br/>Configurable"| Redis

