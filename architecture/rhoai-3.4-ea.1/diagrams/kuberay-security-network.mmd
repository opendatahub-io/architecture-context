%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        DSGateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP HTTPS<br/>TLS Gateway-terminated"]
    end

    subgraph ClusterNS["RAY CLUSTER NAMESPACE"]
        direction TB
        subgraph HeadPod["Ray Head Pod (SCC: run-as-ray-user, UID 1000)"]
            KubeRBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>OIDC/OAuth → SAR"]
            RayDashboard["Ray Dashboard<br/>8265/TCP HTTP"]
            RayGCS["Ray GCS<br/>6379/TCP"]
        end
        WorkerPods["Ray Worker Pods<br/>SCC: run-as-ray-user (UID 1000)<br/>10002/TCP"]
        HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>8265, 10001, 6379"]
        HeadNetPol["{cluster}-head<br/>NetworkPolicy"]
        WorkerNetPol["{cluster}-workers<br/>NetworkPolicy"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP metrics<br/>9443/TCP webhook"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>SA Token Auth"]
        CertManager["cert-manager<br/>443/TCP HTTPS<br/>Issuer + Certificate CRs"]
        Prometheus["Prometheus<br/>HTTP scrape"]
        RhodsOp["rhods-operator<br/>Kustomize deployment"]
    end

    subgraph OptionalExt["OPTIONAL EXTERNAL"]
        Redis["Redis (external)<br/>TCP configurable<br/>GCS fault tolerance"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS (Gateway-terminated)"| DSGateway

    %% Ingress → Cluster
    DSGateway -->|"HTTPS/8443<br/>kube-rbac-proxy auth"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8265<br/>localhost (plaintext)"| RayDashboard

    %% Auth check
    KubeRBACProxy -.->|"SAR check<br/>HTTPS/443"| K8sAPI

    %% Intra-cluster communication
    WorkerPods <-->|"TCP/6379, 8076<br/>plaintext or mTLS"| RayGCS
    RayGCS -->|"TCP/10002<br/>plaintext or mTLS"| WorkerPods

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS, SA token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS, SA token"| CertManager
    Prometheus -->|"HTTP/8080<br/>plaintext"| Operator
    RhodsOp -.->|"deploys"| Operator

    %% Optional
    RayGCS -.->|"TCP<br/>configurable"| Redis

    %% NetworkPolicy indicators
    HeadNetPol -.->|"protects"| HeadPod
    WorkerNetPol -.->|"protects"| WorkerPods

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class DSGateway ingress
    class KubeRBACProxy,RayDashboard,RayGCS,WorkerPods,HeadSvc clusterns
    class Operator operator
    class K8sAPI,CertManager,Prometheus,RhodsOp platform
    class HeadNetPol,WorkerNetPol netpol
    class Redis external
