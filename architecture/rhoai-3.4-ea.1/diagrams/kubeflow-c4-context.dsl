/*
 * C4 Context Diagram - ODH Notebook Controller (kubeflow)
 * Generated by: Claude Opus 4.6
 * Generated from: architecture/rhoai-3.4-ea.1/kubeflow.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and uses notebook workbenches for ML development"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform and notebook configurations"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends Kubeflow Notebook CRDs with RHOAI networking, auth, cert management, and pipeline integration" {
            controller = container "ODH Notebook Controller" "Watches Notebook CRs; creates HTTPRoute, ReferenceGrant, NetworkPolicy, ServiceAccount, Service, ConfigMap, Secret, ClusterRoleBinding per notebook" "Go Operator (controller-runtime)"
            webhook = container "Mutating Webhook" "Intercepts Notebook create/update to inject kube-rbac-proxy sidecar, CA cert bundles, pipeline runtime images, Elyra config" "Go Admission Webhook, 8443/TCP HTTPS"
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-based authentication proxy sidecar injected into notebook pods" "Sidecar Container, 8443/TCP HTTPS"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller that manages Notebook pod lifecycle (StatefulSet), culling/idling" "External"
        dataScienceGateway = softwareSystem "data-science-gateway" "Platform ingress gateway (Envoy) in openshift-ingress namespace" "Internal RHOAI"
        odhOperator = softwareSystem "opendatahub-operator" "Deploys ODH Notebook Controller and Gateway infrastructure" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for creating and managing notebook workbenches" "Internal RHOAI"
        dspa = softwareSystem "DataSciencePipelinesApplication" "Data Science Pipelines for Elyra integration (optional)" "Internal RHOAI"
        feast = softwareSystem "Feast" "Feature store for ML features (optional)" "Internal RHOAI"

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for all resource CRUD operations" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute and ReferenceGrant CRDs for ingress routing" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Auto-provisions TLS certificates for services" "External"
        openshiftImageRegistry = softwareSystem "OpenShift Image Registry" "Hosts container images and ImageStreams" "External"

        // Relationships
        dataScientist -> odhDashboard "Creates notebook workbenches via UI"
        dataScientist -> dataScienceGateway "Accesses notebooks via HTTPS/443"
        platformAdmin -> odhOperator "Configures RHOAI platform"

        odhDashboard -> k8sAPI "Creates Notebook CRs" "HTTPS/443"
        k8sAPI -> odhNotebookController "Sends watch events and webhook calls" "HTTPS"

        odhNotebookController -> k8sAPI "CRUD HTTPRoute, ReferenceGrant, NetworkPolicy, Service, SA, ConfigMap, Secret, RBAC" "HTTPS/443"
        odhNotebookController -> dataScienceGateway "HTTPRoutes reference as parent gateway" "Gateway API"
        odhNotebookController -> openshiftImageRegistry "Resolves ImageStream references" "HTTPS/5000"

        dataScienceGateway -> kubeRbacProxy "Routes auth-enabled notebook traffic" "HTTPS/8443"
        kubeRbacProxy -> k8sAPI "SubjectAccessReview for RBAC auth" "HTTPS/443"

        odhOperator -> odhNotebookController "Deploys controller and webhook"
        kubeflowNotebookController -> k8sAPI "Manages Notebook StatefulSet lifecycle" "HTTPS/443"

        odhNotebookController -> dspa "Reads DSPA CR for Elyra pipeline config (optional)" "Kubernetes API"
        openshiftServiceCA -> odhNotebookController "Provisions TLS certs for webhook and kube-rbac-proxy" "Annotation-driven"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
