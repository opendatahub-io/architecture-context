/* C4 Context Diagram - ODH Notebook Controller (kubeflow)
   Generated by: Claude Opus 4.6 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and uses Jupyter notebook workbenches via RHOAI Dashboard"
        platformAdmin = person "Platform Admin" "Manages RHOAI platform configuration and notebook images"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends Kubeflow Notebook CRs with OpenShift/RHOAI-specific features: Gateway API ingress, kube-rbac-proxy auth sidecars, certificate management, and pipeline integration" {
            reconciler = container "OpenshiftNotebookReconciler" "Watches Notebook CRs; creates HTTPRoute, ReferenceGrant, NetworkPolicy, Service, ConfigMap, ClusterRoleBinding per notebook" "Go Controller (controller-runtime)"
            webhook = container "NotebookWebhook" "Intercepts Notebook create/update; injects kube-rbac-proxy sidecar, resolves images, mounts CA certs, pipeline configs" "Go Mutating Admission Webhook"
            kubeRBACProxy = container "kube-rbac-proxy sidecar" "Authentication sidecar injected per notebook pod; performs SubjectAccessReview before proxying to notebook" "Injected Container"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller managing Notebook CR pod lifecycle" "External"
        dataScienceGateway = softwareSystem "data-science-gateway" "Platform Gateway API gateway in openshift-ingress namespace for notebook ingress" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for creating and managing notebook workbenches" "Internal RHOAI"
        dspa = softwareSystem "Data Science Pipelines" "DataSciencePipelinesApplication for Elyra pipeline runtime config" "Internal RHOAI"
        openshiftImageStreams = softwareSystem "OpenShift ImageStreams" "Container image metadata for notebook runtime images" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning for services" "External"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys ODH Notebook Controller via kustomize overlays" "Internal RHOAI"

        # Relationships
        dataScientist -> odhDashboard "Creates notebook workbenches via" "HTTPS/443"
        dataScientist -> dataScienceGateway "Accesses notebook UI via" "HTTPS/443"
        odhDashboard -> kubernetesAPI "Creates Notebook CRs" "HTTPS/443"
        dataScienceGateway -> kubeRBACProxy "Routes notebook traffic to" "HTTPS/8443"
        kubeRBACProxy -> kubernetesAPI "SubjectAccessReview auth" "HTTPS/443"

        kubernetesAPI -> webhook "Webhook call on Notebook create/update" "HTTPS/443 mTLS"
        webhook -> kubernetesAPI "Reads ImageStreams, ConfigMaps, Secrets" "HTTPS/443"
        reconciler -> kubernetesAPI "CRUD HTTPRoutes, ReferenceGrants, NetworkPolicies, Services" "HTTPS/443"
        reconciler -> dspa "Reads DSPA config for Elyra" "HTTPS/443"
        webhook -> openshiftImageStreams "Resolves notebook images" "HTTPS/443"

        kubeflowNotebookController -> kubernetesAPI "Manages Notebook pod lifecycle" "HTTPS/443"
        openshiftServiceCA -> odhNotebookController "Provisions TLS certificates" "Annotation-based"
        rhodsOperator -> odhNotebookController "Deploys via kustomize" "Deployment"
        platformAdmin -> rhodsOperator "Configures RHOAI platform" "HTTPS/443"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
