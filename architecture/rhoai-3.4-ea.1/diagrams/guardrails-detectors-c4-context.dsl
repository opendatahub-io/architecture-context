// C4 Context Diagram: Guardrails Detectors
// Generated by: Claude Opus 4.6

workspace {
    model {
        orchestrator = person "FMS Guardrails Orchestrator" "Orchestrates content analysis by invoking detector microservices"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Suite of detector microservices for text content analysis (PII, safety, toxicity, file-type validation, LLM-as-a-judge)" {
            builtInDetector = container "Built-in Detector" "Lightweight text detection via regex (PII), file-type validation (JSON/XML/YAML), and custom Python detectors" "Python FastAPI, port 8080" "detector"
            huggingfaceDetector = container "HuggingFace Detector" "ML-based content classification using AutoModelForSequenceClassification or GraniteForCausalLM" "Python FastAPI + PyTorch, port 8000" "detector"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-judge evaluation using vllm-judge library" "Python FastAPI, port 8000" "detector"
            detectorBaseAPI = container "DetectorBaseAPI" "Shared FastAPI base class with Prometheus instrumentation, health endpoint, error handling" "Python Library" "library"
            instrumentedDetector = container "InstrumentedDetector" "Base class providing Prometheus counter instrumentation" "Python Library" "library"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform - deploys HuggingFace detector as InferenceService" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        vllmServer = softwareSystem "vLLM Server" "OpenAI-compatible LLM serving endpoint for LLM Judge evaluation" "External"
        modelStorage = softwareSystem "Model Storage" "Local filesystem (PVC/init container) for HuggingFace model artifacts" "External"

        // Relationships - Orchestrator to Detectors
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080, plaintext, no auth"
        orchestrator -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000, plaintext, no auth"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents" "HTTP/8000, plaintext, no auth"

        // Internal relationships
        builtInDetector -> detectorBaseAPI "extends"
        huggingfaceDetector -> detectorBaseAPI "extends"
        llmJudgeDetector -> detectorBaseAPI "extends"
        builtInDetector -> instrumentedDetector "uses"
        huggingfaceDetector -> instrumentedDetector "uses"
        llmJudgeDetector -> instrumentedDetector "uses"

        // External dependencies
        huggingfaceDetector -> modelStorage "Loads model artifacts" "Filesystem (PVC mount)"
        llmJudgeDetector -> vllmServer "Sends evaluation prompts" "HTTP/HTTPS, OpenAI-compatible API"
        kserve -> huggingfaceDetector "Deploys as InferenceService"
        prometheus -> builtInDetector "Scrapes metrics" "HTTP GET /metrics"
        prometheus -> huggingfaceDetector "Scrapes metrics" "HTTP GET /metrics"
        prometheus -> llmJudgeDetector "Scrapes metrics" "HTTP GET /metrics"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #7ed321
                color #ffffff
            }
            element "detector" {
                background #4a90e2
                color #ffffff
            }
            element "library" {
                background #6baed6
                color #ffffff
            }
        }
    }
}
