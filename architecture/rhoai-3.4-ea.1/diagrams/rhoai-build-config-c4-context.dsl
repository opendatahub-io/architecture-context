/*
 * RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/RHOAI-Build-Config.md
 */

workspace {
    model {
        developer = person "Developer / Release Engineer" "Maintains build configuration and triggers releases"
        clusterAdmin = person "Cluster Administrator" "Installs and manages RHOAI on OpenShift"

        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration that assembles the RHOAI operator bundle and OLM catalog from 43 upstream repositories" {
            bundleBuilder = container "Bundle Builder" "Assembles OLM operator bundle with CRDs, CSV, RBAC, and 100 SHA256-pinned images" "Tekton Pipeline"
            fbcBuilder = container "FBC Builder" "Builds File-Based Catalog fragments for OCP v4.19/v4.20/v4.21" "Tekton Pipeline"
            bundleManifests = container "Bundle Manifests" "CRDs, ClusterServiceVersion, RBAC, Services, Webhook definitions" "YAML/OLM"
            imageConfig = container "Image Configuration" "bundle-patch.yaml + additional-images-patch.yaml: 100 images pinned by SHA256 digest" "YAML"
            catalogConfig = container "Catalog Configuration" "OLM package (rhods-operator), channels (stable, beta), skip ranges" "YAML"
        }

        sourceRepos = softwareSystem "43 Source Repositories" "Upstream source repositories providing operator code and container images" "Internal"
        konflux = softwareSystem "Konflux / RHTAP" "Red Hat CI/CD platform running Tekton pipelines for builds" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Supply chain security verification (SLSA provenance)" "External"
        github = softwareSystem "GitHub" "Source code hosting and webhook triggers" "External"
        quayIO = softwareSystem "quay.io/rhoai" "Pre-release container image registry" "External"
        registryRedHat = softwareSystem "registry.redhat.io/rhoai" "Production container image distribution" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager - installs and manages operator on cluster" "External"
        operatorHub = softwareSystem "OpenShift OperatorHub" "Operator discovery portal for cluster administrators" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target deployment platform (v4.19, v4.20, v4.21)" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for CRD and resource management" "External"

        /* Build-time relationships */
        developer -> rhoaiBuildConfig "Pushes build config changes" "Git/HTTPS/443"
        rhoaiBuildConfig -> github "Stores source, triggers webhooks" "HTTPS/443"
        github -> konflux "Triggers pipelines via PaC webhook" "HTTPS/443"
        konflux -> rhoaiBuildConfig "Executes Tekton PipelineRuns" "HTTPS/443"
        konflux -> sourceRepos "Fetches provenance (bundle_build_args.map)" "HTTPS/443"
        konflux -> quayIO "Pushes bundle and FBC images" "HTTPS/443"
        enterpriseContract -> konflux "Verifies supply chain security" "HTTPS/443"
        sourceRepos -> rhoaiBuildConfig "Provides image references and manifests"

        /* Runtime relationships */
        clusterAdmin -> operatorHub "Discovers RHOAI operator"
        operatorHub -> olm "Reads FBC catalog"
        olm -> quayIO "Pulls FBC fragment and bundle images" "HTTPS/443"
        olm -> registryRedHat "Pulls production images" "HTTPS/443"
        olm -> ocp "Installs CSV, CRDs, RBAC, deploys rhods-operator" "Kubernetes API"
        ocp -> k8sAPI "rhods-operator reconciles resources" "HTTPS/443"

        /* Internal container relationships */
        bundleBuilder -> imageConfig "Reads image pins"
        bundleBuilder -> bundleManifests "Packages manifests"
        fbcBuilder -> catalogConfig "Reads catalog config"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
