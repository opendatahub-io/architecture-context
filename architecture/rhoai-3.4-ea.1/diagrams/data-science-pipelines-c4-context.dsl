/*
 * Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/data-science-pipelines.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist / ML Engineer" "Defines, compiles, runs, and monitors ML pipelines"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines-based ML workflow orchestration platform for building, deploying, and managing ML pipelines on Kubernetes" {
            apiServer = container "ml-pipeline (API Server)" "REST/gRPC API for pipeline and run management; hosts webhook endpoints for PipelineVersion validation/mutation" "Go Service" "8888/TCP REST, 8887/TCP gRPC"
            persistenceAgent = container "ml-pipeline-persistenceagent" "Watches Argo Workflow CRs and syncs run status to the API server database" "Go Agent"
            scheduledWorkflow = container "ml-pipeline-scheduledworkflow" "Manages ScheduledWorkflow CRs to trigger recurring pipeline runs" "Go Controller"
            viewerController = container "ml-pipeline-viewer-crd-controller" "Manages Viewer CRs to deploy Tensorboard instances" "Go Controller"
            cacheServer = container "cache-server" "Mutating admission webhook for pipeline step caching" "Go Service" "443/TCP HTTPS"
            frontend = container "ml-pipeline-ui" "Web UI for pipeline visualization, run monitoring, and experiment management" "Node.js/React" "3000/TCP HTTP"
            vizServer = container "ml-pipeline-visualizationserver" "Generates HTML visualizations for pipeline run outputs" "Python Service" "8888/TCP HTTP"
            mlmdServer = container "metadata-grpc-server" "ML Metadata gRPC service for artifact lineage and metadata storage" "C++ Service" "8080/TCP gRPC"
            metadataEnvoy = container "metadata-envoy" "Envoy sidecar proxy for metadata gRPC service" "Envoy Proxy" "9090/TCP gRPC/HTTP2"
            kfpDriver = container "kfp-driver" "In-pod binary that resolves inputs, manages caching, orchestrates step execution" "Go Binary"
            kfpLauncher = container "kfp-launcher" "In-pod binary that executes user containers and handles artifact upload/download" "Go Binary"
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Workflow execution engine for running pipeline steps as Kubernetes pods (v3.5-v3.7)" "External"
        database = softwareSystem "MySQL / PostgreSQL" "Relational database for pipeline definitions, run metadata, and cache" "External"
        objectStorage = softwareSystem "MinIO / S3 Storage" "Object storage for pipeline artifacts and logs" "External"
        mlMetadata = softwareSystem "ML Metadata (MLMD)" "gRPC service for artifact lineage tracking" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Kubernetes control plane API" "External"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages DSP stack instances via DSPA CR" "Internal RHOAI"

        /* User interactions */
        dataScientist -> dsp "Creates/manages pipelines and runs via SDK or UI"
        dataScientist -> frontend "Visualizes pipelines and monitors runs" "HTTP/3000"

        /* System context relationships */
        dsp -> argoWorkflows "Orchestrates pipeline steps via Workflow CRs" "HTTPS/443 (K8s API)"
        dsp -> database "Stores pipeline metadata, run history, cache" "MySQL/3306 or PostgreSQL/5432"
        dsp -> objectStorage "Stores and retrieves pipeline artifacts" "HTTP-HTTPS/9000-443"
        dsp -> mlMetadata "Tracks artifact lineage and metadata" "gRPC/8080"
        dsp -> k8sAPI "CRD management, pod operations, RBAC checks" "HTTPS/443"
        dspOperator -> dsp "Deploys and manages DSP stack instances" "DSPA CR"

        /* Container-level relationships */
        dataScientist -> apiServer "Pipeline/run CRUD operations" "REST/8888, gRPC/8887"
        frontend -> apiServer "API calls for pipeline data" "HTTP/8888"
        frontend -> objectStorage "Fetches artifacts for display" "HTTP-HTTPS/9000-443"

        apiServer -> k8sAPI "Creates Workflow CRs, RBAC checks" "HTTPS/443"
        apiServer -> database "Stores/retrieves metadata" "MySQL/3306 or PgSQL/5432"
        apiServer -> objectStorage "Stores/retrieves artifacts" "HTTP-HTTPS/9000-443"

        persistenceAgent -> k8sAPI "Watches Workflow CRs" "HTTPS/443"
        persistenceAgent -> apiServer "Reports run status" "HTTP/8888"

        scheduledWorkflow -> k8sAPI "Watches SWF CRs, creates Workflows" "HTTPS/443"

        cacheServer -> database "Checks/stores cache entries" "MySQL/3306 or PgSQL/5432"

        kfpDriver -> apiServer "Resolves inputs" "HTTP/8888"
        kfpDriver -> mlmdServer "Logs metadata" "gRPC/8080"
        kfpLauncher -> objectStorage "Uploads/downloads artifacts" "HTTP-HTTPS/9000-443"

        metadataEnvoy -> mlmdServer "Proxies gRPC requests" "gRPC/8080"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
