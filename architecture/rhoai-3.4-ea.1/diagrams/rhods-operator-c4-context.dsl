/* C4 Context Diagram: rhods-operator
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/rhods-operator.md
 */

workspace {
    model {
        admin = person "Platform Admin" "Configures and manages RHOAI platform components"
        user = person "Data Scientist" "Accesses RHOAI services via Gateway"

        rhodsOperator = softwareSystem "rhods-operator" "RHOAI Platform Operator - manages lifecycle of all AI/ML components, Gateway API ingress, authentication, monitoring, and RBAC" {
            dsciController = container "DSCInitialization Controller" "Reconciles DSCInitialization CR; initializes platform namespace, trusted CA bundles, creates service CRs" "Go Controller"
            dscController = container "DataScienceCluster Controller" "Reconciles DataScienceCluster CR; manages lifecycle of all AI/ML components via sub-controllers" "Go Controller"
            gatewayController = container "Gateway Service Controller" "Creates Gateway API infrastructure: GatewayClass, Gateway, EnvoyFilter, kube-auth-proxy" "Go Controller"
            authController = container "Auth Service Controller" "Manages RBAC: Roles, RoleBindings, ClusterRoles, Groups" "Go Controller"
            monitoringController = container "Monitoring Service Controller" "Deploys MonitoringStack, Prometheus, OpenTelemetry, Tempo, Perses" "Go Controller"
            certController = container "CertConfigmapGenerator" "Distributes trusted CA bundle ConfigMaps to user namespaces" "Go Controller"
            webhookServer = container "Webhook Server" "Admission webhooks for DSC, DSCI, HardwareProfile, Kueue, Monitoring, Notebook, Serving, Dashboard" "Go Webhook Server"
            componentControllers = container "Component Sub-Controllers" "16 sub-controllers managing Dashboard, KServe, Kueue, DSP, Model Registry, Workbenches, Ray, Training Operator, Trainer, TrustyAI, Feast, LlamaStack, MLflow, Spark, MaaS, Model Controller" "Go Sub-Controllers"
        }

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "OAuth2/OIDC authentication proxy deployed by Gateway controller" "Internal RHOAI"

        /* External Dependencies */
        istio = softwareSystem "Istio / OpenShift Service Mesh" "EnvoyFilter and DestinationRule for gateway authentication" "External"
        ocpGatewayController = softwareSystem "OpenShift Gateway Controller" "Processes GatewayClass and Gateway CRs" "External"
        controllerRuntime = softwareSystem "controller-runtime" "Kubernetes controller framework v0.22.4" "External"
        gatewayAPI = softwareSystem "Gateway API" "Gateway API types for ingress management v1.3.0" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator lifecycle management" "External"

        /* Internal ODH Dependencies (deployed components) */
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving infrastructure" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and scheduling" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "Pipeline orchestration" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model metadata management" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches / Notebooks" "Development environments" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay" "Ray cluster management" "Internal RHOAI"
        trainingOp = softwareSystem "Training Operator" "Distributed training" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI" "AI explainability" "Internal RHOAI"

        /* Auth Providers */
        ocpOAuth = softwareSystem "OpenShift OAuth Server" "User authentication (integrated mode)" "External"
        oidcProvider = softwareSystem "External OIDC Provider" "User authentication (OIDC mode)" "External"

        /* Monitoring */
        prometheus = softwareSystem "Prometheus / MonitoringStack" "Metrics collection and alerting" "External"
        otel = softwareSystem "OpenTelemetry Collector" "Trace collection" "External"
        tempo = softwareSystem "Tempo" "Trace storage" "External"

        /* Infrastructure */
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server" "External"
        kuadrant = softwareSystem "Kuadrant" "API management for Models-as-a-Service" "External"

        /* Relationships */
        admin -> rhodsOperator "Creates DSCInitialization and DataScienceCluster CRs" "kubectl / HTTPS"
        user -> kubeAuthProxy "Accesses RHOAI via Gateway" "HTTPS/443"

        rhodsOperator -> k8sAPI "All controller CRUD operations" "HTTPS/443"
        rhodsOperator -> istio "Creates EnvoyFilter, DestinationRule" "Kubernetes API"
        rhodsOperator -> ocpGatewayController "Creates GatewayClass, Gateway CRs" "Kubernetes API"
        rhodsOperator -> kubeAuthProxy "Deploys and configures auth proxy" "Kubernetes API"

        /* Component deployments */
        rhodsOperator -> odhDashboard "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> kserve "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> kueue "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> dsp "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> modelRegistry "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> workbenches "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> kuberay "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> trainingOp "Deploys via kustomize manifests" "Kubernetes API"
        rhodsOperator -> trustyai "Deploys via kustomize manifests" "Kubernetes API"

        /* Auth flows */
        kubeAuthProxy -> ocpOAuth "OAuth2 authentication" "HTTPS/443"
        kubeAuthProxy -> oidcProvider "OIDC authentication" "HTTPS/443"

        /* Monitoring */
        rhodsOperator -> prometheus "Deploys MonitoringStack, ServiceMonitors" "Kubernetes API"
        rhodsOperator -> otel "Deploys OpenTelemetry Collector" "Kubernetes API"
        rhodsOperator -> tempo "Deploys Tempo" "Kubernetes API"
        prometheus -> rhodsOperator "Scrapes metrics" "HTTP/8080"

        /* OLM */
        olm -> rhodsOperator "Manages operator lifecycle" "Subscription/CSV"

        /* Kuadrant */
        rhodsOperator -> kuadrant "Creates AuthPolicy/RateLimitPolicy for MaaS" "Kubernetes API"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
