/*
 * RHODS Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/rhods-operator.md
 */

workspace {
    model {
        admin = person "Platform Admin" "Configures and manages the RHOAI platform"
        datascientist = person "Data Scientist" "Uses data science components via the platform"

        rhodsOperator = softwareSystem "RHODS Operator" "Central orchestrator for Red Hat OpenShift AI - manages lifecycle of all data science components, platform services, and gateway infrastructure" {
            dsciController = container "DSCInitialization Controller" "Initializes platform: namespaces, monitoring, auth, gateway config, hardware profiles" "Go Controller (controller-runtime)"
            dscController = container "DataScienceCluster Controller" "Provisions/deprovisions component CRs based on DSC spec" "Go Reconciler (controller-runtime)"
            gatewayController = container "Gateway Controller" "Deploys Gateway API infrastructure: Gateway, kube-auth-proxy, EnvoyFilter, DestinationRule, NetworkPolicy" "Go Reconciler (controller-runtime)"
            authController = container "Auth Controller" "Manages RBAC ClusterRoles, RoleBindings, and default OpenShift groups" "Go Reconciler (controller-runtime)"
            monitoringController = container "Monitoring Controller" "Deploys MonitoringStack, Tempo, Perses, OpenTelemetry Collector" "Go Reconciler (controller-runtime)"
            certController = container "CertConfigmapGenerator Controller" "Propagates trusted CA certificate ConfigMaps into user namespaces" "Go Controller"
            componentControllers = container "Component Controllers (15)" "Individual controllers for Dashboard, Workbenches, KServe, Ray, Kueue, TrustyAI, ModelRegistry, TrainingOperator, Trainer, Feast, LlamaStack, MLflow, ModelsAsService, SparkOperator" "Go Reconcilers"
            kubeAuthProxy = container "kube-auth-proxy" "OAuth2/OIDC authentication proxy at gateway level, handles login flow and token validation" "Go Deployment"
        }

        # External Dependencies
        olm = softwareSystem "OLM (Operator Lifecycle Manager)" "Manages operator installation and updates" "External"
        gatewayAPI = softwareSystem "Kubernetes Gateway API" "HTTPRoute, Gateway, GatewayClass CRDs" "External"
        istio = softwareSystem "Istio (OpenShift Gateway)" "Service mesh: EnvoyFilter, DestinationRule for gateway auth" "External"
        prometheusOperator = softwareSystem "Prometheus Operator" "Monitoring stack CRDs and scraping" "External"
        tempoOperator = softwareSystem "Tempo Operator" "Distributed tracing" "External"
        otelOperator = softwareSystem "OpenTelemetry Operator" "Telemetry collection" "External"
        persesOperator = softwareSystem "Perses Operator" "Dashboard/visualization" "External"
        obsOperator = softwareSystem "Observability Operator (RHOBS)" "MonitoringStack, ThanosQuerier" "External"

        # Internal ODH Dependencies (deployed components)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for data science platform" "Internal RHOAI"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "ML pipeline orchestration" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless model serving" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay Operator" "Ray distributed computing" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job scheduling and queuing" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry Operator" "Model metadata management" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI Operator" "AI explainability" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator" "Distributed training" "Internal RHOAI"
        odhModelController = softwareSystem "ODH Model Controller" "Model lifecycle management" "Internal RHOAI"

        # External Services
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "Platform OAuth2 authentication" "External"
        oidcProvider = softwareSystem "External OIDC Provider" "External identity provider" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane" "External"
        openshiftIngress = softwareSystem "OpenShift Ingress Controller" "External traffic routing" "External"
        serviceCA = softwareSystem "OpenShift Service-CA" "Auto-generate TLS certificates" "External"

        # Relationships - Admin
        admin -> rhodsOperator "Creates DSCInitialization and DataScienceCluster CRs via kubectl"

        # Relationships - Data Scientist
        datascientist -> dashboard "Accesses via Gateway" "HTTPS/443"

        # Relationships - Operator to External Dependencies
        rhodsOperator -> olm "Installed and managed by" "OLM Subscription"
        rhodsOperator -> gatewayAPI "Creates Gateway, GatewayClass, HTTPRoute CRs"
        rhodsOperator -> istio "Creates EnvoyFilter, DestinationRule for auth" "Istio API"
        rhodsOperator -> prometheusOperator "Creates ServiceMonitors, PrometheusRules" "monitoring.coreos.com"
        rhodsOperator -> obsOperator "Creates MonitoringStack, ThanosQuerier" "monitoring.rhobs"
        rhodsOperator -> tempoOperator "Creates TempoStack" "tempo.grafana.com"
        rhodsOperator -> otelOperator "Creates OpenTelemetryCollector" "opentelemetry.io"
        rhodsOperator -> persesOperator "Creates Perses dashboards" "perses.dev"
        rhodsOperator -> k8sAPI "Watches/manages all CRDs and resources" "HTTPS/443"
        rhodsOperator -> serviceCA "Requests TLS certificates for services"
        rhodsOperator -> openshiftIngress "Creates Routes for gateway access" "HTTPS/443"

        # Relationships - Operator deploys Internal Components
        rhodsOperator -> dashboard "Deploys via kustomize manifests"
        rhodsOperator -> dspOperator "Deploys via kustomize manifests"
        rhodsOperator -> kserve "Deploys via kustomize manifests"
        rhodsOperator -> kuberay "Deploys via kustomize manifests"
        rhodsOperator -> kueue "Deploys via kustomize manifests"
        rhodsOperator -> modelRegistry "Deploys via kustomize manifests"
        rhodsOperator -> trustyai "Deploys via kustomize manifests"
        rhodsOperator -> trainingOperator "Deploys via kustomize manifests"
        rhodsOperator -> odhModelController "Deploys via kustomize manifests"

        # Relationships - Authentication
        kubeAuthProxy -> openshiftOAuth "Authenticates users" "HTTPS/443 OAuth2"
        kubeAuthProxy -> oidcProvider "Authenticates users" "HTTPS/443 OIDC"

        # Container relationships
        dsciController -> dscController "Triggers component provisioning"
        dsciController -> gatewayController "Creates GatewayConfig CR"
        dsciController -> authController "Creates Auth CR"
        dsciController -> monitoringController "Creates Monitoring CR"
        dscController -> componentControllers "Creates component CRs"
        gatewayController -> kubeAuthProxy "Deploys and configures"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
