/* C4 Context Diagram: Distributed Workloads
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4-ea.1/distributed-workloads.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Submits distributed training jobs and uses notebook workbenches"
        mlEngineer = person "ML Engineer" "Configures training runtimes and manages cluster resources"
        testEngineer = person "Test Engineer" "Runs E2E integration tests for distributed workloads"

        distributedWorkloads = softwareSystem "Distributed Workloads" "GPU-accelerated training runtime images and E2E integration test suite for RHOAI distributed training stack" {
            cudaImages = container "CUDA Training Images" "PyTorch + CUDA 12.1/12.4/12.8 GPU training runtime images" "Container Image (UBI 9)"
            rocmImages = container "ROCm Training Images" "PyTorch + ROCm 6.2/6.4 GPU training runtime images" "Container Image (UBI 9)"
            universalImages = container "Universal Training Images" "Dual-mode images: notebook workbench + headless training runtime" "Container Image (UBI 9)"
            rayImages = container "Ray Runtime Images" "Ray 2.52.1 cluster worker images with CUDA/ROCm support" "Container Image (UBI 9)"
            testSuite = container "E2E Test Suite" "Integration tests for Kueue, Training Operator, Trainer v2, KubeRay, JobSet" "Go Test Framework"
            testLibrary = container "Test Support Library" "Reusable helpers for K8s resources, Ray API client, RBAC, storage" "Go Library"
        }

        kueueOperator = softwareSystem "Kueue Operator" "Job queuing, quota management, workload scheduling" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator (Kubeflow)" "PyTorchJob orchestration for distributed training" "Internal RHOAI"
        trainerV2 = softwareSystem "Trainer v2 (Kubeflow)" "TrainJob orchestration with ClusterTrainingRuntimes" "Internal RHOAI"
        kubeRay = softwareSystem "KubeRay Operator" "RayCluster and RayJob lifecycle management" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Platform component lifecycle management via DataScienceCluster" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Notebook workbench spawner for universal images" "Internal RHOAI"

        s3Storage = softwareSystem "S3 / MinIO Storage" "Training data and model artifact storage" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Pre-trained model downloads" "External"
        prometheus = softwareSystem "Prometheus" "Metrics monitoring for training workloads" "External"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster API server" "External"
        olm = softwareSystem "OLM" "Operator lifecycle management" "External"

        /* Person relationships */
        datascientist -> distributedWorkloads "Submits training jobs using runtime images"
        datascientist -> odhDashboard "Spawns notebook workbenches"
        mlEngineer -> kueueOperator "Configures ClusterQueues and quotas"
        testEngineer -> testSuite "Runs E2E integration tests"

        /* Internal container relationships */
        testSuite -> testLibrary "Uses test helpers"

        /* Distributed Workloads to Internal RHOAI */
        distributedWorkloads -> kueueOperator "Job queuing and quota management" "CRD API (kueue.x-k8s.io/v1beta1) / HTTPS 6443"
        distributedWorkloads -> trainingOperator "PyTorchJob orchestration" "CRD API (kubeflow.org/v1) / HTTPS 6443"
        distributedWorkloads -> trainerV2 "TrainJob orchestration" "CRD API (trainer.kubeflow.org/v1alpha1) / HTTPS 6443"
        distributedWorkloads -> kubeRay "RayCluster and RayJob management" "CRD API (ray.io/v1) / HTTPS 6443"
        distributedWorkloads -> rhoaiOperator "Platform component lifecycle" "CRD API (datasciencecluster.opendatahub.io/v2) / HTTPS 6443"
        universalImages -> odhDashboard "Spawned as notebook workbenches"

        /* Distributed Workloads to External */
        distributedWorkloads -> s3Storage "Upload/download training data and models" "HTTPS/443 AWS IAM SigV4"
        distributedWorkloads -> huggingFace "Download pre-trained models" "HTTPS/443 Bearer Token"
        distributedWorkloads -> prometheus "Query training metrics" "HTTPS/9090"
        distributedWorkloads -> kubernetesAPI "CRD CRUD operations" "HTTPS/6443 Bearer Token"
        distributedWorkloads -> olm "Query operator status" "HTTPS/6443"

        /* Test suite specific */
        testSuite -> kubernetesAPI "Creates/monitors CRDs" "HTTPS/6443 Bearer Token"
        testSuite -> kubeRay "Submits Ray jobs via Dashboard API" "HTTP/8265"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
