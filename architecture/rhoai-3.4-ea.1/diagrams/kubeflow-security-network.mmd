%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP HTTPS<br/>TLS 1.2+ SIMPLE termination<br/>PathPrefix: /notebook/{ns}/{name}"]
    end

    subgraph NotebookPod["NOTEBOOK POD (User Namespace)"]
        direction TB
        KubeRBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS: service-ca cert<br/>Auth: SubjectAccessReview<br/>(get notebooks kubeflow.org)"]
        NotebookApp["Notebook Application<br/>8888/TCP HTTP<br/>loopback only"]
    end

    subgraph ControllerNS["CONTROLLER (opendatahub namespace)"]
        direction TB
        Controller["ODH Notebook Controller<br/>SA: odh-notebook-controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        WebhookSvc["Webhook Server<br/>8443/TCP HTTPS<br/>TLS: service-ca cert<br/>Auth: K8s API server mTLS"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    end

    subgraph InternalRHOAI["INTERNAL RHOAI SERVICES"]
        DSPA["DataSciencePipelinesApplication<br/>via K8s API"]
        ImageStreams["OpenShift ImageStreams<br/>via K8s API"]
        ServiceCA["OpenShift service-ca<br/>Annotation-based cert provisioning"]
        CACerts["odh-trusted-ca-bundle<br/>ConfigMap"]
    end

    %% External access flow
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca cert)<br/>Bearer token (SAR)"| KubeRBACProxy
    KubeRBACProxy -->|"HTTP/8888<br/>plaintext (loopback)<br/>X-Auth-Request-User"| NotebookApp

    %% SAR validation
    KubeRBACProxy -.->|"SubjectAccessReview<br/>HTTPS/443"| K8sAPI

    %% Controller flows
    Controller -->|"HTTPS/443<br/>SA token<br/>Watch Notebooks,<br/>CRUD HTTPRoutes,<br/>ReferenceGrants,<br/>NetworkPolicies"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"mTLS<br/>POST /mutate-notebook-v1"| WebhookSvc
    WebhookSvc -.->|"HTTPS/443<br/>SA token<br/>Read ImageStreams,<br/>ConfigMaps, Secrets"| K8sAPI

    %% Internal dependencies
    Controller -.->|"Read DSPA config"| DSPA
    WebhookSvc -.->|"Resolve images"| ImageStreams
    Controller -.->|"Read CA certs"| CACerts
    ServiceCA -.->|"Provision TLS certs"| WebhookSvc
    ServiceCA -.->|"Provision TLS certs"| KubeRBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef notebookpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBACProxy,NotebookApp notebookpod
    class Controller,WebhookSvc controller
    class K8sAPI k8s
    class DSPA,ImageStreams,ServiceCA,CACerts internal
