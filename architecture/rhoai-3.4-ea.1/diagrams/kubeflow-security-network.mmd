%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser / API Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway (Envoy)<br/>Namespace: openshift-ingress<br/>443/TCP HTTPS<br/>TLS Mode: SIMPLE"]
    end

    subgraph UserNS["USER NAMESPACE"]
        direction TB

        subgraph AuthPath["Auth Path (inject-auth: true)"]
            KRBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS (service-ca TLS)<br/>Health: 8444/TCP<br/>SubjectAccessReview auth"]
        end

        subgraph NotebookPod["Notebook Pod (StatefulSet)"]
            NotebookContainer["Notebook Container<br/>8888/TCP HTTP"]
        end

        subgraph CreatedResources["Controller-Created Resources"]
            RefGrant["ReferenceGrant<br/>notebook-httproute-access"]
            NetPol1["{notebook}-ctrl-np<br/>Allow: controller ns → 8888"]
            NetPol2["{notebook}-kube-rbac-proxy-np<br/>Allow: all → 8443"]
            ProxySvc["{notebook}-kube-rbac-proxy<br/>Service ClusterIP 8443"]
            ProxyTLS["{notebook}-kube-rbac-proxy-tls<br/>Secret (service-ca)"]
            ProxyCfg["{notebook}-kube-rbac-proxy-config<br/>ConfigMap"]
            CABundle["workbench-trusted-ca-bundle<br/>ConfigMap"]
        end
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE"]
        direction TB
        Controller["ODH Notebook Controller<br/>SA: manager"]
        WebhookServer["Mutating Webhook<br/>8443/TCP HTTPS (service-ca TLS)<br/>Auth: API server cert"]
        Metrics["Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        HTTPRouteRes["HTTPRoute<br/>nb-{ns}-{notebook}<br/>parent: data-science-gateway"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
        ServiceCA["OpenShift service-ca<br/>TLS cert provisioning"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS"]
    end

    %% External to Gateway
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token or None"| Gateway

    %% Gateway to backends (via HTTPRoute)
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token forwarded<br/>(auth enabled)"| KRBACProxy
    Gateway -->|"HTTP/8888<br/>No encryption<br/>No auth<br/>(auth disabled)"| NotebookContainer

    %% kube-rbac-proxy flow
    KRBACProxy -->|"HTTPS/443<br/>SubjectAccessReview<br/>SA token"| K8sAPI
    KRBACProxy -->|"HTTP/8888<br/>localhost (loopback)<br/>X-Auth-Request-User/Groups"| NotebookContainer

    %% Controller operations
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD resources"| K8sAPI
    K8sAPI -->|"HTTPS/8443<br/>Webhook call<br/>API server cert"| WebhookServer

    %% Service-CA provisions certs
    ServiceCA -.->|"auto-provision TLS"| WebhookServer
    ServiceCA -.->|"auto-provision TLS"| ProxyTLS

    %% HTTPRoute references
    HTTPRouteRes -.->|"parent ref"| Gateway
    RefGrant -.->|"authorizes cross-ns<br/>backend refs"| HTTPRouteRes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef resource fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class User external
    class Gateway ingress
    class KRBACProxy,NotebookContainer servicemesh
    class Controller,WebhookServer,Metrics,HTTPRouteRes controller
    class K8sAPI,ServiceCA,ImageRegistry cluster
