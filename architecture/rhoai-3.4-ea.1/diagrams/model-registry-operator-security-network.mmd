    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress to cluster
    RegistryRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBP_Reg
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>Bearer Token"| KRBP_Cat

    %% kube-rbac-proxy to containers
    KRBP_Reg -->|"HTTP/8080<br/>localhost<br/>No auth (authorized)"| RegContainer
    KRBP_Cat -->|"HTTP/8080<br/>localhost<br/>No auth (authorized)"| CatContainer

    %% Auth verification
    KRBP_Reg -->|"HTTPS/443<br/>TokenReview +<br/>SubjectAccessReview"| K8sAPI
    KRBP_Cat -->|"HTTPS/443<br/>TokenReview +<br/>SubjectAccessReview"| K8sAPI

    %% Init containers
    CatInit -.->|"filesystem"| CatContainer

    %% Database connections
    RegContainer -->|"TCP/5432<br/>Configurable SSL<br/>Password"| RegPG
    RegContainer -.->|"TCP/3306<br/>Configurable SSL<br/>Password"| MySQL
    CatContainer -->|"TCP/5432<br/>Password"| CatPG

    %% Operator flows
    Controller -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

