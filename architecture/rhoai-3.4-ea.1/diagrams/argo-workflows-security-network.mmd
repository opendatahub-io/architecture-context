%% Argo Workflows - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph Internal["CLUSTER INTERNAL (No External Ingress)"]
        direction TB

        subgraph DSPNamespace["Namespace: {dsp-namespace}"]
            direction TB
            Controller["workflow-controller<br/>SA: argo<br/>CR: argo-cluster-role<br/>Ports: 9090/TCP (metrics), 6060/TCP (health)"]
            StepPod["Workflow Step Pod<br/>+ argoexec sidecar<br/>Artifact mgmt & status reporting"]
        end

        subgraph UpstreamOnly["Upstream Only (not in RHOAI)"]
            ArgoServer["argo-server<br/>SA: argo-server<br/>Port: 2746/TCP<br/>gRPC/REST + TLS<br/>Auth: Bearer/SSO/Server"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO Storage<br/>443/TCP or 9000/TCP<br/>HTTPS/HTTP<br/>Access Key Auth"]
        PostgreSQL["PostgreSQL (optional)<br/>5432/TCP<br/>TLS configurable<br/>Username/Password"]
        MySQL["MySQL (optional)<br/>3306/TCP<br/>TLS configurable<br/>Username/Password"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Credentials"]
    end

    subgraph ODHComponents["RHOAI / ODH COMPONENTS"]
        DSP["DSP API Server<br/>Creates Workflow CRs"]
        DSPOp["DSP Operator<br/>Deploys & configures"]
    end

    %% Flows
    DSP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    DSPOp -->|"deploys"| Controller
    DSPOp -->|"configures image"| StepPod

    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRs, Pod CRUD"| K8sAPI
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Report TaskResult"| K8sAPI
    StepPod -->|"HTTPS/443 or HTTP/9000<br/>TLS configurable<br/>Access Key"| S3
    Controller -.->|"TCP/5432<br/>TLS configurable<br/>User/Pass"| PostgreSQL
    Controller -.->|"TCP/3306<br/>TLS configurable<br/>User/Pass"| MySQL
    K8sAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Registry Creds"| Registry

    %% Styling
    classDef controller fill:#4a90e2,stroke:#333,color:#fff,stroke-width:2px
    classDef upstream fill:#cccccc,stroke:#999,stroke-width:1px
    classDef k8s fill:#326ce5,stroke:#333,color:#fff,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef odh fill:#7ed321,stroke:#333,stroke-width:2px

    class Controller,StepPod controller
    class ArgoServer upstream
    class K8sAPI k8s
    class S3,PostgreSQL,MySQL,Registry external
    class DSP,DSPOp odh
