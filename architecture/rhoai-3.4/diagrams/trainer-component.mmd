graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator"]
        Controller["trainer-controller-manager<br/>(Go Operator)<br/>Ports: 9443, 8443, 8081"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS"]
        Metrics["Metrics Endpoint<br/>8443/TCP HTTPS"]
        Health["Health Probes<br/>8081/TCP HTTP"]
        Controller --- Webhook
        Controller --- Metrics
        Controller --- Health

        subgraph PluginFramework["Plugin Framework"]
            JobSetPlugin["JobSet Plugin<br/>(resource builder)"]
            TorchPlugin["Torch Plugin<br/>(PyTorch distributed)"]
            MPIPlugin["MPI Plugin<br/>(OpenMPI/Intel MPI)"]
            PlainMLPlugin["PlainML Plugin<br/>(fallback)"]
            CoSchedPlugin["CoScheduling Plugin<br/>(gang scheduling)"]
            VolcanoPlugin["Volcano Plugin<br/>(gang scheduling)"]
        end

        subgraph RHAIFeatures["RHOAI Features (ENABLE_RHAI_FEATURES)"]
            Progression["Progression Tracking<br/>polls 28080/TCP HTTP"]
            NetPolicy["NetworkPolicy Creator"]
        end
    end

    subgraph DataCache["Data Cache Module (Rust)"]
        CacheHead["data-cache (head)<br/>Arrow Flight gRPC<br/>Iceberg metadata"]
        CacheWorker["data-cache (worker)<br/>Arrow Flight gRPC<br/>in-memory Arrow tables"]
        CacheHead -->|partition assignments| CacheWorker
    end

    SDK["Python SDK<br/>(client library)"]

    %% CRDs
    TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1alpha1"]
    TrainingRuntimeCR["TrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]
    ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1"]

    %% User interactions
    User["User / Data Scientist"] -->|creates| TrainJobCR
    SDK -->|creates| TrainJobCR
    TrainJobCR -->|watched by| Controller
    TrainingRuntimeCR -->|referenced by| Controller
    ClusterTrainingRuntimeCR -->|referenced by| Controller

    %% Controller creates resources
    Controller -->|creates via JobSet plugin| JobSetCR["JobSet<br/>jobset.x-k8s.io/v1alpha2"]
    Controller -->|creates via CoScheduling| PodGroupKS["PodGroup<br/>scheduling.x-k8s.io"]
    Controller -->|creates via Volcano| PodGroupV["PodGroup<br/>scheduling.volcano.sh"]
    Controller -->|creates (MPI)| SSHSecret["SSH Secret<br/>(ECDSA keypair)"]
    NetPolicy -->|creates| NetworkPolicyCR["NetworkPolicy"]

    %% Progression tracking
    Progression -->|polls /metrics| TrainingPod["Training Pods<br/>28080/TCP HTTP"]

    %% External dependencies
    Controller -->|reconciles via| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    K8sAPI -->|calls| Webhook

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style Health fill:#4a90e2,stroke:#333,color:#fff
    style CacheHead fill:#e87d3e,stroke:#333,color:#fff
    style CacheWorker fill:#e87d3e,stroke:#333,color:#fff
    style TrainJobCR fill:#f5a623,stroke:#333
    style TrainingRuntimeCR fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimeCR fill:#f5a623,stroke:#333
    style JobSetCR fill:#f5a623,stroke:#333
    style PodGroupKS fill:#f5a623,stroke:#333
    style PodGroupV fill:#f5a623,stroke:#333
    style NetworkPolicyCR fill:#f5a623,stroke:#333
    style SSHSecret fill:#d4380d,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style TrainingPod fill:#7ed321,stroke:#333
    style SDK fill:#9b59b6,stroke:#333,color:#fff
    style User fill:#e8e8e8,stroke:#333
