graph TB
    subgraph TrainerOperator["Kubeflow Trainer Operator (opendatahub namespace)"]
        Controller["trainer-controller-manager<br/>Go Operator<br/>(controller-runtime)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS"]
        Progression["RHAI Progression Tracker<br/>(Controller Extension)"]
        Controller -->|validates via| Webhook
        Controller -->|extends| Progression
    end

    subgraph CRDs["Custom Resources"]
        TrainJobCR["TrainJob CR<br/>trainer.kubeflow.org/v1alpha1<br/>(Namespaced)"]
        TrainingRuntimeCR["TrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1<br/>(Namespaced)"]
        ClusterTrainingRuntimeCR["ClusterTrainingRuntime CR<br/>trainer.kubeflow.org/v1alpha1<br/>(Cluster-scoped)"]
    end

    subgraph RHOAIRuntimes["Pre-configured Runtimes (RHOAI)"]
        TorchCUDA["PyTorch CUDA Runtime"]
        TorchROCm["PyTorch ROCm Runtime"]
        TorchCPU["PyTorch CPU Runtime"]
    end

    subgraph WorkloadResources["Generated Workload Resources"]
        JobSetCR["JobSet CR<br/>(sigs.k8s.io/jobset)"]
        NetworkPolicy["NetworkPolicy<br/>(per-TrainJob isolation)"]
        PodGroup["PodGroup CR<br/>(gang-scheduling)"]
        TrainingPods["Training Pods<br/>(master + workers)"]
    end

    User["User / Data Scientist"] -->|creates| TrainJobCR
    TrainJobCR -->|references| TrainingRuntimeCR
    TrainJobCR -->|references| ClusterTrainingRuntimeCR

    ClusterTrainingRuntimeCR --- TorchCUDA
    ClusterTrainingRuntimeCR --- TorchROCm
    ClusterTrainingRuntimeCR --- TorchCPU

    TrainJobCR -->|watched by| Controller
    TrainingRuntimeCR -->|watched by| Controller
    ClusterTrainingRuntimeCR -->|watched by| Controller

    Controller -->|creates| JobSetCR
    Controller -->|creates| NetworkPolicy
    Controller -->|creates| PodGroup

    JobSetCR -->|managed by| JobSetController["JobSet Controller"]
    JobSetController -->|creates| TrainingPods

    Progression -->|polls metrics<br/>28080/TCP HTTP| TrainingPods

    Controller -->|depends on| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Controller -->|integrates| Prometheus["OpenShift Monitoring<br/>(PodMonitor)"]

    style Controller fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style Progression fill:#4a90e2,color:#fff
    style TrainJobCR fill:#f5a623,color:#fff
    style TrainingRuntimeCR fill:#f5a623,color:#fff
    style ClusterTrainingRuntimeCR fill:#f5a623,color:#fff
    style JobSetCR fill:#7ed321,color:#fff
    style NetworkPolicy fill:#7ed321,color:#fff
    style PodGroup fill:#7ed321,color:#fff
    style TrainingPods fill:#7ed321,color:#fff
    style JobSetController fill:#e8e8e8
    style K8sAPI fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style TorchCUDA fill:#d5a6e8
    style TorchROCm fill:#d5a6e8
    style TorchCPU fill:#d5a6e8
