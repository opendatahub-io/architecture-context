graph TB
    subgraph "Argo Workflows Component (RHOAI)"
        direction TB

        subgraph Controller["workflow-controller (Go)"]
            Reconciler[Reconciliation Loop]
            LeaderElect[Leader Election]
            Metrics[Metrics Server<br/>9090/TCP HTTPS]
            Healthz[Health Check<br/>6060/TCP HTTP]
            Reconciler --> LeaderElect
            Reconciler --> Metrics
            Reconciler --> Healthz
        end

        subgraph Executor["argoexec (Go Sidecar)"]
            Emissary[Emissary Executor]
            ArtifactMgr[Artifact Manager]
            ResultReporter[Result Reporter]
            Emissary --> ArtifactMgr
            Emissary --> ResultReporter
        end
    end

    %% CRDs
    WorkflowCR[Workflow CR<br/>argoproj.io/v1alpha1]
    CronWorkflowCR[CronWorkflow CR]
    WorkflowTemplateCR[WorkflowTemplate CR]
    ClusterWFTemplate[ClusterWorkflowTemplate CR]
    TaskResultCR[WorkflowTaskResult CR]
    TaskSetCR[WorkflowTaskSet CR]
    ArtifactGCCR[WorkflowArtifactGCTask CR]
    EventBindingCR[WorkflowEventBinding CR]

    %% External interactions
    DSPAPIServer[DSP API Server] -->|creates| WorkflowCR
    WorkflowCR -->|watched by| Reconciler
    CronWorkflowCR -->|watched by| Reconciler
    WorkflowTemplateCR -->|watched by| Reconciler
    ClusterWFTemplate -->|watched by| Reconciler
    TaskResultCR -->|watched by| Reconciler
    TaskSetCR -->|watched by| Reconciler

    Reconciler -->|creates Pods with| Executor
    ResultReporter -->|creates| TaskResultCR
    Reconciler -->|creates| ArtifactGCCR

    %% External dependencies
    Reconciler -->|watches/creates via| K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
    Emissary -->|wraps| UserContainer[User Container Process]
    ArtifactMgr -->|uploads/downloads| ArtifactStore[S3/GCS/Azure<br/>Artifact Storage]
    ResultReporter -->|creates CRDs via| K8sAPI

    %% Optional persistence
    Reconciler -.->|archival| PostgreSQL[(PostgreSQL<br/>5432/TCP)]
    Reconciler -.->|archival| MySQL[(MySQL<br/>3306/TCP)]

    %% Monitoring
    Prometheus[Prometheus] -->|scrapes| Metrics

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Executor fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Reconciler fill:#357abd,stroke:#333,color:#fff
    style LeaderElect fill:#357abd,stroke:#333,color:#fff
    style Metrics fill:#357abd,stroke:#333,color:#fff
    style Healthz fill:#357abd,stroke:#333,color:#fff
    style Emissary fill:#357abd,stroke:#333,color:#fff
    style ArtifactMgr fill:#357abd,stroke:#333,color:#fff
    style ResultReporter fill:#357abd,stroke:#333,color:#fff
