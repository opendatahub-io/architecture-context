graph TB
    subgraph ArgoWorkflows["Argo Workflows (RHOAI)"]
        direction TB

        subgraph Controller["workflow-controller"]
            WFC[Workflow Controller<br/>Go / client-go informers<br/>9090/TCP metrics, 6060/TCP healthz]
            WorkflowInformer[Workflow Informer<br/>20m resync]
            CronInformer[CronWorkflow Informer]
            PodInformer[Pod Informer]
            LeaderElection[Leader Election<br/>Kubernetes Leases]

            WFC --> WorkflowInformer
            WFC --> CronInformer
            WFC --> PodInformer
            WFC --> LeaderElection
        end

        subgraph Executor["argoexec (emissary mode)"]
            ArgoExec[argoexec binary<br/>Injected into workflow pods]
            ArgoExecFIPS[argoexec-fips binary<br/>FIPS-compliant variant]
            ArgoExec -.->|runtime select| ArgoExecFIPS
        end
    end

    %% CRDs
    WorkflowCR[Workflow CR<br/>argoproj.io/v1alpha1]
    CronWorkflowCR[CronWorkflow CR<br/>argoproj.io/v1alpha1]
    WorkflowTemplateCR[WorkflowTemplate CR<br/>argoproj.io/v1alpha1]
    TaskResultCR[WorkflowTaskResult CR<br/>argoproj.io/v1alpha1]
    ArtifactGCCR[WorkflowArtifactGCTask CR<br/>argoproj.io/v1alpha1]

    %% External Systems
    KFP[Kubeflow Pipelines<br/>API Server]
    K8sAPI[Kubernetes API Server<br/>6443/TCP]
    S3[S3 / Minio<br/>Artifact Store]
    DSPOperator[DSP Operator]

    %% Flows
    KFP -->|creates| WorkflowCR
    WorkflowCR -->|watched by| WFC
    CronWorkflowCR -->|watched by| WFC
    WorkflowTemplateCR -->|referenced by| WFC

    WFC -->|creates| StepPod[Workflow Step Pod]
    ArgoExec -->|injected into| StepPod
    StepPod -->|runs| UserContainer[User Container]

    ArgoExec -->|creates| TaskResultCR
    WFC -->|creates| ArtifactGCCR

    WFC -->|CRUD operations| K8sAPI
    ArgoExec -->|read/write| K8sAPI
    ArgoExec -->|upload/download artifacts| S3
    DSPOperator -->|deploys & configures| WFC

    %% Styling
    style WFC fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExec fill:#4a90e2,stroke:#333,color:#fff
    style ArgoExecFIPS fill:#3a7bc8,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#000
    style CronWorkflowCR fill:#f5a623,stroke:#333,color:#000
    style WorkflowTemplateCR fill:#f5a623,stroke:#333,color:#000
    style TaskResultCR fill:#f5a623,stroke:#333,color:#000
    style ArtifactGCCR fill:#f5a623,stroke:#333,color:#000
    style KFP fill:#7ed321,stroke:#333,color:#000
    style DSPOperator fill:#7ed321,stroke:#333,color:#000
    style K8sAPI fill:#e8e8e8,stroke:#333,color:#000
    style S3 fill:#e8e8e8,stroke:#333,color:#000
    style StepPod fill:#d5e8d4,stroke:#333,color:#000
    style UserContainer fill:#d5e8d4,stroke:#333,color:#000
