graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        direction TB
        Controller["workflow-controller<br/>Go Binary (Deployment)<br/>Ports: 9090/TCP metrics, 6060/TCP health"]
        ArgoServer["argo-server<br/>Go Binary (Deployment)<br/>Port: 2746/TCP gRPC/HTTPS"]
        ArgoExec["argoexec<br/>Go Binary (Container Sidecar)<br/>Injected into step pods"]
        ConfigMap["workflow-controller-configmap<br/>ConfigMap<br/>Controller configuration"]
        Metrics["Prometheus Metrics<br/>Port: 9090/TCP"]

        Controller -->|reads config| ConfigMap
        Controller -->|exposes| Metrics
        Controller -->|injects| ArgoExec
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions (argoproj.io/v1alpha1)"]
        WorkflowCR["Workflow<br/>(Namespaced)"]
        WorkflowTemplateCR["WorkflowTemplate<br/>(Namespaced)"]
        ClusterWFTemplateCR["ClusterWorkflowTemplate<br/>(Cluster)"]
        CronWorkflowCR["CronWorkflow<br/>(Namespaced)"]
        WFEventBindingCR["WorkflowEventBinding<br/>(Namespaced)"]
        WFTaskSetCR["WorkflowTaskSet<br/>(Namespaced)"]
        WFTaskResultCR["WorkflowTaskResult<br/>(Namespaced)"]
        WFArtifactGCCR["WorkflowArtifactGCTask<br/>(Namespaced)"]
    end

    %% Users / Clients
    User["User / DSP API Server"] -->|creates| WorkflowCR
    User -->|creates| CronWorkflowCR
    User -->|creates| WorkflowTemplateCR

    %% Controller watches CRDs
    WorkflowCR -->|watched by| Controller
    CronWorkflowCR -->|watched by| Controller
    WorkflowTemplateCR -->|watched by| Controller
    ClusterWFTemplateCR -->|watched by| Controller
    WFEventBindingCR -->|watched by| Controller

    %% Argo Server interactions
    ArgoServer -->|CRUD via API| WorkflowCR
    ArgoServer -->|CRUD via API| WorkflowTemplateCR
    ArgoServer -->|CRUD via API| CronWorkflowCR

    %% Controller creates pods
    Controller -->|creates step pods with| ArgoExec
    Controller -->|creates| WFTaskSetCR
    Controller -->|manages| WFArtifactGCCR

    %% External dependencies
    Controller -->|depends on| K8sAPI["Kubernetes API Server"]
    ArgoExec -->|reports status| K8sAPI
    ArgoExec -->|uploads artifacts| S3["S3/MinIO Object Store"]
    Controller -->|archives workflows| DB["PostgreSQL / MySQL"]
    ArgoServer -->|queries archives| DB
    ArgoServer -->|SSO auth| OIDC["OIDC Provider"]

    %% Internal ODH integrations
    DSPOperator["Data Science Pipelines Operator"] -->|deploys & configures| Controller
    DSPAPI["DSP API Server"] -->|submits workflows| WorkflowCR

    %% Monitoring
    Prometheus["Prometheus"] -->|scrapes| Metrics

