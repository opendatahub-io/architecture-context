graph LR
    Feast["Feast<br/>(Operator + Feature Server)"]

    %% External Dependencies (Required)
    Feast -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.18.4"]
    Feast -->|"HTTP framework"| FastAPI["FastAPI<br/>>=0.68.0"]
    Feast -->|"production server"| Gunicorn["Gunicorn"]
    Feast -->|"gRPC serving"| gRPC["gRPC Python<br/>>=1.56.2"]
    Feast -->|"columnar data"| PyArrow["PyArrow<br/>>=21.0.0"]

    %% External Dependencies (Optional)
    Feast -->|"route creation<br/>(auto-detected)"| OpenShiftAPI["OpenShift API<br/>route/v1<br/>release-4.17"]
    Feast -->|"metrics scraping<br/>(auto-detected)"| PrometheusOp["Prometheus Operator<br/>v0.75.0"]

    %% Persistence Backends (Optional)
    Feast -->|"online store<br/>6379/TCP"| Redis["Redis<br/>>=4.2.2"]
    Feast -->|"online/offline/registry<br/>5432/TCP"| PostgreSQL["psycopg<br/>3.2.5"]
    Feast -->|"offline store"| DuckDB["DuckDB (ibis)<br/>>=10.0.0"]

    %% Internal Platform Dependencies
    ODHOperator["ODH/RHOAI Operator"] -->|"deploys via<br/>kustomize manifests"| Feast
    Feast -->|"CRD watch<br/>notebook integration"| KubeflowNB["Kubeflow Notebooks<br/>(kubeflow.org)"]
    Feast -->|"TLS cert provisioning<br/>annotation-driven"| ServiceCA["OpenShift Service CA"]

    %% Integration Points (consume Feast)
    Notebooks["Data Science Notebooks"] -->|"feature retrieval<br/>HTTP(S)"| Feast
    MLApps["ML Applications"] -->|"inference features<br/>HTTP/gRPC"| Feast

    %% External Service Backends
    Feast -->|"registry persistence<br/>443/TCP HTTPS"| S3["S3 Storage"]
    Feast -->|"registry persistence<br/>443/TCP HTTPS"| GCS["GCS"]
    Feast -->|"online/offline/registry<br/>443/TCP HTTPS"| Snowflake["Snowflake"]
    Feast -->|"online store<br/>443/TCP HTTPS"| DynamoDB["DynamoDB"]
    Feast -->|"online store + vector search<br/>9200/TCP HTTPS"| Elasticsearch["Elasticsearch"]
    Feast -->|"token validation<br/>443/TCP HTTPS"| OIDCProvider["OIDC Provider"]
    Feast -->|"API server<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

