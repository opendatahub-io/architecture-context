graph LR
    Feast["Feast Operator<br/>+ Feature Store"]

    %% Internal Platform Dependencies
    Feast -->|"Kustomize deploy"| RhodsOp["rhods-operator"]
    Feast -->|"CRD watch +<br/>ConfigMap inject"| KFNotebooks["Kubeflow Notebooks"]
    Feast -->|"ServiceMonitor CRD"| PromOp["Prometheus Operator"]
    Feast -->|"Route CRD"| OSRoutes["OpenShift Routes"]
    Feast -->|"TLS cert auto-provision"| OSCerts["OpenShift Service<br/>Serving Certs"]
    Feast -->|"CA certs mount"| ODHTrust["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% External Dependencies - Frameworks
    Feast -->|"operator framework"| CtrlRuntime["controller-runtime<br/>(Go)"]
    Feast -->|"HTTP framework"| FastAPI["FastAPI >=0.68.0<br/>(Python)"]
    Feast -->|"WSGI/ASGI"| Gunicorn["Gunicorn + Uvicorn"]
    Feast -->|"data format"| Arrow["Apache Arrow<br/>v17.0.0 (Go) / >=21.0.0 (Py)"]
    Feast -->|"serialization"| Protobuf["protobuf<br/>v1.36.10 (Go) / >=4.24.0 (Py)"]
    Feast -->|"JWT validation"| PyJWT["PyJWT<br/>(Python)"]
    Feast -->|"tracing"| OTEL["OpenTelemetry<br/>v1.38.0 (Go)"]

    %% Online Store Backends
    Feast -->|"online store"| Redis["Redis<br/>:6379/TCP"]
    Feast -->|"online/offline store"| Postgres["PostgreSQL<br/>:5432/TCP"]
    Feast -->|"online store"| DynamoDB["DynamoDB<br/>:443/TCP"]
    Feast -->|"online/offline store"| Snowflake["Snowflake<br/>:443/TCP"]

    %% Offline Store Backends
    Feast -->|"offline store"| BigQuery["BigQuery<br/>:443/TCP"]

    %% Registry Storage
    Feast -->|"registry storage"| S3["S3 Storage<br/>:443/TCP"]
    Feast -->|"registry storage"| GCS["GCS<br/>:443/TCP"]

    %% Platform Services
    Feast -->|"resource mgmt"| K8sAPI["Kubernetes API<br/>:6443/TCP"]
    Feast -->|"OIDC auth"| OIDCProvider["OIDC Provider<br/>:443/TCP"]
    Feast -->|"feature repo"| GitRepo["Git Repository<br/>:443/22 TCP"]

    %% Integration Points (things that depend on Feast)
    KFNotebooks -.->|"consumes features<br/>via ConfigMap"| Feast
    RhodsOp -.->|"deploys"| Feast

    %% Client Libraries
    Feast -->|"Go client"| GoRedis["go-redis/v9"]
    Feast -->|"Go client"| PGX["pgx/v5"]
    Feast -->|"AWS SDK"| AWSSDK["aws-sdk-go-v2 (Go)<br/>boto3 (Python)"]

    %% Styling
    style Feast fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal platform (green)
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style KFNotebooks fill:#7ed321,stroke:#333,color:#fff
    style PromOp fill:#7ed321,stroke:#333,color:#fff
    style OSRoutes fill:#7ed321,stroke:#333,color:#fff
    style OSCerts fill:#7ed321,stroke:#333,color:#fff
    style ODHTrust fill:#7ed321,stroke:#333,color:#fff

    %% External frameworks (light blue)
    style CtrlRuntime fill:#b8d4e3,stroke:#333,color:#333
    style FastAPI fill:#b8d4e3,stroke:#333,color:#333
    style Gunicorn fill:#b8d4e3,stroke:#333,color:#333
    style Arrow fill:#b8d4e3,stroke:#333,color:#333
    style Protobuf fill:#b8d4e3,stroke:#333,color:#333
    style PyJWT fill:#b8d4e3,stroke:#333,color:#333
    style OTEL fill:#b8d4e3,stroke:#333,color:#333
    style GoRedis fill:#b8d4e3,stroke:#333,color:#333
    style PGX fill:#b8d4e3,stroke:#333,color:#333
    style AWSSDK fill:#b8d4e3,stroke:#333,color:#333

