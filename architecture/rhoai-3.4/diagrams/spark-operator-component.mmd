graph TB
    subgraph SparkOperator["Spark Operator (redhat-ods-applications)"]
        direction TB

        subgraph ControllerPod["Controller Pod"]
            Controller["spark-operator controller<br/>(controller-runtime)<br/>Port 8080: metrics<br/>Port 8081: health"]
            CertProvider["Certificate Provider<br/>(pkg/certificate)"]
            SchedulerRegistry["Scheduler Registry<br/>(internal/scheduler)"]
            Controller --> CertProvider
            Controller --> SchedulerRegistry
        end

        subgraph WebhookPod["Webhook Pod"]
            Webhook["spark-operator webhook<br/>(controller-runtime)<br/>Port 9443: HTTPS<br/>Port 8080: metrics<br/>Port 8081: health"]
        end
    end

    %% CRDs
    SparkAppCR["SparkApplication CR<br/>(sparkoperator.k8s.io/v1beta2)"]
    ScheduledSparkAppCR["ScheduledSparkApplication CR<br/>(sparkoperator.k8s.io/v1beta2)"]
    SparkConnectCR["SparkConnect CR<br/>(sparkoperator.k8s.io/v1alpha1)"]

    %% User interaction
    User["User / Data Scientist"] -->|"kubectl create"| SparkAppCR
    User -->|"kubectl create"| ScheduledSparkAppCR
    User -->|"kubectl create"| SparkConnectCR

    %% Controller watches CRDs
    SparkAppCR -->|"watched by"| Controller
    ScheduledSparkAppCR -->|"watched by"| Controller
    SparkConnectCR -->|"watched by"| Controller

    %% Webhook intercepts
    SparkAppCR -.->|"mutate + validate"| Webhook
    ScheduledSparkAppCR -.->|"mutate + validate"| Webhook

    %% Controller creates resources
    Controller -->|"creates via spark-submit"| DriverPod["Driver Pod"]
    DriverPod -->|"creates"| ExecutorPods["Executor Pods"]
    Controller -->|"creates"| WebUISvc["Web UI Service<br/>(4040/TCP)"]
    Controller -->|"creates"| IngressRes["Ingress (optional)"]
    Controller -->|"creates"| MonitoringCM["Monitoring ConfigMap"]

    %% Webhook mutates pods
    DriverPod -.->|"mutated by (26 steps)"| Webhook
    ExecutorPods -.->|"mutated by (26 steps)"| Webhook

    %% SparkConnect resources
    Controller -->|"creates"| ConnectServer["SparkConnect Server Pod"]
    Controller -->|"creates"| ConnectSvc["SparkConnect Service<br/>7078, 7079, 4040, 15002"]

    %% External dependencies
    Controller -->|"depends on"| K8sAPI["Kubernetes API Server"]
    Webhook -->|"depends on"| K8sAPI

    %% Optional schedulers
    SchedulerRegistry -->|"optional"| Volcano["Volcano Scheduler"]
    SchedulerRegistry -->|"optional"| YuniKorn["Apache YuniKorn"]
    SchedulerRegistry -->|"optional"| KubeScheduler["Kube-Scheduler Plugins"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes :8080"| Controller
    Prometheus -->|"scrapes :8080"| Webhook
    JMXExporter["JMX Exporter<br/>(sidecar :8090)"] -.->|"injected into"| DriverPod
    JMXExporter -.->|"injected into"| ExecutorPods
    Prometheus -->|"scrapes :8090"| JMXExporter

    %% Platform deployment
    RhodsOperator["rhods-operator"] -->|"deploys via kustomize"| SparkOperator

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style CertProvider fill:#5ba8f7,stroke:#333,color:#fff
    style SchedulerRegistry fill:#5ba8f7,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333,color:#000
    style ScheduledSparkAppCR fill:#f5a623,stroke:#333,color:#000
    style SparkConnectCR fill:#f5a623,stroke:#333,color:#000
    style DriverPod fill:#7ed321,stroke:#333,color:#000
    style ExecutorPods fill:#7ed321,stroke:#333,color:#000
    style ConnectServer fill:#7ed321,stroke:#333,color:#000
    style K8sAPI fill:#e8e8e8,stroke:#333,color:#000
    style Volcano fill:#e8e8e8,stroke:#333,color:#000
    style YuniKorn fill:#e8e8e8,stroke:#333,color:#000
    style KubeScheduler fill:#e8e8e8,stroke:#333,color:#000
    style Prometheus fill:#e8e8e8,stroke:#333,color:#000
    style RhodsOperator fill:#9b59b6,stroke:#333,color:#fff
