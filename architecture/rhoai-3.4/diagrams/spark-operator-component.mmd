graph TB
    subgraph SparkOperator["Spark Operator (redhat-ods-applications)"]
        direction TB

        subgraph ControllerDeploy["Controller Deployment"]
            Controller["spark-operator-controller<br/>Go Operator<br/>controller-runtime v0.20.4<br/>10-thread worker pool"]
        end

        subgraph WebhookDeploy["Webhook Deployment"]
            Webhook["spark-operator-webhook<br/>9443/TCP HTTPS<br/>24-step mutation pipeline"]
        end

        subgraph Runtime["Bundled Runtime"]
            PySpark["PySpark 4.0.1<br/>Java 17 OpenJDK"]
        end
    end

    %% CRDs
    User[User / kubectl] -->|creates| SparkAppCR["SparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    User -->|creates| ScheduledCR["ScheduledSparkApplication CR<br/>sparkoperator.k8s.io/v1beta2"]
    User -->|creates| ConnectCR["SparkConnect CR<br/>sparkoperator.k8s.io/v1alpha1"]

    %% API Server interaction
    SparkAppCR -->|admission| Webhook
    ScheduledCR -->|admission| Webhook
    SparkAppCR -->|watched by| Controller
    ScheduledCR -->|watched by| Controller
    ConnectCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|creates| DriverPod["Driver Pod<br/>spark-submit"]
    Controller -->|creates| ExecutorPods["Executor Pods"]
    Controller -->|creates| SparkUI["Spark UI Service<br/>4040/TCP"]
    Controller -->|creates| WebUIIngress["Web UI Ingress<br/>(optional)"]

    %% Webhook mutates pods
    Webhook -->|mutates pods| DriverPod
    Webhook -->|mutates pods| ExecutorPods

    %% Driver-Executor communication
    DriverPod -->|7078/TCP, 7079/TCP| ExecutorPods

    %% External dependencies
    Controller -->|443/TCP HTTPS| K8sAPI["Kubernetes API Server"]
    Webhook -->|443/TCP HTTPS| K8sAPI
    Controller -.->|PodGroup CRDs| Volcano["Volcano Scheduler<br/>(optional)"]
    Controller -.->|pod annotations| Yunikorn["Yunikorn Scheduler<br/>(optional)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|scrape 8080/TCP| Controller
    Prometheus -->|scrape 8080/TCP| Webhook

    %% cert-manager
    CertManager["cert-manager<br/>(optional)"] -.->|TLS certs| Webhook

    %% Platform operator
    RhodsOp["rhods-operator"] -->|deploys manifests| SparkOperator

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style PySpark fill:#4a90e2,stroke:#333,color:#fff
    style SparkAppCR fill:#f5a623,stroke:#333,color:#fff
    style ScheduledCR fill:#f5a623,stroke:#333,color:#fff
    style ConnectCR fill:#f5a623,stroke:#333,color:#fff
    style DriverPod fill:#7ed321,stroke:#333,color:#fff
    style ExecutorPods fill:#7ed321,stroke:#333,color:#fff
    style SparkUI fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333
    style Yunikorn fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style RhodsOp fill:#9b59b6,stroke:#333,color:#fff
