graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(Data Scientist / Application)"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS Termination)"]
        Gateway["Platform Ingress<br/>(Gateway API / OpenShift Route)<br/>443/TCP → 8000/TCP<br/>TLS 1.2+<br/>Auth: Bearer Token (SSO)"]
    end

    subgraph KServeLayer["KSERVE ORCHESTRATION"]
        KServe["KServe Controller<br/>Manages InferenceService lifecycle<br/>RBAC: KServe-managed"]
    end

    subgraph PodBoundary["POD BOUNDARY (UID 2000, GID 0)"]
        direction TB

        subgraph Container["vllm-gaudi Container<br/>Image: odh-vllm-gaudi-rhel9<br/>Non-root: UID 2000, GID 0<br/>⚠ FIPS: openssl-fips-provider REMOVED"]
            APIServer["vLLM OpenAI API Server<br/>8000/TCP HTTP (plaintext)<br/>Auth: None (delegated)"]
            ModelRunner["HPU Model Runner<br/>(in-process)"]
            Worker["HPU Worker<br/>(device management)"]
        end
    end

    subgraph DistComm["DISTRIBUTED COMMUNICATION (Unencrypted)"]
        direction LR
        HCCL["HCCL Peer Workers<br/>Dynamic Port<br/>Protocol: HCCL (RDMA/TCP)<br/>Encryption: None<br/>Auth: None"]
        NIXL["NIXL Peer Nodes<br/>Dynamic Port<br/>Protocol: NIXL (RDMA/TCP)<br/>Encryption: None<br/>Auth: None"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelStore["Model Storage<br/>(PVC mount / S3)<br/>Protocol: Filesystem / HTTPS<br/>Encryption: Varies<br/>Auth: Platform-mounted credentials"]
        HabanaRepo["vault.habana.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>(BUILD-TIME ONLY)"]
    end

    %% Network Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (SSO)"| Gateway
    Gateway -->|"HTTP/8000<br/>Plaintext<br/>No Auth (cluster-internal)"| APIServer
    KServe -->|"Deploys & manages"| Container
    APIServer --> ModelRunner
    ModelRunner --> Worker
    Worker -->|"HCCL (RDMA/TCP)<br/>Dynamic Port<br/>⚠ No Encryption"| HCCL
    Worker -->|"NIXL (RDMA/TCP)<br/>Dynamic Port<br/>⚠ No Encryption"| NIXL
    Container -->|"Model weight loading<br/>Filesystem or HTTPS"| ModelStore

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef kserve fill:#e6d0de,stroke:#996185,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef distcomm fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:3px

    class Client external
    class Gateway ingress
    class KServe kserve
    class APIServer,ModelRunner,Worker pod
    class HCCL,NIXL distcomm
    class ModelStore,HabanaRepo externalservice
