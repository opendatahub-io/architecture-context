graph TB
    subgraph Operator["MLflow Operator (controller-runtime)"]
        direction TB
        Controller["mlflow-operator<br/>Go Controller<br/>8081/TCP health, 8443/TCP metrics"]
        HelmRenderer["HelmRenderer<br/>Embedded Helm Chart Engine"]
        Controller -->|renders via| HelmRenderer
    end

    subgraph MLflowPod["MLflow Server Pod"]
        direction TB
        InitCombineCA["Init: combine-ca-bundles<br/>Concatenates system + platform + custom CAs"]
        InitDBMigration["Init: db-migration<br/>mlflow db fix-migration-gap<br/>(Alembic schema migration)"]
        MLflowServer["MLflow Tracking Server<br/>8443/TCP HTTPS<br/>uvicorn + kubernetes-auth"]
        CAWatcher["Sidecar: ca-bundle-watcher<br/>Polls CA ConfigMap changes<br/>every 30s"]
        InitCombineCA -->|"creates initial bundle"| MLflowServer
        InitDBMigration -->|"schema ready"| MLflowServer
        CAWatcher -->|"updates combined-ca-bundle<br/>(emptyDir volume)"| MLflowServer
    end

    %% CRDs
    User[Platform Admin] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    NSOwner[Namespace Owner] -->|creates| MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespaced"]

    %% Operator watches and reconciles
    MLflowCR -->|watched by| Controller
    Controller -->|"SSA apply<br/>(Deployment, Service,<br/>SA, NetworkPolicy,<br/>PVC, ServiceMonitor)"| MLflowPod
    Controller -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift Console)"]

    %% MLflow server reads config
    MLflowConfigCR -->|"read at runtime<br/>(artifact storage override)"| MLflowServer

    %% External dependencies
    Controller -->|"watches/applies via"| K8sAPI["Kubernetes API<br/>6443/TCP"]
    HTTPRoute -->|"parent ref"| Gateway["data-science-gateway<br/>(Gateway API)"]
    MLflowServer -->|"SelfSubjectAccessReview"| K8sAPI
    MLflowServer -->|"backend store"| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflowServer -->|"artifact storage"| S3["S3-compatible Storage<br/>(MinIO/SeaweedFS/AWS S3)"]

    %% Platform integrations
    ServiceCA["OpenShift service-CA"] -->|"provisions TLS cert"| MLflowPod
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"] -->|"mounted"| MLflowPod
    Prometheus["Prometheus"] -->|"scrapes /metrics via<br/>ServiceMonitor"| MLflowServer

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style HelmRenderer fill:#4a90e2,stroke:#333,color:#fff
    style MLflowServer fill:#50c878,stroke:#333,color:#fff
    style CAWatcher fill:#50c878,stroke:#333,color:#fff
    style InitCombineCA fill:#87ceeb,stroke:#333
    style InitDBMigration fill:#87ceeb,stroke:#333
    style MLflowCR fill:#f5a623,stroke:#333
    style MLflowConfigCR fill:#f5a623,stroke:#333
    style HTTPRoute fill:#f5a623,stroke:#333
    style ConsoleLink fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#dda0dd,stroke:#333
    style CABundle fill:#dda0dd,stroke:#333
    style Prometheus fill:#dda0dd,stroke:#333
