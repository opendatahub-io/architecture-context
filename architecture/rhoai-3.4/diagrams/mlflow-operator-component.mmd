%% MLflow Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4/mlflow-operator.md

graph TB
    subgraph OperatorPod["MLflow Operator Pod"]
        Controller["MLflow Operator Controller<br/>(controller-runtime)"]
        HelmRenderer["Helm Chart Renderer<br/>(embedded Go library)"]
        Controller -->|renders templates| HelmRenderer
    end

    subgraph MLflowPod["MLflow Server Pod"]
        MLflowServer["MLflow Server<br/>Python / uvicorn<br/>Port 8443/TCP HTTPS"]
        CAInit["CA Bundle Init Container<br/>(combines CA bundles)"]
        CAWatcher["CA Bundle Watcher Sidecar<br/>(30s interval)"]
        CAInit -->|initializes| MLflowServer
        CAWatcher -->|updates CA bundle| MLflowServer
    end

    %% CRDs
    User[User / Admin] -->|creates| MLflowCR["MLflow CR<br/>(mlflow.opendatahub.io/v1)<br/>Cluster-scoped"]
    User -->|creates| MLflowConfigCR["MLflowConfig CR<br/>(mlflow.kubeflow.org/v1)<br/>Namespace-scoped"]

    MLflowCR -->|watched by| Controller
    MLflowConfigCR -->|watched by| Controller

    %% Operator creates resources
    Controller -->|Server-Side Apply| Deployment[Deployment]
    Controller -->|Server-Side Apply| Service[Service<br/>ClusterIP 8443/TCP]
    Controller -->|Server-Side Apply| NetworkPolicy[NetworkPolicy]
    Controller -->|Server-Side Apply| PVC[PVC]
    Controller -->|Server-Side Apply| SA[ServiceAccount]
    Controller -->|Server-Side Apply| RBAC[ClusterRole /<br/>ClusterRoleBinding]
    Controller -->|creates| HTTPRoute["HTTPRoute<br/>(Gateway API)"]
    Controller -->|creates| ConsoleLink["ConsoleLink<br/>(OpenShift)"]
    Controller -->|creates| ServiceMonitor["ServiceMonitor<br/>(Prometheus)"]

    Deployment -->|runs| MLflowPod

    %% External dependencies
    Controller -->|depends on| K8sAPI["Kubernetes API<br/>6443/TCP"]
    Controller -->|watches| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    HTTPRoute -->|references parent| Gateway["data-science-gateway<br/>(openshift-ingress)"]
    Service -->|cert from| ServiceCA["OpenShift service-ca"]

    %% MLflow external connections
    MLflowServer -->|auth checks| K8sAPI
    MLflowServer -->|artifacts| S3["S3-compatible Storage<br/>(S3/MinIO/SeaweedFS)"]
    MLflowServer -->|metadata| DB["Database<br/>(PostgreSQL / MySQL)"]

