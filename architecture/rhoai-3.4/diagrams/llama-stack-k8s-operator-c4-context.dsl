// C4 Context Diagram: llama-stack-k8s-operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Platform Admin / Data Scientist" "Creates LlamaStackDistribution CRs to deploy AI inference servers"
        externalClient = person "External Client" "Sends inference requests to exposed Llama Stack endpoints"

        llamaStackOperator = softwareSystem "llama-stack-k8s-operator" "Kubernetes operator managing lifecycle of Llama Stack server distributions on OpenShift/K8s" {
            reconciler = container "LlamaStackDistribution Reconciler" "Watches CRs and reconciles Deployments, Services, NetworkPolicies, PVCs, Ingresses, HPAs, PDBs" "Go Controller (controller-runtime)"
            kustomizeRenderer = container "Kustomize Renderer" "Renders base manifests with Go-based transformer plugins" "Go Library (sigs.k8s.io/kustomize)"
            clusterInfo = container "ClusterInfo" "Detects operator namespace and resolves distribution images" "Go Package"
            featureFlags = container "Feature Flags" "Controls optional features like NetworkPolicy creation" "Go Package"
            npTransformer = container "NetworkPolicy Transformer" "Generates NetworkPolicy ingress rules from CR spec" "Go Plugin"
            kubeRbacProxy = container "kube-rbac-proxy" "RBAC-authenticated metrics endpoint on 8443/TCP" "Sidecar Container"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "AI inference server (uvicorn/FastAPI) deployed per CR, serves on 8321/TCP" "Managed Workload"

        rhodsOperator = softwareSystem "rhods-operator" "Deploys llama-stack-k8s-operator via kustomize overlay" "Internal RHOAI"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "Infrastructure"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Infrastructure"
        odhTrustedCA = softwareSystem "ODH Trusted CA Bundle" "Platform trusted CA certificates ConfigMap" "Internal ODH"
        ingressController = softwareSystem "Kubernetes Ingress Controller" "Routes external traffic to services" "Infrastructure"

        // User interactions
        user -> llamaStackOperator "Creates LlamaStackDistribution CR via kubectl"
        externalClient -> ingressController "Sends inference requests" "HTTP/HTTPS 80/443"

        // Operator interactions
        llamaStackOperator -> k8sAPI "CRUD operations on cluster resources" "HTTPS/443, SA token"
        llamaStackOperator -> llamaStackServer "Health/version checks during reconciliation" "HTTP/8321"
        rhodsOperator -> llamaStackOperator "Deploys via config/overlays/rhoai/" "Kustomize"
        prometheus -> llamaStackOperator "Scrapes operator metrics" "HTTPS/8443, Bearer Token"
        llamaStackOperator -> odhTrustedCA "Auto-detects trusted CA bundle ConfigMap" "K8s API watch"
        ingressController -> llamaStackServer "Forwards traffic when exposeRoute enabled" "HTTP/8321"

        // Internal container relationships
        reconciler -> kustomizeRenderer "Renders manifests"
        reconciler -> clusterInfo "Resolves images and namespace"
        reconciler -> featureFlags "Checks feature toggles"
        kustomizeRenderer -> npTransformer "Applies NP rules"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "Managed Workload" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
