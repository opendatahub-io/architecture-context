graph LR
    MR["Model Registry<br/>(model-registry proxy)"]

    %% External Dependencies
    MR -->|"metadata persistence<br/>TCP/3306"| MySQL["MySQL 8.3+"]
    MR -->|"metadata persistence<br/>TCP/5432"| PostgreSQL["PostgreSQL 16+"]
    MR -->|"mTLS, routing,<br/>authorization"| Istio["Istio Service Mesh"]
    MR -.->|"metrics scrape<br/>HTTPS/8443"| Prometheus["Prometheus"]

    %% Internal ODH Dependencies
    Controller["controller-manager"] -->|"CRD Watch<br/>InferenceService v1beta1<br/>HTTPS/6443"| KServe["KServe"]
    Controller -->|"sync metadata<br/>HTTP/8080"| MR
    CSI["mr-storage-initializer"] -->|"CRD<br/>ClusterStorageContainer v1alpha1"| KServe
    CSI -->|"resolve URIs<br/>HTTP/8080"| MR

    %% Async Upload Dependencies
    AsyncJob["async-upload job"] -->|"register metadata<br/>HTTP/8080"| MR
    AsyncJob -->|"model files<br/>HTTPS/443"| S3["S3-compatible Storage"]
    AsyncJob -->|"model images<br/>HTTPS/443"| OCI["OCI Registries"]
    AsyncJob -->|"signing<br/>HTTPS/443"| Sigstore["Sigstore/Rekor"]
    AsyncJob -.->|"copy images"| Skopeo["skopeo"]

    %% UI Dependencies
    UI["model-registry-ui"] -->|"REST API<br/>HTTP/8080"| MR
    UI -->|"service discovery<br/>SAR checks<br/>HTTPS/6443"| K8sAPI["Kubernetes API"]

    %% Platform Integration
    Istio -->|"VirtualService<br/>ingress routing"| KFGateway["Kubeflow Gateway"]
    KFGateway -->|"external entry point<br/>HTTPS/443 → HTTP/8080"| MR
    RHODSOp["rhods-operator"] -->|"deploy & configure<br/>instances"| MR

    %% Integration Points (reverse direction — things that use MR)
    DSP["Data Science Pipelines"] -.->|"model registration"| MR
    Dashboard["ODH Dashboard"] -.->|"UI integration"| MR

    %% Kubernetes API connections
    Controller -->|"leader election<br/>watch CRs<br/>HTTPS/6443"| K8sAPI

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style AsyncJob fill:#9b59b6,stroke:#333,color:#fff
    style UI fill:#3498db,stroke:#333,color:#fff

    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff

    style KServe fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style KFGateway fill:#999,stroke:#333,color:#fff
    style Skopeo fill:#999,stroke:#333,color:#fff

    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCI fill:#f5a623,stroke:#333,color:#fff
    style Sigstore fill:#f5a623,stroke:#333,color:#fff
