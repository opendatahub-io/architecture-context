graph LR
    MR["Model Registry<br/>REST API Server"]

    %% External Dependencies (Required)
    MR -->|"metadata storage<br/>3306/TCP MySQL"| MySQL["MySQL 8.3+"]
    MR -->|"alt. metadata storage<br/>5432/TCP PostgreSQL"| PostgreSQL["PostgreSQL 16+"]

    %% External Dependencies (Controller only)
    MR -.->|"CRD watch<br/>(controller)"| KServe["KServe v0.17.0-rc1"]
    MR -.->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]

    %% Library Dependencies
    MR -->|"HTTP routing"| Chi["go-chi/chi v5.2.5"]
    MR -->|"ORM"| GORM["GORM v1.31.1"]

    %% Async-Upload Dependencies
    AsyncJob["async-upload Job<br/>(Python)"] -->|"API client"| MRSDK["model-registry<br/>Python SDK<br/>>=0.3.7,<0.4.0"]
    AsyncJob -->|"OCI operations"| Skopeo["skopeo<br/>(system package)"]
    AsyncJob -->|"model downloads"| HFHub["huggingface-hub<br/>>=0.29.3,<0.31.0"]
    AsyncJob -->|"signing"| Cosign["Sigstore (cosign)<br/>via SDK"]

    %% Internal RHOAI Dependencies
    Dashboard["RHOAI Dashboard"] -->|"REST API consumer<br/>8080/TCP HTTP"| MR
    PlatformOp["RHODS Operator"] -->|"deploys via<br/>kustomize"| MR
    KServe -->|"InferenceService CR<br/>watched by controller"| MR
    KServeCSI["KServe Runtime"] -->|"model-registry://<br/>URI resolution"| MR

    %% Integration Points (Egress)
    AsyncJob -->|"model storage<br/>443/TCP HTTPS"| S3["S3 Storage<br/>(AWS/MinIO)"]
    AsyncJob -->|"model images<br/>443/TCP HTTPS"| OCIReg["OCI Registry<br/>(Quay/DockerHub)"]
    AsyncJob -->|"model downloads<br/>443/TCP HTTPS"| HFHubSvc["HuggingFace Hub"]
    AsyncJob -->|"signing/verify<br/>443/TCP HTTPS"| SigstoreSvc["Sigstore Services"]

    %% Infrastructure
    MR -.->|"traffic routing<br/>mTLS"| Istio["Istio Service Mesh"]
    MR -.->|"metrics<br/>8443/TCP HTTPS"| Prometheus["Prometheus"]
    MR -->|"API access<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Styling
    style MR fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style AsyncJob fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    %% Required external deps
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333

    %% Optional/controller deps
    style KServe fill:#999,stroke:#333
    style ControllerRuntime fill:#999,stroke:#333

    %% Library deps
    style Chi fill:#ddd,stroke:#333
    style GORM fill:#ddd,stroke:#333
    style MRSDK fill:#ddd,stroke:#333
    style Skopeo fill:#ddd,stroke:#333
    style HFHub fill:#ddd,stroke:#333
    style Cosign fill:#ddd,stroke:#333

    %% Internal RHOAI
    style Dashboard fill:#7ed321,stroke:#333
    style PlatformOp fill:#7ed321,stroke:#333
    style KServeCSI fill:#7ed321,stroke:#333

    %% External services
    style S3 fill:#e8e8e8,stroke:#333
    style OCIReg fill:#e8e8e8,stroke:#333
    style HFHubSvc fill:#e8e8e8,stroke:#333
    style SigstoreSvc fill:#e8e8e8,stroke:#333

    %% Infrastructure
    style Istio fill:#b8d4e3,stroke:#333
    style Prometheus fill:#b8d4e3,stroke:#333
    style K8sAPI fill:#b8d4e3,stroke:#333
