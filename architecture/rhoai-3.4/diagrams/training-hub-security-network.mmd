graph TB
    subgraph TrainingEnv["TRAINING ENVIRONMENT (GPU Node / Pod)"]
        direction TB

        subgraph Library["training-hub Library (In-Process)"]
            direction LR
            SFT["SFT Algorithm<br/>→ InstructLab Backend"]
            OSFT["OSFT Algorithm<br/>→ Mini-Trainer Backend"]
            LoRA["LoRA SFT Algorithm<br/>→ Unsloth Backend"]
            GRPO["LoRA GRPO Algorithm<br/>→ ART / verl Backend"]
            Profiling["Memory / Timing<br/>Estimators"]
        end

        subgraph LocalIPC["LOCAL IPC (No Encryption)"]
            Torchrun["torchrun Rendezvous<br/>29500/TCP<br/>Protocol: TCP<br/>Encryption: None<br/>Auth: None"]
            vLLM["vLLM Inference<br/>(co-located process)<br/>IPC"]
        end

        subgraph FileIO["LOCAL FILE I/O"]
            Checkpoints["Checkpoint Dir<br/>Model weights<br/>trainer_state.json"]
            Cache["Model Metadata CSV<br/>Cache"]
            TBFiles["TensorBoard<br/>Event Files"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress Only)"]
        direction TB

        HF["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: HF_TOKEN env var"]
        WB["Weights & Biases<br/>api.wandb.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: WANDB_API_KEY"]
        MLflow["MLflow Tracking<br/>Configurable host<br/>HTTP/HTTPS<br/>Auth: Configurable"]
    end

    subgraph MultiNode["MULTI-NODE (If Applicable)"]
        OtherNode["Other Training Nodes<br/>29500/TCP<br/>Protocol: TCP<br/>⚠ Encryption: None<br/>⚠ Auth: None"]
    end

    %% Flows from library to local
    Library -->|"in-process<br/>Python calls"| LocalIPC
    Library -->|"file write"| FileIO

    %% Flows from library to external
    SFT -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    OSFT -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    LoRA -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    GRPO -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    Profiling -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF

    Library -.->|"HTTPS/443<br/>TLS 1.2+<br/>WANDB_API_KEY<br/>(if configured)"| WB
    Library -.->|"HTTP(S)<br/>Configurable<br/>(if configured)"| MLflow

    %% Multi-node
    Torchrun -->|"TCP/29500<br/>⚠ Plaintext<br/>Gradient sync"| OtherNode

    %% Styling
    classDef library fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef localio fill:#e8f0fe,stroke:#4a90e2,stroke-width:1px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class SFT,OSFT,LoRA,GRPO,Profiling library
    class Torchrun,vLLM,Checkpoints,Cache,TBFiles localio
    class HF,WB,MLflow external
    class OtherNode warning
