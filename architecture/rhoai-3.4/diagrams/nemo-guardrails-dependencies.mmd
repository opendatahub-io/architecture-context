graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% Core Framework Dependencies
    NemoGuardrails -->|"HTTP server"| FastAPI["FastAPI >=0.103.0"]
    NemoGuardrails -->|"ASGI server"| Uvicorn["uvicorn >=0.23"]
    NemoGuardrails -->|"DSL parsing"| Lark["Lark >=1.3.0"]

    %% LLM Provider Dependencies
    NemoGuardrails -->|"LLM abstraction"| LangChain["LangChain >=0.2.14"]
    LangChain -->|"provider"| LangChainOpenAI["LangChain OpenAI"]
    LangChain -->|"provider"| LangChainNVIDIA["LangChain NVIDIA"]
    LangChain -->|"integrations"| LangChainCommunity["LangChain Community"]

    %% ML/NLP Dependencies
    NemoGuardrails -->|"NLP pipeline"| spaCy["spaCy >=3.4.4"]
    spaCy -->|"model"| EnCoreWebLg["en_core_web_lg 3.8.0"]
    NemoGuardrails -->|"PII detection"| Presidio["Presidio Analyzer >=2.2"]
    NemoGuardrails -->|"PII masking"| PresidioAnon["Presidio Anonymizer >=2.2"]
    NemoGuardrails -->|"injection rules"| YARA["YARA Python >=4.5.4"]
    NemoGuardrails -->|"embeddings"| SentenceTransformers["Sentence Transformers >=2.2.0"]
    NemoGuardrails -->|"fast embeddings"| FastEmbed["FastEmbed >=0.2.2"]
    NemoGuardrails -->|"ML inference"| ONNX["ONNX Runtime >=1.17.0"]
    NemoGuardrails -->|"ML framework"| PyTorch["PyTorch >=2.0.0"]
    NemoGuardrails -->|"tokenization"| NLTK["NLTK >=3.8"]
    NemoGuardrails -->|"ANN search"| Annoy["Annoy >=1.17.3"]

    %% Observability Dependencies
    NemoGuardrails -->|"tracing API"| OTelAPI["OpenTelemetry API >=1.27.0"]
    OTelAPI -->|"exporter"| OTelOTLP["OTel Exporter OTLP"]
    OTelAPI -->|"auto-instrument"| OTelFastAPI["OTel Instr. FastAPI"]
    OTelAPI -->|"auto-instrument"| OTelHttpx["OTel Instr. httpx"]

    %% Runtime Dependencies
    NemoGuardrails -->|"async HTTP"| aiohttp["aiohttp >=3.10.11"]
    NemoGuardrails -->|"HTTP client"| httpx["httpx >=0.24.1"]
    NemoGuardrails -->|"validation"| Pydantic["Pydantic >=1.10"]
    NemoGuardrails -->|"API schemas"| OpenAISDK["OpenAI SDK >=1.0.0"]
    NemoGuardrails -->|"lang detect"| FastLangDetect["fast-langdetect >=1.0.0"]
    NemoGuardrails -->|"config reload"| Watchdog["watchdog >=3.0.0"]

    %% Internal Platform Dependencies
    NemoGuardrails ==>|"LLM inference<br/>HTTPS/443"| UpstreamLLM["Upstream LLM Server<br/>(OpenAI / NVIDIA NIM)"]
    NemoGuardrails ==>|"trace export<br/>gRPC/4317"| OTelCollector["OpenTelemetry Collector"]
    NemoGuardrails -.->|"thread persistence<br/>TCP/6379 (optional)"| Redis["Redis"]

    %% Platform Integration
    RHOAIPlatform["RHOAI Platform<br/>Operator"] ==>|"deploys"| NemoGuardrails
    RHOAIGateway["RHOAI Gateway<br/>(Ingress)"] ==>|"routes traffic<br/>HTTP/8000"| NemoGuardrails

