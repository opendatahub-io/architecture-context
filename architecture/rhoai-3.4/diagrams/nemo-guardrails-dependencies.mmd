graph LR
    NemoGuardrails["NeMo Guardrails<br/>Server"]

    %% LLM Provider Dependencies (Outbound REST)
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| OpenAI["OpenAI API"]
    NemoGuardrails -->|"HTTPS/443<br/>x-api-key"| Anthropic["Anthropic API"]
    NemoGuardrails -->|"HTTPS/443<br/>api-key"| AzureOpenAI["Azure OpenAI"]
    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| Cohere["Cohere API"]
    NemoGuardrails -->|"HTTP(S)<br/>configurable"| vLLM["vLLM"]
    NemoGuardrails -->|"HTTP(S)<br/>configurable"| NIM["NVIDIA NIM"]
    NemoGuardrails -->|"HTTP(S)<br/>configurable"| TRTLLM["TRT-LLM"]

    %% Safety Model Dependencies
    NemoGuardrails -->|"HTTP(S)<br/>API key"| ContentSafety["Content Safety Model"]
    NemoGuardrails -->|"HTTP(S)<br/>API key"| JailbreakDetect["Jailbreak Detection"]

    %% Optional Service Dependencies
    NemoGuardrails -.->|"TCP/6379<br/>optional TLS"| Redis["Redis"]
    NemoGuardrails -.->|"OTLP<br/>configurable"| OTEL["OpenTelemetry Collector"]
    NemoGuardrails -.->|"HTTPS/443<br/>API key"| NVIDIAEndpoints["NVIDIA AI Endpoints"]

    %% Library Dependencies (In-Process)
    NemoGuardrails -->|"in-process"| FastAPI["FastAPI >=0.103.0"]
    NemoGuardrails -->|"in-process"| LangChain["LangChain >=0.2.14"]
    NemoGuardrails -->|"in-process"| FastEmbed["FastEmbed >=0.2.2<br/>(all-MiniLM-L6-v2)"]
    NemoGuardrails -->|"in-process"| Annoy["Annoy >=1.17.3<br/>(Vector search)"]
    NemoGuardrails -->|"in-process"| Presidio["Presidio<br/>(PII detection)"]
    NemoGuardrails -->|"in-process"| Spacy["spacy en_core_web_lg<br/>(NLP)"]
    NemoGuardrails -->|"in-process"| Lark["Lark >=1.1.7<br/>(Colang parser)"]
    NemoGuardrails -->|"in-process"| ONNX["ONNX Runtime >=1.17.0"]

    %% Platform Dependencies
    RHOAIPlatform["RHOAI Platform<br/>(rhods-operator)"] -->|"manages ingress,<br/>auth, deployment"| NemoGuardrails

    %% Build-time only
    NemoGuardrails -.->|"HTTPS/443<br/>build-time only"| HuggingFace["HuggingFace Hub"]

    %% Styling
    style NemoGuardrails fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% LLM Providers
    style OpenAI fill:#999,stroke:#333,color:#fff
    style Anthropic fill:#999,stroke:#333,color:#fff
    style AzureOpenAI fill:#999,stroke:#333,color:#fff
    style Cohere fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style NIM fill:#999,stroke:#333,color:#fff
    style TRTLLM fill:#999,stroke:#333,color:#fff

    %% Safety Models
    style ContentSafety fill:#f8cecc,stroke:#b85450,color:#000
    style JailbreakDetect fill:#f8cecc,stroke:#b85450,color:#000

    %% Optional Services
    style Redis fill:#fff2cc,stroke:#d6b656,color:#000
    style OTEL fill:#fff2cc,stroke:#d6b656,color:#000
    style NVIDIAEndpoints fill:#fff2cc,stroke:#d6b656,color:#000
    style HuggingFace fill:#fff2cc,stroke:#d6b656,color:#000

    %% Libraries
    style FastAPI fill:#d5e8d4,stroke:#82b366,color:#000
    style LangChain fill:#d5e8d4,stroke:#82b366,color:#000
    style FastEmbed fill:#d5e8d4,stroke:#82b366,color:#000
    style Annoy fill:#d5e8d4,stroke:#82b366,color:#000
    style Presidio fill:#d5e8d4,stroke:#82b366,color:#000
    style Spacy fill:#d5e8d4,stroke:#82b366,color:#000
    style Lark fill:#d5e8d4,stroke:#82b366,color:#000
    style ONNX fill:#d5e8d4,stroke:#82b366,color:#000

    %% Platform
