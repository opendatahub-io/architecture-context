graph LR
    MCP["RHOAI MCP Server<br/>(FastMCP + pluggy)"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies"]
        direction TB
        FastMCP["mcp >=1.0.0<br/>(FastMCP)"]
        K8sPy["kubernetes >=28.1.0"]
        Pydantic["pydantic >=2.0.0"]
        PydanticSettings["pydantic-settings >=2.0.0"]
        Httpx["httpx >=0.27.0"]
        Pluggy["pluggy >=1.4.0"]
    end

    MCP -->|MCP protocol| FastMCP
    MCP -->|K8s API client| K8sPy
    MCP -->|data models| Pydantic
    MCP -->|config mgmt| PydanticSettings
    MCP -->|HTTP client| Httpx
    MCP -->|plugin system| Pluggy

    %% CLI Tools (Optional)
    subgraph CLITools["CLI Tools (Optional)"]
        direction TB
        Git["git (CLI)"]
        Helm["helm v3.18.0"]
        OC["oc stable-4.18"]
    end

    MCP -.->|quickstart clone| Git
    MCP -.->|chart deploy| Helm
    MCP -.->|port-forward, deploy| OC

    %% Internal RHOAI Dependencies (via K8s API)
    subgraph RHOAIComponents["RHOAI Components (via K8s API)"]
        direction TB
        DSC["DataScienceCluster CR"]
        DSCI["DSCInitialization CR"]
        AccProf["AcceleratorProfile CR"]
        NotebookCR["Kubeflow Notebook CR"]
        ISVC["KServe InferenceService CR"]
        ServingRT["KServe ServingRuntime CR"]
        DSPA["DSPA CR"]
        TrainJob["TrainJob CR"]
        CTR["ClusterTrainingRuntime CR"]
        TR["TrainingRuntime CR"]
    end

    MCP -->|reads status| DSC
    MCP -->|reads status| DSCI
    MCP -->|reads GPUs| AccProf
    MCP -->|CRUD| NotebookCR
    MCP -->|CRUD| ISVC
    MCP -->|CRUD| ServingRT
    MCP -->|CRUD| DSPA
    MCP -->|CRUD| TrainJob
    MCP -->|CRUD| CTR
    MCP -->|reads| TR

    %% Internal RHOAI Services
    subgraph RHOAIServices["RHOAI Services (REST API)"]
        direction TB
        NeuralNav["Neural Navigator<br/>HTTP/8000"]
        ModelReg["Model Registry<br/>HTTP/8080, HTTPS/8443"]
        ModelCat["Model Catalog<br/>HTTP/8080, HTTPS/8443"]
    end

    MCP -->|recommendations| NeuralNav
    MCP -->|model metadata| ModelReg
    MCP -->|catalog browse| ModelCat

    %% Platform Dependencies
    subgraph Platform["Platform"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>HTTPS/6443"]
        OSRoute["OpenShift Route API"]
        OSProject["OpenShift Project API"]
        OSTemplate["OpenShift Template API"]
    end

    MCP -->|all resource ops| K8sAPI
    MCP -->|URL discovery| OSRoute
    MCP -->|namespace mgmt| OSProject
    MCP -->|runtime templates| OSTemplate

    %% External Services
    GitHub["GitHub<br/>HTTPS/443"]
    MCP -->|quickstart repos| GitHub

    %% Integration Points (components that use MCP)
    subgraph Consumers["Consumers"]
        direction TB
        Claude["Claude Desktop"]
        ChatGPT["ChatGPT"]
        OtherLLM["Other LLM Agents"]
    end

    Claude -->|stdio| MCP
    ChatGPT -->|SSE/HTTP| MCP
    OtherLLM -->|SSE/HTTP| MCP

