graph TD
    subgraph ServiceIdentity["Service Identity"]
        SA["fms-guardrails-orchestrator<br/>UID: 1001 (non-root)<br/>GID: 0"]
    end

    subgraph NoRBAC["Kubernetes RBAC"]
        NoneRequired["No ClusterRoles<br/>No RoleBindings<br/>No K8s API access required<br/>(standalone service)"]
    end

    subgraph TLSAuth["TLS / mTLS Authentication"]
        direction TB
        ServerTLS["Server TLS<br/>rustls ServerConfig<br/>TLS_CERT_PATH + TLS_KEY_PATH"]
        ClientCA["Client CA Verification<br/>WebPkiClientVerifier<br/>TLS_CLIENT_CA_CERT_PATH"]
        InsecureMode["⚠ NoVerifier Mode<br/>insecure: true<br/>Disables cert verification"]
    end

    subgraph HeaderAuth["Header-Based Authentication"]
        direction TB
        HeaderPassthrough["Header Passthrough<br/>X-Forwarded-Access-Token<br/>→ Bearer token rewrite"]
        DetectorHeaders["Detector Headers<br/>detector-id<br/>x-model-name"]
        APIToken["API Token Config<br/>api_token per backend<br/>→ Bearer authorization"]
    end

    subgraph Secrets["Secrets Management"]
        direction TB
        TLSServerCert["TLS Server Keypair<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager<br/>Auto-Rotate: Yes (cert-manager)"]
        TLSClientCA["TLS Client CA Cert<br/>Type: Opaque<br/>Provisioned: Platform operator<br/>Auto-Rotate: Depends"]
        ClientTLSConfigs["Client TLS Configs<br/>Type: Opaque<br/>Per-service certs/keys<br/>Auto-Rotate: No"]
        APITokenSecret["API Tokens<br/>Type: Opaque<br/>Bearer tokens for backends<br/>Auto-Rotate: No"]
    end

    subgraph Endpoints["Endpoint Security"]
        direction TB
        GuardrailsEP["/api/v1/*, /api/v2/*<br/>Optional mTLS + Header passthrough"]
        HealthEP["/health, /info<br/>No authentication<br/>Open access (plaintext)"]
    end

    SA -->|"runs as"| NoneRequired
    SA -->|"TLS identity"| ServerTLS
    ServerTLS -->|"mutual auth"| ClientCA
    ServerTLS -.->|"dev override"| InsecureMode

    ServerTLS -->|"cert from"| TLSServerCert
    ClientCA -->|"CA from"| TLSClientCA

    HeaderPassthrough -->|"forwards to backends"| DetectorHeaders
    HeaderPassthrough -->|"or uses"| APIToken
    APIToken -->|"stored in"| APITokenSecret

    TLSAuth -->|"protects"| GuardrailsEP
    HeaderAuth -->|"authenticates"| GuardrailsEP

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style NoneRequired fill:#d5e8d4,stroke:#82b366
    style ServerTLS fill:#fff2cc,stroke:#d6b656
    style ClientCA fill:#fff2cc,stroke:#d6b656
    style InsecureMode fill:#f8cecc,stroke:#b85450
    style HeaderPassthrough fill:#dae8fc,stroke:#6c8ebf
    style DetectorHeaders fill:#dae8fc,stroke:#6c8ebf
    style APIToken fill:#dae8fc,stroke:#6c8ebf
    style TLSServerCert fill:#e1d5e7,stroke:#9673a6
    style TLSClientCA fill:#e1d5e7,stroke:#9673a6
    style ClientTLSConfigs fill:#e1d5e7,stroke:#9673a6
    style APITokenSecret fill:#e1d5e7,stroke:#9673a6
    style GuardrailsEP fill:#d5e8d4,stroke:#82b366
    style HealthEP fill:#f8cecc,stroke:#b85450
