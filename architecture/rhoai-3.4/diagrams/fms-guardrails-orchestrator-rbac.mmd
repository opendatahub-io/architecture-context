graph TD
    subgraph "Container Security"
        User["Process User<br/>orchestr8 (UID 1001, GID 0)<br/>Non-root"]
        Image["Base Image<br/>UBI 9 Minimal"]
        Build["Multi-stage Build<br/>cargo test in builder"]
    end

    subgraph "Server Authentication"
        ServerTLS["Server TLS (optional)<br/>rustls/ring<br/>TLS 1.2+"]
        mTLS["mTLS Client Verification<br/>WebPkiClientVerifier<br/>(when TLS_CLIENT_CA_CERT_PATH set)"]
        HeaderPassthrough["Header Passthrough<br/>passthrough_headers config<br/>X-Forwarded-Access-Token<br/>→ Authorization: Bearer"]
    end

    subgraph "Client Authentication (Egress)"
        gRPCAuth["gRPC Client Auth<br/>Per-service mTLS certs<br/>(config.yaml tls section)<br/>mm-model-id header"]
        HTTPAuth["HTTP Client Auth<br/>Bearer token per-service<br/>(api_token env var)<br/>detector-id header"]
    end

    subgraph "Secrets Management"
        TLSCert["TLS Server Cert/Key<br/>kubernetes.io/tls<br/>Via: TLS_CERT_PATH, TLS_KEY_PATH<br/>Manual provisioning"]
        ClientCA["TLS Client CA Cert<br/>Opaque<br/>Via: TLS_CLIENT_CA_CERT_PATH<br/>Manual provisioning"]
        ServiceCerts["Per-service TLS Certs<br/>kubernetes.io/tls<br/>Via: config.yaml tls paths<br/>Manual provisioning"]
        APITokens["Per-service API Tokens<br/>Opaque<br/>Via: env vars in config.yaml<br/>Manual provisioning"]
    end

    subgraph "FIPS Notes"
        FIPSNote["rustls/ring: NOT FIPS-certified<br/>OpenSSL in image: check-payload only<br/>App does NOT use system OpenSSL<br/>NoVerifier: dev/test bypass"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No RBAC Defined<br/>(standalone service,<br/>not a K8s operator)"]
    end

    ServerTLS --> TLSCert
    mTLS --> ClientCA
    gRPCAuth --> ServiceCerts
    HTTPAuth --> APITokens

    style User fill:#4a90e2,stroke:#333,color:#fff
    style Image fill:#4a90e2,stroke:#333,color:#fff
    style Build fill:#4a90e2,stroke:#333,color:#fff
    style ServerTLS fill:#7ed321,stroke:#333
    style mTLS fill:#7ed321,stroke:#333
    style HeaderPassthrough fill:#7ed321,stroke:#333
    style gRPCAuth fill:#f5a623,stroke:#333
    style HTTPAuth fill:#f5a623,stroke:#333
    style TLSCert fill:#d5e8d4,stroke:#82b366
    style ClientCA fill:#d5e8d4,stroke:#82b366
    style ServiceCerts fill:#d5e8d4,stroke:#82b366
    style APITokens fill:#d5e8d4,stroke:#82b366
    style FIPSNote fill:#f8cecc,stroke:#b85450
    style NoRBAC fill:#e8e8e8,stroke:#999
