graph LR
    Trainer["Kubeflow Trainer<br/>Operator"]

    %% External Dependencies (Required)
    Trainer -->|"creates JobSet CRs<br/>jobset.x-k8s.io/v1alpha2"| JobSet["JobSet Controller<br/>v0.10.1<br/>(Required)"]
    Trainer -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.22.3<br/>(Required)"]
    Trainer -->|"webhook cert rotation"| CertController["cert-controller<br/>(OPA) v0.14.0<br/>(Required)"]

    %% External Dependencies (Optional)
    Trainer -->|"creates LeaderWorkerSet<br/>(data-cache runtimes)"| LWS["LeaderWorkerSet<br/>v0.7.0<br/>(Optional)"]
    Trainer -->|"creates PodGroup<br/>(CoScheduling mode)"| SchedPlugins["K8s Scheduler Plugins<br/>v0.34.1<br/>(Optional)"]
    Trainer -->|"creates PodGroup<br/>(Volcano mode)"| Volcano["Volcano<br/>v1.13.1<br/>(Optional)"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>kustomize manifests"| Trainer
    ImageStreams["OpenShift<br/>ImageStreams"] -.->|"image resolution<br/>for training runtimes"| Trainer

    %% Integration Points - Consumers
    Kueue["Kueue<br/>(MultiKueue)"] -.->|"managedBy field<br/>delegation"| Trainer

    %% Integration Points - Watches
    Trainer -->|"watches RuntimeClass<br/>for PodGroup recalc"| RuntimeClass["RuntimeClass<br/>(node.k8s.io)"]
    Trainer -->|"watches LimitRange<br/>for resource recalc"| LimitRange["LimitRange<br/>(core)"]

    %% Integration Points - Monitoring
    Prometheus["Prometheus /<br/>OpenShift Monitoring"] -->|"scrapes 8443/TCP<br/>HTTPS (PodMonitor)"| Trainer

    %% Core Platform
    Trainer -->|"CRD reconciliation<br/>resource management<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]

    %% External Services
    Trainer -.->|"training image pulls<br/>443/TCP HTTPS<br/>(via kubelet)"| Registry["Container Registries<br/>quay.io, ghcr.io"]

    %% Data Cache path
    Trainer -.->|"Iceberg metadata<br/>(data-cache only)"| Iceberg["Iceberg Storage<br/>(S3/GCS/HDFS)"]

    %% Styling
    style Trainer fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style JobSet fill:#e8e8e8,stroke:#333
    style ControllerRuntime fill:#e8e8e8,stroke:#333
    style CertController fill:#e8e8e8,stroke:#333
    style LWS fill:#ccc,stroke:#999,stroke-dasharray: 5 5
    style SchedPlugins fill:#ccc,stroke:#999,stroke-dasharray: 5 5
    style Volcano fill:#ccc,stroke:#999,stroke-dasharray: 5 5
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style ImageStreams fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#ccc,stroke:#999,stroke-dasharray: 5 5
    style RuntimeClass fill:#f5a623,stroke:#333
    style LimitRange fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style Registry fill:#f5a623,stroke:#333
    style Iceberg fill:#ccc,stroke:#999,stroke-dasharray: 5 5
