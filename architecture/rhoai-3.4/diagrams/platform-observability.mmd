graph TB
    subgraph ObsStack["Observability Stack (Platform Namespace)"]
        direction TB
        MonStack["MonitoringStack<br/>Prometheus + Alertmanager<br/>Scrapes ServiceMonitor resources"]
        OTelCollector["OpenTelemetry Collector<br/>Receives: metrics + traces<br/>Protocol: OTLP gRPC"]
        TempoBackend["Tempo<br/>TempoMonolithic or TempoStack<br/>Trace storage + query"]
        PersesDash["Perses Dashboards<br/>Visualization layer<br/>Queries Prometheus"]
    end

    subgraph Prometheus["Prometheus Scrape Targets (ServiceMonitor)"]
        direction TB

        subgraph ControllerMetrics["Platform Controller Metrics"]
            PM_kserve["KServe Controller<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>FIPS cipher suites"]
            PM_llmisvc["llmisvc Controller<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
            PM_dashboard["odh-dashboard<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>FIPS cipher suites"]
            PM_odmctl["odh-model-controller<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>FIPS cipher suites"]
            PM_kubeflow["Kubeflow Notebook Ctrl<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
            PM_kuberay["KubeRay Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
            PM_dspo["DS Pipelines Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
            PM_trustyai["TrustyAI Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy<br/>FIPS cipher suites"]
            PM_feast["Feast Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
            PM_mlflow["MLflow Operator<br/>Port: 8443/TCP<br/>Auth: kube-rbac-proxy"]
        end

        subgraph RuntimeMetrics["Model Serving Runtime Metrics"]
            PM_vllm["vLLM Runtime<br/>Dedicated metrics port<br/>Auth: None<br/>REQUEST_COUNT, latency, GPU"]
            PM_openvino["OpenVINO Runtime<br/>Dedicated metrics port<br/>Auth: None"]
            PM_mlserver["MLServer Runtime<br/>Dedicated metrics port<br/>Auth: None"]
            PM_caikit["Caikit Runtime<br/>Dedicated metrics port<br/>Auth: None"]
        end

        subgraph DataPlaneMetrics["Data Plane Metrics"]
            PM_gwie["gateway-api-inference-ext<br/>EPP metrics port<br/>Auth: None<br/>Scheduling decisions, latency"]
            PM_feastdp["Feast Data Plane<br/>Feature store metrics<br/>Auth: None"]
            PM_pipelines["DSP API Server<br/>Port: 8888/TCP<br/>Auth: Bearer Token"]
        end

        subgraph MaaSMetrics["MaaS Metrics"]
            PM_maas["MaaS API<br/>Metrics port<br/>Auth: None"]
            PM_aigw["AI Gateway Payload Proc<br/>Metrics port<br/>Auth: None"]
        end
    end

    subgraph Probes["Health Probes"]
        direction TB

        subgraph ControllerProbes["Controller Health Probes"]
            HP_kserve["KServe Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_llmisvc["llmisvc Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_dashboard["odh-dashboard<br/>L: :8080 healthz<br/>R: :8080 readyz"]
            HP_odmctl["odh-model-controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_kubeflow["Kubeflow Notebook Ctrl<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_kuberay["KubeRay Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_dspo["DS Pipelines Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_trainingop["Training Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_trainer["Kubeflow Trainer<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_feast["Feast Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_mlflow["MLflow Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_trustyai["TrustyAI Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_spark["Spark Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_modelregop["Model Registry Operator<br/>L: :8081 healthz<br/>R: :8081 readyz"]
            HP_maasctrl["MaaS Controller<br/>L: :8081 healthz<br/>R: :8081 readyz"]
        end

        subgraph RuntimeProbes["Runtime Health Probes"]
            HP_vllm["vLLM Pods<br/>R: model loaded check"]
            HP_lmeval["LMEval Pods<br/>Driver API: :18080<br/>Progress polling"]
        end
    end

    subgraph Tracing["Distributed Tracing"]
        direction TB
        TR_otel["OpenTelemetry SDK<br/>OTLP gRPC export"]
        TR_components["Instrumented Components:<br/>KServe, DS Pipelines,<br/>MaaS, Gateway infra"]
    end

    subgraph KEDA["Autoscaling Metrics"]
        direction TB
        KEDA_trigger["KEDA TriggerAuthentication<br/>(per namespace, shared)"]
        KEDA_prom["Prometheus Query:<br/>vLLM REQUEST_COUNT<br/>Custom metrics"]
        KEDA_scaled["ScaledObject per<br/>InferenceService"]
    end

    %% Prometheus scraping
    MonStack -->|"scrapes"| PM_kserve
    MonStack -->|"scrapes"| PM_llmisvc
    MonStack -->|"scrapes"| PM_dashboard
    MonStack -->|"scrapes"| PM_odmctl
    MonStack -->|"scrapes"| PM_kubeflow
    MonStack -->|"scrapes"| PM_kuberay
    MonStack -->|"scrapes"| PM_dspo
    MonStack -->|"scrapes"| PM_trustyai
    MonStack -->|"scrapes"| PM_feast
    MonStack -->|"scrapes"| PM_mlflow
    MonStack -->|"scrapes"| PM_vllm
    MonStack -->|"scrapes"| PM_openvino
    MonStack -->|"scrapes"| PM_mlserver
    MonStack -->|"scrapes"| PM_gwie
    MonStack -->|"scrapes"| PM_pipelines
    MonStack -->|"scrapes"| PM_maas
    MonStack -->|"scrapes"| PM_aigw

    %% Tracing flow
    TR_components -->|"OTLP gRPC"| OTelCollector
    OTelCollector -->|"traces"| TempoBackend

    %% OTel metrics
    OTelCollector -->|"metrics"| MonStack

    %% Perses queries Prometheus
    PersesDash -->|"PromQL queries"| MonStack

    %% KEDA reads Prometheus
    KEDA_trigger -->|"auth token"| MonStack
    KEDA_prom -->|"PromQL"| MonStack
    KEDA_scaled -->|"scales"| PM_vllm

    %% Styling
    classDef prom fill:#e8d5b7,stroke:#b8860b,stroke-width:2px
    classDef probe fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef trace fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef stack fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef keda fill:#fce4ec,stroke:#e57373,stroke-width:2px

    class PM_kserve,PM_llmisvc,PM_dashboard,PM_odmctl,PM_kubeflow,PM_kuberay,PM_dspo,PM_trustyai,PM_feast,PM_mlflow prom
    class PM_vllm,PM_openvino,PM_mlserver,PM_caikit prom
    class PM_gwie,PM_feastdp,PM_pipelines prom
    class PM_maas,PM_aigw prom

    class HP_kserve,HP_llmisvc,HP_dashboard,HP_odmctl,HP_kubeflow,HP_kuberay,HP_dspo,HP_trainingop,HP_trainer,HP_feast,HP_mlflow,HP_trustyai,HP_spark,HP_modelregop,HP_maasctrl probe
    class HP_vllm,HP_lmeval probe

    class TR_otel,TR_components trace
    class OTelCollector,TempoBackend trace

    class MonStack,PersesDash stack

    class KEDA_trigger,KEDA_prom,KEDA_scaled keda
