graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS LAYER"]
        direction TB
        Gateway["Gateway / Ingress Controller<br/>443/TCP<br/>TLS 1.2+<br/>Kuadrant AuthPolicy (OCP)"]
    end

    subgraph Cluster["INTERNAL CLUSTER"]
        direction TB

        subgraph ControlPlane["Control Plane (Namespace: opendatahub)"]
            KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Webhook: 8443/TCP HTTPS<br/>Metrics: 8080/TCP HTTP"]
            LLMISVCCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>Webhook: 9443/TCP HTTPS<br/>Metrics: 8080/TCP HTTP"]
        end

        subgraph ISVCPath["InferenceService Data Path"]
            direction TB
            AuthProxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS (service-serving-cert)<br/>SubjectAccessReview"]
            ModelServer["Model Server Container<br/>8080/TCP HTTP<br/>(TF/PyTorch/Triton/HF)"]
            AgentSidecar["kserve-agent Sidecar<br/>9081/TCP (proxy)<br/>9083/TCP (log)"]
        end

        subgraph LLMPath["LLMInferenceService Data Path"]
            direction TB
            Scheduler["Scheduler / EPP<br/>SA: {llmisvc}-epp-sa<br/>9002/TCP gRPC<br/>TLS (self-signed)"]
            WorkloadPod["Workload Pod (vLLM)<br/>SA: {llmisvc}-kserve-mn<br/>8000/TCP HTTPS<br/>TLS (self-signed/service-ca)<br/>SCC: openshift-ai-llminferenceservice-scc"]
        end

        subgraph WebhookSvcs["Webhook Services"]
            KServeWebhook["kserve-webhook-server-service<br/>443→8443/TCP<br/>TLS (service-serving-cert)<br/>2 mutating + 7 validating"]
            LLMISVCWebhook["llmisvc-webhook-server-service<br/>443→9443/TCP<br/>TLS (service-serving-cert)<br/>4 validating + 1 conversion"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]

        Prometheus["Prometheus<br/>Monitoring"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCS credentials"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Azure identity"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF token (optional)"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry credentials"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer / AuthPolicy"| Gateway

    %% InferenceService path
    Gateway -->|"HTTPS/8443<br/>TLS<br/>SubjectAccessReview"| AuthProxy
    AuthProxy -->|"HTTP/8080<br/>None (localhost)"| ModelServer
    AuthProxy -.->|"via agent"| AgentSidecar

    %% LLMInferenceService path
    Gateway -->|"HTTPRoute→InferencePool<br/>gRPC/9002<br/>TLS (self-signed)"| Scheduler
    Scheduler -->|"HTTPS/8000<br/>TLS (self-signed/service-ca)"| WorkloadPod

    %% Control plane
    KServeCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    LLMISVCCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    KServeCtrl -.-> KServeWebhook
    LLMISVCCtrl -.-> LLMISVCWebhook

    %% Monitoring
    Prometheus -->|"HTTPS/8000<br/>InsecureSkipVerify"| WorkloadPod
    Prometheus -->|"HTTPS/metrics<br/>TLS + Bearer token"| Scheduler
    Prometheus -->|"HTTP/8080<br/>kube-rbac-proxy"| KServeCtrl

    %% Egress (storage-initializer)
    ModelServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Provider creds"| S3
    ModelServer -->|"HTTPS/443"| GCS
    ModelServer -->|"HTTPS/443"| Azure
    ModelServer -->|"HTTPS/443"| HuggingFace
    ModelServer -->|"HTTPS/443"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datapath fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmpath fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef webhook fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:1px

    class Client external
    class Gateway ingress
    class KServeCtrl,LLMISVCCtrl controlplane
    class AuthProxy,ModelServer,AgentSidecar datapath
    class Scheduler,WorkloadPod llmpath
    class KServeWebhook,LLMISVCWebhook webhook
    class K8sAPI controlplane
    class Prometheus monitoring
    class S3,GCS,Azure,HuggingFace,OCI externalservice
