graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client / Data Scientist"]
    end

    subgraph Ingress["INGRESS LAYER"]
        direction TB
        IstioGW["Istio Gateway<br/>443/TCP → 80/TCP<br/>TLS 1.2+ SIMPLE"]
        GatewayAPI["Gateway API Gateway<br/>443/TCP<br/>TLS 1.2+ SIMPLE"]
        VS["VirtualService<br/>{name}.{ns}.{domain}<br/>80/443 TCP"]
        HTTPRoute["HTTPRoute<br/>443/TCP"]
        OSRoute["OpenShift Route<br/>443/TCP Re-encrypt<br/>(InferenceGraph only)"]

        IstioGW --> VS
        GatewayAPI --> HTTPRoute
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: opendatahub)"]
        direction TB

        KServeCtrl["kserve-controller-manager<br/>SA: kserve-controller-manager<br/>Metrics: 8443/TCP HTTPS (kube-rbac-proxy)<br/>Webhook: 9443/TCP HTTPS (OCP serving cert)<br/>Health: 8081/TCP HTTP"]

        LLMIsvcCtrl["llmisvc-controller-manager<br/>SA: llmisvc-controller-manager<br/>Metrics: 8443/TCP HTTPS (kube-rbac-proxy)<br/>Webhook: 9443/TCP HTTPS (OCP serving cert)<br/>Health: 8081/TCP HTTP"]

        WebhookSvc["kserve-webhook-server-service<br/>ClusterIP 443/TCP → 9443<br/>TLS (OpenShift serving cert)"]
        LLMWebhookSvc["llmisvc-webhook-server-service<br/>ClusterIP 443/TCP → 9443<br/>TLS (OpenShift serving cert)"]
    end

    subgraph DataPlane["DATA PLANE (User Namespaces)"]
        direction TB

        subgraph ISVCPod["InferenceService Pod"]
            StorageInit["storage-initializer<br/>(init container)<br/>Cloud credentials"]
            ModelServer["model-server<br/>8080/TCP HTTP"]
            AgentSidecar["inference-agent<br/>9081/TCP HTTP"]
            OAuthProxy["OAuth/kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer → SAR"]
        end

        subgraph LLMISVCPod["LLMInferenceService Pod"]
            LLMWorkload["LLM Workload<br/>8000/TCP HTTPS<br/>TLS (self-signed/CA-signed)"]
            LLMScheduler["Scheduler (EPP)<br/>gRPC/HTTP TLS"]
        end

        subgraph IGPod["InferenceGraph Router"]
            RouterSvc["inference-router<br/>8080/TCP HTTP/HTTPS<br/>Optional Bearer (TokenReview+SAR)"]
        end

        PredSvc["{isvc}-predictor<br/>ClusterIP 80/TCP"]
        LLMSvc["{llmisvc}-kserve-workload-svc<br/>ClusterIP 8000/TCP HTTPS"]
    end

    subgraph PlatformSvc["PLATFORM SERVICES (Internal)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>SA token auth"]
        Knative["Knative Serving<br/>CRD API"]
        Istio["Istio Service Mesh<br/>VirtualService/DestinationRule"]
        KEDA["KEDA<br/>ScaledObject API"]
        Prometheus["Prometheus<br/>9090/TCP HTTPS<br/>Bearer token"]
        OSCA["OpenShift Service CA<br/>signing-key Secret"]
        Kuadrant["Kuadrant<br/>AuthPolicy CRD"]
    end

    subgraph ExtSvc["EXTERNAL SERVICES"]
        S3["AWS S3<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>GCS credentials"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Azure identity"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS TLS 1.2+<br/>HF token"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token (optional)"| IstioGW
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Kuadrant AuthPolicy"| GatewayAPI

    %% Ingress to Data Plane
    VS -->|"HTTP/80<br/>mesh internal"| PredSvc
    HTTPRoute -->|"via InferencePool"| LLMSvc
    OSRoute -->|"HTTPS re-encrypt"| RouterSvc

    %% Data Plane internal
    PredSvc -->|"HTTP/8080"| ModelServer
    OAuthProxy -->|"HTTP/8080<br/>loopback"| ModelServer
    OAuthProxy -->|"HTTPS/6443<br/>SubjectAccessReview"| K8sAPI
    LLMSvc -->|"HTTPS/8000<br/>TLS"| LLMWorkload
    RouterSvc -->|"HTTP/HTTPS<br/>Istio mTLS"| PredSvc

    %% Control Plane to K8s API
    KServeCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    LLMIsvcCtrl -->|"HTTPS/6443<br/>SA token"| K8sAPI
    LLMIsvcCtrl -->|"HTTPS/9090<br/>Bearer token"| Prometheus
    LLMIsvcCtrl -->|"Secret read"| OSCA

    %% Storage initialization
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials"| S3
    StorageInit -->|"HTTPS/443"| GCS
    StorageInit -->|"HTTPS/443"| Azure
    StorageInit -->|"HTTPS/443"| HF

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class IstioGW,GatewayAPI,VS,HTTPRoute,OSRoute ingress
    class KServeCtrl,LLMIsvcCtrl,WebhookSvc,LLMWebhookSvc controlplane
    class StorageInit,ModelServer,AgentSidecar,OAuthProxy,LLMWorkload,LLMScheduler,RouterSvc,PredSvc,LLMSvc dataplane
    class K8sAPI,Knative,Istio,KEDA,Prometheus,OSCA,Kuadrant platform
    class S3,GCS,Azure,HF externalservice
