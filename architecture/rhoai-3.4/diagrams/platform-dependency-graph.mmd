graph TB
    subgraph OperatorTier["Operator Tier (redhat-ods-operator)"]
        rhods["rhods-operator<br/>Platform Orchestrator<br/>194 watches"]
    end

    subgraph PlatformTier["Platform Tier (redhat-ods-applications)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            KServe["KServe<br/>kserve-controller-manager<br/>InferenceService"]
            LLMISVC["KServe<br/>llmisvc-controller-manager<br/>LLMInferenceService"]
            ODHModelCtrl["odh-model-controller<br/>Routes, HTTPRoutes,<br/>AuthPolicies, KEDA"]
        end

        subgraph UILayer["User Interface"]
            Dashboard["odh-dashboard<br/>Module Federation + 7 BFF sidecars"]
        end

        subgraph MLLifecycle["ML Lifecycle"]
            DSPO["Data Science Pipelines<br/>Operator (DSPO)"]
            DSP["Data Science Pipelines<br/>API Server + Argo"]
            ModelReg["Model Registry<br/>Operator + Service"]
            MLflow["MLflow Operator<br/>Tracking Server"]
            TrustyAI["trustyai-service-operator<br/>TAS, LMES, GORCH,<br/>NeMo, EvalHub"]
        end

        subgraph TrainingStack["Training & Compute"]
            KFTO["Training Operator<br/>(KFTO)"]
            KubeRay["KubeRay Operator"]
            Spark["Spark Operator"]
            KFNotebooks["Kubeflow Notebook<br/>Controllers"]
        end

        subgraph FeatureStore["Feature Management"]
            Feast["Feast Operator<br/>+ FeatureStore"]
        end

        subgraph LLMStack["LLM Serving Stack"]
            GAIE["Gateway API<br/>Inference Extension (EPP)"]
            WVA["Workload Variant<br/>Autoscaler"]
            MaaS["Models as a Service<br/>(MaaS)"]
            BatchGW["Batch Gateway"]
            LlamaStack["LlamaStack<br/>K8s Operator"]
            Guardrails["FMS Guardrails<br/>Orchestrator"]
            VLLMOrchGW["vllm-orchestrator<br/>-gateway"]
            AIGateway["AI Gateway<br/>Payload Processing"]
        end

        subgraph IngressAuth["Ingress & Auth"]
            Gateway["data-science-gateway<br/>Envoy data plane"]
            KubeAuthProxy["kube-auth-proxy<br/>OIDC + OAuth + RBAC"]
        end
    end

    subgraph ExternalDeps["External Platform Dependencies"]
        Istio["Istio<br/>Service Mesh"]
        Knative["Knative Serving<br/>Serverless"]
        OLM["OLM<br/>Operator Lifecycle"]
        ServiceCA["OpenShift service-ca<br/>Certificate Mgmt"]
        Kuadrant["Kuadrant<br/>AuthPolicy"]
    end

    subgraph RuntimeDeps["Runtime Dependencies"]
        S3["S3 / MinIO<br/>Object Storage"]
        ContainerReg["Container Registry<br/>registry.redhat.io"]
        MLMD["ML Metadata<br/>(MLMD)"]
    end

    %% rhods-operator deploys everything
    rhods -->|deploys| KServe
    rhods -->|deploys| LLMISVC
    rhods -->|deploys| ODHModelCtrl
    rhods -->|deploys| Dashboard
    rhods -->|deploys| DSPO
    rhods -->|deploys| ModelReg
    rhods -->|deploys| MLflow
    rhods -->|deploys| TrustyAI
    rhods -->|deploys| KFTO
    rhods -->|deploys| KubeRay
    rhods -->|deploys| Spark
    rhods -->|deploys| KFNotebooks
    rhods -->|deploys| Feast
    rhods -->|deploys| MaaS
    rhods -->|deploys| LlamaStack
    rhods -->|deploys| WVA
    rhods -->|deploys| Gateway
    rhods -->|deploys| KubeAuthProxy

    %% KServe integration hub
    LLMISVC -->|creates InferencePool| GAIE
    LLMISVC -->|creates ScaledObject| WVA
    ODHModelCtrl -->|creates HTTPRoute| Gateway
    ODHModelCtrl -->|creates AuthPolicy| Kuadrant
    ODHModelCtrl -->|creates EnvoyFilter| Istio
    KServe -->|serverless mode| Knative
    KServe -->|traffic mgmt| Istio

    %% Dashboard integrations
    Dashboard -->|Pipeline CRUD| DSP
    Dashboard -->|model metadata| ModelReg
    Dashboard -->|experiment tracking| MLflow
    Dashboard -->|AI inference, RAG| LlamaStack
    Dashboard -->|bias metrics| TrustyAI

    %% Pipeline flow
    DSPO -->|deploys| DSP
    DSP -->|artifact metadata| MLMD
    MLMD -->|model versions| ModelReg
    ModelReg -->|serving refs| KServe

    %% TrustyAI integrations
    TrustyAI -->|patches InferenceServices| KServe
    TrustyAI -->|EvalHub RoleBindings| MLflow

    %% LLM stack integrations
    GAIE -->|ext-proc routing| Gateway
    MaaS -->|AuthPolicy| Kuadrant
    MaaS -->|DestinationRules| Istio
    Guardrails -->|wraps model endpoint| KServe
    VLLMOrchGW -->|content filtering| KServe
    AIGateway -->|ext-proc payload| Gateway
    BatchGW -->|batch inference| KServe

    %% Feast integration
    Feast -->|client config| KFNotebooks

    %% Auth flow
    Gateway -->|auth delegation| KubeAuthProxy

    %% External deps
    KServe -->|model artifacts| S3
    ModelReg -->|artifact storage| S3
    DSP -->|pipeline artifacts| S3
    rhods -->|managed by| OLM
    Dashboard -->|TLS certs| ServiceCA
    DSP -->|TLS certs| ServiceCA
    ModelReg -->|TLS certs| ServiceCA

