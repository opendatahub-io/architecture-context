graph TB
    subgraph MetaOperator["Meta-Operator Tier"]
        rhods["rhods-operator<br/>(Meta-Operator)<br/>104 CRDs, 122 images"]
    end

    subgraph CorePlatform["Core Platform Services"]
        dashboard["odh-dashboard<br/>UI + BFF<br/>Module Federation"]
        kubeflow["Kubeflow Notebook<br/>Controller"]
        odmctl["odh-model-controller<br/>Route/Monitor Bridge"]
        kubeauthproxy["kube-auth-proxy<br/>OAuth2/OIDC Gateway"]
    end

    subgraph Serving["Model Serving"]
        kserve["KServe<br/>(kserve-controller-manager)"]
        llmisvc["KServe<br/>(llmisvc-controller-manager)"]
        vllm["vLLM Runtime"]
        openvino["OpenVINO Runtime"]
        mlserver["MLServer Runtime"]
        caikit["Caikit Runtime"]
        gwie["gateway-api-inference<br/>-extension (EPP)"]
    end

    subgraph Training["Model Training"]
        trainingop["Training Operator<br/>(v1: PyTorchJob, TFJob...)"]
        trainer["Kubeflow Trainer<br/>(v2: TrainJob)"]
        kuberay["KubeRay Operator"]
        spark["Spark Operator"]
    end

    subgraph MLOps["MLOps & Registry"]
        dspo["Data Science Pipelines<br/>Operator (DSPO)"]
        modelreg["Model Registry"]
        modelregop["Model Registry<br/>Operator"]
        mlflow["MLflow Operator"]
        feast["Feast Operator"]
    end

    subgraph Evaluation["Evaluation & Guardrails"]
        trustyai["TrustyAI Service<br/>Operator"]
        guardrails["FMS Guardrails<br/>Orchestrator"]
        lmeval["LMEval"]
        evalhub["EvalHub"]
    end

    subgraph MaaSStack["Models as a Service"]
        maasctrl["MaaS Controller"]
        maasapi["MaaS API"]
        aigw["AI Gateway Payload<br/>Processing (BBR)"]
        authorino["Kuadrant / Authorino"]
    end

    subgraph ExternalPlatform["External Platform Dependencies"]
        envoy["Envoy Proxy<br/>(Gateway API)"]
        istio["Istio<br/>(Legacy Serverless)"]
        knative["Knative Serving<br/>(Legacy Serverless)"]
        argo["Argo Workflows"]
        ocp["OpenShift API"]
    end

    subgraph UserWorkloads["User Workloads"]
        notebooks["Notebook Pods"]
        rayclusters["RayCluster Pods"]
        trainjobs["Training Job Pods"]
        isvc["InferenceService Pods"]
    end

    %% rhods-operator deploys everything
    rhods -->|deploys| dashboard
    rhods -->|deploys| kubeflow
    rhods -->|deploys| odmctl
    rhods -->|deploys| kserve
    rhods -->|deploys| llmisvc
    rhods -->|deploys| dspo
    rhods -->|deploys| modelreg
    rhods -->|deploys| kuberay
    rhods -->|deploys| trainingop
    rhods -->|deploys| trainer
    rhods -->|deploys| spark
    rhods -->|deploys| feast
    rhods -->|deploys| mlflow
    rhods -->|deploys| maasctrl
    rhods -->|deploys| trustyai
    rhods -->|deploys| kubeauthproxy

    %% Dashboard integrations (17 outgoing)
    dashboard -->|manages notebooks| kubeflow
    dashboard -->|model serving UI| kserve
    dashboard -->|pipeline mgmt| dspo
    dashboard -->|model catalog| modelreg
    dashboard -->|experiment tracking| mlflow
    dashboard -->|feature store UI| feast
    dashboard -->|model evaluation| trustyai
    dashboard -->|multi-provider models| maasctrl
    dashboard -->|presents images| notebooks

    %% KServe ecosystem
    kserve -->|creates runtimes| vllm
    kserve -->|creates runtimes| openvino
    kserve -->|creates runtimes| mlserver
    kserve -->|creates runtimes| caikit
    llmisvc -->|creates LLM pools| vllm
    llmisvc -->|creates InferencePool| gwie
    odmctl -->|creates HTTPRoutes| envoy
    odmctl -->|creates ServiceMonitors| kserve
    odmctl -->|KEDA autoscaling| isvc
    gwie -->|ext_proc routing| envoy
    kserve -->|serverless mode| knative
    kserve -->|serverless mTLS| istio
    kserve -->|model metadata| modelreg

    %% Pipeline ecosystem
    dspo -->|executes workflows| argo
    notebooks -->|submit pipelines| dspo

    %% Training ecosystem
    kuberay -->|manages| rayclusters
    trainingop -->|manages| trainjobs
    trainer -->|manages| trainjobs

    %% MaaS ecosystem
    maasctrl -->|deploys| maasapi
    maasctrl -->|deploys| aigw
    maasctrl -->|auth policies| authorino
    aigw -->|API translation| envoy
    maasapi -->|model routing| kserve

    %% Evaluation ecosystem
    trustyai -->|evaluates models| kserve
    trustyai -->|logs results| mlflow
    guardrails -->|intercepts inference| isvc

    %% Kubeflow manages notebooks
    kubeflow -->|creates StatefulSets| notebooks
    kubeflow -->|HTTPRoutes via| envoy

    %% Auth flow
    envoy -->|ext_authz| kubeauthproxy

    %% External API
    rhods -->|watches CRDs| ocp
    dashboard -->|API calls| ocp
    kubeflow -->|API calls| ocp

