graph TB
    subgraph DSPO["Data Science Pipelines Operator"]
        Controller["DSPAReconciler<br/>(controller-runtime)"]
        Webhook["Admission Webhook Server<br/>443/TCP HTTPS"]
        Metrics["Metrics Server<br/>8080/TCP HTTP"]
        ManagedPipelines["Managed Pipelines<br/>Fetcher & Validator"]
        Manifestival["Manifestival<br/>Template Renderer"]

        Controller -->|validates/mutates| Webhook
        Controller -->|exposes| Metrics
        Controller -->|fetches OCI images| ManagedPipelines
        Controller -->|renders templates| Manifestival
    end

    %% CRDs Watched
    DSPACR["DSPA CR<br/>datasciencepipelinesapplications.opendatahub.io"]
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org"]

    DSPACR -->|watched by| Controller
    PipelineCR -->|managed by| Controller
    PipelineVersionCR -->|validated by| Webhook

    %% Deployed Sub-Components
    subgraph DeployedStack["Deployed DSP Stack (per DSPA)"]
        APIServer["ds-pipeline API Server<br/>8888/TCP, 8887/TCP gRPC<br/>+ kube-rbac-proxy 8443/TCP"]
        PersistenceAgent["Persistence Agent"]
        ScheduledWorkflow["Scheduled Workflow<br/>Controller"]
        ArgoController["Argo Workflows<br/>Controller"]
        MLMDgRPC["MLMD gRPC Server<br/>8080/TCP"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP<br/>+ kube-rbac-proxy 8443/TCP"]
        MariaDB["MariaDB<br/>3306/TCP"]
        Minio["Minio Object Storage<br/>9000/TCP"]
    end

    Controller -->|deploys & manages| DeployedStack

    APIServer -->|queries| MariaDB
    APIServer -->|stores artifacts| Minio
    APIServer -->|metadata| MLMDgRPC
    MLMDgRPC -->|queries| MariaDB
    MLMDEnvoy -->|proxies| MLMDgRPC
    PersistenceAgent -->|reads| APIServer
    ScheduledWorkflow -->|triggers| ArgoController
    ArgoController -->|executes| WorkflowCR["Argo Workflow CRs"]

    %% External Access
    Route1["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP Reencrypt"]
    Route2["OpenShift Route<br/>ds-pipeline-md-{name}<br/>443/TCP Reencrypt"]

    Route1 -->|proxies to| APIServer
    Route2 -->|proxies to| MLMDEnvoy

    %% Platform Dependencies
    ServiceCA["OpenShift service-ca"]
    CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    ServiceCA -.->|provisions TLS certs| DeployedStack
    CABundle -.->|CA trust| Controller

    %% External Dependencies
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    Controller -->|CRUD resources| K8sAPI

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style ManagedPipelines fill:#4a90e2,stroke:#333,color:#fff
    style Manifestival fill:#4a90e2,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333,color:#fff
    style PipelineCR fill:#f5a623,stroke:#333,color:#fff
    style PipelineVersionCR fill:#f5a623,stroke:#333,color:#fff
    style APIServer fill:#7ed321,stroke:#333,color:#fff
    style PersistenceAgent fill:#7ed321,stroke:#333,color:#fff
    style ScheduledWorkflow fill:#7ed321,stroke:#333,color:#fff
    style ArgoController fill:#7ed321,stroke:#333,color:#fff
    style MLMDgRPC fill:#7ed321,stroke:#333,color:#fff
    style MLMDEnvoy fill:#7ed321,stroke:#333,color:#fff
    style MariaDB fill:#7ed321,stroke:#333,color:#fff
    style Minio fill:#7ed321,stroke:#333,color:#fff
    style Route1 fill:#e8e8e8,stroke:#333
    style Route2 fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
    style CABundle fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
