graph TB
    subgraph DSPO["Data Science Pipelines Operator"]
        Controller["DSPO Controller Manager<br/>(Go, controller-runtime)"]
        Webhook["Pipeline Versions Webhook<br/>8443/TCP HTTPS"]
        Controller -->|deploys globally| Webhook
    end

    subgraph DSPAInstance["DSPA Instance (per namespace)"]
        APIServer["DS Pipeline API Server<br/>8888/TCP HTTP, 8887/TCP gRPC<br/>8443/TCP HTTPS (kube-rbac-proxy)"]
        PersistenceAgent["Persistence Agent"]
        ScheduledWF["Scheduled Workflow<br/>Controller"]
        ArgoWFC["Argo Workflow<br/>Controller"]
        MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP gRPC-Web"]

        subgraph OptionalStorage["Optional Embedded Storage"]
            MariaDB["MariaDB<br/>3306/TCP MySQL"]
            MinIO["MinIO<br/>9000/TCP S3"]
        end

        PersistenceAgent -->|tracks workflow state| APIServer
        ScheduledWF -->|creates scheduled runs| APIServer
        ArgoWFC -->|executes pipelines| LauncherDriver["KFP Launcher/Driver Pods"]
        APIServer -->|stores metadata| MariaDB
        APIServer -->|stores artifacts| MinIO
        APIServer -->|creates| WorkflowCR["Workflow CR"]
        ArgoWFC -->|watches| WorkflowCR
        MLMDgRPC -->|stores lineage| MariaDB
        MLMDEnvoy -->|proxies| MLMDgRPC
    end

    %% CRDs
    User["User / Dashboard"] -->|creates| DSPACR["DSPA CR"]
    DSPACR -->|watched by| Controller
    Controller -->|reconciles all| DSPAInstance

    User -->|submits pipelines| APIServer

    %% Webhook targets
    PipelineVersionCR["PipelineVersion CR"] -->|validated/mutated by| Webhook

    %% External interactions
    Controller -->|health check| ExtDB["External MySQL DB"]
    Controller -->|health check| ExtS3["External S3 Storage"]
    Controller -->|fetches managed pipelines| OCIRegistry["OCI Container Registry"]

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style APIServer fill:#50b5e9,stroke:#333,color:#fff
    style PersistenceAgent fill:#50b5e9,stroke:#333,color:#fff
    style ScheduledWF fill:#50b5e9,stroke:#333,color:#fff
    style ArgoWFC fill:#50b5e9,stroke:#333,color:#fff
    style MLMDgRPC fill:#50b5e9,stroke:#333,color:#fff
    style MLMDEnvoy fill:#50b5e9,stroke:#333,color:#fff
    style MariaDB fill:#9b59b6,stroke:#333,color:#fff
    style MinIO fill:#9b59b6,stroke:#333,color:#fff
    style DSPACR fill:#f5a623,stroke:#333,color:#fff
    style PipelineVersionCR fill:#f5a623,stroke:#333,color:#fff
    style WorkflowCR fill:#f5a623,stroke:#333,color:#fff
    style ExtDB fill:#e8e8e8,stroke:#333
    style ExtS3 fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style User fill:#7ed321,stroke:#333,color:#fff
