graph TD
    subgraph "Component RBAC Model"
        direction TB
        Note["NOTE: This component defines NO RBAC resources.<br/>It runs within the Llama Stack server pod and<br/>relies on external identity and credentials."]
    end

    subgraph "Runtime Identity: Llama Stack Server Pod"
        SA["ServiceAccount<br/>(Llama Stack Operator managed)"]
    end

    subgraph "Credential Sources"
        Secret1["Secret: kubeflow-pipelines-token<br/>Type: Opaque<br/>Provisioned: Manual (oc whoami -t)<br/>Auto-Rotate: No"]
        Secret2["Secret: llama-stack-inference-model-secret<br/>Type: Opaque<br/>Contents: vLLM URL, API token, TLS settings<br/>Provisioned: Manual"]
        Secret3["Secret: aws-credentials<br/>Type: Opaque<br/>Contents: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION<br/>Provisioned: Manual"]
        Secret4["Secret: S3 credentials (KFP steps)<br/>Type: Opaque<br/>Mounted via: kubernetes.use_secret_as_env<br/>Provisioned: Manual"]
    end

    subgraph "Access Targets"
        K8sAPI["Kubernetes API<br/>GET ConfigMaps<br/>Namespace: redhat-ods-applications<br/>Resource: trustyai-service-operator-config"]
        KFPAPI["Kubeflow Pipelines API<br/>POST /apis/v2beta1/runs<br/>GET /apis/v2beta1/runs/{id}<br/>POST /apis/v2beta1/runs/{id}:cancel"]
        S3["S3 Storage<br/>PUT objects (write results)<br/>GET objects (read results)<br/>Prefix: configured S3 prefix"]
        InferenceBackend["Ollama / vLLM<br/>POST /v1/completions<br/>POST /v1/embeddings"]
    end

    SA -->|"ServiceAccount token<br/>HTTPS/6443"| K8sAPI
    Secret1 -->|"Bearer Token<br/>HTTPS"| KFPAPI
    Secret3 -->|"AWS IAM credentials<br/>HTTPS/443"| S3
    Secret4 -->|"AWS IAM credentials<br/>(mounted in KFP pods)"| S3
    Secret2 -->|"API Token<br/>HTTP/HTTPS"| InferenceBackend

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,color:#fff
    style Secret1 fill:#f8cecc,stroke:#b85450
    style Secret2 fill:#f8cecc,stroke:#b85450
    style Secret3 fill:#f8cecc,stroke:#b85450
    style Secret4 fill:#f8cecc,stroke:#b85450
    style K8sAPI fill:#7ed321,color:#fff
    style KFPAPI fill:#7ed321,color:#fff
    style S3 fill:#f5a623,color:#fff
    style InferenceBackend fill:#f5a623,color:#fff
