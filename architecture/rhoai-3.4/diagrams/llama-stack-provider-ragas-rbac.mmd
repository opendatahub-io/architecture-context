graph TD
    subgraph "llama-stack-provider-ragas RBAC"
        Note["This component defines NO ClusterRoles,<br/>Roles, or RoleBindings.<br/><br/>RBAC is managed by:"]
    end

    subgraph "Delegated RBAC Management"
        LlamaStackOp["Llama Stack Operator<br/>(manages distribution SA<br/>and RBAC for provider pods)"]
        DSPOp["Data Science Pipelines Operator<br/>(manages RBAC for<br/>KFP pipeline execution)"]
    end

    subgraph "Secrets Used (User-Provisioned)"
        direction TB
        S1["kubeflow-pipelines-token<br/>Type: Opaque<br/>Purpose: Bearer token for KFP API<br/>Provisioned: Manual (oc whoami -t)<br/>⚠️ No auto-rotation, limited TTL"]
        S2["aws-credentials<br/>Type: Opaque<br/>Purpose: AWS IAM for S3 storage<br/>Provisioned: Manual<br/>⚠️ No auto-rotation"]
        S3["llama-stack-inference-model-secret<br/>Type: Opaque<br/>Purpose: Model name, vLLM URL,<br/>TLS verify flag, API token<br/>Provisioned: Manual<br/>⚠️ No auto-rotation"]
        S4["KUBEFLOW_S3_CREDENTIALS_SECRET_NAME<br/>Type: Opaque<br/>Purpose: AWS creds mounted<br/>as env vars in KFP pods<br/>Provisioned: Manual<br/>⚠️ No auto-rotation"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        A1["Kubeflow Pipelines API<br/>Methods: POST, GET<br/>Auth: Bearer Token<br/>Enforcement: KFP server<br/>Policy: Pipeline run creation perms"]
        A2["S3 Storage<br/>Methods: PUT, GET<br/>Auth: AWS IAM credentials<br/>Enforcement: S3/MinIO server<br/>Policy: Write access to S3 prefix"]
        A3["Llama Stack API (remote)<br/>Methods: POST<br/>Auth: None (network-level)<br/>Enforcement: Network access<br/>Policy: Accessible from KFP pods"]
    end

    Note -->|delegates to| LlamaStackOp
    Note -->|delegates to| DSPOp

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#000
    style LlamaStackOp fill:#7ed321,stroke:#333,color:#000
    style DSPOp fill:#7ed321,stroke:#333,color:#000
    style S1 fill:#fde8e8,stroke:#e53e3e,color:#000
    style S2 fill:#fde8e8,stroke:#e53e3e,color:#000
    style S3 fill:#fde8e8,stroke:#e53e3e,color:#000
    style S4 fill:#fde8e8,stroke:#e53e3e,color:#000
    style A1 fill:#dbeafe,stroke:#3b82f6,color:#000
    style A2 fill:#dbeafe,stroke:#3b82f6,color:#000
    style A3 fill:#dbeafe,stroke:#3b82f6,color:#000
