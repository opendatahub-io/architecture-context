graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["controller-manager<br/>Namespace: workload-variant-autoscaler-system"]
    end

    subgraph ClusterBindings["Cluster Role Bindings"]
        CRB["manager-rolebinding<br/>(cluster-wide)"]
    end

    subgraph NamespacedBindings["Namespaced Role Bindings"]
        LRB["leader-election-rolebinding<br/>Namespace: system"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["manager-role"]
    end

    subgraph NamespacedRoles["Namespaced Roles"]
        LR["leader-election-role<br/>Namespace: system"]
    end

    SA -->|bound via| CRB
    SA -->|bound via| LRB
    CRB -->|grants| CR
    LRB -->|grants| LR

    subgraph CoreResources["Core API Resources ('')"]
        ConfigMaps["configmaps<br/>get, list, update, watch"]
        ConfigMapsStatus["configmaps/status<br/>get"]
        Events["events<br/>create, patch"]
        NSPodsSecretsSvcs["namespaces, pods,<br/>secrets, services<br/>get, list, watch"]
        Nodes["nodes, nodes/status<br/>get, list, patch,<br/>update, watch"]
    end

    subgraph AppsResources["Apps API Resources"]
        Deployments["deployments<br/>get, list, patch,<br/>update, watch"]
        DeploymentsScale["deployments/scale<br/>get, update"]
        RSandSTS["replicasets, statefulsets<br/>get, list, watch"]
    end

    subgraph InferenceResources["Inference API Resources"]
        InferencePools["inferencepools<br/>(inference.networking.k8s.io +<br/>inference.networking.x-k8s.io)<br/>get, list, watch"]
    end

    subgraph LWSResources["LeaderWorkerSet Resources"]
        LWSets["leaderworkersets<br/>get, list, patch,<br/>update, watch"]
        LWSScale["leaderworkersets/scale<br/>get, update"]
    end

    subgraph LLMDResources["llmd.ai Resources"]
        VAs["variantautoscalings<br/>create, delete, get, list,<br/>patch, update, watch"]
        VAStatus["variantautoscalings/status<br/>get, patch, update"]
        VAFinalizers["variantautoscalings/finalizers<br/>update"]
    end

    subgraph MonitoringResources["Monitoring Resources"]
        SvcMonitors["servicemonitors<br/>(monitoring.coreos.com)<br/>get, list, watch"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        LEConfigMaps["configmaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        LELeases["leases<br/>(coordination.k8s.io)<br/>get, list, watch, create,<br/>update, patch, delete"]
        LEEvents["events<br/>create, patch"]
    end

    %% manager-role grants
    CR -->|core| ConfigMaps
    CR -->|core| ConfigMapsStatus
    CR -->|core| Events
    CR -->|core| NSPodsSecretsSvcs
    CR -->|core| Nodes
    CR -->|apps| Deployments
    CR -->|apps| DeploymentsScale
    CR -->|apps| RSandSTS
    CR -->|inference| InferencePools
    CR -->|lws| LWSets
    CR -->|lws| LWSScale
    CR -->|llmd.ai| VAs
    CR -->|llmd.ai| VAStatus
    CR -->|llmd.ai| VAFinalizers
    CR -->|monitoring| SvcMonitors

    %% leader-election-role grants
    LR -->|core| LEConfigMaps
    LR -->|coordination| LELeases
    LR -->|core| LEEvents

    %% Styling
    style SA fill:#4a90e2,stroke:#2c5f8a,color:#fff
    style CRB fill:#5dade2,stroke:#2e86c1,color:#fff
    style LRB fill:#5dade2,stroke:#2e86c1,color:#fff
    style CR fill:#f5a623,stroke:#d4891c,color:#fff
    style LR fill:#f5a623,stroke:#d4891c,color:#fff

    style VAs fill:#7ed321,stroke:#5ba318,color:#fff
    style VAStatus fill:#7ed321,stroke:#5ba318,color:#fff
    style VAFinalizers fill:#7ed321,stroke:#5ba318,color:#fff

    style Deployments fill:#85c1e9,stroke:#2e86c1
    style DeploymentsScale fill:#85c1e9,stroke:#2e86c1
    style RSandSTS fill:#85c1e9,stroke:#2e86c1

    style InferencePools fill:#bb8fce,stroke:#7d3c98
    style LWSets fill:#bb8fce,stroke:#7d3c98
    style LWSScale fill:#bb8fce,stroke:#7d3c98

    style ConfigMaps fill:#abebc6,stroke:#27ae60
    style ConfigMapsStatus fill:#abebc6,stroke:#27ae60
    style Events fill:#abebc6,stroke:#27ae60
    style NSPodsSecretsSvcs fill:#abebc6,stroke:#27ae60
    style Nodes fill:#abebc6,stroke:#27ae60
    style SvcMonitors fill:#abebc6,stroke:#27ae60

    style LEConfigMaps fill:#f9e79f,stroke:#f1c40f
    style LELeases fill:#f9e79f,stroke:#f1c40f
    style LEEvents fill:#f9e79f,stroke:#f1c40f
