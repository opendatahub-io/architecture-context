graph LR
    VllmGaudi["vllm-gaudi<br/>HPU Plugin +<br/>Container Image"]

    %% Core External Dependencies (Required)
    VllmGaudi -->|"plugin architecture<br/>v0.14.1"| VLLM["vLLM<br/>(upstream)"]
    VllmGaudi -->|"HPU drivers/compiler<br/>v1.23.0"| SynapseAI["Intel Gaudi<br/>Software<br/>(Synapse AI)"]
    VllmGaudi -->|"HPU backend<br/>v2.9.0"| PyTorch["PyTorch<br/>for Gaudi"]
    VllmGaudi -->|"HPU kernels<br/>FusedSDPA, RMSNorm<br/>HCCL"| Habana["habana_frameworks<br/>v1.23.0"]

    %% Runtime Dependencies
    VllmGaudi -->|"distributed workers<br/>>= 2.48.0"| Ray["Ray"]
    VllmGaudi -->|"model loading<br/>>= 4.56.0"| Transformers["HuggingFace<br/>transformers"]
    VllmGaudi -->|"data processing"| Pandas["pandas"]
    VllmGaudi -->|"JIT compilation"| Numba["numba"]
    VllmGaudi -->|"array ops"| NumPy["numpy"]

    %% Base Image
    VllmGaudi -->|"base image"| UBI["UBI 9.6<br/>(Red Hat)"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe /<br/>ServingRuntime"] -->|"references as<br/>container image"| VllmGaudi
    KubeRBACProxy["kube-rbac-proxy"] -->|"sidecar injection<br/>8443→8000"| VllmGaudi

    %% External Service Dependencies
    VllmGaudi -->|"model weights<br/>filesystem/HTTPS"| ModelStorage["Model Storage<br/>(PVC / S3)"]
    VllmGaudi -->|"tokenizer download<br/>HTTPS/443"| HFHub["HuggingFace<br/>Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"scrape /metrics<br/>HTTP/8000"| VllmGaudi

    %% Inter-node Communication
    VllmGaudi -->|"tensor parallelism<br/>HCCL/TCP"| HCCL["HCCL<br/>(inter-HPU)"]
    VllmGaudi -->|"KV cache transfer<br/>RDMA/TCP"| NIXL["NIXL<br/>(disaggregated<br/>prefill)"]

