graph LR
    VllmGaudi["vllm-gaudi<br/>(Gaudi HPU Plugin)"]

    %% Core Runtime Dependencies
    VllmGaudi -->|"plugin registration<br/>(entry_points)"| VllmCore["vLLM Core<br/>v0.14.1"]
    VllmGaudi -->|"HPU backend<br/>(torch.compile)"| PyTorchHPU["PyTorch HPU<br/>v2.9.0"]
    VllmGaudi -->|"device drivers<br/>(habana_frameworks)"| SynapseAI["Intel Gaudi<br/>Synapse AI 1.23.0"]

    %% ML Dependencies
    VllmGaudi -->|"model loading<br/>(tokenizer, config)"| Transformers["HuggingFace<br/>Transformers ≥4.56"]
    VllmGaudi -->|"FP8 calibration"| INC["Intel Neural<br/>Compressor"]
    VllmGaudi -->|"media processing"| HabanaMedia["habana-media-<br/>loader 1.23.0"]

    %% Distributed Dependencies
    VllmGaudi -->|"multi-worker<br/>orchestration"| Ray["Ray ≥2.48.0"]
    VllmGaudi -->|"tensor parallel<br/>(all-reduce, all-gather)"| HCCL["HCCL<br/>(Habana CCL)"]
    VllmGaudi -->|"multi-node<br/>KV cache transfer"| NIXL["NIXL<br/>(RDMA/TCP)"]

    %% Utility Dependencies
    VllmGaudi -->|"data processing"| Pandas["pandas ≥2.2.3"]
    VllmGaudi -->|"JIT compilation"| Numba["numba ≥0.58.0"]
    VllmGaudi -->|"array ops"| NumPy["numpy ≥1.26.0"]

    %% Container Base
    VllmGaudi -->|"container base"| UBI9["UBI 9.6"]

    %% Internal RHOAI Platform Dependencies
    KServe["KServe<br/>InferenceService"] -->|"deploys as<br/>predictor container"| VllmGaudi
    ServingRuntime["ServingRuntime CR<br/>(Model Mesh)"] -->|"references<br/>container image"| VllmGaudi
    Operator["rhods-operator /<br/>odh-operator"] -->|"manages<br/>ServingRuntime lifecycle"| ServingRuntime

    %% External Services
    VllmGaudi -->|"model weight<br/>loading"| ModelStorage["Model Storage<br/>(PVC / S3)"]
    VllmGaudi -.->|"optional<br/>KV sharing"| LMCache["LMCache"]

    %% Styling
    style VllmGaudi fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime (required, tightly coupled)
    style VllmCore fill:#b3d7ff,stroke:#6c8ebf,stroke-width:2px
    style PyTorchHPU fill:#b3d7ff,stroke:#6c8ebf,stroke-width:2px
    style SynapseAI fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    %% ML dependencies
    style Transformers fill:#e8e8e8,stroke:#666
    style INC fill:#e8e8e8,stroke:#666
    style HabanaMedia fill:#e8e8e8,stroke:#666

    %% Distributed
    style Ray fill:#e8e8e8,stroke:#666
    style HCCL fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NIXL fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    %% Utility
    style Pandas fill:#f5f5f5,stroke:#999
    style Numba fill:#f5f5f5,stroke:#999
    style NumPy fill:#f5f5f5,stroke:#999

    %% Container
    style UBI9 fill:#cc0000,stroke:#990000,color:#fff

    %% Internal RHOAI
    style KServe fill:#6c8ebf,stroke:#333,color:#fff
    style ServingRuntime fill:#6c8ebf,stroke:#333,color:#fff
    style Operator fill:#6c8ebf,stroke:#333,color:#fff

    %% External services
    style ModelStorage fill:#f5a623,stroke:#333
    style LMCache fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5
