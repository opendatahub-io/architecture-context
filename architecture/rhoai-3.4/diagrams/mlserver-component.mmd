graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Servers["Protocol Servers"]
            REST["REST Server<br/>(FastAPI/uvicorn)<br/>8080/TCP HTTP"]
            GRPC["gRPC Server<br/>(grpc.aio)<br/>8081/TCP gRPC"]
            Kafka["Kafka Server<br/>(aiokafka)<br/>9092/TCP"]
            Metrics["Metrics Server<br/>(Prometheus)<br/>8082/TCP HTTP"]
        end

        subgraph Core["Data Plane & Core"]
            DataPlane["DataPlane Handler<br/>Inference routing, caching,<br/>CloudEvents injection"]
            Batcher["Adaptive Batcher<br/>Queue-based request merging"]
            Cache["Response Cache<br/>In-memory FIFO"]
            Codecs["Codec System<br/>numpy, pandas, string,<br/>base64, datetime, JSON"]
        end

        subgraph RuntimePlugins["Runtime Plugin System"]
            direction LR
            SKLearn["scikit-learn<br/>Runtime"]
            XGBoost["XGBoost<br/>Runtime"]
            LightGBM["LightGBM<br/>Runtime"]
            ONNX["ONNX<br/>Runtime"]
            HuggingFace["HuggingFace<br/>Runtime"]
            MLflow["MLflow<br/>Runtime"]
            CatBoost["CatBoost<br/>Runtime"]
            AlibiDetect["Alibi Detect<br/>Runtime"]
            AlibiExplain["Alibi Explain<br/>Runtime"]
            MLlib["Spark MLlib<br/>Runtime"]
        end

        subgraph Parallel["Parallel Inference"]
            ParallelModel["ParallelModel Proxy"]
            Dispatcher["Dispatcher<br/>(round-robin)"]
            Workers["Worker Processes<br/>(multiprocessing.Queue)"]
        end

        ModelRepo["Model Repository<br/>File-based discovery<br/>(model-settings.json)"]
        TrustedRuntimes["Trusted Runtimes<br/>(/etc/mlserver/trusted-runtimes.json)<br/>Production mode allowlist"]
    end

    %% Client connections
    Client[External Client] -->|"POST /v2/models/{name}/infer"| REST
    Client -->|"gRPC ModelInfer"| GRPC
    KafkaBroker[Kafka Broker] -->|"Messages"| Kafka

    %% Internal flow
    REST --> DataPlane
    GRPC --> DataPlane
    Kafka --> DataPlane

    DataPlane --> Cache
    DataPlane --> Batcher
    Batcher --> Codecs
    Codecs --> SKLearn
    Codecs --> XGBoost
    Codecs --> LightGBM
    Codecs --> ONNX
    Codecs --> HuggingFace
    Codecs --> MLflow
    Codecs --> CatBoost
    Codecs --> AlibiDetect
    Codecs --> AlibiExplain
    Codecs --> MLlib

    DataPlane --> ParallelModel
    ParallelModel --> Dispatcher
    Dispatcher --> Workers

    ModelRepo -->|"discovers & loads"| RuntimePlugins
    TrustedRuntimes -->|"restricts loading"| ModelRepo

    %% External dependencies
    ModelStorage["/mnt/models<br/>(PVC/S3 Mount)"] -->|"model artifacts"| ModelRepo
    OTelCollector["OpenTelemetry<br/>Collector<br/>4317/TCP gRPC"] -.->|"traces"| DataPlane
    Prometheus["Prometheus"] -.->|"scrapes /metrics"| Metrics

    %% Styling
    style REST fill:#4a90e2,stroke:#333,color:#fff
    style GRPC fill:#4a90e2,stroke:#333,color:#fff
    style Kafka fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
