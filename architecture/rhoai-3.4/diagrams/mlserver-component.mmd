graph TB
    subgraph MLServer["MLServer Inference Server"]
        direction TB

        subgraph Core["Core Services"]
            RESTServer["RESTServer<br/>(FastAPI/Uvicorn)<br/>Port 8080/TCP"]
            GRPCServer["GRPCServer<br/>(grpc.aio)<br/>Port 8081/TCP"]
            MetricsServer["MetricsServer<br/>(Uvicorn)<br/>Port 8082/TCP"]
        end

        subgraph Logic["Business Logic"]
            DataPlane["DataPlane<br/>V2 Inference Protocol Handler"]
            ModelRegistry["Model Registry<br/>Model lifecycle management"]
            InferencePool["InferencePool<br/>Parallel workers (multiprocessing)"]
        end

        subgraph Runtimes["Runtime Plugins"]
            SKLearn["mlserver-sklearn<br/>scikit-learn 1.8.0"]
            XGBoost["mlserver-xgboost<br/>XGBoost 3.2.0"]
            LightGBM["mlserver-lightgbm<br/>LightGBM 4.6.0"]
            ONNX["mlserver-onnx<br/>onnxruntime 1.24.4"]
        end

        subgraph Security["Security"]
            TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json"]
        end

        RESTServer -->|delegates| DataPlane
        GRPCServer -->|delegates| DataPlane
        DataPlane -->|loads/invokes| ModelRegistry
        ModelRegistry -->|validates against| TrustedRuntimes
        ModelRegistry -->|manages| SKLearn
        ModelRegistry -->|manages| XGBoost
        ModelRegistry -->|manages| LightGBM
        ModelRegistry -->|manages| ONNX
        DataPlane -->|parallel inference| InferencePool
        InferencePool -->|dispatches to| SKLearn
        InferencePool -->|dispatches to| XGBoost
        InferencePool -->|dispatches to| LightGBM
        InferencePool -->|dispatches to| ONNX
    end

    Client["External Client"] -->|HTTPS/443<br/>Bearer Token| KServeGateway["KServe Gateway /<br/>kube-rbac-proxy"]
    KServeGateway -->|HTTP/8080| RESTServer
    KServeGateway -->|gRPC/8081| GRPCServer

    ModelStorage["Model Storage<br/>(PVC / S3 / ModelCar)"] -->|volume mount<br/>/mnt/models| ModelRegistry

    Prometheus["Prometheus"] -->|scrapes /metrics<br/>HTTP/8082| MetricsServer

    subgraph Optional["Optional Integrations"]
        KafkaServer["KafkaServer<br/>Event-driven inference"]
        OTelExporter["OpenTelemetry<br/>OTLP Exporter"]
    end

    KafkaBroker["Kafka Broker<br/>9092/TCP"] <-->|consume/produce| KafkaServer
    KafkaServer -->|delegates| DataPlane
    OTelExporter -->|gRPC export| OTelCollector["OpenTelemetry Collector"]

    style RESTServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style MetricsServer fill:#4a90e2,stroke:#333,color:#fff
    style DataPlane fill:#2c5f8a,stroke:#333,color:#fff
    style ModelRegistry fill:#2c5f8a,stroke:#333,color:#fff
    style InferencePool fill:#2c5f8a,stroke:#333,color:#fff
    style SKLearn fill:#7ed321,stroke:#333
    style XGBoost fill:#7ed321,stroke:#333
    style LightGBM fill:#7ed321,stroke:#333
    style ONNX fill:#7ed321,stroke:#333
    style TrustedRuntimes fill:#e74c3c,stroke:#333,color:#fff
    style KServeGateway fill:#f5a623,stroke:#333
    style ModelStorage fill:#f5a623,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style KafkaBroker fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
    style KafkaServer fill:#9b59b6,stroke:#333,color:#fff
    style OTelExporter fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
