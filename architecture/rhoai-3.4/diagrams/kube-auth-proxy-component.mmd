graph TB
    subgraph Image["odh-kube-auth-proxy-rhel9 Container Image"]
        Entrypoint["entrypoint<br/>(Go CLI Multiplexer)<br/>PROXY_MODE=auth|rbac"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>OAuth2/OIDC Reverse Proxy<br/>Port: 4180/TCP (HTTP)<br/>Port: 443/TCP (HTTPS)"]
            SessionChain["Session Loading Chain<br/>K8s Token → JWT → OAuth Bearer<br/>→ Basic Auth → Cookie Session"]
            AuthProxy --> SessionChain
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            RBACProxy["kube-rbac-proxy<br/>K8s RBAC Authorization Proxy<br/>Port: 8443/TCP (HTTPS)"]
            AuthzChain["Authorization Chain<br/>Hardcoded Metrics → Static Rules<br/>→ SubjectAccessReview"]
            RBACProxy --> AuthzChain
        end

        Entrypoint -->|"PROXY_MODE=auth"| AuthProxy
        Entrypoint -->|"PROXY_MODE=rbac"| RBACProxy
    end

    %% External actors
    Browser["User Browser"]
    Gateway["RHOAI Gateway<br/>(Envoy)"]
    ServiceClient["Service Client<br/>(K8s SA Token)"]

    %% Auth mode flow
    Browser -->|"OAuth2/OIDC login<br/>4180/TCP"| AuthProxy
    Gateway -->|"ext_authz check<br/>/oauth2/auth<br/>4180/TCP"| AuthProxy

    %% RBAC mode flow
    ServiceClient -->|"Bearer token<br/>8443/TCP TLS"| RBACProxy
    Gateway -->|"SA token<br/>8443/TCP TLS"| RBACProxy

    %% Upstream dependencies
    AuthProxy -->|"TokenReview<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API Server"]
    AuthProxy -->|"OAuth2 flow<br/>443/TCP HTTPS"| OIDC["OIDC Provider /<br/>OpenShift OAuth"]
    AuthProxy -.->|"Session storage<br/>6379/TCP"| Redis["Redis (optional)"]

    RBACProxy -->|"TokenReview + SAR<br/>443/TCP HTTPS"| K8sAPI
    RBACProxy -.->|"JWT validation<br/>443/TCP HTTPS"| OIDC

    %% Upstream application
    AuthProxy -->|"Proxied requests<br/>X-Forwarded-User headers"| Upstream["Upstream Application"]
    RBACProxy -->|"Proxied requests<br/>x-remote-user headers"| Upstream

    %% Prometheus
    Prometheus["Prometheus"] -->|"Scrape /metrics<br/>8443/TCP HTTPS"| RBACProxy

    %% Styling
    style Entrypoint fill:#4a90e2,stroke:#333,color:#fff
    style AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style RBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style SessionChain fill:#6bb3e0,stroke:#333
    style AuthzChain fill:#6bb3e0,stroke:#333
    style OIDC fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Redis fill:#e8e8e8,stroke:#666,stroke-dasharray: 5 5
    style Upstream fill:#7ed321,stroke:#333
    style Gateway fill:#f5a623,stroke:#333
    style Browser fill:#f9f9f9,stroke:#333
    style ServiceClient fill:#f9f9f9,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
