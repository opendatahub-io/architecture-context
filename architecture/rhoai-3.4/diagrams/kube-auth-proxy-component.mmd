graph TB
    subgraph Image["quay.io/rhoai/odh-kube-auth-proxy-rhel9"]
        direction TB
        Entrypoint["entrypoint<br/>(Mode Selector)<br/>PROXY_MODE env var"]

        subgraph AuthMode["Auth Mode (PROXY_MODE=auth)"]
            direction TB
            AuthProxy["kube-auth-proxy<br/>(OAuth2/OIDC Proxy)<br/>8080/TCP HTTP | 8443/TCP HTTPS"]
            SessionMgmt["Session Management<br/>Cookie / Redis"]
            Middleware["Middleware Chain<br/>Pre-auth → Session → Headers → Proxy"]
            AuthProxy --> SessionMgmt
            AuthProxy --> Middleware
        end

        subgraph RBACMode["RBAC Mode (PROXY_MODE=rbac, default)"]
            direction TB
            RBACProxy["kube-rbac-proxy<br/>(RBAC Authorization Proxy)<br/>8443/TCP HTTPS"]
            TokenReview["TokenReview<br/>Bearer / OIDC JWT"]
            SAR["SubjectAccessReview<br/>K8s RBAC check"]
            RBACProxy --> TokenReview
            RBACProxy --> SAR
        end

        Entrypoint -->|"auth"| AuthProxy
        Entrypoint -->|"rbac (default)"| RBACProxy
    end

    %% External interactions - Auth mode
    Browser["Browser / Client"] -->|"HTTPS/8443<br/>OAuth2 flow"| AuthProxy
    EnvoyGW["Envoy Proxy<br/>(RHOAI Gateway)"] -->|"HTTP/8080<br/>ext_authz /oauth2/auth"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>Token exchange"| OIDC["OIDC Provider<br/>(Keycloak)"]
    AuthProxy -->|"HTTPS/443<br/>OAuth flow"| OSAuth["OpenShift<br/>OAuth Server"]
    AuthProxy -->|"TCP/6379<br/>Sessions"| Redis["Redis<br/>(optional)"]
    AuthProxy -->|"HTTP/HTTPS<br/>Identity headers"| Upstream["Upstream<br/>Application Pod"]

    %% External interactions - RBAC mode
    Client["API Client"] -->|"HTTPS/8443<br/>Bearer token"| RBACProxy
    RBACProxy -->|"HTTPS/443<br/>TokenReview + SAR"| K8sAPI["Kubernetes<br/>API Server"]
    RBACProxy -->|"HTTP/HTTPS/H2C<br/>x-remote-user headers"| Upstream

    %% Monitoring
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|"HTTPS/8443<br/>/metrics"| RBACProxy

    %% Styling
    style Entrypoint fill:#9b59b6,stroke:#333,color:#fff
    style AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style RBACProxy fill:#4a90e2,stroke:#333,color:#fff
    style SessionMgmt fill:#5dade2,stroke:#333,color:#fff
    style Middleware fill:#5dade2,stroke:#333,color:#fff
    style TokenReview fill:#5dade2,stroke:#333,color:#fff
    style SAR fill:#5dade2,stroke:#333,color:#fff
    style OIDC fill:#999,stroke:#333
    style OSAuth fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Redis fill:#999,stroke:#333
    style Upstream fill:#7ed321,stroke:#333
    style EnvoyGW fill:#f5a623,stroke:#333
    style Browser fill:#f9f9f9,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style Prometheus fill:#e74c3c,stroke:#333,color:#fff
