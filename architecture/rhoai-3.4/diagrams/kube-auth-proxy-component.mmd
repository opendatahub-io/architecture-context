    %% Egress
    AuthProxy -->|"OAuth2 Flow<br/>443/TCP HTTPS"| OAuthServer["OpenShift OAuth<br/>Server"]
    OIDCProvider -->|"OIDC Discovery<br/>443/TCP HTTPS"| IDProvider["OIDC Identity<br/>Provider"]
    TokenReview -->|"TokenReview API<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    RBACProxy -->|"TokenReview +<br/>SubjectAccessReview<br/>443/TCP HTTPS"| K8sAPI
    SessionStore -.->|"6379/TCP<br/>(optional)"| Redis["Redis"]

    %% Upstream
    AuthProxy -->|"Forwarded headers<br/>HTTP"| Upstream["Upstream<br/>Application"]
    RBACProxy -->|"x-remote-user<br/>x-remote-groups<br/>HTTP/H2C"| Upstream

    %% Metrics
    Prometheus["Prometheus"] -->|"Scrape<br/>4180/TCP"| AuthProxy

