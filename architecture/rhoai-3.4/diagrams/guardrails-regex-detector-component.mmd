graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        subgraph "Axum HTTP Server (0.0.0.0:8080)"
            Router[Router / Request Handler]
            HealthEndpoint["/health endpoint<br/>GET → 200 'healthy'"]
            DetectEndpoint["/api/v1/text/contents<br/>POST → Detection Results"]
        end

        subgraph "Detection Engine (detectors.rs)"
            Dispatcher["Pattern Dispatcher<br/>(HashMap&lt;String, fn&gt;)"]
            EmailDetector["email_address_detector<br/>Built-in PII"]
            SSNDetector["ssn_detector<br/>Built-in PII"]
            CreditCardDetector["credit_card_detector<br/>Built-in PII"]
            CustomRegex["Custom Regex Matcher<br/>User-supplied patterns"]
        end
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>8080/TCP HTTP"| DetectEndpoint
    Kubelet["Kubernetes Kubelet"] -->|"GET /health<br/>8080/TCP HTTP"| HealthEndpoint

    Router --> HealthEndpoint
    Router --> DetectEndpoint
    DetectEndpoint -->|"detector_params.regex"| Dispatcher
    Dispatcher -->|"'email'"| EmailDetector
    Dispatcher -->|"'ssn'"| SSNDetector
    Dispatcher -->|"'credit-card'"| CreditCardDetector
    Dispatcher -->|"custom pattern"| CustomRegex

    EmailDetector -->|"detection_type: pii<br/>detection: EmailAddress<br/>score: 1.0"| DetectEndpoint
    SSNDetector -->|"detection_type: pii<br/>detection: SSN<br/>score: 1.0"| DetectEndpoint
    CreditCardDetector -->|"detection_type: pii<br/>detection: CreditCard<br/>score: 1.0"| DetectEndpoint
    CustomRegex -->|"detection_type: custom<br/>score: 1.0"| DetectEndpoint

    style Router fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style DetectEndpoint fill:#4a90e2,stroke:#333,color:#fff
    style Dispatcher fill:#6c5ce7,stroke:#333,color:#fff
    style EmailDetector fill:#00b894,stroke:#333,color:#fff
    style SSNDetector fill:#00b894,stroke:#333,color:#fff
    style CreditCardDetector fill:#00b894,stroke:#333,color:#fff
    style CustomRegex fill:#fdcb6e,stroke:#333,color:#333
    style Orchestrator fill:#e17055,stroke:#333,color:#fff
    style Kubelet fill:#999,stroke:#333,color:#fff
