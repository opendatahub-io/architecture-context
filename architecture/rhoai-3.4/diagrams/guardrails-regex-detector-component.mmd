graph TB
    subgraph "Guardrails Regex Detector"
        direction TB
        Server["axum HTTP Server<br/>Port 8080/TCP"]
        DetectionAPI["/api/v1/text/contents<br/>POST"]
        HealthAPI["/health<br/>GET"]

        subgraph "Detection Engine"
            Registry["Pattern Registry<br/>HashMap&lt;&amp;str, fn&gt;"]
            EmailDetector["Email Detector<br/>(built-in)"]
            SSNDetector["SSN Detector<br/>(built-in)"]
            CCDetector["Credit Card Detector<br/>(built-in)"]
            CustomRegex["Custom Regex<br/>(compiled per-request)"]
        end

        Server --> DetectionAPI
        Server --> HealthAPI
        DetectionAPI --> Registry
        Registry --> EmailDetector
        Registry --> SSNDetector
        Registry --> CCDetector
        Registry --> CustomRegex
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP"| Server
    Server -->|"Detection Results<br/>(JSON response)"| Orchestrator

    subgraph "Platform Security (External)"
        NetworkPolicy["Network Policies"]
        ServiceMesh["Service Mesh / mTLS"]
        KubeRBAC["kube-rbac-proxy"]
    end

    NetworkPolicy -.->|"network isolation"| Server
    ServiceMesh -.->|"encryption layer"| Server
    KubeRBAC -.->|"auth proxy"| Server

    style Server fill:#4a90e2,stroke:#333,color:#fff
    style DetectionAPI fill:#4a90e2,stroke:#333,color:#fff
    style HealthAPI fill:#4a90e2,stroke:#333,color:#fff
    style Registry fill:#5ba5e6,stroke:#333,color:#fff
    style EmailDetector fill:#7ed321,stroke:#333,color:#fff
    style SSNDetector fill:#7ed321,stroke:#333,color:#fff
    style CCDetector fill:#7ed321,stroke:#333,color:#fff
    style CustomRegex fill:#f5a623,stroke:#333,color:#fff
    style Orchestrator fill:#9013fe,stroke:#333,color:#fff
    style NetworkPolicy fill:#e8e8e8,stroke:#999
    style ServiceMesh fill:#e8e8e8,stroke:#999
    style KubeRBAC fill:#e8e8e8,stroke:#999
