graph LR
    VllmCPU["vLLM CPU<br/>Inference Server"]

    %% Internal RHOAI Dependencies
    VllmCPU -->|"pod lifecycle<br/>InferenceService CRD"| KServe["KServe"]
    KServe -->|"init container<br/>model download"| StorageInit["KServe Storage<br/>Initializer"]

    %% Core Framework Dependencies
    VllmCPU -->|"HTTP API framework"| FastAPI["FastAPI >= 0.120.1"]
    VllmCPU -->|"ASGI server"| Uvicorn["Uvicorn"]
    VllmCPU -->|"deep learning<br/>framework"| PyTorch["PyTorch 2.10.0+cpu"]
    VllmCPU -->|"model loading<br/>tokenization"| Transformers["Transformers<br/>>= 4.56.0"]
    VllmCPU -->|"fast tokenization"| Tokenizers["Tokenizers >= 0.21.1"]

    %% API Compatibility Dependencies
    VllmCPU -->|"Responses API<br/>compatibility"| OpenAISDK["OpenAI SDK<br/>>= 1.99.1"]
    VllmCPU -->|"Messages API<br/>compatibility"| AnthropicSDK["Anthropic SDK<br/>>= 0.71.0"]

    %% Inference Dependencies
    VllmCPU -->|"data validation"| Pydantic["Pydantic >= 2.12.0"]
    VllmCPU -->|"quantized models"| CompressedTensors["compressed-tensors<br/>0.13.0"]
    VllmCPU -->|"LLaMA tokenizer"| Sentencepiece["sentencepiece"]
    VllmCPU -->|"serialization"| Protobuf["Protobuf >= 5.29.6"]

    %% Observability Dependencies
    VllmCPU -->|"metrics exposition"| PromClient["Prometheus Client<br/>>= 0.18.0"]
    VllmCPU -->|"FastAPI metrics"| PromFastAPI["prometheus-fastapi-<br/>instrumentator >= 7.0.0"]
    VllmCPU -->|"distributed tracing"| OTel["OpenTelemetry SDK<br/>>= 1.27.0"]
    VllmCPU -->|"gRPC interface"| GRPC["gRPC >= 1.76.0"]

    %% Platform/Arch-Specific Dependencies
    VllmCPU -.->|"OpenMP threading<br/>(x86_64 only)"| IntelOMP["intel-openmp<br/>2024.2.1"]
    VllmCPU -.->|"speculative decoding<br/>(excl. s390x)"| Numba["numba 0.61.2"]

    %% External Services
    VllmCPU -->|"model downloads<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    VllmCPU -->|"model storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>HTTP/8000"| VllmCPU
    OTLPCollector["OTLP Collector"] ---|"trace export<br/>gRPC/4317"| VllmCPU

    %% Styling
    style VllmCPU fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style KServe fill:#7ed321,stroke:#333
    style StorageInit fill:#7ed321,stroke:#333

    %% Core frameworks
    style FastAPI fill:#999,stroke:#333
    style Uvicorn fill:#999,stroke:#333
    style PyTorch fill:#999,stroke:#333
    style Transformers fill:#999,stroke:#333
    style Tokenizers fill:#999,stroke:#333

    %% API SDKs
    style OpenAISDK fill:#999,stroke:#333
    style AnthropicSDK fill:#999,stroke:#333

    %% Inference libs
    style Pydantic fill:#999,stroke:#333
    style CompressedTensors fill:#999,stroke:#333
    style Sentencepiece fill:#999,stroke:#333
    style Protobuf fill:#999,stroke:#333

    %% Observability
    style PromClient fill:#999,stroke:#333
    style PromFastAPI fill:#999,stroke:#333
    style OTel fill:#999,stroke:#333
    style GRPC fill:#999,stroke:#333

    %% Conditional
    style IntelOMP fill:#ccc,stroke:#333,stroke-dasharray: 5 5
    style Numba fill:#ccc,stroke:#333,stroke-dasharray: 5 5

    %% External services
    style HFHub fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
    style OTLPCollector fill:#f5a623,stroke:#333
