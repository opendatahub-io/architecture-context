graph LR
    vLLM["vLLM CPU<br/>(Inference Server)"]

    %% Core Runtime Dependencies
    vLLM -->|"tensor computation"| PyTorch["PyTorch 2.10.0<br/>(+cpu)"]
    vLLM -->|"model loading<br/>tokenizers"| Transformers["Transformers<br/>>= 4.56.0"]
    vLLM -->|"HTTP API<br/>framework"| FastAPI["FastAPI<br/>>= 0.120.1"]
    vLLM -->|"gRPC interface"| gRPC["gRPC<br/>>= 1.76.0"]

    %% Platform Dependencies (Internal RHOAI)
    KServe["KServe<br/>(ServingRuntime)"] -->|"container lifecycle<br/>scaling, routing"| vLLM
    Gateway["RHOAI Gateway<br/>(Envoy)"] -->|"HTTP ingress<br/>HTTPRoute"| vLLM
    KubeRBAC["kube-rbac-proxy<br/>(Sidecar)"] -->|"auth proxy<br/>OAuth/OIDC"| vLLM

    %% Observability Integration
    vLLM -->|"metrics scrape<br/>HTTP/8000"| Prometheus["Prometheus"]
    vLLM -->|"trace export<br/>OTLP/4317"| OTel["OpenTelemetry<br/>Collector"]

    %% External Services
    vLLM -->|"model download<br/>HTTPS/443"| HFHub["Hugging Face Hub"]
    vLLM -->|"model storage<br/>HTTPS/443"| S3["S3-Compatible<br/>Storage"]

    %% Protocol/API Compatibility
    vLLM -->|"API types"| OpenAISDK["openai SDK<br/>>= 1.99.1"]
    vLLM -->|"messages API"| AnthropicSDK["anthropic SDK<br/>>= 0.71.0"]
    vLLM -->|"structured output"| XGrammar["xgrammar<br/>>= 0.1.32"]
    vLLM -->|"structured output"| OutlinesCore["outlines_core<br/>== 0.2.11"]

    %% CPU-Specific Dependencies
    vLLM -->|"CPU parallelism<br/>(x86_64)"| IntelOMP["intel-openmp<br/>2024.2.1"]
    vLLM -->|"linear algebra<br/>(ppc64le/s390x)"| OpenBLAS["OpenBLAS<br/>(source-built)"]
    vLLM -->|"NUMA memory"| numactl["numactl<br/>(source-built)"]

    %% Tool Integration
    vLLM -.->|"agentic tools"| MCP["MCP Server<br/>(Model Context Protocol)"]

