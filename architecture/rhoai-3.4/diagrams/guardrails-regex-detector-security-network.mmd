graph TB
    subgraph PlatformSecurity["PLATFORM SECURITY BOUNDARY<br/>(Network Policies / Service Mesh / kube-rbac-proxy)"]
        direction TB

        subgraph ClusterInternal["CLUSTER INTERNAL (ClusterIP only)"]
            direction TB

            subgraph NS_Guardrails["Namespace: guardrails"]
                Orchestrator["FMS Guardrails Orchestrator<br/>Detection request originator"]
                Detector["Guardrails Regex Detector<br/>Service: regex-detector (ClusterIP)<br/>Port: 8080/TCP<br/>Protocol: HTTP (plaintext)<br/>Auth: None (app-level)<br/>TLS: None (app-level)<br/>Image: ubi9/ubi-minimal"]
            end
        end
    end

    subgraph ExternalIngress["EXTERNAL INGRESS"]
        NoIngress["None — Not exposed<br/>outside cluster"]
    end

    subgraph ExternalEgress["EXTERNAL EGRESS"]
        NoEgress["None — No outbound<br/>dependencies"]
    end

    %% Flows
    Orchestrator -->|"POST /api/v1/text/contents<br/>HTTP 8080/TCP<br/>No Auth (app-level)<br/>No TLS (app-level)<br/>Platform may add mTLS"| Detector
    Detector -->|"HTTP 200 JSON Response<br/>Detection results"| Orchestrator

    %% No connections to external
    NoIngress ~~~ Detector
    Detector ~~~ NoEgress

    %% Styling
    classDef platformBoundary fill:#e8f5e9,stroke:#4caf50,stroke-width:3px
    classDef clusterInternal fill:#e3f2fd,stroke:#2196f3,stroke-width:2px
    classDef component fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef orchestrator fill:#9013fe,stroke:#333,stroke-width:2px,color:#fff
    classDef noAccess fill:#f5f5f5,stroke:#bbb,stroke-width:1px,stroke-dasharray: 5 5

    class Orchestrator orchestrator
    class Detector component
    class NoIngress,NoEgress noAccess
