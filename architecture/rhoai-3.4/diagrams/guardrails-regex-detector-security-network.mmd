graph TB
    subgraph ClusterInternal["CLUSTER INTERNAL (Network Policy / Service Mesh)"]
        direction TB

        subgraph NS_Guardrails["Namespace: guardrails / trustyai"]
            Orchestrator["FMS Guardrails Orchestrator<br/>(upstream caller)"]
            Detector["Guardrails Regex Detector<br/>Bind: 0.0.0.0:8080<br/>Image: regex-detector (UBI 9)<br/>User: root ⚠<br/>No TLS ⚠"]
        end

        subgraph NS_System["Namespace: kube-system"]
            Kubelet["Kubernetes Kubelet<br/>(health probes)"]
        end
    end

    %% Flows
    Orchestrator -->|"POST /api/v1/text/contents<br/>HTTP/8080<br/>Plaintext ⚠<br/>No Auth ⚠"| Detector
    Kubelet -->|"GET /health<br/>HTTP/8080<br/>Plaintext<br/>No Auth"| Detector

    %% No egress
    NoEgress["No Egress<br/>(zero outbound calls)"]
    Detector -.-|"✓ No outbound"| NoEgress

    %% No external ingress
    NoIngress["No External Ingress<br/>(ClusterIP only)"]
    NoIngress -.-|"✓ Internal only"| Detector

    %% Styling
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef detector fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef system fill:#f5f5f5,stroke:#999,stroke-width:1px
    classDef noflow fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5

    class Orchestrator internal
    class Detector detector
    class Kubelet system
    class NoEgress,NoIngress noflow
