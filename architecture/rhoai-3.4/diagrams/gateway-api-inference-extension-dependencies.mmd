graph LR
    IGW["Gateway API<br/>Inference Extension"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc filter<br/>gRPC/9002,9004"| Envoy["Envoy Proxy 1.33+<br/>(or compatible gateway)"]
    IGW -->|"Gateway + HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API v1"]
    IGW -->|"CRD hosting, Pod discovery<br/>leader election<br/>HTTPS/443"| K8s["Kubernetes 1.28+"]
    IGW -->|"controller framework<br/>CRD reconciliation"| CtrlRuntime["controller-runtime<br/>v0.23.1"]

    %% External Dependencies (Optional)
    IGW -.->|"metrics collection<br/>HTTP/9090"| Prometheus["Prometheus"]
    IGW -.->|"distributed tracing<br/>gRPC"| OTel["OpenTelemetry<br/>Collector"]
    IGW -.->|"ML latency prediction<br/>(Python servers)"| XGBoost["XGBoost"]

    %% Internal Platform Dependencies
    IGW -->|"metrics scraping +<br/>traffic routing<br/>HTTP(S)"| ModelServers["Model Servers<br/>(vLLM / SGLang / Triton)"]
    IGW -->|"gateway infrastructure<br/>Gateway API CRDs"| GatewayCtrl["Gateway Controller"]

    %% Gateway Provider Variants
    GatewayCtrl --- Istio["Istio<br/>(EnvoyFilter +<br/>DestinationRule)"]
    GatewayCtrl --- GKE["GKE<br/>(GCPRoutingExtension)"]
    GatewayCtrl --- KGateway["kgateway"]
    GatewayCtrl --- NGINX["NGINX Gateway<br/>Fabric"]

    %% Integration Points (consumers)
    HTTPRoute["HTTPRoute<br/>CRD"] -->|"backendRef to<br/>InferencePool"| IGW
    ConfigMaps["ConfigMaps<br/>(bbr-managed)"] -->|"LoRA → base model<br/>mapping"| IGW

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style Envoy fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff

    %% Optional external
    style Prometheus fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style OTel fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style XGBoost fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Internal platform
    style ModelServers fill:#7ed321,stroke:#333,color:#fff
    style GatewayCtrl fill:#7ed321,stroke:#333,color:#fff

    %% Gateway providers
    style Istio fill:#a8d88a,stroke:#333
    style GKE fill:#a8d88a,stroke:#333
    style KGateway fill:#a8d88a,stroke:#333
    style NGINX fill:#a8d88a,stroke:#333

    %% Consumers
    style HTTPRoute fill:#f5a623,stroke:#333
    style ConfigMaps fill:#f5a623,stroke:#333
