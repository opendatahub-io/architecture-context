    style ModelPods fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style LatencyPredictor fill:#e67e22,stroke:#333,color:#fff
    style LoRASidecar fill:#e67e22,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333
    style OTLPCollector fill:#f5a623,stroke:#333
