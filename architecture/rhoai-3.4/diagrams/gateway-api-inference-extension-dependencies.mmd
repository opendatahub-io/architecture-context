graph LR
    IGW["Gateway API<br/>Inference Extension<br/>(EPP + BBR)"]

    %% External Dependencies (Required)
    IGW -->|"ext-proc filter chain"| Envoy["Envoy Proxy<br/>(ext-proc capable)"]
    IGW -->|"CRD storage,<br/>pod discovery"| K8s["Kubernetes 1.30+"]
    IGW -->|"HTTPRoute/Gateway<br/>resources"| GatewayAPI["Gateway API v1.0+"]
    IGW -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.1"]
    IGW -->|"ext-proc protobuf<br/>definitions"| GoControlPlane["go-control-plane<br/>v1.37.0"]
    IGW -->|"metrics exposition<br/>& parsing"| PromClient["Prometheus<br/>client_golang v1.23.2"]

    %% External Dependencies (Optional)
    IGW -.->|"distributed tracing"| OTel["OpenTelemetry<br/>v1.41.0"]

    %% Model Servers (Required)
    IGW -->|"metrics scraping<br/>& inference routing"| ModelServers["vLLM / SGLang<br/>(compatible model servers)"]

    %% Internal Platform Dependencies
    IGW -->|"InferencePool as<br/>HTTPRoute backend"| PlatformGateway["Platform Gateway<br/>(Gateway API)"]
    IGW -->|"Prometheus metrics<br/>scraping for scheduling"| ModelPods["Model Server Pods<br/>(vLLM/SGLang)"]
    IGW -.->|"LoRA adapter<br/>ConfigMap mappings"| ConfigMaps["ConfigMaps<br/>(LoRA mappings)"]

    %% Optional subsystems
    IGW -.->|"latency-aware<br/>scheduling"| LatencyPredictor["Latency Predictor<br/>(Training + Prediction)"]
    IGW -.->|"dynamic LoRA<br/>management"| LoRASidecar["Dynamic LoRA<br/>Sidecar"]

    %% Observability
    IGW -.->|"metrics"| Prometheus["Prometheus"]
    IGW -.->|"traces"| OTLPCollector["OTLP Collector"]

    %% CRDs defined
    IGW -->|"defines"| CRD_Pool["InferencePool<br/>(v1)"]
    IGW -->|"defines"| CRD_Objective["InferenceObjective<br/>(v1alpha2)"]
    IGW -->|"defines"| CRD_Rewrite["InferenceModelRewrite<br/>(v1alpha2)"]
    IGW -->|"defines"| CRD_Import["InferencePoolImport<br/>(v1alpha1)"]
    IGW -->|"defines"| CRD_Config["EndpointPickerConfig<br/>(v1alpha1)"]

    %% Styling
    style IGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Envoy fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style GoControlPlane fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style OTel fill:#bbb,stroke:#333,color:#fff
    style ModelServers fill:#999,stroke:#333,color:#fff
