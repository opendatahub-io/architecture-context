graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Optional - Gateway API)"]
        HTTPRoute["HTTPRoute<br/>/v1/batches, /v1/files<br/>TLS: SIMPLE (parent Gateway)"]
    end

    subgraph Cluster["CLUSTER INTERNAL (Kubernetes)"]
        direction TB

        subgraph NS_BG["Batch Gateway Namespace"]
            direction TB
            APIServer["API Server<br/>8000/TCP (API) + 8081/TCP (obs)<br/>SA: {release}-apiserver<br/>TLS 1.2+ optional (cert-manager)<br/>Auth: Tenant header (X-MaaS-Username)"]
            Processor["Batch Processor<br/>9090/TCP (obs only)<br/>SA: {release}-processor<br/>emptyDir: 10Gi workdir<br/>Auth: Bearer token + mTLS (optional)"]
            GarbageCollector["Garbage Collector<br/>No network listeners<br/>SA: {release}-gc<br/>Single replica"]
        end
    end

    subgraph DataLayer["DATA LAYER"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional (sslmode)<br/>Conn string credentials"]
        Redis["Redis<br/>6379/TCP<br/>TLS optional (enableTLS)<br/>Conn string credentials"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
    end

    subgraph InferenceLayer["INFERENCE LAYER"]
        InfGW["Inference Gateway<br/>(llm-d / vLLM)<br/>Configurable port<br/>TLS 1.2+ optional + custom CA + mTLS<br/>Bearer token (API key)"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>plaintext"]
        Prometheus["Prometheus<br/>Scrapes 8081/TCP + 9090/TCP<br/>HTTP / No auth"]
    end

    %% External flows
    Client -->|"HTTP/HTTPS 8000/TCP<br/>TLS 1.2+ (optional)<br/>Tenant header + ext_authz"| HTTPRoute
    HTTPRoute -->|"8000/TCP<br/>Path-based routing"| APIServer

    %% Internal flows
    APIServer -->|"PostgreSQL/5432<br/>TLS optional<br/>Conn string"| PostgreSQL
    APIServer -->|"Redis/6379<br/>TLS optional<br/>Conn string"| Redis
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    Processor -->|"PostgreSQL/5432<br/>TLS optional<br/>Conn string"| PostgreSQL
    Processor -->|"Redis/6379<br/>TLS optional<br/>Conn string"| Redis
    Processor -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Processor -->|"HTTP/HTTPS<br/>TLS 1.2+ optional + mTLS<br/>Bearer token"| InfGW

    GarbageCollector -->|"PostgreSQL/5432<br/>TLS optional"| PostgreSQL
    GarbageCollector -->|"HTTPS/443<br/>TLS 1.2+"| S3

    %% Observability
    APIServer -.->|"gRPC/4317<br/>OTLP traces"| OTel
    Processor -.->|"gRPC/4317<br/>OTLP traces"| OTel
    Prometheus -.->|"HTTP scrape<br/>8081/TCP"| APIServer
    Prometheus -.->|"HTTP scrape<br/>9090/TCP"| Processor

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef datalayer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef inference fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class HTTPRoute ingress
    class APIServer,Processor,GarbageCollector cluster
    class PostgreSQL,Redis,S3 datalayer
    class InfGW inference
    class OTel,Prometheus observability
