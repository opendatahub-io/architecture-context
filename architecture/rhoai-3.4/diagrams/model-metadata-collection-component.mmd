graph TB
    subgraph BuildTime["Build-Time Pipeline (CI/CD)"]
        direction TB
        ModelExtractor["model-extractor<br/>(Go CLI)"]
        MetadataReport["metadata-report<br/>(Go CLI)"]
        ModelExtractor -->|generates| CatalogFiles["YAML Catalog Files<br/>data/*.yaml"]
        ModelExtractor -->|generates| OutputMetadata["Extracted Metadata<br/>output/*.yaml"]
        OutputMetadata -->|analyzed by| MetadataReport
        MetadataReport -->|generates| Reports["Quality Reports<br/>(markdown + YAML)"]
    end

    subgraph Inputs["Input Sources"]
        ModelsIndex["models-index.yaml<br/>(model definitions)"]
        MCPIndex["MCP Server Index<br/>(input/mcp_servers/)"]
        SupplementalCatalog["supplemental-catalog.yaml<br/>(static models)"]
        VLLMConfig["vLLM Configs<br/>(input/models/vllm-config/)"]
        ServingOverride["Serving Runtime Override<br/>(input/models/)"]
        SVGAssets["SVG Logos<br/>(assets/*.svg)"]
    end

    subgraph ExternalAPIs["External APIs (Build-Time Only)"]
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS"]
        Registry["Red Hat Container Registry<br/>registry.redhat.io<br/>443/TCP HTTPS"]
    end

    subgraph Runtime["Runtime (Deployed)"]
        DataContainer["odh-model-metadata-collection<br/>(ubi9-micro)<br/>sleep infinity"]
        DataVolume["/app/data/<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>*-mcp-servers-catalog.yaml"]
        DataContainer --- DataVolume
    end

    subgraph Consumer["Platform Consumer"]
        Dashboard["RHOAI Dashboard<br/>(volume mount / file copy)"]
    end

    %% Build-time data flows
    ModelsIndex --> ModelExtractor
    MCPIndex --> ModelExtractor
    SupplementalCatalog --> ModelExtractor
    VLLMConfig --> ModelExtractor
    ServingOverride --> ModelExtractor
    SVGAssets --> ModelExtractor

    ModelExtractor -->|"HTTPS 443<br/>Bearer Token (optional)"| HuggingFace
    ModelExtractor -->|"HTTPS 443<br/>No auth (public)"| Registry

    %% Build to deploy
    CatalogFiles -->|"Konflux CI/CD<br/>Dockerfile.konflux"| DataContainer

    %% Runtime consumption
    DataVolume -->|"Volume mount<br/>File I/O"| Dashboard

    %% Styling
    style ModelExtractor fill:#4a90e2,stroke:#333,color:#fff
    style MetadataReport fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style Registry fill:#f5a623,stroke:#333,color:#fff
    style CatalogFiles fill:#e8e8e8,stroke:#333
    style DataVolume fill:#d5e8d4,stroke:#82b366
    style ModelsIndex fill:#fff2cc,stroke:#d6b656
    style MCPIndex fill:#fff2cc,stroke:#d6b656
    style SupplementalCatalog fill:#fff2cc,stroke:#d6b656
    style VLLMConfig fill:#fff2cc,stroke:#d6b656
    style ServingOverride fill:#fff2cc,stroke:#d6b656
    style SVGAssets fill:#fff2cc,stroke:#d6b656
