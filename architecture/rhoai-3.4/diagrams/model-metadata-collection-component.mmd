graph TB
    subgraph BuildTime["Build-Time Pipeline (CI/CD)"]
        direction TB
        ModelExtractor["model-extractor<br/>Go CLI Tool<br/>(build-time only)"]
        MetadataReport["metadata-report<br/>Go CLI Tool<br/>(build-time only)"]
    end

    subgraph DataContainer["odh-model-metadata-collection<br/>(Shipped Container Image)"]
        direction TB
        SleepProcess["sleep infinity<br/>(entrypoint)"]
        DataVolume["/app/data/<br/>YAML Catalog Files"]
        ModelsIndex["models-index.yaml"]
        ModelsCatalog["models-catalog.yaml"]
        MCPCatalog["redhat-mcp-servers-catalog.yaml"]
        DataVolume --- ModelsIndex
        DataVolume --- ModelsCatalog
        DataVolume --- MCPCatalog
    end

    subgraph ExternalAPIs["External APIs (Build-Time)"]
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS"]
        OCIRegistry["OCI Registry<br/>registry.redhat.io<br/>443/TCP HTTPS"]
    end

    subgraph InputFiles["Input Files"]
        ModelsIndexInput["data/models-index.yaml"]
        MCPInput["input/mcp_servers/*.yaml"]
        SupplementalCatalog["supplemental-catalog.yaml"]
    end

    %% Build-time flows
    ModelsIndexInput -->|reads| ModelExtractor
    MCPInput -->|reads| ModelExtractor
    SupplementalCatalog -->|reads| ModelExtractor
    ModelExtractor -->|"discovers collections<br/>fetches model details"| HuggingFace
    ModelExtractor -->|"pulls manifests<br/>extracts modelcards"| OCIRegistry
    ModelExtractor -->|"generates catalog<br/>YAML files"| DataVolume
    ModelsCatalog -->|reads| MetadataReport
    MetadataReport -->|"generates completeness<br/>reports"| Reports["Markdown + YAML<br/>Reports"]

    %% Runtime consumer
    Dashboard["RHOAI Dashboard"] -->|"volume mount<br/>/app/data/"| DataVolume

    %% CI/CD
    Konflux["Konflux CI/CD<br/>(Tekton)"] -->|"builds multi-arch<br/>container image"| DataContainer

    %% Styling
    style ModelExtractor fill:#4a90e2,stroke:#333,color:#fff
    style MetadataReport fill:#4a90e2,stroke:#333,color:#fff
    style DataContainer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style SleepProcess fill:#e8e8e8,stroke:#999
    style DataVolume fill:#7ed321,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style Dashboard fill:#9b59b6,stroke:#333,color:#fff
    style Konflux fill:#e8e8e8,stroke:#999
    style ModelsIndex fill:#d4edda,stroke:#82b366
    style ModelsCatalog fill:#d4edda,stroke:#82b366
    style MCPCatalog fill:#d4edda,stroke:#82b366
