graph TB
    subgraph PayloadProcessing["AI Gateway Payload Processing (BBR ext_proc)"]
        direction TB
        subgraph PluginChain["Plugin Chain (ordered)"]
            direction LR
            ModelExtractor["body-field-to-header<br/>(upstream BBR plugin)<br/>Extracts model name"]
            ModelResolver["model-provider-resolver<br/>Resolves model → provider<br/>+ credential ref"]
            APITranslation["api-translation<br/>OpenAI ↔ provider format<br/>Request + Response"]
            APIKeyInjection["apikey-injection<br/>Injects provider auth<br/>headers"]
            ModelExtractor --> ModelResolver
            ModelResolver --> APITranslation
            APITranslation --> APIKeyInjection
        end

        subgraph OptionalPlugins["Optional Plugins"]
            NemoGuard["nemo-request-guard<br/>Content safety rails"]
        end

        subgraph Reconcilers["Background Reconcilers"]
            EMReconciler["ExternalModel<br/>Reconciler"]
            SecretReconciler["Secret<br/>Reconciler"]
        end

        subgraph InMemoryStores["In-Memory Stores"]
            ModelInfoStore["modelInfoStore<br/>(model → provider info)"]
            SecretStore["secretStore<br/>(secret → API key)"]
        end

        EMReconciler -->|populates| ModelInfoStore
        SecretReconciler -->|populates| SecretStore
        ModelResolver -->|reads| ModelInfoStore
        APIKeyInjection -->|reads| SecretStore

        subgraph CycleState["CycleState (per-request)"]
            ProviderKey["ProviderName"]
            TargetModel["TargetModelName"]
            CredRef["CredentialRef"]
        end

        ModelResolver -->|writes| CycleState
        APITranslation -->|reads| CycleState
        APIKeyInjection -->|reads| CycleState

        HealthEndpoint["/healthz, /readyz<br/>9005/TCP HTTP"]
        ExtProcEndpoint["ext_proc gRPC<br/>9004/TCP"]
    end

    Client[External Client] -->|HTTPS/443| IstioGW["Istio Gateway<br/>(Envoy)"]
    IstioGW -->|gRPC ext_proc<br/>9004/TCP plaintext| ExtProcEndpoint

    EMReconciler -->|watches| ExternalModelCR["ExternalModel CRDs<br/>(maas.opendatahub.io)"]
    SecretReconciler -->|watches| Secrets["Labeled Secrets<br/>(bbr-managed=true)"]
    ExternalModelCR -.->|created by| MaaSController["MaaS Controller"]

    NemoGuard -->|HTTP POST| NemoService["NeMo Guardrails<br/>Service"]

    IstioGW -->|forwards mutated<br/>request| Providers["External AI Providers<br/>(OpenAI, Anthropic,<br/>Azure, Vertex, Bedrock)"]

    subgraph TranslationFormats["Supported Provider Formats"]
        direction LR
        OpenAI["OpenAI<br/>(passthrough)"]
        Anthropic["Anthropic<br/>(full translation)"]
        Azure["Azure OpenAI<br/>(path rewrite)"]
        Vertex["Vertex AI<br/>(GenerateContent)"]
        VertexOAI["Vertex OpenAI<br/>(path rewrite)"]
        Bedrock["Bedrock OpenAI<br/>(path rewrite)"]
    end

    APITranslation -.->|translates to/from| TranslationFormats

    style PayloadProcessing fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style PluginChain fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style ModelExtractor fill:#7ed321,stroke:#333
    style ModelResolver fill:#7ed321,stroke:#333
    style APITranslation fill:#7ed321,stroke:#333
    style APIKeyInjection fill:#7ed321,stroke:#333
    style NemoGuard fill:#f5a623,stroke:#333
    style CycleState fill:#fff2cc,stroke:#d6b656,stroke-width:1px
    style EMReconciler fill:#4a90e2,stroke:#333,color:#fff
    style SecretReconciler fill:#4a90e2,stroke:#333,color:#fff
    style ModelInfoStore fill:#dae8fc,stroke:#6c8ebf
    style SecretStore fill:#dae8fc,stroke:#6c8ebf
    style IstioGW fill:#e8e8e8,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style Secrets fill:#f5a623,stroke:#333
    style MaaSController fill:#7ed321,stroke:#333
    style NemoService fill:#e8e8e8,stroke:#333
    style Providers fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
