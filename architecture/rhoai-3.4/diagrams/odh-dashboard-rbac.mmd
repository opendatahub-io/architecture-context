    style R_ConfigMaps fill:#dae8fc,stroke:#333
    style R_RBAC fill:#dae8fc,stroke:#333
    style R_TokenReview fill:#dae8fc,stroke:#333
    style R_SAR fill:#dae8fc,stroke:#333
    style R_Nodes fill:#dae8fc,stroke:#333
    style R_Pods fill:#dae8fc,stroke:#333
    style R_NS fill:#dae8fc,stroke:#333

