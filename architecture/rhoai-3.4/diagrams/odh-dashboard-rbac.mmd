graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["odh-dashboard<br/>(ServiceAccount)<br/>Namespace: {dashboard-ns}"]
        AuthenticatedGroup["system:authenticated<br/>(Group)"]
        SAGroup["system:serviceaccounts<br/>(Group)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings"]
        CRB_Main["odh-dashboard<br/>(ClusterRoleBinding)"]
        CRB_Auth["odh-dashboard-auth-delegator<br/>(ClusterRoleBinding)"]
        CRB_Mon["odh-dashboard-monitoring<br/>(ClusterRoleBinding)"]
        CRB_DSG["dsg-cluster-roles<br/>(ClusterRoleBinding)"]
        CRB_Pull["cluster-image-pullers<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["RoleBindings (Namespace-scoped)"]
        RB_NS["odh-dashboard<br/>(RoleBinding)"]
        RB_HW["fetch-hardware-profiles<br/>(RoleBinding)"]
        RB_NIM["nim-account-access<br/>(RoleBinding)"]
        RB_SR["servingruntimes-config-updater<br/>(RoleBinding)"]
        RB_LLM["model-serving-llmisvcconfig<br/>(RoleBinding)"]
        RB_MCP["gen-ai-aa-mcp-servers-reader<br/>(RoleBinding)"]
        RB_EVAL["trustyai-evalhubs<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Main["odh-dashboard<br/>(ClusterRole)"]
        CR_AuthDel["system:auth-delegator<br/>(ClusterRole)"]
        CR_MonView["cluster-monitoring-view<br/>(ClusterRole)"]
        CR_DSG["dsg-cluster-roles<br/>(ClusterRole)"]
        CR_Pull["system:image-puller<br/>(ClusterRole)"]
    end

    subgraph Resources_ODH["ODH/RHOAI Resources"]
        R_Notebooks["kubeflow.org<br/>notebooks<br/>get,list,watch,create,<br/>update,patch,delete"]
        R_InfSvc["serving.kserve.io<br/>inferenceservices<br/>get,list,watch"]
        R_ModelReg["modelregistry.opendatahub.io<br/>modelregistries<br/>get,list,watch,create,<br/>update,patch,delete"]
        R_DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>list,watch,get"]
        R_DSCI["dscinitialization.opendatahub.io<br/>dscinitializations<br/>list,watch,get"]
        R_LSD["llamastack.io<br/>llamastackdistributions<br/>get,list,watch"]
        R_Trusty["trustyai.opendatahub.io<br/>guardrailsorchestrators,evalhubs<br/>get,list,watch"]
        R_Feast["feast.dev<br/>featurestores<br/>get,list,watch"]
        R_MLflow["mlflow.opendatahub.io<br/>mlflows<br/>get,list,watch"]
    end

    subgraph Resources_Core["Core K8s Resources"]
        R_ConfigMaps["core<br/>configmaps,secrets,pvcs<br/>create,delete,get,list,<br/>patch,update,watch"]
        R_RBAC["rbac.authorization.k8s.io<br/>rolebindings,clusterrolebindings,<br/>roles<br/>list,get,create,patch,delete"]
        R_TokenReview["authentication.k8s.io<br/>tokenreviews<br/>create"]
        R_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        R_Nodes["core<br/>nodes<br/>get,list"]
        R_Pods["core<br/>pods,serviceaccounts,services<br/>get,list,watch"]
        R_NS["core<br/>namespaces<br/>patch"]
    end

    subgraph Resources_OCP["OpenShift Resources"]
        R_Routes["route.openshift.io<br/>routes<br/>get,list,watch"]
        R_Console["console.openshift.io<br/>consolelinks<br/>get,list,watch"]
        R_CSV["operators.coreos.com<br/>clusterserviceversions,<br/>subscriptions<br/>get,list,watch"]
        R_Users["user.openshift.io<br/>groups,users<br/>get,list,watch"]
        R_Machines["machine.openshift.io<br/>machineautoscalers,machinesets<br/>get,list"]
        R_Storage["storage.k8s.io<br/>storageclasses<br/>update,patch"]
    end

    %% SA -> CRB -> CR -> Resources
    SA -->|bound via| CRB_Main
    SA -->|bound via| CRB_Auth
    SA -->|bound via| CRB_Mon
    SA -->|bound via| RB_NS

    CRB_Main -->|grants| CR_Main
    CRB_Auth -->|grants| CR_AuthDel
    CRB_Mon -->|grants| CR_MonView

    CR_Main -->|permits| R_Notebooks
    CR_Main -->|permits| R_InfSvc
    CR_Main -->|permits| R_ModelReg
    CR_Main -->|permits| R_DSC
    CR_Main -->|permits| R_DSCI
    CR_Main -->|permits| R_LSD
    CR_Main -->|permits| R_Trusty
    CR_Main -->|permits| R_Feast
    CR_Main -->|permits| R_MLflow
    CR_Main -->|permits| R_ConfigMaps
    CR_Main -->|permits| R_RBAC
    CR_Main -->|permits| R_TokenReview
    CR_Main -->|permits| R_SAR
    CR_Main -->|permits| R_Nodes
    CR_Main -->|permits| R_Pods
    CR_Main -->|permits| R_NS
    CR_Main -->|permits| R_Routes
    CR_Main -->|permits| R_Console
    CR_Main -->|permits| R_CSV
    CR_Main -->|permits| R_Users
    CR_Main -->|permits| R_Machines
    CR_Main -->|permits| R_Storage

    %% Group bindings
    AuthenticatedGroup -->|bound via| CRB_DSG
    AuthenticatedGroup -->|bound via| RB_HW
    AuthenticatedGroup -->|bound via| RB_NIM
    AuthenticatedGroup -->|bound via| RB_SR
    AuthenticatedGroup -->|bound via| RB_LLM
    AuthenticatedGroup -->|bound via| RB_MCP
    AuthenticatedGroup -->|bound via| RB_EVAL
    CRB_DSG -->|grants| CR_DSG

    SAGroup -->|bound via| CRB_Pull
    CRB_Pull -->|grants| CR_Pull

