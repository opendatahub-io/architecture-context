graph TD
    subgraph ServiceAccounts["Service Accounts"]
        DashboardSA["dashboard<br/>(deployment namespace)"]
        AuthenticatedUsers["system:authenticated<br/>(all authenticated users)"]
    end

    subgraph ClusterRoleBindings["ClusterRoleBindings / RoleBindings"]
        CRB_Dashboard["dashboard<br/>(ClusterRoleBinding)"]
        RB_Dashboard["dashboard<br/>(RoleBinding, namespace)"]
        CRB_DSG["dsg-cluster-roles<br/>(ClusterRoleBinding)"]
        RB_LLMConfig["model-serving-llmisvcconfig<br/>(RoleBinding)"]
        RB_MCP["gen-ai-aa-mcp-servers<br/>(RoleBinding)"]
        RB_NIM["fetch-nim-account<br/>(RoleBinding)"]
        RB_EvalHub["trustyai-evalhubs<br/>(RoleBinding)"]
    end

    subgraph ClusterRoles["ClusterRoles / Roles"]
        CR_Dashboard["dashboard<br/>(ClusterRole)"]
        R_Dashboard["dashboard<br/>(Role, namespace)"]
        CR_DSG["dsg-cluster-roles<br/>(ClusterRole, aggregate)"]
        R_LLMConfig["model-serving-llmisvcconfig-view<br/>(Role)"]
        R_MCP["gen-ai-aa-mcp-servers-reader<br/>(Role)"]
        R_NIM["fetch-nim-account<br/>(Role)"]
        R_EvalHub["trustyai-evalhubs-view<br/>(Role)"]
        CR_HWProfiles["aggregate-hardware-profiles<br/>(ClusterRole)"]
    end

    subgraph CoreResources["Core K8s Resources"]
        Namespaces["namespaces"]
        Pods["pods"]
        Events["events"]
        Services["services"]
        ConfigMaps["configmaps"]
        Secrets["secrets"]
        SvcAccounts["serviceaccounts"]
        PVCs["persistentvolumeclaims"]
        StorageClasses["storageclasses<br/>(storage.k8s.io)"]
    end

    subgraph OpenShiftResources["OpenShift Resources"]
        MachineSets["machinesets<br/>(machine.openshift.io)"]
        ClusterVersions["clusterversions<br/>(config.openshift.io)"]
        Proxies["proxies<br/>(config.openshift.io)"]
        Ingresses["ingresses<br/>(config.openshift.io)"]
        CSVs["clusterserviceversions<br/>(operators.coreos.com)"]
        Subscriptions["subscriptions<br/>(operators.coreos.com)"]
        InstallPlans["installplans<br/>(operators.coreos.com)"]
        ImageStreams["imagestreams<br/>(image.openshift.io)"]
        Builds["builds, buildconfigs<br/>(build.openshift.io)"]
    end

    subgraph RHOAIResources["RHOAI / ODH Resources"]
        Notebooks["notebooks<br/>(kubeflow.org)"]
        InferenceServices["inferenceservices<br/>(serving.kserve.io)"]
        ServingRuntimes["servingruntimes<br/>(serving.kserve.io)"]
        LLMISvcConfigs["llminferenceserviceconfigs<br/>(serving.kserve.io)"]
        ModelRegistries["modelregistries<br/>(modelregistry.opendatahub.io)"]
        LlamaStackDist["llamastackdistributions<br/>(llamastack.io)"]
        EvalHubs["evalhubs<br/>(trustyai.opendatahub.io)"]
        FeatureStores["featurestores<br/>(feast.dev)"]
        MLflows["mlflows<br/>(mlflow.opendatahub.io)"]
        HWProfiles["hardwareprofiles<br/>(infrastructure.opendatahub.io)"]
    end

    subgraph AuthResources["Auth Resources"]
        TokenReviews["tokenreviews<br/>(authentication.k8s.io)"]
        SAR["subjectaccessreviews<br/>(authorization.k8s.io)"]
    end

    %% Dashboard SA bindings
    DashboardSA -->|bound via| CRB_Dashboard
    DashboardSA -->|bound via| RB_Dashboard
    CRB_Dashboard -->|grants| CR_Dashboard
    RB_Dashboard -->|grants| R_Dashboard

    %% Authenticated users bindings
    AuthenticatedUsers -->|bound via| CRB_DSG
    AuthenticatedUsers -->|bound via| RB_LLMConfig
    AuthenticatedUsers -->|bound via| RB_MCP
    AuthenticatedUsers -->|bound via| RB_NIM
    AuthenticatedUsers -->|bound via| RB_EvalHub

    CRB_DSG -->|grants| CR_DSG
    RB_LLMConfig -->|grants| R_LLMConfig
    RB_MCP -->|grants| R_MCP
    RB_NIM -->|grants| R_NIM
    RB_EvalHub -->|grants| R_EvalHub

    %% ClusterRole → Resources (dashboard)
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Namespaces
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Pods
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Events
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Services
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| ConfigMaps
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Secrets
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| PVCs
    CR_Dashboard -->|"get,list,watch"| StorageClasses
    CR_Dashboard -->|"get,list"| MachineSets
    CR_Dashboard -->|"get,list"| ClusterVersions
    CR_Dashboard -->|"get,list,watch"| CSVs
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| Notebooks
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| InferenceServices
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| ServingRuntimes
    CR_Dashboard -->|"get,list,watch,create,<br/>update,patch,delete"| LlamaStackDist
    CR_Dashboard -->|"get,list,watch"| ModelRegistries
    CR_Dashboard -->|"get,list,watch"| EvalHubs
    CR_Dashboard -->|"get,list,watch"| FeatureStores
    CR_Dashboard -->|"get,list,watch"| MLflows
    CR_Dashboard -->|"create"| TokenReviews
    CR_Dashboard -->|"create"| SAR

    %% Aggregate roles
    CR_DSG -->|"get,list,watch"| ImageStreams
    CR_DSG -->|"get,list,watch"| Builds
    CR_HWProfiles -->|"get,list,watch"| HWProfiles

    %% Authenticated user roles
    R_LLMConfig -->|"get,list,watch"| LLMISvcConfigs
    R_EvalHub -->|"get,list,watch"| EvalHubs

