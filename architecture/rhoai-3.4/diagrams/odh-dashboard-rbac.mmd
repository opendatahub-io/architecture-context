    style SA fill:#4a90e2,stroke:#333,color:#fff
    style AuthenticatedGroup fill:#4a90e2,stroke:#333,color:#fff
    style SAGroup fill:#4a90e2,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333
    style CR_AuthDel fill:#f5a623,stroke:#333
    style CR_MonView fill:#f5a623,stroke:#333
    style CR_DSG fill:#f5a623,stroke:#333
    style CR_Pull fill:#f5a623,stroke:#333

    style R_Notebooks fill:#7ed321,stroke:#333
    style R_InfSvc fill:#7ed321,stroke:#333
    style R_ModelReg fill:#7ed321,stroke:#333
