graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Reverse Proxy Sidecar)"]

    %% Internal Platform Dependencies
    Sidecar -->|"HTTP(S) reverse proxy<br/>8001/TCP · localhost"| Decoder["vLLM Decoder<br/>(Local · Same Pod)"]
    Sidecar -->|"HTTP(S) reverse proxy<br/>Configurable port"| Prefiller["vLLM Prefiller<br/>(Remote Pods)"]
    Sidecar -->|"Watch API<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>(inference.networking.x-k8s.io/v1alpha2)"]
    Sidecar -->|"Watch API<br/>HTTPS/443"| PodAPI["Kubernetes Pod API"]

    %% Upstream caller
    EPP["llm-d-inference-scheduler<br/>(EPP)"] -->|"HTTPS/8000<br/>x-prefiller-host-port"| Sidecar

    %% Gateway API CRD dependency
    Sidecar -.->|"CRD dependency"| GatewayAPI["Gateway API<br/>InferencePool CRD"]

    %% External Go Dependencies
    subgraph GoDeps["Go Dependencies"]
        ClientGo["k8s.io/client-go<br/>0.31.3"]
        APIMachinery["k8s.io/apimachinery<br/>0.31.3"]
        LRU["hashicorp/golang-lru<br/>v2.0.7"]
        UUID["google/uuid<br/>1.6.0"]
        Logr["go-logr/logr<br/>1.4.2"]
        Klog["k8s.io/klog<br/>v2.130.1"]
    end

    Sidecar -->|"SSRF protection"| ClientGo
    Sidecar -->|"K8s types"| APIMachinery
    Sidecar -->|"proxy handler cache"| LRU
    Sidecar -->|"request correlation"| UUID
    Sidecar -->|"structured logging"| Logr
    Sidecar -->|"K8s-style logging"| Klog

    %% Build dependency
    Go["Go 1.24.2"] -->|"build language"| Sidecar

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#2c5f8a,stroke-width:4px,color:#fff
    style Decoder fill:#7ed321,stroke:#5a9e18,stroke-width:2px,color:#fff
    style Prefiller fill:#7ed321,stroke:#5a9e18,stroke-width:2px,color:#fff
    style EPP fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style InferencePool fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    style PodAPI fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    style GatewayAPI fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
