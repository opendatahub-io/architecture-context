graph LR
    Sidecar["llm-d-routing-sidecar<br/>(Go Sidecar Proxy)"]

    %% Runtime Dependencies
    Sidecar -->|"reverse proxy<br/>HTTP(S)/8001"| vLLMDecoder["vLLM Decoder<br/>(local, same pod)"]
    Sidecar -->|"prefill requests<br/>HTTP(S)/variable port"| vLLMPrefiller["vLLM Prefiller<br/>(remote pods)"]

    %% Kubernetes Dependencies (conditional - SSRF protection)
    Sidecar -.->|"watch CRs<br/>HTTPS/443"| InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
    Sidecar -.->|"watch pods<br/>HTTPS/443"| K8sPodAPI["Kubernetes Pod API<br/>core/v1"]

    %% Go Library Dependencies
    Sidecar -->|"K8s client"| ClientGo["k8s.io/client-go<br/>v0.31.3"]
    Sidecar -->|"K8s types"| APIMachinery["k8s.io/apimachinery<br/>v0.31.3"]
    Sidecar -->|"proxy cache"| LRULib["golang-lru/v2<br/>v2.0.7"]
    Sidecar -->|"request IDs"| UUID["google/uuid<br/>v1.6.0"]
    Sidecar -->|"logging"| Logr["go-logr/logr<br/>v1.4.2"]
    Sidecar -->|"K8s logging"| Klog["k8s.io/klog/v2<br/>v2.130.1"]

    %% Code Lineage
    Sidecar -.->|"code lineage<br/>(TLS self-signed cert logic)"| GatewayAPIExt["gateway-api-inference-extension"]

    %% Successor
    Sidecar -.->|"deprecated →<br/>code moved to"| InferenceScheduler["llm-d-inference-scheduler<br/>(cmd/pd_sidecar, pkg/sidecar)"]

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style vLLMDecoder fill:#9b59b6,stroke:#333,color:#fff
    style vLLMPrefiller fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#e8e8e8,stroke:#333
    style K8sPodAPI fill:#e8e8e8,stroke:#333
    style ClientGo fill:#f5a623,stroke:#333,color:#fff
    style APIMachinery fill:#f5a623,stroke:#333,color:#fff
    style LRULib fill:#f5a623,stroke:#333,color:#fff
    style UUID fill:#f5a623,stroke:#333,color:#fff
    style Logr fill:#f5a623,stroke:#333,color:#fff
    style Klog fill:#f5a623,stroke:#333,color:#fff
    style GatewayAPIExt fill:#ddd,stroke:#999,stroke-dasharray: 5 5
    style InferenceScheduler fill:#ddd,stroke:#999,stroke-dasharray: 5 5
