graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["training-operator<br/>Namespace: opendatahub"]
        MPILauncherSA["{jobName}-launcher<br/>Namespace: {job-namespace}<br/>(per MPIJob)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["training-operator<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings"]
        WebhookRB["training-operator-webhook<br/>(RoleBinding)<br/>Namespace: opendatahub"]
        MPILauncherRB["{jobName}-launcher<br/>(RoleBinding)<br/>Namespace: {job-namespace}"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["training-operator<br/>(ClusterRole)"]
        CREdit["training-edit<br/>(Aggregated ClusterRole)<br/>aggregate-to-edit=true"]
        CRView["training-view<br/>(Aggregated ClusterRole)<br/>aggregate-to-view=true"]
    end

    subgraph Roles["Roles"]
        WebhookRole["training-operator-webhook<br/>(Role)<br/>Namespace: opendatahub"]
        MPILauncherRole["{jobName}-launcher<br/>(Role)<br/>Namespace: {job-namespace}"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["core<br/>pods"]
        PodsExec["core<br/>pods/exec"]
        Services["core<br/>services"]
        ConfigMaps["core<br/>configmaps"]
        Events["core<br/>events"]
        ServiceAccountsRes["core<br/>serviceaccounts"]
    end

    subgraph KubeflowResources["Kubeflow API Resources (kubeflow.org)"]
        PyTorchJobs["pytorchjobs"]
        TFJobs["tfjobs"]
        MPIJobs["mpijobs"]
        JAXJobs["jaxjobs"]
        PaddleJobs["paddlejobs"]
        XGBoostJobs["xgboostjobs"]
        StatusRes["*/status"]
        FinalizersRes["*/finalizers"]
    end

    subgraph OtherResources["Other API Resources"]
        HPA["autoscaling<br/>horizontalpodautoscalers"]
        RolesRes["rbac.authorization.k8s.io<br/>roles, rolebindings"]
        VolcanoPG["scheduling.volcano.sh<br/>podgroups"]
        SchedPG["scheduling.x-k8s.io<br/>podgroups"]
        NetPol["networking.k8s.io<br/>networkpolicies"]
        WebhookConfig["admissionregistration.k8s.io<br/>validatingwebhookconfigurations"]
    end

    subgraph WebhookResources["Webhook Secret Resources"]
        WebhookSecret["core<br/>secrets<br/>(webhook-cert only)"]
    end

    %% ServiceAccount → ClusterRoleBinding → ClusterRole
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR

    %% ServiceAccount → RoleBinding → Role (webhook)
    SA -->|"bound via"| WebhookRB
    WebhookRB -->|"grants"| WebhookRole

    %% MPI Launcher SA → RoleBinding → Role
    MPILauncherSA -->|"bound via"| MPILauncherRB
    MPILauncherRB -->|"grants"| MPILauncherRole

    %% ClusterRole → Core Resources
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| Pods
    CR -->|"create"| PodsExec
    CR -->|"get,list,watch,<br/>create,delete"| Services
    CR -->|"create,list,<br/>update,watch"| ConfigMaps
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| Events
    CR -->|"get,list,watch,<br/>create"| ServiceAccountsRes

    %% ClusterRole → Kubeflow Resources
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| PyTorchJobs
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| TFJobs
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| MPIJobs
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| JAXJobs
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| PaddleJobs
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| XGBoostJobs
    CR -->|"get,patch,update"| StatusRes
    CR -->|"update"| FinalizersRes

    %% ClusterRole → Other Resources
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| HPA
    CR -->|"create,list,<br/>update,watch"| RolesRes
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| VolcanoPG
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| SchedPG
    CR -->|"get,list,watch,<br/>create,delete,<br/>patch,update"| NetPol
    CR -->|"get,list,<br/>update,watch"| WebhookConfig

    %% Webhook Role → Secret
    WebhookRole -->|"get,list,watch,<br/>create,update"| WebhookSecret

    %% MPI Launcher Role → pods/exec
    MPILauncherRole -->|"create,get"| PodsExec

    %% Aggregated roles → Kubeflow Resources
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| PyTorchJobs
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| TFJobs
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| MPIJobs
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| JAXJobs
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| PaddleJobs
    CREdit -->|"create,delete,get,<br/>list,patch,update,watch"| XGBoostJobs
    CREdit -->|"get"| StatusRes

    CRView -->|"get,list,watch"| PyTorchJobs
    CRView -->|"get,list,watch"| TFJobs
    CRView -->|"get,list,watch"| MPIJobs
    CRView -->|"get,list,watch"| JAXJobs
    CRView -->|"get,list,watch"| PaddleJobs
    CRView -->|"get,list,watch"| XGBoostJobs
    CRView -->|"get"| StatusRes

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style MPILauncherSA fill:#4a90e2,color:#fff

    style CR fill:#f5a623
    style CREdit fill:#f5a623
    style CRView fill:#f5a623
    style WebhookRole fill:#f5a623
    style MPILauncherRole fill:#f5a623

    style CRB fill:#e1d5e7,stroke:#9673a6
    style WebhookRB fill:#e1d5e7,stroke:#9673a6
    style MPILauncherRB fill:#e1d5e7,stroke:#9673a6

    style Pods fill:#7ed321
    style PodsExec fill:#7ed321
    style Services fill:#7ed321
    style ConfigMaps fill:#7ed321
    style Events fill:#7ed321
    style ServiceAccountsRes fill:#7ed321

    style PyTorchJobs fill:#d5e8d4,stroke:#82b366
    style TFJobs fill:#d5e8d4,stroke:#82b366
    style MPIJobs fill:#d5e8d4,stroke:#82b366
    style JAXJobs fill:#d5e8d4,stroke:#82b366
    style PaddleJobs fill:#d5e8d4,stroke:#82b366
    style XGBoostJobs fill:#d5e8d4,stroke:#82b366
    style StatusRes fill:#d5e8d4,stroke:#82b366
    style FinalizersRes fill:#d5e8d4,stroke:#82b366

    style HPA fill:#fff2cc,stroke:#d6b656
    style RolesRes fill:#fff2cc,stroke:#d6b656
    style VolcanoPG fill:#fff2cc,stroke:#d6b656
    style SchedPG fill:#fff2cc,stroke:#d6b656
    style NetPol fill:#fff2cc,stroke:#d6b656
    style WebhookConfig fill:#fff2cc,stroke:#d6b656
    style WebhookSecret fill:#fff2cc,stroke:#d6b656
