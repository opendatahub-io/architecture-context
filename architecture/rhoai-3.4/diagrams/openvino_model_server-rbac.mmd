graph TD
    subgraph Note["RBAC for OpenVINO Model Server"]
        direction TB
        Info["OVMS is a service binary, not a Kubernetes operator.<br/>It does NOT define its own RBAC resources.<br/>RBAC is configured by the deploying operator."]
    end

    subgraph DeployingOperators["RBAC Managed By"]
        direction TB
        KServe["KServe Operator<br/>Manages InferenceService RBAC"]
        RhodsOp["rhods-operator<br/>Manages platform RBAC"]
    end

    subgraph ContainerSecurity["Container Security Model"]
        direction TB
        User["Non-root user: ovms<br/>UID: 5000"]
        BaseImage["Base: ubi9-minimal"]
        BuildFlags["SDL flags:<br/>Stack Protector<br/>FORTIFY_SOURCE<br/>Format Security"]
    end

    subgraph APIAuth["API-Level Authentication"]
        direction TB
        RESTAuth["REST API Auth<br/>Optional API Key<br/>via --api_key_file<br/>or API_KEY env var"]
        GRPCAuth["gRPC Auth<br/>None<br/>InsecureServerCredentials"]
        HealthAuth["Health Endpoints<br/>/v2/health/*<br/>Always accessible"]
        MetricsAuth["Metrics Endpoint<br/>/metrics<br/>Always accessible"]
    end

    subgraph SecretAccess["Secrets Consumed"]
        direction TB
        APIKey["API Key File<br/>Opaque (file mount)<br/>No auto-rotate"]
        AWSCreds["AWS Credentials<br/>Env: AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_SESSION_TOKEN"]
        AzureCreds["Azure Credentials<br/>Env: Azure SDK vars"]
        GCSCreds["GCS Credentials<br/>Env: GCS SA vars"]
        HFToken["HuggingFace Token<br/>Env: HF_TOKEN"]
    end

    KServe -->|"deploys and configures"| User
    RhodsOp -->|"platform-level RBAC"| User

    RESTAuth -->|"validates key"| APIKey
    ContainerSecurity --- APIAuth
    APIAuth --- SecretAccess

    %% Styling
    style Note fill:#fff3e0,stroke:#E65100,stroke-width:2px
    style Info fill:#fff3e0,stroke:#E65100

    style DeployingOperators fill:#e8f5e9,stroke:#2E7D32
    style KServe fill:#7ed321,stroke:#333
    style RhodsOp fill:#7ed321,stroke:#333

    style ContainerSecurity fill:#e3f2fd,stroke:#1565C0
    style User fill:#4a90e2,stroke:#333,color:#fff
    style BaseImage fill:#4a90e2,stroke:#333,color:#fff
    style BuildFlags fill:#4a90e2,stroke:#333,color:#fff

    style APIAuth fill:#fce4ec,stroke:#C62828
    style RESTAuth fill:#ef9a9a,stroke:#C62828
    style GRPCAuth fill:#ff8a80,stroke:#C62828
    style HealthAuth fill:#a5d6a7,stroke:#2E7D32
    style MetricsAuth fill:#a5d6a7,stroke:#2E7D32

    style SecretAccess fill:#fff9c4,stroke:#F9A825
    style APIKey fill:#f5a623,stroke:#333
    style AWSCreds fill:#f5a623,stroke:#333
    style AzureCreds fill:#f5a623,stroke:#333
    style GCSCreds fill:#f5a623,stroke:#333
    style HFToken fill:#f5a623,stroke:#333
