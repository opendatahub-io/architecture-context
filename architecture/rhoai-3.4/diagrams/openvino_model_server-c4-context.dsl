// OpenVINO Model Server - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/openvino_model_server.md

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries ML models for inference"
        mlEngineer = person "ML Engineer" "Configures model serving and monitoring"

        ovms = softwareSystem "OpenVINO Model Server (OVMS)" "High-performance AI model inference server using OpenVINO runtime, serving models via gRPC and REST APIs (TFS v1, KServe v2, OpenAI v3)" {
            restServer = container "HTTP/REST Server" "Drogon-based HTTP server exposing TFS v1, KServe v2, and OpenAI v3 compatible REST APIs" "C++ / Drogon" "8080/TCP"
            grpcServer = container "gRPC Server" "gRPC server supporting TFS PredictionService and KServe GRPCInferenceService" "C++ / gRPC" "9178/TCP"
            servableManager = container "Servable Manager" "Manages model loading, versioning, lifecycle, and configuration" "C++"
            mediapipeGraphs = container "MediaPipe Graph Engine" "Executes inference pipelines: LLM, embeddings, rerank, image gen, TTS, STT" "C++ / MediaPipe"
            openvinoRuntime = container "OpenVINO Runtime" "Core inference engine for optimized model execution on Intel hardware" "C++ / OpenVINO 2025.4.x"
            metricsModule = container "Metrics Module" "Prometheus-compatible metrics collection and /metrics endpoint" "C++"
            hfPullModule = container "HuggingFace Pull Module" "Downloads models from HuggingFace Hub via git/HTTP" "C++ / libgit2"
            capiModule = container "C API Module" "libovms_shared.so for embedding OVMS as a library" "C / C++"
        }

        kserve = softwareSystem "KServe" "ML model serving controller that orchestrates OVMS deployment as InferenceService runtime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform using OVMS as a runtime backend" "Internal RHOAI"
        rhoaiOperator = softwareSystem "RHOAI Operator" "Platform operator that configures and deploys OVMS runtime" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Monitoring system that scrapes OVMS metrics" "Internal"

        s3 = softwareSystem "S3-compatible Storage" "Object storage for model artifacts (AWS S3, MinIO, etc.)" "External"
        azureBlob = softwareSystem "Azure Blob Storage" "Microsoft cloud object storage for model artifacts" "External"
        gcs = softwareSystem "Google Cloud Storage" "Google cloud object storage for model artifacts" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model repository for downloading pre-trained models" "External"

        // User interactions
        datascientist -> ovms "Sends inference requests via REST/gRPC"
        mlEngineer -> kserve "Creates InferenceService resources"

        // Internal container relationships
        restServer -> mediapipeGraphs "Routes v3 requests to graph calculators"
        restServer -> servableManager "Routes v1/v2 requests"
        grpcServer -> servableManager "Routes gRPC inference requests"
        mediapipeGraphs -> openvinoRuntime "Executes model inference"
        servableManager -> openvinoRuntime "Loads and manages models"
        servableManager -> hfPullModule "Triggers HuggingFace model downloads"

        // Platform interactions
        kserve -> ovms "Deploys as InferenceService runtime container"
        modelmesh -> ovms "Uses as serving runtime via gRPC 8085/TCP"
        rhoaiOperator -> kserve "Configures OVMS serving runtime"
        prometheus -> ovms "Scrapes /metrics endpoint HTTP 8080/TCP"

        // External service interactions
        ovms -> s3 "Downloads model artifacts" "HTTPS/443 TLS 1.2+ AWS IAM"
        ovms -> azureBlob "Downloads model artifacts" "HTTPS/443 TLS 1.2+ Azure creds"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443 TLS 1.2+ GCP SA"
        ovms -> huggingface "Pulls model repositories" "HTTPS/443 TLS 1.2+ HF_TOKEN"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal" {
                background #85bbf0
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
