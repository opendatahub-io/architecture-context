graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (expected)"]
        Ingress["Platform Ingress<br/>(HTTPRoute + kube-rbac-proxy)<br/>Managed by consuming deployment"]
    end

    subgraph GatewayService["GATEWAY SERVICE (Internal ClusterIP)"]
        Gateway["vllm-orchestrator-gateway<br/>Rust/Axum on UBI 9<br/>8090/TCP<br/>POST /{route}/v1/chat/completions<br/>No local auth enforcement<br/>No /healthz or /readyz"]
    end

    subgraph TLSMounts["TLS CERTIFICATES (Volume Mounts)"]
        TLSCert["/etc/tls/private/tls.crt<br/>Client cert for mTLS<br/>service-serving-cert"]
        TLSKey["/etc/tls/private/tls.key<br/>Private key<br/>service-serving-cert"]
        CACert["/etc/tls/ca/service-ca.crt<br/>CA certificate<br/>service-ca-operator"]
    end

    subgraph BackendServices["BACKEND SERVICES (Internal)"]
        direction TB

        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP<br/>HTTP or HTTPS<br/>POST /api/v2/chat/completions-detection"]

        subgraph IndirectBackends["Accessed by Orchestrator (not gateway)"]
            Detectors["Guardrails Detector Services<br/>(e.g., regex-language)"]
            vLLM["vLLM Inference Backend<br/>LLM chat completion"]
        end

        Orchestrator --> Detectors
        Orchestrator --> vLLM
    end

    %% Flows
    Client -->|"HTTP/8090<br/>Plaintext<br/>Authorization header<br/>(forwarded, not enforced)"| Ingress
    Ingress -->|"HTTP/8090<br/>Platform-managed TLS"| Gateway
    TLSCert -.->|"client identity"| Gateway
    TLSKey -.->|"private key"| Gateway
    CACert -.->|"CA trust chain"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Plaintext OR mTLS<br/>(auto-detected from cert presence)<br/>mTLS client cert +<br/>forwarded Authorization"| Orchestrator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef gateway fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef tls fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef indirect fill:#e8e8e8,stroke:#999,stroke-width:1px

    class Client external
    class Ingress ingress
    class Gateway gateway
    class Orchestrator backend
    class Detectors,vLLM indirect
    class TLSCert,TLSKey,CACert tls
