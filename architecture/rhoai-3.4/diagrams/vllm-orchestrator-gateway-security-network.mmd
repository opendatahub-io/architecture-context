graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["API Client<br/>No auth enforced at gateway"]
    end

    subgraph GatewayZone["GATEWAY SERVICE (No Auth Enforcement)"]
        direction TB
        Gateway["vllm-orchestrator-gateway<br/>Rust/axum<br/>Listen: 0.0.0.0:8090/TCP<br/>Exposure: Internal only<br/>No RBAC, No NetworkPolicy"]

        subgraph Routes["Dynamic Routes (config.yaml)"]
            PIIRoute["/{pii}/v1/chat/completions<br/>regex-language detector"]
            PassthroughRoute["/{passthrough}/v1/chat/completions<br/>no detectors"]
        end

        subgraph TLSConfig["TLS Configuration (Optional)"]
            ClientCert["/etc/tls/private/tls.crt<br/>X.509 PEM"]
            ClientKey["/etc/tls/private/tls.key<br/>PEM private key"]
            CACert["/etc/tls/ca/service-ca.crt<br/>X.509 PEM (service-ca)"]
        end
    end

    subgraph Backend["BACKEND SERVICES"]
        Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP<br/>HTTP or HTTPS<br/>/api/v2/chat/completions-detection"]

        subgraph OrchestratorBackends["Orchestrator Backends (indirect)"]
            Detectors["Detector Services<br/>(e.g., guardrails-regex-detector)<br/>PII, toxicity detection"]
            vLLM["vLLM Inference Server<br/>LLM model serving"]
        end
    end

    %% Flows
    Client -->|"HTTP/8090<br/>No encryption<br/>Authorization header<br/>(passthrough, not enforced)"| Gateway
    Gateway -->|"HTTP or HTTPS/8085<br/>Optional mTLS<br/>(auto-detected from cert mounts)<br/>Client cert + forwarded Auth header<br/>POST /api/v2/chat/completions-detection"| Orchestrator
    Orchestrator -->|"Internal"| Detectors
    Orchestrator -->|"Internal"| vLLM

    %% TLS links
    Gateway -.->|"reads certs"| TLSConfig

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef indirect fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef tls fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef route fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway gateway
    class Orchestrator backend
    class Detectors,vLLM indirect
    class ClientCert,ClientKey,CACert tls
    class PIIRoute,PassthroughRoute route
