graph TD
    subgraph "RBAC Model — Notebooks Workbenches"
        direction TB

        Note["NOTE: No RBAC resources defined in the notebooks repository.<br/>All RBAC is managed by odh-notebook-controller at runtime."]

        subgraph RuntimeRBAC["Runtime RBAC (managed by odh-notebook-controller)"]
            direction TB

            subgraph AuthFlow["Authentication Flow"]
                UserBrowser["User Browser<br/>(OAuth/OIDC)"]
                Gateway["RHOAI Gateway<br/>TLS 1.2+"]
                KubeRBAC["kube-rbac-proxy sidecar<br/>Bearer token validation"]
            end

            subgraph WorkbenchAuth["Workbench Authorization"]
                JupyterAuth["JupyterLab (8888/TCP)<br/>Auth: None (deferred to sidecar)"]
                CSAuth["Code Server (8787/TCP)<br/>--auth none (deferred to sidecar)"]
                RSAuth["RStudio Server (8787/TCP)<br/>Auth: None (deferred to sidecar)"]
            end

            subgraph Policy["Authorization Policy"]
                NSAccess["User must have access to<br/>notebook namespace"]
            end
        end

        subgraph BuildSecrets["Build-Time Secrets"]
            RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription for RStudio BuildConfig<br/>Provisioned: Manual (cluster admin)<br/>Auto-rotate: No"]
        end
    end

    %% Auth flow
    UserBrowser -->|"HTTPS/443<br/>OAuth/OIDC redirect"| Gateway
    Gateway -->|"HTTPS/8443<br/>mTLS, Bearer token"| KubeRBAC
    KubeRBAC -->|"validates against"| NSAccess
    KubeRBAC -->|"HTTP/8888 (plaintext)"| JupyterAuth
    KubeRBAC -->|"HTTP/8787 (plaintext)"| CSAuth
    KubeRBAC -->|"HTTP/8787 (plaintext)"| RSAuth

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style UserBrowser fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KubeRBAC fill:#f8cecc,stroke:#b85450
    style NSAccess fill:#d5e8d4,stroke:#82b366
    style JupyterAuth fill:#dae8fc,stroke:#6c8ebf
    style CSAuth fill:#dae8fc,stroke:#6c8ebf
    style RSAuth fill:#dae8fc,stroke:#6c8ebf
    style RHELSecret fill:#e6b8af,stroke:#cc0000
