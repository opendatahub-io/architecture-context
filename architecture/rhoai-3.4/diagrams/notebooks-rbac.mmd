%% RBAC Visualization - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4/notebooks.md

graph TD
    subgraph "Authentication Flow"
        User["User Browser<br/>(Data Scientist)"]
        OAuth["OpenShift OAuth<br/>Bearer Token"]
    end

    subgraph "Authorization Enforcement"
        Gateway["data-science-gateway<br/>Gateway API (Envoy)"]
        KubeRBAC["kube-rbac-proxy sidecar<br/>Port: 8443/TCP HTTPS<br/>Injected by odh-notebook-controller"]
        SAR["SubjectAccessReview<br/>Validates user access to<br/>Notebook CR namespace"]
    end

    subgraph "Workbench Access Policy"
        Policy["Access Policy:<br/>User must have RBAC access<br/>to the Notebook CR namespace"]
    end

    subgraph "Protected Endpoints"
        LabUI["JupyterLab UI<br/>/lab<br/>GET, POST, WebSocket<br/>Port: 8888/TCP"]
        KernelAPI["Kernel Activity API<br/>/api/kernels/<br/>GET<br/>Port: 8888/TCP"]
        CodeServerUI["Code-Server UI<br/>/codeserver/<br/>GET, POST, WebSocket<br/>Port: 8787/TCP"]
        RStudioUI["RStudio UI<br/>/<br/>GET, POST, WebSocket<br/>Port: 8787/TCP"]
    end

    subgraph "Operator RBAC (External)"
        OperatorSA["rhods-operator<br/>ServiceAccount"]
        ControllerSA["odh-notebook-controller<br/>ServiceAccount"]
        OperatorRole["Operator ClusterRole<br/>(defined in rhods-operator repo)"]
        ControllerRole["Controller ClusterRole<br/>(defined in kubeflow repo)"]
    end

    subgraph "OpenShift API Resources Managed"
        ImageStreamRes["ImageStream<br/>image.openshift.io/v1<br/>Workbench + Runtime images"]
        BuildConfigRes["BuildConfig<br/>build.openshift.io/v1<br/>RStudio on-cluster builds"]
        ConfigMapRes["ConfigMap<br/>notebook-image-params<br/>notebook-image-commithash"]
    end

    subgraph "Secrets"
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription<br/>for RStudio BuildConfig<br/>Provisioned: Manual/Operator<br/>Auto-Rotate: No"]
    end

    %% User authentication flow
    User -->|"authenticates via"| OAuth
    OAuth -->|"Bearer token"| Gateway
    Gateway -->|"forwards to"| KubeRBAC
    KubeRBAC -->|"performs"| SAR
    SAR -->|"checks"| Policy

    %% Access to protected endpoints
    KubeRBAC -->|"proxies to"| LabUI
    KubeRBAC -->|"proxies to"| KernelAPI
    KubeRBAC -->|"proxies to"| CodeServerUI
    KubeRBAC -->|"proxies to"| RStudioUI

    %% Operator RBAC
    OperatorSA -->|"bound via"| OperatorRole
    ControllerSA -->|"bound via"| ControllerRole
    OperatorRole -->|"manages"| ImageStreamRes
    OperatorRole -->|"manages"| BuildConfigRes
    OperatorRole -->|"manages"| ConfigMapRes
    BuildConfigRes -->|"uses"| RHELSecret

    %% Styling
    style User fill:#08427b,color:#fff
    style KubeRBAC fill:#4a90e2,color:#fff
