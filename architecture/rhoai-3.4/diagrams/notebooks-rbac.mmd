graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["This repository does NOT define RBAC resources.<br/>RBAC for workbench pods is managed externally."]
    end

    subgraph ExternalRBAC["External RBAC Management"]
        direction TB

        subgraph ControllerRBAC["odh-notebook-controller RBAC"]
            ControllerSA["ServiceAccount:<br/>odh-notebook-controller-manager"]
            KubeRBACProxy["kube-rbac-proxy Sidecar<br/>(injected into every workbench pod)"]
            ControllerSA -->|"injects"| KubeRBACProxy
        end

        subgraph SidecarAuth["Sidecar Authentication"]
            OAuth["OAuth/OIDC Token Validation"]
            NamespaceCheck["Namespace Access Check"]
            KubeRBACProxy -->|"validates"| OAuth
            KubeRBACProxy -->|"enforces"| NamespaceCheck
        end

        subgraph WorkbenchAccess["Workbench Access Control"]
            JupyterUI["JupyterLab UI<br/>/notebook/{ns}/{user}/<br/>GET, POST, WS"]
            CodeServerUI["Code-Server UI<br/>GET, POST, WS"]
            RStudioUI["RStudio UI<br/>GET, POST"]
            JupyterAPI["JupyterLab API (internal)<br/>/notebook/{ns}/{user}/api<br/>No auth (token='')"]
        end

        OAuth -->|"protects"| JupyterUI
        OAuth -->|"protects"| CodeServerUI
        OAuth -->|"protects"| RStudioUI
        NamespaceCheck -->|"user must have<br/>namespace access"| JupyterUI
        NamespaceCheck -->|"user must have<br/>namespace access"| CodeServerUI
        NamespaceCheck -->|"user must have<br/>namespace access"| RStudioUI
    end

    subgraph MountedSecrets["Secrets (Provisioned by Controller)"]
        DSPASecret["DSPA Connection Secret<br/>Type: Opaque<br/>Purpose: Pipeline endpoint + creds<br/>Provisioned by: odh-notebook-controller<br/>Auto-rotate: No"]
        CABundle["CA Bundle<br/>Type: Opaque<br/>Path: /etc/pki/tls/custom-certs/ca-bundle.crt<br/>Provisioned by: odh-notebook-controller<br/>Auto-rotate: No"]
    end

    ControllerSA -->|"mounts into<br/>workbench pods"| DSPASecret
    ControllerSA -->|"mounts into<br/>workbench pods"| CABundle

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,stroke-width:2px
    style Info fill:#fff3cd,stroke:#856404
    style ExternalRBAC fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style ControllerRBAC fill:#d5e8d4,stroke:#82b366
    style SidecarAuth fill:#f8cecc,stroke:#b85450
    style WorkbenchAccess fill:#dae8fc,stroke:#6c8ebf
    style MountedSecrets fill:#e1d5e7,stroke:#9673a6

    style ControllerSA fill:#4a90e2,color:#fff
    style KubeRBACProxy fill:#e74c3c,color:#fff
    style OAuth fill:#f5a623,color:#fff
    style NamespaceCheck fill:#f5a623,color:#fff
    style JupyterUI fill:#7ed321,color:#fff
    style CodeServerUI fill:#7ed321,color:#fff
    style RStudioUI fill:#7ed321,color:#fff
    style JupyterAPI fill:#95a5a6,color:#fff
    style DSPASecret fill:#9b59b6,color:#fff
    style CABundle fill:#9b59b6,color:#fff
