graph LR
    ODHDashboard["ODH Dashboard<br/>(9-container pod)"]

    %% Platform Dependencies (Required)
    ODHDashboard -->|"HTTPS/6443<br/>SA + User Token"| K8sAPI["Kubernetes API<br/>Server"]
    ODHDashboard -->|"HTTPRoute<br/>HTTPS/443"| Gateway["data-science-gateway<br/>(Envoy)"]
    ODHDashboard -->|"sidecar<br/>HTTPS/8443"| KubeRBACProxy["kube-rbac-proxy"]

    %% Internal RHOAI Dependencies
    ODHDashboard -->|"REST proxy<br/>HTTPS/8443"| DSPipelines["Data Science<br/>Pipelines"]
    ODHDashboard -->|"REST proxy<br/>HTTPS/443"| TrustyAI["TrustyAI<br/>Service"]
    ODHDashboard -->|"BFF REST<br/>HTTPS/443"| ModelRegistry["Model Registry<br/>API"]
    ODHDashboard -->|"BFF REST<br/>HTTPS/443"| ModelCatalog["Model Catalog<br/>API"]
    ODHDashboard -->|"REST proxy<br/>HTTP/8080"| Perses["Perses<br/>Dashboards"]

    %% AI/ML Service Dependencies
    ODHDashboard -->|"BFF HTTP/gRPC<br/>TLS optional"| LlamaStack["LlamaStack"]
    ODHDashboard -->|"BFF HTTPS<br/>Token"| MaaSAPI["MaaS API"]
    ODHDashboard -->|"BFF HTTP<br/>Token"| MLflow["MLflow<br/>Tracking"]

    %% External Service Dependencies
    ODHDashboard -->|"HTTPS/443<br/>AWS Creds"| S3["S3 Storage"]

    %% CRD Dependencies
    ODHDashboard -.->|"watches"| OdhDashboardConfig["OdhDashboardConfig CR<br/>80+ feature flags"]
    ODHDashboard -.->|"reads"| DSCluster["DataScienceCluster CR<br/>Platform status"]

    %% Integration: Other components → Dashboard
    OpenShiftConsole["OpenShift Console"] -.->|"ConsoleLink CR"| ODHDashboard

    %% Framework Dependencies
    subgraph Frameworks["Build Dependencies"]
        direction TB
        NodeJS["Node.js 22.x<br/>(UBI9)"]
        Go["Go 1.24-1.25<br/>(UBI9 go-toolset)"]
        React["React 18.2+"]
        PatternFly["PatternFly 6.4.x"]
        Fastify["Fastify 4.28+"]
        ModFed["@module-federation<br/>/runtime 0.15+"]
        K8sClient["@kubernetes<br/>/client-node 0.12+"]
        PluginSDK["@openshift/dynamic<br/>-plugin-sdk 5.0+"]
    end

    ODHDashboard -.->|"runtime"| NodeJS
    ODHDashboard -.->|"runtime"| Go

