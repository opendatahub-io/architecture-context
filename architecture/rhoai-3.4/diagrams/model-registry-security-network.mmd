graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist / Client<br/>(UI, Python SDK, curl)"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Kubeflow Gateway<br/>(Istio VirtualService)<br/>443/TCP → 8080/TCP<br/>TLS Termination<br/>Route: /api/model_registry/*"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            Proxy["model-registry (proxy)<br/>SA: model-registry<br/>8080/TCP HTTP<br/>91 REST operations<br/>FIPS: strictfipsruntime"]
            DB_MySQL["MySQL 8.3+<br/>3306/TCP<br/>Auth: user/pass"]
            DB_Postgres["PostgreSQL 16+<br/>5432/TCP<br/>Auth: user/pass"]
            MRUI["model-registry-ui<br/>SA: model-registry-ui<br/>8080/TCP HTTP<br/>Frontend + BFF"]
        end

        subgraph NS_Controller["Namespace: controller"]
            Controller["controller-manager<br/>SA: system:controller-manager<br/>8081/TCP (health)<br/>8443/TCP HTTPS (metrics)<br/>⚠️ InsecureSkipVerify=true"]
        end

        subgraph NS_KServe["Namespace: KServe pods"]
            CSI["mr-storage-initializer<br/>(KServe init container)<br/>Resolves model-registry:// URIs"]
        end

        subgraph NS_Jobs["Namespace: jobs"]
            AsyncJob["async-upload job<br/>Python 3.12 batch<br/>Hermetic build (cachi2)"]
        end
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA bearer token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>username/password"]
        Sigstore["Sigstore/Rekor<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC identity"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Ingress → Service
    Gateway -->|"HTTP/8080<br/>Istio mTLS (ISTIO_MUTUAL)<br/>AuthorizationPolicy"| Proxy

    %% Proxy → Database
    Proxy -->|"TCP/3306<br/>Optional TLS<br/>user/pass"| DB_MySQL
    Proxy -->|"TCP/5432<br/>Optional TLS<br/>user/pass"| DB_Postgres

    %% UI → Proxy
    MRUI -->|"HTTP/8080<br/>REST API"| Proxy
    MRUI -->|"HTTPS/6443<br/>Service discovery + SAR"| K8sAPI

    %% Controller flows
    K8sAPI -->|"Watch stream<br/>InferenceService CRs<br/>SA token"| Controller
    Controller -->|"HTTP/8080<br/>⚠️ InsecureSkipVerify=true<br/>Bearer Token"| Proxy

    %% CSI flows
    CSI -->|"HTTP/8080<br/>No Auth"| Proxy
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Provider-specific"| S3

    %% Async job flows
    AsyncJob -->|"HTTP/8080<br/>Bearer Token (opt)"| Proxy
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>user/pass"| OCI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC"| Sigstore

    %% Prometheus
    Prometheus["Prometheus<br/>ServiceMonitor"] -->|"HTTPS/8443<br/>TLS 1.2+<br/>TokenReview + SAR"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef database fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#fff2cc,stroke:#d79b00,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class Proxy,MRUI,CSI,AsyncJob servicemesh
    class Controller warning
    class K8sAPI k8s
    class S3,OCI,Sigstore,Prometheus externalservice
    class DB_MySQL,DB_Postgres database
