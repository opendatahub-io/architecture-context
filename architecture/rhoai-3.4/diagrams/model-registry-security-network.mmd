graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Data Scientist / Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Istio VirtualService<br/>→ kubeflow-gateway<br/>8080/TCP<br/>TLS Mode: ISTIO_MUTUAL<br/>AuthorizationPolicy: ALLOW"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Mesh / Trusted)"]
        direction TB

        subgraph NS_MR["Namespace: model-registry"]
            MRAPI["Model Registry REST API<br/>model-registry-service (ClusterIP)<br/>8080/TCP HTTP<br/>SA: model-registry<br/>FIPS: strictfipsruntime<br/>Auth: None (platform delegates)"]
            MRDB["Database<br/>model-registry-db (ClusterIP)<br/>MySQL 3306/TCP or PostgreSQL 5432/TCP<br/>Auth: username/password<br/>Encryption: Optional TLS 1.2+"]
        end

        subgraph NS_Controller["Namespace: controller-system"]
            Controller["MR Controller<br/>SA: controller-manager<br/>Health: 8081/TCP HTTP<br/>Metrics: 8443/TCP HTTPS<br/>⚠ InsecureSkipVerify=true<br/>⚠ CGO_ENABLED=0 (no FIPS)"]
        end

        subgraph NS_KServe["KServe Init Container"]
            CSI["mr-storage-initializer<br/>model-registry:// protocol<br/>Resolves URIs via MR API"]
        end

        subgraph NS_Job["On-Demand Job"]
            AsyncJob["async-upload Job<br/>Python 3.12 on UBI9<br/>FIPS: System OpenSSL<br/>No listener (batch)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCIReg["OCI Registry<br/>(Quay/DockerHub)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF API key"]
        SigstoreSvc["Sigstore<br/>(Fulcio/Rekor/TUF)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC identity"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>ServiceAccount token"]
    end

    %% Flows
    Client -->|"HTTP/8080<br/>Platform Auth Proxy<br/>Istio mTLS"| Gateway
    Gateway -->|"HTTP/8080<br/>ISTIO_MUTUAL mTLS<br/>Service Identity"| MRAPI
    MRAPI -->|"MySQL/3306 or PG/5432<br/>Optional TLS 1.2+<br/>username/password"| MRDB

    Controller -->|"HTTP/8080<br/>⚠ InsecureSkipVerify<br/>No auth"| MRAPI
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI

    CSI -->|"HTTP/8080<br/>Resolve URIs"| MRAPI
    CSI -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3

    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| MRAPI
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker auth"| OCIReg
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>HF API key"| HFHub
    AsyncJob -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC identity"| SigstoreSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class MRAPI internal
    class MRDB database
    class Controller warning
    class CSI internal
    class AsyncJob internal
    class S3,OCIReg,HFHub,SigstoreSvc,K8sAPI externalservice
