graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies (linked libraries)
    subgraph LinkedLibs["Linked Libraries (Built from Source)"]
        OpenVINO["OpenVINO Runtime<br/>2026.0"]
        GenAI["OpenVINO GenAI SDK<br/>2026.0"]
        Tokenizers["OpenVINO Tokenizers<br/>2026.0"]
    end

    OVMS -->|"inference engine"| OpenVINO
    OVMS -->|"LLM pipeline"| GenAI
    OVMS -->|"tokenization"| Tokenizers
    GenAI -->|"delegates to"| OpenVINO

    %% Build / Framework Dependencies
    subgraph Frameworks["Frameworks & Libraries"]
        gRPC["gRPC / Protobuf<br/>(Bazel-managed)"]
        Drogon["Drogon<br/>HTTP Framework"]
        Boost["Boost<br/>1.68.0"]
        OpenCV["OpenCV<br/>Custom Build"]
        MediaPipe["MediaPipe<br/>(Optional)"]
        Jinja2["Jinja2<br/>3.1.6"]
        Prometheus["Prometheus C++<br/>Client"]
    end

    OVMS -->|"gRPC server"| gRPC
    OVMS -->|"REST server"| Drogon
    OVMS -->|"utilities"| Boost
    OVMS -->|"image processing"| OpenCV
    OVMS -.->|"DAG pipelines"| MediaPipe
    OVMS -->|"chat templates"| Jinja2
    OVMS -->|"metrics"| Prometheus

    %% Internal RHOAI Platform Dependencies
    subgraph Platform["RHOAI Platform (Internal)"]
        KServe["KServe<br/>Container Runtime"]
        RHOAIOp["RHOAI Operator<br/>ServingRuntime CR"]
        KubeRBAC["kube-rbac-proxy<br/>Auth Sidecar"]
    end

    KServe -->|"manages pod"| OVMS
    RHOAIOp -->|"configures"| KServe
    KubeRBAC -->|"fronts access"| OVMS

    %% Platform consumers
    subgraph Consumers["Platform Consumers"]
        PromScrape["Prometheus /<br/>OpenShift Monitoring"]
    end

    PromScrape -->|"scrapes /metrics"| OVMS

    %% Cloud Storage Dependencies
    subgraph CloudStorage["Cloud Storage Backends (Egress)"]
        S3["Amazon S3<br/>443/TCP HTTPS"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS + Git LFS"]
    end

    OVMS -->|"s3:// models"| S3
    OVMS -->|"gs:// models"| GCS
    OVMS -->|"azureblob:// models"| Azure
    OVMS -->|"HF model pull"| HFHub

    %% Hardware Dependencies
    subgraph Hardware["Hardware Acceleration"]
        IntelGPU["Intel GPU<br/>OpenCL Drivers<br/>24.52.32224"]
        CPU["Intel CPU<br/>AVX/SSE"]
    end

    OpenVINO -.->|"GPU compute"| IntelGPU
    OpenVINO -->|"CPU inference"| CPU

    %% System Dependencies
    subgraph System["System (UBI9)"]
        OpenSSL["OpenSSL<br/>System (FIPS in FIPS mode)"]
        libgit2["libgit2<br/>(Optional)"]
        Python["Python 3.12<br/>(Optional)"]
    end

    OVMS -->|"MD5 checksums, SSL"| OpenSSL
    OVMS -.->|"HF git clone"| libgit2
    OVMS -.->|"templates, graph nodes"| Python

