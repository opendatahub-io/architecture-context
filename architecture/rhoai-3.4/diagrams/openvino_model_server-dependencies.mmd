graph LR
    OVMS["OpenVINO Model Server<br/>(OVMS)"]

    %% Core Runtime Dependencies
    OVMS -->|"inference engine<br/>(required)"| OVRuntime["OpenVINO Runtime<br/>2026.0"]
    OVMS -->|"LLM/VLM serving<br/>(required)"| OVGenAI["OpenVINO GenAI<br/>2026.0"]
    OVMS -->|"tokenization<br/>(required)"| OVTokenizers["OpenVINO Tokenizers<br/>2026.0"]

    %% Framework Dependencies
    OVMS -->|"pipeline execution<br/>(when enabled)"| MediaPipe["MediaPipe<br/>pinned commit"]
    OVMS -->|"HTTP server<br/>(required)"| Drogon["Drogon<br/>HTTP Framework"]
    OVMS -->|"RPC server<br/>(required)"| gRPC["gRPC<br/>pinned via Bazel"]
    OVMS -->|"metrics<br/>(required)"| PromClient["Prometheus C++<br/>Client"]

    %% Library Dependencies
    OVMS -->|"image processing<br/>(required)"| OpenCV["OpenCV<br/>pinned"]
    OVMS -->|"JSON parsing<br/>(required)"| RapidJSON["RapidJSON"]
    OVMS -->|"logging<br/>(required)"| spdlog["spdlog"]
    OVMS -->|"XML parsing<br/>(required)"| pugixml["pugixml 1.13"]
    OVMS -->|"crypto/checksums<br/>(required)"| BoringSSL["BoringSSL"]
    OVMS -->|"C++ utilities<br/>(required)"| Boost["Boost 1.68.0"]
    OVMS -->|"chat templates<br/>(required)"| Jinja2["Jinja2 3.1.6"]

    %% Optional Cloud SDKs
    OVMS -.->|"S3 storage<br/>(optional)"| AWSSDK["AWS SDK C++"]
    OVMS -.->|"Azure storage<br/>(optional)"| AzureSDK["Azure Storage<br/>SDK 7.5.0"]
    OVMS -.->|"GCS storage<br/>(optional)"| GCSSDK["Google Cloud<br/>Storage SDK"]
    OVMS -.->|"model download<br/>(optional)"| libgit2["libgit2"]

    %% Python Dependencies
    OVMS -.->|"Python nodes<br/>(when enabled)"| Python["Python 3.12"]
    OVMS -.->|"Python binding<br/>(when enabled)"| pybind11["pybind11"]
    OVMS -.->|"tensor processing<br/>(when enabled)"| NumPy["NumPy < 2.0.0"]

    %% Build System
    OVMS -->|"build system"| Bazel["Bazel 6.1.1"]

    %% Hardware Dependencies
    OVMS -.->|"GPU acceleration<br/>(optional)"| IntelGPU["Intel GPU Driver<br/>24.52.32224"]

    %% Internal Platform Dependencies
    KServe["KServe /<br/>ModelMesh"] -->|"KServe v2 protocol<br/>inference runtime"| OVMS
    Prometheus["Prometheus"] -->|"scrapes /metrics"| OVMS
    IstioSidecar["Istio Sidecar"] -->|"mTLS proxy<br/>TLS termination"| OVMS

    %% External Service Dependencies
    OVMS -->|"model storage<br/>HTTPS/443"| S3["AWS S3"]
    OVMS -->|"model storage<br/>HTTPS/443"| AzureBlob["Azure Blob<br/>Storage"]
    OVMS -->|"model storage<br/>HTTPS/443"| GCS["Google Cloud<br/>Storage"]
    OVMS -->|"model download<br/>HTTPS/443"| HFHub["HuggingFace<br/>Hub"]

    %% Styling
    style OVMS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core runtime - purple
    style OVRuntime fill:#7B1FA2,stroke:#333,color:#fff
    style OVGenAI fill:#9C27B0,stroke:#333,color:#fff
    style OVTokenizers fill:#AB47BC,stroke:#333,color:#fff

    %% Frameworks - dark gray
    style MediaPipe fill:#616161,stroke:#333,color:#fff
    style Drogon fill:#616161,stroke:#333,color:#fff
    style gRPC fill:#616161,stroke:#333,color:#fff
    style PromClient fill:#616161,stroke:#333,color:#fff

    %% Libraries - light gray
    style OpenCV fill:#999,stroke:#333
    style RapidJSON fill:#999,stroke:#333
    style spdlog fill:#999,stroke:#333
    style pugixml fill:#999,stroke:#333
    style BoringSSL fill:#999,stroke:#333
    style Boost fill:#999,stroke:#333
    style Jinja2 fill:#999,stroke:#333

    %% Optional - lighter
    style AWSSDK fill:#ccc,stroke:#333
    style AzureSDK fill:#ccc,stroke:#333
    style GCSSDK fill:#ccc,stroke:#333
    style libgit2 fill:#ccc,stroke:#333
    style Python fill:#ccc,stroke:#333
    style pybind11 fill:#ccc,stroke:#333
    style NumPy fill:#ccc,stroke:#333
    style IntelGPU fill:#ccc,stroke:#333

    %% Build
    style Bazel fill:#43A047,stroke:#333,color:#fff

    %% Internal platform - green
    style KServe fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style IstioSidecar fill:#7ed321,stroke:#333

    %% External services - orange
    style S3 fill:#f5a623,stroke:#333
    style AzureBlob fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
