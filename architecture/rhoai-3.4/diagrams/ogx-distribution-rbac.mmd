graph TD
    subgraph AuthConfig["Authentication Configuration"]
        AuthIssuer["AUTH_ISSUER env var<br/>(enables OAuth2 when set)"]
        AuthAudience["AUTH_AUDIENCE<br/>default: llama-stack"]
        AuthJWKS["AUTH_JWKS_URI<br/>(JWKS endpoint for key retrieval)"]
        AuthVerifyTLS["AUTH_VERIFY_TLS<br/>default: true"]
    end

    subgraph OAuth2Flow["OAuth2 JWT Validation Flow"]
        direction TB
        JWKSEndpoint["JWKS Endpoint<br/>(OAuth2 Identity Provider)<br/>443/TCP HTTPS"]
        AuthMiddleware["Llama Stack<br/>Auth Middleware<br/>(built-in)"]
        JWKSEndpoint -->|"Fetches public keys<br/>every AUTH_JWKS_RECHECK_PERIOD (3600s)"| AuthMiddleware
    end

    subgraph AccessPolicy["Access Control Policy"]
        direction TB
        HealthEndpoint["/v1/health<br/>Always accessible<br/>No auth required"]
        ReadUnowned["Read unowned resources<br/>Permit ALL<br/>(no auth required)"]
        CreateResources["Create resources<br/>Permit AUTHENTICATED<br/>(valid JWT required)"]
        CRUDOwned["Read/Update/Delete owned<br/>Permit OWNER only<br/>(JWT subject must match)"]
    end

    subgraph Endpoints["Protected API Endpoints"]
        direction LR
        Inference["/v1/inference/*<br/>/v1/chat/completions"]
        Safety["/v1/safety/*"]
        Eval["/v1/eval/*"]
        VectorIO["/v1/vector_io/*"]
        ToolRuntime["/v1/tool_runtime/*"]
        Files["/v1/files/*"]
        Batches["/v1/batches/*"]
        Scoring["/v1/scoring/*"]
        Responses["/v1/responses/*"]
        Models["/v1/models"]
        Providers["/v1/providers"]
        DatasetIO["/v1/datasetio/*"]
    end

    subgraph K8sRBAC["Kubernetes RBAC"]
        NoRBAC["No Kubernetes RBAC defined<br/>in this repository.<br/>RBAC managed by<br/>rhods-operator"]
    end

    subgraph BuildSecrets["Build-Time Secrets"]
        WheelSecret["rhel-ai-private-index-auth<br/>Type: Opaque<br/>Purpose: GitLab PAT for AIPCC wheel index<br/>Rotation: Manual"]
        GitSecret["git_auth_secret<br/>Type: Opaque<br/>Purpose: Git auth for Tekton PipelineRun<br/>Managed by: Pipelines-as-Code"]
    end

    %% Config to middleware
    AuthIssuer -->|"enables"| AuthMiddleware
    AuthAudience -->|"configures audience"| AuthMiddleware
    AuthJWKS -->|"configures endpoint"| AuthMiddleware
    AuthVerifyTLS -->|"TLS verification"| AuthMiddleware

    %% Middleware to policy
    AuthMiddleware -->|"applies"| AccessPolicy

    %% Policy to endpoints
    AccessPolicy -->|"protects"| Endpoints

    %% Warning
    Warning["WARNING: Without AUTH_ISSUER set,<br/>ALL APIs are completely open<br/>(no authentication enforced)"]

    %% Styling
    style AuthMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style HealthEndpoint fill:#7ed321,stroke:#333,color:#fff
    style ReadUnowned fill:#7ed321,stroke:#333
    style CreateResources fill:#f5a623,stroke:#333,color:#fff
    style CRUDOwned fill:#e74c3c,stroke:#333,color:#fff
    style Warning fill:#f8cecc,stroke:#b85450,stroke-width:3px
    style NoRBAC fill:#e8e8e8,stroke:#999
    style WheelSecret fill:#fff2cc,stroke:#d6b656
    style GitSecret fill:#fff2cc,stroke:#d6b656
    style JWKSEndpoint fill:#999,stroke:#333,color:#fff

    style Inference fill:#dae8fc,stroke:#6c8ebf
    style Safety fill:#dae8fc,stroke:#6c8ebf
    style Eval fill:#dae8fc,stroke:#6c8ebf
    style VectorIO fill:#dae8fc,stroke:#6c8ebf
    style ToolRuntime fill:#dae8fc,stroke:#6c8ebf
    style Files fill:#dae8fc,stroke:#6c8ebf
    style Batches fill:#dae8fc,stroke:#6c8ebf
    style Scoring fill:#dae8fc,stroke:#6c8ebf
    style Responses fill:#dae8fc,stroke:#6c8ebf
