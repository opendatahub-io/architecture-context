graph TD
    subgraph "Note"
        Note["This component is a container image,<br/>not a Kubernetes operator.<br/>No ClusterRoles, Roles, or<br/>RoleBindings are defined."]
    end

    subgraph "Application-Level Access Control"
        direction TB

        subgraph "Auth Flow"
            Client["External Client"] -->|"Bearer JWT<br/>(OAuth2 Token)"| AuthMW["OAuth2 JWT Middleware"]
            AuthMW -->|"Validate signature"| JWKS["OIDC Provider<br/>JWKS Endpoint"]
            JWKS -->|"Public keys"| AuthMW
        end

        subgraph "Auth Configuration"
            AuthIssuer["AUTH_ISSUER<br/>(OIDC Issuer URL)"]
            AuthAudience["AUTH_AUDIENCE<br/>(Expected audience)"]
            AuthJWKS["AUTH_JWKS_URI<br/>(JWKS endpoint URL)"]
            AuthVerifyTLS["AUTH_VERIFY_TLS<br/>(TLS verification flag)"]
        end

        subgraph "Access Policies"
            direction TB

            HealthPolicy["Health Endpoint<br/>/v1/health"]
            SystemReadPolicy["System Resource Read<br/>/v1/* (GET on unowned)"]
            CreatePolicy["Resource Creation<br/>/v1/* (POST)"]
            OwnerPolicy["Owner Resource Mgmt<br/>/v1/* (GET/PUT/DELETE owned)"]
        end

        subgraph "Policy Rules"
            HealthRule["No authentication required"]
            SystemReadRule["All authenticated users<br/>can read unowned<br/>system resources"]
            CreateRule["All authenticated users<br/>can create resources"]
            OwnerRule["Only resource owners can<br/>read, update, or delete<br/>their own resources"]
        end

        AuthMW -->|"unauthenticated"| HealthPolicy
        AuthMW -->|"authenticated"| SystemReadPolicy
        AuthMW -->|"authenticated"| CreatePolicy
        AuthMW -->|"authenticated + owner"| OwnerPolicy

        HealthPolicy --> HealthRule
        SystemReadPolicy --> SystemReadRule
        CreatePolicy --> CreateRule
        OwnerPolicy --> OwnerRule
    end

    subgraph "Build-Time Secrets (Not Runtime RBAC)"
        BuildSecret1["rhel-ai-private-index-auth<br/>Type: Build Secret<br/>Purpose: GitLab PAT for wheel registry<br/>Provisioned: Manual/Konflux<br/>Auto-Rotate: No"]
        BuildSecret2["git_auth_secret<br/>Type: Git Auth<br/>Purpose: Tekton pipeline checkout<br/>Provisioned: Pipelines as Code<br/>Auto-Rotate: Yes"]
    end

    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style AuthMW fill:#e74c3c,stroke:#333,color:#fff
    style JWKS fill:#f5a623,stroke:#333
    style HealthPolicy fill:#7ed321,stroke:#333
    style SystemReadPolicy fill:#4a90e2,stroke:#333,color:#fff
    style CreatePolicy fill:#4a90e2,stroke:#333,color:#fff
    style OwnerPolicy fill:#9b59b6,stroke:#333,color:#fff
    style HealthRule fill:#d5e8d4,stroke:#82b366
    style SystemReadRule fill:#dae8fc,stroke:#6c8ebf
    style CreateRule fill:#dae8fc,stroke:#6c8ebf
    style OwnerRule fill:#e1d5e7,stroke:#9673a6
    style BuildSecret1 fill:#f9f9f9,stroke:#999
    style BuildSecret2 fill:#f9f9f9,stroke:#999
    style AuthIssuer fill:#fff2cc,stroke:#d6b656
    style AuthAudience fill:#fff2cc,stroke:#d6b656
    style AuthJWKS fill:#fff2cc,stroke:#d6b656
    style AuthVerifyTLS fill:#fff2cc,stroke:#d6b656
