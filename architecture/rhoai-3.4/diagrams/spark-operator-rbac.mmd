graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(operator namespace)"]
        SA_Webhook["spark-operator-webhook<br/>(operator namespace)"]
        SA_Spark["spark-operator-spark<br/>(operator namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["spark-operator-controller<br/>(cluster-wide)"]
        CRB_Webhook["spark-operator-webhook<br/>(cluster-wide)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_ControllerLE["spark-operator-controller<br/>(leader-election)"]
        RB_Webhook["spark-operator-webhook<br/>(operator namespace)"]
        RB_Spark["spark-operator-spark<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Controller["spark-operator-controller"]
        CR_Webhook["spark-operator-webhook"]
        CR_SparkEditor["sparkapplication-editor"]
        CR_SparkViewer["sparkapplication-viewer"]
        CR_SchedEditor["scheduledsparkapplication-editor"]
        CR_SchedViewer["scheduledsparkapplication-viewer"]
    end

    subgraph ControllerResources["Controller Resources"]
        Pods_C["core / pods<br/>create, delete, get,<br/>list, update, watch"]
        ConfigMaps_C["core / configmaps<br/>create, get, list,<br/>patch, update, watch"]
        Services_C["core / services<br/>create, delete, get, list,<br/>patch, update, watch"]
        PVCs_C["core / persistentvolumeclaims<br/>list, watch"]
        Events_C["core / events<br/>create, patch, update"]
        CRDs_C["apiextensions.k8s.io / crds<br/>get"]
        Ingresses_C["networking.k8s.io / ingresses<br/>create, delete, get, update"]
        SparkApps_C["sparkoperator.k8s.io /<br/>sparkapplications<br/>create, delete, get,<br/>list, watch + status, finalizers"]
        SchedApps_C["sparkoperator.k8s.io /<br/>scheduledsparkapplications<br/>get, list, watch +<br/>status, finalizers"]
        Connects_C["sparkoperator.k8s.io /<br/>sparkconnects<br/>get, list, watch"]
    end

    subgraph WebhookResources["Webhook Resources"]
        MWC["admissionregistration /<br/>mutatingwebhookconfigurations<br/>list, watch, get, update"]
        VWC["admissionregistration /<br/>validatingwebhookconfigurations<br/>list, watch, get, update"]
        SparkApps_W["sparkoperator.k8s.io /<br/>sparkapplications,<br/>scheduledsparkapplications<br/>get, list, watch"]
        Pods_W["core / pods<br/>list, watch"]
    end

    subgraph SparkDriverResources["Spark Driver Resources"]
        Pods_S["core / pods<br/>full CRUD + deletecollection"]
        ConfigMaps_S["core / configmaps<br/>full CRUD + deletecollection"]
        PVCs_S["core / pvcs<br/>full CRUD + deletecollection"]
        Services_S["core / services<br/>full CRUD + deletecollection"]
    end

    %% Controller bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_ControllerLE
    CRB_Controller -->|grants| CR_Controller

    %% Webhook bindings
    SA_Webhook -->|bound via| CRB_Webhook
    SA_Webhook -->|bound via| RB_Webhook
    CRB_Webhook -->|grants| CR_Webhook

    %% Spark driver bindings
    SA_Spark -->|bound via| RB_Spark

    %% Controller role → resources
    CR_Controller -->|access| Pods_C
    CR_Controller -->|access| ConfigMaps_C
    CR_Controller -->|access| Services_C
    CR_Controller -->|access| PVCs_C
    CR_Controller -->|access| Events_C
    CR_Controller -->|access| CRDs_C
    CR_Controller -->|access| Ingresses_C
    CR_Controller -->|access| SparkApps_C
    CR_Controller -->|access| SchedApps_C
    CR_Controller -->|access| Connects_C

    %% Webhook role → resources
    CR_Webhook -->|access| MWC
    CR_Webhook -->|access| VWC
    CR_Webhook -->|access| SparkApps_W
    CR_Webhook -->|access| Pods_W

    %% Spark driver → resources
    RB_Spark -->|access| Pods_S
    RB_Spark -->|access| ConfigMaps_S
    RB_Spark -->|access| PVCs_S
    RB_Spark -->|access| Services_S

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Webhook fill:#4a90e2,stroke:#333,color:#fff
    style SA_Spark fill:#4a90e2,stroke:#333,color:#fff
    style CR_Controller fill:#f5a623,stroke:#333,color:#fff
    style CR_Webhook fill:#f5a623,stroke:#333,color:#fff
    style CR_SparkEditor fill:#f5a623,stroke:#333,color:#fff
    style CR_SparkViewer fill:#f5a623,stroke:#333,color:#fff
    style CR_SchedEditor fill:#f5a623,stroke:#333,color:#fff
    style CR_SchedViewer fill:#f5a623,stroke:#333,color:#fff
    style CRB_Controller fill:#e8e8e8,stroke:#333
    style CRB_Webhook fill:#e8e8e8,stroke:#333
    style RB_ControllerLE fill:#e8e8e8,stroke:#333
    style RB_Webhook fill:#e8e8e8,stroke:#333
    style RB_Spark fill:#e8e8e8,stroke:#333

    style Pods_C fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps_C fill:#7ed321,stroke:#333,color:#fff
    style Services_C fill:#7ed321,stroke:#333,color:#fff
    style PVCs_C fill:#7ed321,stroke:#333,color:#fff
    style Events_C fill:#7ed321,stroke:#333,color:#fff
    style CRDs_C fill:#7ed321,stroke:#333,color:#fff
    style Ingresses_C fill:#7ed321,stroke:#333,color:#fff
    style SparkApps_C fill:#7ed321,stroke:#333,color:#fff
    style SchedApps_C fill:#7ed321,stroke:#333,color:#fff
    style Connects_C fill:#7ed321,stroke:#333,color:#fff

    style MWC fill:#9b59b6,stroke:#333,color:#fff
    style VWC fill:#9b59b6,stroke:#333,color:#fff
    style SparkApps_W fill:#9b59b6,stroke:#333,color:#fff
    style Pods_W fill:#9b59b6,stroke:#333,color:#fff

    style Pods_S fill:#e74c3c,stroke:#333,color:#fff
    style ConfigMaps_S fill:#e74c3c,stroke:#333,color:#fff
    style PVCs_S fill:#e74c3c,stroke:#333,color:#fff
    style Services_S fill:#e74c3c,stroke:#333,color:#fff
