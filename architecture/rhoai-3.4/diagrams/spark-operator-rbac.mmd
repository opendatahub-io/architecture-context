        AR_SchedEditor["scheduledsparkapplication-editor<br/>(aggregated to: edit, admin)"]
    end

    subgraph ControllerResources["Controller API Resources"]
        Pods["core: pods<br/>create, delete, get,<br/>list, update, watch"]
        ConfigMaps["core: configmaps<br/>create, get, list,<br/>patch, update, watch"]
        Services["core: services<br/>create, delete, get, list,<br/>patch, update, watch"]
