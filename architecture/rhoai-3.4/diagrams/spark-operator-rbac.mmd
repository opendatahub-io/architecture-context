        Events["core: events<br/>create, patch, update"]
        Nodes["core: nodes<br/>get"]
        ResourceQuotas["core: resourcequotas<br/>get, list, watch"]
        CRDs["apiextensions: CRDs<br/>get"]
        Ingresses["networking.k8s.io: ingresses<br/>create, delete, get,<br/>list, update, watch"]
