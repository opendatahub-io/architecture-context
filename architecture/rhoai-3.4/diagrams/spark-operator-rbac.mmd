        SparkAppsStatus["sparkoperator.k8s.io:<br/>sparkapplications/status<br/>update"]
        SparkAppsFinalizers["sparkoperator.k8s.io:<br/>sparkapplications/finalizers<br/>update"]
        ScheduledApps["sparkoperator.k8s.io:<br/>scheduledsparkapplications<br/>get, list, watch"]
        ScheduledAppsStatus["sparkoperator.k8s.io:<br/>scheduledsparkapplications/status<br/>update"]
        ScheduledAppsFinalizers["sparkoperator.k8s.io:<br/>scheduledsparkapplications/finalizers<br/>update, patch"]
        SparkConnects["sparkoperator.k8s.io:<br/>sparkconnects<br/>get, list, watch"]
        SparkConnectsStatus["sparkoperator.k8s.io:<br/>sparkconnects/status<br/>update"]
    end

    subgraph WebhookResources["Webhook API Resources"]
        MutatingWH["admissionregistration:<br/>mutatingwebhookconfigurations<br/>get, list, update, watch"]
        ValidatingWH["admissionregistration:<br/>validatingwebhookconfigurations<br/>get, list, update, watch"]
    end

    subgraph SparkDriverResources["Spark Driver Resources"]
        DriverPods["core: pods<br/>full CRUD + deletecollection"]
        DriverCMs["core: configmaps<br/>full CRUD + deletecollection"]
        DriverPVCs["core: persistentvolumeclaims<br/>full CRUD + deletecollection"]
        DriverSvcs["core: services<br/>full CRUD + deletecollection"]
    end

    subgraph UserFacingResources["User-Facing Resources"]
        ViewSparkApps["sparkapplications<br/>get, list, watch"]
        EditSparkApps["sparkapplications<br/>create, delete, get, list,<br/>patch, update, watch"]
        ViewScheduledApps["scheduledsparkapplications<br/>get, list, watch"]
        EditScheduledApps["scheduledsparkapplications<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

