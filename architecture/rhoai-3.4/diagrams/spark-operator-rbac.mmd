graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["spark-operator-controller<br/>(operator namespace)"]
        SA_Webhook["spark-operator-webhook<br/>(operator namespace)"]
        SA_Spark["spark-operator-spark<br/>(operator namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Controller["spark-operator-controller<br/>(ClusterRoleBinding)"]
        CRB_Webhook["spark-operator-webhook<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_LeaderElection["spark-operator-controller<br/>(leader-election)<br/>Namespace: operator NS"]
        RB_Spark["spark-operator-role<br/>Namespace: operator NS"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Controller["spark-operator-controller"]
        CR_Webhook["spark-operator-webhook"]
    end

