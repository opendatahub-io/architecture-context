    style CR_MetricsAuth fill:#f5a623,color:#fff
    style CR_MetricsRead fill:#f5a623,color:#fff
    style R_Manager fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style CR_MLflow fill:#f5a623,color:#fff
