graph TD
    subgraph OperatorIdentity["Operator Identity"]
        SA_Op["ServiceAccount<br/>mlflow-operator-controller-manager<br/>Namespace: redhat-ods-applications"]
    end

    subgraph MLflowIdentity["MLflow Server Identity"]
        SA_MLflow["ServiceAccount<br/>mlflow-sa<br/>Namespace: redhat-ods-applications"]
    end

    subgraph ClusterBindings["ClusterRoleBindings"]
        CRB_Op["mlflow-operator-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_MLflow["mlflow<br/>(cluster-scoped, Helm-rendered)"]
    end

    subgraph NSBindings["Namespace RoleBindings"]
        RB_Op["mlflow-operator-manager-rolebinding<br/>(redhat-ods-applications)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_NSManager["manager-role<br/>(Role, ns-scoped)"]
        CR_MLflow["mlflow<br/>(ClusterRole, Helm-rendered)"]
    end

    subgraph AggregateRoles["Aggregate Roles (User-Facing)"]
        CR_View["mlflow-view<br/>(aggregated to view)"]
        CR_Edit["mlflow-edit<br/>(aggregated to edit)"]
        CR_Integration["mlflow-integration"]
    end

    subgraph OperatorResources["Operator-Managed API Resources"]
        MLflows["mlflow.opendatahub.io<br/>mlflows<br/>get,list,watch,create,<br/>update,patch,delete"]
        MLflowsStatus["mlflow.opendatahub.io<br/>mlflows/status<br/>get,patch,update"]
        MLflowsFinalizers["mlflow.opendatahub.io<br/>mlflows/finalizers<br/>update"]
        Namespaces_Op["core<br/>namespaces<br/>get,list,watch"]
        Secrets_Op["core<br/>secrets (mlflow-artifact-connection)<br/>get,list,watch"]
        MLflowConfigs_Op["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles,clusterrolebindings<br/>get,list,watch,create,<br/>update,patch,delete"]
        ConsoleLinks["console.openshift.io<br/>consolelinks<br/>get,list,watch,create,<br/>update,patch,delete"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    subgraph NSResources["Namespace-Scoped Resources"]
        CoreRes["core<br/>configmaps,pvc,secrets,<br/>serviceaccounts,services<br/>full CRUD"]
        AppsRes["apps<br/>deployments<br/>full CRUD"]
        NetRes["networking.k8s.io<br/>networkpolicies<br/>full CRUD"]
        MonRes["monitoring.coreos.com<br/>servicemonitors<br/>full CRUD"]
    end

    subgraph MLflowServerResources["MLflow Server API Resources"]
        Namespaces_ML["core<br/>namespaces<br/>get,list,watch"]
        Secrets_ML["core<br/>secrets (mlflow-artifact-connection)<br/>get,list,watch"]
        MLflowConfigs_ML["mlflow.kubeflow.org<br/>mlflowconfigs<br/>get,list,watch"]
    end

    subgraph UserResources["User-Facing Pseudo-Resources"]
        ViewRes["mlflows, mlflows/status<br/>mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewayendpoints,<br/>gatewaymodeldefinitions<br/>get, list, watch"]
        EditRes["mlflows, mlflowconfigs<br/>datasets, experiments,<br/>registeredmodels,<br/>gatewaysecrets,<br/>gatewayendpoints,<br/>gatewaymodeldefinitions<br/>full CRUD + use"]
        IntegrationRes["datasets, experiments,<br/>registeredmodels<br/>get,list,create,update<br/>gatewayendpoints: get,list<br/>gatewayendpoints/use: create"]
    end

    %% Operator SA bindings
    SA_Op -->|bound via| CRB_Op
    SA_Op -->|bound via| RB_Op
    CRB_Op -->|grants| CR_Manager
    RB_Op -->|grants| CR_NSManager

    %% Operator ClusterRole permissions
    CR_Manager -->|manages| MLflows
    CR_Manager -->|manages| MLflowsStatus
    CR_Manager -->|manages| MLflowsFinalizers
    CR_Manager -->|reads| Namespaces_Op
    CR_Manager -->|reads| Secrets_Op
    CR_Manager -->|reads| MLflowConfigs_Op
    CR_Manager -->|manages| RBAC_Res
    CR_Manager -->|manages| ConsoleLinks
    CR_Manager -->|manages| HTTPRoutes

    %% Operator ns-scoped permissions
    CR_NSManager -->|manages| CoreRes
    CR_NSManager -->|manages| AppsRes
    CR_NSManager -->|manages| NetRes
    CR_NSManager -->|manages| MonRes

    %% MLflow SA bindings
    SA_MLflow -->|bound via| CRB_MLflow
    CRB_MLflow -->|grants| CR_MLflow

    %% MLflow ClusterRole permissions
    CR_MLflow -->|reads| Namespaces_ML
    CR_MLflow -->|reads| Secrets_ML
    CR_MLflow -->|reads| MLflowConfigs_ML

    %% Aggregate role resources
    CR_View -->|provides| ViewRes
    CR_Edit -->|provides| EditRes
    CR_Integration -->|provides| IntegrationRes

    %% Styling
    style SA_Op fill:#4a90e2,stroke:#333,color:#fff
    style SA_MLflow fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_NSManager fill:#f5a623,stroke:#333,color:#fff
    style CR_MLflow fill:#f5a623,stroke:#333,color:#fff
    style CR_View fill:#9b59b6,stroke:#333,color:#fff
    style CR_Edit fill:#9b59b6,stroke:#333,color:#fff
    style CR_Integration fill:#9b59b6,stroke:#333,color:#fff
    style CRB_Op fill:#e67e22,stroke:#333,color:#fff
    style CRB_MLflow fill:#e67e22,stroke:#333,color:#fff
    style RB_Op fill:#e67e22,stroke:#333,color:#fff
    style MLflows fill:#7ed321,stroke:#333
    style MLflowsStatus fill:#7ed321,stroke:#333
    style MLflowsFinalizers fill:#7ed321,stroke:#333
    style ConsoleLinks fill:#7ed321,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style RBAC_Res fill:#7ed321,stroke:#333
