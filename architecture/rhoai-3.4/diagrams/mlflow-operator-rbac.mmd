graph TD
    subgraph OperatorSA["Operator Service Account"]
        SA_Op["mlflow-operator-controller-manager<br/>(Namespace: redhat-ods-applications)"]
    end

    subgraph OperatorClusterBindings["Cluster-Scoped Bindings"]
        CRB_Manager["mlflow-operator-manager-rolebinding<br/>(ClusterRoleBinding)"]
        CRB_Metrics["mlflow-operator-metrics-auth-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph OperatorNSBindings["Namespace-Scoped Bindings"]
        RB_Manager["mlflow-operator-manager-rolebinding<br/>(RoleBinding, target namespace)"]
        RB_Leader["mlflow-operator-leader-election-rolebinding<br/>(RoleBinding, target namespace)"]
    end

    subgraph OperatorClusterRoles["Operator ClusterRoles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_MetricsAuth["metrics-auth-role<br/>(ClusterRole)"]
        CR_MetricsRead["metrics-reader<br/>(ClusterRole)"]
    end

    subgraph OperatorNSRoles["Operator Namespace Roles"]
        R_Manager["manager-role<br/>(Role, namespace-scoped)"]
        R_Leader["leader-election-role<br/>(Role)"]
    end

    subgraph ManagerClusterResources["ClusterRole: manager-role Resources"]
        MLflows["mlflow.opendatahub.io<br/>mlflows, mlflows/status,<br/>mlflows/finalizers<br/>→ full CRUD"]
        Namespaces["core<br/>namespaces<br/>→ get, list, watch"]
        Secrets_Named["core<br/>secrets (mlflow-artifact-connection)<br/>→ get, list, watch"]
        ConsoleLinks["console.openshift.io<br/>consolelinks<br/>→ full CRUD"]
        HTTPRoutes["gateway.networking.k8s.io<br/>httproutes<br/>→ full CRUD"]
        MLflowConfigs_Watch["mlflow.kubeflow.org<br/>mlflowconfigs<br/>→ get, list, watch"]
        RBAC_Resources["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings<br/>→ full CRUD"]
    end

    subgraph ManagerNSResources["Role: manager-role Resources (namespace)"]
        CoreResources["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>→ full CRUD"]
        Deployments["apps<br/>deployments<br/>→ full CRUD"]
        NetPolicies["networking.k8s.io<br/>networkpolicies<br/>→ full CRUD"]
        ServiceMonitors["monitoring.coreos.com<br/>servicemonitors<br/>→ full CRUD"]
    end

    subgraph MetricsResources["Metrics Auth Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews<br/>→ create"]
        MetricsURL["nonResourceURL: /metrics<br/>→ get"]
    end

    subgraph LeaderResources["Leader Election Resources"]
        LeaderConfigMaps["core<br/>configmaps, events<br/>→ full CRUD"]
        Leases["coordination.k8s.io<br/>leases<br/>→ full CRUD"]
    end

    %% Operator SA bindings
    SA_Op -->|"bound via"| CRB_Manager
    SA_Op -->|"bound via"| CRB_Metrics
    SA_Op -->|"bound via"| RB_Manager
    SA_Op -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    RB_Manager -->|"grants"| R_Manager
    RB_Leader -->|"grants"| R_Leader

    CR_Manager -->|"permits"| MLflows
    CR_Manager -->|"permits"| Namespaces
    CR_Manager -->|"permits"| Secrets_Named
    CR_Manager -->|"permits"| ConsoleLinks
    CR_Manager -->|"permits"| HTTPRoutes
    CR_Manager -->|"permits"| MLflowConfigs_Watch
    CR_Manager -->|"permits"| RBAC_Resources

    R_Manager -->|"permits"| CoreResources
    R_Manager -->|"permits"| Deployments
    R_Manager -->|"permits"| NetPolicies
    R_Manager -->|"permits"| ServiceMonitors

    CR_MetricsAuth -->|"permits"| TokenReviews
    CR_MetricsAuth -->|"permits"| SubjectAccessReviews
    CR_MetricsRead -->|"permits"| MetricsURL

    R_Leader -->|"permits"| LeaderConfigMaps
    R_Leader -->|"permits"| Leases

    %% ═══════════════════════════════════════════
    %% Deployed MLflow SA
    %% ═══════════════════════════════════════════

    subgraph DeployedSA["Deployed Service Account"]
        SA_MLflow["mlflow-sa<br/>(Namespace: target namespace)"]
    end

    subgraph DeployedBindings["Deployed Bindings"]
        CRB_MLflow["mlflow<br/>(ClusterRoleBinding)"]
    end

    subgraph DeployedRole["Deployed ClusterRole"]
        CR_MLflow["mlflow<br/>(ClusterRole)"]
    end

    subgraph DeployedResources["ClusterRole: mlflow Resources"]
        D_Namespaces["core<br/>namespaces<br/>→ get, list, watch"]
        D_Secrets["core<br/>secrets (mlflow-artifact-connection)<br/>→ get, list, watch"]
        D_MLflowConfigs["mlflow.kubeflow.org<br/>mlflowconfigs<br/>→ get, list, watch"]
    end

    SA_MLflow -->|"bound via"| CRB_MLflow
    CRB_MLflow -->|"grants"| CR_MLflow
    CR_MLflow -->|"permits"| D_Namespaces
    CR_MLflow -->|"permits"| D_Secrets
    CR_MLflow -->|"permits"| D_MLflowConfigs

    %% ═══════════════════════════════════════════
    %% Aggregate Roles (for end users)
    %% ═══════════════════════════════════════════

    subgraph AggregateRoles["Aggregate Roles (end users)"]
        CR_View["mlflow-view<br/>(aggregates into view/edit/admin)<br/>mlflows, mlflowconfigs, datasets,<br/>experiments, registeredmodels<br/>→ get, list, watch"]
        CR_Edit["mlflow-edit<br/>mlflows, mlflowconfigs, datasets,<br/>experiments, registeredmodels,<br/>gatewaysecrets<br/>→ full CRUD"]
        CR_Integration["mlflow-integration<br/>(for pipeline runners)<br/>datasets, experiments,<br/>registeredmodels → get,list,create,update<br/>gatewayendpoints/use → create"]
    end

    K8sView["Kubernetes view ClusterRole"] -.->|"aggregates"| CR_View
    K8sEdit["Kubernetes edit ClusterRole"] -.->|"aggregates"| CR_View
    K8sAdmin["Kubernetes admin ClusterRole"] -.->|"aggregates"| CR_View

