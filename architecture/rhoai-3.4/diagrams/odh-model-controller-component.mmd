graph TB
    subgraph ODH["odh-model-controller (Go Operator)"]
        direction TB

        subgraph Controllers["Controllers (8)"]
            ISVCCtrl["InferenceService<br/>Controller"]
            LLMCtrl["LLMInferenceService<br/>Controller"]
            GWCtrl["Gateway<br/>Controller"]
            SRCtrl["ServingRuntime<br/>Controller"]
            IGCtrl["InferenceGraph<br/>Controller"]
            NIMCtrl["NIM Account<br/>Controller"]
            CMCtrl["ConfigMap<br/>Controller"]
            SecretCtrl["Secret<br/>Controller"]
        end

        subgraph Reconcilers["Sub-Resource Reconcilers"]
            RouteReconciler["Route Reconciler"]
            CRBReconciler["ClusterRoleBinding<br/>Reconciler"]
            MetricsSvcReconciler["Metrics Service<br/>Reconciler"]
            SMReconciler["ServiceMonitor<br/>Reconciler"]
            DashReconciler["Metrics Dashboard<br/>Reconciler"]
            KEDAReconciler["KEDA<br/>Reconciler"]
            AuthPolicyReconciler["AuthPolicy<br/>Reconciler"]
            MRReconciler["Model Registry<br/>Reconciler"]
        end

        subgraph Webhooks["Webhooks (4)"]
            PodWH["Pod Mutating<br/>(Ray TLS injection)"]
            NIMAcctWH["NIM Account<br/>Validating"]
            IGValidWH["InferenceGraph<br/>Validating"]
            ISVCValidWH["InferenceService<br/>Validating + Mutating"]
        end

        subgraph NIMHandlers["NIM Handlers"]
            ValidationH["Validation Handler"]
            ConfigMapH["ConfigMap Handler"]
            TemplateH["Template Handler"]
            PullSecretH["Pull Secret Handler"]
        end

        DeltaProc["Delta Processor"]
    end

    subgraph API["model-serving-api (Go REST Server)"]
        GWHandler["Gateway Discovery<br/>Handler"]
        AuthMW["Auth Middleware<br/>(SSAR validation)"]
        CertReloader["TLS Cert Reloader<br/>(fsnotify)"]
    end

    %% Controller to Reconciler relationships
    ISVCCtrl -->|delegates| RouteReconciler
    ISVCCtrl -->|delegates| CRBReconciler
    ISVCCtrl -->|delegates| MetricsSvcReconciler
    ISVCCtrl -->|delegates| SMReconciler
    ISVCCtrl -->|delegates| DashReconciler
    ISVCCtrl -->|delegates| KEDAReconciler
    LLMCtrl -->|delegates| AuthPolicyReconciler
    ISVCCtrl -->|delegates| MRReconciler

    %% NIM Controller to Handlers
    NIMCtrl -->|sequential| ValidationH
    NIMCtrl -->|sequential| ConfigMapH
    NIMCtrl -->|sequential| TemplateH
    NIMCtrl -->|sequential| PullSecretH

    %% All reconcilers use Delta Processor
    RouteReconciler -->|uses| DeltaProc
    MetricsSvcReconciler -->|uses| DeltaProc
    SMReconciler -->|uses| DeltaProc

    %% CRD watches
    ISVC_CR["InferenceService CR"] -->|watched by| ISVCCtrl
    LLMISVC_CR["LLMInferenceService CR"] -->|watched by| LLMCtrl
    GW_CR["Gateway CR"] -->|watched by| GWCtrl
    SR_CR["ServingRuntime CR"] -->|watched by| SRCtrl
    IG_CR["InferenceGraph CR"] -->|watched by| IGCtrl
    NIM_CR["NIM Account CR"] -->|watched by| NIMCtrl

    %% Created resources
    ISVCCtrl -->|creates| Route["OpenShift Route"]
    ISVCCtrl -->|creates| SvcMon["ServiceMonitor"]
    ISVCCtrl -->|creates| NetPol["NetworkPolicy"]
    KEDAReconciler -->|creates| TrigAuth["KEDA TriggerAuth"]
    GWCtrl -->|creates| EnvoyF["EnvoyFilter"]
    LLMCtrl -->|creates| AuthPol["Kuadrant AuthPolicy"]
    NIMCtrl -->|creates| Template["OpenShift Template"]
    CMCtrl -->|aggregates| CABundle["CA Cert Bundle"]
    SecretCtrl -->|aggregates| StorageConfig["storage-config Secret"]

    %% API relationships
    Dashboard["RHOAI Dashboard"] -->|queries| GWHandler
    GWHandler -->|validates via| AuthMW

    %% Styling
    style ODH fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style API fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style Controllers fill:#fff3e0,stroke:#e65100
    style Reconcilers fill:#fce4ec,stroke:#c62828
    style Webhooks fill:#f3e5f5,stroke:#6a1b9a
    style NIMHandlers fill:#fff8e1,stroke:#f9a825
    style ISVC_CR fill:#f5a623,stroke:#333
    style LLMISVC_CR fill:#f5a623,stroke:#333
    style GW_CR fill:#f5a623,stroke:#333
    style SR_CR fill:#f5a623,stroke:#333
    style IG_CR fill:#f5a623,stroke:#333
    style NIM_CR fill:#f5a623,stroke:#333
    style Route fill:#7ed321,stroke:#333
    style SvcMon fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style TrigAuth fill:#7ed321,stroke:#333
    style EnvoyF fill:#7ed321,stroke:#333
    style AuthPol fill:#7ed321,stroke:#333
    style Template fill:#7ed321,stroke:#333
    style CABundle fill:#7ed321,stroke:#333
    style StorageConfig fill:#7ed321,stroke:#333
    style Dashboard fill:#b3e5fc,stroke:#0277bd
