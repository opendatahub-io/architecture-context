graph TB
    subgraph "odh-model-controller Operator"
        direction TB
        subgraph "InferenceService Subsystem"
            ISVCCtrl["InferenceService<br/>Controller"]
            RouteReconciler["Route<br/>Reconciler"]
            MetricsSvcReconciler["Metrics Service<br/>Reconciler"]
            SMReconciler["ServiceMonitor<br/>Reconciler"]
            DashboardReconciler["Dashboard<br/>Reconciler"]
            CRBReconciler["ClusterRoleBinding<br/>Reconciler"]
            KEDAReconciler["KEDA<br/>Reconciler"]
            MRReconciler["Model Registry<br/>Reconciler"]

            ISVCCtrl -->|orchestrates| RouteReconciler
            ISVCCtrl -->|orchestrates| MetricsSvcReconciler
            ISVCCtrl -->|orchestrates| SMReconciler
            ISVCCtrl -->|orchestrates| DashboardReconciler
            ISVCCtrl -->|orchestrates| CRBReconciler
            ISVCCtrl -->|orchestrates| KEDAReconciler
            ISVCCtrl -.->|optional| MRReconciler
        end

        subgraph "LLM Subsystem"
            LLMCtrl["LLMInferenceService<br/>Controller"]
            GWCtrl["Gateway<br/>Controller"]
            AuthPolicyReconciler["AuthPolicy<br/>Reconciler"]

            LLMCtrl -->|orchestrates| AuthPolicyReconciler
            GWCtrl -->|manages| EnvoyFilterRes["EnvoyFilter<br/>Resources"]
            GWCtrl -->|manages| GWAuthPolicy["Gateway<br/>AuthPolicy"]
        end

        subgraph "NIM Subsystem"
            NIMCtrl["NIM Account<br/>Controller"]
            APIKeyMgr["API Key<br/>Manager"]
            PullSecretHandler["Pull Secret<br/>Handler"]
            TemplateHandler["Template<br/>Handler"]

            NIMCtrl -->|pipeline| APIKeyMgr
            NIMCtrl -->|pipeline| PullSecretHandler
            NIMCtrl -->|pipeline| TemplateHandler
        end

        subgraph "Core Controllers"
            SecretCtrl["Secret<br/>Controller"]
            ConfigMapCtrl["ConfigMap<br/>Controller"]
            PodCtrl["Pod<br/>Controller"]
            SRCtrl["ServingRuntime<br/>Controller"]
        end

        subgraph "Webhooks"
            ISVCWebhook["InferenceService<br/>Webhook"]
            IGWebhook["InferenceGraph<br/>Webhook"]
            PodWebhook["Pod Webhook<br/>(Ray TLS)"]
            NIMWebhook["NIM Account<br/>Webhook"]
        end
    end

    subgraph "model-serving-api Server"
        APIServer["HTTPS Server<br/>8443/TCP"]
        GatewayHandler["Gateway Discovery<br/>Handler"]
        AuthMiddleware["Auth Middleware<br/>(Token Passthrough)"]

        APIServer --> AuthMiddleware
        AuthMiddleware --> GatewayHandler
    end

    %% CRDs Watched
    ISVC["InferenceService CR"]
    LLMISVC["LLMInferenceService CR"]
    SR["ServingRuntime CR"]
    NIMAccount["NIM Account CR"]
    IG["InferenceGraph CR"]
    DSC["DataScienceCluster CR"]

    ISVC -->|watched by| ISVCCtrl
    LLMISVC -->|watched by| LLMCtrl
    SR -->|watched by| SRCtrl
    NIMAccount -->|watched by| NIMCtrl
    IG -->|watched by| IGWebhook

    %% Resources Created
    ISVCCtrl -->|creates| Route["OpenShift Route"]
    ISVCCtrl -->|creates| SvcMon["ServiceMonitor"]
    ISVCCtrl -->|creates| MetricsSvc["Metrics Service"]
    ISVCCtrl -->|creates| TrigAuth["KEDA TriggerAuth"]
    LLMCtrl -->|creates| AuthPolicy["Kuadrant AuthPolicy"]
    GWCtrl -->|creates| EF["Istio EnvoyFilter"]
    NIMCtrl -->|creates| PullSecret["Pull Secret"]
    NIMCtrl -->|creates| Template["OCP Template"]
    PodCtrl -->|injects| RayTLS["Ray TLS Certs"]

    %% External Dependencies
    ISVCCtrl -->|calls| K8sAPI["Kubernetes API"]
    GWCtrl -->|references| Authorino["Authorino<br/>50051/TCP gRPC"]
    NIMCtrl -->|validates| NGC["NVIDIA NGC API<br/>443/TCP HTTPS"]
    GatewayHandler -->|discovers| GatewayAPI["Gateway API<br/>Gateways"]
    MRReconciler -.->|registers| ModelReg["Model Registry<br/>443/TCP HTTPS"]

    %% Dashboard Integration
    Dashboard["RHOAI Dashboard"] -->|GET /api/v1/gateways| APIServer

    %% Styling
    style ISVCCtrl fill:#4a90e2,color:#fff
    style LLMCtrl fill:#4a90e2,color:#fff
    style GWCtrl fill:#4a90e2,color:#fff
    style NIMCtrl fill:#4a90e2,color:#fff
    style SecretCtrl fill:#4a90e2,color:#fff
    style ConfigMapCtrl fill:#4a90e2,color:#fff
    style PodCtrl fill:#4a90e2,color:#fff
    style SRCtrl fill:#4a90e2,color:#fff
    style APIServer fill:#50c878,color:#fff
    style ISVC fill:#f5a623
    style LLMISVC fill:#f5a623
    style SR fill:#f5a623
    style NIMAccount fill:#f5a623
    style IG fill:#f5a623
    style DSC fill:#f5a623
    style Route fill:#7ed321
    style SvcMon fill:#7ed321
    style AuthPolicy fill:#7ed321
    style EF fill:#7ed321
    style PullSecret fill:#7ed321
    style Template fill:#7ed321
    style RayTLS fill:#7ed321
    style K8sAPI fill:#e8e8e8
    style Authorino fill:#e8e8e8
    style NGC fill:#e8e8e8
    style GatewayAPI fill:#e8e8e8
    style ModelReg fill:#e8e8e8
    style Dashboard fill:#d5e8d4
