// C4 Context Diagram: llama-stack-provider-ragas
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/llama-stack-provider-ragas.md

workspace {
    model {
        // Actors
        datascientist = person "Data Scientist" "Submits LLM evaluation requests via Llama Stack Eval API"

        // Primary System
        ragasProvider = softwareSystem "llama-stack-provider-ragas" "Ragas evaluation framework as Llama Stack provider plugin for LLM evaluation" {
            inlineProvider = container "RagasEvaluatorInline" "Runs Ragas evaluation in-process within Llama Stack server" "Python Provider"
            remoteProvider = container "RagasEvaluatorRemote" "Submits Ragas evaluation as Kubeflow Pipeline runs" "Python Provider"
            inlineLLM = container "LlamaStackInlineLLM" "Adapts Llama Stack inference API to Ragas BaseRagasLLM interface" "Python Wrapper"
            inlineEmbeddings = container "LlamaStackInlineEmbeddings" "Adapts Llama Stack embeddings API to Ragas BaseRagasEmbeddings interface" "Python Wrapper"
            remoteLLM = container "LlamaStackRemoteLLM" "Adapts Llama Stack client SDK to Ragas BaseRagasLLM (remote)" "Python Wrapper"
            remoteEmbeddings = container "LlamaStackRemoteEmbeddings" "Adapts Llama Stack client SDK to Ragas BaseRagasEmbeddings (remote)" "Python Wrapper"
            kfpComponents = container "KFP Pipeline Components" "retrieve_data + run_ragas_evaluation pipeline steps" "KFP/Python"
            compatLayer = container "Compatibility Layer" "Backward compat between llama_stack and llama_stack_api imports" "Python Module"
        }

        // Internal RHOAI Systems
        llamaStackServer = softwareSystem "Llama Stack Server" "Host process providing inference, embeddings, datasets, eval APIs" "Internal RHOAI" {
            tags "Internal"
        }
        llamaStackOperator = softwareSystem "Llama Stack Operator" "Manages LlamaStackDistribution CR deployments" "Internal RHOAI" {
            tags "Internal"
        }
        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines - remote evaluation execution engine" "Internal RHOAI" {
            tags "Internal"
        }
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Provides base image config via ConfigMap" "Internal RHOAI" {
            tags "Internal"
        }

        // External Systems
        s3 = softwareSystem "S3-compatible Storage" "Stores remote evaluation results" "External" {
            tags "External"
        }
        inferenceBackend = softwareSystem "Inference Backend (Ollama/vLLM)" "Provides LLM completions and embeddings" "External" {
            tags "External"
        }

        // Relationships - System Context
        datascientist -> ragasProvider "Submits evaluation via Llama Stack Eval API" "HTTP/8321"
        ragasProvider -> llamaStackServer "Runs within as provider plugin" "In-process Python API"
        llamaStackOperator -> llamaStackServer "Deploys and manages" "LlamaStackDistribution CR"
        ragasProvider -> dsp "Submits remote evaluation pipeline runs" "HTTPS/443 Bearer Token"
        ragasProvider -> s3 "Reads/writes evaluation results" "HTTPS/443 AWS IAM"
        ragasProvider -> inferenceBackend "LLM inference and embeddings (via Llama Stack)" "HTTP/11434"
        ragasProvider -> trustyaiOperator "Reads base image config" "ConfigMap API"

        // Container-level relationships
        inlineProvider -> inlineLLM "Uses for LLM calls"
        inlineProvider -> inlineEmbeddings "Uses for embedding calls"
        remoteProvider -> dsp "Creates pipeline runs" "HTTPS/443"
        remoteProvider -> s3 "Reads results via s3fs" "HTTPS/443"
        kfpComponents -> remoteLLM "Uses for remote LLM calls"
        kfpComponents -> remoteEmbeddings "Uses for remote embedding calls"
        kfpComponents -> llamaStackServer "Retrieves data and inference" "HTTP/8321"
        kfpComponents -> s3 "Writes evaluation results" "HTTPS/443"
        inlineLLM -> llamaStackServer "In-process inference API"
        inlineEmbeddings -> llamaStackServer "In-process embeddings API"
        remoteLLM -> llamaStackServer "Remote inference via client SDK" "HTTP/8321"
        remoteEmbeddings -> llamaStackServer "Remote embeddings via client SDK" "HTTP/8321"
    }

    views {
        systemContext ragasProvider "SystemContext" {
            include *
            autoLayout
        }

        container ragasProvider "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
