graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>Namespace: opendatahub"]
        PerClusterSA["{cluster} SA<br/>Namespace: user namespace"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB1["kuberay-operator<br/>(ClusterRoleBinding)"]
        CRB2["kuberay-operator-gateway-api<br/>(ClusterRoleBinding)"]
    end

    subgraph RoleBindings["Role Bindings (namespaced)"]
        RB1["leader-election<br/>(operator namespace)"]
        RB2["{cluster}<br/>(cluster namespace)"]
    end

    subgraph MainClusterRole["ClusterRole: kuberay-operator"]
        direction TB

        subgraph RayCRDs["ray.io CRDs"]
            RayClusters["rayclusters<br/>rayjobs<br/>rayservices<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
            RayFinalizers["rayclusters/finalizers<br/>rayjobs/finalizers<br/>rayservices/finalizers<br/><i>update</i>"]
            RayStatus["rayclusters/status<br/>rayjobs/status<br/>rayservices/status<br/><i>get,patch,update</i>"]
        end

        subgraph CoreResources["Core API Resources"]
            Pods["pods<br/><i>create,delete,deletecollection,<br/>get,list,patch,update,watch</i>"]
            Services["services, serviceaccounts,<br/>configmaps, events<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            Endpoints["endpoints<br/><i>get,list,watch</i>"]
            Secrets["secrets<br/><i>delete,get,list,watch</i>"]
            PodsProxy["pods/proxy, services/proxy<br/><i>create,get,patch,update</i>"]
        end

        subgraph ExtResources["Extended Resources"]
            Deployments["apps/deployments<br/><i>get,list,patch,update,watch</i>"]
            Jobs["batch/jobs<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            CertManagerRes["cert-manager.io/<br/>certificates, issuers<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            NetworkRes["networking.k8s.io/<br/>networkpolicies, ingresses<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        end

        subgraph GatewayRes["Gateway & Route Resources"]
            GatewayRead["gateway.networking.k8s.io/<br/>gateways<br/><i>get,list,watch</i>"]
            HTTPRoutes["gateway.networking.k8s.io/<br/>httproutes, referencegrants<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
            Routes["route.openshift.io/routes<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        end

        subgraph AuthResources["Auth & Config Resources"]
            TokenReview["authentication.k8s.io/<br/>tokenreviews<br/><i>create</i>"]
            SAR["authorization.k8s.io/<br/>subjectaccessreviews<br/><i>create</i>"]
            OSHAuth["config.openshift.io/<br/>authentications, oauths<br/><i>get,list,watch</i>"]
            OSHOp["operator.openshift.io/<br/>kubeapiservers<br/><i>get,list,watch</i>"]
            RBACRes["rbac.authorization.k8s.io/<br/>roles, rolebindings<br/><i>create,delete,get,list,watch</i>"]
            Leases["coordination.k8s.io/leases<br/><i>create,get,list,update</i>"]
        end
    end

    subgraph GatewayClusterRole["ClusterRole: kuberay-operator-gateway-api"]
        GWGateways["gateways<br/><i>get,list,watch</i>"]
        GWHTTPRoutes["httproutes,<br/>referencegrants<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
    end

    subgraph PerClusterRole["Per-RayCluster Role (namespaced)"]
        PCPods["pods<br/><i>get,list,watch</i>"]
        PCRayClusters["rayclusters<br/><i>get,patch</i>"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| RB1
    PerClusterSA -->|bound via| RB2

    CRB1 -->|grants| MainClusterRole
    CRB2 -->|grants| GatewayClusterRole
    RB1 -->|grants| Leases
    RB2 -->|grants| PerClusterRole

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style PerClusterSA fill:#4a90e2,stroke:#333,color:#fff
    style CRB1 fill:#e8e8e8,stroke:#333
    style CRB2 fill:#e8e8e8,stroke:#333
    style RB1 fill:#e8e8e8,stroke:#333
    style RB2 fill:#e8e8e8,stroke:#333
    style MainClusterRole fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style GatewayClusterRole fill:#fff3e0,stroke:#e65100,stroke-width:2px
    style PerClusterRole fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style RayClusters fill:#f5a623,stroke:#333
    style RayFinalizers fill:#f5a623,stroke:#333
    style RayStatus fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Endpoints fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style PodsProxy fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style CertManagerRes fill:#7ed321,stroke:#333
    style NetworkRes fill:#7ed321,stroke:#333
    style GatewayRead fill:#7ed321,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style TokenReview fill:#e57373,stroke:#333,color:#fff
    style SAR fill:#e57373,stroke:#333,color:#fff
    style OSHAuth fill:#7ed321,stroke:#333
    style OSHOp fill:#7ed321,stroke:#333
    style RBACRes fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style GWGateways fill:#7ed321,stroke:#333
    style GWHTTPRoutes fill:#7ed321,stroke:#333
    style PCPods fill:#7ed321,stroke:#333
    style PCRayClusters fill:#7ed321,stroke:#333
