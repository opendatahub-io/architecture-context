graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kuberay-operator<br/>Namespace: operator namespace"]
    end

    subgraph Bindings["Role Bindings"]
        CRB["kuberay-operator<br/>(ClusterRoleBinding)"]
        RB["leader-election-rolebinding<br/>(RoleBinding, operator ns)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["kuberay-operator<br/>(ClusterRole)"]
        LER["leader-election-role<br/>(Role, operator ns)"]
    end

    SA -->|"bound via"| CRB
    SA -->|"bound via"| RB
    CRB -->|"grants"| CR
    RB -->|"grants"| LER

    subgraph CoreResources["Core API Resources ('')"]
        Pods["pods<br/>pods/status<br/>pods/proxy"]
        Services["services<br/>services/status<br/>services/proxy"]
        ConfigMaps["configmaps"]
        Events["events"]
        Endpoints["endpoints"]
        Secrets["secrets"]
        SvcAccounts["serviceaccounts"]
    end

    subgraph RayResources["Ray API Resources (ray.io)"]
        RayClusters["rayclusters<br/>rayclusters/finalizers<br/>rayclusters/status"]
        RayJobs["rayjobs<br/>rayjobs/finalizers<br/>rayjobs/status"]
        RayServices["rayservices<br/>rayservices/finalizers<br/>rayservices/status"]
    end

    subgraph NetworkResources["Networking Resources"]
        NetworkPolicies["networkpolicies<br/>(networking.k8s.io)"]
        Ingresses["ingresses<br/>(networking.k8s.io + extensions)"]
        IngressClasses["ingressclasses<br/>(networking.k8s.io)"]
        HTTPRoutes["httproutes<br/>(gateway.networking.k8s.io)"]
        ReferenceGrants["referencegrants<br/>(gateway.networking.k8s.io)"]
        Gateways["gateways<br/>(gateway.networking.k8s.io)"]
        Routes["routes<br/>(route.openshift.io)"]
    end

    subgraph CertResources["Certificate Resources (cert-manager.io)"]
        Certificates["certificates<br/>certificates/status"]
        Issuers["issuers"]
    end

    subgraph RBACResources["RBAC Resources"]
        Roles["roles<br/>(rbac.authorization.k8s.io)"]
        RoleBindings["rolebindings<br/>(rbac.authorization.k8s.io)"]
        ClusterRolesR["clusterroles<br/>(rbac.authorization.k8s.io)"]
        ClusterRoleBindingsR["clusterrolebindings<br/>(rbac.authorization.k8s.io)"]
    end

    subgraph AuthResources["Auth & OpenShift Resources"]
        TokenReviews["tokenreviews<br/>(authentication.k8s.io)"]
        SAR["subjectaccessreviews<br/>(authorization.k8s.io)"]
        OSAuth["authentications, oauths<br/>(config.openshift.io)"]
        KubeAPIServers["kubeapiservers<br/>(operator.openshift.io)"]
        Deployments["deployments<br/>(apps)"]
        Jobs["jobs<br/>(batch)"]
    end

    subgraph LeaderElection["Leader Election Resources"]
        Leases["leases<br/>(coordination.k8s.io)"]
    end

