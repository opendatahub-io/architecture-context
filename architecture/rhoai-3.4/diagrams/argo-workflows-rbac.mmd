graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Argo[argo<br/>workflow-controller SA]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Cluster["argo-binding<br/>(cluster-wide)"]
        CRB_NS["argo-binding<br/>(namespace: argo)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Main["argo-cluster-role<br/>(workflow-controller)"]
        CR_NS["argo-role<br/>(namespace-scoped)"]
    end

    subgraph AggregateRoles["Aggregate Roles (User-Facing)"]
        CR_View["argo-aggregate-to-view<br/>get, list, watch"]
        CR_Edit["argo-aggregate-to-edit<br/>create, update, patch, delete"]
        CR_Admin["argo-aggregate-to-admin<br/>full access + workflowtasksets"]
    end

    subgraph ArgoCRDs["Argo CRD Resources (argoproj.io)"]
        Workflows["Workflows<br/>+ finalizers"]
        TaskSets["WorkflowTaskSets<br/>+ finalizers"]
        ArtifactGC["WorkflowArtifactGCTasks"]
        Templates["WorkflowTemplates<br/>+ finalizers"]
        ClusterTemplates["ClusterWorkflowTemplates"]
        CronWF["CronWorkflows<br/>+ finalizers"]
        TaskResults["WorkflowTaskResults"]
        EventBindings["WorkflowEventBindings"]
    end

    subgraph CoreResources["Core API Resources"]
        Pods["Pods<br/>+ pods/exec"]
        ConfigMaps["ConfigMaps"]
        PVCs["PersistentVolumeClaims<br/>+ finalizers"]
        SvcAccounts["ServiceAccounts"]
        Secrets["Secrets"]
        Events["Events"]
    end

    subgraph PolicyResources["Policy Resources"]
        PDBs["PodDisruptionBudgets"]
    end

    subgraph CoordinationResources["Coordination Resources"]
        Leases["Leases<br/>coordination.k8s.io"]
    end

    %% Bindings
    SA_Argo -->|bound via| CRB_Cluster
    SA_Argo -->|bound via| CRB_NS
    CRB_Cluster -->|grants| CR_Main
    CRB_NS -->|grants| CR_NS

    %% ClusterRole permissions - Argo CRDs
    CR_Main -->|"get, list, watch,<br/>create, update, patch, delete"| Workflows
    CR_Main -->|"get, list, watch,<br/>create, update, patch, delete"| TaskSets
    CR_Main -->|"get, list, watch,<br/>create, update, patch, delete"| ArtifactGC
    CR_Main -->|"get, list, watch"| Templates
    CR_Main -->|"get, list, watch"| ClusterTemplates
    CR_Main -->|"get, list, watch,<br/>update, patch, delete"| CronWF
    CR_Main -->|"list, watch,<br/>deletecollection"| TaskResults

    %% ClusterRole permissions - Core
    CR_Main -->|"create, get, list,<br/>watch, update, patch, delete"| Pods
    CR_Main -->|"get, watch, list"| ConfigMaps
    CR_Main -->|"create, update,<br/>delete, get"| PVCs
    CR_Main -->|"get, list"| SvcAccounts
    CR_Main -->|"get"| Secrets
    CR_Main -->|"create, patch"| Events

    %% Policy
    CR_Main -->|"create, get, delete"| PDBs

    %% Namespace Role
    CR_NS -->|"create, get, update"| Leases

    %% Aggregate roles
    CR_View -->|"get, list, watch"| Workflows
    CR_View -->|"get, list, watch"| EventBindings
    CR_View -->|"get, list, watch"| Templates
    CR_View -->|"get, list, watch"| CronWF
    CR_View -->|"get, list, watch"| TaskResults

    CR_Edit -->|"create, update,<br/>patch, delete"| Workflows
    CR_Edit -->|"create, update,<br/>patch, delete"| Templates
    CR_Edit -->|"create, update,<br/>patch, delete"| CronWF

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style CR_Main fill:#f5a623,stroke:#333,color:#000
    style CR_NS fill:#f5a623,stroke:#333,color:#000
    style CR_View fill:#d5e8d4,stroke:#82b366,color:#000
    style CR_Edit fill:#ffe6cc,stroke:#d79b00,color:#000
    style CR_Admin fill:#f8cecc,stroke:#b85450,color:#000
    style Workflows fill:#7ed321,stroke:#333,color:#000
    style TaskSets fill:#7ed321,stroke:#333,color:#000
    style ArtifactGC fill:#7ed321,stroke:#333,color:#000
    style Templates fill:#7ed321,stroke:#333,color:#000
    style ClusterTemplates fill:#7ed321,stroke:#333,color:#000
    style CronWF fill:#7ed321,stroke:#333,color:#000
    style TaskResults fill:#7ed321,stroke:#333,color:#000
    style EventBindings fill:#7ed321,stroke:#333,color:#000
