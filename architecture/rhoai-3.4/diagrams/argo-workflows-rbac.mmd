graph TD
    subgraph "Service Accounts"
        SA_Argo[argo<br/>workflow-controller SA]
        SA_Server[argo-server<br/>argo-server SA<br/>(upstream only)]
    end

    subgraph "ClusterRole Bindings"
        CRB_Argo[argo-cluster-role<br/>ClusterRoleBinding]
        CRB_Server[argo-server-cluster-role<br/>ClusterRoleBinding]
        RB_Argo[argo-role<br/>RoleBinding<br/>(namespace-scoped)]
    end

    subgraph "ClusterRoles"
        CR_Argo[argo-cluster-role]
        CR_Server[argo-server-cluster-role]
        CR_View[argo-aggregate-to-view]
        CR_Edit[argo-aggregate-to-edit]
        CR_Admin[argo-aggregate-to-admin]
    end

    subgraph "Core API Resources"
        Pods["core<br/>pods, pods/exec"]
        ConfigMaps["core<br/>configmaps"]
        PVCs["core<br/>persistentvolumeclaims"]
        ServiceAccounts["core<br/>serviceaccounts"]
        Events["core<br/>events"]
        Secrets["core<br/>secrets<br/>(resourceName: agent-ca-certs)"]
        PDBs["policy<br/>poddisruptionbudgets"]
    end

    subgraph "Argo CRD Resources (argoproj.io)"
        Workflows["Workflows<br/>workflows/finalizers"]
        CronWorkflows["CronWorkflows<br/>cronworkflows/finalizers"]
        WFTemplates["WorkflowTemplates<br/>workflowtemplates/finalizers"]
        ClusterWFTemplates["ClusterWorkflowTemplates<br/>clusterworkflowtemplates/finalizers"]
        TaskResults["WorkflowTaskResults"]
        TaskSets["WorkflowTaskSets<br/>workflowtasksets/finalizers"]
        ArtifactGC["WorkflowArtifactGCTasks"]
        EventBindings["WorkflowEventBindings"]
    end

    %% Bindings
    SA_Argo -->|bound via| CRB_Argo
    SA_Argo -->|bound via| RB_Argo
    SA_Server -->|bound via| CRB_Server
    CRB_Argo -->|grants| CR_Argo
    CRB_Server -->|grants| CR_Server

    %% argo-cluster-role permissions
    CR_Argo -->|"create, get, list,<br/>watch, update,<br/>patch, delete"| Pods
    CR_Argo -->|"get, watch, list"| ConfigMaps
    CR_Argo -->|"create, update,<br/>delete, get"| PVCs
    CR_Argo -->|"get, list"| ServiceAccounts
    CR_Argo -->|"create, patch"| Events
    CR_Argo -->|"get (named)"| Secrets
    CR_Argo -->|"create, get, delete"| PDBs
    CR_Argo -->|"full CRUD +<br/>watch, list"| Workflows
    CR_Argo -->|"full CRUD +<br/>watch, list"| TaskSets
    CR_Argo -->|"full CRUD +<br/>watch, list"| ArtifactGC
    CR_Argo -->|"get, list, watch"| WFTemplates
    CR_Argo -->|"get, list, watch"| ClusterWFTemplates
    CR_Argo -->|"list, watch,<br/>deletecollection"| TaskResults
    CR_Argo -->|"full CRUD +<br/>watch, list"| CronWorkflows

    %% argo-server-cluster-role permissions
    CR_Server -->|"get, watch, list"| ConfigMaps
    CR_Server -->|"get, create"| Secrets
    CR_Server -->|"get, list, watch,<br/>delete"| Pods
    CR_Server -->|"watch, create, patch"| Events
    CR_Server -->|"get, list, watch"| ServiceAccounts
    CR_Server -->|"full CRUD"| Workflows
    CR_Server -->|"full CRUD"| CronWorkflows
    CR_Server -->|"full CRUD"| WFTemplates
    CR_Server -->|"full CRUD"| ClusterWFTemplates
    CR_Server -->|"full CRUD"| EventBindings

    %% Aggregate roles
    CR_View -->|"get, list, watch<br/>(all argoproj.io)"| Workflows
    CR_Edit -->|"full CRUD<br/>(all argoproj.io)"| Workflows
    CR_Admin -->|"full CRUD +<br/>workflowtasksets"| Workflows

    %% Styling
    style SA_Argo fill:#4a90e2,stroke:#333,color:#fff
    style SA_Server fill:#4a90e2,stroke:#333,color:#fff
    style CR_Argo fill:#f5a623,stroke:#333
    style CR_Server fill:#f5a623,stroke:#333
    style CR_View fill:#f5a623,stroke:#333
    style CR_Edit fill:#f5a623,stroke:#333
    style CR_Admin fill:#f5a623,stroke:#333
    style CRB_Argo fill:#e8e8e8,stroke:#333
    style CRB_Server fill:#e8e8e8,stroke:#333
    style RB_Argo fill:#e8e8e8,stroke:#333
    style Workflows fill:#7ed321,stroke:#333
    style CronWorkflows fill:#7ed321,stroke:#333
    style WFTemplates fill:#7ed321,stroke:#333
    style ClusterWFTemplates fill:#7ed321,stroke:#333
    style TaskResults fill:#7ed321,stroke:#333
    style TaskSets fill:#7ed321,stroke:#333
    style ArtifactGC fill:#7ed321,stroke:#333
    style EventBindings fill:#7ed321,stroke:#333
    style Pods fill:#dae8fc,stroke:#6c8ebf
    style ConfigMaps fill:#dae8fc,stroke:#6c8ebf
    style PVCs fill:#dae8fc,stroke:#6c8ebf
    style ServiceAccounts fill:#dae8fc,stroke:#6c8ebf
    style Events fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#dae8fc,stroke:#6c8ebf
    style PDBs fill:#dae8fc,stroke:#6c8ebf
