// MLServer C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/MLServer.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries ML models via KServe"

        mlserver = softwareSystem "MLServer" "Python-based inference server implementing V2 Inference Protocol for serving ML models over REST and gRPC" {
            restServer = container "REST Server" "Serves V2 Inference Protocol over HTTP" "FastAPI/Uvicorn, Port 8080/TCP"
            grpcServer = container "gRPC Server" "Serves V2 Inference Protocol over gRPC" "grpc.aio, Port 8081/TCP"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics" "FastAPI/Uvicorn, Port 8082/TCP"
            dataPlane = container "DataPlane" "Routes inference requests to models" "Python"
            adaptiveBatcher = container "Adaptive Batcher" "Groups requests for batch processing" "Python"
            responseCache = container "Response Cache" "LRU cache for repeated predictions" "Python"
            inferencePool = container "Inference Pool Registry" "Manages parallel inference workers" "Python multiprocessing"
            kafkaServer = container "Kafka Server" "Optional async inference via Kafka" "aiokafka"
            sklearnRuntime = container "sklearn Runtime" "Scikit-Learn model serving" "Python"
            xgboostRuntime = container "XGBoost Runtime" "XGBoost model serving" "Python"
            lightgbmRuntime = container "LightGBM Runtime" "LightGBM model serving" "Python"
            onnxRuntime = container "ONNX Runtime" "ONNX model serving" "Python"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Manages model serving infrastructure and deploys MLServer containers" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic management, and sidecar injection" "External"
        gatewayAPI = softwareSystem "Gateway API + kube-rbac-proxy" "External access with authentication for RHOAI 3.x" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"
        kafka = softwareSystem "Kafka" "Async inference message broker" "External"
        modelStorage = softwareSystem "Model Storage (PVC/S3)" "ML model artifact storage mounted at /mnt/models" "External"

        // User interactions
        user -> kserve "Creates InferenceService via kubectl/dashboard"
        kserve -> mlserver "Deploys and manages MLServer pods"

        // Client interactions (via infrastructure)
        user -> gatewayAPI "Sends inference requests" "HTTPS"
        gatewayAPI -> istio "Routes to pod with auth" "mTLS"
        istio -> mlserver "Forwards to MLServer" "HTTP/gRPC (plaintext inside mesh)"

        // Internal container relationships
        restServer -> dataPlane "Routes REST requests"
        grpcServer -> dataPlane "Routes gRPC requests"
        kafkaServer -> dataPlane "Routes Kafka requests"
        dataPlane -> adaptiveBatcher "Batches requests"
        dataPlane -> responseCache "Checks cache"
        dataPlane -> inferencePool "Dispatches to workers"
        dataPlane -> sklearnRuntime "Invokes predict()"
        dataPlane -> xgboostRuntime "Invokes predict()"
        dataPlane -> lightgbmRuntime "Invokes predict()"
        dataPlane -> onnxRuntime "Invokes predict()"

        // External integrations
        mlserver -> modelStorage "Loads model artifacts" "Filesystem /mnt/models"
        mlserver -> otelCollector "Exports traces" "gRPC OTLP"
        mlserver -> kafka "Consumes/produces async inference" "TCP/9092"
        prometheus -> mlserver "Scrapes metrics" "HTTP/8082"
    }

    views {
        systemContext mlserver "SystemContext" {
            include *
            autoLayout
        }

        container mlserver "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
