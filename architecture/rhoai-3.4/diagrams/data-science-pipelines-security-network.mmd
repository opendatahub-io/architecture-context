graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / SDK / Dashboard"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["Platform Gateway (HTTPRoute)<br/>443/TCP → 8888/TCP<br/>TLS 1.2+ (SIMPLE)<br/>kube-rbac-proxy (TokenReview)"]
    end

    subgraph AppLayer["APPLICATION LAYER (DSP Namespace)"]
        direction TB

        subgraph APIGroup["API Server"]
            APIServer["API Server<br/>SA: ml-pipeline<br/>8888/TCP HTTP | 8887/TCP gRPC | 8443/TCP webhook<br/>AuthN: TokenReview (pipelines.kubeflow.org)<br/>AuthZ: SubjectAccessReview<br/>FIPS: strictfipsruntime"]
        end

        subgraph ArgoGroup["Argo Workflow Pods"]
            direction LR
            DriverPod["Driver (init container)<br/>SA: pipeline-runner<br/>FIPS: strictfipsruntime"]
            LauncherPod["Launcher (sidecar)<br/>SA: pipeline-runner<br/>FIPS: dual binary"]
        end

        subgraph Controllers["Controllers"]
            direction LR
            PA["Persistence Agent<br/>SA: ml-pipeline-persistenceagent<br/>FIPS: strictfipsruntime"]
            SWC["Scheduled Workflow Controller<br/>SA: ml-pipeline-scheduledworkflow<br/>9090/TCP metrics<br/>FIPS: strictfipsruntime"]
        end

        subgraph WebhookGroup["Webhooks"]
            CacheSvr["Cache Server<br/>SA: kubeflow-pipelines-cache<br/>443→8443/TCP HTTPS<br/>Auth: AdmissionReview"]
        end
    end

    subgraph DataStores["DATA STORES"]
        direction LR
        DB["MySQL / PostgreSQL<br/>3306/5432 TCP<br/>Optional TLS<br/>Username/Password"]
        ObjStore["S3 / MinIO / GCS<br/>9000/443 TCP<br/>HTTP/HTTPS<br/>Access Key / IAM"]
        MLMD["ML Metadata<br/>8080/TCP gRPC<br/>Optional TLS"]
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP scrape<br/>No auth"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → API
    Gateway -->|"HTTP/8888 or gRPC/8887<br/>Optional TLS<br/>Bearer Token / HTTP Header"| APIServer

    %% API Server → Data Stores
    APIServer -->|"TCP/3306<br/>Optional TLS<br/>Username/Password"| DB
    APIServer -->|"HTTP(S)/9000 or 443<br/>Optional TLS<br/>Access Key"| ObjStore
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% Argo Workflow Pods
    K8sAPI -->|"Creates Argo Workflows"| DriverPod
    DriverPod -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD
    DriverPod -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token"| APIServer
    DriverPod -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    LauncherPod -->|"gRPC/8080<br/>Optional TLS<br/>None"| MLMD
    LauncherPod -->|"HTTP(S)/9000 or 443<br/>Optional TLS<br/>Access Key / IAM"| ObjStore
    LauncherPod -->|"HTTPS/443<br/>TLS<br/>SA Token (Secret reads)"| K8sAPI

    %% Controllers
    PA -->|"HTTPS/443 Watch<br/>TLS<br/>SA Token"| K8sAPI
    PA -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token (SA)"| APIServer
    SWC -->|"HTTPS/443 Watch<br/>TLS<br/>SA Token"| K8sAPI
    SWC -->|"gRPC/8887<br/>Optional TLS<br/>Bearer Token (SA)"| APIServer

    %% Cache Server
    K8sAPI -->|"HTTPS/443→8443<br/>TLS<br/>AdmissionReview"| CacheSvr
    CacheSvr -->|"TCP/3306<br/>Optional TLS<br/>Username/Password"| DB

    %% Monitoring
    Prometheus -.->|"HTTP/8888<br/>No encryption<br/>No auth"| APIServer
    Prometheus -.->|"HTTP/9090<br/>No encryption<br/>No auth"| SWC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef datastore fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class APIServer,DriverPod,LauncherPod,PA,SWC,CacheSvr app
    class DB,ObjStore,MLMD datastore
    class K8sAPI platform
    class Prometheus monitoring
