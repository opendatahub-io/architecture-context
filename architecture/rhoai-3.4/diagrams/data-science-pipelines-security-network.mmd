        end
    end

    subgraph InternalSvc["INTERNAL SERVICES (In-Cluster)"]
        DB["MySQL/MariaDB/PostgreSQL<br/>3306/5432/TCP<br/>DB wire protocol<br/>plaintext<br/>Auth: username/password<br/>(mysql-secret)"]
