    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS<br/>Session/OAuth"| IstioGW

    %% Ingress to Services
    IstioGW -->|"HTTP/80<br/>Istio mTLS<br/>kubeflow-userid header"| MLUI

    %% Internal flows
    MLUI -->|"HTTP/8888<br/>Istio mTLS<br/>Bearer Token"| APIServer
    APIServer -->|"HTTP/8888<br/>plaintext"| VizServer
    PersistenceAgent -->|"HTTP/8888<br/>Optional TLS<br/>SA Token"| APIServer
    MetaWriter -->|"gRPC/8080<br/>plaintext"| MLMD
    MetaEnvoy -->|"gRPC/8080<br/>plaintext"| MLMD

    %% Service to data stores
    APIServer -->|"DB/3306 or 5432<br/>plaintext<br/>username/password"| DB
    APIServer -->|"HTTP/9000 or HTTPS/443<br/>Optional TLS<br/>Access Key"| S3
    CacheServer -->|"DB/3306 or 5432<br/>plaintext<br/>username/password"| DB

    %% Service to K8s API
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    ScheduledWF -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    PersistenceAgent -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    ViewerCtrl -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% K8s API to webhook
    K8sAPI -->|"HTTPS/443→8443<br/>TLS<br/>K8s client cert"| CacheServer

