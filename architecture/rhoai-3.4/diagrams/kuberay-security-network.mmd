graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Platform Operator"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)<br/>Namespace: openshift-ingress"]
        Gateway["data-science-gateway<br/>443/TCP → HTTPRoute<br/>TLS 1.3<br/>OIDC / OAuth"]
    end

    subgraph AuthProxy["AUTH PROXY (Head Pod Sidecar)<br/>Namespace: {user-namespace}"]
        direction LR
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS TLS<br/>SubjectAccessReview<br/>(services/get)"]
        OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS TLS (self-signed)<br/>OpenShift OAuth<br/>(pods/get)"]
    end

    subgraph RayCluster["RAY CLUSTER<br/>Namespace: {user-namespace}"]
        direction TB

        subgraph HeadPodGroup["Head Pod (UID 1000, run-as-ray-user SCC)"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP<br/>No encryption"]
            GCS["GCS Server<br/>6379/TCP<br/>None or mTLS"]
            ClientPort["Client Port<br/>10001/TCP<br/>None or mTLS"]
            ServeProxy["Serve Proxy<br/>8000/TCP HTTP<br/>No encryption"]
            Metrics_Head["Metrics<br/>8080/TCP HTTP"]
        end

        subgraph WorkerPods["Worker Pods (UID 1000, run-as-ray-user SCC)"]
            WorkerClient["Client Port<br/>10001/TCP<br/>None or mTLS"]
            WorkerMetrics["Metrics<br/>8080/TCP HTTP"]
        end

        HeadSvc["{cluster}-head-svc<br/>Headless ClusterIP:None<br/>6379, 8265, 10001, 8080, 8000"]
        ServeSvc["{cluster}-serve-svc<br/>ClusterIP<br/>8000/TCP HTTP"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE<br/>(redhat-ods-applications)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP<br/>Webhooks: 9443/TCP HTTPS"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount token auth"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        CertMgr["cert-manager<br/>CRD API<br/>mTLS PKI:<br/>SelfSigned → CA (10yr) → Certs (90d)"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>Metrics scrape"]
        OAuthConfig["OpenShift Auth Config<br/>443/TCP HTTPS TLS 1.2+<br/>config.openshift.io"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.3<br/>OIDC / OAuth"| Gateway

    %% Ingress → Auth Proxy
    Gateway -->|"HTTPS/8443<br/>TLS<br/>Token forwarded"| KRBP
    Gateway -.->|"HTTPS/8443<br/>TLS (self-signed)<br/>OAuth"| OAuthProxy

    %% Auth Proxy → Dashboard
    KRBP -->|"HTTP/8265<br/>plaintext (localhost)<br/>SubjectAccessReview verified"| Dashboard
    OAuthProxy -.->|"HTTP/8265<br/>plaintext (localhost)<br/>OAuth verified"| Dashboard

    %% KRBP → K8s for SAR
    KRBP -->|"HTTPS/443<br/>SubjectAccessReview"| K8sAPI

    %% Intra-cluster communication
    GCS <-->|"TCP/6379<br/>None or mTLS<br/>(cert-manager)"| WorkerClient
    ClientPort <-->|"TCP/10001<br/>None or mTLS"| WorkerClient

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator → Ray Dashboard
    Operator -->|"HTTP/8265<br/>No encryption<br/>No auth"| Dashboard

    %% Operator → Serve proxy
    Operator -->|"HTTP/8000<br/>No encryption"| ServeProxy

    %% K8s API → Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS (serving cert)<br/>API server cert"| Operator

    %% Platform services
    Operator -->|"CRD API<br/>Issuer, Certificate"| CertMgr
    Prometheus -->|"HTTP/8080<br/>scrape"| Metrics_Head
    Prometheus -->|"HTTP/8080<br/>scrape"| WorkerMetrics
    Prometheus -->|"HTTP/8080<br/>scrape"| Operator
    Operator -->|"HTTPS/443<br/>read auth config"| OAuthConfig

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef raycluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBP,OAuthProxy authproxy
    class Dashboard,GCS,ClientPort,ServeProxy,Metrics_Head,WorkerClient,WorkerMetrics,HeadSvc,ServeSvc raycluster
    class Operator operator
    class K8sAPI controlplane
    class CertMgr,Prometheus,OAuthConfig platform
