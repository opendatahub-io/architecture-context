graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["External User<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS - Gateway API (DMZ)"]
        Gateway["RHOAI Gateway<br/>(data-science-gateway)<br/>443/TCP → HTTPRoute<br/>TLS 1.2+ terminated"]
    end

    subgraph AuthProxy["AUTH PROXY (Trust Boundary)"]
        KRBP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS (cert-manager)<br/>TokenReview + SubjectAccessReview"]
        OAuthProxy["oauth-proxy sidecar<br/>(IntegratedOAuth mode)<br/>Cookie-based session"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Image: kuberay-operator:v1.4.4"]
        Metrics["Metrics: 8080/TCP HTTP"]
        Probes["Probes: 8081/TCP HTTP"]
        WebhookSvc["Webhook Service<br/>443/TCP → 9443/TCP<br/>HTTPS (OpenShift serving certs)<br/>Mutual TLS with API server"]
    end

    subgraph UserNS["USER NAMESPACE (Ray Workloads)"]
        direction TB

        subgraph HeadPodGroup["Head Pod"]
            HeadContainer["ray-head container<br/>8265, 10001, 6379, 8080"]
            AuthSidecar["Auth sidecar<br/>8443/TCP HTTPS"]
        end

        HeadSvc["head-svc ClusterIP<br/>8265, 10001, 6379, 8080"]
        ServeSvc["serve-svc ClusterIP<br/>8000/TCP HTTP"]
        HeadlessSvc["headless-svc<br/>Worker peer discovery"]

        subgraph WorkerPodGroup["Worker Pods"]
            WorkerInit["Init: GCS health check<br/>polls 6379 until ready"]
            WorkerContainer["ray-worker container"]
        end

        NetPol["NetworkPolicies<br/>annotation-gated"]
        MTLSCerts["mTLS Certificates<br/>cert-manager managed<br/>90d duration / 15d renewal"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
        CertManager["cert-manager<br/>Certificate + Issuer CRs"]
        RedisStore["Redis (optional)<br/>6379/TCP<br/>Optional TLS<br/>Optional password"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>Metrics scraping"]
        OSHOAuth["OpenShift OAuth Server<br/>(IntegratedOAuth mode)"]
        OSHConfig["OpenShift API<br/>config.openshift.io<br/>443/TCP HTTPS read-only"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS (cert-manager)<br/>Bearer Token forwarded"| KRBP
    KRBP -->|"HTTP/8265<br/>localhost<br/>pre-authorized"| HeadContainer
    KRBP -->|"HTTPS/443<br/>TokenReview<br/>SubjectAccessReview"| K8sAPI
    OAuthProxy -.->|"delegates auth"| OSHOAuth

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTP/8265<br/>Job status polling"| HeadContainer
    Operator -->|"HTTPS/443<br/>Certificate CRs"| CertManager
    Operator -->|"HTTPS/443<br/>read-only"| OSHConfig
    WebhookSvc -->|"HTTPS/9443<br/>Mutual TLS"| K8sAPI

    %% Head ↔ Worker
    WorkerInit -->|"6379/TCP<br/>GCS health check<br/>None or mTLS"| HeadContainer
    WorkerContainer -->|"6379, 10001/TCP<br/>Ray runtime<br/>None or mTLS"| HeadContainer

    %% Head → External
    HeadContainer -->|"6379/TCP<br/>Redis protocol<br/>Optional TLS"| RedisStore

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>scrape metrics"| Metrics
    Prometheus -->|"HTTP/8080<br/>scrape metrics"| HeadContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef operatorns fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBP,OAuthProxy authproxy
    class Operator,Metrics,Probes,WebhookSvc operatorns
    class HeadContainer,AuthSidecar,HeadSvc,ServeSvc,HeadlessSvc,WorkerInit,WorkerContainer,NetPol,MTLSCerts userns
    class K8sAPI,CertManager,RedisStore,Prometheus,OSHOAuth,OSHConfig externalservice
