%% KubeRay Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        DSGateway["data-science-gateway<br/>openshift-ingress namespace<br/>443/TCP → HTTPRoute<br/>TLS 1.2+"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        KRBP["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS TLS<br/>OIDC/OAuth → SubjectAccessReview<br/>(pods/get in cluster ns)"]
    end

    subgraph RayCluster["RAY CLUSTER (User Namespace)"]
        direction TB

        subgraph HeadPodGroup["Ray Head Pod (SCC: run-as-ray-user, UID 1000)"]
            Dashboard["Ray Dashboard<br/>8265/TCP HTTP"]
            ClientSvr["Client Server<br/>10001/TCP gRPC"]
            GCSSvr["GCS Server<br/>6379/TCP gRPC"]
            HeadMetrics["Metrics<br/>8080/TCP HTTP"]
        end

        Workers["Ray Worker Pods<br/>SCC: run-as-ray-user, UID 1000<br/>mTLS certs (90d/15d renewal)"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>Metrics: 8080/TCP HTTP"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS<br/>OpenShift serving cert"]
    end

    subgraph PlatformSvcs["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>SA Token Auth"]
        CertMgr["cert-manager<br/>CRD API<br/>CA: 10yr/30d renewal<br/>Node: 90d/15d renewal"]
        Prometheus["Prometheus<br/>8080/TCP HTTP<br/>Metrics Scrape"]
        Volcano["Volcano Scheduler<br/>443/TCP HTTPS<br/>(optional)"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| DSGateway
    DSGateway -->|"HTTPS/8443<br/>TLS<br/>OIDC/OAuth"| KRBP
    KRBP -->|"HTTP/8265<br/>plaintext (localhost)<br/>After auth"| Dashboard

    %% Ray cluster internal
    ClientSvr <-->|"gRPC/10001<br/>mTLS (optional)<br/>cert-manager certs"| Workers
    GCSSvr <-->|"gRPC/6379<br/>mTLS (optional)<br/>cert-manager certs"| Workers

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"HTTP/8265<br/>plaintext/mTLS"| Dashboard
    Operator -->|"Creates Issuers/Certs"| CertMgr
    Webhook -->|"HTTPS/443<br/>TLS 1.2+<br/>Webhook client cert"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>Scrape"| HeadMetrics
    Prometheus -->|"HTTP/8080<br/>Scrape"| Operator

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#000
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef raycluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#000
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#000

    class User external
    class DSGateway ingress
    class KRBP auth
    class Dashboard,ClientSvr,GCSSvr,HeadMetrics,Workers raycluster
    class Operator,Webhook operator
