graph LR
    KServe["KServe<br/>(Dual Controller)"]

    %% ─── External Dependencies (Required) ───────────────────────────
    KServe -->|"container orchestration<br/>6443/TCP HTTPS"| K8s["Kubernetes 1.28+"]
    KServe -->|"HTTPRoute/Gateway<br/>(required for LLMInferenceService)"| GatewayAPI["Gateway API v1"]
    KServe -->|"InferencePool<br/>(required for LLMInferenceService)"| InfGW["Inference Gateway<br/>Extension v1/v1alpha2"]

    %% ─── External Dependencies (Optional) ───────────────────────────
    KServe -.->|"scale-to-zero<br/>(serverless mode)"| Knative["Knative Serving 1.x"]
    KServe -.->|"VirtualService/mTLS<br/>DestinationRules (OCP)"| Istio["Istio 1.x"]
    KServe -.->|"Prometheus metric<br/>autoscaling"| KEDA["KEDA v2.17+"]
    KServe -.->|"metrics collection<br/>sidecar"| OTEL["OpenTelemetry<br/>Operator v0.113+"]
    KServe -.->|"PodMonitor<br/>ServiceMonitor"| PromOp["Prometheus<br/>Operator v0.89+"]
    KServe -.->|"multi-node<br/>distributed inference"| LWS["LeaderWorkerSet v1"]
    KServe -.->|"LLM autoscaling<br/>desired replicas"| WVA["WVA v0.6+<br/>(llmd.ai/v1alpha1)"]
    KServe -.->|"AuthPolicy<br/>auth enforcement (OCP)"| Kuadrant["Kuadrant /<br/>Red Hat Connectivity Link"]
    KServe -.->|"TLS certs<br/>(upstream only)"| CertManager["cert-manager v1"]

    %% ─── Internal RHOAI Platform Dependencies ──────────────────────
    RhodsOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize<br/>config/overlays/odh/"| KServe
    KServe -->|"HTTPRoutes reference<br/>platform Gateway"| PlatformGW["Platform Gateway<br/>(data-science-gateway)"]
    KServe -->|"webhook + workload<br/>TLS cert signing"| ServiceCA["OpenShift<br/>service-ca"]
    KServe -->|"LLM workload<br/>pod security"| SCC["OpenShift SCC<br/>(openshift-ai-llm-<br/>inferenceservice-scc)"]

    %% ─── Peer Components that Integrate with KServe ─────────────────
    ODHModelCtrl["odh-model-controller"] -->|"mutates/validates<br/>InferenceService/InferenceGraph"| KServe
    Dashboard["ODH Dashboard"] -.->|"UI management"| KServe
    Pipelines["Data Science<br/>Pipelines"] -.->|"auto deploy models"| KServe

    %% ─── External Services (Egress) ─────────────────────────────────
    KServe -->|"model download<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS"| GCS["Google Cloud<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS"| AzureBlob["Azure Blob<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS"| HFHub["HuggingFace Hub"]
    KServe -->|"model image pull<br/>443/TCP HTTPS"| OCIReg["OCI Registries"]

    %% ─── Styling ─────────────────────────────────────────────────────
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external (solid)
    style K8s fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style InfGW fill:#999,stroke:#333,color:#fff

    %% Optional external (lighter)
    style Knative fill:#bbb,stroke:#666,color:#333
    style Istio fill:#bbb,stroke:#666,color:#333
    style KEDA fill:#bbb,stroke:#666,color:#333
    style OTEL fill:#bbb,stroke:#666,color:#333
    style PromOp fill:#bbb,stroke:#666,color:#333
    style LWS fill:#bbb,stroke:#666,color:#333
    style WVA fill:#bbb,stroke:#666,color:#333
    style Kuadrant fill:#bbb,stroke:#666,color:#333
    style CertManager fill:#bbb,stroke:#666,color:#333

    %% Internal RHOAI (green)
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style PlatformGW fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#50c878,stroke:#333,color:#fff
    style SCC fill:#50c878,stroke:#333,color:#fff

    %% Peer components
    style ODHModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style AzureBlob fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style OCIReg fill:#f5a623,stroke:#333,color:#fff
