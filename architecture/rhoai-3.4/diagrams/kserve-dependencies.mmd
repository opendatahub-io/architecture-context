graph LR
    KServe["KServe Operator<br/><i>kserve-controller-manager<br/>llmisvc-controller-manager</i>"]

    %% Core Framework
    KServe -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.22.5"]

    %% External Dependencies (Optional)
    KServe -->|"serverless mode<br/>(optional)"| Knative["Knative Serving<br/>v0.48.1"]
    KServe -->|"traffic routing<br/>VirtualService/DestinationRule"| Istio["Istio API<br/>v1.27.1"]
    KServe -->|"HTTPRoute ingress<br/>(LLMISVC)"| GatewayAPI["Gateway API<br/>v1.4.2"]
    KServe -->|"InferencePool<br/>load balancing"| GWInference["Gateway API<br/>Inference Extension<br/>v1.3.1"]
    KServe -->|"event-driven<br/>autoscaling"| KEDA["KEDA<br/>v2.17.3"]
    KServe -->|"multi-node<br/>workloads"| LWS["LeaderWorkerSet<br/>v0.8.0"]
    KServe -->|"metrics<br/>collection"| OTel["OpenTelemetry<br/>Operator v0.113.0"]
    KServe -->|"metrics<br/>scraping"| PromOp["Prometheus<br/>Operator v0.89.0"]
    KServe -->|"LLM replica<br/>scaling"| WVA["llm-d WVA<br/>v0.6.0"]
    KServe -->|"webhook TLS<br/>(upstream only)"| CertMgr["cert-manager"]
    KServe -->|"Route, SCC<br/>(OCP only)"| OSAPI["OpenShift API"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via<br/>get_all_manifests.sh"| KServe
    KServe -.->|"VirtualService<br/>DestinationRule"| ServiceMesh["Istio / OpenShift<br/>Service Mesh"]
    KServe -.->|"CA signing key<br/>for workload TLS"| OSCA["OpenShift<br/>Service CA"]
    KServe -.->|"AuthPolicy<br/>gateway precondition"| Kuadrant["Kuadrant"]

    %% External Services (Egress)
    KServe -->|"model download<br/>443/TCP HTTPS"| S3["AWS S3"]
    KServe -->|"model download<br/>443/TCP HTTPS"| GCS["Google Cloud<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS"| Azure["Azure Blob<br/>Storage"]
    KServe -->|"model download<br/>443/TCP HTTPS"| HF["HuggingFace Hub"]

    %% Integration Points (inbound)
    DSC["DataScienceCluster"] -.->|"lifecycle config<br/>(external CRD)"| KServe
    DSCI["DSCInitialization"] -.->|"platform init<br/>(external CRD)"| KServe

