graph TD
    subgraph "Service Accounts"
        SA_Ctrl["odh-model-controller<br/>(Namespace: opendatahub)"]
        SA_API["model-serving-api<br/>(Namespace: opendatahub)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Ctrl["odh-model-controller<br/>(ClusterRoleBinding)"]
        CRB_API["model-serving-api<br/>(ClusterRoleBinding)"]
        CRB_AuthDeleg["{ns}-{sa}-auth-delegator<br/>(Dynamic ClusterRoleBinding)"]
    end

    subgraph "ClusterRoles"
        CR_Ctrl["odh-model-controller<br/>(ClusterRole)"]
        CR_API["model-serving-api<br/>(ClusterRole)"]
        CR_AuthDeleg["system:auth-delegator<br/>(Built-in ClusterRole)"]
    end

    SA_Ctrl -->|bound via| CRB_Ctrl
    CRB_Ctrl -->|grants| CR_Ctrl
    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API

    subgraph "KServe Resources"
        ISVC["serving.kserve.io<br/>inferenceservices<br/>inferenceservices/finalizers"]
        SR["serving.kserve.io<br/>servingruntimes<br/>servingruntimes/finalizers"]
        IG["serving.kserve.io<br/>inferencegraphs<br/>inferencegraphs/finalizers"]
        LLMISVC["serving.kserve.io<br/>llminferenceservices<br/>llminferenceservices/status<br/>llminferenceservices/finalizers"]
        LLMISVCCfg["serving.kserve.io<br/>llminferenceserviceconfigs"]
    end

    subgraph "NIM Resources"
        NIMAcct["nim.opendatahub.io<br/>accounts, accounts/status<br/>accounts/finalizers"]
    end

    subgraph "OpenShift Resources"
        Routes["route.openshift.io<br/>routes, routes/custom-host"]
        Templates["template.openshift.io<br/>templates"]
        OCPAuth["config.openshift.io<br/>authentications"]
    end

    subgraph "Gateway & Networking"
        Gateways["gateway.networking.k8s.io<br/>gateways, gateways/finalizers<br/>httproutes"]
        EnvoyFilters["networking.istio.io<br/>envoyfilters"]
        AuthPolicies["kuadrant.io<br/>authpolicies, kuadrants"]
        Authorinos["operator.authorino.kuadrant.io<br/>authorinos"]
        NetPolicies["networking.k8s.io<br/>networkpolicies"]
    end

    subgraph "Monitoring & Autoscaling"
        SvcMonitors["monitoring.coreos.com<br/>servicemonitors, podmonitors"]
        TrigAuth["keda.sh<br/>triggerauthentications"]
        Metrics["metrics.k8s.io<br/>pods, nodes"]
    end

    subgraph "Core Resources"
        CoreRW["core (read/write)<br/>secrets, configmaps<br/>serviceaccounts, services<br/>namespaces, pods, endpoints"]
        RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>roles, rolebindings"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    subgraph "Platform Resources"
        DSC["datasciencecluster.opendatahub.io<br/>datascienceclusters"]
        DSCI["dscinitialization.opendatahub.io<br/>dscinitializations"]
    end

    %% Controller permissions
    CR_Ctrl -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ISVC
    CR_Ctrl -->|"get,list,watch,<br/>create,update"| SR
    CR_Ctrl -->|"get,list,watch,<br/>update"| IG
    CR_Ctrl -->|"get,list,watch,<br/>update,patch,post"| LLMISVC
    CR_Ctrl -->|"get,list,watch"| LLMISVCCfg
    CR_Ctrl -->|"full CRUD"| NIMAcct
    CR_Ctrl -->|"full CRUD"| Routes
    CR_Ctrl -->|"full CRUD"| Templates
    CR_Ctrl -->|"get,list,watch"| OCPAuth
    CR_Ctrl -->|"get,list,watch,<br/>update,patch"| Gateways
    CR_Ctrl -->|"full CRUD"| EnvoyFilters
    CR_Ctrl -->|"full CRUD"| AuthPolicies
    CR_Ctrl -->|"get,list,watch"| Authorinos
    CR_Ctrl -->|"full CRUD"| NetPolicies
    CR_Ctrl -->|"full CRUD"| SvcMonitors
    CR_Ctrl -->|"full CRUD"| TrigAuth
    CR_Ctrl -->|"get,list,watch"| Metrics
    CR_Ctrl -->|"full CRUD"| CoreRW
    CR_Ctrl -->|"full CRUD"| RBAC
    CR_Ctrl -->|"create"| SAR
    CR_Ctrl -->|"get,list,watch"| DSC
    CR_Ctrl -->|"get,list,watch"| DSCI

    %% API Server permissions
    CR_API -->|"list"| GW_List["gateway.networking.k8s.io<br/>gateways"]
    CR_API -->|"get"| NS_Get["core<br/>namespaces"]

    %% Dynamic bindings
    DynSA["{isvc-service-account}<br/>(Dynamic)"] -->|bound via| CRB_AuthDeleg
    CRB_AuthDeleg -->|grants| CR_AuthDeleg

    %% Styling
    style SA_Ctrl fill:#4a90e2,color:#fff
    style SA_API fill:#50c878,color:#fff
    style CR_Ctrl fill:#f5a623,color:#fff
    style CR_API fill:#f5a623,color:#fff
    style CR_AuthDeleg fill:#f5a623,color:#fff
    style ISVC fill:#d5e8d4,stroke:#82b366
    style SR fill:#d5e8d4,stroke:#82b366
    style IG fill:#d5e8d4,stroke:#82b366
    style LLMISVC fill:#d5e8d4,stroke:#82b366
    style LLMISVCCfg fill:#d5e8d4,stroke:#82b366
    style NIMAcct fill:#e1d5e7,stroke:#9673a6
    style Routes fill:#ffe6cc,stroke:#d79b00
    style Templates fill:#ffe6cc,stroke:#d79b00
    style OCPAuth fill:#ffe6cc,stroke:#d79b00
    style Gateways fill:#dae8fc,stroke:#6c8ebf
    style EnvoyFilters fill:#dae8fc,stroke:#6c8ebf
    style AuthPolicies fill:#dae8fc,stroke:#6c8ebf
    style Authorinos fill:#dae8fc,stroke:#6c8ebf
    style NetPolicies fill:#dae8fc,stroke:#6c8ebf
    style SvcMonitors fill:#fff2cc,stroke:#d6b656
    style TrigAuth fill:#fff2cc,stroke:#d6b656
    style Metrics fill:#fff2cc,stroke:#d6b656
    style DynSA fill:#ccc,stroke:#999
