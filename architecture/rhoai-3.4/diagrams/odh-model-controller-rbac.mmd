graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Ctrl["odh-model-controller<br/>SA"]
        SA_API["model-serving-api<br/>SA"]
        SA_ISVC["Per-ISVC namespace SAs<br/>(dynamic)"]
        SA_Prom["inference-prometheus-auth<br/>SA (dynamic)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Ctrl["odh-model-controller-<br/>rolebinding"]
        CRB_API["model-serving-api-<br/>binding"]
        CRB_AuthDel["{ns}-{sa}-auth-delegator<br/>(dynamic, per-namespace)"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_Leader["odh-model-controller-<br/>leader-election"]
        RB_Prom["inference-prometheus-auth<br/>(dynamic, per-ISVC ns)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Ctrl["odh-model-controller-role"]
        CR_API["model-serving-api"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_Leader["leader-election-role"]
        R_Prom["inference-prometheus-auth<br/>(dynamic)"]
    end

    %% SA to CRB to CR
    SA_Ctrl -->|bound via| CRB_Ctrl
    CRB_Ctrl -->|grants| CR_Ctrl

    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API

    SA_ISVC -->|bound via| CRB_AuthDel
    CRB_AuthDel -->|grants| CR_AuthDel

    %% SA to RB to R
    SA_Ctrl -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    SA_Prom -->|bound via| RB_Prom
    RB_Prom -->|grants| R_Prom

    subgraph CtrlResources["odh-model-controller-role Resources"]
        direction LR

        subgraph CoreAPI["Core API ('')"]
            CoreRes["configmaps, secrets<br/>serviceaccounts, services<br/>endpoints, namespaces<br/>pods, events"]
        end

        subgraph KServeAPI["serving.kserve.io"]
            KServeRes["inferenceservices (+finalizers)<br/>servingruntimes (+finalizers)<br/>inferencegraphs (+finalizers)<br/>llminferenceservices (+status/finalizers)<br/>llminferenceserviceconfigs"]
        end

        subgraph NIMAPI["nim.opendatahub.io"]
            NIMRes["accounts<br/>accounts/status<br/>accounts/finalizers"]
        end

        subgraph RouteAPI["route.openshift.io"]
            RouteRes["routes<br/>routes/custom-host"]
        end

        subgraph GatewayAPI2["gateway.networking.k8s.io"]
            GWRes["gateways (+finalizers)<br/>httproutes"]
        end

        subgraph KuadrantAPI["kuadrant.io"]
            KuadrantRes["authpolicies (+status)<br/>kuadrants"]
        end

        subgraph IstioAPI["networking.istio.io"]
            IstioRes["envoyfilters"]
        end

        subgraph NetAPI["networking.k8s.io"]
            NetRes["networkpolicies"]
        end

        subgraph MonAPI["monitoring.coreos.com"]
            MonRes["servicemonitors<br/>podmonitors"]
        end

        subgraph KEDAAPI["keda.sh"]
            KEDARes["triggerauthentications"]
        end

        subgraph RBACAPI["rbac.authorization.k8s.io"]
            RBACRes["clusterrolebindings<br/>roles, rolebindings"]
        end

        subgraph ODHAPI["opendatahub.io"]
            ODHRes["datascienceclusters<br/>dscinitializations"]
        end

        subgraph OSConfigAPI["config.openshift.io"]
            OSConfigRes["authentications"]
        end

        subgraph TemplateAPI["template.openshift.io"]
            TemplateRes["templates"]
        end

        subgraph MetricsAPI["metrics.k8s.io"]
            MetricsRes["pods, nodes"]
        end
    end

    %% CR to resources
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| CoreRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| KServeRes
    CR_Ctrl -->|"get,list,watch<br/>update,patch"| NIMRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| RouteRes
    CR_Ctrl -->|"get,list,watch<br/>update,patch"| GWRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| KuadrantRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| IstioRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| NetRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| MonRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| KEDARes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>patch,delete"| RBACRes
    CR_Ctrl -->|"get,list,watch"| ODHRes
    CR_Ctrl -->|"get,list,watch"| OSConfigRes
    CR_Ctrl -->|"get,list,watch<br/>create,update<br/>delete,patch"| TemplateRes
    CR_Ctrl -->|"get,list,watch"| MetricsRes

    subgraph APIResources["model-serving-api Resources"]
        GWListRes["gateway.networking.k8s.io<br/>gateways: list"]
        NSGetRes["core<br/>namespaces: get"]
    end

    CR_API -->|"list"| GWListRes
    CR_API -->|"get"| NSGetRes

    %% Styling
    style SA_Ctrl fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_ISVC fill:#4a90e2,stroke:#333,color:#fff
    style SA_Prom fill:#4a90e2,stroke:#333,color:#fff
    style CR_Ctrl fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style CR_AuthDel fill:#f5a623,stroke:#333
    style R_Leader fill:#f5a623,stroke:#333
    style R_Prom fill:#f5a623,stroke:#333
    style CRB_Ctrl fill:#e8e8e8,stroke:#333
    style CRB_API fill:#e8e8e8,stroke:#333
    style CRB_AuthDel fill:#e8e8e8,stroke:#333
    style RB_Leader fill:#e8e8e8,stroke:#333
    style RB_Prom fill:#e8e8e8,stroke:#333
