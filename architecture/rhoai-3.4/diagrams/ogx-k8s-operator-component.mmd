graph TB
    subgraph Operator["LlamaStack K8s Operator<br/>(redhat-ods-applications)"]
        direction TB
        Controller["LlamaStackDistribution<br/>Reconciler"]
        Kustomizer["Kustomize Renderer<br/>(embedded manifests)"]
        Transformers["Transformer Plugins<br/>(name prefix, namespace,<br/>field mutator, NetworkPolicy)"]
        CAManager["CA Bundle Manager<br/>(X.509 validation,<br/>PEM aggregation)"]
        FeatureFlags["Feature Flags<br/>(llama-stack-operator-config)"]
        DistMap["Distribution Mapper<br/>(distributions.json)"]
        CachedClient["Cached Client<br/>(label-filtered informers)"]
        DirectClient["Direct Client<br/>(non-cached API reads)"]

        Controller --> Kustomizer
        Kustomizer --> Transformers
        Controller --> CAManager
        Controller --> FeatureFlags
        Controller --> DistMap
        Controller --> CachedClient
        Controller --> DirectClient
    end

    %% CRD
    User[Data Scientist / Admin] -->|creates/updates| LLSDCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LLSDCR -->|watched by| Controller

    %% Managed Resources
    Controller -->|creates| Deployment["Deployment<br/>(LlamaStack Server Pod)"]
    Controller -->|creates| Service["{instance}-service<br/>ClusterIP 8321/TCP"]
    Controller -->|creates| SA["ServiceAccount<br/>{instance}-sa"]
    Controller -->|creates| RB["RoleBinding<br/>→ anyuid SCC"]
    Controller -->|creates| NP["NetworkPolicy<br/>(namespace isolation)"]
    Controller -->|creates| Ingress["Ingress<br/>(when exposeRoute=true)"]
    Controller -->|creates| PVC["PersistentVolumeClaim<br/>(when storage configured)"]
    Controller -->|creates| PDB["PodDisruptionBudget"]
    Controller -->|creates| HPA["HorizontalPodAutoscaler<br/>(when autoscaling enabled)"]
    Controller -->|creates| ManagedCM["Managed CA ConfigMap<br/>(aggregated certs)"]

    %% CA Bundle Sources
    CAManager -->|reads| UserCACM["User CA ConfigMap"]
    CAManager -->|reads| ODHTrustCM["odh-trusted-ca-bundle<br/>ConfigMap"]
    CAManager -->|writes| ManagedCM

    %% Health checks
    Controller -->|"HTTP GET /v1/health<br/>/v1/providers, /v1/version"| Deployment

    %% External
    Controller -->|REST 443/TCP| K8sAPI["Kubernetes API Server"]

    %% Monitoring
    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|"scrapes 8443/TCP<br/>HTTPS + Bearer Token"| MetricsSvc["controller-manager-<br/>metrics-service"]

    %% Styles
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Kustomizer fill:#4a90e2,stroke:#333,color:#fff
    style Transformers fill:#4a90e2,stroke:#333,color:#fff
    style CAManager fill:#4a90e2,stroke:#333,color:#fff
    style FeatureFlags fill:#4a90e2,stroke:#333,color:#fff
    style DistMap fill:#4a90e2,stroke:#333,color:#fff
    style CachedClient fill:#4a90e2,stroke:#333,color:#fff
    style DirectClient fill:#4a90e2,stroke:#333,color:#fff
    style LLSDCR fill:#f5a623,stroke:#333
    style Deployment fill:#7ed321,stroke:#333
    style Service fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style RB fill:#7ed321,stroke:#333
    style NP fill:#7ed321,stroke:#333
    style Ingress fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style ManagedCM fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style MetricsSvc fill:#7ed321,stroke:#333
    style UserCACM fill:#f5a623,stroke:#333
    style ODHTrustCM fill:#f5a623,stroke:#333
