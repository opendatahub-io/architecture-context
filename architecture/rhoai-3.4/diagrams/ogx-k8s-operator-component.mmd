graph TB
    subgraph Operator["llama-stack-k8s-operator"]
        direction TB
        Controller["LlamaStackDistribution Controller<br/>(controller-runtime)"]
        KustomizePipeline["Kustomize Rendering Pipeline<br/>(embedded manifests + Go plugins)"]
        CABundleMgr["CA Bundle Manager<br/>(crypto/x509 validation)"]
        DistResolver["Distribution Resolver<br/>(distributions.json)"]
        FeatureFlags["Feature Flags<br/>(enableNetworkPolicy)"]
        HealthProbe["/healthz, /readyz<br/>8081/TCP"]
        Metrics["/metrics<br/>8080/TCP"]

        Controller -->|renders manifests| KustomizePipeline
        Controller -->|manages certs| CABundleMgr
        Controller -->|resolves images| DistResolver
        Controller -->|checks flags| FeatureFlags
    end

    User[User / Platform Operator] -->|creates/updates| LLSDCR["LlamaStackDistribution CR<br/>(llamastack.io/v1alpha1)"]
    LLSDCR -->|watched by| Controller

    subgraph ManagedResources["Managed Resources (per LLSD instance)"]
        direction TB
        Deployment["Deployment<br/>(LlamaStack server pods)"]
        Service["Service (ClusterIP)<br/>8321/TCP"]
        Ingress["Ingress<br/>(optional, when exposeRoute: true)"]
        PVC["PersistentVolumeClaim"]
        NetPol["NetworkPolicy<br/>(configurable ingress rules)"]
        HPA["HorizontalPodAutoscaler"]
        PDB["PodDisruptionBudget"]
        SA["ServiceAccount"]
        RB["RoleBinding<br/>(anyuid SCC)"]
        CAConfigMap["CA Bundle ConfigMap<br/>(managed, SSL_CERT_FILE)"]
    end

    KustomizePipeline -->|server-side apply| Deployment
    KustomizePipeline -->|server-side apply| Service
    KustomizePipeline -->|server-side apply| PVC
    KustomizePipeline -->|server-side apply| NetPol
    KustomizePipeline -->|server-side apply| HPA
    KustomizePipeline -->|server-side apply| PDB
    KustomizePipeline -->|server-side apply| SA
    KustomizePipeline -->|server-side apply| RB
    Controller -->|creates/updates| Ingress
    CABundleMgr -->|creates/updates| CAConfigMap

    Controller -->|queries /v1/providers,<br/>/v1/version| Deployment

    subgraph ExternalInputs["External Inputs"]
        UserCAConfigMap["User CA ConfigMap"]
        ODHTrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
        OperatorConfig["llama-stack-operator-config<br/>ConfigMap"]
    end

    CABundleMgr -->|reads certs| UserCAConfigMap
    CABundleMgr -->|reads certs| ODHTrustedCA
    Controller -->|reads config| OperatorConfig

    Prometheus["Prometheus"] -->|scrapes| Metrics

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style KustomizePipeline fill:#4a90e2,stroke:#333,color:#fff
    style CABundleMgr fill:#4a90e2,stroke:#333,color:#fff
    style DistResolver fill:#4a90e2,stroke:#333,color:#fff
    style FeatureFlags fill:#4a90e2,stroke:#333,color:#fff
    style LLSDCR fill:#f5a623,stroke:#333
    style Deployment fill:#7ed321,stroke:#333
    style Service fill:#7ed321,stroke:#333
    style Ingress fill:#7ed321,stroke:#333
    style PVC fill:#7ed321,stroke:#333
    style NetPol fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style PDB fill:#7ed321,stroke:#333
    style SA fill:#7ed321,stroke:#333
    style RB fill:#7ed321,stroke:#333
    style CAConfigMap fill:#7ed321,stroke:#333
    style UserCAConfigMap fill:#e8e8e8,stroke:#333
    style ODHTrustedCA fill:#e8e8e8,stroke:#333
    style OperatorConfig fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
