graph LR
    Provider["TrustyAI Garak<br/>LLS Provider"]

    %% ── External Dependencies (Required) ──
    Provider -->|"vulnerability scanning<br/>v0.14.1+rhaiv.7"| Garak["garak<br/>LLM Scanner"]
    Provider -->|"client SDK<br/>≥0.5.0"| LLSClient["llama-stack-client"]
    Provider -->|"API types<br/>≥0.5.0"| LLSAPI["llama-stack-api"]

    %% ── External Dependencies (Remote Mode) ──
    Provider -->|"pipeline DSL<br/>≥2.14.6"| KFP_SDK["kfp SDK"]
    Provider -->|"secret injection<br/>≥2.14.6"| KFP_K8s["kfp-kubernetes"]
    Provider -->|"API client<br/>≥2.14.6"| KFP_Server["kfp-server-api"]
    Provider -->|"S3 client<br/>≥1.35.88"| Boto3["boto3"]

    %% ── External Dependencies (Eval-Hub Mode) ──
    Provider -->|"adapter SDK<br/>v0.1.4"| EvalHubSDK["eval-hub-sdk"]
    Provider -->|"adversarial prompts<br/>≥0.8.8"| SDGHub["sdg-hub"]

    %% ── External Dependencies (Utilities) ──
    Provider -->|"taxonomy data<br/>≥2.3.3"| Pandas["pandas"]
    Provider -->|"HTML reports<br/>≥3.1.6"| Jinja2["Jinja2"]
    Provider -->|"async patching<br/>≥1.6.0"| NestAsyncio["nest_asyncio"]
    Provider -->|"HTTP + TLS<br/>(transitive)"| HTTPX["httpx"]

    %% ── Internal Platform Dependencies ──
    Provider -->|"provider host<br/>8321/TCP"| LLSServer["Llama Stack<br/>Distribution Server"]
    Provider -->|"pipeline execution<br/>443/TCP HTTPS"| DSPA["Kubeflow Pipelines<br/>(DSPA)"]
    Provider -->|"artifact storage<br/>443/TCP HTTPS"| S3["S3/MinIO<br/>Object Storage"]
    Provider -->|"LLS persistence<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    Provider -->|"target model<br/>443/TCP HTTPS"| vLLM["vLLM Inference<br/>Server"]
    Provider -->|"scan artifacts<br/>8321/TCP"| FilesAPI["Llama Stack<br/>Files API"]
    Provider -->|"guardrail testing<br/>8321/TCP"| SafetyAPI["Llama Stack<br/>Safety API"]
    Provider -->|"artifact logging"| MLflow["MLflow"]
    Provider -->|"OCI artifacts<br/>443/TCP"| OCIRegistry["OCI Registry"]

    %% ── Integration Points (consumed by others) ──
    EvalHubCtrl["Eval-Hub<br/>Controller"] -->|"K8s Job<br/>FrameworkAdapter"| Provider
    Dashboard["ODH Dashboard"] -.->|"evaluation UI"| Provider

    %% ── Build Dependencies ──
    Provider -.->|"base image"| UBI9["UBI9<br/>(FIPS OpenSSL)"]
    Provider -.->|"build-time deps<br/>443/TCP"| PyPI["PyPI<br/>(RH AI Index)"]

