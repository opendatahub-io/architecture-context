graph LR
    LLMDSched["llm-d Inference<br/>Scheduler<br/>(EPP + Sidecar)"]

    %% External Dependencies (Required)
    LLMDSched -->|"ext-proc gRPC<br/>plugin framework"| GIE["Gateway API<br/>Inference Extension<br/>v1.4.0<br/>(red-hat-data-services fork)"]
    LLMDSched -->|"KV-cache indexing<br/>tokenization"| KVCache["llm-d-kv-cache<br/>v0.7.1"]
    LLMDSched -->|"K8s client<br/>logging, signals"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    LLMDSched -->|"CRD type defs"| GatewayAPI["gateway-api<br/>v1.5.1"]
    LLMDSched -->|"data plane<br/>ext-proc filter"| Envoy["Envoy<br/>(Gateway API impl)"]
    LLMDSched -->|"model serving<br/>KV-cache events"| vLLM["vLLM<br/>(model engine)"]

    %% External Dependencies (Optional)
    LLMDSched -.->|"metrics scrape<br/>9090/TCP"| Prometheus["Prometheus"]
    LLMDSched -.->|"trace export<br/>4317/TCP gRPC"| OTLP["OpenTelemetry<br/>Collector"]
    LLMDSched -.->|"KV-cache event<br/>subscription"| ZeroMQ["ZeroMQ"]

    %% Internal Platform Dependencies
    Envoy -->|"gRPC ext-proc<br/>9002/TCP"| LLMDSched
    vLLM -->|"HTTP + ZMQ<br/>model metadata +<br/>KV-cache events"| LLMDSched

    %% CRD Dependencies
    LLMDSched -->|"CRD Watch<br/>pod discovery"| InferencePool["InferencePool CR<br/>(inference.networking.k8s.io)"]
    LLMDSched -->|"Unix Socket IPC"| UDSTokenizer["UDS Tokenizer<br/>(sidecar container)"]

    %% Runtime targets
    LLMDSched -->|"HTTP reverse proxy<br/>8001/TCP local"| DecoderPod["vLLM Decoder<br/>(co-located pod)"]
    LLMDSched -->|"HTTP/HTTPS proxy<br/>remote"| PrefillerPod["vLLM Prefiller<br/>(remote pod)"]
    LLMDSched -->|"HTTP/HTTPS proxy<br/>remote"| EncoderPod["vLLM Encoder<br/>(remote pod)"]

    %% Kubernetes API
    LLMDSched -->|"HTTPS/443<br/>SA token"| K8sAPI["Kubernetes API<br/>Server"]

