graph LR
    Scheduler["llm-d Inference<br/>Scheduler"]

    %% Required External Dependencies
    Scheduler -->|"ext-proc framework<br/>v1.4.0 (RH fork)"| GIE["Gateway API<br/>Inference Extension"]
    Scheduler -->|"Gateway, HTTPRoute<br/>v1.5.1"| GatewayAPICRDs["Gateway API CRDs"]
    Scheduler -->|"ext-proc callbacks<br/>data plane"| Envoy["Envoy<br/>(Istio / kGateway)"]
    Scheduler -->|"KV cache indexing<br/>v0.7.1"| KVCache["llm-d-kv-cache"]
    Scheduler -->|"model serving<br/>prefill/decode/encode"| vLLM["vLLM"]

    %% Conditional / Optional Dependencies
    Scheduler -.->|"metrics collection<br/>(ServiceMonitor)"| Prometheus["Prometheus"]
    Scheduler -.->|"distributed tracing<br/>OTLP gRPC/4317"| OTel["OpenTelemetry<br/>Collector"]
    Scheduler -.->|"KV cache events<br/>ZMQ SUB/5556"| ZMQ["ZeroMQ"]
    Scheduler -.->|"tokenizer downloads<br/>HTTPS/443"| HuggingFace["HuggingFace Hub"]

    %% Platform Dependencies
    Scheduler -->|"watch resources<br/>HTTPS/443"| K8sAPI["Kubernetes<br/>API Server"]

    %% CRDs Consumed
    Scheduler -->|"watches"| InferencePool["InferencePool CR<br/>(GIE CRD)"]
    Scheduler -->|"watches"| InferenceObjective["InferenceObjective CR<br/>(GIE CRD)"]
    Scheduler -->|"watches"| InferenceModelRewrite["InferenceModelRewrite CR<br/>(GIE CRD)"]

    %% Sidecar-specific
    Scheduler -->|"prompt tokenization<br/>gRPC/UDS"| UDSTokenizer["UDS Tokenizer<br/>Sidecar"]

    %% Potential integration points (other RHOAI components)
    KServe["KServe"] -.->|"may deploy<br/>InferencePool"| Scheduler
    Dashboard["ODH Dashboard"] -.->|"UI management<br/>(future)"| Scheduler

    %% Styling
    style Scheduler fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style GIE fill:#e74c3c,stroke:#333,color:#fff
    style GatewayAPICRDs fill:#e74c3c,stroke:#333,color:#fff
    style Envoy fill:#e74c3c,stroke:#333,color:#fff
    style KVCache fill:#e74c3c,stroke:#333,color:#fff
    style vLLM fill:#e74c3c,stroke:#333,color:#fff

    %% Optional/conditional
    style Prometheus fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style ZMQ fill:#999,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333

    %% Platform
    style K8sAPI fill:#f5a623,stroke:#333

    %% CRDs
    style InferencePool fill:#7ed321,stroke:#333
    style InferenceObjective fill:#7ed321,stroke:#333
    style InferenceModelRewrite fill:#7ed321,stroke:#333

    %% Internal
    style UDSTokenizer fill:#9b59b6,stroke:#333,color:#fff

    %% Integrations
    style KServe fill:#7ed321,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333
