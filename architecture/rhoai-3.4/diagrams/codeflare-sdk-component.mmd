graph TB
    subgraph SDK["CodeFlare SDK (Python Client Library)"]
        direction TB

        subgraph UserAPI["User-Facing API Layer"]
            Cluster["Cluster Class<br/>(cluster.py)<br/>RayCluster lifecycle"]
            RayJob["RayJob Class<br/>(rayjob.py)<br/>RayJob lifecycle"]
            RayJobClient["RayJobClient<br/>(ray_jobs.py)<br/>Dashboard job submission"]
        end

        subgraph Config["Configuration Layer"]
            ClusterConfig["ClusterConfiguration<br/>(config.py)<br/>Cluster spec builder"]
            ManagedConfig["ManagedClusterConfig<br/>(rayjobs/config.py)<br/>RayJob cluster spec"]
            RuntimeEnv["RuntimeEnvPackager<br/>(runtime_env.py)<br/>working_dir packaging"]
        end

        subgraph Core["Core Services"]
            Auth["Auth Module<br/>(auth.py)<br/>kube-authkit / legacy"]
            TLSGen["TLS Cert Generator<br/>(generate_cert.py)<br/>mTLS client certs"]
            KueueUtil["Kueue Utilities<br/>(kueue.py)<br/>Queue/priority validation"]
            Widgets["Jupyter Widgets<br/>(widgets.py)<br/>ipywidgets UI"]
        end

        subgraph Vendored["Vendored KubeRay Client"]
            KubeRayCluster["KubeRayClusterApi<br/>RayCluster CRUD"]
            KubeRayJob["KubeRayJobApi<br/>RayJob CRUD"]
        end
    end

    %% Internal relationships
    Cluster -->|uses| ClusterConfig
    Cluster -->|uses| TLSGen
    Cluster -->|uses| KueueUtil
    Cluster -->|uses| KubeRayCluster
    Cluster -->|renders| Widgets
    RayJob -->|uses| ManagedConfig
    RayJob -->|uses| RuntimeEnv
    RayJob -->|uses| KubeRayJob
    RayJob -->|uses| KueueUtil
    RayJobClient -->|connects to| RayDashboard
    Auth -->|configures| KubeRayCluster
    Auth -->|configures| KubeRayJob

    %% External resources (CRDs)
    KubeRayCluster -->|creates/manages| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    KubeRayJob -->|creates/manages| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    KueueUtil -->|queries| LocalQueueCR["LocalQueue CR<br/>(kueue.x-k8s.io/v1beta1)"]
    KueueUtil -->|queries| WorkloadCR["Workload CR<br/>(kueue.x-k8s.io/v1beta1)"]
    Cluster -->|queries| HTTPRouteCR["HTTPRoute CR<br/>(gateway.networking.k8s.io/v1)"]

    %% External systems
    RayClusterCR -->|reconciled by| KubeRayOp["KubeRay Operator"]
    RayJobCR -->|reconciled by| KubeRayOp
    TLSGen -->|reads CA from| CASecret["CA Secret<br/>(Kubernetes)"]
    Auth -->|authenticates via| K8sAPI["Kubernetes API Server"]

    %% External runtime targets
    Cluster -->|connects via mTLS| RayHead["Ray Head Service<br/>10001/TCP"]
    RayJobClient -->|submits jobs| RayDashboard["Ray Dashboard<br/>8265/TCP"]

    %% User
    User["Data Scientist<br/>(Jupyter Notebook)"] -->|uses| Cluster
    User -->|uses| RayJob
    User -->|uses| RayJobClient

    %% Styling
    style SDK fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style UserAPI fill:#bbdefb,stroke:#1565c0
    style Config fill:#c8e6c9,stroke:#2e7d32
    style Core fill:#fff9c4,stroke:#f9a825
    style Vendored fill:#f3e5f5,stroke:#7b1fa2
    style Cluster fill:#4a90e2,color:#fff
    style RayJob fill:#4a90e2,color:#fff
    style RayJobClient fill:#4a90e2,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style LocalQueueCR fill:#f5a623,stroke:#333
    style WorkloadCR fill:#f5a623,stroke:#333
    style HTTPRouteCR fill:#f5a623,stroke:#333
    style KubeRayOp fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RayHead fill:#7ed321,stroke:#333
    style RayDashboard fill:#7ed321,stroke:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
