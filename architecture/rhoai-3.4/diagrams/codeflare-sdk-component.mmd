graph TB
    subgraph SDK["CodeFlare SDK (Python Client Library)"]
        direction TB
        subgraph RayModule["ray module"]
            Cluster["ray.cluster<br/>RayCluster lifecycle<br/>(create, apply, delete,<br/>status, wait_ready)"]
            RayJobs["ray.rayjobs<br/>RayJob submission<br/>(managed cluster support)"]
            RayClient["ray.client<br/>JobSubmissionClient<br/>wrapper"]
        end

        subgraph CommonModule["common module"]
            KubeCluster["common.kubernetes_cluster<br/>K8s auth (kube-authkit,<br/>token, kubeconfig)"]
            KueueMod["common.kueue<br/>LocalQueue &amp;<br/>WorkloadPriorityClass<br/>discovery"]
            GenCert["common.utils.generate_cert<br/>TLS cert generation<br/>(RSA 3072-bit, SHA-256)"]
            Widgets["common.widgets<br/>Jupyter ipywidgets<br/>interactive UI"]
        end

        subgraph Vendored["vendored"]
            KubeRayClient["vendored.python_client<br/>KubeRay Python client<br/>(cluster &amp; job API)"]
        end

        Cluster --> KubeCluster
        Cluster --> KueueMod
        Cluster --> GenCert
        Cluster --> KubeRayClient
        RayJobs --> KubeCluster
        RayJobs --> KueueMod
        RayJobs --> KubeRayClient
        RayClient --> KubeCluster
        Widgets --> Cluster
    end

    User["Data Scientist<br/>(Jupyter Notebook)"] -->|uses| SDK

    %% CRDs Created
    Cluster -->|creates| RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    RayJobs -->|creates| RayJobCR["RayJob CR<br/>ray.io/v1"]

    %% External Dependencies
    RayClusterCR -->|reconciled by| KubeRayOp["KubeRay Operator"]
    RayJobCR -->|reconciled by| KubeRayOp

    KueueMod -->|reads| KueueCRs["Kueue CRs<br/>LocalQueue, Workload,<br/>WorkloadPriorityClass"]
    Cluster -->|discovers| HTTPRoute["HTTPRoute / Route<br/>Dashboard URL"]
    GenCert -->|reads CA from| CASecret["CA Secret<br/>(KubeRay-created)"]
    GenCert -->|generates| ClientCerts["Client TLS Certs<br/>~/.local/share/codeflare/tls/"]

    KubeCluster -->|authenticates via| K8sAPI["Kubernetes API Server<br/>6443/TCP"]

    style SDK fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RayModule fill:#e8f5e9,stroke:#2e7d32
    style CommonModule fill:#fff3e0,stroke:#e65100
    style Vendored fill:#f3e5f5,stroke:#6a1b9a
    style User fill:#fce4ec,stroke:#c62828
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style KubeRayOp fill:#999,stroke:#333
    style KueueCRs fill:#999,stroke:#333
    style HTTPRoute fill:#999,stroke:#333
    style CASecret fill:#fff9c4,stroke:#f57f17
    style ClientCerts fill:#fff9c4,stroke:#f57f17
    style K8sAPI fill:#999,stroke:#333
