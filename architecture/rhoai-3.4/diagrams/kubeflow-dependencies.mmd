graph LR
    Kubeflow["Kubeflow Notebook<br/>Controller Platform"]

    %% External Dependencies (required libraries/frameworks)
    Kubeflow -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.21.0"]
    Kubeflow -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.33.7"]
    Kubeflow -->|"HTTPRoute, Gateway,<br/>ReferenceGrant types"| GatewayAPI["gateway-api<br/>v1.2.1"]
    Kubeflow -->|"Route, ImageStream,<br/>OAuthClient, Proxy types"| OSAPI["openshift/api<br/>v0.0.0-20231118"]
    Kubeflow -->|"DSPA CRD types<br/>(Elyra integration)"| DSPAOP["data-science-pipelines-<br/>operator v1.1.1"]

    %% Internal ODH Platform Dependencies
    Kubeflow -->|"deploys controllers"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    Kubeflow -->|"reads Gateway hostname,<br/>creates HTTPRoutes"| DSGateway["data-science-gateway<br/>(Gateway CR)"]
    Kubeflow -->|"auto-generates TLS certs<br/>for krbp + webhook"| ServingCert["OpenShift<br/>serving-cert-controller"]
    Kubeflow -->|"platform CA certs<br/>for workbench trust"| TrustedCA["odh-trusted-ca-bundle<br/>(ConfigMap)"]
    Kubeflow -->|"K8s root CA for<br/>workbench trust"| KubeRootCA["kube-root-ca.crt<br/>(ConfigMap)"]
    Kubeflow -->|"service CA for<br/>workbench trust"| ServiceCA["openshift-service-ca.crt<br/>(ConfigMap)"]

    %% Integration Points (components that integrate with Kubeflow)
    Dashboard["ODH Dashboard"] -->|"UI notebook<br/>management"| Kubeflow
    DSPipelines["Data Science<br/>Pipelines (DSPA)"] -->|"Elyra runtime<br/>config extraction"| Kubeflow
    MLflow["MLflow Operator"] -->|"tracking URI +<br/>RoleBinding"| Kubeflow
    FeastComp["Feast"] -->|"config ConfigMap<br/>mount"| Kubeflow

    %% External Services
    Kubeflow -->|"all resource CRUD<br/>6443/TCP HTTPS"| K8sAPIServer["Kubernetes<br/>API Server"]
    Kubeflow -->|"ImageStream resolution<br/>5000/TCP HTTPS"| ImageReg["OpenShift<br/>Image Registry"]
    Kubeflow -->|"idle detection<br/>8888/TCP HTTP"| JupyterPods["Jupyter Server<br/>Pods"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scrape<br/>8080/TCP HTTP"| Kubeflow

