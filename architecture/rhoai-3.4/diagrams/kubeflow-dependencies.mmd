graph LR
    Kubeflow["Kubeflow Notebook<br/>Controllers"]

    %% External Dependencies (required libraries/frameworks)
    Kubeflow -->|"controller framework<br/>v0.21.0"| ControllerRuntime["controller-runtime"]
    Kubeflow -->|"networking types<br/>v1.2.1"| GatewayAPI["gateway-api"]
    Kubeflow -->|"OpenShift types"| OpenShiftAPI["openshift/api"]
    Kubeflow -->|"metrics<br/>v1.23.2"| Prometheus["prometheus/<br/>client_golang"]

    %% Internal RHOAI Platform Dependencies
    Kubeflow -->|"deploys controllers"| RHOAIOp["rhods-operator /<br/>opendatahub-operator"]
    Kubeflow -->|"HTTPRoute parent ref"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    Kubeflow -->|"TLS cert generation"| ServiceCA["OpenShift<br/>service-ca-operator"]
    Kubeflow -->|"pipeline config,<br/>S3 credentials"| DSPA["DSPA<br/>(DataSciencePipelines<br/>Application)"]
    Kubeflow -->|"ClusterRole ref<br/>per-notebook RoleBinding"| MLflow["MLflow Operator"]
    Kubeflow -->|"image resolution,<br/>runtime discovery"| ImageStreams["OpenShift<br/>ImageStreams"]

    %% Optional / Conditional
    Kubeflow -.->|"ConfigMap mount<br/>(when label present)"| Feast["Feast<br/>Feature Store"]
    Kubeflow -.->|"DSPA CRD types<br/>(optional dep)"| DSPOTypes["data-science-pipelines<br/>-operator v1.1.1"]

    %% Things that integrate WITH kubeflow
    Dashboard["RHOAI Dashboard"] -->|"creates Notebook CRs"| Kubeflow
    DSPipelines["Data Science<br/>Pipelines"] -->|"pipeline config<br/>injected via secret"| Kubeflow
    PlatformWH["Platform Webhooks<br/>(rhods-operator)"] -->|"connection-notebook,<br/>hardwareprofile"| Kubeflow

    %% External Services
    Kubeflow -->|"all CRUD operations<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    Kubeflow -->|"idle culling<br/>8888/TCP HTTP"| JupyterAPI["Jupyter Server<br/>/api/kernels,<br/>/api/terminals"]

    %% Styling
    style Kubeflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

