graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Group["Endpoint Picker Provider (EPP)"]
            EPP_Server["EPP gRPC Server<br/>9002/TCP ext-proc"]
            EPP_Health["Health Server<br/>9003/TCP"]
            EPP_Metrics["Metrics Server<br/>9090/TCP"]
            EPP_Scheduler["Scheduling Engine<br/>Filter → Score → Pick"]
            EPP_DataLayer["Data Layer<br/>Pluggable Sources & Extractors"]
            EPP_FlowControl["Flow Control<br/>JSQ-Bytes Sharded Queuing"]
            EPP_Server --> EPP_Scheduler
            EPP_Scheduler --> EPP_DataLayer
            EPP_Scheduler --> EPP_FlowControl
        end

        subgraph BBR_Group["Body Based Router (BBR)"]
            BBR_Server["BBR gRPC Server<br/>9004/TCP ext-proc"]
            BBR_Health["Health Server<br/>9005/TCP"]
            BBR_Plugins["Plugin Framework<br/>Body → Header Extraction"]
            BBR_Server --> BBR_Plugins
        end

        subgraph LatencyPredictor["Latency Predictor (Optional)"]
            LP_Training["Training Server<br/>8000/TCP<br/>Bayesian Ridge / XGBoost"]
            LP_Prediction["Prediction Server<br/>8000/TCP<br/>TTFT/TPOT Forecasting"]
            LP_AsyncClient["Async Client Sidecar<br/>Batch & Coalesce"]
            LP_AsyncClient --> LP_Training
            LP_AsyncClient --> LP_Prediction
        end

        subgraph LoRA["Dynamic LoRA Sidecar (Optional)"]
            LoRA_Sidecar["LoRA Sidecar<br/>ConfigMap Watcher"]
        end
    end

    %% External actors
    Client["External Client"] -->|"HTTPS/443"| Gateway["Envoy Gateway<br/>(Gateway API)"]

    %% Gateway to ext-proc chain
    Gateway -->|"gRPC/9004<br/>TLS"| BBR_Server
    BBR_Server -->|"X-Gateway-Model-Name<br/>header injection"| Gateway
    Gateway -->|"gRPC/9002<br/>TLS"| EPP_Server
    EPP_Server -->|"endpoint selection<br/>header mutation"| Gateway
    Gateway -->|"HTTP/8000"| ModelServer["Model Server Pods<br/>(vLLM / SGLang)"]

    %% CRDs watched
    InferencePool["InferencePool CR"] -->|"watched by"| EPP_DataLayer
    InferenceObjective["InferenceObjective CR"] -->|"watched by"| EPP_FlowControl
    InferenceModelRewrite["InferenceModelRewrite CR"] -->|"watched by"| EPP_Scheduler
    ConfigMap["ConfigMaps<br/>(LoRA mappings)"] -->|"watched by"| BBR_Plugins

    %% Metrics scraping
    EPP_DataLayer -->|"HTTP metrics<br/>scraping"| ModelServer

    %% LoRA sidecar
    LoRA_Sidecar -->|"HTTP/8000<br/>load/unload adapters"| ModelServer

    %% K8s API
    EPP_DataLayer -->|"HTTPS/443"| K8sAPI["Kubernetes API"]
    BBR_Plugins -->|"HTTPS/443"| K8sAPI

    %% Observability
    EPP_Metrics -->|"Prometheus"| Prometheus["Prometheus"]
    EPP_Server -.->|"gRPC/4317"| OTLP["OTLP Collector"]

    %% Styling
    style EPP_Server fill:#4a90e2,stroke:#333,color:#fff
    style EPP_Scheduler fill:#4a90e2,stroke:#333,color:#fff
    style EPP_DataLayer fill:#4a90e2,stroke:#333,color:#fff
    style EPP_FlowControl fill:#4a90e2,stroke:#333,color:#fff
    style BBR_Server fill:#5b9bd5,stroke:#333,color:#fff
    style BBR_Plugins fill:#5b9bd5,stroke:#333,color:#fff
    style LP_Training fill:#9b59b6,stroke:#333,color:#fff
    style LP_Prediction fill:#9b59b6,stroke:#333,color:#fff
    style LP_AsyncClient fill:#9b59b6,stroke:#333,color:#fff
    style LoRA_Sidecar fill:#e67e22,stroke:#333,color:#fff
    style Gateway fill:#27ae60,stroke:#333,color:#fff
    style ModelServer fill:#27ae60,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333
    style InferenceObjective fill:#f5a623,stroke:#333
    style InferenceModelRewrite fill:#f5a623,stroke:#333
    style ConfigMap fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
