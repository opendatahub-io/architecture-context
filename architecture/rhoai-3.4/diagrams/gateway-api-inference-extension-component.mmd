graph TB
    subgraph IGW["Gateway API Inference Extension"]
        direction TB

        subgraph EPP_Group["Endpoint Picker Proxy (EPP)"]
            EPP["EPP Server<br/>Go gRPC ext-proc<br/>9002/TCP"]
            EPP_Health["Health Check<br/>gRPC<br/>9003/TCP"]
            EPP_Metrics["Metrics<br/>HTTP<br/>9090/TCP"]
            Scheduler["Scheduling Pipeline<br/>Filters → Scorers → Pickers"]
            FlowControl["Flow Controller<br/>Sharded Queuing<br/>JSQ-Bytes"]
            SatDetector["Saturation Detector<br/>Concurrency + Utilization"]
            Datastore["Datastore<br/>In-Memory CRD Cache"]
        end

        subgraph BBR_Group["Body-Based Router (BBR)"]
            BBR["BBR Server<br/>Go gRPC ext-proc<br/>9004/TCP"]
            BBR_Health["Health Check<br/>gRPC<br/>9005/TCP"]
            BBR_Plugins["Plugin Framework<br/>body_field_to_header"]
            BBR_Store["LoRA Mapping Store<br/>ConfigMap-backed"]
        end

        subgraph Latency_Group["Latency Predictor (Optional)"]
            TrainingServer["Training Server<br/>Python FastAPI<br/>8000/TCP"]
            PredictionServer["Prediction Server<br/>Python FastAPI<br/>8001/TCP"]
            AsyncClient["Async Client<br/>Go Sidecar<br/>Sample Coalescer"]
        end

        subgraph Sidecar_Group["Sidecars"]
            LoRASidecar["Dynamic LoRA Sidecar<br/>Python"]
        end
    end

    %% Internal relationships
    EPP --> Scheduler
    Scheduler --> FlowControl
    Scheduler --> SatDetector
    EPP --> Datastore
    BBR --> BBR_Plugins
    BBR --> BBR_Store
    AsyncClient -->|sends samples| TrainingServer
    EPP -->|requests predictions| PredictionServer
    TrainingServer -->|trained models via PVC| PredictionServer

    %% CRDs watched
    InferencePoolCR["InferencePool CR<br/>inference.networking.k8s.io/v1"]
    InferenceObjCR["InferenceObjective CR<br/>x-k8s.io/v1alpha2"]
    InferenceRewriteCR["InferenceModelRewrite CR<br/>x-k8s.io/v1alpha2"]
    ConfigMapCR["ConfigMaps<br/>bbr-managed=true"]

    InferencePoolCR -->|watched by| Datastore
    InferenceObjCR -->|watched by| Datastore
    InferenceRewriteCR -->|watched by| Datastore
    ConfigMapCR -->|watched by| BBR_Store

    %% External interactions
    Client["Client"] -->|HTTP/80| Gateway
    Gateway["Envoy Gateway<br/>Gateway API"] -->|gRPC ext-proc/9004| BBR
    Gateway -->|gRPC ext-proc/9002| EPP
    EPP -->|routing decision| Gateway
    Gateway -->|routed request| ModelServer["Model Server Pods<br/>(vLLM / SGLang / Triton)"]
    EPP -->|scrape /metrics| ModelServer
    LoRASidecar -->|manages adapters| ModelServer

    EPP -->|watch CRDs| K8sAPI["Kubernetes API<br/>443/TCP"]
    BBR -->|watch ConfigMaps| K8sAPI

    %% Monitoring
    Prometheus["Prometheus"] -->|scrape| EPP_Metrics

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style BBR fill:#4a90e2,stroke:#333,color:#fff
    style Scheduler fill:#5ba3f5,stroke:#333,color:#fff
    style FlowControl fill:#5ba3f5,stroke:#333,color:#fff
    style SatDetector fill:#5ba3f5,stroke:#333,color:#fff
    style Datastore fill:#5ba3f5,stroke:#333,color:#fff
    style BBR_Plugins fill:#5ba3f5,stroke:#333,color:#fff
    style BBR_Store fill:#5ba3f5,stroke:#333,color:#fff
    style TrainingServer fill:#9b59b6,stroke:#333,color:#fff
    style PredictionServer fill:#9b59b6,stroke:#333,color:#fff
    style AsyncClient fill:#9b59b6,stroke:#333,color:#fff
    style LoRASidecar fill:#9b59b6,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style InferenceObjCR fill:#f5a623,stroke:#333
    style InferenceRewriteCR fill:#f5a623,stroke:#333
    style ConfigMapCR fill:#f5a623,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style ModelServer fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#333
