workspace {
    model {
        orchestratorAdmin = person "Platform Admin" "Configures guardrails detection pipelines"

        regexDetector = softwareSystem "Guardrails Regex Detector" "Lightweight Rust-based HTTP service that detects PII in text using regex pattern matching" {
            httpServer = container "HTTP Server" "Axum-based REST API server listening on port 8080" "Rust / Axum 0.7.9"
            emailDetector = container "Email Detector" "Built-in regex pattern for email address detection" "Rust Module"
            ssnDetector = container "SSN Detector" "Built-in regex pattern for Social Security number detection" "Rust Module"
            creditCardDetector = container "Credit Card Detector" "Built-in regex pattern for credit card number detection" "Rust Module"
            customRegexHandler = container "Custom Regex Handler" "Applies arbitrary user-supplied regex patterns" "Rust Module"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Orchestrates multiple detector backends for content guardrails" "Internal RHOAI"
        kubernetes = softwareSystem "Kubernetes" "Container orchestration platform" "Infrastructure"

        // Relationships
        orchestrator -> regexDetector "Sends text content for PII detection" "HTTP/8080 POST /api/v1/text/contents"
        kubernetes -> regexDetector "Health check probes" "HTTP/8080 GET /health"
        orchestratorAdmin -> orchestrator "Configures detection pipelines"

        // Internal relationships
        httpServer -> emailDetector "Routes email detection requests"
        httpServer -> ssnDetector "Routes SSN detection requests"
        httpServer -> creditCardDetector "Routes credit card detection requests"
        httpServer -> customRegexHandler "Routes custom regex requests"
    }

    views {
        systemContext regexDetector "SystemContext" {
            include *
            autoLayout
        }

        container regexDetector "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
