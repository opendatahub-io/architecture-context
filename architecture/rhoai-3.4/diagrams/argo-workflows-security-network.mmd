graph TB
    subgraph Internal["INTERNAL (No External Ingress)"]
        direction TB

        subgraph ControllerPlane["CONTROLLER PLANE"]
            WFC["workflow-controller<br/>SA: argo<br/>UBI9 + FIPS (strictfipsruntime)<br/>9090/TCP metrics (HTTPS, self-signed)<br/>6060/TCP healthz (HTTP)"]
        end

        subgraph KubeCP["KUBERNETES CONTROL PLANE"]
            K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>SA Token Auth"]
        end

        subgraph ExecPlane["WORKFLOW EXECUTION PLANE"]
            StepPod["Workflow Step Pod<br/>SA: (workflow SA)"]
            ArgoExec["argoexec (emissary)<br/>No ports exposed<br/>Dual binary: standard + FIPS"]
            UserContainer["User Container<br/>ML pipeline step"]
            ArgoExec -->|process exec<br/>no network| UserContainer
        end

        subgraph PlatformInternal["RHOAI PLATFORM"]
            DSPOp["DSP Operator<br/>Deploys & configures"]
            KFP["Kubeflow Pipelines<br/>API Server<br/>Creates Workflow CRs"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3 / Minio<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        PostgreSQL["PostgreSQL (optional)<br/>5432/TCP<br/>Optional SSL<br/>Username/Password"]
        Registry["Container Registries<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    %% Internal flows
    DSPOp -->|deploys| WFC
    KFP -->|HTTPS/6443<br/>SA Token<br/>Create Workflow CR| K8sAPI
    WFC -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>Watch CRs, CRUD Pods| K8sAPI
    K8sAPI -->|informer events| WFC
    WFC -->|creates| StepPod

    %% Executor flows
    ArgoExec -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token (mounted)<br/>WorkflowTaskResult| K8sAPI

    %% External egress
    ArgoExec -->|HTTPS/443<br/>TLS 1.2+<br/>S3 credentials<br/>Artifact I/O| S3
    WFC -->|TCP/5432<br/>Optional SSL<br/>Username/Password<br/>Workflow archival| PostgreSQL
    WFC -->|HTTPS/443<br/>TLS 1.2+<br/>Artifact GC| S3
    K8sAPI -->|HTTPS/443<br/>TLS 1.2+<br/>Pull argoexec image| Registry

    %% Styling
    classDef controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef kubecp fill:#e8e8e8,stroke:#333,stroke-width:2px,color:#000
    classDef executor fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#000
    classDef platform fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000

    class WFC controller
    class K8sAPI kubecp
    class StepPod,ArgoExec,UserContainer executor
    class DSPOp,KFP platform
    class S3,PostgreSQL,Registry external
