graph TB
    subgraph Platform["INTERNAL PLATFORM (No External Ingress)"]
        direction TB

        subgraph DSP["Data Science Pipelines"]
            DSPServer["DSP API Server<br/>User-facing pipeline API"]
        end

        subgraph K8sLayer["KUBERNETES API"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth + RBAC"]
        end

        subgraph ArgoRuntime["ARGO WORKFLOWS RUNTIME"]
            direction TB

            subgraph ControllerNS["Namespace: {controller-namespace}"]
                WFC["workflow-controller<br/>SA: argo<br/>Leader Election: lease-based<br/>FIPS: strictfipsruntime"]
                MetricsPort["Metrics: 9090/TCP<br/>HTTPS, TLS 1.2+, No auth"]
                HealthzPort["Healthz: 6060/TCP<br/>HTTP, No encryption"]
            end

            subgraph WorkflowNS["Namespace: {workflow-namespace}"]
                subgraph WFPod["Workflow Pod"]
                    ArgoExec["argoexec (emissary)<br/>FIPS + non-FIPS variants<br/>No network listener"]
                    UserContainer["User Container<br/>Wrapped by emissary"]
                end
            end
        end

        subgraph Monitoring["MONITORING"]
            Prometheus["Prometheus"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3/MinIO Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AccessKey/IAM"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Key"]
        Azure["Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Account Key"]
        PG["PostgreSQL (optional)<br/>5432/TCP<br/>SSL configurable<br/>Secret credentials"]
        MySQL_DB["MySQL (optional)<br/>3306/TCP<br/>Optional TLS<br/>Secret credentials"]
        Git["Git Repos<br/>22/443 SSH/HTTPS<br/>SSH key/password"]
    end

    %% Flows
    DSPServer -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Create Workflow CR"| K8sAPI
    K8sAPI -->|"Watch events<br/>CRD lifecycle"| WFC
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Create Pods"| K8sAPI
    K8sAPI -->|"Schedule Pod"| WFPod
    ArgoExec -->|"Filesystem<br/>/var/run/argo/<br/>Signal files"| UserContainer
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Create TaskResult CR"| K8sAPI
    Prometheus -->|"HTTPS/9090<br/>TLS 1.2+<br/>No auth"| MetricsPort

    %% Egress flows
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>AccessKey/IAM"| S3
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Key"| GCS
    ArgoExec -->|"HTTPS/443<br/>TLS 1.2+<br/>Account Key"| Azure
    ArgoExec -->|"SSH/HTTPS<br/>22/443"| Git
    WFC -.->|"TCP/5432<br/>SSL configurable<br/>Secret creds"| PG
    WFC -.->|"TCP/3306<br/>Optional TLS<br/>Secret creds"| MySQL_DB

    %% Styling
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef argo fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pod fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class DSPServer platform
    class K8sAPI k8s
    class WFC,ArgoExec,MetricsPort,HealthzPort argo
    class Prometheus monitoring
    class S3,GCS,Azure,PG,MySQL_DB,Git external
    class UserContainer pod
