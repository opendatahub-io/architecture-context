// Llama Stack Distribution - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/llama-stack-distribution.md

workspace {
    model {
        user = person "Data Scientist / Developer" "Uses AI/ML APIs for inference, agents, safety, evaluation, and RAG"

        llamaStackDistribution = softwareSystem "Llama Stack Distribution" "Unified AI/ML API server providing inference, agents, safety, evaluation, and vector I/O" {
            server = container "Llama Stack Server" "Core API server exposing REST endpoints on port 8321" "Python (FastAPI/Uvicorn)"
            config = container "Distribution Config" "Defines enabled APIs, providers, and resources" "YAML Configuration"
            entrypoint = container "Entrypoint Script" "Container entrypoint with optional OpenTelemetry wrapping" "Shell Script"
        }

        // Internal RHOAI Dependencies
        vllm = softwareSystem "vLLM" "LLM and embedding inference server (OpenAI-compatible)" "Internal RHOAI"
        trustyaiFMS = softwareSystem "TrustyAI FMS Orchestrator" "Safety shield evaluation service" "Internal RHOAI"
        trustyaiLMEval = softwareSystem "TrustyAI LM Eval" "Model evaluation service" "Internal RHOAI"
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines" "RAGAS and Garak evaluation pipeline execution" "Internal RHOAI"
        postgresql = softwareSystem "PostgreSQL" "Primary persistence backend (KV store, SQL, inference logging)" "Internal RHOAI"

        // Vector Stores
        milvus = softwareSystem "Milvus" "Vector storage and retrieval (inline or remote)" "Configurable"
        pgvector = softwareSystem "pgvector" "PostgreSQL-based vector storage" "Configurable"
        qdrant = softwareSystem "Qdrant" "Vector storage via REST/gRPC" "Configurable"

        // External Cloud Providers
        awsBedrock = softwareSystem "AWS Bedrock" "Cloud inference provider" "External Cloud"
        watsonx = softwareSystem "IBM WatsonX" "Cloud inference provider" "External Cloud"
        azureOpenAI = softwareSystem "Azure OpenAI" "Cloud inference provider" "External Cloud"
        vertexAI = softwareSystem "Google Vertex AI" "Cloud inference provider" "External Cloud"
        openAI = softwareSystem "OpenAI API" "Cloud inference provider" "External Cloud"

        // External Services
        s3 = softwareSystem "S3-compatible Storage" "File and model artifact storage" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Dataset and model downloads" "External"
        braveSearch = softwareSystem "Brave Search API" "Web search tool runtime" "External"
        tavilySearch = softwareSystem "Tavily Search API" "Web search tool runtime" "External"
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry traces and metrics" "External"

        // Platform
        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages deployment, ingress, and RBAC" "Internal RHOAI"

        // Relationships
        user -> llamaStackDistribution "Uses AI/ML APIs via" "HTTP/8321"
        rhoaiOperator -> llamaStackDistribution "Deploys and manages" "Kubernetes API"

        llamaStackDistribution -> vllm "Inference requests" "HTTP(S), API Token"
        llamaStackDistribution -> postgresql "State persistence" "PostgreSQL/5432, Username/Password"
        llamaStackDistribution -> trustyaiFMS "Safety evaluation" "HTTP(S)"
        llamaStackDistribution -> trustyaiLMEval "Model evaluation" "HTTP(S) / K8s API"
        llamaStackDistribution -> kubeflowPipelines "Evaluation pipelines" "HTTP(S), API Token"

        llamaStackDistribution -> milvus "Vector operations" "HTTP/gRPC, Token"
        llamaStackDistribution -> pgvector "Vector storage" "PostgreSQL/5432"
        llamaStackDistribution -> qdrant "Vector storage" "HTTP/gRPC/6333-6334, API Key"

        llamaStackDistribution -> awsBedrock "Inference" "HTTPS/443, Bearer Token"
        llamaStackDistribution -> watsonx "Inference" "HTTPS/443, API Key"
        llamaStackDistribution -> azureOpenAI "Inference" "HTTPS/443, API Key"
        llamaStackDistribution -> vertexAI "Inference" "HTTPS/443, Service Account"
        llamaStackDistribution -> openAI "Inference" "HTTPS/443, API Key"

        llamaStackDistribution -> s3 "File storage" "HTTPS/443, AWS IAM"
        llamaStackDistribution -> huggingface "Model/dataset access" "HTTPS/443"
        llamaStackDistribution -> braveSearch "Web search" "HTTPS/443, API Key"
        llamaStackDistribution -> tavilySearch "Web search" "HTTPS/443, API Key"
        llamaStackDistribution -> otlpCollector "Telemetry export" "OTLP/HTTP"

        // Container-level relationships
        entrypoint -> server "Launches"
        config -> server "Loaded by"
    }

    views {
        systemContext llamaStackDistribution "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackDistribution "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Cloud" {
                background #f5a623
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Configurable" {
                background #9b59b6
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
