graph LR
    Provider["llama-stack-provider-ragas<br/>Python Library"]

    %% External Dependencies (Required)
    Provider -->|"core evaluation<br/>framework"| Ragas["ragas 0.3.0"]
    Provider -->|"API types &<br/>provider interfaces"| LlamaStack["llama-stack >0.2.23"]
    Provider -->|"LLM/embedding<br/>base classes"| LangChain["langchain-core"]
    Provider -->|"DataFrame<br/>manipulation"| Pandas["pandas <2.3.0"]
    Provider -->|"data serialization"| PyArrow["pyarrow >=21.0.0"]
    Provider -->|"config models"| Pydantic["pydantic"]
    Provider -->|"TLS/crypto"| Cryptography["cryptography 46.0.2"]

    %% External Dependencies (Remote mode only)
    Provider -->|"pipeline SDK<br/>(remote mode)"| KFP["kfp >=2.5.0"]
    Provider -->|"K8s secret mount<br/>(remote mode)"| KFPk8s["kfp-kubernetes >=2.0.0"]
    Provider -->|"HTTP client<br/>(remote mode)"| LlamaClient["llama-stack-client"]
    Provider -->|"K8s client<br/>(remote mode)"| K8sClient["kubernetes >=30.0.0"]
    Provider -->|"S3 access<br/>(remote mode)"| S3FS["s3fs >=2024.12.0"]
    Provider -->|"HTTP requests<br/>KFP health check"| Requests["requests >=2.32.5"]

    %% Internal Platform Dependencies
    Provider -.->|"manages deployment"| LlamaStackOp["Llama Stack Operator"]
    Provider -.->|"hosts Eval API"| LLSServer["Llama Stack Distribution Server"]
    Provider -.->|"remote eval jobs"| DSPipelines["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    Provider -.->|"base image config"| TrustyAI["TrustyAI Service Operator"]
    Provider -.->|"inference backend"| vLLM["vLLM / Model Serving"]
    Provider -.->|"result storage"| S3["S3 / Object Storage"]

    %% Integration points (incoming)
    LlamaStackOp -->|"CRD: LlamaStackDistribution"| Provider

    %% Styling
    style Provider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style Ragas fill:#e8e8e8,stroke:#666
    style LlamaStack fill:#e8e8e8,stroke:#666
    style LangChain fill:#e8e8e8,stroke:#666
    style Pandas fill:#e8e8e8,stroke:#666
    style PyArrow fill:#e8e8e8,stroke:#666
    style Pydantic fill:#e8e8e8,stroke:#666
    style Cryptography fill:#e8e8e8,stroke:#666

    %% External remote-mode
    style KFP fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5
    style KFPk8s fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5
    style LlamaClient fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5
    style K8sClient fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5
    style S3FS fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5
    style Requests fill:#d5d5d5,stroke:#666,stroke-dasharray: 5 5

    %% Internal platform
    style LlamaStackOp fill:#7ed321,stroke:#333,color:#000
    style LLSServer fill:#7ed321,stroke:#333,color:#000
    style DSPipelines fill:#7ed321,stroke:#333,color:#000
    style TrustyAI fill:#7ed321,stroke:#333,color:#000
    style vLLM fill:#7ed321,stroke:#333,color:#000
    style S3 fill:#f5a623,stroke:#333,color:#000
