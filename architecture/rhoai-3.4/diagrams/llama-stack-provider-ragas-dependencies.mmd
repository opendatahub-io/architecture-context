graph LR
    RagasProvider["llama-stack-provider-ragas<br/>Python Plugin"]

    %% External Dependencies (always required)
    RagasProvider -->|"evaluation framework"| Ragas["ragas 0.3.0"]
    RagasProvider -->|"provider framework"| LlamaStack["llama-stack >0.2.23"]
    RagasProvider -->|"LLM/embeddings interfaces"| LangChainCore["langchain-core<br/>(transitive via ragas)"]
    RagasProvider -->|"DataFrame operations"| Pandas["pandas <2.3.0"]
    RagasProvider -->|"columnar data"| PyArrow["pyarrow >=21.0.0"]
    RagasProvider -->|"HTTP client"| Requests["requests >=2.32.5"]
    RagasProvider -->|"datasets"| HFDatasets["datasets >=2.16.0"]
    RagasProvider -->|"config validation"| Pydantic["pydantic"]
    RagasProvider -->|"TLS/crypto"| Cryptography["cryptography 46.0.2"]

    %% Remote-only Dependencies
    RagasProvider -.->|"pipeline SDK (remote)"| KFP["kfp >=2.5.0"]
    RagasProvider -.->|"K8s extensions (remote)"| KFPKubernetes["kfp-kubernetes >=2.0.0"]
    RagasProvider -.->|"K8s client (remote)"| Kubernetes["kubernetes >=30.0.0"]
    RagasProvider -.->|"S3 filesystem (remote)"| S3FS["s3fs >=2024.12.0"]
    RagasProvider -.->|"HTTP client (remote)"| LlamaStackClient["llama-stack-client"]

    %% Internal Platform Dependencies
    RagasProvider ==>|"runtime host"| LlamaStackServer["Llama Stack Server"]
    RagasProvider ==>|"deployment CRD"| LlamaStackOp["Llama Stack Operator"]
    RagasProvider ==>|"pipeline execution"| DSP["Data Science Pipelines<br/>(Kubeflow Pipelines)"]
    RagasProvider ==>|"base image config"| TrustyAIOp["TrustyAI Service Operator<br/>ConfigMap"]
    RagasProvider ==>|"inference backend"| InferenceBackend["Ollama / vLLM"]

    %% Integration Points (other components that use this)
    LlamaStackServer -->|"hosts plugin"| RagasProvider

    style RagasProvider fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

