graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["planner-backend<br/>Namespace: planner"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["planner-gpu-reader<br/>(ClusterRoleBinding)<br/>Scope: Cluster-wide"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["planner-gpu-reader<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        Nodes["core (v1)<br/>nodes"]
    end

    subgraph Verbs["Permitted Operations"]
        ListVerb["list"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"allows"| ListVerb
    ListVerb -->|"on resource"| Nodes

    subgraph AuthNSummary["Authentication Summary"]
        direction LR
        NoAuth["Backend API Endpoints<br/>Auth: NONE<br/>28 endpoints, 9 route modules<br/>Relies on OpenShift Route<br/>for external access"]
        MCAuth["Model Catalog (outbound)<br/>Auth: Bearer Token<br/>SA token or MODEL_CATALOG_TOKEN<br/>TLS: service-serving CA"]
        HFAuth["HuggingFace (outbound)<br/>Auth: Bearer Token (optional)<br/>HF_TOKEN env var<br/>Required for gated models"]
        K8sAuth["Kubernetes API (outbound)<br/>Auth: ServiceAccount Token<br/>RBAC: planner-gpu-reader<br/>Resources: nodes (list)"]
        PGAuth["PostgreSQL (internal)<br/>Auth: Password<br/>Secret: planner-secrets"]
    end

    subgraph Secrets["Secrets"]
        PlannerSecrets["planner-secrets<br/>Type: Opaque<br/>Keys: postgres-password,<br/>model-catalog-token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    SA -.->|"mounts"| PlannerSecrets
    PlannerSecrets -.->|"provides credentials"| PGAuth
    PlannerSecrets -.->|"provides token"| MCAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style CRB fill:#ffe6cc,stroke:#d79b00
    style Nodes fill:#7ed321,stroke:#333,color:#fff
    style ListVerb fill:#d5e8d4,stroke:#82b366
    style PlannerSecrets fill:#f8cecc,stroke:#b85450
    style NoAuth fill:#fff2cc,stroke:#d6b656
    style MCAuth fill:#d5e8d4,stroke:#82b366
    style HFAuth fill:#d5e8d4,stroke:#82b366
    style K8sAuth fill:#d5e8d4,stroke:#82b366
    style PGAuth fill:#dae8fc,stroke:#6c8ebf
