graph TD
    subgraph Library["ai4rag (Python Library)"]
        Note["ai4rag is a Python library, not a<br/>Kubernetes operator or deployed service.<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined by this component."]
    end

    subgraph Credentials["Credentials / Secrets"]
        APIKEY["API_KEY<br/><i>Environment Variable</i><br/>Type: API Key (Bearer Token)<br/>Provisioned: User (.env file)<br/>Auto-Rotate: No"]
        BASEURL["BASE_URL<br/><i>Environment Variable</i><br/>Type: URL<br/>Provisioned: User (.env file)<br/>Auto-Rotate: No"]
    end

    subgraph AuthFlow["Authentication Flow"]
        OGXClient["OgxClient<br/><i>api_key=API_KEY<br/>base_url=BASE_URL</i>"]
        OGXServer["OGX Server<br/><i>Validates Bearer Token</i>"]
    end

    subgraph ConsumedRBAC["RBAC When Consumed by KFP"]
        KFPNote["When ai4rag runs inside a KFP pipeline pod:<br/>• Pod uses KFP pipeline ServiceAccount<br/>• RBAC managed by Kubeflow Pipelines<br/>• ai4rag itself requires no K8s API access<br/>• Only needs network egress to OGX Server"]
    end

    APIKEY -->|"loaded at init"| OGXClient
    BASEURL -->|"loaded at init"| OGXClient
    OGXClient -->|"Authorization: Bearer {API_KEY}<br/>HTTPS / TLS"| OGXServer

    %% Styling
    style Note fill:#f0f0f0,stroke:#ccc,stroke-width:1px
    style APIKEY fill:#e74c3c,stroke:#333,color:#fff
    style BASEURL fill:#e67e22,stroke:#333,color:#fff
    style OGXClient fill:#4a90e2,stroke:#333,color:#fff
    style OGXServer fill:#f5a623,stroke:#333,color:#fff
    style KFPNote fill:#f0f0f0,stroke:#ccc,stroke-width:1px
