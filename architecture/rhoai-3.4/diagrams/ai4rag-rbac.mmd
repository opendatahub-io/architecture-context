graph TD
    subgraph Notice["ai4rag RBAC"]
        NoRBAC["ai4rag is a Python library<br/>No Kubernetes RBAC requirements<br/><br/>No ClusterRoles<br/>No Roles<br/>No RoleBindings<br/>No ServiceAccounts"]
    end

    subgraph Credentials["Credentials / Authentication"]
        direction TB
        APIKey["API_KEY<br/>Environment Variable<br/>Provisioned by: User (.env file)<br/>Auto-Rotate: No"]
        BaseURL["BASE_URL<br/>Environment Variable<br/>Provisioned by: User (.env file)<br/>Auto-Rotate: No"]
    end

    subgraph AuthFlow["Authentication Flow"]
        direction LR
        Library["ai4rag Library"]
        LSClient["LlamaStackClient<br/>Bearer token in<br/>HTTP Authorization header"]
        OAIClient["OpenAI Client<br/>Bearer token in<br/>HTTP Authorization header"]
        LSServer["Llama Stack Server<br/>Server-side validation"]
        OAIServer["OpenAI-compatible Server<br/>Server-side validation"]
    end

    APIKey -->|"loaded by"| Library
    BaseURL -->|"loaded by"| Library
    Library -->|"passes API_KEY"| LSClient
    Library -->|"passes API key"| OAIClient
    LSClient -->|"Bearer token<br/>HTTPS"| LSServer
    OAIClient -->|"Bearer token<br/>HTTPS"| OAIServer

    %% Styling
    style NoRBAC fill:#f3f4f6,stroke:#9ca3af,stroke-width:2px
    style APIKey fill:#fef3c7,stroke:#d97706
    style BaseURL fill:#fef3c7,stroke:#d97706
    style Library fill:#dbeafe,stroke:#3b82f6
    style LSClient fill:#e0e7ff,stroke:#6366f1
    style OAIClient fill:#e0e7ff,stroke:#6366f1
    style LSServer fill:#e5e7eb,stroke:#6b7280
    style OAIServer fill:#e5e7eb,stroke:#6b7280
