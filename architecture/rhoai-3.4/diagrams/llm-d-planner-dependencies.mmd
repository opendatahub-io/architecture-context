graph LR
    Planner["llm-d Planner<br/>(FastAPI Backend)"]

    %% Internal Platform Dependencies (co-deployed)
    Planner -->|"LLM inference<br/>HTTP/11434"| Ollama["Ollama<br/>granite3.3:2b / qwen2.5:7b"]
    Planner -->|"benchmark storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 16<br/>(RHEL9)"]

    %% Internal RHOAI Dependencies
    Planner -->|"model & benchmark data<br/>HTTPS/8443"| ModelCatalog["RHOAI Model Catalog<br/>(optional data source)"]
    Planner -.->|"generates YAML for<br/>InferenceService CRD"| KServe["KServe<br/>serving.kserve.io/v1beta1"]
    Planner -.->|"references as<br/>inference runtime"| vLLM["vLLM<br/>(container image)"]

    %% External Dependencies
    Planner -->|"model metadata<br/>HTTPS/443"| HuggingFace["HuggingFace Hub API"]
    Planner -->|"GPU detection, deploy<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]

    %% Embedded Libraries
    Planner -->|"roofline estimation<br/>(embedded library)"| LLMOptimizer["BentoML llm-optimizer<br/>(Python library, no network)"]

    %% Platform Dependencies
    Planner -->|"TLS termination<br/>443 → 8000"| OpenShiftRoute["OpenShift Route<br/>(edge termination)"]
    Planner -->|"CA cert injection"| ServiceCA["OpenShift service-serving CA<br/>(ConfigMap annotation)"]

    %% UI dependency
    StreamlitUI["Streamlit UI<br/>8501/TCP"] -->|"REST API<br/>HTTP/8000"| Planner

    %% NetworkPolicy
    Planner -.->|"NetworkPolicy<br/>allows 8443/TCP"| ModelCatalogNS["rhoai-model-registries<br/>namespace"]

    %% Key Python Dependencies
    subgraph PythonDeps["Key Python Libraries"]
        FastAPI["FastAPI >=0.136.1"]
        Pydantic["Pydantic 2.13.3"]
        Jinja2["Jinja2 3.1.6"]
        HFHub["huggingface_hub >=1.13.0"]
        Transformers["transformers >=5.7.0"]
        K8sClient["kubernetes >=35.0.0<br/>(optional)"]
    end

    Planner -.-> PythonDeps

    %% Styling
    style Planner fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style StreamlitUI fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Ollama fill:#7ed321,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#7ed321,stroke:#333,color:#fff
    style HuggingFace fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style LLMOptimizer fill:#e8e8e8,stroke:#333
    style OpenShiftRoute fill:#ffe6cc,stroke:#d79b00
    style ServiceCA fill:#ffe6cc,stroke:#d79b00
    style ModelCatalogNS fill:#e1d5e7,stroke:#9673a6
    style FastAPI fill:#e8e8e8,stroke:#999
    style Pydantic fill:#e8e8e8,stroke:#999
    style Jinja2 fill:#e8e8e8,stroke:#999
    style HFHub fill:#e8e8e8,stroke:#999
    style Transformers fill:#e8e8e8,stroke:#999
    style K8sClient fill:#e8e8e8,stroke:#999
