graph TB
    subgraph "KServe AutoGluon Server"
        direction TB
        Main["__main__.py<br/>Entry Point"]
        DetectedModel["AutoGluonDetectedModel<br/>Auto-detect model type"]
        TabularModel["AutoGluonTabularModel<br/>Tabular inference (v1 + v2)"]
        TSModel["AutoGluonTimeSeriesModel<br/>Time series inference (v1)"]
        ModelRepo["AutoGluonModelRepository<br/>Multi-model fallback loader"]
        RuntimePaths["runtime_paths.py<br/>Writable dir finder"]

        Main -->|initializes| DetectedModel
        Main -->|fallback| ModelRepo
        DetectedModel -->|"tries timeseries first"| TSModel
        DetectedModel -->|"then tabular"| TabularModel
        ModelRepo -->|"scans subdirs"| DetectedModel
        Main -->|"fixes cwd"| RuntimePaths
    end

    subgraph "KServe SDK (v0.17.0)"
        ModelServer["ModelServer<br/>FastAPI + Uvicorn"]
        ModelBase["Model Base Class"]
        InferProtocol["Inference Protocol<br/>v1 JSON / v2 Tensor"]
    end

    subgraph "Storage (Init Container)"
        StorageInit["Storage Initializer<br/>kserve-storage v0.17.0"]
    end

    Main -->|"registers with"| ModelServer
    DetectedModel -->|"extends"| ModelBase
    TabularModel -->|"uses"| InferProtocol
    TSModel -->|"uses"| InferProtocol

    User[Data Scientist / Client] -->|"POST /v1/models/:predict<br/>POST /v2/models/infer"| ModelServer

    CSR["ClusterServingRuntime CR<br/>kserve-autogluonserver"]
    CSR -->|"defines runtime for"| Main

    KServeCtrl["KServe Controller"] -->|"reads"| CSR
    KServeCtrl -->|"creates pods with"| StorageInit

    StorageInit -->|"downloads to<br/>/mnt/models"| LocalVol["/mnt/models<br/>Local Volume"]
    DetectedModel -->|"loads from"| LocalVol

    CloudStorage["Cloud Storage<br/>S3 / GCS / Azure / HF"]
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+"| CloudStorage

    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8080/TCP"| ModelServer

    style Main fill:#4a90e2,color:#fff
    style DetectedModel fill:#4a90e2,color:#fff
    style TabularModel fill:#4a90e2,color:#fff
    style TSModel fill:#4a90e2,color:#fff
    style ModelRepo fill:#4a90e2,color:#fff
    style RuntimePaths fill:#4a90e2,color:#fff
    style ModelServer fill:#7ed321,color:#fff
    style ModelBase fill:#7ed321,color:#fff
    style InferProtocol fill:#7ed321,color:#fff
    style StorageInit fill:#7ed321,color:#fff
    style CSR fill:#f5a623,color:#fff
    style KServeCtrl fill:#e8e8e8
    style CloudStorage fill:#e8e8e8
    style Prometheus fill:#e8e8e8
    style LocalVol fill:#ddd
