graph TB
    subgraph "KServe AutoGluon Server"
        direction TB
        Main["__main__.py<br/>Entry Point"]
        PredFactory["PredictorFactory<br/>Auto-detect model type"]
        PredDetect["PredictorDetect<br/>TimeSeriesPredictor → TabularPredictor<br/>fallback chain"]
        TabularModel["TabularModel<br/>v1 JSON + v2 Tensor<br/>predict / predict_proba"]
        TSModel["TimeSeriesModel<br/>v1 JSON only<br/>forecast with covariates"]
        ModelRepo["AutoGluonModelRepository<br/>Multi-model directory support"]
        RuntimePaths["RuntimePaths<br/>Writable CWD for non-root containers"]

        Main -->|initializes| PredFactory
        PredFactory -->|uses| PredDetect
        PredDetect -->|loads| TabularModel
        PredDetect -->|loads| TSModel
        Main -->|fallback| ModelRepo
        Main -->|startup + per-request| RuntimePaths
    end

    subgraph "KServe Python SDK"
        ModelServer["ModelServer<br/>FastAPI + Uvicorn"]
        InferProto["Inference Protocol<br/>v1 JSON / v2 Tensor / gRPC"]
        StorageLib["Storage Library<br/>S3 / GCS / Azure / Local"]
        Metrics["Prometheus Metrics<br/>/metrics endpoint"]
    end

    subgraph "Platform Infrastructure"
        KServeCtrl["KServe Controller"]
        StorageInit["Storage Initializer<br/>(init container)"]
        RBAC["kube-rbac-proxy<br/>Sidecar (8443→8080)"]
    end

    subgraph "External Resources"
        ISCR["InferenceService CR"]
        CSRT["ClusterServingRuntime<br/>autogluon format"]
        CloudStorage["Cloud Storage<br/>S3 / GCS / Azure"]
        HFHub["Hugging Face Hub<br/>(Chronos models)"]
    end

    %% Internal connections
    Main -->|extends| ModelServer
    TabularModel -->|implements| InferProto
    TSModel -->|implements| InferProto
    ModelServer -->|exposes| Metrics

    %% Platform connections
    User["Data Scientist"] -->|creates| ISCR
    ISCR -->|references| CSRT
    KServeCtrl -->|watches| ISCR
    KServeCtrl -->|creates pod with| Main
    KServeCtrl -->|injects| StorageInit
    KServeCtrl -->|injects| RBAC
    StorageInit -->|downloads to /mnt/models| CloudStorage

    %% Client flow
    Client["Inference Client"] -->|HTTPS/8443| RBAC
    RBAC -->|HTTP/8080| ModelServer

    %% Egress
    TSModel -.->|optional model download| HFHub

