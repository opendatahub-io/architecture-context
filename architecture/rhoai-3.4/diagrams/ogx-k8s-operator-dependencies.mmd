graph LR
    Operator["llama-stack-k8s-operator<br/>(Go Operator)"]

    %% External Library Dependencies
    subgraph GoLibs["Go Libraries"]
        ControllerRuntime["controller-runtime<br/>v0.22.4"]
        KustomizeAPI["kustomize/api<br/>v0.21.0"]
        GoContainerReg["go-containerregistry<br/>v0.20.7"]
        GoCmp["go-cmp<br/>v0.7.0"]
    end

    Operator -->|"controller framework<br/>reconciliation, leader election"| ControllerRuntime
    Operator -->|"manifest rendering<br/>kustomize plugins"| KustomizeAPI
    Operator -->|"image ref validation"| GoContainerReg
    Operator -->|"object comparison"| GoCmp

    %% Platform Dependencies
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    IngressCtrl["OpenShift Ingress Controller<br/>80/443/TCP"]
    OpenShiftSCC["OpenShift SCC System<br/>(anyuid)"]

    Operator -->|"CRUD, watch, leader election"| K8sAPI
    Operator -->|"external traffic routing"| IngressCtrl
    Operator -->|"SCC RoleBinding"| OpenShiftSCC

    %% Internal Platform Dependencies
    ODHTrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    OperatorConfig["llama-stack-operator-config<br/>ConfigMap"]
    LLSDImages["LlamaStack Distribution<br/>Images (quay.io)"]

    Operator -->|"reads CA certs"| ODHTrustedCA
    Operator -->|"reads feature flags,<br/>image overrides"| OperatorConfig
    Operator -->|"deploys as pods"| LLSDImages

    %% Integration Points (other components that interact)
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"]
    Prometheus["Prometheus"]
    UserConfigMaps["User CA ConfigMaps"]

    RHOAIOp -->|"deploys operator<br/>via kustomize overlays"| Operator
    Prometheus -->|"scrapes /metrics<br/>8080/TCP"| Operator
    UserConfigMaps -->|"user CA certificates<br/>for TLS trust"| Operator

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333
    style KustomizeAPI fill:#999,stroke:#333
    style GoContainerReg fill:#999,stroke:#333
    style GoCmp fill:#999,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
    style IngressCtrl fill:#f5a623,stroke:#333
    style OpenShiftSCC fill:#f5a623,stroke:#333
    style ODHTrustedCA fill:#7ed321,stroke:#333
    style OperatorConfig fill:#7ed321,stroke:#333
    style LLSDImages fill:#7ed321,stroke:#333
    style RHOAIOp fill:#7ed321,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
    style UserConfigMaps fill:#e8e8e8,stroke:#333
