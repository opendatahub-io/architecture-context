graph LR
    Operator["LlamaStack K8s Operator<br/>(ogx-k8s-operator)"]

    %% External Dependencies (Go libraries / frameworks)
    Operator -->|"controller framework<br/>v0.22.4"| ControllerRuntime["controller-runtime"]
    Operator -->|"manifest rendering<br/>v0.21.0"| Kustomize["kustomize/api"]
    Operator -->|"image ref parsing<br/>v0.20.7"| GoContainerReg["go-containerregistry"]
    Operator -->|"metrics exposition<br/>v1.22.0"| PromClient["prometheus/client_golang"]
    Operator -->|"K8s API types<br/>v0.34.3"| K8sAPI["k8s.io/api"]

    %% Internal Platform Dependencies
    Operator -->|"CA cert aggregation"| ODHTrustCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    Operator -->|"anyuid SCC grants"| OpenShiftSCC["OpenShift SCC<br/>(anyuid)"]
    Operator -.->|"deployed by"| RHOAIOp["RHOAI Operator<br/>(rhods-operator)"]

    %% Runtime Dependencies (Cluster Services)
    Operator -->|"resource CRUD<br/>443/TCP HTTPS"| K8sAPISvr["Kubernetes API Server"]
    Operator -->|"feature flags<br/>image overrides"| OperatorConfig["llama-stack-operator-config<br/>ConfigMap"]

    %% Managed Workloads (downstream)
    Operator -->|"creates & manages"| LLServer["LlamaStack Server<br/>Pods"]
    Operator -->|"health/status<br/>8321/TCP HTTP"| LLServer

    %% Monitoring integration
    PromScrape["Prometheus<br/>(ServiceMonitor)"] -->|"scrapes metrics<br/>8443/TCP HTTPS"| Operator

    %% Ingress (optional)
    Operator -->|"creates when<br/>exposeRoute=true"| IngressRes["Ingress Resource"]
    IngressCtrl["Ingress Controller"] -->|"routes traffic<br/>80→8321"| LLServer

    %% Styles
    style Operator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps (grey)
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Kustomize fill:#999,stroke:#333,color:#fff
    style GoContainerReg fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% Internal RHOAI deps (green)
    style ODHTrustCA fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftSCC fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style OperatorConfig fill:#7ed321,stroke:#333,color:#fff

    %% Cluster services (orange)
    style K8sAPISvr fill:#f5a623,stroke:#333,color:#fff
    style PromScrape fill:#f5a623,stroke:#333,color:#fff
    style IngressCtrl fill:#f5a623,stroke:#333,color:#fff

    %% Managed workloads (teal)
    style LLServer fill:#50c8c8,stroke:#333,color:#fff
