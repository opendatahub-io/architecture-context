    CaikitNLP -->|"model loading<br/>tokenization"| Transformers["transformers<br/>>=4.38.0,<4.44.0"]
    CaikitNLP -->|"deep learning<br/>inference & training"| PyTorch["torch<br/>>=2.3.1,<2.5.0"]
    CaikitNLP -->|"prompt tuning<br/>PEFT methods"| PEFT["peft<br/>==0.6.0"]
    CaikitNLP -->|"mixed precision<br/>distributed training"| Accelerate["accelerate<br/>>=0.22.0"]
    CaikitNLP -->|"embeddings<br/>cross-encoders"| SentenceTransformers["sentence-transformers<br/>>=3.0.0,<3.1.0"]

    %% Data & ML Dependencies
    CaikitNLP -->|"dataset loading"| Datasets["datasets<br/>>=2.4.0"]
