graph LR
    CaikitNLP["caikit-nlp<br/>(NLP Runtime Library)"]

    %% Core Framework Dependencies
    CaikitNLP -->|"runtime servers,<br/>module system"| Caikit["caikit<br/>>=0.26.34,<0.28.0"]
    CaikitNLP -->|"TGIS backend<br/>abstraction"| CaikitTGIS["caikit-tgis-backend<br/>>=0.1.36,<0.2.0"]

    %% ML Framework Dependencies
    CaikitNLP -->|"model loading,<br/>tokenizers, trainers"| Transformers["transformers<br/>>=4.38.0,<4.44.0"]
    CaikitNLP -->|"tensor ops,<br/>inference, training"| PyTorch["torch<br/>>=2.3.1,<2.5.0"]
    CaikitNLP -->|"sentence embeddings,<br/>cross-encoders"| SentenceTransformers["sentence-transformers<br/>>=3.0.0,<3.1.0"]
    CaikitNLP -->|"prompt tuning,<br/>multitask PT"| PEFT["peft<br/>==0.6.0"]
    CaikitNLP -->|"distributed<br/>training"| Accelerate["accelerate<br/>>=0.22.0"]
    CaikitNLP -->|"training data"| Datasets["datasets<br/>>=2.4.0"]

    %% gRPC Dependencies
    CaikitNLP -->|"TGIS backend<br/>communication"| GRPC["grpcio<br/>>=1.62.2"]

    %% Scientific Computing
    CaikitNLP -->|"numerical ops"| NumPy["numpy<br/>>=1.22.4"]
    CaikitNLP -->|"ML utilities"| Sklearn["scikit-learn<br/>>=1.1"]

    %% Model Hub
    CaikitNLP -->|"model downloads"| HFHub["huggingface-hub<br/>latest"]

    %% Security-Pinned
    CaikitNLP -->|"HTTP client<br/>(security-pinned)"| Urllib3["urllib3<br/>>=2.6.3"]
    CaikitNLP -->|"async HTTP<br/>(CVE fix)"| Aiohttp["aiohttp<br/>>=3.13.3"]

    %% Optional
    CaikitNLP -.->|"Intel HW<br/>optimization"| IPEX["intel-extension-for-pytorch<br/>(optional)"]

    %% Internal Platform Dependencies
    Caikit -->|"loads library"| CaikitRuntime["caikit Runtime<br/>(gRPC/HTTP servers)"]
    CaikitTGIS -->|"gRPC client"| TGIS["TGIS Server<br/>(Remote Inference)"]
    KServe["KServe / ModelMesh"] -->|"container image<br/>consumer"| CaikitNLP

