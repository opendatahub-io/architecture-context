    CaikitNLP["caikit-nlp<br/>(NLP Runtime Library)"]

    %% Core Framework Dependencies
    CaikitNLP -->|"in-process library<br/>runtime framework"| Caikit["caikit<br/>>=0.26.34,<0.28.0"]
    CaikitNLP -->|"in-process library<br/>TGIS client"| CaikitTGIS["caikit-tgis-backend<br/>>=0.1.36,<0.2.0"]

