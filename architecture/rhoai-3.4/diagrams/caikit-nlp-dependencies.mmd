    %% External Service Dependencies
    CaikitNLP -->|"remote inference<br/>gRPC (optional mTLS)"| TGIS["TGIS Backend"]
    CaikitNLP -->|"model downloads<br/>HTTPS :443"| HuggingFaceHub["HuggingFace Hub<br/>(huggingface.co)"]

