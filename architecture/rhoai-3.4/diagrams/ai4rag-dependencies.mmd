graph LR
    ai4rag["ai4rag<br/><i>RAG HPO Library</i><br/>v0.6.1"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies (pip/uv)"]
        langchain["langchain ~1.1.3<br/><i>RAG framework</i>"]
        langchain_chroma["langchain_chroma ~1.1.0<br/><i>ChromaDB integration</i>"]
        langchain_splitters["langchain-text-splitters ~1.1.0<br/><i>Document chunking</i>"]
        ogx_client["ogx-client ~1.0.0<br/><i>OGX server client</i>"]
        pandas["pandas 2.2.*<br/><i>Data manipulation</i>"]
        pydantic["pydantic 2.11.*<br/><i>Data validation</i>"]
        pygam["pygam ~0.12.0<br/><i>GAM optimization</i>"]
        sklearn["scikit-learn 1.8.*<br/><i>Label encoding</i>"]
        unitxt["unitxt ~1.26.1<br/><i>RAG evaluation metrics</i>"]
    end

    %% Internal Platform Dependencies
    subgraph InternalDeps["Internal RHOAI Platform"]
        ogx_server["OGX Server<br/><i>REST API (HTTPS)</i>"]
        kfp["Kubeflow Pipelines<br/><i>Pipeline orchestration</i>"]
    end

    %% Integration Points (consumers)
    subgraph Consumers["Consumers"]
        kfp_component["KFP Pipeline Components<br/><i>Consumes ai4rag as library</i>"]
    end

    %% Python dependency edges
    ai4rag -->|"document processing"| langchain
    ai4rag -->|"in-memory vector store"| langchain_chroma
    ai4rag -->|"text splitting"| langchain_splitters
    ai4rag -->|"OGX API client"| ogx_client
    ai4rag -->|"data manipulation"| pandas
    ai4rag -->|"validation"| pydantic
    ai4rag -->|"Bayesian HPO"| pygam
    ai4rag -->|"label encoding"| sklearn
    ai4rag -->|"RAG evaluation"| unitxt

    %% Internal platform edges
    ai4rag -->|"chat, embeddings,<br/>vector_stores, vector_io<br/>HTTPS / API Key"| ogx_server
    ai4rag -.->|"KFPEventHandler"| kfp

    %% Consumer edges
    kfp_component -->|"imports library"| ai4rag

