    style ai4rag fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style langchain fill:#e5e7eb,stroke:#6b7280
    style langchainChroma fill:#e5e7eb,stroke:#6b7280
    style langchainSplitters fill:#e5e7eb,stroke:#6b7280
    style llamaStackClient fill:#e5e7eb,stroke:#6b7280
    style openaiSDK fill:#e5e7eb,stroke:#6b7280
    style pandas fill:#e5e7eb,stroke:#6b7280
    style pydantic fill:#e5e7eb,stroke:#6b7280
    style pygam fill:#e5e7eb,stroke:#6b7280
    style sklearn fill:#e5e7eb,stroke:#6b7280
    style unitxt fill:#e5e7eb,stroke:#6b7280

    style llamaStack fill:#7ed321,stroke:#333,color:#fff
    style kfp fill:#7ed321,stroke:#333,color:#fff

    style milvus fill:#f5a623,stroke:#333
    style qdrant fill:#f5a623,stroke:#333
    style openaiEP fill:#f5a623,stroke:#333
