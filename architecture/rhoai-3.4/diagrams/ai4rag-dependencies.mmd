graph LR
    ai4rag["ai4rag<br/>RAG HPO Engine<br/>(Python Library)"]

    %% External Python Dependencies
    subgraph PythonDeps["Python Dependencies (pip)"]
        direction TB
        langchain["langchain ~1.1.3<br/>Document processing"]
        langchainChroma["langchain-chroma ~1.1.0<br/>ChromaDB integration"]
        langchainSplitters["langchain-text-splitters ~1.1.0<br/>Text chunking"]
        llamaStackClient["llama-stack-client ~0.7.1<br/>Llama Stack SDK"]
        openaiSDK["openai 2.23.*<br/>OpenAI-compatible client"]
        pandas["pandas 2.2.*<br/>Data manipulation"]
        pydantic["pydantic 2.11.*<br/>Data validation"]
        pygam["pygam ~0.12.0<br/>GAM surrogate model"]
        sklearn["scikit-learn 1.8.*<br/>Label encoding"]
        unitxt["unitxt ~1.26.1<br/>RAG evaluation metrics"]
    end

    ai4rag -->|chunking| langchain
    ai4rag -->|local vector store| langchainChroma
    ai4rag -->|text splitting| langchainSplitters
    ai4rag -->|Llama Stack API| llamaStackClient
    ai4rag -->|OpenAI API| openaiSDK
    ai4rag -->|data processing| pandas
    ai4rag -->|validation| pydantic
    ai4rag -->|surrogate model| pygam
    ai4rag -->|param encoding| sklearn
    ai4rag -->|evaluation| unitxt

    %% Internal Platform Dependencies
    subgraph PlatformDeps["Internal Platform (RHOAI)"]
        direction TB
        llamaStack["Llama Stack Server<br/>LLM + embedding + vector store"]
        kfp["Kubeflow Pipelines<br/>ML workflow orchestration"]
    end

    ai4rag -->|"HTTPS / API Key<br/>chat, embeddings, vector_io"| llamaStack
    ai4rag -->|"KFPEventHandler<br/>experiment results"| kfp

    %% External Services (via Llama Stack)
    subgraph ExternalServices["External Services"]
        direction TB
        milvus["Milvus<br/>Vector database"]
        qdrant["Qdrant<br/>Vector database"]
        openaiEP["OpenAI-compatible<br/>Endpoint"]
    end

    llamaStack -->|proxied| milvus
    llamaStack -->|proxied| qdrant
    ai4rag -->|"HTTPS / API Key<br/>chat, embeddings"| openaiEP

