graph LR
    MMC["model-metadata-collection<br/>(Build-Time Pipeline +<br/>Data Container)"]

    %% External Dependencies (Build-Time Network)
    MMC -->|"HTTPS/443<br/>Bearer Token (optional)<br/>Model collections, metadata,<br/>README, YAML frontmatter"| HuggingFace["HuggingFace API<br/>huggingface.co"]
    MMC -->|"HTTPS/443<br/>No auth (public)<br/>OCI manifests, layers,<br/>modelcard extraction"| Registry["Red Hat Container Registry<br/>registry.redhat.io<br/>OCI v2"]

    %% Go Library Dependencies
    MMC -->|"Go module"| ContainersImage["containers/image<br/>v5.36.1"]
    MMC -->|"Go module"| GolangText["golang.org/x/text<br/>v0.28.0"]
    MMC -->|"Go module"| YAMLv3["gopkg.in/yaml.v3<br/>v3.0.1"]

    %% Internal Platform Dependencies
    Dashboard["RHOAI Dashboard"] -->|"Volume mount<br/>File I/O<br/>Reads catalog YAML"| MMC
    Konflux["Konflux CI/CD"] -->|"Build pipeline<br/>Tekton tasks<br/>Dockerfile.konflux"| MMC

    %% Static Input Files
    subgraph InputFiles["Static Input Sources"]
        ModelsIndex["models-index.yaml"]
        SupplementalCatalog["supplemental-catalog.yaml"]
        MCPServers["input/mcp_servers/<br/>(redhat, partner, community)"]
        VLLMConfigs["input/models/vllm-config/"]
        ServingOverride["serving-runtime-override.yaml"]
        SVGLogos["assets/*.svg"]
    end

    InputFiles -->|"File I/O<br/>Build-time input"| MMC

    %% Output Artifacts
    MMC -->|"generates"| Catalogs["YAML Catalog Files<br/>data/*.yaml"]

