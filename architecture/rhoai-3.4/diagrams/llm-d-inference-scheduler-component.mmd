graph TB
    subgraph LLMDScheduler["llm-d Inference Scheduler"]
        subgraph EPPComponent["EPP (Endpoint Picker)"]
            EPP["EPP Service<br/>9002/TCP gRPC ext-proc"]
            EPPHealth["Health Probe<br/>9003/TCP gRPC"]
            EPPMetrics["Metrics Endpoint<br/>9090/TCP HTTP"]
            EPPZmq["KV Event Receiver<br/>5557/TCP ZMQ"]
        end

        subgraph SidecarComponent["Routing Sidecar (pd-sidecar)"]
            Sidecar["Inference Proxy<br/>8000/TCP HTTP/HTTPS"]
            SidecarNIXL["NIXL v2 Connector"]
            SidecarSS["Shared Storage Connector"]
            SidecarSGL["SGLang Connector"]
            SidecarSSRF["SSRF Allowlist<br/>InferencePool Watch"]
            Sidecar --> SidecarNIXL
            Sidecar --> SidecarSS
            Sidecar --> SidecarSGL
            Sidecar --> SidecarSSRF
        end

        subgraph TokenizerComponent["UDS Tokenizer"]
            Tokenizer["Tokenizer Sidecar<br/>Unix Domain Socket<br/>8082/TCP health"]
        end
    end

    %% External Inputs
    Client["External Client"] -->|"HTTP/80"| EnvoyGW["Envoy Gateway<br/>(Gateway API)"]
    EnvoyGW -->|"gRPC ext-proc<br/>9002/TCP"| EPP
    EnvoyGW -->|"HTTP/HTTPS<br/>8000/TCP"| Sidecar

    %% EPP Internal Flows
    EPP -->|"Unix Socket"| Tokenizer
    EPP -->|"watches"| InferencePoolCR["InferencePool CR"]
    EPP -->|"watches"| K8sPods["Kubernetes Pods"]

    %% EPP to vLLM
    EPP -->|"ZMQ SUB<br/>5556/TCP"| vLLMEngines["vLLM Engines<br/>(KV-cache events)"]
    EPP -->|"HTTP GET<br/>/v1/models"| vLLMModels["vLLM Model Servers"]

    %% Sidecar flows
    Sidecar -->|"HTTP<br/>8001/TCP"| LocalDecoder["vLLM Decoder<br/>(local)"]
    Sidecar -->|"HTTP/HTTPS<br/>varies"| RemotePrefiller["vLLM Prefiller<br/>(remote)"]
    Sidecar -->|"HTTP/HTTPS<br/>varies"| RemoteEncoder["vLLM Encoder<br/>(remote)"]

    %% Observability
    Prometheus["Prometheus"] -->|"scrape<br/>9090/TCP"| EPPMetrics
    EPP -->|"gRPC<br/>4317/TCP"| OTLP["OTLP Collector"]
    Sidecar -->|"gRPC<br/>4317/TCP"| OTLP

    %% Styling
    style EPP fill:#4a90e2,stroke:#333,color:#fff
    style EPPHealth fill:#4a90e2,stroke:#333,color:#fff
    style EPPMetrics fill:#4a90e2,stroke:#333,color:#fff
    style EPPZmq fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#50c878,stroke:#333,color:#fff
    style SidecarNIXL fill:#50c878,stroke:#333,color:#fff
    style SidecarSS fill:#50c878,stroke:#333,color:#fff
    style SidecarSGL fill:#50c878,stroke:#333,color:#fff
    style SidecarSSRF fill:#50c878,stroke:#333,color:#fff
    style Tokenizer fill:#9b59b6,stroke:#333,color:#fff
    style InferencePoolCR fill:#f5a623,stroke:#333
    style K8sPods fill:#f5a623,stroke:#333
    style EnvoyGW fill:#e74c3c,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style vLLMEngines fill:#999,stroke:#333,color:#fff
    style vLLMModels fill:#999,stroke:#333,color:#fff
    style LocalDecoder fill:#999,stroke:#333,color:#fff
    style RemotePrefiller fill:#999,stroke:#333,color:#fff
    style RemoteEncoder fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTLP fill:#e8e8e8,stroke:#333
