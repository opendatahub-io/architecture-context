%% TrustyAI Explainability - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS (OpenShift Route / Gateway API)"]
        Route["OpenShift Route / HTTPRoute<br/>443/TCP → 80/TCP<br/>TLS Edge Termination<br/>Managed by TrustyAI Operator"]
    end

    subgraph Namespace["NAMESPACE (Internal)"]
        direction TB

        subgraph TrustyAIPod["TrustyAI Pod"]
            AuthProxy["kube-rbac-proxy<br/>(Auth Sidecar)<br/>RBAC Authorization"]
            TrustyAI["TrustyAI Service<br/>8080/TCP HTTP<br/>4443/TCP HTTPS (optional)<br/>SA: trustyai-serviceaccount"]
        end

        subgraph InboundSources["Inbound Data Sources"]
            ModelMesh["ModelMesh Serving<br/>REST callback"]
            KServeLogger["KServe InferenceLogger<br/>CloudEvents"]
            Prometheus["Prometheus<br/>Bearer Token (SA)"]
        end
    end

    subgraph StorageBackends["STORAGE BACKENDS"]
        PVC["PVC Storage<br/>1Gi flat files<br/>File I/O"]
        MinIOStorage["MinIO / S3<br/>9000/TCP or 443/TCP<br/>TLS 1.2+<br/>Access Key / Secret Key"]
        Database["MariaDB / MySQL<br/>3306/TCP<br/>MySQL Protocol<br/>Username / Password"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ModelServer["KServe/ModelMesh<br/>Model Servers<br/>gRPC/HTTP2<br/>plaintext or TLS"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS<br/>OAuth / Bearer Token"| Route

    %% Ingress → Service
    Route -->|"HTTP/80 → 8080<br/>No encryption (internal)<br/>kube-rbac-proxy validated"| AuthProxy
    AuthProxy -->|"HTTP/8080<br/>localhost<br/>RBAC validated"| TrustyAI

    %% Inbound data flows
    ModelMesh -->|"POST /consumer/kserve/v2<br/>HTTP/8080<br/>No Auth (internal)"| TrustyAI
    KServeLogger -->|"CloudEvents HTTP<br/>8080/TCP<br/>No Auth (internal)"| TrustyAI
    Prometheus -->|"GET /q/metrics<br/>HTTP/8080<br/>Bearer Token (SA)"| TrustyAI

    %% Storage flows
    TrustyAI -->|"File I/O<br/>No network"| PVC
    TrustyAI -->|"HTTPS/9000 or 443<br/>TLS 1.2+<br/>Access Key"| MinIOStorage
    TrustyAI -->|"MySQL/3306<br/>plaintext<br/>Username/Password"| Database

    %% External service flows
    TrustyAI -->|"gRPC/HTTP2<br/>varies (8033)<br/>plaintext or TLS"| ModelServer
    TrustyAI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>(init container)"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class AuthProxy authproxy
    class TrustyAI,ModelMesh,KServeLogger,Prometheus internal
    class PVC,MinIOStorage,Database storage
    class ModelServer,K8sAPI externalservice
