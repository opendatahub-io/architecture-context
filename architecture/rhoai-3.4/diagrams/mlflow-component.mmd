graph TB
    subgraph MLflow["MLflow Server (v3.10.1+rhaiv.3)"]
        direction TB

        subgraph APILayer["API Layer"]
            FlaskApp["Flask App<br/>(REST API v2.0/v3.0)"]
            FastAPIApp["FastAPI App<br/>(Jobs, Gateway, OTel)"]
            GraphQL["GraphQL Endpoint<br/>(Experiments, Runs, Models)"]
            WebUI["React Web UI<br/>(TypeScript SPA)"]
        end

        subgraph AuthLayer["Authentication Layer"]
            AuthMiddleware["Auth Middleware<br/>(before_request / ASGI)"]
            K8sAuthProvider["Kubernetes Auth Provider<br/>(SA Token Validation)"]
            WorkspaceResolver["Workspace Resolver<br/>(Namespace Mapping)"]
        end

        subgraph CoreLayer["Core Services"]
            CryptoModule["Crypto Module<br/>(AES-256-GCM + PBKDF2)"]
            StoreLayer["Store Layer<br/>(SQLAlchemy ORM)"]
            ArtifactRepo["Artifact Repository<br/>(S3/Azure/GCS/Local)"]
            JobRunner["Job Runner<br/>(Huey Task Queue)"]
            PrometheusExporter["Prometheus Exporter<br/>(mlflow_* metrics)"]
        end

        FlaskApp --> AuthMiddleware
        FastAPIApp --> AuthMiddleware
        GraphQL --> AuthMiddleware
        AuthMiddleware --> K8sAuthProvider
        AuthMiddleware --> WorkspaceResolver

        FlaskApp --> StoreLayer
        FastAPIApp --> StoreLayer
        FastAPIApp --> JobRunner
        GraphQL --> StoreLayer
        FlaskApp --> ArtifactRepo
        FlaskApp --> CryptoModule
    end

    %% External Actors
    Client["MLflow Client<br/>(Python SDK)"] -->|HTTPS/8443<br/>Bearer Token| KubeRBACProxy
    Browser["Browser"] -->|HTTPS/443<br/>via Platform Gateway| KubeRBACProxy

    subgraph Sidecar["Sidecar Container"]
        KubeRBACProxy["kube-rbac-proxy<br/>(8443/TCP → 5000/TCP)"]
    end

    KubeRBACProxy -->|HTTP/5000<br/>localhost| FlaskApp

    %% External Dependencies
    StoreLayer -->|PostgreSQL/5432<br/>TLS| PostgreSQL[(PostgreSQL)]
    ArtifactRepo -->|HTTPS/443<br/>AWS IAM| S3[(S3 Storage)]
    K8sAuthProvider -->|HTTPS/6443<br/>Bearer Token| K8sAPI["Kubernetes API"]
    PrometheusExporter -.->|HTTP/5000<br/>scrape| Prometheus["Prometheus"]

    %% Styling
    style MLflow fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style APILayer fill:#d5e8f8,stroke:#4a90e2
    style AuthLayer fill:#fff3cd,stroke:#d79b00
    style CoreLayer fill:#d4edda,stroke:#82b366
    style Sidecar fill:#ffe6cc,stroke:#d79b00

    style FlaskApp fill:#4a90e2,color:#fff
    style FastAPIApp fill:#4a90e2,color:#fff
    style GraphQL fill:#4a90e2,color:#fff
    style WebUI fill:#4a90e2,color:#fff
    style AuthMiddleware fill:#f5a623,color:#fff
    style K8sAuthProvider fill:#f5a623,color:#fff
    style WorkspaceResolver fill:#f5a623,color:#fff
    style CryptoModule fill:#7ed321,color:#fff
    style StoreLayer fill:#7ed321,color:#fff
    style ArtifactRepo fill:#7ed321,color:#fff
    style JobRunner fill:#7ed321,color:#fff
    style PrometheusExporter fill:#7ed321,color:#fff
    style KubeRBACProxy fill:#e67e22,color:#fff

    style Client fill:#f9f9f9,stroke:#999
    style Browser fill:#f9f9f9,stroke:#999
    style PostgreSQL fill:#e8e8e8,stroke:#999
    style S3 fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style Prometheus fill:#e8e8e8,stroke:#999
