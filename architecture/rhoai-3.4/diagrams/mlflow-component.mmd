graph TB
    subgraph MLflowServer["MLflow Tracking Server"]
        direction TB
        FlaskApp["Flask Application<br/>(Legacy REST API)<br/>100+ endpoints"]
        FastAPIApp["FastAPI Wrapper<br/>(ASGI entry point)<br/>OTLP, Jobs API"]
        FastAPIApp -->|"WSGIMiddleware"| FlaskApp

        subgraph AuthLayer["Authentication Layer"]
            KubeAuthPlugin["kubernetes-auth Plugin<br/>(SelfSubjectAccessReview)"]
            SecurityMiddleware["Security Middleware<br/>(Host validation, CORS, CSP)"]
        end

        subgraph WorkspaceLayer["Workspace Management"]
            KubeWorkspaceProvider["kubernetes:// Store<br/>(Namespace → Workspace mapping)"]
        end

        subgraph DataLayer["Data Stores"]
            TrackingStore["Tracking Store<br/>(SQLAlchemy ORM)"]
            ArtifactStore["Artifact Store<br/>(S3/GCS/Azure proxy)"]
            EnvelopeEncryption["Envelope Encryption<br/>(AES-256-GCM, PBKDF2)"]
        end

        subgraph UILayer["Embedded UI"]
            ReactSPA["React SPA<br/>(Experiments, Runs,<br/>Models, Traces)"]
        end

        FlaskApp --> KubeAuthPlugin
        FlaskApp --> TrackingStore
        FlaskApp --> ArtifactStore
        FastAPIApp --> KubeAuthPlugin
        KubeAuthPlugin --> KubeWorkspaceProvider
        TrackingStore --> EnvelopeEncryption
    end

    %% External actors
    SDKClient["ML SDK Client<br/>(Notebook / Pipeline)"]
    Browser["Browser<br/>(RHOAI Dashboard)"]

    %% External systems
    Gateway["RHOAI Data Science Gateway<br/>443/TCP HTTPS"]
    KubeAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    ObjectStorage["S3 / GCS / Azure Storage<br/>443/TCP HTTPS"]

    %% Flows
    SDKClient -->|"REST API<br/>Bearer Token (K8s SA)"| Gateway
    Browser -->|"HTTPS<br/>OAuth session"| Gateway
    Gateway -->|"HTTPRoute /mlflow<br/>5000/TCP HTTP"| FastAPIApp
    Gateway -->|"Static assets"| ReactSPA

    KubeAuthPlugin -->|"SelfSubjectAccessReview<br/>Namespace list/watch"| KubeAPI
    KubeWorkspaceProvider -->|"Namespace enumeration<br/>MLflowConfig CR read"| KubeAPI
    TrackingStore -->|"SQL queries"| PostgreSQL
    ArtifactStore -->|"Object read/write"| ObjectStorage

    %% Styling
    style MLflowServer fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style FlaskApp fill:#4a90e2,color:#fff
    style FastAPIApp fill:#4a90e2,color:#fff
    style KubeAuthPlugin fill:#7e57c2,color:#fff
    style SecurityMiddleware fill:#7e57c2,color:#fff
    style KubeWorkspaceProvider fill:#5c6bc0,color:#fff
    style TrackingStore fill:#26a69a,color:#fff
    style ArtifactStore fill:#26a69a,color:#fff
    style EnvelopeEncryption fill:#ef5350,color:#fff
    style ReactSPA fill:#42a5f5,color:#fff
    style Gateway fill:#ffe0b2,stroke:#e65100
    style KubeAPI fill:#e0e0e0,stroke:#616161
    style PostgreSQL fill:#e0e0e0,stroke:#616161
    style ObjectStorage fill:#e0e0e0,stroke:#616161
    style SDKClient fill:#f5f5f5,stroke:#999
    style Browser fill:#f5f5f5,stroke:#999
