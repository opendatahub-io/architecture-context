graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["system:controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-manager-rolebinding<br/>(cluster-wide)"]
        CRB_LeaderElection["leader-election-rolebinding<br/>(namespace: system)"]
        CRB_MetricsAuth["metrics-auth-rolebinding<br/>(cluster-wide)"]
        CRB_UIServices["model-registry-ui-services-reader-binding<br/>(cluster-wide)"]
        CRB_UICRB["model-registry-retrieve-clusterrolebindings-binding<br/>(cluster-wide)"]
        CRB_UISAR["model-registry-create-sars-binding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["model-registry-manager-role"]
        CR_LeaderElection["leader-election-role"]
        CR_MetricsAuth["metrics-auth-role"]
        CR_MetricsReader["metrics-reader"]
        CR_UIServices["model-registry-ui-services-reader"]
        CR_UICRB["model-registry-retrieve-clusterrolebindings"]
        CR_UISAR["model-registry-create-sars"]
    end

    subgraph Resources_KServe["KServe Resources (serving.kserve.io)"]
        InferenceService["InferenceService<br/>get, list, patch, update, watch"]
        InferenceServiceFinalizers["InferenceService/finalizers<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph Resources_Core["Core Resources ('')"]
        Services["Services<br/>get, list, watch"]
        ConfigMaps["ConfigMaps<br/>get, list, watch, create,<br/>update, patch, delete"]
        Events["Events<br/>create, patch"]
    end

    subgraph Resources_Coordination["Coordination (coordination.k8s.io)"]
        Leases["Leases<br/>get, list, watch, create,<br/>update, patch, delete"]
    end

    subgraph Resources_Auth["Auth Resources"]
        TokenReviews["TokenReviews<br/>(authentication.k8s.io)<br/>create"]
        SubjectAccessReviews["SubjectAccessReviews<br/>(authorization.k8s.io)<br/>create"]
    end

    subgraph Resources_RBAC["RBAC Resources"]
        CRBResource["ClusterRoleBindings<br/>(rbac.authorization.k8s.io)<br/>get, list, watch"]
    end

    subgraph Resources_Metrics["Non-Resource URLs"]
        MetricsURL["/metrics<br/>get"]
    end

    %% Controller SA bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_LeaderElection
    SA_Controller -->|"bound via"| CRB_MetricsAuth

    %% UI SA bindings
    SA_UI -->|"bound via"| CRB_UIServices
    SA_UI -->|"bound via"| CRB_UICRB
    SA_UI -->|"bound via"| CRB_UISAR

    %% ClusterRoleBinding → ClusterRole
    CRB_Manager -->|"grants"| CR_Manager
    CRB_LeaderElection -->|"grants"| CR_LeaderElection
    CRB_MetricsAuth -->|"grants"| CR_MetricsAuth
    CRB_UIServices -->|"grants"| CR_UIServices
    CRB_UICRB -->|"grants"| CR_UICRB
    CRB_UISAR -->|"grants"| CR_UISAR

    %% ClusterRole → Resources
    CR_Manager -->|"manages"| InferenceService
    CR_Manager -->|"manages"| InferenceServiceFinalizers
    CR_Manager -->|"reads"| Services

    CR_LeaderElection -->|"manages"| ConfigMaps
    CR_LeaderElection -->|"manages"| Leases
    CR_LeaderElection -->|"writes"| Events

    CR_MetricsAuth -->|"creates"| TokenReviews
    CR_MetricsAuth -->|"creates"| SubjectAccessReviews

    CR_MetricsReader -->|"reads"| MetricsURL

    CR_UIServices -->|"reads"| Services
    CR_UICRB -->|"reads"| CRBResource
    CR_UISAR -->|"creates"| SubjectAccessReviews

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#3498db,stroke:#333,color:#fff

    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_LeaderElection fill:#e8e8e8,stroke:#333
    style CRB_MetricsAuth fill:#e8e8e8,stroke:#333
    style CRB_UIServices fill:#e8e8e8,stroke:#333
    style CRB_UICRB fill:#e8e8e8,stroke:#333
    style CRB_UISAR fill:#e8e8e8,stroke:#333

    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_LeaderElection fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsAuth fill:#f5a623,stroke:#333,color:#fff
    style CR_MetricsReader fill:#f5a623,stroke:#333,color:#fff
    style CR_UIServices fill:#f5a623,stroke:#333,color:#fff
    style CR_UICRB fill:#f5a623,stroke:#333,color:#fff
    style CR_UISAR fill:#f5a623,stroke:#333,color:#fff

    style InferenceService fill:#7ed321,stroke:#333,color:#fff
    style InferenceServiceFinalizers fill:#7ed321,stroke:#333,color:#fff
    style Services fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff
    style Events fill:#7ed321,stroke:#333,color:#fff
    style Leases fill:#7ed321,stroke:#333,color:#fff
    style TokenReviews fill:#e74c3c,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e74c3c,stroke:#333,color:#fff
    style CRBResource fill:#7ed321,stroke:#333,color:#fff
    style MetricsURL fill:#7ed321,stroke:#333,color:#fff
