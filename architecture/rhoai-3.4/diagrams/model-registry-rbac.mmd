graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager"]
        SA_UI["model-registry-ui"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["model-registry-<br/>manager-rolebinding<br/>(cluster-wide)"]
        CRB_Metrics["model-registry-metrics-<br/>auth-rolebinding<br/>(system namespace)"]
        CRB_Leader["leader-election-<br/>rolebinding<br/>(system namespace)"]
        CRB_UIReader["model-registry-ui-<br/>services-reader-binding<br/>(cluster-wide)"]
        CRB_UICRB["model-registry-retrieve-<br/>clusterrolebindings-binding<br/>(cluster-wide)"]
        CRB_UISAR["model-registry-create-<br/>sars-binding<br/>(cluster-wide)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["model-registry-<br/>manager-role"]
        CR_Metrics["model-registry-<br/>metrics-reader"]
        CR_Leader["leader-election-<br/>role"]
        CR_UIReader["model-registry-<br/>ui-services-reader"]
        CR_UICRB["model-registry-retrieve-<br/>clusterrolebindings"]
        CR_UISAR["model-registry-<br/>create-sars"]
    end

    subgraph APIResources_Manager["Manager Role Resources"]
        Svc_Core["core<br/>services<br/>▸ get, list, watch"]
        ISVC["serving.kserve.io<br/>inferenceservices<br/>▸ get, list, watch,<br/>update, patch"]
        ISVC_Final["serving.kserve.io<br/>inferenceservices/<br/>finalizers<br/>▸ get, list, watch,<br/>update, create,<br/>patch, delete"]
    end

    subgraph APIResources_Metrics["Metrics Reader Resources"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>▸ create"]
        SAR_Metrics["authorization.k8s.io<br/>subjectaccessreviews<br/>▸ create"]
    end

    subgraph APIResources_UI["UI Role Resources"]
        Svc_UI["core<br/>services<br/>▸ get, list, watch"]
        CRB_Read["rbac.authorization.k8s.io<br/>clusterrolebindings<br/>▸ get, list, watch"]
        SAR_UI["authorization.k8s.io<br/>subjectaccessreviews<br/>▸ create"]
    end

    %% Controller-manager bindings
    SA_Controller -->|"bound via"| CRB_Manager
    SA_Controller -->|"bound via"| CRB_Metrics
    SA_Controller -->|"bound via"| CRB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    CRB_Leader -->|"grants"| CR_Leader

    CR_Manager -->|"permits"| Svc_Core
    CR_Manager -->|"permits"| ISVC
    CR_Manager -->|"permits"| ISVC_Final

    CR_Metrics -->|"permits"| TokenReview
    CR_Metrics -->|"permits"| SAR_Metrics

    %% UI bindings
    SA_UI -->|"bound via"| CRB_UIReader
    SA_UI -->|"bound via"| CRB_UICRB
    SA_UI -->|"bound via"| CRB_UISAR

    CRB_UIReader -->|"grants"| CR_UIReader
    CRB_UICRB -->|"grants"| CR_UICRB
    CRB_UISAR -->|"grants"| CR_UISAR

    CR_UIReader -->|"permits"| Svc_UI
    CR_UICRB -->|"permits"| CRB_Read
    CR_UISAR -->|"permits"| SAR_UI

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_UI fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_Metrics fill:#f5a623,stroke:#333
    style CR_Leader fill:#f5a623,stroke:#333
    style CR_UIReader fill:#f5a623,stroke:#333
    style CR_UICRB fill:#f5a623,stroke:#333
    style CR_UISAR fill:#f5a623,stroke:#333
    style CRB_Manager fill:#ddd,stroke:#333
    style CRB_Metrics fill:#ddd,stroke:#333
    style CRB_Leader fill:#ddd,stroke:#333
    style CRB_UIReader fill:#ddd,stroke:#333
    style CRB_UICRB fill:#ddd,stroke:#333
    style CRB_UISAR fill:#ddd,stroke:#333
    style Svc_Core fill:#7ed321,stroke:#333
    style ISVC fill:#7ed321,stroke:#333
    style ISVC_Final fill:#7ed321,stroke:#333
    style TokenReview fill:#7ed321,stroke:#333
    style SAR_Metrics fill:#7ed321,stroke:#333
    style Svc_UI fill:#7ed321,stroke:#333
    style CRB_Read fill:#7ed321,stroke:#333
    style SAR_UI fill:#7ed321,stroke:#333
