graph LR
    PC["Pipelines Components<br/>(kfp-components +<br/>Init Container +<br/>Runtime Images)"]

    %% Core KFP Dependencies (Required)
    PC -->|"pipeline definitions"| KFP["Kubeflow Pipelines SDK<br/>kfp >=2.15.2"]
    PC -->|"K8s extensions"| KFPK8s["kfp-kubernetes<br/>>=2.15.2"]

    %% Internal RHOAI Platform Dependencies
    PC -->|"shared volume<br/>pipeline YAMLs"| KFPServer["KFP API Server"]
    PC -->|"image reference"| DSPO["Data Science Pipelines<br/>Operator (DSPO)"]
    PC -->|"REST/8080<br/>model registration"| ModelRegistry["Kubeflow Model<br/>Registry >=0.3.4"]
    PC -->|"CRD TrainJob<br/>HTTPS/443"| KFTrainer["Kubeflow Trainer<br/>>=0.1.0"]
    PC -.->|"pod execution"| Argo["Argo Workflows"]
    PC -.->|"secret provisioning"| RHOAI_Connections["RHOAI Connections API"]

    %% AutoML Dependencies
    PC -->|"tabular/timeseries<br/>ML training"| AutoGluon["AutoGluon<br/>1.5.0+rhaiv.2"]

    %% AutoRAG Dependencies
    PC -->|"RAG optimization"| ai4rag["ai4rag >=1.0.0"]
    PC -->|"document extraction"| docling["docling >=2.72.0"]
    PC -->|"embeddings, vector I/O<br/>HTTPS/443"| LlamaStack["Llama Stack API<br/>>=1.0.0"]
    PC -->|"vector indexing<br/>gRPC/19530"| Milvus["Milvus >=2.0.0"]

    %% Evaluation Dependencies
    PC -->|"LLM benchmarks"| lm_eval["lm-evaluation-harness<br/>>=0.4.0"]
    PC -->|"inference backend<br/>HTTP/8000"| vLLM["vLLM >=0.4.0"]

    %% Fine-tuning Dependencies
    PC -->|"dataset loading"| HFDatasets["HuggingFace Datasets<br/>>=2.14.0"]
    PC -->|"LoRA training"| Unsloth["Unsloth >=2024.11.0"]
    PC -->|"SFT training"| InstructLab["instructlab-training<br/>>=0.1.0"]

    %% SDG Dependencies
    PC -->|"synthetic data flows"| SDGHub["SDG Hub >=0.7.0"]
    PC -->|"LLM gateway<br/>HTTPS/443"| LiteLLM["LiteLLM >=1.0.0"]

    %% Data Access Dependencies
    PC -->|"S3 access<br/>HTTPS/443"| boto3["boto3 >=1.42.34"]

    %% External Services
    PC -->|"model/dataset download<br/>HTTPS/443"| HFHub["HuggingFace Hub"]
    PC -->|"dataset/model storage<br/>HTTPS/443 or 9000"| S3["S3/MinIO<br/>Object Storage"]

    %% Styling
    style PC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI - green
    style KFPServer fill:#7ed321,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style KFTrainer fill:#7ed321,stroke:#333,color:#fff
    style Argo fill:#7ed321,stroke:#333,color:#fff
    style RHOAI_Connections fill:#7ed321,stroke:#333,color:#fff

    %% Core SDK - blue
    style KFP fill:#5dade2,stroke:#333,color:#fff
    style KFPK8s fill:#5dade2,stroke:#333,color:#fff

    %% Python libraries - light blue
    style AutoGluon fill:#85c1e9,stroke:#333
    style ai4rag fill:#85c1e9,stroke:#333
    style docling fill:#85c1e9,stroke:#333
    style lm_eval fill:#85c1e9,stroke:#333
    style HFDatasets fill:#85c1e9,stroke:#333
    style Unsloth fill:#85c1e9,stroke:#333
    style InstructLab fill:#85c1e9,stroke:#333
    style SDGHub fill:#85c1e9,stroke:#333
    style boto3 fill:#85c1e9,stroke:#333

    %% External services - orange
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style LlamaStack fill:#f5a623,stroke:#333,color:#fff
    style LiteLLM fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style Milvus fill:#f5a623,stroke:#333,color:#fff
