graph LR
    PC["Pipelines<br/>Components"]

    %% Internal RHOAI Dependencies
    PC -->|"shared volume<br/>pipeline staging"| KFPAPI["KFP API Server"]
    PC -->|"pod scheduling"| ArgoWF["Argo Workflow<br/>Engine"]
    PC -->|"HTTP/8080<br/>model registration"| MR["Kubeflow<br/>Model Registry"]
    PC -->|"K8s CRD<br/>TrainJob creation"| KFTrainer["Kubeflow Trainer<br/>(ClusterTrainingRuntime)"]

    %% External Service Dependencies
    PC -->|"HTTPS/443<br/>data I/O"| S3["S3-compatible<br/>Storage<br/>(AWS/MinIO)"]
    PC -->|"HTTP(S)/8321<br/>vector store, embedding"| LS["LlamaStack<br/>Server"]
    PC -->|"HTTPS/443<br/>datasets + models"| HF["HuggingFace Hub"]
    PC -->|"HTTPS/443<br/>resource mgmt"| K8sAPI["Kubernetes<br/>API Server"]
    PC -->|"HTTPS<br/>SDG inference"| LiteLLM["LiteLLM<br/>Endpoint"]
    PC -->|"HTTPS/443<br/>model download"| OCI["OCI Registry"]

    %% In-Process Dependencies
    PC -.->|"in-process<br/>GPU inference"| vLLM["vLLM"]
    PC -.->|"in-process<br/>benchmark eval"| LMEval["lm-eval<br/>Harness"]
    PC -.->|"in-process<br/>SDG flows"| SDGHub["sdg-hub"]
    PC -.->|"in-process<br/>vector store"| ChromaDB["ChromaDB"]

    %% Python SDK Dependencies
    PC -.->|"SDK v2.16.0"| KFP["kfp<br/>(Kubeflow Pipelines)"]
    PC -.->|"SDK"| KFPKube["kfp-kubernetes"]
    PC -.->|"SDK v30.1.0"| K8sClient["kubernetes<br/>Python client"]
    PC -.->|"bundled"| AutoGluon["AutoGluon<br/>(Tabular + TimeSeries)"]
    PC -.->|"bundled"| AI4RAG["ai4rag"]
    PC -.->|"bundled"| Docling["docling"]
    PC -.->|"SDK 0.3.4"| MRClient["model-registry<br/>SDK"]

    %% Integration consumers
    Dashboard["ODH Dashboard"] -.->|"UI pipeline mgmt"| KFPAPI
    DSP["Data Science<br/>Pipelines Operator"] -->|"deploys + manages"| KFPAPI

