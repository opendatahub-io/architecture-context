    style AllowedClusterRole fill:#dae8fc,stroke:#6c8ebf
    style AuthDelegator fill:#e1d5e7,stroke:#9673a6
    style KueueAdminRole fill:#fff2cc,stroke:#d6b656

    style DSCAPI fill:#7ed321,stroke:#333,color:#fff
    style DSCIAPI fill:#7ed321,stroke:#333,color:#fff
    style ComponentsAPI fill:#7ed321,stroke:#333,color:#fff
    style ServicesAPI fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style IstioAPI fill:#7ed321,stroke:#333,color:#fff
    style RouteAPI fill:#7ed321,stroke:#333,color:#fff
    style OAuthAPI fill:#7ed321,stroke:#333,color:#fff
    style MonitoringAPI fill:#7ed321,stroke:#333,color:#fff
    style AdmissionAPI fill:#7ed321,stroke:#333,color:#fff
    style CertMgrAPI fill:#7ed321,stroke:#333,color:#fff
    style CoreAPI fill:#7ed321,stroke:#333,color:#fff
    style AppsAPI fill:#7ed321,stroke:#333,color:#fff
