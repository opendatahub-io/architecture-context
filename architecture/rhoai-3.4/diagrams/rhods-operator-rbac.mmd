graph TD
    subgraph ServiceAccounts["Service Accounts"]
        OperatorSA["rhods-operator SA<br/>(OLM-managed)"]
        KubeAuthSA["kube-auth-proxy SA<br/>(openshift-ingress)"]
        AdminGroups["Admin Groups<br/>(from Auth CR)<br/>e.g., rhods-admins"]
        AllowedGroups["Allowed Groups<br/>(from Auth CR)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        OperatorCRB["operator-manager<br/>rolebinding"]
        TokenReviewCRB["kube-auth-proxy-tokenreview"]
        AdminCRB["data-science-admingroupcluster<br/>-rolebinding"]
        AllowedCRB["data-science-allowedgroupcluster<br/>-rolebinding"]
        KueueAdminCRB["kueue-admin-rolebinding"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        AdminNSRB["data-science-admingroup<br/>-rolebinding<br/>(applications ns)"]
        AdminMaaSRB["data-science-admingroup<br/>-maas-rolebinding<br/>(models-as-a-service ns)"]
        AdminKuadrantRB["data-science-admingroup<br/>-kuadrant-rolebinding<br/>(kuadrant-system ns)"]
    end

    subgraph OperatorClusterRole["Operator ClusterRole (wide permissions)"]
        DSCAPI["datasciencecluster.opendatahub.io<br/>datascienceclusters (+status, +finalizers)<br/>get, list, watch, create, update, patch, delete"]
        DSCIAPI["dscinitialization.opendatahub.io<br/>dscinitializations (+status, +finalizers)<br/>get, list, watch, create, update, patch, delete"]
        ComponentsAPI["components.platform.opendatahub.io<br/>dashboards, kserves, kueues, rays,<br/>workbenches, modelregistries, dsp,<br/>trustyais, trainers, trainingoperators,<br/>feastoperators, llamastackoperators,<br/>mlflowoperators, sparkoperators,<br/>modelcontrollers, modelsasservices<br/>get, list, watch, create, update, patch, delete"]
        ServicesAPI["services.platform.opendatahub.io<br/>gatewayconfigs, auths, monitorings<br/>get, list, watch, create, update, patch, delete"]
        GatewayAPI["gateway.networking.k8s.io<br/>gateways, gatewayclasses, httproutes<br/>get, list, watch, create, update, patch, delete"]
        IstioAPI["networking.istio.io<br/>destinationrules, envoyfilters<br/>get, list, watch, create, update, patch, delete"]
        RouteAPI["route.openshift.io<br/>routes, routes/custom-host<br/>get, list, watch, create, update, patch, delete"]
        OAuthAPI["oauth.openshift.io<br/>oauthclients<br/>get, list, watch, create, update, patch, delete"]
        MonitoringAPI["monitoring.coreos.com<br/>servicemonitors, podmonitors,<br/>prometheusrules, prometheuses, alertmanagers<br/>get, list, watch, create, update, patch, delete, deletecollection"]
        AdmissionAPI["admissionregistration.k8s.io<br/>validating/mutating webhook configs,<br/>validatingadmissionpolicies<br/>get, list, watch, create, update, patch, delete"]
        CertMgrAPI["cert-manager.io<br/>issuers, certificates<br/>get, list, watch, create, update, patch, delete"]
        CoreAPI["core (v1)<br/>namespaces, configmaps, secrets,<br/>services, serviceaccounts, events,<br/>pods, pvcs, nodes<br/>get, list, watch, create, update, patch, delete"]
        AppsAPI["apps<br/>deployments, replicasets, statefulsets<br/>get, list, watch, create, update, patch, delete"]
        RBACAPI["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings<br/>ALL verbs (*)"]
    end

    subgraph AdminClusterRole["data-science-admingroupcluster-role"]
        AdminDSC["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list, watch, update, patch"]
        AdminModelReg["modelregistry.opendatahub.io<br/>modelregistries<br/>get, list, watch, create, update, patch, delete"]
        AdminStorage["storage.k8s.io<br/>storageclasses<br/>get, list, watch, update, patch"]
        AdminUsers["user.openshift.io<br/>groups, users<br/>get, list, watch"]
    end

    subgraph AllowedClusterRole["data-science-allowedgroupcluster-role"]
        AllowedAuth["services.platform.opendatahub.io<br/>auths, auths/status<br/>get, list, watch"]
    end

    subgraph AuthDelegator["system:auth-delegator"]
        TokenReview["authentication.k8s.io<br/>tokenreviews<br/>(delegated auth)"]
    end

    subgraph KueueAdminRole["kueue-batch-admin-role"]
        KueueAdmin["kueue.x-k8s.io<br/>clusterqueues, resourceflavors, etc.<br/>admin verbs"]
    end

    %% Operator SA bindings
    OperatorSA -->|"bound via"| OperatorCRB
    OperatorCRB -->|"grants"| OperatorClusterRole

    %% kube-auth-proxy SA bindings
    KubeAuthSA -->|"bound via"| TokenReviewCRB
    TokenReviewCRB -->|"grants"| AuthDelegator

    %% Admin group bindings
    AdminGroups -->|"bound via"| AdminCRB
    AdminCRB -->|"grants"| AdminClusterRole
    AdminGroups -->|"bound via"| AdminNSRB
    AdminGroups -->|"bound via"| AdminMaaSRB
    AdminGroups -->|"bound via"| AdminKuadrantRB
    AdminGroups -->|"bound via"| KueueAdminCRB
    KueueAdminCRB -->|"grants"| KueueAdminRole

    %% Allowed group bindings
    AllowedGroups -->|"bound via"| AllowedCRB
    AllowedCRB -->|"grants"| AllowedClusterRole

    %% Styling
    style OperatorSA fill:#4a90e2,stroke:#333,color:#fff
    style KubeAuthSA fill:#4a90e2,stroke:#333,color:#fff
    style AdminGroups fill:#4a90e2,stroke:#333,color:#fff
    style AllowedGroups fill:#4a90e2,stroke:#333,color:#fff

