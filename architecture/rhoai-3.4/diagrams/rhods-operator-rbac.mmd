    style CRB_Admin fill:#ddd,stroke:#333
    style CRB_Allowed fill:#ddd,stroke:#333
    style DSC_Res fill:#7ed321,stroke:#333
    style DSCI_Res fill:#7ed321,stroke:#333
    style Comp_Res fill:#7ed321,stroke:#333
    style Svc_Res fill:#7ed321,stroke:#333
