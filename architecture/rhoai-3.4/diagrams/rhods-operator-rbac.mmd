graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["opendatahub-operator-<br/>controller-manager<br/>(redhat-ods-operator)"]
        SA_AuthProxy["kube-auth-proxy<br/>(openshift-ingress)"]
        SA_AdminGroups["Admin Groups<br/>(from Auth CR)"]
        SA_AllowedGroups["Allowed Groups<br/>(from Auth CR)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["opendatahub-operator-<br/>manager-rolebinding"]
        CRB_TokenReview["kube-auth-proxy-<br/>tokenreview"]
        CRB_Admin["data-science-<br/>admingroup-binding"]
        CRB_Allowed["data-science-<br/>allowedgroup-binding"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["opendatahub-operator-<br/>manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Admin["data-science-<br/>admingroup-clusterrole"]
        CR_Allowed["data-science-<br/>allowedgroup-clusterrole"]
    end

    subgraph ManagerPermissions["Manager Role Permissions"]
        direction TB

        subgraph DSC_APIs["DSC/DSCI APIs"]
            DSC_Res["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>+status, +finalizers"]
            DSCI_Res["dscinitialization.opendatahub.io<br/>dscinitializations<br/>+status, +finalizers"]
        end

        subgraph Component_APIs["Component APIs"]
            Comp_Res["components.platform.opendatahub.io<br/>Dashboard, KServe, Workbenches,<br/>DSP, ModelRegistry, TrustyAI,<br/>Ray, Kueue, TrainingOperator,<br/>Trainer, Feast, LlamaStack,<br/>MLflow, Spark, ModelController,<br/>ModelsAsService"]
        end

        subgraph Service_APIs["Service APIs"]
            Svc_Res["services.platform.opendatahub.io<br/>gatewayconfigs, auths,<br/>monitorings +status"]
        end

        subgraph Network_APIs["Network / Ingress APIs"]
            GW_Res["gateway.networking.k8s.io<br/>gateways, gatewayclasses,<br/>httproutes"]
            Istio_Res["networking.istio.io<br/>destinationrules, envoyfilters"]
            Route_Res["route.openshift.io<br/>routes, routes/custom-host"]
        end

        subgraph Core_APIs["Core APIs"]
            Core_Res["core ('')<br/>namespaces, secrets, configmaps,<br/>services, serviceaccounts,<br/>pvcs, networkpolicies"]
            Apps_Res["apps<br/>deployments"]
            RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>(+escalate, +bind)"]
        end

        subgraph OpenShift_APIs["OpenShift APIs"]
            OAuth_Res["oauth.openshift.io<br/>oauthclients"]
            User_Res["user.openshift.io<br/>groups"]
        end

        subgraph Meta_APIs["Cluster Meta APIs"]
            CRD_Res["apiextensions.k8s.io<br/>customresourcedefinitions<br/>(read-only)"]
            VAP_Res["admissionregistration.k8s.io<br/>validatingadmissionpolicies,<br/>bindings"]
        end
    end

    subgraph AdminPermissions["Admin Group Permissions"]
        Admin_DSC["datascienceclusters<br/>(full CRUD)"]
        Admin_Other["modelregistries, storageclasses,<br/>groups, users, MaaS resources<br/>(full CRUD)"]
    end

    subgraph AllowedPermissions["Allowed Group Permissions"]
        Allowed_Auth["auths, auths/status<br/>(read-only: get, list, watch)"]
    end

    subgraph TokenReviewPerms["Token Review Permissions"]
        TR_Res["tokenreviews<br/>subjectaccessreviews"]
    end

    %% Service Account → Binding → Role
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager

    SA_AuthProxy -->|"bound via"| CRB_TokenReview
    CRB_TokenReview -->|"grants"| CR_AuthDelegator

    SA_AdminGroups -->|"bound via"| CRB_Admin
    CRB_Admin -->|"grants"| CR_Admin

    SA_AllowedGroups -->|"bound via"| CRB_Allowed
    CRB_Allowed -->|"grants"| CR_Allowed

    %% Role → Permissions
    CR_Manager -->|"CRUD"| DSC_APIs
    CR_Manager -->|"CRUD"| Component_APIs
    CR_Manager -->|"CRUD"| Service_APIs
    CR_Manager -->|"CRUD"| Network_APIs
    CR_Manager -->|"CRUD"| Core_APIs
    CR_Manager -->|"CRUD"| OpenShift_APIs
    CR_Manager -->|"read + CRUD"| Meta_APIs

    CR_Admin -->|"CRUD"| AdminPermissions
    CR_Allowed -->|"read-only"| AllowedPermissions
    CR_AuthDelegator -->|"auth delegation"| TokenReviewPerms

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_AuthProxy fill:#4a90e2,stroke:#333,color:#fff
    style SA_AdminGroups fill:#4a90e2,stroke:#333,color:#fff
    style SA_AllowedGroups fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_AuthDelegator fill:#f5a623,stroke:#333
