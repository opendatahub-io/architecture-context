graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
        LLMClient["LLM Client"]
    end

    subgraph Ingress["INGRESS (Edge)"]
        Route["OpenShift Route<br/>443/TCP<br/>TLS Edge/Reencrypt<br/>Auth: Optional (annotation)"]
        GW["Gateway (Envoy)<br/>443/TCP<br/>TLS 1.2+<br/>Auth: Bearer Token"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            Controller["odh-model-controller<br/>SA: odh-model-controller<br/>Ports: 8081(health) 8080(metrics) 9443(webhooks)<br/>FIPS: strictfipsruntime"]
            APIServer["model-serving-api<br/>SA: model-serving-api<br/>Ports: 8443(HTTPS API) 8080(metrics)<br/>TLS: service-ca, ECDHE+AES-GCM"]
        end

        subgraph NS_Kuadrant["Namespace: kuadrant-system"]
            Authorino["Authorino<br/>50051/TCP gRPC<br/>TLS: service-ca.crt<br/>Auth: mTLS"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            Predictor["Predictor Service<br/>80/443 TCP"]
            PullSecret["Pull Secret<br/>(nvcr.io docker auth)"]
            RayTLS["Ray TLS Certs<br/>(RSA 4096, CA-signed)"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA token / Bearer passthrough"]
        Dashboard["RHOAI Dashboard"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        NGC["api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer (NGC API key)"]
        NVCR["nvcr.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Docker OAuth"]
        AuthN["authn.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API key"]
        ModelReg["Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Edge/Reencrypt<br/>Optional auth"| Route
    LLMClient -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| GW

    %% Ingress to services
    Route -->|"HTTP(S)/80,443<br/>Cluster internal"| Predictor
    GW -->|"gRPC/50051<br/>TLS service-ca.crt<br/>mTLS"| Authorino
    Authorino -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    GW -->|"HTTP(S)<br/>post-auth"| Predictor

    %% Controller egress
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (NGC key)"| NGC
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker auth"| NVCR
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| AuthN
    Controller -.->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| ModelReg

    %% API Server flows
    Dashboard -->|"HTTPS/443→8443<br/>TLS 1.2+ service-ca<br/>Bearer Token"| APIServer
    APIServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer passthrough"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>Webhook cert"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef apiserver fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef userspace fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class Client,LLMClient external
    class Route,GW ingress
    class Controller controller
    class APIServer apiserver
    class Authorino auth
    class K8sAPI,Dashboard k8s
    class NGC,NVCR,AuthN,ModelReg extsvc
    class Predictor,PullSecret,RayTLS userspace
