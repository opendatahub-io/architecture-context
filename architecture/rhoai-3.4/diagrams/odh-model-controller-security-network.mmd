graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
        ExtClient["External Client"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route<br/>{isvc-name}<br/>443/TCP<br/>TLS Edge or Re-encrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_Apps["Namespace: {applications-namespace}"]
            Controller["odh-model-controller<br/>SA: odh-model-controller<br/>8081/TCP HTTP (probes)<br/>8443/TCP HTTPS (metrics)<br/>9443/TCP HTTPS (webhooks)"]
            ServingAPI["model-serving-api<br/>SA: model-serving-api<br/>8443/TCP HTTPS (FIPS: ECDHE+AES-GCM)<br/>8080/TCP HTTPS (metrics)"]
            WebhookSvc["webhook-service<br/>443/TCP → 9443"]
            APISvc["model-serving-api Service<br/>443/TCP → 8443<br/>8080/TCP → 8080"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]

        subgraph NS_User["Namespace: {user-namespace}"]
            MetricsSvc["{isvc-name}-metrics<br/>ClusterIP<br/>HTTP (no TLS)"]
            ISVCPod["InferenceService Pod"]
        end

        Prometheus["Prometheus<br/>(via ServiceMonitor)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        NGC_Auth["NVIDIA NGC API<br/>nvcr.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API Key"]
        NGC_Catalog["NGC Catalog API<br/>api.ngc.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: API Key"]
        ModelReg["Kubeflow Model Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC/Bearer"| K8sAPI
    ExtClient -->|"HTTPS/443<br/>TLS edge/re-encrypt<br/>Per-ISVC auth"| Route

    %% Ingress to internal
    Route -->|"Internal routing"| ISVCPod

    %% K8s API to webhooks
    K8sAPI -->|"HTTPS/443→9443<br/>TLS<br/>Cluster-internal"| WebhookSvc

    %% Controller to K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% model-serving-api flows
    ServingAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>User Bearer (SSAR)"| K8sAPI
    ServingAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (list GW)"| K8sAPI

    %% Dashboard to API
    Dashboard["RHOAI Dashboard"] -->|"HTTPS/443→8443<br/>TLS 1.2+ FIPS<br/>Bearer Token"| APISvc

    %% Controller to external services
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (nvapi-*)"| NGC_Auth
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key (nvapi-*)"| NGC_Catalog
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| ModelReg

    %% Prometheus scraping
    Prometheus -->|"HTTP<br/>No TLS"| MetricsSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sapi fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef dashboard fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User,ExtClient external
    class Route ingress
    class Controller,ServingAPI,WebhookSvc,APISvc,MetricsSvc,ISVCPod,Prometheus internal
    class K8sAPI k8sapi
    class NGC_Auth,NGC_Catalog,ModelReg externalservice
    class Dashboard dashboard
