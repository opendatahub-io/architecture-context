graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["AI Application Client"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE (UID: 1001, non-root)"]
        direction TB

        subgraph APIEndpoint["Guardrails API Server"]
            GuardrailsAPI["guardrails-server (ClusterIP)<br/>8033/TCP HTTP/HTTPS<br/>Optional TLS 1.2+ / mTLS<br/>rustls + ring (non-FIPS)<br/>WebPkiClientVerifier"]
        end

        subgraph HealthEndpoint["Health Server"]
            HealthAPI["health-server (ClusterIP)<br/>8034/TCP HTTP<br/>Plaintext (no TLS)<br/>No auth (open access)"]
        end
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES (Cluster Network)"]
        direction TB

        TGIS["TGIS Server<br/>8033/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>Client certs"]
        CaikitNLP["Caikit NLP Runtime<br/>8085/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>Client certs"]
        CaikitChunker["Caikit Chunker Service<br/>8085/TCP gRPC/HTTP2<br/>Optional TLS/mTLS<br/>Client certs"]
        Detectors["Detector Services<br/>(HAP, PII, etc.)<br/>8080/TCP HTTP/HTTPS<br/>Optional TLS/mTLS<br/>Bearer token + detector-id"]
        OpenAISvr["OpenAI-compatible Server<br/>(vLLM, etc.)<br/>8080/TCP HTTP/HTTPS<br/>Optional TLS<br/>Bearer token (api_token)"]
    end

    subgraph Telemetry["OBSERVABILITY"]
        OTLPCollector["OTLP Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>Configurable encryption<br/>W3C Trace Context"]
    end

    %% Inbound flows
    Client -->|"HTTP/HTTPS 8033/TCP<br/>Optional TLS 1.2+ / mTLS<br/>Header passthrough<br/>(X-Forwarded-Access-Token)"| GuardrailsAPI
    Client -.->|"HTTP 8034/TCP<br/>Plaintext<br/>No auth"| HealthAPI

    %% Egress flows
    GuardrailsAPI -->|"gRPC 8033/TCP<br/>Optional TLS/mTLS<br/>Client certs"| TGIS
    GuardrailsAPI -->|"gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>Client certs"| CaikitNLP
    GuardrailsAPI -->|"gRPC 8085/TCP<br/>Optional TLS/mTLS<br/>Client certs"| CaikitChunker
    GuardrailsAPI -->|"HTTP/S 8080/TCP<br/>Optional TLS/mTLS<br/>Bearer + detector-id"| Detectors
    GuardrailsAPI -->|"HTTP/S 8080/TCP<br/>Optional TLS<br/>Bearer token"| OpenAISvr

    %% Telemetry flow
    GuardrailsAPI -.->|"gRPC 4317/TCP or<br/>HTTP 4318/TCP<br/>OTLP traces + metrics"| OTLPCollector

    %% Health check probes
    HealthAPI -.->|"gRPC Health.check()"| TGIS
    HealthAPI -.->|"gRPC Health.check()"| CaikitNLP
    HealthAPI -.->|"gRPC Health.check()"| CaikitChunker
    HealthAPI -.->|"HTTP GET /health"| Detectors
    HealthAPI -.->|"HTTP GET /health"| OpenAISvr

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef telemetry fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class GuardrailsAPI,HealthAPI orchestrator
    class TGIS,CaikitNLP,CaikitChunker,Detectors,OpenAISvr internal
    class OTLPCollector telemetry
