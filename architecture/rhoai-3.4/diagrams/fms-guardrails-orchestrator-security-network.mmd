graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application"]
    end

    subgraph OrchestratorZone["ORCHESTRATOR SERVICE"]
        direction TB
        subgraph GuardrailsServer["Guardrails API Server (:8033)"]
            API["v1 + v2 REST API<br/>TLS 1.2+ (optional)<br/>mTLS: WebPkiClientVerifier (optional)<br/>Crypto: rustls/ring (NOT OpenSSL)"]
        end
        subgraph HealthSvr["Health Server (:8034)"]
            Health["/health, /info<br/>No encryption<br/>No auth"]
        end
    end

    subgraph GRPCBackends["BACKEND SERVICES (gRPC)"]
        direction TB
        TGIS["TGIS Generation Server<br/>:8033/TCP gRPC<br/>mTLS (configurable)<br/>Auth: mm-model-id header<br/>LB: ginepro DNS"]
        CaikitNLP["Caikit NLP Generation<br/>:8085/TCP gRPC<br/>mTLS (configurable)<br/>Auth: mm-model-id header"]
        Chunker["Caikit Chunker<br/>:8085/TCP gRPC<br/>mTLS (configurable)<br/>Auth: mm-model-id header"]
    end

    subgraph HTTPBackends["BACKEND SERVICES (HTTP REST)"]
        direction TB
        Detectors["Detector Service(s)<br/>(HAP, PII, etc.)<br/>:8080/TCP HTTP/HTTPS<br/>TLS (configurable)<br/>Auth: Bearer token + detector-id"]
        vLLM["OpenAI Service (vLLM)<br/>:8080/TCP HTTP/HTTPS<br/>TLS (configurable)<br/>Auth: Bearer token"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTLP["OTLP Collector<br/>:4317/TCP gRPC or :4318/TCP HTTP<br/>No encryption<br/>No auth"]
    end

    subgraph Probes["KUBERNETES"]
        K8sProbe["Liveness/Readiness Probes"]
    end

    %% Ingress flows
    Client -->|"HTTPS/8033<br/>TLS 1.2+<br/>mTLS (optional)<br/>Header passthrough"| API

    %% Egress flows - gRPC
    API -->|"gRPC/8033<br/>mTLS (configurable)<br/>mm-model-id"| TGIS
    API -->|"gRPC/8085<br/>mTLS (configurable)<br/>mm-model-id"| CaikitNLP
    API -->|"gRPC/8085<br/>mTLS (configurable)<br/>mm-model-id"| Chunker

    %% Egress flows - HTTP
    API -->|"HTTP/8080<br/>TLS (configurable)<br/>Bearer token"| Detectors
    API -->|"HTTP/8080<br/>TLS (configurable)<br/>Bearer token"| vLLM

    %% Observability
    API -->|"gRPC/4317 or<br/>HTTP/4318<br/>OTLP export"| OTLP

    %% Health probes
    K8sProbe -->|"HTTP/8034<br/>No encryption"| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#4a90e2,stroke:#2a70c2,stroke-width:2px,color:#fff
    classDef grpcbackend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef httpbackend fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef probes fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef health fill:#7ed321,stroke:#5eb301,stroke-width:2px,color:#fff

    class Client external
    class API orchestrator
    class Health health
    class TGIS,CaikitNLP,Chunker grpcbackend
    class Detectors,vLLM httpbackend
    class OTLP observability
    class K8sProbe probes
