graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["ML Model / Application"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>feast-{name}-ui<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Internal)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            Operator["Feast Operator<br/>SA: feast-operator-controller-manager<br/>Image: odh-feast-operator-rhel9<br/>Health: 8081/TCP (plaintext)"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            OnlineSvc["feast-{name}-online<br/>80→6566 HTTP | 443→6567 HTTPS<br/>Auth: OIDC/K8s RBAC"]
            OfflineSvc["feast-{name}-offline<br/>80→8815 HTTP | 443→8816 HTTPS<br/>Auth: OIDC/K8s RBAC"]
            RegistryGRPC["feast-{name}-registry<br/>80→6570 gRPC | 443→6571 gRPC+TLS<br/>Auth: OIDC/K8s RBAC"]
            RegistryREST["feast-{name}-registry-rest<br/>80→6572 HTTP | 443→6573 HTTPS<br/>Auth: Bearer (intra-comm JWT)"]
            UISvc["feast-{name}-ui<br/>80→8888 HTTP | 443→8443 HTTPS<br/>Auth: None"]
            MetricsSvc["Metrics: 8000/TCP<br/>HTTP, No Auth<br/>Prometheus scrape"]
            CronJob["CronJob Pod<br/>Image: ose-cli<br/>kubectl exec → feast apply"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        Redis["Redis<br/>6379/TCP<br/>Optional TLS<br/>Password from Secret"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Credentials from Secret"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / access key"]
        GCS["GCS<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>GCP SA"]
        Snowflake["Snowflake<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Credentials from Secret"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials"]
    end

    K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>SA Token"]

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Reencrypt<br/>UI access"| Route
    Route -->|"HTTPS/8443<br/>TLS service cert"| UISvc

    Client -->|"HTTP(S)/80,443<br/>Plaintext or TLS<br/>OIDC/K8s RBAC"| OnlineSvc

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    Operator -->|"HTTP(S)/6572-6573<br/>InsecureSkipVerify<br/>Intra-comm JWT HS256"| RegistryREST

    %% CronJob flows
    CronJob -->|"K8s exec API<br/>HTTPS/443<br/>SA Token"| K8sAPI

    %% Feature server egress
    OnlineSvc -->|"6379/TCP<br/>Redis protocol<br/>Optional TLS"| Redis
    OnlineSvc -->|"5432/TCP<br/>PG wire<br/>Optional TLS"| PostgreSQL
    OfflineSvc -->|"5432/TCP<br/>PG wire<br/>Optional TLS"| PostgreSQL
    OfflineSvc -->|"443/TCP HTTPS<br/>TLS 1.2+"| Snowflake
    RegistryGRPC -->|"5432/TCP<br/>PG wire"| PostgreSQL
    RegistryGRPC -->|"443/TCP HTTPS<br/>TLS 1.2+"| S3
    RegistryGRPC -->|"443/TCP HTTPS<br/>TLS 1.2+"| GCS
    OnlineSvc -->|"443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC validation"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Route ingress
    class Operator,OnlineSvc,OfflineSvc,RegistryGRPC,RegistryREST,UISvc,MetricsSvc,CronJob cluster
    class Redis,PostgreSQL,S3,GCS,Snowflake,OIDC externalservice
    class K8sAPI k8s
