%% Feast Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        ClientApp["Client Application"]
    end

    subgraph K8sTrust["KUBERNETES API (Trust Boundary)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>Auth: ServiceAccount Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB
        Operator["Feast Operator Controller Manager<br/>SA: feast-operator-controller-manager<br/>FIPS-compliant Go runtime"]
        OperatorHealth["Health: 8081/TCP HTTP plaintext"]
        OperatorMetrics["Metrics: 8443/TCP HTTPS TLS<br/>Auth: Bearer Token"]
        MetricsSvc["feast-operator-controller-manager-metrics-service<br/>ClusterIP 8443/TCP"]
    end

    subgraph ManagedNS["MANAGED NAMESPACE (per FeatureStore)"]
        direction TB

        subgraph FeastPod["Feast Deployment (Multi-Container Pod)<br/>SA: feast-{name}"]
            OnlineStore["Online Store Server<br/>6566/HTTP or 6567/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            OfflineStore["Offline Store Server<br/>8815/HTTP or 8816/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            RegistryGRPC["Registry Server (gRPC)<br/>6570/HTTP or 6571/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            RegistryREST["Registry Server (REST)<br/>6572/HTTP or 6573/HTTPS<br/>Auth: K8s RBAC / OIDC"]
            FeastUI["Feast UI<br/>8888/HTTP or 8443/HTTPS<br/>Auth: None"]
            Metrics8000["Metrics: 8000/TCP<br/>HTTP plaintext"]
        end

        CronJobPod["CronJob Pod (ose-cli)<br/>SA: feast-{name}-cronjob<br/>kubectl exec"]

        subgraph Services["ClusterIP Services"]
            SvcOnline["feast-{name}-online<br/>80 or 443/TCP"]
            SvcOffline["feast-{name}-offline<br/>80 or 443/TCP"]
            SvcRegistry["feast-{name}-registry<br/>80 or 443/TCP"]
            SvcRegistryREST["feast-{name}-registry-rest<br/>80 or 443/TCP"]
            SvcUI["feast-{name}-ui<br/>80 or 443/TCP"]
        end
    end

    subgraph IngressZone["INGRESS (External Access)"]
        Route["OpenShift Route (UI only)<br/>443/TCP HTTPS<br/>Edge/Reencrypt TLS"]
    end

    subgraph ExternalServices["EGRESS (External Services - Optional)"]
        ExtDB["External DB<br/>(Postgres/Redis/MongoDB/etc.)<br/>Various ports<br/>TLS varies<br/>Auth: Secret credentials"]
        S3["S3/GCS Object Store<br/>443/TCP HTTPS TLS<br/>Auth: Credentials via secret"]
        RemoteReg["Remote Registry<br/>80 or 443/TCP<br/>gRPC/HTTP<br/>Optional TLS"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS<br/>kubectl cert/token"| K8sAPI
    K8sAPI -->|"Reconcile events<br/>SA Token"| Operator

    %% Operator to K8s
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>CRUD resources"| K8sAPI

    %% Client to services
    ClientApp -->|"HTTP/80 or HTTPS/443<br/>Optional TLS<br/>K8s RBAC / OIDC"| SvcOnline
    ClientApp -->|"HTTP/80 or HTTPS/443<br/>Optional TLS<br/>K8s RBAC / OIDC"| SvcOffline

    %% Service to containers
    SvcOnline --> OnlineStore
    SvcOffline --> OfflineStore
    SvcRegistry --> RegistryGRPC
    SvcRegistryREST --> RegistryREST
    SvcUI --> FeastUI

    %% Route
    Route -->|"HTTPS reencrypt"| SvcUI

    %% CronJob
    CronJobPod -->|"HTTPS/443<br/>kubectl exec<br/>SA Token"| K8sAPI

    %% Internal references
    OnlineStore -->|"gRPC 6570/6571"| RegistryGRPC

    %% Egress
    OnlineStore -->|"Various<br/>Secret credentials"| ExtDB
    OfflineStore -->|"Various<br/>Secret credentials"| ExtDB
    RegistryGRPC -->|"HTTPS/443<br/>TLS"| S3
    RegistryGRPC -->|"gRPC/HTTP<br/>Optional TLS"| RemoteReg

    %% Prometheus
    Prometheus["Prometheus"] -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc
    Prometheus -->|"HTTP/8000<br/>plaintext"| Metrics8000

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8s fill:#326ce5,stroke:#fff,stroke-width:2px,color:#fff
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef managed fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef extsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef service fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:1px

    class User,ClientApp external
    class K8sAPI k8s
    class Operator,OperatorHealth,OperatorMetrics,MetricsSvc operator
    class OnlineStore,OfflineStore,RegistryGRPC,RegistryREST,FeastUI,Metrics8000,CronJobPod managed
    class Route ingress
    class ExtDB,S3,RemoteReg extsvc
    class SvcOnline,SvcOffline,SvcRegistry,SvcRegistryREST,SvcUI service
    class Prometheus monitoring
