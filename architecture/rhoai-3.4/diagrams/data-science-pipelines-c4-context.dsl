// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and runs ML pipelines via SDK, CLI, or web UI"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines platform for orchestrating, scheduling, and managing ML workflows on Kubernetes" {
            apiServer = container "ml-pipeline API Server" "Central API server for pipeline management, run execution, experiment tracking, artifact handling" "Go Service" {
                tags "Core"
            }
            scheduledWF = container "ml-pipeline-scheduledworkflow" "Manages recurring pipeline runs via cron/periodic schedules" "Go Controller" {
                tags "Core"
            }
            persistenceAgent = container "ml-pipeline-persistenceagent" "Syncs workflow state from Argo back to API server" "Go Agent" {
                tags "Core"
            }
            viewerController = container "ml-pipeline-viewer-crd" "Manages TensorBoard viewer deployments" "Go Controller" {
                tags "Core"
            }
            ui = container "ml-pipeline-ui" "Web UI for pipeline management" "TypeScript/React" {
                tags "Frontend"
            }
            vizServer = container "ml-pipeline-visualizationserver" "Generates pipeline visualizations" "Python Service" {
                tags "Core"
            }
            cacheServer = container "cache-server" "Mutating webhook for caching pipeline step results" "Go Webhook" {
                tags "Core"
            }
            mlmd = container "metadata-grpc-server" "ML Metadata store for artifact/execution lineage" "gRPC Service" {
                tags "Core"
            }
            metadataEnvoy = container "metadata-envoy" "gRPC proxy for ML Metadata service" "Envoy Proxy" {
                tags "Core"
            }
            metadataWriter = container "metadata-writer" "Writes pipeline execution metadata to MLMD" "Go Agent" {
                tags "Core"
            }
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Workflow execution engine for pipeline runs" {
            tags "External"
        }
        database = softwareSystem "MySQL/MariaDB/PostgreSQL" "Pipeline metadata, run state, cache storage" {
            tags "External"
        }
        objectStorage = softwareSystem "MinIO / S3 Storage" "Pipeline artifact and log storage" {
            tags "External"
        }
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS, auth policies, ingress routing" {
            tags "External"
        }
        dspo = softwareSystem "Data Science Pipelines Operator" "Deploys and manages DSP instances via DSPA CR" {
            tags "Internal RHOAI"
        }
        kubernetes = softwareSystem "Kubernetes API" "Container orchestration, CRD management" {
            tags "External"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "External"
        }
        kserve = softwareSystem "KServe" "Model serving platform (pipeline component)" {
            tags "Internal RHOAI"
        }

        // User interactions
        user -> ui "Manages pipelines via web browser" "HTTPS/443"
        user -> apiServer "Submits pipelines/runs via SDK" "REST 8888/gRPC 8887"

        // Internal container relationships
        ui -> apiServer "Proxies API calls" "HTTP/8888"
        apiServer -> vizServer "Requests visualizations" "HTTP/8888"
        persistenceAgent -> apiServer "Reports run status/metrics" "HTTP/8888"
        metadataWriter -> mlmd "Writes execution metadata" "gRPC/8080"
        metadataEnvoy -> mlmd "Proxies gRPC requests" "gRPC/8080"

        // External dependencies
        apiServer -> database "Stores pipeline metadata" "MySQL 3306 / PostgreSQL 5432"
        apiServer -> objectStorage "Stores pipeline artifacts" "HTTP/9000 or HTTPS/443"
        apiServer -> kubernetes "Creates Argo Workflows, manages CRDs" "HTTPS/443"
        cacheServer -> database "Checks/stores cache entries" "MySQL 3306 / PostgreSQL 5432"
        scheduledWF -> kubernetes "Watches ScheduledWorkflow CRs, creates Workflows" "HTTPS/443"
        persistenceAgent -> kubernetes "Watches Argo Workflow CRs" "HTTPS/443"
        viewerController -> kubernetes "Watches Viewer CRs, creates Deployments" "HTTPS/443"

        // Integration points
        dspo -> dsp "Deploys and manages via DataSciencePipelinesApplication CR" "HTTPS/443"
        istio -> dsp "Provides mTLS, AuthorizationPolicies, ingress routing"
        prometheus -> apiServer "Scrapes /metrics endpoint" "HTTP/8888"
        kubernetes -> argoWorkflows "Dispatches Workflow execution"
        kubernetes -> cacheServer "Sends admission webhook requests" "HTTPS/443→8443"
    }

    views {
        systemContext dsp "SystemContext" "Data Science Pipelines system context" {
            include *
            autoLayout
        }

        container dsp "Containers" "Data Science Pipelines internal containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Core" {
                background #4a90e2
            }
            element "Frontend" {
                background #2d6cb4
            }
        }
    }
}
