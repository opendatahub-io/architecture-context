graph TB
    subgraph MaaS["Models as a Service (MaaS) Platform"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            TenantReconciler["Tenant Reconciler<br/>Platform lifecycle mgmt"]
            ModelRefReconciler["MaaSModelRef Reconciler<br/>Model routing (HTTPRoute)"]
            AuthPolicyReconciler["MaaSAuthPolicy Reconciler<br/>Auth policy aggregation"]
            SubscriptionReconciler["MaaSSubscription Reconciler<br/>Token rate limit policies"]
            ExternalModelReconciler["ExternalModel Reconciler<br/>Istio networking stack"]
        end

        subgraph API["maas-api (Go/Gin HTTP Service)"]
            APIKeyHandler["API Key Handler<br/>CRUD, hash-only storage"]
            SubscriptionSelector["Subscription Selector<br/>Priority-based resolution"]
            ModelDiscovery["Model Discovery<br/>Access probing"]
            AuthorinoCallback["Authorino Callbacks<br/>Validate + Select"]
        end

        subgraph PayloadProc["payload-processing (ext_proc)"]
            ModelToHeader["model-to-header plugin"]
            ProviderResolver["model-provider-resolver plugin"]
            APITranslation["api-translation plugin"]
            KeyInjection["apikey-injection plugin"]
        end
    end

    %% CRDs
    TenantCR["Tenant CR<br/>maas.opendatahub.io/v1alpha1"]
    ModelRefCR["MaaSModelRef CR"]
    ExternalModelCR["ExternalModel CR"]
    AuthPolicyCR["MaaSAuthPolicy CR"]
    SubscriptionCR["MaaSSubscription CR"]

    %% CRD Watches
    TenantCR -->|watched by| TenantReconciler
    ModelRefCR -->|watched by| ModelRefReconciler
    ExternalModelCR -->|watched by| ExternalModelReconciler
    AuthPolicyCR -->|watched by| AuthPolicyReconciler
    SubscriptionCR -->|watched by| SubscriptionReconciler

    %% Controller creates resources
    TenantReconciler -->|deploys| API
    TenantReconciler -->|deploys| PayloadProc
    ModelRefReconciler -->|creates| HTTPRoute["HTTPRoute<br/>gateway.networking.k8s.io"]
    AuthPolicyReconciler -->|creates| KuadrantAuthPolicy["Kuadrant AuthPolicy<br/>(aggregated per model)"]
    SubscriptionReconciler -->|creates| TokenRateLimit["Kuadrant<br/>TokenRateLimitPolicy<br/>(aggregated per model)"]
    ExternalModelReconciler -->|creates| ServiceEntry["Istio ServiceEntry"]
    ExternalModelReconciler -->|creates| DestRule["Istio DestinationRule"]
    ExternalModelReconciler -->|creates| EnvoyFilter["Istio EnvoyFilter"]

    %% API interactions
    AuthorinoCallback -->|validates| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    APIKeyHandler -->|hash storage| PostgreSQL
    ModelDiscovery -->|probes| KServeEndpoints["KServe Model<br/>Endpoints"]

    %% External interactions
    Client["Client"] -->|HTTPS/443| Gateway["maas-default-gateway<br/>maas.CLUSTER_DOMAIN"]
    Gateway -->|auth eval| Authorino["Authorino"]
    Authorino -->|callback| AuthorinoCallback
    Gateway -->|ext_proc/9004| PayloadProc
    Gateway -->|forward| KServeEndpoints
    Gateway -->|forward| ExternalProviders["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style API fill:#50a0d2,color:#fff
    style PayloadProc fill:#6ab0e2,color:#fff
    style TenantCR fill:#f5a623
    style ModelRefCR fill:#f5a623
    style ExternalModelCR fill:#f5a623
    style AuthPolicyCR fill:#f5a623
    style SubscriptionCR fill:#f5a623
    style Gateway fill:#7ed321
    style Authorino fill:#e8e8e8
    style PostgreSQL fill:#e8e8e8
    style KServeEndpoints fill:#e8e8e8
    style ExternalProviders fill:#e8e8e8
    style Client fill:#f9f9f9,stroke:#333
    style HTTPRoute fill:#d5e8d4
    style KuadrantAuthPolicy fill:#d5e8d4
    style TokenRateLimit fill:#d5e8d4
    style ServiceEntry fill:#d5e8d4
    style DestRule fill:#d5e8d4
    style EnvoyFilter fill:#d5e8d4
