graph TB
    subgraph MaaS["Models as a Service (MaaS)"]
        direction TB

        subgraph Controller["maas-controller (Go Operator)"]
            MaaSModelRefReconciler["MaaSModelRef<br/>Reconciler"]
            MaaSAuthPolicyReconciler["MaaSAuthPolicy<br/>Reconciler"]
            MaaSSubscriptionReconciler["MaaSSubscription<br/>Reconciler"]
            TenantReconciler["Tenant<br/>Reconciler"]
            ExternalModelReconciler["ExternalModel<br/>Reconciler"]
        end

        subgraph API["maas-api (Go REST / Gin)"]
            ModelsEndpoint["/v1/models"]
            APIKeysEndpoint["/v1/api-keys"]
            SubscriptionsEndpoint["/v1/subscriptions"]
            InternalValidate["/internal/v1/api-keys/validate"]
            InternalSelect["/internal/v1/subscriptions/select"]
        end

        subgraph PayloadProc["payload-processing (Envoy ext_proc)"]
            ModelToHeader["Model-to-Header<br/>Plugin"]
            ProviderResolver["Provider Resolver<br/>Plugin"]
            APITranslation["API Translation<br/>Plugin"]
            APIKeyInjection["API Key Injection<br/>Plugin"]
        end
    end

    %% CRDs
    TenantCR["Tenant CR"]
    MaaSModelRefCR["MaaSModelRef CR"]
    MaaSAuthPolicyCR["MaaSAuthPolicy CR"]
    MaaSSubscriptionCR["MaaSSubscription CR"]
    ExternalModelCR["ExternalModel CR"]

    %% CRD watches
    TenantCR -->|watched by| TenantReconciler
    MaaSModelRefCR -->|watched by| MaaSModelRefReconciler
    MaaSAuthPolicyCR -->|watched by| MaaSAuthPolicyReconciler
    MaaSSubscriptionCR -->|watched by| MaaSSubscriptionReconciler
    ExternalModelCR -->|watched by| ExternalModelReconciler

    %% Controller creates
    TenantReconciler -->|deploys via SSA| API
    TenantReconciler -->|deploys| PayloadProc
    MaaSAuthPolicyReconciler -->|creates| AuthPolicy["Kuadrant AuthPolicy"]
    MaaSSubscriptionReconciler -->|creates| TRLP["Kuadrant TokenRateLimitPolicy"]
    ExternalModelReconciler -->|creates| ServiceEntry["Istio ServiceEntry"]
    ExternalModelReconciler -->|creates| DestRule["Istio DestinationRule"]
    ExternalModelReconciler -->|creates| HTTPRoute["Gateway HTTPRoute"]

    %% Authorino integration
    Authorino["Kuadrant Authorino"] -->|HTTP callback| InternalValidate
    Authorino -->|HTTP callback| InternalSelect

    %% External dependencies
    API -->|5432/TCP| PostgreSQL["PostgreSQL"]
    API -->|probes /v1/models| KServeModels["KServe Model Servers"]
    PayloadProc -->|reads| ExternalModelCR
    PayloadProc -->|reads secrets| ProviderKeys["Provider API Key Secrets"]

    %% Users
    User["Data Scientist / Client"] -->|443/TCP HTTPS| Gateway["Gateway API<br/>(Envoy)"]
    Gateway -->|AuthPolicy| Authorino
    Gateway -->|ext_proc 9004/TCP| PayloadProc
    Gateway -->|8443/TCP HTTPS| API
    Gateway -->|routes to| KServeModels
    Gateway -->|routes to| ExternalProviders["External LLM Providers"]

    %% Styles
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style API fill:#4a90e2,stroke:#333,color:#fff
    style PayloadProc fill:#4a90e2,stroke:#333,color:#fff
    style TenantCR fill:#f5a623,stroke:#333
    style MaaSModelRefCR fill:#f5a623,stroke:#333
    style MaaSAuthPolicyCR fill:#f5a623,stroke:#333
    style MaaSSubscriptionCR fill:#f5a623,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style AuthPolicy fill:#7ed321,stroke:#333
    style TRLP fill:#7ed321,stroke:#333
    style Authorino fill:#7ed321,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style KServeModels fill:#e8e8e8,stroke:#333
    style ExternalProviders fill:#e8e8e8,stroke:#333
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style ServiceEntry fill:#d4edda,stroke:#333
    style DestRule fill:#d4edda,stroke:#333
    style HTTPRoute fill:#d4edda,stroke:#333
