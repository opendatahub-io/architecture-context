%% Component Structure Diagram - Models as a Service (MaaS)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph MaaS["Models as a Service (MaaS)"]
        direction TB
        subgraph Controller["maas-controller (Go Operator)"]
            ModelRefCtrl["MaaSModelRef<br/>Controller"]
            AuthPolicyCtrl["MaaSAuthPolicy<br/>Controller"]
            SubscriptionCtrl["MaaSSubscription<br/>Controller"]
        end

        subgraph API["maas-api (Go REST API / Gin)"]
            KeyMgmt["API Key Management<br/>/v1/api-keys"]
            ModelDiscovery["Model Discovery<br/>/v1/models"]
            SubSelect["Subscription Selection<br/>/v1/subscriptions/select"]
            KeyValidate["API Key Validation<br/>/internal/v1/api-keys/validate"]
            HealthCheck["Health Check<br/>/health"]
        end
    end

    subgraph CRDs["Custom Resource Definitions"]
        MaaSModelRefCR["MaaSModelRef<br/>maas.opendatahub.io/v1alpha1"]
        MaaSAuthPolicyCR["MaaSAuthPolicy<br/>maas.opendatahub.io/v1alpha1"]
        MaaSSubscriptionCR["MaaSSubscription<br/>maas.opendatahub.io/v1alpha1"]
    end

    subgraph GatewayInfra["Gateway Infrastructure"]
        DefaultGW["maas-default-gateway<br/>openshift-ingress<br/>443/TCP, 80/TCP"]
        DefaultAuth["gateway-default-auth<br/>Kuadrant AuthPolicy<br/>(deny-all)"]
        DefaultDeny["gateway-default-deny<br/>TokenRateLimitPolicy<br/>(zero-rate)"]
    end

    %% CRD Watches
    MaaSModelRefCR -->|watched by| ModelRefCtrl
    MaaSAuthPolicyCR -->|watched by| AuthPolicyCtrl
    MaaSSubscriptionCR -->|watched by| SubscriptionCtrl

    %% Controller outputs
    ModelRefCtrl -->|validates HTTPRoute exists| HTTPRoute["Model HTTPRoutes"]
    AuthPolicyCtrl -->|creates| KuadrantAP["Kuadrant AuthPolicy<br/>(per-model)"]
    SubscriptionCtrl -->|creates| KuadrantTRLP["Kuadrant TokenRateLimitPolicy<br/>(per-model)"]

    %% Authorino callbacks
    Authorino["Kuadrant/Authorino"] -->|callback| KeyValidate
    Authorino -->|callback| SubSelect

    %% External dependencies
    API -->|queries| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    Controller -->|watches| LLMInferenceService["KServe<br/>LLMInferenceService"]
    Controller -->|manages| HTTPRoute
    HTTPRoute -->|parented by| DefaultGW

    %% Gateway policies
    DefaultAuth -->|targets| DefaultGW
    DefaultDeny -->|targets| DefaultGW
    KuadrantAP -->|targets| HTTPRoute
    KuadrantTRLP -->|targets| HTTPRoute

    %% User interaction
    User["Data Scientist / Client"] -->|creates| MaaSModelRefCR
    User -->|creates| MaaSAuthPolicyCR
    User -->|creates| MaaSSubscriptionCR
    User -->|API key mgmt| KeyMgmt

