// C4 Context Diagram - Workload Variant Autoscaler
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/workload-variant-autoscaler.md

workspace {
    model {
        // People
        mlEngineer = person "ML Engineer / Platform Admin" "Configures autoscaling policies for LLM inference workloads"

        // Main System
        wva = softwareSystem "Workload Variant Autoscaler (WVA)" "Kubernetes-based global autoscaler for inference model servers using saturation-based scaling with KV cache utilization and queue depth metrics" {
            vaController = container "VariantAutoscaling Controller" "Reconciles VariantAutoscaling CRs, resolves scale targets, applies engine decisions" "Go Controller (controller-runtime)"
            cmController = container "ConfigMap Controller" "Watches ConfigMaps for saturation scaling config, supports global and namespace-local overrides" "Go Controller (controller-runtime)"
            ipController = container "InferencePool Controller" "Watches InferencePool CRs (v1 and v1alpha2), syncs endpoint pool data" "Go Controller (controller-runtime)"
            saturationEngine = container "Saturation Engine" "Background loop querying Prometheus for KV cache/queue metrics, computes desired replica counts" "Go Engine Loop"
            scaleFromZeroEngine = container "Scale-from-Zero Engine" "Background loop handling scaling from zero replicas using InferencePool endpoint data" "Go Engine Loop"
            metricsEmitter = container "Metrics Emitter" "Emits custom Prometheus metrics (wva_desired_replicas, wva_desired_ratio, etc.)" "Go Library, Port 8443/TCP HTTPS"
            datastore = container "Datastore" "Tracks namespace-to-VA mappings and InferencePool endpoint data" "Go In-Memory Store"
        }

        // External Systems
        prometheus = softwareSystem "Prometheus / Thanos Querier" "Monitoring system for querying vLLM saturation metrics and scraping WVA metrics" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Kubernetes control plane for CR management" "External"
        hpaKeda = softwareSystem "HPA / KEDA" "Horizontal Pod Autoscaler and KEDA for actual deployment scaling" "External"
        vllm = softwareSystem "vLLM Inference Servers" "LLM inference model servers being autoscaled" "External"
        gatewayApiInf = softwareSystem "Gateway API Inference Extension" "Provides InferencePool CRs for endpoint-aware scaling" "External"

        // Relationships - People
        mlEngineer -> wva "Creates VariantAutoscaling CRs, configures scaling thresholds via ConfigMaps"

        // Relationships - WVA to External
        wva -> prometheus "Queries vLLM saturation metrics (PromQL)" "HTTPS/9091, Bearer Token"
        wva -> k8sApi "Manages CRs, Deployments, ConfigMaps, InferencePools" "HTTPS/443, SA Token"
        prometheus -> wva "Scrapes custom metrics endpoint" "HTTPS/8443, Bearer Token"
        hpaKeda -> prometheus "Reads wva_desired_replicas, wva_desired_ratio" "HTTPS/9091"
        hpaKeda -> k8sApi "Scales Deployment replicas" "HTTPS/443"
        vllm -> prometheus "Exposes KV cache utilization, queue depth metrics"
        gatewayApiInf -> k8sApi "Creates InferencePool CRs"

        // Internal container relationships
        saturationEngine -> prometheus "PromQL queries for KV cache and queue depth" "HTTPS/9091"
        saturationEngine -> metricsEmitter "Emits scaling metrics"
        saturationEngine -> vaController "Triggers reconcile via channel"
        scaleFromZeroEngine -> datastore "Reads endpoint pool data"
        scaleFromZeroEngine -> k8sApi "Scales deployment via scale subresource" "HTTPS/443"
        vaController -> k8sApi "Updates VariantAutoscaling CR status" "HTTPS/443"
        vaController -> datastore "Resolves scale targets"
        cmController -> k8sApi "Watches ConfigMaps" "HTTPS/443"
        ipController -> k8sApi "Watches InferencePool CRs" "HTTPS/443"
        ipController -> datastore "Syncs endpoint data"
    }

    views {
        systemContext wva "SystemContext" {
            include *
            autoLayout
        }

        container wva "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
