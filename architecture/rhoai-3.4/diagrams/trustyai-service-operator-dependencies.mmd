graph LR
    TrustyAI["TrustyAI Service<br/>Operator"]

    %% External Dependencies (Required)
    TrustyAI -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.17.0"]
    TrustyAI -->|"InferenceService CRD<br/>patch + watch"| KServe["KServe<br/>v0.12.1"]
    TrustyAI -->|"Route CRD<br/>external access"| OpenShiftAPI["OpenShift API<br/>(Route)"]

    %% External Dependencies (Optional)
    TrustyAI -.->|"job scheduling<br/>(optional)"| Kueue["Kueue<br/>v0.6.2"]
    TrustyAI -.->|"ServiceMonitor CRD<br/>(optional)"| PromOperator["Prometheus<br/>Operator v0.64.1"]
    TrustyAI -.->|"mTLS DestinationRule<br/>VirtualService<br/>(conditional)"| Istio["Istio /<br/>Service Mesh"]

    %% Internal Platform Dependencies
    TrustyAI -->|"enables controllers<br/>trustyai-dsc-config"| RhodsOp["rhods-operator /<br/>opendatahub-operator"]
    TrustyAI -->|"patches predictors<br/>inference loggers"| KServeISVC["KServe<br/>InferenceService"]
    TrustyAI -->|"introspects runtimes<br/>port discovery"| ServingRuntime["KServe<br/>ServingRuntime"]
    TrustyAI -->|"injects MM_PAYLOAD_PROCESSORS<br/>MM_TLS_KEY_CERT_PATH"| ModelMesh["ModelMesh<br/>Serving"]
    TrustyAI -->|"creates ServiceMonitors"| Prometheus["Prometheus"]
    TrustyAI -->|"inject-cabundle<br/>service serving certs"| OpenShiftCA["OpenShift<br/>Service CA"]
    TrustyAI -->|"RBAC + projected<br/>SA tokens (3600s)"| MLFlow["MLFlow<br/>(RHOAI)"]

    %% Integration Points (consumers of TrustyAI)
    Dashboard["ODH Dashboard"] -.->|"UI management"| TrustyAI
    DSPipelines["Data Science<br/>Pipelines"] -.->|"evaluation<br/>integration"| TrustyAI

    %% External Service Dependencies
    TrustyAI -->|"model + result<br/>storage"| S3["S3-compatible<br/>Storage"]
    TrustyAI -->|"result upload<br/>OCI artifacts"| OCIReg["OCI<br/>Registries"]
    TrustyAI -->|"model + dataset<br/>download"| HFHub["HuggingFace<br/>Hub"]
    TrustyAI -->|"custom task<br/>fetching"| Git["Git<br/>Repositories"]
    TrustyAI -->|"data storage"| PostgreSQL["PostgreSQL"]
    TrustyAI -->|"SAR auth<br/>sidecar"| KubeRBACProxy["kube-rbac-proxy<br/>4.19"]
    TrustyAI -->|"CRD CRUD<br/>SA Token"| K8sAPI["Kubernetes<br/>API"]

