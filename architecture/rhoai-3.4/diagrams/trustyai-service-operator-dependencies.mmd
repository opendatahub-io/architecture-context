graph LR
    TSO["trustyai-service-operator<br/>(Multi-Controller Operator)"]

    %% External Dependencies (frameworks/libraries)
    TSO -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.17.0"]
    TSO -->|"CRD types"| KServe["KServe<br/>v0.12.1"]
    TSO -->|"Route API"| OpenShiftAPI["openshift/api"]
    TSO -->|"ServiceMonitor CRD"| PromOperator["prometheus-operator<br/>v0.64.1"]
    TSO -.->|"optional: job scheduling"| Kueue["Kueue<br/>v0.6.2"]

    %% Internal Platform Dependencies
    TSO -->|"watch/patch InferenceService<br/>discover ServingRuntimes"| KServeISvc["KServe<br/>InferenceService"]
    TSO -->|"create DestinationRule<br/>+ VirtualService"| Istio["Istio<br/>Service Mesh"]
    TSO -->|"create Routes<br/>for external access"| OSRouter["OpenShift Router"]
    TSO -->|"annotation-triggered<br/>cert generation"| OSCA["OpenShift<br/>Service CA"]
    TSO -->|"create ServiceMonitors<br/>for metrics scraping"| Prometheus["Prometheus<br/>Operator"]
    TSO -->|"sidecar container<br/>SAR auth"| KRBP["kube-rbac-proxy"]
    TSO -->|"create RoleBindings<br/>for experiment access"| MLFlow["MLFlow"]
    TSO -->|"read platform settings"| DSCConfigMap["DSC ConfigMap"]
    TSO -->|"read image references"| OperatorConfigMap["Platform Operator<br/>ConfigMap"]
    TSO -->|"read custom CAs"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]

    %% External Service Dependencies
    TSO -->|"download offline assets<br/>HTTPS/443, AWS IAM"| S3["S3 Storage"]
    TSO -->|"upload result artifacts<br/>HTTPS/443, credentials"| OCI["OCI Registry"]
    TSO -->|"clone custom tasks<br/>HTTPS/443 only"| Git["Git Repos"]
    TSO -->|"prediction storage<br/>TCP/TLS, DB creds"| PostgreSQL["PostgreSQL"]
    TSO -->|"telemetry export<br/>gRPC/HTTP"| OTLP["OTLP Collector"]

    %% Integration Points (other components → operator)
    KServeISvc -.->|"InferenceLogger sends<br/>prediction payloads"| TSO

