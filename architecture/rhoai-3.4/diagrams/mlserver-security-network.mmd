graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (TLS Termination + AuthN/AuthZ)"]
        Gateway["RHOAI Gateway<br/>+ kube-rbac-proxy<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token + K8s RBAC"]
    end

    subgraph PodNetwork["POD NETWORK (No TLS, No Auth - Cluster Internal)"]
        direction TB

        subgraph ServerPorts["MLServer Listening Ports"]
            RESTServer["REST Server<br/>(FastAPI/uvicorn)<br/>8080/TCP HTTP<br/>Plaintext<br/>No Auth"]
            GRPCServer["gRPC Server<br/>(add_insecure_port)<br/>8081/TCP gRPC<br/>No Encryption<br/>No Auth"]
            MetricsServer["Metrics Server<br/>(Prometheus)<br/>8082/TCP HTTP<br/>Plaintext<br/>No Auth"]
        end

        subgraph Security["Runtime Security Enforcement"]
            TrustedRuntimes["Trusted Runtimes<br/>/etc/mlserver/trusted-runtimes.json<br/>Production mode allowlist<br/>Rejects: custom envs, wildcard CORS"]
        end

        subgraph LocalFS["Filesystem Access"]
            ModelMount["/mnt/models<br/>(PVC/S3 mount)<br/>Read-only<br/>Model artifacts"]
            SAToken["/var/run/secrets/.../namespace<br/>Read-only<br/>CloudEvents headers"]
        end
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>No Encryption (insecure=True)<br/>No Auth"]
        Kafka["Kafka Broker<br/>9092/TCP<br/>No Encryption<br/>No Auth<br/>(optional)"]
        RemoteInfer["Remote Inference Server<br/>Variable port<br/>HTTP/HTTPS<br/>Configurable SSL<br/>(Alibi-Explain only)"]
    end

    subgraph Monitoring["MONITORING (Inbound Scrape)"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Pod (no encryption)
    Gateway -->|"HTTP/8080<br/>Plaintext<br/>No Auth"| RESTServer
    Gateway -->|"gRPC/8081<br/>Insecure<br/>No Auth"| GRPCServer

    %% Monitoring
    Prometheus -->|"HTTP/8082<br/>Plaintext<br/>Scrape"| MetricsServer

    %% Egress
    RESTServer -.->|"gRPC/4317<br/>insecure=True<br/>Traces"| OTel
    RESTServer -.->|"TCP/9092<br/>No Encryption<br/>Async Inference"| Kafka
    RESTServer -.->|"HTTP(S)/Variable<br/>Configurable SSL<br/>Black-box explain"| RemoteInfer

    %% Local filesystem
    ModelMount -.->|"Filesystem<br/>Read-only"| RESTServer
    SAToken -.->|"Filesystem<br/>Read-only"| RESTServer

    %% Security enforcement
    TrustedRuntimes -.->|"Restricts<br/>model loading"| RESTServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef monitoring fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef filesystem fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class RESTServer,GRPCServer,MetricsServer podnetwork
    class OTel,Kafka,RemoteInfer egress
    class TrustedRuntimes security
    class Prometheus monitoring
    class ModelMount,SAToken filesystem
