graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph AuthBoundary["INGRESS (Auth Boundary)"]
        Gateway["KServe Gateway /<br/>kube-rbac-proxy<br/>443/TCP<br/>TLS 1.2+ Termination<br/>Bearer Token AuthN<br/>Kubernetes RBAC AuthZ"]
    end

    subgraph Pod["POD INTERNAL (Trusted - same network namespace)"]
        direction TB

        RESTServer["MLServer REST Server<br/>(FastAPI/Uvicorn)<br/>8080/TCP HTTP<br/>No encryption<br/>CORS: wildcards blocked in prod"]

        GRPCServer["MLServer gRPC Server<br/>8081/TCP gRPC (HTTP/2)<br/>No encryption<br/>add_insecure_port()"]

        MetricsServer["MLServer Metrics Server<br/>(Uvicorn)<br/>8082/TCP HTTP<br/>No encryption<br/>Endpoint: /metrics"]

        DataPlane["DataPlane<br/>V2 Protocol Handler<br/>Runtime security validation"]

        TrustedRuntimes["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>(read-only, baked at build)<br/>Blocks: custom envs, untrusted impls"]

        subgraph RuntimePlugins["ML Runtime Plugins (allowlisted only)"]
            SKLearn["mlserver-sklearn<br/>scikit-learn 1.8.0"]
            XGBoost["mlserver-xgboost<br/>XGBoost 3.2.0"]
            LightGBM["mlserver-lightgbm<br/>LightGBM 4.6.0"]
            ONNXRuntime["mlserver-onnx<br/>onnxruntime 1.24.4"]
        end

        RESTServer --> DataPlane
        GRPCServer --> DataPlane
        DataPlane -->|validates| TrustedRuntimes
        DataPlane --> SKLearn
        DataPlane --> XGBoost
        DataPlane --> LightGBM
        DataPlane --> ONNXRuntime
    end

    subgraph Storage["MODEL STORAGE"]
        ModelStorage["PVC / S3 / ModelCar<br/>Volume mount: /mnt/models<br/>Credentials: managed by KServe"]
    end

    subgraph OptionalEgress["OPTIONAL EGRESS"]
        OTelCollector["OpenTelemetry Collector<br/>gRPC (insecure=True)<br/>No encryption, No auth<br/>OTLP trace export"]
        KafkaBroker["Kafka Brokers<br/>9092/TCP<br/>No encryption (default)<br/>No auth"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>HTTP/8082<br/>No auth (NetworkPolicy)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8080<br/>No encryption<br/>pod-internal"| RESTServer
    Gateway -->|"gRPC/8081<br/>No encryption<br/>pod-internal"| GRPCServer

    %% Storage
    ModelStorage -->|"Filesystem<br/>/mnt/models<br/>read-only"| DataPlane

    %% Optional egress
    RESTServer -.->|"gRPC<br/>insecure"| OTelCollector
    GRPCServer -.->|"gRPC<br/>insecure"| OTelCollector
    DataPlane -.->|"TCP/9092<br/>No encryption"| KafkaBroker

    %% Monitoring
    Prometheus -->|"HTTP/8082<br/>GET /metrics"| MetricsServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366

    class Client external
    class Gateway ingress
    class RESTServer,GRPCServer,MetricsServer,DataPlane podinternal
    class TrustedRuntimes security
    class SKLearn,XGBoost,LightGBM,ONNXRuntime runtime
    class ModelStorage storage
    class OTelCollector,KafkaBroker optional
    class Prometheus monitoring
