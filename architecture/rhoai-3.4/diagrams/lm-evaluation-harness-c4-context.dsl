// LM Evaluation Harness - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        operator = person "TrustyAI LMEval Operator" "Creates and manages LMES Job pods with ConfigMaps and Secrets"
        datascientist = person "Data Scientist" "Triggers model evaluations via EvalHub"

        // Primary System
        lmesJob = softwareSystem "LM Evaluation Harness (LMES Job)" "Batch-oriented container runtime for evaluating LLMs against benchmark tasks using lm-evaluation-harness framework" {
            adapter = container "LMEvalAdapter (main.py)" "EvalHub adapter entry point; orchestrates benchmark execution lifecycle" "Python 3.11"
            lmEvalCore = container "lm_eval Core Library" "EleutherAI evaluation engine with 150+ benchmark task families" "Python Library"
            localCompletions = container "local-completions Backend" "OpenAI-compatible API client for model inference" "Python Module"
            ociPublisher = container "OCI Artifact Publisher" "Pushes evaluation results as OCI artifacts via skopeo" "Python Script"
            s3Downloader = container "S3 Downloader" "Downloads model assets from S3-compatible storage" "Python Script"
            offlineMetrics = container "Offline Metrics" "50+ pre-packaged metrics for disconnected environments" "Python Modules"

            adapter -> lmEvalCore "Orchestrates evaluation"
            lmEvalCore -> localCompletions "Sends evaluation prompts"
            lmEvalCore -> offlineMetrics "Computes metrics"
            adapter -> ociPublisher "Publishes result artifacts"
            adapter -> s3Downloader "Downloads model assets"
        }

        // Internal ODH Systems
        evalHub = softwareSystem "EvalHub Service" "Job orchestration and result reporting service" "Internal ODH"
        modelInference = softwareSystem "Model Inference Service" "KServe/vLLM model serving endpoint" "Internal ODH"
        trustyaiOperator = softwareSystem "TrustyAI LMEval Operator" "Creates and manages LMES Job workloads" "Internal ODH"

        // External Systems
        ociRegistry = softwareSystem "OCI Registry" "Container/artifact registry for evaluation results" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Model asset and dataset storage (S3/MinIO)" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and dataset repository" "External"
        mlflowServer = softwareSystem "MLflow Tracking Server" "Optional experiment tracking" "External"

        // Relationships
        datascientist -> evalHub "Triggers evaluation jobs"
        trustyaiOperator -> lmesJob "Creates Kubernetes Job with ConfigMap and Secrets"
        lmesJob -> evalHub "Reports job status and evaluation results" "HTTPS/443 Bearer Token"
        lmesJob -> modelInference "Sends evaluation prompts, receives completions" "HTTPS/443 Bearer Token"
        lmesJob -> ociRegistry "Pushes evaluation result artifacts" "HTTPS/443 Docker auth"
        lmesJob -> s3Storage "Downloads model assets and datasets" "HTTPS/443 AWS IAM"
        lmesJob -> huggingfaceHub "Downloads tokenizers and datasets" "HTTPS/443 HF_TOKEN"
        lmesJob -> mlflowServer "Logs evaluation metrics and artifacts" "HTTP(S)/5000"
    }

    views {
        systemContext lmesJob "SystemContext" {
            include *
            autoLayout
        }

        container lmesJob "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
