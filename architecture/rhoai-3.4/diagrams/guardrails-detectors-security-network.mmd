graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>User Application"]
    end

    subgraph Ingress["INGRESS (KServe Gateway)"]
        KServeGW["KServe InferenceService<br/>HTTPRoute<br/>443/TCP → internal<br/>TLS SIMPLE"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        Orchestrator["FMS Guardrails Orchestrator<br/>Invokes detectors on<br/>LLM input/output"]

        subgraph NS_Deploy["Namespace: (deploy namespace)"]
            direction TB

            BuiltIn["Built-in Detector<br/>ClusterIP 8080/TCP<br/>Image: odh-built-in-detector-rhel9<br/>4 uvicorn workers<br/>No external deps"]

            HFDetector["HuggingFace Detector<br/>ClusterIP 8000/TCP (KServe ISVC)<br/>Image: odh-guardrails-detector-hf-rhel9<br/>1 uvicorn worker (GPU-bound)<br/>Istio sidecar + auth annotation"]

            JudgeDetector["LLM Judge Detector<br/>ClusterIP 8000/TCP (KServe ISVC)<br/>Image: guardrails-detector-llm-judge<br/>Istio sidecar + auth annotation<br/>No Konflux build (pre-GA)"]

            MinIO["S3/MinIO<br/>minio-guardrails-guardian<br/>ClusterIP 9000/TCP"]
        end

        VLLMServer["vLLM Inference Server<br/>8080/TCP HTTP<br/>OpenAI-compatible"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS (KServe-managed)<br/>kube-rbac-proxy / OAuth"| KServeGW

    %% Ingress to service mesh
    KServeGW -->|"HTTP/8080,8000<br/>mTLS STRICT<br/>Istio service identity"| Orchestrator

    %% Orchestrator to detectors
    Orchestrator -->|"HTTP/8080<br/>mTLS (Istio)<br/>POST /api/v1/text/contents"| BuiltIn
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>POST /api/v1/text/contents"| HFDetector
    Orchestrator -->|"HTTP/8000<br/>mTLS (Istio)<br/>POST /api/v1/text/contents"| JudgeDetector

    %% HF to MinIO
    HFDetector -->|"HTTP/9000<br/>S3 API<br/>No TLS (cluster-internal)<br/>AWS access key/secret"| MinIO

    %% Judge to vLLM
    JudgeDetector -->|"HTTP/8080<br/>OpenAI-compatible<br/>No TLS (cluster-internal)<br/>No Auth"| VLLMServer

    %% Monitoring
    Prometheus -->|"HTTP/8080,8000<br/>GET /metrics<br/>No Auth"| BuiltIn
    Prometheus -->|"HTTP/8000<br/>GET /metrics<br/>No Auth"| HFDetector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef detector fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KServeGW ingress
    class Orchestrator servicemesh
    class BuiltIn,HFDetector,JudgeDetector detector
    class MinIO,VLLMServer storage
    class Prometheus monitoring
