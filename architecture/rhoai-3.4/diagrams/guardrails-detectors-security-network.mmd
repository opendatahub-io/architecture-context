graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph ServiceMesh["SERVICE MESH (Istio mTLS STRICT)"]
        direction TB

        subgraph Caller["Caller"]
            Orch["FMS Guardrails Orchestrator<br/>IBM Detector API caller"]
        end

        subgraph NS_Detectors["Namespace: detector deployment namespace"]
            direction TB

            BuiltIn["Built-in Detector<br/>rhoai/odh-built-in-detector-rhel9<br/>8080/TCP ClusterIP<br/>Istio sidecar: true<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics, /registry"]

            HFDet["HuggingFace Detector<br/>rhoai/odh-guardrails-detector-<br/>huggingface-runtime-rhel9<br/>8000/TCP ClusterIP<br/>Istio sidecar: true<br/>KServe ISVC (RawDeployment)<br/>Endpoints: /api/v1/text/contents,<br/>/health, /metrics"]

            JudgeDet["LLM Judge Detector<br/>quay.io/trustyai/guardrails-<br/>detector-llm-judge:latest<br/>8000/TCP ClusterIP<br/>Istio sidecar: true<br/>KServe ISVC (RawDeployment)<br/>Endpoints: /api/v1/text/contents,<br/>/api/v1/text/generation,<br/>/api/v1/metrics, /health, /metrics"]
        end

        subgraph InCluster["In-Cluster Services"]
            S3["S3/MinIO Model Storage<br/>9000/TCP ClusterIP<br/>HTTP (plaintext)<br/>AWS IAM credentials"]

            vLLM["vLLM Inference Server<br/>8080/TCP<br/>HTTP (plaintext)<br/>OpenAI-compatible API"]
        end

        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    subgraph Platform["PLATFORM INFRASTRUCTURE"]
        KServe["KServe<br/>InferenceService host<br/>RawDeployment mode<br/>Auth: security.opendatahub.io/<br/>enable-auth: true"]
        Istio["Istio Service Mesh<br/>PeerAuth: STRICT<br/>TLS: ISTIO_MUTUAL"]
    end

    %% Flows with security details
    Orch -->|"HTTP/8080<br/>mTLS STRICT<br/>KServe platform auth"| BuiltIn
    Orch -->|"HTTP/8000<br/>mTLS STRICT<br/>KServe platform auth"| HFDet
    Orch -->|"HTTP/8000<br/>mTLS STRICT<br/>KServe platform auth"| JudgeDet

    HFDet -->|"HTTP/9000<br/>No encryption<br/>AWS credentials (Secret)"| S3
    HFDet -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF token (optional)"| HFHub

    JudgeDet -->|"HTTP/8080<br/>No encryption<br/>No auth (in-cluster)"| vLLM

    Prometheus -->|"HTTP/8080,8000<br/>No auth<br/>scrape /metrics"| BuiltIn
    Prometheus -->|"HTTP/8080,8000<br/>No auth<br/>scrape /metrics"| HFDet
    Prometheus -->|"HTTP/8080,8000<br/>No auth<br/>scrape /metrics"| JudgeDet

    KServe -.->|manages| BuiltIn
    KServe -.->|manages| HFDet
    KServe -.->|manages| JudgeDet
    Istio -.->|sidecar injection| BuiltIn
    Istio -.->|sidecar injection| HFDet
    Istio -.->|sidecar injection| JudgeDet

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef incluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef caller fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class HFHub external
    class BuiltIn,HFDet,JudgeDet servicemesh
    class S3,vLLM incluster
    class KServe,Istio platform
    class Orch caller
    class Prometheus servicemesh
