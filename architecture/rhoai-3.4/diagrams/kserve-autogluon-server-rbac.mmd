graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["The autogluon server runs as a model serving<br/>container, NOT an operator. It has no direct<br/>Kubernetes API interaction. RBAC is managed<br/>by the KServe controller and platform operator."]
    end

    subgraph PodSecurity["Pod Security Context"]
        direction TB
        Container["autogluonserver Container<br/>User: 1001 (non-root)<br/>Image: UBI9-based"]
    end

    subgraph AuthEnforcement["Authentication & Authorization"]
        direction TB

        subgraph InferenceEndpoints["Inference Endpoints"]
            RBAC_Proxy["kube-rbac-proxy Sidecar<br/>Port: 8443/TCP (TLS)"]
            SAR["SubjectAccessReview<br/>Validates Bearer Token"]
            Endpoints["Protected Endpoints:<br/>/v1/models/*<br/>/v2/models/*"]
        end

        subgraph MetricsEndpoint["Metrics Endpoint"]
            MetricsAuth["No Authentication<br/>(internal scraping only)"]
            MetricsPolicy["Access Control:<br/>NetworkPolicy"]
            MetricsEP["/metrics (8080/TCP)"]
        end
    end

    subgraph ManagedByKServe["RBAC Managed by KServe Controller"]
        direction TB
        KServeCtrl["KServe Controller<br/>kserve-controller-manager SA"]
        KServeRole["ClusterRole:<br/>kserve-manager-role"]
        KServeBinding["ClusterRoleBinding:<br/>kserve-manager-rolebinding"]
        ISResource["serving.kserve.io<br/>InferenceService"]
        CSRTResource["serving.kserve.io<br/>ClusterServingRuntime"]
        PodResource["core<br/>Pods, Services"]
    end

    subgraph Secrets["Secrets Access"]
        direction TB
        StorageCreds["(storage credentials)<br/>Type: Opaque<br/>S3/GCS/Azure creds"]
        ProvisionedBy["Provisioned by:<br/>User / Platform Admin<br/>Auto-Rotate: No"]
    end

    %% Auth flow
    RBAC_Proxy -->|validates via| SAR
    SAR -->|authorizes access to| Endpoints
    Endpoints -->|forwards to| Container

    MetricsAuth -->|controlled by| MetricsPolicy
    MetricsPolicy -->|allows access to| MetricsEP

    %% KServe RBAC
    KServeCtrl -->|bound via| KServeBinding
    KServeBinding -->|grants| KServeRole
    KServeRole -->|"get,list,watch,create,<br/>update,patch,delete"| ISResource
    KServeRole -->|"get,list,watch"| CSRTResource
    KServeRole -->|"get,list,watch,create,<br/>update,patch,delete"| PodResource

    %% Secrets
    StorageCreds -->|mounted into| Container
    StorageCreds --- ProvisionedBy

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style RBAC_Proxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style SAR fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Endpoints fill:#d5e8d4,stroke:#82b366
    style MetricsAuth fill:#e1d5e7,stroke:#9673a6
    style MetricsPolicy fill:#e1d5e7,stroke:#9673a6
    style MetricsEP fill:#e1d5e7,stroke:#9673a6
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333
    style KServeBinding fill:#f5a623,stroke:#333
    style ISResource fill:#7ed321,stroke:#333
    style CSRTResource fill:#7ed321,stroke:#333
    style PodResource fill:#7ed321,stroke:#333
    style StorageCreds fill:#fff2cc,stroke:#d6b656
    style ProvisionedBy fill:#fff2cc,stroke:#d6b656
