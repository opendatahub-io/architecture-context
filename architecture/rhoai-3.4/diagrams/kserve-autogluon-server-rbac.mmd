graph TD
    subgraph "AutoGluon Server RBAC"
        direction TB
        Note["No RBAC roles or role bindings<br/>defined by this component"]
    end

    subgraph "RBAC Managed By KServe Controller"
        SA["ServiceAccount<br/>(per InferenceService)"]
        KServeSA["kserve-controller-manager<br/>ServiceAccount"]
    end

    subgraph "KServe Controller Permissions (External)"
        CRB["ClusterRoleBinding<br/>kserve-manager-rolebinding"]
        CR["ClusterRole<br/>kserve-manager-role"]
    end

    subgraph "API Resources Relevant to AutoGluon Server"
        CSR["serving.kserve.io<br/>ClusterServingRuntime<br/>(kserve-autogluonserver)"]
        ISVC["serving.kserve.io<br/>InferenceService"]
        Pods["core<br/>Pods"]
        Services["core<br/>Services"]
    end

    subgraph "Auth at Ingress Layer"
        IngressAuth["KServe Ingress Auth<br/>kube-rbac-proxy / oauth-proxy"]
        BearerToken["Bearer Token<br/>(from client)"]
    end

    KServeSA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CSR
    CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ISVC
    CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Pods
    CR -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Services

    SA -->|"assigned to"| Pods
    BearerToken -->|"validated by"| IngressAuth
    IngressAuth -->|"forwards to"| Pods

    Note -.->|"All RBAC delegated to<br/>KServe Controller"| KServeSA

    style Note fill:#fff3cd,stroke:#856404,color:#856404,stroke-width:2px
    style SA fill:#4a90e2,color:#fff
    style KServeSA fill:#4a90e2,color:#fff
    style CR fill:#f5a623,color:#fff
    style CRB fill:#f5a623,color:#fff
    style CSR fill:#7ed321,color:#fff
    style ISVC fill:#7ed321,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Services fill:#7ed321,color:#fff
    style IngressAuth fill:#e8e8e8
    style BearerToken fill:#e8e8e8
