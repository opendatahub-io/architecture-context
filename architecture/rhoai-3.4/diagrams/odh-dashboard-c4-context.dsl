/*
 * ODH Dashboard - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4/odh-dashboard.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and manages AI/ML workloads via the dashboard"
        mlEngineer = person "ML Engineer" "Deploys models and manages inference services"
        admin = person "Platform Admin" "Configures platform settings and user access"

        odhDashboard = softwareSystem "ODH Dashboard" "Web-based management console for Red Hat OpenShift AI" {
            kubeRbacProxy = container "kube-rbac-proxy" "Authentication enforcement sidecar via SubjectAccessReview" "Go Sidecar" "Auth"
            dashboardBackend = container "rhods-dashboard Backend" "Serves React frontend and proxies Kubernetes API requests" "Node.js 22 / Fastify"
            dashboardFrontend = container "React Frontend" "PatternFly 6 UI for managing AI/ML workloads" "React 18 / TypeScript"
            modelRegistryUI = container "model-registry-ui" "Model Registry micro-frontend module" "Module Federation Remote" "Sidecar"
            genAiUI = container "gen-ai-ui" "Generative AI micro-frontend module" "Module Federation Remote" "Sidecar"
            maasUI = container "maas-ui" "Model-as-a-Service micro-frontend module" "Module Federation Remote" "Sidecar"
            mlflowUI = container "mlflow-ui" "MLflow micro-frontend module" "Module Federation Remote" "Sidecar"
            evalHubUI = container "eval-hub-ui" "Evaluation Hub micro-frontend module" "Module Federation Remote" "Sidecar"
            automlUI = container "automl-ui" "AutoML micro-frontend module" "Module Federation Remote" "Sidecar"
            autoragUI = container "autorag-ui" "AutoRAG micro-frontend module" "Module Federation Remote" "Sidecar"
        }

        # Internal ODH Components
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and configures dashboard via kustomize overlays" "Internal ODH"
        kserve = softwareSystem "KServe" "Serverless ML inference platform" "Internal ODH"
        kubeflowNotebooks = softwareSystem "Kubeflow Notebooks" "Notebook lifecycle management" "Internal ODH"
        modelRegistryOperator = softwareSystem "Model Registry Operator" "Model registry instance management" "Internal ODH"
        dataScienceCluster = softwareSystem "DataScienceCluster" "Platform component status" "Internal ODH"
        trustyai = softwareSystem "TrustyAI" "Guardrails orchestrator management" "Internal ODH"
        feast = softwareSystem "Feast" "Feature store management" "Internal ODH"
        llamaStack = softwareSystem "LlamaStack" "LlamaStack distribution management" "Internal ODH"
        nvidianIM = softwareSystem "NVIDIA NIM" "NIM account management" "Internal ODH"
        perses = softwareSystem "Perses" "Observability dashboard metrics" "Internal ODH"
        mlflow = softwareSystem "MLflow" "ML experiment tracking" "Internal ODH"

        # External Dependencies
        k8sApiServer = softwareSystem "Kubernetes API Server" "Cluster API for all resource operations" "External"
        dataScienceGateway = softwareSystem "data-science-gateway" "Gateway API ingress (Envoy)" "External"
        openshiftConsole = softwareSystem "OpenShift Console" "ConsoleLink integration" "External"

        # Relationships - Users
        dataScientist -> odhDashboard "Manages notebooks, models, pipelines via" "HTTPS/443"
        mlEngineer -> odhDashboard "Deploys and monitors inference services via" "HTTPS/443"
        admin -> odhDashboard "Configures platform settings via" "HTTPS/443"

        # Relationships - External
        dataScienceGateway -> odhDashboard "Routes external traffic to" "HTTPS/8443"
        rhodsOperator -> odhDashboard "Deploys and configures" "Kustomize"
        odhDashboard -> k8sApiServer "All resource CRUD operations" "HTTPS/443"
        odhDashboard -> openshiftConsole "Creates ConsoleLink entry" "CR"

        # Relationships - Internal ODH
        odhDashboard -> kserve "Manages InferenceServices and ServingRuntimes" "HTTPS/443 (k8s API)"
        odhDashboard -> kubeflowNotebooks "Manages Notebook CRs" "HTTPS/443 (k8s API)"
        odhDashboard -> modelRegistryOperator "Manages ModelRegistry CRs" "HTTPS/443 (k8s API)"
        odhDashboard -> dataScienceCluster "Monitors platform status" "HTTPS/443 (k8s API)"
        odhDashboard -> trustyai "Manages GuardrailsOrchestrators" "HTTPS/443 (k8s API)"
        odhDashboard -> feast "Manages FeatureStores" "HTTPS/443 (k8s API)"
        odhDashboard -> llamaStack "Manages LlamaStackDistributions" "HTTPS/443 (k8s API)"
        odhDashboard -> nvidianIM "Manages NIM Accounts" "HTTPS/443 (k8s API)"
        odhDashboard -> perses "Proxies metrics dashboards" "HTTP/8080"
        odhDashboard -> mlflow "Proxies MLflow UI" "HTTPS/8443"

        # Container-level relationships
        kubeRbacProxy -> k8sApiServer "SubjectAccessReview" "HTTPS/443"
        kubeRbacProxy -> dashboardBackend "Authenticated requests" "HTTP/8080 localhost"
        dashboardBackend -> dashboardFrontend "Serves" "HTTP"
        dashboardBackend -> modelRegistryUI "Module federation proxy" "HTTPS/8043"
        dashboardBackend -> genAiUI "Module federation proxy" "HTTPS/8143"
        dashboardBackend -> maasUI "Module federation proxy" "HTTPS/8243"
        dashboardBackend -> mlflowUI "Module federation proxy" "HTTPS/8343"
        dashboardBackend -> evalHubUI "Module federation proxy" "HTTPS/8543"
        dashboardBackend -> automlUI "Module federation proxy" "HTTPS/8643"
        dashboardBackend -> autoragUI "Module federation proxy" "HTTPS/8743"
        dashboardBackend -> k8sApiServer "Resource operations" "HTTPS/443"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Auth" {
                background #e74c3c
                color #ffffff
            }
            element "Sidecar" {
                background #9b59b6
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
