/*
 * C4 Context Diagram for kube-auth-proxy
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4/kube-auth-proxy.md
 */

workspace {
    model {
        user = person "User / Data Scientist" "Accesses RHOAI applications through browser or API client"
        serviceAccount = person "Service Account" "Kubernetes service account making API calls"

        kubeAuthProxy = softwareSystem "kube-auth-proxy" "FIPS-compliant authentication and RBAC authorization proxy for RHOAI" {
            entrypoint = container "entrypoint" "Binary multiplexer selecting proxy mode via PROXY_MODE env" "Go Binary"
            authProxy = container "kube-auth-proxy" "OAuth2/OIDC authentication proxy supporting OpenShift OAuth and OIDC providers" "Go Reverse Proxy" {
                tags "AuthProxy"
            }
            rbacProxy = container "kube-rbac-proxy" "Kubernetes RBAC authorization proxy using SubjectAccessReview API" "Go Reverse Proxy" {
                tags "RBACProxy"
            }
            sessionStore = container "Session Store" "Cookie-based or Redis-backed session storage" "Cookie/Redis"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Provides TokenReview and SubjectAccessReview APIs" {
            tags "External"
        }
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "OpenShift internal OAuth/OIDC provider" {
            tags "External"
        }
        oidcProvider = softwareSystem "OIDC Identity Provider" "External OIDC authentication provider" {
            tags "External"
        }
        redis = softwareSystem "Redis" "Optional session storage backend" {
            tags "External Optional"
        }
        upstreamApp = softwareSystem "Upstream Application" "Backend application receiving authenticated requests" {
            tags "Internal RHOAI"
        }
        envoyGateway = softwareSystem "Envoy / Gateway API" "Ingress gateway using ext_authz for auth decisions" {
            tags "Internal RHOAI"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "Internal RHOAI"
        }
        rhodsOperator = softwareSystem "RHODS Operator" "Creates HTTPRoute/Route resources pointing to proxy-fronted services" {
            tags "Internal RHOAI"
        }

        # User interactions
        user -> kubeAuthProxy "Authenticates via OAuth2/OIDC" "HTTPS/4180"
        user -> kubeAuthProxy "Authorizes via RBAC" "HTTPS/8443"
        serviceAccount -> kubeAuthProxy "Authenticates via SA Token" "HTTP/4180"

        # Internal container flows
        entrypoint -> authProxy "Launches in auth mode" "PROXY_MODE=auth"
        entrypoint -> rbacProxy "Launches in rbac mode" "PROXY_MODE=rbac (default)"
        authProxy -> sessionStore "Stores/retrieves sessions"

        # Egress
        authProxy -> openshiftOAuth "OAuth2 authorization code flow" "HTTPS/443 TLS 1.2+"
        authProxy -> oidcProvider "OIDC discovery, token exchange, JWKS" "HTTPS/443 TLS 1.2+"
        authProxy -> k8sAPI "TokenReview (SA token validation)" "HTTPS/443 TLS 1.2+"
        rbacProxy -> k8sAPI "TokenReview + SubjectAccessReview" "HTTPS/443 TLS 1.2+"
        sessionStore -> redis "Session storage (optional)" "TCP/6379"

        # Upstream
        authProxy -> upstreamApp "Forwards authenticated requests" "HTTP configurable"
        rbacProxy -> upstreamApp "Forwards authorized requests" "HTTP/H2C configurable"

        # Ingress integrations
        envoyGateway -> authProxy "ext_authz decision requests" "HTTP/4180"
        prometheus -> authProxy "Scrapes metrics" "HTTP/4180"
        rhodsOperator -> kubeAuthProxy "Deploys as sidecar" "Kubernetes API"
    }

    views {
        systemContext kubeAuthProxy "SystemContext" {
            include *
            autoLayout
            description "System context showing kube-auth-proxy in the RHOAI ecosystem"
        }

        container kubeAuthProxy "Containers" {
            include *
            autoLayout
            description "Container view showing auth-proxy and rbac-proxy modes"
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #BBBBBB
                color #ffffff
                shape RoundedBox
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "AuthProxy" {
                background #4a90e2
            }
            element "RBACProxy" {
                background #2d6cb4
            }
        }
    }
}
