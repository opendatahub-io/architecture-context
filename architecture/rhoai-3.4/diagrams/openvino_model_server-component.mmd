graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph ServerLayer["Server Layer"]
            DrogonHTTP["Drogon HTTP Server<br/>REST port/TCP"]
            GRPCServer["gRPC Server<br/>gRPC port/TCP"]
            MetricsExporter["Prometheus Metrics<br/>/metrics endpoint"]
        end

        subgraph APIFrontends["API Frontends"]
            TFSFrontend["TFS v1 Frontend<br/>/v1/models/*"]
            KFSFrontend["KServe v2 Frontend<br/>/v2/models/*"]
            OpenAIFrontend["OpenAI v1 Frontend<br/>/v1/chat/completions<br/>/v1/completions<br/>/v1/embeddings"]
            V3Frontend["v3 Frontend<br/>/v3/images/generations"]
            CohereRank["Cohere Rerank<br/>/v1/rerankings"]
        end

        subgraph InferenceEngine["Inference Engine"]
            ModelManager["Model Manager"]
            DAGScheduler["DAG Scheduler"]
            MediaPipe["MediaPipe Graph<br/>Executor"]
        end

        subgraph Calculators["MediaPipe Calculators"]
            HttpLLMCalc["HttpLLMCalculator<br/>LLM Serving"]
            EmbeddingsCalc["EmbeddingsCalculator<br/>Text Embeddings"]
            RerankCalc["RerankCalculator<br/>Document Reranking"]
            ImageGenCalc["ImageGenCalculator<br/>Text-to-Image"]
            AudioCalc["Audio Calculators<br/>STT / TTS"]
            PythonExec["Python Executor<br/>pybind11"]
        end

        subgraph Runtime["OpenVINO Runtime Stack"]
            OVRuntime["OpenVINO Runtime 2026.0<br/>CPU/GPU/NPU"]
            OVGenAI["OpenVINO GenAI<br/>Continuous Batching"]
            OVTokenizers["OpenVINO Tokenizers<br/>NLP Tokenization"]
        end

        subgraph Storage["Model Storage Layer"]
            FilesystemFactory["FilesystemFactory"]
            LocalFS["Local Filesystem"]
            S3FS["S3 Filesystem"]
            AzureFS["Azure Blob Filesystem"]
            GCSFS["GCS Filesystem"]
            HFFS["HuggingFace Pull<br/>libgit2"]
        end
    end

    %% External clients
    RESTClient["REST Client"]
    GRPCClient["gRPC Client"]

    %% External services
    S3["AWS S3<br/>443/TCP HTTPS"]
    Azure["Azure Blob Storage<br/>443/TCP HTTPS"]
    GCS["Google Cloud Storage<br/>443/TCP HTTPS"]
    HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    KServe["KServe InferenceService"]
    Prometheus["Prometheus"]
    IstioSidecar["Istio Sidecar<br/>mTLS Proxy"]

    %% Client flows
    RESTClient -->|HTTP| IstioSidecar
    GRPCClient -->|gRPC/HTTP2| IstioSidecar
    IstioSidecar -->|plaintext| DrogonHTTP
    IstioSidecar -->|plaintext| GRPCServer

    %% Server to frontends
    DrogonHTTP --> TFSFrontend
    DrogonHTTP --> KFSFrontend
    DrogonHTTP --> OpenAIFrontend
    DrogonHTTP --> V3Frontend
    DrogonHTTP --> CohereRank
    GRPCServer --> TFSFrontend
    GRPCServer --> KFSFrontend

    %% Frontends to engine
    TFSFrontend --> ModelManager
    KFSFrontend --> ModelManager
    OpenAIFrontend --> MediaPipe
    V3Frontend --> MediaPipe
    CohereRank --> MediaPipe

    %% Engine flows
    ModelManager --> DAGScheduler
    ModelManager --> OVRuntime
    MediaPipe --> HttpLLMCalc
    MediaPipe --> EmbeddingsCalc
    MediaPipe --> RerankCalc
    MediaPipe --> ImageGenCalc
    MediaPipe --> AudioCalc
    MediaPipe --> PythonExec

    %% Calculators to runtime
    HttpLLMCalc --> OVGenAI
    EmbeddingsCalc --> OVRuntime
    RerankCalc --> OVRuntime
    ImageGenCalc --> OVGenAI
    OVGenAI --> OVRuntime
    OVGenAI --> OVTokenizers

    %% Model storage
    ModelManager --> FilesystemFactory
    FilesystemFactory --> LocalFS
    FilesystemFactory --> S3FS
    FilesystemFactory --> AzureFS
    FilesystemFactory --> GCSFS
    FilesystemFactory --> HFFS

    %% Egress
    S3FS -->|HTTPS/443| S3
    AzureFS -->|HTTPS/443| Azure
    GCSFS -->|HTTPS/443| GCS
    HFFS -->|HTTPS/443| HFHub

    %% Integration
    KServe -->|KServe v2 protocol| GRPCServer
    KServe -->|KServe v2 protocol| DrogonHTTP
    Prometheus -->|scrape /metrics| MetricsExporter

    %% Styling
    style OVMS fill:#e8f4fd,stroke:#2196F3,stroke-width:2px
    style ServerLayer fill:#bbdefb,stroke:#1976D2
    style APIFrontends fill:#c8e6c9,stroke:#388E3C
    style InferenceEngine fill:#fff9c4,stroke:#F9A825
    style Calculators fill:#ffe0b2,stroke:#E65100
    style Runtime fill:#f3e5f5,stroke:#7B1FA2
    style Storage fill:#fce4ec,stroke:#C62828

    style DrogonHTTP fill:#4a90e2,color:#fff
    style GRPCServer fill:#4a90e2,color:#fff
    style OVRuntime fill:#7B1FA2,color:#fff
    style OVGenAI fill:#9C27B0,color:#fff
    style MediaPipe fill:#FF9800,color:#fff

    style S3 fill:#f5a623,stroke:#333
    style Azure fill:#f5a623,stroke:#333
    style GCS fill:#f5a623,stroke:#333
    style HFHub fill:#f5a623,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Prometheus fill:#7ed321,stroke:#333
    style IstioSidecar fill:#999,stroke:#333,color:#fff
    style RESTClient fill:#f9f9f9,stroke:#999
    style GRPCClient fill:#f9f9f9,stroke:#999
