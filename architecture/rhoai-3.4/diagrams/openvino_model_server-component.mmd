graph TB
    subgraph OVMS["OpenVINO Model Server (OVMS)"]
        direction TB

        subgraph Core["Core Server"]
            Main["ovms (main binary)<br/>C++ Service"]
            GRPCServer["gRPC Server Module<br/>InsecureServerCredentials"]
            HTTPServer["HTTP Server Module<br/>Drogon Framework"]
            ModelMgr["Model Manager<br/>Lifecycle, Hot-Reload, Versioning"]
        end

        subgraph APIs["API Handlers"]
            TFSv1["TFS v1 Handler<br/>/v1/models/..."]
            KServev2["KServe v2 Handler<br/>/v2/models/.../infer"]
            OpenAIv3["OpenAI v3 Handler<br/>/v3/chat/completions"]
            MetricsEP["Metrics<br/>/metrics"]
        end

        subgraph Engines["Inference Engines"]
            LLMPipeline["LLM Pipeline<br/>Continuous Batching<br/>LLMExecutor Worker Thread"]
            VLMPipeline["VLM Pipeline<br/>Vision-Language Model"]
            EmbeddingsEng["Embeddings Engine<br/>Pooling Modes"]
            RerankEng["Reranking Engine<br/>Document Scoring"]
            ImageGenEng["Image Generation<br/>Diffusion Pipeline"]
            AudioEng["Audio Engine<br/>Whisper STT / TTS"]
            MediaPipe["MediaPipe Graph Executor<br/>Custom DAG Pipelines"]
        end

        subgraph Support["Support Modules"]
            HFPull["HuggingFace Pull Module<br/>Git LFS Download"]
            MetricsMod["Metrics Module<br/>Prometheus Client"]
            CAPI["C API (libovms_shared.so)<br/>Embedded Usage"]
        end

        Main -->|initializes| GRPCServer
        Main -->|initializes| HTTPServer
        Main -->|initializes| ModelMgr

        GRPCServer -->|routes| TFSv1
        GRPCServer -->|routes| KServev2
        HTTPServer -->|routes| TFSv1
        HTTPServer -->|routes| KServev2
        HTTPServer -->|routes| OpenAIv3
        HTTPServer -->|routes| MetricsEP

        OpenAIv3 -->|dispatches| LLMPipeline
        OpenAIv3 -->|dispatches| VLMPipeline
        OpenAIv3 -->|dispatches| EmbeddingsEng
        OpenAIv3 -->|dispatches| RerankEng
        OpenAIv3 -->|dispatches| ImageGenEng
        OpenAIv3 -->|dispatches| AudioEng

        TFSv1 -->|infers via| ModelMgr
        KServev2 -->|infers via| ModelMgr

        ModelMgr -->|loads models| HFPull
        MetricsEP -->|collects| MetricsMod
    end

    %% External runtime
    OpenVINO["OpenVINO Runtime 2026.0<br/>CPU / GPU / NPU"]
    GenAI["OpenVINO GenAI SDK<br/>Tokenizer + Generation"]

    ModelMgr -->|executes inference| OpenVINO
    LLMPipeline -->|pipeline.step()| GenAI
    VLMPipeline -->|pipeline.step()| GenAI
    GenAI -->|delegates| OpenVINO

    %% Platform integration
    KServe["KServe<br/>InferenceService Pod"]
    KubeRBAC["kube-rbac-proxy<br/>Sidecar (8443/TCP)"]
    Client["External Client"]

    Client -->|HTTPS/8443| KubeRBAC
    KubeRBAC -->|HTTP (localhost)| HTTPServer
    KServe -->|manages pod| OVMS

    %% Storage backends
    subgraph Storage["Cloud Storage Backends"]
        S3["Amazon S3"]
        GCS["Google Cloud Storage"]
        Azure["Azure Blob Storage"]
        HFHub["HuggingFace Hub"]
    end

    ModelMgr -->|s3://| S3
    ModelMgr -->|gs://| GCS
    ModelMgr -->|azureblob://| Azure
    HFPull -->|git clone + LFS| HFHub

    %% Styling
    style OVMS fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Core fill:#bbdefb,stroke:#1565c0
    style APIs fill:#c8e6c9,stroke:#2e7d32
    style Engines fill:#fff3e0,stroke:#e65100
    style Support fill:#f3e5f5,stroke:#6a1b9a
    style Storage fill:#fff9c4,stroke:#f57f17
    style Main fill:#1565c0,color:#fff
    style OpenVINO fill:#0d47a1,color:#fff
    style GenAI fill:#0d47a1,color:#fff
    style KubeRBAC fill:#ff8f00,color:#fff
    style KServe fill:#2e7d32,color:#fff
    style Client fill:#f5f5f5,stroke:#333
