graph TB
    subgraph "llm-d Stack"
        direction TB

        subgraph Images["Container Images"]
            CUDA["llm-d-cuda<br/>NVIDIA CUDA GPU<br/>vLLM + NIXL + UCX + NVSHMEM<br/>DeepEP, DeepGEMM, FlashInfer"]
            CPU["llm-d-cpu<br/>CPU-only inference<br/>vLLM + NIXL + UCX"]
            HPU["llm-d-hpu<br/>Intel Gaudi HPU<br/>vLLM + vllm-gaudi"]
            ROCm["llm-d-rocm<br/>AMD ROCm GPU<br/>vLLM + RIXL + UCX"]
            RDMATools["llm-d-rdma-tools<br/>Diagnostics Only<br/>iperf3, perftest, NCCL"]
        end

        subgraph Recipes["Deployment Recipes (Kustomize/Helm)"]
            OptBaseline["Optimized Baseline<br/>Qwen3-32B, 8 replicas"]
            PDDisagg["P/D Disaggregation<br/>Prefill + Decode split"]
            WideEP["Wide Expert-Parallelism<br/>DeepSeek-R1, LWS"]
            PrefixCache["Prefix Cache-Aware<br/>Tiered KV offload"]
            FlowCtrl["Flow Control<br/>Multi-tenant fairness"]
        end
    end

    subgraph "Runtime Components (External)"
        EPP["llm-d Inference Scheduler<br/>(EPP v0.8.0)<br/>Port 8081/TCP"]
        Sidecar["llm-d Routing Sidecar<br/>(v0.7.1)<br/>Port 8000/TCP"]
        WVA["Workload Variant<br/>Autoscaler (WVA)<br/>Port 8443/TCP"]
    end

    Client[Client] -->|HTTP 80/TCP| Gateway["Gateway API<br/>(Istio / AgentGateway)<br/>Port 80/TCP"]
    Gateway -->|ExtProc| EPP
    EPP -->|HTTP 8000/TCP| Sidecar
    Sidecar -->|HTTP 8200/TCP| CUDA
    CUDA -->|RDMA/TCP 5600| CUDA

    OptBaseline -.->|deploys| CUDA
    PDDisagg -.->|deploys| CUDA
    PDDisagg -.->|configures| Sidecar
    WideEP -.->|deploys| CUDA
    PrefixCache -.->|deploys| CUDA

    CUDA -->|metrics 8000/TCP| Prometheus["Prometheus<br/>PodMonitor"]
    EPP -->|metrics 9090/TCP| Prometheus
    WVA -->|scales| CUDA

    CUDA -->|HTTPS 443/TCP| HFHub["HuggingFace Hub<br/>Model Downloads"]
    CUDA -->|gRPC 4317/TCP| OTel["OpenTelemetry<br/>Collector"]

    style CUDA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CPU fill:#4a90e2,stroke:#333,color:#fff
    style HPU fill:#4a90e2,stroke:#333,color:#fff
    style ROCm fill:#4a90e2,stroke:#333,color:#fff
    style RDMATools fill:#999,stroke:#333,color:#fff
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style Sidecar fill:#7ed321,stroke:#333,color:#fff
    style WVA fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#f5a623,stroke:#333,color:#fff
    style OptBaseline fill:#e8d4f0,stroke:#333
    style PDDisagg fill:#e8d4f0,stroke:#333
    style WideEP fill:#e8d4f0,stroke:#333
    style PrefixCache fill:#e8d4f0,stroke:#333
    style FlowCtrl fill:#e8d4f0,stroke:#333
    style HFHub fill:#f9f9f9,stroke:#999
    style Prometheus fill:#f9f9f9,stroke:#999
    style OTel fill:#f9f9f9,stroke:#999
    style Client fill:#fff,stroke:#333
