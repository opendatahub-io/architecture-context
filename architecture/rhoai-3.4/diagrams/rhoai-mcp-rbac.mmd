graph TD
    subgraph ServiceAccount["Service Account"]
        SA["rhoai-mcp<br/>Namespace: rhoai-mcp"]
    end

    subgraph Binding["ClusterRole Binding"]
        CRB["rhoai-mcp<br/>(cluster-wide)"]
    end

    subgraph ClusterRole["ClusterRole: rhoai-mcp"]
        CR["rhoai-mcp"]
    end

    SA -->|bound via| CRB
    CRB -->|grants| CR

    subgraph ReadOnly["Read-Only Resources (get, list, watch)"]
        direction TB
        CoreRead["Core API Group<br/>namespaces, pods, pods/log,<br/>services, configmaps, secrets,<br/>persistentvolumeclaims, events"]
        ODHRead["opendatahub.io<br/>datascienceclusters,<br/>datasciencepipelinesapplications"]
        RouteRead["route.openshift.io<br/>routes"]
        ProjectRead["project.openshift.io<br/>projects"]
    end

    subgraph FullCRUD["Full CRUD Resources (get, list, watch, create, update, patch, delete)"]
        direction TB
        Kubeflow["kubeflow.org<br/>notebooks, profiles"]
        Tekton["tekton.dev<br/>pipelineruns, taskruns,<br/>pipelines, tasks"]
        KServe["serving.kserve.io<br/>inferenceservices,<br/>servingruntimes"]
        OpenVINO["serving.openvino.ai<br/>ovms"]
        OBC["objectbucket.io<br/>objectbucketclaims"]
    end

    CR -->|"get, list, watch"| CoreRead
    CR -->|"get, list, watch"| ODHRead
    CR -->|"get, list, watch"| RouteRead
    CR -->|"get, list, watch"| ProjectRead

    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Kubeflow
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| Tekton
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| KServe
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| OpenVINO
    CR -->|"get, list, watch,<br/>create, update, patch, delete"| OBC

    subgraph SafetyControls["Application-Level Safety Controls"]
        direction TB
        ReadOnlyMode["RHOAI_MCP_READ_ONLY_MODE<br/>Disables ALL write ops<br/>(default: false)"]
        DangerousOps["RHOAI_MCP_ENABLE_DANGEROUS_OPERATIONS<br/>Gates delete ops<br/>(default: false)"]
        ToolChecks["Per-Tool Permission Checks<br/>Each tool validates permissions<br/>before executing"]
    end

    CR -.->|"gated by"| SafetyControls

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#ff9800,color:#fff
    style CR fill:#f5a623,color:#fff

    style CoreRead fill:#c8e6c9,stroke:#2e7d32
    style ODHRead fill:#c8e6c9,stroke:#2e7d32
    style RouteRead fill:#c8e6c9,stroke:#2e7d32
    style ProjectRead fill:#c8e6c9,stroke:#2e7d32

    style Kubeflow fill:#ffcdd2,stroke:#c62828
    style Tekton fill:#ffcdd2,stroke:#c62828
    style KServe fill:#ffcdd2,stroke:#c62828
    style OpenVINO fill:#ffcdd2,stroke:#c62828
    style OBC fill:#ffcdd2,stroke:#c62828

    style ReadOnlyMode fill:#fff3e0,stroke:#e65100
    style DangerousOps fill:#fff3e0,stroke:#e65100
    style ToolChecks fill:#fff3e0,stroke:#e65100

    style ReadOnly fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    style FullCRUD fill:#ffebee,stroke:#c62828,stroke-width:2px
    style SafetyControls fill:#fff8e1,stroke:#e65100,stroke-width:2px
