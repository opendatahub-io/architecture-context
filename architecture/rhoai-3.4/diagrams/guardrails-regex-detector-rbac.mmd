graph TD
    subgraph "Guardrails Regex Detector — RBAC"
        direction TB

        Note["This component defines NO RBAC resources.<br/><br/>No ClusterRoles, Roles, or RoleBindings.<br/>No ServiceAccount configured (uses default).<br/>No Kubernetes API access required.<br/><br/>The component is a stateless HTTP service<br/>that does not interact with the Kubernetes<br/>API server. All it does is receive HTTP<br/>requests, run regex matching, and return<br/>JSON responses.<br/><br/>Platform-level access control is handled<br/>externally via:<br/>- Kubernetes Network Policies<br/>- Service Mesh AuthorizationPolicy<br/>- kube-rbac-proxy sidecar (if deployed)"]
    end

    subgraph "Platform-Level Access Control (External)"
        NetworkPolicy["Network Policies<br/>Pod-to-pod isolation"]
        AuthzPolicy["AuthorizationPolicy<br/>(Service Mesh)"]
        KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"]
    end

    NetworkPolicy -.->|"restricts which pods<br/>can reach 8080/TCP"| Note
    AuthzPolicy -.->|"enforces service<br/>identity checks"| Note
    KubeRBACProxy -.->|"authenticates &<br/>authorizes callers"| Note

    style Note fill:#f9f9f9,stroke:#999,stroke-width:1px
    style NetworkPolicy fill:#e8e8e8,stroke:#999
    style AuthzPolicy fill:#e8e8e8,stroke:#999
    style KubeRBACProxy fill:#e8e8e8,stroke:#999
