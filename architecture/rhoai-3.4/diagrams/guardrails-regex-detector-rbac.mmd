graph TD
    subgraph "Guardrails Regex Detector — RBAC"
        direction TB

        Note["ℹ No RBAC Required"]

        subgraph "Service Characteristics"
            NoK8sAPI["No Kubernetes API interaction"]
            NoSA["No custom ServiceAccount<br/>(uses default)"]
            NoCR["No ClusterRoles"]
            NoRB["No RoleBindings"]
            NoSecrets["No Secrets consumed"]
        end

        subgraph "Security Model"
            NetworkIsolation["Network-Level Isolation<br/>━━━━━━━━━━━━━━━━━━<br/>• NetworkPolicy (expected)<br/>• Service Mesh mTLS (optional)<br/>• kube-rbac-proxy sidecar (optional)"]
            StatelessDesign["Stateless Design<br/>━━━━━━━━━━━━━━━━━━<br/>• No persistent storage<br/>• No outbound calls<br/>• No database access"]
        end

        Note --> NoK8sAPI
        Note --> NoSA
        Note --> NoCR
        Note --> NoRB
        Note --> NoSecrets
        NoK8sAPI --> NetworkIsolation
        NoSecrets --> StatelessDesign
    end

    subgraph "Security Concerns"
        Warning1["⚠ No TLS on port 8080"]
        Warning2["⚠ No authentication on endpoints"]
        Warning3["⚠ Container runs as root"]
    end

    NetworkIsolation -.->|"mitigates"| Warning1
    NetworkIsolation -.->|"mitigates"| Warning2

    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style NoK8sAPI fill:#d5e8d4,stroke:#82b366
    style NoSA fill:#d5e8d4,stroke:#82b366
    style NoCR fill:#d5e8d4,stroke:#82b366
    style NoRB fill:#d5e8d4,stroke:#82b366
    style NoSecrets fill:#d5e8d4,stroke:#82b366
    style NetworkIsolation fill:#dae8fc,stroke:#6c8ebf
    style StatelessDesign fill:#dae8fc,stroke:#6c8ebf
    style Warning1 fill:#f8cecc,stroke:#b85450
    style Warning2 fill:#f8cecc,stroke:#b85450
    style Warning3 fill:#f8cecc,stroke:#b85450
