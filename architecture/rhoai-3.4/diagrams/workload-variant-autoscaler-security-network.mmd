graph TB
    subgraph Cluster["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph WVA_NS["Namespace: workload-variant-autoscaler-system"]
            WVA["WVA Controller Manager<br/>SA: controller-manager<br/>Image: llm-d-workload-variant-autoscaler:v0.6.0<br/>FIPS: strictfipsruntime + OpenSSL"]

            subgraph Ports["Exposed Ports"]
                MetricsPort["8443/TCP HTTPS<br/>Prometheus Metrics<br/>TLS (cert-managed)<br/>Auth: Bearer Token<br/>(TokenReview + SAR)"]
                HealthPort["8081/TCP HTTP<br/>Health Probes<br/>No Encryption<br/>No Auth"]
            end

            MetricsService["Service: controller-manager-metrics-service<br/>ClusterIP 8443/TCP → 8443/TCP<br/>HTTPS + Bearer Token"]
        end

        subgraph Monitoring["Namespace: openshift-monitoring"]
            Prometheus["Prometheus / Thanos Querier<br/>9091/TCP HTTPS<br/>TLS 1.2+"]
        end

        subgraph UserNS["Namespace: {user-namespaces}"]
            vLLM["vLLM Inference Servers<br/>(metrics source via Prometheus)"]
            EPP["EPP Pods (Endpoint Picker)<br/>varies/TCP HTTPS<br/>TLS"]
            ScaleTargets["Scale Targets<br/>Deployments / StatefulSets / LWS"]
        end

        subgraph ControlPlane["Control Plane"]
            K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        end

        subgraph Consumers["Metrics Consumers"]
            HPA["HPA / KEDA<br/>(reads wva_desired_replicas)"]
            PromAdapter["Prometheus Adapter<br/>(custom metrics API bridge)"]
        end
    end

    %% WVA Egress flows
    WVA -->|"PromQL Queries<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (SA) +<br/>optional mTLS (client cert)"| Prometheus
    WVA -->|"Watch/Update CRs<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (SA)"| K8sAPI
    WVA -->|"Scrape Flow Metrics<br/>HTTPS<br/>TLS<br/>Auth: Bearer Token<br/>(epp-metrics-token)"| EPP

    %% Prometheus scrapes vLLM
    Prometheus -->|"Scrape vLLM metrics"| vLLM

    %% Prometheus scrapes WVA
    Prometheus -->|"Scrape /metrics<br/>8443/TCP HTTPS<br/>TLS<br/>Auth: Bearer Token<br/>via ServiceMonitor"| MetricsService

    %% HPA/KEDA reads from Prometheus
    HPA -->|"Query wva_desired_replicas<br/>via Prometheus"| Prometheus
    PromAdapter -->|"Bridge metrics<br/>to custom metrics API"| Prometheus

    %% HPA scales targets
    HPA -->|"Scale subresource<br/>443/TCP HTTPS"| ScaleTargets

    %% Styling
    classDef wvaNode fill:#4a90e2,stroke:#2c5f8a,color:#fff,stroke-width:2px
    classDef serviceNode fill:#5dade2,stroke:#2e86c1,color:#fff
    classDef portNode fill:#85c1e9,stroke:#2e86c1,color:#000
    classDef external fill:#e8e8e8,stroke:#999,stroke-width:2px
    classDef monitoring fill:#f39c12,stroke:#d68910,color:#fff
    classDef consumer fill:#7ed321,stroke:#5ba318,color:#fff
    classDef target fill:#e1d5e7,stroke:#9673a6,color:#000
    classDef epp fill:#e74c3c,stroke:#c0392b,color:#fff

    class WVA wvaNode
    class MetricsService serviceNode
    class MetricsPort,HealthPort portNode
    class K8sAPI external
    class Prometheus monitoring
    class vLLM monitoring
    class HPA,PromAdapter consumer
    class ScaleTargets target
    class EPP epp
