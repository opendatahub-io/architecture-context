graph TB
    subgraph External["EXTERNAL SERVICES"]
        direction TB
        Prometheus["Prometheus / Thanos Querier<br/>thanos-querier.openshift-monitoring.svc<br/>9091/TCP HTTPS<br/>TLS 1.2+"]
        EPP["EPP Pods<br/>(Gateway API Inference Extension)<br/>configurable/TCP HTTPS<br/>TLS"]
    end

    subgraph Cluster["CLUSTER INTERNAL"]
        direction TB

        subgraph WVANamespace["Namespace: workload-variant-autoscaler-system"]
            direction TB
            WVA["WVA Controller Manager<br/>SA: controller-manager<br/>Image: llm-d-workload-variant-autoscaler:v0.6.0<br/>FIPS: strictfipsruntime + UBI9"]

            subgraph Ports["Exposed Ports"]
                Metrics["8443/TCP HTTPS<br/>/metrics<br/>TLS (self-signed/cert-manager)<br/>Auth: Bearer Token<br/>(TokenReview + SubjectAccessReview)"]
                Health["8081/TCP HTTP<br/>/healthz, /readyz<br/>No encryption<br/>No auth"]
            end

            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP"]
            NetPol["NetworkPolicy:<br/>allow-metrics-traffic<br/>(restricts to Prometheus)"]
        end

        subgraph MonitoringNS["Namespace: openshift-monitoring"]
            PromScraper["Prometheus Scraper<br/>(cluster-monitoring)"]
        end

        subgraph UserNS["Namespace: {user-namespaces}"]
            Deployments["Deployments / StatefulSets<br/>(vLLM model servers)"]
            LWSNS["LeaderWorkerSets"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>SA token"]
    end

    %% Ingress flows
    PromScraper -->|"HTTPS/8443<br/>TLS<br/>Bearer Token<br/>(TokenReview + SAR)"| MetricsSvc
    MetricsSvc --> Metrics

    %% Egress flows
    WVA -->|"HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token (SA token)<br/>PromQL queries"| Prometheus
    WVA -->|"HTTPS/configurable<br/>TLS<br/>Bearer Token (epp-metrics-token)<br/>Queue metrics scraping"| EPP
    WVA -->|"HTTPS/443<br/>TLS<br/>SA token<br/>CRUD: VA, Deployments,<br/>ConfigMaps, LWS, Nodes"| K8sAPI

    %% Scale targets
    K8sAPI -.->|"scale subresource"| Deployments
    K8sAPI -.->|"scale subresource"| LWSNS

    %% Secrets
    subgraph Secrets["Secrets (mounted volumes)"]
        SAToken["SA token<br/>/var/run/secrets/kubernetes.io/<br/>serviceaccount/token"]
        EPPToken["epp-metrics-token<br/>/var/run/secrets/epp-metrics/token"]
        PromCert["prometheus-client-cert<br/>(optional mTLS)"]
    end

    Secrets -.->|"mounted in"| WVA

    %% Styling
    classDef wva fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    classDef service fill:#6baed6,stroke:#333,color:#fff
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#e8e8e8,stroke:#333
    classDef netpol fill:#ffcccc,stroke:#cc0000
    classDef secret fill:#f0e6ff,stroke:#9966cc
    classDef workload fill:#d5e8d4,stroke:#82b366

    class WVA wva
    class MetricsSvc,Metrics,Health service
    class Prometheus,EPP external
    class K8sAPI,PromScraper k8s
    class NetPol netpol
    class SAToken,EPPToken,PromCert secret
    class Deployments,LWSNS workload
