graph LR
    OGX["ogx-distribution<br/>(Llama Stack Server)<br/>8321/TCP"]

    %% Core Framework
    OGX -->|"core framework<br/>v0.7.1+rhaiv.1"| LlamaStack["llama-stack"]
    OGX -->|"client lib<br/>v0.7.2"| LlamaStackClient["llama-stack-client"]
    OGX -->|"HTTP framework"| FastAPI["FastAPI"]
    OGX -->|"ASGI server"| Uvicorn["uvicorn"]

    %% Internal RHOAI Dependencies
    OGX -->|"LLM inference<br/>HTTP/HTTPS"| vLLM["vLLM Serving Runtime"]
    OGX -->|"embedding inference<br/>HTTP/HTTPS"| vLLMEmbed["vLLM Embedding Runtime"]
    OGX -->|"safety guardrails<br/>HTTP/HTTPS"| TrustyAIFMS["TrustyAI FMS<br/>v0.4.0"]
    OGX -->|"model eval<br/>HTTP"| TrustyAILMEval["TrustyAI LM-Eval<br/>v0.5.0"]
    OGX -->|"RAG eval<br/>HTTP"| TrustyAIRAGAS["TrustyAI RAGAS<br/>v0.6.1"]
    OGX -->|"security eval<br/>HTTP"| TrustyAIGarak["TrustyAI Garak<br/>v0.3.1"]
    OGX -->|"pipeline jobs<br/>HTTP"| Kubeflow["Kubeflow Pipelines"]
    OGX -->|"state storage<br/>5432/TCP"| PostgreSQL["PostgreSQL 5.x+"]
    OGX -->|"file storage<br/>443/TCP HTTPS"| S3["S3 Storage<br/>(MinIO/ODF)"]
    OGX -->|"telemetry<br/>HTTP OTLP"| OTEL["OTEL Collector"]

    %% External Cloud Providers (conditional)
    OGX -.->|"cloud inference<br/>443/TCP"| Bedrock["AWS Bedrock"]
    OGX -.->|"cloud inference<br/>443/TCP"| VertexAI["Google Vertex AI"]
    OGX -.->|"cloud inference<br/>443/TCP"| OpenAI["OpenAI API"]
    OGX -.->|"cloud inference<br/>443/TCP"| WatsonX["IBM WatsonX"]
    OGX -.->|"cloud inference<br/>443/TCP"| AzureOAI["Azure OpenAI"]

    %% Vector Databases (conditional)
    OGX -.->|"vector search<br/>pymilvus 2.6.9"| Milvus["Milvus"]
    OGX -.->|"vector search<br/>5432/TCP"| PGVector["PGVector"]
    OGX -.->|"vector search<br/>6333/6334 TCP"| Qdrant["Qdrant"]
    OGX -.->|"vector search<br/>(in-process)"| FAISS["FAISS<br/>(faiss-cpu)"]

    %% Tools (conditional)
    OGX -.->|"web search<br/>443/TCP"| Brave["Brave Search"]
    OGX -.->|"web search<br/>443/TCP"| Tavily["Tavily Search"]

    %% Auth
    OGX -.->|"JWT validation<br/>443/TCP"| OAuth2["OAuth2 Provider<br/>(JWKS)"]

    %% Python Dependencies
    OGX -->|"AWS SDK<br/>v1.35.88"| Boto3["boto3"]
    OGX -.->|"Google SDK"| GoogleGenAI["google-genai"]
    OGX -.->|"Kubeflow SDK<br/>v2.14.6"| KFPKubernetes["kfp-kubernetes"]
    OGX -.->|"inline embeddings"| SentenceTransformers["sentence-transformers"]
    OGX -->|"pre-cached model"| GraniteEmbed["granite-embedding-<br/>125m-english"]
    OGX -->|"pre-cached tokenizer"| Tiktoken["tiktoken<br/>(cl100k_base)"]

    %% Platform Operator (manages this component)
    RHODSOperator["rhods-operator"] -->|"deploys &<br/>manages"| OGX

