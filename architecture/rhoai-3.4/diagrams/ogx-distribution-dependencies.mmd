graph LR
    LlamaStack["ogx-distribution<br/>(Llama Stack Server)"]

    %% Core Runtime Dependencies (Required)
    subgraph CoreRuntime["Core Runtime (Required)"]
        LlamaStackFW["llama-stack<br/>v0.7.1+rhaiv.1"]
        LlamaStackClient["llama-stack-client<br/>0.7.2"]
        FastAPI["FastAPI"]
        Uvicorn["Uvicorn"]
        PyTorch["PyTorch/torchao<br/>>=0.12.0"]
        Transformers["HuggingFace<br/>transformers"]
    end

    %% Storage Dependencies (Required)
    subgraph Storage["Storage (Required)"]
        PostgreSQLDep["PostgreSQL<br/>(any version)"]
        Psycopg2["psycopg2-binary"]
        Asyncpg["asyncpg"]
    end

    %% Internal RHOAI Platform Dependencies
    subgraph InternalRHOAI["Internal RHOAI Platform"]
        vLLMDep["vLLM Serving Runtime"]
        TrustyAIFMS["TrustyAI FMS<br/>Orchestrator"]
        TrustyAILMEval["TrustyAI LMEval"]
        KubeflowDep["Kubeflow Pipelines"]
    end

    %% Bundled Provider Plugins
    subgraph BundledPlugins["Bundled Provider Plugins"]
        TrustyAIFMSPlugin["trustyai-fms<br/>0.4.0"]
        LMEvalPlugin["lmeval plugin<br/>0.5.0"]
        RAGASInline["ragas-inline<br/>0.6.1"]
        RAGASRemote["ragas-remote<br/>0.6.1"]
        GarakPlugin["garak plugin<br/>0.3.1"]
    end

    %% Conditional - Inference Providers
    subgraph CloudInference["Cloud Inference Providers (Conditional)"]
        Boto3["boto3 1.35.88<br/>(AWS Bedrock)"]
        GoogleGenAI["google-genai<br/>(Vertex AI)"]
    end

    %% Conditional - Vector DB Providers
    subgraph VectorProviders["Vector DB Providers (Conditional)"]
        PyMilvus["pymilvus 2.6.9<br/>(Milvus)"]
        FaissCPU["faiss-cpu<br/>(FAISS)"]
        QdrantClient["qdrant-client<br/>(Qdrant)"]
    end

    %% Conditional - Other
    subgraph ConditionalOther["Other Conditional Dependencies"]
        SentenceTransformers["sentence-transformers"]
        OTELDistro["opentelemetry-distro"]
        KFPKubernetes["kfp-kubernetes 2.14.6"]
    end

    %% Embedded Assets
    subgraph EmbeddedAssets["Pre-cached Assets"]
        GraniteEmbed["granite-embedding<br/>-125m-english"]
        TiktokenCache["tiktoken<br/>cl100k_base"]
    end

    %% Core Runtime connections
    LlamaStack -->|"core framework"| LlamaStackFW
    LlamaStack -->|"client library"| LlamaStackClient
    LlamaStack -->|"web framework"| FastAPI
    LlamaStack -->|"ASGI server"| Uvicorn
    LlamaStack -->|"ML operations"| PyTorch
    LlamaStack -->|"model loading"| Transformers

    %% Storage connections
    LlamaStack -->|"KV + SQL store"| PostgreSQLDep
    LlamaStack -->|"sync adapter"| Psycopg2
    LlamaStack -->|"async adapter"| Asyncpg

    %% Internal Platform connections
    LlamaStack -->|"LLM inference"| vLLMDep
    LlamaStack -->|"safety guardrails"| TrustyAIFMS
    LlamaStack -->|"LLM evaluation"| TrustyAILMEval
    LlamaStack -->|"eval pipelines"| KubeflowDep

    %% Plugin connections
    LlamaStack -->|"safety provider"| TrustyAIFMSPlugin
    LlamaStack -->|"eval provider"| LMEvalPlugin
    LlamaStack -->|"RAG eval"| RAGASInline
    LlamaStack -->|"RAG eval remote"| RAGASRemote
    LlamaStack -->|"security eval"| GarakPlugin

    %% Conditional connections
    LlamaStack -.->|"AWS provider"| Boto3
    LlamaStack -.->|"Google provider"| GoogleGenAI
    LlamaStack -.->|"vector DB"| PyMilvus
    LlamaStack -.->|"vector search"| FaissCPU
    LlamaStack -.->|"vector DB"| QdrantClient
    LlamaStack -.->|"inline embeddings"| SentenceTransformers
    LlamaStack -.->|"observability"| OTELDistro
    LlamaStack -.->|"Kubeflow SDK"| KFPKubernetes

    %% Embedded assets
    LlamaStack -->|"pre-cached"| GraniteEmbed
    LlamaStack -->|"pre-cached"| TiktokenCache

