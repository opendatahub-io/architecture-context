graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API Layer)"]
        Gateway["Envoy Gateway<br/>inference-gateway<br/>80/TCP HTTP<br/>No encryption (configurable)"]
    end

    subgraph ClusterInternal["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_EPP["EPP Deployment"]
            EPP["Endpoint Picker Processor<br/>SA: $EPP_NAME<br/>Image: odh-llm-d-inference-scheduler<br/>FIPS: strictfipsruntime"]
            EPP_extproc["9002/TCP gRPC ext-proc<br/>No encryption, No auth"]
            EPP_health["9003/TCP gRPC health<br/>No encryption, No auth"]
            EPP_metrics["9090/TCP HTTP metrics<br/>No encryption, No auth"]
            EPP_zmq["5557/TCP ZMQ subscriber<br/>No encryption, No auth"]
        end

        subgraph NS_vLLM["vLLM Pod (with Sidecar)"]
            Sidecar["P/D Routing Sidecar<br/>Image: odh-llm-d-routing-sidecar<br/>FIPS: strictfipsruntime"]
            Sidecar_proxy["8000/TCP HTTPS proxy<br/>TLS 1.2+ FIPS ciphers<br/>No auth (SSRF opt-in)"]
            Decoder["vLLM Decoder<br/>8001/TCP<br/>Encryption: configurable"]
            Tokenizer["UDS Tokenizer<br/>gRPC over UDS<br/>No encryption"]
        end

        subgraph NS_Remote["Remote vLLM Workers"]
            Prefiller["vLLM Prefiller<br/>(configurable port)<br/>Encryption: configurable"]
            Encoder["vLLM Encoder<br/>(configurable port, EPD)<br/>Encryption: configurable"]
        end
    end

    subgraph Platform["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP<br/>HTTP, No auth"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>No encryption (insecure)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
    end

    subgraph ZMQEvents["vLLM KV-Events"]
        vLLMZMQ["ZMQ PUB<br/>5556/TCP<br/>No encryption, No auth"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No encryption<br/>No auth"| Gateway

    %% Ingress → EPP (ext-proc)
    Gateway -->|"gRPC/9002<br/>No encryption<br/>No auth"| EPP_extproc

    %% Ingress → Sidecar (routed request)
    Gateway -->|"HTTPS/8000<br/>TLS 1.2+<br/>No auth"| Sidecar_proxy

    %% Sidecar → vLLM
    Sidecar_proxy -->|"HTTP(S)/8001<br/>Configurable TLS<br/>No auth"| Decoder
    Sidecar_proxy -->|"HTTP(S)/configurable<br/>Configurable TLS<br/>No auth"| Prefiller
    Sidecar_proxy -->|"HTTP(S)/configurable<br/>Configurable TLS<br/>No auth"| Encoder

    %% EPP → Platform
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    EPP_metrics -.->|"HTTP/9090<br/>Scraped by"| Prometheus
    EPP -->|"gRPC/4317<br/>Insecure<br/>No auth"| OTel
    Sidecar -->|"gRPC/4317<br/>Insecure<br/>No auth"| OTel

    %% ZMQ Events
    vLLMZMQ -->|"ZMQ SUB/5556<br/>No encryption<br/>No auth"| EPP_zmq

    %% EPP → Tokenizer
    Tokenizer -->|"gRPC/UDS<br/>No encryption"| EPP

    %% Sidecar → K8s (SSRF allowlist)
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% External services
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HuggingFace

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef zmq fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:3px,stroke-dasharray: 5

    class Client external
    class Gateway ingress
    class EPP,EPP_extproc,EPP_health,EPP_metrics,EPP_zmq,Sidecar,Sidecar_proxy,Decoder,Tokenizer,Prefiller,Encoder internal
    class K8sAPI,Prometheus,OTel platform
    class HuggingFace externalservice
    class vLLMZMQ zmq
