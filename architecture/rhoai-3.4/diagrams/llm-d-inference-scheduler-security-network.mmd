graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Envoy["Envoy Gateway<br/>80/TCP HTTP<br/>ext-proc filter"]
    end

    subgraph ControlPlane["SCHEDULING CONTROL PLANE (Cluster Internal)"]
        direction TB

        subgraph NS_EPP["Namespace: ${NAMESPACE}"]
            EPP["EPP (Endpoint Picker)<br/>SA: ${EPP_NAME}<br/>Image: odh-llm-d-inference-scheduler<br/>FIPS: strictfipsruntime"]
            EPP_Ports["Ports:<br/>9002/TCP gRPC ext-proc<br/>9003/TCP gRPC health<br/>9090/TCP HTTP metrics<br/>5557/TCP ZMQ events"]
            Tokenizer["UDS Tokenizer<br/>Unix Socket<br/>8082/TCP health"]
        end
    end

    subgraph DataPlane["RUNTIME DATA PLANE (Per Pod)"]
        direction TB

        subgraph NS_Model["Namespace: ${NAMESPACE}"]
            Sidecar["Routing Sidecar<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ configurable<br/>SSRF: Pod IP allowlist<br/>FIPS: strictfipsruntime"]
            LocalDecoder["vLLM Decoder (local)<br/>8001/TCP HTTP"]
        end
    end

    subgraph RemoteWorkers["REMOTE MODEL WORKERS"]
        Prefiller["vLLM Prefiller<br/>varies HTTP/HTTPS<br/>TLS 1.2+ configurable"]
        Encoder["vLLM Encoder<br/>varies HTTP/HTTPS<br/>TLS 1.2+ configurable"]
    end

    subgraph K8sServices["KUBERNETES SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        vLLMEngines["vLLM Engines<br/>5556/TCP ZMQ<br/>No Encryption"]
        vLLMModels["vLLM /v1/models<br/>varies HTTP<br/>No Encryption"]
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP<br/>HTTP, No TLS"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>⚠ Insecure credentials"]
    end

    %% External to Ingress
    Client -->|"HTTP/80<br/>No TLS<br/>No Auth"| Envoy

    %% Envoy to components
    Envoy -->|"gRPC/9002<br/>No TLS (cluster-internal)<br/>No Auth"| EPP
    Envoy -->|"HTTP(S)/8000<br/>TLS 1.2+ configurable<br/>No Auth"| Sidecar

    %% EPP internal
    EPP -->|"Unix Socket<br/>N/A"| Tokenizer

    %% EPP to K8s
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    EPP -->|"ZMQ SUB/5556<br/>No TLS<br/>No Auth"| vLLMEngines
    EPP -->|"HTTP/varies<br/>No TLS<br/>⚠ insecureSkipVerify=true"| vLLMModels

    %% Sidecar flows
    Sidecar -->|"HTTP/8001<br/>No TLS (localhost)<br/>No Auth"| LocalDecoder
    Sidecar -->|"HTTP(S)/varies<br/>TLS 1.2+ configurable<br/>No Auth"| Prefiller
    Sidecar -->|"HTTP(S)/varies<br/>TLS 1.2+ configurable<br/>No Auth"| Encoder
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Observability
    Prometheus -->|"HTTP/9090<br/>No TLS"| EPP
    EPP -->|"gRPC/4317<br/>⚠ Insecure"| OTLP
    Sidecar -->|"gRPC/4317<br/>⚠ Insecure"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef dataplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef remote fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Envoy ingress
    class EPP,EPP_Ports,Tokenizer controlplane
    class Sidecar,LocalDecoder dataplane
    class Prefiller,Encoder remote
    class K8sAPI,vLLMEngines,vLLMModels k8s
    class Prometheus,OTLP observability
