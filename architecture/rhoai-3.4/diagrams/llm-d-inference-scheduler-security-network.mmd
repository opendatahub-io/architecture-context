%% Security Network Diagram: llm-d Inference Scheduler
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Envoy Gateway<br/>inference-gateway<br/>80/TCP HTTP<br/>No encryption"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Namespace-scoped RBAC)"]
        direction TB

        subgraph EPP_Zone["EPP (Endpoint Picker)"]
            EPP["EPP Server<br/>SA: ${EPP_NAME}<br/>9002/TCP gRPC plaintext<br/>9003/TCP gRPC health<br/>9090/TCP HTTP metrics"]
            UDS["UDS Tokenizer Sidecar<br/>gRPC over Unix Socket"]
        end

        subgraph PD_Zone["P/D Routing Sidecar"]
            Sidecar["P/D Sidecar<br/>8000/TCP HTTP/HTTPS<br/>TLS 1.2+ (optional)<br/>SSRF Allowlist Enforced"]
            SSRF["SSRF Allowlist Validator<br/>Watches InferencePool pods"]
        end

        subgraph vLLM_Pods["vLLM Inference Pods"]
            PrefillPod["Prefill Worker Pod<br/>vLLM<br/>HTTP/HTTPS"]
            DecodePod["Decode Worker Pod<br/>vLLM<br/>8001/TCP HTTP/HTTPS"]
            KVEvents["KV-Events<br/>5556/TCP ZMQ PUB"]
        end
    end

    subgraph K8s["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP"]
    end

    %% External → Ingress
    Client -->|"HTTP/80<br/>No encryption<br/>No auth"| Gateway

    %% Ingress → EPP (ext-proc)
    Gateway -->|"gRPC/9002<br/>plaintext<br/>cluster-internal"| EPP

    %% EPP → Gateway (routing decision)
    EPP -.->|"gRPC/9002<br/>routing response"| Gateway

    %% Ingress → P/D Sidecar
    Gateway -->|"HTTP(S)/8000<br/>TLS 1.2+ optional"| Sidecar

    %% P/D Sidecar → vLLM
    Sidecar -->|"HTTP(S)/varies<br/>TLS 1.2+ optional<br/>SSRF Allowlist validated"| PrefillPod
    Sidecar -->|"HTTP(S)/8001<br/>TLS 1.2+ optional<br/>No auth"| DecodePod

    %% EPP → KV Events
    KVEvents -->|"ZMQ PUB-SUB/5556<br/>plaintext<br/>No auth"| EPP

    %% EPP → UDS Tokenizer
    EPP -->|"gRPC over UDS<br/>Unix socket"| UDS

    %% Control plane access
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI
    SSRF -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/9090<br/>plaintext"| EPP

    %% KV-cache transfer between pods
    DecodePod <-->|"NIXL v2 / shared-storage<br/>Protocol-specific"| PrefillPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
