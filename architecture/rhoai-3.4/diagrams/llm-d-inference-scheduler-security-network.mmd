    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,UDS,Sidecar,PrefillPod,DecodePod,KVEvents internal
