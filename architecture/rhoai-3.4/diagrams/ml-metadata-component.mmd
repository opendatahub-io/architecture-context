graph TB
    subgraph "ML Metadata (MLMD)"
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Server)<br/>Port 8080/TCP"]
        ProtoAPI["Proto Definitions<br/>(MetadataStoreService)<br/>~50 RPC Methods"]
        PythonLib["ml_metadata<br/>(Python Client Library)<br/>gRPC Client + Direct DB"]
        ProtoAPI -.->|defines API for| Server
        ProtoAPI -.->|defines API for| PythonLib
    end

    subgraph "Clients"
        DSPBackend["DSP Backend<br/>(Pipeline Runner)"]
        DSPUI["DSP UI<br/>(Pipeline Dashboard)"]
        KFPSDK["Kubeflow Pipelines SDK<br/>(Python)"]
        PipelineStep["Pipeline Component<br/>(Argo/Tekton Step)"]
    end

    subgraph "Database Backends"
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>(Primary in RHOAI)"]
        MySQL["MySQL<br/>3306/TCP<br/>(Alternative)"]
        SQLite["SQLite<br/>(Embedded/Testing)"]
    end

    subgraph "Deployer"
        DSPOperator["Data Science Pipelines<br/>Operator"]
    end

    DSPBackend -->|gRPC/8080| Server
    DSPUI -->|via DSP Backend| Server
    KFPSDK -->|gRPC/8080| Server
    PipelineStep -->|gRPC/8080<br/>via Python SDK| Server

    Server -->|TCP/5432| PostgreSQL
    Server -->|TCP/3306| MySQL
    Server -->|File I/O| SQLite

    DSPOperator -->|deploys &<br/>configures| Server

    style Server fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ProtoAPI fill:#6c5ce7,stroke:#333,color:#fff
    style PythonLib fill:#4a90e2,stroke:#333,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style MySQL fill:#4479a1,stroke:#333,color:#fff
    style SQLite fill:#003b57,stroke:#333,color:#fff
    style DSPBackend fill:#7ed321,stroke:#333
    style DSPUI fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style PipelineStep fill:#7ed321,stroke:#333
    style DSPOperator fill:#f5a623,stroke:#333
