graph TB
    subgraph MLMDComponent["ML Metadata (MLMD)"]
        direction TB
        Server["metadata_store_server<br/>(C++ gRPC Service)"]
        ServiceImpl["MetadataStoreServiceImpl<br/>(gRPC Interface Implementation)"]
        MetadataStore["MetadataStore<br/>(Storage Abstraction)"]
        MAO["MetadataAccessObject<br/>(DB Operations)"]

        Server -->|"implements"| ServiceImpl
        ServiceImpl -->|"delegates to"| MetadataStore
        MetadataStore -->|"uses"| MAO
    end

    subgraph PythonClient["Python Client"]
        PyLib["ml-metadata Python Library<br/>(Client Library)"]
    end

    subgraph Clients["Clients"]
        DSP["Data Science Pipelines<br/>(DSP Operator)"]
        KFP["Kubeflow Pipelines<br/>Backend"]
        KFPUI["Kubeflow Pipelines<br/>UI"]
    end

    subgraph Databases["Database Backends"]
        MySQL["MySQL / MariaDB<br/>3306/TCP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        SQLite["SQLite<br/>(Embedded)"]
    end

    %% Client interactions
    DSP -->|"deploys container"| Server
    KFP -->|"gRPC/8080<br/>Optional TLS"| Server
    KFPUI -->|"gRPC via backend"| KFP
    PyLib -->|"gRPC/8080<br/>Optional TLS"| Server

    %% Database connections
    MAO -->|"MySQL protocol<br/>Optional TLS"| MySQL
    MAO -->|"PostgreSQL protocol<br/>Optional TLS"| PostgreSQL
    MAO -->|"Embedded"| SQLite

    %% Styling
    style Server fill:#4a90e2,stroke:#333,color:#fff
    style ServiceImpl fill:#4a90e2,stroke:#333,color:#fff
    style MetadataStore fill:#4a90e2,stroke:#333,color:#fff
    style MAO fill:#4a90e2,stroke:#333,color:#fff
    style PyLib fill:#6cb4ee,stroke:#333
    style DSP fill:#7ed321,stroke:#333
    style KFP fill:#7ed321,stroke:#333
    style KFPUI fill:#7ed321,stroke:#333
    style MySQL fill:#f5a623,stroke:#333
    style PostgreSQL fill:#f5a623,stroke:#333
    style SQLite fill:#f5a623,stroke:#333
