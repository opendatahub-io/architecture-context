graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (OpenShift SDN/OVN)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            LLS["Llama Stack Server<br/>ClusterIP 8321/TCP<br/>HTTP (plaintext)<br/>Llama Stack auth"]

            subgraph Provider["llama-stack-provider-ragas"]
                InlineEval["RagasEvaluatorInline<br/>(in-process, no network)"]
                RemoteEval["RagasEvaluatorRemote<br/>(network egress)"]
            end
        end

        subgraph NS_KFP["Namespace: {kubeflow-namespace}"]
            KFPPods["KFP Pipeline Pods<br/>Image: odh-trustyai-ragas-<br/>lls-provider-dsp-rhel9<br/>Step 1: retrieve_data<br/>Step 2: run_ragas"]
        end

        subgraph NS_RHOAI["Namespace: redhat-ods-applications"]
            TrustyAICM["ConfigMap:<br/>trustyai-service-operator-config<br/>(base image resolution)"]
        end

        subgraph ClusterServices["Cluster Services"]
            K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
            KFPAPI["Kubeflow Pipelines API<br/>HTTPS TLS 1.2+<br/>Bearer Token"]
            InferenceBackend["Ollama / vLLM<br/>11434/TCP HTTP (Ollama)<br/>8443/TCP HTTPS (vLLM)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
    end

    %% Client to LLS
    Client -->|"HTTP/8321<br/>Llama Stack auth<br/>⚠️ No TLS (relies on ingress)"| LLS

    %% LLS internal
    LLS --- InlineEval
    LLS --- RemoteEval

    %% Remote provider egress
    RemoteEval -->|"HTTPS<br/>TLS 1.2+<br/>Bearer Token"| KFPAPI
    RemoteEval -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RemoteEval -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% KFP pods
    KFPAPI -->|"launches"| KFPPods
    KFPPods -->|"HTTP/8321<br/>⚠️ No TLS, No auth"| LLS
    KFPPods -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% Inference backend
    LLS -->|"HTTP/11434 or HTTPS/8443<br/>⚠️ Demo: TLS_VERIFY=false"| InferenceBackend

    %% ConfigMap read
    K8sAPI -.->|"reads"| TrustyAICM

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kfp fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef warning fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef clusterservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class LLS,InlineEval,RemoteEval cluster
    class KFPPods kfp
    class S3 externalservice
    class K8sAPI,KFPAPI,InferenceBackend clusterservice
    class TrustyAICM cluster
