graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway / DMZ)"]
        Gateway["Istio Gateway (Envoy)<br/>443/TCP → internal<br/>TLS 1.2+ termination<br/>EnvoyFilter: INSERT_AFTER<br/>Gateway CR: maas-default-gateway"]
    end

    subgraph ServiceInternal["PAYLOAD PROCESSING SERVICE (Internal)"]
        direction TB

        subgraph NS_PP["Namespace: {release-namespace}"]
            PP["ai-gateway-payload-processing<br/>SA: payload-processing-{release}<br/>Image: quay.io/opendatahub/<br/>odh-ai-gateway-payload-processing:odh-stable<br/>FIPS: strictfipsruntime + UBI9"]

            subgraph Endpoints["Service Endpoints"]
                ExtProc["ext_proc gRPC<br/>9004/TCP ClusterIP<br/>plaintext"]
                Health["/healthz, /readyz<br/>9005/TCP ClusterIP<br/>HTTP plaintext"]
            end

            subgraph Plugins["Plugin Chain (in-process)"]
                direction LR
                P1["body-field-to-header"]
                P2["model-provider-resolver"]
                P3["api-translation"]
                P4["apikey-injection"]
            end
        end
    end

    subgraph ControlPlane["CONTROL PLANE SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: SA token"]
        NemoSvc["NeMo Guardrails Service<br/>(optional)<br/>Port: configurable<br/>HTTP/HTTPS<br/>Timeout: 360s"]
    end

    subgraph ExternalServices["EXTERNAL AI PROVIDERS (via Envoy upstream)"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>Auth: Bearer token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>Auth: x-api-key"]
        Azure["Azure OpenAI<br/>*.openai.azure.com<br/>Auth: api-key header"]
        Vertex["Vertex AI<br/>*.googleapis.com<br/>Auth: Bearer token"]
        Bedrock["Amazon Bedrock<br/>*.amazonaws.com<br/>Auth: Bearer token"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (user)"| Gateway
    Gateway -->|"gRPC ext_proc/9004<br/>plaintext (pod-local)<br/>No auth (Envoy-internal)"| ExtProc

    PP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>Watch: ExternalModel, Secrets"| K8sAPI
    PP -->|"HTTP(S)/configurable<br/>No auth (sidecar-level)<br/>Input rail check"| NemoSvc

    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Injected API key<br/>(after payload mutation)"| OpenAI
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key header"| Anthropic
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| Azure
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Vertex
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| Bedrock

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef serviceinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef plugin fill:#e1d5e7,stroke:#9673a6

    class Client external
    class Gateway ingress
    class PP,ExtProc,Health serviceinternal
    class P1,P2,P3,P4 plugin
    class K8sAPI,NemoSvc controlplane
    class OpenAI,Anthropic,Azure,Vertex,Bedrock externalservice
