// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/model-registry.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Registers, versions, and manages ML models"
        mlEngineer = person "ML Engineer" "Deploys models and manages inference services"

        modelRegistry = softwareSystem "Model Registry" "Central metadata repository for recording, versioning, and managing ML model metadata" {
            proxy = container "model-registry proxy" "Core REST API server (OpenAPI v1alpha3) for CRUD on models, versions, artifacts, inference services, experiments" "Go REST API Server" "Component"
            catalogServer = container "model-catalog server" "Catalog API server (OpenAPI v1alpha1) for curated model catalogs and MCP server catalogs" "Go REST API Server" "Component"
            controller = container "inferenceservice-controller" "Watches KServe InferenceService CRs and synchronizes state with Model Registry API" "Go Controller (controller-runtime)" "Component"
            bff = container "model-registry-ui BFF" "Backend-for-Frontend proxying UI requests to Model Registry and Catalog APIs with K8s auth" "Go HTTP Server" "Component"
            frontend = container "model-registry-ui frontend" "Web UI for browsing and managing registered models, versions, artifacts, and catalog" "React/TypeScript SPA" "Component"
            csi = container "mr-storage-initializer" "KServe CSI storage initializer supporting model-registry:// URI scheme" "Go CLI" "Component"
            asyncUpload = container "async-upload job" "Kubernetes Job for asynchronous model upload/transfer operations" "Python Job" "Component"
        }

        // External Systems
        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService CRDs" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for mTLS and traffic management" "External"
        dashboard = softwareSystem "ODH Dashboard" "Web UI for the OpenShift AI platform" "Internal ODH"
        mysql = softwareSystem "MySQL Database" "Backend metadata storage for model registry" "External"
        postgresql = softwareSystem "PostgreSQL Database" "Backend storage for catalog and optionally model registry" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Source for curated model catalog data" "External"
        s3Storage = softwareSystem "Model Storage (S3/OCI)" "Model artifact storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"

        // User interactions
        dataScientist -> modelRegistry "Registers models, creates versions, uploads artifacts via REST API"
        mlEngineer -> modelRegistry "Manages inference services and serving environments"
        dataScientist -> dashboard "Uses Dashboard UI to interact with Model Registry"

        // System-level relationships
        modelRegistry -> kserve "Syncs InferenceService state, registers CSI storage initializer"
        modelRegistry -> istio "Uses for mTLS service mesh communication"
        modelRegistry -> mysql "Stores model metadata" "MySQL/3306"
        modelRegistry -> postgresql "Stores catalog data and optionally model metadata" "PostgreSQL/5432"
        modelRegistry -> hfHub "Fetches model catalog data" "HTTPS/443"
        modelRegistry -> s3Storage "Downloads model artifacts via CSI" "HTTPS/443"
        modelRegistry -> k8sApi "Watches InferenceService CRs, performs SAR checks" "HTTPS"
        dashboard -> modelRegistry "Consumes BFF API for model management" "HTTP/8080"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS/8443"

        // Container-level relationships
        frontend -> bff "Proxied UI requests" "HTTP/8080"
        bff -> proxy "REST API calls" "HTTP/8080 (Istio mTLS)"
        bff -> catalogServer "Catalog queries" "HTTP/8080 (Istio mTLS)"
        bff -> k8sApi "SAR checks, service discovery" "HTTPS"
        proxy -> mysql "GORM ORM queries" "MySQL/3306 TLS"
        proxy -> postgresql "GORM ORM queries" "PostgreSQL/5432 TLS"
        catalogServer -> postgresql "Catalog storage + pglock" "PostgreSQL/5432"
        catalogServer -> hfHub "Fetch catalog models" "HTTPS/443"
        controller -> proxy "Sync InferenceService state" "HTTP/8080"
        controller -> k8sApi "Watch InferenceService CRs, update labels" "HTTPS"
        csi -> proxy "Fetch model artifact metadata" "HTTP/8080"
        csi -> s3Storage "Download model artifacts" "HTTPS/443"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
