graph TD
    subgraph AuthMechanisms["Authentication Mechanisms (6 distinct systems)"]
        OAuth["Gateway OAuth2/OIDC<br/>kube-auth-proxy<br/>Dashboard, Notebooks,<br/>Pipelines UI, MLflow UI,<br/>Feast UI, Ray Dashboard"]
        KRBP["kube-rbac-proxy Sidecar<br/>TokenReview + SAR<br/>Dashboard, Kubeflow, KubeRay,<br/>KServe, TrustyAI, guardrails,<br/>odh-model-controller"]
        Kuadrant["Kuadrant AuthPolicy<br/>Authorino<br/>Models as a Service<br/>(API key, OCP token, OIDC JWT)"]
        K8sAuth["Kubernetes API Auth<br/>ServiceAccount Tokens<br/>All 17 operators/controllers"]
        BearerFwd["Bearer Token Forwarding<br/>User OAuth in headers<br/>Dashboard, codeflare-sdk,<br/>Feast, MLflow, Model Registry"]
        AppRBAC["Application-Level RBAC<br/>Custom implementations<br/>Feast (OIDC groups),<br/>Model Registry (SelfSAR),<br/>EvalHub (tenant header SAR)"]
    end

    subgraph KeyServiceAccounts["Key ServiceAccounts"]
        SA_rhods["rhods-operator<br/>NS: redhat-ods-operator"]
        SA_kserve["kserve-controller-manager<br/>NS: opendatahub"]
        SA_dashboard["odh-dashboard<br/>NS: opendatahub"]
        SA_odmctl["odh-model-controller<br/>NS: opendatahub"]
        SA_kubeflow["notebook-controller<br/>NS: opendatahub"]
        SA_kuberay["kuberay-operator<br/>NS: opendatahub"]
        SA_dspo["data-science-pipelines-operator<br/>NS: opendatahub"]
        SA_trustyai["trustyai-service-operator<br/>NS: opendatahub"]
    end

    subgraph ClusterRoles["ClusterRoles (Most Privileged)"]
        CR_rhods["rhods-operator<br/>Platform CRDs (all verbs)<br/>Deployments, Services, ConfigMaps<br/>RBAC across namespaces<br/>Gateway API resources"]
        CR_kserve["kserve-controller-manager<br/>serving.kserve.io/*<br/>serving.knative.dev/*<br/>core/services, core/secrets<br/>apps/deployments<br/>gateway.networking.k8s.io/*"]
        CR_odmctl["odh-model-controller<br/>InferenceService (patch status)<br/>HTTPRoutes (create)<br/>ServiceMonitors (create)<br/>KEDA resources (create)"]
        CR_kubeflow["notebook-controller<br/>StatefulSets, Services (user NS)<br/>HTTPRoutes (platform NS)<br/>ReferenceGrants (user NS)<br/>Mutating webhook"]
        CR_kuberay["kuberay-operator<br/>ray.io/* (all verbs)<br/>Pods, Services (user NS)<br/>Mutating webhook"]
    end

    subgraph Secrets["Critical Secrets"]
        Secret_webhook["Webhook TLS Certificates<br/>Type: kubernetes.io/tls<br/>KServe, DSPO, Kubeflow,<br/>Training Op, Trainer, Spark,<br/>KubeRay, Model Registry Op<br/>Rotation: service-CA auto"]
        Secret_storage["storage-config<br/>Type: Opaque<br/>S3 credentials for model<br/>artifact storage<br/>Used by: KServe, Pipelines"]
        Secret_gateway["Gateway TLS Certificates<br/>Type: kubernetes.io/tls<br/>data-science-gateway HTTPS<br/>OpenShift service-CA signed"]
        Secret_maas["MaaS API Keys<br/>Type: Opaque<br/>External provider credentials<br/>(Anthropic, Azure, Vertex,<br/>Bedrock API keys)"]
        Secret_db["Database Credentials<br/>Type: Opaque<br/>MariaDB/PostgreSQL passwords<br/>DSP, Model Registry, MLflow"]
    end

    subgraph TLSConfig["TLS Configuration"]
        TLS_gateway["Gateway HTTPS Listeners<br/>443/TCP Server TLS<br/>TLS 1.3<br/>OpenShift service-CA"]
        TLS_webhook["Webhook Servers<br/>9443/TCP Server TLS<br/>service-CA certificates<br/>8 webhook servers"]
        TLS_metrics["Metrics Endpoints<br/>8443/TCP Server TLS<br/>kube-rbac-proxy<br/>FIPS cipher suites"]
        TLS_internal["Internal service-CA<br/>odh-dashboard, KServe,<br/>model-registry, MLflow,<br/>kube-rbac-proxy"]
        TLS_pod2pod["Pod-to-Pod TLS (optional)<br/>PodToPodTLS flag<br/>KServe InferenceService,<br/>llm-d components"]
        TLS_grpc["gRPC (PLAINTEXT)<br/>46 gRPC services<br/>MLServer, Caikit, MLMD,<br/>guardrails, gateway-ext,<br/>Model Registry"]
    end

    subgraph ContainerSecurity["Container Security Patterns"]
        CS_ubi["UBI Base Images<br/>43 of 53 components<br/>UBI 9 minimal, UBI 9 Python 3.12<br/>FIPS-validated OpenSSL"]
        CS_nonroot["Non-Root Execution<br/>45 of 53 components<br/>UID 1001 or 65532<br/>runAsNonRoot: true"]
        CS_distroless["Distroless Final Stages<br/>KServe, KubeRay, Kubeflow,<br/>Trainer, Training Op, Argo,<br/>Batch Gateway, Model Registry,<br/>odh-dashboard<br/>No shell, no pkg manager"]
        CS_multistage["Multi-Stage Builds<br/>261 of 377 Dockerfiles<br/>Builder → runtime artifact copy<br/>Reduced attack surface"]
        CS_hermetic["Hermetic Builds (Konflux)<br/>notebooks, pipelines-components,<br/>model-registry, rhods-operator<br/>Cachi2 prefetch, offline install"]
        CS_digest["Digest-Pinned Images<br/>All 122 shipped images<br/>sha256 digest in CSV relatedImages<br/>Prevents tag mutation"]
    end

    subgraph GatewayAuth["Gateway API Security Chain"]
        GW_class["GatewayClass<br/>(platform-level)"]
        GW_instance["Gateway<br/>data-science-gateway<br/>HTTPS listeners"]
        GW_envoy["Envoy Proxy<br/>EnvoyFilter: ext_authz + Lua"]
        GW_authproxy["kube-auth-proxy<br/>OAuth2/OIDC validation<br/>Header injection:<br/>x-forwarded-access-token<br/>x-auth-request-user<br/>x-auth-request-groups"]
        GW_httproute["HTTPRoutes<br/>(per-service routing)"]
    end

    subgraph MeshSecurity["Service Mesh Security (Legacy)"]
        Mesh_istio["Istio mTLS STRICT<br/>KServe Serverless mode only"]
        Mesh_peer["PeerAuthentication<br/>Namespace-scoped enforcement"]
        Mesh_authz["AuthorizationPolicy<br/>Model Registry (optional)"]
    end

    %% SA to Role bindings
    SA_rhods -->|"bound to"| CR_rhods
    SA_kserve -->|"bound to"| CR_kserve
    SA_odmctl -->|"bound to"| CR_odmctl
    SA_kubeflow -->|"bound to"| CR_kubeflow
    SA_kuberay -->|"bound to"| CR_kuberay

    %% SA to Auth mechanisms
    SA_rhods -->|"uses"| K8sAuth
    SA_kserve -->|"uses"| K8sAuth
    SA_dashboard -->|"uses"| K8sAuth
    SA_dashboard -->|"protected by"| OAuth
    SA_dashboard -->|"protected by"| KRBP
    SA_kubeflow -->|"protected by"| KRBP
    SA_kuberay -->|"protected by"| KRBP

    %% SA to Secrets
    SA_kserve -->|"uses"| Secret_webhook
    SA_kserve -->|"reads"| Secret_storage
    SA_dashboard -->|"uses"| Secret_gateway

    %% Gateway auth chain
    GW_class --> GW_instance
    GW_instance --> GW_envoy
    GW_envoy -->|"ext_authz"| GW_authproxy
    GW_authproxy -->|"validated"| GW_envoy
    GW_envoy --> GW_httproute
    GW_authproxy -->|"implements"| OAuth

    %% TLS relationships
    TLS_gateway -->|"terminates at"| GW_instance
    TLS_webhook -->|"certs from"| Secret_webhook
    TLS_metrics -->|"via"| KRBP
    TLS_internal -->|"service-CA"| Secret_gateway

    %% Mesh security
    Mesh_peer -->|"enforces"| Mesh_istio
    Mesh_authz -->|"restricts"| Mesh_istio

