%% Guardrails Detectors - RBAC & Security Controls Visualization
%% Generated by: Claude Opus 4.6
%% Note: No RBAC resources defined by this component.
%% RBAC is managed by the deploying platform (KServe, Guardrails Orchestrator).
%% This diagram shows security controls and authentication mechanisms instead.

graph TD
    subgraph "Authentication & Authorization"
        subgraph "Endpoint-Level Auth"
            NoAuth["No Auth Endpoints<br/>(HF & Built-in Detectors)"]
            DetectorIdAuth["Header Auth: detector_id<br/>(LLM Judge Detector)"]
        end

        subgraph "Platform-Level Auth (External)"
            PlatformAuth["Platform/Orchestrator<br/>Enforces Auth"]
        end
    end

    subgraph "Security Controls"
        subgraph "Custom Detector Sandboxing"
            AST["Static AST Analysis<br/>on User Code"]
            ForbiddenImports["Forbidden Imports:<br/>os, subprocess, sys, shutil"]
            ForbiddenCalls["Forbidden Calls:<br/>eval, exec, open, compile, input"]
            AllowedExceptions["Allowed Exceptions:<br/>os.environ, os.getenv"]
            PrivateFilter["Private Function Filter:<br/>_ prefixed functions hidden"]
        end

        subgraph "Optional TLS Configuration"
            TLSConfig["TLS Support via config.yaml<br/>ssl_ca_certs<br/>ssl_certfile<br/>ssl_keyfile"]
        end
    end

    subgraph "Detector Endpoints"
        HF_EP["HuggingFace Detector<br/>POST /api/v1/text/contents<br/>GET /health, /metrics<br/>Port: 8000/TCP"]
        LJ_EP["LLM Judge Detector<br/>POST /api/v1/text/contents<br/>POST /api/v1/text/generation<br/>GET /api/v1/metrics<br/>GET /health, /metrics<br/>Port: 8000/TCP"]
        BI_EP["Built-in Detector<br/>POST /api/v1/text/contents<br/>GET /registry<br/>GET /health, /metrics<br/>Port: 8080/TCP"]
    end

    NoAuth -->|"applies to"| HF_EP
    NoAuth -->|"applies to"| BI_EP
    DetectorIdAuth -->|"applies to"| LJ_EP
    PlatformAuth -->|"protects all"| HF_EP
    PlatformAuth -->|"protects all"| LJ_EP
    PlatformAuth -->|"protects all"| BI_EP

    AST -->|"blocks"| ForbiddenImports
    AST -->|"blocks"| ForbiddenCalls
    AST -->|"allows"| AllowedExceptions
    AST -->|"applies to"| BI_EP
    PrivateFilter -->|"applies to"| BI_EP

    TLSConfig -.->|"optional"| HF_EP
    TLSConfig -.->|"optional"| LJ_EP
    TLSConfig -.->|"optional"| BI_EP

    style NoAuth fill:#f9f9f9,stroke:#999
    style DetectorIdAuth fill:#ffe6cc,stroke:#d79b00
    style PlatformAuth fill:#d5e8d4,stroke:#82b366
    style AST fill:#f8cecc,stroke:#b85450
