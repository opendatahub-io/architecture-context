graph TD
    subgraph "Guardrails Detectors RBAC Model"
        direction TB

        subgraph "Note"
            Note["This component does NOT define its own<br/>ClusterRoles or ClusterRoleBindings.<br/>It relies on KServe and platform RBAC."]
        end

        subgraph "Example RoleBinding (from deploy manifests)"
            SA_User["ServiceAccount<br/>user-one"]
            RB["RoleBinding<br/>user-one-view<br/>Namespace: (deploy namespace)"]
            CR_View["ClusterRole<br/>view"]
        end

        subgraph "KServe-Managed Resources"
            ISVC["InferenceService<br/>(per detector)"]
            SR["ServingRuntime<br/>(per detector type)"]
            Deployment["Deployment<br/>(managed by KServe)"]
            Service["Service<br/>(ClusterIP, managed by KServe)"]
        end

        subgraph "Istio Security (per ISVC)"
            IstioSidecar["Istio Sidecar<br/>sidecar.istio.io/inject: 'true'"]
            AuthAnnotation["Auth Annotation<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
            mTLS["PeerAuthentication<br/>mTLS STRICT"]
        end

        subgraph "Secrets"
            S3Secret["aws-connection-minio-<br/>data-connection-guardrails-guardian<br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>endpoint, bucket, region<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        end

        SA_User -->|"bound via"| RB
        RB -->|"grants"| CR_View
        CR_View -->|"get, list, watch"| ISVC
        CR_View -->|"get, list, watch"| SR
        CR_View -->|"get, list, watch"| Deployment
        CR_View -->|"get, list, watch"| Service

        ISVC -.->|"enforced by"| IstioSidecar
        ISVC -.->|"configures"| AuthAnnotation
        IstioSidecar -.->|"enforces"| mTLS

        ISVC -.->|"references"| S3Secret
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA_User fill:#4a90e2,color:#fff
    style RB fill:#f5a623,color:#fff
    style CR_View fill:#f5a623,color:#fff
    style ISVC fill:#7ed321,color:#fff
    style SR fill:#7ed321,color:#fff
    style Deployment fill:#7ed321,color:#fff
    style Service fill:#7ed321,color:#fff
    style IstioSidecar fill:#e8e8e8,stroke:#333
    style AuthAnnotation fill:#e8e8e8,stroke:#333
    style mTLS fill:#e8e8e8,stroke:#333
    style S3Secret fill:#e74c3c,color:#fff
