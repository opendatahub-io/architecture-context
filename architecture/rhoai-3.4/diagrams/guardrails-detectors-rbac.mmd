graph TD
    subgraph Note["RBAC Model"]
        direction TB
        Info["Note: Guardrails Detectors defines<br/>NO custom ClusterRoles or RBAC.<br/>All RBAC is delegated to KServe<br/>and platform-level policies."]
    end

    subgraph ExampleRBAC["Example Deployment RBAC (from model_container.yaml)"]
        direction TB
        SA_User["ServiceAccount<br/>user-one"]
        RB_View["RoleBinding<br/>user-one-view"]
        CR_View["ClusterRole<br/>view (built-in K8s)"]
    end

    subgraph AuthEnforcement["Authentication & Authorization Enforcement"]
        direction TB

        subgraph KServeAuth["KServe Auth Layer"]
            AuthAnnotation["Annotation:<br/>security.opendatahub.io/<br/>enable-auth: 'true'"]
        end

        subgraph IstioAuth["Istio Auth Layer"]
            PeerAuth["PeerAuthentication<br/>Mode: STRICT<br/>(namespace-scoped)"]
            Sidecar["Sidecar Injection<br/>sidecar.istio.io/<br/>inject: 'true'"]
        end
    end

    subgraph Endpoints["Protected Endpoints"]
        direction TB
        APIContents["/api/v1/text/contents<br/>POST<br/>Auth: Istio mTLS +<br/>KServe platform auth"]
        APIGeneration["/api/v1/text/generation<br/>POST<br/>Auth: Istio mTLS +<br/>KServe platform auth"]
        Health["/health<br/>GET<br/>Auth: None (open)"]
        Metrics["/metrics<br/>GET<br/>Auth: None (open)"]
    end

    subgraph SecretsAccess["Secrets"]
        direction TB
        S3Secret["Secret:<br/>aws-connection-minio-<br/>data-connection-<br/>guardrails-guardian<br/><br/>Type: Opaque<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_S3_ENDPOINT,<br/>AWS_S3_BUCKET<br/><br/>Provisioned: Manual<br/>Auto-rotate: No"]
    end

    subgraph CustomDetectorSecurity["Custom Detector Security (Built-in)"]
        direction TB
        ASTCheck["AST Static Code Analysis<br/><br/>Blocked imports:<br/>os, subprocess, sys, shutil<br/><br/>Blocked calls:<br/>eval, exec, open,<br/>compile, input<br/><br/>Note: Best-effort inspection,<br/>NOT process isolation"]
    end

    %% Example RBAC flow
    SA_User -->|"bound via"| RB_View
    RB_View -->|"grants"| CR_View

    %% Auth enforcement → endpoints
    KServeAuth -->|"enforces on"| APIContents
    KServeAuth -->|"enforces on"| APIGeneration
    IstioAuth -->|"mTLS on"| APIContents
    IstioAuth -->|"mTLS on"| APIGeneration

    %% Styling
    style Info fill:#fff3cd,stroke:#856404,color:#333
    style SA_User fill:#4a90e2,color:#fff
    style CR_View fill:#f5a623,color:#fff
    style RB_View fill:#7ed321,color:#fff
    style AuthAnnotation fill:#e1d5e7,stroke:#9673a6
    style PeerAuth fill:#e1d5e7,stroke:#9673a6
    style Sidecar fill:#e1d5e7,stroke:#9673a6
    style APIContents fill:#d5e8d4,stroke:#82b366
    style APIGeneration fill:#d5e8d4,stroke:#82b366
    style Health fill:#f9f9f9,stroke:#999
    style Metrics fill:#f9f9f9,stroke:#999
    style S3Secret fill:#f8cecc,stroke:#b85450
    style ASTCheck fill:#fff2cc,stroke:#d6b656
