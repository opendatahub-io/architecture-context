graph TB
    subgraph ClientEnv["CLIENT ENVIRONMENT (User Workstation / Jupyter Notebook)"]
        SDK["CodeFlare SDK<br/>Python 3.11+<br/>cryptography 46.0.7<br/>kube-authkit"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforcement"]
    end

    subgraph IngressLayer["INGRESS LAYER (Dashboard Access)"]
        HTTPRoute["HTTPRoute (RHOAI 3.x)<br/>{gateway}/ray/{ns}/{cluster}<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        Route["Route (Legacy RHOAI 2.x)<br/>ray-dashboard-{name}<br/>443/TCP HTTPS Edge<br/>OAuth Proxy"]
        Ingress["Ingress (Vanilla K8s)<br/>{name}-ingress<br/>80-443/TCP<br/>HTTP/HTTPS"]
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Internal Services)"]
        direction TB

        subgraph KubeRayNS["KubeRay Operator Namespace"]
            KubeRayOp["KubeRay Operator<br/>Reconciles RayCluster/RayJob<br/>Creates CA Secret"]
        end

        subgraph UserNS["Namespace: {user-namespace}"]
            RayHead["Ray Head Node<br/>{cluster}-head-svc<br/>ClusterIP"]
            GCS["GCS Port<br/>6379/TCP gRPC<br/>mTLS"]
            Dashboard["Dashboard Port<br/>8265/TCP HTTP<br/>Proxied via HTTPRoute"]
            ClientPort["Client Port<br/>10001/TCP gRPC<br/>mTLS (RSA 3072-bit)"]
            CASecret["CA Secret<br/>{cluster}-ca-secret-{suffix}<br/>Opaque"]
            FilesSecret["Files Secret<br/>{job}-files<br/>Opaque (owner ref)"]
        end

        subgraph KueueNS["Kueue Controller"]
            Kueue["Kueue<br/>LocalQueue admission<br/>Workload management"]
        end

        RayHead --- GCS
        RayHead --- Dashboard
        RayHead --- ClientPort
    end

    %% SDK → K8s API (all CRD operations)
    SDK -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / kubeconfig / SA"| K8sAPI

    %% K8s API → Internal resources
    K8sAPI -.->|"CRD CRUD"| KubeRayOp
    K8sAPI -.->|"Read"| Kueue
    K8sAPI -.->|"Read CA"| CASecret
    K8sAPI -.->|"Create files"| FilesSecret

    %% SDK → Dashboard (via ingress)
    SDK -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HTTPRoute
    HTTPRoute -->|"HTTP/8265<br/>Proxied"| Dashboard

    %% SDK → Ray Client (direct mTLS)
    SDK -->|"gRPC/10001<br/>mTLS<br/>Client cert (RSA 3072, SHA-256)"| ClientPort

    %% Fallback dashboard paths
    SDK -.->|"HTTPS/443<br/>Edge TLS<br/>OAuth"| Route
    Route -.->|"HTTP/8265"| Dashboard

    %% Styling
    classDef client fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef controlplane fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secret fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    classDef port fill:#f5f5f5,stroke:#616161

    class SDK client
    class K8sAPI controlplane
    class HTTPRoute,Route,Ingress ingress
    class KubeRayOp,RayHead,Kueue cluster
    class CASecret,FilesSecret secret
    class GCS,Dashboard,ClientPort port
