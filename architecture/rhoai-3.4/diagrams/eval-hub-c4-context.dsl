// EvalHub C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and manages LLM evaluation jobs"
        platformadmin = person "Platform Admin" "Manages RHOAI platform and operator configuration"

        evalhub = softwareSystem "EvalHub" "Lightweight REST API service that orchestrates LLM evaluations across multiple backends" {
            apiServer = container "eval-hub API Server" "Main REST API server handling evaluation orchestration, provider/benchmark management, and job lifecycle" "Go REST Service, Port 8080"
            authMiddleware = container "Auth Middleware" "Kubernetes TokenReview authentication and SubjectAccessReview authorization" "Go Module"
            k8sRuntime = container "K8s Runtime" "Creates Kubernetes batch/v1 Jobs and ConfigMaps for evaluation execution in tenant namespaces" "Go Module"
            sqlStorage = container "SQL Storage Layer" "Pluggable storage abstraction supporting SQLite and PostgreSQL" "Go Module"
            mlflowClient = container "MLflow Client" "Integration with MLflow tracking server for experiment creation and management" "Go Module"
            metrics = container "Observability" "Prometheus metrics and OpenTelemetry tracing" "Go Module"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages EvalHub instances via EvalHub CRD" "Internal RHOAI"
        k8sApi = softwareSystem "Kubernetes API Server" "Core Kubernetes API for resource management, authn, and authz" "External"
        mlflow = softwareSystem "MLflow Tracking Server" "Experiment tracking and result storage" "Internal RHOAI"
        postgresql = softwareSystem "PostgreSQL" "Production database backend" "External"
        s3 = softwareSystem "AWS S3" "Test data storage for evaluation benchmarks" "External"
        ociRegistry = softwareSystem "OCI Registry" "Container image and artifact storage (quay.io)" "External"
        otlpCollector = softwareSystem "OTLP Collector" "Distributed tracing collection" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // Adapter frameworks
        lmEvalHarness = softwareSystem "lm-evaluation-harness Adapter" "Runs LM Evaluation Harness benchmarks (167 benchmarks)" "Internal RHOAI"
        guideLLM = softwareSystem "GuideLLM Adapter" "Runs GuideLLM performance benchmarks" "Internal RHOAI"
        lightEval = softwareSystem "LightEval Adapter" "Runs LightEval benchmarks" "Internal RHOAI"

        // Relationships - External
        datascientist -> evalhub "Creates evaluation jobs via REST API" "HTTPS/8080, Bearer Token"
        platformadmin -> trustyaiOperator "Configures EvalHub instances" "kubectl/oc"

        // Relationships - Internal containers
        apiServer -> authMiddleware "Authenticates and authorizes requests"
        apiServer -> k8sRuntime "Dispatches evaluation jobs"
        apiServer -> sqlStorage "Persists job state and metadata"
        apiServer -> mlflowClient "Creates experiments and logs results"
        apiServer -> metrics "Exposes metrics and traces"

        // Relationships - System
        trustyaiOperator -> evalhub "Deploys and manages via EvalHub CR"
        evalhub -> k8sApi "Job/ConfigMap CRUD, TokenReview, SAR" "HTTPS/443"
        evalhub -> mlflow "Experiment tracking" "HTTP(S)/5000"
        evalhub -> postgresql "Production data storage" "TCP/5432"
        evalhub -> s3 "Downloads test data" "HTTPS/443"
        evalhub -> otlpCollector "Sends traces" "gRPC/4317"
        prometheus -> evalhub "Scrapes metrics" "HTTP(S)/8080"

        // Adapter relationships
        k8sRuntime -> lmEvalHarness "Creates evaluation Jobs" "Kubernetes batch/v1"
        k8sRuntime -> guideLLM "Creates evaluation Jobs" "Kubernetes batch/v1"
        k8sRuntime -> lightEval "Creates evaluation Jobs" "Kubernetes batch/v1"
        lmEvalHarness -> evalhub "Status callbacks" "HTTPS/8080"
        guideLLM -> evalhub "Status callbacks" "HTTPS/8080"
        lightEval -> evalhub "Status callbacks" "HTTPS/8080"
    }

    views {
        systemContext evalhub "SystemContext" {
            include *
            autoLayout
        }

        container evalhub "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
