graph TD
    subgraph Note["training-hub RBAC"]
        direction TB
        Info["training-hub is a Python library (PyPI package)<br/>NOT a Kubernetes operator or service.<br/><br/>No Kubernetes RBAC resources are defined:<br/>- No ClusterRoles<br/>- No ClusterRoleBindings<br/>- No Roles<br/>- No RoleBindings<br/>- No ServiceAccounts"]
    end

    subgraph RuntimeAuth["Runtime Authentication (Environment Variables)"]
        direction TB
        HFToken["HF_TOKEN<br/>━━━━━━━━━━━<br/>Source: Environment variable<br/>Purpose: HuggingFace Hub access<br/>Scope: Model/dataset downloads<br/>Required: Optional (public models)"]
        WandBKey["WANDB_API_KEY<br/>━━━━━━━━━━━<br/>Source: Environment variable<br/>Purpose: W&B experiment tracking<br/>Scope: Metrics logging<br/>Required: Only if W&B configured"]
        MLflowCreds["MLflow Credentials<br/>━━━━━━━━━━━<br/>Source: Environment variables<br/>Purpose: MLflow tracking server<br/>Scope: Experiment logging<br/>Required: Only if MLflow configured"]
    end

    subgraph AccessedResources["Resources Accessed"]
        direction TB
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>HTTPS/443"]
        WandBAPI["Weights & Biases<br/>api.wandb.ai<br/>HTTPS/443"]
        MLflowServer["MLflow Server<br/>Configurable<br/>HTTP(S)"]
        LocalFS["Local Filesystem<br/>Checkpoints, caches,<br/>TensorBoard events"]
        GPU["GPU Hardware<br/>CUDA devices<br/>No auth required"]
    end

    HFToken -->|authenticates| HFHub
    WandBKey -->|authenticates| WandBAPI
    MLflowCreds -->|authenticates| MLflowServer

    %% Styling
    style Info fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#333
    style HFToken fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style WandBKey fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style MLflowCreds fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    style HFHub fill:#e8f0fe,stroke:#4a90e2,stroke-width:1px
    style WandBAPI fill:#e8f0fe,stroke:#4a90e2,stroke-width:1px
    style MLflowServer fill:#e8f0fe,stroke:#4a90e2,stroke-width:1px
    style LocalFS fill:#e8e8e8,stroke:#999,stroke-width:1px
    style GPU fill:#e8e8e8,stroke:#999,stroke-width:1px
