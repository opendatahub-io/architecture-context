graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway Layer)"]
        Gateway["Envoy Gateway<br/>Gateway API v1<br/>80/TCP HTTP<br/>ext-proc filter chain"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB

        subgraph NS_Pool["Namespace: {pool-namespace}"]
            direction TB

            BBR["Body-Based Router (BBR)<br/>SA: {release}-bbr<br/>9004/TCP gRPC TLS (SIMPLE)<br/>9005/TCP health<br/>9090/TCP metrics"]

            EPP["Endpoint Picker Proxy (EPP)<br/>SA: {release}-epp<br/>9002/TCP gRPC TLS (optional)<br/>9003/TCP health<br/>9090/TCP metrics"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            ModelServer["Model Server Pods<br/>(vLLM / SGLang / Triton)<br/>configurable/TCP inference<br/>configurable/TCP metrics"]
        end

        subgraph NS_Latency["Latency Predictor (Optional)"]
            TrainingSrv["Training Server<br/>8000/TCP HTTP<br/>XGBoost training"]
            PredSrv["Prediction Server<br/>8001/TCP HTTP<br/>Real-time predictions"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        Prometheus["Prometheus<br/>HTTP scrape<br/>Bearer Token (optional)"]
        OTel["OpenTelemetry Collector<br/>gRPC (optional)"]
    end

    %% Flows with security details
    Client -->|"HTTP/80<br/>No encryption<br/>No auth"| Gateway

    Gateway -->|"gRPC/9004<br/>TLS (SIMPLE)<br/>No auth"| BBR
    BBR -->|"gRPC response<br/>routing headers<br/>(x-gateway-model-name)"| Gateway

    Gateway -->|"gRPC/9002<br/>TLS (optional, self-signed)<br/>No auth"| EPP
    EPP -->|"gRPC response<br/>endpoint selection<br/>(x-gateway-destination-endpoint)"| Gateway

    Gateway -->|"HTTP/configurable<br/>No encryption<br/>No auth"| ModelServer

    EPP -->|"HTTP(S)/configurable<br/>None/TLS<br/>No auth<br/>metrics scraping"| ModelServer

    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (JWT)<br/>CRD watches + leases"| K8sAPI
    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (JWT)<br/>ConfigMap watches"| K8sAPI

    EPP -->|"HTTP/8001<br/>No encryption<br/>No auth"| PredSrv
    EPP -->|"HTTP/8000<br/>No encryption<br/>async samples"| TrainingSrv

    Prometheus -->|"HTTP/9090<br/>Bearer Token (optional)<br/>TokenReview + SAR"| EPP
    Prometheus -->|"HTTP/9090<br/>No auth"| BBR

    EPP -.->|"gRPC/configurable<br/>No encryption"| OTel

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterservice fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class Gateway ingress
    class EPP,BBR,ModelServer clusterservice
    class K8sAPI,Prometheus,OTel platform
    class TrainingSrv,PredSrv optional
