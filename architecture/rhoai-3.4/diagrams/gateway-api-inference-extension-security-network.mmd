graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph GatewayLayer["GATEWAY LAYER (TLS Termination)"]
        Gateway["Envoy Gateway<br/>443/TCP → ext-proc chain<br/>TLS 1.2+<br/>Bearer Token / API Key"]
    end

    subgraph ExtProc["EXT-PROC LAYER (ClusterIP Services)"]
        direction TB

        subgraph BBR_NS["BBR Service"]
            BBR["Body Based Router<br/>ext-proc: 9004/TCP gRPC TLS<br/>health: 9005/TCP gRPC<br/>metrics: 9090/TCP HTTP<br/>SA: BBR ServiceAccount"]
        end

        subgraph EPP_NS["EPP Service"]
            EPP["Endpoint Picker Provider<br/>ext-proc: 9002/TCP gRPC TLS<br/>health: 9003/TCP gRPC<br/>metrics: 9090/TCP HTTP<br/>SA: EPP ServiceAccount"]
        end
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    subgraph ModelLayer["MODEL SERVING LAYER (Pod IPs)"]
        direction TB
        ModelServer["Model Server Pods<br/>(vLLM / SGLang)<br/>Serving: 8000/TCP HTTP<br/>Metrics: Prometheus HTTP"]
        LoRASidecar["Dynamic LoRA Sidecar<br/>(optional, in-pod)<br/>No exposed ports"]
    end

    subgraph LatencyLayer["LATENCY PREDICTION (Optional, ClusterIP)"]
        LPTrain["Latency Predictor Training<br/>8000/TCP HTTP<br/>No TLS, No Auth"]
        LPPredict["Latency Predictor Prediction<br/>8000/TCP HTTP<br/>No TLS, No Auth"]
        AsyncClient["EPP Async Client Sidecar<br/>Batch & Coalesce"]
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        Prometheus["Prometheus<br/>Scrapes 9090/TCP HTTP"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>No TLS"]
    end

    %% External to Gateway
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / API Key"| Gateway

    %% Gateway to ext-proc chain
    Gateway -->|"gRPC/9004<br/>TLS<br/>No client auth"| BBR
    Gateway -->|"gRPC/9002<br/>TLS<br/>No client auth"| EPP

    %% Gateway to model server (after routing decision)
    Gateway -->|"HTTP/8000<br/>No TLS<br/>No Auth"| ModelServer

    %% BBR to K8s API
    BBR -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch: ConfigMaps"| K8sAPI

    %% EPP to K8s API
    EPP -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Watch: CRDs, Pods, Leases"| K8sAPI

    %% EPP to Model Server (metrics scraping)
    EPP -->|"HTTP(S)/configurable<br/>InsecureSkipVerify<br/>No Auth<br/>Prometheus scrape"| ModelServer

    %% LoRA sidecar to vLLM
    LoRASidecar -->|"HTTP/8000<br/>No TLS<br/>LoRA load/unload"| ModelServer

    %% Latency prediction
    AsyncClient -->|"HTTP/8000<br/>No TLS<br/>Training data"| LPTrain
    AsyncClient -->|"HTTP/8000<br/>No TLS<br/>Bulk predictions"| LPPredict

    %% Observability
    EPP -.->|"HTTP/9090<br/>Metrics"| Prometheus
    BBR -.->|"HTTP/9090<br/>Metrics"| Prometheus
    EPP -.->|"gRPC/4317<br/>No TLS<br/>OTLP traces"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef extproc fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelserving fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef latency fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef observability fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5

    class Client external
    class Gateway gateway
    class BBR,EPP extproc
    class K8sAPI k8s
    class ModelServer,LoRASidecar modelserving
    class LPTrain,LPPredict,AsyncClient latency
    class Prometheus,OTLP observability
