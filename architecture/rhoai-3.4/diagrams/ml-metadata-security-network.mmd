graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph DSPNamespace["Namespace: {dsp-namespace}"]
            direction TB

            subgraph ServiceMesh["SERVICE MESH (Optional mTLS)"]
                direction TB

                subgraph MLMDPod["MLMD Pod (UID 65534 - non-root)"]
                    Server["metadata_store_server<br/>8080/TCP gRPC<br/>C++ Binary<br/>TLS: Optional (BoringSSL)"]
                end

                Service["metadata-grpc-service<br/>ClusterIP<br/>8080/TCP gRPC"]

                DSPBackend["DSP Backend<br/>gRPC Client"]
                DSPRunner["Pipeline Runner<br/>(Argo/Tekton Steps)<br/>via Python SDK"]
            end
        end

        subgraph DBNamespace["Database (managed by DSP)"]
            PostgreSQL["PostgreSQL<br/>5432/TCP<br/>SSL: Optional<br/>Auth: Password + Client Certs"]
        end
    end

    subgraph External["EXTERNAL (Build-time only)"]
        UBI9["UBI9-minimal<br/>Base Image<br/>(Runtime)"]
    end

    %% Network Flows
    DSPBackend -->|"gRPC/8080<br/>Optional TLS (BoringSSL)<br/>Optional mTLS (client_verify)"| Service
    DSPRunner -->|"gRPC/8080<br/>Optional TLS<br/>Optional mTLS"| Service
    Service -->|"gRPC/8080"| Server
    Server -->|"TCP/5432<br/>Optional SSL (sslmode: verify-ca/verify-full)<br/>Auth: Password + optional client certs<br/>Crypto: System OpenSSL (FIPS-validated)"| PostgreSQL

    %% Styling
    classDef cluster fill:#f0f0f0,stroke:#666,stroke-width:2px
    classDef namespace fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef db fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:1px
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class Server pod
    class Service service
    class PostgreSQL db
    class DSPBackend,DSPRunner client
    class UBI9 external
