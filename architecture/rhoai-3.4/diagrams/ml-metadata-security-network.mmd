graph TB
    subgraph InternalClients["INTERNAL CLIENTS (Trusted - Cluster Namespace)"]
        KFP["Kubeflow Pipelines Backend<br/>SA: pipeline-runner"]
        DSP["Data Science Pipelines<br/>(DSP Operator)"]
        KFPUI["Pipeline UI<br/>(via backend)"]
    end

    subgraph MLMDServer["MLMD gRPC SERVER"]
        direction TB
        Server["metadata_store_server<br/>Container: odh-mlmd-grpc-server-rhel9<br/>User: 65534:65534 (non-root)<br/>Port: 8080/TCP gRPC<br/>Crypto: BoringSSL"]
    end

    subgraph DatabaseBackend["DATABASE BACKEND (Persistent Storage)"]
        MySQL["MySQL / MariaDB<br/>3306/TCP<br/>MySQL Protocol<br/>Optional TLS (SSLOptions)"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL Protocol<br/>Optional TLS (sslmode)"]
        SQLite["SQLite<br/>(Embedded, no network)"]
    end

    %% Client flows
    KFP -->|"gRPC/8080<br/>Optional TLS (SSLConfig)<br/>Optional mTLS (client_verify)"| Server
    DSP -->|"gRPC/8080<br/>Optional TLS (SSLConfig)<br/>Optional mTLS (client_verify)"| Server
    KFPUI -->|"via backend"| KFP

    %% Database flows
    Server -->|"3306/TCP<br/>MySQL Protocol<br/>Optional TLS<br/>Username/Password"| MySQL
    Server -->|"5432/TCP<br/>PostgreSQL Protocol<br/>Optional TLS<br/>Username/Password"| PostgreSQL
    Server -->|"Embedded<br/>No network"| SQLite

    %% Styling
    classDef client fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef server fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef database fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class KFP,DSP,KFPUI client
    class Server server
    class MySQL,PostgreSQL,SQLite database
