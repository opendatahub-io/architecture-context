graph LR
    Notebooks["Notebooks<br/>(Workbench Image Factory)"]

    %% External Dependencies (Build-time)
    Notebooks -->|"base image"| UBI9["UBI9 Python 3.12<br/>(latest)"]
    Notebooks -->|"GPU drivers"| CUDA["CUDA Toolkit<br/>12.6 - 13.0"]
    Notebooks -->|"GPU drivers"| ROCm["ROCm<br/>6.2 - 6.4"]
    Notebooks -->|"IDE (Jupyter)"| JupyterLab["JupyterLab<br/>4.5"]
    Notebooks -->|"IDE (VS Code)"| CodeServer["Code-Server<br/>v4.106.3"]
    Notebooks -->|"IDE (R)"| RStudioSrv["RStudio Server<br/>2025.09.0"]
    Notebooks -->|"ML framework"| PyTorch["PyTorch<br/>2.10"]
    Notebooks -->|"ML framework"| TensorFlow["TensorFlow"]
    Notebooks -->|"reverse proxy"| Nginx["nginx<br/>1.24"]
    Notebooks -->|"CGI gateway"| HTTPD["httpd<br/>(UBI default)"]
    Notebooks -->|"JS runtime"| NodeJS["Node.js<br/>22.21.1"]
    Notebooks -->|"R runtime"| RLang["R<br/>4.5.1"]
    Notebooks -->|"pkg installer"| UV["uv<br/>0.11.6"]
    Notebooks -->|"pkg installer"| Micropipenv["micropipenv<br/>1.10.0"]

    %% Internal Platform Dependencies
    Operator["rhods-operator"] -->|"deploys ImageStreams from<br/>manifests/rhoai/"| Notebooks
    Dashboard["ODH Dashboard"] -->|"reads annotations<br/>opendatahub.io/notebook-image-*"| Notebooks
    Controller["odh-notebook-controller"] -->|"injects sidecar,<br/>mounts CA + secrets"| Notebooks
    DSP["Data Science Pipelines"] -->|"executes runtime<br/>images as tasks"| Notebooks
    Elyra["Elyra Extension"] -->|"reads runtime-image-metadata<br/>annotations"| Notebooks
    OSRegistry["OpenShift Image Registry"] -->|"imports from<br/>registry.redhat.io"| Notebooks
    Konflux["Konflux CI/CD"] -->|"builds hermetic images<br/>.tekton/ pipelines"| Notebooks
    SecurityConfig["security-config<br/>(opendatahub-io)"] -->|"syncs scanning configs<br/>semgrep, gitleaks, coderabbit"| Notebooks

    %% Runtime egress dependencies
    Notebooks -.->|"user pip install<br/>(runtime)"| PyPI["PyPI"]
    Notebooks -.->|"user git ops<br/>(runtime)"| GitRepos["Git Repos"]
    Notebooks -.->|"data access<br/>(runtime)"| S3["S3 Storage"]
    Notebooks -.->|"pipeline submit<br/>(runtime)"| DSPAAPI["DSPA API"]
    Notebooks -.->|"R pkg install<br/>(runtime)"| CRAN["CRAN"]

