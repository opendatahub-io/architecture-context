graph TB
    subgraph Operator["TrustyAI Service Operator"]
        direction TB
        Manager["trustyai-service-operator<br/>(manager)<br/>Go 1.23 / controller-runtime"]

        subgraph Controllers["Pluggable Controllers (--enable-services)"]
            TASCtrl["TAS Controller<br/>TrustyAIService"]
            LMESCtrl["LMES Controller<br/>LMEvalJob"]
            GORCHCtrl["GORCH Controller<br/>GuardrailsOrchestrator"]
            NEMOCtrl["NEMO Controller<br/>NemoGuardrails"]
            EVALCtrl["EVALHUB Controller<br/>EvalHub"]
        end

        subgraph Support["Support Controllers"]
            JobMgr["Job Manager<br/>Kueue Integration"]
            FailReconciler["Job Failure<br/>Reconciler"]
        end

        Manager --> TASCtrl
        Manager --> LMESCtrl
        Manager --> GORCHCtrl
        Manager --> NEMOCtrl
        Manager --> EVALCtrl
        LMESCtrl --> JobMgr
        EVALCtrl --> FailReconciler
    end

    subgraph CRDs["Custom Resource Definitions"]
        TrustyAISvc["TrustyAIService<br/>v1 / v1alpha1"]
        LMEvalJob["LMEvalJob<br/>v1alpha1"]
        GOrchCR["GuardrailsOrchestrator<br/>v1alpha1"]
        NemoCR["NemoGuardrails<br/>v1alpha1"]
        EvalHubCR["EvalHub<br/>v1alpha1"]
    end

    subgraph ManagedResources["Managed Resources"]
        Deployments["Deployments"]
        Services["Services + Routes"]
        ConfigMaps["ConfigMaps"]
        Secrets["Secrets / TLS"]
        PVCs["PVCs"]
        RBACRes["RBAC Objects"]
        SvcMonitors["ServiceMonitors"]
    end

    subgraph DriverPod["LMEvalJob Pod"]
        InitContainer["ta-lmes-driver<br/>(init container)"]
        MainContainer["lm-eval<br/>(main container)"]
        InitContainer -->|"copies binary<br/>to shared vol"| MainContainer
    end

    %% CRD watches
    TASCtrl -->|watches| TrustyAISvc
    LMESCtrl -->|watches| LMEvalJob
    GORCHCtrl -->|watches| GOrchCR
    NEMOCtrl -->|watches| NemoCR
    EVALCtrl -->|watches| EvalHubCR

    %% Managed resources
    TASCtrl -->|creates| Deployments
    TASCtrl -->|creates| Services
    TASCtrl -->|creates| ConfigMaps
    TASCtrl -->|creates| Secrets
    TASCtrl -->|creates| RBACRes
    TASCtrl -->|creates| SvcMonitors

    GORCHCtrl -->|creates| Deployments
    GORCHCtrl -->|creates| Services
    GORCHCtrl -->|creates| SvcMonitors

    NEMOCtrl -->|creates| Deployments
    NEMOCtrl -->|creates| Services

    EVALCtrl -->|creates| Deployments
    EVALCtrl -->|creates| Services
    EVALCtrl -->|creates| RBACRes

    LMESCtrl -->|creates| DriverPod

    %% External integrations
    TASCtrl -->|"patches predictors"| KServeISVC["KServe<br/>InferenceService"]
    TASCtrl -->|"injects env vars"| ModelMesh["ModelMesh<br/>Serving"]
    TASCtrl -->|"creates (conditional)"| Istio["Istio<br/>DestinationRule<br/>VirtualService"]

    GORCHCtrl -->|"auto-discovers ISVCs"| KServeISVC
    GORCHCtrl -->|"introspects"| ServingRuntime["KServe<br/>ServingRuntime"]

    JobMgr -->|"wraps as Workload"| Kueue["Kueue"]

    EVALCtrl -->|"provisions RBAC"| MLFlow["MLFlow"]

    %% Auth sidecar
    AuthProxy["kube-rbac-proxy<br/>sidecar"] -.->|"SAR auth"| Services

    %% Styling
    style Manager fill:#4a90e2,stroke:#333,color:#fff
    style TASCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style LMESCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style GORCHCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style NEMOCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style EVALCtrl fill:#5ba3f5,stroke:#333,color:#fff
    style JobMgr fill:#7bb8f7,stroke:#333,color:#fff
    style FailReconciler fill:#7bb8f7,stroke:#333,color:#fff

    style TrustyAISvc fill:#f5a623,stroke:#333
    style LMEvalJob fill:#f5a623,stroke:#333
    style GOrchCR fill:#f5a623,stroke:#333
    style NemoCR fill:#f5a623,stroke:#333
    style EvalHubCR fill:#f5a623,stroke:#333

    style KServeISVC fill:#7ed321,stroke:#333
    style ModelMesh fill:#7ed321,stroke:#333
    style ServingRuntime fill:#7ed321,stroke:#333
    style Kueue fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style MLFlow fill:#7ed321,stroke:#333
    style AuthProxy fill:#e8e8e8,stroke:#333

    style InitContainer fill:#b8d4f0,stroke:#333
    style MainContainer fill:#b8d4f0,stroke:#333
