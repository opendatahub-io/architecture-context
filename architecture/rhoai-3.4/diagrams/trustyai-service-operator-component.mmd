graph TB
    subgraph Operator["trustyai-service-operator (Go Operator)"]
        direction TB

        subgraph Controllers["Controllers (selectively enabled via --enable-services)"]
            TAS["TAS Controller<br/>TrustyAIService CRs"]
            LMES["LMES Controller<br/>LMEvalJob CRs"]
            JobMgr["Job Manager Controller<br/>Kueue Integration (optional)"]
            GORCH["GORCH Controller<br/>GuardrailsOrchestrator CRs"]
            NEMO["NemoGuardrails Controller<br/>NemoGuardrails CRs"]
            EVALHUB["EvalHub Controller<br/>EvalHub CRs"]
            FailureReconciler["Evaluation Job<br/>Failure Reconciler"]
        end

        Metrics["Metrics Server<br/>:8080/TCP"]
        Health["Health Probes<br/>:8081/TCP"]
    end

    %% CRDs
    TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GORCHCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]
    NEMOCR["NemoGuardrails CR<br/>trustyai.opendatahub.io/v1alpha1"]
    EVALHUBCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% CRD watches
    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    GORCHCR -->|watched by| GORCH
    NEMOCR -->|watched by| NEMO
    EVALHUBCR -->|watched by| EVALHUB

    %% Managed resources - TAS
    TAS -->|creates| TASDeployment["TrustyAI Service<br/>Deployment + kube-rbac-proxy"]
    TAS -->|creates| TASRoute["OpenShift Route<br/>(reencrypt TLS)"]
    TAS -->|patches| InferenceService["KServe InferenceService<br/>(prediction logger)"]
    TAS -->|creates| IstioResources["Istio DestinationRule<br/>+ VirtualService"]
    TAS -->|creates| TASMonitor["ServiceMonitor"]

    %% Managed resources - LMES
    LMES -->|creates| EvalPod["Evaluation Pod<br/>(driver + lm-eval)"]
    JobMgr -->|creates| KueueWorkload["Kueue Workload"]
    EvalPod -->|init copies| DriverBin["ta-lmes-driver binary<br/>(EmptyDir)"]

    %% Managed resources - GORCH
    GORCH -->|creates| GORCHDeploy["GORCH Deployment<br/>(orchestrator + gateway<br/>+ detectors + kube-rbac-proxy)"]
    GORCH -->|creates| GORCHRoutes["OpenShift Routes<br/>(orchestrator, gateway,<br/>health, built-in)"]
    GORCH -->|discovers| ISvcDiscovery["KServe InferenceServices<br/>(auto-config generation)"]

    %% Managed resources - NeMo
    NEMO -->|creates| NemoDeploy["NeMo Server Deployment<br/>+ kube-rbac-proxy"]
    NEMO -->|aggregates| CABundle["CA Bundle<br/>(ODH + OpenShift + user CAs)"]

    %% Managed resources - EvalHub
    EVALHUB -->|creates| EvalHubDeploy["EvalHub API Deployment<br/>+ kube-rbac-proxy (SAR)"]
    EVALHUB -->|manages| TenantNS["Tenant Namespaces<br/>(RBAC, ServiceAccounts)"]
    FailureReconciler -->|watches| BatchJobs["Batch Jobs & Pods<br/>(across tenant namespaces)"]
    FailureReconciler -->|reports to| EvalHubDeploy

    %% Styling
    style Operator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style Controllers fill:#e8eaf6,stroke:#283593,stroke-width:1px
    style TAS fill:#4a90e2,color:#fff
    style LMES fill:#4a90e2,color:#fff
    style JobMgr fill:#4a90e2,color:#fff
    style GORCH fill:#4a90e2,color:#fff
    style NEMO fill:#4a90e2,color:#fff
    style EVALHUB fill:#4a90e2,color:#fff
    style FailureReconciler fill:#4a90e2,color:#fff
    style TrustyAIServiceCR fill:#f5a623
    style LMEvalJobCR fill:#f5a623
    style GORCHCR fill:#f5a623
    style NEMOCR fill:#f5a623
    style EVALHUBCR fill:#f5a623
    style InferenceService fill:#7ed321
    style ISvcDiscovery fill:#7ed321
    style IstioResources fill:#e8e8e8
    style KueueWorkload fill:#e8e8e8
    style TASMonitor fill:#e8e8e8
    style CABundle fill:#e8e8e8
