graph TD
    subgraph Deployment["Deployment (managed by rhods-operator)"]
        RhodsOp["rhods-operator<br/>Deploys sidecar + RBAC"]
    end

    subgraph ServiceAccounts["Service Accounts"]
        ComponentSA["Component Service Account<br/>(e.g., dashboard-sa, model-registry-sa)<br/>Runs kube-auth-proxy sidecar"]
        PromSA["system:serviceaccount:<br/>openshift-monitoring:prometheus-k8s<br/>Hardcoded metrics access"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings<br/>(managed by rhods-operator)"]
        CRB1["Component ClusterRoleBinding<br/>(operator-managed)"]
    end

    subgraph ClusterRoles["Required ClusterRole Permissions"]
        CR_TokenReview["TokenReview Permission"]
        CR_SAR["SubjectAccessReview Permission"]
        CR_OAuth["OAuthAccessToken Permission<br/>(OpenShift mode only)"]
    end

    subgraph APIResources["Kubernetes API Resources"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>Verbs: create"]
        SubjectAccessReviews["authorization.k8s.io<br/>subjectaccessreviews<br/>Verbs: create"]
        OAuthAccessTokens["oauth.openshift.io<br/>oauthaccesstokens<br/>Verbs: get, delete"]
    end

    subgraph HardcodedAuth["Hardcoded Authorization Rules"]
        MetricsRule["/metrics endpoint<br/>Allows prometheus-k8s SA<br/>without SAR check"]
    end

    subgraph Modes["Proxy Modes"]
        AuthMode["kube-auth-proxy (auth mode)<br/>Uses: TokenReview (optional)<br/>Uses: OAuthAccessToken (OpenShift)"]
        RBACMode["kube-rbac-proxy (rbac mode)<br/>Uses: TokenReview (always)<br/>Uses: SubjectAccessReview (always)"]
    end

    %% Deployment flow
    RhodsOp -->|"creates"| CRB1
    RhodsOp -->|"creates"| ComponentSA

    %% RBAC binding flow
    ComponentSA -->|"bound via"| CRB1
    CRB1 -->|"grants"| CR_TokenReview
    CRB1 -->|"grants"| CR_SAR
    CRB1 -->|"grants (OpenShift)"| CR_OAuth

    %% Permission to resource mapping
    CR_TokenReview -->|"create"| TokenReviews
    CR_SAR -->|"create"| SubjectAccessReviews
    CR_OAuth -->|"get, delete"| OAuthAccessTokens

    %% Mode usage
    RBACMode -->|"requires"| CR_TokenReview
    RBACMode -->|"requires"| CR_SAR
    AuthMode -.->|"optional"| CR_TokenReview
    AuthMode -.->|"OpenShift provider"| CR_OAuth

    %% Hardcoded auth
    PromSA -->|"hardcoded allow"| MetricsRule
    MetricsRule -->|"bypasses SAR for"| RBACMode

    %% Styling
    style ComponentSA fill:#4a90e2,stroke:#333,color:#fff
    style PromSA fill:#f5a623,stroke:#333,color:#fff
    style CRB1 fill:#9b59b6,stroke:#333,color:#fff
    style CR_TokenReview fill:#f5a623,stroke:#333
    style CR_SAR fill:#f5a623,stroke:#333
    style CR_OAuth fill:#f5a623,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SubjectAccessReviews fill:#7ed321,stroke:#333
    style OAuthAccessTokens fill:#7ed321,stroke:#333
    style MetricsRule fill:#e74c3c,stroke:#333,color:#fff
    style RhodsOp fill:#999,stroke:#333,color:#fff
    style AuthMode fill:#5dade2,stroke:#333,color:#fff
    style RBACMode fill:#5dade2,stroke:#333,color:#fff
