graph TD
    subgraph PodIdentity["Pod Service Account Identity"]
        SA["Pod Service Account<br/>(configured by rhods-operator<br/>per component)"]
    end

    subgraph RoleBindings["Role Bindings (created by rhods-operator)"]
        CRB1["ClusterRoleBinding<br/>(TokenReview access)"]
        CRB2["ClusterRoleBinding<br/>(SubjectAccessReview access)"]
        CRB3["ClusterRoleBinding<br/>(OAuthAccessToken access)<br/>OpenShift only"]
    end

    subgraph RequiredPermissions["Required API Permissions"]
        TR["authentication.k8s.io<br/>tokenreviews"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        OAT["oauth.openshift.io<br/>oauthaccesstokens"]
    end

    subgraph Verbs["Permitted Verbs"]
        CreateTR["create"]
        CreateSAR["create"]
        DeleteOAT["delete"]
    end

    subgraph ProxyAuthz["Proxy Authorization Models"]
        direction TB

        subgraph AuthModeAuthz["Auth Mode Authorization"]
            AuthChain["Session Chain (first match wins)"]
            M1["1. K8s SA Token → TokenReview API"]
            M2["2. JWT Bearer → OIDC Verification"]
            M3["3. OpenShift OAuth → sha256~ validation"]
            M4["4. Basic Auth → htpasswd file"]
            M5["5. Cookie Session → stored session + refresh"]
            AuthChain --> M1
            AuthChain --> M2
            AuthChain --> M3
            AuthChain --> M4
            AuthChain --> M5
        end

        subgraph RBACModeAuthz["RBAC Mode Authorization"]
            RBACChain["Union Authorizer"]
            R1["1. Hardcoded: prometheus-k8s SA<br/>→ /metrics allowed"]
            R2["2. Static Rules from config file"]
            R3["3. SubjectAccessReview<br/>allow cache: 5min TTL<br/>deny cache: 30s TTL"]
            RBACChain --> R1
            RBACChain --> R2
            RBACChain --> R3
        end
    end

    subgraph HTTPVerbMapping["HTTP → K8s Verb Mapping (rbac mode)"]
        GET["GET → get"]
        POST["POST → create"]
        PUT["PUT → update"]
        PATCH["PATCH → patch"]
        DELETE["DELETE → delete"]
    end

    %% Connections
    SA -->|"bound via"| CRB1
    SA -->|"bound via"| CRB2
    SA -->|"bound via (OpenShift)"| CRB3
    CRB1 -->|"grants"| TR
    CRB2 -->|"grants"| SAR
    CRB3 -->|"grants"| OAT
    TR -->|"verb"| CreateTR
    SAR -->|"verb"| CreateSAR
    OAT -->|"verb"| DeleteOAT

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB1 fill:#f5a623,stroke:#333
    style CRB2 fill:#f5a623,stroke:#333
    style CRB3 fill:#f5a623,stroke:#333,stroke-dasharray: 5 5
    style TR fill:#7ed321,stroke:#333
    style SAR fill:#7ed321,stroke:#333
    style OAT fill:#7ed321,stroke:#333
    style CreateTR fill:#d5e8d4,stroke:#333
    style CreateSAR fill:#d5e8d4,stroke:#333
    style DeleteOAT fill:#d5e8d4,stroke:#333
    style AuthChain fill:#6bb3e0,stroke:#333
    style RBACChain fill:#6bb3e0,stroke:#333
    style M1 fill:#e8e8e8,stroke:#333
    style M2 fill:#e8e8e8,stroke:#333
    style M3 fill:#e8e8e8,stroke:#333
    style M4 fill:#e8e8e8,stroke:#333
    style M5 fill:#e8e8e8,stroke:#333
    style R1 fill:#e8e8e8,stroke:#333
    style R2 fill:#e8e8e8,stroke:#333
    style R3 fill:#e8e8e8,stroke:#333
