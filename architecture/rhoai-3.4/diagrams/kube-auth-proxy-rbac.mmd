%% RBAC Visualization for kube-auth-proxy
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.4/kube-auth-proxy.md

graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Auth["Pod ServiceAccount<br/>(kube-auth-proxy mode)"]
        SA_RBAC["Pod ServiceAccount<br/>(kube-rbac-proxy mode)"]
    end

    subgraph RequiredPermissions["Required API Permissions"]
        direction TB

        subgraph AuthModePerms["kube-auth-proxy Mode<br/>(K8s token validation enabled)"]
            TokenReview1["authentication.k8s.io<br/>tokenreviews"]
        end

        subgraph RBACModePerms["kube-rbac-proxy Mode"]
            TokenReview2["authentication.k8s.io<br/>tokenreviews"]
            SAR["authorization.k8s.io<br/>subjectaccessreviews"]
        end
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        OAuth["OAuth2/OIDC<br/>(cookie session)"]
        Bearer["Bearer Token<br/>(JWT)"]
        Htpasswd["htpasswd<br/>(Basic Auth)"]
        K8sSAToken["K8s SA Token<br/>(TokenReview)"]
        Delegating["Delegating Auth<br/>(TokenReview)"]
        OIDCAuth["OIDC JWT<br/>Validation"]
        X509["X509 Client<br/>Certificate"]
    end

    subgraph AuthzMechanisms["Authorization Mechanisms"]
        SessionPolicy["Session-based<br/>email domain/group<br/>restrictions"]
        ExtAuthz["ext_authz<br/>200 OK / 401 / 403"]
        SARCheck["SubjectAccessReview<br/>Resource attributes"]
    end

    subgraph Secrets["Secrets"]
        OAuthSecret["OAuth Client Secret<br/>(Opaque)<br/>Admin-provisioned"]
        CookieSecret["Cookie Secret<br/>(Opaque)<br/>HMAC key"]
        TLSAuth["TLS Cert - auth-proxy<br/>(kubernetes.io/tls)<br/>cert-manager/Admin"]
        TLSRBAC["TLS Cert - rbac-proxy<br/>(kubernetes.io/tls)<br/>cert-manager, auto-rotate"]
        JWTKey["JWT Signing Key<br/>(Opaque, optional)"]
        SAToken["SA Token<br/>(auto-mounted)<br/>auto-rotate"]
        RedisPass["Redis Password<br/>(Opaque, optional)"]
    end

    %% Auth mode connections
    SA_Auth -->|"requires"| TokenReview1
    TokenReview1 -->|"create"| K8sAPI1["Kubernetes API"]

    %% RBAC mode connections
    SA_RBAC -->|"requires"| TokenReview2
    SA_RBAC -->|"requires"| SAR
    TokenReview2 -->|"create"| K8sAPI2["Kubernetes API"]
    SAR -->|"create"| K8sAPI2

    %% Auth mode uses these mechanisms
    SA_Auth -.->|"supports"| OAuth
    SA_Auth -.->|"supports"| Bearer
    SA_Auth -.->|"supports"| Htpasswd
    SA_Auth -.->|"supports"| K8sSAToken

    %% RBAC mode uses these mechanisms
    SA_RBAC -.->|"supports"| Delegating
    SA_RBAC -.->|"supports"| OIDCAuth
    SA_RBAC -.->|"supports"| X509

    %% Authorization
    OAuth -->|"enforces"| SessionPolicy
    Bearer -->|"ext_authz"| ExtAuthz
    Delegating -->|"checks"| SARCheck
    OIDCAuth -->|"checks"| SARCheck
    X509 -->|"checks"| SARCheck

