graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client<br/>(User / Dashboard)"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        RouteAPI["ds-pipeline-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        RouteMLMD["ds-pipeline-md-{name} Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        RouteMinio["minio-{name} Route<br/>443/TCP → 9000/TCP<br/>TLS Edge"]
    end

    subgraph AuthBoundary["AUTH BOUNDARY (kube-rbac-proxy)"]
        RBACProxy1["kube-rbac-proxy<br/>(API Server sidecar)<br/>8443/TCP TLS<br/>SubjectAccessReview"]
        RBACProxy2["kube-rbac-proxy<br/>(MLMD Envoy sidecar)<br/>8443/TCP TLS<br/>SubjectAccessReview"]
    end

    subgraph DSPMesh["DSP COMPONENT MESH (NetworkPolicy Restricted)<br/>Namespace: {user-namespace}"]
        direction TB

        APIServer["ds-pipeline API Server<br/>SA: ds-pipeline-{name}<br/>8888/TCP, 8887/TCP gRPC"]
        MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP HTTP"]
        MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC<br/>TLS (service-ca)"]
        MariaDBInt["MariaDB<br/>3306/TCP MySQL<br/>TLS (service-ca)"]
        MinioInt["Minio<br/>9000/TCP HTTP<br/>Plaintext"]
        PersistAgent["Persistence Agent"]
        SchedWF["Scheduled Workflow"]
        ArgoCtrl["Argo Workflows Controller"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        DSPOCtrl["DSPO Controller<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        WebhookSvc["ds-pipelines-webhook<br/>443→8443/TCP TLS"]
    end

    subgraph PlatformSvc["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        ServiceCA["OpenShift service-ca<br/>Auto-provisions TLS certs"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        ExtDB["External MariaDB<br/>3306/TCP MySQL<br/>TLS configurable"]
        ExtS3["External S3 Storage<br/>443/TCP HTTPS<br/>S3 access key"]
        OCIReg["OCI Container Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secret"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RouteAPI
    Client -->|"HTTPS/443<br/>TLS"| RouteMLMD

    %% Ingress → Auth
    RouteAPI -->|"HTTPS/8443<br/>Reencrypt<br/>service-ca cert"| RBACProxy1
    RouteMLMD -->|"HTTPS/8443<br/>Reencrypt<br/>service-ca cert"| RBACProxy2

    %% Auth → K8s API (SAR check)
    RBACProxy1 -->|"HTTPS/6443<br/>TLS 1.2+<br/>SAR: DSPA/api"| K8sAPI
    RBACProxy2 -->|"HTTPS/6443<br/>TLS 1.2+<br/>SAR: DSPA/api"| K8sAPI

    %% Auth → DSP Components
    RBACProxy1 -->|"HTTPS/8888<br/>TLS (PodToPodTLS)"| APIServer
    RBACProxy2 -->|"HTTP/9090<br/>Plaintext to Envoy"| MLMDEnvoy

    %% DSP Internal Flows
    APIServer -->|"MySQL/3306<br/>TLS configurable<br/>Password"| MariaDBInt
    APIServer -->|"HTTP/9000<br/>Plaintext<br/>S3 access key"| MinioInt
    APIServer -->|"gRPC/8080<br/>TLS (service-ca)"| MLMDgRPC
    MLMDEnvoy -->|"gRPC/8080<br/>TLS (service-ca)"| MLMDgRPC
    MLMDgRPC -->|"MySQL/3306<br/>TLS configurable<br/>Password"| MariaDBInt
    PersistAgent -->|reads| APIServer
    SchedWF -->|triggers| ArgoCtrl

    %% Operator flows
    DSPOCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    DSPOCtrl -->|"MySQL/3306<br/>Health check"| MariaDBInt
    DSPOCtrl -->|"HTTP/9000<br/>Health check"| MinioInt
    DSPOCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| OCIReg
    ServiceCA -.->|provisions certs| DSPMesh
    CABundle -.->|CA trust| DSPOCtrl

    %% External service flows (when external DB/S3)
    APIServer -.->|"MySQL/3306<br/>TLS"| ExtDB
    APIServer -.->|"HTTPS/443<br/>S3 API"| ExtS3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef dspmesh fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RouteAPI,RouteMLMD,RouteMinio ingress
    class RBACProxy1,RBACProxy2 auth
    class APIServer,MLMDEnvoy,MLMDgRPC,MariaDBInt,MinioInt,PersistAgent,SchedWF,ArgoCtrl dspmesh
    class DSPOCtrl,WebhookSvc operator
    class K8sAPI,ServiceCA,CABundle platform
    class ExtDB,ExtS3,OCIReg externalsvc
