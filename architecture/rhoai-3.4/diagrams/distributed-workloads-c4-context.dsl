// C4 Context Diagram - Distributed Workloads
// Generated by: Claude Opus 4.6
workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs distributed ML training jobs"
        mlEngineer = person "ML Engineer" "Builds and maintains training pipelines"

        distributedWorkloads = softwareSystem "Distributed Workloads" "Container runtime images for distributed ML training and comprehensive E2E test suite" {
            trainingImagesCUDA = container "CUDA Training Images" "UBI9 + CUDA 12.1/12.4/12.8 + PyTorch" "Container Image"
            trainingImagesROCm = container "ROCm Training Images" "UBI9 + ROCm 6.2/6.4 + PyTorch" "Container Image"
            universalImages = container "Universal Training Images (TH06)" "Jupyter Workbench + ML Runtime (CPU/CUDA/ROCm)" "Container Image"
            rayImages = container "Ray Runtime Images" "Ray 2.52.1/2.53.0 + CUDA/ROCm" "Container Image"
            e2eTestSuite = container "E2E Test Suite" "Integration tests for distributed workload stack" "Go Test Framework"
            rayClusterClient = container "Ray Cluster Client" "HTTP client for Ray Dashboard API" "Go Library"
        }

        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages PyTorchJob distributed training" "Internal ODH"
        trainerV2 = softwareSystem "Kubeflow Trainer v2" "Next-gen training job orchestration (TrainJob)" "Internal ODH"
        kuberay = softwareSystem "KubeRay Operator" "Manages Ray clusters and jobs" "Internal ODH"
        kueue = softwareSystem "Kueue" "Job queuing, scheduling, and quota management" "Internal ODH"
        kueueOperator = softwareSystem "Kueue Operator" "Manages Kueue installation on OpenShift" "Internal ODH"
        jobsetController = softwareSystem "JobSet Controller" "Coordinated multi-job training" "Internal ODH"
        dscOperator = softwareSystem "DataScienceCluster Operator" "Platform component lifecycle management" "Internal ODH"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager" "External"

        s3Storage = softwareSystem "S3-compatible Storage" "Dataset and model artifact storage" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Pre-trained model repository" "External"
        konflux = softwareSystem "Konflux CI/CD" "Build system for container images" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API server" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // User interactions
        dataScientist -> distributedWorkloads "Runs distributed training jobs using training images"
        mlEngineer -> distributedWorkloads "Validates distributed workload stack via E2E tests"

        // Internal ODH dependencies
        distributedWorkloads -> trainingOperator "Creates PyTorchJob CRs" "HTTPS/6443"
        distributedWorkloads -> trainerV2 "Creates TrainJob CRs" "HTTPS/6443"
        distributedWorkloads -> kuberay "Creates RayCluster/RayJob CRs" "HTTPS/6443"
        distributedWorkloads -> kueue "Creates ClusterQueue/LocalQueue CRs" "HTTPS/6443"
        distributedWorkloads -> kueueOperator "Creates Kueue CRs" "HTTPS/6443"
        distributedWorkloads -> jobsetController "Creates JobSet CRs" "HTTPS/6443"
        distributedWorkloads -> dscOperator "Reads DataScienceCluster status" "HTTPS/6443"
        distributedWorkloads -> olm "Checks operator versions (CSV)" "HTTPS/6443"

        // External dependencies
        distributedWorkloads -> s3Storage "Upload/download datasets and models" "HTTPS/443"
        distributedWorkloads -> huggingFace "Download pre-trained models" "HTTPS/443"
        distributedWorkloads -> k8sAPI "Cluster interaction" "HTTPS/6443"
        distributedWorkloads -> prometheus "Validate metrics" "HTTPS/9090"
        konflux -> distributedWorkloads "Builds container images"

        // Container relationships
        e2eTestSuite -> rayClusterClient "Uses for Ray job submission"
        e2eTestSuite -> trainingOperator "Tests PyTorchJob workflows"
        e2eTestSuite -> kuberay "Tests RayCluster/RayJob workflows"
        e2eTestSuite -> kueue "Tests quota and scheduling"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container Image" {
                shape RoundedBox
                background #4a90e2
                color #ffffff
            }
            element "Go Test Framework" {
                shape Hexagon
                background #6c8ebf
                color #ffffff
            }
            element "Go Library" {
                shape Component
                background #6c8ebf
                color #ffffff
            }
        }
    }
}
