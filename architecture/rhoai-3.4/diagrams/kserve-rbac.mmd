graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager<br/>(opendatahub)"]
        SA_LLMISVC["llmisvc-controller-manager<br/>(opendatahub)"]
        SA_EPP["{llmisvc}-epp-sa<br/>({service-namespace})"]
        SA_Metrics["kserve-metrics-reader-sa<br/>({namespace})"]
        SA_MN["{llmisvc}-kserve-mn<br/>({service-namespace})"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_LLMISVC["llmisvc-manager-rolebinding<br/>(cluster-scoped)"]
        CRB_EPP["{llmisvc}-epp-auth-rb<br/>(cluster-scoped)"]
        CRB_Metrics["kserve-metrics-reader-role-binding-{ns}<br/>(cluster-scoped)"]
    end

    subgraph RoleBindings["Namespace Role Bindings"]
        RB_EPP["{llmisvc}-epp-rb<br/>({service-namespace})"]
        RB_SCC["{llmisvc}-kserve-mn-scc<br/>(OCP, {service-namespace})"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMISVC["llmisvc-manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_MetricsReader["kserve-metrics-reader-cluster-role"]
    end

    subgraph UserFacingRoles["User-Facing Aggregate ClusterRoles"]
        CR_Admin["kserve-admin"]
        CR_Edit["kserve-edit"]
        CR_View["kserve-view"]
    end

    subgraph SCCs["Security Context Constraints (OCP)"]
        SCC_LLM["openshift-ai-llminferenceservice-scc"]
    end

    %% ─── kserve-controller-manager bindings ──────────────────────
    SA_KServe -->|"bound via"| CRB_KServe
    CRB_KServe -->|"grants"| CR_KServe

    %% ─── llmisvc-controller-manager bindings ─────────────────────
    SA_LLMISVC -->|"bound via"| CRB_LLMISVC
    CRB_LLMISVC -->|"grants"| CR_LLMISVC

    %% ─── EPP service account bindings ────────────────────────────
    SA_EPP -->|"bound via"| RB_EPP
    SA_EPP -->|"bound via"| CRB_EPP
    CRB_EPP -->|"grants"| CR_AuthDelegator

    %% ─── Metrics reader bindings ─────────────────────────────────
    SA_Metrics -->|"bound via"| CRB_Metrics
    CRB_Metrics -->|"grants"| CR_MetricsReader

    %% ─── SCC bindings (OCP) ──────────────────────────────────────
    SA_MN -->|"bound via"| RB_SCC
    RB_SCC -->|"grants use"| SCC_LLM

    %% ─── kserve-manager-role resources ───────────────────────────
    subgraph KServeResources["kserve-manager-role Resources"]
        KR_ISVC["serving.kserve.io<br/>InferenceService<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_SR["serving.kserve.io<br/>ServingRuntime<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_CSR["serving.kserve.io<br/>ClusterServingRuntime<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_Deploy["apps<br/>Deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_Core["core<br/>Services, ConfigMaps,<br/>Secrets, Pods, etc.<br/>varies"]
        KR_Knative["serving.knative.dev<br/>Services<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_Istio["networking.istio.io<br/>VirtualServices<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_GW["gateway.networking.k8s.io<br/>HTTPRoutes<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_HPA["autoscaling<br/>HPA<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_KEDA["keda.sh<br/>ScaledObjects<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_OTEL["opentelemetry.io<br/>Collectors<br/>get,list,watch,create,<br/>update,patch,delete"]
        KR_Webhook["admissionregistration<br/>WebhookConfigs<br/>get,list,watch,create,<br/>update,patch,delete"]
    end

    CR_KServe -->|"manages"| KR_ISVC
    CR_KServe -->|"manages"| KR_SR
    CR_KServe -->|"manages"| KR_CSR
    CR_KServe -->|"manages"| KR_Deploy
    CR_KServe -->|"manages"| KR_Core
    CR_KServe -->|"manages"| KR_Knative
    CR_KServe -->|"manages"| KR_Istio
    CR_KServe -->|"manages"| KR_GW
    CR_KServe -->|"manages"| KR_HPA
    CR_KServe -->|"manages"| KR_KEDA
    CR_KServe -->|"manages"| KR_OTEL
    CR_KServe -->|"manages"| KR_Webhook

    %% ─── llmisvc-manager-role resources ──────────────────────────
    subgraph LLMISVCResources["llmisvc-manager-role Resources"]
        LR_LLMISVC["serving.kserve.io<br/>LLMInferenceService<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_Config["serving.kserve.io<br/>LLMInferenceServiceConfig<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_GW["gateway.networking.k8s.io<br/>HTTPRoutes, Gateways,<br/>GatewayClasses<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_InfPool["inference.networking<br/>InferencePools,<br/>InferenceModels<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_WVA["llmd.ai<br/>VariantAutoscalings<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_Mon["monitoring.coreos.com<br/>PodMonitors,<br/>ServiceMonitors<br/>get,list,watch,create,<br/>update,patch,delete"]
        LR_DestRule["networking.istio.io<br/>DestinationRules (OCP)<br/>get,list,watch,create,<br/>update,delete"]
        LR_SCC["security.openshift.io<br/>SCC (OCP)<br/>use"]
    end

    CR_LLMISVC -->|"manages"| LR_LLMISVC
    CR_LLMISVC -->|"manages"| LR_Config
    CR_LLMISVC -->|"manages"| LR_LWS
    CR_LLMISVC -->|"manages"| LR_GW
    CR_LLMISVC -->|"manages"| LR_InfPool
    CR_LLMISVC -->|"manages"| LR_WVA
    CR_LLMISVC -->|"manages"| LR_Mon
    CR_LLMISVC -->|"manages"| LR_DestRule
    CR_LLMISVC -->|"manages"| LR_SCC

    %% ─── User-facing roles resources ─────────────────────────────
    subgraph UserResources["User-Facing Resources"]
        UR_All["serving.kserve.io<br/>InferenceService,<br/>LLMInferenceService,<br/>LLMInferenceServiceConfig,<br/>ServingRuntime"]
    end

    CR_Admin -->|"get,list,watch,create,<br/>update,patch,delete"| UR_All
    CR_Edit -->|"get,list,watch,create,<br/>update,patch,delete"| UR_All
    CR_View -->|"get,list,watch"| UR_All

