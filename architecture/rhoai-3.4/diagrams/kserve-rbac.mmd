graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_KServe["kserve-controller-manager<br/><i>Namespace: opendatahub</i>"]
        SA_LLMIsvc["llmisvc-controller-manager<br/><i>Namespace: opendatahub</i>"]
        SA_IGAuth["{graph-name}-auth-verifier<br/><i>Namespace: per InferenceGraph</i>"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_KServe["kserve-manager-rolebinding<br/><i>Cluster-scoped</i>"]
        CRB_LLMIsvc["llmisvc-manager-rolebinding<br/><i>Cluster-scoped</i>"]
        CRB_IGAuth["kserve-inferencegraph-auth-verifiers<br/><i>Cluster-scoped</i>"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_Leader["kserve-leader-election-rolebinding<br/><i>Namespace: opendatahub</i>"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_KServe["kserve-manager-role"]
        CR_LLMIsvc["llmisvc-manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Leader["kserve-leader-election-role<br/><i>(Role, not ClusterRole)</i>"]
    end

    %% Bindings
    SA_KServe -->|"bound via"| CRB_KServe
    SA_KServe -->|"bound via"| RB_Leader
    SA_LLMIsvc -->|"bound via"| CRB_LLMIsvc
    SA_IGAuth -->|"bound via"| CRB_IGAuth

    CRB_KServe -->|"grants"| CR_KServe
    CRB_LLMIsvc -->|"grants"| CR_LLMIsvc
    CRB_IGAuth -->|"grants"| CR_AuthDelegator
    RB_Leader -->|"grants"| CR_Leader

    %% kserve-manager-role resources
    subgraph KServeResources["kserve-manager-role Resources"]
        direction LR
        KR_ISVC["serving.kserve.io<br/>InferenceService<br/>InferenceGraph<br/>TrainedModel<br/>ServingRuntime<br/>ClusterServingRuntime<br/>ClusterStorageContainer<br/>LocalModelCache/*"]
        KR_Apps["apps<br/>Deployments"]
        KR_Core["core<br/>Services, ConfigMaps<br/>Secrets, SA, Pods<br/>Events, Namespaces"]
        KR_Knative["serving.knative.dev<br/>Services"]
        KR_Istio["networking.istio.io<br/>VirtualServices"]
        KR_Ingress["networking.k8s.io<br/>Ingresses"]
        KR_GW["gateway.networking.k8s.io<br/>HTTPRoutes"]
        KR_HPA["autoscaling<br/>HorizontalPodAutoscalers"]
        KR_KEDA["keda.sh<br/>ScaledObjects"]
        KR_OTel["opentelemetry.io<br/>OpenTelemetryCollectors"]
        KR_Route["route.openshift.io<br/>Routes"]
        KR_Batch["batch<br/>Jobs"]
    end

    CR_KServe -->|"get,list,watch<br/>create,update<br/>patch,delete"| KR_ISVC
    CR_KServe -->|"full CRUD"| KR_Apps
    CR_KServe -->|"get,list,watch<br/>(some: CRUD)"| KR_Core
    CR_KServe -->|"full CRUD"| KR_Knative
    CR_KServe -->|"full CRUD"| KR_Istio
    CR_KServe -->|"full CRUD"| KR_Ingress
    CR_KServe -->|"full CRUD"| KR_GW
    CR_KServe -->|"full CRUD"| KR_HPA
    CR_KServe -->|"full CRUD"| KR_KEDA
    CR_KServe -->|"full CRUD"| KR_OTel
    CR_KServe -->|"full CRUD"| KR_Route
    CR_KServe -->|"full CRUD"| KR_Batch

    %% llmisvc-manager-role resources
    subgraph LLMIsvcResources["llmisvc-manager-role Resources"]
        direction LR
        LR_LLMISVC["serving.kserve.io<br/>LLMInferenceService<br/>LLMInferenceServiceConfig"]
        LR_LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
        LR_GW2["gateway.networking.k8s.io<br/>HTTPRoutes, Gateways<br/>GatewayClasses"]
        LR_InfExt["inference.networking.*<br/>InferencePools<br/>InferenceObjectives<br/>InferenceModels"]
        LR_WVA["llmd.ai<br/>VariantAutoscalings"]
        LR_Mon["monitoring.coreos.com<br/>PodMonitors<br/>ServiceMonitors"]
        LR_IstioLLM["networking.istio.io<br/>DestinationRules"]
        LR_SCC["security.openshift.io<br/>SecurityContextConstraints<br/><i>(use only)</i>"]
    end

    CR_LLMIsvc -->|"full CRUD"| LR_LLMISVC
    CR_LLMIsvc -->|"full CRUD"| LR_LWS
    CR_LLMIsvc -->|"full CRUD"| LR_GW2
    CR_LLMIsvc -->|"full CRUD"| LR_InfExt
    CR_LLMIsvc -->|"full CRUD"| LR_WVA
    CR_LLMIsvc -->|"full CRUD"| LR_Mon
    CR_LLMIsvc -->|"CRUD (no patch)"| LR_IstioLLM
    CR_LLMIsvc -->|"use"| LR_SCC

    %% Styling
    style SA_KServe fill:#4a90e2,stroke:#333,color:#fff
    style SA_LLMIsvc fill:#4a90e2,stroke:#333,color:#fff
    style SA_IGAuth fill:#4a90e2,stroke:#333,color:#fff
    style CR_KServe fill:#f5a623,stroke:#333
    style CR_LLMIsvc fill:#f5a623,stroke:#333
    style CR_AuthDelegator fill:#f5a623,stroke:#333
    style CR_Leader fill:#f5a623,stroke:#333
    style KR_ISVC fill:#7ed321,stroke:#333
    style KR_Apps fill:#7ed321,stroke:#333
    style KR_Core fill:#7ed321,stroke:#333
    style KR_Knative fill:#7ed321,stroke:#333
    style KR_Istio fill:#7ed321,stroke:#333
    style KR_Ingress fill:#7ed321,stroke:#333
    style KR_GW fill:#7ed321,stroke:#333
    style KR_HPA fill:#7ed321,stroke:#333
    style KR_KEDA fill:#7ed321,stroke:#333
    style KR_OTel fill:#7ed321,stroke:#333
    style KR_Route fill:#7ed321,stroke:#333
    style KR_Batch fill:#7ed321,stroke:#333
    style LR_LLMISVC fill:#7ed321,stroke:#333
    style LR_LWS fill:#7ed321,stroke:#333
    style LR_GW2 fill:#7ed321,stroke:#333
    style LR_InfExt fill:#7ed321,stroke:#333
    style LR_WVA fill:#7ed321,stroke:#333
    style LR_Mon fill:#7ed321,stroke:#333
    style LR_IstioLLM fill:#7ed321,stroke:#333
    style LR_SCC fill:#e74c3c,stroke:#333,color:#fff
