graph TD
    subgraph ServiceAccounts["Service Accounts"]
        KFPSA["KFP Pipeline Runner SA<br/>(provided by KFP installation)"]
        TrainerSA["Training Worker SA<br/>(per-namespace)"]
    end

    subgraph SecretsAccess["Secrets (injected via use_secret_as_env)"]
        S3Secret["s3-secret<br/>Opaque<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>AWS_S3_ENDPOINT"]
        K8sCreds["kubernetes-credentials<br/>Opaque<br/>K8s API creds for<br/>Trainer job mgmt"]
        HFToken["hf-token<br/>Opaque<br/>HuggingFace token<br/>(gated content)"]
        OCISecret["oci-pull-secret-model-download<br/>dockerconfigjson<br/>OCI registry auth"]
        LSSecret["llama-stack-secret<br/>Opaque<br/>LLAMA_STACK_CLIENT_API_KEY<br/>LLAMA_STACK_CLIENT_BASE_URL"]
        TestDataSecret["test-data-secret<br/>Opaque<br/>S3 creds for<br/>AutoRAG test data"]
        InputDataSecret["input-data-secret<br/>Opaque<br/>S3 creds for<br/>AutoRAG input docs"]
    end

    subgraph PipelineSteps["Pipeline Steps (pods scheduled by Argo)"]
        AutoMLSteps["AutoML Components<br/>tabular_data_loader<br/>timeseries_data_loader<br/>autogluon_training"]
        AutoRAGSteps["AutoRAG Components<br/>documents_discovery<br/>text_extraction<br/>rag_optimization<br/>documents_indexing"]
        FinetuneSteps["Finetuning Components<br/>lora / osft / sft"]
        UtilSteps["Utility Components<br/>dataset_download<br/>sdg / lm_eval<br/>model_registry"]
    end

    subgraph RequiredPermissions["Required Kubernetes API Permissions"]
        TrainJobPerms["TrainJob CRD<br/>kubeflow.org/TrainJob<br/>Verbs: create, get,<br/>watch, delete"]
        PodLogPerms["Pods/log<br/>core/v1<br/>Verbs: get"]
        NamespacePerms["Namespaces<br/>core/v1<br/>Verbs: get<br/>(namespace detection)"]
    end

    subgraph ExternalAuth["External Service Auth Mechanisms"]
        AWSIAM["AWS IAM<br/>Credentials via env vars"]
        APIKeyAuth["API Key<br/>Header-based auth"]
        BearerAuth["Bearer Token<br/>HF_TOKEN / SA token"]
        DockerAuth["Docker Config<br/>OCI registry pull"]
        NoAuth["No Auth<br/>Model Registry<br/>HTTP/8080"]
    end

    %% SA to steps
    KFPSA -->|"runs as"| AutoMLSteps
    KFPSA -->|"runs as"| AutoRAGSteps
    KFPSA -->|"runs as"| FinetuneSteps
    KFPSA -->|"runs as"| UtilSteps

    %% Secrets to steps
    S3Secret -->|"env inject"| AutoMLSteps
    S3Secret -->|"env inject"| AutoRAGSteps
    LSSecret -->|"env inject"| AutoRAGSteps
    TestDataSecret -->|"env inject"| AutoRAGSteps
    InputDataSecret -->|"env inject"| AutoRAGSteps
    K8sCreds -->|"env inject"| FinetuneSteps
    HFToken -->|"env inject"| FinetuneSteps
    HFToken -->|"env inject"| UtilSteps
    OCISecret -->|"env inject"| UtilSteps

    %% Finetuning RBAC needs
    FinetuneSteps -->|"requires"| TrainJobPerms
    FinetuneSteps -->|"requires"| PodLogPerms
    FinetuneSteps -->|"requires"| NamespacePerms

    %% Auth mechanisms
    S3Secret -.->|"provides"| AWSIAM
    LSSecret -.->|"provides"| APIKeyAuth
    HFToken -.->|"provides"| BearerAuth
    OCISecret -.->|"provides"| DockerAuth
    UtilSteps -.->|"uses"| NoAuth

    %% Styling
    style KFPSA fill:#4a90e2,stroke:#333,color:#fff
    style TrainerSA fill:#4a90e2,stroke:#333,color:#fff

    style S3Secret fill:#f5a623,stroke:#333
    style K8sCreds fill:#f5a623,stroke:#333
    style HFToken fill:#f5a623,stroke:#333
    style OCISecret fill:#f5a623,stroke:#333
    style LSSecret fill:#f5a623,stroke:#333
    style TestDataSecret fill:#f5a623,stroke:#333
    style InputDataSecret fill:#f5a623,stroke:#333

    style AutoMLSteps fill:#7ed321,stroke:#333
    style AutoRAGSteps fill:#7ed321,stroke:#333
    style FinetuneSteps fill:#7ed321,stroke:#333
    style UtilSteps fill:#7ed321,stroke:#333

    style TrainJobPerms fill:#e74c3c,stroke:#333,color:#fff
    style PodLogPerms fill:#e74c3c,stroke:#333,color:#fff
    style NamespacePerms fill:#e74c3c,stroke:#333,color:#fff

    style NoAuth fill:#f2dede,stroke:#a94442
