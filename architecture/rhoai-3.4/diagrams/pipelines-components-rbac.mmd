graph TD
    subgraph "Pipeline Runner Identity"
        SA["KFP Pipeline Runner<br/>ServiceAccount<br/>(pipeline-runner)"]
    end

    subgraph "Required Permissions (on KFP Runner SA)"
        Perm1["Create/Manage Pods<br/>core/pods<br/>get, list, watch, create, delete"]
        Perm2["Read Secrets<br/>core/secrets<br/>get, list"]
        Perm3["Create PVCs<br/>core/persistentvolumeclaims<br/>get, list, create, delete"]
        Perm4["Submit TrainingJobs<br/>trainer.kubeflow.org/trainingjobs<br/>get, list, watch, create, update"]
    end

    subgraph "Secrets Accessed by Components"
        HFToken["hf-token<br/>(Opaque)<br/>HF_TOKEN env var<br/>Provisioned by: User/Admin"]
        S3Secret["s3-secret<br/>(Opaque)<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>Provisioned by: User/Admin"]
        K8sCreds["kubernetes-credentials<br/>(Opaque)<br/>KUBERNETES_SERVER_URL<br/>KUBERNETES_AUTH_TOKEN<br/>Provisioned by: User/Admin"]
        OCISecret["oci-pull-secret-model-download<br/>(Opaque)<br/>Docker config.json<br/>Provisioned by: User/Admin"]
        GitSecret["git_auth_secret<br/>(Opaque)<br/>Git auth for Konflux<br/>Provisioned by: Konflux/PaC"]
    end

    subgraph "Components Using Secrets"
        DatasetDL["dataset_download"]
        TrainModel["train_model"]
        AutoMLLoader["automl_data_loader"]
        Workers["Training Worker Pods"]
        KonfluxBuild["Konflux Build Pipeline"]
    end

