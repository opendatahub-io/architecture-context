graph TD
    subgraph RuntimeIdentity["Runtime Identity"]
        PipelineRunner["KFP Pipeline Runner<br/>ServiceAccount<br/>(inherited from KFP)"]
    end

    subgraph SecretAccess["Secrets Consumed by Pipeline Steps"]
        direction TB

        subgraph StorageSecrets["Storage Credentials"]
            S3Secret["s3-secret<br/>(Opaque)<br/>access_key_id,<br/>secret_access_key,<br/>endpoint, bucket, region"]
            InputDataSecret["input_data_secret_name<br/>(Opaque)<br/>S3 creds for AutoRAG docs"]
            TestDataSecret["test_data_secret_name<br/>(Opaque)<br/>S3 creds for RAG test data"]
            TrainDataSecret["train_data_secret_name<br/>(Opaque)<br/>S3 creds for AutoML training"]
        end

        subgraph APISecrets["API Credentials"]
            HFToken["hf-token<br/>(Opaque)<br/>HuggingFace API token"]
            LlamaStackSecret["llama_stack_secret_name<br/>(Opaque)<br/>LLAMA_STACK_CLIENT_BASE_URL,<br/>LLAMA_STACK_CLIENT_API_KEY"]
            LLMCredentials["llm-credentials<br/>(Opaque)<br/>LLM_API_KEY for SDG"]
        end

        subgraph K8sSecrets["Kubernetes Credentials"]
            K8sCreds["kubernetes-credentials<br/>(Opaque)<br/>K8s creds for TrainJob<br/>CR management"]
        end

        subgraph BuildSecrets["Build-Time Secrets"]
            GitAuth["git_auth_secret<br/>(Opaque)<br/>Git auth for Konflux<br/>Tekton builds"]
        end
    end

    subgraph SecretProviders["Provisioned By"]
        User["User"]
        RHOAIConnections["RHOAI Connections API"]
        KonfluxPaC["Konflux / PaC"]
    end

    subgraph ExternalAccess["External Service Access"]
        S3Access["S3/MinIO<br/>AWS Signature V4<br/>Bucket-level ACLs"]
        HFAccess["HuggingFace Hub<br/>Bearer Token<br/>Gated model access"]
        LlamaAccess["Llama Stack API<br/>API Key (header)"]
        LiteLLMAccess["LiteLLM API<br/>API Key (env)"]
        K8sAPIAccess["Kubernetes API<br/>ServiceAccount Token<br/>RBAC enforced"]
        ModelRegAccess["Model Registry<br/>No auth (cluster-internal)<br/>Network policy only"]
    end

    %% SA → Secrets
    PipelineRunner -->|"mounts"| S3Secret
    PipelineRunner -->|"mounts"| HFToken
    PipelineRunner -->|"mounts"| K8sCreds
    PipelineRunner -->|"mounts"| LlamaStackSecret
    PipelineRunner -->|"mounts"| LLMCredentials
    PipelineRunner -->|"mounts"| InputDataSecret
    PipelineRunner -->|"mounts"| TestDataSecret
    PipelineRunner -->|"mounts"| TrainDataSecret

    %% Secret provisioning
    User -->|"provisions"| S3Secret
    User -->|"provisions"| HFToken
    User -->|"provisions"| K8sCreds
    User -->|"provisions"| LLMCredentials
    User -->|"provisions"| TrainDataSecret
    RHOAIConnections -->|"provisions"| S3Secret
    RHOAIConnections -->|"provisions"| LlamaStackSecret
    RHOAIConnections -->|"provisions"| InputDataSecret
    RHOAIConnections -->|"provisions"| TestDataSecret
    KonfluxPaC -->|"provisions"| GitAuth

    %% Secrets → External access
    S3Secret -->|"authenticates"| S3Access
    HFToken -->|"authenticates"| HFAccess
    LlamaStackSecret -->|"authenticates"| LlamaAccess
    LLMCredentials -->|"authenticates"| LiteLLMAccess
    K8sCreds -->|"authenticates"| K8sAPIAccess

    %% Styling
    style PipelineRunner fill:#4a90e2,stroke:#333,color:#fff

    style S3Secret fill:#f5a623,stroke:#333
    style HFToken fill:#f5a623,stroke:#333
    style K8sCreds fill:#f5a623,stroke:#333
    style LlamaStackSecret fill:#f5a623,stroke:#333
    style LLMCredentials fill:#f5a623,stroke:#333
    style InputDataSecret fill:#f5a623,stroke:#333
    style TestDataSecret fill:#f5a623,stroke:#333
    style TrainDataSecret fill:#f5a623,stroke:#333
    style GitAuth fill:#f5a623,stroke:#333

    style User fill:#27ae60,stroke:#333,color:#fff
    style RHOAIConnections fill:#27ae60,stroke:#333,color:#fff
    style KonfluxPaC fill:#27ae60,stroke:#333,color:#fff

    style S3Access fill:#e8e8e8,stroke:#333
    style HFAccess fill:#e8e8e8,stroke:#333
    style LlamaAccess fill:#e8e8e8,stroke:#333
    style LiteLLMAccess fill:#e8e8e8,stroke:#333
    style K8sAPIAccess fill:#e8e8e8,stroke:#333
    style ModelRegAccess fill:#e8e8e8,stroke:#333
