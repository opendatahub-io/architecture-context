graph TB
    subgraph External["External Access"]
        Browser[Browser / Client]
    end

    subgraph Gateway["Gateway API Layer"]
        GW["data-science-gateway<br/>HTTPRoute<br/>443/TCP HTTPS"]
    end

    subgraph Pod["odh-dashboard Pod"]
        direction TB

        subgraph AuthProxy["Authentication Layer"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>OAuth Token Validation"]
        end

        subgraph Core["Core Dashboard"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP"]
            Frontend["odh-dashboard Frontend<br/>React/PatternFly 6 SPA"]
            Backend -->|serves| Frontend
        end

        subgraph BFFModules["Module Federation BFF Sidecars"]
            GenAI["gen-ai BFF<br/>Go 1.24<br/>8143/TCP HTTPS"]
            ModelReg["model-registry BFF<br/>Go 1.25<br/>8043/TCP HTTPS"]
            MaaS["maas BFF<br/>Go 1.24<br/>8243/TCP HTTPS"]
            MLflow["mlflow BFF<br/>Go 1.24<br/>8343/TCP HTTPS"]
            EvalHub["eval-hub BFF<br/>Go 1.24<br/>8543/TCP HTTPS"]
            AutoML["automl BFF<br/>Go 1.24<br/>8643/TCP HTTPS"]
            AutoRAG["autorag BFF<br/>Go 1.24<br/>8743/TCP HTTPS"]
        end

        KRBP -->|x-forwarded-access-token| Backend
        Backend -->|proxy /gen-ai/api/*| GenAI
        Backend -->|proxy /model-registry/api/*| ModelReg
        Backend -->|proxy /maas/api/*| MaaS
        Backend -->|proxy /_bff/mlflow/api/*| MLflow
        Backend -->|proxy /eval-hub/api/*| EvalHub
        Backend -->|proxy /automl/api/*| AutoML
        Backend -->|proxy /autorag/api/*| AutoRAG
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApp["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDoc["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQS["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph PlatformServices["Platform Services"]
        K8sAPI["Kubernetes API<br/>443/TCP"]
        Thanos["Thanos Querier<br/>9092/TCP"]
        DSP["Data Science Pipelines<br/>8443/TCP"]
        KServe["KServe<br/>InferenceService"]
        ModelRegSvc["Model Registry<br/>443/TCP"]
        TrustyAI["TrustyAI<br/>443/TCP"]
        LlamaStack["Llama Stack<br/>443/TCP"]
    end

    Browser -->|HTTPS/443| GW
    GW -->|HTTPS/8443| KRBP
    Backend -->|HTTPS/443| K8sAPI
    Backend -->|HTTPS/9092| Thanos
    Backend -->|HTTPS/8443| DSP
    Backend -->|watches| KServe
    Backend -->|HTTPS/443| ModelRegSvc
    Backend -->|HTTPS/443| TrustyAI
    GenAI -->|HTTPS/443| LlamaStack
    Backend -->|watches| OdhConfig
    Backend -->|watches| OdhApp

