graph TB
    subgraph ExternalAccess["External Access"]
        Browser[Browser / User]
    end

    subgraph Gateway["data-science-gateway (Envoy)"]
        HTTPRoute["HTTPRoute<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Pod["odh-dashboard Pod (9 containers, 2 replicas)"]
        direction TB

        subgraph AuthLayer["Authentication Layer"]
            KubeRBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
        end

        subgraph CoreDashboard["Core Dashboard"]
            Backend["Dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP"]
            Frontend["React SPA<br/>PatternFly 6<br/>Module Federation Host"]
            Backend -->|serves| Frontend
        end

        subgraph BFFSidecars["BFF Sidecars (Go, TLS 1.3)"]
            direction LR
            ModelRegBFF["Model Registry BFF<br/>8043/TCP"]
            GenAIBFF["Gen AI BFF<br/>8143/TCP"]
            MaaSBFF["MaaS BFF<br/>8243/TCP"]
            MLflowBFF["MLflow BFF<br/>8343/TCP"]
            EvalHubBFF["Eval Hub BFF<br/>8543/TCP"]
            AutoMLBFF["AutoML BFF<br/>8643/TCP"]
            AutoRAGBFF["AutoRAG BFF<br/>8743/TCP"]
        end

        KubeRBACProxy -->|"x-forwarded headers<br/>HTTP/8080"| Backend
        Backend -->|"/_mf/modelRegistry/*<br/>HTTPS/8043"| ModelRegBFF
        Backend -->|"/_mf/genAi/*<br/>HTTPS/8143"| GenAIBFF
        Backend -->|"/_mf/maas/*<br/>HTTPS/8243"| MaaSBFF
        Backend -->|"/_mf/mlflow/*<br/>HTTPS/8343"| MLflowBFF
        Backend -->|"/_mf/evalHub/*<br/>HTTPS/8543"| EvalHubBFF
        Backend -->|"/_mf/automl/*<br/>HTTPS/8643"| AutoMLBFF
        Backend -->|"/_mf/autorag/*<br/>HTTPS/8743"| AutoRAGBFF
    end

    subgraph CRDs["Custom Resource Definitions"]
        OdhDashboardConfig["OdhDashboardConfig<br/>opendatahub.io/v1alpha"]
        OdhApplication["OdhApplication<br/>dashboard.opendatahub.io/v1"]
        OdhDocument["OdhDocument<br/>dashboard.opendatahub.io/v1"]
        OdhQuickStart["OdhQuickStart<br/>console.openshift.io/v1"]
    end

    subgraph ExternalServices["External / Platform Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP"]
        ModelRegistry["Model Registry API"]
        LlamaStack["LlamaStack"]
        MaaSAPI["MaaS API"]
        MLflow["MLflow Tracking"]
        DSPipelines["Data Science Pipelines"]
        TrustyAI["TrustyAI"]
        S3["S3 Storage"]
        Perses["Perses Dashboards"]
    end

    Browser -->|"HTTPS/443"| HTTPRoute
    HTTPRoute -->|"HTTPS/8443<br/>TLS reencrypt"| KubeRBACProxy

    Backend -->|"HTTPS/6443<br/>User Token"| K8sAPI
    Backend -->|proxy| DSPipelines
    Backend -->|proxy| TrustyAI
    Backend -->|proxy| Perses

    ModelRegBFF -->|"HTTPS/443"| ModelRegistry
    GenAIBFF --> LlamaStack
    GenAIBFF --> MaaSAPI
    GenAIBFF --> MLflow
    MaaSBFF --> MaaSAPI
    MLflowBFF --> MLflow
    AutoMLBFF --> S3
    AutoMLBFF --> DSPipelines
    AutoRAGBFF --> LlamaStack
    AutoRAGBFF --> S3

    Backend -.->|watches| OdhDashboardConfig
    Backend -.->|reads| OdhApplication
    Backend -.->|reads| OdhDocument
    Backend -.->|reads| OdhQuickStart

