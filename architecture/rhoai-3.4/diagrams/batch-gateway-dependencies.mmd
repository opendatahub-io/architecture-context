graph LR
    BGW["Batch Gateway<br/>(API Server + Processor + GC)"]

    %% External Dependencies (Required Infrastructure)
    BGW -->|"metadata storage<br/>5432/TCP, TLS"| PostgreSQL["PostgreSQL 12+"]
    BGW -->|"priority queue<br/>events, status<br/>6379/TCP, TLS"| Redis["Redis 6+"]
    BGW -->|"file storage<br/>443/TCP HTTPS"| S3["S3-compatible Storage<br/>(AWS S3 / MinIO / Ceph RGW)"]

    %% Internal Platform Dependencies
    BGW -->|"inference dispatch<br/>HTTP/HTTPS, Bearer token"| InfScheduler["llm-d-inference-scheduler"]
    BGW -.->|"workload routing<br/>Gateway API"| GIE["gateway-api-inference-extension"]

    %% Infrastructure Dependencies
    BGW -.->|"TLS certificates<br/>Certificate CR"| CertManager["cert-manager"]
    BGW -.->|"external routing<br/>HTTPRoute CR"| GatewayAPI["Gateway API<br/>(parent Gateway)"]

    %% Observability Dependencies
    BGW -.->|"metrics scrape<br/>:8081, :9090 HTTP"| Prometheus["Prometheus"]
    BGW -.->|"traces export<br/>gRPC OTLP"| OTel["OTLP Collector"]
    BGW -.->|"dashboards<br/>ConfigMap"| Grafana["Grafana"]

    %% Alerting
    BGW -.->|"PrometheusRule<br/>HighQueueWait<br/>HighJobFailureRate<br/>ExpiredJobsDetected<br/>WorkersSaturated"| AlertManager["Alert Manager"]

    %% Styling
    style BGW fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External infrastructure (gray)
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff

    %% Internal platform (green)
    style InfScheduler fill:#7ed321,stroke:#333,color:#fff
    style GIE fill:#7ed321,stroke:#333,color:#fff

    %% Observability (yellow)
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style OTel fill:#f5a623,stroke:#333,color:#fff
    style Grafana fill:#f5a623,stroke:#333,color:#fff
    style AlertManager fill:#f5a623,stroke:#333,color:#fff
