graph LR
    BG["Batch Gateway<br/>(API Server + Processor + GC)"]

    %% External Dependencies (Required)
    BG -->|"metadata storage<br/>5432/TCP PostgreSQL"| PostgreSQL["PostgreSQL 12+<br/>(Required)"]
    BG -->|"priority queue, events,<br/>status cache<br/>6379/TCP Redis"| Redis["Redis 6+<br/>(Required)"]

    %% External Dependencies (Optional)
    BG -->|"file storage<br/>443/TCP HTTPS"| S3["S3-compatible Storage<br/>(Production)"]
    BG -->|"TLS certificates<br/>Certificate CRD"| CertManager["cert-manager v1<br/>(Optional)"]
    BG -->|"trace export<br/>4317/TCP gRPC OTLP"| OTel["OpenTelemetry Collector<br/>(Optional)"]
    BG -->|"metrics scraping<br/>ServiceMonitor/PodMonitor"| Prometheus["Prometheus<br/>(Optional)"]
    BG -->|"dashboards<br/>JSON ConfigMaps"| Grafana["Grafana<br/>(Optional)"]

    %% Internal Platform Dependencies
    BG -->|"inference dispatch<br/>HTTP/HTTPS Bearer token"| InfGW["Inference Gateway<br/>(llm-d / vLLM)"]
    BG -.->|"ingress exposure<br/>HTTPRoute CRD"| GatewayAPI["Gateway API<br/>(Kubernetes)"]
    BG -.->|"flow control header<br/>x-gateway-inference-objective"| GIE["GIE InferenceObjective<br/>(CRD reference)"]

    %% Integration Points (consumed by)
    EnvoyAuth["Envoy ext_authz"] -.->|"external auth<br/>pass-through headers"| BG

    style BG fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style OTel fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style Grafana fill:#999,stroke:#333,color:#fff
    style InfGW fill:#9b59b6,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style GIE fill:#7ed321,stroke:#333,color:#fff
    style EnvoyAuth fill:#e8e8e8,stroke:#333
