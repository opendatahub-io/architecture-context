graph TB
    subgraph "vLLM CPU Component"
        direction TB
        subgraph "API Layer"
            APIServer["vllm-openai<br/>(FastAPI + Uvicorn)<br/>Port 8000/TCP"]
            GRPCServer["vllm-grpc<br/>(gRPC Server)<br/>Port 50051/TCP"]
        end

        subgraph "Engine Layer"
            AsyncLLM["vLLM Engine<br/>(v1 AsyncLLM)<br/>PagedAttention + Continuous Batching"]
            ZMQ["ZeroMQ IPC<br/>(Frontend Multiprocessing)"]
        end

        subgraph "Execution Layer"
            ModelExecutor["Model Executor<br/>150+ Model Architectures<br/>Weight Management"]
            CSRCKernels["csrc Kernels<br/>(C/C++ Extensions)<br/>CPU-Optimized Attention/Quantization"]
        end

        APIServer -->|"in-process or ZMQ"| ZMQ
        GRPCServer -->|"in-process or ZMQ"| ZMQ
        ZMQ --> AsyncLLM
        AsyncLLM --> ModelExecutor
        ModelExecutor --> CSRCKernels
    end

    %% External Clients
    Client[External Client] -->|"HTTPS/443<br/>OAuth/OIDC"| Gateway
    Gateway["RHOAI Gateway<br/>(Envoy)<br/>HTTPRoute"] -->|"HTTPS/8443"| KubeRBACProxy
    KubeRBACProxy["kube-rbac-proxy<br/>(Sidecar)"] -->|"HTTP/8000"| APIServer

    %% Model Sources
    ModelExecutor -->|"HTTPS/443<br/>HF_TOKEN"| HFHub["Hugging Face Hub"]
    ModelExecutor -->|"HTTPS/443<br/>AWS IAM"| S3["S3-Compatible Storage"]

    %% Observability
    APIServer -->|"/metrics<br/>HTTP/8000"| Prometheus["Prometheus"]
    AsyncLLM -->|"gRPC/4317<br/>OTLP"| OTel["OpenTelemetry Collector"]

    %% Platform
    KServe["KServe<br/>(ServingRuntime)"] -.->|manages lifecycle| APIServer

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style GRPCServer fill:#4a90e2,stroke:#333,color:#fff
    style AsyncLLM fill:#4a90e2,stroke:#333,color:#fff
    style ModelExecutor fill:#4a90e2,stroke:#333,color:#fff
    style CSRCKernels fill:#4a90e2,stroke:#333,color:#fff
    style ZMQ fill:#4a90e2,stroke:#333,color:#fff
    style Gateway fill:#ffe6cc,stroke:#d79b00
    style KubeRBACProxy fill:#ffe6cc,stroke:#d79b00
    style HFHub fill:#e8e8e8,stroke:#999
    style S3 fill:#e8e8e8,stroke:#999
    style Prometheus fill:#7ed321,stroke:#333
    style OTel fill:#7ed321,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style Client fill:#f9f9f9,stroke:#999
