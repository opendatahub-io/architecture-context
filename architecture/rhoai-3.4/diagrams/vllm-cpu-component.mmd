graph TB
    subgraph External["External Access"]
        Client[Client / Data Scientist]
    end

    subgraph KServePlatform["KServe Platform Layer"]
        KServeGW["KServe Gateway<br/>443/TCP HTTPS"]
        KServeIS["InferenceService CR"]
        StorageInit["Model Storage Initializer<br/>(init container)"]
    end

    subgraph VllmCPU["vLLM CPU Service"]
        subgraph APIServer["vllm-openai (FastAPI/Uvicorn)"]
            ChatAPI["/v1/chat/completions"]
            CompletionsAPI["/v1/completions"]
            EmbeddingsAPI["/v1/embeddings"]
            ModelsAPI["/v1/models"]
            ResponsesAPI["/v1/responses"]
            MessagesAPI["/v1/messages"]
            HealthAPI["/health"]
            MetricsAPI["/metrics"]
            LoRAAPI["/v1/load_lora_adapter<br/>/v1/unload_lora_adapter"]
        end

        Engine["AsyncLLM Engine (v1)<br/>Model Loading | Scheduling<br/>Batching | Token Generation"]

        subgraph Kernels["C/C++ CPU Kernels (csrc/)"]
            Attention["CPU Attention"]
            Quantization["Quantization"]
            MoE["MoE Kernels"]
        end

        GrpcServer["gRPC Server<br/>50051/TCP<br/>(optional)"]
        OTelTracing["OpenTelemetry Tracing"]
        PromMetrics["Prometheus Metrics<br/>Middleware"]
    end

    subgraph ExternalServices["External Services"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS"]
        OTLPCollector["OTLP Collector<br/>4317/TCP gRPC"]
        Prometheus["Prometheus"]
    end

    %% Flows
    Client -->|HTTPS/443| KServeGW
    KServeGW -->|HTTP/8000| APIServer
    KServeIS -->|manages lifecycle| VllmCPU
    StorageInit -->|shared volume| Engine

    ChatAPI --> Engine
    CompletionsAPI --> Engine
    EmbeddingsAPI --> Engine
    ResponsesAPI --> Engine
    MessagesAPI --> Engine
    Engine --> Kernels

    GrpcServer --> Engine
    PromMetrics --> MetricsAPI

    Engine -->|model download| HFHub
    Engine -->|model download| S3
    OTelTracing -->|trace export| OTLPCollector
    Prometheus -->|scrapes /metrics| MetricsAPI

    %% Styling
    style Client fill:#f9f9f9,stroke:#999,stroke-width:2px
    style KServeGW fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style KServeIS fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style StorageInit fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style Engine fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style APIServer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style GrpcServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style OTelTracing fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PromMetrics fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style HFHub fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style S3 fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style OTLPCollector fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Prometheus fill:#fff2cc,stroke:#d6b656,stroke-width:2px
