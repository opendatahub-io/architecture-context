graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token / OIDC / SA Token"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph ControllerPod["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>Image: quay.io/opendatahub/trainer:odh-3.4.0<br/>FIPS: strictfipsruntime + UBI9"]
            WebhookSvc["Webhook Server<br/>ClusterIP 443→9443/TCP<br/>TLS (auto-rotated, cert-controller)<br/>Auth: API Server client cert"]
            MetricsSvc["Metrics Server<br/>ClusterIP 8443/TCP<br/>TLS (self-signed)<br/>Auth: None (insecureSkipVerify)"]
            HealthSvc["Health Probes<br/>8081/TCP HTTP<br/>No encryption<br/>/healthz, /readyz"]
        end

        PodMonitor["Prometheus / PodMonitor<br/>Scrapes 8443/TCP HTTPS"]
    end

    subgraph UserNS["USER NAMESPACE ({user-namespace})"]
        direction TB

        subgraph TrainingPods["Training Pods (JobSet managed)<br/>NetworkPolicy: per-TrainJob"]
            MasterPod["Training Pod (node-0)<br/>29500/TCP rendezvous<br/>28080/TCP metrics (HTTP)"]
            WorkerPod["Training Worker Pods<br/>Dynamic/TCP NCCL"]
        end

        subgraph DataCacheOpt["Data Cache (Optional)"]
            DCHead["data-cache (head)<br/>8080/TCP health<br/>Dynamic gRPC Arrow Flight<br/>Image: ghcr.io/.../data-cache:v2.1.0"]
            DCWorker["data-cache (worker)<br/>8080/TCP health<br/>Dynamic gRPC Arrow Flight"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registries<br/>quay.io, ghcr.io<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Pull secret"]
        IcebergStore["Iceberg Storage (Optional)<br/>S3/GCS/HDFS<br/>Auth: Varies"]
    end

    %% Flows - External to Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token / OIDC"| K8sAPI

    %% Flows - Control Plane to Operator
    K8sAPI -->|"HTTPS/9443<br/>TLS auto-rotated<br/>API Server client cert<br/>FailurePolicy: Fail"| WebhookSvc

    %% Flows - Operator to Control Plane
    ControllerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRD reconciliation + resource mgmt"| K8sAPI

    %% Flows - Operator to User Namespace
    ControllerPod -->|"HTTP/28080<br/>No encryption<br/>NetworkPolicy restricted<br/>Progression tracking"| MasterPod

    %% Flows - Monitoring
    PodMonitor -->|"HTTPS/8443<br/>TLS self-signed<br/>insecureSkipVerify"| MetricsSvc

    %% Flows - Training Inter-Pod
    WorkerPod -->|"TCP/29500<br/>No encryption<br/>torchrun rendezvous"| MasterPod
    MasterPod <-->|"TCP/Dynamic<br/>NCCL all-reduce<br/>No encryption"| WorkerPod

    %% Flows - Data Cache
    DCHead -->|"gRPC/Dynamic<br/>Arrow Flight<br/>No encryption"| DCWorker
    MasterPod -->|"gRPC/Dynamic<br/>Arrow Flight"| DCHead
    MasterPod -->|"gRPC/Dynamic<br/>Arrow Flight"| DCWorker
    DCHead -->|"Varies<br/>Iceberg metadata"| IcebergStore

    %% Flows - External Services
    UserNS -.->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret<br/>(kubelet pulls)"| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class User external
    class K8sAPI controlplane
    class WebhookSvc,MetricsSvc,HealthSvc operatorns
    class MasterPod,WorkerPod,DCHead,DCWorker userns
    class Registry,IcebergStore externalservice
    class PodMonitor monitoring
