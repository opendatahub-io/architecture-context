graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Platform UI"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP<br/>TLS 1.2+<br/>RBAC AuthZ"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        Controller["trainer-controller-manager<br/>SA: kubeflow-trainer-controller-manager<br/>FIPS: strictfipsruntime + CGO_ENABLED=1"]

        subgraph ControllerPorts["Controller Ports"]
            WebhookPort["9443/TCP Webhook<br/>HTTPS TLS<br/>API server client cert"]
            MetricsPort["8443/TCP Metrics<br/>HTTPS TLS<br/>No auth"]
            HealthPort["8081/TCP Health<br/>HTTP plaintext<br/>No auth"]
        end

        Controller --- ControllerPorts
    end

    subgraph UserNS["USER NAMESPACE (per-TrainJob NetworkPolicy isolation)"]
        direction TB

        subgraph TrainingWorkload["Training Workload (JobSet)"]
            Master["Training Pod 0 (Master/Rank-0)<br/>29500/TCP NCCL + 28080/TCP Metrics"]
            Worker1["Training Pod 1 (Worker)<br/>29500/TCP NCCL"]
            WorkerN["Training Pod N (Worker)<br/>29500/TCP NCCL"]
        end

        NetPol["NetworkPolicy<br/>Ingress: same JobSet + controller only"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["OpenShift Monitoring<br/>Prometheus<br/>PodMonitor scrape"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (RBAC)"| K8sAPI

    %% Control Plane → Operator
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server client cert"| WebhookPort

    %% Operator → Control Plane
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (Bearer)<br/>CRD CRUD, JobSet mgmt,<br/>Pod listing, NetworkPolicy mgmt"| K8sAPI

    %% Operator → Training Pods (RHAI)
    Controller -->|"HTTP/28080<br/>plaintext<br/>No auth (NetworkPolicy)<br/>RHAI progression polling"| Master

    %% Inter-pod training communication
    Master -->|"TCP/29500<br/>plaintext<br/>NCCL/gRPC<br/>NetworkPolicy restricted"| Worker1
    Master -->|"TCP/29500<br/>plaintext<br/>NCCL/gRPC<br/>NetworkPolicy restricted"| WorkerN

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>PodMonitor scrape"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dce6f5,stroke:#4a6fa5,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Controller,WebhookPort,MetricsPort,HealthPort operator
    class Master,Worker1,WorkerN userns
    class Prometheus monitoring
    class NetPol netpol
