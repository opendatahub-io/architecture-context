graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        EPP["llm-d-inference-scheduler<br/>(EPP)<br/>Upstream Router"]
    end

    subgraph DecoderPod["DECODER POD (Sidecar Boundary)"]
        direction TB

        subgraph SidecarContainer["Sidecar Container"]
            Sidecar["llm-d-routing-sidecar<br/>8000/TCP · HTTPS · TLS 1.2+<br/>Curated Cipher Suites<br/>CGO_ENABLED=0 (upstream)"]

            subgraph SSRF["SSRF Protection (Optional)"]
                Allowlist["AllowlistValidator<br/>InferencePool-based<br/>Host-only validation<br/>30s resync"]
            end
        end

        subgraph DecoderContainer["Decoder Container"]
            Decoder["vLLM Decoder<br/>8001/TCP · HTTP(S)<br/>localhost"]
        end
    end

    subgraph ClusterNetwork["CLUSTER NETWORK (Pod-to-Pod)"]
        Prefiller["vLLM Prefiller Pod(s)<br/>Configurable Port<br/>HTTP(S) · Optional TLS 1.2+"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP · HTTPS · TLS<br/>ServiceAccount Token Auth"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        PodAPI["Pod Resources<br/>(Matching Selectors)"]
    end

    subgraph OpenShiftIngress["OPENSHIFT INGRESS (Optional)"]
        Route["OpenShift Route<br/>443/TCP · TLS Edge<br/>→ Service 8080/TCP"]
        Service["ClusterIP Service<br/>8080/TCP · HTTP<br/>No encryption"]
    end

    %% Ingress flows
    EPP -->|"HTTPS/8000<br/>TLS 1.2+<br/>No App Auth<br/>x-prefiller-host-port header"| Sidecar

    %% Internal pod flow
    Sidecar -->|"HTTP(S)/8001<br/>Optional TLS<br/>localhost<br/>No Auth"| Decoder

    %% Remote prefill flow
    Sidecar -->|"HTTP(S)/Configurable<br/>Optional TLS 1.2+<br/>SSRF Validated<br/>No Auth"| Prefiller

    %% K8s API flows (conditional)
    Allowlist -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>Watch"| APIServer
    APIServer --- InferencePool
    APIServer --- PodAPI

    %% OpenShift ingress
    Route -->|"TLS Edge<br/>Termination"| Service
    Service -->|"HTTP/8080"| Sidecar

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#4a90e2,stroke:#2c5f8a,stroke-width:2px,color:#fff
    classDef decoder fill:#7ed321,stroke:#5a9e18,stroke-width:2px,color:#fff
    classDef prefiller fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    classDef ssrf fill:#e74c3c,stroke:#c0392b,stroke-width:1px,color:#fff
    classDef k8s fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class EPP external
    class Sidecar sidecar
    class Decoder decoder
    class Prefiller prefiller
    class Allowlist ssrf
    class APIServer,InferencePool,PodAPI k8s
    class Route,Service ingress
