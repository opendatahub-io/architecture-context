graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client /<br/>Upstream Gateway"]
    end

    subgraph Ingress["INGRESS"]
        Route["OpenShift Route<br/>443/TCP → 8080/TCP<br/>TLS edge termination"]
        Service["ClusterIP Service<br/>8080/TCP<br/>Internal only"]
    end

    subgraph SidecarProxy["SIDECAR PROXY (llm-d-routing-sidecar)"]
        direction TB
        Listener["Proxy Listener<br/>8000/TCP HTTPS<br/>TLS 1.2+ min<br/>6 AEAD cipher suites<br/>Cert: external or self-signed RSA-4096"]

        subgraph SSRFProtection["SSRF Protection (optional)"]
            Allowlist["AllowlistValidator<br/>Validates prefiller IP<br/>against InferencePool pods<br/>403 if not in allowlist"]
        end
    end

    subgraph LocalPod["LOCAL POD"]
        Decoder["vLLM Decoder<br/>8001/TCP<br/>HTTP or HTTPS<br/>TLS 1.2+ (configurable)<br/>InsecureSkipVerify: false"]
    end

    subgraph RemotePods["REMOTE PODS"]
        Prefiller["vLLM Prefiller<br/>Variable Port<br/>HTTP or HTTPS<br/>TLS 1.2+ (configurable)<br/>InsecureSkipVerify: false"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS edge"| Route
    Route -->|"HTTP/8080<br/>Internal"| Service
    Service -->|"HTTP/8080"| Listener

    %% P/D flow
    Listener -->|"Validate IP"| Allowlist
    Allowlist -->|"Phase 1: Prefill<br/>HTTP(S) / Variable port<br/>TLS 1.2+ (configurable)<br/>No auth"| Prefiller
    Allowlist -->|"Phase 2: Decode<br/>HTTP(S)/8001<br/>TLS 1.2+ (configurable)<br/>No auth"| Decoder

    %% Direct flow
    Listener -->|"Direct passthrough<br/>HTTP(S)/8001<br/>TLS 1.2+ (configurable)<br/>No auth"| Decoder

    %% Control plane
    Allowlist -->|"Watch InferencePool + Pods<br/>HTTPS/443<br/>TLS<br/>ServiceAccount token<br/>30s resync"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef localpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef remotepod fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef ssrf fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Route,Service ingress
    class Listener sidecar
    class Allowlist ssrf
    class Decoder localpod
    class Prefiller remotepod
    class K8sAPI controlplane
