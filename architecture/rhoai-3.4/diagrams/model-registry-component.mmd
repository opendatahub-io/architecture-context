graph TB
    subgraph ModelRegistry["Model Registry Platform"]
        direction TB

        subgraph CoreService["Core API Service"]
            Proxy["model-registry (proxy)<br/>Go REST API<br/>Port: 8080/TCP"]
            DynRouter["Dynamic Router<br/>503 → full API"]
            EmbedMD["EmbedMD Datastore<br/>GORM ORM"]
            Proxy --> DynRouter
            Proxy --> EmbedMD
        end

        subgraph Controller["Controller Manager"]
            CtrlMgr["controller-manager<br/>Go Controller<br/>Port: 8081/TCP (health)<br/>Port: 8443/TCP (metrics)"]
        end

        subgraph CSI["CSI Storage Initializer"]
            StorageInit["mr-storage-initializer<br/>Go CLI<br/>Resolves model-registry:// URIs"]
        end

        subgraph AsyncJob["Async Upload Job"]
            AsyncUpload["async-upload job<br/>Python 3.12<br/>Batch Job"]
        end

        subgraph UI["Web Interface"]
            MRUI["model-registry-ui<br/>TypeScript/Go<br/>Frontend + BFF<br/>Port: 8080/TCP"]
        end

        subgraph Catalog["Model Catalog"]
            CatalogSvc["catalog<br/>Go REST API<br/>Model curation"]
        end
    end

    %% External Users
    User["Data Scientist / Client"]
    KServe["KServe<br/>(InferenceService CR)"]

    %% Database Backends
    MySQL["MySQL 8.3+<br/>Port: 3306/TCP"]
    PostgreSQL["PostgreSQL 16+<br/>Port: 5432/TCP"]

    %% External Storage
    S3["S3-compatible Storage<br/>Port: 443/TCP"]
    OCI["OCI Registries<br/>Port: 443/TCP"]
    Sigstore["Sigstore/Rekor<br/>Port: 443/TCP"]

    %% Infrastructure
    K8sAPI["Kubernetes API<br/>Port: 6443/TCP"]
    IstioGW["Kubeflow Gateway<br/>(Istio VirtualService)"]

    %% User flows
    User -->|"REST API calls"| IstioGW
    IstioGW -->|"HTTP/8080<br/>Istio mTLS"| Proxy
    User -->|"Browse UI"| MRUI
    MRUI -->|"REST API"| Proxy

    %% Database connections
    EmbedMD -->|"TCP/3306<br/>username/password"| MySQL
    EmbedMD -->|"TCP/5432<br/>username/password"| PostgreSQL

    %% Controller flows
    K8sAPI -->|"Watch stream<br/>InferenceService CRs"| CtrlMgr
    CtrlMgr -->|"HTTP/8080<br/>Bearer Token"| Proxy

    %% CSI flows
    KServe -->|"Init container"| StorageInit
    StorageInit -->|"HTTP/8080<br/>Resolve URI"| Proxy
    StorageInit -->|"Download model"| S3

    %% Async job flows
    AsyncUpload -->|"HTTP/8080<br/>Register metadata"| Proxy
    AsyncUpload -->|"HTTPS/443"| S3
    AsyncUpload -->|"HTTPS/443"| OCI
    AsyncUpload -->|"HTTPS/443<br/>Signing"| Sigstore

    %% Styling
    style Proxy fill:#4a90e2,stroke:#333,color:#fff
    style CtrlMgr fill:#4a90e2,stroke:#333,color:#fff
    style StorageInit fill:#4a90e2,stroke:#333,color:#fff
    style AsyncUpload fill:#9b59b6,stroke:#333,color:#fff
    style MRUI fill:#3498db,stroke:#333,color:#fff
    style CatalogSvc fill:#4a90e2,stroke:#333,color:#fff
    style EmbedMD fill:#2ecc71,stroke:#333,color:#fff
    style DynRouter fill:#2ecc71,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style OCI fill:#e8e8e8,stroke:#333
    style Sigstore fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style IstioGW fill:#e8e8e8,stroke:#333
    style KServe fill:#7ed321,stroke:#333
    style User fill:#f9f9f9,stroke:#333
