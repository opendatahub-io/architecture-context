graph TB
    subgraph ModelRegistry["Model Registry Component"]
        direction TB

        subgraph APIServer["REST API Server (Go)"]
            Router["Chi Router<br/>8080/TCP HTTP"]
            OpenAPI["OpenAPI v1alpha3<br/>REST Interface"]
            Middleware["Validation Middleware"]
            ProxyRouter["Dynamic Proxy Router"]
            Router --> OpenAPI
            Router --> Middleware
            Router --> ProxyRouter
        end

        subgraph DataStore["Embedded Metadata Datastore"]
            EmbedMD["embedmd Service<br/>GORM ORM"]
            TypeSync["Type Synchronizer<br/>13 MLMD Types"]
            Migrator["Schema Migrator"]
            EmbedMD --> TypeSync
            EmbedMD --> Migrator
        end

        subgraph Controller["InferenceService Controller (Go)"]
            Reconciler["ISVC Reconciler<br/>controller-runtime"]
            HealthProbe["Health Probes<br/>8081/TCP"]
            MetricsEndpoint["Metrics<br/>8443/TCP HTTPS"]
        end

        subgraph CSI["mr-storage-initializer (Go CLI)"]
            MRProvider["model-registry:// Provider"]
            APIClient["MR API Client"]
            MRProvider --> APIClient
        end

        subgraph AsyncUpload["async-upload Job (Python)"]
            Entrypoint["Entrypoint<br/>multi-intent pattern"]
            Download["Download Module<br/>S3/OCI/HuggingFace"]
            Upload["Upload Module<br/>S3/OCI"]
            Signing["Sigstore Signing"]
            MRClient["MR SDK Client"]
            Entrypoint --> Download
            Entrypoint --> Upload
            Entrypoint --> Signing
            Entrypoint --> MRClient
        end

        OpenAPI --> EmbedMD
    end

    %% External Resources
    User["Data Scientist / Client"] -->|"REST API calls"| Router
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"] -->|"watched by"| Reconciler
    Reconciler -->|"syncs metadata via HTTP"| Router
    APIClient -->|"resolves model-registry:// URIs"| Router
    MRClient -->|"registers artifacts via REST"| Router

    %% Database
    EmbedMD -->|"MySQL 3306/TCP<br/>or PostgreSQL 5432/TCP"| Database[(MySQL 8.3+ / PostgreSQL 16+)]

    %% External Services
    Download -->|"HTTPS/443"| S3["S3 Storage"]
    Download -->|"HTTPS/443"| OCI["OCI Registry"]
    Download -->|"HTTPS/443"| HF["HuggingFace Hub"]
    Upload -->|"HTTPS/443"| OCIDest["OCI Registry (dest)"]
    Signing -->|"HTTPS/443"| Sigstore["Sigstore<br/>(Fulcio/Rekor/TUF)"]

    %% KServe integration
    MRProvider -->|"delegates download"| KServeProvider["KServe Built-in<br/>Storage Provider"]

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style DataStore fill:#3a7bd5,stroke:#333,color:#fff
    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style CSI fill:#4a90e2,stroke:#333,color:#fff
    style AsyncUpload fill:#9b59b6,stroke:#333,color:#fff
    style Database fill:#f5a623,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCI fill:#e8e8e8,stroke:#333
    style HF fill:#e8e8e8,stroke:#333
    style OCIDest fill:#e8e8e8,stroke:#333
    style Sigstore fill:#e8e8e8,stroke:#333
    style User fill:#7ed321,stroke:#333
    style KServeProvider fill:#e8e8e8,stroke:#333
