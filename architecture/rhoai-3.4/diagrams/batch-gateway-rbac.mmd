graph TD
    subgraph ServiceAccounts["Service Accounts (per Helm chart)"]
        SA_API["batch-gateway-apiserver<br/>ServiceAccount"]
        SA_PROC["batch-gateway-processor<br/>ServiceAccount"]
        SA_GC["batch-gateway-gc<br/>ServiceAccount"]
    end

    subgraph RBACNote["RBAC Configuration"]
        Note["No ClusterRole or Role resources<br/>defined in Helm chart.<br/>Relies on external RBAC<br/>configuration or workload identity."]
    end

    subgraph TenantIsolation["Application-Level Tenant Isolation"]
        direction TB
        TenantMW["Tenant Middleware<br/>Extracts X-MaaS-Username header"]

        subgraph Endpoints["Protected Endpoints"]
            BatchEndpoints["/v1/batches/*<br/>GET, POST"]
            FileEndpoints["/v1/files/*<br/>GET, POST, DELETE"]
            CancelEndpoint["/v1/batches/{id}/cancel<br/>POST"]
        end

        subgraph Policy["Isolation Policy"]
            TenantScope["All DB queries scoped by tenant_id<br/>Cross-tenant access returns 404<br/>(not 403 — prevents info leakage)"]
        end

        subgraph PassThrough["Pass-Through Auth"]
            ExtAuth["External auth headers captured<br/>(e.g., Envoy ext_authz)<br/>Forwarded to inference gateway<br/>Stored for audit trail"]
        end

        TenantMW --> BatchEndpoints
        TenantMW --> FileEndpoints
        TenantMW --> CancelEndpoint
        BatchEndpoints --> TenantScope
        FileEndpoints --> TenantScope
        CancelEndpoint --> TenantScope
        BatchEndpoints --> ExtAuth
    end

    subgraph UnauthEndpoints["Unauthenticated Endpoints"]
        Health["/health<br/>:8081 (apiserver)<br/>:9090 (processor)"]
        Ready["/ready<br/>:8081 (apiserver)<br/>:9090 (processor)"]
        Metrics["/metrics<br/>:8081 (apiserver)<br/>:9090 (processor)"]
    end

    subgraph Secrets["Secrets Access"]
        BGWSecrets["batch-gateway-secrets (Opaque)<br/>Mount: /etc/.secrets<br/>Keys: redis-url, postgresql-url,<br/>inference-api-key, s3-secret-access-key<br/>Auto-Rotate: No"]
        TLSSecret["batch-gateway-apiserver-tls (tls)<br/>TLS cert + key (when enabled)<br/>Auto-Rotate: Yes (cert-manager)"]
    end

    SA_API --> TenantMW
    SA_API --> UnauthEndpoints
    SA_API -.-> RBACNote

    SA_API -->|mounts| BGWSecrets
    SA_PROC -->|mounts| BGWSecrets
    SA_GC -->|mounts| BGWSecrets
    SA_API -->|mounts| TLSSecret

    %% Styling
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PROC fill:#7ed321,stroke:#333,color:#fff
    style SA_GC fill:#f5a623,stroke:#333,color:#fff
    style TenantMW fill:#e8e8e8,stroke:#333
    style TenantScope fill:#d5e8d4,stroke:#82b366
    style Note fill:#fff2cc,stroke:#d6b656
    style BGWSecrets fill:#f8cecc,stroke:#b85450
    style TLSSecret fill:#f8cecc,stroke:#b85450
    style ExtAuth fill:#dae8fc,stroke:#6c8ebf
