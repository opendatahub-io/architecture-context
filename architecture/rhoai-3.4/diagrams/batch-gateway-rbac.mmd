graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["No Kubernetes RBAC defined"]
        L2["User-space application"]
    end

    subgraph ServiceAccounts["Service Accounts (automount enabled)"]
        SA_API["{release}-apiserver<br/>ServiceAccount"]
        SA_PROC["{release}-processor<br/>ServiceAccount"]
        SA_GC["{release}-gc<br/>ServiceAccount"]
    end

    subgraph Components["Components"]
        APIServer["API Server<br/>Port: 8000/TCP, 8081/TCP"]
        Processor["Batch Processor<br/>Port: 9090/TCP (obs)"]
        GC["Garbage Collector<br/>No network listeners"]
    end

    subgraph TenantAuth["Tenant-Level Authorization (Application Layer)"]
        TenantHeader["Tenant Header Extraction<br/>X-MaaS-Username (configurable)"]
        TenantScope["Tenant-Scoped DB Queries<br/>All lookups filtered by tenant ID"]
        PassThrough["Pass-Through Headers<br/>Captured at batch creation<br/>Forwarded to inference gateway"]
    end

    subgraph SecretAccess["Secrets Accessed"]
        BGSecrets["batch-gateway-secrets (Opaque)<br/>- redis-url<br/>- postgresql-url<br/>- s3-secret-access-key<br/>- inference-api-key<br/>Provisioned: Manual | Rotate: No"]
        TLSSecret["{release}-apiserver-tls (kubernetes.io/tls)<br/>- tls.crt<br/>- tls.key<br/>Provisioned: cert-manager | Rotate: Yes"]
    end

    SA_API --> APIServer
    SA_PROC --> Processor
    SA_GC --> GC

    APIServer --> TenantHeader
    TenantHeader --> TenantScope
    APIServer --> PassThrough

    APIServer -->|"volume mount"| BGSecrets
    APIServer -->|"volume mount (optional)"| TLSSecret
    Processor -->|"volume mount"| BGSecrets
    GC -->|"volume mount"| BGSecrets

    subgraph Note["RBAC Note"]
        RBACNote["Batch Gateway does NOT define ClusterRoles,<br/>ClusterRoleBindings, Roles, or RoleBindings.<br/>It operates as a user-space application with<br/>no Kubernetes API access.<br/><br/>Authentication is handled externally<br/>(Envoy ext_authz) and tenant isolation<br/>is enforced at the application layer."]
    end

    style SA_API fill:#4a90e2,color:#fff
    style SA_PROC fill:#4a90e2,color:#fff
    style SA_GC fill:#4a90e2,color:#fff
    style APIServer fill:#438dd5,color:#fff
    style Processor fill:#7ed321,color:#fff
    style GC fill:#f5a623,color:#fff
    style BGSecrets fill:#e74c3c,color:#fff
    style TLSSecret fill:#e74c3c,color:#fff
    style TenantHeader fill:#f39c12,color:#fff
    style TenantScope fill:#f39c12,color:#fff
    style PassThrough fill:#f39c12,color:#fff
    style RBACNote fill:#fff3cd,stroke:#856404
