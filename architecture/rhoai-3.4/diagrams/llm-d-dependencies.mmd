graph LR
    LLMD["llm-d<br/>Inference Serving Stack"]

    %% Core Runtime Dependencies (Required)
    LLMD -->|"model engine<br/>(embedded)"| vLLM["vLLM v0.19.1"]
    LLMD -->|"KV-cache transfer<br/>RDMA/TCP 5600"| NIXL["NIXL v1.0.0"]
    LLMD -->|"transport layer"| UCX["UCX v1.20.0"]
    LLMD -->|"GPU-to-GPU comm<br/>InfiniBand"| NVSHMEM["NVSHMEM v3.5.19-1"]
    LLMD -->|"GPU-direct RDMA"| GDRCopy["GDRCopy v2.5.2"]

    %% Optional Performance Libraries
    LLMD -.->|"MoE expert kernels"| DeepEP["DeepEP<br/>(neuralmagic fork)"]
    LLMD -.->|"GEMM kernels"| DeepGEMM["DeepGEMM"]
    LLMD -.->|"attention kernels"| FlashInfer["FlashInfer v0.6.6"]
    LLMD -.->|"KV-cache offload"| LMCache["LMCache v0.4.4-cu13"]
    LLMD -.->|"remote memory"| InfiniStore["InfiniStore 0.2.33"]

    %% Platform Dependencies (Required)
    LLMD -->|"routing 8081/TCP"| EPP["llm-d Inference<br/>Scheduler (EPP) v0.8.0"]
    LLMD -->|"P/D coordination<br/>8000/TCP"| RoutingSidecar["llm-d Routing<br/>Sidecar v0.7.1"]
    LLMD -->|"load balancing<br/>80/TCP"| GatewayAPI["Kubernetes<br/>Gateway API v1"]
    LLMD -->|"endpoint selection"| InferencePool["InferencePool CRD<br/>(gateway-api-inference-ext)"]

    %% Optional Platform Dependencies
    LLMD -.->|"multi-node GPU<br/>5555/TCP"| LWS["LeaderWorkerSet v1<br/>(x-k8s.io)"]
    LLMD -.->|"tracing 4317/TCP"| OTel["OpenTelemetry SDK<br/>≥1.39.1"]
    LLMD -.->|"metrics scraping"| PromOp["Prometheus Operator<br/>(PodMonitor)"]

    %% Gateway Providers (choose one)
    GatewayAPI -->|"data plane"| Istio["Istio<br/>(Gateway provider)"]
    GatewayAPI -->|"data plane"| AgentGW["AgentGateway<br/>(Gateway provider)"]
    GatewayAPI -->|"data plane"| GKE["GKE<br/>(Gateway provider)"]

    %% Autoscaling
    LLMD -.->|"SLO-aware scaling<br/>8443/TCP"| WVA["Workload Variant<br/>Autoscaler (WVA)"]

    %% External Services
    LLMD -->|"model downloads<br/>HTTPS 443"| HFHub["HuggingFace Hub"]

    %% ROCm variant
    LLMD -.->|"ROCm KV-cache"| RIXL["RIXL<br/>(ROCm NIXL impl)"]

    %% Styling
    style LLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Core required (dark)
    style vLLM fill:#2c3e50,stroke:#333,color:#fff
    style NIXL fill:#2c3e50,stroke:#333,color:#fff
    style UCX fill:#2c3e50,stroke:#333,color:#fff
    style NVSHMEM fill:#2c3e50,stroke:#333,color:#fff
    style GDRCopy fill:#2c3e50,stroke:#333,color:#fff

    %% Optional performance (lighter)
    style DeepEP fill:#7f8c8d,stroke:#333,color:#fff
    style DeepGEMM fill:#7f8c8d,stroke:#333,color:#fff
    style FlashInfer fill:#7f8c8d,stroke:#333,color:#fff
    style LMCache fill:#7f8c8d,stroke:#333,color:#fff
    style InfiniStore fill:#7f8c8d,stroke:#333,color:#fff
    style RIXL fill:#7f8c8d,stroke:#333,color:#fff

    %% Internal llm-d ecosystem (green)
    style EPP fill:#7ed321,stroke:#333,color:#fff
    style RoutingSidecar fill:#7ed321,stroke:#333,color:#fff
    style WVA fill:#7ed321,stroke:#333,color:#fff

    %% Platform (orange)
    style GatewayAPI fill:#f5a623,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
    style LWS fill:#f5a623,stroke:#333,color:#fff

    %% Gateway providers (grey)
    style Istio fill:#999,stroke:#333,color:#fff
    style AgentGW fill:#999,stroke:#333,color:#fff
    style GKE fill:#999,stroke:#333,color:#fff

    %% External services
    style HFHub fill:#fff2cc,stroke:#d6b656
    style OTel fill:#e1d5e7,stroke:#9673a6
    style PromOp fill:#e1d5e7,stroke:#9673a6
