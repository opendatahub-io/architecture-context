graph TB
    subgraph PodBoundary["POD BOUNDARY (Inference Scheduler Pod)"]
        direction TB

        Scheduler["llm-d-inference-scheduler<br/>Embeds kvcache.Indexer + kvevents.Pool<br/>SA: (consuming deployment)"]
        UDSTokenizer["UDS Tokenizer Sidecar<br/>Image: odh-llm-d-kv-cache-rhel9<br/>Python 3.12 / vLLM CPU<br/>Health: 8082/TCP HTTP"]
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL (Trusted)"]
        direction TB

        subgraph vLLMFleet["vLLM Pod Fleet"]
            vLLM1["vLLM Pod 1<br/>ZMQ PUB 5557/TCP"]
            vLLM2["vLLM Pod 2<br/>ZMQ PUB 5557/TCP"]
            vLLMN["vLLM Pod N<br/>ZMQ PUB 5557/TCP"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]

        subgraph OptionalBackends["Optional Backends"]
            Redis["Redis / Valkey<br/>6379/TCP<br/>Optional TLS (rediss://)"]
        end

        subgraph PVCComponents["Optional: PVC-backed KV-Cache Pod"]
            PVCEvictor["PVC Evictor<br/>N+2 processes<br/>No network ports"]
            FSBackend["llmd_fs_backend<br/>CUDA tensor I/O<br/>Shared PVC/NFS"]
        end
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC"]
        Prometheus["Prometheus<br/>HTTP metrics scrape"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+"]
    end

    %% Pod-internal flow
    Scheduler -->|"gRPC over UDS<br/>/tmp/tokenizer/tokenizer-uds.socket<br/>No encryption, No auth<br/>(filesystem permissions)"| UDSTokenizer

    %% ZMQ event ingestion
    vLLM1 -->|"ZMQ PUB/SUB<br/>5557/TCP<br/>msgpack<br/>No encryption, No auth"| Scheduler
    vLLM2 -->|"ZMQ PUB/SUB<br/>5557/TCP<br/>No encryption"| Scheduler
    vLLMN -->|"ZMQ PUB/SUB<br/>5557/TCP<br/>No encryption"| Scheduler

    %% Kubernetes API
    Scheduler -->|"HTTPS/443<br/>TLS<br/>SA Token<br/>pods: get,list,watch"| K8sAPI

    %% Optional Redis
    Scheduler -.->|"Redis/6379<br/>Optional TLS (rediss://)<br/>No auth (URL creds)"| Redis

    %% Observability
    Scheduler -.->|"gRPC/4317<br/>Insecure (default)<br/>No auth"| OTLP
    Scheduler -.->|"HTTP metrics<br/>No encryption"| Prometheus

    %% External egress
    UDSTokenizer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (optional)"| HFHub

    %% PVC Evictor
    PVCEvictor -.->|"local disk I/O<br/>/mnt/pvc"| FSBackend

    %% Styling
    classDef podInternal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef clusterService fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:1px,stroke-dasharray: 5 5
    classDef external fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef platform fill:#f5f5f5,stroke:#666,stroke-width:2px

    class Scheduler,UDSTokenizer podInternal
    class vLLM1,vLLM2,vLLMN clusterService
    class K8sAPI platform
    class Redis,PVCEvictor,FSBackend optional
    class OTLP,Prometheus observability
    class HFHub external
