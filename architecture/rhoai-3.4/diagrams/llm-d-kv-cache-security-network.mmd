graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Ingress["INGRESS (OpenShift Route)"]
        Route["OpenShift Route<br/>Edge TLS Termination<br/>→ 8080/TCP backend"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph KVCachePod["Pod: llm-d-kv-cache (StatefulSet)<br/>Namespace: ${NAMESPACE}"]
            direction TB

            subgraph GoContainer["Container: KV-Cache Manager (Go)"]
                Indexer["KV-Cache Indexer<br/>8080/TCP HTTP<br/>No encryption, No auth"]
                EventPool["KV Events Pool<br/>5557/TCP ZMQ SUB<br/>No encryption, No auth"]
                IndexerGRPC["Indexer gRPC<br/>50051/TCP gRPC<br/>grpc.WithInsecure()"]
            end

            subgraph PythonContainer["Container: UDS Tokenizer (Python)<br/>Image: quay.io/rhoai/odh-llm-d-kv-cache-rhel9"]
                TokenizerGRPC["gRPC Server<br/>UDS: /tmp/tokenizer/*.socket<br/>No encryption (UDS)<br/>File perms UID 65532"]
                HealthEndpoint["Health Check<br/>8082/TCP HTTP<br/>No auth"]
            end

            SharedVol["Shared Volume: emptyDir<br/>/tmp/tokenizer/"]
        end

        subgraph InferencePods["vLLM/SGLang Inference Pods"]
            VLLMPod["vLLM Pod<br/>ZMQ PUB 5557/TCP"]
            SGLangPod["SGLang Pod<br/>ZMQ PUB 5557/TCP"]
        end

        subgraph PlatformServices["Platform Services"]
            Scheduler["llm-d-inference-scheduler<br/>Go API (in-process)<br/>Indexer.GetPodScores()"]
            K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>mTLS (ServiceAccount)"]
            Prometheus["Prometheus<br/>HTTP scrape 8080/TCP"]
        end
    end

    subgraph OptionalExternal["OPTIONAL EXTERNAL SERVICES"]
        Redis["Redis/Valkey<br/>6379/TCP RESP<br/>No encryption default<br/>TLS via rediss://<br/>Redis ACL optional"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>Insecure default"]
    end

    %% External flows
    PythonContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Ingress
    Route -->|"HTTP/8080<br/>No encryption<br/>No auth"| Indexer

    %% Pod-internal UDS
    GoContainer -->|"gRPC over UDS<br/>No encryption<br/>File permissions"| TokenizerGRPC

    %% Cluster-internal flows
    VLLMPod -->|"ZMQ PUB/SUB 5557/TCP<br/>MessagePack<br/>Plaintext, No auth"| EventPool
    SGLangPod -->|"ZMQ PUB/SUB 5557/TCP<br/>MessagePack<br/>Plaintext, No auth"| EventPool
    Scheduler -->|"Go library API<br/>In-process call"| Indexer
    K8sAPI -->|"HTTPS/6443<br/>mTLS<br/>ServiceAccount token"| EventPool
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>GET /metrics"| Indexer

    %% Optional external
    GoContainer -->|"RESP/6379<br/>No encryption default<br/>TLS optional (rediss://)"| Redis
    GoContainer -->|"gRPC OTLP/4317<br/>Insecure default"| OTEL

    %% Styling - Trust zones
    classDef external fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef gocomp fill:#4a90e2,stroke:#333,color:#fff
    classDef pycomp fill:#f5a623,stroke:#333

    class HFHub external
    class Route ingress
    class VLLMPod,SGLangPod,Scheduler,K8sAPI,Prometheus internal
    class Indexer,EventPool,IndexerGRPC gocomp
    class TokenizerGRPC,HealthEndpoint pycomp
    class Redis,OTEL optional
