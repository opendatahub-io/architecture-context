graph TB
    subgraph "Caikit-NLP Library"
        direction TB

        subgraph "Text Generation Modules"
            PeftPromptTuning["PeftPromptTuning<br/>(Local PEFT Training + Inference)"]
            PeftTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS Inference)"]
            TextGenLocal["TextGeneration<br/>(Local HF Inference)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS Inference)"]
        end

        subgraph "Embedding Modules"
            EmbeddingModule["EmbeddingModule<br/>(sentence-transformers)"]
            CrossEncoder["CrossEncoderModule<br/>(cross-encoder reranking)"]
        end

        subgraph "Classification Modules"
            SeqClassification["SequenceClassification"]
            TokenClassification["FilteredSpanClassification"]
        end

        subgraph "Tokenization Modules"
            RegexSplitter["RegexSentenceSplitter"]
        end

        subgraph "Resources"
            PretrainedBase["PretrainedModelBase"]
            HFCausalLM["HFAutoCausalLM"]
            HFSeq2SeqLM["HFAutoSeq2SeqLM"]
            HFSeqClassifier["HFAutoSequenceClassifier"]
            PretrainedBase --> HFCausalLM
            PretrainedBase --> HFSeq2SeqLM
            PretrainedBase --> HFSeqClassifier
        end

        subgraph "Model Management"
            TGISAutoFinder["TGISAutoFinder<br/>(local vs remote detection)"]
        end

        subgraph "Toolkit"
            ModelRunUtils["model_run_utils"]
            TGISUtils["tgis_utils"]
            TorchRun["torch_run<br/>(distributed training)"]
            TrainerUtils["trainer_utils"]
            VerbalizerUtils["verbalizer_utils"]
        end
    end

    %% Internal connections
    PeftPromptTuning -->|"uses"| HFCausalLM
    PeftPromptTuning -->|"uses"| HFSeq2SeqLM
    PeftTGIS -->|"uses"| TGISUtils
    TextGenLocal -->|"uses"| ModelRunUtils
    TextGenTGIS -->|"uses"| TGISUtils
    EmbeddingModule -->|"uses"| ModelRunUtils
    TGISAutoFinder -->|"detects backend"| PeftTGIS
    TGISAutoFinder -->|"detects backend"| TextGenTGIS

    %% External integrations
    CaikitRuntime["Caikit Runtime<br/>(gRPC: 8085 / HTTP: 8080)"]
    CaikitRuntime -->|"discovers & serves"| PeftPromptTuning
    CaikitRuntime -->|"discovers & serves"| PeftTGIS
    CaikitRuntime -->|"discovers & serves"| TextGenLocal
    CaikitRuntime -->|"discovers & serves"| TextGenTGIS
    CaikitRuntime -->|"discovers & serves"| EmbeddingModule
    CaikitRuntime -->|"discovers & serves"| CrossEncoder
    CaikitRuntime -->|"discovers & serves"| SeqClassification
    CaikitRuntime -->|"discovers & serves"| TokenClassification
    CaikitRuntime -->|"discovers & serves"| RegexSplitter

    Client["Client"] -->|"HTTP :8080 / gRPC :8085"| CaikitRuntime

    TGISBackend["TGIS Backend<br/>(gRPC)"]
    TGISUtils -->|"gRPC (optional TLS/mTLS)"| TGISBackend

    HFHub["HuggingFace Hub<br/>(HTTPS :443)"]
    HFCausalLM -->|"model downloads"| HFHub
    HFSeq2SeqLM -->|"model downloads"| HFHub
    EmbeddingModule -->|"model downloads"| HFHub

    KServeModelMesh["KServe / ModelMesh<br/>(Deployment Platform)"]
    KServeModelMesh -->|"deploys & manages"| CaikitRuntime

    %% Styling
    style CaikitRuntime fill:#4a90e2,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style TGISBackend fill:#999,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333
    style KServeModelMesh fill:#7ed321,stroke:#333
    style PeftPromptTuning fill:#e8d5f5,stroke:#7b4ea3
    style PeftTGIS fill:#e8d5f5,stroke:#7b4ea3
    style TextGenLocal fill:#e8d5f5,stroke:#7b4ea3
    style TextGenTGIS fill:#e8d5f5,stroke:#7b4ea3
    style EmbeddingModule fill:#d5e8f5,stroke:#4a7ba3
    style CrossEncoder fill:#d5e8f5,stroke:#4a7ba3
    style TGISAutoFinder fill:#fff2cc,stroke:#d6b656
