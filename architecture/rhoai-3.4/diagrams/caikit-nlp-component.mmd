graph TB
    subgraph CaikitNLP["caikit-nlp Library"]
        direction TB

        subgraph TextGen["Text Generation Modules"]
            TextGenLocal["TextGeneration<br/>(Local HuggingFace)"]
            TextGenTGIS["TextGenerationTGIS<br/>(Remote TGIS)"]
            PeftPT["PeftPromptTuning<br/>(Local PEFT Training)"]
            PeftPTTGIS["PeftPromptTuningTGIS<br/>(Remote TGIS + PEFT)"]
        end

        subgraph EmbedMods["Embedding Modules"]
            EmbeddingMod["EmbeddingModule<br/>(sentence-transformers)<br/>7 tasks: Embed, Similarity,<br/>Rerank, Tokenize"]
            CrossEncoder["CrossEncoderModule<br/>(Cross-Encoder Reranking)"]
        end

        subgraph ClassMods["Classification Modules"]
            SeqClass["SequenceClassification<br/>(HuggingFace AutoModel)"]
            TokenClass["FilteredSpanClassification<br/>(Token/Span Classification)"]
        end

        subgraph TokenMods["Tokenization"]
            RegexSplitter["RegexSentenceSplitter"]
        end

        subgraph Resources["Resources"]
            PretrainedBase["PretrainedModelBase"]
            HFCausalLM["HFAutoCausalLM"]
            HFSeq2Seq["HFAutoSeq2SeqLM"]
            HFSeqClassifier["HFAutoSequenceClassifier"]
            PretrainedBase --> HFCausalLM
            PretrainedBase --> HFSeq2Seq
            PretrainedBase --> HFSeqClassifier
        end

        subgraph ModelMgmt["Model Management"]
            TGISFinder["TGISAutoFinder<br/>(Auto model discovery)"]
        end

        subgraph Toolkit["Toolkit"]
            TGISClient["TGISGenerationClient<br/>(gRPC Client)"]
            TorchRun["torch_run<br/>(Distributed Training)"]
        end
    end

    %% Internal relationships
    TextGenLocal -->|uses| HFCausalLM
    TextGenLocal -->|uses| HFSeq2Seq
    TextGenTGIS -->|inherits| TextGenLocal
    TextGenTGIS -->|delegates to| TGISClient
    PeftPT -->|uses| HFCausalLM
    PeftPT -->|trains via| TorchRun
    PeftPTTGIS -->|inherits| PeftPT
    PeftPTTGIS -->|delegates to| TGISClient
    TGISFinder -->|routes to| TextGenTGIS
    TGISFinder -->|routes to| PeftPTTGIS
    SeqClass -->|uses| HFSeqClassifier

    %% External interfaces
    Client[Client] -->|HTTP 8080/TCP| HTTPServer["caikit HTTP Server<br/>(8080/TCP)"]
    Client -->|gRPC 8085/TCP| GRPCServer["caikit gRPC Server<br/>(8085/TCP)"]

    HTTPServer -->|loads modules| CaikitNLP
    GRPCServer -->|loads modules| CaikitNLP

    TGISClient -->|gRPC| TGISServer["TGIS Server<br/>(Remote)"]
    EmbeddingMod -->|loads| STModels["sentence-transformers<br/>Models"]
    TextGenLocal -->|loads| HFModels["HuggingFace<br/>Models"]
    PeftPT -->|downloads| HFHub["HuggingFace Hub<br/>(443/HTTPS)"]

    %% Styling
    style CaikitNLP fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    style TextGen fill:#e0f2fe,stroke:#0284c7
    style EmbedMods fill:#e0f2fe,stroke:#0284c7
    style ClassMods fill:#e0f2fe,stroke:#0284c7
    style TokenMods fill:#e0f2fe,stroke:#0284c7
    style Resources fill:#fef3c7,stroke:#d97706
    style ModelMgmt fill:#fce7f3,stroke:#db2777
    style Toolkit fill:#fce7f3,stroke:#db2777

    style HTTPServer fill:#4ade80,stroke:#166534
    style GRPCServer fill:#4ade80,stroke:#166534
    style Client fill:#f9fafb,stroke:#6b7280
    style TGISServer fill:#d1d5db,stroke:#374151
    style STModels fill:#d1d5db,stroke:#374151
    style HFModels fill:#d1d5db,stroke:#374151
    style HFHub fill:#fbbf24,stroke:#92400e
