graph LR
    PP["AI Gateway<br/>Payload Processing<br/>(BBR ext_proc)"]

    %% External Dependencies (required, compiled/runtime)
    PP -->|"plugin framework<br/>ext_proc server"| BBR["Gateway API<br/>Inference Extension<br/>(BBR) v1.5.0-rc.2"]
    PP -->|"K8s client<br/>reconciler framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    PP -->|"core API types<br/>(Secret, etc.)"| K8sAPI["k8s.io/api<br/>v0.35.4"]
    PP -->|"ext_proc gRPC calls<br/>runtime dependency"| Envoy["Envoy<br/>(via Istio)"]

    %% Internal Platform Dependencies
    PP -->|"watches ExternalModel CRDs<br/>(model → provider mapping)"| MaaS["MaaS Controller<br/>(models-as-a-service)"]
    PP -->|"watches labeled Secrets<br/>(bbr-managed=true)"| K8sSecrets["Kubernetes Secrets<br/>(provider API keys)"]
    PP -->|"EnvoyFilter attaches<br/>ext_proc to Gateway"| IstioGW["Istio Gateway<br/>+ EnvoyFilter"]
    PP -->|"HTTP POST<br/>input rail checks"| NemoGR["NeMo Guardrails<br/>Service"]

    %% Integration Points (consumers of payload processing)
    IstioGW -->|"forwards mutated<br/>requests"| Providers["External AI<br/>Providers"]
    MaaS -->|"creates"| ExternalModelCR["ExternalModel CRDs<br/>(maas.opendatahub.io)"]
    ExternalModelCR -->|"watched by"| PP

    %% Upstream BBR plugin dependency
    BBRPlugin["body-field-to-header<br/>(upstream BBR plugin)"] -->|"extracts model name<br/>before custom plugins"| PP

    %% Kuadrant integration
    Kuadrant["Kuadrant<br/>(rate limiting)"] -.->|"WASM filter<br/>anchor for EnvoyFilter"| IstioGW

    %% External AI Providers detail
    subgraph ProviderList["External AI Providers"]
        direction TB
        OpenAI["OpenAI<br/>(Bearer token)"]
        Anthropic["Anthropic<br/>(x-api-key)"]
        Azure["Azure OpenAI<br/>(api-key header)"]
        Vertex["Vertex AI<br/>(Bearer token)"]
        Bedrock["Amazon Bedrock<br/>(Bearer token)"]
    end

    Providers --- ProviderList

    style PP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style BBR fill:#999,stroke:#333
    style ControllerRuntime fill:#999,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Envoy fill:#999,stroke:#333
    style MaaS fill:#7ed321,stroke:#333
    style K8sSecrets fill:#7ed321,stroke:#333
    style IstioGW fill:#7ed321,stroke:#333
    style NemoGR fill:#7ed321,stroke:#333
    style ExternalModelCR fill:#f5a623,stroke:#333
    style BBRPlugin fill:#999,stroke:#333
    style Kuadrant fill:#999,stroke:#333
    style Providers fill:#f5a623,stroke:#333
    style OpenAI fill:#fff2cc,stroke:#d6b656
    style Anthropic fill:#fff2cc,stroke:#d6b656
    style Azure fill:#fff2cc,stroke:#d6b656
    style Vertex fill:#fff2cc,stroke:#d6b656
    style Bedrock fill:#fff2cc,stroke:#d6b656
