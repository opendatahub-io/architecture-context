    DSP -.->|"alt DB<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>12+"]
    DSP -.->|"TLS certs"| CertManager["cert-manager"]
    DSP -.->|"cloud storage<br/>443/TCP"| AWSS3["AWS S3"]
    DSP -.->|"cloud storage<br/>443/TCP"| GCS["GCS"]

    %% Internal RHOAI Dependencies
    DSPAOperator["DSPA Operator"] -->|"deploys & configures<br/>CRD lifecycle"| DSP
