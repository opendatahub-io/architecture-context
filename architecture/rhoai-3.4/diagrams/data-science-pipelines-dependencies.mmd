graph LR
    DSP["Data Science Pipelines<br/>(Kubeflow Pipelines v2)"]

    %% External Dependencies (Required)
    DSP -->|"execution engine<br/>Workflow CRs"| Argo["Argo Workflows<br/>v3.7.11"]
    DSP -->|"metadata storage<br/>TCP/3306"| MySQL["MySQL 5.7+/8.0+"]
    DSP -->|"metadata storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 12+"]
    DSP -->|"artifact storage<br/>HTTP(S)/9000,443"| S3["MinIO / S3 / GCS"]
    DSP -->|"execution lineage<br/>gRPC/8080"| MLMD["ML Metadata<br/>(MLMD)"]
    DSP -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    DSP -->|"orchestration platform<br/>HTTPS/443"| K8s["Kubernetes 1.31+"]

    %% Internal RHOAI Dependencies
    DSPO["DSPO<br/>(Operator)"] -->|"deploys via<br/>DSPA CR"| DSP
    RHOAIOp["RHOAI Operator"] -->|"manages lifecycle"| DSPO
    GatewayAPI["Gateway API<br/>(HTTPRoute)"] -->|"platform ingress<br/>HTTPS/443"| DSP
    KubeRBACProxy["kube-rbac-proxy"] -.->|"auth sidecar"| DSP

    %% Optional Integration Points
    Dashboard["ODH Dashboard"] -->|"UI management"| DSP
    DSP -.->|"model serving<br/>(optional)"| Seldon["Seldon<br/>(optional)"]

    %% Monitoring
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>HTTP/8888,9090"| DSP

    %% Styling
    style DSP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style MySQL fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style MLMD fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style K8s fill:#999,stroke:#333,color:#fff
    style DSPO fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style GatewayAPI fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Seldon fill:#f5a623,stroke:#333
    style Prometheus fill:#e1d5e7,stroke:#9673a6
