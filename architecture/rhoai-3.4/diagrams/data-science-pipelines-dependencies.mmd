    %% External optional (lighter grey)
    style PostgreSQL fill:#bbb,stroke:#333,color:#fff
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style AWSS3 fill:#f5a623,stroke:#333,color:#fff
