// C4 Context Diagram: vllm-orchestrator-gateway
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/vllm-orchestrator-gateway.md

workspace {
    model {
        client = person "API Client" "Application or user sending OpenAI-compatible chat completion requests"

        gateway = softwareSystem "vLLM Orchestrator Gateway" "HTTP gateway that routes chat completion requests through configurable detector pipelines for content filtering" {
            configLoader = container "Config Loader" "Reads YAML config defining orchestrator connection, detectors, and routes" "Rust (config.rs)"
            requestRouter = container "Request Router" "Dynamically registers POST endpoints per configured route" "axum Router"
            streamingHandler = container "Streaming Handler" "Processes Server-Sent Events for streaming chat completions" "Rust SSE"
            apiTypes = container "API Types" "Request/response data structures for orchestrator communication" "Rust (api.rs)"
            tlsBuilder = container "TLS Client Builder" "Builds mTLS-capable HTTP client for orchestrator communication" "Rust/OpenSSL"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Performs chat completion with content detection using configured detector pipelines" "Internal RHOAI"
        detectors = softwareSystem "Guardrails Detectors" "Content detection services (PII, regex patterns, etc.)" "Internal RHOAI"
        vllm = softwareSystem "vLLM Model Server" "LLM inference backend for chat completions" "Internal RHOAI"
        serviceCa = softwareSystem "OpenShift Service CA" "Provides CA certificates for service-to-service TLS" "Platform"

        // Relationships
        client -> gateway "POST /{route}/v1/chat/completions" "HTTP/8090 plaintext"
        gateway -> orchestrator "POST /api/v2/chat/completions-detection" "HTTP or HTTPS/8085, optional mTLS"
        orchestrator -> detectors "Runs configured content detectors" "Internal"
        orchestrator -> vllm "Forwards inference requests" "Internal"
        serviceCa -> gateway "Provides service-ca.crt" "Volume mount"

        // Container relationships
        configLoader -> requestRouter "Defines routes and detectors"
        configLoader -> tlsBuilder "Defines orchestrator connection"
        requestRouter -> streamingHandler "Delegates streaming requests"
        requestRouter -> apiTypes "Uses request/response types"
        streamingHandler -> apiTypes "Uses request/response types"
        tlsBuilder -> orchestrator "mTLS HTTP client" "HTTPS/8085"
    }

    views {
        systemContext gateway "SystemContext" {
            include *
            autoLayout
        }

        container gateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
