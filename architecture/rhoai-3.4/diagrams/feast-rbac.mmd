graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Operator["feast-operator-controller-manager<br/>(Namespace: redhat-ods-applications)"]
        SA_Feast["{name}<br/>(Namespace: {user-namespace})<br/>Per-FeatureStore SA"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["feast-operator-manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_TokenReview["{name}-cluster-binding<br/>(Cluster-scoped)"]
        CRB_Discover["feast-{ns}--{name}-discover<br/>(Cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Feast["feast-{name}<br/>(FeatureStore namespace)"]
        RB_Viewer["feast-{name}-viewer<br/>(FeatureStore namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Editor["featurestore-editor-role<br/>(aggregated to admin/edit)"]
        CR_Viewer["featurestore-viewer-role<br/>(aggregated to view)"]
        CR_Discover["feast-discover-namespaces"]
        CR_TokenReview["feast-token-review-cluster-role"]
    end

    subgraph ManagerPermissions["manager-role Permissions"]
        direction TB
        P_Feast["feast.dev<br/>featurestores, status, finalizers<br/>get,list,watch,create,update,patch,delete"]
        P_Apps["apps<br/>deployments<br/>get,list,create,update,watch,delete"]
        P_Core["core<br/>services, configmaps, pvcs, serviceaccounts<br/>get,list,create,update,watch,delete"]
        P_NS["core<br/>namespaces<br/>get,list,watch,patch,update"]
        P_Secrets["core<br/>secrets, pods<br/>get,list,watch"]
        P_Exec["core<br/>pods/exec<br/>create"]
        P_RBAC["rbac.authorization.k8s.io<br/>roles, rolebindings, clusterroles,<br/>clusterrolebindings, subjectaccessreviews<br/>get,list,create,update,watch,delete"]
        P_Routes["route.openshift.io<br/>routes<br/>get,list,create,update,watch,delete"]
        P_Batch["batch<br/>cronjobs<br/>get,list,watch,create,update,patch,delete"]
        P_HPA["autoscaling<br/>horizontalpodautoscalers<br/>get,list,watch,create,update,patch,delete"]
        P_PDB["policy<br/>poddisruptionbudgets<br/>get,list,watch,create,update,patch,delete"]
        P_Monitor["monitoring.coreos.com<br/>servicemonitors<br/>get,list,watch,create,patch,delete"]
        P_Auth["authentication.k8s.io<br/>tokenreviews<br/>create"]
        P_KF["kubeflow.org<br/>notebooks<br/>get,list,watch"]
        P_CRD["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get,list"]
    end

    subgraph TokenReviewPermissions["feast-token-review-cluster-role Permissions"]
        TR_Token["authentication.k8s.io<br/>tokenreviews<br/>create"]
        TR_SAR["rbac.authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        TR_NS["core<br/>namespaces, roles, clusterroles<br/>get,list,watch"]
    end

    subgraph EditorPermissions["featurestore-editor-role Permissions"]
        EP_FS["feast.dev<br/>featurestores, status<br/>create,delete,get,list,patch,update,watch"]
    end

    subgraph ViewerPermissions["featurestore-viewer-role Permissions"]
        VP_FS["feast.dev<br/>featurestores, status<br/>get,list,watch"]
    end

    subgraph DiscoverPermissions["feast-discover-namespaces Permissions"]
        DP_NS["core<br/>namespaces<br/>get,list,watch"]
    end

    %% Operator SA bindings
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    CR_Manager --> P_Feast
    CR_Manager --> P_Apps
    CR_Manager --> P_Core
    CR_Manager --> P_NS
    CR_Manager --> P_Secrets
    CR_Manager --> P_Exec
    CR_Manager --> P_RBAC
    CR_Manager --> P_Routes
    CR_Manager --> P_Batch
    CR_Manager --> P_HPA
    CR_Manager --> P_PDB
    CR_Manager --> P_Monitor
    CR_Manager --> P_Auth
    CR_Manager --> P_KF
    CR_Manager --> P_CRD

    %% Feast SA bindings
    SA_Feast -->|"bound via"| CRB_TokenReview
    CRB_TokenReview -->|"grants"| CR_TokenReview
    CR_TokenReview --> TR_Token
    CR_TokenReview --> TR_SAR
    CR_TokenReview --> TR_NS

    SA_Feast -->|"bound via"| RB_Feast

    %% Aggregated roles (for users/groups)
    CR_Editor --> EP_FS
    CR_Viewer --> VP_FS
    CR_Discover --> DP_NS

    %% Discovery bindings (from registry policies)
    CRB_Discover -->|"grants"| CR_Discover
    RB_Viewer -->|"grants"| CR_Viewer

    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_Feast fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_Editor fill:#f5a623,stroke:#333,color:#fff
    style CR_Viewer fill:#f5a623,stroke:#333,color:#fff
    style CR_Discover fill:#f5a623,stroke:#333,color:#fff
    style CR_TokenReview fill:#f5a623,stroke:#333,color:#fff
    style P_Feast fill:#7ed321,stroke:#333,color:#fff
    style P_Apps fill:#7ed321,stroke:#333,color:#fff
    style P_Core fill:#7ed321,stroke:#333,color:#fff
    style P_NS fill:#7ed321,stroke:#333,color:#fff
    style P_Secrets fill:#7ed321,stroke:#333,color:#fff
    style P_Exec fill:#e74c3c,stroke:#333,color:#fff
    style P_RBAC fill:#e74c3c,stroke:#333,color:#fff
    style P_Routes fill:#7ed321,stroke:#333,color:#fff
    style P_Batch fill:#7ed321,stroke:#333,color:#fff
    style P_HPA fill:#7ed321,stroke:#333,color:#fff
    style P_PDB fill:#7ed321,stroke:#333,color:#fff
    style P_Monitor fill:#7ed321,stroke:#333,color:#fff
    style P_Auth fill:#e74c3c,stroke:#333,color:#fff
    style P_KF fill:#7ed321,stroke:#333,color:#fff
    style P_CRD fill:#7ed321,stroke:#333,color:#fff
