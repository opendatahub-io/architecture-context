graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Op["feast-operator-controller-manager<br/>(Namespace: redhat-ods-applications)"]
        SA_Dynamic["Registry permission subjects<br/>(dynamically created from<br/>Feast registry permissions)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Mgr["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Metrics["metrics-auth-rolebinding<br/>(feast-operator-system)"]
        CRB_Discover["feast-{ns}--{name}-discover<br/>(Cluster-scoped, auto-created)"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_Leader["leader-election-rolebinding<br/>(feast-operator-system)"]
        RB_Viewer["feast-{ns}--{name}-viewer<br/>({namespace}, auto-created)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Mgr["manager-role"]
        CR_Editor["featurestore-editor-role"]
        CR_Viewer["featurestore-viewer-role"]
        CR_Metrics["metrics-reader"]
        CR_Discover["feast-discover-namespaces"]
        CR_Leader["leader-election-role<br/>(Role, not ClusterRole)"]
        CR_MetricsAuth["metrics-auth-role"]
    end

    subgraph ManagerPermissions["manager-role Permissions"]
        subgraph FeastAPI["feast.dev API Group"]
            FS["featurestores<br/>featurestores/status<br/>featurestores/finalizers<br/>get, list, watch, create,<br/>update, patch, delete"]
        end

        subgraph CoreAPI["Core API Group"]
            ConfigMaps["configmaps<br/>services<br/>persistentvolumeclaims<br/>serviceaccounts<br/>get, list, create, update,<br/>watch, delete"]
            Namespaces["namespaces<br/>get, list, watch,<br/>patch, update"]
            ReadOnly["pods, secrets<br/>get, list, watch"]
            Exec["pods/exec<br/>create"]
        end

        subgraph AppsAPI["apps API Group"]
            Deployments["deployments<br/>get, list, create,<br/>update, watch, delete"]
        end

        subgraph RbacAPI["rbac.authorization.k8s.io"]
            RBACRes["roles, rolebindings<br/>clusterroles,<br/>clusterrolebindings<br/>get, list, create, update,<br/>watch, delete"]
        end

        subgraph BatchAPI["batch API Group"]
            CronJobs["cronjobs<br/>get, list, watch, create,<br/>update, patch, delete"]
        end

        subgraph AutoscaleAPI["autoscaling API Group"]
            HPA["horizontalpodautoscalers<br/>get, list, watch, create,<br/>update, patch, delete"]
        end

        subgraph PolicyAPI["policy API Group"]
            PDB["poddisruptionbudgets<br/>get, list, watch, create,<br/>update, patch, delete"]
        end

        subgraph MonitoringAPI["monitoring.coreos.com"]
            ServiceMonitors["servicemonitors<br/>get, list, watch,<br/>create, patch, delete"]
        end

        subgraph RouteAPI["route.openshift.io"]
            Routes["routes<br/>get, list, create,<br/>update, watch, delete"]
        end

        subgraph AuthAPI["authentication.k8s.io"]
            TokenReview["tokenreviews<br/>create"]
        end

        subgraph ExtAPI["apiextensions.k8s.io"]
            CRDs["customresourcedefinitions<br/>get, list"]
        end

        subgraph KubeflowAPI["kubeflow.org"]
            Notebooks["notebooks<br/>get, list, watch"]
        end
    end

    subgraph OtherPermissions["Other Role Permissions"]
        EditorPerm["featurestore-editor-role<br/>feast.dev: featurestores<br/>create, delete, get, list,<br/>patch, update, watch"]
        ViewerPerm["featurestore-viewer-role<br/>feast.dev: featurestores<br/>get, list, watch"]
        DiscoverPerm["feast-discover-namespaces<br/>core: namespaces<br/>get, list"]
        MetricsPerm["metrics-reader<br/>non-resource: /metrics<br/>get"]
    end

    %% Bindings
    SA_Op -->|"bound via"| CRB_Mgr
    SA_Op -->|"bound via"| RB_Leader
    SA_Op -->|"bound via"| CRB_Metrics
    SA_Dynamic -->|"bound via"| CRB_Discover
    SA_Dynamic -->|"bound via"| RB_Viewer

    CRB_Mgr -->|"grants"| CR_Mgr
    RB_Leader -->|"grants"| CR_Leader
    CRB_Metrics -->|"grants"| CR_MetricsAuth
    CRB_Discover -->|"grants"| CR_Discover
    RB_Viewer -.->|"grants auto-created<br/>viewer Role"| ViewerPerm

    %% Manager role to permissions
    CR_Mgr -->|"permits"| FS
    CR_Mgr -->|"permits"| ConfigMaps
    CR_Mgr -->|"permits"| Namespaces
    CR_Mgr -->|"permits"| ReadOnly
    CR_Mgr -->|"permits"| Exec
    CR_Mgr -->|"permits"| Deployments
    CR_Mgr -->|"permits"| RBACRes
    CR_Mgr -->|"permits"| CronJobs
    CR_Mgr -->|"permits"| HPA
    CR_Mgr -->|"permits"| PDB
    CR_Mgr -->|"permits"| ServiceMonitors
    CR_Mgr -->|"permits"| Routes
    CR_Mgr -->|"permits"| TokenReview
    CR_Mgr -->|"permits"| CRDs
    CR_Mgr -->|"permits"| Notebooks

    CR_Editor -->|"permits"| EditorPerm
    CR_Viewer -->|"permits"| ViewerPerm
    CR_Discover -->|"permits"| DiscoverPerm
    CR_Metrics -->|"permits"| MetricsPerm

