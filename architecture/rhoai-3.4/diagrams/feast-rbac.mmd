%% Feast Operator - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA_Operator["feast-operator-controller-manager<br/>(Operator SA)"]
        SA_Feast["feast-{name}<br/>(FeatureStore SA)"]
        SA_CronJob["feast-{name}-cronjob<br/>(CronJob SA)"]
        SA_Authenticated["system:authenticated<br/>(All authenticated users)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["feast-operator-manager-rolebinding"]
        CRB_TokenReview["feast-token-review-binding"]
        CRB_Registry["feast-configs-registry-binding"]
    end

    subgraph "ClusterRoles"
        CR_Manager["feast-operator-manager-role"]
        CR_TokenReview["feast-token-review-cluster-role"]
    end

    subgraph "Roles (Namespaced)"
        R_Feast["feast-{name}<br/>(per FeatureStore)"]
        R_CronJob["feast-{name}-cronjob<br/>(per CronJob)"]
        R_Registry["feast-configs-registry-reader"]
    end

    subgraph "API Resources - Operator Manager"
        FeatureStores["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers"]
        Deployments["apps<br/>deployments"]
        CoreRW["core<br/>services, configmaps,<br/>persistentvolumeclaims,<br/>serviceaccounts"]
        CoreRO["core<br/>secrets, pods,<br/>namespaces"]
        PodsExec["core<br/>pods/exec"]
        RBACResources["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings,<br/>subjectaccessreviews"]
        TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        Routes["route.openshift.io<br/>routes"]
        CronJobs["batch<br/>cronjobs"]
        HPAs["autoscaling<br/>horizontalpodautoscalers"]
        PDBs["policy<br/>poddisruptionbudgets"]
        Notebooks["kubeflow.org<br/>notebooks"]
        CRDs["apiextensions.k8s.io<br/>customresourcedefinitions"]
    end

    subgraph "API Resources - Token Review"
        TR_RBAC["rbac.authorization.k8s.io<br/>rolebindings, clusterroles,<br/>clusterrolebindings"]
        TR_TokenReviews["authentication.k8s.io<br/>tokenreviews"]
        TR_SAR["rbac.authorization.k8s.io<br/>subjectaccessreviews"]
        TR_NS["core<br/>namespaces"]
    end

    subgraph "API Resources - CronJob"
        CJ_Deploy["apps<br/>deployments (specific)"]
        CJ_Pods["core<br/>pods"]
        CJ_Exec["core<br/>pods/exec"]
    end

    subgraph "API Resources - Registry"
        Reg_CM["core<br/>configmaps<br/>(feast-configs-registry)"]
    end

    %% Operator Manager bindings
    SA_Operator -->|"bound via"| CRB_Manager
    CRB_Manager -->|"grants"| CR_Manager
    CR_Manager -->|"get,list,watch,create,update,patch,delete"| FeatureStores
    CR_Manager -->|"get,list,create,update,watch,delete"| Deployments
    CR_Manager -->|"get,list,create,update,watch,delete"| CoreRW
    CR_Manager -->|"get,list,watch"| CoreRO
    CR_Manager -->|"create"| PodsExec
    CR_Manager -->|"get,list,create,update,watch,delete"| RBACResources
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"get,list,create,update,watch,delete"| Routes
    CR_Manager -->|"get,list,watch,create,update,patch,delete"| CronJobs
    CR_Manager -->|"get,list,watch,create,update,patch,delete"| HPAs
    CR_Manager -->|"get,list,watch,create,update,patch,delete"| PDBs
    CR_Manager -->|"get,list,watch"| Notebooks
    CR_Manager -->|"get,list"| CRDs

    %% Token Review bindings (FeatureStore SA)
    SA_Feast -->|"bound via"| CRB_TokenReview
    CRB_TokenReview -->|"grants"| CR_TokenReview
    CR_TokenReview -->|"get,list"| TR_RBAC
    CR_TokenReview -->|"create"| TR_TokenReviews
    CR_TokenReview -->|"create"| TR_SAR
    CR_TokenReview -->|"get,list,watch"| TR_NS

    %% CronJob bindings
    SA_CronJob --> R_CronJob
    R_CronJob -->|"get"| CJ_Deploy
    R_CronJob -->|"list"| CJ_Pods
    R_CronJob -->|"create"| CJ_Exec

    %% Registry bindings
    SA_Authenticated --> CRB_Registry
    CRB_Registry --> R_Registry
    R_Registry -->|"get,list"| Reg_CM

