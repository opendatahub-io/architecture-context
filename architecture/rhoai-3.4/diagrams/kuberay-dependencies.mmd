graph LR
    KubeRay["KubeRay Operator<br/>(kuberay-operator)"]

    %% External Dependencies (Required)
    KubeRay -->|"controller framework<br/>(required)"| ControllerRuntime["controller-runtime<br/>v0.22.1"]
    KubeRay -->|"resource CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% External Dependencies (Optional)
    KubeRay -->|"mTLS certificates<br/>(optional)"| CertManager["cert-manager<br/>v1 API"]
    KubeRay -->|"route management<br/>(OpenShift only)"| RouteAPI["OpenShift Route API<br/>route.openshift.io/v1"]
    KubeRay -->|"HTTPRoute + ReferenceGrant<br/>(OpenShift only)"| GatewayAPI["Gateway API<br/>v1/v1beta1"]
    KubeRay -->|"auth sidecar injection<br/>(OpenShift only)"| KubeRBACProxy["kube-rbac-proxy<br/>ose-kube-rbac-proxy-rhel9"]
    KubeRay -->|"OAuth sidecar injection<br/>(OpenShift only)"| OAuthProxy["oauth-proxy<br/>ose-oauth-proxy"]

    %% Internal Platform Dependencies
    RHOAIOp["rhods-operator /<br/>opendatahub-operator"] -->|"deploys via kustomize"| KubeRay
    KubeRay -->|"HTTPRoute parentRef<br/>(OpenShift only)"| DSGateway["data-science-gateway<br/>Gateway CR"]
    KubeRay -->|"job submission + status<br/>8265/TCP HTTP"| RayDashboard["Ray Dashboard<br/>(head pod)"]
    KubeRay -->|"serve health checks<br/>8000/TCP HTTP"| RayServe["Ray HTTP Proxy<br/>(head pod)"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"metrics scrape<br/>8080/TCP HTTP"| KubeRay

    %% Integration Points (consumers)
    ODHDashboard["ODH Dashboard"] -.->|"UI management"| KubeRay
    DSPipelines["Data Science<br/>Pipelines"] -.->|"auto deploy<br/>Ray clusters"| KubeRay

    %% Batch Schedulers (optional)
    KubeRay -.->|"pod scheduling<br/>(optional plugin)"| Volcano["Volcano"]
    KubeRay -.->|"pod scheduling<br/>(optional plugin)"| Yunikorn["Apache YuniKorn"]

    %% Auth config
    KubeRay -->|"read auth config<br/>443/TCP HTTPS"| OSAuthConfig["OpenShift Auth<br/>config.openshift.io"]

    %% Styling
    style KubeRay fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#bbb,stroke:#333,color:#fff
    style RouteAPI fill:#bbb,stroke:#333,color:#fff
    style GatewayAPI fill:#bbb,stroke:#333,color:#fff
    style KubeRBACProxy fill:#bbb,stroke:#333,color:#fff
    style OAuthProxy fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style RayDashboard fill:#7ed321,stroke:#333,color:#fff
    style RayServe fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style ODHDashboard fill:#7ed321,stroke:#333,color:#fff
    style DSPipelines fill:#7ed321,stroke:#333,color:#fff

