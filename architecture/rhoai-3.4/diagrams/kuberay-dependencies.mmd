graph LR
    KubeRay["KubeRay Operator<br/>v1.4.2"]

    %% Required External Dependencies
    KubeRay -->|"CRD CRUD, pods, services<br/>HTTPS/443"| K8s["Kubernetes v1.29+"]
    KubeRay -->|"controller-runtime<br/>reconciliation, webhooks"| CtrlRuntime["controller-runtime<br/>v0.22.1"]
    KubeRay -->|"manages lifecycle<br/>HTTP/8265"| Ray["Ray v2.x"]

    %% Optional External Dependencies
    KubeRay -->|"mTLS certificates<br/>Issuer/Certificate CRs"| CertManager["cert-manager<br/>v1.18.2"]
    KubeRay -->|"GCS fault tolerance<br/>6379/TCP"| Redis["Redis"]
    KubeRay -->|"gang scheduling<br/>PodGroup CRs"| Volcano["Volcano"]
    KubeRay -->|"gang scheduling<br/>pod annotations"| YuniKorn["YuniKorn"]
    KubeRay -->|"coscheduling<br/>PodGroup CRs"| SchedPlugins["scheduler-plugins"]
    KubeRay -->|"HTTPRoute ingress<br/>cross-namespace routing"| GatewayAPI["Gateway API<br/>v1.4.0"]

    %% Internal RHOAI Dependencies
    KubeRay -->|"HTTPRoute reference<br/>dashboard access"| RHOAIGw["RHOAI Gateway<br/>(data-science-gateway)"]
    KubeRay -->|"OAuth delegation<br/>IntegratedOAuth mode"| OSHOAuth["OpenShift OAuth<br/>Server"]
    KubeRay -->|"webhook TLS<br/>serving cert annotation"| OSHCertSigner["OpenShift Serving<br/>Cert Signer"]
    KubeRay -->|"RBAC enforcement<br/>sidecar injection"| KRBP["kube-rbac-proxy"]
    KubeRay -->|"metrics scraping<br/>HTTP/8080"| Prometheus["Prometheus"]

    %% Integration Points (other components → KubeRay)
    Dashboard["ODH Dashboard"] -.->|"UI management"| KubeRay
    Kueue["Kueue"] -.->|"managedBy field<br/>multikueue scheduling"| KubeRay

    %% Reads from OpenShift APIs
    KubeRay -->|"auth mode detection<br/>read-only"| OSHConfigAPI["OpenShift API<br/>config.openshift.io"]
    KubeRay -->|"OIDC setup<br/>read-only"| OSHOperatorAPI["OpenShift API<br/>operator.openshift.io"]

