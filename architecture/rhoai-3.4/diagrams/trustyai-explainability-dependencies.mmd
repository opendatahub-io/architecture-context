graph LR
    TrustyAI["TrustyAI Explainability<br/>Service"]

    %% Internal RHOAI Dependencies
    TrustyAI -->|"inference payloads<br/>REST/gRPC"| KServeModelMesh["KServe / ModelMesh<br/>(Model Servers)"]
    TrustyAI -->|"ConfigMap registration"| ModelMeshConfig["ModelMesh<br/>(model-serving-config)"]
    TrustyAI -->|"deployment management"| TrustyAIOperator["TrustyAI Operator<br/>(separate repo)"]
    TrustyAI -->|"metrics scrape<br/>/q/metrics"| Prometheus["Prometheus"]
    TrustyAI -->|"CloudEvent consumer"| KnativeEventing["Knative Eventing"]

    %% External Framework Dependencies
    TrustyAI -->|"app framework"| Quarkus["Quarkus 3.8.5"]
    TrustyAI -->|"constraint solver"| OptaPlanner["OptaPlanner 8.30.0"]
    TrustyAI -->|"columnar data"| Arrow["Apache Arrow 15.0.2"]
    TrustyAI -->|"v2 gRPC client"| gRPC["gRPC 1.75.0"]
    TrustyAI -->|"serialization"| Protobuf["Protobuf 3.25.5"]

    %% Optional Storage Dependencies
    TrustyAI -.->|"optional DB<br/>JDBC/3306"| MariaDB["MariaDB/MySQL"]
    TrustyAI -.->|"optional S3"| MinIO["MinIO 3.3.1"]

    %% Platform Dependencies
    TrustyAI -->|"init container<br/>oc apply"| K8sAPI["Kubernetes API"]
    TrustyAI -->|"PVC storage"| PVC["PVC Volume<br/>(1Gi)"]

    %% Integration Points - other components consuming TrustyAI
    ODHDashboard["ODH Dashboard"] -.->|"UI integration"| TrustyAI

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI - green
    style KServeModelMesh fill:#7ed321,stroke:#333,color:#fff
    style ModelMeshConfig fill:#7ed321,stroke:#333,color:#fff
    style TrustyAIOperator fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style KnativeEventing fill:#7ed321,stroke:#333,color:#fff
    style ODHDashboard fill:#7ed321,stroke:#333,color:#fff

    %% External frameworks - gray
    style Quarkus fill:#999,stroke:#333,color:#fff
    style OptaPlanner fill:#999,stroke:#333,color:#fff
    style Arrow fill:#999,stroke:#333,color:#fff
    style gRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff

    %% External services - orange
    style MariaDB fill:#f5a623,stroke:#333,color:#fff
    style MinIO fill:#f5a623,stroke:#333,color:#fff

    %% Platform - light gray
    style K8sAPI fill:#bdbdbd,stroke:#333
    style PVC fill:#fff9c4,stroke:#f9a825
