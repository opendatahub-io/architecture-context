    TrustyAI -->|"deploys & configures<br/>kube-rbac-proxy sidecar"| Operator["TrustyAI Operator<br/>(trustyai-service-operator)"]
    TrustyAI -->|"gRPC client + REST consumer<br/>+ CloudEvent consumer"| KServe["KServe"]
