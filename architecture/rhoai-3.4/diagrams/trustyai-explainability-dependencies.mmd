    TrustyAI -->|"KServe v2 protocol"| GRPC["gRPC 1.75.0"]
    TrustyAI -->|"payload serialization"| Protobuf["Protobuf 3.25.5"]
    TrustyAI -->|"async I/O"| Netty["Netty 4.1.125"]
    TrustyAI -->|"metric publication"| Micrometer["Micrometer +<br/>Prometheus Registry"]

