graph LR
    RhodsOp["rhods-operator<br/>(Platform Operator)"]

    %% External Dependencies (Required)
    RhodsOp -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.19+"]
    RhodsOp -->|"CRD/resource CRUD<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API"]
    RhodsOp -->|"Route, OAuth, Console APIs"| OpenShiftAPI["OpenShift API<br/>v4.x"]
    RhodsOp -->|"EnvoyFilter,<br/>DestinationRule"| Istio["Istio / Sail Operator<br/>v1.x"]
    RhodsOp -->|"webhook + KServe certs"| CertManager["cert-manager<br/>v1.x"]
    RhodsOp -->|"Gateway, HTTPRoute<br/>443/TCP HTTPS"| GatewayAPI["Gateway API<br/>v1"]
    RhodsOp -->|"install/upgrade"| OLM["OLM<br/>v1"]

    %% External Dependencies (Conditional)
    RhodsOp -.->|"MonitoringStack,<br/>ThanosQuerier CRDs"| ObsOperator["Observability Stack<br/>Operator"]
    RhodsOp -.->|"OTEL Collector,<br/>Instrumentation CRDs"| OTELOperator["OpenTelemetry<br/>Operator"]
    RhodsOp -.->|"TempoMonolithic,<br/>TempoStack CRDs"| TempoOp["Tempo Operator"]
    RhodsOp -.->|"Perses,<br/>PersesDashboard CRDs"| PersesOp["Perses Operator"]
    RhodsOp -.->|"KueueConfig CR<br/>(Unmanaged mode)"| KueueOp["Kueue Operator"]
    RhodsOp -.->|"required for<br/>Trainer component"| JobSetOp["JobSet Operator"]
    RhodsOp -.->|"required for KServe<br/>expert parallelism"| LWSOp["LeaderWorkerSet<br/>Operator"]
    RhodsOp -.->|"required for<br/>ModelController WVA"| KEDA["KEDA<br/>(Custom Metrics)"]

    %% Internal RHOAI Components
    RhodsOp -->|"CRD + kustomize"| Dashboard["Dashboard"]
    RhodsOp -->|"CRD + kustomize"| KServe["KServe"]
    RhodsOp -->|"CRD + kustomize<br/>+ config conversion"| Kueue["Kueue"]
    RhodsOp -->|"CRD + kustomize"| Workbenches["Workbenches"]
    RhodsOp -->|"CRD + kustomize"| ModelRegistry["Model Registry"]
    RhodsOp -->|"CRD + kustomize"| DSP["Data Science<br/>Pipelines"]
    RhodsOp -->|"CRD + kustomize"| ModelCtrl["Model Controller"]
    RhodsOp -->|"CRD + kustomize"| TrustyAI["TrustyAI"]
    RhodsOp -->|"CRD + kustomize"| Ray["Ray"]
    RhodsOp -->|"CRD + kustomize"| Trainer["Trainer"]
    RhodsOp -->|"CRD + kustomize"| TrainingOp["Training Operator"]
    RhodsOp -->|"CRD + kustomize"| Feast["Feast"]
    RhodsOp -->|"CRD + kustomize"| LlamaStack["LlamaStack"]
    RhodsOp -->|"CRD + kustomize"| MLflow["MLflow"]
    RhodsOp -->|"CRD + kustomize"| Spark["Spark"]
    RhodsOp -->|"CRD + kustomize"| MaaS["MaaS"]

    %% External Services
    RhodsOp -->|"OAuthClient creation<br/>443/TCP HTTPS"| OAuthAPI["OpenShift OAuth API"]
    RhodsOp -->|"legacy URL redirects<br/>443/TCP HTTPS"| Router["OpenShift Router"]
    RhodsOp -.->|"usage analytics<br/>443/TCP HTTPS"| Segment["Segment.io"]

    %% Cloud Manager Dependencies
    subgraph CloudDeps["cloudmanager (XKS only)"]
        CloudMgr["cloudmanager"]
        CloudMgr -->|"Helm chart"| GatewayAPIHelm["gateway-api CRDs"]
        CloudMgr -->|"Helm chart"| CertMgrHelm["cert-manager"]
        CloudMgr -->|"Helm chart"| LWSHelm["lws-operator"]
        CloudMgr -->|"Helm chart"| SailHelm["sail-operator"]
    end

    %% Cross-component dependencies
    ModelCtrl -.->|"requires"| KServe
    TrustyAI -.->|"requires InferenceService CRD"| KServe
    Trainer -.->|"requires"| JobSetOp

    %% Styling
    style RhodsOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external deps
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OpenShiftAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style CertManager fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OLM fill:#999,stroke:#333,color:#fff

    %% Conditional external deps
    style ObsOperator fill:#bbb,stroke:#333,color:#fff
    style OTELOperator fill:#bbb,stroke:#333,color:#fff
    style TempoOp fill:#bbb,stroke:#333,color:#fff
    style PersesOp fill:#bbb,stroke:#333,color:#fff
    style KueueOp fill:#bbb,stroke:#333,color:#fff
    style JobSetOp fill:#bbb,stroke:#333,color:#fff
    style LWSOp fill:#bbb,stroke:#333,color:#fff
    style KEDA fill:#bbb,stroke:#333,color:#fff

    %% Internal RHOAI components
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style Workbenches fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistry fill:#7ed321,stroke:#333,color:#fff
    style DSP fill:#7ed321,stroke:#333,color:#fff
    style ModelCtrl fill:#7ed321,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style Ray fill:#7ed321,stroke:#333,color:#fff
    style Trainer fill:#7ed321,stroke:#333,color:#fff
    style TrainingOp fill:#7ed321,stroke:#333,color:#fff
    style Feast fill:#7ed321,stroke:#333,color:#fff
    style LlamaStack fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Spark fill:#7ed321,stroke:#333,color:#fff
    style MaaS fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style OAuthAPI fill:#f5a623,stroke:#333,color:#fff
    style Router fill:#f5a623,stroke:#333,color:#fff
    style Segment fill:#f5a623,stroke:#333,color:#fff

    %% Cloud deps
    style CloudDeps fill:#e1d5e7,stroke:#9673a6
    style CloudMgr fill:#9673a6,stroke:#333,color:#fff
    style GatewayAPIHelm fill:#c9b2d9,stroke:#333
    style CertMgrHelm fill:#c9b2d9,stroke:#333
    style LWSHelm fill:#c9b2d9,stroke:#333
    style SailHelm fill:#c9b2d9,stroke:#333
