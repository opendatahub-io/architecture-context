graph LR
    RhodsOp["rhods-operator<br/>(manager)"]
    CloudMgr["rhods-operator<br/>(cloudmanager)"]

    %% External Framework Dependencies
    RhodsOp -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    RhodsOp -->|"ingress types"| GatewayAPI["gateway-api<br/>v1.3.0"]
    RhodsOp -->|"OpenShift APIs"| OSApi["openshift/api<br/>v0.0.0-20230823"]
    RhodsOp -->|"OLM APIs"| OFApi["operator-framework/api<br/>v0.31.0"]
    RhodsOp -->|"conditional monitoring"| PromApi["prometheus-operator/apis<br/>v0.68.0"]
    CloudMgr -->|"Helm rendering"| Helm["helm.sh/helm/v4<br/>v4.1.1"]
    CloudMgr -->|"chart engine"| ManifestKit["k8s-manifest-kit/engine<br/>v0.2.1"]

    %% Internal RHOAI Components (deployed via kustomize)
    RhodsOp -->|"deploys"| Dashboard["Dashboard"]
    RhodsOp -->|"deploys"| KServe["KServe"]
    RhodsOp -->|"deploys"| Workbenches["Workbenches"]
    RhodsOp -->|"deploys"| DSP["DataScience<br/>Pipelines"]
    RhodsOp -->|"deploys"| ModelReg["Model Registry"]
    RhodsOp -->|"deploys"| TrustyAI["TrustyAI"]
    RhodsOp -->|"deploys"| Ray["KubeRay"]
    RhodsOp -->|"deploys"| Kueue["Kueue"]
    RhodsOp -->|"deploys"| TrainingOp["Training<br/>Operator"]
    RhodsOp -->|"deploys"| Trainer["Trainer"]
    RhodsOp -->|"deploys"| Feast["Feast<br/>Operator"]
    RhodsOp -->|"deploys"| LlamaStack["LlamaStack<br/>Operator"]
    RhodsOp -->|"deploys"| MLflow["MLflow<br/>Operator"]
    RhodsOp -->|"deploys"| Spark["Spark<br/>Operator"]
    RhodsOp -->|"deploys"| ModelCtrl["Model<br/>Controller"]
    RhodsOp -->|"deploys"| MaaS["ModelsAs<br/>Service"]

    %% Observability Dependencies (CRD Watch)
    RhodsOp -->|"CRD watch"| COO["Cluster Observability<br/>Operator"]
    RhodsOp -->|"CRD watch"| TempoOp["Tempo Operator"]
    RhodsOp -->|"CRD watch"| OTelOp["OpenTelemetry<br/>Operator"]
    RhodsOp -.->|"conditional CRD watch"| PromOp["Prometheus<br/>Operator"]

    %% Platform Dependencies
    RhodsOp -->|"EnvoyFilter, mTLS"| Istio["Istio / Sail<br/>Operator"]
    RhodsOp -->|"OLM subscription watch"| OLM["OLM"]
    RhodsOp -->|"CRD watch (JobSet)"| JobSetOp["JobSet Operator"]

    %% Cloud Manager Dependencies (XKS only, Helm deploy)
    CloudMgr -->|"Helm deploy (XKS)"| CertMgr["cert-manager"]
    CloudMgr -->|"Helm deploy (XKS)"| SailOp["Sail Operator<br/>(Istio)"]
    CloudMgr -->|"Helm deploy (XKS)"| LWS["LeaderWorkerSet<br/>Operator"]
    CloudMgr -->|"Helm deploy (XKS)"| GatewayAPICRDs["Gateway API<br/>CRDs"]

    %% External Services
    RhodsOp -->|"OAuth registration"| OSAuth["OpenShift OAuth"]
    RhodsOp -->|"TLS certs"| ServiceCA["OpenShift<br/>Service CA"]
    RhodsOp -->|"API server"| K8sAPI["Kubernetes API"]

    %% Integration Points (consumed by)
    OLM -->|"manages lifecycle"| RhodsOp

    %% Styling
    style RhodsOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style CloudMgr fill:#6c5ce7,stroke:#333,stroke-width:3px,color:#fff

    %% External framework deps
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style OSApi fill:#999,stroke:#333,color:#fff
    style OFApi fill:#999,stroke:#333,color:#fff
