graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph KFPPod["KFP API Server Pod"]
            InitContainer["Init Container<br/>pipelines-components<br/>UBI9/python-311<br/>No ports exposed"]
            SharedVol["/config/managed-pipelines<br/>(Shared Volume)"]
            KFPServer["KFP API Server<br/>Pipeline registration"]
            InitContainer -->|"Filesystem<br/>shutil.copy2<br/>path-escape validation"| SharedVol
            SharedVol -->|"Volume mount<br/>(read)"| KFPServer
        end

        subgraph PipelinePods["PIPELINE STEP PODS (Argo Workflow)"]
            direction TB
            AutoML["AutoML Pods<br/>Image: odh-automl<br/>rhai/base-image-cpu-rhel9"]
            AutoRAG["AutoRAG Pods<br/>Image: odh-autorag<br/>rhai/base-image-cpu-rhel9"]
            Finetune["Finetuning Pods<br/>LoRA / OSFT / SFT"]
            Utility["Utility Pods<br/>dataset_download, sdg<br/>lm_eval, model_registry"]
        end
    end

    subgraph ExternalSecure["EXTERNAL SERVICES (TLS)"]
        S3["S3 Storage<br/>(AWS/MinIO)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer token (optional)"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA bearer token"]
        LiteLLM["LiteLLM Endpoint<br/>Custom port HTTPS<br/>TLS 1.2+<br/>LLM_API_KEY"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>dockerconfigjson"]
    end

    subgraph InternalInsecure["INTERNAL SERVICES (Security Gaps)"]
        LS["LlamaStack Server<br/>8321/TCP HTTP/HTTPS<br/>TLS: Optional<br/>API key auth"]
        MR["Model Registry<br/>8080/TCP HTTP<br/>TLS: NONE<br/>Auth: NONE"]
    end

    %% Secure egress flows
    AutoML -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3-secret)"| S3
    AutoRAG -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (s3-secret)<br/>verify=False fallback"| S3
    Finetune -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN (hf-token)"| HF
    Finetune -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Utility -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HF
    Utility -->|"HTTPS<br/>TLS 1.2+<br/>LLM_API_KEY"| LiteLLM
    Utility -->|"HTTPS/443<br/>TLS 1.2+<br/>dockerconfigjson"| OCI

    %% Insecure egress flows
    AutoRAG -->|"HTTP/8321<br/>TLS: Optional<br/>API key (llama-stack-secret)"| LS
    Utility -->|"HTTP/8080<br/>NO TLS<br/>NO AUTH"| MR

    %% Styling
    classDef cluster fill:#e8f4f8,stroke:#2c3e50,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef secure fill:#dff0d8,stroke:#3c763d,stroke-width:2px
    classDef insecure fill:#f2dede,stroke:#a94442,stroke-width:2px
    classDef initcontainer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    class InitContainer,SharedVol,KFPServer initcontainer
    class AutoML,AutoRAG,Finetune,Utility pod
    class S3,HF,K8sAPI,LiteLLM,OCI secure
    class LS,MR insecure
