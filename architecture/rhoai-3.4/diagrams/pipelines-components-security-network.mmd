graph TB
    subgraph PipelinePods["PIPELINE STEP PODS (Ephemeral Argo Workflow Pods)"]
        direction TB

        subgraph InitPhase["Init Container Phase"]
            InitContainer["odh-pipelines-components<br/>(Init Container)<br/>SA: KFP API Server pod SA"]
            SharedVol["Shared Volume<br/>/config/managed-pipelines/"]
            KFPServer["KFP API Server"]
        end

        subgraph RuntimePhase["Pipeline Step Execution"]
            StepPod["Pipeline Step Pod<br/>SA: KFP pipeline runner<br/>Namespace: user namespace"]
        end

        subgraph RuntimeImages["Runtime Container Images"]
            AutoMLImg["odh-automl<br/>quay.io/rhoai/odh-automl-rhel9<br/>AutoGluon runtime"]
            AutoRAGImg["odh-autorag<br/>quay.io/rhoai/odh-autorag-rhel9<br/>docling + ai4rag runtime"]
        end
    end

    subgraph ClusterInternal["CLUSTER-INTERNAL SERVICES (No Encryption)"]
        vLLM["vLLM Inference<br/>8000/TCP HTTP<br/>No auth"]
        ModelRegistry["Kubeflow Model Registry<br/>8080/TCP HTTP<br/>No auth"]
        Milvus["Milvus Vector Store<br/>19530/TCP gRPC<br/>TLS optional, Token optional"]
    end

    subgraph ExternalTLS["EXTERNAL SERVICES (TLS 1.2+)"]
        S3["S3/MinIO Storage<br/>443/TCP or 9000/TCP<br/>HTTPS, TLS 1.2+<br/>AWS Signature V4<br/>Secret: s3-secret"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)<br/>Secret: hf-token"]
        LlamaStack["Llama Stack API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (header)<br/>Secret: llama_stack_secret_name"]
        LiteLLM["LiteLLM API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API Key (env)<br/>Secret: llm-credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Secret: kubernetes-credentials"]
    end

    subgraph BuildTime["BUILD-TIME (Konflux)"]
        RHPyPI["Red Hat Internal PyPI<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        PyPI["PyPI (pypi.org)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
    end

    %% Init container flow
    InitContainer -->|"Filesystem copy"| SharedVol
    KFPServer -->|"Filesystem read"| SharedVol

    %% Runtime image usage
    AutoMLImg -.->|"base_image"| StepPod
    AutoRAGImg -.->|"base_image"| StepPod

    %% Egress to external TLS services
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS Sig V4"| S3
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| HuggingFace
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LlamaStack
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| LiteLLM
    StepPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Egress to cluster-internal services
    StepPod -->|"HTTP/8000<br/>No encryption"| vLLM
    StepPod -->|"HTTP/8080<br/>No encryption"| ModelRegistry
    StepPod -->|"gRPC/19530<br/>TLS optional"| Milvus

    %% Styling
    classDef pipeline fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef buildtime fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class InitContainer,SharedVol,KFPServer,StepPod,AutoMLImg,AutoRAGImg pipeline
    class vLLM,ModelRegistry,Milvus internal
    class S3,HuggingFace,LlamaStack,LiteLLM,K8sAPI external
    class RHPyPI,PyPI buildtime
