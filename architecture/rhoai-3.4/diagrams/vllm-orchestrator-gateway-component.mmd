graph TB
    subgraph "vllm-orchestrator-gateway (Rust/axum)"
        direction TB
        ConfigLoader["Config Loader<br/>(config.rs)<br/>Reads config.yaml"]
        Router["Axum Router<br/>Dynamic Route Registration"]
        Handler["Request Handler<br/>(main.rs)<br/>Injects detector config"]
        TLSModule["TLS Module<br/>(optional mTLS)<br/>OpenSSL + native-tls"]
        StreamProcessor["Stream Processor<br/>SSE chunk parsing<br/>& detection enforcement"]

        ConfigLoader -->|"registers routes"| Router
        Router -->|"dispatches to"| Handler
        Handler -->|"uses if certs mounted"| TLSModule
        Handler -->|"streaming mode"| StreamProcessor
    end

    Client["API Client"] -->|"POST /{route}/v1/chat/completions<br/>8090/TCP HTTP<br/>Authorization header"| Router

    subgraph "Configured Routes (from config.yaml)"
        PIIRoute["/pii/v1/chat/completions<br/>regex-language detector"]
        PassthroughRoute["/passthrough/v1/chat/completions<br/>no detectors"]
    end

    ConfigLoader -.->|"defines"| PIIRoute
    ConfigLoader -.->|"defines"| PassthroughRoute

    Handler -->|"POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP or HTTPS<br/>Optional mTLS + Auth passthrough"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    Orchestrator -->|"invokes"| Detectors["Detector Services<br/>(e.g., guardrails-regex-detector)"]
    Orchestrator -->|"forwards generation to"| vLLM["vLLM Inference Server"]

    subgraph "TLS Certificates (Volume Mounts)"
        ClientCert["/etc/tls/private/tls.crt"]
        ClientKey["/etc/tls/private/tls.key"]
        CACert["/etc/tls/ca/service-ca.crt"]
    end

    TLSModule -.->|"reads"| ClientCert
    TLSModule -.->|"reads"| ClientKey
    TLSModule -.->|"reads"| CACert

    style ConfigLoader fill:#4a90e2,color:#fff
    style Router fill:#4a90e2,color:#fff
    style Handler fill:#4a90e2,color:#fff
    style TLSModule fill:#4a90e2,color:#fff
    style StreamProcessor fill:#4a90e2,color:#fff
    style PIIRoute fill:#f5a623,color:#fff
    style PassthroughRoute fill:#f5a623,color:#fff
    style Orchestrator fill:#7ed321,color:#fff
    style Detectors fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
    style ClientCert fill:#fff2cc,stroke:#d6b656
    style ClientKey fill:#fff2cc,stroke:#d6b656
    style CACert fill:#fff2cc,stroke:#d6b656
