graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Orchestration["Experiment Orchestration"]
            Experiment["AI4RAGExperiment<br/><i>Orchestrator for RAG HPO</i>"]
            MPS["ModelsPreSelector<br/><i>Fast model pair screening</i>"]
        end

        subgraph HPO["Hyperparameter Optimization"]
            GAM["GAMOptimizer<br/><i>GAM-based Bayesian HPO</i>"]
            Random["RandomOptimizer<br/><i>Random search baseline</i>"]
        end

        subgraph RAGPipeline["RAG Pipeline"]
            SimpleRAG["SimpleRAG<br/><i>Chunk→Embed→Retrieve→Generate</i>"]
            Retriever["Retriever<br/><i>Simple + window retrieval</i>"]
            LangChainChunker["LangChainChunker<br/><i>RecursiveCharacterTextSplitter</i>"]
        end

        subgraph Models["Model Integrations"]
            OGXFoundation["OGXFoundationModel<br/><i>Text generation via OGX</i>"]
            OGXEmbedding["OGXEmbeddingModel<br/><i>Document vectorization via OGX</i>"]
        end

        subgraph VectorStores["Vector Stores"]
            OGXVectorStore["OGXVectorStore<br/><i>OGX-managed indexing & search</i>"]
            ChromaVectorStore["ChromaVectorStore<br/><i>In-memory ChromaDB</i>"]
        end

        subgraph Evaluation["Evaluation"]
            UnitxtEval["UnitxtEvaluator<br/><i>Answer correctness, faithfulness,<br/>context correctness</i>"]
        end

        subgraph Config["Configuration"]
            SearchSpace["AI4RAGSearchSpace<br/><i>Constraint rules & parameter combos</i>"]
            EventHandler["EventHandler<br/><i>Pluggable status/results streaming</i>"]
        end
    end

    %% Internal flows
    Experiment -->|"runs optimization"| GAM
    Experiment -->|"fallback"| Random
    Experiment -->|"pre-selects models"| MPS
    Experiment -->|"executes RAG"| SimpleRAG
    Experiment -->|"evaluates results"| UnitxtEval
    Experiment -->|"emits events"| EventHandler
    Experiment -->|"uses"| SearchSpace

    MPS -->|"fast screening"| ChromaVectorStore
    MPS -->|"chunks docs"| LangChainChunker

    SimpleRAG -->|"chunks"| LangChainChunker
    SimpleRAG -->|"embeds"| OGXEmbedding
    SimpleRAG -->|"stores/retrieves"| OGXVectorStore
    SimpleRAG -->|"retrieves docs"| Retriever
    SimpleRAG -->|"generates answers"| OGXFoundation

    Retriever -->|"queries"| OGXVectorStore

    %% External
    OGXServer["OGX Server<br/><i>REST API (HTTPS)</i>"]
    OGXFoundation -->|"chat.completions"| OGXServer
    OGXEmbedding -->|"embeddings.create"| OGXServer
    OGXVectorStore -->|"vector_stores/vector_io"| OGXServer
    MPS -->|"embeddings + chat"| OGXServer

    KFP["Kubeflow Pipelines<br/><i>Pipeline orchestration</i>"]
    KFP -->|"consumes library"| Experiment

    %% Styling
    style Experiment fill:#4a90e2,stroke:#333,color:#fff
    style MPS fill:#4a90e2,stroke:#333,color:#fff
    style GAM fill:#9b59b6,stroke:#333,color:#fff
    style Random fill:#9b59b6,stroke:#333,color:#fff
    style SimpleRAG fill:#2ecc71,stroke:#333,color:#fff
    style Retriever fill:#2ecc71,stroke:#333,color:#fff
    style LangChainChunker fill:#2ecc71,stroke:#333,color:#fff
    style OGXFoundation fill:#e67e22,stroke:#333,color:#fff
    style OGXEmbedding fill:#e67e22,stroke:#333,color:#fff
    style OGXVectorStore fill:#e74c3c,stroke:#333,color:#fff
    style ChromaVectorStore fill:#e74c3c,stroke:#333,color:#fff
    style UnitxtEval fill:#1abc9c,stroke:#333,color:#fff
    style SearchSpace fill:#95a5a6,stroke:#333,color:#fff
    style EventHandler fill:#95a5a6,stroke:#333,color:#fff
    style OGXServer fill:#f5a623,stroke:#333,color:#fff
    style KFP fill:#7ed321,stroke:#333,color:#fff
