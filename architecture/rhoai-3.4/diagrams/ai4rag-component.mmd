graph TB
    subgraph ai4rag["ai4rag Library"]
        direction TB

        subgraph Core["Core - Experiment Engine"]
            Experiment["AI4RAGExperiment<br/>Orchestrates optimization lifecycle"]
            MPS["ModelsPreSelector<br/>Filters models on sample data"]
            SearchSpace["AI4RAGSearchSpace<br/>Parameter combinations + constraints"]
            ExHandler["ExceptionHandler<br/>Aggregates errors across iterations"]
        end

        subgraph HPO["HPO - Hyperparameter Optimization"]
            GAM["GAMOptimizer<br/>GAM surrogate + Bayesian optimization"]
            Random["RandomOptimizer<br/>Baseline random search"]
        end

        subgraph RAG["RAG Pipeline"]
            SimpleRAG["SimpleRAG Template<br/>Chunking → Retrieval → Generation"]
            Chunker["LangChainChunker<br/>RecursiveCharacterTextSplitter"]
            Retriever["Retriever<br/>Similarity search + context assembly"]
        end

        subgraph Providers["Provider Adapters"]
            direction LR
            LSFoundation["LSFoundationModel<br/>Llama Stack chat"]
            LSEmbedding["LSEmbeddingModel<br/>Llama Stack embeddings"]
            LSVector["LSVectorStore<br/>Llama Stack vector_io"]
            OAIFoundation["OpenAIFoundationModel<br/>OpenAI-compatible chat"]
            OAIEmbedding["OpenAIEmbeddingModel<br/>OpenAI-compatible embeddings"]
            ChromaStore["ChromaVectorStore<br/>In-memory ChromaDB"]
        end

        subgraph Eval["Evaluation"]
            Unitxt["UnitxtEvaluator<br/>faithfulness, answer/context correctness"]
        end

        subgraph Output["Output Handlers"]
            LocalHandler["LocalEventHandler<br/>JSON file output"]
            KFPHandler["KFPEventHandler<br/>Kubeflow Pipelines integration"]
        end
    end

    %% Internal flows
    Experiment -->|runs| MPS
    Experiment -->|uses| SearchSpace
    Experiment -->|delegates to| GAM
    Experiment -->|delegates to| Random
    Experiment -->|executes| SimpleRAG
    Experiment -->|evaluates with| Unitxt
    Experiment -->|reports via| LocalHandler
    Experiment -->|reports via| KFPHandler

    MPS -->|filters| SearchSpace
    MPS -->|evaluates with| Unitxt
    MPS -->|uses| ChromaStore

    SimpleRAG -->|chunks with| Chunker
    SimpleRAG -->|retrieves via| Retriever
    SimpleRAG -->|generates via| LSFoundation
    SimpleRAG -->|generates via| OAIFoundation

    Retriever -->|queries| LSVector
    Retriever -->|queries| ChromaStore

    GAM -->|encodes params| SearchSpace

    %% External services
    LlamaStack["Llama Stack Server<br/>(External)"]
    OpenAI["OpenAI-compatible Endpoint<br/>(External)"]
    KFP["Kubeflow Pipelines<br/>(External)"]

    LSFoundation -->|HTTPS / API Key| LlamaStack
    LSEmbedding -->|HTTPS / API Key| LlamaStack
    LSVector -->|HTTPS / API Key| LlamaStack
    OAIFoundation -->|HTTPS / API Key| OpenAI
    OAIEmbedding -->|HTTPS / API Key| OpenAI
    KFPHandler -->|integrates| KFP

    %% Styling
    style ai4rag fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#dbeafe,stroke:#3b82f6
    style HPO fill:#e0e7ff,stroke:#6366f1
    style RAG fill:#dcfce7,stroke:#22c55e
    style Providers fill:#fef3c7,stroke:#f59e0b
    style Eval fill:#fce7f3,stroke:#ec4899
    style Output fill:#f3e8ff,stroke:#a855f7

    style LlamaStack fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    style OpenAI fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
    style KFP fill:#e5e7eb,stroke:#6b7280,stroke-width:2px
