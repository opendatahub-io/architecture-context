// C4 Context Diagram - Models as a Service (MaaS)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / API Consumer" "Creates model references, manages API keys, and invokes inference endpoints"
        admin = person "Platform Admin" "Configures auth policies, subscriptions, and gateway infrastructure"

        maas = softwareSystem "Models as a Service (MaaS)" "Platform for providing LLM inference endpoints as managed services with API key management, subscription-based access control, and token rate limiting" {
            maasController = container "maas-controller" "Reconciles MaaSModelRef, MaaSAuthPolicy, MaaSSubscription CRDs into Kuadrant policies" "Go Operator (controller-runtime)"
            maasApi = container "maas-api" "API key lifecycle management, model discovery, subscription selection, API key validation callback" "Go REST API (Gin framework)"
            modelRefCtrl = container "MaaSModelRef Controller" "Validates HTTPRoutes, populates model status" "Controller"
            authPolicyCtrl = container "MaaSAuthPolicy Controller" "Aggregates auth policies per model into Kuadrant AuthPolicy" "Controller"
            subscriptionCtrl = container "MaaSSubscription Controller" "Aggregates subscriptions per model into Kuadrant TokenRateLimitPolicy" "Controller"
        }

        kuadrant = softwareSystem "Kuadrant (Authorino + Limitador)" "API gateway policy engine for authentication, authorization, and rate limiting" "External"
        kserve = softwareSystem "KServe" "LLMInferenceService CRD for model serving and inference" "External"
        gatewayAPI = softwareSystem "Gateway API (OpenShift)" "Gateway and HTTPRoute resources for traffic routing" "External"
        postgresql = softwareSystem "PostgreSQL" "API key hash storage, validation, and CRUD operations" "External"
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform with Gateway API support" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate provisioning" "External"
        odhPlatform = softwareSystem "ODH Platform Auth CR" "Admin group configuration for API key management authorization" "Internal ODH"

        // User interactions
        user -> maas "Creates MaaSModelRef, manages API keys via REST API"
        admin -> maas "Creates MaaSAuthPolicy, MaaSSubscription CRs via kubectl"

        // MaaS to external systems
        maas -> kuadrant "Creates AuthPolicy and TokenRateLimitPolicy resources" "Kubernetes API"
        maas -> kserve "Watches LLMInferenceService Ready status" "Kubernetes API"
        maas -> gatewayAPI "Manages HTTPRoutes, references Gateway" "Kubernetes API"
        maas -> postgresql "API key hash storage and validation" "PostgreSQL/5432 TLS"
        maas -> kubernetes "Watches CRDs, manages resources" "HTTPS/443"
        maas -> certManager "TLS certificate for maas-api" "Kubernetes API"
        maas -> odhPlatform "Reads admin group configuration" "Kubernetes API"

        // External to MaaS
        kuadrant -> maas "API key validation and subscription selection callbacks" "HTTPS/8443"

        // Internal container relationships
        maasApi -> postgresql "Stores/validates API key hashes" "PostgreSQL/5432"
        authPolicyCtrl -> kuadrant "Creates Kuadrant AuthPolicy" "Kubernetes API"
        subscriptionCtrl -> kuadrant "Creates Kuadrant TokenRateLimitPolicy" "Kubernetes API"
        modelRefCtrl -> kserve "Watches LLMInferenceService" "Kubernetes API"
        modelRefCtrl -> gatewayAPI "Validates HTTPRoute existence" "Kubernetes API"
    }

    views {
        systemContext maas "SystemContext" {
            include *
            autoLayout
        }

        container maas "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
