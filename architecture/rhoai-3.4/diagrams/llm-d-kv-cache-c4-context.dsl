/*
 * C4 Context Diagram for llm-d-kv-cache
 * Generated by: Claude Opus 4.6
 *
 * Render with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   OR: structurizr-cli export -workspace llm-d-kv-cache-c4-context.dsl -format png
 */

workspace {
    model {
        scheduler = person "Inference Scheduler" "llm-d-inference-scheduler; imports kvcache.Indexer as a Go library for KV-cache aware routing"

        kvCache = softwareSystem "llm-d-kv-cache" "KV-Cache Indexer providing global tracking and scoring of KV-Cache block locality across vLLM pod fleets" {
            indexer = container "kvcache.Indexer" "Main orchestrator: tokenization, key generation, index lookup, and pod scoring" "Go Library"
            eventPool = container "kvevents.Pool" "Sharded worker pool ingesting ZMQ-streamed KVEvents from vLLM pods" "Go Library"
            subscriberManager = container "kvevents.SubscriberManager" "Manages per-pod ZMQ subscribers based on pod lifecycle" "Go Library"
            blockIndex = container "kvblock.Index" "Core KV-block hash to pod location store (In-Memory LRU, Ristretto, Redis, Valkey)" "Go Library"
            tokenProcessor = container "kvblock.TokenProcessor" "Converts token sequences into KV-block keys via FNV-64a hashing" "Go Library"
            scorer = container "kvblock.Scorer" "Scores pods using longest consecutive prefix matching with weighted device tiers" "Go Library"
            tokenPool = container "tokenization.Pool" "Worker pool for sync/async tokenization" "Go Library"
            udsTokenizer = container "UDS Tokenizer Service" "Sidecar providing tokenization via gRPC over Unix Domain Sockets" "Python gRPC Service"
            podReconciler = container "PodReconciler" "Kubernetes controller watching pods for dynamic ZMQ subscriber management" "Go controller-runtime"
            grpcServer = container "IndexerService" "Standalone gRPC server wrapping Indexer for remote scoring" "Go gRPC Service" {
                tags "Optional"
            }
            metricsCollector = container "Metrics Collector" "Prometheus metrics for index and tokenization operations" "Go Library"
            telemetry = container "Telemetry" "OpenTelemetry tracing with OTLP exporter" "Go Library"
        }

        vllm = softwareSystem "vLLM Pod Fleet" "LLM inference engines publishing KVEvents via ZMQ PUB/SUB" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for pod discovery and reconciliation" "External"
        redis = softwareSystem "Redis/Valkey" "Optional distributed KV-block index backend" "External" {
            tags "Optional"
        }
        hfHub = softwareSystem "HuggingFace Hub" "Tokenizer model repository for on-demand downloads" "External" {
            tags "Optional"
        }
        otlpCollector = softwareSystem "OpenTelemetry Collector" "Trace collection and export destination" "External" {
            tags "Optional"
        }
        prometheus = softwareSystem "Prometheus" "Metrics scraping and monitoring" "External"

        # Relationships - System level
        scheduler -> kvCache "Imports as Go library; calls GetPodScores()" "In-process"
        vllm -> kvCache "Streams KVEvents (BlockStored/BlockRemoved/AllBlocksCleared)" "ZMQ PUB/SUB :5557"
        kvCache -> k8sApi "Watches pods for auto-discovery" "HTTPS :443"
        kvCache -> redis "Stores/retrieves KV-block index entries" "Redis :6379 (optional TLS)"
        kvCache -> hfHub "Downloads tokenizer models" "HTTPS :443"
        kvCache -> otlpCollector "Exports distributed traces" "gRPC :4317"
        prometheus -> kvCache "Scrapes metrics" "HTTP"

        # Relationships - Container level
        scheduler -> indexer "GetPodScores(prompt, model)" "Go function call"
        indexer -> tokenPool "Tokenize(text)" "Go function call"
        tokenPool -> udsTokenizer "Tokenize()" "gRPC over UDS"
        indexer -> tokenProcessor "TokensToBlockKeys()" "Go function call"
        indexer -> blockIndex "Lookup(blockKeys)" "Go function call / Redis"
        indexer -> scorer "ScorePods()" "Go function call"
        eventPool -> blockIndex "Add/Evict blocks" "Go function call / Redis"
        subscriberManager -> eventPool "Route events" "Go function call"
        podReconciler -> subscriberManager "Add/Remove subscribers" "Go function call"
        podReconciler -> k8sApi "Watch pods" "HTTPS :443"
        udsTokenizer -> hfHub "Download tokenizer models" "HTTPS :443"
        telemetry -> otlpCollector "Export traces" "gRPC :4317"
        vllm -> subscriberManager "KVEvents" "ZMQ PUB/SUB :5557"
    }

    views {
        systemContext kvCache "SystemContext" {
            include *
            autoLayout
        }

        container kvCache "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Optional" {
                background #bbbbbb
                color #ffffff
                border dashed
            }
            element "Person" {
                background #7ed321
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
