graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["${EPP_NAME}<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_EPP["${EPP_NAME}<br/>(ClusterRoleBinding)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_EPP["${EPP_NAME}<br/>(ClusterRole)"]
    end

    subgraph APIResources_GIE_xk8s["inference.networking.x-k8s.io"]
        InferencePools_xk8s["InferencePools<br/>(x-k8s.io)"]
        InferenceObjectives["InferenceObjectives<br/>(x-k8s.io)"]
        InferenceModelRewrites["InferenceModelRewrites<br/>(x-k8s.io)"]
    end

    subgraph APIResources_GIE_k8s["inference.networking.k8s.io"]
        InferencePools_k8s["InferencePools<br/>(k8s.io)"]
    end

    subgraph APIResources_Core["Core API Group"]
        Pods["Pods"]
    end

    subgraph APIResources_Auth["Authentication / Authorization"]
        TokenReviews["TokenReviews<br/>(authentication.k8s.io)"]
        SubjectAccessReviews["SubjectAccessReviews<br/>(authorization.k8s.io)"]
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB_EPP
    RB_EPP -->|"grants"| CR_EPP

    %% Permissions - GIE x-k8s.io
    CR_EPP -->|"get, list, watch"| InferencePools_xk8s
    CR_EPP -->|"get, list, watch"| InferenceObjectives
    CR_EPP -->|"get, list, watch"| InferenceModelRewrites

    %% Permissions - GIE k8s.io
    CR_EPP -->|"get, list, watch"| InferencePools_k8s

    %% Permissions - Core
    CR_EPP -->|"get, list, watch"| Pods

    %% Permissions - Auth
    CR_EPP -->|"create"| TokenReviews
    CR_EPP -->|"create"| SubjectAccessReviews

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style RB_EPP fill:#7ed321,stroke:#333
    style CR_EPP fill:#f5a623,stroke:#333
    style InferencePools_xk8s fill:#dae8fc,stroke:#6c8ebf
    style InferenceObjectives fill:#dae8fc,stroke:#6c8ebf
    style InferenceModelRewrites fill:#dae8fc,stroke:#6c8ebf
    style InferencePools_k8s fill:#d5e8d4,stroke:#82b366
    style Pods fill:#fff2cc,stroke:#d6b656
    style TokenReviews fill:#f8cecc,stroke:#b85450
    style SubjectAccessReviews fill:#f8cecc,stroke:#b85450
