graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["ServiceAccount<br/>$EPP_NAME<br/>Namespace: $NAMESPACE"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["RoleBinding<br/>$EPP_NAME-binding<br/>Namespace: $NAMESPACE"]
    end

    subgraph ClusterRole["ClusterRole: $EPP_NAME"]
        CR["$EPP_NAME"]
    end

    subgraph APIResources["API Resources"]
        direction TB

        subgraph GIE_Legacy["inference.networking.x-k8s.io (legacy)"]
            InferencePools_Legacy["InferencePools"]
            InferenceObjectives["InferenceObjectives"]
            InferenceModelRewrites["InferenceModelRewrites"]
        end

        subgraph GIE_Stable["inference.networking.k8s.io (stable)"]
            InferencePools_Stable["InferencePools"]
        end

        subgraph Core["core ('')"]
            Pods["Pods"]
        end

        subgraph AuthN["authentication.k8s.io"]
            TokenReviews["TokenReviews"]
        end

        subgraph AuthZ["authorization.k8s.io"]
            SubjectAccessReviews["SubjectAccessReviews"]
        end
    end

    %% Bindings
    SA_EPP -->|"bound via"| RB
    RB -->|"grants"| CR

    %% Permissions
    CR -->|"get, watch, list"| InferencePools_Legacy
    CR -->|"get, watch, list"| InferenceObjectives
    CR -->|"get, watch, list"| InferenceModelRewrites
    CR -->|"get, watch, list"| InferencePools_Stable
    CR -->|"get, watch, list"| Pods
    CR -->|"create"| TokenReviews
    CR -->|"create"| SubjectAccessReviews

    %% Secrets
    subgraph Secrets["Secrets"]
        TLSCert["TLS Certificate<br/>Self-signed 4096-bit RSA<br/>or mounted via --cert-path<br/>10-year validity (self-signed)<br/>Filesystem watcher for rotation"]
    end

    SA_EPP -.->|"uses (sidecar)"| TLSCert

    %% SSRF Protection
    subgraph SSRFProtection["SSRF Protection (Optional)"]
        SSRFNote["InferencePool-based pod allowlist<br/>Validates prefill/encoder targets<br/>from request headers<br/>Enabled: --enable-ssrf-protection"]
    end

    InferencePools_Stable -.->|"builds allowlist from"| SSRFNote

    %% Auth endpoints
    subgraph AuthEndpoints["Authentication & Authorization"]
        ExtProc["ext-proc gRPC (9002)<br/>Auth: None<br/>Policy: cluster network"]
        SidecarProxy["Sidecar proxy (8000)<br/>Auth: None<br/>SSRF: optional allowlist"]
        MetricsEP["Prometheus metrics (9090)<br/>Auth: None<br/>Policy: internal-only"]
    end

    SA_EPP -.->|"runs"| ExtProc
    SA_EPP -.->|"runs"| SidecarProxy
    SA_EPP -.->|"exposes"| MetricsEP

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style RB fill:#e8e8e8,stroke:#333

    style InferencePools_Legacy fill:#7ed321,stroke:#333
    style InferenceObjectives fill:#7ed321,stroke:#333
    style InferenceModelRewrites fill:#7ed321,stroke:#333
    style InferencePools_Stable fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style TokenReviews fill:#e67e22,stroke:#333,color:#fff
    style SubjectAccessReviews fill:#e67e22,stroke:#333,color:#fff

    style TLSCert fill:#f39c12,stroke:#333
    style SSRFNote fill:#fff3e0,stroke:#ef6c00

    style ExtProc fill:#dae8fc,stroke:#6c8ebf
    style SidecarProxy fill:#dae8fc,stroke:#6c8ebf
    style MetricsEP fill:#dae8fc,stroke:#6c8ebf
