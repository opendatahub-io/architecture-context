graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph PlatformIngress["INGRESS (Platform-Managed by rhods-operator)"]
        Gateway["Platform Gateway<br/>(Gateway API / OpenShift Route)<br/>TLS Termination"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph NS_LLS["Namespace: (operator-managed)"]
            LLS["Llama Stack Server<br/>llama-stack ClusterIP<br/>8321/TCP HTTP (plaintext)<br/>OAuth2 JWT (optional)<br/>Image: quay.io/rhoai/odh-llama-stack-core-rhel9"]
        end

        subgraph NS_Platform["Platform Services"]
            vLLM["vLLM Inference<br/>HTTP/HTTPS<br/>Bearer Token"]
            vLLME["vLLM Embedding<br/>HTTP/HTTPS<br/>Bearer Token"]
            TrustyAIFMS["TrustyAI FMS<br/>HTTP/HTTPS<br/>Certificate auth"]
            TrustyAILMEval["TrustyAI LM-Eval<br/>HTTP<br/>No auth"]
            KFP["Kubeflow Pipelines<br/>HTTP<br/>Bearer Token"]
            PG["PostgreSQL<br/>5432/TCP<br/>Password auth"]
            OTEL["OTEL Collector<br/>HTTP OTLP<br/>No auth"]
        end

        subgraph NS_Storage["Storage Services"]
            S3["S3-compatible Storage<br/>(MinIO/ODF)<br/>443/TCP HTTPS<br/>AWS IAM"]
        end
    end

    subgraph ExternalCloud["EXTERNAL CLOUD SERVICES"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS TLS 1.2+<br/>Bearer Token"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS TLS 1.2+<br/>Google ADC OAuth2"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS TLS 1.2+<br/>API Key"]
    end

    subgraph ExternalVectorDBs["EXTERNAL VECTOR DATABASES"]
        Milvus["Milvus (remote)<br/>TCP TLS/mTLS (optional)<br/>Token (optional)"]
        PGVector["PGVector<br/>5432/TCP plaintext<br/>Password"]
        Qdrant["Qdrant<br/>6333/6334 TCP<br/>HTTPS (optional)<br/>API Key (optional)"]
    end

    subgraph ExternalTools["EXTERNAL TOOLS & SERVICES"]
        Brave["Brave Search<br/>443/TCP HTTPS<br/>API Key"]
        Tavily["Tavily Search<br/>443/TCP HTTPS<br/>API Key"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>Token (optional)"]
        JWKS["OAuth2 JWKS Endpoint<br/>443/TCP HTTPS<br/>Public keys"]
    end

    %% External to Ingress
    Client -->|"HTTPS (TLS terminated)<br/>OAuth2 JWT (optional)"| Gateway

    %% Ingress to Service
    Gateway -->|"HTTP/8321<br/>plaintext (cluster-internal)"| LLS

    %% Internal Platform flows
    LLS -->|"HTTP/HTTPS<br/>TLS configurable<br/>Bearer Token"| vLLM
    LLS -->|"HTTP/HTTPS<br/>TLS configurable<br/>Bearer Token"| vLLME
    LLS -->|"HTTP/HTTPS<br/>TLS optional (cert)<br/>Certificate"| TrustyAIFMS
    LLS -->|"HTTP<br/>No TLS"| TrustyAILMEval
    LLS -->|"HTTP<br/>Bearer Token"| KFP
    LLS -->|"TCP/5432<br/>plaintext<br/>Password"| PG
    LLS -.->|"HTTP OTLP<br/>No auth"| OTEL
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3

    %% External Cloud flows
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2"| VertexAI
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WatsonX
    LLS -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| AzureOAI

    %% Vector DB flows
    LLS -->|"TCP<br/>TLS/mTLS optional<br/>Token optional"| Milvus
    LLS -->|"TCP/5432<br/>plaintext<br/>Password"| PGVector
    LLS -->|"HTTP-gRPC/6333-6334<br/>HTTPS optional<br/>API Key optional"| Qdrant

    %% Tools & Services flows
    LLS -->|"HTTPS/443<br/>API Key"| Brave
    LLS -->|"HTTPS/443<br/>API Key"| Tavily
    LLS -->|"HTTPS/443<br/>Token optional"| HFHub
    LLS -.->|"HTTPS/443<br/>JWKS validation"| JWKS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalcloud fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef vectordb fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef tools fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef warn fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Gateway ingress
    class LLS internal
    class vLLM,vLLME,TrustyAIFMS,TrustyAILMEval,KFP,PG,OTEL,S3 internal
    class Bedrock,VertexAI,OpenAI,WatsonX,AzureOAI externalcloud
    class Milvus,PGVector,Qdrant vectordb
    class Brave,Tavily,HFHub,JWKS tools
