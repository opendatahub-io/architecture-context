graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed TLS Termination)"]
        Gateway["Platform Ingress<br/>(Gateway API / HTTPRoute)<br/>443/TCP → 8321/TCP<br/>TLS 1.2+ termination"]
    end

    subgraph Application["APPLICATION (Llama Stack Server Container)"]
        direction TB

        AuthMW["OAuth2 JWT Middleware<br/>AUTH_ISSUER / AUTH_JWKS_URI<br/>Owner-based access control"]
        LlamaStack["Llama Stack Server<br/>Port: 8321/TCP HTTP<br/>Non-root user<br/>UBI 9 Python 3.12"]
        HealthEndpoint["/v1/health<br/>(Unauthenticated)"]
    end

    subgraph InternalPlatform["INTERNAL PLATFORM SERVICES"]
        direction TB

        vLLMInference["vLLM Inference<br/>configurable port<br/>HTTP/HTTPS<br/>API Token"]
        vLLMEmbed["vLLM Embedding<br/>configurable port<br/>HTTP/HTTPS<br/>API Token"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>plaintext<br/>Username/Password"]
        TrustyAIFMS["TrustyAI FMS<br/>configurable port<br/>HTTP/HTTPS<br/>FMS_SSL_CERT_PATH<br/>None (in-cluster)"]
        TrustyAILMEval["TrustyAI LMEval<br/>configurable port<br/>HTTP/HTTPS<br/>None (in-cluster)"]
        Kubeflow["Kubeflow Pipelines<br/>configurable port<br/>HTTP/HTTPS<br/>API Token"]
        pgvector["pgvector<br/>5432/TCP<br/>PostgreSQL<br/>Username/Password"]
    end

    subgraph VectorDBs["VECTOR DATABASES (Conditional)"]
        Milvus["Milvus (remote)<br/>configurable port<br/>HTTP/HTTPS<br/>mTLS (CA+Client certs)<br/>Token auth"]
        Qdrant["Qdrant<br/>6333/TCP (HTTP)<br/>6334/TCP (gRPC)<br/>configurable HTTPS<br/>API Key"]
    end

    subgraph CloudServices["EXTERNAL CLOUD SERVICES (TLS 1.2+)"]
        direction TB

        Bedrock["AWS Bedrock<br/>443/TCP HTTPS<br/>Bearer Token"]
        Azure["Azure OpenAI<br/>443/TCP HTTPS<br/>API Key"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS<br/>App Default Credentials"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS<br/>API Key"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS<br/>API Key"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>None/Token"]
    end

    subgraph ToolServices["TOOL SERVICES (TLS 1.2+)"]
        BraveSearch["Brave Search<br/>443/TCP HTTPS<br/>API Key"]
        TavilySearch["Tavily Search<br/>443/TCP HTTPS<br/>API Key"]
        MCPServers["MCP Servers<br/>configurable<br/>HTTP/HTTPS"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTELCollector["OTEL Collector<br/>configurable port<br/>HTTP (OTLP)<br/>No auth"]
    end

    subgraph AuthProvider["AUTH PROVIDER"]
        OIDC["OAuth2/OIDC Issuer<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>JWKS endpoint"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer JWT"| Gateway

    %% Ingress → Application
    Gateway -->|"HTTP/8321<br/>plaintext<br/>JWT passthrough"| AuthMW
    Gateway -->|"HTTP/8321<br/>No auth"| HealthEndpoint
    AuthMW --> LlamaStack

    %% Auth validation
    LlamaStack -.->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| OIDC

    %% Application → Internal Platform
    LlamaStack -->|"HTTP/HTTPS<br/>API Token"| vLLMInference
    LlamaStack -->|"HTTP/HTTPS<br/>API Token"| vLLMEmbed
    LlamaStack -->|"PostgreSQL/5432<br/>plaintext<br/>User/Pass"| PostgreSQL
    LlamaStack -->|"HTTP/HTTPS<br/>FMS_SSL_CERT<br/>In-cluster"| TrustyAIFMS
    LlamaStack -->|"HTTP/HTTPS<br/>In-cluster"| TrustyAILMEval
    LlamaStack -->|"HTTP/HTTPS<br/>API Token"| Kubeflow
    LlamaStack -->|"PostgreSQL/5432<br/>User/Pass"| pgvector

    %% Application → Vector DBs
    LlamaStack -->|"HTTP/HTTPS<br/>mTLS<br/>Token"| Milvus
    LlamaStack -->|"HTTP 6333 / gRPC 6334<br/>API Key"| Qdrant

    %% Application → Cloud Services
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Bedrock
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| Azure
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| VertexAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| OpenAI
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| WatsonX
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    LlamaStack -->|"HTTPS/443<br/>TLS 1.2+"| HuggingFace

    %% Application → Tool Services
    LlamaStack -->|"HTTPS/443<br/>API Key"| BraveSearch
    LlamaStack -->|"HTTPS/443<br/>API Key"| TavilySearch
    LlamaStack -->|"HTTP/HTTPS<br/>configurable"| MCPServers

    %% Application → Observability
    LlamaStack -.->|"HTTP (OTLP)<br/>configurable"| OTELCollector

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internalplatform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef vectordb fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cloudservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef toolservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef observability fill:#e6e6e6,stroke:#666,stroke-width:1px
    classDef auth fill:#f5a623,stroke:#333,stroke-width:2px

    class Client external
    class Gateway ingress
    class AuthMW,LlamaStack,HealthEndpoint application
    class vLLMInference,vLLMEmbed,PostgreSQL,TrustyAIFMS,TrustyAILMEval,Kubeflow,pgvector internalplatform
    class Milvus,Qdrant vectordb
    class Bedrock,Azure,VertexAI,OpenAI,WatsonX,S3,HuggingFace cloudservice
    class BraveSearch,TavilySearch,MCPServers toolservice
    class OTELCollector observability
    class OIDC auth
