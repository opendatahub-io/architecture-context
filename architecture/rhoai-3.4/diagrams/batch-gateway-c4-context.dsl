// C4 Context Diagram: batch-gateway
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/batch-gateway.md

workspace {
    model {
        user = person "API Client" "Submits batch inference requests and manages files via OpenAI-compatible API"

        batchGateway = softwareSystem "Batch Gateway" "OpenAI-compatible batch inference API gateway for processing bulk LLM inference requests" {
            apiServer = container "API Server" "Exposes OpenAI-compatible /v1/files and /v1/batches REST endpoints for file upload, batch creation, listing, retrieval, and cancellation" "Go HTTP Service, port 8000/TCP"
            batchProcessor = container "Batch Processor" "Polls priority queue for pending batch jobs, dispatches to worker pool, forwards inference requests to downstream gateway" "Go Worker Service, port 9090/TCP"
            workerPool = container "Worker Pool" "Fixed-size goroutine pool with channel-based worker ID management for concurrent job processing" "Go Concurrency"
            inferenceClient = container "Inference HTTP Client" "Sends inference requests to downstream gateway with retry logic, mTLS support, and exponential backoff" "Go HTTP Client"
            middlewareStack = container "Middleware Stack" "Recovery (panic handling), request monitoring, security headers, CORS" "Go Middleware"
        }

        redis = softwareSystem "Redis" "Priority queue, event channels, status store, and metadata storage" "External"
        postgresql = softwareSystem "PostgreSQL" "Alternative persistent metadata storage" "External"
        s3 = softwareSystem "AWS S3 / S3-compatible" "File storage backend for batch input/output files" "External"
        inferenceGateway = softwareSystem "Inference Gateway (llm-d/GAIE)" "Downstream endpoint for executing individual inference requests" "Internal ODH"
        certManager = softwareSystem "cert-manager" "Optional TLS certificate provisioning" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // External relationships
        user -> batchGateway "Submits batch jobs and files" "HTTP/HTTPS 8000/TCP, X-MaaS-User header"
        batchGateway -> redis "Stores metadata, queues jobs, publishes events" "Redis/6379/TCP, TLS optional"
        batchGateway -> postgresql "Stores batch/file metadata (alternative)" "PostgreSQL/5432/TCP, TLS optional"
        batchGateway -> s3 "Stores and retrieves batch files" "HTTPS/443"
        batchGateway -> inferenceGateway "Forwards individual inference requests" "HTTP/HTTPS, TLS 1.2+, mTLS optional"
        certManager -> batchGateway "Provisions TLS certificates" "Certificate CR"
        prometheus -> batchGateway "Scrapes metrics" "HTTP/HTTPS 8000/TCP, 9090/TCP"

        // Internal relationships
        apiServer -> redis "Metadata CRUD, enqueue jobs" "Redis/6379/TCP"
        apiServer -> postgresql "Metadata CRUD" "PostgreSQL/5432/TCP"
        apiServer -> s3 "Upload/download files" "HTTPS/443"
        batchProcessor -> redis "Poll queue, status updates" "Redis/6379/TCP"
        batchProcessor -> workerPool "Dispatches jobs"
        workerPool -> inferenceClient "Sends inference requests"
        inferenceClient -> inferenceGateway "Forward inference request" "HTTP/HTTPS, Bearer Token"
        middlewareStack -> apiServer "Wraps request handling"
    }

    views {
        systemContext batchGateway "SystemContext" {
            include *
            autoLayout
        }

        container batchGateway "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #6ba3e8
                color #ffffff
            }
        }
    }
}
