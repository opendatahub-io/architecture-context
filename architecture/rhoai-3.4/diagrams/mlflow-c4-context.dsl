// MLflow C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/mlflow.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates experiments, tracks runs, registers models, and queries AI gateway"
        mlApp = person "ML Application / SDK" "Automated pipeline or SDK client logging metrics, parameters, and traces"

        mlflow = softwareSystem "MLflow" "ML lifecycle platform providing experiment tracking, model registry, AI gateway, and artifact management" {
            trackingServer = container "MLflow Tracking Server" "FastAPI/Flask application providing REST API for experiment tracking, model registry, and UI" "Python FastAPI/Flask (uvicorn:5000)"
            reactUI = container "React UI" "Web-based interface for experiment visualization, model management, and trace inspection" "TypeScript/React SPA"
            kubeWorkspaceProvider = container "Kubernetes Workspace Provider" "Maps MLflow workspaces to Kubernetes namespaces with watch-based caching and MLflowConfig CRD support" "Python Plugin"
            kubeAuthPlugin = container "Kubernetes Auth Plugin" "Enforces Kubernetes RBAC via TokenReview and SubjectAccessReview for all API calls" "Python Plugin"
            aiGateway = container "AI Gateway API" "Database-backed gateway for proxying requests to LLM providers" "FastAPI Router"
            otelIngest = container "OpenTelemetry Ingest API" "OTLP/HTTP endpoint for ingesting trace spans in protobuf format" "FastAPI Router"
            prometheusExporter = container "Prometheus Exporter" "Prometheus metrics collection for monitoring" "Flask Extension"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for authentication, authorization, namespace management, and CRD access" "External"
        postgresql = softwareSystem "PostgreSQL Database" "Backend store for experiment tracking, model registry, and gateway configuration" "External"
        s3Storage = softwareSystem "S3-compatible Object Storage" "Artifact storage for models, datasets, and run artifacts" "External"
        platformIngress = softwareSystem "OpenShift Platform Ingress" "TLS termination and external access via Routes or Gateway API" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"

        openai = softwareSystem "OpenAI API" "LLM provider for chat, embeddings, and responses" "External"
        anthropic = softwareSystem "Anthropic API" "LLM provider for chat" "External"
        gemini = softwareSystem "Google Gemini API" "LLM provider for content generation" "External"
        mistral = softwareSystem "Mistral API" "LLM provider for chat" "External"

        // User interactions
        dataScientist -> mlflow "Creates experiments, logs runs, registers models, queries gateway" "HTTPS/443"
        mlApp -> mlflow "Logs metrics, parameters, artifacts, exports OTLP traces" "HTTPS/443"

        // Internal container relationships
        trackingServer -> kubeAuthPlugin "Delegates authentication and authorization"
        kubeAuthPlugin -> kubeWorkspaceProvider "Resolves workspace context"
        trackingServer -> reactUI "Serves bundled UI"
        trackingServer -> aiGateway "Routes /gateway/* requests"
        trackingServer -> otelIngest "Routes /v1/traces requests"
        trackingServer -> prometheusExporter "Exposes /metrics"

        // External system interactions
        mlflow -> k8sAPI "TokenReview, SubjectAccessReview, namespace watch, secret reads, MLflowConfig CRD watch" "HTTPS/443"
        mlflow -> postgresql "Experiment tracking, model registry, gateway config persistence" "PostgreSQL/5432"
        mlflow -> s3Storage "Artifact storage operations (upload/download)" "HTTPS/443"
        mlflow -> openai "AI Gateway LLM proxy (chat/embeddings)" "HTTPS/443"
        mlflow -> anthropic "AI Gateway LLM proxy (chat)" "HTTPS/443"
        mlflow -> gemini "AI Gateway LLM proxy (generateContent)" "HTTPS/443"
        mlflow -> mistral "AI Gateway LLM proxy (chat)" "HTTPS/443"

        platformIngress -> mlflow "Routes external traffic" "HTTP/5000"
        prometheus -> mlflow "Scrapes metrics" "HTTP/5000"
    }

    views {
        systemContext mlflow "SystemContext" {
            include *
            autoLayout
        }

        container mlflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
