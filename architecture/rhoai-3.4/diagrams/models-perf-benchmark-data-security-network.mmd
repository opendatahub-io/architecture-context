graph TB
    subgraph BuildEnv["BUILD-TIME ENVIRONMENT (Offline - Not on Cluster)"]
        direction TB
        Processor["Kafka Processor<br/>Python 3.12<br/>confluent-kafka / librdkafka<br/>Consumer Group: model-benchmark-processor"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time)"]
        KafkaBroker["Kafka Broker<br/>9092/TCP or 9096/TCP<br/>SASL_SSL (TLS)<br/>SCRAM-SHA-512"]
    end

    subgraph Cluster["KUBERNETES CLUSTER (Runtime)"]
        direction TB

        subgraph NS_Registry["Namespace: odh-model-registries"]
            direction TB

            subgraph Pod["model-catalog Pod"]
                direction TB
                InitContainer["Init Container (Data Image)<br/>odh-model-performance-data-rhel9<br/>Base: UBI9-minimal<br/>UID: 1001 (non-root)<br/>NO NETWORK ACTIVITY"]
                SharedVolume[("Shared Volume<br/>/app/benchmarks<br/>Static data files")]
                MainContainer["model-catalog<br/>Main Container"]

                InitContainer -->|"Volume mount<br/>(no network)"| SharedVolume
                SharedVolume -->|"Read at startup<br/>(no network)"| MainContainer
            end
        end

        Operator["model-registry-operator<br/>Manages Deployment"]
    end

    %% Build-time flow
    KafkaBroker -->|"Kafka/9096<br/>SASL_SSL<br/>SCRAM-SHA-512"| Processor

    %% Runtime management
    Operator -->|"Manages deployment<br/>Injects init container ref"| Pod

    %% Styling
    classDef buildtime fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef initcontainer fill:#dcedc8,stroke:#689f38,stroke-width:2px
    classDef maincontainer fill:#c8e6c9,stroke:#388e3c,stroke-width:2px
    classDef volume fill:#f5f5f5,stroke:#9e9e9e,stroke-width:2px
    classDef operator fill:#e1bee7,stroke:#7b1fa2,stroke-width:2px

    class Processor buildtime
    class KafkaBroker external
    class InitContainer initcontainer
    class MainContainer maincontainer
    class SharedVolume volume
    class Operator operator
