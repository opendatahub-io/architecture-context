graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / kubectl"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer / x509 / SA tokens"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)<br/>NetworkPolicy: intra-namespace + OpenShift Ingress"]
        direction TB

        WebhookPod["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>9443/TCP HTTPS (self-signed/cert-manager)<br/>8080/TCP HTTP metrics<br/>8081/TCP HTTP probes"]

        ControllerPod["spark-operator-controller<br/>SA: spark-operator-controller<br/>8080/TCP HTTP metrics<br/>8081/TCP HTTP probes"]
    end

    subgraph SparkNS["SPARK JOB NAMESPACE (user namespace)"]
        direction TB

        DriverPod["Driver Pod<br/>SA: spark-operator-spark<br/>4040/TCP HTTP (Spark UI)<br/>7078/TCP, 7079/TCP TCP"]

        ExecutorPods["Executor Pods<br/>SA: spark-operator-spark<br/>7078/TCP, 7079/TCP TCP"]

        SparkUISvc["Spark UI Service<br/>ClusterIP 4040/TCP<br/>HTTP, no auth"]

        ConnectSvc["SparkConnect Service<br/>ClusterIP 15002/TCP<br/>Spark Connect protocol<br/>no encryption"]
    end

    subgraph Ingress["INGRESS (Optional)"]
        UIIngress["Spark UI Ingress<br/>80/TCP HTTP<br/>TLS optional (SIMPLE)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus / OpenShift Monitoring<br/>PodMonitor scrape<br/>8080/TCP HTTP, no auth"]
    end

    subgraph OptionalDeps["OPTIONAL INTEGRATIONS (CRD-based, no network)"]
        Volcano["Volcano Scheduler<br/>PodGroup CRDs"]
        CertMgr["cert-manager<br/>Certificate + Issuer CRDs"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| APIServer

    %% Control Plane → Webhook
    APIServer -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client auth"| WebhookPod

    %% Controller → API Server
    ControllerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount token"| APIServer

    %% Controller → Spark pods
    ControllerPod -->|"creates via API"| DriverPod
    DriverPod -->|"TCP/7078, 7079<br/>No encryption<br/>No auth"| ExecutorPods

    %% Spark UI
    DriverPod -->|"HTTP/4040"| SparkUISvc
    SparkUISvc -->|"HTTP/4040"| UIIngress

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| ControllerPod
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| WebhookPod

    %% Optional deps (CRD-based)
    ControllerPod -.->|"PodGroup CRDs"| Volcano
    WebhookPod -.->|"Certificate CRDs"| CertMgr

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef sparkns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class APIServer controlplane
    class WebhookPod,ControllerPod operatorns
    class DriverPod,ExecutorPods,SparkUISvc,ConnectSvc sparkns
    class UIIngress ingress
    class Prometheus monitoring
    class Volcano,CertMgr optional
