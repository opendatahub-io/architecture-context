graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
        Client["SparkConnect Client"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer token / client certs"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE: redhat-ods-applications"]
        direction TB

        subgraph WebhookZone["Webhook (TLS Endpoint)"]
            WebhookSvc["spark-operator-webhook-svc<br/>ClusterIP 443→9443/TCP<br/>HTTPS TLS (self-signed CA)<br/>2048-bit RSA, 10yr validity"]
            WebhookPod["spark-operator-webhook<br/>SA: spark-operator-webhook<br/>9443: HTTPS (webhooks)<br/>8080: HTTP (metrics)<br/>8081: HTTP (health)<br/>HTTP/2 disabled"]
            WebhookSvc --> WebhookPod
        end

        subgraph ControllerZone["Controller"]
            ControllerPod["spark-operator-controller<br/>SA: spark-operator-controller<br/>8080: HTTP (metrics)<br/>8081: HTTP (health)<br/>Contains: spark-submit"]
        end

        WebhookCerts["Secret: spark-operator-webhook-certs<br/>ca-key.pem, ca-cert.pem<br/>server-key.pem, server-cert.pem<br/>Auto-rotate: 180d threshold"]
        NetPolicy["NetworkPolicy:<br/>spark-operator-allow-internal"]
    end

    subgraph UserNS["USER NAMESPACE (per SparkApplication)"]
        direction TB

        DriverPod["Driver Pod<br/>SA: spark-operator-spark<br/>7078/TCP: Driver RPC (no enc)<br/>7079/TCP: BlockManager (no enc)<br/>Optional: JMX :8090"]
        ExecutorPods["Executor Pods<br/>7078→Driver (TCP, no enc)<br/>7079→Driver (TCP, no enc)<br/>Optional: JMX :8090"]
        WebUISvc["Web UI Service<br/>4040/TCP HTTP (no enc)"]
        IngressOpt["Ingress (optional)<br/>80/443 HTTP/HTTPS<br/>Optional TLS"]
    end

    subgraph SparkConnectNS["SPARKCONNECT NAMESPACE"]
        ConnectSvc["SparkConnect Service<br/>7078: Driver RPC<br/>7079: BlockManager<br/>4040: Web UI<br/>15002: gRPC (no enc)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scraping"]
    end

    subgraph OptionalSchedulers["OPTIONAL BATCH SCHEDULERS"]
        Volcano["Volcano<br/>PodGroup CRDs<br/>via K8s API"]
        YuniKorn["Apache YuniKorn<br/>Pod annotations"]
        KubeSched["Kube-Scheduler Plugins<br/>PodGroup CRDs<br/>via K8s API"]
    end

    %% External → Control Plane
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| K8sAPI

    %% Control Plane → Webhook (admission)
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API server client cert"| WebhookSvc

    %% Controller → API Server
    ControllerPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Controller creates workloads
    ControllerPod -.->|"creates via<br/>spark-submit"| DriverPod
    DriverPod -.->|"creates via<br/>K8s API"| ExecutorPods
    ControllerPod -.->|"creates"| WebUISvc
    ControllerPod -.->|"creates"| ConnectSvc

    %% Driver → API
    DriverPod -->|"HTTPS/443<br/>TLS 1.2+<br/>spark SA token"| K8sAPI

    %% Executor → Driver (unencrypted)
    ExecutorPods -->|"TCP/7078<br/>No encryption<br/>No auth"| DriverPod
    ExecutorPods -->|"TCP/7079<br/>No encryption<br/>No auth"| DriverPod

    %% SparkConnect client
    Client -->|"gRPC/15002<br/>No encryption<br/>No auth"| ConnectSvc

    %% Ingress
    IngressOpt -->|"HTTP/4040"| WebUISvc

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No auth"| ControllerPod
    Prometheus -->|"HTTP/8080<br/>No auth"| WebhookPod
    Prometheus -->|"HTTP/8090<br/>No auth"| DriverPod

    %% Webhook certs
    WebhookCerts -.->|"mounted"| WebhookPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operatorns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef scheduler fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef secret fill:#ffe6cc,stroke:#d79b00,stroke-width:1px,stroke-dasharray: 5 5

    class User,Client external
    class K8sAPI controlplane
    class WebhookPod,WebhookSvc,ControllerPod operatorns
    class DriverPod,ExecutorPods,WebUISvc,IngressOpt userns
    class ConnectSvc userns
    class Prometheus monitoring
    class Volcano,YuniKorn,KubeSched scheduler
    class WebhookCerts,NetPolicy secret
