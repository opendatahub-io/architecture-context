        Caller["User / ServiceAccount<br/>(caller's existing RBAC)"]
    end

    subgraph "Read Permissions (lint + backup)"
        direction TB

        subgraph "Platform APIs"
            DSC_R["datasciencecluster.opendatahub.io<br/>datascienceclusters<br/>get, list"]
            DSCI_R["dscinitialization.opendatahub.io<br/>dscinitializations<br/>get, list"]
            CRD_R["apiextensions.k8s.io<br/>customresourcedefinitions<br/>get, list"]
            CV_R["config.openshift.io<br/>clusterversions<br/>get, list"]
        end

        subgraph "OLM APIs"
            OLM_R["operators.coreos.com<br/>subscriptions, csvs, installplans<br/>get, list"]
            PKG_R["packages.operators.coreos.com<br/>packagemanifests<br/>get, list"]
        end

        subgraph "Workload APIs"
            NB_R["kubeflow.org<br/>notebooks, pytorchjobs<br/>get, list"]
            KS_R["serving.kserve.io<br/>inferenceservices, servingruntimes<br/>llminferenceservices<br/>get, list"]
            KQ_R["kueue.x-k8s.io<br/>clusterqueues, localqueues<br/>get, list"]
