            CF_R["workload.codeflare.dev<br/>appwrappers<br/>get, list"]
            GR_R["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>get, list"]
            DSPA_R["datasciencepipelinesapplications<br/>.opendatahub.io<br/>datasciencepipelinesapplications<br/>get, list"]
        end

        subgraph "Core APIs"
            CORE_R["core ('')<br/>configmaps, secrets, namespaces<br/>pods, services, pvcs<br/>get, list"]
            APPS_R["apps<br/>deployments, statefulsets<br/>replicasets, daemonsets<br/>get, list"]
            BATCH_R["batch<br/>jobs, cronjobs<br/>get, list"]
            IMG_R["image.openshift.io<br/>imagestreams, imagestreamtags<br/>get, list"]
        end

        subgraph "Profile APIs"
            PROF_R["dashboard.opendatahub.io<br/>opendatahub.io<br/>acceleratorprofiles, hardwareprofiles<br/>get, list"]
            INFRA_R["infrastructure.opendatahub.io<br/>hardwareprofiles<br/>get, list"]
        end
    end

