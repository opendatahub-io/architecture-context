/*
 * C4 Context Diagram - odh-model-controller
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-19
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and deploys ML models via InferenceService and LLMInferenceService CRs"
        platformAdmin = person "Platform Admin" "Configures NIM accounts, serving runtimes, and platform settings"

        odhModelController = softwareSystem "odh-model-controller" "Kubernetes operator automating model serving infrastructure: routes, monitoring, autoscaling, authentication, and certificate management" {
            manager = container "Controller Manager" "Main controller binary with 8 controllers managing InferenceService, LLMInferenceService, ServingRuntime, ConfigMap, Secret, Pod, NIM Account, and InferenceGraph resources" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Mutating/Validating admission webhooks for Pod (Ray TLS), InferenceService, InferenceGraph, and NIM Account" "Go (9443/TCP TLS)"
            discoveryServer = container "Gateway Discovery Server" "HTTPS API endpoint for Gateway API resource discovery at /api/v1/gateways" "Go HTTP Server (8443/TCP TLS)"
        }

        kserve = softwareSystem "KServe" "Provides InferenceService, ServingRuntime, LLMInferenceService CRDs (ODH fork v0.17)" "External"
        istio = softwareSystem "Istio" "Service mesh - EnvoyFilter creation for Authorino TLS bootstrap" "External"
        kuadrant = softwareSystem "Kuadrant / Authorino" "Gateway API authentication via AuthPolicy CRDs" "External"
        keda = softwareSystem "KEDA" "Autoscaling via TriggerAuthentication on Prometheus metrics" "External"
        prometheusOp = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor CRDs for observability" "External"
        gatewayAPI = softwareSystem "Gateway API" "Gateway and HTTPRoute resources for LLM serving ingress" "External"
        certManager = softwareSystem "OpenShift service-ca" "Webhook TLS certificate provisioning" "External"
        openshift = softwareSystem "OpenShift" "Route and Template CRDs for ingress and runtime management" "External"

        rhodsOperator = softwareSystem "rhods-operator" "Deploys odh-model-controller via Kustomize overlays" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Optional InferenceService metadata sync" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing model serving" "Internal ODH"

        nvidiaAPI = softwareSystem "NVIDIA NGC API" "NIM API key validation and model catalog retrieval" "External Service"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource watches and management" "Infrastructure"

        # User interactions
        user -> odhModelController "Creates InferenceService / LLMInferenceService via kubectl" "HTTPS/443"
        platformAdmin -> odhModelController "Creates NIM Account, configures data connections" "HTTPS/443"

        # Controller interactions
        odhModelController -> kserve "Watches InferenceService, ServingRuntime, LLMInferenceService CRs"
        odhModelController -> openshift "Creates Routes for exposed InferenceServices" "HTTPS/443"
        odhModelController -> istio "Creates EnvoyFilters for Authorino TLS"
        odhModelController -> kuadrant "Creates AuthPolicies for Gateway API auth"
        odhModelController -> keda "Creates TriggerAuthentications for autoscaling"
        odhModelController -> prometheusOp "Creates ServiceMonitors/PodMonitors"
        odhModelController -> gatewayAPI "Watches Gateway/HTTPRoute resources"
        odhModelController -> nvidiaAPI "Validates NIM API keys, fetches model catalog" "HTTPS/443"
        odhModelController -> modelRegistry "Syncs InferenceService metadata" "HTTP/HTTPS"
        odhModelController -> k8sAPI "Watches and manages cluster resources" "HTTPS/443"

        # Platform interactions
        rhodsOperator -> odhModelController "Deploys via Kustomize, injects image parameters"
        odhDashboard -> odhModelController "UI-driven model serving management"

        # Internal container relationships
        manager -> webhookServer "Hosts webhook endpoints"
        manager -> k8sAPI "Watches CRs, creates resources" "HTTPS/443 TLS 1.2+ ServiceAccount"
        discoveryServer -> k8sAPI "Queries Gateway resources" "HTTPS/443 TLS 1.2+ ServiceAccount"
    }

    views {
        systemContext odhModelController "SystemContext" "System Context diagram for odh-model-controller" {
            include *
            autoLayout
        }

        container odhModelController "Containers" "Container diagram showing internal components" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
