graph TB
    subgraph BuildTime["Build-Time Environment (Offline)"]
        direction TB
        subgraph KafkaProc["Kafka Processor (Python CLI)"]
            Consumer["Kafka Consumer<br/>confluent-kafka"]
            Pipeline["Processing Pipeline<br/>Entity Detection &amp; Routing"]
            Transforms["Transforms<br/>OverallAccuracy<br/>HardwareConfiguration"]
            Writer["File Writer<br/>JSON / NDJSON"]
            Consumer --> Pipeline
            Pipeline --> Transforms
            Transforms --> Writer
        end
        Writer -->|writes| DataDir["data/ Directory<br/>provider/model structure<br/>manifest.json"]
    end

    subgraph ContainerBuild["Container Image Build"]
        DataDir -->|COPY| DataImage["Data Container Image<br/>managed-open-data-hub/<br/>odh-model-performance-data-rhel9<br/>Base: UBI9-minimal"]
    end

    subgraph Runtime["Runtime - Kubernetes Cluster"]
        subgraph NS_ModelReg["Namespace: odh-model-registries"]
            subgraph ModelCatalogPod["model-catalog Pod"]
                InitContainer["Init Container<br/>(Data Image)<br/>UID: 1001"]
                SharedVol[("Shared Volume<br/>/app/benchmarks")]
                ModelCatalog["model-catalog<br/>Main Container"]
                InitContainer -->|mounts &amp; populates| SharedVol
                SharedVol -->|reads at startup| ModelCatalog
            end
        end
    end

    KafkaBroker["Kafka Broker<br/>9096/TCP<br/>SASL_SSL"] -->|consume messages| Consumer
    Operator["model-registry-operator"] -->|manages deployment<br/>injects init container| ModelCatalogPod

    %% Styling
    style Consumer fill:#4a90e2,stroke:#333,color:#fff
    style Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style Transforms fill:#4a90e2,stroke:#333,color:#fff
    style Writer fill:#4a90e2,stroke:#333,color:#fff
    style DataDir fill:#f5a623,stroke:#333,color:#fff
    style DataImage fill:#7ed321,stroke:#333,color:#fff
    style InitContainer fill:#7ed321,stroke:#333,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style SharedVol fill:#f5a623,stroke:#333
    style KafkaBroker fill:#999,stroke:#333,color:#fff
    style Operator fill:#7ed321,stroke:#333,color:#fff
