graph LR
    Orch["FMS Guardrails<br/>Orchestrator"]

    %% gRPC Backend Dependencies
    Orch -->|"gRPC/8033<br/>mTLS, mm-model-id"| TGIS["TGIS Generation<br/>Server"]
    Orch -->|"gRPC/8085<br/>mTLS, mm-model-id"| CaikitNLP["Caikit NLP<br/>Generation Server"]
    Orch -->|"gRPC/8085<br/>mTLS, mm-model-id"| Chunker["Caikit Chunker<br/>Service"]

    %% HTTP Backend Dependencies
    Orch -->|"HTTP/8080<br/>TLS, Bearer token"| Detectors["Detector Service(s)<br/>(HAP, PII, etc.)"]
    Orch -->|"HTTP/8080<br/>TLS, Bearer token"| vLLM["OpenAI Service<br/>(vLLM)"]

    %% Observability
    Orch -->|"gRPC/4317 or<br/>HTTP/4318"| OTLP["OTLP Collector"]

    %% Key Rust Library Dependencies
    Orch -.->|"HTTP server"| Axum["axum 0.8.8"]
    Orch -.->|"gRPC client"| Tonic["tonic 0.14.2"]
    Orch -.->|"TLS (ring backend)"| Rustls["rustls 0.23.36"]
    Orch -.->|"HTTP client"| Reqwest["reqwest 0.12.28"]
    Orch -.->|"async runtime"| Tokio["tokio 1.49.0"]
    Orch -.->|"gRPC load balancing"| Ginepro["ginepro (custom fork)"]
    Orch -.->|"tracing + metrics"| OTel["opentelemetry 0.31.0"]

    %% Consumers (what calls the orchestrator)
    InferenceGateway["KServe / Inference<br/>Gateway"] -->|"HTTP/8033<br/>X-Forwarded-Access-Token"| Orch
    K8s["Kubernetes Probes"] -->|"HTTP/8034"| Orch

    style Orch fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% gRPC backends
    style TGIS fill:#82b366,stroke:#333
    style CaikitNLP fill:#82b366,stroke:#333
    style Chunker fill:#82b366,stroke:#333

    %% HTTP backends
    style Detectors fill:#d6b656,stroke:#333
    style vLLM fill:#d6b656,stroke:#333

    %% Observability
    style OTLP fill:#9673a6,stroke:#333,color:#fff

    %% Library dependencies
    style Axum fill:#e8e8e8,stroke:#999
    style Tonic fill:#e8e8e8,stroke:#999
    style Rustls fill:#e8e8e8,stroke:#999
    style Reqwest fill:#e8e8e8,stroke:#999
    style Tokio fill:#e8e8e8,stroke:#999
    style Ginepro fill:#e8e8e8,stroke:#999
    style OTel fill:#e8e8e8,stroke:#999

    %% Consumers
    style InferenceGateway fill:#f5a623,stroke:#333
    style K8s fill:#f5a623,stroke:#333
