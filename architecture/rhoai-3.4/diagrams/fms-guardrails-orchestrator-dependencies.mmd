graph LR
    Orchestrator["FMS Guardrails<br/>Orchestrator<br/>(Rust/axum)"]

    %% Internal RHOAI Dependencies (gRPC backends)
    Orchestrator -->|"gRPC/8033<br/>generate, tokenize<br/>Optional TLS/mTLS"| TGIS["TGIS Server"]
    Orchestrator -->|"gRPC/8085<br/>text gen, tokenize<br/>Optional TLS/mTLS"| CaikitNLP["Caikit NLP Runtime"]
    Orchestrator -->|"gRPC/8085<br/>chunking, tokenize<br/>Optional TLS/mTLS"| CaikitChunker["Caikit Chunker Service"]

    %% Internal RHOAI Dependencies (HTTP backends)
    Orchestrator -->|"HTTP/8080<br/>content detection<br/>Optional TLS/mTLS"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    Orchestrator -->|"HTTP/8080<br/>chat/completions<br/>Optional TLS"| OpenAI["OpenAI-compatible<br/>Server (vLLM)"]

    %% Infrastructure Dependencies
    Orchestrator -.->|"gRPC/4317 or HTTP/4318<br/>traces + metrics"| OTLP["OTLP Collector"]

    %% Platform Management
    RHODSOp["RHODS Operator"] -->|"deploys, manages<br/>Routes/HTTPRoutes"| Orchestrator
    CertMgr["cert-manager"] -.->|"TLS certs<br/>auto-rotation"| Orchestrator

    %% Downstream consumers
    AIApps["AI Applications"] -->|"REST API<br/>HTTP/S 8033/TCP"| Orchestrator
    K8sProbes["Kubernetes Probes"] -.->|"HTTP 8034/TCP<br/>/health, /info"| Orchestrator

    %% Rust library dependencies (key ones)
    subgraph CoreLibs["Core Rust Libraries"]
        direction TB
        Axum["axum 0.8.8<br/>(HTTP routing)"]
        Hyper["hyper 1.8.1<br/>(HTTP server)"]
        Tonic["tonic 0.14.2<br/>(gRPC client)"]
        Rustls["rustls 0.23.36<br/>(TLS, ring backend)"]
        Tokio["tokio 1.49.0<br/>(async runtime)"]
        Reqwest["reqwest 0.12.28<br/>(HTTP client)"]
    end

    Orchestrator -.->|"built with"| CoreLibs

    %% Styling
    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TGIS fill:#7ed321,stroke:#333,color:#fff
    style CaikitNLP fill:#7ed321,stroke:#333,color:#fff
    style CaikitChunker fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style OpenAI fill:#7ed321,stroke:#333,color:#fff
    style RHODSOp fill:#7ed321,stroke:#333,color:#fff
    style CertMgr fill:#999,stroke:#333,color:#fff
    style OTLP fill:#999,stroke:#333,color:#fff
    style AIApps fill:#f9f9f9,stroke:#333
    style K8sProbes fill:#f9f9f9,stroke:#333
    style CoreLibs fill:#fff2cc,stroke:#d6b656
    style Axum fill:#fff2cc,stroke:#d6b656
    style Hyper fill:#fff2cc,stroke:#d6b656
    style Tonic fill:#fff2cc,stroke:#d6b656
    style Rustls fill:#fff2cc,stroke:#d6b656
    style Tokio fill:#fff2cc,stroke:#d6b656
    style Reqwest fill:#fff2cc,stroke:#d6b656
