// C4 Context Diagram - ODH Notebook Controller (kubeflow)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages notebook workbenches via ODH Dashboard or kubectl"

        odhNotebookController = softwareSystem "ODH Notebook Controller" "Extends upstream Kubeflow Notebook Controller with OpenShift-specific integrations for auth, networking, and pipeline connectivity" {
            reconciler = container "OpenshiftNotebookReconciler" "Reconciles Notebook CRs: manages HTTPRoutes, ReferenceGrants, NetworkPolicies, kube-rbac-proxy infrastructure, CA cert ConfigMaps, pipeline RoleBindings, Elyra runtime secrets" "Go Controller (controller-runtime)"
            webhook = container "NotebookWebhook" "Mutating admission webhook: injects kube-rbac-proxy sidecar, mounts CA bundles, resolves ImageStream images, injects pipeline/Feast config" "Go Webhook Server"
            kubeRbacProxy = container "kube-rbac-proxy Sidecar" "Per-notebook TLS-terminating reverse proxy enforcing Kubernetes RBAC authorization (SubjectAccessReview)" "Go Sidecar Container"
        }

        kubeflowNotebookController = softwareSystem "Kubeflow Notebook Controller" "Upstream controller managing notebook pod lifecycle" "External"
        dataScienceGateway = softwareSystem "data-science-gateway" "Platform Gateway (Envoy) in openshift-ingress for external notebook ingress" "Internal RHOAI"
        rhODSOperator = softwareSystem "rhods-operator" "Deploys and manages ODH Notebook Controller and data-science-gateway" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for creating and managing notebook workbenches" "Internal RHOAI"
        dspa = softwareSystem "Data Science Pipelines Application" "Pipeline execution engine; provides Elyra runtime configuration" "Internal RHOAI"
        feastFeatureStore = softwareSystem "Feast Feature Store" "Feature store for ML feature management" "Internal RHOAI"

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource CRUD and RBAC authorization" "External"
        openshiftServiceCA = softwareSystem "OpenShift Service CA" "Auto-provisions TLS certificates for services" "External"
        openshiftImageStreams = softwareSystem "OpenShift ImageStreams" "Image metadata and tag resolution for notebook images" "External"
        imageRegistry = softwareSystem "OpenShift Image Registry" "Container image storage" "External"

        // Relationships
        user -> odhDashboard "Creates notebook workbenches via" "HTTPS/443"
        user -> dataScienceGateway "Accesses notebooks via" "HTTPS/443"
        odhDashboard -> k8sAPI "Creates Notebook CRs via" "HTTPS/443"

        k8sAPI -> webhook "Sends admission reviews" "HTTPS/8443"
        reconciler -> k8sAPI "CRUD: HTTPRoutes, ReferenceGrants, NetworkPolicies, Services, Secrets, RBAC" "HTTPS/443"
        webhook -> k8sAPI "Reads ImageStreams, DSPA CRs" "HTTPS/443"

        dataScienceGateway -> kubeRbacProxy "Routes notebook traffic (with auth)" "HTTPS/8443"
        kubeRbacProxy -> k8sAPI "SubjectAccessReview authorization" "HTTPS/443"

        reconciler -> dspa "Reads DSPA CR for pipeline config" "Kubernetes API"
        reconciler -> dataScienceGateway "Reads Gateway CR for hostname" "Kubernetes API"
        webhook -> openshiftImageStreams "Resolves notebook images from tags" "Kubernetes API"
        openshiftServiceCA -> odhNotebookController "Provisions TLS certificates" "Automatic"

        rhODSOperator -> odhNotebookController "Deploys via kustomize" "Kubernetes API"
        kubeflowNotebookController -> k8sAPI "Manages notebook pod lifecycle" "HTTPS/443"
    }

    views {
        systemContext odhNotebookController "SystemContext" {
            include *
            autoLayout
        }

        container odhNotebookController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
