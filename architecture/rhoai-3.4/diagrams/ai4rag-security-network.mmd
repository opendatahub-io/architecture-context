graph TB
    subgraph InProcess["IN-PROCESS (Library Boundary)"]
        direction TB

        User["User Code / KFP Component<br/><i>Python function call</i>"]

        subgraph ai4rag["ai4rag Library"]
            direction TB

            Experiment["AI4RAGExperiment<br/><i>Orchestrator</i><br/>ThreadPoolExecutor (10 threads)"]

            subgraph LocalCompute["Local Computation (No Network)"]
                MPS["ModelsPreSelector"]
                GAM["GAMOptimizer<br/><i>pygam + scikit-learn</i>"]
                Chunker["LangChainChunker<br/><i>Text splitting</i>"]
                Chroma["ChromaVectorStore<br/><i>In-memory, no network</i>"]
                Evaluator["UnitxtEvaluator<br/><i>Metrics computation</i>"]
            end

            subgraph OGXClients["OGX Client Layer (Network)"]
                OGXFoundation["OGXFoundationModel<br/><i>chat.completions</i>"]
                OGXEmbed["OGXEmbeddingModel<br/><i>embeddings.create</i>"]
                OGXVector["OGXVectorStore<br/><i>vector_stores/vector_io</i>"]
            end
        end
    end

    subgraph External["EXTERNAL SERVICES"]
        OGXServer["OGX Server<br/>Host: BASE_URL (configurable)<br/>Protocol: HTTPS / REST<br/>Encryption: TLS<br/>Auth: API Key (Bearer)"]
    end

    %% Internal flows (in-process)
    User -->|"In-process<br/>Python API"| Experiment
    Experiment --> MPS
    Experiment --> GAM
    Experiment --> Chunker
    Experiment --> Evaluator
    MPS --> Chroma

    %% Network flows (egress)
    OGXFoundation -->|"HTTPS<br/>TLS<br/>API Key Bearer<br/>chat.completions.create"| OGXServer
    OGXEmbed -->|"HTTPS<br/>TLS<br/>API Key Bearer<br/>embeddings.create"| OGXServer
    OGXVector -->|"HTTPS<br/>TLS<br/>API Key Bearer<br/>vector_stores.*/vector_io.*"| OGXServer

    %% Styling
    classDef inprocess fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef localcompute fill:#e8f5e9,stroke:#a5d6a7,stroke-width:1px
    classDef ogxclient fill:#fff3e0,stroke:#ffb74d,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef user fill:#f9f9f9,stroke:#999,stroke-width:2px

    class User user
    class Experiment,MPS,GAM,Chunker,Chroma,Evaluator inprocess
    class OGXFoundation,OGXEmbed,OGXVector ogxclient
    class OGXServer external
