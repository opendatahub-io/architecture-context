graph TB
    subgraph AppProcess["APPLICATION PROCESS (Python Runtime)"]
        direction TB

        subgraph Library["ai4rag Library (pip package)"]
            direction TB

            Experiment["AI4RAGExperiment<br/>Orchestrator"]
            MPS["ModelsPreSelector<br/>Model Filtering"]

            subgraph Adapters["Provider Adapters"]
                direction LR
                LSAdapters["Llama Stack Adapters<br/>LSFoundationModel<br/>LSEmbeddingModel<br/>LSVectorStore"]
                OAIAdapters["OpenAI Adapters<br/>OpenAIFoundationModel<br/>OpenAIEmbeddingModel"]
            end

            subgraph InProcess["In-Process (No Network I/O)"]
                direction LR
                Chroma["ChromaDB<br/>In-memory vector store"]
                Unitxt["Unitxt Evaluator<br/>Metrics computation"]
                Chunker["LangChain Chunker<br/>Text splitting"]
            end

            Experiment --> MPS
            Experiment --> Adapters
            MPS --> Adapters
            MPS --> InProcess
        end
    end

    subgraph EgressLS["EGRESS: Llama Stack Server"]
        LlamaStack["Llama Stack Server<br/>Port: configurable<br/>Protocol: HTTPS<br/>Encryption: TLS<br/>Auth: API Key (Bearer)"]

        LSEndpoints["Endpoints:<br/>POST /chat/completions<br/>POST /embeddings<br/>POST /vector_stores/create<br/>POST /vector_io/insert<br/>POST /vector_io/query<br/>GET /models/list"]

        subgraph ProxiedBackends["Proxied Backends"]
            Milvus["Milvus<br/>Vector storage"]
            Qdrant["Qdrant<br/>Vector storage"]
        end

        LlamaStack --- LSEndpoints
        LlamaStack --> Milvus
        LlamaStack --> Qdrant
    end

    subgraph EgressOAI["EGRESS: OpenAI-compatible Endpoint"]
        OpenAI["OpenAI-compatible API<br/>Port: configurable<br/>Protocol: HTTPS<br/>Encryption: TLS<br/>Auth: API Key (Bearer)"]

        OAIEndpoints["Endpoints:<br/>POST /chat/completions<br/>POST /embeddings"]

        OpenAI --- OAIEndpoints
    end

    %% Egress flows
    LSAdapters -->|"HTTPS<br/>TLS<br/>API Key (Bearer)<br/>Client: llama-stack-client (httpx)"| LlamaStack
    OAIAdapters -->|"HTTPS<br/>TLS<br/>API Key (Bearer)<br/>Client: openai SDK (httpx)"| OpenAI

    %% Styling
    classDef appProcess fill:#dbeafe,stroke:#3b82f6,stroke-width:2px
    classDef library fill:#eff6ff,stroke:#60a5fa,stroke-width:1px
    classDef inprocess fill:#dcfce7,stroke:#22c55e,stroke-width:1px
    classDef egress fill:#fef3c7,stroke:#d97706,stroke-width:2px
    classDef proxied fill:#fff7ed,stroke:#f97316,stroke-width:1px
    classDef endpoint fill:#f3f4f6,stroke:#9ca3af,stroke-width:1px

    class AppProcess appProcess
    class Library library
    class InProcess inprocess
    class EgressLS,EgressOAI egress
    class ProxiedBackends proxied
    class LSEndpoints,OAIEndpoints endpoint
    class Experiment,MPS,LSAdapters,OAIAdapters library
    class Chroma,Unitxt,Chunker inprocess
    class LlamaStack,OpenAI egress
    class Milvus,Qdrant proxied
