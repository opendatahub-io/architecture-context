graph TB
    subgraph EvalHubService["Eval-Hub Service"]
        direction TB
        API["eval-hub API Server<br/>Go HTTP Service<br/>8080/TCP"]
        AuthMW["Auth Middleware<br/>TokenReview + SAR"]
        Handlers["Request Handlers<br/>Jobs / Providers / Collections"]
        Storage["Storage Layer<br/>SQL Interface"]
        Runtime["Runtime Abstraction<br/>K8s / Local"]

        API --> AuthMW
        AuthMW --> Handlers
        Handlers --> Storage
        Handlers --> Runtime
    end

    subgraph EvalJobPod["Evaluation Job Pod (batch/v1)"]
        direction TB
        InitContainer["eval-runtime-init<br/>Go CLI (init container)<br/>S3 Test Data Download"]
        Sidecar["eval-runtime-sidecar<br/>Go HTTP (KEP-753 native sidecar)<br/>8080/TCP localhost"]
        Adapter["Framework Adapter<br/>lm-eval-harness / RAGAS / Garak /<br/>GuideLLM / LightEval / MTEB"]

        InitContainer -.->|shared volume<br/>/test_data| Adapter
        Adapter -->|HTTP localhost:8080<br/>plaintext| Sidecar
    end

    %% External Actors
    Client["Client<br/>(Dashboard / SDK)"]
    Operator["TrustyAI Service Operator"]

    %% CRD
    EvalHubCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"]

    %% External Dependencies
    K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    PostgreSQL["PostgreSQL<br/>5432/TCP"]
    MLflow["MLflow Tracking Server<br/>5000/TCP HTTPS"]
    OTELCollector["OTEL Collector<br/>4317/TCP gRPC"]
    S3["AWS S3<br/>443/TCP HTTPS"]
    OCIRegistry["OCI Registry<br/>443/TCP HTTPS"]
    Prometheus["Prometheus<br/>Scrapes /metrics"]

    %% Flows
    Client -->|"HTTPS 8080/TCP<br/>Bearer Token"| API
    Operator -->|creates| EvalHubCR
    EvalHubCR -->|"watched by<br/>operator deploys"| API

    Runtime -->|"creates batch/v1 Jobs<br/>+ ConfigMaps"| K8sAPI
    API -->|"TokenReview + SAR"| K8sAPI
    Storage -->|SQL| PostgreSQL
    Handlers -->|"REST API"| MLflow
    API -.->|"OTLP traces"| OTELCollector
    Prometheus -.->|"scrape"| API

    InitContainer -->|"download test data"| S3
    Sidecar -->|"HTTPS 8443/TCP<br/>SA Token"| API
    Sidecar -->|"HTTPS<br/>Projected SA Token"| MLflow
    Sidecar -->|"HTTPS 443/TCP<br/>Bearer Token"| OCIRegistry

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style AuthMW fill:#4a90e2,stroke:#333,color:#fff
    style Handlers fill:#4a90e2,stroke:#333,color:#fff
    style Storage fill:#4a90e2,stroke:#333,color:#fff
    style Runtime fill:#4a90e2,stroke:#333,color:#fff
    style Sidecar fill:#5b9bd5,stroke:#333,color:#fff
    style InitContainer fill:#5b9bd5,stroke:#333,color:#fff
    style Adapter fill:#9dc3e6,stroke:#333
    style EvalHubCR fill:#f5a623,stroke:#333
    style Client fill:#7ed321,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style OTELCollector fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
