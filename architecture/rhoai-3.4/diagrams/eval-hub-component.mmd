graph TB
    subgraph EvalHubService["EvalHub Service"]
        direction TB
        API["eval-hub API Server<br/>Go Service<br/>8080/TCP"]
        AuthMW["Auth Middleware<br/>TokenReview + SAR"]
        Handlers["Route Handlers<br/>Jobs / Collections / Providers"]
        Storage["Storage Layer<br/>PostgreSQL / SQLite"]
        MLflowClient["MLflow Client"]
        K8sRuntime["K8s Runtime<br/>Job Builder"]

        API --> AuthMW
        AuthMW --> Handlers
        Handlers --> Storage
        Handlers --> MLflowClient
        Handlers --> K8sRuntime
    end

    subgraph EvalJobPod["Evaluation Job Pod (per-job)"]
        direction TB
        InitContainer["eval-runtime-init<br/>S3 Test Data Download"]
        Adapter["Evaluation Adapter<br/>(lm-eval / LightEval / Garak / GuideLLM)"]
        Sidecar["eval-runtime-sidecar<br/>Reverse Proxy<br/>8080/TCP"]

        InitContainer -.->|"completes before"| Adapter
        Adapter -->|"localhost:8080"| Sidecar
    end

    User["User / Dashboard"] -->|"POST /api/v1/evaluations/jobs<br/>Bearer Token"| API
    EvalHubCR["EvalHub CR<br/>trustyai.opendatahub.io/v1alpha1"] -->|"watched by"| TrustyAIOp["TrustyAI Service Operator"]
    TrustyAIOp -->|"creates Deployment"| API

    K8sRuntime -->|"creates"| EvalJobPod
    Sidecar -->|"callbacks"| API
    Sidecar -->|"tracking"| MLflow["MLflow Tracking Server"]
    Sidecar -->|"artifacts"| OCIRegistry["OCI Registry"]
    InitContainer -->|"downloads"| S3["S3 Storage"]

    API -->|"TokenReview / SAR"| K8sAPI["Kubernetes API Server"]
    K8sRuntime -->|"Job/ConfigMap CRUD"| K8sAPI
    MLflowClient -->|"experiments"| MLflow
    Storage -->|"queries"| PostgreSQL["PostgreSQL"]

    style API fill:#4a90e2,stroke:#333,color:#fff
    style AuthMW fill:#4a90e2,stroke:#333,color:#fff
    style Handlers fill:#4a90e2,stroke:#333,color:#fff
    style Storage fill:#4a90e2,stroke:#333,color:#fff
    style MLflowClient fill:#4a90e2,stroke:#333,color:#fff
    style K8sRuntime fill:#4a90e2,stroke:#333,color:#fff
    style InitContainer fill:#50c878,stroke:#333,color:#fff
    style Adapter fill:#50c878,stroke:#333,color:#fff
    style Sidecar fill:#50c878,stroke:#333,color:#fff
    style EvalHubCR fill:#f5a623,stroke:#333,color:#fff
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style PostgreSQL fill:#e8e8e8,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#333
