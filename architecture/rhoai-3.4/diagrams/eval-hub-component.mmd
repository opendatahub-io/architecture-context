    K8sRuntime -->|"Job/ConfigMap CRUD"| K8sAPI
    MLflowClient -->|"REST API<br/>5000/TCP"| MLflow["MLflow Tracking Server"]
    AdapterPods -->|"inference"| ModelEndpoint["Model Endpoint<br/>HTTPS"]

