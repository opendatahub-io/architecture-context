graph TB
    subgraph Operator["Model Registry Operator"]
        direction TB
        Controller["ModelRegistry Controller<br/>(Reconciler)"]
        CatalogCtrl["ModelCatalog Controller<br/>(Reconciler)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS"]
        MigrationMgr["Storage Migration Manager<br/>(Background Task)"]

        Controller -->|"validates/mutates via"| Webhook
        CatalogCtrl -->|"validates/mutates via"| Webhook
        MigrationMgr -->|"triggers conversion"| Webhook
    end

    %% CRDs
    ModelRegistryCR["ModelRegistry CR<br/>(v1beta1 storage)"]
    ModelRegistryCRLegacy["ModelRegistry CR<br/>(v1alpha1 deprecated)"]

    %% Per-Instance Resources Created
    subgraph PerInstance["Per-Instance Resources (created by Controller)"]
        direction TB
        RestDeploy["REST API Deployment<br/>model-registry:latest"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS"]
        PostgresDeploy["PostgreSQL<br/>(auto-provisioned, optional)<br/>5432/TCP"]
        InstanceRoute["OpenShift Route<br/>(edge + reencrypt)"]
        InstanceRBAC["RBAC<br/>Roles, RoleBindings,<br/>ClusterRoleBindings"]
        NetPol["NetworkPolicies"]
        RestDeploy --- KubeRBACProxy
    end

    %% Catalog Resources
    subgraph CatalogResources["Model Catalog Subsystem (created by CatalogCtrl)"]
        direction TB
        CatalogDeploy["Catalog REST API Deployment"]
        CatalogProxy["kube-rbac-proxy Sidecar<br/>8443/TCP HTTPS"]
        CatalogDB["Catalog PostgreSQL<br/>5432/TCP"]
        CatalogRoute["Catalog HTTPS Route"]
        CatalogRBAC["Admin RBAC<br/>(from Auth CR groups)"]
        CatalogDeploy --- CatalogProxy
    end

    %% User Interaction
    User["User / Platform Operator"] -->|"creates"| ModelRegistryCR
    ModelRegistryCRLegacy -->|"converted by webhook"| ModelRegistryCR
    ModelRegistryCR -->|"watched by"| Controller
    Controller -->|"provisions"| PerInstance
    CatalogCtrl -->|"provisions"| CatalogResources

    %% Migration
    MigrationMgr -->|"migrates v1alpha1→v1beta1"| ModelRegistryCRLegacy

    %% External Dependencies
    Controller -->|"discovers ingress domain"| OCPIngress["config.openshift.io/Ingress"]
    Controller -->|"creates routes"| RouteAPI["route.openshift.io/Route"]
    Controller -->|"creates groups"| UserAPI["user.openshift.io/Group"]
    CatalogCtrl -->|"reads admin groups"| AuthCR["services.platform.opendatahub.io/Auth"]
    CatalogCtrl -->|"owner reference"| PlatformMR["components.platform.opendatahub.io/ModelRegistry"]
    CatalogCtrl -->|"discovers sources"| CatalogCMs["ConfigMaps<br/>(catalog-source=true)"]

    %% Styling
    style Controller fill:#4a90e2,color:#fff
    style CatalogCtrl fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style MigrationMgr fill:#4a90e2,color:#fff
    style ModelRegistryCR fill:#f5a623,color:#fff
    style ModelRegistryCRLegacy fill:#f5a623,color:#fff,stroke-dasharray: 5 5
    style RestDeploy fill:#7ed321,color:#fff
    style KubeRBACProxy fill:#7ed321,color:#fff
    style PostgresDeploy fill:#7ed321,color:#fff
    style InstanceRoute fill:#7ed321,color:#fff
    style InstanceRBAC fill:#7ed321,color:#fff
    style NetPol fill:#7ed321,color:#fff
    style CatalogDeploy fill:#7ed321,color:#fff
    style CatalogProxy fill:#7ed321,color:#fff
    style CatalogDB fill:#7ed321,color:#fff
    style CatalogRoute fill:#7ed321,color:#fff
    style CatalogRBAC fill:#7ed321,color:#fff
    style OCPIngress fill:#e8e8e8,stroke:#999
    style RouteAPI fill:#e8e8e8,stroke:#999
    style UserAPI fill:#e8e8e8,stroke:#999
    style AuthCR fill:#e8e8e8,stroke:#999
    style PlatformMR fill:#e8e8e8,stroke:#999
    style CatalogCMs fill:#e8e8e8,stroke:#999
