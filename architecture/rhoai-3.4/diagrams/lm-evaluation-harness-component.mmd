graph TB
    subgraph EvalHubOperator["EvalHub / TrustyAI Operator"]
        Operator[EvalHub Operator]
    end

    subgraph LMESJob["LMES Job Container (Kubernetes Job)"]
        direction TB
        Adapter["LMEval Adapter<br/>(main.py)<br/>FrameworkAdapter interface"]
        LMEval["lm-evaluation-harness<br/>(lm_eval/)<br/>v0.4.8 fork"]
        OCIPublisher["OCI Artifact Publisher<br/>(scripts/oci.py)<br/>skopeo + olot"]
        OfflineMetrics["Offline Metrics<br/>(metrics/)<br/>55+ pre-packaged metrics"]

        Adapter -->|configures & invokes<br/>simple_evaluate| LMEval
        Adapter -->|publishes results| OCIPublisher
        LMEval -->|loads metrics| OfflineMetrics
    end

    subgraph K8sResources["Kubernetes Resources"]
        JobSpec["ConfigMap<br/>/meta/job.json<br/>Job Specification"]
        Secrets["Secrets<br/>API keys, HF tokens,<br/>CA certificates"]
    end

    Operator -->|creates Job| LMESJob
    JobSpec -->|mounted as file| Adapter
    Secrets -->|env vars / mounts| Adapter

    Adapter -->|callbacks: status,<br/>progress, results| EvalHub["EvalHub Service<br/>(HTTPS/443)"]
    LMEval -->|POST completions<br/>local-completions backend| ModelEndpoint["Model Inference<br/>Endpoint<br/>(vLLM/TGI/etc.)"]
    OCIPublisher -->|skopeo push| OCIRegistry["OCI Registry<br/>(Quay)<br/>(HTTPS/443)"]
    Adapter -->|log metrics| MLflow["MLflow Tracking<br/>(HTTPS)"]
    LMEval -->|download datasets<br/>& tokenizers| HFHub["HuggingFace Hub<br/>(HTTPS/443)"]

    style Adapter fill:#4a90e2,color:#fff
    style LMEval fill:#4a90e2,color:#fff
    style OCIPublisher fill:#4a90e2,color:#fff
    style OfflineMetrics fill:#4a90e2,color:#fff
    style Operator fill:#7ed321,color:#fff
    style EvalHub fill:#7ed321,color:#fff
    style ModelEndpoint fill:#f5a623,color:#fff
    style OCIRegistry fill:#f5a623,color:#fff
    style MLflow fill:#f5a623,color:#fff
    style HFHub fill:#999,color:#fff
    style JobSpec fill:#e8e8e8,stroke:#333
    style Secrets fill:#e8e8e8,stroke:#333
