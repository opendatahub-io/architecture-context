graph TB
    subgraph "lm-evaluation-harness (Kubernetes Job)"
        subgraph "RHOAI Adapter Layer"
            MainPy["EvalHub Adapter<br/>(main.py)"]
            MainPy -->|parses| JobSpec["/meta/job.json<br/>ConfigMap Mount"]
            MainPy -->|implements| FrameworkAdapter["FrameworkAdapter<br/>(eval-hub-sdk)"]
        end

        subgraph "lm-eval Core Framework"
            SimpleEval["simple_evaluate()"]
            TaskManager["TaskManager<br/>(200+ tasks)"]
            ModelBackend["Model Backend<br/>(local-completions)"]
            Metrics["Metric Computation<br/>(accuracy, F1, ROUGE, etc.)"]
            SimpleEval --> TaskManager
            SimpleEval --> ModelBackend
            SimpleEval --> Metrics
        end

        subgraph "Task Suites"
            MMLU["MMLU"]
            GSM8K["GSM8K"]
            HellaSwag["HellaSwag"]
            ARC["ARC"]
            GPQA["GPQA"]
            IFEval["IFEval"]
            Unitxt["Unitxt Framework"]
        end

        MainPy -->|calls| SimpleEval
        TaskManager --> MMLU
        TaskManager --> GSM8K
        TaskManager --> HellaSwag
        TaskManager --> ARC
        TaskManager --> GPQA
        TaskManager --> IFEval
        TaskManager --> Unitxt
    end

    %% External Interactions
    Operator["TrustyAI LMEval Operator"] -->|creates Job| MainPy
    MainPy -->|status callbacks| EvalHub["EvalHub Service"]
    ModelBackend -->|OpenAI /v1/completions| ModelEndpoint["Model Serving Endpoint<br/>(vLLM / KServe)"]
    MainPy -->|push artifacts| OCIRegistry["OCI Registry"]
    MainPy -->|log metrics| MLflow["MLflow"]
    TaskManager -->|download datasets| HFHub["HuggingFace Hub"]
    MainPy -->|offline data| S3["S3 / IBM COS"]

    %% Container Image
    ContainerImage["lmes-job Container Image<br/>(UBI9 / Python 3.11)<br/>x86_64, s390x, ppc64le"] -.->|packages| MainPy

    %% Styling
    style MainPy fill:#4a90e2,stroke:#333,color:#fff
    style FrameworkAdapter fill:#4a90e2,stroke:#333,color:#fff
    style SimpleEval fill:#4a90e2,stroke:#333,color:#fff
    style TaskManager fill:#4a90e2,stroke:#333,color:#fff
    style ModelBackend fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style JobSpec fill:#f5a623,stroke:#333
    style Operator fill:#7ed321,stroke:#333
    style EvalHub fill:#7ed321,stroke:#333
    style ModelEndpoint fill:#7ed321,stroke:#333
    style OCIRegistry fill:#e8e8e8,stroke:#333
    style MLflow fill:#7ed321,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style S3 fill:#e8e8e8,stroke:#333
    style ContainerImage fill:#ddd,stroke:#666,stroke-dasharray:5 5
    style MMLU fill:#d4e6f1,stroke:#333
    style GSM8K fill:#d4e6f1,stroke:#333
    style HellaSwag fill:#d4e6f1,stroke:#333
