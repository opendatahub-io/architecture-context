graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>(opendatahub namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(cluster-wide)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB
        CR_Core["Core API Group (&quot;&quot;)"]
        CR_Admission["admissionregistration.k8s.io"]
        CR_Coordination["coordination.k8s.io"]
        CR_JobSet["jobset.x-k8s.io"]
        CR_Node["node.k8s.io"]
