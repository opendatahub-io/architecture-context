        CR_Trainer["trainer.kubeflow.org"]
        CR_Networking["networking.k8s.io<br/>(RHOAI only)"]
    end

    subgraph CoreResources["Core API Resources"]
        ConfigMaps["configmaps, secrets<br/>create, get, list, patch,<br/>update, watch"]
        Events["events<br/>create, patch, update, watch"]
        LimitRanges["limitranges<br/>get, list, watch"]
        Pods["pods<br/>get, list<br/>(RHOAI only - progression)"]
    end

    subgraph TrainerResources["Trainer CRD Resources"]
        TrainJobs["trainjobs<br/>get, list, patch, update, watch"]
        Runtimes["trainingruntimes<br/>clustertrainingruntimes<br/>get, list, patch, update, watch"]
        Finalizers["*/finalizers<br/>trainjobs/status<br/>get, patch, update"]
    end

    subgraph WorkloadResources["Workload Resources"]
        JobSets["jobsets<br/>create, get, list, patch,<br/>update, watch"]
        PodGroups["podgroups<br/>create, get, list, patch,<br/>update, watch"]
        RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        Webhooks["validatingwebhookconfigurations<br/>get, list, update, watch"]
        NetworkPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch (RHOAI only)"]
    end

