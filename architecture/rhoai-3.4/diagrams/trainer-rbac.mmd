graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["kubeflow-trainer-controller-manager<br/>Namespace: opendatahub"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["kubeflow-trainer-controller-manager<br/>(ClusterRoleBinding)"]
    end

    subgraph ControllerRole["ClusterRole: kubeflow-trainer-controller-manager"]
        direction TB

        subgraph CoreAPI["API Group: core ('')"]
            ConfigMaps["configmaps<br/>create, get, list, patch,<br/>update, watch"]
            Secrets["secrets<br/>create, get, list, patch,<br/>update, watch"]
            Events["events<br/>create, patch, update, watch"]
            LimitRanges["limitranges<br/>get, list, watch"]
            Pods["pods<br/>get, list<br/>(RHOAI patch)"]
        end

        subgraph AdmissionAPI["API Group: admissionregistration.k8s.io"]
            VWC["validatingwebhookconfigurations<br/>get, list, update, watch"]
        end

        subgraph CoordAPI["API Group: coordination.k8s.io"]
            Leases["leases<br/>create, get, list, update"]
        end

        subgraph JobSetAPI["API Group: jobset.x-k8s.io"]
            JobSets["jobsets<br/>create, get, list, patch,<br/>update, watch"]
        end

        subgraph NodeAPI["API Group: node.k8s.io"]
            RuntimeClasses["runtimeclasses<br/>get, list, watch"]
        end

        subgraph SchedulingAPIs["API Groups: scheduling.volcano.sh,<br/>scheduling.x-k8s.io"]
            PodGroups["podgroups<br/>create, get, list, patch,<br/>update, watch"]
        end

        subgraph TrainerAPI["API Group: trainer.kubeflow.org"]
            TrainJobs["trainjobs<br/>get, list, patch, update, watch"]
            TrainingRuntimes["trainingruntimes<br/>get, list, patch, update, watch"]
            ClusterTrainingRuntimes["clustertrainingruntimes<br/>get, list, patch, update, watch"]
            TrainJobsStatus["trainjobs/status<br/>get, patch, update"]
            Finalizers["*/finalizers<br/>get, patch, update"]
        end

        subgraph NetworkAPI["API Group: networking.k8s.io"]
            NetworkPolicies["networkpolicies<br/>get, list, watch, create,<br/>update, patch<br/>(RHOAI patch)"]
        end
    end

    subgraph AggregatedRoles["Aggregated ClusterRoles (RHOAI)"]
        direction TB

        subgraph AdminRole["training-admin"]
            AdminPerms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>Full CRUD"]
        end

        subgraph EditRole["training-edit"]
            EditPerms["trainjobs<br/>create, delete, get, list,<br/>patch, update, watch"]
        end

        subgraph ViewRole["training-view"]
            ViewPerms["trainjobs, trainingruntimes,<br/>clustertrainingruntimes<br/>get, list, watch"]
        end
    end

    %% Bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| ControllerRole

    %% Controller Role to Resources
    ControllerRole -->|"manages"| CoreAPI
    ControllerRole -->|"manages"| AdmissionAPI
    ControllerRole -->|"manages"| CoordAPI
    ControllerRole -->|"manages"| JobSetAPI
    ControllerRole -->|"watches"| NodeAPI
    ControllerRole -->|"manages"| SchedulingAPIs
    ControllerRole -->|"manages"| TrainerAPI
    ControllerRole -->|"manages"| NetworkAPI

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#9b59b6,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style LimitRanges fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style VWC fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style JobSets fill:#7ed321,stroke:#333
    style RuntimeClasses fill:#7ed321,stroke:#333
    style PodGroups fill:#7ed321,stroke:#333
    style TrainJobs fill:#f5a623,stroke:#333
    style TrainingRuntimes fill:#f5a623,stroke:#333
    style ClusterTrainingRuntimes fill:#f5a623,stroke:#333
    style TrainJobsStatus fill:#f5a623,stroke:#333
    style Finalizers fill:#f5a623,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
    style AdminPerms fill:#e74c3c,stroke:#333,color:#fff
    style EditPerms fill:#e67e22,stroke:#333,color:#fff
    style ViewPerms fill:#3498db,stroke:#333,color:#fff
