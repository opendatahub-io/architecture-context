graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["RHOAI Gateway / kube-rbac-proxy<br/>Platform TLS Termination<br/>AuthN: kube-rbac-proxy"]
    end

    subgraph ApplicationTier["APPLICATION TIER (Internal - ClusterIP)"]
        direction TB

        subgraph NS_App["Namespace: application"]
            Server["NeMo Guardrails Server<br/>Service: ClusterIP<br/>Port: 8000/TCP HTTP<br/>UID: 1001 (non-root)<br/>No K8s API access"]
            ActionsServer["Actions Server<br/>Service: ClusterIP<br/>Port: 8001/TCP HTTP"]
        end
    end

    subgraph EgressLLM["EGRESS - LLM Services"]
        UpstreamLLM["Upstream LLM Server<br/>(OpenAI / Custom)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        NIM["NVIDIA NIM Endpoint<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        HuggingFace["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (optional)"]
    end

    subgraph EgressObs["EGRESS - Observability"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP<br/>TLS (configurable)<br/>No Auth"]
    end

    subgraph EgressData["EGRESS - Data Stores (Optional)"]
        Redis["Redis<br/>6379/TCP<br/>Redis Protocol<br/>Optional TLS<br/>Username/Password"]
    end

    %% Flows
    Client -->|"HTTPS<br/>Platform TLS<br/>Platform Auth"| Gateway
    Gateway -->|"HTTP/8000<br/>No encryption (TLS terminated)<br/>No app-level auth"| Server
    Server -->|"HTTP/8001<br/>No auth"| ActionsServer
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (API key)"| UpstreamLLM
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| NIM
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>(pre-cached at build)"| HuggingFace
    Server -->|"gRPC OTLP/4317<br/>TLS (configurable)<br/>No auth"| OTel
    Server -.->|"TCP/6379<br/>Optional TLS<br/>Username/Password"| Redis

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egressllm fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egressobs fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egressdata fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class Server,ActionsServer application
    class UpstreamLLM,NIM,HuggingFace egressllm
    class OTel egressobs
    class Redis egressdata
