graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Application"]
    end

    subgraph PlatformIngress["PLATFORM INGRESS (RHOAI-Managed)"]
        Ingress["RHOAI Platform Ingress<br/>HTTPRoute / Route<br/>TLS Termination<br/>kube-rbac-proxy / HTTPRoute auth"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Service Network)"]
        direction TB

        subgraph NS_Guardrails["NeMo Guardrails Services"]
            Server["NeMo Guardrails Server<br/>ClusterIP: 8000/TCP<br/>HTTP, No TLS<br/>User: 1001 (non-root)<br/>UBI9/python-312"]
            ActionsServer["Actions Server<br/>ClusterIP: 8001/TCP<br/>HTTP, No TLS<br/>Internal only"]
        end
    end

    subgraph LLMProviders["EGRESS - LLM PROVIDERS"]
        OpenAI["OpenAI API<br/>api.openai.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        Anthropic["Anthropic API<br/>api.anthropic.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>x-api-key"]
        AzureOpenAI["Azure OpenAI<br/>{endpoint}.openai.azure.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>api-key header"]
        Cohere["Cohere API<br/>api.cohere.ai<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        SelfHosted["vLLM / NIM / TRT-LLM<br/>(Self-hosted)<br/>Configurable port<br/>HTTP/HTTPS<br/>Bearer Token (optional)"]
    end

    subgraph SafetyEndpoints["EGRESS - SAFETY MODELS"]
        ContentSafety["Content Safety Model<br/>Configurable port<br/>HTTP/HTTPS<br/>API key"]
        Jailbreak["Jailbreak Detection<br/>Configurable port<br/>HTTP/HTTPS<br/>API key"]
    end

    subgraph OptionalServices["EGRESS - OPTIONAL SERVICES"]
        Redis["Redis<br/>6379/TCP<br/>Redis protocol<br/>Optional TLS<br/>Username/password"]
        OTEL["OpenTelemetry Collector<br/>Configurable port<br/>HTTP/gRPC (OTLP)<br/>Configurable"]
        NVIDIA["NVIDIA AI Endpoints<br/>integrate.api.nvidia.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>API key"]
    end

    %% Flows
    Client -->|"HTTPS<br/>Platform TLS<br/>Platform auth"| Ingress
    Ingress -->|"HTTP/8000<br/>No encryption<br/>Authorization header forwarded"| Server

    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OPENAI_API_KEY)"| OpenAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>x-api-key (ANTHROPIC_API_KEY)"| Anthropic
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>api-key header"| AzureOpenAI
    Server -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (COHERE_API_KEY)"| Cohere
    Server -->|"HTTP(S)<br/>Configurable<br/>Bearer Token (optional)"| SelfHosted

    Server -->|"HTTP(S)<br/>Configurable<br/>API key"| ContentSafety
    Server -->|"HTTP(S)<br/>Configurable<br/>API key"| Jailbreak

    Server -.->|"TCP/6379<br/>Optional TLS<br/>Username/password"| Redis
    Server -.->|"OTLP<br/>Configurable<br/>When OTEL_EXPORTER_OTLP_ENDPOINT set"| OTEL
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>API key"| NVIDIA

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llmprovider fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef safety fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef optional fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Ingress ingress
    class Server,ActionsServer internal
    class OpenAI,Anthropic,AzureOpenAI,Cohere,SelfHosted llmprovider
    class ContentSafety,Jailbreak safety
    class Redis,OTEL,NVIDIA optional
