graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_NB["notebook-controller-<br/>service-account<br/>(opendatahub ns)"]
        SA_ODH["odh-notebook-controller-<br/>manager<br/>(opendatahub ns)"]
        SA_PERNB["{notebook-name}<br/>(per-notebook SA,<br/>user namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_NB["notebook-controller-<br/>role-binding<br/>(cluster-scoped)"]
        CRB_PROXY["notebook-controller-<br/>proxy-rolebinding<br/>(cluster-scoped)"]
        CRB_ODH["odh-notebook-controller-<br/>manager-rolebinding<br/>(cluster-scoped)"]
        CRB_PERNB["{notebook-name}-rbac-<br/>{namespace}-auth-delegator<br/>(cluster-scoped, per notebook)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_NB["notebook-controller-role"]
        CR_PROXY["notebook-controller-<br/>proxy-role"]
        CR_ODH["odh-notebook-controller-<br/>manager-role"]
        CR_AUTHDELEG["system:auth-delegator"]
    end

    subgraph UserFacingRoles["User-Facing Roles (Aggregation)"]
        CR_ADMIN["kubeflow-notebooks-admin<br/>notebooks-admin"]
        CR_EDIT["kubeflow-notebooks-edit<br/>notebooks-edit"]
        CR_VIEW["kubeflow-notebooks-view<br/>notebooks-view"]
        CR_ADMIN -->|aggregates| CR_EDIT
        CR_EDIT -->|includes| CR_VIEW
    end

    subgraph PerNotebookBindings["Per-Notebook RoleBindings (dynamic)"]
        RB_ELYRA["elyra-pipelines-{name}<br/>(notebook ns)"]
        RB_MLFLOW["{name}-{mlflow}<br/>(notebook ns)"]
    end

    subgraph PerNotebookRoles["Per-Notebook Roles"]
        R_DSPA["ds-pipeline-user-<br/>access-dspa"]
        CR_MLFLOW_INT["mlflow-operator-<br/>mlflow-integration"]
    end

    %% SA → CRB → CR bindings
    SA_NB -->|bound via| CRB_NB
    SA_NB -->|bound via| CRB_PROXY
    SA_ODH -->|bound via| CRB_ODH
    SA_PERNB -->|bound via| CRB_PERNB

    CRB_NB -->|grants| CR_NB
    CRB_PROXY -->|grants| CR_PROXY
    CRB_ODH -->|grants| CR_ODH
    CRB_PERNB -->|grants| CR_AUTHDELEG

    %% Per-notebook dynamic bindings
    SA_PERNB -->|bound via| RB_ELYRA
    SA_PERNB -->|bound via| RB_MLFLOW
    RB_ELYRA -->|grants| R_DSPA
    RB_MLFLOW -->|grants| CR_MLFLOW_INT

    subgraph NBCtrlResources["notebook-controller-role Resources"]
        NB_R1["core: pods<br/>get, list, watch, delete"]
        NB_R2["core: events<br/>get, list, watch, create, patch"]
        NB_R3["core: services<br/>* (all verbs)"]
        NB_R4["apps: statefulsets<br/>* (all verbs)"]
        NB_R5["kubeflow.org: notebooks,<br/>notebooks/status,<br/>notebooks/finalizers<br/>* (all verbs)"]
        NB_R6["networking.istio.io:<br/>virtualservices<br/>* (all verbs)"]
    end

    subgraph ProxyResources["proxy-role Resources"]
        PR_R1["authentication.k8s.io:<br/>tokenreviews<br/>create"]
        PR_R2["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
    end

    subgraph ODHCtrlResources["odh-notebook-controller-manager-role Resources"]
        ODH_R1["core: configmaps, secrets,<br/>serviceaccounts, services<br/>create, get, list, patch,<br/>update, watch"]
        ODH_R2["gateway.networking.k8s.io:<br/>gateways<br/>get, list, watch"]
        ODH_R3["gateway.networking.k8s.io:<br/>httproutes, referencegrants<br/>create, delete, get, list,<br/>patch, update, watch"]
        ODH_R4["kubeflow.org: notebooks<br/>get, list, patch, update, watch"]
        ODH_R5["networking.k8s.io:<br/>networkpolicies<br/>create, get, list, patch,<br/>update, watch"]
        ODH_R6["rbac.authorization.k8s.io:<br/>clusterrolebindings,<br/>rolebindings, roles<br/>create, delete, get, list,<br/>patch, update, watch"]
        ODH_R7["image.openshift.io:<br/>imagestreams<br/>get, list, watch"]
        ODH_R8["oauth.openshift.io:<br/>oauthclients<br/>delete, get, list, patch,<br/>update, watch"]
    end

    subgraph UserResources["User-Facing Role Resources"]
        USR_R1["kubeflow.org: notebooks,<br/>notebooks/status<br/>get, list, watch (view)"]
        USR_R2["kubeflow.org: notebooks,<br/>notebooks/status<br/>create, delete, deletecollection,<br/>patch, update (edit)"]
    end

    CR_NB -->|permissions| NB_R1
    CR_NB -->|permissions| NB_R2
    CR_NB -->|permissions| NB_R3
    CR_NB -->|permissions| NB_R4
    CR_NB -->|permissions| NB_R5
    CR_NB -->|permissions| NB_R6
    CR_PROXY -->|permissions| PR_R1
    CR_PROXY -->|permissions| PR_R2
    CR_ODH -->|permissions| ODH_R1
    CR_ODH -->|permissions| ODH_R2
    CR_ODH -->|permissions| ODH_R3
    CR_ODH -->|permissions| ODH_R4
    CR_ODH -->|permissions| ODH_R5
    CR_ODH -->|permissions| ODH_R6
    CR_ODH -->|permissions| ODH_R7
    CR_ODH -->|permissions| ODH_R8
    CR_VIEW -->|permissions| USR_R1
    CR_EDIT -->|permissions| USR_R2

