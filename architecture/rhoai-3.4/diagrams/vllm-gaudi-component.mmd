graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph Platform["RHOAI Platform Layer"]
        Ingress["Platform Ingress<br/>(Gateway/Route)<br/>443/TCP HTTPS"]
        KServe["KServe<br/>InferenceService"]
    end

    subgraph VllmGaudi["vllm-gaudi Container (odh-vllm-gaudi-rhel9)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["vLLM OpenAI API Server<br/>Port 8000/TCP HTTP"]
        end

        subgraph PluginLayer["vllm-gaudi Plugin"]
            Plugin["Plugin Registration<br/>(entry_points)"]
            Platform_["HpuPlatform<br/>(platform detection)"]
            CustomOps["Custom Ops Registry<br/>(01. load order)"]
            CustomModels["Custom Models Registry<br/>(02. load order)"]
            Plugin --> Platform_
            Plugin --> CustomOps
            Plugin --> CustomModels
        end

        subgraph ExecutionLayer["Execution Layer"]
            ModelRunner["HPU Model Runner<br/>(forward pass, bucketing,<br/>graph compilation)"]
            Worker["HPU Worker<br/>(device lifecycle,<br/>memory profiling)"]
            InputBatch["Input Batch Manager<br/>(sampling metadata)"]
            Worker --> ModelRunner
            ModelRunner --> InputBatch
        end

        subgraph AttentionLayer["Attention Backends"]
            StdAttn["HPUAttentionV1<br/>(Standard Paged)"]
            MLAAttn["HPUAttentionMLA<br/>(Multi-head Latent)"]
            UnifiedAttn["HPUUnifiedAttention<br/>(Batched Causal+Cached)"]
            UnifiedMLA["HPUUnifiedMLA<br/>(Unified + MLA)"]
        end

        subgraph OpsLayer["HPU Custom Ops"]
            FP8Ops["FP8 Quantization"]
            FusedMoE["Fused MoE"]
            RotaryEmb["Rotary Embedding"]
            LayerNorm["Layer Normalization"]
        end

        subgraph DistLayer["Distributed Communication"]
            HCCL["HCCL Communicator<br/>(all-reduce, all-gather)"]
            NIXL["NIXL Connector<br/>(KV cache transfer)"]
        end

        APIServer --> ModelRunner
        ModelRunner --> AttentionLayer
        ModelRunner --> OpsLayer
        Worker --> DistLayer
    end

    subgraph HardwareLayer["Intel Gaudi Hardware"]
        HPU["Gaudi 2/3 HPU<br/>(Synapse AI 1.23.0)"]
        PyTorch["PyTorch HPU<br/>(v2.9.0)"]
    end

    subgraph ExternalDeps["External Services"]
        ModelStorage["Model Storage<br/>(PVC / S3)"]
        HFHub["HuggingFace Hub<br/>(model weights)"]
    end

    %% Flows
    Client -->|HTTPS/443| Ingress
    Ingress -->|HTTP/8000| APIServer
    KServe -->|deploys| VllmGaudi
    Worker -->|HPU DMA| HPU
    ModelRunner -->|torch.compile| PyTorch
    PyTorch -->|habana_frameworks| HPU
    HCCL -->|RDMA/TCP| HPU
    VllmGaudi -->|model loading| ModelStorage
    VllmGaudi -->|tokenizer/config| HFHub

    %% Styling
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef hardware fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef client fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef attention fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef ops fill:#f8cecc,stroke:#b85450,stroke-width:1px

    class Client client
    class Ingress,KServe platform
    class APIServer,Plugin,Platform_,CustomOps,CustomModels,ModelRunner,Worker,InputBatch,HCCL,NIXL container
    class StdAttn,MLAAttn,UnifiedAttn,UnifiedMLA attention
    class FP8Ops,FusedMoE,RotaryEmb,LayerNorm ops
    class HPU,PyTorch hardware
    class ModelStorage,HFHub external
