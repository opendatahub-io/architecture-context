graph TB
    subgraph External["External Clients"]
        Client[Client via KServe Route]
    end

    subgraph Sidecar["kube-rbac-proxy Sidecar"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ / Bearer Token"]
    end

    subgraph VllmGaudi["vllm-gaudi Container Image"]
        direction TB

        subgraph APIServer["vLLM OpenAI-Compatible API Server (port 8000)"]
            Completions["/v1/completions"]
            Chat["/v1/chat/completions"]
            Models["/v1/models"]
            Embeddings["/v1/embeddings"]
            Health["/health"]
            Metrics["/metrics"]
        end

        subgraph Platform["Platform Registration"]
            HpuPlatform["HpuPlatform<br/>(vllm.platform_plugins)"]
        end

        subgraph Extension["Extension Framework"]
            Config["Config Engine<br/>(Lazy-evaluated)"]
            Features["Feature Flags<br/>(Bucketing, Compilation,<br/>Attention, Quantization)"]
            Bucketing["Bucketing Manager<br/>(Exponential/Linear)"]
            Config --> Features
            Features --> Bucketing
        end

        subgraph Ops["Custom Operator Library"]
            RotaryEmb["Rotary Embeddings"]
            LayerNorm["Layer Normalization"]
            FP8Quant["FP8/AWQ/GPTQ<br/>Quantization"]
            MoE["MoE Kernels"]
            MambaSSM["Mamba SSM"]
        end

        subgraph Attention["Attention Backends"]
            PagedAttn["Paged Attention"]
            UnifiedAttn["Unified Attention"]
            MLA["MLA (Multi-head<br/>Latent Attention)"]
            UnifiedMLA["Unified MLA"]
        end

        subgraph Worker["HPU Worker (v1)"]
            ModelRunner["Model Runner"]
            KVCache["KV Cache Manager"]
            HPUGraph["HPU Graph Compiler"]
            Profiler["Model Profiler"]
        end

        subgraph Distributed["Distributed Communication"]
            HCCL["HCCL Communicator<br/>(all-reduce, all-gather)"]
            NIXL["NIXL KV Connector<br/>(RDMA/TCP)"]
            ExpertParallel["Expert Parallelism<br/>(dispatch/combine)"]
        end

        subgraph ModelOverrides["Model Overrides"]
            Gemma3["Gemma3 VL"]
            Qwen25VL["Qwen2.5-VL"]
            Qwen3VL["Qwen3-VL"]
            Qwen3MoE["Qwen3-MoE"]
        end

        HpuPlatform --> Extension
        HpuPlatform --> Worker
        Extension --> Ops
        Extension --> Attention
        Worker --> Ops
        Worker --> Attention
        Worker --> Distributed
        Worker --> ModelOverrides
        APIServer --> Worker
    end

    subgraph HardwareLayer["Intel Gaudi Hardware"]
        HPU["Gaudi 2 / Gaudi 3<br/>HPU Accelerators"]
    end

    Client -->|"HTTPS/8443<br/>Bearer Token"| KRBP
    KRBP -->|"HTTP/8000<br/>localhost"| APIServer
    Worker -->|"PCIe/RDMA"| HPU
    HCCL -->|"HCCL/TCP<br/>Dynamic ports"| HPU
    Prometheus["Prometheus"] -.->|"scrape /metrics<br/>HTTP/8000"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef sidecar fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef api fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef core fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef hardware fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef distributed fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class KRBP sidecar
    class Completions,Chat,Models,Embeddings,Health,Metrics api
    class HpuPlatform,Config,Features,Bucketing,RotaryEmb,LayerNorm,FP8Quant,MoE,MambaSSM core
    class PagedAttn,UnifiedAttn,MLA,UnifiedMLA core
    class ModelRunner,KVCache,HPUGraph,Profiler core
    class Gemma3,Qwen25VL,Qwen3VL,Qwen3MoE core
    class HCCL,NIXL,ExpertParallel distributed
    class HPU hardware
    class Prometheus external
