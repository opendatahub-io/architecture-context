graph TB
    subgraph KVCacheComponent["llm-d-kv-cache Component"]
        direction TB

        subgraph GoLibrary["Go Library (embedded by consumers)"]
            Indexer["kvcache.Indexer<br/>Maintains global KV-cache block index<br/>Scores pods for cache-aware routing"]
            EventPool["kvevents.Pool<br/>Sharded worker pool<br/>FNV-1a hash routing per pod"]
            BlockIndex["kvblock.Index<br/>Pluggable backend interface<br/>(InMemory / Redis / Valkey / CostAware)"]
            TokenPool["tokenization.Pool<br/>Worker pool for tokenization<br/>(UDS or embedded backends)"]
            TokenProcessor["TokenProcessor<br/>CBOR + FNV-64a hashing<br/>Token-to-block-key conversion"]

            Indexer -->|"ingests events via"| EventPool
            Indexer -->|"queries/updates"| BlockIndex
            Indexer -->|"tokenizes prompts via"| TokenPool
            Indexer -->|"computes block keys"| TokenProcessor
        end

        subgraph UDSTokenizerSidecar["UDS Tokenizer Sidecar (Python)"]
            UDSTokenizer["UDS Tokenizer<br/>Python gRPC Service<br/>Port: 8082/TCP (health)"]
            Renderer["OpenAIServingRender<br/>Chat template rendering<br/>Multimodal support"]
            UDSTokenizer --> Renderer
        end

        subgraph PVCEvictorSidecar["PVC Evictor (Python)"]
            PVCEvictor["PVC Evictor<br/>N+2 process architecture<br/>(crawlers + activator + deleter)"]
        end

        subgraph FSBackend["llmd_fs_backend (Python/C++/CUDA)"]
            FSConnector["Filesystem Backend<br/>CUDA-accelerated tensor I/O<br/>Zero-copy GPU-to-storage"]
        end

        TokenPool -->|"gRPC over UDS<br/>/tmp/tokenizer/tokenizer-uds.socket"| UDSTokenizer
    end

    subgraph ExternalSources["Event Sources"]
        vLLMPods["vLLM Pods<br/>ZMQ PUB 5557/TCP"]
    end

    subgraph Consumers["Library Consumers"]
        Scheduler["llm-d-inference-scheduler<br/>Go import"]
        EPP["Envoy Gateway EPP<br/>Go import"]
    end

    subgraph ExternalStorage["External Storage Backends"]
        Redis["Redis / Valkey<br/>6379/TCP"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS"]
    end

    subgraph Platform["Kubernetes Platform"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    end

    %% Event ingestion
    vLLMPods -->|"ZMQ PUB/SUB<br/>5557/TCP<br/>msgpack"| EventPool

    %% Library consumption
    Scheduler -->|"Go import"| Indexer
    EPP -->|"Go import"| Indexer

    %% External backends
    BlockIndex -.->|"6379/TCP<br/>Redis protocol<br/>optional TLS"| Redis
    UDSTokenizer -->|"443/TCP HTTPS<br/>download tokenizers"| HFHub

    %% Kubernetes
    EventPool -->|"Watch pods<br/>443/TCP HTTPS"| K8sAPI

    %% PVC Evictor connection
    PVCEvictor -.->|"manages PVC<br/>disk usage"| FSConnector

    %% Styling
    style Indexer fill:#4a90e2,stroke:#333,color:#fff
    style EventPool fill:#4a90e2,stroke:#333,color:#fff
    style BlockIndex fill:#4a90e2,stroke:#333,color:#fff
    style TokenPool fill:#4a90e2,stroke:#333,color:#fff
    style TokenProcessor fill:#4a90e2,stroke:#333,color:#fff
    style UDSTokenizer fill:#7ed321,stroke:#333,color:#fff
    style Renderer fill:#7ed321,stroke:#333,color:#fff
    style PVCEvictor fill:#f5a623,stroke:#333,color:#fff
    style FSConnector fill:#f5a623,stroke:#333,color:#fff
    style vLLMPods fill:#e8e8e8,stroke:#333
    style Scheduler fill:#d5e8d4,stroke:#82b366
    style EPP fill:#d5e8d4,stroke:#82b366
    style Redis fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
