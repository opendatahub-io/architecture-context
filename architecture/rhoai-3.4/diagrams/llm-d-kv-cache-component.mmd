    style Indexer fill:#4a90e2,stroke:#333,color:#fff
    style EventPool fill:#4a90e2,stroke:#333,color:#fff
    style TokenProcessor fill:#4a90e2,stroke:#333,color:#fff
    style Scorer fill:#4a90e2,stroke:#333,color:#fff
    style InMemoryLRU fill:#b8d4f0,stroke:#333
    style CostAware fill:#b8d4f0,stroke:#333
    style RedisBackend fill:#b8d4f0,stroke:#333
    style GRPCServer fill:#f5a623,stroke:#333
    style VLLMRenderer fill:#f5a623,stroke:#333
    style HFTokenizer fill:#f5a623,stroke:#333
    style HealthCheck fill:#f5a623,stroke:#333
