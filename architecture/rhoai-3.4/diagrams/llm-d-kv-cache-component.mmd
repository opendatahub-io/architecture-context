%% Component Structure Diagram for llm-d-kv-cache
%% Generated by: Claude Opus 4.6

graph TB
    subgraph LLMDKVCache["llm-d-kv-cache Component"]
        direction TB

        subgraph CoreLib["Core Library (Go)"]
            Indexer["kvcache.Indexer<br/>Main Orchestrator"]
            TokenProcessor["kvblock.TokenProcessor<br/>FNV-64a Hashing"]
            Scorer["kvblock.Scorer<br/>Longest Prefix Match"]
            TokenPool["tokenization.Pool<br/>Worker Pool"]
        end

        subgraph IndexBackends["Index Backends"]
            IndexInterface["kvblock.Index<br/>(Interface)"]
            InMemory["In-Memory (LRU)"]
            Ristretto["Cost-Aware (Ristretto)"]
            RedisBackend["Redis Backend"]
            ValkeyBackend["Valkey Backend"]
            IndexInterface --> InMemory
            IndexInterface --> Ristretto
            IndexInterface --> RedisBackend
            IndexInterface --> ValkeyBackend
        end

        subgraph EventIngestion["Event Ingestion"]
            SubManager["kvevents.SubscriberManager<br/>Per-pod ZMQ Lifecycle"]
            EventPool["kvevents.Pool<br/>Sharded Worker Pool"]
            ZMQSub["zmqSubscriber<br/>ZMQ SUB Client"]
        end

        subgraph Controllers["Controllers"]
            PodReconciler["PodReconciler<br/>controller-runtime"]
        end

        subgraph Sidecar["UDS Tokenizer Sidecar (Python)"]
            UDSTokenizer["TokenizationService<br/>gRPC over UDS"]
            HealthEndpoint["Health Endpoint<br/>:8082/health"]
        end

        subgraph Observability["Observability"]
            Metrics["Metrics Collector<br/>Prometheus"]
            Tracing["Telemetry<br/>OpenTelemetry"]
        end

        Indexer -->|tokenize| TokenPool
        TokenPool -->|gRPC UDS| UDSTokenizer
        Indexer -->|hash tokens| TokenProcessor
        Indexer -->|lookup| IndexInterface
        Indexer -->|score pods| Scorer

        PodReconciler -->|manage subscribers| SubManager
        SubManager -->|create/remove| ZMQSub
        ZMQSub -->|feed events| EventPool
        EventPool -->|update| IndexInterface
    end

    %% External Interactions
    Scheduler["llm-d-inference-scheduler<br/>(Go library import)"]
    Scheduler -->|"GetPodScores()"| Indexer

    vLLMPods["vLLM Pods<br/>ZMQ PUB :5557"]
    vLLMPods -->|KVEvents<br/>ZMQ PUB/SUB| ZMQSub

    K8sAPI["Kubernetes API<br/>HTTPS :443"]
    PodReconciler -->|watch pods| K8sAPI

    RedisServer["Redis/Valkey<br/>:6379"]
    RedisBackend -.->|optional| RedisServer
    ValkeyBackend -.->|optional| RedisServer

    HFHub["HuggingFace Hub<br/>HTTPS :443"]
    UDSTokenizer -.->|download models| HFHub

    OTLPCollector["OTLP Collector<br/>gRPC :4317"]
    Tracing -.->|export traces| OTLPCollector

    PromServer["Prometheus<br/>HTTP scrape"]
    Metrics -.->|expose metrics| PromServer

