graph TB
    subgraph LLMDKVCache["llm-d-kv-cache Component"]
        direction TB

        subgraph GoLibrary["Go Library (Core Indexer)"]
            Indexer["KV-Cache Indexer<br/>Tokenizes prompts, computes<br/>block keys, scores pods"]
            EventPool["KV Events Pool<br/>Sharded worker pool<br/>FNV-1a hash sharding"]
            TokenProcessor["Token Processor<br/>FNV-64a hashing<br/>Block key computation"]
            Scorer["KV Block Scorer<br/>Cache hit rate scoring"]
        end

        subgraph IndexBackends["Index Backends (Pluggable)"]
            InMemoryLRU["In-Memory LRU<br/>(hashicorp/golang-lru)"]
            CostAware["Cost-Aware Memory<br/>(dgraph-io/ristretto)"]
            RedisBackend["Redis/Valkey Backend<br/>(Lua scripts, HSET/HKEYS)"]
        end

        subgraph TokenizerSidecar["UDS Tokenizer Service (Python)"]
            GRPCServer["gRPC Server<br/>UDS Socket"]
            VLLMRenderer["vLLM OpenAIServingRender<br/>Chat template rendering"]
            HFTokenizer["HuggingFace AutoTokenizer<br/>Token encoding"]
            HealthCheck["Health Check<br/>8082/TCP"]
        end

        subgraph FSBackend["llmd_fs_backend (Python/C++)"]
            StorageManager["Storage Manager<br/>GPU-to-storage transfers"]
            GDSAccel["CUDA GPU Direct Storage<br/>Optional acceleration"]
        end

        subgraph PVCEvictorComp["PVC Evictor (Python)"]
            DiskMonitor["Disk Monitor<br/>Multi-process crawler"]
            FileEvictor["File Evictor<br/>Cold file deletion"]
        end
    end

    %% Internal flows
    Indexer -->|"computes keys"| TokenProcessor
    Indexer -->|"scores pods"| Scorer
    Indexer -->|"tokenize request"| GRPCServer
    EventPool -->|"updates index"| InMemoryLRU
    EventPool -->|"updates index"| CostAware
    EventPool -->|"updates index"| RedisBackend
    Indexer -->|"lookups"| InMemoryLRU
    Indexer -->|"lookups"| CostAware
    Indexer -->|"lookups"| RedisBackend
    GRPCServer --> VLLMRenderer
    GRPCServer --> HFTokenizer
    DiskMonitor -->|"triggers"| FileEvictor

    %% External interactions
    VLLMPods["vLLM/SGLang Pods"] -->|"ZMQ PUB 5557/TCP<br/>MessagePack events"| EventPool
    Scheduler["llm-d-inference-scheduler"] -->|"Go API<br/>GetPodScores()"| Indexer
    RedisBackend -->|"RESP 6379/TCP"| Redis["Redis/Valkey"]
    HFTokenizer -->|"HTTPS 443/TCP"| HFHub["HuggingFace Hub"]
    Indexer -->|"HTTP 8080/TCP<br/>Prometheus metrics"| Prometheus["Prometheus"]
    K8sAPI["Kubernetes API<br/>6443/TCP"] -->|"Pod Watch"| EventPool

    %% External service styling
    style VLLMPods fill:#e8e8e8,stroke:#666
    style Scheduler fill:#7ed321,stroke:#333
    style Redis fill:#e8e8e8,stroke:#666
    style HFHub fill:#e8e8e8,stroke:#666
    style Prometheus fill:#e8e8e8,stroke:#666
    style K8sAPI fill:#e8e8e8,stroke:#666

