graph LR
    ArgoWF[Argo Workflows<br/>workflow-controller + argoexec]

    %% External Dependencies (Required)
    ArgoWF -->|"CRUD CRs, Pods<br/>HTTPS/6443"| K8sAPI[Kubernetes API Server<br/>v1.28+]
    ArgoWF -->|"artifact I/O<br/>HTTPS/443"| S3[S3-Compatible Store<br/>Minio / AWS S3]

    %% External Dependencies (Optional)
    ArgoWF -.->|"workflow archival<br/>TCP/5432"| PostgreSQL[PostgreSQL 12+<br/>optional]
    ArgoWF -.->|"alternative DB<br/>TCP/3306"| MySQL[MySQL/MariaDB 5.7+<br/>optional]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| GCS[Google Cloud Storage<br/>optional]
    ArgoWF -.->|"artifact storage<br/>HTTPS/443"| Azure[Azure Blob Storage<br/>optional]

    %% Internal RHOAI Dependencies
    DSPOperator[DSP Operator] -->|"deploys &<br/>configures"| ArgoWF
    KFP[Kubeflow Pipelines<br/>API Server] -->|"creates Workflow CRs<br/>HTTPS/6443"| ArgoWF

    %% Integration Points
    ArgoWF -->|"S3 API<br/>GetObject/PutObject"| Minio[Minio<br/>Pipeline Artifact Store]
    ArgoWF -->|"image pull<br/>HTTPS/443"| Registry[Container Registries]
    ArgoWF -.->|"OTLP metrics<br/>gRPC"| OTel[OpenTelemetry Collector<br/>optional]
    ArgoWF -->|"leader election<br/>Leases"| Leases[Kubernetes Leases<br/>coordination.k8s.io]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style S3 fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style MySQL fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style GCS fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style Azure fill:#999,stroke:#333,color:#fff,stroke-dasharray: 5 5
    style DSPOperator fill:#7ed321,stroke:#333,color:#000
    style KFP fill:#7ed321,stroke:#333,color:#000
    style Minio fill:#7ed321,stroke:#333,color:#000
    style Registry fill:#f5a623,stroke:#333,color:#000
    style OTel fill:#f5a623,stroke:#333,color:#000,stroke-dasharray: 5 5
    style Leases fill:#e8e8e8,stroke:#333,color:#000
