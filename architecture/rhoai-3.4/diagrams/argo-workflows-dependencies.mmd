graph LR
    ArgoWF[Argo Workflows<br/>workflow-controller + argoexec]

    %% Platform Dependencies (Required)
    ArgoWF -->|"CRD watch/create<br/>pod mgmt, RBAC<br/>443/TCP HTTPS"| K8sAPI[Kubernetes 1.32+]

    %% Internal RHOAI Dependencies
    DSPO[Data Science Pipelines<br/>Operator] -->|"deploys &<br/>configures"| ArgoWF
    DSPServer[DSP API Server] -->|"creates Workflow CRs<br/>reads results<br/>443/TCP HTTPS"| ArgoWF

    %% Artifact Storage Dependencies (Optional - at least one needed)
    ArgoWF -->|"artifact I/O<br/>443/TCP HTTPS<br/>AccessKey/IAM"| S3[S3/MinIO Storage]
    ArgoWF -.->|"artifact I/O<br/>443/TCP HTTPS<br/>SA key"| GCS[Google Cloud Storage]
    ArgoWF -.->|"artifact I/O<br/>443/TCP HTTPS<br/>Account key"| Azure[Azure Blob Storage]

    %% Persistence Dependencies (Optional)
    ArgoWF -.->|"workflow archival<br/>5432/TCP SSL"| PostgreSQL[(PostgreSQL)]
    ArgoWF -.->|"workflow archival<br/>3306/TCP"| MySQL[(MySQL)]

    %% Monitoring
    Prometheus[Prometheus] -->|"metrics scrape<br/>9090/TCP HTTPS"| ArgoWF

    %% Other Optional Egress
    ArgoWF -.->|"git artifacts<br/>22/443 SSH/HTTPS"| Git[Git Repositories]
    ArgoWF -.->|"HTTP artifacts<br/>varies HTTP/HTTPS"| HTTPEndpoints[HTTP/HTTPS Endpoints]
    ArgoWF -.->|"artifacts<br/>HDFS/Kerberos"| HDFS[HDFS]
    ArgoWF -.->|"artifacts<br/>443/TCP HTTPS"| OSS[Alibaba OSS]

    %% Styling
    style ArgoWF fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style DSPO fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style DSPServer fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style S3 fill:#f5a623,stroke:#333,stroke-width:2px
    style GCS fill:#fff2cc,stroke:#d6b656
    style Azure fill:#fff2cc,stroke:#d6b656
    style PostgreSQL fill:#fff2cc,stroke:#d6b656
    style MySQL fill:#fff2cc,stroke:#d6b656
    style Prometheus fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style Git fill:#e8e8e8,stroke:#999
    style HTTPEndpoints fill:#e8e8e8,stroke:#999
    style HDFS fill:#e8e8e8,stroke:#999
    style OSS fill:#e8e8e8,stroke:#999
