graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>(Data Scientist / App)"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["maas-default-gateway<br/>80/TCP, 443/TCP<br/>TLS TERMINATE<br/>Host: maas.CLUSTER_DOMAIN"]
        InferenceGW["openshift-ai-inference<br/>Gateway<br/>80/TCP HTTP"]
    end

    subgraph PolicyEnforcement["POLICY ENFORCEMENT (Kuadrant)"]
        Authorino["Kuadrant Authorino<br/>NS: kuadrant-system<br/>API key + K8s TokenReview + OIDC<br/>OPA group membership check"]
        Limitador["Kuadrant Limitador<br/>TokenRateLimitPolicy<br/>per-model per-subscription"]
        DefaultAuth["gateway-default-auth<br/>OPA deny: 401/403"]
        DefaultDeny["gateway-default-deny<br/>0 tokens/min: 429"]
    end

    subgraph RequestTransform["REQUEST TRANSFORMATION"]
        PayloadProc["payload-processing<br/>NS: openshift-ingress<br/>SA: payload-processing<br/>9004/TCP gRPC TLS SIMPLE<br/>Metrics: 9005/TCP"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8443/TCP HTTPS<br/>TLS 1.2+ (service-ca)<br/>Authorino-enforced"]
            MaaSCtrl["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health"]
            InternalEndpoints["Internal Endpoints<br/>/internal/v1/api-keys/validate<br/>/internal/v1/subscriptions/select<br/>NetworkPolicy: Authorino + CronJob only"]
        end

        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>DB credentials from Secret<br/>API key storage (SHA-256)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS<br/>SA token auth"]
        KServe["KServe Model Servers<br/>HTTPS TLS<br/>Auth header stripped"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        ExtLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS TLS<br/>DestinationRule SIMPLE SNI<br/>Provider API key (injected)"]
        OSConfig["OpenShift Config API<br/>6443/TCP HTTPS<br/>SA token<br/>OIDC audience detection"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer: sk-oai-* OR K8s token OR OIDC JWT"| Gateway

    %% Ingress to Policy
    Gateway -->|"AuthPolicy<br/>evaluation"| Authorino
    Gateway ---|"rate limit<br/>enforcement"| Limitador

    %% Policy to Internal
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy-protected"| InternalEndpoints

    %% Ingress to Transform
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>ext_proc filter"| PayloadProc

    %% Transform reads
    PayloadProc -->|"HTTPS/6443<br/>TLS<br/>SA token"| K8sAPI

    %% Gateway routes (after auth + transform)
    Gateway -->|"HTTPS<br/>Auth header STRIPPED"| KServe
    Gateway -->|"HTTPS/443<br/>TLS SNI<br/>Provider key injected"| ExtLLM

    %% Gateway to maas-api (public endpoints)
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>Authorino-enforced"| MaaSAPI

    %% Internal connections
    MaaSAPI -->|"TCP/5432<br/>DB credentials"| PostgreSQL
    MaaSAPI -->|"HTTPS/6443<br/>SA token<br/>SAR + informers"| K8sAPI
    MaaSCtrl -->|"HTTPS/6443<br/>SA token<br/>CR watches + SSA"| K8sAPI
    MaaSCtrl -->|"HTTPS/6443<br/>SA token"| OSConfig

    %% Identity injection note
    Authorino -.->|"Injects:<br/>X-MaaS-Username<br/>X-MaaS-Group<br/>X-MaaS-Subscription"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef policy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef transform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef database fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class Gateway,InferenceGW ingress
    class Authorino,Limitador,DefaultAuth,DefaultDeny policy
    class PayloadProc transform
    class MaaSAPI,MaaSCtrl,InternalEndpoints,KServe,K8sAPI internal
    class PostgreSQL database
    class ExtLLM,OSConfig externalservice
