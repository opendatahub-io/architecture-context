graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ) - Gateway API + Istio"]
        direction TB
        Gateway["maas-default-gateway<br/>Namespace: openshift-ingress<br/>Host: maas.CLUSTER_DOMAIN<br/>80/TCP HTTP, 443/TCP HTTPS<br/>TLS SIMPLE (cert from Secret)<br/>Default: deny-unconfigured + deny-all rate limit"]

        subgraph AuthEval["Authentication Evaluation (Authorino)"]
            Authorino["Authorino (Kuadrant)<br/>Priority: 1.API key → 2.K8s token → 3.OIDC JWT<br/>Post-auth: Strip Authorization header"]
        end

        subgraph NS_Ingress["Namespace: openshift-ingress"]
            PayloadProc["payload-processing (ext_proc)<br/>SA: payload-processing<br/>9004/TCP gRPC, TLS SIMPLE<br/>9005/TCP metrics (HTTP)"]
        end

        Limitador["Limitador (Kuadrant)<br/>Token rate limit enforcement<br/>gRPC, mTLS"]
    end

    subgraph AppTier["APPLICATION TIER (Internal Services)"]
        direction TB

        subgraph NS_ODH["Namespace: opendatahub"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8443/TCP HTTPS TLS 1.2+<br/>(OpenShift service-ca cert)<br/>Auth: Kuadrant AuthPolicy (ext)<br/>NetworkPolicy (int)"]

            MaaSController["maas-controller<br/>SA: maas-controller<br/>8080/TCP metrics (HTTP)<br/>8081/TCP probes (HTTP)"]
        end

        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (connection URL)<br/>Hash-only key storage<br/>(SHA-256 + per-key salt)"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        ExtLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)<br/>443/TCP HTTPS<br/>TLS SIMPLE (Istio DestinationRule)<br/>Auth: Injected API key<br/>(from credentialRef Secret)"]

        KServeEndpoints["KServe Model Endpoints<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Bearer token passthrough<br/>⚠ InsecureSkipVerify for probes"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS (Gateway cert)<br/>Bearer: API key / K8s token / OIDC JWT"| Gateway

    %% Auth flow
    Gateway -->|"Auth evaluation"| Authorino
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+<br/>NetworkPolicy: maas-authorino-allow"| MaaSAPI
    Authorino -->|"gRPC<br/>mTLS"| Limitador

    %% Gateway → payload processing
    Gateway -->|"gRPC/9004<br/>TLS SIMPLE<br/>(DestinationRule)"| PayloadProc

    %% Gateway → backends
    Gateway -->|"HTTPS/443<br/>TLS SIMPLE<br/>Injected credential"| ExtLLM
    Gateway -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer passthrough"| KServeEndpoints

    %% Gateway → maas-api (external routes)
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>X-MaaS-Username/Group headers"| MaaSAPI

    %% App tier → data
    MaaSAPI -->|"PostgreSQL/5432<br/>TLS<br/>Connection URL Secret"| PostgreSQL
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer passthrough<br/>(access probes)"| KServeEndpoints

    %% Controller → K8s API
    MaaSController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    PayloadProc -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>(ConfigMaps, Secrets)"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef apptier fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef control fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef datastore fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway,PayloadProc ingress
    class Authorino,Limitador auth
    class MaaSAPI,MaaSController apptier
    class K8sAPI control
    class ExtLLM,KServeEndpoints externalservice
    class PostgreSQL datastore
