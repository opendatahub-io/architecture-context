%% Security Network Diagram - Models as a Service (MaaS)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["maas-default-gateway<br/>Namespace: openshift-ingress<br/>443/TCP HTTPS → TLS Terminate<br/>80/TCP HTTP<br/>Host: maas.CLUSTER_DOMAIN<br/>GatewayClass: openshift-default"]
        GWAuthDefault["gateway-default-auth<br/>AuthPolicy (deny-all catch-all)"]
        GWDenyDefault["gateway-default-deny<br/>TokenRateLimitPolicy (zero-rate)"]
    end

    subgraph PolicyEnforcement["POLICY ENFORCEMENT (Kuadrant)"]
        Authorino["Kuadrant/Authorino<br/>NS: kuadrant-system<br/>AuthPolicy evaluation:<br/>1. API key validation<br/>2. Group membership<br/>3. Subscription selection"]
        Limitador["Kuadrant/Limitador<br/>TokenRateLimitPolicy<br/>Per-user, per-model token limits"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph NS_MaaS["Namespace: maas-namespace"]
            MaaSAPI["maas-api<br/>SA: maas-api<br/>8080/TCP HTTP (base)<br/>8443/TCP HTTPS (TLS overlay)<br/>Endpoints: /v1/api-keys, /v1/models,<br/>/internal/v1/api-keys/validate,<br/>/v1/subscriptions/select"]
            MaaSController["maas-controller<br/>SA: maas-controller<br/>8081/TCP health probes<br/>8080/TCP metrics"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>CRD mgmt: AuthPolicy,<br/>TokenRateLimitPolicy, HTTPRoute"]
    end

    subgraph ModelBackends["MODEL BACKENDS"]
        LLMService["LLMInferenceService Backends<br/>8080/TCP HTTP (internal)<br/>No auth (pre-validated by Authorino)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>Auth: Connection URL creds<br/>Data: API key hashes only"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer: sk-oai-* or K8s Token"| Gateway
    GWAuthDefault -.->|targets| Gateway
    GWDenyDefault -.->|targets| Gateway
    Gateway -->|"Auth evaluation<br/>(internal)"| Authorino
    Authorino -->|"HTTPS/8443<br/>TLS 1.2+ SIMPLE<br/>NetworkPolicy restricted"| MaaSAPI
    Authorino -->|"Auth result +<br/>X-MaaS-Username<br/>X-MaaS-Group<br/>X-MaaS-Key-Id"| Gateway
    Gateway -->|"Rate limit check"| Limitador
    Gateway -->|"HTTP/8080<br/>No auth (internal)"| LLMService
    MaaSAPI -->|"PostgreSQL/5432<br/>TLS configurable<br/>Connection URL"| PostgreSQL
    MaaSController -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef policy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef backend fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,GWAuthDefault,GWDenyDefault ingress
    class Authorino,Limitador policy
    class MaaSAPI,MaaSController,K8sAPI internal
    class LLMService backend
    class PostgreSQL externalservice
