    subgraph Registries["IMAGE REGISTRIES"]
        RRHI["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>22 current images"]
        Quay["quay.io/modh<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>34 legacy images"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.3"| Gateway

    %% Ingress to Pod
    Gateway -->|"HTTPS/8443<br/>Bearer token (OAuth)"| RBAC

    %% Within Pod
    RBAC -->|"HTTP/8888<br/>plaintext (localhost)"| Jupyter
    RBAC -->|"HTTP/80<br/>plaintext (localhost)"| Nginx
    Nginx -->|"HTTP/8080<br/>plaintext"| HTTPD
    HTTPD -->|"HTTP/8787<br/>plaintext"| IDE

    %% Egress from workbench
    Jupyter -->|"HTTPS/6443<br/>SA token"| K8sAPI
    Jupyter -->|"HTTPS/8443<br/>Bearer token"| DSP
    Jupyter -->|"HTTPS/443<br/>AWS creds"| S3
    Jupyter -->|"HTTPS/443<br/>None"| PyPI

    %% Control plane
    Operator -->|"HTTPS/6443<br/>SA token"| K8sAPI
    Operator -->|"HTTPS/443<br/>Pull secret"| RRHI
    Operator -->|"HTTPS/443<br/>Pull secret"| Quay
    Controller -->|"Webhook injection"| RBAC
    Dashboard -->|"HTTPS/6443<br/>ImageStream annotations"| K8sAPI

