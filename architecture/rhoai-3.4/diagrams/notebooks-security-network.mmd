graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (Gateway)"]
        Gateway["RHOAI Gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+<br/>HTTPRoute per-notebook"]
    end

    subgraph AuthProxy["AUTH PROXY (Trust Boundary)"]
        KRBAC["kube-rbac-proxy sidecar<br/>8443/TCP → 8888 or 8787/TCP<br/>Bearer token (OAuth/OIDC)<br/>TLS termination"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (Application)"]
        direction TB

        subgraph JupyterOption["Option A: JupyterLab"]
            Jupyter["JupyterLab<br/>8888/TCP HTTP<br/>Auth: None (proxy)"]
        end

        subgraph CodeServerOption["Option B: Code Server"]
            CSApp["code-server 4.106.3<br/>8787/TCP HTTP<br/>--auth none"]
            CSNginx["nginx proxy<br/>8080/TCP HTTP"]
            CSHttpd["httpd CGI<br/>/api/kernels"]
            CSApp --> CSNginx
            CSHttpd --> CSNginx
        end

        subgraph RStudioOption["Option C: RStudio"]
            RSApp["RStudio Server<br/>8787/TCP HTTP"]
            RSNginx["nginx proxy<br/>8080/TCP HTTP"]
            RSHttpd["httpd CGI<br/>/api/kernels"]
            RSApp --> RSNginx
            RSHttpd --> RSNginx
        end
    end

    subgraph EgressTargets["EGRESS (Outbound)"]
        PyPI["PyPI / RH Python Index<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        CRAN["CRAN<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / HMAC"]
        Git["Git Repos<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SSH key / PAT"]
        MLflow["MLflow Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph BuildPipeline["BUILD PIPELINE (Hermetic)"]
        Konflux["Konflux CI"]
        Cachi2["Cachi2 Prefetch<br/>443/TCP HTTPS"]
        Registry["registry.redhat.io<br/>443/TCP HTTPS<br/>Registry credentials"]
        Konflux -->|prefetch deps| Cachi2
        Konflux -->|push images| Registry
    end

    %% Access flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth/OIDC"| Gateway
    Gateway -->|"HTTPS/8443<br/>mTLS<br/>Bearer token"| KRBAC
    KRBAC -->|"HTTP/8888<br/>plaintext (pod-internal)<br/>pre-authorized"| Jupyter
    KRBAC -->|"HTTP/8080<br/>plaintext (pod-internal)<br/>pre-authorized"| CSNginx
    KRBAC -->|"HTTP/8080<br/>plaintext (pod-internal)<br/>pre-authorized"| RSNginx

    %% Egress flows
    Jupyter -->|pip install| PyPI
    Jupyter -->|oc CLI| K8sAPI
    Jupyter -->|boto3| S3
    Jupyter -->|git-lfs| Git
    Jupyter -->|mlflow SDK| MLflow
    RSApp -->|R packages| CRAN

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Gateway ingress
    class KRBAC authproxy
    class Jupyter,CSApp,CSNginx,CSHttpd,RSApp,RSNginx,RSHttpd workbench
    class PyPI,CRAN,K8sAPI,S3,Git,MLflow egress
    class Konflux,Cachi2,Registry build
