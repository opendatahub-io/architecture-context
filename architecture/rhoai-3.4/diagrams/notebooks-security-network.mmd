        Dashboard["ODH Dashboard<br/>Discovers images via annotations"]
    end

    subgraph EgressTargets["EGRESS TARGETS"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
