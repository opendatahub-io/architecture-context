graph TB
    subgraph "Notebooks Component — Workbench Image Factory"
        direction TB

        subgraph BaseImages["Base Image Layers"]
            BaseCPU["Base CPU<br/>UBI9 Python 3.12"]
            BaseCUDA["Base CUDA<br/>CUDA 12.9 + cuDNN 9.14"]
            BaseROCm["Base ROCm<br/>ROCm 6.4"]
        end

        subgraph JupyterLab["JupyterLab Workbenches (7 variants)"]
            JupyterMinimal["Jupyter Minimal<br/>CPU / CUDA / ROCm<br/>Port: 8888/TCP"]
            JupyterDS["Jupyter Data Science<br/>CPU<br/>Elyra, DB connectors, CodeFlare"]
            JupyterPyTorch["Jupyter PyTorch<br/>CUDA<br/>PyTorch 2.10, torchvision 0.25"]
            JupyterLLM["Jupyter PyTorch+LLMCompressor<br/>CUDA<br/>LLMCompressor 0.10"]
            JupyterTF["Jupyter TensorFlow<br/>CUDA<br/>TensorFlow 2.21"]
            JupyterTrust["Jupyter TrustAI<br/>CPU<br/>TrustyAI, Java 17"]
        end

        subgraph CodeServer["Code Server Workbench"]
            CS["Code Server<br/>CPU<br/>code-server 4.106.3<br/>Port: 8787→nginx 8080"]
        end

        subgraph RStudio["RStudio Workbenches (2 variants)"]
            RSCpu["RStudio Server<br/>CPU<br/>R 4.5, RStudio 2025.09<br/>Port: 8787→nginx 8080"]
            RSCuda["RStudio Server<br/>CUDA<br/>R 4.5, CUDA 12.8"]
        end

        subgraph Runtimes["Runtime Images (7 variants)"]
            RTMinimal["Runtime Minimal"]
            RTDataSci["Runtime Data Science"]
            RTPyTorch["Runtime PyTorch"]
            RTLLM["Runtime LLMCompressor"]
            RTTF["Runtime TensorFlow"]
            RTROCmPT["Runtime ROCm PyTorch"]
            RTROCmTF["Runtime ROCm TensorFlow"]
        end

        subgraph Manifests["ImageStream Manifests"]
            ISManifests["ImageStream Definitions<br/>Kustomize + ConfigMap params<br/>RHOAI + ODH variants"]
        end

        subgraph BuildInfra["Build Infrastructure"]
            Makefile["Makefile + Scripts<br/>Lock file generation<br/>Dockerfile sync, CVE mgmt"]
        end
    end

    %% Image inheritance chain
    BaseCPU --> JupyterMinimal
    BaseCUDA --> JupyterMinimal
    BaseROCm --> JupyterMinimal
    JupyterMinimal --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTF
    JupyterDS --> JupyterTrust
    JupyterPyTorch --> JupyterLLM
    BaseCPU --> RTMinimal
    RTMinimal --> RTDataSci
    RTDataSci --> RTPyTorch
    RTDataSci --> RTTF

    %% Platform consumers
    NotebookController["odh-notebook-controller"] -->|creates pods from| JupyterLab
    NotebookController -->|creates pods from| CodeServer
    NotebookController -->|creates pods from| RStudio
    RhodsOperator["rhods-operator"] -->|applies| ISManifests
    Dashboard["Dashboard"] -->|reads annotations| ISManifests
    DSPipelines["Data Science Pipelines"] -->|executes in| Runtimes

    %% Auth sidecar
    KubeRBAC["kube-rbac-proxy<br/>(sidecar)"] -->|auth proxy for| JupyterLab
    KubeRBAC -->|auth proxy for| CodeServer
    KubeRBAC -->|auth proxy for| RStudio

    %% Build
    KonfluxCI["Konflux CI + Cachi2"] -->|hermetic build| BaseImages
    BuildInfra -->|generates lock files| KonfluxCI

    %% Styling
    style BaseCPU fill:#b3d9ff,stroke:#333
    style BaseCUDA fill:#ffccb3,stroke:#333
    style BaseROCm fill:#d9b3ff,stroke:#333
    style JupyterMinimal fill:#4a90e2,stroke:#333,color:#fff
    style JupyterDS fill:#4a90e2,stroke:#333,color:#fff
    style JupyterPyTorch fill:#4a90e2,stroke:#333,color:#fff
    style JupyterLLM fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTF fill:#4a90e2,stroke:#333,color:#fff
    style JupyterTrust fill:#4a90e2,stroke:#333,color:#fff
    style CS fill:#7ed321,stroke:#333,color:#fff
