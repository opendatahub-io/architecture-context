graph TB
    subgraph NotebooksRepo["Notebooks Repository (Image Factory)"]
        direction TB

        subgraph BuildSystem["Build System"]
            Makefile["Makefile<br/>Build orchestration"]
            Buildinputs["buildinputs (Go CLI)<br/>Dockerfile dependency analysis"]
            NtbLib["ntb Library (Python)<br/>Shared CI utilities"]
        end

        subgraph JupyterImages["Jupyter Workbench Images"]
            JupMinimal["jupyter-minimal<br/>JupyterLab 4.5 + Python 3.12<br/>CPU / CUDA / ROCm"]
            JupDS["jupyter-datascience<br/>NumPy, Pandas, scikit-learn"]
            JupPyTorch["jupyter-pytorch<br/>PyTorch 2.10 + CUDA"]
            JupTF["jupyter-tensorflow<br/>TensorFlow + CUDA"]
            JupTrustyAI["jupyter-trustyai<br/>TrustyAI explainability"]
            JupLLM["jupyter-pytorch+llmcompressor<br/>LLM quantization"]
            JupROCm["jupyter-rocm-pytorch/tensorflow<br/>AMD GPU variants"]
        end

        subgraph OtherIDEs["Non-Jupyter Workbench Images"]
            CodeServer["codeserver-datascience<br/>VS Code in browser (v4.106.3)<br/>nginx + httpd CGI"]
            RStudio["rstudio-minimal<br/>RStudio Server 2025.09.0<br/>R 4.5.1 + nginx CGI"]
        end

        subgraph RuntimeImages["Pipeline Runtime Images"]
            RTMinimal["runtime-minimal"]
            RTDS["runtime-datascience"]
            RTPyTorch["runtime-pytorch"]
            RTTF["runtime-tensorflow"]
            RTLLM["runtime-llmcompressor"]
        end

        subgraph BaseImages["Base Images"]
            BaseCPU["base-cpu<br/>UBI9 + Python 3.12"]
            BaseCUDA["base-cuda<br/>CUDA 12.6-13.0"]
            BaseROCm["base-rocm<br/>ROCm 6.2-6.4"]
        end

        subgraph Manifests["ImageStream Manifests"]
            KustomizeRHOAI["manifests/rhoai/<br/>Kustomize overlays"]
            KustomizeODH["manifests/odh/<br/>Kustomize overlays"]
        end
    end

    %% Image hierarchy
    BaseCPU -->|FROM| JupMinimal
    BaseCUDA -->|FROM| JupMinimal
    BaseROCm -->|FROM| JupMinimal
    JupMinimal -->|extends| JupDS
    JupDS -->|extends| JupPyTorch
    JupDS -->|extends| JupTF
    JupDS -->|extends| JupTrustyAI
    JupPyTorch -->|extends| JupLLM
    JupDS -->|extends| JupROCm

    %% External consumers
    Operator["rhods-operator"] -->|deploys| KustomizeRHOAI
    Dashboard["ODH Dashboard"] -->|reads annotations| KustomizeRHOAI
    Controller["odh-notebook-controller"] -->|injects sidecar into| WorkbenchPods["Workbench Pods"]
    Elyra["Elyra Extension"] -->|reads runtime metadata| RuntimeImages
    DSP["Data Science Pipelines"] -->|executes| RuntimeImages
    Konflux["Konflux CI/CD"] -->|builds| JupyterImages
    Konflux -->|builds| OtherIDEs
    Konflux -->|builds| RuntimeImages
    Registry["registry.redhat.io"] -->|hosts| JupyterImages

    %% Styling
    style NotebooksRepo fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style BuildSystem fill:#f0f0f0,stroke:#999
    style JupyterImages fill:#d5e8d4,stroke:#82b366
    style OtherIDEs fill:#dae8fc,stroke:#6c8ebf
    style RuntimeImages fill:#fff2cc,stroke:#d6b656
    style BaseImages fill:#f8cecc,stroke:#b85450
    style Manifests fill:#e1d5e7,stroke:#9673a6

    style Operator fill:#e8e8e8,stroke:#666
    style Dashboard fill:#e8e8e8,stroke:#666
    style Controller fill:#e8e8e8,stroke:#666
    style Elyra fill:#e8e8e8,stroke:#666
    style DSP fill:#e8e8e8,stroke:#666
    style Konflux fill:#e8e8e8,stroke:#666
    style Registry fill:#e8e8e8,stroke:#666
    style WorkbenchPods fill:#fff,stroke:#333
