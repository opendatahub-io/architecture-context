/*
 * C4 Context Diagram for vllm-gaudi
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4/vllm-gaudi.md
 */

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM inference services on Intel Gaudi hardware"

        vllmGaudi = softwareSystem "vLLM Gaudi Plugin" "Hardware plugin enabling optimized LLM inference on Intel Gaudi AI accelerators via vLLM" {
            apiServer = container "vLLM OpenAI API Server" "OpenAI-compatible inference API serving LLM completions, chat, embeddings" "Python / vLLM" "Runtime"
            hpuPlatform = container "HpuPlatform Plugin" "Registers Intel Gaudi as vLLM compute platform with attention backends, quantization, custom ops" "Python Plugin"
            hpuWorker = container "HPU Worker" "Worker process managing model loading, KV cache, and execution on Gaudi devices" "Python Module"
            hpuModelRunner = container "HPU Model Runner" "Runs model forward passes with bucketing, graph compilation, and memory optimization" "Python Module"
            customOps = container "Custom Operators" "HPU-optimized ops: fused MoE, rotary embedding, LayerNorm, FP8/AWQ/GPTQ quantization" "Python / HPU Kernels"
            hpuCommunicator = container "HpuCommunicator" "HCCL-based device communicator for tensor/expert/data parallelism" "Python / HCCL"
            nixlConnector = container "NIXL Connector" "KV cache disaggregation via NIXL for multi-node inference" "Python / NIXL"
        }

        kserve = softwareSystem "KServe" "Deploys and manages InferenceService instances using vLLM Gaudi as a ServingRuntime" "Internal RHOAI"
        rhoaiGateway = softwareSystem "RHOAI Gateway" "Routes external traffic to inference endpoints with TLS termination and auth" "Internal RHOAI"
        rhoaiModelController = softwareSystem "RHOAI Model Controller" "Manages lifecycle of vLLM-Gaudi inference service instances" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage (S3/PVC)" "Stores model weight artifacts for download at startup" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Public model repository for downloading model weights" "External"
        ray = softwareSystem "Ray" "Distributed inference orchestration for multi-HPU serving" "External"
        prometheus = softwareSystem "Prometheus" "Collects inference metrics (latency, throughput, GPU utilization)" "Internal RHOAI"
        gaudiHardware = softwareSystem "Intel Gaudi Hardware" "AI accelerator hardware with Synapse AI drivers and HCCL communication" "Infrastructure"

        /* Relationships */
        user -> rhoaiGateway "Sends inference requests" "HTTPS/443"
        rhoaiGateway -> vllmGaudi "Routes requests" "HTTP/80"
        kserve -> vllmGaudi "Deploys as ServingRuntime container"
        rhoaiModelController -> kserve "Creates InferenceService CRs"
        vllmGaudi -> modelStorage "Downloads model weights" "HTTPS/443"
        vllmGaudi -> huggingFace "Downloads models (optional)" "HTTPS/443"
        vllmGaudi -> ray "Coordinates multi-HPU workers" "TCP/6379"
        vllmGaudi -> gaudiHardware "Executes inference on HPU" "Synapse AI Driver"
        prometheus -> vllmGaudi "Scrapes inference metrics" "HTTP/8000"

        /* Internal container relationships */
        apiServer -> hpuPlatform "Loads plugin"
        hpuPlatform -> hpuWorker "Configures workers"
        hpuWorker -> hpuModelRunner "Executes models"
        hpuModelRunner -> customOps "Uses optimized operators"
        hpuWorker -> hpuCommunicator "Distributed communication"
        hpuWorker -> nixlConnector "KV cache transfer"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Runtime" {
                background #e65100
                color #ffffff
            }
        }
    }
}
