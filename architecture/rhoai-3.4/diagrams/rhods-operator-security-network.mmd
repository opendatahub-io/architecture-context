%% RHOAI Operator (rhods-operator) - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
        Admin["Platform Admin"]
    end

    subgraph Ingress["INGRESS (DMZ) - Two Modes"]
        direction TB

        subgraph LBMode["LoadBalancer Mode"]
            GatewayLB["Gateway LB Service<br/>443/TCP HTTPS<br/>TLS 1.2+ Terminate<br/>Host: rh-ai.{cluster-domain}"]
        end

        subgraph RouteMode["OcpRoute Mode"]
            OCPRouter["OpenShift Router<br/>443/TCP HTTPS<br/>Reencrypt TLS"]
            GatewayCIP["Gateway ClusterIP<br/>443/TCP HTTPS"]
        end
    end

    subgraph GatewayLayer["GATEWAY LAYER (openshift-ingress)"]
        direction TB

        Gateway["Gateway (Envoy)<br/>data-science-gateway<br/>GatewayClass: data-science-gateway-class"]
        EnvoyFilter["EnvoyFilter<br/>data-science-authn-filter<br/>ext_authz + Lua"]
        DestRule["DestinationRule<br/>SIMPLE TLS<br/>ports 443, 8443"]
        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS (service-CA TLS)<br/>9000/TCP HTTP (metrics)<br/>OAuth2/OIDC Auth"]
        HTTPRoutes["HTTPRoute CRs<br/>(per-component routing)"]
    end

    subgraph OperatorLayer["OPERATOR LAYER (system namespace)"]
        Operator["RHOAI Operator<br/>SA: controller-manager<br/>8080/TCP metrics (HTTP)<br/>8081/TCP health (HTTP)<br/>9443/TCP webhooks (HTTPS)"]
    end

    subgraph RedirectLayer["REDIRECT LAYER"]
        Nginx["dashboard-redirect (nginx)<br/>8080/TCP HTTP<br/>301 Redirect"]
    end

    subgraph BackendServices["BACKEND COMPONENT SERVICES"]
        Dashboard["ODH Dashboard"]
        KServe["KServe"]
        DSP["Data Science Pipelines"]
        MR["Model Registry"]
        OtherComponents["Other Components..."]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Client Creds"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC Client Creds"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
    end

    %% External to Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+"| GatewayLB
    User -->|"HTTPS/443<br/>TLS 1.2+"| OCPRouter
    OCPRouter -->|"HTTPS/443<br/>Reencrypt TLS"| GatewayCIP

    %% Ingress to Gateway flows
    GatewayLB --> Gateway
    GatewayCIP --> Gateway

    %% Gateway auth flow
    Gateway -->|"ext_authz"| EnvoyFilter
    EnvoyFilter -->|"HTTPS/8443<br/>service-CA TLS"| AuthProxy
    AuthProxy -->|"HTTPS/443<br/>OAuth2 Flow"| OAuth
    AuthProxy -->|"HTTPS/443<br/>OIDC Flow"| OIDC

    %% Gateway to backend
    Gateway -->|"HTTP/HTTPS<br/>Bearer Token (Lua)"| HTTPRoutes
    HTTPRoutes --> Dashboard
    HTTPRoutes --> KServe
    HTTPRoutes --> DSP
    HTTPRoutes --> MR
    HTTPRoutes --> OtherComponents

    %% Operator flows
    Admin -->|"HTTPS/6443<br/>Bearer Token"| K8sAPI
    Operator -->|"HTTPS/6443<br/>SA Token"| K8sAPI

    %% Legacy redirect
    User -.->|"HTTPS/443<br/>legacy route"| OCPRouter
    OCPRouter -.->|"HTTP/8080"| Nginx
    Nginx -.->|"301 Redirect"| User

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef gateway fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef redirect fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User,Admin external
    class GatewayLB,OCPRouter,GatewayCIP ingress
    class Gateway,EnvoyFilter,DestRule,AuthProxy,HTTPRoutes gateway
    class Operator operator
    class Dashboard,KServe,DSP,MR,OtherComponents backend
    class OAuth,OIDC,K8sAPI externalservice
    class Nginx redirect
