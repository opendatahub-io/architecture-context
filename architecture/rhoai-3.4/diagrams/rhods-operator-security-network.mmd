graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        LB["LoadBalancer / OpenShift Route<br/>443/TCP<br/>TLS 1.2+ Terminate/Reencrypt"]
        Gateway["data-science-gateway<br/>(Gateway API / Envoy)<br/>443/TCP HTTPS<br/>TLS SIMPLE (Terminate)"]
    end

    subgraph AuthZone["AUTHENTICATION ZONE"]
        EnvoyFilter["data-science-authn-filter<br/>(EnvoyFilter ext_authz + Lua)<br/>Redirect → OAuth/OIDC"]
        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS (service-ca TLS)<br/>9000/TCP HTTP (metrics)<br/>SA: kube-auth-proxy<br/>NS: openshift-ingress"]
    end

    subgraph AuthProviders["IDENTITY PROVIDERS"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuthClient credentials"]
        OIDC["External OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OIDC client credentials"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        Manager["rhods-operator manager<br/>SA: opendatahub-operator-controller-manager<br/>8080/TCP HTTP (metrics)<br/>8081/TCP HTTP (probes)<br/>9443/TCP HTTPS (webhooks, mTLS)"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Bearer Token"]
    end

    subgraph MonitoringNS["MONITORING (redhat-ods-monitoring)"]
        MonStack["MonitoringStack<br/>(Prometheus)"]
        Thanos["ThanosQuerier<br/>9090/TCP<br/>TLS (service-ca)"]
        Tempo["Tempo<br/>4317/TCP gRPC OTLP"]
        OTelCol["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP"]
        Perses["Perses<br/>Dashboarding"]
    end

    subgraph InternalSvc["INTERNAL SERVICES"]
        DashRedirect["dashboard-redirect<br/>nginx 8080/TCP HTTP<br/>Legacy URL redirect"]
    end

    subgraph CertServices["CERTIFICATE SERVICES"]
        ServiceCA["OpenShift Service CA<br/>Auto-generated TLS certs"]
        ClusterIngress["Cluster Ingress<br/>Default ingress cert propagation"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+"| LB
    LB -->|"HTTPS/443<br/>TLS terminate/reencrypt"| Gateway

    %% Gateway → Auth
    Gateway -->|"ext_authz intercept"| EnvoyFilter
    EnvoyFilter -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Cookie/Bearer"| AuthProxy

    %% Auth → Identity Providers
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuthClient creds"| OAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OIDC client creds"| OIDC

    %% Auth → K8s (TokenReview)
    AuthProxy -->|"TokenReview<br/>SubjectAccessReview"| K8sAPI

    %% Gateway → Backend (after auth)
    EnvoyFilter -->|"Lua injects Auth header<br/>strips cookies<br/>→ Backend via HTTPRoute"| InternalSvc

    %% Operator → K8s API
    Manager -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRD watches, SSA"| K8sAPI

    %% K8s API → Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS 1.2+<br/>mTLS (API server cert)"| Manager

    %% Monitoring flows
    OTelCol -->|"gRPC/4317<br/>OTLP"| Tempo
    MonStack -->|"HTTP/9090<br/>TLS (service-ca)"| Thanos

    %% Cert flows
    ServiceCA -.->|"auto-generate"| AuthProxy
    ClusterIngress -.->|"cert propagation"| Gateway

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authzone fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef authprovider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:1px
    classDef certs fill:#f5f5f5,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class LB,Gateway ingress
    class EnvoyFilter,AuthProxy authzone
    class OAuth,OIDC authprovider
    class Manager operator
    class K8sAPI controlplane
    class MonStack,Thanos,Tempo,OTelCol,Perses monitoring
    class DashRedirect internal
    class ServiceCA,ClusterIngress certs
