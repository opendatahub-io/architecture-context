graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API + Envoy)"]
        direction TB
        Gateway["data-science-gateway<br/>Gateway (K8s Gateway API)<br/>443/TCP TLS Terminate<br/>Hosts: rh-ai.{cluster-domain}"]
        EnvoyFilter["EnvoyFilter<br/>ext_authz + Lua Script"]
        AuthProxy["kube-auth-proxy<br/>8443/TCP HTTPS (service-ca)<br/>9000/TCP HTTP (metrics)<br/>SA: kube-auth-proxy<br/>Auth: OAuth2/OIDC"]
        Gateway --> EnvoyFilter
        EnvoyFilter -->|"HTTPS/8443<br/>TLS (insecureSkipVerify)<br/>ext_authz protocol"| AuthProxy
        AuthProxy -->|"x-auth-request-access-token<br/>x-auth-request-user"| EnvoyFilter
    end

    subgraph LegacyRedirects["LEGACY REDIRECTS"]
        DashRoute["odh-dashboard Route<br/>443/TCP edge TLS"]
        NginxRedirect["dashboard-redirect (nginx)<br/>8080/TCP HTTP<br/>301 Redirect"]
        GatewayLegacyRoute["Legacy Gateway Route<br/>443/TCP edge TLS<br/>301 Redirect"]
    end

    subgraph OperatorPlane["OPERATOR CONTROL PLANE"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-operator"]
            Operator["rhods-operator (manager)<br/>SA: operator SA (OLM)<br/>Webhook: 8443/TCP HTTPS<br/>FIPS: strictfipsruntime<br/>Image: odh-rhel8-operator"]
        end

        subgraph NS_Ingress["Namespace: openshift-ingress"]
            AuthProxyDeploy["kube-auth-proxy Deployment<br/>SA: kube-auth-proxy<br/>HPA: 1-3 replicas"]
        end
    end

    subgraph Backends["BACKEND SERVICES (via HTTPRoute)"]
        Dashboard["Dashboard"]
        ModelReg["Model Registry"]
        MLflow["MLflow"]
        OtherSvc["Other Components..."]
    end

    subgraph Observability["OBSERVABILITY STACK"]
        direction TB

        subgraph NS_Apps["Namespace: redhat-ods-applications"]
            OTELCollector["OpenTelemetry Collector<br/>4317/TCP gRPC<br/>4318/TCP HTTP"]
            PromStack["Prometheus (MonitoringStack)<br/>8889/TCP HTTPS (serving-cert)<br/>Auth: Bearer token"]
            TempoInst["Tempo<br/>4317/TCP gRPC TLS<br/>Auth: Multitenancy header"]
            PersesInst["Perses<br/>8080/TCP HTTP"]
            ThanosQ["ThanosQuerier<br/>10902/TCP HTTPS"]
        end

        subgraph NS_Monitoring["Namespace: redhat-ods-monitoring"]
            PromRoute["Prometheus Route<br/>443/TCP HTTPS reencrypt<br/>Auth: OAuth proxy"]
            ThanosRoute["ThanosQuerier Route<br/>443/TCP HTTPS edge<br/>Auth: OAuth proxy"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>Auth: SA token"]
        OAuthAPI["OpenShift OAuth API<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: SA token"]
        ClusterThanos["thanos-querier.openshift-monitoring<br/>9091/TCP HTTPS TLS<br/>Auth: Bearer token (Secret)"]
        Segment["Segment.io<br/>443/TCP HTTPS TLS 1.2+<br/>(RHOAI analytics only)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS Terminate<br/>GatewayConfig cert"| Gateway
    EnvoyFilter -->|"HTTP(S)<br/>Bearer token forwarded<br/>via Lua script"| Backends

    %% Legacy redirect flows
    Client -.->|"HTTPS/443<br/>edge TLS"| DashRoute
    DashRoute -->|"HTTP/8080<br/>no encryption"| NginxRedirect
    NginxRedirect -.->|"301 redirect"| Client
    Client -.->|"HTTPS/443<br/>edge TLS"| GatewayLegacyRoute
    GatewayLegacyRoute -.->|"301 redirect"| Client

    %% Operator control plane flows
    Operator -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| OAuthAPI
    Operator -->|"deploys + manages"| AuthProxyDeploy

    %% Observability flows
    OTELCollector -->|"HTTPS/8889<br/>serving-cert TLS<br/>Bearer token"| PromStack
    OTELCollector -->|"gRPC/4317<br/>TLS<br/>Multitenancy"| TempoInst
    PersesInst -->|"HTTPS/10902, 9091<br/>TLS (CA ConfigMap)<br/>Bearer token"| ThanosQ
    PersesInst -->|"HTTPS/9091<br/>TLS (CA ConfigMap)<br/>Bearer token"| ClusterThanos

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef legacy fill:#f5f5f5,stroke:#999,stroke-dasharray:5 5

    class Client external
    class Gateway,EnvoyFilter,AuthProxy ingress
    class Operator,AuthProxyDeploy operator
    class Dashboard,ModelReg,MLflow,OtherSvc backend
    class OTELCollector,PromStack,TempoInst,PersesInst,ThanosQ,PromRoute,ThanosRoute observability
    class K8sAPI,OAuthAPI,ClusterThanos,Segment externalservice
    class DashRoute,NginxRedirect,GatewayLegacyRoute legacy
