graph TD
    subgraph Legend["Legend"]
        direction LR
        L1["Component defines RBAC"]
        L2["Platform provides RBAC"]
        style L1 fill:#dae8fc,stroke:#6c8ebf
        style L2 fill:#7ed321,stroke:#333,color:#fff
    end

    subgraph VllmGaudiPod["vllm-gaudi Pod (No Self-Defined RBAC)"]
        direction TB
        Container["vllm-gaudi Container<br/>UID: 2000, GID: 0<br/>Non-root"]
        Note1["This component defines NO<br/>ClusterRoles, Roles, or<br/>RoleBindings"]
    end

    subgraph PlatformRBAC["RBAC Provided by RHOAI Platform"]
        direction TB

        subgraph KServeRBAC["KServe Serving Infrastructure"]
            SA["ServiceAccount<br/>(created by KServe for<br/>each InferenceService)"]
            KServeRole["KServe-managed Roles<br/>(model serving permissions)"]
            SA -->|"bound via RoleBinding"| KServeRole
        end

        subgraph SidecarRBAC["kube-rbac-proxy Sidecar"]
            SidecarSA["kube-rbac-proxy<br/>ServiceAccount"]
            SubjectAccessReview["SubjectAccessReview<br/>API calls"]
            SidecarSA -->|"performs"| SubjectAccessReview
        end
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction TB

        Client["External Client"]
        Route["KServe Route<br/>(HTTPRoute/Gateway API)"]
        KRBP["kube-rbac-proxy<br/>Port 8443/TCP<br/>TLS 1.2+"]
        VllmAPI["vLLM API Server<br/>Port 8000/TCP<br/>No Auth"]

        Client -->|"1. Bearer Token /<br/>OpenShift OAuth"| Route
        Route -->|"2. Route to pod"| KRBP
        KRBP -->|"3. Validate via<br/>Kubernetes RBAC /<br/>SubjectAccessReview"| SubjectAccessReview
        KRBP -->|"4. Forward if authorized<br/>(plaintext HTTP)"| VllmAPI
    end

    subgraph EndpointPolicy["Endpoint Authorization Policies"]
        direction TB

        EP1["/v1/* endpoints<br/>Methods: GET, POST<br/>Auth: Bearer Token / OAuth<br/>Enforced by: kube-rbac-proxy"]
        EP2["/health endpoint<br/>Methods: GET<br/>Auth: None<br/>Policy: Unrestricted"]
        EP3["/metrics endpoint<br/>Methods: GET<br/>Auth: None (or via sidecar)<br/>Enforced by: kube-rbac-proxy"]
    end

    SA -->|"assigned to"| Container
    VllmAPI --> EP1
    VllmAPI --> EP2
    VllmAPI --> EP3

    %% Styling
    classDef component fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#7ed321,stroke:#333,color:#fff
    classDef auth fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef endpoint fill:#fff2cc,stroke:#d6b656
    classDef note fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5

    class Container component
    class Note1 note
    class SA,KServeRole,SidecarSA,SubjectAccessReview platform
    class Client,Route,KRBP,VllmAPI auth
    class EP1,EP2,EP3 endpoint
