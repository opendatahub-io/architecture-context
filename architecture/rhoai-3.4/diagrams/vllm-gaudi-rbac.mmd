graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["vllm-gaudi does not define its own RBAC resources.<br/>RBAC is managed by the deploying platform<br/>(KServe / RHOAI Operator)."]
    end

    subgraph ContainerSecurity["Container Security Context"]
        direction TB
        Container["odh-vllm-gaudi-rhel9"]
        RunAs["Run As User: 2000 (vllm)<br/>Run As Group: 0 (root, OpenShift compat)<br/>Capabilities: Default (no privileged)"]
        BaseImage["Base Image: UBI 9.6<br/>FIPS: openssl-fips-provider removed"]
    end

    subgraph AuthZ["Authentication & Authorization"]
        direction TB
        APIEndpoints["/v1/* API Endpoints"]
        HealthEndpoint["/health Endpoint"]
        GatewayAuth["RHOAI Gateway<br/>(kube-rbac-proxy)<br/>Bearer Token validation"]
        NoAuth["No Authentication<br/>(health probe)"]
    end

    subgraph Secrets["Secrets (User-Configured)"]
        direction TB
        ModelCreds["(model-credentials)<br/>Type: Opaque<br/>S3/storage credentials<br/>Provisioned by: User/RHOAI<br/>Auto-Rotate: No"]
        HFToken["(huggingface-token)<br/>Type: Opaque<br/>HF Hub access token<br/>Provisioned by: User<br/>Auto-Rotate: No"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC"]
        direction TB
        KServeSA["KServe ServiceAccount"]
        KServeRole["KServe ClusterRole<br/>(manages ServingRuntimes,<br/>InferenceServices)"]
        ModelControllerSA["RHOAI Model Controller SA"]
        ModelControllerRole["Model Controller ClusterRole<br/>(manages InferenceService lifecycle)"]
    end

    Container --> RunAs
    Container --> BaseImage

    APIEndpoints -->|"auth delegated to"| GatewayAuth
    HealthEndpoint -->|"unauthenticated"| NoAuth

    KServeSA -->|"bound to"| KServeRole
    ModelControllerSA -->|"bound to"| ModelControllerRole
    KServeRole -->|"deploys"| Container
    ModelControllerRole -->|"manages"| Container

    Container -.->|"mounts"| ModelCreds
    Container -.->|"mounts"| HFToken

