graph TD
    subgraph Legend["Legend"]
        direction LR
        LegendNote["ℹ vllm-gaudi is a container image, not an operator.<br/>It defines NO ClusterRoles, Roles, RoleBindings, or Secrets.<br/>All RBAC is fully delegated to KServe and the RHOAI platform."]
    end

    subgraph KServeRBAC["KServe-Managed RBAC (external to this component)"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            KServeSA["kserve-controller-manager<br/>(manages InferenceService)"]
            PredictorSA["Predictor Pod SA<br/>(runs vllm-gaudi container)"]
        end

        subgraph Roles["Roles (KServe-defined)"]
            KServeRole["kserve-manager-role<br/>(ClusterRole)"]
        end

        subgraph Resources["Kubernetes Resources"]
            InferenceService["serving.kserve.io<br/>InferenceService"]
            ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
            Pods["core<br/>Pods"]
            Services["core<br/>Services"]
            Deployments["apps<br/>Deployments"]
        end
    end

    subgraph ContainerSecurity["Container Security Context"]
        direction TB
        NonRoot["Non-root Execution<br/>UID: 2000 (vllm user)<br/>GID: 0 (root group)<br/>OpenShift arbitrary UID supported"]
        Dirs["Group-Writable Directories<br/>/home/vllm<br/>/usr/src<br/>/workspace<br/>/var/log/habana_logs"]
    end

    subgraph AuthZ["Authentication & Authorization"]
        direction TB
        Endpoints["API Endpoints:<br/>POST /v1/completions<br/>POST /v1/chat/completions<br/>GET /v1/models<br/>POST /v1/embeddings<br/>GET /health"]
        AuthMech["Auth Mechanism:<br/>None at container level<br/>Enforcement: KServe / Platform Ingress<br/>(kube-rbac-proxy or Gateway API)"]
        Endpoints --> AuthMech
    end

    subgraph SecretsInfo["Secrets"]
        direction TB
        NoSecrets["No secrets used directly.<br/>Model access credentials are<br/>mounted by the platform<br/>(KServe storage initializer)."]
    end

    %% Relationships
    KServeSA -->|"bound via ClusterRoleBinding"| KServeRole
    KServeRole -->|"get, list, watch,<br/>create, update, patch, delete"| InferenceService
    KServeRole -->|"get, list, watch,<br/>create, update, patch, delete"| ServingRuntime
    KServeRole -->|"get, list, watch,<br/>create, update, patch, delete"| Pods
    KServeRole -->|"get, list, watch,<br/>create, update, patch, delete"| Services
    KServeRole -->|"get, list, watch,<br/>create, update, patch, delete"| Deployments

    KServeSA -->|"deploys pod with"| PredictorSA
    PredictorSA -->|"runs container as"| NonRoot

    %% Styling
    classDef delegated fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef info fill:#f9f9f9,stroke:#999,stroke-width:1px
    classDef resource fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class KServeSA,PredictorSA,KServeRole delegated
    class NonRoot,Dirs container
    class LegendNote,NoSecrets,AuthMech info
    class InferenceService,ServingRuntime,Pods,Services,Deployments resource
    class Endpoints info
