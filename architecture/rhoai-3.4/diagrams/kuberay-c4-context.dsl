// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages Ray clusters, jobs, and services for distributed computing"

        kuberay = softwareSystem "KubeRay Operator" "Kubernetes operator managing the lifecycle of Ray clusters, jobs, and services on OpenShift" {
            rcController = container "RayCluster Controller" "Reconciles RayCluster CRs: creates/manages head pods, worker pods, services, ingress" "Go Controller"
            rjController = container "RayJob Controller" "Reconciles RayJob CRs: creates RayClusters and K8s batch Jobs" "Go Controller"
            rsController = container "RayService Controller" "Reconciles RayService CRs: manages blue-green deployments" "Go Controller"
            authController = container "Authentication Controller" "Manages OIDC/OAuth auth: injects kube-rbac-proxy, creates HTTPRoutes and ReferenceGrants" "Go Controller"
            npController = container "NetworkPolicy Controller" "Creates NetworkPolicies for secure cluster isolation" "Go Controller"
            mtlsController = container "mTLS Controller" "Manages cert-manager Issuers and Certificates for inter-node mTLS" "Go Controller"
            webhook = container "Admission Webhooks" "Validates and defaults RayCluster specs" "Go Webhook Server" "9443/TCP"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics" "HTTP Server" "8080/TCP"
        }

        openshift = softwareSystem "OpenShift" "Container platform with Route API, SCC, serving certs" "External"
        certManager = softwareSystem "cert-manager" "Certificate lifecycle management for mTLS" "External"
        gatewayAPI = softwareSystem "Gateway API / data-science-gateway" "HTTPRoute-based ingress for Ray dashboards" "Internal ODH"
        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "OIDC/OAuth authentication sidecar for Ray head pods" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys kuberay-operator via Kustomize overlay" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano" "Batch scheduler for gang scheduling" "External"
        kueue = softwareSystem "Kueue" "Multi-cluster job queuing" "External"

        // User interactions
        user -> kuberay "Creates RayCluster/RayJob/RayService via kubectl"
        user -> gatewayAPI "Accesses Ray Dashboard via browser" "HTTPS/443"

        // System interactions
        kuberay -> openshift "Manages pods, services, routes, SCCs" "HTTPS/443"
        kuberay -> certManager "Creates Issuers and Certificates for mTLS" "Kubernetes API"
        kuberay -> gatewayAPI "Creates HTTPRoutes for dashboard access" "Gateway API"
        kuberay -> kubeRbacProxy "Injects as sidecar into Ray head pods" "Container injection"
        rhodsOperator -> kuberay "Deploys via Kustomize openshift overlay" "Kustomize"
        prometheus -> kuberay "Scrapes operator and Ray cluster metrics" "HTTP/8080"
        kuberay -> volcano "Gang scheduling for Ray pod groups" "Scheduler plugin"
        kuberay -> kueue "Multi-cluster job queuing integration" "ManagedBy field"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
