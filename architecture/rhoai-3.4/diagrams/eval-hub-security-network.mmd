graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client (Dashboard / SDK)"]
    end

    subgraph PlatformNS["PLATFORM NAMESPACE (Managed by TrustyAI Operator)"]
        direction TB
        API["eval-hub API Server<br/>ClusterIP Service<br/>8080/TCP (HTTP) or 8443/TCP (HTTPS)<br/>TLS 1.2-1.3<br/>FIPS: strictfipsruntime"]
    end

    subgraph TenantNS["TENANT NAMESPACE (Evaluation Job Pod)"]
        direction TB

        subgraph JobPod["batch/v1 Job Pod"]
            direction TB
            Init["eval-runtime-init<br/>(init container)<br/>No listener"]
            Sidecar["eval-runtime-sidecar<br/>(KEP-753 native sidecar)<br/>8080/TCP localhost<br/>HTTP plaintext (pod-local)"]
            Adapter["Framework Adapter<br/>lm-eval-harness / RAGAS /<br/>Garak / GuideLLM / LightEval / MTEB"]
        end
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Password auth"]
        MLflow["MLflow Tracking Server<br/>5000/TCP HTTPS<br/>TLS 1.2+"]
        OTEL["OTEL Collector<br/>4317/TCP gRPC<br/>TLS (configurable)"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
        ServiceCA["OpenShift Service CA<br/>ConfigMap mount"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["AWS S3<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        OCIRegistry["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    %% External to Platform
    Client -->|"HTTPS/8080-8443<br/>TLS 1.2-1.3<br/>Bearer Token (K8s SA)"| API

    %% Platform to Internal Services
    API -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview + SAR + Jobs"| K8sAPI
    API -->|"TCP/5432<br/>Configurable TLS<br/>Password (secret file)"| PostgreSQL
    API -->|"HTTPS/5000<br/>TLS 1.2+<br/>Bearer Token (projected SA)"| MLflow
    API -.->|"gRPC/4317<br/>TLS<br/>No auth"| OTEL
    Prometheus -.->|"HTTP(S)/8080<br/>Scrape /metrics"| API

    %% Job Pod Flows
    Init -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    Adapter -->|"HTTP/8080<br/>plaintext<br/>No auth (pod-local)"| Sidecar
    Sidecar -->|"HTTPS/8443<br/>TLS 1.2+<br/>SA Token (file)"| API
    Sidecar -->|"HTTPS/5000<br/>TLS 1.2+<br/>Projected SA Token"| MLflow
    Sidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (challenge)"| OCIRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef tenant fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class API platform
    class Init,Sidecar,Adapter tenant
    class K8sAPI,PostgreSQL,MLflow,OTEL,Prometheus,ServiceCA internal
    class S3,OCIRegistry extservice
