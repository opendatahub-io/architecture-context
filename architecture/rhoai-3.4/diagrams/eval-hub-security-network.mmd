graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Platform["PLATFORM LAYER (Operator-managed)"]
        KRBACProxy["kube-rbac-proxy<br/>TLS termination<br/>8443/TCP"]
    end

    subgraph EvalHubNS["EVAL-HUB SERVICE (Namespace-scoped)"]
        direction TB
        EvalHubAPI["eval-hub API Server<br/>ClusterIP: 8080/TCP<br/>HTTP (TLS optional)<br/>SA: eval-hub<br/>Image: quay.io/rhoai/odh-eval-hub-rhel9"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
    end

    subgraph EvalJobPod["EVALUATION JOB POD (Batch v1 Job)"]
        direction TB
        InitCont["eval-runtime-init<br/>(Init Container)<br/>S3 test data download"]
        AdapterCont["Evaluation Adapter<br/>(lm-eval / LightEval /<br/>Garak / GuideLLM)<br/>Provider-defined image"]
        SidecarCont["eval-runtime-sidecar<br/>(Native Sidecar KEP-753)<br/>8080/TCP HTTP<br/>restartPolicy: Always"]
    end

    subgraph DataPersistence["DATA PERSISTENCE"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>Password auth<br/>No encryption (in-cluster)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        OCI["OCI Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer (challenge/response)"]
        MLflow["MLflow Tracking Server<br/>5000/TCP HTTP/HTTPS<br/>TLS optional (custom CA)<br/>Bearer Token"]
    end

    %% External → Platform
    User -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| KRBACProxy

    %% Platform → EvalHub
    KRBACProxy -->|"HTTP/8080<br/>pod-local<br/>pre-authenticated"| EvalHubAPI

    %% EvalHub → K8s API
    EvalHubAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>In-cluster SA token<br/>TokenReview + SAR"| K8sAPI
    EvalHubAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Job/ConfigMap CRUD"| K8sAPI

    %% EvalHub → Data
    EvalHubAPI -->|"TCP/5432<br/>No encryption<br/>Password (DB_URL)"| PostgreSQL
    EvalHubAPI -->|"HTTP(S)/5000<br/>TLS optional<br/>Bearer Token"| MLflow

    %% K8s creates Job
    K8sAPI -.->|"creates"| EvalJobPod

    %% Init container → S3
    InitCont -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM (static key pair)"| S3

    %% Adapter → Sidecar (pod-local)
    AdapterCont -->|"HTTP/8080<br/>localhost<br/>No auth (pod-internal)"| SidecarCont

    %% Sidecar → upstream services
    SidecarCont -->|"HTTPS/8080<br/>TLS 1.2+<br/>Bearer SA token<br/>/api/v1/evaluations/*"| EvalHubAPI
    SidecarCont -->|"HTTPS/5000<br/>TLS 1.2+<br/>Bearer token (5min cache)<br/>/api/2.0/mlflow/*"| MLflow
    SidecarCont -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer (challenge/response)<br/>/{oci-repo-path}"| OCI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#e6d5f7,stroke:#8e44ad,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8s fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef jobpod fill:#d5f5e3,stroke:#27ae60,stroke-width:2px
    classDef persistence fill:#fdebd0,stroke:#e67e22,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class KRBACProxy platform
    class EvalHubAPI service
    class K8sAPI k8s
    class InitCont,AdapterCont,SidecarCont jobpod
    class PostgreSQL persistence
    class S3,OCI,MLflow externalservice
