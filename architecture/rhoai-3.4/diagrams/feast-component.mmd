graph TB
    subgraph FeastOperator["Feast Operator (Go - controller-runtime)"]
        Controller["FeatureStore Controller<br/>Reconciles FeatureStore CRs"]
        NotebookCtrl["Notebook ConfigMap Controller<br/>Watches Kubeflow Notebooks"]
        AccessMgr["Access Manager<br/>Auto-access RBAC reconciliation"]
        AuthzMgr["AuthZ Manager<br/>OIDC + K8s RBAC config"]
        RegistryClient["Registry Client<br/>Intra-comm JWT (HS256)"]
        TLSMgr["TLS Manager<br/>Service serving certs"]
    end

    subgraph FeatureServer["Feature Server (Python - FastAPI/Gunicorn)"]
        OnlineServer["Online Store Server<br/>6566/TCP (HTTP) | 6567/TCP (TLS)"]
        OfflineServer["Offline Store Server<br/>8815/TCP (HTTP) | 8816/TCP (TLS)"]
        RegistryGRPC["Registry gRPC Server<br/>6570/TCP (HTTP) | 6571/TCP (TLS)"]
        RegistryREST["Registry REST Server<br/>6572/TCP (HTTP) | 6573/TCP (TLS)"]
        UIServer["UI Server<br/>8888/TCP (HTTP) | 8443/TCP (TLS)"]
        Metrics["Prometheus Metrics<br/>8000/TCP"]
    end

    User["Data Scientist / ML App"] -->|"creates"| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|"watched by"| Controller

    Controller -->|"deploys"| FeatureServer
    Controller -->|"creates"| Services["ClusterIP Services<br/>online, offline, registry,<br/>registry-rest, ui"]
    Controller -->|"creates"| ConfigMaps["ConfigMaps<br/>feature_store.yaml"]
    Controller -->|"creates"| CronJobs["CronJobs<br/>feast apply / materialize"]
    Controller -->|"creates"| HPAs["HPA + PDB<br/>autoscaling"]
    Controller -->|"provisions"| RBAC["Roles & RoleBindings"]

    RegistryClient -->|"fetches permissions"| RegistryREST
    AccessMgr -->|"creates K8s RBAC from<br/>Feast permissions"| RBAC

    NotebookCtrl -->|"watches"| NotebookCR["Notebook CR<br/>(kubeflow.org)"]
    NotebookCtrl -->|"creates"| ClientCM["Client ConfigMap<br/>feast client config"]

    TLSMgr -->|"provisions via"| ServiceCA["OpenShift Service CA"]

    OnlineServer -->|"reads/writes"| OnlineStore["Online Store<br/>(Redis/PostgreSQL/DynamoDB)"]
    OfflineServer -->|"reads"| OfflineStore["Offline Store<br/>(DuckDB/PostgreSQL/Snowflake)"]
    RegistryGRPC -->|"persists to"| RegistryBackend["Registry Backend<br/>(SQLite/PostgreSQL/S3/GCS)"]

    Controller -->|"K8s API calls"| K8sAPI["Kubernetes API Server"]

    style FeastOperator fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServer fill:#7ed321,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style OnlineStore fill:#e8e8e8,stroke:#333
    style OfflineStore fill:#e8e8e8,stroke:#333
    style RegistryBackend fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style ServiceCA fill:#e8e8e8,stroke:#333
