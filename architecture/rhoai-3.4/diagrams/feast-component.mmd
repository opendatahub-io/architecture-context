graph TB
    subgraph "Feast Operator (redhat-ods-applications)"
        direction TB
        FSController["FeatureStore Controller<br/>(controller-runtime)"]
        NBController["NotebookConfigMap Controller<br/>(controller-runtime)"]
        AuthzPkg["FeastAuthorization<br/>(Go package)"]
        FSController -->|"delegates authz"| AuthzPkg
    end

    subgraph "Managed Feature Store (per namespace)"
        direction TB
        subgraph "Feast Deployment (multi-container Pod)"
            OnlineServer["Online Store Server<br/>(Python/gunicorn)<br/>6566/HTTP or 6567/HTTPS"]
            OfflineServer["Offline Store Server<br/>(Python/gunicorn)<br/>8815/HTTP or 8816/HTTPS"]
            RegistryServer["Registry Server<br/>(gRPC+REST)<br/>6570-6573/TCP"]
            UIServer["Feast UI<br/>8888/HTTP or 8443/HTTPS"]
            MetricsEndpoint["Metrics<br/>8000/HTTP"]
        end
        CronJob["CronJob Runner<br/>(ose-cli)<br/>feast apply / materialize"]
        NSRegistry["Namespace Registry<br/>(ConfigMap)"]
    end

    User[User / Data Scientist] -->|"creates"| FeatureStoreCR["FeatureStore CR<br/>(feast.dev/v1)"]
    FeatureStoreCR -->|"watched by"| FSController

    FSController -->|"creates"| OnlineServer
    FSController -->|"creates"| OfflineServer
    FSController -->|"creates"| RegistryServer
    FSController -->|"creates"| UIServer
    FSController -->|"creates"| CronJob
    FSController -->|"manages"| NSRegistry

    NotebookCR["Kubeflow Notebook CR"] -->|"watched by"| NBController
    NBController -->|"creates"| NBConfigMap["Per-Notebook<br/>ConfigMap"]

    AuthzPkg -->|"creates"| RBACResources["Roles / RoleBindings<br/>ClusterRoles / ClusterRoleBindings"]

    FSController -->|"depends on"| K8sAPI["Kubernetes API"]
    FSController -->|"deployed by"| RhodsOp["rhods-operator"]
    FSController -->|"auto TLS via"| OSCerts["OpenShift Service<br/>Serving Certs"]
    FSController -->|"creates Route"| OSRoute["OpenShift Route<br/>(UI only)"]

    CronJob -->|"kubectl exec"| OnlineServer

