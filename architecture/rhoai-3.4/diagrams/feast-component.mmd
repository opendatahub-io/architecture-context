graph TB
    subgraph FeastOperator["feast-operator (Go, controller-runtime)"]
        Controller["FeatureStore Controller<br/>Reconciles FeatureStore CRs"]
        NotebookCtrl["Notebook ConfigMap Controller<br/>Watches Kubeflow Notebooks"]
        AccessCtrl["Auto-Access RBAC Controller<br/>Polls registry permissions"]
        HealthProbe["Health Probes<br/>:8081/TCP"]
        Metrics["Operator Metrics<br/>:8443/TCP HTTPS"]
    end

    subgraph FeatureServerPython["feature-server Python (FastAPI/Gunicorn)"]
        RestAPI["REST API<br/>:6566/TCP"]
        OIDCAuth["OIDC / K8s Auth Middleware"]
        SecurityMgr["SecurityManager<br/>Permission-based RBAC"]
        MetricsPy["Prometheus Metrics<br/>:8000/TCP"]
    end

    subgraph FeatureServerGo["feature-server Go (net/http + gRPC)"]
        GoHTTP["HTTP Server<br/>:8080/TCP"]
        GoGRPC["gRPC Server<br/>:8080/TCP"]
        MetricsGo["Prometheus Metrics<br/>:9090/TCP"]
    end

    subgraph FeastUI["feast-ui (React/TypeScript)"]
        Dashboard["Web Dashboard<br/>:8080/TCP"]
    end

    subgraph SDK["feast Python SDK"]
        CLI["CLI (feast apply, materialize)"]
        ClientLib["Client Library"]
    end

    %% CRDs
    FeatureStoreCR["FeatureStore CR<br/>feast.dev/v1<br/>(Namespaced)"]

    %% User interactions
    User["Data Scientist / ML Engineer"]
    MLApp["ML Application"]

    User -->|"creates/manages"| FeatureStoreCR
    User -->|"defines features via"| CLI
    User -->|"browses features"| Dashboard
    FeatureStoreCR -->|"watched by"| Controller

    %% Operator creates child resources
    Controller -->|"deploys"| FeatureServerPython
    Controller -->|"deploys"| FeatureServerGo
    Controller -->|"deploys"| FeastUI
    Controller -->|"creates Deployments,<br/>Services, ConfigMaps,<br/>CronJobs, HPA, PDB,<br/>Routes, RBAC"| K8sResources["Kubernetes Resources"]

    NotebookCtrl -->|"injects feast-config<br/>ConfigMap"| Notebooks["Kubeflow Notebooks<br/>(labeled opendatahub.io/<br/>feast-integration=true)"]

    AccessCtrl -->|"fetches permissions"| RestAPI
    AccessCtrl -->|"creates ClusterRoles<br/>& RoleBindings"| K8sRBAC["Kubernetes RBAC"]

    %% Feature serving flows
    MLApp -->|"POST /get-online-features"| RestAPI
    MLApp -->|"gRPC GetOnlineFeatures"| GoGRPC
    RestAPI -->|"reads/writes"| OnlineStore["Online Store<br/>(Redis/Postgres/DynamoDB)"]
    GoHTTP -->|"reads"| OnlineStore
    GoGRPC -->|"reads"| OnlineStore

    %% Registry
    RestAPI -->|"gRPC/HTTP<br/>Bearer JWT"| Registry["Feature Registry<br/>:6570/TCP gRPC<br/>:8080/TCP REST"]
    Controller -->|"REST API<br/>Bearer JWT"| Registry

    %% Platform integration
    PlatformOp["rhods-operator"] -->|"deploys via<br/>Kustomize"| FeastOperator

    %% Styling
    style FeastOperator fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServerPython fill:#4a90e2,stroke:#333,color:#fff
    style FeatureServerGo fill:#4a90e2,stroke:#333,color:#fff
    style FeastUI fill:#4a90e2,stroke:#333,color:#fff
    style SDK fill:#4a90e2,stroke:#333,color:#fff
    style FeatureStoreCR fill:#f5a623,stroke:#333,color:#000
    style OnlineStore fill:#e8e8e8,stroke:#333,color:#000
    style Registry fill:#7ed321,stroke:#333,color:#000
    style PlatformOp fill:#7ed321,stroke:#333,color:#000
    style Notebooks fill:#7ed321,stroke:#333,color:#000
    style K8sResources fill:#e8e8e8,stroke:#333,color:#000
    style K8sRBAC fill:#e8e8e8,stroke:#333,color:#000
    style User fill:#f9f9f9,stroke:#999,color:#000
    style MLApp fill:#f9f9f9,stroke:#999,color:#000
