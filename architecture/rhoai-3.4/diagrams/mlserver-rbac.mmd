graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        subgraph NoK8sRBAC["Kubernetes RBAC"]
            NoRoles["No ClusterRoles<br/>No RoleBindings<br/>No ServiceAccount RBAC<br/><br/>MLServer does not interact<br/>with Kubernetes API directly"]
        end

        subgraph PlatformAuth["Platform-Level Auth (Delegated)"]
            Gateway["RHOAI Gateway<br/>+ kube-rbac-proxy sidecar"]
            BearerToken["Bearer Token Validation"]
            K8sRBAC["Kubernetes RBAC<br/>Authorization"]
            Gateway --> BearerToken
            BearerToken --> K8sRBAC
        end

        subgraph RuntimeSecurity["Runtime Security (Application-Level)"]
            direction TB
            TrustedFile["/etc/mlserver/trusted-runtimes.json<br/>(baked at container build time)"]
            ProdMode["Production Mode<br/>(file exists)"]
            DevMode["Development Mode<br/>(file absent)"]

            TrustedFile -->|"exists"| ProdMode
            TrustedFile -->|"absent"| DevMode

            subgraph ProdRestrictions["Production Mode Restrictions"]
                AllowList["Only allowlisted runtime<br/>import paths permitted"]
                NoCustEnv["Custom Python environments<br/>REJECTED"]
                NoCORS["Wildcard CORS origins<br/>REJECTED"]
                BuildValidation["Build-time validation:<br/>is_valid_runtime_import_path()"]
            end

            ProdMode --> ProdRestrictions

            subgraph DevPermissions["Development Mode Permissions"]
                AllRuntimes["All runtime implementations<br/>ALLOWED"]
                CustEnv["Custom Python environments<br/>ALLOWED"]
                CORS["Wildcard CORS origins<br/>ALLOWED"]
            end

            DevMode --> DevPermissions
        end

        subgraph FilesystemAccess["Filesystem Access (Read-Only)"]
            ModelDir["/mnt/models<br/>Model artifacts<br/>(PVC/S3 mount)"]
            SANamespace["/var/run/secrets/kubernetes.io/<br/>serviceaccount/namespace<br/>(CloudEvents headers)"]
        end

        subgraph NoSecrets["Kubernetes Secrets"]
            NoSecretsNote["No secrets defined or required<br/>TLS certs: platform gateway<br/>Storage creds: KServe storage initializer"]
        end
    end

    %% External flow
    Client["External Client"] -->|"HTTPS/443<br/>Bearer Token"| Gateway
    Gateway -->|"HTTP/8080 (plaintext)<br/>No Auth"| MLServerPod["MLServer Pod<br/>(no application-level auth)"]

    %% Styling
    style NoRoles fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style BearerToken fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style K8sRBAC fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style TrustedFile fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style ProdMode fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style DevMode fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style AllowList fill:#f8cecc,stroke:#b85450
    style NoCustEnv fill:#f8cecc,stroke:#b85450
    style NoCORS fill:#f8cecc,stroke:#b85450
    style BuildValidation fill:#f8cecc,stroke:#b85450
    style AllRuntimes fill:#fff2cc,stroke:#d6b656
    style CustEnv fill:#fff2cc,stroke:#d6b656
    style CORS fill:#fff2cc,stroke:#d6b656
    style ModelDir fill:#e1d5e7,stroke:#9673a6
    style SANamespace fill:#e1d5e7,stroke:#9673a6
    style NoSecretsNote fill:#d5e8d4,stroke:#82b366
    style Client fill:#f9f9f9,stroke:#999
    style MLServerPod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
