graph TD
    subgraph MLServerSecurity["MLServer Security Model"]
        direction TB

        Note["MLServer is a user-space application (not an operator)<br/>No Kubernetes RBAC roles defined<br/>Authentication and authorization delegated to external infrastructure"]
    end

    subgraph ExternalAuth["External Authentication/Authorization"]
        direction TB

        subgraph KubeRbacProxy["kube-rbac-proxy Sidecar (RHOAI 3.x)"]
            KRBP["kube-rbac-proxy<br/>Port: 8443/TCP (external)<br/>→ 8080/TCP (MLServer REST)"]
            KRBP_Auth["AuthN: Bearer Token<br/>AuthZ: Kubernetes RBAC<br/>TLS: Terminates TLS"]
        end

        subgraph KServeGW["KServe Gateway (Gateway API)"]
            GW["Envoy / Istio Gateway<br/>Port: 443/TCP (external)"]
            GW_Auth["AuthN: Bearer Token<br/>AuthZ: Gateway policies<br/>TLS: TLS 1.2+ termination"]
        end
    end

    subgraph RuntimeSecurity["Application-Level Security Controls"]
        direction TB

        TrustedAllowlist["Trusted Runtimes Allowlist<br/>/etc/mlserver/trusted-runtimes.json<br/>(read-only, baked into image at build)"]

        subgraph Controls["Enforcement Points"]
            ModelValidation["Model Settings Validation<br/>Rejects non-allowlisted<br/>implementation import paths<br/>(early rejection)"]
            ImplAccess["Implementation Access Check<br/>Defense-in-depth validation<br/>at model load time"]
            EnvBlock["Custom Environment Blocking<br/>Blocks environment_tarball<br/>and environment_path<br/>in production mode"]
            CORSBlock["CORS Restriction<br/>Wildcard CORS origins<br/>blocked in production mode"]
        end

        TrustedAllowlist -->|restricts| ModelValidation
        TrustedAllowlist -->|restricts| ImplAccess
        TrustedAllowlist -->|triggers| EnvBlock
        TrustedAllowlist -->|triggers| CORSBlock
    end

    subgraph AllowedRuntimes["Allowed Runtime Implementations (Production)"]
        SKLearn["mlserver_sklearn.SKLearnModel"]
        XGBoost["mlserver_xgboost.XGBoostModel"]
        LightGBM["mlserver_lightgbm.LightGBMModel"]
        ONNX["mlserver_onnx.ONNXModel"]
    end

    subgraph Blocked["Blocked in Production Mode"]
        ArbitraryImpl["Arbitrary Python import paths<br/>(prevents code execution)"]
        CustomEnv["Custom environment tarballs<br/>(prevents sys.path injection)"]
        CustomPath["Custom environment paths<br/>(prevents path manipulation)"]
        WildcardCORS["Wildcard CORS origins<br/>(prevents cross-origin abuse)"]
    end

    %% Flows
    KRBP -->|"proxies authenticated<br/>requests to"| MLServerSecurity
    GW -->|"proxies authenticated<br/>requests to"| MLServerSecurity

    ModelValidation -->|allows| AllowedRuntimes
    ModelValidation -->|rejects| ArbitraryImpl
    EnvBlock -->|blocks| CustomEnv
    EnvBlock -->|blocks| CustomPath
    CORSBlock -->|blocks| WildcardCORS

    %% Network access control
    subgraph NetworkSecurity["Network-Level Controls"]
        NP["NetworkPolicy<br/>Restricts access to<br/>metrics port 8082<br/>(Prometheus only)"]
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KRBP fill:#4a90e2,stroke:#333,color:#fff
    style KRBP_Auth fill:#bbdefb,stroke:#333
    style GW fill:#4a90e2,stroke:#333,color:#fff
    style GW_Auth fill:#bbdefb,stroke:#333
    style TrustedAllowlist fill:#e74c3c,stroke:#333,color:#fff
    style ModelValidation fill:#f5a623,stroke:#333
    style ImplAccess fill:#f5a623,stroke:#333
    style EnvBlock fill:#f5a623,stroke:#333
    style CORSBlock fill:#f5a623,stroke:#333
    style SKLearn fill:#7ed321,stroke:#333
    style XGBoost fill:#7ed321,stroke:#333
    style LightGBM fill:#7ed321,stroke:#333
    style ONNX fill:#7ed321,stroke:#333
    style ArbitraryImpl fill:#e57373,stroke:#333,color:#fff
    style CustomEnv fill:#e57373,stroke:#333,color:#fff
    style CustomPath fill:#e57373,stroke:#333,color:#fff
    style WildcardCORS fill:#e57373,stroke:#333,color:#fff
    style NP fill:#dae8fc,stroke:#6c8ebf
