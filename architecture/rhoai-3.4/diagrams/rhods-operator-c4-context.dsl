// RHOAI Operator (rhods-operator) - C4 Context Diagram
// Generated by: Claude Opus 4.6

workspace {
    model {
        admin = person "Platform Admin" "Configures RHOAI platform via DSC/DSCI custom resources"
        user = person "Data Scientist / Developer" "Accesses AI/ML services via gateway"

        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Central control-plane operator for Red Hat OpenShift AI, managing lifecycle of all AI/ML platform components" {
            dsciController = container "DSCInitialization Controller" "Initializes platform namespace, trusted CA bundles, and platform services" "Go Controller"
            dscController = container "DataScienceCluster Controller" "Reconciles component lifecycle (Managed/Unmanaged/Removed) for all AI/ML components" "Go Controller"
            gatewayController = container "Gateway Controller" "Deploys Gateway API infrastructure (GatewayClass, Gateway, kube-auth-proxy, EnvoyFilter)" "Go Controller"
            authController = container "Auth Controller" "Manages Auth CR for admin/allowed group RBAC" "Go Controller"
            monitoringController = container "Monitoring Controller" "Deploys Prometheus, alerting, Tempo" "Go Controller"
            componentControllers = container "Component Controllers" "16 controllers managing individual AI/ML components (Dashboard, KServe, DSP, etc.)" "Go Controllers"
            webhookServer = container "Admission Webhooks" "Validates/defaults DSC, DSCI, HardwareProfile, and other resources" "Go Webhook Server"
            kubeAuthProxy = container "kube-auth-proxy" "OAuth2/OIDC proxy for gateway authentication" "OAuth2 Proxy"
        }

        // External Dependencies
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        olm = softwareSystem "OLM (Operator Lifecycle Manager)" "Operator installation and upgrade lifecycle" "External"
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for gateway data plane (Envoy)" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API for ingress management" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management" "External"
        ocpOAuth = softwareSystem "OpenShift OAuth Server" "User authentication (IntegratedOAuth mode)" "External"
        externalOIDC = softwareSystem "External OIDC Provider" "User authentication (ROSA/external IdP)" "External"
        ocpIngress = softwareSystem "OpenShift Ingress Controller" "Route management for OcpRoute mode" "External"
        ocpServiceCA = softwareSystem "OpenShift Service CA" "Auto-provision TLS certificates for services" "External"
        prometheus = softwareSystem "Prometheus / Monitoring Stack" "Metrics collection and alerting" "External"

        // Internal ODH/RHOAI Components (deployed by operator)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for RHOAI platform" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving infrastructure" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model metadata management" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches" "Jupyter notebook environments" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay" "Ray distributed computing" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI" "Model explainability" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator" "Distributed training jobs" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and scheduling" "Internal RHOAI"
        feast = softwareSystem "Feast Operator" "Feature store management" "Internal RHOAI"
        llamastack = softwareSystem "LlamaStack Operator" "LLM serving infrastructure" "Internal RHOAI"
        mlflow = softwareSystem "MLflow Operator" "Experiment tracking" "Internal RHOAI"
        sparkOp = softwareSystem "Spark Operator" "Batch processing" "Internal RHOAI"
        maas = softwareSystem "Models-as-a-Service" "Managed model serving with API management" "Internal RHOAI"
        kuadrant = softwareSystem "Kuadrant" "API management (AuthPolicy, RateLimitPolicy)" "External"

        // Relationships - Admin
        admin -> rhoaiOperator "Creates DSC/DSCI CRs via kubectl" "HTTPS/6443"
        user -> rhoaiOperator "Accesses AI/ML services" "HTTPS/443 via Gateway"

        // Relationships - Operator to K8s
        rhoaiOperator -> k8sAPI "Reconciles resources" "HTTPS/6443 SA Token"
        rhoaiOperator -> olm "Managed by OLM" "CSV, Subscription"

        // Relationships - Operator to Infrastructure
        rhoaiOperator -> istio "Creates EnvoyFilter, DestinationRule" "CRD management"
        rhoaiOperator -> gatewayAPI "Creates GatewayClass, Gateway, HTTPRoute" "CRD management"
        rhoaiOperator -> certManager "Creates Certificate, ClusterIssuer" "CRD management"
        rhoaiOperator -> ocpOAuth "Authenticates users" "HTTPS/443 OAuth2"
        rhoaiOperator -> externalOIDC "Authenticates users (ROSA)" "HTTPS/443 OIDC"
        rhoaiOperator -> ocpIngress "Creates OCP Routes" "Route CRDs"
        rhoaiOperator -> ocpServiceCA "Auto-provisions TLS certs" "Annotations"
        rhoaiOperator -> prometheus "Exposes metrics" "HTTP/9000"

        // Relationships - Operator deploys components
        rhoaiOperator -> dashboard "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> kserve "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> dsp "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> modelRegistry "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> workbenches "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> kuberay "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> trustyai "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> trainingOperator "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> kueue "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> feast "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> llamastack "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> mlflow "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> sparkOp "Deploys from prefetched manifests" "kustomize"
        rhoaiOperator -> maas "Deploys from prefetched manifests" "kustomize"
        maas -> kuadrant "Uses for API management" "AuthPolicy, RateLimitPolicy CRDs"
    }

    views {
        systemContext rhoaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
