graph TD
    subgraph "Container Identity"
        Container["NeMo Guardrails Container<br/>UID: 1001 (non-root)"]
    end

    subgraph "Kubernetes RBAC"
        NoRBAC["No ClusterRoles Defined<br/>No RoleBindings Defined<br/>No Kubernetes API Access"]
    end

    subgraph "Application-Level Auth"
        direction TB
        NoBuiltInAuth["No Built-In Authentication<br/>on any endpoint"]

        subgraph "Endpoint Auth Delegation"
            ChatEndpoint["/v1/chat/completions<br/>Auth: None (app-level)<br/>Delegated to platform ingress"]
            CheckEndpoint["/v1/guardrail/checks<br/>Auth: None (app-level)<br/>Delegated to platform ingress"]
            ModelsEndpoint["/v1/models<br/>Auth: Forwarded Authorization header<br/>Passed through to upstream LLM"]
            ConfigsEndpoint["/v1/rails/configs<br/>Auth: None"]
            ActionsEndpoint["/v1/actions/run<br/>Auth: None<br/>Internal only (8001/TCP)"]
        end
    end

    subgraph "Platform Auth Layer"
        PlatformAuth["RHOAI Gateway / kube-rbac-proxy<br/>Provides AuthN/AuthZ at ingress<br/>TLS Termination"]
    end

    subgraph "Upstream Auth"
        LLMAuth["Upstream LLM Provider<br/>Auth: Bearer Token (API key)<br/>via environment variable"]
    end

    subgraph "Secrets"
        LLMKey["LLM API Key<br/>Type: Environment variable<br/>Provisioned: Manual / External<br/>Auto-Rotate: No"]
        OTelConfig["OTEL Configuration<br/>Type: Environment variables<br/>Provisioned: Platform operator<br/>Auto-Rotate: No"]
    end

    Container --> NoRBAC
    Container --> NoBuiltInAuth
    PlatformAuth -->|"HTTP/8000<br/>auth enforced at ingress"| ChatEndpoint
    PlatformAuth -->|"HTTP/8000<br/>auth enforced at ingress"| CheckEndpoint
    PlatformAuth -->|"HTTP/8000"| ModelsEndpoint
    PlatformAuth -->|"HTTP/8000"| ConfigsEndpoint
    ModelsEndpoint -->|"forwards auth header"| LLMAuth
    Container -->|"uses"| LLMKey
    Container -->|"uses"| OTelConfig

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style NoRBAC fill:#95a5a6,stroke:#333,color:#fff
    style NoBuiltInAuth fill:#e74c3c,stroke:#333,color:#fff
    style PlatformAuth fill:#2ecc71,stroke:#333,color:#fff
    style LLMAuth fill:#f5a623,stroke:#333
    style ChatEndpoint fill:#f9e79f,stroke:#333
    style CheckEndpoint fill:#f9e79f,stroke:#333
    style ModelsEndpoint fill:#f9e79f,stroke:#333
    style ConfigsEndpoint fill:#f9e79f,stroke:#333
    style ActionsEndpoint fill:#f9e79f,stroke:#333
    style LLMKey fill:#fadbd8,stroke:#333
    style OTelConfig fill:#fadbd8,stroke:#333
