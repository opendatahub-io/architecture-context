graph TD
    subgraph PlatformManaged["Platform-Managed RBAC (rhods-operator)"]
        direction TB

        Note["NeMo Guardrails is a standalone service.<br/>No Kubernetes RBAC (ClusterRoles, RoleBindings)<br/>defined within the component itself.<br/><br/>All RBAC is managed by the RHOAI<br/>platform operator (rhods-operator)."]
    end

    subgraph AuthenticationFlow["Authentication & Authorization Flow"]
        direction TB

        subgraph ExternalAuth["External Authentication"]
            PlatformAuth["Platform-Level Auth<br/>(kube-rbac-proxy or HTTPRoute policy)<br/>Enforcement: RHOAI platform ingress"]
        end

        subgraph HeaderForwarding["Header Forwarding (Application-Level)"]
            ClientHeaders["Client Headers<br/>(Authorization, X-* headers)"]
            ServerForward["NeMo Guardrails Server<br/>Forwards headers to LLM provider"]
            LLMAuth["LLM Provider Auth<br/>(Bearer Token / api-key / x-api-key)"]
        end

        PlatformAuth -->|"Authenticated request"| ClientHeaders
        ClientHeaders -->|"Authorization header<br/>X-* headers forwarded"| ServerForward
        ServerForward -->|"Provider-specific auth"| LLMAuth
    end

    subgraph EndpointAuth["Endpoint Authentication Matrix"]
        direction TB

        ChatEndpoint["/v1/chat/completions<br/>Auth: None (proxies Authorization to LLM)<br/>Enforcement: Application code"]
        ModelsEndpoint["/v1/models<br/>Auth: Forwards Authorization to LLM<br/>Enforcement: Application code"]
        ChecksEndpoint["/v1/guardrail/checks<br/>Auth: None<br/>Enforcement: Application code"]
        AllEndpoints["All endpoints<br/>Auth: Platform-level<br/>Enforcement: Platform ingress"]
    end

    subgraph Secrets["Secrets (No Auto-Rotation)"]
        direction TB

        LLMKey["LLM API Key<br/>(Opaque)<br/>OPENAI_API_KEY,<br/>ANTHROPIC_API_KEY, etc.<br/>Provisioned: Manual/Platform"]
        AzureConfig["Azure OpenAI Config<br/>(Opaque)<br/>Endpoint, API version, API key<br/>Provisioned: Manual/Platform"]
        CohereKey["Cohere API Key<br/>(Opaque)<br/>COHERE_API_KEY<br/>Provisioned: Manual/Platform"]
        RedisCredentials["Redis Credentials<br/>(Opaque)<br/>Username/password<br/>Provisioned: Manual/Platform"]
    end

    subgraph ContainerSecurity["Container Security"]
        direction TB

        NonRoot["Non-root user: 1001"]
        BaseImage["Base: UBI9/python-312"]
        VirtualEnv["Virtual env: /app/.venv"]
        AirGapped["Pre-downloaded ML models<br/>(air-gapped deployments)"]
    end

    style PlatformManaged fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style AuthenticationFlow fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style EndpointAuth fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Secrets fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style ContainerSecurity fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style Note fill:#ffe6cc,stroke:#d79b00
    style PlatformAuth fill:#d5e8d4,stroke:#82b366
    style ClientHeaders fill:#d5e8d4,stroke:#82b366
    style ServerForward fill:#d5e8d4,stroke:#82b366
    style LLMAuth fill:#d5e8d4,stroke:#82b366
