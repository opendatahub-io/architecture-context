graph LR
    MLServer["MLServer<br/>V2 Inference Server<br/>Python 1.7.1+rhaiv.8"]

    %% Platform Dependencies (Internal)
    MLServer -->|"container runtime<br/>InferenceService pod"| KServe["KServe<br/>(deploys MLServer)"]
    MLServer -->|"CRD reference<br/>containers[].image"| ServingRuntime["KServe<br/>ServingRuntime CR"]
    MLServer -->|"volume mount<br/>/mnt/models"| ModelStorage["Model Storage<br/>(PVC / S3 / ModelCar)"]
    MLServer -->|"metrics scraping<br/>HTTP/8082"| Prometheus["Prometheus"]
    MLServer -.->|"OTLP traces<br/>gRPC (insecure)"| OTelCollector["OpenTelemetry<br/>Collector"]
    MLServer -.->|"event-driven inference<br/>TCP/9092"| Kafka["Kafka Broker"]
    MLServer -->|"auth proxy<br/>8443→8080"| KubeRbacProxy["kube-rbac-proxy<br/>(RHOAI 3.x)"]

    %% Framework Dependencies (Key Libraries)
    subgraph Frameworks["Core Frameworks"]
        FastAPI["FastAPI<br/>>=0.88.0,<0.116.0"]
        Uvicorn["Uvicorn<br/>ASGI server"]
        GRPC["grpcio<br/>>=1.67.1"]
        Protobuf["protobuf<br/>>=5.27.2,<7.0.0"]
        Pydantic["pydantic<br/>^2.7.1"]
    end

    MLServer -->|REST API| FastAPI
    MLServer -->|HTTP server| Uvicorn
    MLServer -->|gRPC server| GRPC
    MLServer -->|serialization| Protobuf
    MLServer -->|data validation| Pydantic

    %% ML Runtime Dependencies
    subgraph MLFrameworks["ML Frameworks (Runtime Plugins)"]
        ScikitLearn["scikit-learn<br/>1.8.0"]
        XGBoost["XGBoost<br/>3.2.0"]
        LightGBM["LightGBM<br/>4.6.0"]
        ONNXRuntime["onnxruntime<br/>1.24.4"]
    end

    MLServer -->|sklearn runtime| ScikitLearn
    MLServer -->|xgboost runtime| XGBoost
    MLServer -->|lightgbm runtime| LightGBM
    MLServer -->|onnx runtime| ONNXRuntime

    %% Observability Dependencies
    subgraph Observability["Observability Libraries"]
        PromClient["prometheus-client"]
        OTelSDK["opentelemetry-sdk<br/>^1.22.0"]
        StarletteExp["starlette-exporter"]
        GRPCProm["py-grpc-prometheus"]
    end

    MLServer -->|metrics| PromClient
    MLServer -->|tracing| OTelSDK
    MLServer -->|REST metrics| StarletteExp
    MLServer -->|gRPC metrics| GRPCProm

    %% Build Dependencies
    subgraph Build["Build Infrastructure"]
        BaseImage["UBI Base Image<br/>quay.io/aipcc/base-images/cpu:3.4.0"]
        PyPI["Red Hat Private PyPI<br/>console.redhat.com/api/pypi"]
        Konflux["Konflux/Tekton<br/>Hermetic Builds"]
    end

    MLServer -.->|base image| BaseImage
    MLServer -.->|pip packages| PyPI
    MLServer -.->|CI/CD| Konflux

