graph LR
    MLServer["MLServer<br/>Inference Server<br/>v1.7.1+rhaiv.8"]

    %% Internal RHOAI Dependencies
    MLServer -->|"container image<br/>in InferenceService pods"| KServe["KServe<br/>Controller"]
    MLServer -->|"TLS termination<br/>+ auth proxy"| RHOAIGateway["RHOAI Gateway<br/>+ kube-rbac-proxy"]

    %% Runtime Frameworks (bundled in RHOAI image)
    subgraph BundledRuntimes["RHOAI Curated Runtimes (in container)"]
        SKLearn["scikit-learn<br/>1.8.0"]
        XGBoost["XGBoost<br/>3.2.0"]
        LightGBM["LightGBM<br/>4.6.0"]
        ONNX["ONNX Runtime<br/>1.24.4"]
    end
    MLServer -->|"pluggable runtime"| BundledRuntimes

    %% Core Framework Dependencies
    subgraph CoreDeps["Core Framework Dependencies"]
        FastAPI["FastAPI<br/>>=0.88.0,<0.116.0"]
        Uvicorn["uvicorn"]
        GRPCIO["grpcio<br/>>=1.67.1"]
        Protobuf["protobuf<br/>>=5.27.2,<7.0.0"]
        Pydantic["pydantic<br/>^2.7.1"]
    end
    MLServer -->|"REST framework"| FastAPI
    MLServer -->|"ASGI server"| Uvicorn
    MLServer -->|"gRPC framework"| GRPCIO
    MLServer -->|"serialization"| Protobuf
    MLServer -->|"settings/validation"| Pydantic

    %% Observability Dependencies
    subgraph ObsDeps["Observability"]
        OTelSDK["opentelemetry-sdk<br/>^1.22.0"]
        OTelFastAPI["opentelemetry-instrumentation<br/>-fastapi >=0.43b0"]
        OTelGRPC["opentelemetry-instrumentation<br/>-grpc >=0.43b0"]
        StarletteProm["starlette-exporter"]
        GRPCProm["py-grpc-prometheus"]
    end
    MLServer -->|"distributed tracing"| OTelSDK
    MLServer -->|"REST tracing"| OTelFastAPI
    MLServer -->|"gRPC tracing"| OTelGRPC
    MLServer -->|"REST metrics"| StarletteProm
    MLServer -->|"gRPC metrics"| GRPCProm

    %% External Services
    MLServer -->|"model artifacts<br/>filesystem mount"| ModelStorage["Model Storage<br/>(PVC / S3)"]
    MLServer -.->|"trace export<br/>gRPC/4317 insecure"| OTelCollector["OpenTelemetry<br/>Collector"]
    MLServer -.->|"async inference<br/>TCP/9092"| KafkaBroker["Kafka Broker"]
    MLServer -.->|"black-box explain<br/>HTTP(S)"| RemoteInfer["Remote Inference<br/>Server"]

    %% Integration Points (inbound)
    Prometheus["Prometheus"] -->|"scrapes<br/>HTTP/8082 /metrics"| MLServer

