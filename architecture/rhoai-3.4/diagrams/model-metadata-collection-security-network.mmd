%% Security Network Diagram - Model Metadata Collection
%% Generated by: Claude Opus 4.6

graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Environment)"]
        direction TB

        subgraph CICD["CI/CD Pipeline (GitHub Actions / Tekton)"]
            CLI["model-extractor CLI<br/>Go 1.24+<br/>Runs to completion"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Outbound Egress Only)"]
        direction TB
        HF["HuggingFace API<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None (public)"]
        RHR["Red Hat Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Docker credentials"]
    end

    subgraph ImageRegistry["IMAGE REGISTRY (Build Output)"]
        Quay["Quay.io<br/>quay.io/opendatahub/odh-model-metadata-collection<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: QUAY_USERNAME/PASSWORD"]
    end

    subgraph Runtime["RUNTIME (OpenShift Cluster)"]
        direction TB

        subgraph ConsumerPod["Consumer Pod"]
            Dashboard["RHOAI Dashboard<br/>Container"]
            DataContainer["Data Container<br/>odh-model-metadata-collection<br/>ubi9-minimal | UID 1001<br/>sleep infinity<br/>NO network services<br/>NO egress"]
        end

        DataFiles["/app/data/<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>other-models-catalog.yaml<br/>(chmod 644, read-only)"]
    end

    %% Build-time flows
    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (public API)<br/>30s timeout"| HF
    CLI -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker registry auth"| RHR
    CICD -->|"HTTPS/443<br/>TLS 1.2+<br/>Username/Password"| Quay

    %% Runtime flows
    Dashboard -->|"Volume mount<br/>File I/O<br/>Pod-level RBAC"| DataContainer
    DataContainer --- DataFiles

    %% Styling
    classDef buildtime fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
