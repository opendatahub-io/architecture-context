graph TB
    subgraph BuildTime["BUILD-TIME (CI/CD Pipeline Only)"]
        direction TB

        subgraph TektonPod["Tekton Build Pod"]
            Extractor["model-extractor CLI<br/>Go 1.24<br/>Hermetic build (gomod prefetch)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time Egress)"]
        direction TB
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        OCIRegistry["OCI Registry<br/>registry.redhat.io<br/>TLS 1.2+<br/>Public pull (no auth)"]
    end

    subgraph Runtime["RUNTIME (Kubernetes Cluster)"]
        direction TB

        subgraph DataPod["Data Container Pod"]
            DataContainer["odh-model-metadata-collection<br/>Image: quay.io/rhoai/odh-model-metadata-collection-rhel9<br/>Base: ubi9-minimal<br/>Entrypoint: sleep infinity<br/>Network: NONE<br/>Binaries: NONE"]
            DataVolume["/app/data/<br/>models-catalog.yaml<br/>mcp-servers-catalog.yaml<br/>models-index.yaml"]
            DataContainer --- DataVolume
        end

        subgraph Consumer["Consumer Pod"]
            Dashboard["RHOAI Dashboard<br/>Reads catalog YAML"]
        end
    end

    %% Build-time flows
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN (optional)<br/>Retry: 3x exp backoff"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (public)<br/>OCI Distribution v2"| OCIRegistry

    %% Build output
    Extractor -.->|"Generates YAML<br/>→ Container image"| DataVolume

    %% Runtime flow (no network)
    Dashboard -->|"Volume mount<br/>Filesystem only<br/>No network"| DataVolume

    %% Styling
    classDef buildtime fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef external fill:#fff3e0,stroke:#e65100,stroke-width:2px
    classDef runtime fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px
    classDef datacontainer fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px
    classDef nonetwork fill:#d5e8d4,stroke:#82b366,stroke-width:3px

    class Extractor buildtime
    class HuggingFace,OCIRegistry external
    class Dashboard runtime
    class DataContainer,DataVolume nonetwork
