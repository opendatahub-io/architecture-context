graph TB
    subgraph BuildTime["BUILD-TIME ENVIRONMENT (CI Pipeline)"]
        direction TB
        Extractor["model-extractor<br/>(Go CLI)<br/>No RBAC required"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Build-Time Egress Only)"]
        direction LR
        HuggingFace["HuggingFace API<br/>huggingface.co<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token (optional)"]
        Registry["Red Hat Container Registry<br/>registry.redhat.io<br/>443/TCP<br/>TLS 1.2+<br/>No auth (public)"]
    end

    subgraph BuildOutput["BUILD ARTIFACT"]
        CatalogFiles["Pre-generated YAML Catalogs<br/>models-catalog.yaml<br/>validated-models-catalog.yaml<br/>*-mcp-servers-catalog.yaml"]
    end

    subgraph KonfluxBuild["KONFLUX CI/CD"]
        Dockerfile["Dockerfile.konflux<br/>COPY data/*.yaml /app/data/"]
    end

    subgraph Runtime["RUNTIME (No Network Access)"]
        direction TB
        subgraph DataContainer["odh-model-metadata-collection"]
            Container["Data Container<br/>Image: ubi9-micro<br/>CMD: sleep infinity<br/>UID: 1001 (non-root)<br/>No ports, no ingress, no egress<br/>No RBAC, no executable code"]
            Volume["/app/data/<br/>YAML catalog files<br/>+ benchmarks/"]
            Container --- Volume
        end
    end

    subgraph Consumers["PLATFORM CONSUMERS"]
        Dashboard["RHOAI Dashboard<br/>Reads catalog files<br/>via volume mount"]
    end

    %% Build-time flows (network)
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN (optional)<br/>Rate-limited without token"| HuggingFace
    Extractor -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth (public)"| Registry

    %% Build pipeline
    Extractor -->|"File I/O<br/>Generates YAML"| CatalogFiles
    CatalogFiles -->|"Committed to repo<br/>data/ directory"| Dockerfile
    Dockerfile -->|"Container build<br/>COPY to /app/data/"| Container

    %% Runtime consumption (no network)
    Volume -->|"Volume mount<br/>File I/O only<br/>No network"| Dashboard

    %% Styling - trust zones
    classDef buildtime fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef artifact fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef consumer fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef pipeline fill:#ffe6cc,stroke:#d79b00,stroke-width:2px

    class Extractor buildtime
    class HuggingFace,Registry external
    class CatalogFiles artifact
    class Container,Volume runtime
    class Dashboard consumer
    class Dockerfile pipeline
