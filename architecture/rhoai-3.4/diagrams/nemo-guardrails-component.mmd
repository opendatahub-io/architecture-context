graph TB
    subgraph NemoGuardrails["NeMo Guardrails Server"]
        direction TB
        FastAPIServer["FastAPI Server<br/>8000/TCP"]

        subgraph Engines["Dual Engine Architecture"]
            LLMRails["LLMRails Engine<br/>Full-featured: dialog flows,<br/>RAG, multi-step rails"]
            IORails["IORails Engine<br/>Fast path: content safety<br/>checks without LLM generation"]
        end

        Facade["Guardrails Facade<br/>Auto-selects engine"]

        subgraph ColangRuntime["Colang Runtime"]
            Colang1["Colang 1.0<br/>Pattern matching"]
            Colang2["Colang 2.x<br/>State machine /<br/>event-driven flows"]
        end

        subgraph GuardrailsLibrary["Open-Source Guardrails Library (11 modules)"]
            SelfCheck["Self-Check<br/>Input/Output"]
            ContentSafety["Content Safety"]
            InjectionDetect["Injection Detection<br/>(YARA)"]
            SensitiveData["Sensitive Data<br/>Detection (Presidio)"]
            TopicSafety["Topic Safety"]
            Regex["Regex Filters"]
            Hallucination["Hallucination<br/>Check"]
            FactCheck["Fact Checking"]
        end

        KnowledgeBase["Knowledge Base<br/>Embedding Index"]
        EmbeddingsSystem["Embeddings System<br/>FastEmbed / Sentence Transformers"]
        TracingAdapter["OpenTelemetry<br/>Tracing Adapter"]
    end

    subgraph ActionsServer["Actions Server"]
        ActionsAPI["FastAPI Server<br/>8001/TCP"]
    end

    Client["Client"] -->|"POST /v1/chat/completions<br/>POST /v1/guardrail/checks"| FastAPIServer
    FastAPIServer --> Facade
    Facade -->|"complex flows"| LLMRails
    Facade -->|"safety-only"| IORails
    LLMRails --> ColangRuntime
    LLMRails --> GuardrailsLibrary
    IORails --> GuardrailsLibrary
    LLMRails --> KnowledgeBase
    KnowledgeBase --> EmbeddingsSystem
    FastAPIServer --> TracingAdapter

    LLMRails -->|"LLM inference<br/>HTTPS/443"| UpstreamLLM["Upstream LLM Server<br/>(OpenAI / NVIDIA NIM)"]
    TracingAdapter -->|"OTLP gRPC/4317"| OTelCollector["OpenTelemetry Collector"]
    FastAPIServer -.->|"optional<br/>TCP/6379"| Redis["Redis<br/>Thread Persistence"]
    FastAPIServer -->|"remote actions"| ActionsAPI

    PlatformGateway["RHOAI Gateway<br/>(Ingress)"] -->|"HTTP/8000<br/>Platform TLS"| FastAPIServer

