graph TB
    subgraph NemoGuardrails["NeMo Guardrails Component"]
        direction TB

        subgraph Server["Guardrails Server (FastAPI/Uvicorn)"]
            API["HTTP API Server<br/>Port 8000/TCP"]
            ChatUI["Chat UI<br/>Static Frontend"]
        end

        subgraph Engines["Rails Engines"]
            LLMRails["LLMRails Engine<br/>Full-featured Colang flows"]
            IORails["IORails Engine<br/>Optimized I/O-only rails"]
            ColangRT["Colang Runtime<br/>DSL for conversational guardrails"]
            LLMRails -->|uses| ColangRT
        end

        subgraph Managers["Orchestration"]
            RailsMgr["RailsManager<br/>Orchestrates rail execution"]
            ModelMgr["ModelManager<br/>Manages model engine instances"]
            RailsMgr -->|delegates to| ModelMgr
        end

        subgraph HTTPClients["HTTP Clients"]
            ModelEngine["ModelEngine<br/>LLM /v1/chat/completions client"]
            APIEngine["APIEngine<br/>External API client"]
        end

        subgraph NLPModels["Embedded NLP Models"]
            Embeddings["Embeddings Engine<br/>FastEmbed / sentence-transformers"]
            SpaCy["spaCy en_core_web_lg<br/>Entity Recognition"]
            Presidio["Presidio Analyzer/Anonymizer<br/>PII Detection"]
            YARA["YARA Rules Engine<br/>Jailbreak Pattern Matching"]
            KB["Knowledge Base<br/>RAG-style context"]
        end

        subgraph GuardrailLib["Guardrail Library"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            TopicSafety["Topic Safety"]
            SDD["Sensitive Data Detection"]
            Hallucination["Hallucination Detection"]
            SelfCheck["Self Check"]
            Regex["Regex Filters"]
            InjectionDetect["Injection Detection"]
        end

        ActionsServer["Actions Server<br/>Port 8001/TCP"]
        CLI["CLI (Typer)<br/>Chat, Server Mgmt"]
        Tracing["Tracing<br/>OpenTelemetry"]
    end

    %% Internal connections
    API -->|routes to| LLMRails
    API -->|routes to| IORails
    LLMRails --> RailsMgr
    IORails --> RailsMgr
    RailsMgr --> GuardrailLib
    ModelMgr --> ModelEngine
    GuardrailLib --> Embeddings
    GuardrailLib --> SpaCy
    SDD --> Presidio
    JailbreakDetect --> YARA
    JailbreakDetect --> APIEngine
    LLMRails --> KB

    %% External connections
    Client["Client Application"] -->|POST /v1/chat/completions<br/>HTTP 8000/TCP| API
    ModelEngine -->|POST /v1/chat/completions<br/>HTTPS/HTTP| UpstreamLLM["Upstream LLM Server<br/>(vLLM / TGI)"]
    ModelEngine -->|HTTPS 443/TCP| NIM["NVIDIA NIM API"]
    Tracing -.->|OTLP 4317/4318| OTelCollector["OpenTelemetry Collector"]

