graph TB
    subgraph NemoGuardrails["NeMo Guardrails Server (FastAPI/Uvicorn)"]
        direction TB

        subgraph APILayer["API Layer (Port 8000)"]
            ChatAPI["/v1/chat/completions<br/>POST"]
            ChecksAPI["/v1/guardrail/checks<br/>POST (RHOAI-specific)"]
            ModelsAPI["/v1/models<br/>GET"]
            ConfigsAPI["/v1/rails/configs<br/>GET"]
            HealthAPI["/ Health Check<br/>GET"]
        end

        subgraph Engines["Execution Engines"]
            IORails["IORails Engine<br/>(Optimized fast path)"]
            LLMRails["LLMRails Engine<br/>(Full Colang runtime)"]
        end

        subgraph GuardrailsLib["Guardrails Library (30+ types)"]
            ContentSafety["Content Safety"]
            JailbreakDetect["Jailbreak Detection"]
            SDD["Sensitive Data Detection<br/>(Presidio/spacy)"]
            Hallucination["Hallucination Check"]
            SelfCheck["Self-Check<br/>(Input/Output/Facts)"]
        end

        subgraph Support["Supporting Components"]
            ColangParser["Colang Parser<br/>(v1.0 + v2.x)"]
            EmbeddingSystem["Embedding System<br/>(FastEmbed/ONNX)"]
            KnowledgeBase["Knowledge Base<br/>(Annoy vector index)"]
            LFUCache["LFU Cache<br/>(LLM response cache)"]
        end

        ChatAPI --> IORails
        ChatAPI --> LLMRails
        ChecksAPI --> IORails
        ChecksAPI --> LLMRails
        IORails --> GuardrailsLib
        LLMRails --> ColangParser
        LLMRails --> GuardrailsLib
        EmbeddingSystem --> KnowledgeBase
    end

    subgraph ActionsServer["Actions Server (Port 8001)"]
        ActionsRun["/v1/actions/run<br/>POST"]
        ActionsList["/v1/actions/list<br/>GET"]
    end

    Client[Client / Platform Ingress] -->|"HTTP/8000<br/>Platform TLS"| ChatAPI
    Client -->|"HTTP/8000<br/>Platform TLS"| ChecksAPI
    Client -->|"HTTP/8000<br/>Platform TLS"| ModelsAPI

    NemoGuardrails -->|"HTTPS/443<br/>Bearer Token"| LLMProvider["LLM Provider<br/>(OpenAI/vLLM/NIM/etc.)"]
    ContentSafety -->|"HTTP(S)<br/>API key"| ContentSafetyModel["Content Safety Model"]
    JailbreakDetect -->|"HTTP(S)<br/>API key"| JailbreakEndpoint["Jailbreak Detection Endpoint"]
    NemoGuardrails -.->|"TCP/6379<br/>Optional"| Redis["Redis<br/>(Thread state)"]

    CLI["CLI (Typer)"] -->|"In-process"| NemoGuardrails

