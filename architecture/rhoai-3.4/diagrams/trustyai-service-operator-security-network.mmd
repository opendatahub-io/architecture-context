graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Clients<br/>Data Scientists"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - Reencrypt TLS)"]
        TASRoute["TAS Route<br/>443/TCP → 8443<br/>Reencrypt TLS"]
        GORCHRoute["GORCH Route<br/>443/TCP → 8432<br/>Reencrypt TLS"]
        GORCHGWRoute["GORCH Gateway Route<br/>443/TCP → 8490<br/>Reencrypt TLS"]
        GORCHBIRoute["GORCH Built-in Route<br/>443/TCP → 8480<br/>Reencrypt TLS"]
        GORCHHealthRoute["GORCH Health Route<br/>443/TCP → 8034<br/>Edge TLS"]
        NemoRoute["NeMo Route<br/>443/TCP → 8443<br/>Reencrypt TLS"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443<br/>Reencrypt TLS"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph TAS_NS["TrustyAI Service"]
            TAS_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ FIPS ciphers<br/>SAR: services/get"]
            TAS_SVC["TrustyAI Service<br/>8080/TCP HTTP (internal)<br/>4443/TCP HTTPS (internal TLS)<br/>SA: {tas}-proxy"]
        end

        subgraph GORCH_NS["Guardrails Orchestrator"]
            GORCH_KRBP["kube-rbac-proxy (orchestrator)<br/>8432/TCP HTTPS<br/>SAR auth"]
            GORCH_ORCH["Orchestrator<br/>8032/TCP HTTP loopback"]
            GORCH_GW_KRBP["kube-rbac-proxy (gateway)<br/>8490/TCP HTTPS<br/>SAR auth"]
            GORCH_GW["Gateway Sidecar"]
            GORCH_BI_KRBP["kube-rbac-proxy (built-in)<br/>8480/TCP HTTPS<br/>SAR auth"]
            GORCH_BI["Built-in Regex Detector<br/>8080/TCP HTTP loopback"]
            GORCH_HEALTH["Health<br/>8034/TCP HTTP no auth<br/>SA: {gorch}-serviceaccount"]
        end

        subgraph NEMO_NS["NeMo Guardrails"]
            NEMO_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR auth"]
            NEMO_SVC["NeMo Server<br/>CA: ODH+OpenShift+user<br/>SA: {nemo}-serviceaccount"]
        end

        subgraph EVALHUB_NS["EvalHub"]
            EH_KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SAR + X-Tenant header<br/>Multi-tenant access"]
            EH_SVC["EvalHub API Server<br/>SA: {evalhub}-service"]
        end

        subgraph OPERATOR_NS["Operator"]
            OP["trustyai-service-operator<br/>8080/TCP metrics (HTTP)<br/>8081/TCP probes (HTTP)<br/>SA: controller-manager"]
        end

        subgraph LMES_PODS["LMEval Jobs (Ephemeral)"]
            LMES_POD["Evaluation Pod<br/>Driver: 18080/TCP localhost<br/>Controller polls via SPDY/TLS"]
        end
    end

    subgraph ExternalServices["EGRESS (External Services)"]
        KServeEP["KServe InferenceService<br/>varies HTTP/HTTPS<br/>TLS conditional"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS<br/>AWS IAM"]
        OCI["OCI Registries<br/>443/TCP HTTPS TLS<br/>credentials"]
        Git["Git Repos<br/>443/TCP HTTPS<br/>(HTTPS-only enforced)"]
        PgSQL["PostgreSQL<br/>configurable TCP<br/>TLS verify-ca (optional)"]
        MLFlow["MLFlow Server<br/>varies HTTP/HTTPS<br/>SA token"]
        OTLP["OTLP Collector<br/>configurable gRPC/HTTP<br/>TLS conditional"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>Bearer Token"| TASRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| GORCHRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| GORCHGWRoute
    Client -->|"HTTPS/443"| GORCHHealthRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| GORCHBIRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| NemoRoute
    Client -->|"HTTPS/443<br/>Bearer Token + X-Tenant"| EvalHubRoute

    %% Ingress → Services
    TASRoute --> TAS_KRBP
    GORCHRoute --> GORCH_KRBP
    GORCHGWRoute --> GORCH_GW_KRBP
    GORCHBIRoute --> GORCH_BI_KRBP
    GORCHHealthRoute --> GORCH_HEALTH
    NemoRoute --> NEMO_KRBP
    EvalHubRoute --> EH_KRBP

    %% Internal flows
    TAS_KRBP --> TAS_SVC
    GORCH_KRBP --> GORCH_ORCH
    GORCH_GW_KRBP --> GORCH_GW
    GORCH_BI_KRBP --> GORCH_BI
    NEMO_KRBP --> NEMO_SVC
    EH_KRBP --> EH_SVC

    %% Egress flows
    TAS_SVC -->|"HTTP/HTTPS<br/>prediction logging"| KServeEP
    GORCH_ORCH -->|"HTTPS/TLS<br/>auto-discovered"| KServeEP
    LMES_POD -->|"HTTPS/443<br/>AWS IAM"| S3
    LMES_POD -->|"HTTPS/443<br/>credentials"| OCI
    LMES_POD -->|"HTTPS/443"| Git
    TAS_SVC -->|"TCP/TLS<br/>DB credentials"| PgSQL
    EH_SVC -->|"HTTP/HTTPS<br/>SA token"| MLFlow
    GORCH_ORCH -->|"gRPC/HTTP"| OTLP
    EH_SVC -->|"gRPC/HTTP"| OTLP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef krbp fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class Client external
    class TASRoute,GORCHRoute,GORCHGWRoute,GORCHBIRoute,GORCHHealthRoute,NemoRoute,EvalHubRoute ingress
    class TAS_SVC,GORCH_ORCH,GORCH_GW,GORCH_BI,GORCH_HEALTH,NEMO_SVC,EH_SVC,OP,LMES_POD internal
    class TAS_KRBP,GORCH_KRBP,GORCH_GW_KRBP,GORCH_BI_KRBP,NEMO_KRBP,EH_KRBP krbp
    class KServeEP,S3,OCI,Git,PgSQL,MLFlow,OTLP egress
