graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes - TLS Termination)"]
        TASRoute["TrustyAI Route<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS"]
        GORCHRoute["Guardrails Route<br/>443/TCP → 8432/TCP<br/>Reencrypt TLS"]
        GORCHHealthRoute["Guardrails Health Route<br/>443/TCP → 9443/TCP<br/>Edge TLS"]
        GORCHGatewayRoute["Guardrails Gateway Route<br/>443/TCP → 8490/TCP<br/>Edge/Reencrypt (conditional)"]
        NEMORoute["NeMo Route<br/>443/TCP → 8443/TCP<br/>Edge/Reencrypt TLS"]
        EvalHubRoute["EvalHub Route<br/>443/TCP → 8443/TCP<br/>Reencrypt TLS"]
    end

    subgraph AuthLayer["AUTH LAYER (kube-rbac-proxy sidecars)"]
        direction TB
        AuthNote["TokenReview + SubjectAccessReview<br/>FIPS 140-2 cipher suites<br/>Image: origin-kube-rbac-proxy:4.19"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["trustyai-service-operator<br/>SA: controller-manager<br/>8080/TCP metrics, 8081/TCP health<br/>Image: trustyai-service-operator:latest"]
    end

    subgraph UserNS["USER / DATA SCIENCE NAMESPACE"]
        direction TB

        TrustyAISvc["TrustyAI Service<br/>SA: {tas-name}-proxy<br/>8443/TCP HTTPS<br/>OpenShift serving cert"]

        GORCHDeploy["Guardrails Orchestrator<br/>SA: {gorch-name}<br/>8432/TCP orchestrator<br/>8490/TCP gateway<br/>8480/TCP detector<br/>9443/TCP health"]

        NEMODeploy["NeMo Guardrails Server<br/>SA: {nemo-name}<br/>8443/TCP → 8000/TCP<br/>kube-rbac-proxy"]

        EvalHubDeploy["EvalHub API<br/>SA: {evalhub-name}<br/>8443/TCP HTTPS<br/>X-Tenant → namespace SAR"]

        LMEvalPod["LMEvalJob Pod (ephemeral)<br/>Init: ta-lmes-driver<br/>Main: lm-eval<br/>Driver: 18080/TCP HTTP<br/>(pod-internal only)"]
    end

    subgraph IstioLayer["ISTIO (Conditional)"]
        IstioMTLS["DestinationRule: mTLS STRICT<br/>VirtualService: traffic routing<br/>(created when Istio CRD detected)"]
    end

    subgraph PlatformSvc["INTERNAL PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        KServeISVC["KServe InferenceService<br/>HTTP/HTTPS<br/>TLS (auto-detected)"]
        ModelMesh["ModelMesh Serving<br/>HTTP/HTTPS<br/>mTLS (Istio)"]
        Prometheus["Prometheus<br/>(ServiceMonitor CRDs)"]
        Kueue["Kueue<br/>(Workload CRDs)"]
        MLFlow["MLFlow Tracking<br/>HTTPS<br/>Projected SA Token 3600s"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM credentials"]
        OCI["OCI Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Basic auth/dockerconfig"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>None/Token"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        PostgreSQL["PostgreSQL<br/>TCP TLS (optional)<br/>Username/password"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>Bearer Token"| TASRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| GORCHRoute
    Client -->|"HTTPS/443"| GORCHHealthRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| GORCHGatewayRoute
    Client -->|"HTTPS/443<br/>Bearer Token"| NEMORoute
    Client -->|"HTTPS/443<br/>Bearer Token + X-Tenant"| EvalHubRoute

    %% Ingress to Auth to Services
    TASRoute -->|"reencrypt"| AuthNote
    GORCHRoute -->|"reencrypt"| AuthNote
    NEMORoute -->|"reencrypt"| AuthNote
    EvalHubRoute -->|"reencrypt"| AuthNote

    AuthNote -->|"SAR passed"| TrustyAISvc
    AuthNote -->|"SAR passed"| GORCHDeploy
    AuthNote -->|"SAR passed"| NEMODeploy
    AuthNote -->|"SAR passed<br/>+ tenant NS"| EvalHubDeploy

    %% Operator to K8s API
    Operator -->|"HTTPS/6443<br/>SA Token<br/>CRD Watch/CRUD"| K8sAPI

    %% Service integrations
    TrustyAISvc -.->|"inference logging"| KServeISVC
    GORCHDeploy -->|"generation +<br/>detection requests"| KServeISVC
    Operator -->|"patch deployments<br/>MM_PAYLOAD_PROCESSORS"| ModelMesh
    Operator -->|"create ServiceMonitors"| Prometheus
    Operator -->|"Kueue Workloads"| Kueue
    EvalHubDeploy -->|"HTTPS<br/>SA Token 3600s"| MLFlow

    %% LMEvalJob egress
    LMEvalPod -->|"HTTPS/443<br/>AWS IAM"| S3
    LMEvalPod -->|"HTTPS/443<br/>Basic auth"| OCI
    LMEvalPod -->|"HTTPS/443<br/>None/Token"| HFHub
    LMEvalPod -->|"HTTPS/443"| Git

    %% Database connections
    TrustyAISvc -->|"TCP TLS<br/>user/pass"| PostgreSQL
    EvalHubDeploy -->|"TCP TLS<br/>user/pass"| PostgreSQL

    %% Istio integration
    TrustyAISvc -.->|"conditional"| IstioMTLS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef istio fill:#f0f0f0,stroke:#666,stroke-width:1px,stroke-dasharray: 5 5

    class Client external
    class TASRoute,GORCHRoute,GORCHHealthRoute,GORCHGatewayRoute,NEMORoute,EvalHubRoute ingress
    class AuthNote auth
    class Operator operator
    class TrustyAISvc,GORCHDeploy,NEMODeploy,EvalHubDeploy,LMEvalPod service
    class K8sAPI,KServeISVC,ModelMesh,Prometheus,Kueue,MLFlow platform
    class S3,OCI,HFHub,Git,PostgreSQL externalservice
    class IstioMTLS istio
