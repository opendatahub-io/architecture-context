graph TB
    subgraph "odh-cli (kubectl-odh / rhai-cli)"
        direction TB

        subgraph "CLI Layer (cobra)"
            LintCmd["lint<br/>38 upgrade readiness checks"]
            BackupCmd["backup<br/>Export workloads to YAML"]
            MigrateCmd["migrate<br/>list | prepare | run"]
            VersionCmd["version<br/>Build info"]
        end

        subgraph "Lint Framework"
            CheckRegistry["Check Registry<br/>38 registered checks"]
            CheckExecutor["Check Executor<br/>Parallel execution"]
            ValidateBuilders["Validate Builders<br/>Component / Workloads / Operator / DSC / DSCI"]
            ResultModel["DiagnosticResult<br/>CR-like output model"]
        end

        subgraph "Backup Pipeline"
            Discovery["Discovery<br/>List resources by GVR"]
            DependencyResolver["Dependency Resolver<br/>ConfigMaps / Secrets / PVCs"]
            Writer["Writer<br/>Strip metadata, output YAML"]
        end

        subgraph "Migration Framework"
            ActionRegistry["Action Registry"]
            RHBOKMigration["RHBOK Migration<br/>Kueue → standalone operator"]
        end

        subgraph "Client Layer"
            UnifiedClient["Unified K8s Client<br/>Reader + Writer interfaces"]
            DynamicClient["Dynamic Client"]
            DiscoveryClient["Discovery Client"]
            OLMClient["OLM Client"]
            MetadataClient["Metadata Client"]
        end

        LintCmd --> CheckRegistry
        CheckRegistry --> CheckExecutor
        CheckExecutor --> ValidateBuilders
        ValidateBuilders --> ResultModel
        CheckExecutor --> UnifiedClient

        BackupCmd --> Discovery
        Discovery --> DependencyResolver
        DependencyResolver --> Writer
        Discovery --> UnifiedClient

        MigrateCmd --> ActionRegistry
        ActionRegistry --> RHBOKMigration
        RHBOKMigration --> UnifiedClient

        UnifiedClient --> DynamicClient
        UnifiedClient --> DiscoveryClient
        UnifiedClient --> OLMClient
        UnifiedClient --> MetadataClient
    end

    subgraph "Container Image (ose-cli-rhel9)"
        CLI["kubectl-odh binary<br/>FIPS-compliant"]
        YQ["yq (FIPS-compliant)<br/>vendored build"]
        OC["oc + kubectl"]
        JQ["jq"]
        UpgradeHelpers["rhoai-upgrade-helpers<br/>Python/Shell scripts"]
    end

    K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]

    DynamicClient -->|"HTTPS/TLS 1.2+"| K8sAPI
    DiscoveryClient -->|"HTTPS/TLS 1.2+"| K8sAPI
    OLMClient -->|"HTTPS/TLS 1.2+"| K8sAPI
    MetadataClient -->|"HTTPS/TLS 1.2+"| K8sAPI

    User["User / CI Pipeline"] -->|"runs"| CLI
    User -->|"interactive shell"| UpgradeHelpers

    style LintCmd fill:#4a90e2,color:#fff
    style BackupCmd fill:#4a90e2,color:#fff
    style MigrateCmd fill:#4a90e2,color:#fff
    style VersionCmd fill:#4a90e2,color:#fff
    style UnifiedClient fill:#f5a623,color:#fff
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CLI fill:#7ed321,color:#fff
    style YQ fill:#7ed321,color:#fff
    style CheckRegistry fill:#d5e8d4,stroke:#82b366
    style RHBOKMigration fill:#d5e8d4,stroke:#82b366
    style User fill:#f9f9f9,stroke:#999
