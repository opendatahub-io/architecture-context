graph TB
    subgraph "odh-cli (kubectl-odh / rhai-cli)"
        direction TB

        subgraph "Command Layer"
            LintCmd[lint command<br/>Upgrade readiness assessment]
            BackupCmd[backup command<br/>Workload export to YAML]
            MigrateCmd[migrate command<br/>Version-specific migrations]
            VersionCmd[version command<br/>Build metadata]
        end

        subgraph "Lint Subsystem"
            CheckRegistry[CheckRegistry<br/>37 checks, glob selector]
            Executor[Executor<br/>Sequential check runner]

            subgraph "Check Categories"
                PlatformChecks[Platform Checks (2)<br/>DSC/DSCI readiness]
                ComponentChecks[Component Checks (13)<br/>KServe, Kueue, Dashboard,<br/>Ray, DSPA, etc.]
                DependencyChecks[Dependency Checks (3)<br/>cert-manager, OpenShift,<br/>ServiceMesh]
                WorkloadChecks[Workload Checks (19)<br/>Notebooks, ISVCs,<br/>RayClusters, PyTorchJobs]
            end

            CheckRegistry --> Executor
            Executor --> PlatformChecks
            Executor --> ComponentChecks
            Executor --> DependencyChecks
            Executor --> WorkloadChecks
        end

        subgraph "Backup Subsystem"
            Discovery[Discovery Stage<br/>List workloads]
            Resolver[Resolution Stage<br/>Chase dependencies]
            Writer[Writing Stage<br/>YAML output]
            Discovery --> Resolver --> Writer
        end

        subgraph "Migrate Subsystem"
            ActionRegistry[Action Registry]
            KueueMigration[Kueue → RHBOK<br/>Migration Action]
            ActionRegistry --> KueueMigration
        end

        subgraph "Shared Infrastructure"
            K8sClient[Kubernetes Client<br/>controller-runtime + client-go<br/>QPS=50, Burst=100]
            OutputFormatter[Output Formatter<br/>table / json / yaml]
        end

        LintCmd --> CheckRegistry
        BackupCmd --> Discovery
        MigrateCmd --> ActionRegistry

        PlatformChecks --> K8sClient
        ComponentChecks --> K8sClient
        DependencyChecks --> K8sClient
        WorkloadChecks --> K8sClient
        Discovery --> K8sClient
        KueueMigration --> K8sClient

        Executor --> OutputFormatter
        Writer --> OutputFormatter
    end

    subgraph "Container Image"
        direction LR
        CLI[kubectl-odh binary<br/>FIPS: strictfipsruntime]
        YQ[yq binary<br/>FIPS: strictfipsruntime]
        UpgradeHelpers[rhoai-upgrade-helpers<br/>Python scripts]
    end

    User[User / CI Pipeline] -->|kubeconfig| LintCmd
    User -->|kubeconfig| BackupCmd
    User -->|kubeconfig| MigrateCmd

    K8sClient -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| K8sAPI[Kubernetes API Server]

    K8sAPI -->|CRD Read| DSC[DataScienceCluster]
    K8sAPI -->|CRD Read| DSCI[DSCInitialization]
    K8sAPI -->|CRD Read| Notebooks[Notebooks]
    K8sAPI -->|CRD Read| ISVCs[InferenceServices]
    K8sAPI -->|CRD Read| Kueue[ClusterQueues / LocalQueues]
    K8sAPI -->|OLM Read| OLM[Subscriptions / CSVs]

    Writer -->|YAML files| LocalFS[Local Filesystem]

    style LintCmd fill:#4a90e2,color:#fff
    style BackupCmd fill:#4a90e2,color:#fff
    style MigrateCmd fill:#4a90e2,color:#fff
    style VersionCmd fill:#4a90e2,color:#fff
    style K8sClient fill:#7ed321,color:#fff
    style OutputFormatter fill:#7ed321,color:#fff
    style K8sAPI fill:#f5a623,color:#fff
    style User fill:#e8e8e8,stroke:#333
    style CLI fill:#4a90e2,color:#fff
    style YQ fill:#4a90e2,color:#fff
    style UpgradeHelpers fill:#9b59b6,color:#fff
