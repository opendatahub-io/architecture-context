graph LR
    GD["Guardrails Detectors<br/>(3 detector services)"]

    %% Internal Platform Dependencies
    GD -->|"callee: POST /api/v1/text/contents<br/>8080/TCP, 8000/TCP mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]
    GD -->|"CRD: InferenceService,<br/>ServingRuntime"| KServe["KServe"]
    GD -->|"sidecar injection<br/>mTLS enforcement"| Istio["Istio Service Mesh"]
    GD -->|"metrics scrape<br/>/metrics endpoint"| Prometheus["Prometheus"]
    Dashboard["RHOAI Dashboard"] -->|"UI integration<br/>opendatahub.io/dashboard"| GD

    %% External Service Dependencies
    GD -->|"S3 API / 9000/TCP<br/>model artifacts<br/>AWS credentials"| S3["S3/MinIO<br/>Model Storage"]
    GD -->|"OpenAI-compatible<br/>8080/TCP HTTP<br/>judge evaluation"| VLLM["vLLM Inference<br/>Server"]

    %% Python Framework Dependencies
    GD -->|"web framework"| FastAPI["FastAPI 0.121.2"]
    GD -->|"ASGI server"| Uvicorn["uvicorn 0.30.5"]
    GD -->|"metrics"| PromClient["prometheus_client"]
    GD -->|"ML inference"| Transformers["transformers 4.57.1"]
    GD -->|"deep learning"| PyTorch["torch 2.6.0+"]
    GD -->|"LLM judge"| VLLMJudge["vllm-judge 0.1.8"]

    %% Container Base
    GD -->|"base image"| UBI["UBI 9 Minimal<br/>FIPS-compliant OpenSSL"]

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI (green)
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style VLLM fill:#f5a623,stroke:#333,color:#fff

    %% Python libraries (gray)
    style FastAPI fill:#999,stroke:#333,color:#fff
    style Uvicorn fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff
    style Transformers fill:#999,stroke:#333,color:#fff
    style PyTorch fill:#999,stroke:#333,color:#fff
    style VLLMJudge fill:#999,stroke:#333,color:#fff

    %% Base image
    style UBI fill:#e74c3c,stroke:#333,color:#fff
