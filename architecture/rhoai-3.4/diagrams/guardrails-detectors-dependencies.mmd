graph LR
    GD["Guardrails<br/>Detectors"]

    %% Internal Platform Dependencies
    GD -->|"called by<br/>IBM Detector API"| Orch["FMS Guardrails<br/>Orchestrator"]
    GD -->|"deployed as<br/>InferenceService"| KServe["KServe"]
    GD -->|"mTLS sidecar<br/>injection"| Istio["Istio Service Mesh"]
    GD -->|"model download<br/>S3 protocol"| S3["S3/MinIO<br/>Model Storage"]

    %% External Service Dependencies
    GD -->|"LLM evaluation<br/>OpenAI-compat API"| vLLM["vLLM Inference<br/>Server"]
    GD -->|"model download<br/>init container"| HFHub["HuggingFace Hub"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrape /metrics"| GD

    %% Python Framework Dependencies
    subgraph PythonDeps["Python Dependencies (All Detectors)"]
        FastAPI["FastAPI 0.121.2"]
        Uvicorn["uvicorn 0.30.5"]
        PromClient["prometheus_client >=0.18.0"]
        PromFastAPI["prometheus-fastapi-<br/>instrumentator >=7.0.0"]
        PyYAML["PyYAML 6.0.2"]
    end

    subgraph HFDeps["Python Dependencies (HF Detector)"]
        Transformers["transformers 4.57.1"]
        PyTorch["torch (system)"]
        SentencePiece["sentencepiece 0.2.1"]
        TikToken["tiktoken 0.12.0"]
    end

    subgraph BuiltInDeps["Python Dependencies (Built-in Detector)"]
        JSONSchema["jsonschema 4.24.0"]
        XMLSchema["xmlschema 4.1.0"]
        Markdown["markdown 3.8.2"]
    end

    subgraph JudgeDeps["Python Dependencies (LLM Judge)"]
        VLLMJudge["vllm-judge 0.1.8"]
    end

    GD -.->|all detectors| PythonDeps
    GD -.->|HF detector| HFDeps
    GD -.->|built-in detector| BuiltInDeps
    GD -.->|LLM judge detector| JudgeDeps

    %% Styling
    style GD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orch fill:#9b59b6,stroke:#333,color:#fff
    style KServe fill:#7ed321,stroke:#333,color:#fff
    style Istio fill:#7ed321,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style vLLM fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style FastAPI fill:#e8e8e8,stroke:#333
    style Uvicorn fill:#e8e8e8,stroke:#333
    style PromClient fill:#e8e8e8,stroke:#333
    style PromFastAPI fill:#e8e8e8,stroke:#333
    style PyYAML fill:#e8e8e8,stroke:#333
    style Transformers fill:#e8e8e8,stroke:#333
    style PyTorch fill:#e8e8e8,stroke:#333
    style SentencePiece fill:#e8e8e8,stroke:#333
    style TikToken fill:#e8e8e8,stroke:#333
    style JSONSchema fill:#e8e8e8,stroke:#333
