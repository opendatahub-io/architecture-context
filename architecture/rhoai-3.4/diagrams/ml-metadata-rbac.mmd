graph TD
    subgraph MLMDServer["ML Metadata Server"]
        Container["metadata_store_server<br/>Container: odh-mlmd-grpc-server-rhel9<br/>User: 65534:65534 (non-root)"]
    end

    subgraph NoK8sRBAC["No Kubernetes RBAC"]
        direction TB
        Note1["No ClusterRoles defined"]
        Note2["No Roles defined"]
        Note3["No RoleBindings defined"]
        Note4["No Kubernetes API access required"]
    end

    subgraph ApplicationAuth["Application-Level Authentication"]
        direction TB
        gRPCAuth["gRPC mTLS Authentication<br/>(Optional)"]
        DBAuth["Database Authentication<br/>(Username/Password)"]
    end

    subgraph TLSConfig["TLS Configuration (SSLConfig)"]
        ServerCert["Server Certificate<br/>(server_key + server_cert)"]
        ClientVerify["Client Verification<br/>(client_verify flag)"]
        CustomCA["Custom CA<br/>(custom_ca)"]
    end

    subgraph Secrets["Secrets"]
        DBCreds["Database Credentials<br/>(Opaque)<br/>Provisioned by: DSP operator"]
        TLSCerts["SSL/TLS Certificates<br/>(kubernetes.io/tls)<br/>Provisioned by: Admin / cert-manager"]
        MySQLSSL["MySQL SSL Certificates<br/>(Opaque)<br/>Provisioned by: Admin"]
        PgSSL["PostgreSQL SSL Certificates<br/>(Opaque)<br/>Provisioned by: Admin"]
    end

    Container -->|"no K8s API calls"| NoK8sRBAC
    Container -->|"optional mTLS"| gRPCAuth
    Container -->|"connects to DB"| DBAuth

    gRPCAuth -->|"configured via"| TLSConfig
    ServerCert -->|"stored in"| TLSCerts
    ClientVerify -->|"validates against"| CustomCA

    DBAuth -->|"credentials from"| DBCreds
    DBAuth -->|"MySQL TLS from"| MySQLSSL
    DBAuth -->|"PostgreSQL TLS from"| PgSSL

    %% Styling
    style Container fill:#4a90e2,stroke:#333,color:#fff
    style Note1 fill:#e8e8e8,stroke:#999
    style Note2 fill:#e8e8e8,stroke:#999
    style Note3 fill:#e8e8e8,stroke:#999
    style Note4 fill:#e8e8e8,stroke:#999
    style gRPCAuth fill:#f5a623,stroke:#333
    style DBAuth fill:#f5a623,stroke:#333
    style ServerCert fill:#dae8fc,stroke:#6c8ebf
    style ClientVerify fill:#dae8fc,stroke:#6c8ebf
    style CustomCA fill:#dae8fc,stroke:#6c8ebf
    style DBCreds fill:#fff2cc,stroke:#d6b656
    style TLSCerts fill:#fff2cc,stroke:#d6b656
    style MySQLSSL fill:#fff2cc,stroke:#d6b656
    style PgSSL fill:#fff2cc,stroke:#d6b656
