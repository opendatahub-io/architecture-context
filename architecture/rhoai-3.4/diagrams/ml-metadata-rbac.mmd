graph TD
    subgraph "ML Metadata RBAC Model"
        direction TB
        Note["Note: MLMD defines NO Kubernetes RBAC.<br/>The server has no Kubernetes API access.<br/>All RBAC is managed by the DSP Operator."]
    end

    subgraph "Managed by DSP Operator"
        SA["ServiceAccount<br/>(created by DSP Operator)"]
        Pod["MLMD Pod<br/>UID: 65534 (non-root)<br/>No K8s API access"]
    end

    subgraph "Application-Level Auth"
        direction TB
        gRPCAuth["gRPC Authentication"]
        NoAuth["No Auth Mode<br/>(default)"]
        mTLSAuth["mTLS Mode<br/>(SSLConfig.client_verify=true)"]

        gRPCAuth -->|"SSLConfig provided"| mTLSAuth
        gRPCAuth -->|"No SSLConfig"| NoAuth
    end

    subgraph "Network-Level Access Control"
        direction TB
        NSBoundary["Namespace Boundary<br/>Primary isolation"]
        NetPol["NetworkPolicies<br/>(if configured)"]
        ClusterIP["ClusterIP Service<br/>No external exposure"]
    end

    subgraph "Clients (Authenticated via)"
        DSP["DSP Backend<br/>Auth: mTLS cert or none"]
        PipelineStep["Pipeline Steps<br/>Auth: mTLS cert or none"]
    end

    SA -->|"runs as"| Pod
    Pod -->|"serves"| gRPCAuth
    DSP -->|"gRPC/8080"| ClusterIP
    PipelineStep -->|"gRPC/8080"| ClusterIP
    ClusterIP -->|"routes to"| Pod

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style Pod fill:#dae8fc,stroke:#6c8ebf
    style gRPCAuth fill:#f5a623,stroke:#333
    style NoAuth fill:#e74c3c,stroke:#333,color:#fff
    style mTLSAuth fill:#7ed321,stroke:#333
    style NSBoundary fill:#d5e8d4,stroke:#82b366
    style NetPol fill:#d5e8d4,stroke:#82b366
    style ClusterIP fill:#fff2cc,stroke:#d6b656
    style DSP fill:#e8e8e8,stroke:#333
    style PipelineStep fill:#e8e8e8,stroke:#333
