%% Source: architecture/rhoai-3.4/ml-metadata.md
%% Note: MLMD does not define Kubernetes RBAC resources.
%% Access control is handled at the gRPC transport layer.
%% This diagram shows the application-level security model.

graph TD
    subgraph "gRPC Transport Security (Optional)"
        SSLConfig["SSLConfig<br/>(MetadataStoreServerConfig)"]
        ServerCert["server_cert + server_key<br/>(Server TLS Certificate)"]
        CustomCA["custom_ca<br/>(CA Certificate)"]
        ClientVerify["client_verify = true<br/>(Mutual TLS)"]
    end

    subgraph "gRPC Clients"
        DSP["Data Science Pipelines<br/>(ds-pipeline-*)<br/>Requires valid client cert if mTLS enabled"]
        KFPSDK["Kubeflow Pipelines SDK<br/>(Python Client)<br/>Requires valid client cert if mTLS enabled"]
    end

    subgraph "MetadataStoreService RPCs (40+ methods)"
        TypeMgmt["Type Management<br/>PutArtifactType, GetArtifactType,<br/>PutExecutionType, PutContextType, ..."]
        ArtifactMgmt["Artifact Management<br/>PutArtifacts, GetArtifacts,<br/>GetArtifactsByID, GetArtifactsByType, ..."]
        ExecMgmt["Execution Management<br/>PutExecutions, GetExecutions,<br/>GetExecutionsByID, PutExecution, ..."]
        CtxMgmt["Context Management<br/>PutContexts, GetContexts,<br/>GetContextsByArtifact, ..."]
        RelMgmt["Relationship Management<br/>PutEvents, PutAttributionsAndAssociations,<br/>PutParentContexts, ..."]
        LineageMgmt["Lineage<br/>PutLineageSubgraph,<br/>GetLineageSubgraph"]
    end

    subgraph "Database Auth"
        DBCreds["Database Credentials<br/>(Username/Password)<br/>Injected via config/flags"]
        DBSSL["Database SSL<br/>(MySQL SSLOptions / PostgreSQL sslmode)<br/>Optional TLS for DB connections"]
    end

    SSLConfig -->|"configures"| ServerCert
    SSLConfig -->|"configures"| CustomCA
    SSLConfig -->|"enables"| ClientVerify

    DSP -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional mTLS"| TypeMgmt
    DSP -->|"gRPC/HTTP2"| ArtifactMgmt
    DSP -->|"gRPC/HTTP2"| ExecMgmt
    DSP -->|"gRPC/HTTP2"| CtxMgmt
    DSP -->|"gRPC/HTTP2"| RelMgmt
    DSP -->|"gRPC/HTTP2"| LineageMgmt

    KFPSDK -->|"gRPC/HTTP2<br/>8080/TCP<br/>Optional mTLS"| TypeMgmt
    KFPSDK -->|"gRPC/HTTP2"| ArtifactMgmt

    ClientVerify -.->|"validates client cert"| DSP
    ClientVerify -.->|"validates client cert"| KFPSDK

    TypeMgmt -->|"DB access"| DBCreds
    ArtifactMgmt -->|"DB access"| DBCreds
    ExecMgmt -->|"DB access"| DBCreds
    CtxMgmt -->|"DB access"| DBCreds
    RelMgmt -->|"DB access"| DBCreds
    LineageMgmt -->|"DB access"| DBCreds
    DBCreds -->|"secured by"| DBSSL

