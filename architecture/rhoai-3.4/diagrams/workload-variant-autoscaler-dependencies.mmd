graph LR
    WVA["WVA Controller Manager<br/>(Workload Variant Autoscaler)"]

    %% External Dependencies (Required)
    WVA -->|"operator framework"| CR["controller-runtime<br/>v0.22.5"]
    WVA -->|"InferencePool CRD types"| GAIE["gateway-api-inference-extension<br/>v1.2.1"]
    WVA -->|"ServiceMonitor CRD"| PromOp["prometheus-operator<br/>v0.89.0"]
    WVA -->|"metrics client"| PromClient["prometheus client_golang<br/>v1.23.2"]
    WVA -->|"signal smoothing"| Kalman["kalman-filter<br/>v0.1.2"]
    WVA -->|"numerical computing"| Gonum["gonum<br/>v0.17.0"]
    WVA -->|"configuration"| Viper["viper<br/>v1.21.0"]

    %% External Dependencies (Optional)
    WVA -.->|"optional scale target"| LWS["LeaderWorkerSet<br/>v0.8.0"]

    %% Internal Platform Dependencies
    WVA -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"EPP scraping<br/>HTTPS"| EPP["EPP Pods<br/>(Endpoint Picker)"]

    %% Indirect Dependencies
    Prometheus -->|"scrapes metrics"| vLLM["vLLM Inference<br/>Servers"]

    %% Integration Points - Consumers of WVA metrics
    HPA["HPA<br/>(Horizontal Pod Autoscaler)"] -->|"reads wva_desired_replicas<br/>via Prometheus"| WVA
    KEDA["KEDA<br/>(Event Driven Autoscaling)"] -->|"reads wva_desired_replicas<br/>via Prometheus"| WVA
    PromAdapter["Prometheus Adapter"] -->|"bridges WVA metrics<br/>to custom metrics API"| WVA

    %% Integration Points - CRD interactions
    WVA -->|"watches InferencePool CRs"| InfPool["InferencePool<br/>(Gateway API)"]
    WVA -->|"watches/scales"| Deployments["Deployments<br/>(apps/v1)"]
    WVA -->|"watches"| StatefulSets["StatefulSets<br/>(apps/v1)"]
    WVA -->|"watches"| ServiceMonitor["ServiceMonitor<br/>(monitoring.coreos.com)"]
    WVA -->|"watches"| ConfigMaps["ConfigMaps<br/>(well-known names)"]
    WVA -->|"reads GPU labels"| Nodes["Nodes<br/>(nvidia/amd/gke)"]

    %% Kubernetes API
    WVA -->|"watch/update<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API"]

    %% Styling
    style WVA fill:#4a90e2,stroke:#2c5f8a,stroke-width:4px,color:#fff

    %% External library deps - grey
    style CR fill:#bdc3c7,stroke:#7f8c8d
    style GAIE fill:#bdc3c7,stroke:#7f8c8d
    style PromOp fill:#bdc3c7,stroke:#7f8c8d
    style PromClient fill:#bdc3c7,stroke:#7f8c8d
    style Kalman fill:#bdc3c7,stroke:#7f8c8d
    style Gonum fill:#bdc3c7,stroke:#7f8c8d
    style Viper fill:#bdc3c7,stroke:#7f8c8d
    style LWS fill:#bdc3c7,stroke:#7f8c8d

    %% Internal platform deps - green
    style Prometheus fill:#7ed321,stroke:#5ba318,color:#fff
    style EPP fill:#7ed321,stroke:#5ba318,color:#fff
    style vLLM fill:#7ed321,stroke:#5ba318,color:#fff
    style InfPool fill:#7ed321,stroke:#5ba318,color:#fff

    %% Consumers - orange
    style HPA fill:#f5a623,stroke:#d4891c,color:#fff
    style KEDA fill:#f5a623,stroke:#d4891c,color:#fff
    style PromAdapter fill:#f5a623,stroke:#d4891c,color:#fff

    %% Kubernetes resources - purple
    style Deployments fill:#e1d5e7,stroke:#9673a6
    style StatefulSets fill:#e1d5e7,stroke:#9673a6
    style ServiceMonitor fill:#e1d5e7,stroke:#9673a6
    style ConfigMaps fill:#e1d5e7,stroke:#9673a6
    style Nodes fill:#e1d5e7,stroke:#9673a6
    style K8sAPI fill:#e1d5e7,stroke:#9673a6
