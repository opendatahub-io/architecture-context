graph LR
    WVA["WVA Controller<br/>(Workload Variant Autoscaler)"]

    %% External Dependencies (Required)
    WVA -->|"PromQL queries<br/>9091/TCP HTTPS"| Prometheus["Prometheus /<br/>Thanos Querier"]
    WVA -->|"indirect via Prometheus"| vLLM["vLLM Inference<br/>Servers"]
    WVA -->|"metrics consumed by"| HPA["HPA / KEDA"]
    WVA -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.22.5"]
    WVA -->|"state estimation"| Kalman["kalman-filter<br/>v0.1.2"]

    %% External Dependencies (Optional)
    WVA -.->|"queue metrics scraping<br/>HTTPS"| EPP["Gateway API<br/>Inference Extension<br/>(EPP) v1/v1alpha2"]
    WVA -.->|"scale target type"| LWS["LeaderWorkerSet<br/>(LWS) v0.8.0"]
    WVA -.->|"ServiceMonitor CRD"| PromOperator["Prometheus<br/>Operator"]
    WVA -->|"InferencePool types"| GAIE["gateway-api-inference-<br/>extension v1.2.1"]

    %% Kubernetes API Resources
    WVA -->|"CRUD operations<br/>443/TCP HTTPS"| K8sAPI["Kubernetes<br/>API Server"]
    K8sAPI -->|"scale subresource"| Deployments["Deployments /<br/>StatefulSets"]
    K8sAPI -->|"scale subresource"| LWSRes["LeaderWorkerSets"]

    %% ConfigMap Dependencies
    ConfigMaps["ConfigMaps<br/>(saturation-scaling,<br/>scale-to-zero,<br/>queueing-model)"] -->|"watched by"| WVA
    InferencePool["InferencePool CRs<br/>(v1 / v1alpha2)"] -->|"watched by"| WVA

    %% Downstream Consumers
    HPA -->|"scales workloads"| K8sAPI

    %% Styling
    style WVA fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style HPA fill:#999,stroke:#333,color:#fff
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style Kalman fill:#999,stroke:#333,color:#fff
    style EPP fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style LWS fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#fff
    style GAIE fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Deployments fill:#7ed321,stroke:#333,color:#fff
    style LWSRes fill:#7ed321,stroke:#333,color:#fff
    style ConfigMaps fill:#f5a623,stroke:#333,color:#fff
    style InferencePool fill:#f5a623,stroke:#333,color:#fff
