graph TB
    subgraph UserEnv["USER ENVIRONMENT (Untrusted)"]
        User["User / CI Pipeline<br/>kubeconfig credentials"]
    end

    subgraph CLIProcess["CLI PROCESS (No Network Listener)"]
        CLI["kubectl-odh (rhai-cli)<br/>FIPS-compliant binary<br/>CGO_ENABLED=1, strictfipsruntime<br/>No inbound ports"]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        direction TB

        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>AuthN: Bearer / Cert / OIDC<br/>AuthZ: RBAC"]

        subgraph ReadAPIs["Read-Only API Access (lint + backup)"]
            direction LR
            PlatformAPIs["Platform APIs<br/>DSC, DSCI, CRDs<br/>ClusterVersion"]
            OLMAPIs["OLM APIs<br/>Subscriptions, CSVs<br/>PackageManifests"]
            WorkloadAPIs["Workload APIs<br/>Notebooks, InferenceServices<br/>RayClusters, PyTorchJobs<br/>Kueue, Guardrails, DSPAs"]
            CoreAPIs["Core APIs<br/>ConfigMaps, Secrets<br/>Deployments, Namespaces<br/>ImageStreams"]
        end

        subgraph WriteAPIs["Write API Access (migration only)"]
            MigrationWrite["Kueue Migration<br/>Subscriptions: CREATE<br/>DSC: UPDATE<br/>ConfigMaps: UPDATE"]
        end

        APIServer --- ReadAPIs
        APIServer --- WriteAPIs
    end

    subgraph LocalFS["LOCAL FILESYSTEM"]
        BackupOutput["Backup Output<br/>Portable YAML files<br/>Metadata stripped<br/>May contain Secrets"]
    end

    %% Flows
    User -->|"Runs CLI binary<br/>or container"| CLI
    CLI -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token / Client Cert<br/>EGRESS ONLY"| APIServer
    CLI -->|"Backup command<br/>writes YAML files"| BackupOutput

    %% Styling
    classDef untrusted fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cli fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef readapi fill:#e8f5e9,stroke:#4caf50,stroke-width:1px
    classDef writeapi fill:#fff3e0,stroke:#ff9800,stroke-width:1px
    classDef filesystem fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User untrusted
    class CLI cli
    class APIServer trusted
    class PlatformAPIs,OLMAPIs,WorkloadAPIs,CoreAPIs readapi
    class MigrationWrite writeapi
    class BackupOutput filesystem
