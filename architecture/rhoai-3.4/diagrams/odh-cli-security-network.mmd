graph TB
    subgraph Client["CLIENT (User Terminal / CI Pipeline)"]
        CLI["odh-cli (kubectl-odh)<br/>Go Binary, FIPS: strictfipsruntime<br/>Image: quay.io/rhoai/rhoai-upgrade-helpers-rhel9<br/>No listening ports"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE (Trusted)"]
        direction TB

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC AuthZ"]

        subgraph ReadResources["Resources Accessed (READ - lint/backup)"]
            direction LR
            PlatformCRDs["Platform CRDs<br/>DataScienceCluster<br/>DSCInitialization"]
            WorkloadCRDs["Workload CRDs<br/>Notebooks, ISVCs,<br/>RayClusters, PyTorchJobs,<br/>ClusterQueues, DSPA,<br/>GuardrailsOrchestrator"]
            OLMResources["OLM Resources<br/>Subscriptions, CSVs,<br/>PackageManifests"]
            OSResources["OpenShift Resources<br/>ClusterVersion,<br/>ImageStreams"]
            CoreResources["Core K8s Resources<br/>ConfigMaps, Secrets,<br/>Namespaces, Deployments,<br/>PVCs, Pods"]
        end

        subgraph WriteResources["Resources Accessed (WRITE - migrate only)"]
            MigrateTargets["Subscriptions (CREATE)<br/>DataScienceCluster (PATCH)"]
        end

        K8sAPI --- ReadResources
        K8sAPI --- WriteResources
    end

    subgraph LocalOutput["LOCAL FILESYSTEM (Backup Output)"]
        BackupFiles["Sanitized YAML Files<br/>Workloads + Dependencies<br/>No encryption (local)"]
    end

    %% Flows
    CLI -->|"HTTPS/6443<br/>TLS 1.2+ (FIPS)<br/>Bearer Token OR<br/>X.509 Client Cert<br/>QPS=50, Burst=100"| K8sAPI

    CLI -.->|"backup command<br/>Local write<br/>No network"| BackupFiles

    %% Styling
    classDef client fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef resources fill:#e8f5e9,stroke:#a5d6a7,stroke-width:1px,color:#333
    classDef writeresources fill:#fff3e0,stroke:#ffb74d,stroke-width:1px,color:#333
    classDef local fill:#f5f5f5,stroke:#bdbdbd,stroke-width:2px,color:#333

    class CLI client
    class K8sAPI controlplane
    class PlatformCRDs,WorkloadCRDs,OLMResources,OSResources,CoreResources resources
    class MigrateTargets writeresources
    class BackupFiles local
