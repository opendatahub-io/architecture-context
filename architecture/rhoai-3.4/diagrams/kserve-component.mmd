graph TB
    subgraph KServe["KServe Platform"]
        direction TB

        subgraph Controllers["Controller Managers"]
            KServeCtrl["kserve-controller-manager<br/><i>Go Operator</i><br/>8443/TCP metrics, 9443/TCP webhook"]
            LLMIsvcCtrl["llmisvc-controller-manager<br/><i>Go Operator</i><br/>8443/TCP metrics, 9443/TCP webhook"]
        end

        subgraph Sidecars["Injected Components"]
            StorageInit["storage-initializer<br/><i>Python Init Container</i><br/>S3/GCS/Azure/HF/OCI"]
            Agent["inference-agent<br/><i>Go Sidecar</i><br/>9081/TCP"]
        end

        subgraph Routing["Routing"]
            Router["inference-router<br/><i>Go Service</i><br/>8080/TCP"]
        end

        subgraph LocalModel["Local Model Cache"]
            LMController["localmodel-controller<br/><i>Go Controller</i>"]
            LMNodeAgent["localmodelnode-agent<br/><i>Go DaemonSet Agent</i>"]
        end

        SDK["kserve Python SDK<br/><i>Python Library</i><br/>REST/gRPC model server framework"]
    end

    %% CRDs
    subgraph CRDs["Custom Resource Definitions"]
        ISVC["InferenceService<br/><i>v1beta1</i>"]
        LLMISVC["LLMInferenceService<br/><i>v1alpha2</i>"]
        IG["InferenceGraph<br/><i>v1alpha1</i>"]
        TM["TrainedModel<br/><i>v1alpha1</i>"]
        SR["ServingRuntime<br/><i>v1alpha1</i>"]
        LMC["LocalModelCache<br/><i>v1alpha1</i>"]
    end

    %% Controller watches
    ISVC -->|watched by| KServeCtrl
    IG -->|watched by| KServeCtrl
    TM -->|watched by| KServeCtrl
    SR -->|watched by| KServeCtrl
    LMC -->|watched by| LMController
    LLMISVC -->|watched by| LLMIsvcCtrl

    %% Controller creates
    KServeCtrl -->|creates| KnativeSvc["Knative Service"]
    KServeCtrl -->|creates| VS["VirtualService"]
    KServeCtrl -->|creates| Deployment["Predictor Deployment"]
    KServeCtrl -->|creates| ScaledObj["ScaledObject (KEDA)"]
    KServeCtrl -->|creates| OTelCollector["OTel Collector"]

    LLMIsvcCtrl -->|creates| HTTPRoute["HTTPRoute"]
    LLMIsvcCtrl -->|creates| LWS["LeaderWorkerSet"]
    LLMIsvcCtrl -->|creates| InfPool["InferencePool"]
    LLMIsvcCtrl -->|creates| VarAutoScale["VariantAutoscaling (WVA)"]
    LLMIsvcCtrl -->|creates| DestRule["DestinationRule (OCP)"]

    %% Webhook injection
    KServeCtrl -->|webhook injects| StorageInit
    KServeCtrl -->|webhook injects| Agent

    %% Router orchestrates
    Router -->|routes to| ISVC

    %% Local model flow
    LMController -->|schedules| LMNodeAgent
    LMNodeAgent -->|downloads to| LocalDisk["Node Local Storage"]

    %% External dependencies
    KServeCtrl -->|depends on| K8sAPI["Kubernetes API<br/>6443/TCP"]
    LLMIsvcCtrl -->|depends on| K8sAPI
    StorageInit -->|downloads from| CloudStorage["Cloud Storage<br/>S3/GCS/Azure/HF<br/>443/TCP"]

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMIsvcCtrl fill:#4a90e2,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style Router fill:#9b59b6,stroke:#333,color:#fff
    style LMController fill:#4a90e2,stroke:#333,color:#fff
    style LMNodeAgent fill:#4a90e2,stroke:#333,color:#fff
    style SDK fill:#f39c12,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333
    style LLMISVC fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333
    style TM fill:#f5a623,stroke:#333
    style SR fill:#f5a623,stroke:#333
    style LMC fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CloudStorage fill:#e8e8e8,stroke:#333
