graph TB
    subgraph KServeComponent["KServe Component (opendatahub namespace)"]
        direction TB

        subgraph Controllers["Controllers"]
            KServeCtrl["kserve-controller-manager<br/>Go Operator (controller-runtime)<br/>Webhook: 8443/TCP | Metrics: 8080/TCP"]
            LLMISVCCtrl["llmisvc-controller-manager<br/>Go Operator (controller-runtime)<br/>Webhook: 9443/TCP | Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        end

        subgraph Sidecars["Injected Sidecars / Init Containers"]
            Agent["kserve-agent<br/>Go Sidecar<br/>Proxy: 9081/TCP | Log: 9083/TCP"]
            StorageInit["kserve-storage-initializer<br/>Python 3.11 Init Container<br/>S3/GCS/Azure/HF/OCI/PVC/HDFS"]
        end

        Router["kserve-router<br/>Go Service<br/>8080/TCP<br/>InferenceGraph DAG Routing"]
    end

    %% CRDs watched by kserve-controller-manager
    ISVC["InferenceService CR<br/>(v1beta1)"]
    IG["InferenceGraph CR<br/>(v1alpha1)"]
    TM["TrainedModel CR<br/>(v1alpha1)"]
    LM["LocalModelCache CR<br/>(v1alpha1)"]
    SR["ServingRuntime CR<br/>(v1alpha1)"]

    %% CRDs watched by llmisvc-controller-manager
    LLMISVC["LLMInferenceService CR<br/>(v1alpha2)"]
    LLMISVCConfig["LLMInferenceServiceConfig CR<br/>(v1alpha2)"]

    %% Users
    User["Data Scientist / ML Engineer"]

    %% CRD relationships
    User -->|"creates"| ISVC
    User -->|"creates"| LLMISVC
    User -->|"creates"| IG

    ISVC -->|"watched by"| KServeCtrl
    IG -->|"watched by"| KServeCtrl
    TM -->|"watched by"| KServeCtrl
    LM -->|"watched by"| KServeCtrl
    SR -->|"queried by"| KServeCtrl

    LLMISVC -->|"watched by"| LLMISVCCtrl
    LLMISVCConfig -->|"queried by"| LLMISVCCtrl

    %% Resources created by kserve-controller-manager
    KServeCtrl -->|"creates"| Deployment["Deployment<br/>(predictor/transformer/explainer)"]
    KServeCtrl -->|"creates"| KnativeSvc["Knative Service<br/>(serverless mode)"]
    KServeCtrl -->|"creates"| VS["VirtualService<br/>(Istio mode)"]
    KServeCtrl -->|"creates"| HTTPRoute1["HTTPRoute<br/>(Gateway API mode)"]
    KServeCtrl -->|"creates"| HPA1["HPA / KEDA ScaledObject"]
    KServeCtrl -->|"creates"| OTELCol["OpenTelemetry Collector"]

    %% Resources created by llmisvc-controller-manager
    LLMISVCCtrl -->|"creates"| LWS["LeaderWorkerSet<br/>(multi-node)"]
    LLMISVCCtrl -->|"creates"| HTTPRoute2["HTTPRoute<br/>(Gateway API)"]
    LLMISVCCtrl -->|"creates"| InfPool["InferencePool<br/>(scheduler LB)"]
    LLMISVCCtrl -->|"creates"| WVA["VariantAutoscaling<br/>(WVA)"]
    LLMISVCCtrl -->|"creates"| PodMon["PodMonitor /<br/>ServiceMonitor"]
    LLMISVCCtrl -->|"creates"| DestRule["DestinationRule<br/>(OCP Istio TLS)"]

    %% Sidecar injection
    KServeCtrl -->|"annotates pods for"| Agent
    KServeCtrl -->|"annotates pods for"| StorageInit

    %% Router relationship
    IG -->|"deployed as"| Router
    Router -->|"calls"| ISVC

    %% Styling
    style KServeCtrl fill:#4a90e2,stroke:#333,color:#fff
    style LLMISVCCtrl fill:#4a90e2,stroke:#333,color:#fff
    style Agent fill:#50c878,stroke:#333,color:#fff
    style StorageInit fill:#50c878,stroke:#333,color:#fff
    style Router fill:#50c878,stroke:#333,color:#fff
    style ISVC fill:#f5a623,stroke:#333,color:#fff
    style LLMISVC fill:#f5a623,stroke:#333,color:#fff
    style LLMISVCConfig fill:#f5a623,stroke:#333
    style IG fill:#f5a623,stroke:#333,color:#fff
    style TM fill:#f5a623,stroke:#333,color:#fff
    style LM fill:#f5a623,stroke:#333,color:#fff
    style SR fill:#f5a623,stroke:#333,color:#fff
    style User fill:#e8e8e8,stroke:#333
    style Deployment fill:#d5e8d4,stroke:#82b366
    style KnativeSvc fill:#d5e8d4,stroke:#82b366
    style VS fill:#d5e8d4,stroke:#82b366
    style HTTPRoute1 fill:#d5e8d4,stroke:#82b366
    style HTTPRoute2 fill:#d5e8d4,stroke:#82b366
    style HPA1 fill:#d5e8d4,stroke:#82b366
    style OTELCol fill:#d5e8d4,stroke:#82b366
    style LWS fill:#d5e8d4,stroke:#82b366
    style InfPool fill:#d5e8d4,stroke:#82b366
    style WVA fill:#d5e8d4,stroke:#82b366
    style PodMon fill:#d5e8d4,stroke:#82b366
    style DestRule fill:#d5e8d4,stroke:#82b366
