graph LR
    MLflowOp["MLflow Operator<br/>(Go, controller-runtime)"]

    %% External Dependencies (required)
    MLflowOp -->|"operator framework"| ControllerRuntime["controller-runtime<br/>v0.22.4"]
    MLflowOp -->|"chart rendering"| Helm["helm.sh/helm/v3<br/>v3.19.2"]
    MLflowOp -->|"config mgmt"| Viper["spf13/viper<br/>v1.21.0"]

    %% External Dependencies (conditional)
    MLflowOp -.->|"HTTPRoute CRD<br/>(if available)"| GatewayAPI["gateway-api<br/>v1.4.1"]
    MLflowOp -.->|"ConsoleLink CRD<br/>(if available)"| OpenshiftAPI["openshift/api<br/>(OpenShift only)"]
    MLflowOp -.->|"ServiceMonitor CRD<br/>(if available)"| PromOperator["prometheus-operator<br/>v0.89.0"]

    %% Internal Platform Dependencies
    MLflowOp -->|"HTTPRoute parentRef<br/>external ingress"| DSGateway["data-science-gateway<br/>(Gateway CR)"]
    MLflowOp -->|"CRD deployment<br/>lifecycle mgmt"| RHOAIOp["rhods-operator /<br/>opendatahub-operator"]
    MLflowOp -->|"CA certificates<br/>volume mount"| TrustedCA["odh-trusted-ca-bundle<br/>ConfigMap"]
    MLflowOp -->|"TLS cert provisioning<br/>annotation-triggered"| ServiceCA["openshift-service-ca"]
    MLflowOp -->|"metrics scraping<br/>ServiceMonitor"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% Runtime Dependencies (MLflow Server)
    MLflowSrv["MLflow Server<br/>(deployed)"]
    MLflowOp -->|deploys| MLflowSrv

    MLflowSrv -->|"metadata store<br/>5432/TCP TLS"| PostgreSQL["PostgreSQL"]
    MLflowSrv -->|"metadata store<br/>3306/TCP TLS"| MySQL["MySQL<br/>(alternative)"]
    MLflowSrv -->|"artifact storage<br/>9000/TCP HTTPS"| S3["S3-compatible Storage<br/>(MinIO / SeaweedFS)"]
    MLflowSrv -->|"authz checks<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]

    %% Integration Points (consumers of MLflow)
    DSGateway -->|"routes traffic"| MLflowSrv
    RHOAIOp -->|"creates MLflow CR"| MLflowOp
    Console["OpenShift Console"] -.->|"ConsoleLink<br/>menu entry"| MLflowOp

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MLflowSrv fill:#7ed321,stroke:#333,stroke-width:3px,color:#fff

    %% Required external deps
    style ControllerRuntime fill:#e8e8e8,stroke:#333
    style Helm fill:#e8e8e8,stroke:#333
    style Viper fill:#e8e8e8,stroke:#333

    %% Conditional external deps
    style GatewayAPI fill:#e8e8e8,stroke:#999,stroke-dasharray:5 5
    style OpenshiftAPI fill:#e8e8e8,stroke:#999,stroke-dasharray:5 5
    style PromOperator fill:#e8e8e8,stroke:#999,stroke-dasharray:5 5

    %% Internal platform deps
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style RHOAIOp fill:#7ed321,stroke:#333,color:#fff
    style TrustedCA fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style Console fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
