graph LR
    MLflowOp["MLflow Operator<br/>(mlflow-operator)"]

    %% External Library Dependencies
    subgraph ExtLibs["External Libraries (Go)"]
        ControllerRuntime["controller-runtime<br/>v0.22.4"]
        HelmV3["helm.sh/helm/v3<br/>v3.19.2"]
        Viper["spf13/viper<br/>v1.21.0"]
    end

    MLflowOp -->|"controller framework"| ControllerRuntime
    MLflowOp -->|"Helm chart rendering"| HelmV3
    MLflowOp -->|"env var config"| Viper

    %% Conditional External Dependencies (CRD integrations)
    subgraph ConditionalDeps["Conditional CRD Dependencies"]
        GatewayAPI["Gateway API<br/>v1.4.1"]
        OpenShiftAPI["openshift/api<br/>ConsoleLink CRD"]
        PromOperator["prometheus-operator<br/>v0.89.0<br/>ServiceMonitor CRD"]
    end

    MLflowOp -.->|"HTTPRoute CRD<br/>(conditional)"| GatewayAPI
    MLflowOp -.->|"ConsoleLink CRD<br/>(conditional)"| OpenShiftAPI
    MLflowOp -.->|"ServiceMonitor CRD<br/>(conditional)"| PromOperator

    %% Internal RHOAI Platform Dependencies
    subgraph InternalDeps["Internal RHOAI Platform"]
        DSGateway["data-science-gateway<br/>(Gateway API)"]
        ServiceCA["OpenShift service-CA"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
        OSConsole["OpenShift Console"]
        Prometheus["Prometheus"]
    end

    MLflowOp -->|"HTTPRoute parent ref<br/>ingress entry point"| DSGateway
    MLflowOp -->|"TLS cert provisioning<br/>(annotation-based)"| ServiceCA
    MLflowOp -->|"CA certificates<br/>(volume mount, watch)"| CABundle
    MLflowOp -->|"ConsoleLink<br/>(app menu entry)"| OSConsole
    Prometheus -->|"ServiceMonitor scrape<br/>HTTPS/8443"| MLflowOp

    %% External Runtime Services
    subgraph ExtServices["External Services"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        MySQL["MySQL<br/>3306/TCP"]
        S3["S3-compatible Storage<br/>(MinIO/SeaweedFS/AWS S3)<br/>443/9000/8333 TCP"]
    end

    MLflowOp -->|"CRD watches, SSA apply<br/>SelfSubjectAccessReview"| K8sAPI
    MLflowOp -->|"backend metadata store<br/>TLS verify-full"| PostgreSQL
    MLflowOp -.->|"alternative backend<br/>TLS"| MySQL
    MLflowOp -->|"artifact storage<br/>HTTPS, AWS creds"| S3

    %% Styling
    style MLflowOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style HelmV3 fill:#999,stroke:#333,color:#fff
    style Viper fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style OpenShiftAPI fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style PromOperator fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style DSGateway fill:#7ed321,stroke:#333,color:#fff
    style ServiceCA fill:#7ed321,stroke:#333,color:#fff
    style CABundle fill:#7ed321,stroke:#333,color:#fff
    style OSConsole fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style MySQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
