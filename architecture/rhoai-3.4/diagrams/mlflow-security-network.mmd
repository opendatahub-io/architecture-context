graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        SDKClient["ML SDK Client<br/>(Notebook / Pipeline)"]
        BrowserUser["Browser<br/>(RHOAI Dashboard)"]
    end

    subgraph Ingress["INGRESS (Platform Gateway)"]
        Gateway["RHOAI Data Science Gateway<br/>(Envoy)<br/>HTTPRoute: /mlflow<br/>443/TCP → 5000/TCP<br/>TLS 1.2+ (SIMPLE)"]
    end

    subgraph Application["APPLICATION (MLflow Server Pod)"]
        direction TB

        KubeRBACProxy["kube-rbac-proxy<br/>(sidecar, operator-managed)<br/>TLS termination"]

        subgraph ServerInternal["MLflow Tracking Server<br/>SA: mlflow-server<br/>Image: UBI9 ubi-minimal:9.7"]
            SecurityMW["Security Middleware<br/>Host validation, CORS,<br/>CSP, Content-Type"]
            KubeAuthPlugin["kubernetes-auth Plugin<br/>SelfSubjectAccessReview<br/>Token cache: 60s TTL"]
            FastAPI["FastAPI + Flask<br/>(ASGI/WSGI)"]
            EncryptionEngine["Envelope Encryption<br/>AES-256-GCM<br/>PBKDF2-HMAC-SHA256<br/>600k iterations"]
        end

        KubeRBACProxy --> SecurityMW
        SecurityMW --> FastAPI
        FastAPI --> KubeAuthPlugin
        FastAPI --> EncryptionEngine
    end

    subgraph EgressK8s["EGRESS - Kubernetes"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Bearer Token"]
    end

    subgraph EgressDB["EGRESS - Database"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS (configurable)<br/>DB credentials"]
    end

    subgraph EgressStorage["EGRESS - Object Storage (Optional)"]
        ObjectStore["S3 / GCS / Azure Blob<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>IAM / SA / Azure creds"]
    end

    %% External → Ingress
    SDKClient -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)<br/>X-MLFLOW-WORKSPACE"| Gateway
    BrowserUser -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth session"| Gateway

    %% Ingress → Application
    Gateway -->|"HTTP/5000<br/>Plaintext (cluster-internal)<br/>Token passthrough"| KubeRBACProxy

    %% Application → Egress
    KubeAuthPlugin -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token<br/>SelfSubjectAccessReview<br/>Namespace list/watch<br/>MLflowConfig read"| K8sAPI
    FastAPI -->|"PostgreSQL/5432<br/>TLS (configurable)<br/>DB credentials<br/>Tracking, Registry, Auth"| PostgreSQL
    FastAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>Cloud credentials<br/>Artifact read/write"| ObjectStore

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#e1bee7,stroke:#8e24aa,stroke-width:2px
    classDef crypto fill:#ffcdd2,stroke:#c62828,stroke-width:2px

    class SDKClient,BrowserUser external
    class Gateway ingress
    class KubeRBACProxy,SecurityMW,KubeAuthPlugin security
    class FastAPI application
    class EncryptionEngine crypto
    class K8sAPI,PostgreSQL,ObjectStore egress
