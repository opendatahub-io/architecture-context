graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["MLflow Client<br/>(Python SDK)"]
        Browser["Browser<br/>(Web UI)"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Gateway["Platform Gateway (Envoy)<br/>443/TCP<br/>TLS 1.2+<br/>HTTPRoute"]
        KRP["kube-rbac-proxy (Sidecar)<br/>8443/TCP → 5000/TCP<br/>TLS 1.2+<br/>SubjectAccessReview"]
    end

    subgraph Application["APPLICATION (MLflow Server Pod)"]
        direction TB

        subgraph AuthZone["Auth Layer"]
            AuthMW["Auth Middleware<br/>Flask: before_request<br/>FastAPI: ASGI middleware<br/>Permissions: READ/USE/EDIT/MANAGE"]
            K8sAuth["K8s Auth Provider<br/>SA Token Validation<br/>60s TTL Cache"]
            WorkspaceAuth["Workspace Resolver<br/>Namespace → Workspace<br/>10k-entry Permission Cache"]
        end

        subgraph AppZone["Application"]
            MLflowServer["MLflow Tracking Server<br/>5000/TCP HTTP (plaintext)<br/>Service: mlflow-server (ClusterIP)<br/>Image: odh-mlflow-rhel9"]
            CryptoMod["Crypto Module<br/>AES-256-GCM (DEK)<br/>PBKDF2-HMAC-SHA256 (KEK)<br/>600k iterations"]
        end
    end

    subgraph BackendStore["BACKEND STORE"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PostgreSQL wire protocol<br/>TLS (configurable)<br/>Auth: Username/password"]
    end

    subgraph ArtifactStorage["ARTIFACT STORAGE"]
        S3["S3-Compatible Storage<br/>(MinIO/Ceph)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM / Access Key"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Connection string"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ADC"]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer Token (SA)"]
    end

    subgraph Observability["OBSERVABILITY"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS (configurable)"]
        Prometheus["Prometheus<br/>5000/TCP HTTP scrape<br/>No encryption (cluster-internal)"]
    end

    %% Inbound Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| Gateway
    Browser -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s SA)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KRP
    KRP -->|"HTTP/5000<br/>Plaintext (localhost)<br/>Proxied Token"| MLflowServer

    %% Internal Auth
    MLflowServer --> AuthMW
    AuthMW --> K8sAuth
    AuthMW --> WorkspaceAuth
    MLflowServer --> CryptoMod

    %% Egress Flows
    MLflowServer -->|"PostgreSQL/5432<br/>TLS (configurable)<br/>Username/password"| PostgreSQL
    MLflowServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    MLflowServer -.->|"HTTPS/443<br/>TLS 1.2+<br/>Connection string"| Azure
    MLflowServer -.->|"HTTPS/443<br/>TLS 1.2+<br/>ADC"| GCS
    K8sAuth -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    MLflowServer -.->|"OTLP/4317<br/>TLS (configurable)"| OTel
    Prometheus -.->|"HTTP/5000<br/>scrape"| MLflowServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef auth fill:#fff3cd,stroke:#d79b00,stroke-width:2px
    classDef backend fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef observability fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client,Browser external
    class Gateway,KRP ingress
    class MLflowServer,CryptoMod application
    class AuthMW,K8sAuth,WorkspaceAuth auth
    class PostgreSQL backend
    class S3,Azure,GCS storage
    class K8sAPI controlplane
    class OTel,Prometheus observability
