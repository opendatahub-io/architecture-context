graph TD
    subgraph Notice["caikit-nlp RBAC"]
        direction TB
        Info["caikit-nlp is a Library / Runtime Module<br/>NOT a Kubernetes Operator<br/><br/>No ClusterRoles, Roles, or RoleBindings<br/>are defined by this component"]
    end

    subgraph PlatformRBAC["Platform-Managed RBAC<br/>(defined by KServe / ModelMesh, not caikit-nlp)"]
        direction TB
        SA["Pod ServiceAccount<br/>(defined by ServingRuntime)"]
        PodSecurity["Pod Security Context<br/>(defined by platform)"]
    end

    subgraph TLSAuth["Authentication & Authorization<br/>(Application-Level, Configurable)"]
        direction TB

        subgraph GRPCAuth["gRPC Server (8085/TCP)"]
            GRPCTLS["TLS Encryption<br/>RUNTIME_TLS_SERVER_KEY<br/>RUNTIME_TLS_SERVER_CERT"]
            GRPCClient["Client TLS<br/>RUNTIME_TLS_CLIENT_CERT"]
        end

        subgraph HTTPAuth["HTTP Server (8080/TCP)"]
            HTTPTLS["TLS Encryption<br/>Configurable via runtime"]
        end

        subgraph TGISAuth["TGIS Backend (gRPC Egress)"]
            TGISCA["CA Verification<br/>ca_cert_file"]
            TGISmTLS["mTLS Authentication<br/>client_cert_file<br/>client_key_file"]
        end
    end

    subgraph Secrets["Secrets / Certificates"]
        direction TB
        ServerKey["RUNTIME_TLS_SERVER_KEY<br/>TLS key file<br/>Provisioned: Manual / cert-manager<br/>Auto-Rotate: No"]
        ServerCert["RUNTIME_TLS_SERVER_CERT<br/>TLS cert file<br/>Provisioned: Manual / cert-manager<br/>Auto-Rotate: No"]
        ClientCert["RUNTIME_TLS_CLIENT_CERT<br/>TLS client cert<br/>Provisioned: Manual / cert-manager<br/>Auto-Rotate: No"]
        CACert["ca_cert_file<br/>CA cert for TGIS<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        TGISClientCert["client_cert_file<br/>TGIS mTLS cert<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        TGISClientKey["client_key_file<br/>TGIS mTLS key<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    %% Relationships
    ServerKey -->|configures| GRPCTLS
    ServerCert -->|configures| GRPCTLS
    ClientCert -->|configures| GRPCClient
    CACert -->|configures| TGISCA
    TGISClientCert -->|configures| TGISmTLS
    TGISClientKey -->|configures| TGISmTLS

    SA -.->|"manages pod<br/>identity"| GRPCAuth
    SA -.->|"manages pod<br/>identity"| HTTPAuth

    %% Styling
    style Notice fill:#fef3c7,stroke:#d97706,stroke-width:2px
    style Info fill:#fef3c7,stroke:#d97706
    style PlatformRBAC fill:#e0e7ff,stroke:#6366f1
    style TLSAuth fill:#d1fae5,stroke:#059669
    style Secrets fill:#fee2e2,stroke:#dc2626

    style SA fill:#818cf8,stroke:#4338ca,color:#fff
    style PodSecurity fill:#818cf8,stroke:#4338ca,color:#fff

    style GRPCTLS fill:#6ee7b7,stroke:#047857
    style GRPCClient fill:#6ee7b7,stroke:#047857
    style HTTPTLS fill:#6ee7b7,stroke:#047857
    style TGISCA fill:#6ee7b7,stroke:#047857
    style TGISmTLS fill:#6ee7b7,stroke:#047857

    style ServerKey fill:#fca5a5,stroke:#b91c1c
    style ServerCert fill:#fca5a5,stroke:#b91c1c
    style ClientCert fill:#fca5a5,stroke:#b91c1c
    style CACert fill:#fca5a5,stroke:#b91c1c
    style TGISClientCert fill:#fca5a5,stroke:#b91c1c
    style TGISClientKey fill:#fca5a5,stroke:#b91c1c
