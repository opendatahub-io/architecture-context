graph TD
    subgraph "caikit-nlp RBAC Model"
        direction TB

        Note["NOTE: caikit-nlp is a library, not a Kubernetes operator.<br/>It defines NO Kubernetes RBAC (ClusterRoles, Roles, RoleBindings).<br/>All RBAC is managed by the model serving platform."]

        subgraph "Platform-Managed RBAC"
            direction TB

            SA["Pod ServiceAccount<br/>(provided by KServe/ModelMesh)"]

            subgraph "KServe Path"
                KServeSA["ServiceAccount:<br/>{inference-service}-sa"]
                KServeRole["Platform ClusterRole:<br/>kserve-manager-role"]
                KServeBinding["Platform Binding:<br/>kserve-manager-rolebinding"]
                KServeSA -->|"bound via platform"| KServeBinding
                KServeBinding -->|"grants"| KServeRole
            end

            subgraph "ModelMesh Path"
                MMeshSA["ServiceAccount:<br/>modelmesh-serving-sa"]
                MMeshRole["Platform ClusterRole:<br/>modelmesh-controller-role"]
                MMeshBinding["Platform Binding:<br/>modelmesh-controller-rolebinding"]
                MMeshSA -->|"bound via platform"| MMeshBinding
                MMeshBinding -->|"grants"| MMeshRole
            end
        end

        subgraph "Authentication Delegation"
            direction TB
            HTTPEndpoint["HTTP API :8080<br/>Auth: None (caikit-nlp)"]
            gRPCEndpoint["gRPC API :8085<br/>Auth: None (caikit-nlp)"]
            PlatformAuth["Platform Auth Enforcement<br/>(kube-rbac-proxy / istio)"]

            HTTPEndpoint -->|"auth delegated to"| PlatformAuth
            gRPCEndpoint -->|"auth delegated to"| PlatformAuth
        end

        subgraph "TGIS Connection Security"
            direction TB
            TGISConn["TGIS Backend Connection"]
            TLSCerts["TGIS TLS Certificates<br/>- ca_cert_file<br/>- client_cert_file<br/>- client_key_file"]
            TGISConn -->|"optional mTLS"| TLSCerts
        end
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style KServeSA fill:#4a90e2,stroke:#333,color:#fff
    style MMeshSA fill:#4a90e2,stroke:#333,color:#fff
    style KServeRole fill:#f5a623,stroke:#333
    style MMeshRole fill:#f5a623,stroke:#333
    style HTTPEndpoint fill:#d5e8d4,stroke:#82b366
    style gRPCEndpoint fill:#d5e8d4,stroke:#82b366
    style PlatformAuth fill:#e8d5f5,stroke:#7b4ea3
    style TGISConn fill:#fff2cc,stroke:#d6b656
    style TLSCerts fill:#fce4ec,stroke:#e57373
