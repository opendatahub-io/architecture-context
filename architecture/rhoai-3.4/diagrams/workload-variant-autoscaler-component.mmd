graph TB
    subgraph WVA["Workload Variant Autoscaler"]
        direction TB

        subgraph Controllers["Controllers"]
            VAController["VA Controller<br/>(Reconciler)"]
            CMReconciler["ConfigMap<br/>Reconciler"]
            IPReconciler["InferencePool<br/>Reconciler"]
        end

        subgraph Engines["Engine Loops"]
            SatEngine["Saturation Engine<br/>(60s interval)"]
            SFZEngine["Scale-from-Zero<br/>Engine"]
        end

        subgraph Core["Core Libraries"]
            Actuator["Actuator<br/>(Metrics Emitter)"]
            Collector["Metrics Collector<br/>(Pluggable Sources)"]
            Datastore["Datastore<br/>(In-Memory Cache)"]
            DecisionCache["Decision Cache"]
            Config["Unified Config"]
        end
    end

    %% Internal flows
    SatEngine -->|queries metrics| Collector
    SatEngine -->|publishes decisions| DecisionCache
    DecisionCache -->|triggers reconcile via Channel| VAController
    SFZEngine -->|monitors idle models| DecisionCache
    Collector -->|reads endpoint data| Datastore
    IPReconciler -->|populates pools| Datastore
    CMReconciler -->|updates| Config
    Config -->|configures| SatEngine
    VAController -->|reads decisions| DecisionCache
    VAController -->|emits metrics via| Actuator

    %% CRDs
    VACR["VariantAutoscaling CR<br/>(llmd.ai/v1alpha1)"]
    InferencePoolCR["InferencePool CR<br/>(inference.networking.k8s.io)"]
    ConfigMapCR["ConfigMaps<br/>(saturation, scale-to-zero,<br/>queueing model)"]

    VACR -->|watched by| VAController
    VAController -->|patches status| VACR
    InferencePoolCR -->|watched by| IPReconciler
    ConfigMapCR -->|watched by| CMReconciler

    %% External dependencies
    Prometheus["Prometheus /<br/>Thanos Querier<br/>9091/TCP HTTPS"]
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    EPP["EPP Pods<br/>(Endpoint Picker)"]

    Collector -->|PromQL queries| Prometheus
    Collector -->|scrapes flow metrics| EPP
    VAController -->|watch/update| K8sAPI

    %% Scale targets
    subgraph ScaleTargets["Scale Targets"]
        Deploy["Deployments"]
        STS["StatefulSets"]
        LWS["LeaderWorkerSets"]
    end

    VAController -->|resolves & reads scale| ScaleTargets

    %% Downstream consumers
    HPA["HPA / KEDA"]
    HPA -->|reads wva_desired_replicas| Prometheus
    HPA -->|scales| ScaleTargets
    Actuator -->|emits wva_* metrics| Prometheus

    %% Styling
    style WVA fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8d4,stroke:#82b366
    style Engines fill:#fff2cc,stroke:#d6b656
    style Core fill:#f8cecc,stroke:#b85450
    style ScaleTargets fill:#e1d5e7,stroke:#9673a6

    style VAController fill:#4a90e2,color:#fff
    style SatEngine fill:#f5a623,color:#fff
    style SFZEngine fill:#f5a623,color:#fff
    style Actuator fill:#e74c3c,color:#fff
    style Collector fill:#e74c3c,color:#fff
    style Datastore fill:#e74c3c,color:#fff
    style DecisionCache fill:#e74c3c,color:#fff
    style Config fill:#e74c3c,color:#fff

    style VACR fill:#f5a623,stroke:#333
    style InferencePoolCR fill:#f5a623,stroke:#333
    style ConfigMapCR fill:#f5a623,stroke:#333

    style Prometheus fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style EPP fill:#e8e8e8,stroke:#333
    style HPA fill:#7ed321,stroke:#333
