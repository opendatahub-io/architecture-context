graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator NS)"]
        SA_TAS["${tas-name}-proxy<br/>(user NS)"]
        SA_GORCH["${gorch-name}<br/>(user NS)"]
        SA_NEMO["${nemo-name}<br/>(user NS)"]
        SA_EVALHUB["${evalhub-name}<br/>(user NS)"]
        SA_EVALJOB["${evalhub-name}-job<br/>(tenant NS)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Proxy["proxy-rolebinding"]
        CRB_Leader["leader-election-rolebinding"]
        CRB_TASProxy["${tas-name}-proxy CRB"]
        CRB_GORCHAuth["auth-delegator CRB (GORCH)"]
        CRB_NEMOAuth["auth-delegator CRB (NeMo)"]
        CRB_EvalAuth["evalhub-auth-reviewer CRB"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_MLFlow["evalhub-mlflow-access RB<br/>(tenant NS)"]
        RB_JobsWriter["evalhub-jobs-writer RB<br/>(tenant NS)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Proxy["proxy-role"]
        CR_Leader["leader-election-role"]
        CR_TAS["manager-role (TAS)"]
        CR_LMES["manager-role (LMES)"]
        CR_JobMgr["manager-role (job-mgr)"]
        CR_GORCH["manager-role (GORCH)"]
        CR_NEMO["manager-role (NEMO)"]
        CR_EVALHUB["manager-role (EVALHUB)"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_Providers["evalhub-providers-access"]
        CR_Collections["evalhub-collections-access"]
        CR_JobsWriter["evalhub-jobs-writer"]
        CR_MLFlow["evalhub-mlflow-access"]
    end

    subgraph TAS_Resources["TAS API Resources"]
        TAS_CRD["trustyai.opendatahub.io<br/>trustyaiservices<br/>+ status + finalizers"]
        TAS_Deploy["apps<br/>deployments<br/>+ status + finalizers"]
        TAS_Core["core<br/>services, pods, configmaps,<br/>secrets, serviceaccounts,<br/>events, pvcs"]
        TAS_Routes["route.openshift.io<br/>routes"]
        TAS_KServe["serving.kserve.io<br/>inferenceservices<br/>+ finalizers"]
        TAS_Monitor["monitoring.coreos.com<br/>servicemonitors"]
        TAS_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings"]
        TAS_Istio["networking.istio.io<br/>destinationrules<br/>virtualservices"]
    end

    subgraph LMES_Resources["LMES API Resources"]
        LMES_CRD["trustyai.opendatahub.io<br/>lmevaljobs<br/>+ status + finalizers"]
        LMES_Pods["core<br/>pods, pods/exec"]
        LMES_Read["core<br/>configmaps, secrets<br/>(read-only)"]
        LMES_Storage["core<br/>pvs (read), pvcs (CRUD)"]
    end

    subgraph JobMgr_Resources["Job Manager Resources"]
        JM_Workloads["kueue.x-k8s.io<br/>workloads<br/>+ status + finalizers"]
        JM_Read["kueue.x-k8s.io<br/>resourceflavors<br/>workloadpriorityclasses<br/>(read-only)"]
    end

    subgraph GORCH_Resources["GORCH API Resources"]
        GORCH_CRD["trustyai.opendatahub.io<br/>guardrailsorchestrators<br/>+ status + finalizers"]
        GORCH_KServe["serving.kserve.io<br/>inferenceservices<br/>servingruntimes<br/>(read-only)"]
        GORCH_Deploy["apps<br/>deployments"]
        GORCH_Core["core<br/>pods, configmaps, secrets,<br/>serviceaccounts, services"]
    end

    subgraph EVALHUB_Resources["EvalHub API Resources"]
        EH_CRD["trustyai.opendatahub.io<br/>evalhubs<br/>+ status + finalizers"]
        EH_NS["core<br/>namespaces (read-only)"]
        EH_Jobs["batch<br/>jobs"]
        EH_Eval["trustyai.opendatahub.io<br/>evaluations (read-only)"]
        EH_Status["trustyai.opendatahub.io<br/>status-events (create, update)"]
        EH_MLFlow["mlflow.opendatahub.io<br/>experiments (read-only)"]
    end

    subgraph Auth_Resources["Auth Resources"]
        Auth_TokenReview["authentication.k8s.io<br/>tokenreviews"]
        Auth_SAR["authorization.k8s.io<br/>subjectaccessreviews"]
    end

    %% SA → CRB → CR bindings
    SA_CM -->|bound via| CRB_Proxy
    SA_CM -->|bound via| CRB_Leader
    CRB_Proxy -->|grants| CR_Proxy
    CRB_Leader -->|grants| CR_Leader

    SA_TAS -->|bound via| CRB_TASProxy
    CRB_TASProxy -->|grants| CR_Proxy

    SA_GORCH -->|bound via| CRB_GORCHAuth
    CRB_GORCHAuth -->|grants| CR_AuthDeleg

    SA_NEMO -->|bound via| CRB_NEMOAuth
    CRB_NEMOAuth -->|grants| CR_AuthDeleg

    SA_EVALHUB -->|bound via| CRB_EvalAuth
    CRB_EvalAuth -->|grants| CR_AuthDeleg

    SA_EVALJOB -->|bound via| RB_MLFlow
    RB_MLFlow -->|grants| CR_MLFlow

    SA_EVALJOB -->|bound via| RB_JobsWriter
    RB_JobsWriter -->|grants| CR_JobsWriter

    %% CR → Resources
    CR_Proxy -->|create| Auth_TokenReview
    CR_Proxy -->|create| Auth_SAR

    CR_TAS -->|CRUD| TAS_CRD
    CR_TAS -->|CRUD| TAS_Deploy
    CR_TAS -->|CRUD| TAS_Core
    CR_TAS -->|CRUD| TAS_Routes
    CR_TAS -->|CRUD| TAS_KServe
    CR_TAS -->|list,watch,create| TAS_Monitor
    CR_TAS -->|CRUD| TAS_RBAC
    CR_TAS -->|CRUD| TAS_Istio

    CR_LMES -->|CRUD| LMES_CRD
    CR_LMES -->|get,list,watch,create,delete| LMES_Pods
    CR_LMES -->|read-only| LMES_Read
    CR_LMES -->|read + CRUD pvcs| LMES_Storage

    CR_JobMgr -->|CRUD| JM_Workloads
    CR_JobMgr -->|read-only| JM_Read

    CR_GORCH -->|CRUD| GORCH_CRD
    CR_GORCH -->|read-only| GORCH_KServe
    CR_GORCH -->|CRUD| GORCH_Deploy
    CR_GORCH -->|CRUD| GORCH_Core

    CR_EVALHUB -->|CRUD| EH_CRD
    CR_EVALHUB -->|read-only| EH_NS
    CR_EVALHUB -->|CRUD| EH_Jobs

    CR_Providers -->|read-only| EH_Eval
    CR_Collections -->|read-only| EH_Eval
    CR_JobsWriter -->|create,update| EH_Status
    CR_MLFlow -->|read-only| EH_MLFlow

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_TAS fill:#4a90e2,stroke:#333,color:#fff
    style SA_GORCH fill:#4a90e2,stroke:#333,color:#fff
    style SA_NEMO fill:#4a90e2,stroke:#333,color:#fff
    style SA_EVALHUB fill:#4a90e2,stroke:#333,color:#fff
    style SA_EVALJOB fill:#4a90e2,stroke:#333,color:#fff

    style CR_Proxy fill:#f5a623,stroke:#333
    style CR_Leader fill:#f5a623,stroke:#333
    style CR_TAS fill:#f5a623,stroke:#333
    style CR_LMES fill:#f5a623,stroke:#333
    style CR_JobMgr fill:#f5a623,stroke:#333
    style CR_GORCH fill:#f5a623,stroke:#333
    style CR_NEMO fill:#f5a623,stroke:#333
    style CR_EVALHUB fill:#f5a623,stroke:#333
