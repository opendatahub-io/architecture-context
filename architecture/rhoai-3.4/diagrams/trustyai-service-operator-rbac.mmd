    style CR_Providers fill:#f5a623,stroke:#333
    style CR_Collections fill:#f5a623,stroke:#333
    style CR_JobsWriter fill:#f5a623,stroke:#333
    style CR_MLFlow fill:#f5a623,stroke:#333

    style TAS_CRD fill:#7ed321,stroke:#333
    style TAS_Deploy fill:#7ed321,stroke:#333
    style TAS_Core fill:#7ed321,stroke:#333
    style TAS_Routes fill:#7ed321,stroke:#333
    style TAS_KServe fill:#7ed321,stroke:#333
    style TAS_Monitor fill:#7ed321,stroke:#333
    style TAS_RBAC fill:#7ed321,stroke:#333
    style TAS_Istio fill:#7ed321,stroke:#333
    style LMES_CRD fill:#7ed321,stroke:#333
    style LMES_Pods fill:#7ed321,stroke:#333
    style LMES_Read fill:#7ed321,stroke:#333
    style LMES_Storage fill:#7ed321,stroke:#333
    style JM_Workloads fill:#7ed321,stroke:#333
    style JM_Read fill:#7ed321,stroke:#333
    style GORCH_CRD fill:#7ed321,stroke:#333
    style GORCH_KServe fill:#7ed321,stroke:#333
    style GORCH_Deploy fill:#7ed321,stroke:#333
    style GORCH_Core fill:#7ed321,stroke:#333
    style EH_CRD fill:#7ed321,stroke:#333
    style EH_NS fill:#7ed321,stroke:#333
    style EH_Jobs fill:#7ed321,stroke:#333
    style EH_Eval fill:#7ed321,stroke:#333
    style EH_Status fill:#7ed321,stroke:#333
