%% Security Network Diagram: llama-stack-k8s-operator
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Optional - exposeRoute)"]
        IngressCtrl["Kubernetes Ingress Controller<br/>{instance}-ingress<br/>80/TCP → 8321/TCP<br/>No TLS by default"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            direction TB
            OperatorPod["Operator Manager Pod<br/>RunAsNonRoot: true<br/>Capabilities: Drop ALL"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token/SAR<br/>Capabilities: Drop ALL"]
            MetricsSvc["controller-manager-metrics-service<br/>ClusterIP 8443/TCP HTTPS"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP plaintext"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB
            LlamaServer["Llama Stack Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid<br/>FSGroup: 1001<br/>8321/TCP HTTP plaintext"]
            LlamaSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP plaintext"]
            NetPol["{instance}-network-policy<br/>Ingress: same-ns, operator-ns,<br/>OCP ingress, user-configured"]
        end

        Prometheus["Prometheus<br/>ServiceMonitor"]
    end

    %% External flows
    Client -->|"HTTP(S) 80/443<br/>No auth"| IngressCtrl
    IngressCtrl -->|"HTTP 8321/TCP<br/>plaintext, no auth"| LlamaSvc

    %% Operator to K8s API
    OperatorPod -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Operator health check to Llama Stack
    OperatorPod -->|"HTTP 8321/TCP<br/>plaintext<br/>GET /v1/health"| LlamaSvc

    %% K8s API watch events to operator
    K8sAPI -->|"HTTPS 443/TCP<br/>Watch events<br/>SA token"| OperatorPod

    %% Prometheus scraping
    Prometheus -->|"HTTPS 8443/TCP<br/>TLS<br/>Bearer Token/SAR"| MetricsSvc
    MetricsSvc -->|proxy| RBACProxy
    RBACProxy -->|"HTTP 8080/TCP<br/>localhost"| OperatorPod

    %% Service to pod
    LlamaSvc -->|"8321/TCP"| LlamaServer
    NetPol -.->|"protects"| LlamaServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8s fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray:5

    class Client external
    class IngressCtrl ingress
    class OperatorPod,RBACProxy,MetricsSvc,HealthProbe operator
    class K8sAPI k8s
    class LlamaServer,LlamaSvc workload
    class NetPol netpol
    class Prometheus monitoring
