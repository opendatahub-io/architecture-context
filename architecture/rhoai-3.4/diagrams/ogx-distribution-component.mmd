graph TB
    subgraph "ogx-distribution (Llama Stack Server)"
        direction TB

        subgraph "API Layer (Port 8321/TCP)"
            HealthAPI["/v1/health<br/>Health Check"]
            InferenceAPI["/v1/inference/*<br/>/v1/chat/completions"]
            SafetyAPI["/v1/safety/*<br/>Guardrails"]
            VectorAPI["/v1/vector_io/*<br/>RAG"]
            EvalAPI["/v1/eval/*<br/>Evaluation"]
            FilesAPI["/v1/files/*<br/>File Mgmt"]
            ResponsesAPI["/v1/responses/*<br/>Agent Responses"]
            BatchAPI["/v1/batches/*<br/>Batch Inference"]
            ScoringAPI["/v1/scoring/*<br/>Scoring"]
            ToolAPI["/v1/tool_runtime/*<br/>Tools (MCP, Search)"]
            DatasetAPI["/v1/datasetio/*<br/>Dataset I/O"]
        end

        subgraph "Auth Middleware"
            AuthMW["OAuth2 JWT Validation<br/>AUTH_ISSUER / AUTH_JWKS_URI"]
        end

        subgraph "Provider Framework"
            direction LR
            InferenceProv["Inference Providers<br/>vLLM, Bedrock, Azure,<br/>Vertex AI, OpenAI, WatsonX"]
            SafetyProv["Safety Providers<br/>TrustyAI FMS"]
            VectorProv["Vector Providers<br/>Milvus, pgvector,<br/>Qdrant, FAISS"]
            EvalProv["Eval Providers<br/>LMEval, RAGAS, Garak"]
            ToolProv["Tool Providers<br/>Brave, Tavily, MCP"]
        end

        subgraph "Storage Layer"
            KVStore["KV Store<br/>(kv_postgres)"]
            SQLStore["SQL Store<br/>(sql_postgres)"]
        end

        subgraph "Embedded Models"
            EmbedModel["granite-embedding-125m-english<br/>(pre-cached)"]
            Tiktoken["tiktoken cl100k_base<br/>(pre-cached)"]
        end

        Entrypoint["entrypoint.sh<br/>llama stack run"]
        ConfigYAML["distribution/config.yaml<br/>Server Configuration"]
    end

    Client[External Client] -->|"HTTP 8321/TCP<br/>OAuth2 JWT"| AuthMW
    AuthMW --> InferenceAPI
    AuthMW --> SafetyAPI
    AuthMW --> VectorAPI
    AuthMW --> EvalAPI
    AuthMW --> FilesAPI
    Client -->|"No Auth"| HealthAPI

    InferenceAPI --> InferenceProv
    SafetyAPI --> SafetyProv
    VectorAPI --> VectorProv
    EvalAPI --> EvalProv
    ToolAPI --> ToolProv

    InferenceProv --> KVStore
    InferenceProv --> SQLStore
    VectorProv --> EmbedModel

    ConfigYAML -.->|configures| Entrypoint

    %% External connections
    InferenceProv -->|"HTTP/HTTPS"| vLLM["vLLM Serving Runtime"]
    InferenceProv -->|"HTTPS/443"| CloudLLM["Cloud LLM Providers<br/>(Bedrock, Azure, Vertex,<br/>OpenAI, WatsonX)"]
    SafetyProv -->|"HTTP/HTTPS"| TrustyAI["TrustyAI FMS Orchestrator"]
    VectorProv -->|"Various protocols"| VectorDBs["Vector Databases<br/>(Milvus, pgvector, Qdrant)"]
    EvalProv -->|"HTTP/HTTPS"| Kubeflow["Kubeflow Pipelines"]
    KVStore -->|"5432/TCP"| PostgreSQL["PostgreSQL"]
    SQLStore -->|"5432/TCP"| PostgreSQL

    PlatformIngress["Platform Ingress<br/>(Gateway API)<br/>TLS Termination"] -->|"HTTP 8321"| Client

    style HealthAPI fill:#7ed321,stroke:#333
    style InferenceAPI fill:#4a90e2,stroke:#333
    style SafetyAPI fill:#e74c3c,stroke:#333
    style VectorAPI fill:#9b59b6,stroke:#333
    style EvalAPI fill:#f39c12,stroke:#333
    style AuthMW fill:#e74c3c,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333
    style CloudLLM fill:#999,stroke:#333
    style TrustyAI fill:#7ed321,stroke:#333
    style VectorDBs fill:#999,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Kubeflow fill:#999,stroke:#333
    style PlatformIngress fill:#ffe6cc,stroke:#d79b00
    style ConfigYAML fill:#f5a623,stroke:#333
    style Entrypoint fill:#f5a623,stroke:#333
    style EmbedModel fill:#d5e8d4,stroke:#82b366
    style Tiktoken fill:#d5e8d4,stroke:#82b366
