graph TB
    subgraph External["External Clients"]
        Client[Client Application]
    end

    subgraph LlamaStack["Llama Stack Server (Port 8321/TCP)"]
        direction TB
        API["FastAPI/Uvicorn HTTP Server<br/>OAuth2 JWT Auth (optional)"]

        subgraph APIs["Llama Stack APIs"]
            direction LR
            InferenceAPI["/v1/inference/*<br/>/v1/chat/completions"]
            SafetyAPI["/v1/safety/*"]
            EvalAPI["/v1/eval/*"]
            VectorAPI["/v1/vector_io/*"]
            ToolAPI["/v1/tool_runtime/*"]
            FilesAPI["/v1/files/*"]
            OtherAPIs["/v1/batches/*<br/>/v1/scoring/*<br/>/v1/responses/*<br/>/v1/datasetio/*"]
        end

        subgraph Providers["Provider Layer (Conditional Activation)"]
            direction LR
            InferenceProviders["Inference Providers<br/>vLLM | Bedrock | Vertex AI<br/>OpenAI | WatsonX | Azure"]
            SafetyProviders["Safety Providers<br/>TrustyAI FMS<br/>Passthrough"]
            EvalProviders["Eval Providers<br/>LM-Eval | RAGAS | Garak"]
            VectorProviders["Vector Providers<br/>Milvus | FAISS | PGVector | Qdrant"]
            ToolProviders["Tool Providers<br/>Brave | Tavily | MCP"]
            StorageProviders["Storage Providers<br/>Local FS | S3"]
        end

        subgraph Storage["Storage Layer"]
            KVStore["kv_postgres<br/>(metadata, state)"]
            SQLStore["sql_postgres<br/>(inference, files, responses)"]
        end

        DistroConfig["distribution/config.yaml<br/>Provider Configuration"]
    end

    subgraph InferenceBackends["Inference Backends"]
        vLLM["vLLM Serving Runtime<br/>HTTP/HTTPS"]
        vLLMEmbed["vLLM Embedding Runtime<br/>HTTP/HTTPS"]
        Bedrock["AWS Bedrock<br/>443/TCP HTTPS"]
        VertexAI["Google Vertex AI<br/>443/TCP HTTPS"]
        OpenAI["OpenAI API<br/>443/TCP HTTPS"]
        WatsonX["IBM WatsonX<br/>443/TCP HTTPS"]
        AzureOAI["Azure OpenAI<br/>443/TCP HTTPS"]
    end

    subgraph VectorDBs["Vector Databases"]
        Milvus["Milvus<br/>TCP"]
        PGVector["PGVector<br/>5432/TCP"]
        Qdrant["Qdrant<br/>6333/6334 TCP"]
        FAISS["FAISS<br/>(in-process)"]
    end

    subgraph SafetyServices["Safety & Eval Services"]
        TrustyAIFMS["TrustyAI FMS<br/>HTTP/HTTPS"]
        TrustyAILMEval["TrustyAI LM-Eval<br/>HTTP"]
        KubeflowPipelines["Kubeflow Pipelines<br/>RAGAS & Garak"]
    end

    subgraph DataServices["Data & Observability"]
        PostgreSQL["PostgreSQL<br/>5432/TCP"]
        S3["S3 Storage<br/>443/TCP HTTPS"]
        OTEL["OTEL Collector<br/>HTTP OTLP"]
        OAuth2IDP["OAuth2 Identity Provider<br/>JWKS 443/TCP"]
    end

    subgraph SearchTools["Search Tools"]
        Brave["Brave Search<br/>443/TCP HTTPS"]
        Tavily["Tavily Search<br/>443/TCP HTTPS"]
    end

    %% Client flow
    Client -->|"HTTP 8321/TCP<br/>OAuth2 JWT (optional)"| API
    API --> APIs
    APIs --> Providers

    %% Provider to backend connections
    InferenceProviders --> vLLM
    InferenceProviders --> vLLMEmbed
    InferenceProviders --> Bedrock
    InferenceProviders --> VertexAI
    InferenceProviders --> OpenAI
    InferenceProviders --> WatsonX
    InferenceProviders --> AzureOAI

    VectorProviders --> Milvus
    VectorProviders --> PGVector
    VectorProviders --> Qdrant
    VectorProviders --> FAISS

    SafetyProviders --> TrustyAIFMS
    EvalProviders --> TrustyAILMEval
    EvalProviders --> KubeflowPipelines

    ToolProviders --> Brave
    ToolProviders --> Tavily

    StorageProviders --> S3

    %% Storage connections
    Storage --> PostgreSQL

    %% Observability
    API -.->|"OTLP traces/metrics"| OTEL
    API -.->|"JWKS validation"| OAuth2IDP

    %% Config
    DistroConfig -.->|"configures"| Providers

    %% Platform management
    RHODSOperator["rhods-operator<br/>(deploys & manages)"] -.->|"manages"| LlamaStack

    %% Styling
    style API fill:#4a90e2,stroke:#333,color:#fff
    style DistroConfig fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style RHODSOperator fill:#b8d4e3,stroke:#333

    style vLLM fill:#7ed321,stroke:#333
    style vLLMEmbed fill:#7ed321,stroke:#333
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style TrustyAIFMS fill:#7ed321,stroke:#333
    style TrustyAILMEval fill:#7ed321,stroke:#333
    style KubeflowPipelines fill:#7ed321,stroke:#333

    style Bedrock fill:#999,stroke:#333,color:#fff
    style VertexAI fill:#999,stroke:#333,color:#fff
    style OpenAI fill:#999,stroke:#333,color:#fff
    style WatsonX fill:#999,stroke:#333,color:#fff
    style AzureOAI fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333
    style Milvus fill:#f5a623,stroke:#333
    style Qdrant fill:#f5a623,stroke:#333
