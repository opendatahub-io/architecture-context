%% Data Flow Diagram for llm-d-kv-cache
%% Generated by: Claude Opus 4.6

sequenceDiagram
    participant Scheduler as Inference Scheduler<br/>(Go library import)
    participant Indexer as kvcache.Indexer<br/>(in-process)
    participant TokenPool as tokenization.Pool<br/>(in-process)
    participant UDS as UDS Tokenizer<br/>gRPC over UDS
    participant TokenProc as TokenProcessor<br/>FNV-64a Hashing
    participant Index as kvblock.Index<br/>(in-memory/Redis)
    participant Scorer as kvblock.Scorer<br/>(in-process)

    Note over Scheduler, Scorer: Flow 1: Scoring a Prompt (Read Path)
    Scheduler->>Indexer: GetPodScores(prompt, model)
    Indexer->>TokenPool: Tokenize(text)
    TokenPool->>UDS: gRPC Tokenize()<br/>UDS: /tmp/tokenizer/tokenizer-uds.socket
    UDS-->>TokenPool: Token IDs + offsets
    TokenPool-->>Indexer: Token sequence
    Indexer->>TokenProc: TokensToBlockKeys(tokens, blockSize)
    TokenProc-->>Indexer: Block key hashes (FNV-64a)
    Indexer->>Index: Lookup(blockKeys)
    Index-->>Indexer: Pod locations per block
    Indexer->>Scorer: ScorePods(blockHits, pods)
    Scorer-->>Indexer: Scored pod list (weighted)
    Indexer-->>Scheduler: PodScores response

    participant vLLM as vLLM Pod<br/>ZMQ PUB :5557
    participant ZMQSub as zmqSubscriber<br/>ZMQ SUB
    participant EvPool as kvevents.Pool<br/>Sharded Workers
    participant Engine as EngineAdapter<br/>(vLLM)

    Note over vLLM, Index: Flow 2: Ingesting KV-Cache Events (Write Path)
    vLLM->>ZMQSub: KVEvent (topic: kv@)<br/>ZMQ PUB/SUB :5557/TCP
    ZMQSub->>EvPool: Route to shard worker
    EvPool->>Engine: Decode event (BlockStored/BlockRemoved/AllBlocksCleared)
    Engine-->>EvPool: Parsed block keys + pod ID
    alt BlockStored
        EvPool->>Index: Add(blockKey, podID, deviceTier)
    else BlockRemoved
        EvPool->>Index: Evict(blockKey, podID)
    else AllBlocksCleared
        EvPool->>Index: EvictAll(podID)
    end

    participant K8sAPI as Kubernetes API<br/>HTTPS :443
    participant Reconciler as PodReconciler<br/>controller-runtime
    participant SubMgr as SubscriberManager

    Note over K8sAPI, vLLM: Flow 3: Pod Auto-Discovery (Controller)
    K8sAPI->>Reconciler: Pod event (label selector match)<br/>HTTPS :443, SA token
    alt Pod Created/Running
        Reconciler->>SubMgr: AddSubscriber(podIP)
        SubMgr->>vLLM: ZMQ CONNECT<br/>tcp://podIP:5557
    else Pod Deleted
        Reconciler->>SubMgr: RemoveSubscriber(podIP)
        SubMgr->>ZMQSub: Close connection
    end
