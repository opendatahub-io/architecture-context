graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["User Browser"]
    end

    subgraph ClusterIngress["CLUSTER INTERNAL"]
        Gateway["RHOAI Gateway (Envoy)<br/>Ingress traffic routing"]
        Prometheus["Prometheus<br/>SA: openshift-monitoring/prometheus-k8s"]
    end

    subgraph PodBoundary["POD BOUNDARY (Sidecar Container)"]
        direction TB

        subgraph AuthModeBox["Auth Mode (PROXY_MODE=auth)"]
            AuthProxy["kube-auth-proxy<br/>4180/TCP HTTP / 443/TCP HTTPS<br/>TLS 1.2-1.3 (configurable)<br/>OAuth2 Cookie / JWT / K8s Token / Basic Auth"]
        end

        subgraph RBACModeBox["RBAC Mode (PROXY_MODE=rbac)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+ (self-signed fallback)<br/>Bearer Token / mTLS / OIDC JWT<br/>SubjectAccessReview per request"]
        end

        Upstream["Upstream Application<br/>(protected by proxy sidecar)"]
    end

    subgraph ClusterServices["CLUSTER SERVICES (Trusted)"]
        K8sAPI["Kubernetes API Server<br/>kubernetes.default.svc<br/>443/TCP HTTPS<br/>TLS 1.2+ (cluster CA)<br/>TokenReview + SAR + OAuthAccessToken"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OIDC["OIDC Provider<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2 Client Credentials"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+ (custom CA)<br/>SA Bearer Token"]
        Redis["Redis (optional)<br/>6379/TCP<br/>Optional TLS<br/>Password / Sentinel Auth"]
    end

    %% External to proxy flows
    Browser -->|"HTTP(S)/4180 or 443<br/>TLS 1.2+ configurable<br/>OAuth2 Cookie / JWT"| AuthProxy

    %% Gateway flows
    Gateway -->|"HTTP/4180 ext_authz<br/>No encryption (pod-local)<br/>Authorization check"| AuthProxy
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>K8s SA Bearer Token"| RBACProxy

    %% Prometheus
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Hardcoded SA allow"| RBACProxy

    %% Proxy to upstream
    AuthProxy -->|"HTTP(S)/configurable<br/>X-Forwarded-User headers"| Upstream
    RBACProxy -->|"HTTP(S)/h2c configurable<br/>mTLS supported<br/>x-remote-user headers"| Upstream

    %% Proxy to cluster services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+ (cluster CA)<br/>In-cluster SA token<br/>TokenReview + OAuthAccessToken"| K8sAPI
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+ (cluster CA)<br/>In-cluster SA token<br/>TokenReview + SAR"| K8sAPI

    %% Proxy to external services
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2 client credentials"| OIDC
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+ (custom CA)<br/>SA bearer token"| OAuthServer
    AuthProxy -.->|"TCP/6379<br/>Optional TLS<br/>Password auth"| Redis
    RBACProxy -.->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS retrieval"| OIDC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class Gateway,Prometheus ingress
    class AuthProxy,RBACProxy,Upstream pod
    class K8sAPI clusterservice
    class OIDC,OAuthServer,Redis externalservice
