graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (RHOAI Gateway)"]
        Envoy["Envoy Proxy<br/>443/TCP → internal<br/>TLS 1.3 termination<br/>ext_authz delegation"]
    end

    subgraph Pod["SIDECAR CONTAINER (Pod-level trust boundary)"]
        direction TB

        subgraph AuthMode["Auth Mode"]
            AuthProxy["kube-auth-proxy<br/>8080/TCP HTTP | 8443/TCP HTTPS<br/>TLS 1.2+, FIPS<br/>AuthN: OIDC / OpenShift OAuth /<br/>JWT / K8s SA / Cookie"]
        end

        subgraph RBACMode["RBAC Mode (default)"]
            RBACProxy["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS 1.2+, FIPS, hot-reload certs<br/>AuthN: TokenReview / OIDC JWT / client cert<br/>AuthZ: SubjectAccessReview"]
        end

        UpstreamApp["Upstream Application<br/>(RHOAI Component)<br/>localhost, no auth required<br/>Identity headers injected"]
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth<br/>TokenReview + SAR APIs"]
        OIDC["OIDC Provider (Keycloak)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials<br/>Token exchange + JWKS"]
        OSAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth<br/>OAuth flow + token deletion"]
        Redis["Redis (optional)<br/>6379/TCP<br/>TCP or TLS<br/>Password auth<br/>Session storage"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>(openshift-monitoring)<br/>SA: prometheus-k8s<br/>Hardcoded allow for /metrics"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer / Cookie"| Envoy

    %% Envoy to auth proxy
    Envoy -->|"HTTP/8080 (in-pod)<br/>No encryption<br/>ext_authz: /oauth2/auth<br/>Returns 202 or 401"| AuthProxy

    %% Auth proxy to upstream
    AuthProxy -->|"HTTP/HTTPS (localhost)<br/>Configurable<br/>X-Forwarded-User/Email/Groups"| UpstreamApp

    %% RBAC proxy to upstream
    RBACProxy -->|"HTTP/HTTPS/H2C (localhost)<br/>Configurable<br/>x-remote-user/x-remote-groups"| UpstreamApp

    %% Direct client to RBAC proxy
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer / Client cert"| RBACProxy

    %% Egress - Auth proxy
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials"| OIDC
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| OSAuth
    AuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    AuthProxy -->|"TCP or TLS/6379<br/>Password"| Redis

    %% Egress - RBAC proxy
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>TokenReview + SAR"| K8sAPI
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>JWKS retrieval"| OIDC

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS 1.2+<br/>Hardcoded SA auth"| RBACProxy

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef sidecar fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef upstream fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Envoy ingress
    class AuthProxy,RBACProxy sidecar
    class UpstreamApp upstream
    class K8sAPI,OIDC,OSAuth,Redis egress
    class Prometheus monitoring
