%% Training Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "Training Operator (opendatahub namespace)"
        Controller["Training Operator Controller<br/>(controller-runtime)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS"]
        CertMgr["Cert Manager<br/>(OPA cert-controller)"]

        subgraph "Job Controllers"
            PyTorch["PyTorchJob Controller"]
            TFJob["TFJob Controller"]
            XGBoost["XGBoostJob Controller"]
            MPI["MPIJob Controller"]
            Paddle["PaddleJob Controller"]
            JAX["JAXJob Controller"]
        end

        subgraph "Optional Integration"
            GangSched["Gang Scheduling<br/>(Volcano / scheduler-plugins)"]
        end

        CertMgr -->|rotates certs| Webhook
        Controller --- PyTorch
        Controller --- TFJob
        Controller --- XGBoost
        Controller --- MPI
        Controller --- Paddle
        Controller --- JAX
    end

    %% CRDs
    User[User / Client] -->|creates| PyTorchJobCR["PyTorchJob CR<br/>kubeflow.org/v1"]
    User -->|creates| TFJobCR["TFJob CR<br/>kubeflow.org/v1"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR<br/>kubeflow.org/v1"]
    User -->|creates| MPIJobCR["MPIJob CR<br/>kubeflow.org/v1"]
    User -->|creates| PaddleJobCR["PaddleJob CR<br/>kubeflow.org/v1"]
    User -->|creates| JAXJobCR["JAXJob CR<br/>kubeflow.org/v1"]

    %% CRD watches
    PyTorchJobCR -->|watched by| PyTorch
    TFJobCR -->|watched by| TFJob
    XGBoostJobCR -->|watched by| XGBoost
    MPIJobCR -->|watched by| MPI
    PaddleJobCR -->|watched by| Paddle
    JAXJobCR -->|watched by| JAX

    %% Webhook validation
    K8sAPI["Kubernetes API Server"] -->|validates via| Webhook

    %% Created resources
    PyTorch -->|creates| Pods["Worker/Master Pods"]
    PyTorch -->|creates| HeadlessSvc["Headless Services"]
    PyTorch -->|creates| NetPol["NetworkPolicies"]
    PyTorch -->|creates| HPA["HorizontalPodAutoscaler<br/>(elastic training)"]

    TFJob -->|creates| Pods
    TFJob -->|creates| HeadlessSvc

    %% Gang scheduling
    PyTorch -.->|optional| GangSched
    GangSched -->|creates| PodGroup["PodGroups"]

    %% Dependencies
    Controller -->|API calls| K8sAPI
    Prometheus["Prometheus<br/>(openshift-monitoring)"] -->|scrapes :8080| Controller

    %% Deployment
    RhodsOp["rhods-operator"] -->|deploys via kustomize| Controller

