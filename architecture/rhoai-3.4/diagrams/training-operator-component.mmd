graph TB
    subgraph TrainingOperator["Training Operator (KFTO)"]
        direction TB
        Controller["training-operator<br/>Go Operator<br/>(controller-runtime)"]
        Webhook["ValidatingWebhookConfiguration<br/>9443/TCP HTTPS"]
        CertController["OPA cert-controller<br/>Auto-rotates TLS certs"]
        Metrics["Prometheus Metrics<br/>8080/TCP HTTP"]

        CertController -->|generates certs for| Webhook
        Controller -->|registers| Webhook
        Controller -->|exposes| Metrics
    end

    subgraph CRDs["Custom Resource Definitions (kubeflow.org/v1)"]
        PyTorchJob["PyTorchJob"]
        TFJob["TFJob"]
        XGBoostJob["XGBoostJob"]
        JAXJob["JAXJob"]
        MPIJob["MPIJob"]
        PaddleJob["PaddleJob"]
    end

    subgraph CreatedResources["Created Resources"]
        Pods["Per-Replica Pods<br/>(Master/Worker/PS)"]
        HeadlessSvc["Headless Services<br/>(pod-to-pod discovery)"]
        HPA["HorizontalPodAutoscaler<br/>(PyTorch elastic only)"]
        PodGroup["PodGroup CRs<br/>(Volcano / scheduler-plugins)"]
    end

    User["User / Platform"] -->|creates| PyTorchJob
    User -->|creates| TFJob
    User -->|creates| XGBoostJob
    User -->|creates| JAXJob
    User -->|creates| MPIJob
    User -->|creates| PaddleJob

    PyTorchJob -->|watched by| Controller
    TFJob -->|watched by| Controller
    XGBoostJob -->|watched by| Controller
    JAXJob -->|watched by| Controller
    MPIJob -->|watched by| Controller
    PaddleJob -->|watched by| Controller

    Webhook -->|validates| PyTorchJob
    Webhook -->|validates| TFJob
    Webhook -->|validates| XGBoostJob
    Webhook -->|validates| JAXJob
    Webhook -->|validates| PaddleJob

    Controller -->|creates| Pods
    Controller -->|creates| HeadlessSvc
    Controller -->|creates| HPA
    Controller -->|creates| PodGroup

    Controller -->|CRUD via| K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS"]
    Prometheus["Prometheus"] -->|scrapes via PodMonitor| Metrics

    style Controller fill:#4a90e2,stroke:#333,color:#fff
    style Webhook fill:#4a90e2,stroke:#333,color:#fff
    style CertController fill:#4a90e2,stroke:#333,color:#fff
    style Metrics fill:#4a90e2,stroke:#333,color:#fff
    style PyTorchJob fill:#f5a623,stroke:#333
    style TFJob fill:#f5a623,stroke:#333
    style XGBoostJob fill:#f5a623,stroke:#333
    style JAXJob fill:#f5a623,stroke:#333
    style MPIJob fill:#f5a623,stroke:#333
    style PaddleJob fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style HeadlessSvc fill:#7ed321,stroke:#333
    style HPA fill:#7ed321,stroke:#333
    style PodGroup fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
