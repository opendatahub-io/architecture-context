graph TB
    subgraph TrainingOperator["Training Operator (KFTO)"]
        direction TB

        subgraph Controllers["Framework Controllers"]
            PyTorchCtrl["PyTorchJob Controller<br/>Elastic training, HPA,<br/>init containers, NetworkPolicy"]
            TFCtrl["TFJob Controller<br/>TF_CONFIG cluster specs,<br/>PS/Worker/Chief topology"]
            MPICtrl["MPIJob Controller<br/>Launcher/Worker RBAC,<br/>ConfigMap, kubectl-delivery"]
            JAXCtrl["JAXJob Controller<br/>Coordinator-based topology"]
            PaddleCtrl["PaddleJob Controller<br/>Collective & PS modes"]
            XGBoostCtrl["XGBoostJob Controller<br/>Master/Worker topology"]
        end

        subgraph SharedBase["Shared Base (pkg/controller.v1/common)"]
            JobController["Job Controller<br/>Core reconciliation loop"]
            PodControl["Pod Control<br/>Create/Delete pods"]
            ServiceControl["Service Control<br/>Headless services"]
            SchedulingControl["Scheduling Control<br/>Gang scheduling abstraction"]
            StatusManager["Status Manager<br/>Job status tracking"]
        end

        subgraph Webhooks["Admission Webhooks (9443/TCP)"]
            PyTorchWH["PyTorchJob Validator"]
            TFWH["TFJob Validator"]
            JAXWH["JAXJob Validator"]
            PaddleWH["PaddleJob Validator"]
            XGBoostWH["XGBoostJob Validator"]
        end

        CertMgr["Certificate Manager<br/>TLS cert auto-rotation"]
    end

    %% CRDs
    PyTorchJobCR["PyTorchJob CR<br/>kubeflow.org/v1"]
    TFJobCR["TFJob CR<br/>kubeflow.org/v1"]
    MPIJobCR["MPIJob CR<br/>kubeflow.org/v1"]
    JAXJobCR["JAXJob CR<br/>kubeflow.org/v1"]
    PaddleJobCR["PaddleJob CR<br/>kubeflow.org/v1"]
    XGBoostJobCR["XGBoostJob CR<br/>kubeflow.org/v1"]

    %% External
    User["Data Scientist / User"]
    K8sAPI["Kubernetes API Server"]

    %% User creates CRDs
    User -->|"kubectl apply"| K8sAPI
    K8sAPI -->|"validates"| Webhooks
    K8sAPI -->|"stores"| PyTorchJobCR
    K8sAPI -->|"stores"| TFJobCR
    K8sAPI -->|"stores"| MPIJobCR
    K8sAPI -->|"stores"| JAXJobCR
    K8sAPI -->|"stores"| PaddleJobCR
    K8sAPI -->|"stores"| XGBoostJobCR

    %% Controllers watch CRDs
    PyTorchJobCR -->|"watched by"| PyTorchCtrl
    TFJobCR -->|"watched by"| TFCtrl
    MPIJobCR -->|"watched by"| MPICtrl
    JAXJobCR -->|"watched by"| JAXCtrl
    PaddleJobCR -->|"watched by"| PaddleCtrl
    XGBoostJobCR -->|"watched by"| XGBoostCtrl

    %% Controllers use shared base
    PyTorchCtrl --> JobController
    TFCtrl --> JobController
    MPICtrl --> JobController
    JAXCtrl --> JobController
    PaddleCtrl --> JobController
    XGBoostCtrl --> JobController

    JobController --> PodControl
    JobController --> ServiceControl
    JobController --> SchedulingControl
    JobController --> StatusManager

    %% Controllers create resources via K8s API
    PodControl -->|"creates Pods"| K8sAPI
    ServiceControl -->|"creates Headless Services"| K8sAPI
    SchedulingControl -->|"creates PodGroups"| K8sAPI

    %% Cert manager
    CertMgr -->|"provisions TLS certs"| Webhooks

    %% Created resources
    TrainingPods["Training Pods<br/>(Master + Workers)"]
    HeadlessSvc["Headless Services<br/>(inter-pod DNS)"]

    K8sAPI -->|"schedules"| TrainingPods
    K8sAPI -->|"creates"| HeadlessSvc

    TrainingPods <-->|"distributed training<br/>NCCL/Gloo/MPI"| TrainingPods

    %% Styling
    style TrainingOperator fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#dbeafe,stroke:#3b82f6,stroke-width:1px
    style SharedBase fill:#f0fdf4,stroke:#22c55e,stroke-width:1px
    style Webhooks fill:#fef3c7,stroke:#f59e0b,stroke-width:1px

    style PyTorchCtrl fill:#4a90e2,color:#fff
    style TFCtrl fill:#4a90e2,color:#fff
    style MPICtrl fill:#4a90e2,color:#fff
    style JAXCtrl fill:#4a90e2,color:#fff
    style PaddleCtrl fill:#4a90e2,color:#fff
    style XGBoostCtrl fill:#4a90e2,color:#fff

    style PyTorchJobCR fill:#f5a623
    style TFJobCR fill:#f5a623
    style MPIJobCR fill:#f5a623
    style JAXJobCR fill:#f5a623
    style PaddleJobCR fill:#f5a623
    style XGBoostJobCR fill:#f5a623

    style K8sAPI fill:#e8e8e8,stroke:#333
    style User fill:#f9f9f9,stroke:#999
    style TrainingPods fill:#d5e8d4,stroke:#82b366
    style HeadlessSvc fill:#d5e8d4,stroke:#82b366
    style CertMgr fill:#e1d5e7,stroke:#9673a6
