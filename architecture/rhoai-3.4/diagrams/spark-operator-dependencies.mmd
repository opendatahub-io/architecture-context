graph LR
    SparkOp["Spark Operator<br/>v2.3.0"]

    %% External Dependencies (Required)
    SparkOp -->|"controller framework"| CtrlRuntime["controller-runtime<br/>v0.20.4"]
    SparkOp -->|"API client"| K8sAPI["Kubernetes API<br/>v0.32.5"]
    SparkOp -->|"bundled runtime"| Spark["Apache Spark<br/>4.0.1"]
    SparkOp -->|"JVM runtime"| Java["Java OpenJDK<br/>17"]
    SparkOp -->|"init process"| Tini["tini"]
    SparkOp -->|"cron parsing"| Cron["robfig/cron<br/>v3"]

    %% External Dependencies (Optional)
    SparkOp -.->|"gang scheduling<br/>PodGroup CRDs"| Volcano["Volcano<br/>v1.10.0"]
    SparkOp -.->|"scheduler plugins"| SchedPlugins["scheduler-plugins<br/>v0.32.7"]
    SparkOp -.->|"chart deployment"| Helm["Helm v3<br/>v3.18.5"]
    SparkOp -.->|"TLS certs"| CertManager["cert-manager"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator"] -->|"deploys manifests<br/>via ApplyParams"| SparkOp
    SparkOp -->|"PodMonitor scrape<br/>8080/TCP HTTP"| Prometheus["Prometheus /<br/>OpenShift Monitoring"]

    %% Integration Points (Consumers)
    SparkOp -->|"creates"| DriverPod["Driver Pods"]
    SparkOp -->|"creates"| ExecutorPods["Executor Pods"]
    SparkOp -->|"creates"| Services["K8s Services<br/>(Spark UI, Connect)"]
    SparkOp -->|"creates"| Ingresses["K8s Ingresses<br/>(optional)"]

    %% Scheduling Integration
    SparkOp -.->|"pod annotations"| Yunikorn["Yunikorn Scheduler"]
    SparkOp -.->|"schedulerName"| CustomSched["Custom K8s Scheduler"]

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Spark fill:#999,stroke:#333,color:#fff
    style Java fill:#999,stroke:#333,color:#fff
    style Tini fill:#999,stroke:#333,color:#fff
    style Cron fill:#999,stroke:#333,color:#fff

    %% Optional external
    style Volcano fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style SchedPlugins fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Helm fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style Yunikorn fill:#bbb,stroke:#333,stroke-dasharray: 5 5
    style CustomSched fill:#bbb,stroke:#333,stroke-dasharray: 5 5

    %% Internal platform
    style RhodsOp fill:#9b59b6,stroke:#333,color:#fff
    style Prometheus fill:#7ed321,stroke:#333,color:#fff

    %% Created resources
    style DriverPod fill:#f5a623,stroke:#333,color:#fff
    style ExecutorPods fill:#f5a623,stroke:#333,color:#fff
    style Services fill:#f5a623,stroke:#333,color:#fff
    style Ingresses fill:#f5a623,stroke:#333,color:#fff
