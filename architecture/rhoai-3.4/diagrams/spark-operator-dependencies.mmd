graph LR
    SparkOp["Spark Operator<br/>(v2.3.0)"]

    %% Required External Dependencies
    SparkOp -->|"CRD reconciliation<br/>pod/svc CRUD<br/>HTTPS/443"| K8sAPI["Kubernetes 1.16+"]
    SparkOp -->|"driver/executor images<br/>spark-submit"| Spark["Apache Spark 3.0+<br/>(4.0.1 default)"]
    SparkOp -->|"JVM runtime<br/>bundled in image"| Java17["Java 17<br/>(OpenJDK)"]
    SparkOp -->|"Python bindings<br/>bundled in image"| PySpark["PySpark 4.0.1"]

    %% Optional External Dependencies
    SparkOp -.->|"optional TLS certs<br/>Certificate CRD"| CertManager["cert-manager v1"]
    SparkOp -.->|"optional gang scheduling<br/>PodGroup CRDs"| Volcano["Volcano v1/v1beta1"]
    SparkOp -.->|"optional gang scheduling<br/>pod annotations"| YuniKorn["Apache YuniKorn"]
    SparkOp -.->|"optional batch scheduling<br/>PodGroup CRD"| KubeSched["Kube-Scheduler<br/>Plugins"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator"] -->|"deploys via<br/>kustomize overlays"| SparkOp

    %% Integration Points - Incoming
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>HTTP/8080"| SparkOp
    Prometheus -->|"scrapes JMX<br/>HTTP/8090"| SparkPods["Spark Pods<br/>(driver/executor)"]

    %% Integration Points - Created Resources
    SparkOp -->|"creates via<br/>spark-submit"| SparkPods
    SparkOp -->|"creates<br/>web UI service"| WebUI["Web UI<br/>4040/TCP"]
    SparkOp -->|"creates<br/>optional"| Ingress["Ingress<br/>HTTP/HTTPS"]
    SparkOp -->|"creates<br/>SparkConnect server"| ConnectSvc["SparkConnect<br/>15002/TCP gRPC"]
    SparkOp -->|"validates quota<br/>HTTPS/443"| ResourceQuota["ResourceQuota<br/>(optional)"]

    %% Webhook ↔ API Server
    K8sAPI -->|"admission reviews<br/>HTTPS/9443"| SparkOp

    %% Styling
    style SparkOp fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Spark fill:#999,stroke:#333,color:#fff
    style Java17 fill:#999,stroke:#333,color:#fff
    style PySpark fill:#999,stroke:#333,color:#fff

    %% Optional external
    style CertManager fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style Volcano fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style YuniKorn fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000
    style KubeSched fill:#bbb,stroke:#333,stroke-dasharray: 5 5,color:#000

    %% Internal platform
    style RhodsOp fill:#9b59b6,stroke:#333,color:#fff

    %% Monitoring
    style Prometheus fill:#e8e8e8,stroke:#333,color:#000

    %% Managed resources
    style SparkPods fill:#7ed321,stroke:#333,color:#000
    style WebUI fill:#7ed321,stroke:#333,color:#000
    style Ingress fill:#7ed321,stroke:#333,color:#000
    style ConnectSvc fill:#7ed321,stroke:#333,color:#000
    style ResourceQuota fill:#f5a623,stroke:#333,color:#000
