graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        RESTClient["REST Client"]
        GRPCClient["gRPC Client"]
    end

    subgraph MeshLayer["SERVICE MESH (Istio mTLS)"]
        IstioSidecar["Istio Envoy Sidecar<br/>TLS Termination<br/>mTLS between services<br/>SPIFFE Identity"]
    end

    subgraph OVMSContainer["OVMS CONTAINER (UID 5000, UBI 9 Minimal)"]
        direction TB

        subgraph Servers["Server Layer (No TLS)"]
            DrogonHTTP["Drogon HTTP Server<br/>0.0.0.0:REST_PORT<br/>HTTP plaintext<br/>API Key (optional)"]
            GRPCServer["gRPC Server<br/>0.0.0.0:GRPC_PORT<br/>InsecureServerCredentials<br/>No auth"]
            Metrics["Prometheus Metrics<br/>/metrics<br/>No auth"]
        end

        subgraph APIs["API Endpoints"]
            TFSv1["/v1 TFS<br/>predict, classify, regress"]
            KServev2["/v2 KServe<br/>infer, ready, health"]
            OpenAIv1["/v1 OpenAI<br/>chat/completions<br/>embeddings, tokenize"]
            Cohere["/v1 Cohere<br/>rerankings"]
            ImageGen["/v3 ImageGen<br/>generations, edits"]
        end

        subgraph Engine["Inference Engine (In-Process)"]
            Runtime["OpenVINO Runtime 2026.0<br/>CPU / GPU / NPU"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["AWS S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: AWS IAM"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: Azure SDK"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: GCS SA"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: HF Token (optional)"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        KServe["KServe<br/>InferenceService<br/>KServe v2 Protocol"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% External to Mesh
    RESTClient -->|"HTTPS/443<br/>TLS (Istio-terminated)"| IstioSidecar
    GRPCClient -->|"gRPC over TLS/443<br/>TLS (Istio-terminated)"| IstioSidecar

    %% Mesh to OVMS (plaintext - localhost)
    IstioSidecar -->|"HTTP plaintext<br/>REST_PORT<br/>localhost loopback"| DrogonHTTP
    IstioSidecar -->|"gRPC/HTTP2 plaintext<br/>GRPC_PORT<br/>InsecureCredentials"| GRPCServer

    %% Server to APIs
    DrogonHTTP --> TFSv1
    DrogonHTTP --> KServev2
    DrogonHTTP --> OpenAIv1
    DrogonHTTP --> Cohere
    DrogonHTTP --> ImageGen
    GRPCServer --> TFSv1
    GRPCServer --> KServev2

    %% APIs to Engine
    TFSv1 --> Runtime
    KServev2 --> Runtime
    OpenAIv1 --> Runtime
    Cohere --> Runtime
    ImageGen --> Runtime

    %% Egress
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM creds"| S3
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure SDK creds"| Azure
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>GCS SA creds"| GCS
    Runtime -->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    %% Platform integration
    KServe -->|"KServe v2<br/>gRPC + REST"| IstioSidecar
    Prometheus -->|"HTTP scrape<br/>/metrics<br/>No auth"| Metrics

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef mesh fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef server fill:#4a90e2,stroke:#333,color:#fff
    classDef noauth fill:#ff6b6b,stroke:#c92a2a,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px

    class RESTClient,GRPCClient external
    class IstioSidecar mesh
    class DrogonHTTP,Metrics server
    class GRPCServer noauth
    class S3,Azure,GCS,HFHub externalservice
    class KServe,Prometheus platform
