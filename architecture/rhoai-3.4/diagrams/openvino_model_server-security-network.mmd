graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Pod["POD BOUNDARY (KServe InferenceService Pod)"]
        direction TB

        KubeRBAC["kube-rbac-proxy Sidecar<br/>8443/TCP<br/>TLS 1.2+ Termination<br/>Platform Bearer Token Auth"]

        subgraph OVMSContainer["OVMS Container"]
            direction TB
            RESTServer["REST Server (Drogon)<br/>REST port/TCP<br/>HTTP Plaintext<br/>No built-in TLS"]
            GRPCServer["gRPC Server<br/>gRPC port/TCP<br/>InsecureServerCredentials<br/>No built-in TLS"]

            subgraph V3Auth["V3 Endpoints (Optional Auth)"]
                V3["OpenAI-Compatible API<br/>/v3/chat/completions<br/>/v3/embeddings<br/>/v3/rerank<br/>Bearer API key (--api_key_file)"]
            end

            subgraph NoAuth["V1/V2 Endpoints (No App Auth)"]
                V1V2["/v1/* TFS v1<br/>/v2/* KServe v2<br/>/metrics Prometheus<br/>Relies on platform auth"]
            end

            RESTServer --- V3Auth
            RESTServer --- NoAuth
        end

        KubeRBAC -->|"HTTP (localhost)<br/>No encryption<br/>No auth"| RESTServer
    end

    subgraph Platform["PLATFORM SERVICES (Internal)"]
        KServe["KServe Controller<br/>Pod lifecycle & scaling"]
        Operator["RHOAI Operator<br/>ServingRuntime CR"]
        Prometheus["Prometheus<br/>Metrics scraping"]
    end

    subgraph EgressServices["EGRESS - EXTERNAL SERVICES"]
        S3["Amazon S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>OAuth2/SA"]
        Azure["Azure Blob Storage<br/>*.blob.core.windows.net<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Managed Identity"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN Bearer"]
    end

    %% Flows
    Client -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| KubeRBAC

    KServe -.->|"manages pod"| Pod
    Operator -.->|"configures"| Pod
    Prometheus -->|"HTTP scrape<br/>/metrics"| RESTServer

    RESTServer -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    RESTServer -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth2"| GCS
    RESTServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure MI"| Azure
    RESTServer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef pod fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef proxy fill:#ffe0b2,stroke:#e65100,stroke-width:2px
    classDef ovms fill:#bbdefb,stroke:#1565c0,stroke-width:2px
    classDef authzone fill:#c8e6c9,stroke:#2e7d32,stroke-width:1px
    classDef noauthzone fill:#ffcdd2,stroke:#c62828,stroke-width:1px
    classDef platform fill:#e8eaf6,stroke:#283593,stroke-width:2px
    classDef egress fill:#fff9c4,stroke:#f57f17,stroke-width:2px

    class Client external
    class KubeRBAC proxy
    class RESTServer,GRPCServer ovms
    class V3 authzone
    class V1V2 noauthzone
    class KServe,Operator,Prometheus platform
    class S3,GCS,Azure,HFHub egress
