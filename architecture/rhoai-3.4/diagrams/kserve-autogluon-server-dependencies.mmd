graph LR
    AutoGluon["KServe AutoGluon Server<br/>(autogluonserver)"]

    %% Internal Platform Dependencies
    AutoGluon -->|"CRD watch<br/>ClusterServingRuntime"| KServeCtrl["KServe Controller"]
    AutoGluon -->|"init container<br/>model download"| StorageInit["Storage Initializer<br/>kserve-storage 0.17.0"]
    AutoGluon -->|"HTTP reverse proxy<br/>8080/TCP"| KServeIngress["KServe Ingress<br/>Gateway / Route"]

    %% Core Framework Dependencies
    AutoGluon -->|"model server framework"| KServeSDK["KServe SDK 0.17.0<br/>(ModelServer, Model)"]
    KServeSDK -->|"HTTP framework"| FastAPI["FastAPI 0.135.3"]
    KServeSDK -->|"ASGI server"| Uvicorn["Uvicorn 0.44.0"]
    KServeSDK -->|"gRPC runtime"| gRPC["grpcio 1.80.0"]

    %% ML Framework Dependencies
    AutoGluon -->|"tabular inference"| AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
    AutoGluon -->|"timeseries inference"| AGTimeseries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]
    AGTabular -->|"deep learning backend"| PyTorch["torch 2.10.0"]
    AGTabular -->|"gradient boosting"| LightGBM["LightGBM 4.6.0"]
    AGTabular -->|"gradient boosting"| XGBoost["XGBoost 3.1.3"]
    AGTabular -->|"ML algorithms"| Sklearn["scikit-learn 1.7.2"]
    AGTimeseries -->|"Chronos models"| Transformers["transformers 4.57.6"]

    %% External Service Dependencies
    StorageInit -->|"HTTPS/443"| S3["S3-Compatible Storage"]
    StorageInit -->|"HTTPS/443"| HFHub["HuggingFace Hub"]
    StorageInit -->|"HTTPS/443"| GitRepos["Git Repositories"]

    %% Monitoring
    Prometheus["Prometheus"] -->|"scrapes /metrics<br/>8080/TCP"| AutoGluon

    %% Styling
    style AutoGluon fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI components (green)
    style KServeCtrl fill:#7ed321,stroke:#333,color:#fff
    style StorageInit fill:#7ed321,stroke:#333,color:#fff
    style KServeIngress fill:#7ed321,stroke:#333,color:#fff

    %% Core framework (blue)
    style KServeSDK fill:#5b9bd5,stroke:#333,color:#fff
    style FastAPI fill:#5b9bd5,stroke:#333,color:#fff
    style Uvicorn fill:#5b9bd5,stroke:#333,color:#fff
    style gRPC fill:#5b9bd5,stroke:#333,color:#fff

    %% ML frameworks (purple)
    style AGTabular fill:#9b59b6,stroke:#333,color:#fff
    style AGTimeseries fill:#9b59b6,stroke:#333,color:#fff
    style PyTorch fill:#c39bd3,stroke:#333,color:#fff
    style LightGBM fill:#c39bd3,stroke:#333,color:#fff
    style XGBoost fill:#c39bd3,stroke:#333,color:#fff
    style Sklearn fill:#c39bd3,stroke:#333,color:#fff
    style Transformers fill:#c39bd3,stroke:#333,color:#fff

    %% External services (orange)
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#f5a623,stroke:#333,color:#fff
    style GitRepos fill:#f5a623,stroke:#333,color:#fff

    %% Monitoring (gray)
    style Prometheus fill:#999,stroke:#333,color:#fff
