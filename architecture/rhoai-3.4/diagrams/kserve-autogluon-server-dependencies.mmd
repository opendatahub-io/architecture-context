graph LR
    AGServer["KServe AutoGluon Server<br/>(autogluonserver)"]

    %% ML Framework Dependencies
    subgraph ML["ML Frameworks"]
        AGTabular["autogluon.tabular<br/>1.5.0+rhaiv.2"]
        AGTimeseries["autogluon.timeseries<br/>1.5.0+rhaiv.2"]
        LightGBM["lightgbm<br/>4.6.0"]
        XGBoost["xgboost<br/>3.1.3"]
        PyTorch["torch<br/>2.10.0"]
        Transformers["transformers<br/>4.57.6"]
    end

    %% KServe SDK Dependencies
    subgraph KServeDeps["KServe SDK Stack"]
        KServeSDK["kserve SDK<br/>0.17.0"]
        FastAPI["fastapi<br/>0.135.3"]
        Uvicorn["uvicorn<br/>0.44.0"]
        GRPC["grpcio<br/>1.80.0"]
        PromClient["prometheus-client<br/>0.25.0"]
    end

    %% Data Processing
    subgraph DataProc["Data Processing"]
        Pandas["pandas<br/>2.3.3"]
        NumPy["numpy<br/>2.1.3"]
    end

    %% Infrastructure Libraries
    subgraph InfraLibs["Infrastructure"]
        Boto3["boto3<br/>1.42.87"]
        K8sClient["kubernetes<br/>35.0.0"]
        Crypto["cryptography<br/>46.0.7"]
    end

    %% Internal Platform Dependencies
    subgraph Platform["RHOAI Platform (Internal)"]
        KServeCtrl["KServe Controller<br/>CRD Watch"]
        StorageInit["Storage Initializer<br/>Init Container"]
        KubeRBAC["kube-rbac-proxy<br/>Auth Sidecar"]
    end

    %% Integration Points
    subgraph Integrations["Integrates With"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% External Services
    subgraph ExtServices["External Services"]
        S3["S3 Storage"]
        GCS["Google Cloud Storage"]
        AzureBlob["Azure Blob Storage"]
        HFHub["Hugging Face Hub"]
    end

    %% Server → ML Framework connections
    AGServer -->|"tabular inference"| AGTabular
    AGServer -->|"time series inference"| AGTimeseries
    AGTabular -->|"gradient boosting"| LightGBM
    AGTabular -->|"gradient boosting"| XGBoost
    AGTimeseries -->|"deep learning / Chronos"| PyTorch
    AGTimeseries -->|"Chronos tokenizer"| Transformers

    %% Server → KServe SDK connections
    AGServer -->|"ModelServer runtime"| KServeSDK
    KServeSDK -->|"HTTP server"| FastAPI
    KServeSDK -->|"ASGI server"| Uvicorn
    KServeSDK -->|"gRPC server"| GRPC
    KServeSDK -->|"metrics"| PromClient

    %% Server → Data Processing
    AGServer -->|"DataFrame ops"| Pandas
    AGServer -->|"array ops"| NumPy

    %% Server → Infrastructure
    KServeSDK -->|"model download"| Boto3
    KServeSDK -->|"K8s API"| K8sClient
    KServeSDK -->|"TLS/crypto"| Crypto

    %% Platform connections
    KServeCtrl -->|"creates pods"| AGServer
    StorageInit -->|"downloads models"| AGServer
    KubeRBAC -->|"auth proxy"| AGServer

    %% Integration connections
    Prometheus -->|"scrapes /metrics"| AGServer

    %% External service connections
    StorageInit -->|"HTTPS/443"| S3
    StorageInit -->|"HTTPS/443"| GCS
    StorageInit -->|"HTTPS/443"| AzureBlob
    AGServer -.->|"HTTPS/443 optional"| HFHub

