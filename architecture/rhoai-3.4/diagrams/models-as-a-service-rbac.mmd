graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>NS: opendatahub"]
        SA_API["maas-api<br/>NS: opendatahub"]
        SA_PayloadProc["payload-processing<br/>NS: openshift-ingress"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-rolebinding<br/>(cluster-scoped)"]
        CRB_LeaderElection["maas-controller-leader-election-rolebinding<br/>(NS: opendatahub)"]
        CRB_API["maas-api-rolebinding<br/>(cluster-scoped)"]
        CRB_APISupp["maas-api-supplemental-rolebinding<br/>(cluster-scoped)"]
        CRB_PayloadProc["payload-processing-rolebinding<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["maas-controller-role"]
        CR_LeaderElection["maas-controller-leader-election-role"]
        CR_API["maas-api"]
        CR_APISupp["maas-api-supplemental"]
        CR_PayloadProc["payload-processing-reader"]
        CR_Owner["maas-owner-role<br/>(aggregated)"]
        CR_Viewer["maas-viewer-role<br/>(aggregated)"]
    end

    subgraph ControllerResources["maas-controller-role Resources"]
        direction TB
        MaaSCRDs["maas.opendatahub.io<br/>tenants, maasmodelrefs,<br/>maasauthpolicies,<br/>maassubscriptions,<br/>externalmodels<br/>+ status + finalizers"]
        KuadrantCRDs["kuadrant.io<br/>authpolicies,<br/>tokenratelimitpolicies,<br/>ratelimitpolicies"]
        GatewayRes["gateway.networking.k8s.io<br/>gateways (read-only)<br/>httproutes (full CRUD)"]
        IstioRes["networking.istio.io<br/>serviceentries,<br/>destinationrules,<br/>envoyfilters"]
        TelemetryRes["telemetry.istio.io<br/>telemetries<br/>extensions.kuadrant.io<br/>telemetrypolicies"]
        CoreRes["core<br/>configmaps, serviceaccounts,<br/>services, namespaces, secrets"]
        AppsRes["apps: deployments<br/>batch: cronjobs<br/>networking.k8s.io: networkpolicies"]
        RBACRes["rbac.authorization.k8s.io<br/>clusterroles,<br/>clusterrolebindings"]
        AuthRes["authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews<br/>apiextensions.k8s.io: CRDs (read-only)"]
        PersesRes["perses.dev<br/>persesdashboards,<br/>persesdatasources"]
    end

    subgraph APIResources["maas-api Resources"]
        direction TB
        APISecrets["core: secrets<br/>(resourceNames: maas-db-config)<br/>Verbs: get"]
        APINSRes["core: namespaces, serviceaccounts<br/>Verbs: create, list, watch, delete"]
        APITokenRes["core: serviceaccounts/token<br/>Verbs: create"]
        APIAuthRes["authentication.k8s.io: tokenreviews<br/>authorization.k8s.io: subjectaccessreviews<br/>Verbs: create"]
        APIMaaSRes["maas.opendatahub.io<br/>maasmodelrefs, maassubscriptions<br/>Verbs: get, list, watch"]
        APIGWRes["gateway.networking.k8s.io: httproutes<br/>core: pods, services, endpoints<br/>Verbs: get, list, watch"]
    end

    subgraph PayloadProcResources["payload-processing-reader Resources"]
        PPConfigMaps["core: configmaps<br/>Verbs: get, list, watch"]
        PPSecrets["core: secrets<br/>Verbs: get, list, watch"]
        PPExtModels["maas.opendatahub.io: externalmodels<br/>Verbs: get, list, watch"]
    end

    subgraph UserRoles["Aggregated User Roles"]
        OwnerRes["maas-owner-role<br/>maasmodelrefs, externalmodels<br/>Verbs: full CRUD"]
        ViewerRes["maas-viewer-role<br/>maasmodelrefs, externalmodels<br/>Verbs: get, list, watch"]
    end

    %% SA to CRB
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_APISupp
    SA_PayloadProc -->|bound via| CRB_PayloadProc

    %% CRB to CR
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_API -->|grants| CR_API
    CRB_APISupp -->|grants| CR_APISupp
    CRB_PayloadProc -->|grants| CR_PayloadProc

    %% CR to Resources
    CR_Controller -->|full CRUD| MaaSCRDs
    CR_Controller -->|full CRUD| KuadrantCRDs
    CR_Controller -->|read + CRUD| GatewayRes
    CR_Controller -->|full CRUD| IstioRes
    CR_Controller -->|full CRUD| TelemetryRes
    CR_Controller -->|full CRUD| CoreRes
    CR_Controller -->|full CRUD| AppsRes
    CR_Controller -->|full CRUD| RBACRes
    CR_Controller -->|create + read| AuthRes
    CR_Controller -->|full CRUD| PersesRes

    CR_API -->|get| APISecrets
    CR_API -->|CRUD| APINSRes
    CR_API -->|create| APITokenRes
    CR_API -->|create| APIAuthRes
    CR_API -->|read| APIMaaSRes
    CR_API -->|read| APIGWRes

    CR_PayloadProc -->|read| PPConfigMaps
    CR_PayloadProc -->|read| PPSecrets
    CR_PayloadProc -->|read| PPExtModels

    CR_Owner -->|full CRUD| OwnerRes
    CR_Viewer -->|read| ViewerRes

    %% Styles
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_API fill:#4a90e2,stroke:#333,color:#fff
    style SA_PayloadProc fill:#4a90e2,stroke:#333,color:#fff
    style CR_Controller fill:#f5a623,stroke:#333
    style CR_LeaderElection fill:#f5a623,stroke:#333
    style CR_API fill:#f5a623,stroke:#333
    style CR_APISupp fill:#f5a623,stroke:#333
    style CR_PayloadProc fill:#f5a623,stroke:#333
    style CR_Owner fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style MaaSCRDs fill:#7ed321,stroke:#333
    style KuadrantCRDs fill:#7ed321,stroke:#333
    style GatewayRes fill:#7ed321,stroke:#333
    style IstioRes fill:#7ed321,stroke:#333
    style TelemetryRes fill:#7ed321,stroke:#333
    style CoreRes fill:#7ed321,stroke:#333
    style AppsRes fill:#7ed321,stroke:#333
    style RBACRes fill:#7ed321,stroke:#333
    style AuthRes fill:#7ed321,stroke:#333
    style PersesRes fill:#7ed321,stroke:#333
    style APISecrets fill:#d5e8d4,stroke:#333
    style APINSRes fill:#d5e8d4,stroke:#333
    style APITokenRes fill:#d5e8d4,stroke:#333
    style APIAuthRes fill:#d5e8d4,stroke:#333
    style APIMaaSRes fill:#d5e8d4,stroke:#333
    style APIGWRes fill:#d5e8d4,stroke:#333
    style PPConfigMaps fill:#e8e8e8,stroke:#333
    style PPSecrets fill:#e8e8e8,stroke:#333
    style PPExtModels fill:#e8e8e8,stroke:#333
    style OwnerRes fill:#fff2cc,stroke:#333
    style ViewerRes fill:#fff2cc,stroke:#333
