graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["maas-controller<br/>NS: opendatahub"]
        SA_API["maas-api<br/>NS: (app-namespace)"]
        SA_PayloadProc["payload-processing<br/>NS: openshift-ingress"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Controller["maas-controller-rolebinding<br/>(cluster-scoped)"]
        CRB_API["maas-api<br/>(cluster-scoped)"]
        CRB_API_Supp["maas-api-supplemental<br/>(cluster-scoped)"]
        CRB_PayloadProc["payload-processing-reader<br/>(cluster-scoped)"]
        RB_LeaderElect["maas-controller-leader-election<br/>(NS: opendatahub)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Controller["maas-controller-role"]
        CR_API["maas-api"]
        CR_API_Supp["maas-api-supplemental"]
        CR_PayloadProc["payload-processing-reader"]
        CR_LeaderElect["maas-controller-leader-election-role"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_LeaderElect
    SA_API -->|bound via| CRB_API
    SA_API -->|bound via| CRB_API_Supp
    SA_PayloadProc -->|bound via| CRB_PayloadProc

    CRB_Controller -->|grants| CR_Controller
    CRB_API -->|grants| CR_API
    CRB_API_Supp -->|grants| CR_API_Supp
    CRB_PayloadProc -->|grants| CR_PayloadProc
    RB_LeaderElect -->|grants| CR_LeaderElect

    subgraph ControllerResources["maas-controller-role Resources"]
        direction LR
        MaasCRDs["maas.opendatahub.io<br/>tenants, externalmodels,<br/>maasmodelrefs, maasauthpolicies,<br/>maassubscriptions<br/>(+/status, /finalizers)<br/>full CRUD"]
        KuadrantCRDs["kuadrant.io<br/>authpolicies,<br/>tokenratelimitpolicies,<br/>ratelimitpolicies<br/>full CRUD"]
        GatewayAPICRDs["gateway.networking.k8s.io<br/>httproutes (+/finalizers),<br/>gateways<br/>full CRUD"]
        IstioCRDs["networking.istio.io<br/>serviceentries,<br/>destinationrules,<br/>envoyfilters<br/>full CRUD"]
        CoreResources["core ('')<br/>configmaps, services,<br/>deployments, namespaces,<br/>secrets, pods, sa, endpoints<br/>full CRUD"]
        RBACResources["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings,<br/>roles, rolebindings<br/>full CRUD"]
        KServeCRDs["serving.kserve.io<br/>llminferenceservices<br/>get, list, watch"]
        AuthzResources["authentication.k8s.io<br/>tokenreviews (create)<br/>authorization.k8s.io<br/>subjectaccessreviews (create)"]
        OSResources["config.openshift.io<br/>authentications (get)<br/>apiextensions.k8s.io<br/>CRDs (get, list, watch)"]
        PersesCRDs["perses.dev<br/>persesdashboards,<br/>persesdatasources<br/>full CRUD"]
    end

    CR_Controller -->|access| MaasCRDs
    CR_Controller -->|access| KuadrantCRDs
    CR_Controller -->|access| GatewayAPICRDs
    CR_Controller -->|access| IstioCRDs
    CR_Controller -->|access| CoreResources
    CR_Controller -->|access| RBACResources
    CR_Controller -->|access| KServeCRDs
    CR_Controller -->|access| AuthzResources
    CR_Controller -->|access| OSResources
    CR_Controller -->|access| PersesCRDs

    subgraph APIResources["maas-api Resources"]
        direction LR
        APISecrets["core<br/>secrets (maas-db-config),<br/>serviceaccounts,<br/>serviceaccounts/token<br/>get, list, watch,<br/>create, delete"]
        APIAuthz["authentication.k8s.io<br/>tokenreviews (create)<br/>authorization.k8s.io<br/>subjectaccessreviews (create)"]
        APIMaaS["maas.opendatahub.io<br/>maasmodelrefs,<br/>maassubscriptions<br/>get, list, watch"]
        APIGateway["gateway.networking.k8s.io<br/>httproutes<br/>get, list, watch"]
    end

    CR_API -->|access| APISecrets
    CR_API -->|access| APIAuthz
    CR_API -->|access| APIMaaS
    CR_API -->|access| APIGateway

    subgraph PayloadProcResources["payload-processing-reader Resources"]
        direction LR
        PPConfigMaps["core<br/>configmaps, secrets<br/>get, list, watch"]
        PPExternalModels["maas.opendatahub.io<br/>externalmodels<br/>get, list, watch"]
    end

    CR_PayloadProc -->|access| PPConfigMaps
    CR_PayloadProc -->|access| PPExternalModels

    subgraph AggregatedRoles["Aggregated Roles (Label-based)"]
        MaaSOwner["maas-owner-role<br/>→ aggregated into: admin, edit<br/>maasmodelrefs, externalmodels<br/>full CRUD"]
        MaaSViewer["maas-viewer-role<br/>→ aggregated into: view, admin, edit<br/>maasmodelrefs, externalmodels<br/>get, list, watch"]
    end

    %% Styling
    style SA_Controller fill:#4a90e2,color:#fff
    style SA_API fill:#50a0d2,color:#fff
    style SA_PayloadProc fill:#6ab0e2,color:#fff

    style CR_Controller fill:#f5a623,color:#fff
    style CR_API fill:#f5a623,color:#fff
    style CR_API_Supp fill:#f5a623,color:#fff
    style CR_PayloadProc fill:#f5a623,color:#fff
    style CR_LeaderElect fill:#f5a623,color:#fff

    style MaasCRDs fill:#7ed321,color:#fff
    style KuadrantCRDs fill:#7ed321,color:#fff
    style GatewayAPICRDs fill:#7ed321,color:#fff
    style IstioCRDs fill:#7ed321,color:#fff
    style CoreResources fill:#7ed321,color:#fff
    style RBACResources fill:#7ed321,color:#fff
    style KServeCRDs fill:#7ed321,color:#fff
    style AuthzResources fill:#7ed321,color:#fff
    style OSResources fill:#7ed321,color:#fff
    style PersesCRDs fill:#7ed321,color:#fff

    style APISecrets fill:#7ed321,color:#fff
    style APIAuthz fill:#7ed321,color:#fff
    style APIMaaS fill:#7ed321,color:#fff
    style APIGateway fill:#7ed321,color:#fff

    style PPConfigMaps fill:#7ed321,color:#fff
    style PPExternalModels fill:#7ed321,color:#fff

    style MaaSOwner fill:#d5e8d4,color:#333
    style MaaSViewer fill:#d5e8d4,color:#333
