graph TD
    subgraph "RBAC Configuration"
        direction TB
        Note["No RBAC manifests defined in this repository.<br/>RBAC is managed by the consuming deployment<br/>(e.g., TrustyAI Operator or platform operator)."]
    end

    subgraph "Authentication Flow"
        direction TB
        Client["Client"] -->|"Authorization header<br/>X-Forwarded-* headers"| Gateway["vllm-orchestrator-gateway<br/>8090/TCP"]
        Gateway -->|"Headers forwarded<br/>(no local enforcement)"| Orchestrator["FMS Guardrails Orchestrator<br/>8085/TCP"]
    end

    subgraph "TLS Identity (mTLS)"
        direction TB
        SA["ServiceAccount<br/>(defined by consuming operator)"]
        TLSSecret["TLS Secret<br/>/etc/tls/private/tls.crt<br/>/etc/tls/private/tls.key<br/>Provisioned by: cert-manager<br/>or service-serving-cert"]
        CASecret["CA ConfigMap<br/>/etc/tls/ca/service-ca.crt<br/>Provisioned by: service-ca-operator"]

        SA -.->|"pod identity"| Gateway2["vllm-orchestrator-gateway Pod"]
        TLSSecret -.->|"volume mount<br/>client cert for mTLS"| Gateway2
        CASecret -.->|"volume mount<br/>CA trust chain"| Gateway2
    end

    subgraph "Expected External RBAC (not in repo)"
        direction TB
        ExtSA["ServiceAccount<br/>(created by TrustyAI Operator)"]
        ExtRole["Role/ClusterRole<br/>(created by platform operator)"]
        ExtRB["RoleBinding<br/>(created by platform operator)"]

        ExtSA -->|"bound via"| ExtRB
        ExtRB -->|"grants"| ExtRole

        subgraph "Expected Permissions"
            ConfigMap["core/ConfigMaps<br/>(config mount)"]
            Secrets["core/Secrets<br/>(TLS certs)"]
        end

        ExtRole -->|"get, watch"| ConfigMap
        ExtRole -->|"get, watch"| Secrets
    end

    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style Client fill:#f9f9f9,stroke:#333
    style Gateway fill:#4a90e2,stroke:#333,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style SA fill:#dae8fc,stroke:#6c8ebf
    style TLSSecret fill:#fff2cc,stroke:#d6b656
    style CASecret fill:#fff2cc,stroke:#d6b656
    style Gateway2 fill:#4a90e2,stroke:#333,color:#fff
    style ExtSA fill:#e8e8e8,stroke:#999
    style ExtRole fill:#e8e8e8,stroke:#999
    style ExtRB fill:#e8e8e8,stroke:#999
    style ConfigMap fill:#e8e8e8,stroke:#999
    style Secrets fill:#e8e8e8,stroke:#999
