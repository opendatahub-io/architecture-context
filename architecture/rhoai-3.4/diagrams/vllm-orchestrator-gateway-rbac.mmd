graph TD
    subgraph "vllm-orchestrator-gateway RBAC"
        direction TB

        Note["ℹ No Kubernetes RBAC Defined<br/>This component has no ClusterRoles,<br/>Roles, or RoleBindings"]

        subgraph "Authentication Model"
            AuthNote["Gateway does NOT enforce authentication<br/>Authorization header is passed through<br/>to the FMS Guardrails Orchestrator"]
        end

        subgraph "Security Boundary"
            SB1["No Kubernetes API access required"]
            SB2["No ServiceAccount with elevated permissions"]
            SB3["Must be protected by upstream infrastructure"]
        end

        subgraph "Recommended Production Controls"
            RC1["Network Policies<br/>Restrict ingress to authorized pods"]
            RC2["kube-rbac-proxy sidecar<br/>Add authentication at gateway"]
            RC3["Service Mesh (Istio/OSSM)<br/>mTLS + AuthorizationPolicy"]
        end
    end

    subgraph "mTLS Identity (Optional)"
        ClientCert["Client Certificate<br/>/etc/tls/private/tls.crt<br/>Volume mount"]
        ClientKey["Client Private Key<br/>/etc/tls/private/tls.key<br/>Volume mount"]
        CACert["CA Certificate<br/>/etc/tls/ca/service-ca.crt<br/>Volume mount (service-ca)"]
    end

    Note --> AuthNote
    AuthNote --> SB1
    SB1 --> SB2
    SB2 --> SB3
    SB3 --> RC1
    SB3 --> RC2
    SB3 --> RC3

    style Note fill:#fff3cd,stroke:#856404,color:#856404,stroke-width:2px
    style AuthNote fill:#f8d7da,stroke:#721c24,color:#721c24
    style SB1 fill:#d4edda,stroke:#155724,color:#155724
    style SB2 fill:#d4edda,stroke:#155724,color:#155724
    style SB3 fill:#f8d7da,stroke:#721c24,color:#721c24
    style RC1 fill:#cce5ff,stroke:#004085,color:#004085
    style RC2 fill:#cce5ff,stroke:#004085,color:#004085
    style RC3 fill:#cce5ff,stroke:#004085,color:#004085
    style ClientCert fill:#e1d5e7,stroke:#9673a6
    style ClientKey fill:#e1d5e7,stroke:#9673a6
    style CACert fill:#e1d5e7,stroke:#9673a6
