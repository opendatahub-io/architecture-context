// C4 Context Diagram - Data Science Pipelines Operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and manages ML pipelines via Dashboard or CLI"
        admin = person "Platform Admin" "Deploys and configures DSPA instances"

        dspo = softwareSystem "Data Science Pipelines Operator" "Kubernetes operator managing full lifecycle of Kubeflow Pipelines v2 infrastructure on OpenShift" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, reconciles all DSP sub-components via template rendering" "Go Operator (controller-runtime)"
            webhook = container "Webhook Server" "Validates/mutates PipelineVersion CRs" "Go Webhook"
            apiServer = container "DSP API Server" "Kubeflow Pipelines v2 REST/gRPC endpoint" "Go Service" {
                tags "PerDSPA"
            }
            kubeRbacProxy = container "kube-rbac-proxy" "TLS termination and RBAC enforcement" "Sidecar" {
                tags "PerDSPA"
            }
            workflowCtrl = container "Argo Workflow Controller" "Orchestrates pipeline step execution" "Go Controller" {
                tags "PerDSPA"
            }
            scheduledWF = container "Scheduled Workflow" "Manages cron-scheduled pipeline runs" "Go Controller" {
                tags "PerDSPA"
            }
            persistAgent = container "Persistence Agent" "Syncs pipeline run status to database" "Go Service" {
                tags "PerDSPA"
            }
            mlmdGrpc = container "MLMD gRPC Server" "ML Metadata gRPC for artifact/execution lineage" "Go/C++ Service" {
                tags "PerDSPA"
            }
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD gRPC" "Envoy" {
                tags "PerDSPA"
            }
            mariadb = container "MariaDB" "Relational database for pipeline metadata" "MariaDB" {
                tags "PerDSPA"
            }
            minio = container "Minio" "S3-compatible object storage for artifacts" "Minio" {
                tags "PerDSPA"
            }
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys DSPO via kustomize overlay" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for pipeline management" "Internal RHOAI"
        serviceCa = softwareSystem "OpenShift service-ca" "Automatic TLS certificate provisioning" "OpenShift Platform"
        router = softwareSystem "OpenShift Router" "Ingress routing with TLS termination" "OpenShift Platform"
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API server" "OpenShift Platform"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "OpenShift Platform"
        kserve = softwareSystem "KServe" "ML model serving platform" "Internal RHOAI"
        ray = softwareSystem "Ray (KubeRay)" "Distributed computing framework" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare" "Distributed workload orchestration" "Internal RHOAI"
        extS3 = softwareSystem "External S3 Storage" "Production artifact storage" "External"
        extDB = softwareSystem "External SQL Database" "Production metadata database" "External"

        // Relationships
        admin -> dspo "Creates DSPA CRs via kubectl/Dashboard"
        user -> odhDashboard "Manages pipelines via UI"
        odhDashboard -> dspo "REST/gRPC API calls" "HTTPS/8443"

        rhodsOperator -> dspo "Deploys via kustomize" "Kubernetes API"
        dspo -> k8sApi "CR operations, SAR checks, pod management" "HTTPS/443"
        dspo -> serviceCa "TLS certificate injection" "Annotations"
        dspo -> router "Creates Routes for external access" "Kubernetes API"

        controller -> apiServer "Reconciles deployment"
        controller -> workflowCtrl "Reconciles deployment"
        controller -> mariadb "Health checks" "MySQL/3306"
        controller -> minio "Health checks" "S3/9000"

        user -> router "Pipeline API access" "HTTPS/443"
        router -> kubeRbacProxy "TLS reencrypt" "HTTPS/8443"
        kubeRbacProxy -> apiServer "Proxied requests" "HTTP(S)/8888"

        apiServer -> mariadb "Metadata storage" "MySQL/3306"
        apiServer -> minio "Artifact storage" "S3/9000"
        mlmdGrpc -> mariadb "Lineage storage" "MySQL/3306"
        mlmdEnvoy -> mlmdGrpc "Proxy" "gRPC/8080"
        persistAgent -> apiServer "Status sync" "HTTP(S)/8888"

        workflowCtrl -> kserve "Pipeline tasks create InferenceServices" "Kubernetes API"
        workflowCtrl -> ray "Pipeline tasks create RayClusters/Jobs" "Kubernetes API"
        workflowCtrl -> codeflare "Pipeline tasks create AppWrappers" "Kubernetes API"

        dspo -> extS3 "Production artifact storage" "HTTPS/443"
        dspo -> extDB "Production metadata storage" "MySQL/3306"
        prometheus -> dspo "Scrapes metrics" "HTTP/8080"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "OpenShift Platform" {
                background #e8744f
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "PerDSPA" {
                background #85bbf0
                color #000000
            }
        }
    }
}
