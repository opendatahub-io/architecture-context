graph LR
    ODHCLI["odh-cli<br/>(kubectl-odh / rhai-cli)"]

    %% External Dependencies (Required)
    ODHCLI -->|"all operations<br/>6443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v1.28+"]
    ODHCLI -->|"platform validation<br/>6443/TCP HTTPS"| OpenShift["OpenShift<br/>4.19.9+"]

    %% External Dependencies (Optional)
    ODHCLI -.->|"operator detection<br/>6443/TCP HTTPS"| OLM["OLM<br/>v0.40+<br/>(optional)"]

    %% Internal RHOAI Platform Dependencies
    ODHCLI -->|"component states<br/>singleton GET"| DSC["DataScienceCluster"]
    ODHCLI -->|"platform init state<br/>singleton GET"| DSCI["DSCInitialization"]
    ODHCLI -->|"version detection<br/>CSV LIST"| RhodsOperator["rhods-operator CSV"]

    %% Dependency Validation Targets
    ODHCLI -->|"validates installation"| CertManager["cert-manager<br/>Operator"]
    ODHCLI -->|"validates availability"| ServiceMeshV3["Service Mesh v3<br/>Operator"]
    ODHCLI -.->|"detects deprecated"| ServiceMeshV2["Service Mesh v2<br/>(deprecated)"]
    ODHCLI -->|"extracts Gateway API<br/>version/channel"| IngressOperator["Ingress Operator"]

    %% Workload Inspection Targets
    ODHCLI -->|"inspects workloads"| Notebooks["Notebook Controller"]
    ODHCLI -->|"inspects InferenceServices"| KServe["KServe"]
    ODHCLI -->|"inspects DSPAs"| Pipelines["Data Science Pipelines"]
    ODHCLI -->|"validates queues"| Kueue["Kueue"]
    ODHCLI -->|"inspects clusters"| Ray["Ray / CodeFlare"]
    ODHCLI -->|"validates configs"| Guardrails["GuardrailsOrchestrator"]
    ODHCLI -->|"detects resources"| LlamaStack["LlamaStack"]
    ODHCLI -->|"inspects jobs"| TrainingOperator["TrainingOperator"]

    %% Migration Targets (Write)
    ODHCLI ==>|"installs operator<br/>CREATE Subscription"| KueueOperator["Red Hat Build of<br/>Kueue Operator"]
    ODHCLI -.->|"validates readiness"| Kuadrant["Kuadrant"]
    ODHCLI -.->|"validates TLS"| Authorino["Authorino"]

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies (Go)"]
        Cobra["cobra v1.10.2"]
        ClientGo["client-go v0.35.1"]
        ControllerRuntime["controller-runtime v0.23.1"]
        OperatorAPI["operator-framework/api v0.39.0"]
        GoJQ["gojq v0.12.18"]
        Semver["semver/v4 v4.0.0"]
    end

    ODHCLI -.->|"build deps"| BuildDeps

    %% Styling
    style ODHCLI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff
    style OLM fill:#b0bec5,stroke:#333,color:#fff

    style DSC fill:#7ed321,stroke:#333,color:#fff
    style DSCI fill:#7ed321,stroke:#333,color:#fff
    style RhodsOperator fill:#7ed321,stroke:#333,color:#fff

    style CertManager fill:#b0bec5,stroke:#333,color:#fff
    style ServiceMeshV3 fill:#b0bec5,stroke:#333,color:#fff
    style ServiceMeshV2 fill:#e0e0e0,stroke:#999,color:#666
