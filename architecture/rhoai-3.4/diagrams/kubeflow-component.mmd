graph TB
    subgraph KubeflowPlatform["Kubeflow Notebook Platform (opendatahub namespace)"]
        direction TB

        subgraph NotebookCtrl["notebook-controller (upstream Kubeflow)"]
            NBController["Notebook Controller<br/>Go controller-runtime<br/>8080/TCP metrics, 8081/TCP health"]
            CullingCtrl["Culling Controller<br/>Idle detection via Jupyter API<br/>Configurable CULL_IDLE_TIME"]
        end

        subgraph ODHCtrl["odh-notebook-controller (RHOAI extension)"]
            ODHReconciler["ODH Reconciler<br/>Go controller-runtime<br/>8080/TCP metrics, 8081/TCP health"]
            MutatingWH["Mutating Webhook<br/>8443/TCP HTTPS<br/>/mutate-notebook-v1"]
            ValidatingWH["Validating Webhook<br/>8443/TCP HTTPS<br/>/validate-notebook-v1"]
            ODHReconciler --> MutatingWH
            ODHReconciler --> ValidatingWH
        end

        subgraph SharedLib["Shared Library"]
            ReconcileHelper["common/reconcilehelper<br/>Reconcile utilities for<br/>Deployments, Services, StatefulSets"]
        end
    end

    %% CRD
    User["User<br/>(kubectl / Dashboard)"] -->|creates/updates| NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>(Namespaced)"]

    %% Webhook intercept
    NotebookCR -->|CREATE/UPDATE intercepted by| MutatingWH
    MutatingWH -->|injects sidecars,<br/>resolves ImageStreams,<br/>mounts CA bundles| NotebookCR

    %% Core controller watches
    NotebookCR -->|watched by| NBController
    NBController -->|creates/manages| StatefulSet["StatefulSet<br/>(per notebook)"]
    NBController -->|creates| NBService["Service<br/>{notebook-name}<br/>80→8888"]

    %% Culling
    CullingCtrl -->|queries /api/kernels<br/>& /api/terminals| JupyterServer["Jupyter Server<br/>8888/TCP"]
    CullingCtrl -->|sets stop annotation<br/>→ replicas=0| StatefulSet

    %% ODH controller creates
    ODHReconciler -->|creates| HTTPRoute["HTTPRoute<br/>nb-{ns}-{name}<br/>(Gateway API)"]
    ODHReconciler -->|creates| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    ODHReconciler -->|creates| NetPol["NetworkPolicy<br/>(per notebook)"]
    ODHReconciler -->|injects| KubeRBACProxy["kube-rbac-proxy<br/>sidecar (8443/TCP)"]
    ODHReconciler -->|creates| DSPASecret["ds-pipeline-config<br/>(Elyra runtime)"]

    %% Gateway routing
    HTTPRoute -->|parent ref| Gateway["data-science-gateway<br/>(Gateway CR)"]
    HTTPRoute -->|backend ref| NBService

    %% External access
    UserBrowser["User Browser"] -->|HTTPS/443| Gateway
    Gateway -->|routes to| KubeRBACProxy
    KubeRBACProxy -->|TokenReview +<br/>SubjectAccessReview| K8sAPI["Kubernetes API<br/>6443/TCP"]
    KubeRBACProxy -->|proxies to| JupyterServer

    %% Styling
    style NBController fill:#4a90e2,color:#fff
    style CullingCtrl fill:#4a90e2,color:#fff
    style ODHReconciler fill:#4a90e2,color:#fff
    style MutatingWH fill:#4a90e2,color:#fff
    style ValidatingWH fill:#4a90e2,color:#fff
    style ReconcileHelper fill:#b8d4f0,color:#333
    style NotebookCR fill:#f5a623,color:#333
    style StatefulSet fill:#7ed321,color:#333
    style NBService fill:#7ed321,color:#333
    style HTTPRoute fill:#7ed321,color:#333
    style RefGrant fill:#7ed321,color:#333
    style NetPol fill:#7ed321,color:#333
    style KubeRBACProxy fill:#e87d7d,color:#fff
    style Gateway fill:#e8e8e8,color:#333
    style K8sAPI fill:#e8e8e8,color:#333
    style JupyterServer fill:#d4a5f5,color:#333
