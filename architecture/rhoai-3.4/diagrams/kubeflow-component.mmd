graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers"]
        direction TB

        subgraph NC["notebook-controller (upstream)"]
            NCController["KF Notebook Controller<br/>Go / controller-runtime"]
            CullingReconciler["Culling Reconciler<br/>Idle notebook detection"]
            NCController --> CullingReconciler
        end

        subgraph ODH["odh-notebook-controller"]
            ODHController["ODH Notebook Controller<br/>Go / controller-runtime"]
            MutatingWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>8443/TCP"]
            ValidatingWH["Validating Webhook<br/>/validate-notebook-v1<br/>8443/TCP"]
            ODHController --> MutatingWH
            ODHController --> ValidatingWH
        end
    end

    %% CRD
    NotebookCR["Notebook CR<br/>kubeflow.org/v1<br/>(Namespaced)"]

    %% User entry
    User["User / Dashboard"] -->|"creates/updates"| NotebookCR

    %% Both controllers watch the same CRD
    NotebookCR -->|"watched by"| NCController
    NotebookCR -->|"watched by"| ODHController

    %% notebook-controller creates
    NCController -->|"creates"| StatefulSet["StatefulSet<br/>(notebook pod)"]
    NCController -->|"creates"| NBService["Service<br/>{notebook-name}<br/>80 → 8888"]
    NCController -.->|"creates (if Istio)"| VirtualService["VirtualService<br/>(optional)"]

    %% Culling checks
    CullingReconciler -->|"HTTP GET /api/kernels<br/>/api/terminals"| JupyterPod["Jupyter Server<br/>8888/TCP"]
    StatefulSet --> JupyterPod

    %% odh-notebook-controller creates
    ODHController -->|"creates"| HTTPRoute["HTTPRoute<br/>nb-{ns}-{name}<br/>in central namespace"]
    ODHController -->|"creates"| RBACProxy["kube-rbac-proxy<br/>Service 8443/TCP"]
    ODHController -->|"creates"| RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    ODHController -->|"creates"| NetworkPolicy["NetworkPolicy"]
    ODHController -->|"injects"| DSPASecret["ds-pipeline-config<br/>Secret"]
    ODHController -->|"creates"| RoleBindings["RoleBindings<br/>(DSPA, MLflow)"]

    %% Webhook mutations
    MutatingWH -->|"injects sidecar"| RBACProxySidecar["kube-rbac-proxy<br/>sidecar container"]
    MutatingWH -->|"mounts"| CABundle["CA Certificate<br/>Bundle"]
    MutatingWH -->|"injects"| MLflowEnv["MLflow Env Vars"]
    MutatingWH -->|"injects"| ProxyEnv["Cluster Proxy<br/>Env Vars"]
    MutatingWH -->|"resolves"| ImageStream["ImageStream<br/>image resolution"]

    %% External systems
    HTTPRoute -->|"references parent"| Gateway["data-science-gateway<br/>(Gateway CR)"]
    RBACProxy -->|"SubjectAccessReview"| K8sAPI["Kubernetes API<br/>443/TCP"]
    ODHController -->|"reads DSPA CR"| DSPA["DSPA<br/>(Pipeline Config)"]
    ODHController -->|"reads"| MLflow["MLflow Operator"]
    ODHController -->|"watches"| ISWatch["OpenShift<br/>ImageStreams"]

    %% Styling
    style NCController fill:#4a90e2,stroke:#333,color:#fff
    style CullingReconciler fill:#4a90e2,stroke:#333,color:#fff
    style ODHController fill:#4a90e2,stroke:#333,color:#fff
    style MutatingWH fill:#4a90e2,stroke:#333,color:#fff
    style ValidatingWH fill:#4a90e2,stroke:#333,color:#fff
    style NotebookCR fill:#f5a623,stroke:#333,color:#fff
    style StatefulSet fill:#7ed321,stroke:#333,color:#fff
    style NBService fill:#7ed321,stroke:#333,color:#fff
    style HTTPRoute fill:#7ed321,stroke:#333,color:#fff
    style RBACProxy fill:#7ed321,stroke:#333,color:#fff
    style RefGrant fill:#7ed321,stroke:#333,color:#fff
    style NetworkPolicy fill:#7ed321,stroke:#333,color:#fff
    style Gateway fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style DSPA fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style ISWatch fill:#e8e8e8,stroke:#333
    style JupyterPod fill:#9b59b6,stroke:#333,color:#fff
