graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>HTTPRoute<br/>443/TCP → 8443/TCP<br/>TLS SIMPLE"]
        LegacyRoute["OpenShift Route (legacy)<br/>443/TCP → 8443/TCP<br/>TLS reencrypt + HSTS"]
    end

    subgraph AuthLayer["AUTHENTICATION (kube-rbac-proxy)"]
        KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>service-serving-cert TLS<br/>AuthZ: list project.openshift.io/projects<br/>Outputs: x-forwarded-access-token"]
    end

    subgraph AppLayer["APPLICATION LAYER (odh-dashboard Pod)"]
        direction TB

        subgraph CoreApp["Core Dashboard"]
            Backend["odh-dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP (localhost)<br/>SA: odh-dashboard<br/>AuthZ: secureRoute() + secureAdminRoute()"]
        end

        subgraph BFF["Module Federation BFF Sidecars (shared proxy-tls cert)"]
            GenAI["gen-ai BFF<br/>Go 1.24 FIPS<br/>8143/TCP HTTPS"]
            ModelRegBFF["model-registry BFF<br/>Go 1.25 FIPS<br/>8043/TCP HTTPS"]
            MaaSBFF["maas BFF<br/>Go 1.24 FIPS<br/>8243/TCP HTTPS"]
            MLflowBFF["mlflow BFF<br/>Go 1.24 FIPS<br/>8343/TCP HTTPS"]
            EvalHubBFF["eval-hub BFF<br/>Go 1.24 FIPS<br/>8543/TCP HTTPS"]
            AutoMLBFF["automl BFF<br/>Go 1.24 FIPS<br/>8643/TCP HTTPS"]
            AutoRAGBFF["autorag BFF<br/>Go 1.24 FIPS<br/>8743/TCP HTTPS"]
        end

        Backend -->|HTTPS proxy<br/>shared proxy-tls| GenAI
        Backend -->|HTTPS proxy| ModelRegBFF
        Backend -->|HTTPS proxy| MaaSBFF
        Backend -->|HTTPS proxy| MLflowBFF
        Backend -->|HTTPS proxy| EvalHubBFF
        Backend -->|HTTPS proxy| AutoMLBFF
        Backend -->|HTTPS proxy| AutoRAGBFF
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA Bearer Token"]
        Thanos["thanos-querier<br/>openshift-monitoring<br/>9092/TCP HTTPS<br/>SA Bearer Token"]
        DSP["ds-pipeline-dspa<br/>8443/TCP HTTPS<br/>SA Bearer Token"]
        MLMD["ds-pipeline-md-dspa<br/>8443/TCP HTTPS<br/>SA Bearer Token"]
        ModelRegSvc["Model Registry<br/>443/TCP HTTPS<br/>SA Bearer Token"]
        TrustyAI["TrustyAI<br/>443/TCP HTTPS<br/>SA Bearer Token"]
        ModelServing["model-serving-api<br/>443/TCP HTTPS<br/>SA Bearer Token"]
        LlamaStack["Llama Stack<br/>443/TCP HTTPS<br/>Bearer Token"]
        Feast["Feast Registry<br/>8080/TCP HTTP<br/>SA Bearer Token"]
        Perses["Perses<br/>8080/TCP HTTP<br/>user_token"]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        MaaSSvc["MaaS Backend<br/>HTTPS<br/>Bearer Token"]
        MLflowSvc["MLflow Tracking<br/>HTTPS<br/>Bearer Token"]
        MCPSvc["MCP Servers<br/>HTTPS<br/>Bearer Token"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        Segment["Segment Analytics<br/>443/TCP HTTPS<br/>Segment Key"]
    end

    %% External flows
    Browser -->|"HTTPS/443<br/>OAuth Token"| Gateway
    Browser -->|"HTTPS/443<br/>OAuth Token"| LegacyRoute
    Gateway -->|"HTTPS/8443<br/>TLS service-serving-cert<br/>Bearer Token"| KRBP
    LegacyRoute -->|"HTTPS/8443<br/>TLS reencrypt"| KRBP
    KRBP -->|"HTTP/8080<br/>localhost (no TLS)<br/>x-forwarded-access-token"| Backend

    %% Backend egress
    Backend -->|"HTTPS/443<br/>SA Token / User Token"| K8sAPI
    Backend -->|"HTTPS/9092<br/>SA Bearer Token"| Thanos
    Backend -->|"HTTPS/8443<br/>SA Bearer Token"| DSP
    Backend -->|"HTTPS/8443<br/>SA Bearer Token"| MLMD
    Backend -->|"HTTPS/443<br/>SA Bearer Token"| ModelRegSvc
    Backend -->|"HTTPS/443<br/>SA Bearer Token"| TrustyAI
    Backend -->|"HTTPS/443<br/>SA Bearer Token"| ModelServing
    Backend -->|"HTTP/8080<br/>SA Bearer Token"| Feast
    Backend -->|"HTTP/8080<br/>user_token"| Perses

    %% BFF egress
    GenAI -->|"HTTPS/443<br/>Bearer Token"| LlamaStack
    GenAI -->|"HTTPS<br/>Bearer Token"| MCPSvc
    MaaSBFF -->|"HTTPS<br/>Bearer Token"| MaaSSvc
    MLflowBFF -->|"HTTPS<br/>Bearer Token"| MLflowSvc
    AutoMLBFF -->|"HTTPS/443<br/>AWS IAM"| S3
    AutoRAGBFF -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef app fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef bff fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalsvc fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Browser external
    class Gateway,LegacyRoute ingress
    class KRBP auth
    class Backend app
    class GenAI,ModelRegBFF,MaaSBFF,MLflowBFF,EvalHubBFF,AutoMLBFF,AutoRAGBFF bff
    class K8sAPI,Thanos,DSP,MLMD,ModelRegSvc,TrustyAI,ModelServing,LlamaStack,Feast,Perses internal
    class MaaSSvc,MLflowSvc,MCPSvc,S3,Segment externalsvc
