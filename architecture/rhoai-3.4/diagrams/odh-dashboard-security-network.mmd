graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Browser["Browser / External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway (Envoy)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ termination<br/>HTTPRoute: PathPrefix /"]
    end

    subgraph AuthLayer["AUTHENTICATION (kube-rbac-proxy)"]
        KRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS (serving cert)<br/>8444/TCP metrics<br/>AuthZ: SubjectAccessReview<br/>projects.list permission"]
    end

    subgraph PodInternal["POD INTERNAL (9 containers, shared network namespace)"]
        direction TB

        subgraph Core["Core Dashboard"]
            DashboardBackend["Dashboard Backend<br/>Node.js/Fastify<br/>8080/TCP HTTP<br/>SA: dashboard"]
        end

        subgraph BFFs["BFF Sidecars (Go, TLS 1.3, FIPS strictfipsruntime)"]
            direction LR
            MR["Model Registry BFF<br/>8043/TCP HTTPS"]
            GAI["Gen AI BFF<br/>8143/TCP HTTPS"]
            MAAS["MaaS BFF<br/>8243/TCP HTTPS"]
            MLF["MLflow BFF<br/>8343/TCP HTTPS"]
            EH["Eval Hub BFF<br/>8543/TCP HTTPS"]
            AML["AutoML BFF<br/>8643/TCP HTTPS"]
            ARG["AutoRAG BFF<br/>8743/TCP HTTPS"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES (Internal)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token / User Token"]
        DSPipelines["Data Science Pipelines<br/>8443/TCP HTTPS<br/>Bearer Token"]
        TrustyAI["TrustyAI Service<br/>443/TCP HTTPS<br/>Bearer Token"]
        ModelReg["Model Registry API<br/>443/TCP HTTPS<br/>Bearer Token"]
        ModelCat["Model Catalog API<br/>443/TCP HTTPS<br/>Bearer Token"]
        Perses["Perses Dashboards<br/>8080/TCP HTTP<br/>No Auth"]
    end

    subgraph AIServices["AI / ML SERVICES"]
        LlamaStack["LlamaStack<br/>HTTP/gRPC<br/>TLS optional<br/>Per-request Token"]
        MaaSAPI["MaaS API<br/>HTTPS<br/>Token-based"]
        MLflowSvc["MLflow Tracking<br/>HTTP<br/>TLS optional<br/>Token-based"]
    end

    subgraph ExternalStorage["EXTERNAL SERVICES"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS<br/>AWS Credentials"]
    end

    %% External → Ingress
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| Gateway

    %% Ingress → Auth
    Gateway -->|"HTTPS/8443<br/>TLS reencrypt<br/>serving cert"| KRBAC

    %% Auth → Core
    KRBAC -->|"HTTP/8080<br/>localhost (no TLS)<br/>x-forwarded-access-token<br/>x-forwarded-user"| DashboardBackend

    %% Core → BFFs (all TLS 1.3, x-forwarded-access-token)
    DashboardBackend -->|"HTTPS/8043<br/>TLS 1.3"| MR
    DashboardBackend -->|"HTTPS/8143<br/>TLS 1.3"| GAI
    DashboardBackend -->|"HTTPS/8243<br/>TLS 1.3"| MAAS
    DashboardBackend -->|"HTTPS/8343<br/>TLS 1.3"| MLF
    DashboardBackend -->|"HTTPS/8543<br/>TLS 1.3"| EH
    DashboardBackend -->|"HTTPS/8643<br/>TLS 1.3"| AML
    DashboardBackend -->|"HTTPS/8743<br/>TLS 1.3"| ARG

    %% Egress from Core
    DashboardBackend -->|"HTTPS/6443<br/>User Token"| K8sAPI
    DashboardBackend -->|"HTTPS/8443<br/>User Token"| DSPipelines
    DashboardBackend -->|"HTTPS/443<br/>User Token"| TrustyAI
    DashboardBackend -->|"HTTP/8080<br/>No Auth"| Perses

    %% Egress from BFFs
    MR -->|"HTTPS/443<br/>Bearer Token"| ModelReg
    MR -->|"HTTPS/443<br/>Bearer Token"| ModelCat
    GAI -->|"HTTP/gRPC<br/>Per-request Token"| LlamaStack
    GAI -->|"HTTPS<br/>Token"| MaaSAPI
    GAI -->|"HTTP<br/>Token"| MLflowSvc
    MAAS -->|"HTTPS<br/>Token"| MaaSAPI
    MLF -->|"HTTP<br/>Token"| MLflowSvc
    AML -->|"HTTPS/443<br/>AWS Creds"| S3
    AML -->|"HTTPS<br/>Bearer Token"| DSPipelines
    ARG -->|"HTTP/gRPC<br/>Token"| LlamaStack
    ARG -->|"HTTPS/443<br/>AWS Creds"| S3

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef auth fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#333
    classDef core fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333
    classDef bff fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef aiservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333
    classDef externalsvc fill:#f5f5f5,stroke:#666,stroke-width:2px,color:#333

    class Browser external
    class Gateway ingress
    class KRBAC auth
    class DashboardBackend core
    class MR,GAI,MAAS,MLF,EH,AML,ARG bff
    class K8sAPI,DSPipelines,TrustyAI,ModelReg,ModelCat,Perses platform
    class LlamaStack,MaaSAPI,MLflowSvc aiservice
    class S3 externalsvc
