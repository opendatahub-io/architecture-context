graph TB
    subgraph TrustyAI["TrustyAI Explainability Service"]
        direction TB

        subgraph ServiceLayer["explainability-service (Quarkus 3.8.5)"]
            direction LR
            FairnessAPI["Fairness Endpoints<br/>/metrics/group/fairness/*<br/>SPD, DIR"]
            DriftAPI["Drift Endpoints<br/>/metrics/drift/*<br/>KS, ApproxKS, FourierMMD, Meanshift"]
            ExplainerAPI["Explainer Endpoints<br/>/explainers/*<br/>LIME, SHAP, CF, TSSaliency, PDP<br/>(disabled in RHOAI)"]
            ConsumerAPI["Consumer Endpoints<br/>/consumer/kserve/v2<br/>CloudEventConsumer"]
            DataAPI["Data Endpoints<br/>/data/upload, /data/download"]
            InfoAPI["Info Endpoints<br/>/info, /info/tags, /info/names"]
            HealthAPI["Health & Metrics<br/>/q/health/*, /q/metrics"]
        end

        subgraph Scheduling["Prometheus Scheduling"]
            PrometheusScheduler["PrometheusScheduler<br/>(cron: 5s default)"]
            PrometheusPublisher["PrometheusPublisher<br/>(Micrometer gauges)"]
            PrometheusScheduler --> PrometheusPublisher
        end

        subgraph Storage["Storage Backends (Strategy Pattern)"]
            direction LR
            CSVDataSource["CSVDataSource<br/>(PVC / MinIO / Memory)"]
            HibernateDataSource["HibernateDataSource<br/>(MariaDB / MySQL)"]
        end

        subgraph Reconcilers["Payload Reconcilers"]
            MMReconciler["ModelMesh<br/>PayloadReconciler"]
            KSReconciler["KServe<br/>PayloadReconciler"]
        end

        ConsumerAPI --> MMReconciler
        ConsumerAPI --> KSReconciler
        MMReconciler --> Storage
        KSReconciler --> Storage

        FairnessAPI --> Storage
        DriftAPI --> Storage
        DataAPI --> Storage
    end

    subgraph CoreLib["explainability-core (Library)"]
        direction LR
        FairnessAlgo["Fairness Metrics<br/>SPD, DIR"]
        DriftAlgo["Drift Detectors<br/>KS, ApproxKS, FourierMMD, Meanshift"]
        XAIAlgo["XAI Algorithms<br/>LIME, SHAP, Counterfactual"]
        OptaPlanner["OptaPlanner<br/>Constraint Solving"]
        XAIAlgo --> OptaPlanner
    end

    subgraph ConnectorsLib["explainability-connectors (Library)"]
        direction LR
        KServeHTTP["KServe v1/v2<br/>HTTP Adapter"]
        KServeGRPC["KServe v2<br/>gRPC Adapter"]
    end

    subgraph ArrowLib["explainability-arrow (Library)"]
        ArrowIPC["Arrow IPC<br/>Java-Python Bridge"]
    end

    %% Internal relationships
    FairnessAPI --> FairnessAlgo
    DriftAPI --> DriftAlgo
    ExplainerAPI --> XAIAlgo
    ExplainerAPI --> ConnectorsLib

    %% External integrations
    ModelMesh["ModelMesh Serving"] -->|"POST /consumer/kserve/v2<br/>8080/TCP HTTP"| ConsumerAPI
    KServe["KServe<br/>(Knative CloudEvents)"] -->|"CloudEvent triggers<br/>8080/TCP HTTP"| ConsumerAPI

    ExplainerAPI -->|"gRPC KServe v2<br/>outbound"| InferenceService["KServe/ModelMesh<br/>Inference Service"]

    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|"GET /q/metrics<br/>8080/TCP Bearer Token"| HealthAPI
    PrometheusPublisher -->|"trustyai_* gauges"| HealthAPI

    CSVDataSource -->|"File I/O"| PVC["PVC<br/>/inputs"]
    CSVDataSource -->|"HTTPS"| MinIO["MinIO / S3"]
    HibernateDataSource -->|"JDBC 3306/TCP"| DB["MariaDB / MySQL"]

    TrustyAIOperator["TrustyAI Operator"] -.->|"deploys & configures"| TrustyAI

    %% Styling
    style TrustyAI fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style ServiceLayer fill:#bbdefb,stroke:#1976d2
    style CoreLib fill:#c8e6c9,stroke:#388e3c
    style ConnectorsLib fill:#c8e6c9,stroke:#388e3c
    style ArrowLib fill:#c8e6c9,stroke:#388e3c
    style Storage fill:#fff3e0,stroke:#ef6c00
    style Scheduling fill:#f3e5f5,stroke:#7b1fa2
    style Reconcilers fill:#e0f2f1,stroke:#00695c

    style ModelMesh fill:#e8e8e8,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style InferenceService fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style PVC fill:#fff9c4,stroke:#f9a825
    style MinIO fill:#fff9c4,stroke:#f9a825
    style DB fill:#fff9c4,stroke:#f9a825
    style TrustyAIOperator fill:#7ed321,stroke:#333
