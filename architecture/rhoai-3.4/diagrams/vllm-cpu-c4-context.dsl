// vLLM CPU - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM models for inference"

        vllmCpu = softwareSystem "vLLM CPU" "CPU-optimized LLM inference serving runtime with OpenAI-compatible API" {
            apiServer = container "OpenAI API Server" "OpenAI-compatible HTTP REST API for inference serving" "Python (FastAPI/Uvicorn), Port 8000"
            grpcServer = container "gRPC Server" "Binary gRPC interface for engine communication with Rust router" "Python (grpcio), Port 50051"
            asyncEngine = container "AsyncLLM Engine" "Asynchronous inference engine with continuous batching and PagedAttention" "Python"
            cpuBackend = container "CPU Backend" "CPU-specific optimized compute kernels" "C++"
            anthropicRouter = container "Anthropic API Router" "Anthropic Messages API compatibility endpoint" "Python (FastAPI)"
            mcpServer = container "MCP Tool Server" "Model Context Protocol tool server support" "Python"
            metrics = container "Prometheus Metrics" "Metrics exporter for inference server monitoring" "Python"
        }

        kserve = softwareSystem "KServe" "Inference serving orchestration and lifecycle management" "Internal RHOAI"
        dashboard = softwareSystem "RHOAI Dashboard" "Web UI for model serving configuration" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML workflow orchestration" "Internal RHOAI"
        modelMesh = softwareSystem "Model Mesh" "Model serving orchestration" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Monitoring and metrics collection" "Internal RHOAI"
        rustRouter = softwareSystem "Rust Router (llm-d)" "Inference request routing" "Internal RHOAI"

        hfHub = softwareSystem "HuggingFace Hub" "Model weight repository" "External"
        s3Storage = softwareSystem "S3/MinIO Storage" "Model artifact storage backend" "External"
        containerRegistry = softwareSystem "Container Registry" "Container image registry (quay.io)" "External"

        // User interactions
        user -> vllmCpu "Sends inference requests via HTTPS/443"
        user -> dashboard "Configures model serving"

        // Internal RHOAI interactions
        kserve -> vllmCpu "Manages lifecycle, scaling, routing via InferenceService CR"
        dashboard -> kserve "Configures InferenceServices"
        dsPipelines -> kserve "Deploys models from pipelines"
        prometheus -> vllmCpu "Scrapes metrics from /metrics endpoint" "HTTP/8000"
        rustRouter -> vllmCpu "Sends inference requests" "gRPC/50051"

        // External interactions
        vllmCpu -> hfHub "Downloads model weights" "HTTPS/443"
        vllmCpu -> s3Storage "Downloads model artifacts" "HTTPS/443"

        // Container relationships
        apiServer -> asyncEngine "Submits inference requests" "in-process"
        grpcServer -> asyncEngine "Submits inference requests" "in-process"
        asyncEngine -> cpuBackend "PagedAttention compute" "in-process"
        apiServer -> anthropicRouter "Routes Anthropic API requests" "in-process"
        apiServer -> mcpServer "Routes MCP requests" "in-process"
        apiServer -> metrics "Exposes Prometheus metrics" "in-process"
    }

    views {
        systemContext vllmCpu "SystemContext" {
            include *
            autoLayout
        }

        container vllmCpu "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
