graph LR
    DSPO["Data Science Pipelines<br/>Operator (DSPO)"]

    %% External Dependencies (libraries/frameworks)
    DSPO -->|"operator framework"| CtrlRuntime["controller-runtime<br/>v0.23.3"]
    DSPO -->|"manifest rendering"| Manifestival["manifestival<br/>v0.7.2"]
    DSPO -->|"pipeline engine"| KFP["Kubeflow Pipelines<br/>2.16.0"]
    DSPO -->|"workflow execution"| Argo["Argo Workflows<br/>(bundled)"]
    DSPO -->|"config mgmt"| Viper["viper v1.21.0"]
    DSPO -->|"metrics"| PromClient["prometheus/client_golang<br/>v1.23.2"]

    %% Internal Platform Dependencies
    DSPO -->|"deploys operator"| RHODSOp["rhods-operator /<br/>opendatahub-operator"]
    DSPO -->|"CA bundle trust"| CABundle["odh-trusted-ca-bundle<br/>ConfigMap"]
    DSPO -->|"TLS cert provisioning"| ServiceCA["OpenShift Service CA"]
    DSPO -->|"external access"| OSRouter["OpenShift Router"]
    DSPO -->|"metrics scraping"| Prometheus["Prometheus /<br/>User Workload Monitoring"]

    %% Integration Points (downstream consumers)
    Dashboard["ODH Dashboard"] -->|"UI pipeline mgmt"| DSPO
    KServe["KServe"] -.->|"pipeline steps deploy<br/>InferenceService CRs"| DSPO
    Ray["Ray"] -.->|"pipeline steps create<br/>RayCluster/RayJob CRs"| DSPO
    CodeFlare["CodeFlare"] -.->|"pipeline steps create<br/>AppWrapper CRs"| DSPO
    Seldon["Seldon"] -.->|"pipeline steps create<br/>SeldonDeployment CRs"| DSPO

    %% External Services
    DSPO -->|"model storage<br/>S3 API"| ExtS3["External S3 Storage"]
    DSPO -->|"metadata storage<br/>MySQL protocol"| ExtDB["External MySQL DB"]
    DSPO -->|"managed pipelines<br/>OCI API"| OCIReg["OCI Container Registry"]
    DSPO -->|"resource mgmt<br/>HTTPS/443"| K8sAPI["Kubernetes API Server"]

    %% Styling
    style DSPO fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External dependencies (gray)
    style CtrlRuntime fill:#999,stroke:#333,color:#fff
    style Manifestival fill:#999,stroke:#333,color:#fff
    style KFP fill:#999,stroke:#333,color:#fff
    style Argo fill:#999,stroke:#333,color:#fff
    style Viper fill:#999,stroke:#333,color:#fff
    style PromClient fill:#999,stroke:#333,color:#fff

