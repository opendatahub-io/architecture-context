graph TD
    subgraph RuntimeRBAC["Runtime RBAC (Shipped Container)"]
        direction TB
        NoRBAC["No RBAC Required<br/><br/>The shipped data container:<br/>- Does not interact with Kubernetes API<br/>- Has no ServiceAccount requirements<br/>- Requires no ClusterRole or RoleBinding<br/>- Pod lifecycle managed by consuming operator"]
    end

    subgraph BuildTimeAuth["Build-Time Authentication"]
        direction TB

        subgraph HFAuth["HuggingFace API Access"]
            HFToken["HF_TOKEN<br/>(Environment Variable)"]
            HFEndpoints["HuggingFace Endpoints"]
            HFCollections["GET /api/users/RedHatAI/collections"]
            HFModels["GET /api/models/{model_id}"]
            HFReadme["GET /{model_id}/resolve/main/README.md"]
            HFToken -->|"Bearer Token<br/>(optional)"| HFEndpoints
            HFEndpoints --- HFCollections
            HFEndpoints --- HFModels
            HFEndpoints --- HFReadme
        end

        subgraph OCIAuth["OCI Registry Access"]
            NoAuth["No Authentication"]
            OCIEndpoints["registry.redhat.io<br/>OCI Distribution v2"]
            OCIManifest["GET manifest"]
            OCIBlob["GET blob (layers + config)"]
            NoAuth -->|"Public pull<br/>(no credentials)"| OCIEndpoints
            OCIEndpoints --- OCIManifest
            OCIEndpoints --- OCIBlob
        end

        subgraph CISecrets["CI/CD Secrets"]
            GitSecret["git_auth_secret<br/>(Kubernetes Secret)"]
            GitPurpose["Tekton pipeline<br/>Git workspace auth"]
            GitSecret -->|"Provisioned by<br/>Konflux/PaC"| GitPurpose
        end
    end

    style NoRBAC fill:#d4edda,stroke:#82b366,stroke-width:2px
    style HFToken fill:#fff3cd,stroke:#ffc107
    style NoAuth fill:#d4edda,stroke:#82b366
    style GitSecret fill:#fff3cd,stroke:#ffc107
    style HFCollections fill:#e3f2fd,stroke:#1565c0
    style HFModels fill:#e3f2fd,stroke:#1565c0
    style HFReadme fill:#e3f2fd,stroke:#1565c0
    style OCIManifest fill:#e3f2fd,stroke:#1565c0
    style OCIBlob fill:#e3f2fd,stroke:#1565c0
