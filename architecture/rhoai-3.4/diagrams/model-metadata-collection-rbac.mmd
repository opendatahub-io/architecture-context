graph TD
    subgraph RuntimeSecurity["Runtime Security Profile"]
        direction TB

        subgraph DataContainerSec["Data Container Security"]
            Container["odh-model-metadata-collection<br/>(ubi9-micro)"]
            UID["UID: 1001 (non-root)"]
            NoExec["No executable code"]
            NoPorts["No network ports"]
            NoIngress["No ingress"]
            NoEgress["No egress"]
            NoCRDs["No CRDs"]
            NoRBAC["No ClusterRoles<br/>No RoleBindings"]
        end

        Container --- UID
        Container --- NoExec
        Container --- NoPorts
        Container --- NoIngress
        Container --- NoEgress
        Container --- NoCRDs
        Container --- NoRBAC
    end

    subgraph BuildTimeSecurity["Build-Time Security"]
        direction TB

        subgraph SecretManagement["Secret Management"]
            HFToken["HF_TOKEN<br/>Type: Opaque (env var)<br/>Purpose: HuggingFace API auth<br/>Provisioned: Manual (developer/CI)<br/>Auto-Rotate: No"]
        end

        subgraph AuthMechanisms["Authentication Mechanisms"]
            HFAuth["HuggingFace API<br/>Method: Bearer Token<br/>Enforcement: HuggingFace server<br/>Required: No (optional)<br/>Impact if absent: Rate limiting,<br/>no access to gated models"]
            RegistryAuth["Red Hat Registry<br/>Method: None (public)<br/>No auth required"]
        end

        subgraph TLSConfig["TLS Configuration"]
            GoTLS["Go stdlib net/http<br/>Default TLS config<br/>System trust store<br/>No custom cipher suites<br/>FIPS-compliant on<br/>FIPS-enabled toolchain"]
        end
    end

    subgraph FIPSCompliance["FIPS Compliance"]
        RuntimeFIPS["Runtime: N/A<br/>(data-only, no crypto)"]
        BuildFIPS["Build-time: Go stdlib TLS<br/>(FIPS on FIPS toolchain)"]
        NoCrypto["No custom crypto<br/>No MD5/RC4/DES"]
    end

    %% Connections
    HFToken -->|"Authorization: Bearer"| HFAuth

