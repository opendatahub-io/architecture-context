// RHOAI-Build-Config C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/RHOAI-Build-Config.md

workspace {
    model {
        releaseEngineer = person "Release Engineer" "Manages RHOAI build configuration and release pipeline"
        developer = person "Component Developer" "Develops upstream RHOAI components"

        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration repository defining all container images, OLM operator bundle, and FBC fragments for RHOAI 3.4" {
            bundle = container "OLM Operator Bundle" "CSV, CRDs (24), RBAC, 86+ RELATED_IMAGE refs for rhods-operator" "YAML Manifests"
            catalog = container "FBC Fragments" "Per-OCP-version File-Based Catalog definitions (v4.19, v4.20, v4.21)" "YAML/JSON"
            buildAutomation = container "Build Automation" "Tekton pipelines and GitHub Actions for bundle/catalog processing" "Tekton, GitHub Actions"
            buildConfig = container "Build Configuration" "Registry mappings, OCP versions, base images" "YAML"
            integrationTests = container "Integration Tests" "Enterprise Contract verification and IntegrationTestScenario" "YAML"
        }

        // External Systems
        konflux = softwareSystem "Konflux (RHTAP)" "CI/CD build system for container images" "External"
        github = softwareSystem "GitHub" "Source control and CI/CD platform" "External"
        quayio = softwareSystem "quay.io/rhoai" "Container image registry for all RHOAI images" "External"
        registryRedHat = softwareSystem "registry.redhat.io" "Production Red Hat container registry" "External"
        olm = softwareSystem "OLM" "Operator Lifecycle Manager for operator installation" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target platform (v4.19, v4.20, v4.21)" "External"
        rhOperatorIndex = softwareSystem "Red Hat Operator Index" "Consumes FBC fragments for operator discovery" "External"
        opm = softwareSystem "opm" "Operator Package Manager for FBC catalog rendering" "External"

        // Internal ODH Systems
        rhodsOperator = softwareSystem "rhods-operator" "The actual operator whose bundle is packaged here" "Internal RHOAI"
        rhoaiKonfluxAutomation = softwareSystem "RHOAI-Konflux-Automation" "Shared automation utilities for bundle/catalog patching" "Internal RHOAI"
        pnc = softwareSystem "PNC (Product New Build)" "Maven build system for TrustyAI Java artifacts" "External"

        // Upstream component builds (aggregated)
        upstreamComponents = softwareSystem "Upstream Component Builds" "86+ RHOAI component images built by Konflux" "Internal RHOAI"

        // Relationships
        developer -> upstreamComponents "Develops and submits code changes"
        releaseEngineer -> rhoaiBuildConfig "Manages build configuration and release"

        upstreamComponents -> rhoaiBuildConfig "Triggers image digest updates via Konflux nudge" "HTTPS/443"
        rhoaiBuildConfig -> konflux "Triggers Tekton PipelineRuns for bundle/FBC builds" "HTTPS/443"
        rhoaiBuildConfig -> github "Hosts repository, triggers GitHub Actions" "HTTPS/443"
        rhoaiBuildConfig -> quayio "Pushes bundle and FBC fragment images" "HTTPS/443"
        rhoaiBuildConfig -> registryRedHat "Validates PCC cache, references base images" "HTTPS/443"
        rhoaiBuildConfig -> opm "Uses for FBC catalog rendering (v1.47.0)" "CLI"
        rhoaiBuildConfig -> rhoaiKonfluxAutomation "Clones shared automation utilities" "HTTPS/443"
        rhoaiBuildConfig -> pnc "TrustyAI Java artifact build" "HTTPS/443"

        rhodsOperator -> rhoaiBuildConfig "Provides CSV, CRDs, and operator source"
        rhoaiBuildConfig -> olm "Bundle installed via OLM" "OLM Protocol"
        rhoaiBuildConfig -> rhOperatorIndex "FBC fragments consumed by index"
        olm -> ocp "Installs operator on OpenShift"

        // Container relationships
        buildAutomation -> bundle "Patches and processes"
        buildAutomation -> catalog "Renders and updates"
        buildConfig -> buildAutomation "Configures"
        integrationTests -> bundle "Verifies Enterprise Contract compliance"
        bundle -> catalog "Bundle image referenced in catalog"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape Person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
