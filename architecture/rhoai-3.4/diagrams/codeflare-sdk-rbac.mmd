graph TD
    subgraph UserIdentity["User Identity"]
        User["Data Scientist<br/>(Jupyter Notebook User)"]
    end

    subgraph AuthMethods["Authentication Methods"]
        BearerToken["Bearer Token (JWT)"]
        Kubeconfig["kubeconfig"]
        SAToken["In-Cluster SA Token"]
        KubeAuthkit["kube-authkit<br/>(auto-detect)"]
    end

    subgraph RequiredPermissions["Required RBAC Permissions (User Role)"]
        direction TB

        subgraph RayIO["API Group: ray.io"]
            RayClusters["rayclusters<br/>get, list, create,<br/>update, patch, delete"]
            RayJobsRes["rayjobs<br/>get, list, create,<br/>update, patch, delete"]
        end

        subgraph CoreAPI["API Group: core ('')"]
            Secrets["secrets<br/>get, list, create,<br/>update, delete"]
            Namespaces["namespaces<br/>get"]
        end

        subgraph KueueAPI["API Group: kueue.x-k8s.io"]
            LocalQueues["localqueues<br/>get, list"]
            Workloads["workloads<br/>get, list"]
            WPC["workloadpriorityclasses<br/>get"]
        end

        subgraph GatewayAPI["API Group: gateway.networking.k8s.io"]
            HTTPRoutes["httproutes<br/>get, list"]
            Gateways["gateways<br/>get"]
        end

        subgraph RouteAPI["API Group: route.openshift.io"]
            Routes["routes<br/>get, list"]
        end

        subgraph NetworkingAPI["API Group: networking.k8s.io"]
            Ingresses["ingresses<br/>get, list"]
        end
    end

    subgraph AdditionalAuth["Additional Auth (Non-RBAC)"]
        mTLS["Ray Client mTLS<br/>Client certificate<br/>RSA 3072-bit, SHA-256<br/>Signed by cluster CA"]
        DashboardAuth["Ray Dashboard Auth<br/>Bearer Token forwarded<br/>via kube-rbac-proxy /<br/>HTTPRoute"]
        OAuthProxy["OAuth Proxy (Legacy)<br/>OpenShift OAuth<br/>via sidecar"]
    end

    %% Auth flow
    User --> KubeAuthkit
    KubeAuthkit -->|"auto-detect"| BearerToken
    KubeAuthkit -->|"auto-detect"| Kubeconfig
    KubeAuthkit -->|"auto-detect"| SAToken

    %% RBAC permissions
    BearerToken -->|"authorizes"| RayClusters
    BearerToken -->|"authorizes"| RayJobsRes
    BearerToken -->|"authorizes"| Secrets
    BearerToken -->|"authorizes"| Namespaces
    BearerToken -->|"authorizes"| LocalQueues
    BearerToken -->|"authorizes"| Workloads
    BearerToken -->|"authorizes"| WPC
    BearerToken -->|"authorizes"| HTTPRoutes
    BearerToken -->|"authorizes"| Gateways
    BearerToken -->|"authorizes"| Routes
    BearerToken -->|"authorizes"| Ingresses

    %% Additional auth
    User --> mTLS
    User --> DashboardAuth
    User -.-> OAuthProxy

    style User fill:#4a90e2,stroke:#333,color:#fff
    style KubeAuthkit fill:#f5a623,stroke:#333
    style BearerToken fill:#f5a623,stroke:#333
    style Kubeconfig fill:#f5a623,stroke:#333
    style SAToken fill:#f5a623,stroke:#333

    style RayClusters fill:#7ed321,stroke:#333
    style RayJobsRes fill:#7ed321,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style Namespaces fill:#7ed321,stroke:#333
    style LocalQueues fill:#7ed321,stroke:#333
    style Workloads fill:#7ed321,stroke:#333
    style WPC fill:#7ed321,stroke:#333
    style HTTPRoutes fill:#7ed321,stroke:#333
    style Gateways fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333

    style mTLS fill:#e8e8e8,stroke:#333
    style DashboardAuth fill:#e8e8e8,stroke:#333
    style OAuthProxy fill:#e8e8e8,stroke:#333
