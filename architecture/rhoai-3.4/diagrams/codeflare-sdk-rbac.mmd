graph TD
    subgraph "Authentication Methods (kube-authkit)"
        AutoDetect["Auto-Detect<br/>(priority chain)"]
        TokenAuth["Bearer Token<br/>(JWT)"]
        OIDCAuth["OIDC<br/>(OpenID Connect)"]
        OAuthAuth["OpenShift OAuth"]
        KubeconfigAuth["Kubeconfig File"]
        InClusterAuth["In-Cluster SA<br/>(ServiceAccount)"]
    end

    subgraph "User Identity"
        User["Authenticated User<br/>(Data Scientist)"]
    end

    AutoDetect --> User
    TokenAuth --> User
    OIDCAuth --> User
    OAuthAuth --> User
    KubeconfigAuth --> User
    InClusterAuth --> User

    subgraph "Required RBAC Permissions"
        direction TB

        subgraph RayPerms["ray.io API Group"]
            RayClusters["rayclusters<br/>get, list, create,<br/>update, patch, delete"]
            RayJobs["rayjobs<br/>get, list, create,<br/>update, patch, delete"]
        end

        subgraph CorePerms["Core API Group"]
            Secrets["secrets<br/>get, list, create, update"]
        end

        subgraph KueuePerms["kueue.x-k8s.io API Group"]
            LocalQueues["localqueues<br/>get, list"]
            Workloads["workloads<br/>get, list"]
            PriorityClasses["workloadpriorityclasses<br/>get"]
        end

        subgraph GatewayPerms["gateway.networking.k8s.io API Group"]
            HTTPRoutes["httproutes<br/>get, list"]
            Gateways["gateways<br/>get"]
        end

        subgraph RoutePerms["route.openshift.io API Group"]
            Routes["routes<br/>get, list"]
        end

        subgraph NetworkPerms["networking.k8s.io API Group"]
            Ingresses["ingresses<br/>get, list"]
        end
    end

    %% User to permissions
    User -->|"requires"| RayClusters
    User -->|"requires"| RayJobs
    User -->|"requires"| Secrets
    User -->|"requires"| LocalQueues
    User -->|"requires"| Workloads
    User -->|"requires"| PriorityClasses
    User -->|"requires"| HTTPRoutes
    User -->|"requires"| Gateways
    User -->|"requires"| Routes
    User -->|"requires"| Ingresses

    subgraph "Kubernetes API Server"
        RBAC["RBAC Enforcement<br/>6443/TCP HTTPS"]
    end

    RayClusters --> RBAC
    RayJobs --> RBAC
    Secrets --> RBAC
    LocalQueues --> RBAC
    Workloads --> RBAC
    PriorityClasses --> RBAC
    HTTPRoutes --> RBAC
    Gateways --> RBAC
    Routes --> RBAC
    Ingresses --> RBAC

    %% Note about SDK being a client
    Note["Note: The SDK runs as a client<br/>using the authenticated user's credentials.<br/>It does not install RBAC roles.<br/>The user must have these permissions<br/>granted via ClusterRole/RoleBindings."]

    %% Styling
    style User fill:#4a90e2,color:#fff
    style RBAC fill:#e65100,color:#fff,stroke-width:2px
    style RayClusters fill:#7ed321
    style RayJobs fill:#7ed321
    style Secrets fill:#f5a623
    style LocalQueues fill:#50e3c2
    style Workloads fill:#50e3c2
    style PriorityClasses fill:#50e3c2
    style HTTPRoutes fill:#b8e6ff
    style Gateways fill:#b8e6ff
    style Routes fill:#b8e6ff
    style Ingresses fill:#b8e6ff
    style Note fill:#fff9c4,stroke:#f57f17,stroke-dasharray: 5 5
    style AutoDetect fill:#e3f2fd,stroke:#1565c0
    style TokenAuth fill:#e3f2fd,stroke:#1565c0
    style OIDCAuth fill:#e3f2fd,stroke:#1565c0
    style OAuthAuth fill:#e3f2fd,stroke:#1565c0
    style KubeconfigAuth fill:#e3f2fd,stroke:#1565c0
    style InClusterAuth fill:#e3f2fd,stroke:#1565c0
