graph LR
    EvalHub["EvalHub<br/>Evaluation Orchestration Service"]

    %% Internal RHOAI Dependencies
    EvalHub -->|"CRD Watch<br/>(EvalHub CR)"| TrustyAIOp["TrustyAI Service<br/>Operator"]
    EvalHub -->|"REST API<br/>5000/TCP"| MLflow["MLflow Tracking<br/>Server"]
    EvalHub -.->|"platform sidecar<br/>8443/TCP"| KRBACProxy["kube-rbac-proxy"]

    %% Kubernetes Dependencies
    EvalHub -->|"TokenReview + SAR<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>Server"]
    EvalHub -->|"Job/ConfigMap CRUD<br/>443/TCP HTTPS"| K8sAPI
    EvalHub -.->|"queue scheduling<br/>(label-based)"| Kueue["Kueue"]

    %% External Dependencies
    EvalHub -->|"production storage<br/>5432/TCP"| PostgreSQL["PostgreSQL"]
    EvalHub -->|"test data download<br/>443/TCP HTTPS"| S3["S3-compatible<br/>Storage"]
    EvalHub -->|"model artifacts<br/>443/TCP HTTPS"| OCI["OCI Registry"]
    EvalHub -.->|"TLS certificates"| CertManager["cert-manager /<br/>OpenShift Service CA"]

    %% Evaluation Framework Providers
    EvalHub -->|"K8s Job pods"| LMEval["lm-evaluation-harness<br/>(180+ benchmarks)"]
    EvalHub -->|"K8s Job pods"| LightEval["LightEval"]
    EvalHub -->|"K8s Job pods"| Garak["Garak<br/>(security testing)"]
    EvalHub -->|"K8s Job pods"| GuideLLM["GuideLLM<br/>(performance)"]
    EvalHub -->|"K8s Job pods"| IBMCLEAR["IBM CLEAR"]

    %% Integration Points (other components depending on EvalHub)
    Dashboard["ODH Dashboard"] -->|"UI management"| EvalHub
    Pipelines["Data Science<br/>Pipelines"] -.->|"KFP component<br/>(LightEval)"| EvalHub

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Internal RHOAI
    style TrustyAIOp fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style KRBACProxy fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff

    %% Kubernetes / Platform
    style K8sAPI fill:#dae8fc,stroke:#6c8ebf
    style Kueue fill:#dae8fc,stroke:#6c8ebf
    style CertManager fill:#dae8fc,stroke:#6c8ebf

    %% External Services
    style PostgreSQL fill:#f5a623,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style OCI fill:#f5a623,stroke:#333,color:#fff

    %% Evaluation Providers
    style LMEval fill:#e8e8e8,stroke:#333
    style LightEval fill:#e8e8e8,stroke:#333
    style Garak fill:#e8e8e8,stroke:#333
    style GuideLLM fill:#e8e8e8,stroke:#333
    style IBMCLEAR fill:#e8e8e8,stroke:#333
