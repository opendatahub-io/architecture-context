graph LR
    EvalHub["eval-hub<br/>LLM Evaluation Orchestrator"]

    %% Internal RHOAI Dependencies
    EvalHub -->|"CRD lifecycle<br/>(EvalHub CR)"| TrustyAI["TrustyAI Service<br/>Operator"]
    EvalHub -->|"experiment tracking<br/>HTTPS/5000"| MLflow["MLflow Tracking<br/>Server"]
    EvalHub -->|"job queue labels<br/>(optional)"| Kueue["Kueue"]

    %% Platform Dependencies
    EvalHub -->|"TokenReview + SAR<br/>Jobs + ConfigMaps<br/>HTTPS/443"| K8sAPI["Kubernetes<br/>API Server"]
    EvalHub -->|"CA certificates<br/>ConfigMap mount"| ServiceCA["OpenShift<br/>Service CA"]

    %% External Dependencies
    EvalHub -->|"persistent storage<br/>TCP/5432"| PostgreSQL["PostgreSQL 5+"]
    EvalHub -->|"test data download<br/>HTTPS/443"| S3["AWS S3"]
    EvalHub -->|"artifact export<br/>HTTPS/443"| OCIRegistry["OCI Registry"]
    EvalHub -->|"trace export<br/>gRPC/4317"| OTEL["OTEL Collector"]

    %% Integration Points (components that interact with eval-hub)
    Dashboard["ODH Dashboard /<br/>RHOAI UI"] -->|"user management<br/>HTTPS/8080"| EvalHub
    SDK["eval-hub-sdk<br/>(Python)"] -->|"adapter callbacks<br/>HTTP/8080 via sidecar"| EvalHub
    Prometheus["Prometheus"] -->|"metrics scrape<br/>/metrics"| EvalHub

    %% Evaluation Frameworks (downstream via BYOF)
    EvalHub -.->|"BYOF adapter"| LMEval["lm-evaluation-harness"]
    EvalHub -.->|"BYOF adapter"| RAGAS["RAGAS"]
    EvalHub -.->|"BYOF adapter"| Garak["Garak"]
    EvalHub -.->|"BYOF adapter"| GuideLLM["GuideLLM"]
    EvalHub -.->|"BYOF adapter"| LightEval["LightEval"]
    EvalHub -.->|"BYOF adapter"| MTEB["MTEB"]

    %% Styling
    style EvalHub fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style MLflow fill:#7ed321,stroke:#333,color:#fff
    style Kueue fill:#7ed321,stroke:#333,color:#fff
    style K8sAPI fill:#438dd5,stroke:#333,color:#fff
    style ServiceCA fill:#438dd5,stroke:#333,color:#fff
    style PostgreSQL fill:#f5a623,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style OCIRegistry fill:#f5a623,stroke:#333
    style OTEL fill:#f5a623,stroke:#333
    style Dashboard fill:#7ed321,stroke:#333,color:#fff
    style SDK fill:#7ed321,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style LMEval fill:#e8e8e8,stroke:#333
    style RAGAS fill:#e8e8e8,stroke:#333
    style Garak fill:#e8e8e8,stroke:#333
    style GuideLLM fill:#e8e8e8,stroke:#333
    style LightEval fill:#e8e8e8,stroke:#333
    style MTEB fill:#e8e8e8,stroke:#333
