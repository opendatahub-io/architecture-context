graph TB
    subgraph External["External Callers"]
        EPP["llm-d-inference-scheduler<br/>(EPP)"]
        Client["Direct Client"]
    end

    subgraph SidecarPod["Decoder Pod"]
        subgraph Sidecar["llm-d-routing-sidecar<br/>(Port 8000/TCP · HTTPS)"]
            direction TB
            Proxy["HTTP Reverse Proxy<br/>(Go net/http)"]
            ChatHandler["/v1/chat/completions<br/>Handler"]
            CompHandler["/v1/completions<br/>Handler"]
            HealthHandler["/health<br/>Handler"]
            CatchAll["/* Catch-All<br/>Passthrough"]

            subgraph Connectors["Protocol Connectors"]
                NIXLV2["NIXL V2 Connector<br/>(default)"]
                NIXLV1["NIXL V1 Connector<br/>(deprecated)"]
                LMCache["LMCache Connector<br/>(deprecated)"]
            end

            subgraph Security["Security Layer"]
                AllowlistValidator["AllowlistValidator<br/>(SSRF Protection)"]
                TLSConfig["TLS Configuration<br/>TLS 1.2+ · Curated Ciphers"]
            end

            LRUCache["LRU Cache<br/>(Prefiller Proxy Handlers)"]

            Proxy --> ChatHandler
            Proxy --> CompHandler
            Proxy --> HealthHandler
            Proxy --> CatchAll
            ChatHandler --> AllowlistValidator
            CompHandler --> AllowlistValidator
            AllowlistValidator --> NIXLV2
            AllowlistValidator --> NIXLV1
            AllowlistValidator --> LMCache
            NIXLV2 --> LRUCache
            NIXLV1 --> LRUCache
        end

        Decoder["vLLM Decoder<br/>(Port 8001/TCP · localhost)"]
    end

    subgraph RemoteWorkers["Remote Prefill Workers"]
        Prefiller["vLLM Prefiller Pod(s)<br/>(Configurable Port)"]
    end

    subgraph K8sAPI["Kubernetes API Server"]
        InferencePoolCR["InferencePool CR<br/>(inference.networking.x-k8s.io/v1alpha2)"]
        PodAPI["Pod API<br/>(Watch · Allowlist)"]
    end

    %% External flows
    EPP -->|"POST · HTTPS/8000<br/>x-prefiller-host-port header"| Proxy
    Client -->|"POST · HTTPS/8000"| Proxy

    %% Internal flows
    NIXLV2 -->|"Prefill Request<br/>HTTP(S)"| Prefiller
    Prefiller -->|"kv_transfer_params<br/>Response"| NIXLV2
    NIXLV2 -->|"Decode Request + KV params<br/>HTTP(S)/8001"| Decoder
    CatchAll -->|"Passthrough<br/>HTTP(S)/8001"| Decoder

    %% K8s watches
    AllowlistValidator -->|"Watch<br/>HTTPS/443"| InferencePoolCR
    AllowlistValidator -->|"Watch<br/>HTTPS/443"| PodAPI

    %% Styling
    style Sidecar fill:#4a90e2,stroke:#2c5f8a,stroke-width:2px,color:#fff
    style Decoder fill:#7ed321,stroke:#5a9e18,stroke-width:2px,color:#fff
    style Prefiller fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    style NIXLV2 fill:#6c5ce7,stroke:#4b3dbd,stroke-width:1px,color:#fff
    style NIXLV1 fill:#999,stroke:#666,stroke-width:1px,color:#fff
    style LMCache fill:#999,stroke:#666,stroke-width:1px,color:#fff
    style AllowlistValidator fill:#e74c3c,stroke:#c0392b,stroke-width:1px,color:#fff
    style TLSConfig fill:#e74c3c,stroke:#c0392b,stroke-width:1px,color:#fff
    style EPP fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style InferencePoolCR fill:#f39c12,stroke:#d68910,stroke-width:1px,color:#fff
    style PodAPI fill:#f39c12,stroke:#d68910,stroke-width:1px,color:#fff
