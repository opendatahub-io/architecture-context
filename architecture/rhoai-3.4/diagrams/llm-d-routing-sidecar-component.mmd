graph TB
    subgraph External["External Clients"]
        Client[Client / Upstream Gateway]
    end

    subgraph Sidecar["llm-d-routing-sidecar (Go HTTP Reverse Proxy)"]
        direction TB
        ProxyListener["Proxy Listener<br/>8000/TCP HTTPS<br/>TLS 1.2+ (AEAD ciphers)"]

        subgraph Routing["Request Routing"]
            ChatHandler["/v1/chat/completions<br/>POST"]
            CompHandler["/v1/completions<br/>POST"]
            HealthHandler["/health<br/>GET"]
            CatchAll["/* catch-all<br/>ANY"]
        end

        subgraph Connectors["P/D Connectors"]
            NIXLv2["NIXL v2 Connector<br/>(default, active)"]
            NIXLv1["NIXL v1 Connector<br/>(deprecated)"]
            LMCache["LMCache Connector<br/>(deprecated)"]
        end

        subgraph Security["Security"]
            AllowlistValidator["AllowlistValidator<br/>K8s Informer"]
            LRUCache["LRU Cache<br/>(capacity: 16)<br/>Prefiller proxy handlers"]
        end

        ProxyListener --> ChatHandler
        ProxyListener --> CompHandler
        ProxyListener --> HealthHandler
        ProxyListener --> CatchAll

        ChatHandler -->|"x-prefiller-host-port<br/>header present"| NIXLv2
        CompHandler -->|"x-prefiller-host-port<br/>header present"| NIXLv2
        ChatHandler -->|"no prefill header"| CatchAll
        CompHandler -->|"no prefill header"| CatchAll

        NIXLv2 -->|"validate prefiller IP"| AllowlistValidator
        NIXLv2 -->|"cache proxy handler"| LRUCache
    end

    subgraph K8sAPI["Kubernetes API"]
        InferencePool["InferencePool CR<br/>inference.networking.x-k8s.io/v1alpha2"]
        PodAPI["Pod API<br/>core/v1"]
    end

    subgraph LocalPod["Local Pod"]
        vLLMDecoder["vLLM Decoder<br/>8001/TCP"]
    end

    subgraph RemotePods["Remote Pods"]
        vLLMPrefiller["vLLM Prefiller<br/>Variable Port"]
    end

    Client -->|"HTTPS/8000<br/>TLS 1.2+"| ProxyListener
    NIXLv2 -->|"Phase 1: Prefill request<br/>HTTP(S)"| vLLMPrefiller
    NIXLv2 -->|"Phase 2: Decode request<br/>with kv_transfer_params"| vLLMDecoder
    CatchAll -->|"Passthrough<br/>HTTP(S)/8001"| vLLMDecoder

    AllowlistValidator -->|"Watch<br/>HTTPS/443"| InferencePool
    AllowlistValidator -->|"Watch pods<br/>HTTPS/443"| PodAPI

    vLLMDecoder -->|"Response"| Client

    style ProxyListener fill:#4a90e2,stroke:#333,color:#fff
    style ChatHandler fill:#5ba8f7,stroke:#333,color:#fff
    style CompHandler fill:#5ba8f7,stroke:#333,color:#fff
    style HealthHandler fill:#5ba8f7,stroke:#333,color:#fff
    style CatchAll fill:#5ba8f7,stroke:#333,color:#fff
    style NIXLv2 fill:#7ed321,stroke:#333,color:#fff
    style NIXLv1 fill:#999,stroke:#333,color:#fff
    style LMCache fill:#999,stroke:#333,color:#fff
    style AllowlistValidator fill:#f5a623,stroke:#333,color:#fff
    style LRUCache fill:#f5a623,stroke:#333,color:#fff
    style vLLMDecoder fill:#9b59b6,stroke:#333,color:#fff
    style vLLMPrefiller fill:#9b59b6,stroke:#333,color:#fff
    style InferencePool fill:#e8e8e8,stroke:#333
    style PodAPI fill:#e8e8e8,stroke:#333
    style Client fill:#f9f9f9,stroke:#333
