graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        RouteHTTP["{registry-name} Route<br/>443/TCP → 8080/TCP<br/>TLS Edge"]
        RouteHTTPS["{registry-name}-https Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
        CatalogRoute["model-catalog-https Route<br/>443/TCP → 8443/TCP<br/>TLS Reencrypt"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["Operator Pod<br/>SA: controller-manager"]
            Operator["Model Registry Operator<br/>Image: model-registry-operator:latest"]
            MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>Bearer Token"]
            WebhookSvc["Webhook Service<br/>443→9443/TCP HTTPS<br/>TLS cert-manager<br/>K8s API mTLS"]
            HealthProbe["Health Probes<br/>8081/TCP HTTP<br/>No Auth"]
        end

        subgraph CatalogPod["Catalog Pod<br/>SA: model-catalog"]
            CatalogAPI["Catalog REST API<br/>8080/TCP HTTP<br/>No Auth (localhost)"]
            CatalogKRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>TokenReview + SAR"]
        end

        subgraph CatalogDBPod["Catalog PostgreSQL"]
            CatalogDB["PostgreSQL<br/>5432/TCP<br/>Password Auth"]
        end
    end

    subgraph InstanceNS["INSTANCE NAMESPACE ({registry-namespace})"]
        direction TB

        subgraph RegistryPod["Registry Pod<br/>SA: {registry-name}"]
            RestAPI["Registry REST API<br/>8080/TCP HTTP<br/>No Auth (localhost)"]
            KRBP["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>TLS serving cert<br/>TokenReview + SAR"]
        end

        subgraph PostgresPod["PostgreSQL (optional)"]
            PG["PostgreSQL 16<br/>5432/TCP<br/>SSLMode configurable<br/>Password Auth"]
        end
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>SA Token Auth"]
        TokenReview["TokenReview API"]
        SAR["SubjectAccessReview API"]
        SVM["StorageVersionMigration API"]
    end

    subgraph PlatformAPIs["ODH/RHOAI PLATFORM APIs"]
        AuthCR["Auth CR<br/>(admin groups)"]
        PlatformMR["ModelRegistry CR<br/>(owner reference)"]
        OCPIngress["config.openshift.io/Ingress<br/>(domain discovery)"]
        OCPRoute["route.openshift.io/Route"]
        OCPGroup["user.openshift.io/Group"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtPG["PostgreSQL (user-provided)<br/>5432/TCP<br/>SSLMode configurable<br/>Password Auth"]
        Prometheus["Prometheus<br/>Scrapes 8443/TCP HTTPS<br/>Bearer Token"]
        CertMgr["cert-manager<br/>Self-signed certs"]
        ServingCert["serving-cert-signer<br/>Annotation-driven"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RouteHTTP
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RouteHTTPS
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress → Services
    RouteHTTP -->|"HTTP/8080<br/>Edge terminated"| RestAPI
    RouteHTTPS -->|"HTTPS/8443<br/>Reencrypt<br/>TLS serving cert"| KRBP
    CatalogRoute -->|"HTTPS/8443<br/>Reencrypt<br/>TLS serving cert"| CatalogKRBP

    %% kube-rbac-proxy flows
    KRBP -->|"HTTP/8080<br/>localhost"| RestAPI
    KRBP -->|"HTTPS/443<br/>TokenReview"| TokenReview
    KRBP -->|"HTTPS/443<br/>SAR"| SAR
    CatalogKRBP -->|"HTTP/8080<br/>localhost"| CatalogAPI
    CatalogKRBP -->|"HTTPS/443<br/>TokenReview"| TokenReview
    CatalogKRBP -->|"HTTPS/443<br/>SAR"| SAR

    %% REST API → DB
    RestAPI -->|"PostgreSQL/5432<br/>SSLMode configurable<br/>Password"| PG
    RestAPI -.->|"PostgreSQL/5432<br/>SSLMode configurable<br/>Password"| ExtPG
    CatalogAPI -->|"PostgreSQL/5432<br/>Password"| CatalogDB

    %% Operator → Control Plane
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Operator -->|"Migration"| SVM

    %% Operator → Platform APIs
    Operator -->|"GET admin groups"| AuthCR
    Operator -->|"GET owner ref"| PlatformMR
    Operator -->|"GET domain"| OCPIngress
    Operator -->|"Create routes"| OCPRoute
    Operator -->|"Create groups"| OCPGroup

    %% External services → Operator
    Prometheus -->|"HTTPS/8443<br/>TLS serving cert<br/>Bearer Token"| MetricsSvc
    CertMgr -.->|"Cert provisioning"| WebhookSvc
    ServingCert -.->|"Annotation-driven"| MetricsSvc
    K8sAPI -->|"HTTPS/9443<br/>mTLS"| WebhookSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef instance fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class RouteHTTP,RouteHTTPS,CatalogRoute ingress
    class Operator,MetricsSvc,WebhookSvc,HealthProbe,CatalogAPI,CatalogKRBP,CatalogDB operator
    class RestAPI,KRBP,PG instance
    class K8sAPI,TokenReview,SAR,SVM controlplane
    class AuthCR,PlatformMR,OCPIngress,OCPRoute,OCPGroup platform
    class ExtPG,Prometheus,CertMgr,ServingCert extservice
