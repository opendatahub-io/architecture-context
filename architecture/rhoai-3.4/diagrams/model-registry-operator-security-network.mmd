graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["User / Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        RegistryRoute["Route: {name}-https<br/>{name}-rest.{domain}<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
        CatalogRoute["Route: {name}-catalog-https<br/>{name}-catalog.{domain}<br/>443/TCP → 8443/TCP<br/>TLS reencrypt"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER"]
        KRBP_Registry["kube-rbac-proxy<br/>(registry sidecar)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>AuthN: TokenReview<br/>AuthZ: SAR (GET services)"]
        KRBP_Catalog["kube-rbac-proxy<br/>(catalog sidecar)<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving cert<br/>AuthN: TokenReview<br/>AuthZ: SAR (GET services)"]
    end

    subgraph AppLayer["APPLICATION LAYER (Cluster Internal)"]
        direction TB

        subgraph NS_Registry["Namespace: {namespace}"]
            Registry["model-registry REST<br/>SA: {name}<br/>8080/TCP HTTP<br/>(pod-internal only)"]
            RegistryPG["PostgreSQL 16<br/>5432/TCP<br/>Credentials: Secret<br/>NP: app={name} only"]
            Catalog["Catalog Service<br/>8080/TCP HTTP<br/>(pod-internal only)"]
            CatalogPG["Catalog PostgreSQL<br/>5432/TCP<br/>Credentials: Secret"]
        end
    end

    subgraph ControlPlane["OPERATOR CONTROL PLANE"]
        Operator["Model Registry Operator<br/>NS: opendatahub<br/>SA: controller-manager<br/>8081/TCP HTTP (probes)<br/>8443/TCP HTTPS (metrics)<br/>9443/TCP HTTPS (webhooks)"]
    end

    subgraph K8sPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        ExtPG["External PostgreSQL<br/>5432/TCP<br/>Optional TLS<br/>Username/password"]
        ExtMySQL["External MySQL/MariaDB<br/>3306/TCP<br/>Optional TLS<br/>Username/password"]
        S3["S3 Storage<br/>443/TCP HTTPS TLS<br/>(async upload jobs)"]
        OCI["OCI Registry<br/>443/TCP HTTPS TLS<br/>(async upload jobs)"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| RegistryRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| CatalogRoute

    %% Ingress → Auth Proxy
    RegistryRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OpenShift serving cert"| KRBP_Registry
    CatalogRoute -->|"HTTPS/8443<br/>TLS reencrypt<br/>OpenShift serving cert"| KRBP_Catalog

    %% Auth Proxy → K8s API (auth delegation)
    KRBP_Registry -->|"HTTPS/6443<br/>TLS<br/>TokenReview + SAR"| K8sAPI
    KRBP_Catalog -->|"HTTPS/6443<br/>TLS<br/>TokenReview + SAR"| K8sAPI

    %% Auth Proxy → Application
    KRBP_Registry -->|"HTTP/8080<br/>None (localhost)<br/>Authenticated"| Registry
    KRBP_Catalog -->|"HTTP/8080<br/>None (localhost)<br/>Authenticated"| Catalog

    %% Application → Database
    Registry -->|"TCP/5432<br/>Optional TLS<br/>Username/password"| RegistryPG
    Catalog -->|"TCP/5432<br/>None<br/>Username/password"| CatalogPG

    %% Operator → K8s API
    Operator -->|"HTTPS/6443<br/>TLS<br/>SA token<br/>Watches + CRUD"| K8sAPI

    %% K8s API → Operator (webhooks)
    K8sAPI -->|"HTTPS/9443<br/>TLS serving cert<br/>Admission webhooks"| Operator

    %% Application → External Services (optional)
    Registry -.->|"TCP/5432<br/>Optional TLS<br/>Username/password"| ExtPG
    Registry -.->|"TCP/3306<br/>Optional TLS<br/>Username/password"| ExtMySQL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef k8splane fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class RegistryRoute,CatalogRoute ingress
    class KRBP_Registry,KRBP_Catalog authproxy
    class Registry,RegistryPG,Catalog,CatalogPG application
    class Operator controlplane
    class K8sAPI k8splane
    class ExtPG,ExtMySQL,S3,OCI externalservice
