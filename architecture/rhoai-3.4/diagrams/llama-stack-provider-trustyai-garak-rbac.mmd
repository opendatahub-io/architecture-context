graph TD
    subgraph Note["RBAC Note"]
        direction TB
        Info["This component does NOT define<br/>its own RBAC manifests.<br/>It is a provider library, not a K8s operator."]
    end

    subgraph KFPMode["KFP Mode - Inherited RBAC"]
        direction TB

        subgraph ServiceAccounts["Service Accounts (Inherited)"]
            KFPSA["KFP Pipeline Runner SA<br/>(provided by Kubeflow Pipelines)"]
        end

        subgraph RequiredAccess["Required Kubernetes API Access"]
            ConfigMapRead["ConfigMap Read<br/>trustyai-service-operator-config"]
            SecretMount["Secret Mount<br/>(via KFP kubernetes extensions)"]
        end

        subgraph Namespaces["Target Namespaces"]
            NS1["redhat-ods-applications"]
            NS2["opendatahub"]
        end

        KFPSA -->|"reads"| ConfigMapRead
        KFPSA -->|"mounts"| SecretMount
        ConfigMapRead -->|"namespace"| NS1
        ConfigMapRead -->|"namespace"| NS2
    end

    subgraph Secrets["Secrets Used (Not Defined)"]
        direction TB
        ModelKeys["Model API Keys<br/>Type: Opaque<br/>Provisioned: Manual / K8s Secret mount<br/>Auto-Rotate: No"]
        KFPToken["KFP API Token<br/>Type: Opaque<br/>Provisioned: Manual / SA token<br/>Auto-Rotate: No"]
        S3Creds["S3 Data Connection<br/>Type: Opaque<br/>Provisioned: Manual / DSPA<br/>Auto-Rotate: No"]
        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Provisioned: Manual / K8s Secret mount<br/>Auto-Rotate: No"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB
        APIKeyAuth["API Key Auth<br/>Multi-level resolution:<br/>1. Env var (MODEL_API_KEY)<br/>2. Mounted Secret file<br/>3. Fallback: DUMMY"]
        BearerAuth["Bearer Token Auth<br/>Resolution:<br/>1. Config-provided token<br/>2. Kubeconfig SA token"]
        AWSAuth["AWS IAM Auth<br/>Access key + Secret key<br/>via kubernetes.use_secret_as_env()"]
    end

    SecretMount -->|"provides"| ModelKeys
    SecretMount -->|"provides"| S3Creds
    SecretMount -->|"provides"| HFToken
    KFPSA -->|"generates"| KFPToken

    ModelKeys -->|"used by"| APIKeyAuth
    KFPToken -->|"used by"| BearerAuth
    S3Creds -->|"used by"| AWSAuth

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style Info fill:#fff3cd,stroke:#ffc107
    style KFPMode fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style KFPSA fill:#4a90e2,color:#fff
    style ConfigMapRead fill:#f5a623
    style SecretMount fill:#f5a623
    style NS1 fill:#7ed321
    style NS2 fill:#7ed321
    style ModelKeys fill:#f8cecc,stroke:#b85450
    style KFPToken fill:#f8cecc,stroke:#b85450
    style S3Creds fill:#f8cecc,stroke:#b85450
    style HFToken fill:#f8cecc,stroke:#b85450
    style APIKeyAuth fill:#d5e8d4,stroke:#82b366
    style BearerAuth fill:#d5e8d4,stroke:#82b366
    style AWSAuth fill:#d5e8d4,stroke:#82b366
