graph LR
    KFTO["Training Operator<br/>(KFTO)"]

    %% External Dependencies (Required)
    KFTO -->|"controller framework<br/>v0.19.1"| ControllerRuntime["controller-runtime<br/>v0.19.1"]
    KFTO -->|"target platform<br/>client-go v0.31.3"| Kubernetes["Kubernetes<br/>1.31+"]
    KFTO -->|"TLS cert rotation<br/>v0.12.0"| CertController["OPA cert-controller<br/>v0.12.0"]
    KFTO -->|"metrics instrumentation<br/>v1.20.2"| PromClient["prometheus/<br/>client_golang v1.20.2"]

    %% External Dependencies (Optional)
    KFTO -.->|"gang scheduling<br/>v1.9.0 (optional)"| Volcano["Volcano APIs<br/>v1.9.0"]
    KFTO -.->|"gang scheduling<br/>v0.28.9 (optional)"| SchedPlugins["scheduler-plugins<br/>v0.28.9"]

    %% Internal RHOAI Dependencies
