    KFTO -->|"reconciles"| JAXJob["JAXJob<br/>kubeflow.org/v1"]
    KFTO -->|"reconciles"| PaddleJob["PaddleJob<br/>kubeflow.org/v1"]
    KFTO -->|"reconciles"| XGBoostJob["XGBoostJob<br/>kubeflow.org/v1"]

