    Prometheus["Prometheus"] -->|"scrapes metrics<br/>via PodMonitor"| KFTO

    %% Kubernetes API Resources
    KFTO -->|"CRUD operations"| K8sAPI["Kubernetes API<br/>Server"]

    %% Created Resources
    subgraph ManagedResources["Managed K8s Resources"]
        Pods["Pods"]
        Services["Services"]
        HPA["HPA"]
        PodGroups["PodGroups"]
        NP["NetworkPolicies"]
        RBAC["Roles /<br/>RoleBindings"]
    end

    KFTO -->|"creates/manages"| ManagedResources

