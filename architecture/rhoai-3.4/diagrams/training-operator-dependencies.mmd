graph LR
    KFTO["Training Operator<br/>(KFTO)"]

    %% External Dependencies (Required)
    KFTO -->|"Pod/Svc/CM/RBAC CRUD<br/>443/TCP HTTPS"| K8sAPI["Kubernetes API<br/>v1.31+"]
    KFTO -->|"operator framework<br/>reconciliation, webhooks"| ControllerRuntime["controller-runtime<br/>v0.19.1"]
    KFTO -->|"TLS cert generation<br/>& rotation"| CertController["cert-controller<br/>v0.12.0"]

    %% External Dependencies (Optional)
    KFTO -.->|"gang scheduling<br/>PodGroup CRD"| Volcano["Volcano<br/>v1.9.0"]
