graph TD
    subgraph ConsumingDeployment["Consuming Deployment (e.g., llm-d-inference-scheduler)"]
        SA["ServiceAccount<br/>(defined by consumer)"]
    end

    subgraph RoleBindings["Role Bindings"]
        CRB["ClusterRoleBinding / RoleBinding<br/>(defined by consuming deployment)"]
    end

    subgraph ClusterRolePerms["ClusterRole Permissions"]
        CR["Pod Reconciler Role<br/>(cluster or namespace scoped)"]
    end

    subgraph APIResources["API Resources Accessed"]
        Pods["core (v1)<br/>pods"]
    end

    subgraph LabelSelector["Label Selector Filter"]
        Label["llm-d.ai/inferenceServing=true<br/>(default pod selector)"]
    end

    subgraph AccessPattern["Access Pattern"]
        Watch["controller-runtime cached client<br/>Watch + List + Get"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| Pods
    Pods -->|"filtered by"| Label
    Watch -->|"uses"| Pods

    subgraph Notes["Security Notes"]
        direction TB
        Note1["This is a LIBRARY component - RBAC is<br/>configured by the consuming deployment,<br/>not by llm-d-kv-cache itself"]
        Note2["The kvevents.Pool pod reconciler uses<br/>controller-runtime's cached client to<br/>watch pods matching the label selector"]
        Note3["No secrets directly consumed<br/>Redis creds: via connection URL<br/>HF tokens: via env vars from consumer"]
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#b8d4e3,stroke:#333
    style CR fill:#f5a623,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style Label fill:#e8e8e8,stroke:#333
    style Watch fill:#e8e8e8,stroke:#333
    style Note1 fill:#fff3cd,stroke:#856404,color:#856404
    style Note2 fill:#fff3cd,stroke:#856404,color:#856404
    style Note3 fill:#fff3cd,stroke:#856404,color:#856404
