graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["operator-controller-manager<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph RoleBindings["Role Bindings"]
        RB["exec-rbac-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        Role["exec-rbac-role<br/>(deploy/rbac/)"]
    end

    subgraph APIResources["API Resources"]
        Pods["Core API Group<br/>pods<br/>Verbs: get, list, create"]
        PodsExec["Core API Group<br/>pods/exec<br/>Verbs: get, list, create"]
    end

    SA -->|"bound via"| RB
    RB -->|"grants"| Role
    Role -->|"get, list, create"| Pods
    Role -->|"get, list, create"| PodsExec

    subgraph Secrets["Secrets"]
        HFToken["HF Token Secret<br/>Type: Opaque<br/>Purpose: HuggingFace Hub auth<br/>Provisioned: Manual/Helm<br/>Auto-rotate: No"]
    end

    subgraph AuthMechanisms["Authentication Mechanisms"]
        UDSAuth["UDS Tokenizer gRPC<br/>Auth: None (UDS file perms)<br/>Enforcement: Filesystem<br/>UID 65532"]
        HealthAuth["Health /healthz<br/>Auth: None<br/>Enforcement: None<br/>Open endpoint"]
        ZMQAuth["ZMQ Event Sub<br/>Auth: None<br/>Enforcement: Network isolation<br/>Cluster-internal only"]
        RedisAuth["Redis/Valkey<br/>Auth: None (default)<br/>Enforcement: Network<br/>Redis ACL optional"]
        K8sAuth["Kubernetes API<br/>Auth: ServiceAccount token<br/>Enforcement: mTLS<br/>controller-runtime"]
        HFAuth["HuggingFace Hub<br/>Auth: Bearer Token<br/>Enforcement: HTTPS<br/>HF_TOKEN env var"]
    end

    SA -->|"uses"| K8sAuth
    HFToken -->|"provides credentials for"| HFAuth

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style RB fill:#b8d4f0,stroke:#333
    style Role fill:#f5a623,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style PodsExec fill:#7ed321,stroke:#333
    style HFToken fill:#e74c3c,stroke:#333,color:#fff
    style UDSAuth fill:#d5e8d4,stroke:#82b366
    style HealthAuth fill:#d5e8d4,stroke:#82b366
    style ZMQAuth fill:#fff2cc,stroke:#d6b656
    style RedisAuth fill:#fff2cc,stroke:#d6b656
    style K8sAuth fill:#d5e8d4,stroke:#82b366
    style HFAuth fill:#ffe6cc,stroke:#d79b00
