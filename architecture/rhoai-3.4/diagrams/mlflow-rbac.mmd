graph TD
    subgraph OperatorManaged["Kubernetes RBAC (Managed by rhods-operator)"]
        SA["ServiceAccount<br/>{mlflow-sa}"]
        RoleBinding["RoleBinding<br/>(operator-managed)"]
        Role["Role / ClusterRole<br/>(operator-managed)"]

        subgraph K8sResources["Kubernetes API Resources"]
            Namespaces["core<br/>Namespaces<br/>(read - workspace discovery)"]
            TokenReview["authentication.k8s.io<br/>TokenReview<br/>(create - SA token validation)"]
        end

        SA -->|"bound via"| RoleBinding
        RoleBinding -->|"grants"| Role
        Role -->|"get, list, watch"| Namespaces
        Role -->|"create"| TokenReview
    end

    subgraph AppLevelAuth["Application-Level Authorization (MLflow Auth Module)"]
        direction TB

        subgraph AuthFlow["Authentication Flow"]
            Request["Incoming Request"]
            KubeRBACProxy2["kube-rbac-proxy<br/>(K8s SubjectAccessReview)"]
            AuthMiddleware["MLflow Auth Middleware<br/>(before_request / ASGI)"]
            K8sTokenValidation["K8s Token Validation<br/>(TokenReview API call)"]
        end

        subgraph PermissionModel["Permission Model"]
            direction LR
            READ["READ<br/>(view experiments,<br/>runs, models)"]
            USE["USE<br/>(use registered<br/>models)"]
            EDIT["EDIT<br/>(create/modify<br/>experiments, runs)"]
            MANAGE["MANAGE<br/>(admin: delete,<br/>manage permissions)"]
        end

        subgraph PermissionHierarchy["Permission Resolution (3-Tier)"]
            Tier1["1. Resource-Specific<br/>Permissions"]
            Tier2["2. Workspace-Level<br/>Permissions"]
            Tier3["3. Default<br/>Permissions"]
            Tier1 -->|"fallback"| Tier2
            Tier2 -->|"fallback"| Tier3
        end

        subgraph WorkspaceScope["Workspace Scoping"]
            WSHeader["X-MLFLOW-WORKSPACE<br/>HTTP Header"]
            WSStore["Workspace Store<br/>(kubernetes:// provider)"]
            NSMapping["Namespace → Workspace<br/>Mapping"]
            PermCache["Permission Cache<br/>(10,000 entries, TTL)"]
        end

        Request --> KubeRBACProxy2
        KubeRBACProxy2 --> AuthMiddleware
        AuthMiddleware --> K8sTokenValidation
        AuthMiddleware --> PermissionHierarchy
        WSHeader --> WSStore
        WSStore --> NSMapping
        AuthMiddleware --> PermCache
    end

    subgraph AuthExempt["Auth-Exempt Endpoints"]
        Health["/health - GET"]
        Version["/version - GET"]
        Static["/static-files/* - GET"]
        Index["/ - GET (SPA)"]
    end

    subgraph SpecialAuth["Special Auth Handling"]
        GraphQLAuth["GraphQL:<br/>Field-level read check<br/>Admin bypass"]
        GatewayAuth["Gateway:<br/>FastAPI permission middleware<br/>Endpoint-specific check"]
    end

    %% Styling
    style OperatorManaged fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style AppLevelAuth fill:#fff3cd,stroke:#d79b00,stroke-width:2px
    style AuthExempt fill:#d4edda,stroke:#82b366,stroke-width:2px
    style SpecialAuth fill:#f8d7da,stroke:#b85450,stroke-width:2px

    style SA fill:#4a90e2,color:#fff
    style RoleBinding fill:#4a90e2,color:#fff
    style Role fill:#4a90e2,color:#fff
    style Namespaces fill:#7ed321,color:#fff
    style TokenReview fill:#7ed321,color:#fff

    style READ fill:#28a745,color:#fff
    style USE fill:#17a2b8,color:#fff
    style EDIT fill:#ffc107,color:#000
    style MANAGE fill:#dc3545,color:#fff

    style Tier1 fill:#f5a623,color:#fff
    style Tier2 fill:#f5a623,color:#fff
    style Tier3 fill:#f5a623,color:#fff

    style PermCache fill:#e8e8e8,stroke:#999
    style WSHeader fill:#e8e8e8,stroke:#999
    style WSStore fill:#e8e8e8,stroke:#999
    style NSMapping fill:#e8e8e8,stroke:#999
