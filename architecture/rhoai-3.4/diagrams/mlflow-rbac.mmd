graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["mlflow-server SA"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings (Operator-Managed)"]
        CRB["(Operator-managed)<br/>ClusterRoleBinding<br/>Scope: cluster-scoped"]
    end

    subgraph ClusterRoles["ClusterRoles (Operator-Managed)"]
        CR["(Operator-managed)<br/>ClusterRole"]
    end

    subgraph APIResources["API Resources"]
        Namespaces["core (v1)<br/>namespaces"]
        SSAR["authorization.k8s.io<br/>selfsubjectaccessreviews"]
        MLflowConfig["mlflow.kubeflow.org<br/>MLflowConfig"]
    end

    subgraph PseudoResources["Pseudo-Resources (Authorization Target)"]
        direction TB
        MLflowExperiments["mlflow.kubeflow.org<br/>experiments<br/>(pseudo-resource)"]
        MLflowRuns["mlflow.kubeflow.org<br/>runs<br/>(pseudo-resource)"]
        MLflowModels["mlflow.kubeflow.org<br/>registered-models<br/>(pseudo-resource)"]
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction TB
        BearerToken["Bearer Token<br/>(K8s SA Token)"]
        KubeAuthPlugin["kubernetes-auth Plugin"]
        SSARCheck["SelfSubjectAccessReview<br/>Check"]
        Decision{"Allowed?"}
    end

    %% RBAC bindings
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"get, list, watch"| Namespaces
    CR -->|"create"| SSAR
    CR -->|"get, list, watch"| MLflowConfig

    %% Auth flow
    BearerToken -->|"extracted from<br/>Authorization header"| KubeAuthPlugin
    KubeAuthPlugin -->|"creates"| SSARCheck
    SSARCheck -->|"checks against"| MLflowExperiments
    SSARCheck -->|"checks against"| MLflowRuns
    SSARCheck -->|"checks against"| MLflowModels
    SSARCheck --> Decision

    %% Endpoint auth mapping
    subgraph EndpointAuth["Endpoint Authentication"]
        AuthEndpoints["/api/2.0/mlflow/*<br/>/ajax-api/*<br/>/v1/traces<br/>→ Bearer Token required"]
        NoAuthEndpoints["/health, /version<br/>/static-files/*, /<br/>→ No auth (public)"]
    end

    AuthEndpoints -->|"enforced by"| KubeAuthPlugin
    NoAuthEndpoints -.->|"exempt"| KubeAuthPlugin

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#5c6bc0,color:#fff
    style CR fill:#f5a623,color:#fff
    style Namespaces fill:#7ed321,color:#fff
    style SSAR fill:#7ed321,color:#fff
    style MLflowConfig fill:#7ed321,color:#fff
    style MLflowExperiments fill:#26a69a,color:#fff
    style MLflowRuns fill:#26a69a,color:#fff
    style MLflowModels fill:#26a69a,color:#fff
    style BearerToken fill:#e1bee7,stroke:#8e24aa
    style KubeAuthPlugin fill:#7e57c2,color:#fff
    style SSARCheck fill:#7e57c2,color:#fff
    style Decision fill:#fff9c4,stroke:#f9a825
    style AuthEndpoints fill:#c8e6c9,stroke:#2e7d32
    style NoAuthEndpoints fill:#ffcdd2,stroke:#c62828
