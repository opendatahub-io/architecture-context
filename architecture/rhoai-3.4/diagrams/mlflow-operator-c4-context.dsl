// MLflow Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/mlflow-operator.md

workspace {
    model {
        // People
        dataScientist = person "Data Scientist" "Creates experiments, logs runs, registers models via MLflow"
        admin = person "Platform Admin" "Deploys and configures MLflow instances via MLflow CRs"

        // Primary System
        mlflowOperator = softwareSystem "MLflow Operator" "Kubernetes operator managing MLflow tracking server lifecycle on OpenShift" {
            controller = container "MLflow Operator Controller" "Reconciles MLflow CRs, renders Helm chart templates, creates child resources via Server-Side Apply" "Go (controller-runtime)"
            helmRenderer = container "Helm Chart Renderer" "Embedded Helm v3 library rendering charts/mlflow templates to Kubernetes manifests" "Go Library"
            mlflowServer = container "MLflow Server" "MLflow tracking server with experiment tracking, model registry, workspaces, and AI Gateway; HTTPS on port 8443" "Python (uvicorn)"
            caInitContainer = container "CA Bundle Init Container" "Combines system, platform, and custom CA bundles into a single PEM file" "Container"
            caWatcherSidecar = container "CA Bundle Watcher Sidecar" "Watches for CA ConfigMap changes and regenerates combined CA bundle (30s interval)" "Container"
        }

        // External Dependencies
        gatewayAPI = softwareSystem "Gateway API (data-science-gateway)" "RHOAI 3.x ingress pattern; Envoy-based Gateway in openshift-ingress namespace" "External"
        openshiftConsole = softwareSystem "OpenShift Console" "Web console with application menu integration via ConsoleLink CRs" "External"
        prometheusOperator = softwareSystem "Prometheus (via ServiceMonitor)" "Metrics scraping for operator and MLflow server" "External"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster API server for CR watches, Server-Side Apply, and SelfSubjectAccessReview" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca" "Auto-provisions TLS certificates for annotated services" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys MLflow operator via config/overlays/rhoai kustomize overlay" "Internal RHOAI"
        odhTrustedCA = softwareSystem "odh-trusted-ca-bundle" "Platform CA bundle ConfigMap for TLS verification" "Internal RHOAI"

        // External Services
        s3Storage = softwareSystem "S3-compatible Storage" "Artifact storage (AWS S3, MinIO, SeaweedFS)" "External Service"
        postgresql = softwareSystem "PostgreSQL" "Backend and registry metadata store" "External Service"
        mysql = softwareSystem "MySQL" "Backend and registry metadata store (alternative)" "External Service"

        // Relationships - Users
        dataScientist -> mlflowOperator "Uses MLflow UI and REST API" "HTTPS/443 via Gateway"
        admin -> mlflowOperator "Creates MLflow CRs" "kubectl / HTTPS"

        // Relationships - Internal
        controller -> helmRenderer "Renders chart templates" "Function call"
        controller -> mlflowServer "Deploys and manages" "Server-Side Apply"
        caInitContainer -> mlflowServer "Initializes CA bundles" "Startup"
        caWatcherSidecar -> mlflowServer "Updates CA bundles" "30s interval"

        // Relationships - External Dependencies
        mlflowOperator -> gatewayAPI "Creates HTTPRoute resources for ingress" "Gateway API v1 / HTTPS 8443"
        mlflowOperator -> openshiftConsole "Creates ConsoleLink for menu integration" "ConsoleLink CR"
        mlflowOperator -> prometheusOperator "Creates ServiceMonitor for metrics scraping" "ServiceMonitor CR / HTTPS 8443"
        mlflowOperator -> kubernetesAPI "Watches CRs, applies resources, RBAC checks" "HTTPS/6443"
        mlflowOperator -> openshiftServiceCA "Uses for TLS certificate provisioning" "Annotation-driven"

        // Relationships - Internal ODH
        rhodsOperator -> mlflowOperator "Deploys via kustomize overlay"
        mlflowOperator -> odhTrustedCA "Watches for CA bundle updates" "ConfigMap watch"

        // Relationships - External Services
        mlflowOperator -> s3Storage "Stores/retrieves model artifacts" "HTTPS/443, HTTP/9000,8333"
        mlflowOperator -> postgresql "Stores experiment and registry metadata" "PostgreSQL/5432 TLS"
        mlflowOperator -> mysql "Stores experiment and registry metadata" "MySQL/3306 TLS"
    }

    views {
        systemContext mlflowOperator "SystemContext" {
            include *
            autoLayout
        }

        container mlflowOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #d4a017
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
