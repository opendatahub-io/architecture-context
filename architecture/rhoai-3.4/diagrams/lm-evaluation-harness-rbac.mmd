graph TD
    subgraph "lm-evaluation-harness RBAC Model"
        direction TB

        Note["NOTE: This component does not define its own RBAC.<br/>All RBAC is managed by the TrustyAI / LMEval Operator<br/>that creates the Kubernetes Job."]

        subgraph "Operator-Managed RBAC"
            OperatorSA["TrustyAI LMEval Operator<br/>ServiceAccount"]
            OperatorSA -->|"creates"| Job["Kubernetes Job<br/>(lm-evaluation-harness)"]
        end

        subgraph "Job Runtime Identity"
            JobSA["Job ServiceAccount<br/>(provisioned by Operator)"]
        end

        subgraph "Credential Access (Secrets)"
            ModelSecret["model-auth-secret<br/>(Opaque)<br/>OPENAI_API_KEY<br/>HF_TOKEN<br/>Custom CA cert"]
            OCISecret["OCI Registry Credentials<br/>(Opaque)<br/>Username / Password"]
        end

        subgraph "External Auth Mechanisms"
            ModelAuth["Model Endpoint Auth<br/>Method: Bearer Token<br/>Source: OPENAI_API_KEY env var"]
            EvalHubAuth["EvalHub Callback Auth<br/>Method: Bearer Token<br/>Source: Job spec"]
            HFAuth["HuggingFace Hub Auth<br/>Method: Bearer Token<br/>Source: HF_TOKEN env var"]
            OCIAuth["OCI Registry Auth<br/>Method: Username/Password<br/>Source: Registry credentials"]
            MLflowAuth["MLflow Auth<br/>Method: Bearer Token<br/>Source: Environment"]
        end

        Job -->|"runs as"| JobSA
        JobSA -->|"mounts"| ModelSecret
        JobSA -->|"mounts"| OCISecret
        ModelSecret -->|"provides"| ModelAuth
        ModelSecret -->|"provides"| HFAuth
        OCISecret -->|"provides"| OCIAuth
    end

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style OperatorSA fill:#4a90e2,stroke:#333,color:#fff
    style Job fill:#4a90e2,stroke:#333,color:#fff
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style ModelSecret fill:#f5a623,stroke:#333
    style OCISecret fill:#f5a623,stroke:#333
    style ModelAuth fill:#d4e6f1,stroke:#333
    style EvalHubAuth fill:#d4e6f1,stroke:#333
    style HFAuth fill:#d4e6f1,stroke:#333
    style OCIAuth fill:#d4e6f1,stroke:#333
    style MLflowAuth fill:#d4e6f1,stroke:#333
