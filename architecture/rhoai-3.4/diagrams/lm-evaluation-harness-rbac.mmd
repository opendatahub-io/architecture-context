graph TD
    subgraph ParentOperator["Parent Operator (TrustyAI / EvalHub)"]
        Operator["EvalHub Operator<br/>Manages Job lifecycle"]
    end

    subgraph JobExecution["LMES Job (Kubernetes Job)"]
        SA["ServiceAccount<br/>(managed by Operator)"]
        Job["LMES Job Container"]
    end

    subgraph SecretAccess["Secrets Consumed"]
        ModelSecret["Model Auth Secret<br/>(model.auth.secret_ref)<br/>Type: Opaque<br/>Keys: OPENAI_API_KEY, hf-token"]
        OCISecret["OCI Registry Auth<br/>(/tmp/.docker/config.json)<br/>Type: Docker config<br/>Registry credentials"]
        CASecret["CA Certificate Bundle<br/>(verify_certificate)<br/>Type: Opaque<br/>Custom CA cert"]
    end

    subgraph ConfigAccess["ConfigMaps Consumed"]
        JobSpec["/meta/job.json<br/>Job Specification<br/>Model, benchmark,<br/>parameters, callback URL"]
    end

    subgraph AuthMechanisms["Authentication at Runtime"]
        ModelAuth["Model Endpoint<br/>Bearer Token<br/>(OPENAI_API_KEY env var)"]
        EvalHubAuth["EvalHub Callbacks<br/>Bearer Token<br/>(from job spec)"]
        HFAuth["HuggingFace Hub<br/>HF_TOKEN env var<br/>(optional)"]
        OCIAuth["OCI Registry<br/>Docker config or<br/>OCI_USERNAME/PASSWORD"]
        MLflowAuth["MLflow<br/>Bearer Token"]
    end

    Operator -->|"creates Job with<br/>ServiceAccount & RBAC"| SA
    SA -->|"runs as"| Job
    Job -->|"reads"| ModelSecret
    Job -->|"reads"| OCISecret
    Job -->|"reads"| CASecret
    Job -->|"reads"| JobSpec
    ModelSecret -->|"provides"| ModelAuth
    ModelSecret -->|"provides"| HFAuth
    OCISecret -->|"provides"| OCIAuth
    Job -->|"uses"| EvalHubAuth
    Job -->|"uses"| MLflowAuth

    Note1["Note: No RBAC resources (ClusterRoles,<br/>RoleBindings) are defined in this repository.<br/>All RBAC is managed by the parent<br/>EvalHub/TrustyAI Operator."]

    style Operator fill:#7ed321,color:#fff
    style SA fill:#4a90e2,color:#fff
    style Job fill:#4a90e2,color:#fff
    style ModelSecret fill:#f5a623,color:#fff
    style OCISecret fill:#f5a623,color:#fff
    style CASecret fill:#f5a623,color:#fff
    style JobSpec fill:#e8e8e8,stroke:#333
    style ModelAuth fill:#fff,stroke:#999
    style EvalHubAuth fill:#fff,stroke:#999
    style HFAuth fill:#fff,stroke:#999
    style OCIAuth fill:#fff,stroke:#999
    style MLflowAuth fill:#fff,stroke:#999
    style Note1 fill:#ffe6e6,stroke:#cc0000,color:#333
