graph TB
    subgraph Provider["llama-stack-provider-trustyai-garak"]
        direction TB

        subgraph EvalAPI["Eval API Provider"]
            RegisterBenchmark["register_benchmark()<br/>BenchmarksProtocolPrivate"]
            RunEval["run_eval()<br/>Eval Protocol"]
            JobStatus["job_status()"]
            JobResult["job_result()"]
            JobCancel["job_cancel()"]
        end

        subgraph ExecModes["Execution Modes"]
            InlineEval["Inline Eval<br/>(garak_eval.py)<br/>Local subprocess"]
            RemoteEval["Remote Eval<br/>(garak_remote_eval.py)<br/>KFP pipeline submission"]
            EvalHubAdapter["EvalHub Adapter<br/>(garak_adapter.py)<br/>FrameworkAdapter"]
        end

        subgraph CoreLogic["Core Logic"]
            GarakRunner["Garak Runner<br/>Subprocess execution<br/>+ timeout mgmt"]
            PipelineSteps["Pipeline Steps<br/>Config building<br/>+ API key resolution"]
            ResultUtils["Result Utils<br/>JSONL/AVID/hit parsing<br/>+ TBSA scoring"]
            GarakConfig["Garak Command Config<br/>Profile resolution<br/>+ deep-merge"]
        end

        subgraph SDGSubsystem["SDG Subsystem"]
            SDG["SDG Generator<br/>(sdg.py)<br/>sdg-hub FlowRegistry"]
            Intents["Intent Generator<br/>(intents.py)<br/>CAS topology files"]
        end

        subgraph SafetyLayer["Safety Layer"]
            ShieldOrchestrator["SimpleShieldOrchestrator<br/>(shield_scan.py)<br/>Input/Output shield checks"]
        end

        RunEval --> InlineEval
        RunEval --> RemoteEval
        RunEval --> EvalHubAdapter
        InlineEval --> GarakRunner
        RemoteEval --> PipelineSteps
        EvalHubAdapter --> PipelineSteps
        GarakRunner --> ResultUtils
        RegisterBenchmark --> GarakConfig
        InlineEval --> SDG
        SDG --> Intents
        InlineEval --> ShieldOrchestrator
    end

    %% External Systems
    LlamaStackServer["Llama Stack Server<br/>(Host Process)"]
    KFP["Kubeflow Pipelines<br/>API"]
    TargetLLM["Target LLM<br/>(Under Test)"]
    S3["S3 / Object Storage"]
    FilesAPI["Llama Stack Files API"]
    SafetyAPI["Llama Stack Safety API"]
    InferenceAPI["Llama Stack Inference API"]
    HuggingFace["HuggingFace Hub"]
    ConfigMap["trustyai-service-operator-config<br/>ConfigMap"]

    %% Connections
    LlamaStackServer -->|hosts provider| Provider
    InlineEval -->|subprocess| TargetLLM
    RemoteEval -->|submit pipeline| KFP
    EvalHubAdapter -->|submit pipeline| KFP
    EvalHubAdapter -->|artifacts| S3
    Provider -->|upload/download| FilesAPI
    ShieldOrchestrator -->|shield checks| SafetyAPI
    ShieldOrchestrator -->|LLM calls| InferenceAPI
    GarakRunner -->|model downloads| HuggingFace
    RemoteEval -->|resolve base image| ConfigMap

    %% Styling
    style Provider fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style EvalAPI fill:#d5e8d4,stroke:#82b366
    style ExecModes fill:#fff2cc,stroke:#d6b656
    style CoreLogic fill:#f8cecc,stroke:#b85450
    style SDGSubsystem fill:#e1d5e7,stroke:#9673a6
    style SafetyLayer fill:#ffe6cc,stroke:#d79b00
    style LlamaStackServer fill:#4a90e2,color:#fff
    style KFP fill:#999,stroke:#333
    style TargetLLM fill:#f5a623,stroke:#333
    style S3 fill:#999,stroke:#333
    style FilesAPI fill:#4a90e2,color:#fff
    style SafetyAPI fill:#4a90e2,color:#fff
    style InferenceAPI fill:#4a90e2,color:#fff
    style HuggingFace fill:#999,stroke:#333
    style ConfigMap fill:#999,stroke:#333
