graph TB
    subgraph GarakProvider["TrustyAI Garak LLS Provider"]
        direction TB

        subgraph Core["Core Library (core/)"]
            ConfigRes[Config Resolution<br/>Multi-layer cascade]
            CmdBuilder[Command Builder<br/>Garak CLI args]
            Runner[Garak Runner<br/>Subprocess mgmt]
            PipeSteps[Pipeline Steps<br/>6-step workflow]
        end

        subgraph InlineProvider["Inline Provider (inline/)"]
            InlineAdapter[GarakInlineEvalAdapter<br/>Local subprocess exec]
            Semaphore[asyncio.Semaphore<br/>Concurrency control]
            InlineAdapter --> Semaphore
        end

        subgraph RemoteProvider["Remote Provider (remote/)"]
            RemoteAdapter[GarakRemoteEvalAdapter<br/>KFP-based exec]
            KFPComponents[KFP Components<br/>6-step pipeline DSL]
            RemoteAdapter --> KFPComponents
        end

        subgraph EvalHubAdapters["Eval-Hub Adapters (evalhub/)"]
            SimpleAdapter[GarakAdapter<br/>In-pod execution]
            KFPAdapter[KFP Adapter<br/>S3-mediated exec]
            EvalHubPipeline[KFP Pipeline<br/>S3-based 6-step]
            KFPAdapter --> EvalHubPipeline
        end

        subgraph Utilities["Shared Utilities"]
            ResultUtils[Result Utils<br/>JSONL/AVID parse, TBSA scoring]
            ShieldScan[Shield Scan<br/>Guardrail orchestration]
            Intents[Intents<br/>Taxonomy + CAS generation]
            SDG[SDG<br/>Synthetic prompt gen]
            ReportGen[Report Generator<br/>Jinja2 + Vega HTML]
        end

        InlineAdapter --> Core
        RemoteAdapter --> Core
        SimpleAdapter --> Core
        KFPAdapter --> Core
        Core --> ResultUtils
        Core --> Intents
        Core --> SDG
        ResultUtils --> ReportGen
    end

    %% External Interactions
    Client[Client / User] -->|POST /alpha/eval/run-eval| LLSServer
    LLSServer[Llama Stack<br/>Distribution Server<br/>8321/TCP] -->|routes eval calls| InlineAdapter
    LLSServer -->|routes eval calls| RemoteAdapter
    EvalHubCtrl[Eval-Hub Controller] -->|K8s Job| SimpleAdapter
    EvalHubCtrl -->|K8s Job| KFPAdapter

    InlineAdapter -->|subprocess| GarakEngine[Garak Engine<br/>Vulnerability Scanner]
    GarakEngine -->|inference requests| vLLM[vLLM Server<br/>Target Model]

    RemoteAdapter -->|submit pipeline| KFPAPI[KFP API Server]
    KFPAdapter -->|submit pipeline| KFPAPI
    KFPAPI -->|runs pods| KFPPods[KFP Pipeline Pods<br/>Container Image]
    KFPPods -->|scan| vLLM

    RemoteAdapter -->|artifacts| FilesAPI[Llama Stack Files API]
    KFPAdapter -->|artifacts| S3[S3/MinIO Storage]
    SimpleAdapter -->|log artifacts| MLflow[MLflow]

    ShieldScan -->|shield test| SafetyAPI[Llama Stack Safety API]

    %% Styling
    style GarakProvider fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style Core fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style InlineProvider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style RemoteProvider fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style EvalHubAdapters fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Utilities fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style LLSServer fill:#4a90e2,color:#fff
    style EvalHubCtrl fill:#4a90e2,color:#fff
    style vLLM fill:#e8e8e8,stroke:#333
    style KFPAPI fill:#e8e8e8,stroke:#333
    style S3 fill:#f5a623,stroke:#333
    style FilesAPI fill:#e8e8e8,stroke:#333
    style MLflow fill:#e8e8e8,stroke:#333
    style SafetyAPI fill:#e8e8e8,stroke:#333
    style GarakEngine fill:#7ed321,stroke:#333
