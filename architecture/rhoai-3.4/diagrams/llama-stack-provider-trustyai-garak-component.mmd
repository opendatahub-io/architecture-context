            GarakInlineEvalAdapter["GarakInlineEvalAdapter<br/>inline::trustyai_garak<br/>Local subprocess execution"]
        end

        subgraph KFPPipeline["KFP Pipeline (6-Step DAG)"]
            Validate["1. validate"]
            ResolveTaxonomy["2. resolve_taxonomy"]
            SDGGenerate["3. sdg_generate"]
            PreparePrompts["4. prepare_prompts"]
            GarakScan["5. garak_scan"]
            ParseResults["6. parse_results"]
            Validate --> ResolveTaxonomy
            ResolveTaxonomy --> SDGGenerate
            SDGGenerate --> PreparePrompts
            PreparePrompts --> GarakScan
            GarakScan --> ParseResults
        end

        subgraph ShieldLayer["Shield Testing"]
            SimpleShieldOrchestrator["SimpleShieldOrchestrator<br/>Input/Output shield checks"]
        end

