    style V1Score fill:#d5e8d4,stroke:#82b366
    style V1Rerank fill:#d5e8d4,stroke:#82b366
    style V1Audio fill:#d5e8d4,stroke:#82b366
    style V1LoRA fill:#d5e8d4,stroke:#82b366
