graph TD
    subgraph "Note"
        Note["⚠️ No RBAC manifests in this repository<br/>RBAC is managed externally by KServe/RHOAI operator"]
    end

    subgraph "Platform-Level Auth (kube-rbac-proxy Sidecar)"
        direction TB
        KRBAC_SA["Service Account<br/>(Injected by RHOAI)"]
        KRBAC_Policy["Auth Policy<br/>OAuth/OIDC Token Validation"]
        KRBAC_RBAC["Kubernetes RBAC<br/>SubjectAccessReview"]

        KRBAC_SA -->|"configured with"| KRBAC_Policy
        KRBAC_Policy -->|"enforces"| KRBAC_RBAC
    end

    subgraph "Application-Level Auth (vLLM Native)"
        direction TB
        AuthMiddleware["AuthenticationMiddleware<br/>(ASGI Middleware)"]
        APIKeyValidation["API Key Validation<br/>SHA-256 Hash Comparison"]

        AuthMiddleware -->|"validates"| APIKeyValidation
    end

    subgraph "Authenticated Endpoints (/v1/*)"
        V1Chat["POST /v1/chat/completions"]
        V1Completions["POST /v1/completions"]
        V1Embeddings["POST /v1/embeddings"]
        V1Messages["POST /v1/messages"]
        V1Models["GET /v1/models"]
        V1Responses["POST /v1/responses"]
        V1Score["POST /v1/score"]
        V1Rerank["POST /v1/rerank"]
        V1Audio["POST /v1/audio/transcriptions"]
        V1LoRA["POST /v1/load_lora_adapter"]
    end

    subgraph "Unauthenticated Endpoints"
        Health["GET /health"]
        Metrics["GET /metrics"]
        Version["GET /version"]
        Ping["GET /ping"]
        Load["GET /load"]
        Tokenize["POST /tokenize"]
        Detokenize["POST /detokenize"]
    end

    subgraph "Secrets Used"
        APIKey["VLLM_API_KEY<br/>(env var / --api-key)<br/>Bearer Token for /v1/*"]
        HFToken["HF_TOKEN<br/>(env var)<br/>Hugging Face Hub access"]
        S3Creds["S3_ACCESS_KEY_ID<br/>S3_SECRET_ACCESS_KEY<br/>(env vars)<br/>Model storage access"]
        SSLCerts["--ssl-keyfile<br/>--ssl-certfile<br/>(file mount)<br/>TLS termination"]
    end

    %% Auth flows
    KRBAC_RBAC -->|"allows access to"| AuthMiddleware
    APIKeyValidation -->|"protects"| V1Chat
    APIKeyValidation -->|"protects"| V1Completions
    APIKeyValidation -->|"protects"| V1Embeddings
    APIKeyValidation -->|"protects"| V1Messages
    APIKeyValidation -->|"protects"| V1Models
    APIKeyValidation -->|"protects"| V1Responses
    APIKeyValidation -->|"protects"| V1Score
    APIKeyValidation -->|"protects"| V1Rerank
    APIKeyValidation -->|"protects"| V1Audio
    APIKeyValidation -->|"protects"| V1LoRA

    APIKey -->|"used by"| APIKeyValidation

