%% vLLM CPU - RBAC & Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: vLLM CPU does not define its own RBAC resources.
%% RBAC is managed by KServe and the RHOAI operator.
%% This diagram shows the security context and auth model.

graph TD
    subgraph "Container Security Context"
        Pod["vLLM CPU Pod<br/>Image: rhoai/odh-vllm-cpu-rhel9<br/>Base: UBI 9 Minimal (FIPS)"]
        User["UID: 2000 (non-root)"]
        Group["GID: 0 (root group)<br/>OCP arbitrary UID support"]
        Telemetry["VLLM_NO_USAGE_STATS=1<br/>(telemetry disabled)"]
        Pod --- User
        Pod --- Group
        Pod --- Telemetry
    end

    subgraph "KServe-Managed RBAC"
        KServeSA["ServiceAccount<br/>(KServe-managed)"]
        KServeRole["KServe Controller<br/>manages InferenceService CRs"]
        RHOAIOp["RHOAI Operator<br/>manages platform RBAC"]
    end

    subgraph "Authentication Mechanisms"
        APIKeyAuth["API Key Auth<br/>(optional, via --api-key)<br/>Protects /v1/* endpoints"]
        TLSAuth["TLS Client Certs<br/>(optional, via --ssl-cert-reqs)<br/>Mutual TLS support"]
        NoAuth["No Auth Required<br/>/health, /metrics, /version<br/>Always accessible"]
        GRPCNoAuth["gRPC: No Auth<br/>Port 50051/TCP<br/>Internal use only"]
    end

    subgraph "Secrets"
        TLSSecret["model-serving TLS<br/>Type: kubernetes.io/tls<br/>Provisioned by: KServe/cert-manager<br/>Auto-rotate: Yes"]
        HFSecret["HF Token<br/>Type: Opaque<br/>Provisioned by: User<br/>Auto-rotate: No"]
        S3Secret["S3 Credentials<br/>Type: Opaque<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    KServeSA -->|"runs as"| Pod
    KServeRole -->|"manages lifecycle"| Pod
    RHOAIOp -->|"manages platform RBAC"| KServeRole

    Pod -->|"uses"| APIKeyAuth
    Pod -->|"optional"| TLSAuth
    Pod -->|"exposes"| NoAuth
    Pod -->|"exposes"| GRPCNoAuth

    TLSSecret -->|"mounted for HTTPS"| Pod
    HFSecret -->|"model downloads"| Pod
    S3Secret -->|"S3 access"| Pod

    style Pod fill:#4a90e2,stroke:#333,color:#fff
    style User fill:#dae8fc,stroke:#6c8ebf
    style Group fill:#dae8fc,stroke:#6c8ebf
    style Telemetry fill:#dae8fc,stroke:#6c8ebf
    style KServeSA fill:#7ed321,stroke:#333
    style KServeRole fill:#7ed321,stroke:#333
    style RHOAIOp fill:#7ed321,stroke:#333
    style APIKeyAuth fill:#ffe6cc,stroke:#d79b00
    style TLSAuth fill:#ffe6cc,stroke:#d79b00
    style NoAuth fill:#ffe6cc,stroke:#d79b00
    style GRPCNoAuth fill:#ffe6cc,stroke:#d79b00
