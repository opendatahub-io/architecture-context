    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style KRBAC_SA fill:#ffe6cc,stroke:#d79b00
    style KRBAC_Policy fill:#ffe6cc,stroke:#d79b00
    style KRBAC_RBAC fill:#ffe6cc,stroke:#d79b00
    style AuthMiddleware fill:#4a90e2,stroke:#333,color:#fff
    style APIKeyValidation fill:#4a90e2,stroke:#333,color:#fff
