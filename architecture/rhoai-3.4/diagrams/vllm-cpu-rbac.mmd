graph TD
    subgraph VllmCPU["vLLM CPU (No Direct RBAC)"]
        direction TB
        Note["vLLM CPU is a containerized service,<br/>not a Kubernetes operator.<br/>It does not interact with the<br/>Kubernetes API directly."]
    end

    subgraph KServeManaged["RBAC Managed by KServe"]
        direction TB

        subgraph ServiceAccounts["Service Accounts"]
            SA["ServiceAccount<br/>(assigned by KServe<br/>InferenceService)"]
        end

        subgraph PodSecurity["Pod-Level Security"]
            PodRBAC["KServe manages pod RBAC<br/>for InferenceService pods"]
        end
    end

    subgraph ApplicationAuth["Application-Level Authentication"]
        direction TB

        subgraph AuthMiddleware["AuthenticationMiddleware (FastAPI)"]
            APIKeyCheck{"API Key<br/>Configured?"}
        end

        subgraph AuthenticatedPaths["Authenticated (when --api-key set)"]
            V1APIs["/v1/* endpoints<br/>chat/completions, completions,<br/>embeddings, models, responses,<br/>messages, tokenize, detokenize,<br/>score, audio, LoRA mgmt,<br/>profiling, cache, lifecycle"]
        end

        subgraph UnauthenticatedPaths["Always Accessible (No Auth)"]
            HealthEndpoints["/health - Health check<br/>/metrics - Prometheus metrics<br/>/version - Server version<br/>/load - Server load<br/>/server_info - Server config<br/>/ping - SageMaker health"]
        end

        APIKeyCheck -->|"API Key present<br/>in request header"| V1APIs
        APIKeyCheck -->|"No API Key<br/>required"| UnauthenticatedPaths
    end

    subgraph PlatformAuth["Platform-Level Auth (External)"]
        direction TB
        KServeGW["KServe Gateway<br/>kube-rbac-proxy / OAuth"]
        PlatformRBAC["Platform RBAC<br/>(OpenShift / Kubernetes)"]

        KServeGW --> PlatformRBAC
    end

    SA --> PodRBAC
    PlatformAuth -->|"external requests<br/>HTTPS/443"| KServeManaged
    KServeManaged -->|"internal requests<br/>HTTP/8000"| ApplicationAuth

    %% Styling
    style Note fill:#fff3cd,stroke:#ffc107,stroke-width:2px
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PodRBAC fill:#7ed321,stroke:#333,stroke-width:2px
    style APIKeyCheck fill:#f5a623,stroke:#333,stroke-width:2px
    style V1APIs fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style HealthEndpoints fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style KServeGW fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    style PlatformRBAC fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
