graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EPP["ServiceAccount<br/>{release}-epp"]
        SA_BBR["ServiceAccount<br/>{release}-bbr"]
    end

    subgraph RoleBindings["Role Bindings (Namespaced)"]
        RB_EPP["RoleBinding<br/>{release}-epp"]
        RB_EPP_LE["RoleBinding<br/>{release}-epp-leader-election"]
        RB_BBR["RoleBinding<br/>{release}-bbr"]
    end

    subgraph Roles["Roles (Namespaced)"]
        R_EPP["Role<br/>{release}-epp"]
        R_EPP_LE["Role<br/>{release}-epp-leader-election"]
        R_BBR["Role<br/>{release}-bbr"]
    end

    subgraph CRB["ClusterRoleBinding (Conditional)"]
        CRB_Metrics["ClusterRoleBinding<br/>{release}-epp-metrics"]
    end

    subgraph CR["ClusterRole (Conditional)"]
        CR_Metrics["ClusterRole<br/>{release}-epp-metrics"]
    end

    subgraph EPP_Resources["EPP API Resources"]
        InferencePool["inference.networking.k8s.io<br/>InferencePool"]
        InferencePoolX["inference.networking.x-k8s.io<br/>InferencePool"]
        InferenceObj["inference.networking.x-k8s.io<br/>InferenceObjective"]
        InferenceRewrite["inference.networking.x-k8s.io<br/>InferenceModelRewrite"]
        Pods["core<br/>Pods"]
        ConfigMapsEPP["core<br/>ConfigMaps"]
    end

    subgraph LE_Resources["Leader Election Resources"]
        Leases["coordination.k8s.io<br/>Leases"]
        Events["core<br/>Events"]
    end

    subgraph BBR_Resources["BBR API Resources"]
        ConfigMapsBBR["core<br/>ConfigMaps<br/>(bbr-managed=true)"]
    end

    subgraph Metrics_Resources["Metrics Resources (Conditional)"]
        TokenReviews["authentication.k8s.io<br/>TokenReviews"]
        SAR["authorization.k8s.io<br/>SubjectAccessReviews"]
        MetricsURL["nonResourceURLs<br/>/metrics"]
    end

    %% EPP bindings
    SA_EPP -->|bound via| RB_EPP
    RB_EPP -->|grants| R_EPP
    R_EPP -->|"get, list, watch"| InferencePool
    R_EPP -->|"get, list, watch"| InferencePoolX
    R_EPP -->|"get, list, watch"| InferenceObj
    R_EPP -->|"get, list, watch"| InferenceRewrite
    R_EPP -->|"get, list, watch"| Pods
    R_EPP -->|"get, list, watch"| ConfigMapsEPP

    %% EPP leader election
    SA_EPP -->|bound via| RB_EPP_LE
    RB_EPP_LE -->|grants| R_EPP_LE
    R_EPP_LE -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Leases
    R_EPP_LE -->|"create, patch"| Events

    %% EPP metrics (conditional)
    SA_EPP -->|bound via| CRB_Metrics
    CRB_Metrics -->|grants| CR_Metrics
    CR_Metrics -->|create| TokenReviews
    CR_Metrics -->|create| SAR
    CR_Metrics -->|get| MetricsURL

    %% BBR bindings
    SA_BBR -->|bound via| RB_BBR
    RB_BBR -->|grants| R_BBR
    R_BBR -->|"get, list, watch"| ConfigMapsBBR

    %% Styling
    style SA_EPP fill:#4a90e2,stroke:#333,color:#fff
    style SA_BBR fill:#4a90e2,stroke:#333,color:#fff

    style R_EPP fill:#f5a623,stroke:#333
    style R_EPP_LE fill:#f5a623,stroke:#333
    style R_BBR fill:#f5a623,stroke:#333
    style CR_Metrics fill:#e67e22,stroke:#333,color:#fff

    style RB_EPP fill:#d4a574,stroke:#333
    style RB_EPP_LE fill:#d4a574,stroke:#333
    style RB_BBR fill:#d4a574,stroke:#333
    style CRB_Metrics fill:#d4a574,stroke:#333

    style InferencePool fill:#7ed321,stroke:#333
    style InferencePoolX fill:#7ed321,stroke:#333
    style InferenceObj fill:#7ed321,stroke:#333
    style InferenceRewrite fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style ConfigMapsEPP fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style Events fill:#7ed321,stroke:#333
    style ConfigMapsBBR fill:#7ed321,stroke:#333
    style TokenReviews fill:#e8e8e8,stroke:#333
    style SAR fill:#e8e8e8,stroke:#333
    style MetricsURL fill:#e8e8e8,stroke:#333
