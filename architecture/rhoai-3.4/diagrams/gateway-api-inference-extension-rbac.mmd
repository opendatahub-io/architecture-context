graph TD
    subgraph ServiceAccounts["Service Accounts"]
        EPP_SA["EPP ServiceAccount<br/>(pool namespace)"]
        BBR_SA["BBR ServiceAccount<br/>(pool namespace)"]
    end

    subgraph RoleBindings["ClusterRole Bindings"]
        EPP_CRB["EPP ClusterRoleBinding<br/>(chart-generated)"]
        BBR_CRB["BBR ClusterRoleBinding<br/>(chart-generated)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        EPP_CR["EPP ClusterRole"]
        BBR_CR["BBR ClusterRole"]
    end

    subgraph EPP_Resources["EPP API Resources"]
        InferencePool["inference.networking.k8s.io<br/>inferencepools"]
        InferencePoolStatus["inference.networking.k8s.io<br/>inferencepools/status"]
        InferenceObjective["inference.networking.x-k8s.io<br/>inferenceobjectives"]
        InferenceModelRewrite["inference.networking.x-k8s.io<br/>inferencemodelrewrites"]
        Pods["core<br/>pods"]
        Leases["coordination.k8s.io<br/>leases"]
    end

    subgraph BBR_Resources["BBR API Resources"]
        ConfigMaps["core<br/>configmaps"]
    end

    %% EPP bindings
    EPP_SA -->|"bound via"| EPP_CRB
    EPP_CRB -->|"grants"| EPP_CR

    %% EPP permissions
    EPP_CR -->|"get, list, watch"| InferencePool
    EPP_CR -->|"update"| InferencePoolStatus
    EPP_CR -->|"get, list, watch"| InferenceObjective
    EPP_CR -->|"get, list, watch"| InferenceModelRewrite
    EPP_CR -->|"get, list, watch"| Pods
    EPP_CR -->|"get, list, watch,<br/>create, update"| Leases

    %% BBR bindings
    BBR_SA -->|"bound via"| BBR_CRB
    BBR_CRB -->|"grants"| BBR_CR

    %% BBR permissions
    BBR_CR -->|"get, list, watch"| ConfigMaps

    %% Styling
    style EPP_SA fill:#4a90e2,stroke:#333,color:#fff
    style BBR_SA fill:#5b9bd5,stroke:#333,color:#fff
    style EPP_CRB fill:#dae8fc,stroke:#6c8ebf
    style BBR_CRB fill:#dae8fc,stroke:#6c8ebf
    style EPP_CR fill:#f5a623,stroke:#333
    style BBR_CR fill:#f5a623,stroke:#333
    style InferencePool fill:#7ed321,stroke:#333
    style InferencePoolStatus fill:#7ed321,stroke:#333
    style InferenceObjective fill:#7ed321,stroke:#333
    style InferenceModelRewrite fill:#7ed321,stroke:#333
    style Pods fill:#7ed321,stroke:#333
    style Leases fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
