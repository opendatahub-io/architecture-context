graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        SA_Placeholder["ServiceAccount:<br/>placeholder<br/>(to be patched)"]
        Group_Auth["Group:<br/>system:authenticated"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Exec["${PROJECT_NAME}-exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        CRB_SSRF["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Exec["${PROJECT_NAME}-exec-role"]
        CR_SSRF["ssrf-allowlist-role"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            PodsExec["pods/exec"]
            Pods["pods"]
        end

        subgraph InferenceAPI["API Group: inference.networking.x-k8s.io"]
            InferencePools["inferencepools"]
        end
    end

    %% Exec role chain
    Group_Auth -->|"bound via"| CRB_Exec
    CRB_Exec -->|"grants"| CR_Exec
    CR_Exec -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SA_Placeholder -->|"bound via"| CRB_SSRF
    CRB_SSRF -->|"grants"| CR_SSRF
    CR_SSRF -->|"get, watch, list"| Pods
    CR_SSRF -->|"get, watch, list"| InferencePools

    %% Styling
    style SA_Placeholder fill:#4a90e2,stroke:#333,color:#fff
    style Group_Auth fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Exec fill:#e8e8e8,stroke:#333
    style CRB_SSRF fill:#e8e8e8,stroke:#333
    style CR_Exec fill:#f5a623,stroke:#333,color:#fff
    style CR_SSRF fill:#f5a623,stroke:#333,color:#fff
    style PodsExec fill:#7ed321,stroke:#333,color:#fff
    style Pods fill:#7ed321,stroke:#333,color:#fff
    style InferencePools fill:#7ed321,stroke:#333,color:#fff
