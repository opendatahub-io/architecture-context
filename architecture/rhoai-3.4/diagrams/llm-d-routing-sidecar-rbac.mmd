graph TD
    subgraph ServiceAccounts["Service Accounts / Subjects"]
        SystemAuth["Group: system:authenticated"]
        SSRFSA["ServiceAccount<br/>(parameterized)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-Scoped)"]
        ExecBinding["${PROJECT_NAME}-exec-rolebinding<br/>Namespace: ${NAMESPACE}"]
        SSRFBinding["ssrf-allowlist-rolebinding<br/>Namespace: ${NAMESPACE}"]
    end

    subgraph Roles["Roles"]
        ExecRole["${PROJECT_NAME}-exec-role"]
        SSRFRole["ssrf-allowlist-role"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            PodsExec["pods/exec"]
            Pods["pods"]
        end

        subgraph InferenceAPI["API Group: inference.networking.x-k8s.io"]
            InferencePools["inferencepools"]
        end
    end

    %% Exec role chain
    SystemAuth -->|"bound via"| ExecBinding
    ExecBinding -->|"grants"| ExecRole
    ExecRole -->|"create"| PodsExec

    %% SSRF allowlist role chain
    SSRFSA -->|"bound via"| SSRFBinding
    SSRFBinding -->|"grants"| SSRFRole
    SSRFRole -->|"get, watch, list"| Pods
    SSRFRole -->|"get, watch, list"| InferencePools

    %% Styling
    style SystemAuth fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style SSRFSA fill:#3498db,stroke:#2980b9,stroke-width:2px,color:#fff
    style ExecBinding fill:#9b59b6,stroke:#8e44ad,stroke-width:1px,color:#fff
    style SSRFBinding fill:#9b59b6,stroke:#8e44ad,stroke-width:1px,color:#fff
    style ExecRole fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    style SSRFRole fill:#f5a623,stroke:#c48419,stroke-width:2px,color:#fff
    style PodsExec fill:#7ed321,stroke:#5a9e18,stroke-width:1px,color:#fff
    style Pods fill:#7ed321,stroke:#5a9e18,stroke-width:1px,color:#fff
    style InferencePools fill:#7ed321,stroke:#5a9e18,stroke-width:1px,color:#fff
