graph TB
    subgraph External["External Users & Services"]
        User["👤 Data Scientist / ML Engineer"]
        HF["HuggingFace Hub API<br/>443/TCP HTTPS"]
        ModelCatalog["RHOAI Model Catalog<br/>8443/TCP HTTPS"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS"]
    end

    subgraph OpenShiftRoute["OpenShift Routes (TLS Edge Termination)"]
        RoutePlanner["Route: planner<br/>443/TCP HTTPS"]
        RouteBackend["Route: planner-backend<br/>443/TCP HTTPS"]
    end

    subgraph PlannerNamespace["Namespace: planner"]
        subgraph UIComponent["UI (Streamlit)"]
            StreamlitApp["Streamlit App<br/>8501/TCP HTTP"]
            ChatUI["Chat-based Requirements<br/>Gathering"]
            CapacityPage["Capacity Planner Page"]
            GPURecPage["GPU Recommender Page"]
            DeployMgmt["Deployment Management"]
        end

        subgraph BackendComponent["Backend (FastAPI)"]
            FastAPIServer["FastAPI Server<br/>8000/TCP HTTP<br/>28 endpoints / 9 route modules"]
            IntentExtraction["Intent Extraction<br/>Module"]
            RecommendationEngine["Recommendation<br/>Engine"]
            CapacityPlanner["Capacity Planner<br/>Module"]
            GPURecommender["GPU Recommender<br/>Module"]
            YAMLGenerator["YAML Generator<br/>(Jinja2 Templates)"]
            ClusterManager["Cluster Manager<br/>& GPU Detector"]
            ModelCatalogClient["Model Catalog<br/>Client"]
            ConfigFinder["Config Finder<br/>& Scorer"]
        end

        subgraph DataLayer["Data Layer"]
            PostgreSQL["PostgreSQL 16<br/>5432/TCP"]
            Ollama["Ollama LLM<br/>11434/TCP HTTP<br/>granite3.3:2b / qwen2.5:7b"]
        end

        subgraph OptionalComponents["Optional Components"]
            Simulator["vLLM Simulator<br/>8080/TCP HTTP<br/>OpenAI-compatible API"]
        end
    end

    %% User flows
    User -->|HTTPS/443| RoutePlanner
    User -->|HTTPS/443| RouteBackend
    RoutePlanner -->|HTTP/8501| StreamlitApp
    RouteBackend -->|HTTP/8000| FastAPIServer

    %% UI to Backend
    StreamlitApp -->|HTTP/8000<br/>REST API| FastAPIServer

    %% Internal UI structure
    StreamlitApp --- ChatUI
    StreamlitApp --- CapacityPage
    StreamlitApp --- GPURecPage
    StreamlitApp --- DeployMgmt

    %% Backend internal modules
    FastAPIServer --> IntentExtraction
    FastAPIServer --> RecommendationEngine
    FastAPIServer --> CapacityPlanner
    FastAPIServer --> GPURecommender
    FastAPIServer --> YAMLGenerator
    FastAPIServer --> ClusterManager
    FastAPIServer --> ModelCatalogClient

    RecommendationEngine --> ConfigFinder

    %% Backend to Data Layer
    IntentExtraction -->|HTTP/11434| Ollama
    RecommendationEngine -->|TCP/5432<br/>psycopg2| PostgreSQL
    ConfigFinder -->|TCP/5432| PostgreSQL
    ModelCatalogClient -->|TCP/5432<br/>sync target| PostgreSQL

    %% Backend to External
    CapacityPlanner -->|HTTPS/443<br/>Bearer Token| HF
    GPURecommender -->|HTTPS/443| HF
    ModelCatalogClient -->|HTTPS/8443<br/>Bearer Token<br/>service-serving CA| ModelCatalog
    ClusterManager -->|HTTPS/6443<br/>SA Token| K8sAPI
    YAMLGenerator -.->|generates<br/>InferenceService YAML| K8sAPI

    %% Styling
    style FastAPIServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style StreamlitApp fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,stroke-width:2px,color:#fff
    style Ollama fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style Simulator fill:#f5a623,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style HF fill:#e8e8e8,stroke:#333
    style ModelCatalog fill:#e8e8e8,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style RoutePlanner fill:#ffe6cc,stroke:#d79b00
    style RouteBackend fill:#ffe6cc,stroke:#d79b00
