graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway<br/>443/TCP → 8443/TCP<br/>TLS (SIMPLE mode)<br/>Path: /mlflow"]
    end

    subgraph Cluster["CLUSTER INTERNAL (redhat-ods-applications)"]
        direction TB

        subgraph OperatorPod["MLflow Operator Pod"]
            OperatorContainer["mlflow-operator<br/>SA: mlflow-operator-controller-manager<br/>8081/TCP health (HTTP)<br/>8443/TCP metrics (HTTPS/TLS)"]
        end

        subgraph MLflowPod["MLflow Server Pod"]
            direction TB
            InitCA["Init: combine-ca-bundles<br/>system + platform + custom CAs"]
            InitMigration["Init: db-migration<br/>mlflow db fix-migration-gap"]
            MLflowContainer["MLflow Server<br/>SA: mlflow-sa<br/>8443/TCP HTTPS<br/>TLS: service-CA cert<br/>Auth: kubernetes-auth<br/>(SelfSubjectAccessReview)<br/>Ciphers: PROFILE=SYSTEM"]
            CAWatcher["Sidecar: ca-bundle-watcher<br/>Polls every 30s<br/>Regenerates combined CA"]
        end

        subgraph Services["Cluster Services"]
            MLflowSvc["mlflow Service<br/>ClusterIP 8443/TCP<br/>TLS (service-CA)"]
            MetricsSvc["operator-metrics-service<br/>ClusterIP 8443/TCP<br/>TLS (self-signed)"]
        end
    end

    subgraph EgressTargets["EGRESS TARGETS (NetworkPolicy-controlled)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS, SA Token"]
        DNS["CoreDNS<br/>53/TCP+UDP, 5353/TCP+UDP"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS verify-full<br/>Connection string creds"]
        MySQL["MySQL<br/>3306/TCP<br/>TLS (when configured)<br/>Connection string creds"]
        S3MinIO["S3/MinIO<br/>9000/TCP HTTPS<br/>TLS, AWS creds"]
        S3SeaweedFS["SeaweedFS<br/>8333-8334/TCP<br/>HTTP/HTTPS<br/>AWS creds"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        ServiceCA["OpenShift service-CA<br/>Auto-provisions TLS certs"]
        Prometheus["Prometheus<br/>ServiceMonitor scrape<br/>8443/TCP HTTPS"]
        Console["OpenShift Console<br/>ConsoleLink integration"]
        CABundle["odh-trusted-ca-bundle<br/>ConfigMap (platform CAs)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (K8s)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS (service-CA)<br/>Bearer Token passthrough"| MLflowSvc
    MLflowSvc --> MLflowContainer

    %% Operator flows
    OperatorContainer -->|"HTTPS/6443<br/>TLS, SA token<br/>CRD watch, SSA apply"| K8sAPI
    MetricsSvc --> OperatorContainer

    %% MLflow server flows
    MLflowContainer -->|"HTTPS/6443<br/>TLS<br/>Delegated Bearer Token<br/>SelfSubjectAccessReview"| K8sAPI
    MLflowContainer -->|"PostgreSQL/5432<br/>TLS verify-full<br/>Credentials"| PostgreSQL
    MLflowContainer -->|"MySQL/3306<br/>TLS<br/>Credentials"| MySQL
    MLflowContainer -->|"HTTPS/9000<br/>TLS<br/>AWS IAM creds"| S3MinIO
    MLflowContainer -->|"HTTP(S)/8333-8334<br/>AWS creds"| S3SeaweedFS
    MLflowContainer -->|"DNS/53+5353"| DNS

    %% Platform integrations
    ServiceCA -.->|"provisions mlflow-tls secret"| MLflowPod
    CABundle -.->|"volume mount"| MLflowPod
    Prometheus -.->|"scrapes HTTPS/8443"| MLflowSvc
    OperatorContainer -.->|"creates ConsoleLink"| Console

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef platform fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Gateway ingress
    class OperatorContainer,MLflowContainer,CAWatcher,InitCA,InitMigration,MLflowSvc,MetricsSvc cluster
    class K8sAPI,DNS,PostgreSQL,MySQL,S3MinIO,S3SeaweedFS egress
    class ServiceCA,Prometheus,Console,CABundle platform
