    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>SA token / delegated token"]
        S3["S3-compatible Storage<br/>(AWS S3 / MinIO / SeaweedFS)<br/>443/9000/8333 TCP<br/>HTTPS/HTTP TLS 1.2+<br/>AWS credentials"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS verify-full<br/>Connection string"]
