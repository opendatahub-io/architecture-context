graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Platform"]
    end

    subgraph K8sControl["KUBERNETES CONTROL PLANE"]
        APIServer["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer / client cert / OIDC"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB
        subgraph OperatorPod["training-operator Pod"]
            direction LR
            WebhookPort["Webhook<br/>9443/TCP HTTPS<br/>TLS (auto-rotated)<br/>API server client cert"]
            MetricsPort["Metrics<br/>8080/TCP HTTP<br/>No auth"]
            ProbePort["Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]
        end
        CertSecret["Secret: kubeflow-training-<br/>operator-webhook-cert<br/>OPA cert-controller<br/>Auto-rotated"]
    end

    subgraph UserNS["USER NAMESPACES (training workloads)"]
        direction TB
        subgraph TrainingJob["Training Job"]
            MasterPod["Master Pod<br/>Framework env vars"]
            WorkerPods["Worker Pods<br/>(N replicas)"]
            HeadlessSvc["Headless Service<br/>ClusterIP: None<br/>Pod DNS discovery"]
        end
    end

    subgraph GangScheduling["GANG SCHEDULING (Optional)"]
        Volcano["Volcano<br/>PodGroup CRD<br/>scheduling.volcano.sh"]
        SchedPlugins["scheduler-plugins<br/>PodGroup CRD<br/>scheduling.x-k8s.io"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scraping"]
    end

    %% External → API Server
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer token"| APIServer

    %% API Server → Webhook (admission)
    APIServer -->|"HTTPS/9443<br/>TLS (auto-rotated)<br/>API server client cert<br/>failurePolicy: Fail"| WebhookPort

    %% Controller → API Server (reconciliation)
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer token<br/>CRUD: Pods, Services,<br/>CRDs, Events, RBAC,<br/>NetworkPolicies, HPA"| APIServer

    %% Controller creates training resources
    OperatorPod -->|"Creates via API Server"| MasterPod
    OperatorPod -->|"Creates via API Server"| WorkerPods
    OperatorPod -->|"Creates via API Server"| HeadlessSvc

    %% Gang scheduling
    OperatorPod -.->|"Creates PodGroup CRs<br/>HTTPS/443"| Volcano
    OperatorPod -.->|"Creates PodGroup CRs<br/>HTTPS/443"| SchedPlugins

    %% Inter-pod communication
    MasterPod <-->|"TCP<br/>Framework-specific ports<br/>No encryption<br/>Cluster-internal"| WorkerPods
    MasterPod --- HeadlessSvc
    WorkerPods --- HeadlessSvc

    %% Cert management
    CertSecret -->|"TLS certs mounted at<br/>/tmp/k8s-webhook-server/<br/>serving-certs"| WebhookPort

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No encryption<br/>No auth"| MetricsPort

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef control fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef optional fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef secret fill:#f5f5f5,stroke:#666,stroke-width:1px

    class User external
    class APIServer control
    class WebhookPort,MetricsPort,ProbePort operator
    class MasterPod,WorkerPods,HeadlessSvc workload
    class Volcano,SchedPlugins optional
    class Prometheus monitoring
    class CertSecret secret
