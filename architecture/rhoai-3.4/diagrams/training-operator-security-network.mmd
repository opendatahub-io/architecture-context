    %% External flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token/Cert"| K8sAPI

    %% Webhook flow
    K8sAPI -->|"HTTPS/9443<br/>TLS (self-signed)<br/>API Server TLS Client Cert"| WebhookSvr

    %% Operator to API
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CRUD: pods, svcs, netpol, hpa"| K8sAPI

    %% Metrics scraping
    Prometheus -->|"HTTP/8080<br/>plaintext<br/>No auth"| MetricsEP

    %% Training job communication
    MasterPod <-->|"TCP/framework-specific<br/>plaintext<br/>No auth"| WorkerPods
    WorkerPods <-->|"TCP/framework-specific<br/>plaintext<br/>No auth"| WorkerPods

    %% Init container DNS
    InitContainer -->|"DNS/53 UDP<br/>plaintext"| CoreDNS

    %% Gang scheduling (optional)
    OperatorPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>PodGroup CRUD"| Volcano

    %% Cert management
    WebhookCert -.->|"mounts cert"| WebhookSvr

