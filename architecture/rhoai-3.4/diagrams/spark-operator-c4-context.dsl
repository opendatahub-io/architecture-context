/* Spark Operator - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4/spark-operator.md
 */

workspace {
    model {
        user = person "Data Scientist / Engineer" "Submits Spark applications and manages Spark workloads"

        sparkOperator = softwareSystem "Spark Operator" "Kubernetes operator that manages Apache Spark application lifecycle on OpenShift/Kubernetes" {
            controller = container "spark-operator-controller" "Watches SparkApplication/ScheduledSparkApplication/SparkConnect CRs; creates and manages Spark driver pods, executor pods, Services, Ingresses, and ConfigMaps" "Go Operator (controller-runtime)"
            webhook = container "spark-operator-webhook" "Mutates and validates SparkApplication/ScheduledSparkApplication CRs and Spark pods; injects configuration, volumes, environment variables; self-manages TLS certificates" "Go Webhook Server"
            sparkSA = container "spark-operator-spark" "ServiceAccount used by Spark driver pods to manage executor pods" "Kubernetes ServiceAccount"
        }

        kubernetes = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano Scheduler" "Optional batch scheduler for gang scheduling of Spark jobs" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys Spark Operator via kustomize overlays" "Internal RHOAI"

        # Relationships - User
        user -> sparkOperator "Creates SparkApplication/ScheduledSparkApplication/SparkConnect CRs via kubectl"

        # Relationships - Internal
        controller -> kubernetes "Watches CRDs, manages pods/services/ingresses/configmaps" "HTTPS/443"
        webhook -> kubernetes "Receives admission requests, manages webhook configs and TLS secrets" "HTTPS/443"
        controller -> volcano "Uses for gang scheduling via PodGroup CRD (optional)" "HTTPS/443"

        # Relationships - Monitoring
        prometheus -> controller "Scrapes metrics" "HTTP/8080"
        prometheus -> webhook "Scrapes metrics" "HTTP/8080"

        # Relationships - Deployment
        rhodsOperator -> sparkOperator "Deploys via kustomize overlays, injects image references"

        # Container-level relationships
        controller -> webhook "Webhook intercepts pod/CR creation"
        sparkSA -> kubernetes "Driver pods use SA to manage executor pods" "HTTPS/443"
    }

    views {
        systemContext sparkOperator "SystemContext" {
            include *
            autoLayout
        }

        container sparkOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
