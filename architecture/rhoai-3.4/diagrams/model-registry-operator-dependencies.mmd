graph LR
    MRO["Model Registry<br/>Operator"]

    %% External Dependencies (Required)
    MRO -->|"controller framework"| ControllerRuntime["controller-runtime<br/>v0.23.3"]
    MRO -->|"K8s API types"| K8sAPI["k8s.io/api<br/>v0.35.3"]
    MRO -->|"OpenShift API types"| OpenShiftAPI["openshift/api<br/>v0.0.0-20260320"]
    MRO -->|"3-way diff reconciliation"| ObjectMatcher["banzaicloud/<br/>k8s-objectmatcher<br/>v1.8.0"]
    MRO -->|"legacy scheme registration"| IstioClient["istio.io/client-go<br/>v1.29.1"]

    %% Conditional External Dependencies
    MRO -->|"auto-provisioned DB<br/>(conditional)"| PostgreSQL["PostgreSQL 16<br/>sclorg image"]
    MRO -.->|"external DB backend<br/>(conditional)"| MySQL["MySQL/MariaDB<br/>external"]

    %% Internal Platform Dependencies
    MRO -->|"capability detection<br/>(HasAuthAPI)"| PlatformMR["components.platform<br/>ModelRegistry CR"]
    MRO -->|"admin groups<br/>for catalog RBAC"| AuthCR["services.platform<br/>Auth CR"]
    MRO -->|"cluster domain<br/>for Route hostnames"| IngressConfig["config.openshift.io<br/>Ingress"]

    %% Deployed Components (managed by operator)
    MRO -->|"deploys per CR"| RegistryService["model-registry<br/>REST Service"]
    MRO -->|"deploys auth sidecar"| KubeRBACProxy["kube-rbac-proxy<br/>Sidecar"]
    MRO -->|"deploys catalog"| CatalogService["Model Catalog<br/>Service"]
    MRO -->|"init container data"| CatalogData["odh-model-<br/>metadata-collection"]
    MRO -->|"Job template"| AsyncUpload["model-registry-job<br/>async-upload"]

    %% Infrastructure Dependencies
    MRO -->|"resource CRUD,<br/>watches, webhooks"| K8sAPIServer["Kubernetes<br/>API Server"]
    MRO -->|"external access<br/>(Routes)"| OpenShiftRouter["OpenShift<br/>Router"]
    MRO -->|"user groups"| UserAPI["user.openshift.io<br/>Groups"]
    MRO -->|"CRD storage migration"| SVM["migration.k8s.io<br/>StorageVersionMigration"]

    %% Integration Points (other components using this)
    Dashboard["ODH Dashboard"] -.->|"UI management"| MRO
    DSPipelines["Data Science<br/>Pipelines"] -.->|"model deployment"| MRO

