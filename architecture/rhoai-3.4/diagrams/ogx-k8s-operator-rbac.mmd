graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller["controller-manager<br/>(operator namespace)"]
        SA_Instance["{instance-name}-sa<br/>(LLSD namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster/Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(ClusterRoleBinding)"]
        RB_Leader["leader-election-rolebinding<br/>(RoleBinding, operator ns)"]
        RB_Instance["{instance-name}-rb<br/>(RoleBinding, LLSD ns)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role<br/>(ClusterRole)"]
        CR_Leader["leader-election-role<br/>(Role, operator ns)"]
        CR_Editor["llsd-editor-role<br/>(ClusterRole, aggregate)"]
        CR_Viewer["llsd-viewer-role<br/>(ClusterRole, aggregate)"]
        CR_SCC["system:openshift:scc:anyuid<br/>(ClusterRole)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        LLSD["llamastack.io<br/>llamastackdistributions<br/>get,list,watch,create,<br/>update,patch,delete"]
        LLSDStatus["llamastack.io<br/>llamastackdistributions/status<br/>get,update,patch"]
        LLSDFinalizers["llamastack.io<br/>llamastackdistributions/finalizers<br/>update"]
        Deployments["apps<br/>deployments<br/>get,list,watch,create,<br/>update,patch,delete"]
        CoreResources["core<br/>services, serviceaccounts<br/>get,list,watch,create,<br/>update,patch,delete"]
        PVCs["core<br/>persistentvolumeclaims<br/>get,list,watch,create"]
        ConfigMaps["core<br/>configmaps<br/>get,list,watch,create,<br/>update,patch"]
        NetworkResources["networking.k8s.io<br/>networkpolicies, ingresses<br/>get,list,watch,create,<br/>update,patch,delete"]
        PDBs["policy<br/>poddisruptionbudgets<br/>get,list,watch,create,<br/>update,patch,delete"]
        HPAs["autoscaling<br/>horizontalpodautoscalers<br/>get,list,watch,create,<br/>update,patch,delete"]
        RBACResources["rbac.authorization.k8s.io<br/>rolebindings: full CRUD<br/>clusterrolebindings: get,list,delete<br/>clusterroles: get,list,watch"]
        SCCResources["security.openshift.io<br/>securitycontextconstraints<br/>use (anyuid)"]
    end

    subgraph EditorResources["llsd-editor-role Resources"]
        EditorLLSD["llamastack.io<br/>llamastackdistributions<br/>create,delete,get,list,<br/>patch,update,watch"]
        EditorStatus["llamastack.io<br/>llamastackdistributions/status<br/>get"]
    end

    subgraph ViewerResources["llsd-viewer-role Resources"]
        ViewerLLSD["llamastack.io<br/>llamastackdistributions<br/>get,list,watch"]
        ViewerStatus["llamastack.io<br/>llamastackdistributions/status<br/>get"]
    end

    %% Controller SA bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    CRB_Manager -->|grants| CR_Manager
    RB_Leader -->|grants| CR_Leader

    %% Instance SA bindings
    SA_Instance -->|bound via| RB_Instance
    RB_Instance -->|grants| CR_SCC

    %% Manager role to resources
    CR_Manager -->|manages| LLSD
    CR_Manager -->|manages| LLSDStatus
    CR_Manager -->|manages| LLSDFinalizers
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| CoreResources
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| NetworkResources
    CR_Manager -->|manages| PDBs
    CR_Manager -->|manages| HPAs
    CR_Manager -->|manages| RBACResources
    CR_Manager -->|manages| SCCResources

    %% Editor/Viewer role to resources
    CR_Editor -->|manages| EditorLLSD
    CR_Editor -->|manages| EditorStatus
    CR_Viewer -->|reads| ViewerLLSD
    CR_Viewer -->|reads| ViewerStatus

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333
    style CR_Leader fill:#f5a623,stroke:#333
    style CR_Editor fill:#f5a623,stroke:#333
    style CR_Viewer fill:#f5a623,stroke:#333
    style CR_SCC fill:#e8685d,stroke:#333,color:#fff
    style LLSD fill:#7ed321,stroke:#333
    style LLSDStatus fill:#7ed321,stroke:#333
    style LLSDFinalizers fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style CoreResources fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style NetworkResources fill:#7ed321,stroke:#333
    style PDBs fill:#7ed321,stroke:#333
    style HPAs fill:#7ed321,stroke:#333
    style RBACResources fill:#7ed321,stroke:#333
    style SCCResources fill:#e8685d,stroke:#333,color:#fff
    style EditorLLSD fill:#7ed321,stroke:#333
    style EditorStatus fill:#7ed321,stroke:#333
    style ViewerLLSD fill:#7ed321,stroke:#333
    style ViewerStatus fill:#7ed321,stroke:#333
