graph TD
    subgraph ServiceAccounts["Service Accounts"]
        OperatorSA["controller-manager<br/>(redhat-ods-applications)"]
        InstanceSA["{instance}-sa<br/>({workload-namespace})"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB["manager-rolebinding"]
    end

    subgraph RoleBindings["Role Bindings (per-instance)"]
        RB["{instance}-rb<br/>({workload-namespace})"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        ManagerRole["manager-role"]
        MetricsReader["metrics-reader"]
        AnyuidSCC["system:openshift:scc:anyuid"]
    end

    subgraph LlamaStackResources["llamastack.io API Group"]
        LLSD["llamastackdistributions<br/>get, list, watch,<br/>create, update, patch, delete"]
        LLSDStatus["llamastackdistributions/status<br/>get, update, patch"]
        LLSDFinalizers["llamastackdistributions/finalizers<br/>update"]
    end

    subgraph CoreResources["Core API Group ('')"]
        Services["services<br/>get, list, watch,<br/>create, update, patch, delete"]
        SvcAccounts["serviceaccounts<br/>get, list, watch,<br/>create, update, patch, delete"]
        ConfigMaps["configmaps<br/>get, list, watch,<br/>create, update, patch"]
        PVCs["persistentvolumeclaims<br/>get, list, watch, create"]
    end

    subgraph AppsResources["apps API Group"]
        Deployments["deployments<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph NetworkingResources["networking.k8s.io API Group"]
        NetworkPolicies["networkpolicies<br/>get, list, watch,<br/>create, update, patch, delete"]
        Ingresses["ingresses<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph PolicyResources["policy API Group"]
        PDBs["poddisruptionbudgets<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph AutoscalingResources["autoscaling API Group"]
        HPAs["horizontalpodautoscalers<br/>get, list, watch,<br/>create, update, patch, delete"]
    end

    subgraph RBACResources["rbac.authorization.k8s.io"]
        RoleBindingsRes["rolebindings<br/>get, list, watch,<br/>create, update, patch, delete"]
        ClusterRoleBindingsRes["clusterrolebindings<br/>get, list, delete"]
        ClusterRolesRes["clusterroles<br/>get, list, watch"]
    end

    subgraph SecurityResources["security.openshift.io"]
        SCCs["securitycontextconstraints<br/>use"]
    end

    %% Operator SA bindings
    OperatorSA -->|"bound via"| CRB
    CRB -->|"grants"| ManagerRole

    %% Manager role permissions
    ManagerRole -->|"manages"| LLSD
    ManagerRole -->|"manages"| LLSDStatus
    ManagerRole -->|"manages"| LLSDFinalizers
    ManagerRole -->|"manages"| Deployments
    ManagerRole -->|"manages"| Services
    ManagerRole -->|"manages"| SvcAccounts
    ManagerRole -->|"manages"| ConfigMaps
    ManagerRole -->|"manages"| PVCs
    ManagerRole -->|"manages"| NetworkPolicies
    ManagerRole -->|"manages"| Ingresses
    ManagerRole -->|"manages"| PDBs
    ManagerRole -->|"manages"| HPAs
    ManagerRole -->|"manages"| RoleBindingsRes
    ManagerRole -->|"manages"| ClusterRoleBindingsRes
    ManagerRole -->|"manages"| ClusterRolesRes
    ManagerRole -->|"manages"| SCCs

    %% Instance SA bindings (anyuid)
    InstanceSA -->|"bound via"| RB
    RB -->|"grants"| AnyuidSCC

    %% Metrics reader
    OperatorSA -.->|"metrics access"| MetricsReader

    %% Styles
    style OperatorSA fill:#4a90e2,stroke:#333,color:#fff
    style InstanceSA fill:#4a90e2,stroke:#333,color:#fff
    style ManagerRole fill:#f5a623,stroke:#333,color:#000
    style MetricsReader fill:#f5a623,stroke:#333,color:#000
    style AnyuidSCC fill:#e74c3c,stroke:#333,color:#fff
    style CRB fill:#b8d4e8,stroke:#333
    style RB fill:#b8d4e8,stroke:#333

    style LLSD fill:#7ed321,stroke:#333
    style LLSDStatus fill:#7ed321,stroke:#333
    style LLSDFinalizers fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style SvcAccounts fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style PVCs fill:#7ed321,stroke:#333
    style Deployments fill:#7ed321,stroke:#333
    style NetworkPolicies fill:#7ed321,stroke:#333
    style Ingresses fill:#7ed321,stroke:#333
    style PDBs fill:#7ed321,stroke:#333
    style HPAs fill:#7ed321,stroke:#333
    style RoleBindingsRes fill:#7ed321,stroke:#333
    style ClusterRoleBindingsRes fill:#7ed321,stroke:#333
    style ClusterRolesRes fill:#7ed321,stroke:#333
    style SCCs fill:#7ed321,stroke:#333
