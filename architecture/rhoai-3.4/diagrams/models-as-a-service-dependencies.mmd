graph LR
    MaaS["Models as a Service<br/>(MaaS Platform)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy,<br/>TokenRateLimitPolicy"| Kuadrant["Kuadrant / RHCL<br/>1.4.2+ / 1.3+"]
    MaaS -->|"API key validation,<br/>subscription selection"| Authorino["Authorino<br/>v0.23.1+<br/>(via Kuadrant)"]
    MaaS -->|"Token rate limit<br/>enforcement"| Limitador["Limitador<br/>(via Kuadrant)"]
    MaaS -->|"LLMInferenceService<br/>model serving"| KServe["KServe<br/>v0.15.0+"]
    MaaS -->|"HTTPRoute<br/>model exposure"| GatewayAPI["Gateway API<br/>v1.2+"]
    MaaS -->|"ServiceEntry,<br/>DestinationRule,<br/>EnvoyFilter"| Istio["Istio / OSSM<br/>(via Gateway)"]
    MaaS -->|"API key hash<br/>storage"| PostgreSQL["PostgreSQL"]
    MaaS -->|"Routes, Auth,<br/>serving certs"| OpenShift["OpenShift<br/>4.19.9+"]

    %% External Dependencies (Optional)
    MaaS -.->|"Perses dashboards<br/>(optional)"| COO["Cluster Observability<br/>Operator (COO)"]

    %% Internal Platform Dependencies
    PlatformOp["rhods-operator /<br/>opendatahub-operator"] -->|"DataScienceCluster<br/>.modelsAsService"| MaaS
    KServe -->|"LLMInferenceService<br/>CRD Watch"| MaaS
    OpenShiftAuth["OpenShift<br/>Authentication"] -->|"OIDC issuer<br/>discovery"| MaaS
    MonitoringCM["openshift-monitoring<br/>cluster-monitoring-config"] -.->|"UWM enabled<br/>check (prereq)"| MaaS

    %% Integration Points (downstream consumers)
    MaaS -->|"inference<br/>HTTPS/443"| ExtLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"inference +<br/>access probes"| KServeEndpoints["KServe Model<br/>Endpoints"]
    MaaS -->|"CRD CRUD,<br/>RBAC, Secrets"| K8sAPI["Kubernetes API<br/>Server"]
    Prometheus["Prometheus"] -->|"scrape<br/>8080, 9005,<br/>15090"| MaaS

    %% Styling
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External required
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Limitador fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#9673a6,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff

    %% Optional
    style COO fill:#bbb,stroke:#333,color:#fff

    %% Internal platform
    style PlatformOp fill:#7ed321,stroke:#333,color:#fff
    style OpenShiftAuth fill:#7ed321,stroke:#333,color:#fff
    style MonitoringCM fill:#7ed321,stroke:#333,color:#fff

    %% External services
    style ExtLLM fill:#f5a623,stroke:#333,color:#fff
    style KServeEndpoints fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Prometheus fill:#f5a623,stroke:#333,color:#fff
