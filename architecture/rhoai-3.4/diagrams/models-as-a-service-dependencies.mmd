graph LR
    MaaS["Models as a Service<br/>(MaaS Operator + API)"]

    %% External Dependencies (Required)
    MaaS -->|"AuthPolicy, TRLP,<br/>API key validation callbacks"| Kuadrant["Kuadrant<br/>v1.4.2+ / RHCL v1.3+"]
    MaaS -->|"LLMInferenceService<br/>model serving"| KServe["KServe<br/>v0.15+"]
    MaaS -->|"HTTPRoute ingress,<br/>Gateway CR"| GatewayAPI["Gateway API<br/>v1.2+"]
    MaaS -->|"EnvoyFilter, ServiceEntry,<br/>DestinationRule, Telemetry"| Istio["Istio"]
    MaaS -->|"API key storage<br/>(SHA-256 hash)"| PostgreSQL["PostgreSQL"]
    MaaS -->|"Gateway controller,<br/>service-ca, OAuth"| OpenShift["OpenShift<br/>4.19.9+"]

    %% Internal Platform Dependencies
    MaaS -->|"HTTP callback:<br/>validate + select"| Authorino["Kuadrant<br/>Authorino"]
    MaaS -->|"token rate limit<br/>enforcement"| Limitador["Kuadrant<br/>Limitador"]
    MaaS -->|"CRD watch +<br/>HTTPRoute creation"| KServeLLM["KServe<br/>LLMInferenceService"]
    MaaS -->|"creates ingress routes,<br/>TLS termination"| OSGW["OpenShift<br/>Gateway Controller"]
    MaaS -->|"mesh routing,<br/>ext_proc injection"| IstioCP["Istio<br/>Control Plane"]

    %% Optional Dependencies
    MaaS -.->|"PersesDashboard,<br/>PersesDatasource"| Perses["Perses<br/>(optional)"]

    %% Integration Points (other components → MaaS)
    Prometheus["Prometheus"] -->|"scrapes metrics<br/>8080, 9005, 15090/TCP"| MaaS

    %% External Services
    MaaS -->|"inference via<br/>ServiceEntry 443/TCP"| ExtLLM["External LLM Providers<br/>(OpenAI, Anthropic, etc.)"]
    MaaS -->|"CR watches, SSA,<br/>SAR, TokenReview"| K8sAPI["Kubernetes API<br/>6443/TCP"]

    %% Styles
    style MaaS fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style KServe fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style OpenShift fill:#999,stroke:#333,color:#fff
    style Authorino fill:#7ed321,stroke:#333
    style Limitador fill:#7ed321,stroke:#333
    style KServeLLM fill:#7ed321,stroke:#333
    style OSGW fill:#7ed321,stroke:#333
    style IstioCP fill:#7ed321,stroke:#333
    style Perses fill:#7ed321,stroke:#333,stroke-dasharray: 5 5
    style Prometheus fill:#7ed321,stroke:#333
    style ExtLLM fill:#f5a623,stroke:#333
    style K8sAPI fill:#f5a623,stroke:#333
