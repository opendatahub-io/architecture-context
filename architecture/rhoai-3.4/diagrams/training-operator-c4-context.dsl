// Training Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Submits distributed training jobs via kubectl or automation"

        trainingOperator = softwareSystem "Kubeflow Training Operator (KFTO)" "Kubernetes-native operator for orchestrating distributed ML training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, and JAX" {
            controller = container "Training Operator Controller" "Manages lifecycle of distributed training jobs across 6 frameworks" "Go (controller-runtime)" "Operator"
            pytorchCtrl = container "PyTorchJob Controller" "Reconciles PyTorchJob CRs; creates Pods, Services, NetworkPolicies, HPAs" "Go Reconciler"
            tfCtrl = container "TFJob Controller" "Reconciles TFJob CRs; creates Pods and Services for TensorFlow" "Go Reconciler"
            xgboostCtrl = container "XGBoostJob Controller" "Reconciles XGBoostJob CRs" "Go Reconciler"
            mpiCtrl = container "MPIJob Controller" "Reconciles MPIJob CRs with launcher/worker topology" "Go Reconciler"
            paddleCtrl = container "PaddleJob Controller" "Reconciles PaddleJob CRs" "Go Reconciler"
            jaxCtrl = container "JAXJob Controller" "Reconciles JAXJob CRs" "Go Reconciler"
            webhook = container "Webhook Server" "Validates training job CRs on create/update" "Go HTTPS Server" "Webhook"
            certMgr = container "Cert Manager" "Manages TLS certificate rotation for webhook" "OPA cert-controller"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster control plane for resource management" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal Platform"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages RHOAI components" "Internal Platform"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for coordinated pod placement" "External Optional"
        schedulerPlugins = softwareSystem "Scheduler Plugins" "Kubernetes scheduler extensions for PodGroup scheduling" "External Optional"
        coreDNS = softwareSystem "CoreDNS" "Cluster DNS for pod discovery via headless services" "External"

        // Relationships
        user -> trainingOperator "Submits training jobs (PyTorchJob, TFJob, etc.) via kubectl" "HTTPS/443"
        rhodsOperator -> trainingOperator "Deploys via kustomize overlay" "Kustomize"
        trainingOperator -> k8sAPI "CRUD for Pods, Services, NetworkPolicies, HPAs, PodGroups" "HTTPS/443"
        k8sAPI -> trainingOperator "Sends admission review requests to webhook" "HTTPS/9443"
        prometheus -> trainingOperator "Scrapes metrics via PodMonitor" "HTTP/8080"
        trainingOperator -> volcano "Creates PodGroup resources (optional)" "HTTPS/443"
        trainingOperator -> schedulerPlugins "Creates PodGroup resources (optional)" "HTTPS/443"
        trainingOperator -> coreDNS "PyTorch init container resolves master pod" "DNS/53"

        // Container relationships
        controller -> pytorchCtrl "delegates"
        controller -> tfCtrl "delegates"
        controller -> xgboostCtrl "delegates"
        controller -> mpiCtrl "delegates"
        controller -> paddleCtrl "delegates"
        controller -> jaxCtrl "delegates"
        certMgr -> webhook "rotates TLS certificates"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #999999
                color #ffffff
                border dashed
            }
            element "Internal Platform" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Operator" {
                shape hexagon
            }
            element "Webhook" {
                shape roundedbox
            }
        }
    }
}
