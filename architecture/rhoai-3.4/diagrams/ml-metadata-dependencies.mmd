graph LR
    MLMD["ML Metadata<br/>(MLMD gRPC Server)"]

    %% Database Backends
    MLMD -->|"metadata storage<br/>TCP/5432<br/>Optional SSL"| PostgreSQL["PostgreSQL 12.17+<br/>(Primary in RHOAI)"]
    MLMD -->|"alt. storage<br/>TCP/3306<br/>Optional SSL"| MySQL["MySQL<br/>(Alternative)"]
    MLMD -.->|"embedded/testing"| SQLite["SQLite 3.39.2<br/>(Testing Only)"]

    %% Build/Runtime Dependencies
    MLMD -->|"RPC framework"| gRPC["gRPC 1.46.3"]
    MLMD -->|"serialization"| Protobuf["Protobuf 3.21.12"]
    MLMD -->|"TLS/SSL"| BoringSSL["BoringSSL<br/>(NOT FIPS-validated)"]
    MLMD -->|"SQL parsing"| ZetaSQL["ZetaSQL<br/>(filter_query)"]
    MLMD -->|"C++ utilities"| Abseil["Abseil C++<br/>20230802.0"]

    %% Internal RHOAI Dependencies
    DSPOperator["Data Science Pipelines<br/>Operator"] -->|"deploys &<br/>configures"| MLMD
    DSPBackend["DSP Backend<br/>(Pipeline Runner)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    DSPUI["DSP UI<br/>(Pipeline Dashboard)"] -->|"queries via<br/>DSP Backend"| MLMD
    KFPSDK["Kubeflow Pipelines<br/>SDK (Python)"] -->|"gRPC client<br/>8080/TCP"| MLMD
    PipelineRunner["Pipeline Runner<br/>(Argo/Tekton)"] -->|"records metadata<br/>via Python SDK"| MLMD

    %% Build Dependencies
    MLMD -.->|"build system"| Bazel["Bazel 5.3.0+"]
    MLMD -.->|"Python binding"| pybind11["pybind11 2.10.1"]

    %% Styling
    style MLMD fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Database backends
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style MySQL fill:#4479a1,stroke:#333,color:#fff
    style SQLite fill:#003b57,stroke:#333,color:#fff

    %% External/build dependencies
    style gRPC fill:#999,stroke:#333,color:#fff
    style Protobuf fill:#999,stroke:#333,color:#fff
    style BoringSSL fill:#e74c3c,stroke:#333,color:#fff
    style ZetaSQL fill:#999,stroke:#333,color:#fff
    style Abseil fill:#999,stroke:#333,color:#fff
    style Bazel fill:#bbb,stroke:#333
    style pybind11 fill:#bbb,stroke:#333

    %% Internal RHOAI components
    style DSPOperator fill:#f5a623,stroke:#333
    style DSPBackend fill:#7ed321,stroke:#333
    style DSPUI fill:#7ed321,stroke:#333
    style KFPSDK fill:#7ed321,stroke:#333
    style PipelineRunner fill:#7ed321,stroke:#333
