graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_Instance["{registry-name}<br/>(per instance)"]
        SA_Catalog["model-catalog<br/>(operator namespace)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Proxy["proxy-rolebinding<br/>(Cluster-scoped)"]
        CRB_Instance["{registry-name}-auth-delegator<br/>(Cluster-scoped, per instance)"]
        CRB_Catalog["model-catalog-auth-delegator<br/>(Cluster-scoped)"]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader["leader-election-rolebinding<br/>(operator namespace)"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_Proxy["proxy-role"]
        CR_Metrics["metrics-reader"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_Admin["modelregistry-admin-role"]
        CR_Editor["modelregistry-editor-role"]
        CR_Viewer["modelregistry-viewer-role"]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader["leader-election-role"]
    end

    %% Bindings
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Proxy
    SA_CM -->|"bound via"| RB_Leader
    SA_Instance -->|"bound via"| CRB_Instance
    SA_Catalog -->|"bound via"| CRB_Catalog

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Proxy -->|"grants"| CR_Proxy
    CRB_Instance -->|"grants"| CR_AuthDelegator
    CRB_Catalog -->|"grants"| CR_AuthDelegator
    RB_Leader -->|"grants"| R_Leader

    %% manager-role resources
    subgraph ManagerResources["manager-role Permissions"]
        direction LR
        MR_Core["core<br/>configmaps, pvc, secrets,<br/>serviceaccounts, services<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_CoreRO["core<br/>endpoints, pods, pods/log<br/><i>get,list,watch</i>"]
        MR_Apps["apps<br/>deployments<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_ModelReg["modelregistry.opendatahub.io<br/>modelregistries,<br/>modelregistries/finalizers,<br/>modelregistries/status<br/><i>all verbs</i>"]
        MR_Network["networking.k8s.io<br/>networkpolicies<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_Route["route.openshift.io<br/>routes, routes/custom-host<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_User["user.openshift.io<br/>groups<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_Platform["platform APIs<br/>components, services,<br/>config (Ingress)<br/><i>get,list,watch</i>"]
        MR_Migration["migration.k8s.io<br/>storageversionmigrations<br/><i>create,delete,get,list,<br/>patch,update,watch</i>"]
        MR_Auth["authentication/authorization<br/>tokenreviews,<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    CR_Manager -->|"permissions"| ManagerResources

    %% proxy-role resources
    subgraph ProxyResources["proxy-role Permissions"]
        PR_Auth["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        PR_Authz["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    CR_Proxy -->|"permissions"| ProxyResources

    %% auth-delegator resources
    subgraph AuthDelegatorResources["system:auth-delegator Permissions"]
        AD_Token["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
        AD_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
    end

    CR_AuthDelegator -->|"permissions"| AuthDelegatorResources

    %% User-facing roles
    subgraph UserRoles["User-Facing Role Permissions"]
        UR_Admin["modelregistry-admin-role<br/>modelregistries: * (all)<br/>modelregistries/status: get"]
        UR_Editor["modelregistry-editor-role<br/>modelregistries: CRUD<br/>modelregistries/status: get"]
        UR_Viewer["modelregistry-viewer-role<br/>modelregistries: read-only<br/>modelregistries/status: get"]
    end

    CR_Admin -->|"permissions"| UR_Admin
    CR_Editor -->|"permissions"| UR_Editor
    CR_Viewer -->|"permissions"| UR_Viewer

    %% leader-election resources
    subgraph LeaderResources["leader-election-role Permissions"]
        LE_CM["core<br/>configmaps<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        LE_Lease["coordination.k8s.io<br/>leases<br/><i>get,list,watch,create,<br/>update,patch,delete</i>"]
        LE_Events["core<br/>events<br/><i>create,patch</i>"]
    end

    R_Leader -->|"permissions"| LeaderResources

    %% Styling
    style SA_CM fill:#4a90e2,color:#fff
    style SA_Instance fill:#4a90e2,color:#fff
    style SA_Catalog fill:#4a90e2,color:#fff
    style CR_Manager fill:#f5a623,color:#fff
    style CR_Proxy fill:#f5a623,color:#fff
    style CR_Metrics fill:#f5a623,color:#fff
    style CR_AuthDelegator fill:#f5a623,color:#fff
    style CR_Admin fill:#f5a623,color:#fff
    style CR_Editor fill:#f5a623,color:#fff
    style CR_Viewer fill:#f5a623,color:#fff
    style R_Leader fill:#f5a623,color:#fff
    style MR_Core fill:#7ed321,color:#fff
    style MR_CoreRO fill:#7ed321,color:#fff
    style MR_Apps fill:#7ed321,color:#fff
    style MR_ModelReg fill:#7ed321,color:#fff
    style MR_Network fill:#7ed321,color:#fff
    style MR_RBAC fill:#7ed321,color:#fff
    style MR_Route fill:#7ed321,color:#fff
    style MR_User fill:#7ed321,color:#fff
    style MR_Platform fill:#7ed321,color:#fff
    style MR_Migration fill:#7ed321,color:#fff
    style MR_Auth fill:#7ed321,color:#fff
