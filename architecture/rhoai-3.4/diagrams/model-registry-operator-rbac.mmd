graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>NS: opendatahub"]
        SA_Instance["SA: {name}<br/>NS: {namespace}<br/>(per ModelRegistry instance)"]
    end

    subgraph Groups["OpenShift Groups"]
        GRP_Users["{name}-users<br/>(per-instance user group)"]
        GRP_Auth["system:authenticated<br/>(all authenticated users)"]
        GRP_Admin["Auth CR adminGroups<br/>(platform admin groups)"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDelegator["{name}-auth-delegator"]
    end

    subgraph RoleBindings["Role Bindings (per namespace)"]
        RB_Leader["leader-election-rolebinding<br/>NS: {namespace}"]
        RB_Users["{name}-users<br/>NS: {namespace}"]
        RB_CatalogUsers["{name}-catalog-users<br/>NS: {namespace}"]
        RB_CatalogAdmin["{name}-catalog-admin<br/>NS: {namespace}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDelegator["system:auth-delegator"]
        CR_LeaderElection["leader-election-role"]
    end

    subgraph NamespacedRoles["Roles (per namespace)"]
        R_RegistryUser["registry-user-{name}"]
        R_CatalogUser["catalog-user"]
        R_CatalogAdmin["catalog-admin"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        MR_Core["core<br/>configmaps, pvcs, secrets,<br/>serviceaccounts, services<br/>→ create, delete, get, list,<br/>patch, update, watch"]
        MR_CoreRO["core<br/>endpoints, pods, pods/log<br/>→ get, list, watch"]
        MR_Events["core, events.k8s.io<br/>events<br/>→ create, patch"]
        MR_CRD["apiextensions.k8s.io<br/>customresourcedefinitions<br/>→ get, list, watch"]
        MR_Apps["apps<br/>deployments<br/>→ create, delete, get, list,<br/>patch, update, watch"]
        MR_ModelReg["modelregistry.opendatahub.io<br/>modelregistries,<br/>modelregistries/finalizers,<br/>modelregistries/status<br/>→ full CRUD"]
        MR_Network["networking.k8s.io<br/>networkpolicies<br/>→ full CRUD"]
        MR_RBAC["rbac.authorization.k8s.io<br/>clusterrolebindings,<br/>rolebindings, roles<br/>→ full CRUD"]
        MR_Routes["route.openshift.io<br/>routes, routes/custom-host<br/>→ full CRUD"]
        MR_Groups["user.openshift.io<br/>groups<br/>→ full CRUD"]
        MR_Platform["components.platform +<br/>services.platform<br/>modelregistries, auths<br/>→ get, list, watch"]
        MR_Migration["migration.k8s.io<br/>storageversionmigrations<br/>→ full CRUD"]
    end

    subgraph AuthDelegatorResources["auth-delegator Resources"]
        AD_Token["authentication.k8s.io<br/>tokenreviews<br/>→ create"]
        AD_SAR["authorization.k8s.io<br/>subjectaccessreviews<br/>→ create"]
    end

    subgraph RegistryUserResources["registry-user Resources"]
        RU_Svc["core<br/>services, endpoints<br/>→ get, list"]
    end

    subgraph CatalogUserResources["catalog-user Resources"]
        CU_Svc["core<br/>services, endpoints<br/>→ get, list"]
    end

    subgraph CatalogAdminResources["catalog-admin Resources"]
        CA_CM["core<br/>configmaps, secrets<br/>→ get, list, watch,<br/>update, patch"]
    end

    %% SA → CRB → CR → Resources
    SA_CM -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|accesses| MR_Core
    CR_Manager -->|accesses| MR_CoreRO
    CR_Manager -->|accesses| MR_Events
    CR_Manager -->|accesses| MR_CRD
    CR_Manager -->|accesses| MR_Apps
    CR_Manager -->|accesses| MR_ModelReg
    CR_Manager -->|accesses| MR_Network
    CR_Manager -->|accesses| MR_RBAC
    CR_Manager -->|accesses| MR_Routes
    CR_Manager -->|accesses| MR_Groups
    CR_Manager -->|accesses| MR_Platform
    CR_Manager -->|accesses| MR_Migration

    %% Auth delegator
    SA_Instance -->|bound via| CRB_AuthDelegator
    CRB_AuthDelegator -->|grants| CR_AuthDelegator
    CR_AuthDelegator -->|accesses| AD_Token
    CR_AuthDelegator -->|accesses| AD_SAR

    %% Leader election
    SA_CM -->|bound via| RB_Leader
    RB_Leader -->|grants| CR_LeaderElection

    %% Per-instance registry user
    GRP_Users -->|bound via| RB_Users
    RB_Users -->|grants| R_RegistryUser
    R_RegistryUser -->|accesses| RU_Svc

    %% Catalog user
    GRP_Auth -->|bound via| RB_CatalogUsers
    RB_CatalogUsers -->|grants| R_CatalogUser
    R_CatalogUser -->|accesses| CU_Svc

    %% Catalog admin
    GRP_Admin -->|bound via| RB_CatalogAdmin
    RB_CatalogAdmin -->|grants| R_CatalogAdmin
    R_CatalogAdmin -->|accesses| CA_CM

    %% Styling
    style SA_CM fill:#4a90e2,stroke:#333,color:#fff
    style SA_Instance fill:#4a90e2,stroke:#333,color:#fff
    style GRP_Users fill:#9b59b6,stroke:#333,color:#fff
    style GRP_Auth fill:#9b59b6,stroke:#333,color:#fff
    style GRP_Admin fill:#9b59b6,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDelegator fill:#f5a623,stroke:#333,color:#fff
    style CR_LeaderElection fill:#f5a623,stroke:#333,color:#fff
    style R_RegistryUser fill:#e67e22,stroke:#333,color:#fff
    style R_CatalogUser fill:#e67e22,stroke:#333,color:#fff
    style R_CatalogAdmin fill:#e67e22,stroke:#333,color:#fff
    style MR_Core fill:#7ed321,stroke:#333
    style MR_CoreRO fill:#7ed321,stroke:#333
    style MR_Events fill:#7ed321,stroke:#333
    style MR_CRD fill:#7ed321,stroke:#333
    style MR_Apps fill:#7ed321,stroke:#333
    style MR_ModelReg fill:#7ed321,stroke:#333
    style MR_Network fill:#7ed321,stroke:#333
    style MR_RBAC fill:#7ed321,stroke:#333
    style MR_Routes fill:#7ed321,stroke:#333
    style MR_Groups fill:#7ed321,stroke:#333
    style MR_Platform fill:#7ed321,stroke:#333
    style MR_Migration fill:#7ed321,stroke:#333
    style AD_Token fill:#7ed321,stroke:#333
    style AD_SAR fill:#7ed321,stroke:#333
    style RU_Svc fill:#7ed321,stroke:#333
    style CU_Svc fill:#7ed321,stroke:#333
    style CA_CM fill:#7ed321,stroke:#333
