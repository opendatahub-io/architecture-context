graph TD
    subgraph "Service Accounts"
        SA["sa<br/>(model server)<br/>automountServiceAccountToken: false"]
    end

    subgraph "RBAC Configuration"
        NoClusterRoles["No ClusterRoles Defined<br/>(minimal RBAC by design)"]
        NoRoleBindings["No RoleBindings in base recipes<br/>(WVA adds metrics-reader)"]
    end

    subgraph "Pod Security (OpenShift)"
        DropCaps["Drop ALL capabilities"]
        ReadOnly["readOnlyRootFilesystem"]
        NonRoot["runAsNonRoot"]
    end

    subgraph "Secrets"
        HFToken["hf-token<br/>Type: Opaque<br/>Purpose: HuggingFace API token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
        PromTLS["prometheus-web-tls<br/>Type: kubernetes.io/tls<br/>Purpose: Prometheus HTTPS<br/>Provisioned: Script-generated<br/>Auto-Rotate: No"]
        CtrlToken["controller-manager-token<br/>Type: Opaque<br/>Purpose: WVA controller auth<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph "Authentication & Authorization"
        InferenceAPI["/v1/completions<br/>/v1/chat/completions<br/>Auth: None (cluster-internal)<br/>Enforcement: NetworkPolicy/Gateway"]
        MetricsAPI["/metrics<br/>Auth: None<br/>Enforcement: NetworkPolicy"]
        GatewayAuth["Gateway External Access<br/>Auth: Platform-dependent<br/>Enforcement: Gateway provider"]
    end

    SA -->|"minimal permissions"| NoClusterRoles
    SA -->|"no auto-mount"| NoRoleBindings

    SA -->|"pod security"| DropCaps
    SA -->|"pod security"| ReadOnly
    SA -->|"pod security"| NonRoot

    SA -->|"uses"| HFToken
    SA -.->|"WVA uses"| PromTLS
    SA -.->|"WVA uses"| CtrlToken

    SA -->|"serves"| InferenceAPI
    SA -->|"exposes"| MetricsAPI
    InferenceAPI -->|"fronted by"| GatewayAuth

