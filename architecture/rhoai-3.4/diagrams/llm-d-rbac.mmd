graph TD
    subgraph ModelServerSA["Model Server Service Account"]
        SA_MS["ServiceAccount<br/>(per-deployment)<br/>automountServiceAccountToken: false"]
    end

    subgraph ModelServerPerms["Model Server Permissions"]
        NoPerms["No Kubernetes API Access<br/>(token not mounted)"]
    end

    subgraph EPPSA["EPP / Router Service Account (GAIE Chart Managed)"]
        SA_EPP["ServiceAccount<br/>(GAIE-created)"]
    end

    subgraph EPPRoleBindings["EPP Role Bindings"]
        CRB_EPP["RoleBinding<br/>(GAIE-created)<br/>Namespace: deployment NS"]
    end

    subgraph EPPRole["EPP ClusterRole / Role"]
        CR_EPP["Role<br/>(GAIE chart managed)"]
    end

    subgraph EPPResources["API Resources (EPP)"]
        InferencePool["inference.networking.k8s.io<br/>InferencePool"]
        Pods["core ('')<br/>Pods"]
    end

    subgraph Secrets["Secrets"]
        HFSecret["hf-secret<br/>Type: Opaque<br/>Purpose: HF API token<br/>Provisioned: Manual<br/>Auto-Rotate: No"]
    end

    subgraph NetworkEndpoints["Exposed Endpoints (No Auth)"]
        EP_Completions["/v1/completions<br/>POST 8000/TCP<br/>Auth: None"]
        EP_Chat["/v1/chat/completions<br/>POST 8000/TCP<br/>Auth: None"]
        EP_Models["/v1/models<br/>GET 8000/TCP<br/>Auth: None"]
        EP_Health["/health<br/>GET 8000/TCP<br/>Auth: None"]
        EP_Metrics["/metrics<br/>GET 8000/TCP<br/>Auth: None"]
        EP_ExtProc["ext-proc<br/>gRPC 6789/TCP<br/>Auth: None"]
        EP_Gateway["Gateway<br/>80/TCP<br/>Auth: Provider-configurable"]
    end

    %% Model Server SA flow
    SA_MS -->|"no token mounted"| NoPerms
    SA_MS -.->|"mounts"| HFSecret

    %% EPP SA flow
    SA_EPP -->|"bound via"| CRB_EPP
    CRB_EPP -->|"grants"| CR_EPP
    CR_EPP -->|"get, list, watch"| InferencePool
    CR_EPP -->|"get, list, watch"| Pods

    %% Styling
    style SA_MS fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NoPerms fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style SA_EPP fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CRB_EPP fill:#dae8fc,stroke:#6c8ebf
    style CR_EPP fill:#f5a623,stroke:#333,stroke-width:2px
    style InferencePool fill:#7ed321,stroke:#333,stroke-width:2px
    style Pods fill:#7ed321,stroke:#333,stroke-width:2px
    style HFSecret fill:#ffcdd2,stroke:#e53935,stroke-width:2px
    style EP_Completions fill:#fff2cc,stroke:#d6b656
    style EP_Chat fill:#fff2cc,stroke:#d6b656
    style EP_Models fill:#fff2cc,stroke:#d6b656
    style EP_Health fill:#fff2cc,stroke:#d6b656
    style EP_Metrics fill:#fff2cc,stroke:#d6b656
    style EP_ExtProc fill:#fff2cc,stroke:#d6b656
    style EP_Gateway fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
