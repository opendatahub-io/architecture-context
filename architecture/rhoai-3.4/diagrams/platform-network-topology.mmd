graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Clients["External Clients<br/>Data Scientists, ML Engineers,<br/>API Consumers"]
    end

    subgraph Ingress["INGRESS (data-science-gateway - Envoy)"]
        direction TB
        Dashboard_GW["ODH Dashboard<br/>443 → 8080/TCP<br/>HTTPS, TLS termination<br/>kube-auth-proxy (OIDC/OAuth)"]
        Notebook_GW["Notebooks / Workbenches<br/>443 → 8888/TCP<br/>HTTPS, TLS termination<br/>kube-auth-proxy (SAR)"]
        KServe_GW["KServe InferenceService<br/>443 → 8012/TCP<br/>HTTPS, Istio Gateway<br/>mTLS STRICT + SA tokens"]
        LLMIS_GW["LLMInferenceService<br/>443 → 8080/TCP via EPP<br/>HTTPS, Gateway API<br/>Kuadrant AuthPolicy"]
        DSP_GW["DS Pipelines UI/API<br/>443 → 8888/TCP<br/>HTTPS, TLS termination<br/>kube-auth-proxy"]
        MaaS_GW["MaaS Gateway<br/>443 → 8080/TCP<br/>HTTPS, OpenAI-compat<br/>Kuadrant + MaaSAPIKey"]
    end

    subgraph PlatformNS["PLATFORM (redhat-ods-applications)"]
        direction TB

        subgraph Controllers["Operator Controllers"]
            rhods["rhods-operator<br/>194 watches"]
            KServeCtrl["KServe Controller<br/>49 watches"]
            LLMISVCCtrl["llmisvc Controller"]
            ODHModelCtrl["odh-model-controller<br/>40 watches"]
            DSPO["DSPO"]
            OtherOps["KubeRay, Feast, Spark,<br/>KFTO, MLflow, ModelReg,<br/>LlamaStack, MaaS,<br/>TrustyAI, WVA"]
        end

        subgraph IngressInfra["Ingress Infrastructure"]
            Gateway["data-science-gateway<br/>Envoy data plane<br/>20+ HTTPRoutes"]
            KubeAuthProxy["kube-auth-proxy<br/>Dual mode: auth + rbac<br/>FIPS compliant"]
        end

        subgraph LLMDataPlane["LLM Inference Data Plane"]
            EPP["Gateway API Inference<br/>Extension (EPP)<br/>ext-proc gRPC"]
            LLMDSched["llm-d Inference<br/>Scheduler"]
            Guardrails["FMS Guardrails<br/>Orchestrator"]
            VLLMOrchGW["vllm-orchestrator<br/>-gateway (Rust)"]
            AIGateway["AI Gateway<br/>Payload Processing"]
        end

        subgraph PlatformSvcs["Platform Services"]
            Dashboard["ODH Dashboard<br/>Module Fed + 7 BFF"]
            ModelReg["Model Registry"]
            MLflow["MLflow Tracking"]
            DSP["DS Pipelines<br/>API Server"]
            Feast["Feast<br/>Feature Server"]
            TrustyAI["TrustyAI Service"]
        end
    end

    subgraph UserNS["USER NAMESPACES (per Data Science Project)"]
        direction TB
        Notebooks["Notebook Pods<br/>JupyterLab, RStudio,<br/>Code-Server"]
        ISvcPods["InferenceService Pods<br/>vLLM, OpenVINO,<br/>MLServer, caikit-nlp"]
        LLMISPods["LLMInferenceService Pods<br/>vLLM + llm-d stack"]
        PipelinePods["Pipeline Step Pods<br/>Argo Workflows"]
        RayClusters["Ray Clusters<br/>KubeRay managed"]
        TrainingJobs["Training Jobs<br/>KFTO / Kubeflow Trainer"]
    end

    subgraph Monitoring["MONITORING (redhat-ods-monitoring)"]
        Prometheus["Prometheus<br/>ServiceMonitor scrapes"]
    end

    subgraph ExtPlatform["EXTERNAL PLATFORM"]
        Istio["Istio Control Plane<br/>(istio-system)<br/>mTLS STRICT"]
        Knative["Knative Serving<br/>(knative-serving)<br/>Autoscaling"]
    end

    subgraph EgressSvcs["EGRESS (External Services)"]
        S3["S3 / MinIO<br/>Object Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        ContainerReg["Container Registry<br/>registry.redhat.io<br/>443/TCP HTTPS<br/>Pull secrets"]
        OAuthServer["OpenShift OAuth<br/>Token validation<br/>HTTPS"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>SA tokens"]
    end

    %% External to Ingress
    Clients -->|HTTPS/443| Dashboard_GW
    Clients -->|HTTPS/443| Notebook_GW
    Clients -->|HTTPS/443| KServe_GW
    Clients -->|HTTPS/443| LLMIS_GW
    Clients -->|HTTPS/443| DSP_GW
    Clients -->|HTTPS/443| MaaS_GW

    %% Ingress to Gateway
    Dashboard_GW -->|HTTPRoute| Gateway
    Notebook_GW -->|HTTPRoute| Gateway
    KServe_GW -->|Istio GW| Istio
    LLMIS_GW -->|HTTPRoute| Gateway
    DSP_GW -->|HTTPRoute| Gateway
    MaaS_GW -->|HTTPRoute| Gateway

    %% Gateway to auth and services
    Gateway -->|auth delegation| KubeAuthProxy
    Gateway -->|ext-proc gRPC| EPP
    Gateway -->|ext-proc gRPC| AIGateway
    Gateway -->|HTTP| Dashboard
    Gateway -->|HTTP| Notebooks
    Gateway -->|HTTP| DSP
    Gateway -->|HTTP| ModelReg
    Gateway -->|HTTP| Feast
    Gateway -->|HTTP| LLMISPods

    %% Auth to external
    KubeAuthProxy -->|token validation<br/>HTTPS| OAuthServer
    KubeAuthProxy -->|SubjectAccessReview<br/>HTTPS/443| K8sAPI

    %% Controller to K8s API
    rhods -->|HTTPS/443<br/>SA token| K8sAPI
    KServeCtrl -->|HTTPS/443<br/>SA token| K8sAPI
    ODHModelCtrl -->|HTTPS/443<br/>SA token| K8sAPI
    DSPO -->|HTTPS/443<br/>SA token| K8sAPI

    %% Controller to external platform
    KServeCtrl -->|config| Knative
    KServeCtrl -->|config| Istio
    LLMISVCCtrl -->|HTTPRoute CRUD| Gateway
    ODHModelCtrl -->|HTTPRoute, EnvoyFilter| Gateway

    %% LLM data plane
    EPP -->|inference routing| LLMISPods
    LLMDSched -->|P/D scheduling| EPP
    Guardrails -->|content filtering| ISvcPods
    VLLMOrchGW -->|filtered inference| ISvcPods

    %% Platform service integrations
    Dashboard -->|gRPC| ModelReg
    Dashboard -->|HTTP| DSP
    Dashboard -->|HTTP| MLflow
    Dashboard -->|HTTP| TrustyAI

    %% User workload to egress
    Notebooks -->|HTTPS/443<br/>AWS IAM| S3
    ISvcPods -->|HTTPS/443<br/>model download| S3
    LLMISPods -->|HTTPS/443<br/>model download| S3
    PipelinePods -->|HTTPS/443<br/>artifacts| S3
    RayClusters -->|HTTPS/443<br/>checkpoints| S3
    TrainingJobs -->|HTTPS/443<br/>data/models| S3

    %% Image pulls
    ISvcPods -->|HTTPS/443<br/>pull secret| ContainerReg
    LLMISPods -->|HTTPS/443<br/>pull secret| ContainerReg

    %% Monitoring
    Prometheus -->|scrape :8080<br/>or :8443| Controllers
    Prometheus -->|scrape| PlatformSvcs

    %% Istio to pods
    Istio -->|sidecar inject<br/>mTLS STRICT| ISvcPods

    %% Pipeline flow
    PipelinePods -->|gRPC<br/>lineage| ModelReg
    DSP -->|gRPC<br/>metadata| ModelReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef platform fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef userworkload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef extplat fill:#f0f0f0,stroke:#666,stroke-width:2px

    class Clients external
    class Dashboard_GW,Notebook_GW,KServe_GW,LLMIS_GW,DSP_GW,MaaS_GW ingress
    class rhods,KServeCtrl,LLMISVCCtrl,ODHModelCtrl,DSPO,OtherOps,Gateway,KubeAuthProxy,EPP,LLMDSched,Guardrails,VLLMOrchGW,AIGateway,Dashboard,ModelReg,MLflow,DSP,Feast,TrustyAI platform
    class Notebooks,ISvcPods,LLMISPods,PipelinePods,RayClusters,TrainingJobs userworkload
    class Prometheus monitoring
    class Istio,Knative extplat
    class S3,ContainerReg,OAuthServer,K8sAPI egress
