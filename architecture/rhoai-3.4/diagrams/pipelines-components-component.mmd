graph TB
    subgraph BuildTime["Build Time"]
        direction TB
        GenManaged["generate_managed_pipelines<br/>(Build Script)<br/>Discovers managed pipelines,<br/>validates metadata, compiles to YAML"]
    end

    subgraph KFPComponents["kfp-components Python Library"]
        direction TB

        subgraph DataProcessing["Data Processing Components"]
            DatasetDownload["dataset_download<br/>@dsl.component"]
            YodaProcessor["yoda_data_processor<br/>@dsl.component"]
            SDG["sdg (Synthetic Data Gen)<br/>@dsl.component"]
        end

        subgraph Training["Training Components"]
            SFT["sft (Supervised Fine-Tuning)<br/>@dsl.component"]
            LoRA["lora (Low-Rank Adaptation)<br/>@dsl.component"]
            OSFT["osft (Offline SFT)<br/>@dsl.component"]
        end

        subgraph AutoML["AutoML Components"]
            TabularTraining["autogluon_models_training<br/>@dsl.component"]
            TabularEval["autogluon_leaderboard_evaluation<br/>@dsl.component"]
            TSTraining["autogluon_timeseries_models<br/>@dsl.component"]
        end

        subgraph AutoRAG["AutoRAG Components"]
            DocsDiscovery["documents_discovery<br/>@dsl.component"]
            TextExtract["text_extraction<br/>@dsl.component"]
            SearchSpacePrep["search_space_preparation<br/>@dsl.component"]
            RAGOptimize["rag_templates_optimization<br/>@dsl.component"]
        end

        subgraph Evaluation["Evaluation Components"]
            LMEval["universal_llm_evaluator<br/>@dsl.component"]
        end

        subgraph Deployment["Deployment Components"]
            ModelReg["kubeflow_model_registry<br/>@dsl.component"]
            BuildResponses["build_responses_request_bodies<br/>@dsl.component"]
        end
    end

    subgraph RuntimeImages["Container Images"]
        InitContainer["odh-pipelines-components<br/>(Init Container)<br/>quay.io/rhoai/odh-pipelines-components-rhel9"]
        AutoMLImage["odh-automl<br/>(Runtime Image)<br/>quay.io/rhoai/odh-automl-rhel9"]
        AutoRAGImage["odh-autorag<br/>(Runtime Image)<br/>quay.io/rhoai/odh-autorag-rhel9"]
    end

    subgraph Runtime["Runtime"]
        direction TB
        InitScript["init_managed_pipelines<br/>(Container CMD)"]
        SharedVolume["/config/managed-pipelines/<br/>(Shared Volume)"]
        KFPServer["KFP API Server"]
    end

    %% Build-time flow
    GenManaged -->|"compiles managed pipelines<br/>to KFP YAML"| InitContainer

    %% Runtime flow
    InitContainer -->|"runs"| InitScript
    InitScript -->|"copies pipeline YAMLs"| SharedVolume
    KFPServer -->|"discovers pipelines"| SharedVolume

    %% Image usage
    AutoMLImage -->|"base_image for"| AutoML
    AutoRAGImage -->|"base_image for"| AutoRAG

    %% Styling
    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style AutoMLImage fill:#4a90e2,stroke:#333,color:#fff
    style AutoRAGImage fill:#4a90e2,stroke:#333,color:#fff
    style GenManaged fill:#9b59b6,stroke:#333,color:#fff
    style InitScript fill:#27ae60,stroke:#333,color:#fff
    style SharedVolume fill:#f5a623,stroke:#333,color:#fff
    style KFPServer fill:#e74c3c,stroke:#333,color:#fff
    style DatasetDownload fill:#85c1e9,stroke:#333
    style SFT fill:#85c1e9,stroke:#333
    style LoRA fill:#85c1e9,stroke:#333
    style OSFT fill:#85c1e9,stroke:#333
    style TabularTraining fill:#85c1e9,stroke:#333
    style LMEval fill:#85c1e9,stroke:#333
    style ModelReg fill:#85c1e9,stroke:#333
    style DocsDiscovery fill:#85c1e9,stroke:#333
    style RAGOptimize fill:#85c1e9,stroke:#333
