graph TB
    subgraph PipelinesComponents["Pipelines Components"]
        direction TB

        subgraph InitContainer["Init Container (pipelines-components)"]
            InitScript["init_managed_pipelines.py<br/>Copies compiled YAMLs<br/>to shared volume"]
            Manifest["managed-pipelines.json<br/>Pipeline manifest"]
            Manifest -->|read by| InitScript
        end

        subgraph BuildTime["Build-Time Pipeline Compilation"]
            Generator["generate_managed_pipelines.py<br/>Discovers & compiles pipelines"]
            MetadataFiles["metadata.yaml files<br/>(managed: true)"]
            KFPCompiler["KFP Compiler v2.16.0"]
            MetadataFiles -->|discovered by| Generator
            Generator -->|uses| KFPCompiler
            KFPCompiler -->|produces| CompiledYAMLs["Compiled Pipeline YAMLs"]
            CompiledYAMLs -->|bundled into| InitScript
        end

        subgraph ComponentLibrary["KFP Component Library (v1.11.0)"]
            direction LR
            AutoMLComps["AutoML Components<br/>tabular_data_loader<br/>timeseries_data_loader<br/>autogluon_models_training<br/>leaderboard_evaluation"]
            AutoRAGComps["AutoRAG Components<br/>documents_discovery<br/>text_extraction<br/>search_space_preparation<br/>rag_templates_optimization<br/>documents_indexing"]
            FinetuneComps["Finetuning Components<br/>lora<br/>osft<br/>sft"]
            UtilComps["Utility Components<br/>dataset_download<br/>sdg<br/>lm_eval<br/>kubeflow_model_registry"]
        end
    end

    subgraph RuntimeImages["Runtime Container Images"]
        AutoMLImage["odh-automl<br/>AutoGluon + ML deps<br/>UBI9 base"]
        AutoRAGImage["odh-autorag<br/>ai4rag + docling + LlamaStack<br/>UBI9 base"]
    end

    subgraph ManagedPipelines["Managed Pipeline Collection"]
        TabularPipeline["AutoML Tabular Training"]
        TimeseriesPipeline["AutoML Timeseries Training"]
        RAGPipeline["AutoRAG Optimization"]
        LoRAPipeline["LoRA Finetuning"]
        SFTPipeline["SFT Finetuning"]
        OSFTPipeline["OSFT Finetuning"]
        SDGPipeline["SDG Pipeline"]
        IndexingPipeline["Documents Indexing"]
    end

    %% Init container staging
    SharedVolume["/config/managed-pipelines<br/>(Shared Volume)"]
    KFPAPIServer["KFP API Server"]
    InitScript -->|"copies YAMLs<br/>(shutil.copy2)"| SharedVolume
    SharedVolume -->|"volume mount<br/>pipeline registration"| KFPAPIServer

    %% Runtime images used by components
    AutoMLComps -.->|base_image| AutoMLImage
    AutoRAGComps -.->|base_image| AutoRAGImage

    %% Pipelines use components
    TabularPipeline -.->|uses| AutoMLComps
    TimeseriesPipeline -.->|uses| AutoMLComps
    RAGPipeline -.->|uses| AutoRAGComps
    LoRAPipeline -.->|uses| FinetuneComps
    SFTPipeline -.->|uses| FinetuneComps
    OSFTPipeline -.->|uses| FinetuneComps

    %% External dependencies
    ArgoWorkflow["KFP Argo Workflow Engine"]
    KFPAPIServer -->|orchestrates via| ArgoWorkflow
    ArgoWorkflow -->|schedules pods for| ComponentLibrary

    style InitContainer fill:#4a90e2,stroke:#333,color:#fff
    style ComponentLibrary fill:#7ed321,stroke:#333
    style RuntimeImages fill:#f5a623,stroke:#333
    style ManagedPipelines fill:#9b59b6,stroke:#333,color:#fff
    style SharedVolume fill:#e8e8e8,stroke:#333
    style KFPAPIServer fill:#e74c3c,stroke:#333,color:#fff
    style ArgoWorkflow fill:#e74c3c,stroke:#333,color:#fff
