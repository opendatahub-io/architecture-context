graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Platform-managed)"]
        IngressCtrl["Kubernetes Ingress Controller<br/>{instance}-ingress<br/>80/TCP → 8321/TCP<br/>TLS: platform-dependent"]
    end

    subgraph WorkloadNS["WORKLOAD NAMESPACE ({user-namespace})<br/>NetworkPolicy: {instance}-netpol"]
        direction TB

        subgraph PodBox["LlamaStack Server Pod"]
            LLPod["LlamaStack Server<br/>SA: {instance}-sa<br/>SCC: anyuid (fsGroup=1001)<br/>SSL_CERT_FILE: /certs/ca-bundle.crt<br/>Port: 8321/TCP HTTP"]
        end

        InstanceSvc["{instance}-service<br/>ClusterIP 8321/TCP<br/>HTTP, plaintext"]
        ManagedCA["Managed CA ConfigMap<br/>(aggregated certs)"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-applications)"]
        direction TB

        Operator["LlamaStack K8s Operator<br/>SA: controller-manager<br/>ClusterRole: manager-role<br/>Probes: 8081/TCP"]
        MetricsSvc["Metrics Service<br/>8443/TCP HTTPS<br/>kube-rbac-proxy<br/>Auth: Bearer Token"]
    end

    subgraph ClusterSvcs["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        Prometheus["Prometheus<br/>(ServiceMonitor)"]
        SCC["OpenShift SCC: anyuid"]
    end

    subgraph ConfigSources["CONFIGURATION SOURCES"]
        UserCACM["User CA ConfigMap"]
        ODHTrustCM["odh-trusted-ca-bundle<br/>ConfigMap"]
        OperatorConfig["llama-stack-operator-config<br/>ConfigMap<br/>(feature flags, image overrides)"]
    end

    %% External access flow
    Client -->|"HTTP/80<br/>No Auth<br/>NetworkPolicy enforced"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>plaintext"| InstanceSvc
    InstanceSvc --> LLPod

    %% Operator → K8s API
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Bearer Token<br/>CR watch + resource CRUD"| K8sAPI

    %% Operator → Managed pods (health checks)
    Operator -->|"HTTP/8321<br/>plaintext<br/>No Auth<br/>health/providers/version"| InstanceSvc

    %% Operator → ConfigMap reads
    Operator -->|"HTTPS/443<br/>direct client read"| UserCACM
    Operator -->|"HTTPS/443<br/>direct client read"| ODHTrustCM
    Operator -->|"HTTPS/443<br/>direct client read"| OperatorConfig

    %% CA bundle flow
    Operator -->|"creates/updates"| ManagedCA
    ManagedCA -->|"mounted as<br/>SSL_CERT_FILE"| LLPod

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| MetricsSvc

    %% SCC reference
    LLPod -.->|"RoleBinding →<br/>system:openshift:scc:anyuid"| SCC

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workload fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef config fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class LLPod,InstanceSvc,ManagedCA workload
    class Operator,MetricsSvc operator
    class K8sAPI,Prometheus,SCC cluster
    class UserCACM,ODHTrustCM,OperatorConfig config
