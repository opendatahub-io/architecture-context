graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressCtrl["OpenShift Ingress Controller<br/>80/443/TCP<br/>TLS termination (configurable)<br/>No auth at Ingress level"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (NetworkPolicy Protected)"]
        direction TB

        subgraph NS_Operator["Namespace: redhat-ods-applications"]
            OperatorPod["llama-stack-k8s-operator<br/>SA: controller-manager<br/>Metrics: 8080/TCP<br/>Health: 8081/TCP"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            LLSDService["{instance}-service<br/>ClusterIP 8321/TCP"]
            LLSDPod["LlamaStack Server Pod<br/>SA: {instance}-sa<br/>SCC: anyuid (fsGroup 1001)<br/>Port: 8321/TCP<br/>SSL_CERT_FILE: managed CA"]
            NetPol["NetworkPolicy<br/>Allow: same-ns, operator-ns,<br/>explicit ns, label selectors,<br/>router ns"]
        end
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Token"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry credentials"]
    end

    %% External access flow
    Client -->|"HTTP/HTTPS 80/443<br/>No auth (Ingress level)"| IngressCtrl
    IngressCtrl -->|"HTTP/8321<br/>No encryption<br/>No auth"| LLSDService
    LLSDService --> LLSDPod

    %% Operator flows
    OperatorPod -->|"HTTP/8321<br/>No encryption<br/>Status: /v1/providers, /v1/version"| LLSDPod
    OperatorPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token (bearer)<br/>Reconciliation, CRUD, leader election"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>No auth<br/>Scrape /metrics"| OperatorPod

    %% Image pull (by Kubelet)
    LLSDPod -.->|"HTTPS/443<br/>TLS 1.2+<br/>Registry creds<br/>(pulled by Kubelet)"| Registry

    %% NetworkPolicy enforcement
    NetPol -.->|protects| LLSDPod

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef clusterinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef platform fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class IngressCtrl ingress
    class OperatorPod,LLSDPod,LLSDService clusterinternal
    class K8sAPI,Prometheus platform
    class Registry externalservice
    class NetPol netpol
