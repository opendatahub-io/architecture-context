graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (DMZ) — Managed by KServe Controller"]
        Gateway["KServe Ingress Gateway<br/>OpenShift Route / HTTPRoute<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ termination<br/>Auth: kube-rbac-proxy / oauth-proxy"]
    end

    subgraph PodNetwork["POD NETWORK (Internal)"]
        direction TB

        subgraph Pod["InferenceService Pod — Namespace: {user-ns}"]
            direction LR
            InitContainer["Storage Initializer<br/>(init container)<br/>kserve-storage v0.17.0"]
            Volume["/mnt/models<br/>Shared Volume"]
            ServerContainer["autogluonserver<br/>8080/TCP HTTP (REST v1/v2)<br/>8081/TCP gRPC (optional)<br/>UBI9 base, multi-arch<br/>cryptography 46.0.7"]
            InitContainer -->|"writes"| Volume
            Volume -->|"reads"| ServerContainer
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / Access Key"]
        HF["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
        Git["Git Repositories<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Git credentials (optional)"]
    end

    subgraph Monitoring["MONITORING (Cluster-Internal)"]
        Prometheus["Prometheus<br/>Metrics Scraper"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Pod
    Gateway -->|"HTTP/8080<br/>No TLS (pod network)<br/>Auth delegated"| ServerContainer

    %% Init container → External storage
    InitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage credentials"| S3
    InitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>HF token"| HF
    InitContainer -->|"HTTPS/443<br/>TLS 1.2+<br/>Git creds"| Git

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>GET /metrics<br/>No auth"| ServerContainer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef volume fill:#f5f5f5,stroke:#666,stroke-dasharray:5 5

    class Client external
    class Gateway ingress
    class InitContainer,ServerContainer podnetwork
    class S3,HF,Git externalservice
    class Prometheus monitoring
    class Volume volume
