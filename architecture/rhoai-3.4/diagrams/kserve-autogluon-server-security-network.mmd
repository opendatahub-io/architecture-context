graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Inference Client"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        Route["HTTPRoute / OpenShift Route<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE<br/>Managed by KServe Controller"]
    end

    subgraph Pod["INFERENCE POD (KServe-managed)"]
        direction TB

        subgraph AuthProxy["Auth Sidecar"]
            RBAC["kube-rbac-proxy<br/>8443/TCP HTTPS TLS 1.2+<br/>SubjectAccessReview<br/>Injected by RHOAI operator"]
        end

        subgraph ServerContainer["autogluonserver Container"]
            Server["autogluonserver<br/>User: 1001 (non-root)<br/>UBI9 base image"]
            REST["REST API<br/>8080/TCP HTTP<br/>v1: /v1/models/{'{name}'}:predict<br/>v2: /v2/models/{'{name}'}/infer"]
            GRPC["gRPC API<br/>8081/TCP gRPC<br/>GRPCInferenceService"]
            MetricsEP["Prometheus Metrics<br/>8080/TCP GET /metrics"]
        end

        subgraph InitPhase["Init Container Phase"]
            StorageInit["Storage Initializer<br/>Downloads to /mnt/models"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS TLS 1.2+<br/>AWS IAM credentials"]
        GCS["Google Cloud Storage<br/>443/TCP HTTPS TLS 1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>443/TCP HTTPS TLS 1.2+<br/>Azure credentials"]
        HFHub["Hugging Face Hub<br/>443/TCP HTTPS TLS 1.2+<br/>HF Token (optional)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Route
    Route -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| RBAC
    RBAC -->|"HTTP/8080<br/>localhost<br/>Pre-authorized"| REST
    RBAC -->|"HTTP/8080<br/>localhost<br/>Pre-authorized"| GRPC

    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>GCP SA"| GCS
    StorageInit -->|"HTTPS/443<br/>TLS 1.2+<br/>Azure creds"| Azure
    Server -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token"| HFHub

    Prometheus -->|"HTTP/8080<br/>GET /metrics"| MetricsEP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef server fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef initcontainer fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class RBAC authproxy
    class Server,REST,GRPC,MetricsEP server
    class StorageInit initcontainer
    class S3,GCS,Azure,HFHub externalservice
    class Prometheus monitoring
