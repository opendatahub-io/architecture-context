graph TB
    subgraph KubeRayOperator["KubeRay Operator (/manager)"]
        direction TB
        RayClusterReconciler["RayClusterReconciler<br/>Core cluster orchestration"]
        RayJobReconciler["RayJobReconciler<br/>Job submission & lifecycle"]
        RayServiceReconciler["RayServiceReconciler<br/>Ray Serve management"]
        AuthController["AuthenticationController<br/>OAuth/OIDC infrastructure"]
        NetworkPolicyCtrl["NetworkPolicyController<br/>Network access control"]
        MTLSController["RayClusterMTLSController<br/>mTLS certificate management"]
        MutatingWebhook["Mutating Webhook<br/>OpenShift defaults"]
        ValidatingWebhook["Validating Webhook<br/>Name/group validation"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    RayServiceCR["RayService CR<br/>(ray.io/v1)"]
    ConfigCR["Configuration CR<br/>(config.ray.io/v1alpha1)"]

    %% Created Resources
    HeadPod["Head Pod<br/>Ray head node"]
    WorkerPods["Worker Pods<br/>Ray worker nodes"]
    HeadSvc["Head Service<br/>8265, 10001, 6379, 8080"]
    ServeSvc["Serve Service<br/>8000"]
    HeadlessSvc["Headless Service<br/>Worker peer discovery"]
    HTTPRoute["HTTPRoute<br/>Gateway API ingress"]
    RefGrant["ReferenceGrant<br/>Cross-namespace ref"]
    NetPolicies["NetworkPolicies<br/>Head & worker pods"]
    Certs["Certificates & Issuers<br/>mTLS via cert-manager"]
    AuthSidecar["Auth Sidecar<br/>kube-rbac-proxy / oauth-proxy"]
    SubmitterJob["Submitter K8s Job<br/>ray job submit"]

    %% User
    User["User / Data Scientist"]

    %% Flows
    User -->|kubectl apply| RayClusterCR
    User -->|kubectl apply| RayJobCR
    User -->|kubectl apply| RayServiceCR

    RayClusterCR -->|watched by| RayClusterReconciler
    RayJobCR -->|watched by| RayJobReconciler
    RayServiceCR -->|watched by| RayServiceReconciler
    ConfigCR -.->|configures| KubeRayOperator

    RayClusterCR -->|webhook intercept| MutatingWebhook
    RayClusterCR -->|webhook intercept| ValidatingWebhook

    RayClusterReconciler -->|creates| HeadPod
    RayClusterReconciler -->|creates| WorkerPods
    RayClusterReconciler -->|creates| HeadSvc
    RayClusterReconciler -->|creates| ServeSvc
    RayClusterReconciler -->|creates| HeadlessSvc

    RayJobReconciler -->|creates| SubmitterJob
    RayJobReconciler -->|creates RayCluster| RayClusterCR

    RayServiceReconciler -->|manages active/pending| RayClusterCR

    AuthController -->|creates| HTTPRoute
    AuthController -->|creates| RefGrant
    AuthController -->|injects| AuthSidecar

    NetworkPolicyCtrl -->|creates| NetPolicies

    MTLSController -->|creates| Certs

    %% External Dependencies
    K8sAPI["Kubernetes API Server"]
    Gateway["RHOAI Gateway<br/>(data-science-gateway)"]
    CertManager["cert-manager"]
    RayDashboard["Ray Dashboard<br/>(head pod :8265)"]

    RayClusterReconciler -->|CRUD via| K8sAPI
    RayJobReconciler -->|job status| RayDashboard
    AuthController -->|references| Gateway
    MTLSController -->|creates CRs| CertManager

    %% Styling
    style KubeRayOperator fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    style RayClusterReconciler fill:#4a90e2,stroke:#333,color:#fff
    style RayJobReconciler fill:#4a90e2,stroke:#333,color:#fff
    style RayServiceReconciler fill:#4a90e2,stroke:#333,color:#fff
    style AuthController fill:#4a90e2,stroke:#333,color:#fff
    style NetworkPolicyCtrl fill:#4a90e2,stroke:#333,color:#fff
    style MTLSController fill:#4a90e2,stroke:#333,color:#fff
    style MutatingWebhook fill:#7b1fa2,stroke:#333,color:#fff
    style ValidatingWebhook fill:#7b1fa2,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style ConfigCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style HeadSvc fill:#7ed321,stroke:#333
    style ServeSvc fill:#7ed321,stroke:#333
    style HeadlessSvc fill:#7ed321,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style RefGrant fill:#7ed321,stroke:#333
    style NetPolicies fill:#7ed321,stroke:#333
    style Certs fill:#7ed321,stroke:#333
    style AuthSidecar fill:#7ed321,stroke:#333
    style SubmitterJob fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
