%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "KubeRay Operator (opendatahub namespace)"
        direction TB
        RCController["RayCluster Controller"]
        RJController["RayJob Controller"]
        RSController["RayService Controller"]
        AuthController["Authentication Controller"]
        NPController["NetworkPolicy Controller"]
        MTLSController["mTLS Controller"]
        MutWebhook["Mutating Webhook<br/>9443/TCP HTTPS"]
        ValWebhook["Validating Webhook<br/>9443/TCP HTTPS"]
        Metrics["Metrics Server<br/>8080/TCP HTTP"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    %% Created Resources
    subgraph "User Namespace"
        HeadPod["Ray Head Pod<br/>(+ kube-rbac-proxy sidecar)"]
        WorkerPods["Ray Worker Pods"]
        HeadSvc["{cluster}-head-svc<br/>8265, 10001, 6379, 8080"]
        ServeSvc["{cluster}-serve-svc<br/>8000"]
        NetPolicies["NetworkPolicies<br/>(head + worker)"]
        MTLSCerts["mTLS Certificates<br/>(cert-manager)"]
        RefGrant["ReferenceGrant<br/>(cross-namespace)"]
    end

    subgraph "Platform Namespace"
        HTTPRoute["HTTPRoute<br/>/ray/{ns}/{cluster}"]
    end

    %% User interactions
    User["User / kubectl"] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CR watches
    RayClusterCR -->|watched by| RCController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController
    RayClusterCR -->|watched by| AuthController
    RayClusterCR -->|watched by| NPController
    RayClusterCR -->|watched by| MTLSController

    %% Webhook validations
    RayClusterCR -.->|mutate| MutWebhook
    RayClusterCR -.->|validate| ValWebhook

    %% Controller creates
    RCController -->|creates| HeadPod
    RCController -->|creates| WorkerPods
    RCController -->|creates| HeadSvc
    RCController -->|creates| ServeSvc
    AuthController -->|creates| HTTPRoute
    AuthController -->|creates| RefGrant
    AuthController -->|injects| HeadPod
    NPController -->|creates| NetPolicies
    MTLSController -->|creates| MTLSCerts

    %% RayJob creates RayCluster
    RJController -->|creates| RayClusterCR

    %% External Dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"]
    CertManager["cert-manager"]
    DSGateway["data-science-gateway<br/>(openshift-ingress)"]
    Prometheus["Prometheus"]

    RCController -->|manages resources via| K8sAPI
    MTLSController -->|creates Issuers/Certs| CertManager
    HTTPRoute -->|parent ref| DSGateway
    Metrics -->|scraped by| Prometheus

