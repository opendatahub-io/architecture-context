graph TB
    subgraph KubeRayOperator["KubeRay Operator (kuberay-operator)"]
        direction TB
        RCController["RayCluster Controller<br/>Reconciles RayCluster CRs<br/>Creates Pods, Services, RBAC"]
        RJController["RayJob Controller<br/>Reconciles RayJob CRs<br/>Creates transient clusters + K8s Jobs"]
        RSController["RayService Controller<br/>Reconciles RayService CRs<br/>Zero-downtime upgrades"]
        AuthController["Authentication Controller<br/>(OpenShift)<br/>HTTPRoutes, ReferenceGrants<br/>kube-rbac-proxy ConfigMaps"]
        NPController["NetworkPolicy Controller<br/>Per-cluster head + worker<br/>NetworkPolicies"]
        MTLSController["mTLS Controller<br/>cert-manager Issuers<br/>& Certificates"]
        MutatingWH["Mutating Webhook<br/>9443/TCP HTTPS<br/>Enforces secure defaults"]
        ValidatingWH["Validating Webhook<br/>9443/TCP HTTPS<br/>Name + worker group validation"]
    end

    %% CRDs
    RayClusterCR["RayCluster CR<br/>ray.io/v1"]
    RayJobCR["RayJob CR<br/>ray.io/v1"]
    RayServiceCR["RayService CR<br/>ray.io/v1"]

    %% Created Resources
    HeadPod["Head Pod<br/>Ray head node"]
    WorkerPods["Worker Pods<br/>Ray worker nodes"]
    HeadSvc["{cluster}-head-svc<br/>Headless Service<br/>6379, 8265, 10001, 8080, 8000"]
    ServeSvc["{cluster}-serve-svc<br/>ClusterIP Service<br/>8000"]
    HTTPRoute["HTTPRoute<br/>(platform namespace)<br/>Gateway API"]
    RefGrant["ReferenceGrant<br/>(user namespace)"]
    NP_Head["Head NetworkPolicy<br/>Ingress rules"]
    NP_Worker["Worker NetworkPolicy<br/>Intra-cluster only"]
    Certs["mTLS Certificates<br/>Head + Worker + CA<br/>cert-manager"]

    %% User interaction
    User["User / Platform Operator"] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% Webhook interception
    RayClusterCR -->|intercepted by| MutatingWH
    MutatingWH -->|validates via| ValidatingWH

    %% Controller watches
    RayClusterCR -->|watched by| RCController
    RayJobCR -->|watched by| RJController
    RayServiceCR -->|watched by| RSController
    RayClusterCR -->|watched by| AuthController
    RayClusterCR -->|watched by| NPController
    RayClusterCR -->|watched by| MTLSController

    %% Controller creates
    RCController -->|creates| HeadPod
    RCController -->|creates| WorkerPods
    RCController -->|creates| HeadSvc
    RCController -->|creates| ServeSvc
    AuthController -->|creates| HTTPRoute
    AuthController -->|creates| RefGrant
    NPController -->|creates| NP_Head
    NPController -->|creates| NP_Worker
    MTLSController -->|creates| Certs
    RJController -->|creates transient| RayClusterCR

    %% External dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"]
    CertManager["cert-manager<br/>v1 API"]
    Gateway["data-science-gateway<br/>Gateway CR"]
    RayDashboard["Ray Dashboard<br/>8265/TCP"]
    KubeRBACProxy["kube-rbac-proxy<br/>sidecar (8443)"]

    RCController -->|CRUD ops| K8sAPI
    MTLSController -->|creates Issuers/Certs| CertManager
    HTTPRoute -->|parentRef| Gateway
    KubeRBACProxy -->|proxies to| RayDashboard
    RJController -->|submits jobs via| RayDashboard
    RSController -->|manages Serve apps via| RayDashboard

    %% Styling
    style KubeRayOperator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RCController fill:#5ba0f2,stroke:#333,color:#fff
    style RJController fill:#5ba0f2,stroke:#333,color:#fff
    style RSController fill:#5ba0f2,stroke:#333,color:#fff
    style AuthController fill:#e67e22,stroke:#333,color:#fff
    style NPController fill:#e67e22,stroke:#333,color:#fff
    style MTLSController fill:#e67e22,stroke:#333,color:#fff
    style MutatingWH fill:#9b59b6,stroke:#333,color:#fff
    style ValidatingWH fill:#9b59b6,stroke:#333,color:#fff
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style HeadSvc fill:#7ed321,stroke:#333
    style ServeSvc fill:#7ed321,stroke:#333
    style HTTPRoute fill:#7ed321,stroke:#333
    style RefGrant fill:#7ed321,stroke:#333
    style NP_Head fill:#7ed321,stroke:#333
    style NP_Worker fill:#7ed321,stroke:#333
    style Certs fill:#7ed321,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Gateway fill:#e8e8e8,stroke:#333
    style RayDashboard fill:#e8e8e8,stroke:#333
    style KubeRBACProxy fill:#e8e8e8,stroke:#333
    style User fill:#fff,stroke:#333,stroke-width:2px
