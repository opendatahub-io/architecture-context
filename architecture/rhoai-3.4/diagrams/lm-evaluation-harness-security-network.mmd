graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph JobContainer["LMES Job Container (Batch Job - Ephemeral)"]
            direction TB
            Adapter["LMEval Adapter<br/>(main.py)<br/>FrameworkAdapter"]
            LMEval["lm-evaluation-harness<br/>(lm_eval/)<br/>v0.4.8 fork"]
            OCIPub["OCI Publisher<br/>(scripts/oci.py)<br/>skopeo + olot"]
            Metrics["Offline Metrics<br/>(metrics/)<br/>55+ pre-packaged"]
        end

        subgraph K8sMount["Kubernetes Mounted Resources"]
            ConfigMap["/meta/job.json<br/>(ConfigMap)<br/>Job specification"]
            SecretMount["Secrets<br/>API keys, HF tokens,<br/>CA certificates"]
        end

        ConfigMap -.->|filesystem mount| Adapter
        SecretMount -.->|env vars / mount| Adapter
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        EvalHub["EvalHub Service<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        ModelEndpoint["Model Inference Endpoint<br/>configurable port<br/>HTTP/HTTPS<br/>TLS configurable<br/>Bearer Token (OPENAI_API_KEY)"]
        OCIReg["OCI Registry (Quay)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Docker config auth"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF_TOKEN (optional)"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / IBM COS"]
        MLflowSvc["MLflow Tracking<br/>configurable port HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
    end

    %% Egress flows (no ingress - batch job)
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Status & results callbacks"| EvalHub
    LMEval -->|"HTTP(S)/configurable<br/>TLS configurable<br/>Bearer Token<br/>Completions & logprobs<br/>up to 128 concurrent"| ModelEndpoint
    OCIPub -->|"HTTPS/443<br/>TLS 1.2+<br/>Docker auth<br/>Push OCI artifacts"| OCIReg
    LMEval -->|"HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN<br/>Datasets & tokenizers"| HFHub
    Adapter -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>Pre-staged test data<br/>(offline mode, init container)"| S3
    Adapter -->|"HTTPS/configurable<br/>TLS 1.2+<br/>Bearer Token<br/>Metrics & run metadata"| MLflowSvc

    %% Styling
    classDef jobcontainer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef k8sresource fill:#e8e8e8,stroke:#666,stroke-width:1px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef cluster fill:#f5f5f5,stroke:#333,stroke-width:2px

    class Adapter,LMEval,OCIPub,Metrics jobcontainer
    class ConfigMap,SecretMount k8sresource
    class EvalHub,ModelEndpoint,OCIReg,HFHub,S3,MLflowSvc externalservice
