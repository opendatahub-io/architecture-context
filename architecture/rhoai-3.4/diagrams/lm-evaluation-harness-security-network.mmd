graph TB
    subgraph Cluster["KUBERNETES CLUSTER"]
        direction TB

        subgraph ControlPlane["CONTROL PLANE"]
            Operator["TrustyAI LMEval Operator<br/>Creates Jobs from LMEvalJob CRDs"]
        end

        subgraph JobExecution["BATCH JOB EXECUTION (No Inbound Ports)"]
            direction TB

            InitContainer["Init Container<br/>(offline mode only)<br/>Pre-downloads datasets"]
            SharedVol["/test_data<br/>Shared Volume"]
            ConfigMap["/meta/job.json<br/>ConfigMap Mount"]

            JobContainer["lm-evaluation-harness<br/>Job Container<br/>Image: odh-ta-lmes-job-rhel9<br/>UBI9 / Python 3.11<br/>Arch: x86_64, s390x, ppc64le"]

            InitContainer -->|Filesystem| SharedVol
            SharedVol -->|Filesystem<br/>offline mode| JobContainer
            ConfigMap -->|Filesystem| JobContainer
        end
    end

    subgraph InternalServices["INTERNAL PLATFORM SERVICES"]
        EvalHub["EvalHub Service<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token"]
        ModelEndpoint["Model Serving Endpoint<br/>(vLLM / KServe)<br/>443/TCP or 8080/TCP<br/>TLS 1.2+ (custom CA)<br/>OPENAI_API_KEY Bearer"]
        MLflow["MLflow Tracking Server<br/>443/TCP or 5000/TCP<br/>TLS 1.2+<br/>Bearer Token"]
        OCIRegistry["OCI Registry<br/>443/TCP<br/>TLS 1.2+<br/>Username/Password"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP<br/>TLS 1.2+<br/>HF_TOKEN Bearer"]
        S3["S3 / IBM COS<br/>443/TCP<br/>TLS 1.2+<br/>AWS IAM / IBM COS creds"]
    end

    %% Control plane flow
    Operator -->|K8s Job API<br/>ServiceAccount| JobContainer

    %% Egress flows from Job Container
    JobContainer -->|HTTPS/443<br/>TLS 1.2+<br/>Bearer Token<br/>Status callbacks + results| EvalHub
    JobContainer -->|HTTPS/443 or HTTP/8080<br/>TLS 1.2+<br/>OPENAI_API_KEY<br/>/v1/completions<br/>Up to 128 concurrent| ModelEndpoint
    JobContainer -->|HTTPS/443<br/>TLS 1.2+<br/>Registry creds<br/>OCI artifact push| OCIRegistry
    JobContainer -->|HTTPS/443 or HTTP/5000<br/>TLS 1.2+<br/>Bearer Token<br/>Metrics + run metadata| MLflow
    JobContainer -->|HTTPS/443<br/>TLS 1.2+<br/>HF_TOKEN<br/>Tokenizers, datasets| HFHub
    InitContainer -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM<br/>Offline test data| S3

    %% Styling
    classDef controlplane fill:#e6f3ff,stroke:#4a90e2,stroke-width:2px
    classDef job fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef storage fill:#e8e8e8,stroke:#666,stroke-width:1px

    class Operator controlplane
    class InitContainer,JobContainer job
    class EvalHub,ModelEndpoint,MLflow,OCIRegistry internal
    class HFHub,S3 external
    class SharedVol,ConfigMap storage
