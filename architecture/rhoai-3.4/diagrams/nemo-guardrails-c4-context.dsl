// NeMo Guardrails - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/NeMo-Guardrails.md

workspace {
    model {
        developer = person "Application Developer" "Builds LLM-based applications with guardrails"
        platform_admin = person "Platform Admin" "Deploys and configures RHOAI platform components"

        nemoGuardrails = softwareSystem "NeMo Guardrails" "Programmable guardrails toolkit for LLM-based conversational systems. OpenAI-compatible API server that intercepts and validates chat completion requests." {
            guardrailsServer = container "Guardrails Server" "OpenAI-compatible HTTP API server for guardrailed chat completions" "FastAPI/Uvicorn, Port 8000"
            actionsServer = container "Actions Server" "Separate HTTP API server for executing custom guardrail actions" "FastAPI, Port 8001"
            llmRailsEngine = container "LLMRails Engine" "Full-featured rails engine using Colang dialog flows and LLM calls" "Python Module"
            ioRailsEngine = container "IORails Engine" "Optimized inference engine for input/output-only guardrail configurations" "Python Module"
            colangRuntime = container "Colang Runtime" "Domain-specific language runtime for defining conversational guardrails" "Python Module"
            embeddingsEngine = container "Embeddings Engine" "Local embedding computation using FastEmbed, sentence-transformers" "Python Module"
            guardrailLibrary = container "Guardrail Library" "Built-in guardrail implementations: content safety, jailbreak, topic safety, SDD, hallucination" "Python Modules"
            nlpModels = container "Embedded NLP Models" "Pre-downloaded spaCy, Presidio, YARA rules for air-gapped operation" "Python/ONNX"
            chatUI = container "Chat UI" "Optional web-based chat interface" "Static Frontend"
            tracing = container "Tracing" "OpenTelemetry-based tracing and span extraction" "Python Module"
        }

        // External systems
        upstreamLLM = softwareSystem "Upstream LLM Server" "Backend LLM inference server (vLLM, TGI, etc.) providing /v1/chat/completions" "External"
        nvidiaNIM = softwareSystem "NVIDIA NIM" "NVIDIA cloud inference microservice" "External"
        openAI = softwareSystem "OpenAI API" "OpenAI cloud inference service" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Model download repository (disabled in disconnected mode)" "External"
        jailbreakAPI = softwareSystem "Jailbreak Detection API" "External jailbreak detection endpoint" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection service" "Internal"

        // RHOAI platform components
        rhoaiPlatform = softwareSystem "RHOAI Platform" "Red Hat OpenShift AI platform (Gateway API, Service Mesh)" "Internal RHOAI"

        // Relationships - external
        developer -> nemoGuardrails "Sends chat completion requests via" "HTTP/8000"
        platform_admin -> nemoGuardrails "Deploys and configures guardrail policies"

        nemoGuardrails -> upstreamLLM "Forwards chat completions to" "HTTP or HTTPS/443,8000 - Bearer Token"
        nemoGuardrails -> nvidiaNIM "Sends inference requests to" "HTTPS/443 - Bearer Token"
        nemoGuardrails -> openAI "Sends inference requests to" "HTTPS/443 - Bearer Token"
        nemoGuardrails -> huggingFace "Downloads models from (disconnected: disabled)" "HTTPS/443"
        nemoGuardrails -> jailbreakAPI "Checks for jailbreak attempts via" "HTTPS - Configurable"
        nemoGuardrails -> otelCollector "Exports tracing spans to" "OTLP/4317,4318"
        rhoaiPlatform -> nemoGuardrails "Routes external traffic to" "Gateway API / Routes"

        // Internal container relationships
        guardrailsServer -> llmRailsEngine "Routes requests to"
        guardrailsServer -> ioRailsEngine "Routes requests to (optimized mode)"
        llmRailsEngine -> colangRuntime "Executes Colang dialog flows"
        llmRailsEngine -> guardrailLibrary "Applies input/output rails"
        ioRailsEngine -> guardrailLibrary "Applies input/output rails"
        guardrailLibrary -> embeddingsEngine "Computes embeddings for similarity"
        guardrailLibrary -> nlpModels "Uses spaCy, Presidio, YARA"
        guardrailsServer -> actionsServer "Executes custom actions via" "HTTP/8001"
        guardrailsServer -> tracing "Records execution spans"
    }

    views {
        systemContext nemoGuardrails "SystemContext" {
            include *
            autoLayout
        }

        container nemoGuardrails "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
