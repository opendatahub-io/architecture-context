graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["RHOAI Gateway (Envoy)<br/>HTTPRoute (Gateway API)<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ SIMPLE"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER"]
        KubeRBAC["kube-rbac-proxy (Sidecar)<br/>8443/TCP → 8000/TCP<br/>OAuth/OIDC validation<br/>RBAC enforcement"]
    end

    subgraph Application["APPLICATION LAYER (vLLM CPU Pod)<br/>UID: 2000 / GID: 0 (non-root)<br/>Image: rhoai/odh-vllm-cpu-rhel9"]
        direction TB

        APIServer["vLLM OpenAI API Server<br/>(FastAPI + Uvicorn)<br/>Port: 8000/TCP<br/>Auth: SHA-256 Bearer Token<br/>SSL hot-reload capable"]

        GRPCServer["vLLM gRPC Server<br/>(Optional)<br/>Port: 50051/TCP<br/>⚠️ INSECURE (plaintext, no auth)"]

        Engine["AsyncLLM Engine (v1)<br/>PagedAttention + Continuous Batching<br/>ZeroMQ IPC (multiprocess)"]

        APIServer --> Engine
        GRPCServer --> Engine
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token (HF_TOKEN)"]

        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]

        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC or 4318/TCP HTTP<br/>TLS 1.2+<br/>OTLP (optional)"]
    end

    subgraph Observability["OBSERVABILITY"]
        Prometheus["Prometheus<br/>Scrapes /metrics<br/>HTTP/8000"]
    end

    subgraph Platform["PLATFORM"]
        KServe["KServe<br/>ServingRuntime<br/>Manages lifecycle"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth/OIDC)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS 1.2+<br/>Service Account Token"| KubeRBAC
    KubeRBAC -->|"HTTP/8000<br/>plaintext (localhost)<br/>Bearer Token (optional)"| APIServer

    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Engine -->|"gRPC/4317 or HTTP/4318<br/>TLS 1.2+<br/>OTLP traces"| OTel

    Prometheus -.->|"HTTP/8000<br/>GET /metrics<br/>No auth"| APIServer
    KServe -.->|"manages"| Application

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef authproxy fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef observability fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef platform fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef warning fill:#ff6666,stroke:#cc0000,stroke-width:2px,color:#fff

    class Client external
    class Gateway ingress
    class KubeRBAC authproxy
    class APIServer,Engine application
    class GRPCServer warning
    class HFHub,S3,OTel externalservice
    class Prometheus observability
    class KServe platform
