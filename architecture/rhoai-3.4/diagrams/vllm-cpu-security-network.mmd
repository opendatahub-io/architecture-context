graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client<br/>Data Scientist"]
    end

    subgraph Ingress["INGRESS (Platform-Managed)"]
        KServeGW["KServe Gateway / HTTPRoute<br/>443/TCP → 8000/TCP<br/>TLS 1.2+ termination<br/>Platform RBAC (kube-rbac-proxy / OAuth)"]
    end

    subgraph Application["APPLICATION (vLLM CPU Pod)"]
        direction TB

        subgraph AuthEndpoints["Authenticated Endpoints (API Key optional)"]
            ChatAPI["POST /v1/chat/completions"]
            CompletionsAPI["POST /v1/completions"]
            EmbeddingsAPI["POST /v1/embeddings"]
            ModelsAPI["GET /v1/models"]
            ResponsesAPI["POST /v1/responses"]
            MessagesAPI["POST /v1/messages"]
            LoRAAPI["POST /v1/load_lora_adapter<br/>POST /v1/unload_lora_adapter"]
        end

        subgraph UnauthEndpoints["Unauthenticated Endpoints"]
            HealthAPI["GET /health"]
            MetricsAPI["GET /metrics"]
            VersionAPI["GET /version"]
            PingAPI["GET /ping"]
        end

        Engine["AsyncLLM Engine<br/>CPU Memory (PagedAttention)<br/>C/C++ Kernels"]

        GrpcServer["gRPC Server<br/>50051/TCP<br/>plaintext (optional)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["Hugging Face Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Bearer HF_TOKEN"]
        S3["S3-Compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS IAM"]
        OTLP["OTLP Collector<br/>4317/TCP gRPC<br/>TLS (configurable)"]
    end

    subgraph Monitoring["MONITORING (Inbound)"]
        Prometheus["Prometheus<br/>Scrapes /metrics"]
    end

    %% External → Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Platform Auth"| KServeGW

    %% Ingress → Application
    KServeGW -->|"HTTP/8000<br/>plaintext (internal)<br/>API Key (optional)"| AuthEndpoints
    KServeGW -->|"HTTP/8000<br/>plaintext (internal)<br/>No auth"| UnauthEndpoints

    %% Internal flows
    AuthEndpoints --> Engine
    GrpcServer --> Engine

    %% Egress
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    Engine -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    Engine -->|"gRPC/4317<br/>TLS (configurable)"| OTLP

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>No auth"| MetricsAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef authEndpoint fill:#dae8fc,stroke:#6c8ebf,stroke-width:1px
    classDef unauthEndpoint fill:#e1d5e7,stroke:#9673a6,stroke-width:1px
    classDef engine fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class KServeGW ingress
    class ChatAPI,CompletionsAPI,EmbeddingsAPI,ModelsAPI,ResponsesAPI,MessagesAPI,LoRAAPI authEndpoint
    class HealthAPI,MetricsAPI,VersionAPI,PingAPI unauthEndpoint
    class Engine,GrpcServer engine
    class HFHub,S3,OTLP externalservice
    class Prometheus monitoring
