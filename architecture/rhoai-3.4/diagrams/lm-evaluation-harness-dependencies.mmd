graph LR
    LMES["LM Evaluation Harness<br/>(Batch Job)"]

    %% Internal RHOAI Dependencies
    LMES -->|"callbacks:<br/>status, progress, results"| EvalHub["EvalHub Service"]
    LMES -->|"POST completions<br/>& logprobs"| ModelServing["Model Serving Runtime<br/>(vLLM / TGI / etc.)"]
    EvalHubOp["EvalHub / TrustyAI<br/>Operator"] -->|creates Job| LMES

    %% External Service Dependencies
    LMES -->|"push OCI artifacts"| OCIRegistry["OCI Registry<br/>(Quay)"]
    LMES -->|"log metrics &<br/>parameters"| MLflow["MLflow Tracking"]
    LMES -->|"download datasets<br/>& tokenizers"| HFHub["HuggingFace Hub"]
    LMES -->|"retrieve test data<br/>(offline mode)"| S3["S3-compatible<br/>Storage"]

    %% Infrastructure Dependencies
    LMES -->|"job spec"| ConfigMap["K8s ConfigMap<br/>/meta/job.json"]
    LMES -->|"credentials"| Secrets["K8s Secrets<br/>API keys, tokens, certs"]

    %% Key Library Dependencies
    subgraph RuntimeDeps["Key Runtime Dependencies"]
        Python["Python >=3.11,<3.13"]
        PyTorch["PyTorch 2.6.0<br/>(CPU-only)"]
        Transformers["transformers 4.48.0"]
        EvalHubSDK["eval-hub-sdk 0.1.5"]
        Boto3["boto3 1.42.12"]
        Olot["olot 0.1.15"]
        Skopeo["skopeo (system)"]
        Unitxt["unitxt 1.17.2"]
    end

    LMES -.->|runtime| Python
    LMES -.->|tensor ops| PyTorch
    LMES -.->|tokenizers| Transformers
    LMES -.->|adapter framework| EvalHubSDK
    LMES -.->|S3 access| Boto3
    LMES -.->|OCI layout| Olot
    LMES -.->|OCI push| Skopeo
    LMES -.->|eval framework| Unitxt

    style LMES fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style EvalHub fill:#7ed321,stroke:#333,color:#fff
    style ModelServing fill:#7ed321,stroke:#333,color:#fff
    style EvalHubOp fill:#7ed321,stroke:#333,color:#fff
    style OCIRegistry fill:#f5a623,stroke:#333,color:#fff
    style MLflow fill:#f5a623,stroke:#333,color:#fff
    style HFHub fill:#999,stroke:#333,color:#fff
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style ConfigMap fill:#e8e8e8,stroke:#333
    style Secrets fill:#e8e8e8,stroke:#333
    style Python fill:#fff,stroke:#999
    style PyTorch fill:#fff,stroke:#999
    style Transformers fill:#fff,stroke:#999
    style EvalHubSDK fill:#fff,stroke:#999
    style Boto3 fill:#fff,stroke:#999
