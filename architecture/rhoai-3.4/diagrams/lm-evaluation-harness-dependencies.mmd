graph LR
    LMEval["lm-evaluation-harness<br/>(Batch Job)"]

    %% Internal RHOAI Dependencies
    LMEval -->|status callbacks<br/>REST API| EvalHub["EvalHub Service"]
    LMEval -->|inference requests<br/>/v1/completions| ModelServing["Model Serving<br/>(vLLM / KServe)"]
    LMEval -->|metric logging<br/>REST API| MLflow["MLflow"]
    LMEval -->|artifact push<br/>OCI API| OCIRegistry["OCI Registry"]

    %% Operator dependency (creates this job)
    LMEvalOperator["TrustyAI LMEval<br/>Operator"] -->|creates Job| LMEval

    %% External Service Dependencies
    LMEval -->|datasets, tokenizers| HFHub["HuggingFace Hub"]
    LMEval -->|offline test data| S3["S3 / IBM COS"]

    %% Core Framework Dependencies
    LMEval -->|evaluation engine| LMEvalLib["lm-eval v0.4.8<br/>(EleutherAI fork)"]
    LMEval -->|adapter SDK| EvalHubSDK["eval-hub-sdk 0.1.5"]

    %% Key Python Dependencies
    subgraph "ML / AI Libraries"
        PyTorch["PyTorch 2.6.0"]
        Transformers["Transformers 4.48.0"]
        Accelerate["Accelerate 1.0.1"]
        Datasets["Datasets 3.1.0"]
        PEFT["PEFT 0.13.2"]
        Unitxt["Unitxt 1.17.2"]
    end

    subgraph "Metric Libraries"
        Evaluate["Evaluate 0.4.3"]
        SacreBLEU["sacrebleu 2.4.3"]
        ROUGE["rouge-score 0.1.2"]
        Sklearn["scikit-learn 1.5.2"]
    end

    subgraph "Infrastructure Libraries"
        Boto3["boto3 1.42.12"]
        OLOT["olot 0.1.15<br/>(OCI Layout Transport)"]
        Aiohttp["aiohttp 3.13.3"]
        PyArrow["PyArrow 23.0.0"]
    end

    LMEvalLib --> PyTorch
    LMEvalLib --> Transformers
    LMEvalLib --> Accelerate
    LMEvalLib --> Datasets
    LMEvalLib --> PEFT
    LMEvalLib --> Unitxt
    LMEvalLib --> Evaluate
    LMEvalLib --> SacreBLEU
    LMEvalLib --> ROUGE
    LMEvalLib --> Sklearn
    EvalHubSDK --> OLOT
    LMEval --> Boto3
    LMEval --> Aiohttp

    %% Container Base
    ContainerBase["UBI9 / Python 3.11<br/>+ skopeo (RPM)"] -.->|base image| LMEval

