%% Data Science Pipelines - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB
        APIServer["ml-pipeline<br/>(API Server)<br/>Go Service<br/>gRPC: 8887/TCP<br/>REST: 8888/TCP<br/>Webhook: 8443/TCP"]
        ScheduledWF["ml-pipeline-scheduledworkflow<br/>Go Controller"]
        PersistenceAgent["ml-pipeline-persistenceagent<br/>Go Agent"]
        ViewerController["ml-pipeline-viewer-crd<br/>Go Controller"]
        UI["ml-pipeline-ui<br/>TypeScript/React<br/>Port: 3000"]
        VizServer["ml-pipeline-visualizationserver<br/>Python Service<br/>Port: 8888"]
        CacheServer["cache-server<br/>Go Webhook<br/>Port: 8443/TCP TLS"]

        subgraph PipelineExec["Pipeline Execution"]
            Driver["kfp-driver<br/>(init container)"]
            Launcher["kfp-launcher<br/>(container)"]
            Driver --> Launcher
        end

        subgraph MetadataStack["ML Metadata Stack"]
            MLMD["metadata-grpc-server<br/>gRPC: 8080"]
            Envoy["metadata-envoy<br/>Port: 9090"]
            MetadataWriter["metadata-writer<br/>Go Agent"]
            MetadataWriter -->|writes| MLMD
            Envoy -->|proxies| MLMD
        end
    end

    %% CRDs
    User[User / SDK] -->|creates| PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    User -->|creates| PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    User -->|submits runs via| APIServer

    ScheduledWFCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"] -->|watched by| ScheduledWF
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"] -->|watched by| ViewerController

    APIServer -->|creates| ScheduledWFCR
    APIServer -->|validates/mutates| PipelineVersionCR
    ScheduledWF -->|creates| ArgoWF["Argo Workflow CR<br/>argoproj.io"]
    APIServer -->|creates| ArgoWF

    PersistenceAgent -->|watches| ArgoWF
    PersistenceAgent -->|reports status| APIServer

    UI -->|proxies API calls| APIServer
    APIServer -->|requests viz| VizServer
    ViewerController -->|creates| TBDeploy["TensorBoard<br/>Deployment/Service"]

    %% External Dependencies
    APIServer -->|stores metadata| DB[(MySQL/PostgreSQL)]
    APIServer -->|stores artifacts| S3[(MinIO / S3)]
    CacheServer -->|checks cache| DB
    APIServer -->|CRD ops| K8sAPI["Kubernetes API<br/>443/TCP"]

    %% Integration
    DSPO["data-science-pipelines-operator"] -->|manages via DSPA CR| DSP
    Istio["Istio Service Mesh"] -.->|mTLS, AuthZ| DSP
    Prometheus["Prometheus"] -->|scrapes /metrics| APIServer

