graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB
        subgraph APIServer["API Server"]
            REST["REST API<br/>8888/TCP"]
            GRPC["gRPC API<br/>8887/TCP"]
            Webhook["Webhook Server<br/>8443/TCP"]
            REST --- GRPC
        end

        subgraph ExecutionEngine["Pipeline Execution"]
            Driver["Driver<br/>(init container)"]
            Launcher["Launcher<br/>(sidecar container)"]
            Driver -->|"prepares context<br/>generates pod spec"| Launcher
        end

        subgraph Controllers["Controllers & Agents"]
            PersistenceAgent["Persistence Agent"]
            SWController["Scheduled Workflow<br/>Controller"]
        end
    end

    %% External Users
    User["User / KFP SDK"] -->|"REST/gRPC<br/>Bearer Token"| REST
    Dashboard["OpenShift Dashboard"] -->|"REST API<br/>8888/TCP"| REST
    Workbench["Workbench<br/>(Jupyter)"  ] -->|"Python SDK<br/>8888/TCP"| REST

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    SWCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]

    REST -->|"creates/manages"| PipelineCR
    REST -->|"creates/manages"| PipelineVersionCR
    Webhook -->|"validates/mutates"| PipelineVersionCR
    SWController -->|"watches"| SWCR
    SWController -->|"gRPC 8887<br/>CreateRun"| GRPC

    %% Argo Integration
    REST -->|"creates Workflow<br/>via K8s API"| ArgoWorkflow["Argo Workflow CR"]
    ArgoController["Argo Workflows<br/>Controller"] -->|"watches"| ArgoWorkflow
    ArgoController -->|"creates pods with"| Driver
    PersistenceAgent -->|"watches"| ArgoWorkflow
    PersistenceAgent -->|"gRPC 8887<br/>ReportWorkflow"| GRPC

    %% External Dependencies
    REST -->|"3306/TCP"| MySQL["MySQL/MariaDB"]
    REST -->|"9000/TCP"| ObjectStore["MinIO/S3<br/>Object Store"]
    Driver -->|"gRPC 8080"| MLMD["ML Metadata<br/>(MLMD)"]
    Driver -->|"gRPC 8887<br/>cache lookup"| GRPC
    Launcher -->|"gRPC 8080"| MLMD
    Launcher -->|"HTTP/S"| ObjectStore
    REST -->|"6443/TCP"| K8sAPI["Kubernetes API"]

    %% DSPA Operator
    DSPAOperator["DSPA Operator"] -.->|"deploys & configures"| DSP

    %% Styling
    style DSP fill:#e8f4fd,stroke:#4a90e2,stroke-width:2px
    style APIServer fill:#d5e8f9,stroke:#4a90e2,stroke-width:2px
    style ExecutionEngine fill:#d5e8f9,stroke:#4a90e2,stroke-width:2px
    style Controllers fill:#d5e8f9,stroke:#4a90e2,stroke-width:2px
    style REST fill:#4a90e2,color:#fff
    style GRPC fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style Driver fill:#4a90e2,color:#fff
    style Launcher fill:#4a90e2,color:#fff
    style PersistenceAgent fill:#4a90e2,color:#fff
    style SWController fill:#4a90e2,color:#fff
    style PipelineCR fill:#f5a623,color:#fff
    style PipelineVersionCR fill:#f5a623,color:#fff
    style SWCR fill:#f5a623,color:#fff
    style ArgoWorkflow fill:#f5a623,color:#fff
    style MySQL fill:#e8e8e8,stroke:#999
    style ObjectStore fill:#e8e8e8,stroke:#999
    style MLMD fill:#e8e8e8,stroke:#999
    style K8sAPI fill:#e8e8e8,stroke:#999
    style ArgoController fill:#e8e8e8,stroke:#999
    style DSPAOperator fill:#7ed321,color:#fff
    style Dashboard fill:#7ed321,color:#fff
    style Workbench fill:#7ed321,color:#fff
    style User fill:#f9f9f9,stroke:#999
