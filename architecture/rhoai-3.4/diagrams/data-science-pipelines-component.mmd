graph TB
    subgraph DSP["Data Science Pipelines"]
        direction TB

        subgraph CoreServices["Core Services"]
            APIServer["API Server<br/>Go | 8888/TCP HTTP, 8887/TCP gRPC"]
            PersistenceAgent["Persistence Agent<br/>Go Controller"]
            SWController["Scheduled Workflow Controller<br/>Go Controller | 9090/TCP metrics"]
            CacheServer["Cache Server<br/>Go Webhook | 8443/TCP HTTPS"]
            ViewerController["Viewer Controller<br/>Go Controller"]
        end

        subgraph Sidecars["Argo Workflow Sidecars"]
            Driver["Driver<br/>Go CLI (init container)"]
            Launcher["Launcher<br/>Go CLI (container wrapper)<br/>FIPS + non-FIPS binaries"]
        end

        subgraph Frontend["Frontend"]
            UI["Frontend UI<br/>TypeScript/React | 3000/TCP"]
            VizServer["Visualization Server<br/>Python | 8888/TCP"]
        end

        subgraph Webhooks["Admission Webhooks"]
            PVWebhook["PipelineVersion Webhook<br/>8443/TCP HTTPS"]
            CacheWebhookInt["Cache Mutation Webhook<br/>443→8443/TCP HTTPS"]
        end
    end

    %% CRDs
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]

    %% External
    User["User / SDK"]
    DSPO["DSPO<br/>(Operator)"]

    %% CRD relationships
    SWController -->|watches| ScheduledWorkflowCR
    ViewerController -->|watches| ViewerCR
    APIServer -->|validates/mutates| PipelineVersionCR
    APIServer -->|manages| PipelineCR

    %% User interaction
    User -->|REST/gRPC| APIServer
    User -->|browse| UI
    DSPO -->|deploys all| DSP

    %% Internal flows
    PersistenceAgent -->|reports state via gRPC| APIServer
    SWController -->|creates runs via gRPC| APIServer
    Driver -->|cache check via gRPC| APIServer
    APIServer -->|creates| ArgoWF["Argo Workflow CR"]
    ArgoWF -->|runs| Driver
    Driver -->|patches pod spec| Launcher

    %% External dependencies
    APIServer -->|stores metadata| DB["MySQL / PostgreSQL"]
    APIServer -->|stores artifacts| ObjStore["S3 / MinIO / GCS"]
    Driver -->|lineage| MLMD["ML Metadata<br/>gRPC :8080"]
    Launcher -->|artifacts| ObjStore
    Launcher -->|publishes| MLMD
    CacheServer -->|cache lookup| DB

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style PersistenceAgent fill:#4a90e2,stroke:#333,color:#fff
    style SWController fill:#4a90e2,stroke:#333,color:#fff
    style CacheServer fill:#4a90e2,stroke:#333,color:#fff
    style ViewerController fill:#4a90e2,stroke:#333,color:#fff
    style Driver fill:#50c878,stroke:#333,color:#fff
    style Launcher fill:#50c878,stroke:#333,color:#fff
    style UI fill:#9b59b6,stroke:#333,color:#fff
    style VizServer fill:#9b59b6,stroke:#333,color:#fff
    style ScheduledWorkflowCR fill:#f5a623,stroke:#333
    style ViewerCR fill:#f5a623,stroke:#333
    style PipelineCR fill:#f5a623,stroke:#333
    style PipelineVersionCR fill:#f5a623,stroke:#333
    style DB fill:#e8e8e8,stroke:#666
    style ObjStore fill:#e8e8e8,stroke:#666
    style MLMD fill:#e8e8e8,stroke:#666
    style ArgoWF fill:#f5a623,stroke:#333
    style DSPO fill:#7ed321,stroke:#333
