graph LR
    ODMC["odh-model-controller<br/>Go Operator"]
    MSAPI["model-serving-api<br/>Go REST Server"]

    %% Required External Dependencies
    ODMC -->|"CRD provider<br/>(required)"| KServe["KServe v0.17.0-rc1<br/>(ODH fork)"]

    %% Optional External Dependencies
    ODMC -->|"AuthPolicy CRD<br/>(optional)"| Kuadrant["Kuadrant Operator<br/>v1.4.2"]
    ODMC -->|"AuthN provider<br/>(optional)"| Authorino["Authorino Operator<br/>v0.22.0"]
    ODMC -->|"EnvoyFilter CRD<br/>(optional)"| Istio["Istio / Service Mesh<br/>v1.27.1"]
    ODMC -->|"TriggerAuth CRD<br/>(optional)"| KEDA["KEDA<br/>v2.17.3"]
    ODMC -->|"ServiceMonitor CRD<br/>(optional)"| PromOp["Prometheus Operator<br/>v0.89.0"]
    ODMC -->|"Gateway/HTTPRoute<br/>(optional)"| GatewayAPI["Gateway API<br/>v1.2.1"]
    ODMC -->|"serverless mode<br/>(optional)"| Knative["Knative Serving<br/>v0.48.1"]

    %% External Services
    ODMC -->|"API key validation<br/>model catalog"| NGC["NVIDIA NGC API<br/>nvcr.io / api.ngc.nvidia.com"]
    ODMC -->|"ISVC sync<br/>(optional)"| ModelReg["Kubeflow Model Registry<br/>v0.2.19"]

    %% Internal Platform Dependencies
    ODMC -->|"namespace discovery<br/>(read-only)"| DSC["DataScienceCluster /<br/>DSCInitialization"]
    ODMC -->|"traffic exposure"| Routes["OpenShift Routes"]
    ODMC -->|"NIM templates"| Templates["OpenShift Templates"]
    ODMC -->|"cluster auth config"| AuthConfig["OpenShift Authentication"]
    ODMC -->|"metrics federation<br/>(RBAC only)"| Monitoring["OpenShift Monitoring"]

    %% model-serving-api dependencies
    MSAPI -->|"list Gateways<br/>get Namespaces"| K8sAPI["Kubernetes API"]
    MSAPI -->|"SSAR validation"| K8sAPI

    %% Integration Points (other components consuming this)
    Dashboard["RHOAI Dashboard"] -->|"gateway discovery<br/>REST API"| MSAPI
    DSPipelines["Data Science Pipelines"] -.->|"auto-deploy models"| ODMC

    %% Styling
    style ODMC fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style MSAPI fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff

    %% Required
    style KServe fill:#e74c3c,stroke:#333,color:#fff

    %% Optional external
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style Knative fill:#999,stroke:#333,color:#fff

    %% External services
    style NGC fill:#f5a623,stroke:#333
    style ModelReg fill:#7ed321,stroke:#333

    %% Internal platform
    style DSC fill:#7ed321,stroke:#333
    style Routes fill:#d5e8d4,stroke:#333
    style Templates fill:#d5e8d4,stroke:#333
    style AuthConfig fill:#d5e8d4,stroke:#333
    style Monitoring fill:#d5e8d4,stroke:#333
    style K8sAPI fill:#dae8fc,stroke:#333

    %% Consumers
    style Dashboard fill:#b3e5fc,stroke:#0277bd
    style DSPipelines fill:#b3e5fc,stroke:#0277bd
