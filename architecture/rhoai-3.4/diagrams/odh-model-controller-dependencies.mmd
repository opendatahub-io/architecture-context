graph LR
    ODH["odh-model-controller<br/>Operator"]

    %% Required External Dependencies
    ODH -->|"InferenceService,<br/>ServingRuntime,<br/>LLMInferenceService CRDs"| KServe["KServe<br/>v0.17.0-rc1<br/>(ODH fork)"]

    %% Conditional External Dependencies
    ODH -->|"AuthPolicy CRD<br/>(Gateway API auth)"| Kuadrant["Kuadrant Operator<br/>v1.4.2"]
    ODH -->|"Authorino CRD<br/>(availability detection)"| Authorino["Authorino Operator<br/>v0.22.0"]
    ODH -->|"EnvoyFilter CRD<br/>(Gateway-Authorino TLS)"| Istio["Istio<br/>v1.27.1"]
    ODH -->|"TriggerAuthentication<br/>(Prometheus autoscaling)"| KEDA["KEDA<br/>v2.17.3"]
    ODH -->|"ServiceMonitor,<br/>PodMonitor CRDs"| PromOp["Prometheus<br/>Operator"]
    ODH -->|"Gateway, HTTPRoute<br/>CRDs"| GatewayAPI["Gateway API<br/>v1.2.1"]
    ODH -->|"InferencePool,<br/>InferenceModel CRDs"| GWInference["Gateway API<br/>Inference Ext<br/>v1.3.1"]

    %% Optional
    ODH -.->|"model registration<br/>(optional)"| ModelReg["Model Registry<br/>v0.2.19"]

    %% Internal Platform Dependencies
    RhodsOp["rhods-operator"] -->|"DSC, DSCI CRDs<br/>(platform config)"| ODH
    Dashboard["RHOAI Dashboard"] -->|"GET /api/v1/gateways<br/>(gateway selection UI)"| ODH

    %% External Services
    ODH -->|"API key validation<br/>runtime catalog"| NGC["NVIDIA NGC API<br/>api.ngc.nvidia.com"]
    ODH -->|"image pull auth"| NVCR["nvcr.io<br/>Container Registry"]
    ODH -->|"CRD reconciliation"| K8sAPI["Kubernetes API"]
    ODH -->|"Route creation"| OSRouter["OpenShift Router"]

    %% Styling
    style ODH fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required
    style KServe fill:#e74c3c,stroke:#333,color:#fff

    %% Conditional
    style Kuadrant fill:#999,stroke:#333,color:#fff
    style Authorino fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style KEDA fill:#999,stroke:#333,color:#fff
    style PromOp fill:#999,stroke:#333,color:#fff
    style GatewayAPI fill:#999,stroke:#333,color:#fff
    style GWInference fill:#999,stroke:#333,color:#fff

    %% Optional
    style ModelReg fill:#bbb,stroke:#333,color:#333

    %% Internal RHOAI
    style RhodsOp fill:#7ed321,stroke:#333,color:#fff
    style Dashboard fill:#7ed321,stroke:#333,color:#fff

    %% External Services
    style NGC fill:#f5a623,stroke:#333,color:#fff
    style NVCR fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style OSRouter fill:#ee0000,stroke:#333,color:#fff
