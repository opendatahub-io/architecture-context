graph LR
    SDK["CodeFlare SDK<br/>(Python Client Library)"]

    %% External Dependencies (Language/Runtime)
    SDK -->|"runtime"| Python["Python 3.11+"]
    SDK -->|"ray client libs"| Ray["ray 2.54.1<br/>(data, default extras)"]
    SDK -->|"k8s API client"| K8sClient["kubernetes >= 27.2.0"]
    SDK -->|"OpenShift API"| OcpClient["openshift-client 1.0.18"]
    SDK -->|"TLS cert gen<br/>RSA-3072, SHA-256"| Cryptography["cryptography 46.0.7"]
    SDK -->|"k8s auth<br/>auto-detect, OIDC"| KubeAuthkit["kube-authkit >= 0.4.0"]
    SDK -->|"data validation"| Pydantic["pydantic >= 2.10.6"]
    SDK -->|"CLI pretty-print"| Rich["rich >= 12.5, < 15.0"]
    SDK -->|"notebook widgets"| IPyWidgets["ipywidgets 8.1.2"]

    %% Internal Platform Dependencies (RHOAI)
    SDK -->|"CRD: ray.io/v1<br/>RayCluster, RayJob"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD: kueue.x-k8s.io/v1beta1<br/>LocalQueue, Workload"| Kueue["Kueue Controller"]
    SDK -->|"CRD: gateway.networking.k8s.io/v1<br/>HTTPRoute, Gateway"| RHOAIGateway["RHOAI Gateway<br/>(rhods-operator)"]
    SDK -.->|"CRD: route.openshift.io/v1<br/>(fallback)"| OcpRouter["OpenShift Router"]
    SDK -.->|"ConfigMap volume mount"| ODHCA["ODH Trusted CA Bundle"]

    %% Runtime Targets
    SDK -->|"ray:// 10001/TCP<br/>mTLS client cert"| RayHead["Ray Head Service"]
    SDK -->|"HTTP 8265/TCP<br/>Job submission"| RayDashboard["Ray Dashboard"]

    %% Control Plane
    SDK -->|"HTTPS 6443/TCP<br/>CRD CRUD"| K8sAPI["Kubernetes API Server"]

    %% Integration Points (other components that use SDK)
    Notebook["Jupyter Notebook<br/>(RHOAI Workbench)"] -->|"import codeflare_sdk"| SDK

    %% Styling
    style SDK fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External deps
    style Python fill:#999,stroke:#333
    style Ray fill:#999,stroke:#333
    style K8sClient fill:#999,stroke:#333
    style OcpClient fill:#999,stroke:#333
    style Cryptography fill:#999,stroke:#333
    style KubeAuthkit fill:#999,stroke:#333
    style Pydantic fill:#999,stroke:#333
    style Rich fill:#999,stroke:#333
    style IPyWidgets fill:#999,stroke:#333

    %% Internal RHOAI
    style KubeRay fill:#7ed321,stroke:#333
    style Kueue fill:#7ed321,stroke:#333
    style RHOAIGateway fill:#7ed321,stroke:#333
    style OcpRouter fill:#7ed321,stroke:#333
    style ODHCA fill:#7ed321,stroke:#333

    %% Runtime
    style RayHead fill:#f5a623,stroke:#333
    style RayDashboard fill:#f5a623,stroke:#333

    %% Infra
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Notebook fill:#fff,stroke:#333,stroke-width:2px
