graph LR
    SDK["CodeFlare SDK<br/>v0.37.0"]

    %% External Dependencies (Required Libraries)
    SDK -->|"runtime"| Python["Python 3.11+"]
    SDK -->|"Ray client"| Ray["ray 2.54.1"]
    SDK -->|"K8s client"| K8sClient["kubernetes >= 27.2.0"]
    SDK -->|"OpenShift client"| OSClient["openshift-client 1.0.18"]
    SDK -->|"TLS certs"| Cryptography["cryptography 46.0.7"]
    SDK -->|"K8s auth"| KubeAuthkit["kube-authkit >= 0.4.0"]
    SDK -->|"validation"| Pydantic["pydantic >= 2.10.6"]
    SDK -->|"pretty-print"| Rich["rich >= 12.5"]
    SDK -->|"Jupyter widgets"| IPyWidgets["ipywidgets 8.1.2"]

    %% Internal Platform Dependencies
    SDK -->|"CRD: RayCluster,<br/>RayJob"| KubeRay["KubeRay Operator"]
    SDK -->|"CRD: LocalQueue,<br/>Workload, WPC"| Kueue["Kueue"]
    SDK -->|"CRD: HTTPRoute,<br/>Gateway"| RHOAIGateway["RHOAI Gateway<br/>(Gateway API)"]
    SDK -.->|"CRD: Route<br/>(legacy fallback)"| OSRoutes["OpenShift Routes"]
    SDK -.->|"CRD: Ingress<br/>(vanilla K8s fallback)"| K8sIngress["Kubernetes Ingress"]

    %% Runtime Dependencies
    SDK -->|"API server"| K8sAPI["Kubernetes API<br/>Server"]
    SDK -->|"dashboard +<br/>job submit"| RayDashboard["Ray Dashboard<br/>(via HTTPRoute)"]
    SDK -->|"ray.init()<br/>gRPC mTLS"| RayClient["Ray Head Node<br/>Client Port"]

    %% ConfigMap dependency
    SDK -.->|"CA bundle<br/>(optional mount)"| ODHCA["ODH Trusted<br/>CA Bundle"]

    %% Integration Points (other components that interact with SDK-created resources)
    ODHDashboard["ODH Dashboard"] -.->|"UI management"| SDK
    DSPipelines["Data Science<br/>Pipelines"] -.->|"auto deploy"| SDK

