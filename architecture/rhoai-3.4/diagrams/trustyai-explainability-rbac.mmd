%% TrustyAI Explainability - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Account"
        SA["trustyai-serviceaccount"]
    end

    subgraph "ClusterRole Bindings"
        CRB["trustyai-clusterrolebinding<br/>(cluster-wide)"]
    end

    subgraph "ClusterRole"
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph "API Resources"
        ConfigMaps["core (v1)<br/>ConfigMaps"]
    end

    subgraph "Permitted Verbs"
        Verbs["create, delete, get,<br/>list, patch, update, watch"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        NoAuth["Base Service<br/>No Authentication<br/>(relies on sidecar)"]
        KubeRBACProxy["kube-rbac-proxy Sidecar<br/>RBAC Authorization<br/>(Production RHOAI)"]
        BearerToken["Bearer Token<br/>ServiceAccount Token<br/>(/q/metrics endpoint)"]
    end

    subgraph "Secrets"
        TLSCert["TLS Certificate<br/>kubernetes.io/tls<br/>Port 4443/TCP<br/>Operator/cert-manager managed<br/>Auto-rotate: Yes"]
        MinIOCreds["MinIO Credentials<br/>Opaque<br/>Access Key / Secret Key<br/>Auto-rotate: No"]
        DBCreds["Database Credentials<br/>Opaque<br/>Username / Password<br/>Auto-rotate: No"]
    end

    %% RBAC flow
    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permits"| Verbs
    Verbs -->|"on resources"| ConfigMaps

    %% Auth mechanisms
    SA -->|"identity for"| NoAuth
    SA -->|"validated by"| KubeRBACProxy
    SA -->|"provides token"| BearerToken

    %% Secrets usage
    SA -.->|"mounts"| TLSCert
    SA -.->|"reads"| MinIOCreds
    SA -.->|"reads"| DBCreds

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#e67e22,color:#fff
    style CR fill:#f5a623,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Verbs fill:#9b59b6,color:#fff
    style NoAuth fill:#e8e8e8,stroke:#999
    style KubeRBACProxy fill:#f8cecc,stroke:#b85450
    style BearerToken fill:#d5e8d4,stroke:#82b366
    style TLSCert fill:#fff2cc,stroke:#d6b656
    style MinIOCreds fill:#fff2cc,stroke:#d6b656
    style DBCreds fill:#fff2cc,stroke:#d6b656
