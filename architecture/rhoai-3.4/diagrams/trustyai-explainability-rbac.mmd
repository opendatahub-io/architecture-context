graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA["trustyai-serviceaccount"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB["trustyai-clusterrolebinding<br/>(Cluster-wide scope)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR["trustyai-role<br/>(ClusterRole)"]
    end

    subgraph APIResources["API Resources"]
        ConfigMaps["core (&quot;&quot;)<br/>configmaps"]
    end

    subgraph Verbs["Permissions"]
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"applies to"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph AuthEndpoints["Authentication Endpoints"]
        MetricsEndpoint["/q/metrics<br/>Auth: Bearer Token (SA)<br/>Enforcement: ServiceMonitor"]
        RESTEndpoints["All REST Endpoints<br/>Auth: None (app-level)<br/>Enforcement: kube-rbac-proxy<br/>+ NetworkPolicy"]
        TLSEndpoint["Port 4443/TCP<br/>Auth: TLS Client Cert (optional)<br/>Encryption: TLS<br/>Cert: service-ca / Operator"]
    end

    subgraph Secrets["Secrets"]
        TLSCert["TLS Certificate<br/>kubernetes.io/tls<br/>/etc/tls/internal/tls.crt<br/>Provisioned by: Operator/service-ca<br/>Auto-Rotate: No"]
        DBCreds["Database Credentials<br/>Opaque<br/>QUARKUS_DATASOURCE_USERNAME<br/>QUARKUS_DATASOURCE_PASSWORD<br/>Provisioned by: Manual/Operator<br/>Auto-Rotate: No"]
    end

    SA -.->|"mounts token"| MetricsEndpoint
    TLSCert -.->|"mounted at<br/>/etc/tls/internal/"| TLSEndpoint

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#78909c,color:#fff
    style CR fill:#f5a623,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff

    style Create fill:#e8f5e9,stroke:#2e7d32
    style Delete fill:#ffebee,stroke:#c62828
    style Get fill:#e8f5e9,stroke:#2e7d32
    style List fill:#e8f5e9,stroke:#2e7d32
    style Patch fill:#fff3e0,stroke:#e65100
    style Update fill:#fff3e0,stroke:#e65100
    style Watch fill:#e8f5e9,stroke:#2e7d32

    style MetricsEndpoint fill:#e1d5e7,stroke:#9673a6
    style RESTEndpoints fill:#f8cecc,stroke:#b85450
    style TLSEndpoint fill:#d5e8d4,stroke:#82b366

    style TLSCert fill:#fff2cc,stroke:#d6b656
    style DBCreds fill:#fff2cc,stroke:#d6b656
