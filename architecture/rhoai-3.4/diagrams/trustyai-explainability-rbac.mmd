graph TD
    subgraph "Service Account"
        SA["trustyai-serviceaccount<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Binding"
        CRB["trustyai-clusterrolebinding<br/>Scope: cluster-wide"]
    end

    subgraph "ClusterRole"
        CR["trustyai-role"]
    end

    subgraph "API Resources"
        ConfigMaps["core (v1)<br/>configmaps"]
    end

    subgraph "Permitted Verbs"
        direction LR
        Create["create"]
        Delete["delete"]
        Get["get"]
        List["list"]
        Patch["patch"]
        Update["update"]
        Watch["watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"permits"| ConfigMaps
    ConfigMaps --- Create
    ConfigMaps --- Delete
    ConfigMaps --- Get
    ConfigMaps --- List
    ConfigMaps --- Patch
    ConfigMaps --- Update
    ConfigMaps --- Watch

    subgraph "Authentication & Authorization"
        direction TB
        MetricsAuth["Endpoint: /q/metrics<br/>Auth: Bearer Token (SA)<br/>Enforcement: ServiceMonitor bearerTokenFile<br/>Policy: Prometheus scraping only"]
        AllOtherAuth["All other endpoints<br/>Auth: None (cluster-internal)<br/>Enforcement: Network isolation<br/>Production: kube-rbac-proxy sidecar<br/>(injected by TrustyAI Operator)"]
    end

    subgraph "Secrets"
        direction TB
        TLSSecret["TLS Certificate (optional)<br/>Type: kubernetes.io/tls<br/>Mount: /etc/tls/internal/<br/>Provisioned: External<br/>Auto-Rotate: No"]
        DBSecret["Database Credentials (optional)<br/>Type: Opaque (env vars)<br/>Purpose: MariaDB/MySQL auth<br/>Provisioned: Manual/Operator<br/>Auto-Rotate: No"]
        MinIOSecret["MinIO Credentials (optional)<br/>Type: Opaque (env vars)<br/>Purpose: S3 storage auth<br/>Provisioned: Manual/Operator<br/>Auto-Rotate: No"]
    end

    %% Styling
    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB fill:#8e44ad,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333,color:#fff
    style ConfigMaps fill:#7ed321,stroke:#333,color:#fff

    style Create fill:#e8e8e8,stroke:#333
    style Delete fill:#e8e8e8,stroke:#333
    style Get fill:#e8e8e8,stroke:#333
    style List fill:#e8e8e8,stroke:#333
    style Patch fill:#e8e8e8,stroke:#333
    style Update fill:#e8e8e8,stroke:#333
    style Watch fill:#e8e8e8,stroke:#333

    style MetricsAuth fill:#fff3e0,stroke:#ef6c00
    style AllOtherAuth fill:#ffcdd2,stroke:#c62828

    style TLSSecret fill:#e1bee7,stroke:#6a1b9a
    style DBSecret fill:#e1bee7,stroke:#6a1b9a
    style MinIOSecret fill:#e1bee7,stroke:#6a1b9a
