graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_EvalHub["eval-hub SA<br/>(platform namespace)"]
        SA_Job["evaluation job SA<br/>(tenant namespace)"]
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction TB
        TokenReview["K8s TokenReview API<br/>Validates Bearer Token<br/>→ User Identity"]
        SAR["K8s SubjectAccessReview<br/>Checks RBAC permissions<br/>Namespace from X-Tenant header"]
    end

    subgraph RequiredPermissions["Required Permissions (provisioned by TrustyAI Operator)"]
        direction TB

        subgraph BatchPerms["batch API Group"]
            Jobs["batch/v1 Jobs<br/>create, delete, list, watch"]
        end

        subgraph CorePerms["core API Group"]
            ConfigMaps["v1 ConfigMaps<br/>create, delete, get"]
        end

        subgraph AuthPerms["Auth API Groups"]
            TokenReviews["authentication.k8s.io<br/>tokenreviews<br/>create"]
            SARs["authorization.k8s.io<br/>subjectaccessreviews<br/>create"]
        end
    end

    subgraph CustomAPIGroups["Custom API Groups (for SAR checks)"]
        direction TB

        subgraph TrustyAIGroup["trustyai.opendatahub.io"]
            Evaluations["evaluations<br/>create, get, delete"]
            StatusEvents["status-events<br/>create"]
            Providers["providers<br/>create, get, update, patch, delete"]
            Collections["collections<br/>create, get, update, patch, delete"]
        end

        subgraph MLflowGroup["mlflow.kubeflow.org"]
            Experiments["experiments<br/>create, get"]
        end
    end

    subgraph AuthConfig["Auth Config (config/auth.yaml)"]
        direction TB
        EndpointMapping["HTTP Endpoint → K8s Resource Mapping<br/>POST /api/v1/evaluations/jobs → evaluations:create<br/>GET /api/v1/evaluations/jobs → evaluations:get<br/>POST /api/v1/evaluations/jobs/{id}/events → status-events:create<br/>* /api/v1/evaluations/providers → providers:{verb}<br/>* /api/v1/evaluations/collections → collections:{verb}"]
    end

    subgraph Secrets["Secrets & Credentials"]
        direction TB
        ServiceCACert["evalhub-service-ca<br/>ConfigMap (service-ca.crt)<br/>OpenShift Service CA<br/>Auto-rotate: Yes"]
        MLflowToken["MLflow Projected SA Token<br/>ProjectedServiceAccountToken<br/>Expiry: 3600s<br/>Auto-rotate: Yes"]
        S3Creds["S3 Credentials<br/>Opaque Secret<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>Auto-rotate: No"]
        OCICreds["OCI Registry Credentials<br/>kubernetes.io/dockerconfigjson<br/>Auto-rotate: No"]
        DBPassword["Database Password<br/>Secret file mapping<br/>PostgreSQL connection<br/>Auto-rotate: No"]
        ModelAuth["Model Auth Credentials<br/>Opaque Secret<br/>Model endpoint auth<br/>Auto-rotate: No"]
    end

    %% Flows
    SA_EvalHub -->|"uses"| TokenReview
    TokenReview -->|"identity verified"| SAR
    SAR -->|"checks against"| CustomAPIGroups
    SAR -->|"namespace from"| EndpointMapping

    SA_EvalHub -->|"needs"| BatchPerms
    SA_EvalHub -->|"needs"| CorePerms
    SA_EvalHub -->|"needs"| AuthPerms

    SA_EvalHub -->|"mounts"| ServiceCACert
    SA_EvalHub -->|"mounts"| DBPassword
    SA_Job -->|"mounts"| MLflowToken
    SA_Job -->|"mounts"| S3Creds
    SA_Job -->|"mounts"| OCICreds
    SA_Job -->|"mounts"| ModelAuth

    %% Styling
    style SA_EvalHub fill:#4a90e2,stroke:#333,color:#fff
    style SA_Job fill:#4a90e2,stroke:#333,color:#fff
    style TokenReview fill:#f5a623,stroke:#333
    style SAR fill:#f5a623,stroke:#333
    style Jobs fill:#7ed321,stroke:#333
    style ConfigMaps fill:#7ed321,stroke:#333
    style TokenReviews fill:#7ed321,stroke:#333
    style SARs fill:#7ed321,stroke:#333
    style Evaluations fill:#9dc3e6,stroke:#333
    style StatusEvents fill:#9dc3e6,stroke:#333
    style Providers fill:#9dc3e6,stroke:#333
    style Collections fill:#9dc3e6,stroke:#333
    style Experiments fill:#9dc3e6,stroke:#333
    style EndpointMapping fill:#e8e8e8,stroke:#333
    style ServiceCACert fill:#fff2cc,stroke:#d6b656
    style MLflowToken fill:#fff2cc,stroke:#d6b656
    style S3Creds fill:#f8cecc,stroke:#b85450
    style OCICreds fill:#f8cecc,stroke:#b85450
    style DBPassword fill:#f8cecc,stroke:#b85450
    style ModelAuth fill:#f8cecc,stroke:#b85450
