graph TD
    subgraph ServiceAccounts["Service Accounts"]
        EvalHubSA["eval-hub<br/>(operator-created)"]
        TestSA["test-sa<br/>(example tenant SA)"]
        JobSA["per-job SA<br/>(evaluation workload)"]
    end

    subgraph ClusterRoleBindings["Role Bindings"]
        CRB_FullAccess["eval-hub-service-full-access<br/>(RoleBinding - per namespace)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_FullAccess["eval-hub-service-full-access<br/>(example ClusterRole)"]
    end

    subgraph APIResources_TrustyAI["API Group: trustyai.opendatahub.io"]
        Evaluations["evaluations<br/>get, list, create, update,<br/>patch, delete"]
        Collections["collections<br/>get, list, create, update,<br/>patch, delete"]
        Providers["providers<br/>get, list, create, update,<br/>patch, delete"]
        StatusEvents["status-events<br/>create"]
    end

    subgraph APIResources_MLflow["API Group: mlflow.kubeflow.org"]
        Experiments["experiments<br/>create, get"]
    end

    subgraph AuthFlow["Authentication & Authorization Flow"]
        direction LR
        BearerToken["Bearer Token<br/>(K8s SA Token)"]
        TokenReview["TokenReview<br/>(K8s API)"]
        SAR["SubjectAccessReview<br/>(K8s API)"]
        XTenant["X-Tenant Header<br/>→ Namespace"]
    end

    subgraph K8sResources["Kubernetes Resources (eval-hub SA permissions)"]
        Jobs["batch/v1 Jobs<br/>create, delete, list, watch"]
        ConfigMaps["core/v1 ConfigMaps<br/>create, delete"]
        Secrets["core/v1 Secrets<br/>get"]
    end

    %% Tenant SA → RBAC flow
    TestSA -->|"bound via"| CRB_FullAccess
    CRB_FullAccess -->|"grants"| CR_FullAccess
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Evaluations
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Collections
    CR_FullAccess -->|"get, list, create,<br/>update, patch, delete"| Providers
    CR_FullAccess -->|"create"| StatusEvents

    %% Job creation requires MLflow permissions
    CR_FullAccess -->|"create, get<br/>(for job creation)"| Experiments

    %% EvalHub SA → K8s resources
    EvalHubSA -->|"in-cluster token"| Jobs
    EvalHubSA -->|"in-cluster token"| ConfigMaps
    EvalHubSA -->|"in-cluster token"| Secrets

    %% Auth flow
    BearerToken -->|"validates identity"| TokenReview
    TokenReview -->|"checks permissions"| SAR
    SAR -->|"namespace from"| XTenant

    %% Job SA
    JobSA -->|"projected token<br/>(1h expiry)"| StatusEvents

    %% Styling
    style EvalHubSA fill:#4a90e2,stroke:#333,color:#fff
    style TestSA fill:#4a90e2,stroke:#333,color:#fff
    style JobSA fill:#4a90e2,stroke:#333,color:#fff
    style CR_FullAccess fill:#f5a623,stroke:#333,color:#fff
    style CRB_FullAccess fill:#f5a623,stroke:#333,color:#fff
    style Evaluations fill:#7ed321,stroke:#333,color:#fff
    style Collections fill:#7ed321,stroke:#333,color:#fff
    style Providers fill:#7ed321,stroke:#333,color:#fff
    style StatusEvents fill:#7ed321,stroke:#333,color:#fff
    style Experiments fill:#50c878,stroke:#333,color:#fff
    style Jobs fill:#dae8fc,stroke:#6c8ebf
    style ConfigMaps fill:#dae8fc,stroke:#6c8ebf
    style Secrets fill:#dae8fc,stroke:#6c8ebf
    style BearerToken fill:#e8e8e8,stroke:#333
    style TokenReview fill:#e8e8e8,stroke:#333
    style SAR fill:#e8e8e8,stroke:#333
    style XTenant fill:#e8e8e8,stroke:#333
