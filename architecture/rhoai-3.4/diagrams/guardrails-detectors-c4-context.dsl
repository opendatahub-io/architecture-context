// Guardrails Detectors - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        orchestrator = person "FMS Guardrails Orchestrator" "Invokes detector APIs to analyze LLM input/output text for risks"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Suite of detector microservices for AI content analysis (toxicity, PII, prompt injection, format validation)" {
            hfDetector = container "HuggingFace Detector" "ML-model-based content classification using AutoModelForSequenceClassification and GraniteForCausalLM" "Python FastAPI, port 8000"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-judge evaluation for safety, accuracy, helpfulness metrics" "Python FastAPI, port 8000"
            builtInDetector = container "Built-in Detector" "Lightweight heuristic detections: regex PII, file-type validation, custom user-defined functions" "Python FastAPI, port 8080"
            commonLibrary = container "Common Library" "Shared API schemas, FastAPI base app, Prometheus instrumentation, detector base classes" "Python Library"
        }

        kserve = softwareSystem "KServe" "Serverless ML inference platform for deploying detector services" "Internal RHOAI"
        vllm = softwareSystem "vLLM / LLM Server" "OpenAI-compatible LLM server for judge evaluations" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage" "Local volume mount for HuggingFace model artifacts" "Infrastructure"

        // Relationships
        orchestrator -> guardrailsDetectors "Sends text content for analysis" "REST API / HTTP"
        orchestrator -> hfDetector "POST /api/v1/text/contents" "HTTP/8000"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents, /generation" "HTTP/8000, Header: detector_id"
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080"

        hfDetector -> modelStorage "Loads model files from MODEL_DIR" "Filesystem"
        hfDetector -> commonLibrary "Uses base classes and schemas"
        llmJudgeDetector -> vllm "Sends evaluation prompts" "HTTP/HTTPS, API key optional"
        llmJudgeDetector -> commonLibrary "Uses base classes and schemas"
        builtInDetector -> commonLibrary "Uses base classes and schemas"

        kserve -> hfDetector "Deploys as InferenceService" "Kubernetes"
        prometheus -> guardrailsDetectors "Scrapes /metrics endpoints" "HTTP/8000, HTTP/8080"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
        }
    }
}
