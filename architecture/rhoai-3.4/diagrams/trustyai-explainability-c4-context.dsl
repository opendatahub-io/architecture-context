// TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Configures fairness metrics and monitors model bias/drift"
        platformadmin = person "Platform Admin" "Deploys and manages TrustyAI service instances"

        trustyai = softwareSystem "TrustyAI Explainability" "AI fairness metrics, bias tracking, model drift detection, and explainability for ML models" {
            service = container "TrustyAI Service" "Quarkus REST service exposing fairness, drift, and explainability endpoints" "Java 17 / Quarkus 3.8.5"
            core = container "Explainability Core" "Fairness metrics (SPD, DIR), drift detection (KSTest, Meanshift, FourierMMD), XAI algorithms" "Java Library"
            connectors = container "Explainability Connectors" "KServe v1/v2 model server connectors via gRPC and HTTP" "Java Library"
            arrow = container "Explainability Arrow" "Apache Arrow bridge for Java-Python interoperability" "Java Library"
            initContainer = container "Config Map Overrider" "Init container that creates model-serving-config ConfigMap" "Shell Script"
        }

        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform with payload processing" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Serverless ML inference with InferenceLogger" "Internal RHOAI"
        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Deploys and manages TrustyAI Service instances per namespace" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "Internal OpenShift"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Web UI for managing AI/ML workloads" "Internal RHOAI"

        minio = softwareSystem "MinIO / S3 Storage" "S3-compatible object storage for observation data" "External"
        database = softwareSystem "MariaDB / MySQL" "Relational database for observation data" "External"
        k8sapi = softwareSystem "Kubernetes API" "Cluster API server" "External"

        // User interactions
        datascientist -> trustyai "Configures fairness/drift metrics, views results" "REST API / HTTPS"
        platformadmin -> trustyaiOperator "Deploys TrustyAI instances" "kubectl / YAML"

        // Inbound integrations
        modelmesh -> trustyai "Sends inference payloads via callback" "HTTP/8080"
        kserve -> trustyai "Sends inference events" "CloudEvents HTTP/8080"
        prometheus -> trustyai "Scrapes fairness/drift metrics" "HTTP/8080 Bearer Token"
        dashboard -> trustyai "Displays metrics, manages metric requests" "HTTP via kube-rbac-proxy"
        trustyaiOperator -> trustyai "Manages lifecycle, deploys instances" "Kubernetes API"

        // Outbound integrations
        trustyai -> minio "Stores/retrieves observation data" "HTTPS/443 or HTTP/9000"
        trustyai -> database "Stores/retrieves observation data" "MySQL/3306"
        trustyai -> k8sapi "Init container creates ConfigMap" "HTTPS/443"

        // Internal container relationships
        service -> core "Uses fairness/drift/XAI algorithms"
        service -> connectors "Uses KServe gRPC/HTTP clients"
        connectors -> kserve "Makes gRPC inference calls for explanations" "gRPC/HTTP2"
        connectors -> modelmesh "Makes gRPC inference calls for explanations" "gRPC/HTTP2"
        service -> arrow "Uses Arrow bridge for Python interop"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Internal OpenShift" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
