graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client Application<br/>API Consumer"]
    end

    subgraph Platform["PLATFORM INGRESS<br/>(Managed by KServe / ModelMesh)"]
        KServe["KServe InferenceService /<br/>ModelMesh ServingRuntime<br/>TLS termination at platform level"]
    end

    subgraph ServingPod["SERVING POD (caikit-nlp container)"]
        direction TB

        HTTPServer["caikit HTTP Server<br/>8080/TCP HTTP<br/>Configurable TLS<br/>10 REST endpoints"]
        GRPCServer["caikit gRPC Server<br/>8085/TCP gRPC<br/>TLS via RUNTIME_TLS_SERVER_KEY/CERT<br/>7 gRPC services"]
        Gateway["REST Gateway (optional)<br/>8080/TCP HTTP<br/>No TLS<br/>Proxies to gRPC 8085"]

        subgraph Modules["caikit_nlp Modules (in-process)"]
            LocalMods["Local Modules<br/>TextGeneration<br/>PeftPromptTuning<br/>EmbeddingModule<br/>CrossEncoder<br/>Classification"]
            RemoteMods["TGIS Remote Modules<br/>TextGenerationTGIS<br/>PeftPromptTuningTGIS"]
        end

        HTTPServer --> Modules
        GRPCServer --> Modules
        Gateway -->|gRPC/8085<br/>internal| GRPCServer
    end

    subgraph EgressZone["EGRESS (Outbound)"]
        TGIS["TGIS Server<br/>gRPC (configurable port)<br/>Configurable TLS/mTLS<br/>ca_cert + client_cert + client_key"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)"]
    end

    %% External flows
    Client -->|HTTP/8080 or gRPC/8085<br/>Configurable TLS<br/>Auth: Configurable| KServe
    KServe -->|HTTP/8080<br/>Configurable TLS| HTTPServer
    KServe -->|gRPC/8085<br/>Configurable TLS| GRPCServer

    %% Egress flows
    RemoteMods -->|gRPC<br/>Configurable TLS/mTLS<br/>Auth: mTLS (optional)| TGIS
    LocalMods -->|HTTPS/443<br/>TLS 1.2+<br/>Auth: HF Token (optional)<br/>ALLOW_DOWNLOADS=true| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servingpod fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef server fill:#4ade80,stroke:#166534,stroke-width:2px
    classDef module fill:#93c5fd,stroke:#2563eb

    class Client external
    class KServe platform
    class HTTPServer,GRPCServer,Gateway server
    class LocalMods,RemoteMods module
    class TGIS,HFHub egress
