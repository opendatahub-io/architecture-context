graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Platform["MODEL SERVING PLATFORM (Trust Boundary)"]
        KServe["KServe / ModelMesh<br/>Ingress: 443/TCP HTTPS<br/>TLS Termination<br/>kube-rbac-proxy Auth"]
    end

    subgraph PodInternal["POD-INTERNAL (Trusted)"]
        direction TB

        subgraph Runtime["Caikit Runtime"]
            HTTPServer["HTTP Server<br/>8080/TCP<br/>No Encryption<br/>No Auth (platform-delegated)"]
            gRPCServer["gRPC Server<br/>8085/TCP<br/>No Encryption<br/>No Auth (platform-delegated)"]
        end

        subgraph CaikitNLP["caikit-nlp Modules"]
            TextGen["Text Generation<br/>(Local / TGIS Remote)"]
            Embedding["Embedding<br/>(sentence-transformers)"]
            Reranking["Reranking<br/>(cross-encoder)"]
            Classification["Classification<br/>(sequence / token)"]
            Tokenization["Tokenization"]
        end

        subgraph LocalInference["Local Inference"]
            PyTorch["PyTorch Model<br/>GPU/CPU Memory<br/>In-process"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        TGIS["TGIS Backend<br/>gRPC (configurable port)<br/>Optional TLS/mTLS<br/>ca_cert + client_cert"]
        HFHub["HuggingFace Hub<br/>huggingface.co<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Optional HF Token"]
    end

    subgraph DistributedTraining["DISTRIBUTED TRAINING (Optional)"]
        TorchPeers["PyTorch Distributed Peers<br/>29550/TCP<br/>gloo/nccl<br/>No Encryption"]
    end

    %% Flows
    Client -->|"HTTPS/443<br/>TLS (platform)<br/>Bearer Token"| KServe
    KServe -->|"HTTP/8080<br/>No Encryption<br/>Platform Auth"| HTTPServer
    KServe -->|"gRPC/8085<br/>No Encryption<br/>Platform Auth"| gRPCServer
    HTTPServer -->|"In-process<br/>Python call"| TextGen
    HTTPServer -->|"In-process<br/>Python call"| Embedding
    HTTPServer -->|"In-process<br/>Python call"| Reranking
    gRPCServer -->|"In-process<br/>Python call"| TextGen
    gRPCServer -->|"In-process<br/>Python call"| Classification
    TextGen -->|"In-process<br/>PyTorch"| PyTorch
    Embedding -->|"In-process<br/>PyTorch"| PyTorch
    TextGen -->|"gRPC (configurable port)<br/>Optional TLS/mTLS"| TGIS
    TextGen -->|"HTTPS/443<br/>TLS 1.2+<br/>Optional HF Token"| HFHub
    Embedding -->|"HTTPS/443<br/>TLS 1.2+<br/>Optional HF Token"| HFHub
    TextGen -.->|"TCP/29550<br/>No Encryption"| TorchPeers

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef platform fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podinternal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef training fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class KServe platform
    class HTTPServer,gRPCServer,TextGen,Embedding,Reranking,Classification,Tokenization,PyTorch podinternal
    class TGIS,HFHub externalservice
    class TorchPeers training
