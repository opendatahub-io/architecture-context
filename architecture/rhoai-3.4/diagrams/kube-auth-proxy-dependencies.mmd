graph LR
    KAP["kube-auth-proxy<br/>(Sidecar Proxy)"]

    %% Build Dependencies
    subgraph BuildDeps["Build Dependencies"]
        Go["Go 1.25.3<br/>(FIPS: strictfipsruntime)"]
        UBI["UBI 9 ubi-minimal<br/>(FIPS base image)"]
    end

    %% External Runtime Dependencies
    subgraph ExternalDeps["External Runtime Dependencies"]
        K8sAPI["Kubernetes API Server<br/>TokenReview + SAR"]
        OIDCProv["OIDC Provider<br/>(Keycloak)<br/>Token exchange, JWKS"]
        OSAuth["OpenShift OAuth Server<br/>OAuth flow, token mgmt"]
        RedisStore["Redis<br/>(optional session store)"]
    end

    %% Key Go Libraries
    subgraph GoLibs["Key Go Libraries"]
        GoOIDC["coreos/go-oidc/v3<br/>v3.18.0"]
        GoRedis["redis/go-redis/v9<br/>v9.17.0"]
        K8sClient["k8s.io/client-go<br/>v0.35.3"]
        K8sAPIServer["k8s.io/apiserver<br/>v0.35.3"]
        PromClient["prometheus/client_golang<br/>v1.23.2"]
        GorillaMux["gorilla/mux<br/>v1.8.1"]
        Cobra["spf13/cobra<br/>v1.10.1"]
    end

    %% Internal RHOAI Dependencies
    subgraph InternalDeps["Internal RHOAI Platform"]
        EnvoyGW["Envoy Proxy<br/>(RHOAI Gateway)<br/>ext_authz integration"]
        RhodsOp["rhods-operator<br/>Deploys as sidecar"]
        ComponentPod["RHOAI Component Pods<br/>Upstream applications"]
    end

    %% Integration Points (consume kube-auth-proxy)
    subgraph Consumers["Consumers"]
        PromMon["Prometheus<br/>(openshift-monitoring)<br/>Metrics scraping"]
    end

    %% Build dependency edges
    KAP -.->|"build"| Go
    KAP -.->|"base image"| UBI

    %% Runtime dependency edges
    KAP -->|"HTTPS/443<br/>TokenReview + SAR"| K8sAPI
    KAP -->|"HTTPS/443<br/>OAuth2 + JWKS"| OIDCProv
    KAP -->|"HTTPS/443<br/>OAuth flow"| OSAuth
    KAP -->|"TCP/6379<br/>sessions"| RedisStore

    %% Library edges
    KAP -.->|"OIDC tokens"| GoOIDC
    KAP -.->|"Redis client"| GoRedis
    KAP -.->|"K8s API"| K8sClient
    KAP -.->|"auth delegation"| K8sAPIServer
    KAP -.->|"metrics"| PromClient
    KAP -.->|"HTTP routing"| GorillaMux
    KAP -.->|"CLI (rbac mode)"| Cobra

    %% Internal edges
    EnvoyGW -->|"HTTP/8080<br/>ext_authz"| KAP
    RhodsOp -->|"deploys"| KAP
    KAP -->|"HTTP/HTTPS/H2C<br/>identity headers"| ComponentPod

    %% Consumer edges
    PromMon -->|"HTTPS/8443<br/>/metrics"| KAP

