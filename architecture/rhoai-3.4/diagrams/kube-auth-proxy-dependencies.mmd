graph LR
    KAP["kube-auth-proxy<br/>(dual-mode proxy sidecar)"]

    %% Platform Dependencies
    KAP -->|"TokenReview +<br/>SubjectAccessReview +<br/>OAuthAccessToken"| K8sAPI["Kubernetes API Server"]
    KAP -->|"OAuth2 flow +<br/>user info API"| OAuthServer["OpenShift OAuth Server"]
    KAP -->|"OIDC discovery +<br/>token exchange + JWKS"| OIDC["OIDC Provider<br/>(configurable)"]

    %% Optional Dependencies
    KAP -.->|"Session storage<br/>+ distributed locking"| Redis["Redis<br/>(optional)"]

    %% Build Dependencies
    KAP -->|"OIDC verification"| GoOIDC["coreos/go-oidc/v3<br/>v3.18.0"]
    KAP -->|"OAuth2 token exchange"| GoOAuth2["golang.org/x/oauth2<br/>v0.36.0"]
    KAP -->|"K8s API client"| ClientGo["k8s.io/client-go<br/>v0.35.3"]
    KAP -->|"Delegating authn/authz"| APIServer["k8s.io/apiserver<br/>v0.35.3"]
    KAP -->|"Metrics"| PromClient["prometheus/client_golang<br/>v1.23.2"]
    KAP -->|"HTTP routing"| Mux["gorilla/mux<br/>v1.8.1"]
    KAP -->|"CLI framework"| Cobra["spf13/cobra<br/>v1.10.1"]

    %% Internal RHOAI Integration
    RHOAIGateway["RHOAI Gateway<br/>(Envoy)"] -->|"ext_authz check"| KAP
    Prometheus["Prometheus"] -->|"Scrape /metrics"| KAP
    RhodsOp["rhods-operator"] -->|"Deploys sidecar<br/>+ configures"| KAP

    %% Upstream
    KAP -->|"Proxied traffic<br/>HTTP/HTTPS/h2c"| Upstream["Upstream Application<br/>(protected component)"]

    %% Build Infrastructure
    KAP -->|"Base image"| UBI9["UBI 9 ubi-minimal"]
    KAP -->|"Build toolchain"| Go["Go 1.25<br/>(FIPS: strictfipsruntime)"]

    %% Styling
    style KAP fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style K8sAPI fill:#666,stroke:#333,color:#fff
