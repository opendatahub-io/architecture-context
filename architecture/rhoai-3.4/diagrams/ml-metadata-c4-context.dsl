/*
 * ML Metadata (MLMD) - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.4/ml-metadata.md
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Runs ML pipelines and tracks experiments"
        pipelinedev = person "Pipeline Developer" "Builds and manages ML pipelines"

        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server that records and retrieves metadata associated with ML workflows, tracking artifacts, executions, contexts, and their relationships (lineage)" {
            grpcServer = container "metadata_store_server" "C++ gRPC server exposing MetadataStoreService with 40+ RPC methods for CRUD on ML metadata" "C++ Binary, gRPC/HTTP2, Port 8080"
            metadataStore = container "metadata_store" "Core metadata store logic with RDBMS abstraction layer" "C++ Library"
            mysqlBackend = container "mysql_metadata_source" "MySQL/MariaDB backend implementation" "C++ Library"
            postgresBackend = container "postgresql_metadata_source" "PostgreSQL backend implementation" "C++ Library"
            sqliteBackend = container "sqlite_metadata_source" "SQLite backend implementation (in-memory or file-based)" "C++ Library"
            pythonClient = container "ml_metadata (Python)" "Python client library for interacting with the gRPC server" "Python Package"

            grpcServer -> metadataStore "Uses"
            metadataStore -> mysqlBackend "Uses"
            metadataStore -> postgresBackend "Uses"
            metadataStore -> sqliteBackend "Uses"
        }

        dsp = softwareSystem "Data Science Pipelines" "Pipeline orchestration system (Kubeflow Pipelines / Tekton)" "Internal RHOAI"
        kfpSdk = softwareSystem "Kubeflow Pipelines SDK" "Python SDK for programmatic pipeline and metadata access" "Internal RHOAI"
        mysql = softwareSystem "MySQL / MariaDB" "Relational database for persistent metadata storage" "External"
        postgresql = softwareSystem "PostgreSQL" "Relational database for persistent metadata storage" "External"

        datascientist -> dsp "Runs ML pipelines via"
        pipelinedev -> kfpSdk "Accesses metadata programmatically via"

        dsp -> mlmd "Stores/retrieves pipeline metadata, artifact lineage" "gRPC/HTTP2, Port 8080, Optional TLS/mTLS"
        kfpSdk -> mlmd "Programmatic metadata access" "gRPC/HTTP2, Port 8080, Optional TLS"
        mlmd -> mysql "Persistent metadata storage" "MySQL Protocol, Port 3306, Optional TLS"
        mlmd -> postgresql "Persistent metadata storage" "PostgreSQL Protocol, Port 5432, Optional TLS"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
        }

        container mlmd "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
