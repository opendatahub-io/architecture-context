graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_CM["controller-manager<br/>(operator namespace)"]
        SA_DSP["ds-pipeline-{name}<br/>(DSPA namespace)"]
        SA_Envoy["ds-pipeline-metadata-envoy-{name}<br/>(DSPA namespace)"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager["manager-rolebinding<br/>(cluster-scoped)"]
        CRB_Argo["manager-argo-rolebinding<br/>(cluster-scoped)"]
        CRB_AuthDeleg["ds-pipeline-ui-auth-delegator<br/>(cluster-scoped)"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager["manager-role"]
        CR_Argo["manager-argo-role"]
        CR_AuthDeleg["system:auth-delegator"]
        CR_Edit["aggregate-dspa-admin-edit<br/>(aggregated to admin/edit)"]
        CR_View["aggregate-dspa-admin-view<br/>(aggregated to view)"]
    end

    subgraph ManagerResources["manager-role Resources"]
        direction TB
        DSPA_Res["datasciencepipelinesapplications.opendatahub.io<br/>DSPA, DSPA/api, DSPA/finalizers, DSPA/status<br/>create, delete, get, list, patch, update, watch"]
        Pipeline_Res["pipelines.kubeflow.org<br/>pipelines, pipelineversions + finalizers/status<br/>create, delete, get, list, patch, update, watch"]
        Core_Res["core<br/>configmaps, secrets, serviceaccounts,<br/>services, PVCs, PVs, pods, pods/exec, pods/log<br/>* (full access)"]
        Apps_Res["apps<br/>deployments, deployments/finalizers, replicasets<br/>* (full access)"]
        Argo_Res["argoproj.io<br/>workflows, workflowartifactgctasks + finalizers<br/>* (full access)"]
        Route_Res["route.openshift.io<br/>routes<br/>create, delete, get, list, patch, update, watch"]
        NetPol_Res["networking.k8s.io<br/>networkpolicies<br/>create, delete, get, list, patch, update, watch"]
        RBAC_Res["rbac.authorization.k8s.io<br/>clusterroles, clusterrolebindings, roles, rolebindings<br/>create, delete, get, list, update, watch"]
        Webhook_Res["admissionregistration.k8s.io<br/>mutatingwebhookconfigurations, validatingwebhookconfigurations<br/>create, delete, get, list, patch, update, watch"]
        Serving_Res["serving.kserve.io<br/>inferenceservices<br/>create, delete, get, list, patch"]
        Ray_Res["ray.io<br/>rayclusters, rayjobs, rayservices<br/>create, delete, get, list, patch"]
        KF_Res["kubeflow.org<br/>* (all resources)<br/>* (all verbs)"]
        Auth_Res["authentication.k8s.io + authorization.k8s.io<br/>tokenreviews, subjectaccessreviews<br/>create"]
    end

    subgraph ArgoResources["manager-argo-role Resources"]
        Argo_Pods["core<br/>pods, pods/exec, PVCs + finalizers<br/>create, get, list, watch, update, patch, delete"]
        Argo_WF["argoproj.io<br/>workflows, workflowtasksets, cronworkflows + finalizers<br/>get, list, watch, update, patch, delete, create"]
        Argo_Tmpl["argoproj.io<br/>workflowtemplates + finalizers<br/>get, list, watch"]
        Argo_Lease["coordination.k8s.io<br/>leases<br/>create, get, update"]
    end

    subgraph AggregateResources["Aggregate Roles Resources"]
        Agg_Edit["datasciencepipelinesapplications.opendatahub.io<br/>+ pipelines.kubeflow.org<br/>get, list, watch, create, update, patch, delete"]
        Agg_View["datasciencepipelinesapplications.opendatahub.io<br/>+ pipelines.kubeflow.org<br/>get, list, watch"]
    end

    %% Bindings
    SA_CM -->|"bound via"| CRB_Manager
    SA_CM -->|"bound via"| CRB_Argo
    SA_DSP -->|"bound via"| CRB_AuthDeleg
    SA_Envoy -->|"bound via"| CRB_AuthDeleg

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Argo -->|"grants"| CR_Argo
    CRB_AuthDeleg -->|"grants"| CR_AuthDeleg

    %% Role → Resources
    CR_Manager -->|"permits"| DSPA_Res
    CR_Manager -->|"permits"| Pipeline_Res
    CR_Manager -->|"permits"| Core_Res
    CR_Manager -->|"permits"| Apps_Res
    CR_Manager -->|"permits"| Argo_Res
