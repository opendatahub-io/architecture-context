    CR_Manager -->|"permits"| Ray_Res
    CR_Manager -->|"permits"| KF_Res
    CR_Manager -->|"permits"| Auth_Res

    CR_Argo -->|"permits"| Argo_Pods
    CR_Argo -->|"permits"| Argo_WF
    CR_Argo -->|"permits"| Argo_Tmpl
    CR_Argo -->|"permits"| Argo_Lease

    CR_Edit -->|"permits"| Agg_Edit
    CR_View -->|"permits"| Agg_View

