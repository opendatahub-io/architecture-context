graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_DSPO["data-science-pipelines-operator-<br/>controller-manager"]
        SA_Pipeline["ds-pipeline-{name}"]
        SA_Envoy["ds-pipeline-metadata-<br/>envoy-{name}"]
    end

    subgraph ClusterRoleBindings["ClusterRole Bindings"]
        CRB_Manager["manager-rolebinding"]
        CRB_AuthDel["ds-pipeline-ui-auth-<br/>delegator-{ns}-{name}"]
    end

    subgraph ClusterRoles["ClusterRoles"]
        CR_Manager["manager-role"]
        CR_AuthDel["system:auth-delegator"]
    end

    subgraph DSPAResources["DSPA Resources<br/>(datasciencepipelinesapplications.opendatahub.io)"]
        DSPA["datasciencepipelinesapplications"]
        DSPAApi["datasciencepipelinesapplications/api"]
        DSPAStatus["datasciencepipelinesapplications/status"]
        DSPAFinalizers["datasciencepipelinesapplications/finalizers"]
    end

    subgraph CoreResources["Core API Resources"]
        Deployments["apps/deployments"]
        Secrets["core/secrets"]
        ConfigMaps["core/configmaps"]
        ServiceAccs["core/serviceaccounts"]
        PVCs["core/persistentvolumeclaims"]
        Services["core/services"]
        Pods["core/pods, pods/exec, pods/log"]
        Events["core/events"]
    end

    subgraph NetworkResources["Network Resources"]
        NetworkPolicies["networking.k8s.io/<br/>networkpolicies"]
        Ingresses["networking.k8s.io/<br/>ingresses"]
        Routes["route.openshift.io/<br/>routes"]
    end

    subgraph RBACResources["RBAC Resources"]
        Roles["rbac/roles"]
        RoleBindings["rbac/rolebindings"]
        CRoles["rbac/clusterroles"]
        CRoleBindings["rbac/clusterrolebindings"]
    end

    subgraph WorkflowResources["Workflow Resources"]
        ArgoWorkflows["argoproj.io/<br/>workflows, workflowartifactgctasks"]
        ArgoResults["argoproj.io/<br/>workflowtaskresults"]
        Jobs["batch/jobs"]
        KubeflowAll["kubeflow.org/*"]
    end

    subgraph PipelineResources["Pipeline Resources<br/>(pipelines.kubeflow.org)"]
        Pipelines["pipelines"]
        PipelineVersions["pipelineversions"]
    end

    subgraph MLResources["ML Integration Resources"]
        InferenceServices["serving.kserve.io/<br/>inferenceservices"]
        RayClusters["ray.io/<br/>rayclusters, rayjobs,<br/>rayservices"]
        SeldonDeploys["machinelearning.seldon.io/<br/>seldondeployments"]
        AppWrappers["workload.codeflare.dev/<br/>appwrappers"]
    end

    subgraph AdminResources["Admin Resources"]
        ServiceMonitors["monitoring.coreos.com/<br/>servicemonitors"]
        Webhooks["admissionregistration.k8s.io/<br/>mutating/validating<br/>webhookconfigurations"]
        TokenReviews["authentication.k8s.io/<br/>tokenreviews"]
        SARs["authorization.k8s.io/<br/>subjectaccessreviews"]
    end

    %% Bindings
    SA_DSPO -->|"bound via"| CRB_Manager
    SA_Pipeline -->|"bound via"| CRB_AuthDel
    SA_Envoy -->|"bound via"| CRB_AuthDel

    CRB_Manager -->|"grants"| CR_Manager
    CRB_AuthDel -->|"grants"| CR_AuthDel

    %% manager-role permissions
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| DSPA
    CR_Manager -->|"get,list,watch"| DSPAApi
    CR_Manager -->|"get,update,patch"| DSPAStatus
    CR_Manager -->|"update"| DSPAFinalizers
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Deployments
    CR_Manager -->|"full access (*)"| Secrets
    CR_Manager -->|"full access (*)"| ConfigMaps
    CR_Manager -->|"full access (*)"| Services
    CR_Manager -->|"full access (*)"| Pods
    CR_Manager -->|"create,list,patch"| Events
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| NetworkPolicies
    CR_Manager -->|"get,list"| Ingresses
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Routes
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Roles
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| RoleBindings
    CR_Manager -->|"full access (*)"| ArgoWorkflows
    CR_Manager -->|"create,patch"| ArgoResults
    CR_Manager -->|"full access (*)"| Jobs
    CR_Manager -->|"full access (*)"| KubeflowAll
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| Pipelines
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| PipelineVersions
    CR_Manager -->|"create,get,list,<br/>patch,delete"| InferenceServices
    CR_Manager -->|"create,get,list,<br/>patch,delete"| RayClusters
    CR_Manager -->|"full access (*)"| SeldonDeploys
    CR_Manager -->|"full CRUD + watch"| AppWrappers
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| ServiceMonitors
    CR_Manager -->|"create (unrestricted);<br/>scoped CRUD"| Webhooks
    CR_Manager -->|"create"| TokenReviews
    CR_Manager -->|"create"| SARs

    %% auth-delegator permissions
    CR_AuthDel -->|"create"| TokenReviews
    CR_AuthDel -->|"create"| SARs

    %% Styling
    style SA_DSPO fill:#4a90e2,stroke:#333,color:#fff
    style SA_Pipeline fill:#4a90e2,stroke:#333,color:#fff
    style SA_Envoy fill:#4a90e2,stroke:#333,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,color:#fff
    style CR_AuthDel fill:#f5a623,stroke:#333,color:#fff
    style CRB_Manager fill:#e8e8e8,stroke:#333
    style CRB_AuthDel fill:#e8e8e8,stroke:#333
    style DSPA fill:#7ed321,stroke:#333,color:#fff
    style DSPAApi fill:#7ed321,stroke:#333,color:#fff
    style DSPAStatus fill:#7ed321,stroke:#333,color:#fff
    style DSPAFinalizers fill:#7ed321,stroke:#333,color:#fff
    style Pipelines fill:#7ed321,stroke:#333,color:#fff
    style PipelineVersions fill:#7ed321,stroke:#333,color:#fff
