graph TD
    subgraph ServiceAccounts["Service Account"]
        SA["payload-processing-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_Cluster["{release}-externalmodels-reader<br/>(ClusterRoleBinding)<br/>When multiNamespace=true"]
        RB_Namespace["{release}-externalmodels-reader<br/>(RoleBinding)<br/>When multiNamespace=false"]
    end

    subgraph Roles["Cluster Role / Role"]
        CR["{release}-externalmodels-reader<br/>(ClusterRole or Role)"]
    end

    subgraph APIResources["API Resources"]
        subgraph CoreAPI["API Group: core ('')"]
            Secrets["secrets"]
        end

        subgraph MaaSAPI["API Group: maas.opendatahub.io"]
            ExternalModels["externalmodels"]
        end
    end

    subgraph WatchedResources["Watched Resources (runtime)"]
        LabeledSecrets["Labeled Secrets<br/>Label: inference.networking.k8s.io/<br/>bbr-managed=true<br/>Contains: Provider API keys"]
        ExternalModelCRs["ExternalModel CRs<br/>Kind: ExternalModel<br/>Group: maas.opendatahub.io<br/>Version: v1alpha1"]
    end

    %% Bindings
    SA -->|"bound via"| CRB_Cluster
    SA -->|"bound via (alt)"| RB_Namespace
    CRB_Cluster -->|"grants (cluster-wide)"| CR
    RB_Namespace -->|"grants ({release-namespace} only)"| CR

    %% Permissions
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels

    %% Runtime watch targets
    Secrets -.->|"reconciled as"| LabeledSecrets
    ExternalModels -.->|"reconciled as"| ExternalModelCRs

    %% Notes
    subgraph Notes["Security Notes"]
        direction TB
        Note1["Read-only access only<br/>(no create/update/delete)"]
        Note2["Secret scope narrowed at runtime<br/>by label predicate filter"]
        Note3["multiNamespace=true (default)<br/>enables cross-namespace access"]
    end

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CRB_Cluster fill:#dae8fc,stroke:#6c8ebf
    style RB_Namespace fill:#dae8fc,stroke:#6c8ebf
    style CR fill:#f5a623,stroke:#333
    style Secrets fill:#7ed321,stroke:#333
    style ExternalModels fill:#7ed321,stroke:#333
    style LabeledSecrets fill:#fff2cc,stroke:#d6b656
    style ExternalModelCRs fill:#fff2cc,stroke:#d6b656
    style Note1 fill:#f9f9f9,stroke:#ccc
    style Note2 fill:#f9f9f9,stroke:#ccc
    style Note3 fill:#f9f9f9,stroke:#ccc
