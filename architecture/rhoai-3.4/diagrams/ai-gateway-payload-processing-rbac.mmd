graph TD
    subgraph "Service Account"
        SA["payload-processing-{release}<br/>Namespace: {release-namespace}"]
    end

    subgraph "Cluster Role Bindings"
        CRB_Cluster["ClusterRoleBinding<br/>{release}-externalmodels-reader<br/>(when multiNamespace=true)"]
        CRB_NS["RoleBinding<br/>{release}-externalmodels-reader<br/>(when multiNamespace=false)<br/>Namespace: {release-namespace}"]
    end

    subgraph "Cluster Role"
        CR["{release}-externalmodels-reader"]
    end

    subgraph "API Resources"
        Secrets["Core API (\"\")<br/>secrets"]
        ExternalModels["maas.opendatahub.io<br/>externalmodels"]
    end

    subgraph "Permitted Verbs"
        V_Secrets["get, list, watch"]
        V_EM["get, list, watch"]
    end

    subgraph "Purpose"
        P_Secrets["apikey-injection plugin<br/>Watches Secrets labeled<br/>inference.networking.k8s.io/bbr-managed=true<br/>Caches API keys in memory"]
        P_EM["model-provider-resolver plugin<br/>Watches ExternalModel CRDs<br/>Resolves model → provider mapping"]
    end

    SA -->|"bound via<br/>(cluster-wide)"| CRB_Cluster
    SA -->|"bound via<br/>(namespace-scoped)"| CRB_NS
    CRB_Cluster -->|grants| CR
    CRB_NS -->|grants| CR
    CR -->|"get, list, watch"| Secrets
    CR -->|"get, list, watch"| ExternalModels
    Secrets --- V_Secrets
    ExternalModels --- V_EM
    V_Secrets -.->|"used by"| P_Secrets
    V_EM -.->|"used by"| P_EM

    style SA fill:#4a90e2,stroke:#333,color:#fff
    style CR fill:#f5a623,stroke:#333
    style CRB_Cluster fill:#ffe6cc,stroke:#d79b00
    style CRB_NS fill:#ffe6cc,stroke:#d79b00
    style Secrets fill:#7ed321,stroke:#333
    style ExternalModels fill:#7ed321,stroke:#333
    style V_Secrets fill:#fff3cd,stroke:#d6b656
    style V_EM fill:#fff3cd,stroke:#d6b656
    style P_Secrets fill:#dae8fc,stroke:#6c8ebf
    style P_EM fill:#dae8fc,stroke:#6c8ebf
