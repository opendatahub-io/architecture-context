graph TB
    subgraph BatchGateway["Batch Gateway"]
        subgraph APIServer["API Server (8000/TCP, 8081/TCP)"]
            BatchHandler[Batch Handler<br/>/v1/batches]
            FileHandler[File Handler<br/>/v1/files]
            TenantMiddleware[Tenant Middleware<br/>X-MaaS-Username]
            SecurityHeaders[Security Headers<br/>Middleware]
            HealthAPI[Health/Ready/Metrics<br/>8081/TCP]
        end

        subgraph Processor["Batch Processor (9090/TCP obs)"]
            Poller[Queue Poller<br/>poll_interval: 5s]
            Preprocessor[Preprocessor<br/>JSONL parsing]
            Planner[Planner<br/>Binary plan files]
            Executor[Executor<br/>Concurrent dispatch]
            Finalizer[Finalizer<br/>Output assembly]
            Recovery[Recovery Manager<br/>Crash recovery]
            ConcurrencyCtrl[Concurrency Control<br/>Global: 100 / Per-model: 10]
            HealthProc[Health/Ready/Metrics<br/>9090/TCP]
        end

        subgraph GC["Garbage Collector"]
            Collector[Collector<br/>interval: 30m]
        end
    end

    Client[External Client] -->|POST /v1/batches<br/>Tenant header| TenantMiddleware
    Client -->|POST /v1/files<br/>multipart/form-data| TenantMiddleware
    TenantMiddleware --> SecurityHeaders
    SecurityHeaders --> BatchHandler
    SecurityHeaders --> FileHandler

    BatchHandler -->|Enqueue job| Redis
    FileHandler -->|Store metadata| PostgreSQL[(PostgreSQL)]
    FileHandler -->|Upload content| S3[S3 Storage]

    Poller -->|Dequeue (sorted set)| Redis[(Redis)]
    Poller --> Preprocessor
    Preprocessor --> Planner
    Planner -->|FNV-32a sort<br/>16-byte binary format| Executor
    Executor -->|HTTP POST<br/>Bearer token| InferenceGW[Inference Gateway]
    Executor --> ConcurrencyCtrl
    Finalizer -->|Upload results| S3

    Collector -->|Query expired| PostgreSQL
    Collector -->|Delete files| S3

    Recovery -->|Scan work_dir<br/>Phase-aware recovery| Poller

    style APIServer fill:#4a90e2,stroke:#333,color:#fff
    style Processor fill:#7ed321,stroke:#333,color:#fff
    style GC fill:#f5a623,stroke:#333,color:#fff
    style Client fill:#f9f9f9,stroke:#999
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
