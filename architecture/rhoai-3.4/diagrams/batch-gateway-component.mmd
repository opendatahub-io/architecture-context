graph TB
    subgraph BatchGateway["Batch Gateway System"]
        direction TB

        subgraph APIServer["API Server (8000/TCP, 8081/TCP)"]
            Router[HTTP Router]
            TenantMW[Tenant Middleware<br/>X-MaaS-Username]
            SecurityMW[Security Headers MW]
            RecoveryMW[Recovery MW]
            BatchHandler[Batch Handler<br/>/v1/batches]
            FileHandler[File Handler<br/>/v1/files]
            HealthHandler[Health/Ready/Metrics<br/>:8081]

            Router --> TenantMW
            TenantMW --> SecurityMW
            SecurityMW --> RecoveryMW
            RecoveryMW --> BatchHandler
            RecoveryMW --> FileHandler
            Router --> HealthHandler
        end

        subgraph Processor["Processor (9090/TCP observability)"]
            Poller[Job Poller<br/>poll_interval: 5s]
            Workers[Worker Pool<br/>num_workers goroutines]
            Preprocessor[Preprocessor<br/>FNV-32a hash sorting]
            Planner[Planner<br/>SLO scoring]
            Executor[Executor<br/>Concurrency control]
            Finalizer[Finalizer<br/>Result upload]
            Recovery[Recovery Manager<br/>Crash recovery]
            CancelHandler[Cancel Handler]

            Poller --> Workers
            Workers --> Preprocessor
            Preprocessor --> Planner
            Planner --> Executor
            Executor --> Finalizer
            Recovery -.->|startup| Workers
            CancelHandler -.->|event| Workers
        end

        subgraph GC["Garbage Collector"]
            Scanner[Expiry Scanner<br/>interval: 1h]
            Deleter[Batch Deleter<br/>max_concurrency: 10]
            Scanner --> Deleter
        end
    end

    %% External clients
    Client[External Client] -->|POST /v1/batches<br/>POST /v1/files| Router
    Client -->|GET /v1/batches/{id}<br/>POST /v1/batches/{id}/cancel| Router

    %% Data layer
    subgraph DataLayer["Data Layer"]
        PostgreSQL[(PostgreSQL<br/>5432/TCP)]
        Redis[(Redis<br/>6379/TCP)]
        S3[(S3-compatible Storage<br/>443/TCP)]
    end

    %% API Server connections
    BatchHandler -->|metadata CRUD| PostgreSQL
    BatchHandler -->|PQ enqueue/cancel| Redis
    FileHandler -->|file metadata| PostgreSQL
    FileHandler -->|upload/download| S3

    %% Processor connections
    Poller -->|ZMPOP dequeue| Redis
    Executor -->|HTTP/HTTPS inference| InferenceGW[Inference Gateway]
    Executor -->|progress updates| Redis
    Preprocessor -->|download input| S3
    Finalizer -->|upload output| S3
    Finalizer -->|status update| PostgreSQL

    %% GC connections
    Deleter -->|delete expired| PostgreSQL
    Deleter -->|delete files| S3
    Deleter -->|delete keys| Redis

    %% Observability
    Prometheus[Prometheus] -.->|scrape :8081| HealthHandler
    Prometheus -.->|scrape :9090| Processor
    OTel[OTLP Collector] -.->|traces| Processor

    %% Styling
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Processor fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    style GC fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    style PostgreSQL fill:#336791,stroke:#333,color:#fff
    style Redis fill:#dc382d,stroke:#333,color:#fff
    style S3 fill:#ff9900,stroke:#333,color:#fff
    style InferenceGW fill:#9b59b6,stroke:#333,color:#fff
    style Client fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTel fill:#e8e8e8,stroke:#333
