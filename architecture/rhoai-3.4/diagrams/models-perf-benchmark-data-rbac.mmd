graph TD
    subgraph Component["models-perf-benchmark-data"]
        direction TB
        Note["This component does NOT define<br/>any RBAC resources"]
    end

    subgraph RuntimeContext["Runtime RBAC Context"]
        direction TB
        InitContainer["Init Container<br/>(Data Image)"]
        PodSA["Pod ServiceAccount<br/>(inherited from model-catalog Pod)"]
        ManagedBy["Managed by:<br/>model-registry-operator"]
    end

    subgraph BuildTimeAuth["Build-Time Authentication"]
        direction TB
        KafkaAuth["Kafka Authentication<br/>Protocol: SASL_SSL<br/>Mechanism: SCRAM-SHA-512"]
        KafkaCreds["Credentials<br/>SASL_USERNAME<br/>SASL_PASSWORD<br/>(env vars, manual)"]
        SSLCerts["SSL Certificates<br/>SSL_CA_LOCATION<br/>SSL_CERTIFICATE_LOCATION<br/>SSL_KEY_LOCATION<br/>(file paths, manual)"]
    end

    subgraph SecurityPosture["Security Posture"]
        direction TB
        NoRBAC["No ClusterRoles"]
        NoBindings["No RoleBindings"]
        NoSA["No ServiceAccounts created"]
        NonRoot["Runs as UID 1001 (non-root)"]
        NoNetwork["No network services exposed"]
        DataOnly["Data-only container<br/>No executable code"]
    end

    InitContainer -->|"runs under"| PodSA
    ManagedBy -->|"configures"| PodSA
    KafkaAuth -->|"requires"| KafkaCreds
    KafkaAuth -->|"optionally uses"| SSLCerts

    %% Styling
    style Note fill:#fff3cd,stroke:#856404,color:#856404
    style InitContainer fill:#7ed321,stroke:#333,color:#fff
    style PodSA fill:#4a90e2,stroke:#333,color:#fff
    style ManagedBy fill:#e1bee7,stroke:#7b1fa2
    style KafkaAuth fill:#f5a623,stroke:#333,color:#fff
    style KafkaCreds fill:#ffccbc,stroke:#bf360c
    style SSLCerts fill:#ffccbc,stroke:#bf360c
    style NoRBAC fill:#c8e6c9,stroke:#388e3c
    style NoBindings fill:#c8e6c9,stroke:#388e3c
    style NoSA fill:#c8e6c9,stroke:#388e3c
    style NonRoot fill:#c8e6c9,stroke:#388e3c
    style NoNetwork fill:#c8e6c9,stroke:#388e3c
    style DataOnly fill:#c8e6c9,stroke:#388e3c
