graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator (Rust/axum+tonic)"]
        direction TB
        Router["HTTP Router<br/>(axum routes.rs)"]
        Handlers["Orchestration Handlers<br/>(Handle&lt;Task&gt; trait)"]
        StreamPipeline["Streaming Pipeline<br/>(broadcast channels,<br/>DetectionBatcher,<br/>CompletionState)"]

        subgraph Clients["Client Layer"]
            GenClient["Generation Client<br/>(tonic gRPC)"]
            ChunkerClient["Chunker Client<br/>(tonic gRPC)"]
            DetectorClient["Detector Client<br/>(reqwest HTTP)"]
            OpenAIClient["OpenAI Client<br/>(reqwest HTTP)"]
            OTELExporter["OTLP Exporter<br/>(opentelemetry)"]
        end

        subgraph TLS["TLS Layer"]
            ServerTLS["Server TLS<br/>(rustls/ring)"]
            ClientTLS["Client TLS<br/>(per-service config)"]
            mTLSVerifier["mTLS Verifier<br/>(WebPkiClientVerifier)"]
        end

        Router --> Handlers
        Handlers --> StreamPipeline
        Handlers --> GenClient
        Handlers --> ChunkerClient
        Handlers --> DetectorClient
        Handlers --> OpenAIClient
        StreamPipeline --> GenClient
        StreamPipeline --> ChunkerClient
        StreamPipeline --> DetectorClient
    end

    subgraph HealthServer["Health Server (:8034)"]
        HealthEndpoint["/health, /info"]
    end

    Client[Client Application] -->|"HTTP/HTTPS :8033<br/>TLS 1.2+ (optional)<br/>mTLS (optional)"| Router

    GenClient -->|"gRPC :8033<br/>mTLS (configurable)"| TGIS["TGIS Generation<br/>Server"]
    GenClient -->|"gRPC :8085<br/>mTLS (configurable)"| CaikitNLP["Caikit NLP<br/>Generation Server"]
    ChunkerClient -->|"gRPC :8085<br/>mTLS (configurable)"| Chunker["Caikit Chunker<br/>Service"]
    DetectorClient -->|"HTTP :8080<br/>TLS (configurable)"| Detectors["Detector Service(s)<br/>(HAP, PII, etc.)"]
    OpenAIClient -->|"HTTP :8080<br/>TLS (configurable)"| vLLM["OpenAI-compatible<br/>Service (vLLM)"]
    OTELExporter -->|"gRPC :4317 /<br/>HTTP :4318"| OTLPCollector["OTLP Collector"]

    K8sProbe["Kubernetes Probes"] -->|"HTTP :8034"| HealthEndpoint

    style Orchestrator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style Router fill:#5ba0f2,stroke:#333,color:#fff
    style Handlers fill:#5ba0f2,stroke:#333,color:#fff
    style StreamPipeline fill:#5ba0f2,stroke:#333,color:#fff
    style GenClient fill:#6cb0f5,stroke:#333,color:#fff
    style ChunkerClient fill:#6cb0f5,stroke:#333,color:#fff
    style DetectorClient fill:#6cb0f5,stroke:#333,color:#fff
    style OpenAIClient fill:#6cb0f5,stroke:#333,color:#fff
    style OTELExporter fill:#6cb0f5,stroke:#333,color:#fff
    style ServerTLS fill:#8cc0f8,stroke:#333
    style ClientTLS fill:#8cc0f8,stroke:#333
    style mTLSVerifier fill:#8cc0f8,stroke:#333
    style HealthServer fill:#7ed321,stroke:#333
    style HealthEndpoint fill:#8fe332,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#333
    style CaikitNLP fill:#e8e8e8,stroke:#333
