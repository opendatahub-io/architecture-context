graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator (Rust/axum)"]
        direction TB
        subgraph APIServer["API Server (port 8033)"]
            V1API["v1 API Routes<br/>/api/v1/task/*"]
            V2API["v2 API Routes<br/>/api/v2/text/*<br/>/api/v2/chat/*"]
            TLSLayer["TLS/mTLS Layer<br/>rustls + ring"]
        end

        subgraph HealthServer["Health Server (port 8034)"]
            HealthEP["/health endpoint"]
            InfoEP["/info endpoint<br/>(aggregated backend health)"]
        end

        subgraph OrchestratorCore["Orchestrator Core"]
            Handlers["Request Handlers<br/>(unary + streaming)"]
            Tasks["Task Pipeline<br/>(buffer_unordered, broadcast)"]
            HeaderFilter["Header Filter<br/>(X-Forwarded-Access-Token rewrite)"]
        end

        subgraph Clients["Backend Clients"]
            TGISClient["TGIS Client<br/>(tonic gRPC)"]
            NLPClient["Caikit NLP Client<br/>(tonic gRPC)"]
            ChunkerClient["Chunker Client<br/>(tonic gRPC)"]
            DetectorClient["Detector Client<br/>(reqwest HTTP)"]
            OpenAIClient["OpenAI Client<br/>(reqwest HTTP)"]
        end

        subgraph Observability["Observability"]
            OTelTracing["OpenTelemetry Tracing<br/>(W3C Trace Context)"]
            OTelMetrics["OpenTelemetry Metrics<br/>(request counts, durations)"]
        end
    end

    %% Client interaction
    Client[AI Application Client] -->|"POST HTTP/HTTPS<br/>8033/TCP"| V1API
    Client -->|"POST HTTP/HTTPS<br/>8033/TCP"| V2API
    K8sProbe[Kubernetes Probes] -->|"GET HTTP<br/>8034/TCP"| HealthEP

    %% Internal flow
    V1API --> Handlers
    V2API --> Handlers
    TLSLayer -.->|"enforces"| V1API
    TLSLayer -.->|"enforces"| V2API
    Handlers --> Tasks
    Handlers --> HeaderFilter

    %% Backend connections
    Tasks --> TGISClient
    Tasks --> NLPClient
    Tasks --> ChunkerClient
    Tasks --> DetectorClient
    Tasks --> OpenAIClient

    %% External backends
    TGISClient -->|"gRPC/8033<br/>Optional TLS/mTLS"| TGIS["TGIS Server"]
    NLPClient -->|"gRPC/8085<br/>Optional TLS/mTLS"| CaikitNLP["Caikit NLP Runtime"]
    ChunkerClient -->|"gRPC/8085<br/>Optional TLS/mTLS"| CaikitChunker["Caikit Chunker Service"]
    DetectorClient -->|"HTTP/8080<br/>Optional TLS/mTLS"| Detectors["Detector Services<br/>(HAP, PII, etc.)"]
    OpenAIClient -->|"HTTP/8080<br/>Optional TLS"| OpenAISvr["OpenAI-compatible Server<br/>(vLLM, etc.)"]

    %% Telemetry
    OTelTracing -->|"gRPC/4317 or HTTP/4318"| OTLPCollector["OTLP Collector"]
    OTelMetrics -->|"gRPC/4317 or HTTP/4318"| OTLPCollector

    %% Health checks
    HealthEP -.->|"health checks"| TGIS
    HealthEP -.->|"health checks"| CaikitNLP
    HealthEP -.->|"health checks"| CaikitChunker
    HealthEP -.->|"health checks"| Detectors
    HealthEP -.->|"health checks"| OpenAISvr

    %% Styling
    style Orchestrator fill:#e8f0fe,stroke:#4a90e2,stroke-width:3px
    style APIServer fill:#d5e8d4,stroke:#82b366
    style HealthServer fill:#d5e8d4,stroke:#82b366
    style OrchestratorCore fill:#fff2cc,stroke:#d6b656
    style Clients fill:#ffe6cc,stroke:#d79b00
    style Observability fill:#f8cecc,stroke:#b85450

    style Client fill:#f9f9f9,stroke:#333
    style K8sProbe fill:#f9f9f9,stroke:#333
    style TGIS fill:#e8e8e8,stroke:#666
    style CaikitNLP fill:#e8e8e8,stroke:#666
    style CaikitChunker fill:#e8e8e8,stroke:#666
    style Detectors fill:#e8e8e8,stroke:#666
    style OpenAISvr fill:#e8e8e8,stroke:#666
    style OTLPCollector fill:#e8e8e8,stroke:#666
