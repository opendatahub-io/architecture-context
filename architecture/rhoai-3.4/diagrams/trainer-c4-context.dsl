// C4 Context Diagram - Kubeflow Trainer
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages distributed training jobs via TrainJob CRs"

        trainer = softwareSystem "Kubeflow Trainer" "Kubernetes operator managing distributed ML training jobs and training runtimes on RHOAI" {
            controllerManager = container "trainer-controller-manager" "Reconciles TrainJob, TrainingRuntime, and ClusterTrainingRuntime CRDs; creates JobSet resources, NetworkPolicies, PodGroups" "Go Operator (controller-runtime)"
            webhooks = container "Validating Webhooks" "Validates TrainJob, TrainingRuntime, and ClusterTrainingRuntime on CREATE/UPDATE" "Admission Webhook (9443/TCP TLS)"
            progressionTracker = container "Progression Tracking" "Polls training pod HTTP metrics to track real-time training progress (RHAI feature)" "Go"
            networkPolicyManager = container "NetworkPolicy Manager" "Creates per-TrainJob NetworkPolicies for pod isolation (RHAI feature)" "Go"
            certManager = container "Certificate Manager" "Self-manages TLS certificates for webhook serving" "cert-controller"
            clusterRuntimes = container "ClusterTrainingRuntimes" "15 pre-configured runtimes for torch-distributed and training-hub (CUDA/ROCm/CPU)" "Kubernetes CRs"
        }

        kubeAPI = softwareSystem "Kubernetes API Server" "Cluster control plane API" "External"
        jobsetController = softwareSystem "JobSet Controller" "Reconciles JobSet CRs into Jobs and Pods" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys Trainer via kustomize overlays" "Internal ODH"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano Scheduler" "Optional co-scheduling via PodGroups" "External"
        schedulerPlugins = softwareSystem "Scheduler Plugins" "Optional co-scheduling via PodGroups" "External"
        openshiftImageRegistry = softwareSystem "OpenShift Image Registry" "Training-hub workbench image references via ImageStreams" "External"

        // User interactions
        user -> trainer "Creates TrainJob CRs via kubectl/dashboard"
        user -> kubeAPI "kubectl apply TrainJob" "HTTPS/443"

        // Trainer internal relationships
        controllerManager -> webhooks "Serves validation requests"
        controllerManager -> progressionTracker "Invokes for progress polling"
        controllerManager -> networkPolicyManager "Invokes for NetworkPolicy creation"
        certManager -> webhooks "Provides TLS certificates"
        controllerManager -> clusterRuntimes "Reads runtime templates"

        // Trainer external interactions
        trainer -> kubeAPI "CRUD: TrainJobs, JobSets, NetworkPolicies, Pods, Secrets, Events" "HTTPS/443"
        trainer -> jobsetController "Creates JobSet CRs for reconciliation" "CRD (jobset.x-k8s.io/v1alpha2)"
        kubeAPI -> trainer "Sends AdmissionReview for validation" "HTTPS/9443"
        prometheus -> trainer "Scrapes controller metrics via PodMonitor" "HTTPS/8443"
        trainer -> volcano "Creates PodGroups for co-scheduling (optional)" "CRD (scheduling.volcano.sh)"
        trainer -> schedulerPlugins "Creates PodGroups for co-scheduling (optional)" "CRD (scheduling.x-k8s.io)"
        rhodsOperator -> trainer "Deploys via kustomize overlays" "Kustomize"
        trainer -> openshiftImageRegistry "References training-hub images" "ImageStream"

        // Progression tracking
        progressionTracker -> kubeAPI "Lists training pods, patches TrainJob annotations" "HTTPS/443"
    }

    views {
        systemContext trainer "SystemContext" {
            include *
            autoLayout
        }

        container trainer "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
