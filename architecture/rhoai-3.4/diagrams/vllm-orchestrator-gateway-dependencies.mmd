graph LR
    Gateway["vLLM Orchestrator<br/>Gateway<br/>(Rust/Axum)"]

    %% Internal Platform Dependencies (direct)
    Gateway -->|"REST API<br/>POST /api/v2/chat/completions-detection<br/>8085/TCP HTTP or HTTPS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Internal Platform Dependencies (indirect, via Orchestrator)
    Orchestrator -.->|"detector calls"| Detectors["Guardrails Detector<br/>Services<br/>(e.g., regex-language)"]
    Orchestrator -.->|"LLM inference"| vLLM["vLLM Inference<br/>Backend"]

    %% Platform Infrastructure
    TrustyAI["TrustyAI Operator"] -->|"deploys & configures<br/>container spec, probes,<br/>config mount"| Gateway

    %% TLS Infrastructure
    CertManager["cert-manager /<br/>service-serving-cert"] -.->|"TLS cert + key<br/>/etc/tls/private/"| Gateway
    ServiceCA["service-ca-operator"] -.->|"CA cert<br/>/etc/tls/ca/"| Gateway

    %% Runtime Dependencies (Rust crates)
    subgraph RustDeps["Key Rust Dependencies"]
        Axum["axum 0.7.9<br/>(HTTP framework)"]
        Reqwest["reqwest 0.12.12<br/>(HTTP client)"]
        Tokio["tokio 1.41.1<br/>(async runtime)"]
        OpenSSL["openssl 0.10.73<br/>(TLS/PKCS#12)"]
        NativeTLS["native-tls 0.2.12<br/>(TLS transport)"]
    end

    Gateway -.->|"runtime"| Axum
    Gateway -.->|"upstream calls"| Reqwest
    Gateway -.->|"async runtime"| Tokio
    Gateway -.->|"mTLS identity"| OpenSSL
    Gateway -.->|"TLS transport"| NativeTLS

    %% Kubernetes API
    Gateway -.->|"TCP socket probe<br/>8090/TCP"| K8sAPI["Kubernetes API<br/>(liveness/readiness)"]

    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#999,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style TrustyAI fill:#7ed321,stroke:#333,color:#fff
    style CertManager fill:#f5a623,stroke:#333,color:#fff
    style ServiceCA fill:#f5a623,stroke:#333,color:#fff
    style K8sAPI fill:#f5a623,stroke:#333,color:#fff
    style Axum fill:#dae8fc,stroke:#6c8ebf
    style Reqwest fill:#dae8fc,stroke:#6c8ebf
    style Tokio fill:#dae8fc,stroke:#6c8ebf
    style OpenSSL fill:#dae8fc,stroke:#6c8ebf
    style NativeTLS fill:#dae8fc,stroke:#6c8ebf
