graph LR
    Gateway["vllm-orchestrator-gateway<br/>(Rust/axum)"]

    %% Direct Platform Dependencies
    Gateway -->|"REST API POST<br/>8085/TCP HTTP/HTTPS<br/>Optional mTLS"| Orchestrator["FMS Guardrails<br/>Orchestrator"]

    %% Indirect Dependencies (via orchestrator)
    Orchestrator -->|"invokes"| Detectors["Detector Services<br/>(e.g., guardrails-regex-detector)"]
    Orchestrator -->|"forwards generation"| vLLM["vLLM Inference Server"]

    %% Infrastructure Dependencies
    Gateway -.->|"volume mount<br/>/etc/tls/ca/"| ServiceCA["Kubernetes<br/>service-ca"]
    Gateway -.->|"volume mount<br/>/etc/tls/private/"| TLSSecret["TLS Secret<br/>(client identity)"]

    %% Key Library Dependencies
    subgraph "Rust Crate Dependencies"
        Axum["axum 0.7.9<br/>HTTP framework"]
        Reqwest["reqwest 0.12.12<br/>HTTP client"]
        Tokio["tokio 1.41.1<br/>Async runtime"]
        OpenSSL["openssl 0.10.73<br/>TLS handling"]
        NativeTLS["native-tls 0.2.12<br/>System TLS backend"]
        SerdeYml["serde_yml 0.0.12<br/>Config parsing"]
        Futures["futures 0.3.30<br/>SSE streaming"]
    end

    Gateway -.->|"built with"| Axum
    Gateway -.->|"HTTP client"| Reqwest
    Gateway -.->|"async runtime"| Tokio
    Gateway -.->|"mTLS identity"| OpenSSL
    Gateway -.->|"TLS connector"| NativeTLS
    Gateway -.->|"config loading"| SerdeYml
    Gateway -.->|"SSE processing"| Futures

    %% Styling
    style Gateway fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style Orchestrator fill:#7ed321,stroke:#333,color:#fff
    style Detectors fill:#7ed321,stroke:#333,color:#fff
    style vLLM fill:#999,stroke:#333,color:#fff
    style ServiceCA fill:#f5a623,stroke:#333,color:#fff
    style TLSSecret fill:#f5a623,stroke:#333,color:#fff
    style Axum fill:#e8e8e8,stroke:#333
    style Reqwest fill:#e8e8e8,stroke:#333
    style Tokio fill:#e8e8e8,stroke:#333
    style OpenSSL fill:#e8e8e8,stroke:#333
    style NativeTLS fill:#e8e8e8,stroke:#333
    style SerdeYml fill:#e8e8e8,stroke:#333
    style Futures fill:#e8e8e8,stroke:#333
