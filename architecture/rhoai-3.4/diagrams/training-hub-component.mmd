graph TB
    subgraph TrainingHub["training-hub Library"]
        direction TB

        subgraph Registry["Algorithm Registry"]
            AlgRegistry["AlgorithmRegistry<br/>Factory + Lookup"]
            AlgABC["Algorithm ABC"]
            BackendABC["Backend ABC"]
        end

        subgraph Algorithms["Fine-Tuning Algorithms"]
            SFT["SFTAlgorithm<br/>Full-parameter SFT"]
            OSFT["OSFTAlgorithm<br/>Orthogonal Subspace FT"]
            LoRASFT["LoRASFTAlgorithm<br/>LoRA Parameter-Efficient SFT"]
            LoRAGRPO["LoRAGRPOAlgorithm<br/>LoRA + GRPO RL"]
            GRPO["grpo()<br/>Full FT GRPO<br/>(lora_r=0, verl)"]
        end

        subgraph Backends["Training Backends"]
            ILTBackend["InstructLabTraining<br/>SFTBackend"]
            MiniTrainer["MiniTrainer<br/>OSFTBackend"]
            Unsloth["Unsloth<br/>LoRABackend"]
            ARTBackend["ART<br/>LoRAGRPOBackend<br/>(single-GPU)"]
            VeRLBackend["verl<br/>LoRAGRPOBackend<br/>(multi-GPU)"]
        end

        subgraph Support["Support Modules"]
            PEFTExt["PEFT Extender<br/>LoRA Config"]
            Rewards["Reward Functions<br/>tool_call / binary"]
            ToolAgent["verl Tool Agent Loop<br/>SingleTurnToolAgentLoop"]
            TorchrunUtil["Torchrun Utilities<br/>Distributed Launch Config"]
        end

        subgraph Profiling["Profiling Suite"]
            MemEst["Memory Estimator<br/>SFT/OSFT/LoRA/QLoRA"]
            TimeEst["Timing Estimator<br/>Subset Extrapolation"]
        end

        subgraph Viz["Visualization"]
            PlotLoss["plot_loss()<br/>Training Loss Curves"]
        end
    end

    %% User entry points
    User["User / Script"] -->|"sft()"| SFT
    User -->|"osft()"| OSFT
    User -->|"lora_sft()"| LoRASFT
    User -->|"lora_grpo()"| LoRAGRPO
    User -->|"grpo()"| GRPO
    User -->|"estimate()"| MemEst
    User -->|"time_estimate()"| TimeEst
    User -->|"plot_loss()"| PlotLoss

    %% Algorithm → Registry
    SFT -->|registers| AlgRegistry
    OSFT -->|registers| AlgRegistry
    LoRASFT -->|registers| AlgRegistry
    LoRAGRPO -->|registers| AlgRegistry

    %% Algorithm → Backend delegation
    SFT -->|delegates to| ILTBackend
    OSFT -->|delegates to| MiniTrainer
    LoRASFT -->|delegates to| Unsloth
    LoRAGRPO -->|delegates to| ARTBackend
    LoRAGRPO -->|delegates to| VeRLBackend
    GRPO -->|delegates to| VeRLBackend

    %% Support connections
    LoRAGRPO --> PEFTExt
    LoRASFT --> PEFTExt
    LoRAGRPO --> Rewards
    VeRLBackend --> ToolAgent
    ILTBackend --> TorchrunUtil
    MiniTrainer --> TorchrunUtil

    %% External connections
    ILTBackend -->|in-process| ILT["instructlab-training"]
    MiniTrainer -->|in-process| MiniT["rhai-mini-trainer"]
    Unsloth -->|in-process| UnslothLib["unsloth"]
    ARTBackend -->|subprocess| ARTLib["openpipe-art"]
    VeRLBackend -->|subprocess + Hydra| VeRLLib["verl"]

    MemEst -->|"HTTPS/443"| HFHub["HuggingFace Hub"]
    ILTBackend -->|"HTTPS/443"| HFHub

    %% Styling
    style TrainingHub fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style SFT fill:#4a90e2,color:#fff
    style OSFT fill:#4a90e2,color:#fff
    style LoRASFT fill:#4a90e2,color:#fff
    style LoRAGRPO fill:#4a90e2,color:#fff
    style GRPO fill:#4a90e2,color:#fff
    style ILTBackend fill:#7ed321,color:#fff
    style MiniTrainer fill:#7ed321,color:#fff
    style Unsloth fill:#7ed321,color:#fff
    style ARTBackend fill:#7ed321,color:#fff
    style VeRLBackend fill:#7ed321,color:#fff
    style MemEst fill:#f5a623,color:#fff
    style TimeEst fill:#f5a623,color:#fff
    style PlotLoss fill:#9b59b6,color:#fff
    style ILT fill:#e8e8e8
    style MiniT fill:#e8e8e8
    style UnslothLib fill:#e8e8e8
    style ARTLib fill:#e8e8e8
    style VeRLLib fill:#e8e8e8
    style HFHub fill:#e8e8e8
    style User fill:#fff,stroke:#333,stroke-width:2px
