graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser / kubectl<br/>Dashboard"]
    end

    subgraph Ingress["INGRESS (Gateway API - TLS Termination)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP → HTTPRoute backend<br/>TLS 1.2+ (SIMPLE)"]
    end

    subgraph AuthProxy["AUTH PROXY LAYER (per notebook pod)"]
        KRBP["kube-rbac-proxy sidecar<br/>Port: 8443/TCP HTTPS<br/>TLS: serving-cert (auto-rotated)<br/>Auth: TokenReview + SubjectAccessReview<br/>Policy: GET kubeflow.org/v1.notebooks"]
    end

    subgraph Workload["WORKLOAD LAYER (user namespaces)"]
        Jupyter["Jupyter Server<br/>Port: 8888/TCP HTTP<br/>No encryption (pod-internal)<br/>NetworkPolicy: ctrl-np (8888)<br/>NetworkPolicy: krbp-np (8443)"]
    end

    subgraph Controllers["CONTROLLER LAYER (opendatahub namespace)"]
        direction TB

        NBCtrl["notebook-controller<br/>SA: notebook-controller-service-account<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]

        ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP<br/>Webhook: 8443/TCP HTTPS"]
    end

    subgraph PlatformSvcs["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount tokens"]

        ImageReg["OpenShift Image Registry<br/>5000/TCP HTTPS<br/>TLS<br/>Auth: ServiceAccount token"]

        ServingCert["serving-cert-controller<br/>Annotation-triggered<br/>Auto-generates & rotates TLS certs"]

        DSPA["DSPA API Server<br/>HTTPS, TLS<br/>Auth: ServiceAccount token<br/>(optional)"]

        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Auth Proxy
    Gateway -->|"HTTPS/8443<br/>TLS (serving cert)<br/>Bearer token forwarded"| KRBP

    %% Auth Proxy → K8s API (auth check)
    KRBP -->|"HTTPS/6443<br/>TLS 1.2+<br/>TokenReview + SAR"| K8sAPI

    %% Auth Proxy → Jupyter (proxied request)
    KRBP -->|"HTTP/8888<br/>No encryption (localhost)<br/>X-Auth-Request-User header"| Jupyter

    %% Controllers → K8s API
    NBCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token<br/>StatefulSet/Service CRUD"| K8sAPI
    ODHCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token<br/>HTTPRoute/NetworkPolicy/RBAC CRUD"| K8sAPI

    %% Culling → Jupyter
    NBCtrl -->|"HTTP/8888<br/>No encryption<br/>No auth<br/>/api/kernels, /api/terminals"| Jupyter

    %% ODH → Image Registry
    ODHCtrl -->|"HTTPS/5000<br/>TLS<br/>SA token<br/>ImageStream resolution"| ImageReg

    %% ODH → DSPA
    ODHCtrl -.->|"HTTPS<br/>TLS<br/>SA token<br/>Elyra config"| DSPA

    %% serving-cert → secrets
    ServingCert -.->|"auto-generates<br/>kube-rbac-proxy-tls<br/>webhook-cert"| KRBP
    ServingCert -.->|"auto-generates<br/>webhook-cert"| ODHCtrl

    %% Prometheus scraping
    Prometheus -.->|"HTTP/8080<br/>No auth"| NBCtrl
    Prometheus -.->|"HTTP/8080<br/>No auth"| ODHCtrl

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px,color:#333
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px,color:#333
    classDef authproxy fill:#f8cecc,stroke:#b85450,stroke-width:2px,color:#333
    classDef workload fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#333

    class User external
    class Gateway ingress
    class KRBP authproxy
    class Jupyter workload
    class NBCtrl,ODHCtrl controller
    class K8sAPI,ImageReg,ServingCert,DSPA,Prometheus platform
