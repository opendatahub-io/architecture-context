%% Security Network Diagram - ODH Notebook Controller (kubeflow)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / ODH Dashboard"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["data-science-gateway (Envoy)<br/>openshift-ingress namespace<br/>443/TCP HTTPS TLS 1.2+<br/>Path: /notebook/{ns}/{name}"]
    end

    subgraph ControllerNS["CONTROLLER NAMESPACE (opendatahub)"]
        direction TB
        Controller["ODH Notebook Controller<br/>SA: odh-notebook-controller-manager<br/>Ports: 8443 (webhook), 8081 (health), 8080 (metrics)"]
        WebhookSvc["Webhook Service<br/>443/TCP -> 8443/TCP<br/>HTTPS TLS (service-ca)<br/>Auth: K8s API server"]
        MetricsSvc["Metrics Service<br/>8080/TCP HTTP<br/>plaintext, no auth"]
        HTTPRoutes["HTTPRoute CRs<br/>(created in central ns)<br/>parentRef: data-science-gateway"]
    end

    subgraph UserNS["USER NAMESPACE (per notebook)"]
        direction TB
        KRBP["kube-rbac-proxy Sidecar<br/>SA: {notebook-name}<br/>8443/TCP HTTPS<br/>TLS (service-ca signed)<br/>Auth: SAR on notebooks/get"]
        NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>plaintext (pod-internal)"]
        KRBPSvc["{name}-kube-rbac-proxy Service<br/>8443/TCP ClusterIP"]
        RefGrant["ReferenceGrant<br/>(cross-ns backend ref)"]
        NetPol1["{name}-ctrl-np<br/>Allow TCP/8888<br/>from controller ns only"]
        NetPol2["{name}-kube-rbac-proxy-np<br/>Allow TCP/8443<br/>from any source"]
    end

    subgraph ClusterServices["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>Auth: ServiceAccount token"]
        ServiceCA["OpenShift Service CA<br/>Auto-provisions TLS certs"]
        ImageRegistry["OpenShift Image Registry<br/>5000/TCP HTTPS TLS<br/>Auth: ServiceAccount token"]
    end

    %% External -> Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Browser session"| Gateway

    %% Ingress -> User NS (with auth path)
    Gateway -->|"HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token forwarded"| KRBPSvc
    KRBPSvc --> KRBP

    %% kube-rbac-proxy -> K8s API (SAR check)
    KRBP -->|"HTTPS/443<br/>TLS 1.2+<br/>SubjectAccessReview"| K8sAPI

    %% kube-rbac-proxy -> notebook (after auth)
    KRBP -->|"HTTP/8888<br/>plaintext (localhost)<br/>X-Auth-Request headers"| NotebookContainer

    %% Controller -> K8s API
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD resources"| K8sAPI

    %% Controller -> Image Registry
    Controller -->|"HTTPS/5000<br/>TLS<br/>SA token"| ImageRegistry

    %% K8s API -> Webhook
    K8sAPI -->|"HTTPS/443->8443<br/>TLS (service-ca)<br/>Webhook auth"| WebhookSvc

    %% Service CA provisions certs
    ServiceCA -.->|"provisions TLS certs"| WebhookSvc
    ServiceCA -.->|"provisions TLS certs"| KRBPSvc

    %% HTTPRoute references
    HTTPRoutes -.->|"parentRef"| Gateway
    HTTPRoutes -.->|"backendRef (cross-ns)"| KRBPSvc
    RefGrant -.->|"allows cross-ns ref"| HTTPRoutes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef cluster fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef netpol fill:#f8cecc,stroke:#b85450,stroke-width:1px,stroke-dasharray: 5 5

    class User external
    class Gateway ingress
    class Controller,WebhookSvc,MetricsSvc,HTTPRoutes controller
    class KRBP,NotebookContainer,KRBPSvc,RefGrant userns
    class K8sAPI,ServiceCA,ImageRegistry cluster
    class NetPol1,NetPol2 netpol
