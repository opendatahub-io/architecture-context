graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Dashboard"]
    end

    subgraph Ingress["INGRESS (Gateway / Router)"]
        Gateway["data-science-gateway<br/>Namespace: openshift-ingress<br/>443/TCP<br/>TLS 1.2+ (SIMPLE)<br/>Gateway API"]
    end

    subgraph AuthLayer["AUTHENTICATION LAYER"]
        RBACProxy["kube-rbac-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS: serving cert<br/>SubjectAccessReview"]
    end

    subgraph Controllers["CONTROLLERS (Namespace: opendatahub)"]
        direction TB

        NC["notebook-controller<br/>SA: notebook-controller-service-account<br/>8080/TCP metrics, 8081/TCP health"]

        ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>8080/TCP metrics, 8081/TCP health<br/>8443/TCP webhook HTTPS"]

        subgraph Webhooks["Webhook Services"]
            MutWH["Mutating Webhook<br/>/mutate-notebook-v1<br/>443→8443/TCP HTTPS<br/>fail-closed"]
            ValWH["Validating Webhook<br/>/validate-notebook-v1<br/>443→8443/TCP HTTPS<br/>fail-closed"]
        end
    end

    subgraph Workload["WORKLOAD (Notebook Pod - StatefulSet)"]
        Jupyter["Jupyter Server<br/>Namespace: {user-namespace}<br/>SA: {notebook-name}<br/>8888/TCP HTTP<br/>Image: from ImageStream"]
    end

    subgraph PlatformServices["PLATFORM SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+"]
        ServiceCA["OpenShift service-ca-operator<br/>Auto-generates TLS certs"]
        ImageStreams["OpenShift ImageStreams<br/>443/TCP HTTPS"]
        DSPA["DSPA API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph IntegrationServices["INTEGRATION SERVICES"]
        MLflow["MLflow Operator<br/>ClusterRole reference"]
        Feast["Feast Feature Store<br/>ConfigMap mount"]
    end

    %% External → Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| Gateway

    %% Ingress → Auth (with auth)
    Gateway -->|"HTTPS/8443<br/>TLS serving cert<br/>Bearer Token fwd"| RBACProxy

    %% Auth → K8s API (SubjectAccessReview)
    RBACProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>SubjectAccessReview"| K8sAPI

    %% Auth → Jupyter (after auth passes)
    RBACProxy -->|"HTTP/8888<br/>None (localhost)<br/>X-Auth-Request-User"| Jupyter

    %% Controllers → K8s API
    NC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD: StatefulSets, Services"| K8sAPI
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token<br/>CRUD: HTTPRoutes, RBAC, Secrets"| K8sAPI

    %% Idle culling
    NC -->|"HTTP/8888<br/>No encryption<br/>No auth<br/>/api/kernels, /api/terminals"| Jupyter

    %% ODH → Platform
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| DSPA
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| ImageStreams

    %% K8s API → Webhooks
    K8sAPI -->|"HTTPS/443→8443<br/>TLS serving cert<br/>API server auth"| MutWH
    K8sAPI -->|"HTTPS/443→8443<br/>TLS serving cert<br/>API server auth"| ValWH

    %% Cert provisioning
    ServiceCA -.->|"auto-generates"| RBACProxy
    ServiceCA -.->|"auto-generates"| ODHCtrl

    %% Integration references
    ODHCtrl -.->|"ClusterRole ref"| MLflow
    ODHCtrl -.->|"ConfigMap mount"| Feast

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#ffcccc,stroke:#cc0000,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef workload fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef platform fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef webhook fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Gateway ingress
    class RBACProxy auth
    class NC,ODHCtrl controller
    class MutWH,ValWH webhook
    class Jupyter workload
    class K8sAPI,ServiceCA,ImageStreams,DSPA platform
    class MLflow,Feast integration
