graph TB
    subgraph RhodsOperator["rhods-operator (Platform Operator)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCController["DataScienceCluster<br/>Controller"]
            DSCIController["DSCInitialization<br/>Controller"]
            SetupController["Setup Controller"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway Controller"]
            AuthCtrl["Auth Controller"]
            MonitoringCtrl["Monitoring Controller"]
            CertConfigMap["CertConfigMapGenerator<br/>Controller"]
        end

        subgraph ComponentControllers["Component Controllers (16)"]
            DashboardCtrl["Dashboard"]
            KServeCtrl["KServe"]
            KueueCtrl["Kueue"]
            WorkbenchesCtrl["Workbenches"]
            ModelRegCtrl["Model Registry"]
            DSPCtrl["DSP"]
            ModelCtrlCtrl["Model Controller"]
            TrustyAICtrl["TrustyAI"]
            RayCtrl["Ray"]
            TrainerCtrl["Trainer"]
            TrainingOpCtrl["Training Operator"]
            FeastCtrl["Feast"]
            LlamaCtrl["LlamaStack"]
            MLflowCtrl["MLflow"]
            SparkCtrl["Spark"]
            MaaSCtrl["MaaS"]
        end

        subgraph Webhooks["Admission Webhooks (12)"]
            DSCWebhook["DSC Singleton<br/>Validation/Defaulting"]
            DSCIWebhook["DSCI Singleton<br/>Validation"]
            HWProfileWebhook["Hardware Profile<br/>Injection"]
            NotebookWebhook["Notebook Connection<br/>Injection"]
            ServingWebhook["Serving Connection<br/>Injection"]
            MonitoringWebhook["Monitoring Label<br/>Injection"]
        end

        ComponentRegistry["Component Registry<br/>(handler interface)"]
    end

    subgraph CloudManager["cloudmanager (XKS only)"]
        AzureCtrl["Azure AKS Controller"]
        CoreWeaveCtrl["CoreWeave Controller"]
        HelmCharts["Helm Chart Manager"]
    end

    %% CRDs
    DSCCR["DataScienceCluster CR<br/>(Cluster-scoped)"]
    DSCICR["DSCInitialization CR<br/>(Cluster-scoped)"]
    ComponentCRs["Component CRs<br/>(Dashboard, KServe,<br/>Kueue, etc.)"]
    ServiceCRs["Service CRs<br/>(GatewayConfig, Auth,<br/>Monitoring)"]

    %% External Systems
    K8sAPI["Kubernetes API<br/>6443/TCP"]
    OLM["OLM<br/>(Operator Lifecycle)"]

    %% User interaction
    User["Platform Admin"]

    %% Flows
    User -->|"creates/updates"| DSCCR
    User -->|"creates/updates"| DSCICR
    DSCCR -->|"watched by"| DSCController
    DSCICR -->|"watched by"| DSCIController
    DSCController -->|"iterates"| ComponentRegistry
    ComponentRegistry -->|"dispatches to"| ComponentControllers
    DSCIController -->|"creates singletons"| ServiceCRs
    ServiceCRs -->|"watched by"| ServiceControllers
    ComponentControllers -->|"creates"| ComponentCRs
    ComponentControllers -->|"applies kustomize manifests via"| K8sAPI
    GatewayCtrl -->|"deploys ingress stack via"| K8sAPI
    AuthCtrl -->|"manages RBAC via"| K8sAPI
    MonitoringCtrl -->|"deploys observability stack via"| K8sAPI
    OLM -->|"installs/upgrades"| RhodsOperator

    %% Cloud Manager
    AzureCtrl -->|"deploys"| HelmCharts
    CoreWeaveCtrl -->|"deploys"| HelmCharts
    HelmCharts -->|"installs prereqs via"| K8sAPI

    %% Styling
    style RhodsOperator fill:#e8f0fe,stroke:#4a90e2,stroke-width:2px
    style CoreControllers fill:#d5e8d4,stroke:#82b366
    style ServiceControllers fill:#dae8fc,stroke:#6c8ebf
    style ComponentControllers fill:#fff2cc,stroke:#d6b656
    style Webhooks fill:#f8cecc,stroke:#b85450
    style CloudManager fill:#e1d5e7,stroke:#9673a6
    style DSCCR fill:#f5a623,stroke:#333
    style DSCICR fill:#f5a623,stroke:#333
    style ComponentCRs fill:#f5a623,stroke:#333
    style ServiceCRs fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OLM fill:#e8e8e8,stroke:#333
    style ComponentRegistry fill:#b9e0a5,stroke:#6aa84f,stroke-width:2px
