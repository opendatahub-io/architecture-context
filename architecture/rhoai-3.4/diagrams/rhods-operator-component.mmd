graph TB
    subgraph Operator["rhods-operator (manager)"]
        direction TB

        subgraph CoreControllers["Core Controllers"]
            DSCICtrl["DSCInitialization<br/>Controller"]
            DSCCtrl["DataScienceCluster<br/>Controller"]
        end

        subgraph ServiceControllers["Service Controllers"]
            GatewayCtrl["Gateway Controller"]
            AuthCtrl["Auth Controller"]
            MonitoringCtrl["Monitoring Controller"]
            CertCtrl["CertConfigMapGenerator<br/>Controller"]
            SetupCtrl["Setup Controller"]
        end

        subgraph ComponentControllers["Component Controllers (16)"]
            DashboardCtrl["Dashboard"]
            KServeCtrl["KServe"]
            WorkbenchesCtrl["Workbenches"]
            DSPCtrl["DataScience<br/>Pipelines"]
            ModelRegCtrl["Model<br/>Registry"]
            TrustyAICtrl["TrustyAI"]
            RayCtrl["Ray"]
            KueueCtrl["Kueue"]
            TrainingCtrl["Training<br/>Operator"]
            TrainerCtrl["Trainer"]
            FeastCtrl["Feast<br/>Operator"]
            LlamaCtrl["LlamaStack<br/>Operator"]
            MLflowCtrl["MLflow<br/>Operator"]
            SparkCtrl["Spark<br/>Operator"]
            ModelCtrlCtrl["Model<br/>Controller"]
            MaaSCtrl["ModelsAs<br/>Service"]
        end

        Webhooks["Webhook Server<br/>9443/TCP"]
    end

    subgraph CloudMgr["cloudmanager"]
        AzureCtrl["Azure AKS<br/>Controller"]
        CoreWeaveCtrl["CoreWeave<br/>Controller"]
    end

    %% CRDs
    DSCI_CR["DSCInitialization CR<br/>(Singleton)"]
    DSC_CR["DataScienceCluster CR<br/>(Singleton)"]
    ComponentCRs["Component CRs<br/>(Dashboard, KServe,<br/>Workbenches, etc.)"]
    ServiceCRs["Service CRs<br/>(Auth, GatewayConfig,<br/>Monitoring)"]

    %% External Dependencies
    K8sAPI["Kubernetes API<br/>443/TCP"]
    OLM["OLM<br/>Operator Lifecycle Manager"]

    %% Flows
    Admin["Admin / User"] -->|"creates"| DSCI_CR
    Admin -->|"creates"| DSC_CR
    DSCI_CR -->|"watched by"| DSCICtrl
    DSC_CR -->|"watched by"| DSCCtrl

    DSCICtrl -->|"creates"| ServiceCRs
    DSCCtrl -->|"creates/updates"| ComponentCRs

    ServiceCRs -->|"watched by"| GatewayCtrl
    ServiceCRs -->|"watched by"| AuthCtrl
    ServiceCRs -->|"watched by"| MonitoringCtrl

    ComponentCRs -->|"watched by"| ComponentControllers

    DSCCtrl -->|"SSA applies"| K8sAPI
    DSCICtrl -->|"SSA applies"| K8sAPI

    Webhooks -->|"validates/mutates"| DSC_CR
    Webhooks -->|"validates/mutates"| DSCI_CR

    OLM -->|"manages"| Operator

    %% Cloud Manager flows
    AzureCtrl -->|"Helm deploys"| K8sAPI
    CoreWeaveCtrl -->|"Helm deploys"| K8sAPI

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CloudMgr fill:#6c5ce7,stroke:#333,stroke-width:2px,color:#fff
    style CoreControllers fill:#74b9ff,stroke:#333
    style ServiceControllers fill:#81ecec,stroke:#333
    style ComponentControllers fill:#a29bfe,stroke:#333
    style DSCI_CR fill:#f5a623,stroke:#333
    style DSC_CR fill:#f5a623,stroke:#333
    style ComponentCRs fill:#f5a623,stroke:#333
    style ServiceCRs fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style OLM fill:#e8e8e8,stroke:#333
    style Admin fill:#7ed321,stroke:#333
    style Webhooks fill:#fd79a8,stroke:#333
