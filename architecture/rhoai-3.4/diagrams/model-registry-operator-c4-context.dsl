// C4 Context Diagram - Model Registry Operator
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.4/model-registry-operator.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages model registry instances"
        admin = person "Platform Admin" "Deploys and configures the operator"

        modelRegistryOperator = softwareSystem "Model Registry Operator" "Manages lifecycle of Model Registry and Model Catalog instances on OpenShift/Kubernetes" {
            operatorManager = container "Operator Manager" "Main entry point; initializes controller-runtime manager" "Go Application"
            mrReconciler = container "ModelRegistryReconciler" "Reconciles ModelRegistry CRs; provisions registry stacks" "Go Controller"
            mcReconciler = container "ModelCatalogReconciler" "Manages singleton Model Catalog instance" "Go Controller"
            storageMigration = container "StorageMigrationManager" "Monitors and executes CRD storage version migrations" "Go Component"
            webhookServer = container "Webhook Server" "Mutating and validating webhooks for ModelRegistry CR" "Admission Webhook"
        }

        registryInstance = softwareSystem "Model Registry Instance" "REST API + PostgreSQL + kube-rbac-proxy per registry" "Managed"
        catalogInstance = softwareSystem "Model Catalog Instance" "Curated catalog of AI/ML models" "Managed"

        // External Dependencies
        k8sApi = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        openShiftRouter = softwareSystem "OpenShift Router" "Ingress controller for Route resources" "External"
        servingCertCtrl = softwareSystem "OpenShift Serving Cert Controller" "Auto-provisions TLS certificates" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        postgresql = softwareSystem "PostgreSQL 16" "Backend database for model metadata" "External"
        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Authentication sidecar using SubjectAccessReview" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys this operator via Kustomize overlays" "Internal ODH"
        platformAuthCR = softwareSystem "Platform Auth CR" "Provides admin groups for catalog RBAC" "Internal ODH"
        platformModelRegCR = softwareSystem "Platform ModelRegistry CR" "Component CR for catalog reconciliation" "Internal ODH"
        modelRegistryImage = softwareSystem "Model Registry REST Service" "REST API server image deployed per CR" "Internal ODH"
        metadataCollection = softwareSystem "odh-model-metadata-collection" "Init container for catalog/benchmark data" "Internal ODH"

        // Relationships - Users
        admin -> rhodsOperator "Deploys operator"
        user -> registryInstance "Accesses model registry REST API" "HTTPS/443"
        user -> catalogInstance "Browses model catalog" "HTTPS/443"

        // Relationships - Operator Internal
        operatorManager -> mrReconciler "Starts controller"
        operatorManager -> mcReconciler "Starts controller"
        operatorManager -> storageMigration "Starts migration manager"
        operatorManager -> webhookServer "Starts webhook server"

        // Relationships - Operator to External
        mrReconciler -> k8sApi "Reconciles resources (Deployments, Services, Routes, RBAC, NetworkPolicies)" "HTTPS/443"
        mcReconciler -> k8sApi "Creates catalog stack resources" "HTTPS/443"
        webhookServer -> k8sApi "Receives admission requests" "HTTPS/9443"
        storageMigration -> k8sApi "Manages StorageVersionMigration resources" "HTTPS/443"

        // Relationships - Managed instances
        mrReconciler -> registryInstance "Creates and manages"
        mcReconciler -> catalogInstance "Creates and manages"
        registryInstance -> postgresql "Stores model metadata" "PostgreSQL/5432"
        registryInstance -> kubeRbacProxy "Auth sidecar" "HTTPS/8443"
        catalogInstance -> postgresql "Stores catalog data" "PostgreSQL/5432"

        // Relationships - Platform
        rhodsOperator -> modelRegistryOperator "Deploys via Kustomize" "Kustomize overlays"
        openShiftRouter -> registryInstance "Routes external traffic" "HTTPS reencrypt/443"
        openShiftRouter -> catalogInstance "Routes external traffic" "HTTPS reencrypt/443"
        servingCertCtrl -> modelRegistryOperator "Provisions TLS certificates"
        prometheus -> modelRegistryOperator "Scrapes metrics" "HTTPS/8443"
        mcReconciler -> platformAuthCR "Reads admin groups" "HTTPS/443"
        mcReconciler -> platformModelRegCR "Watches component CR" "HTTPS/443"
        registryInstance -> modelRegistryImage "Runs REST server image"
        catalogInstance -> metadataCollection "Init container data"
    }

    views {
        systemContext modelRegistryOperator "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistryOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
