graph LR
    DataImage["Data Container Image<br/>(Init Container)<br/>odh-model-performance-data-rhel9"]
    KafkaProc["Kafka Processor<br/>(Build-Time Python CLI)"]

    %% Internal RHOAI Dependencies
    DataImage -->|"init container<br/>volume mount"| ModelCatalog["model-catalog"]
    ModelRegistryOp["model-registry-operator"] -->|"manages deployment<br/>injects init container"| DataImage

    %% Build-Time External Dependencies
    KafkaProc -->|"consume messages<br/>Kafka/9096 SASL_SSL"| KafkaBroker["Kafka Broker"]

    %% Python Library Dependencies (Build-Time)
    KafkaProc -->|"Kafka client"| ConfluentKafka["confluent-kafka<br/>>=2.11.1"]
    KafkaProc -->|"compression"| LZ4["lz4<br/>>=4.4.4"]
    KafkaProc -->|"env config"| PythonDotenv["python-dotenv<br/>>=1.1.1"]
    ConfluentKafka -->|"native lib"| LibRDKafka["librdkafka<br/>(C library)"]

    %% Build Infrastructure
    KafkaProc -->|"produces data/"| DataDir["data/ directory"]
    DataDir -->|"COPY into image"| DataImage

    %% Container Base
    DataImage -->|"base image"| UBI9["UBI9-minimal<br/>FIPS compliant"]

    %% Styling
    style DataImage fill:#7ed321,stroke:#333,stroke-width:4px,color:#fff
    style KafkaProc fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff
    style ModelCatalog fill:#7ed321,stroke:#333,color:#fff
    style ModelRegistryOp fill:#7ed321,stroke:#333,color:#fff
    style KafkaBroker fill:#f5a623,stroke:#333,color:#fff
    style ConfluentKafka fill:#999,stroke:#333,color:#fff
    style LZ4 fill:#999,stroke:#333,color:#fff
    style PythonDotenv fill:#999,stroke:#333,color:#fff
    style LibRDKafka fill:#999,stroke:#333,color:#fff
    style DataDir fill:#f5a623,stroke:#333,color:#fff
    style UBI9 fill:#999,stroke:#333,color:#fff
