graph LR
    MLflow["MLflow Server<br/>(v3.10.1+rhaiv.3)"]

    %% Internal RHOAI Dependencies
    MLflow -->|"deployment mgmt<br/>HTTPRoute, sidecar"| RHODSOperator["rhods-operator"]
    MLflow -->|"auth proxy<br/>8443→5000"| KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"]
    MLflow -->|"ingress routing<br/>HTTPRoute ref"| PlatformGateway["Platform Gateway<br/>(Envoy)"]

    %% External Service Dependencies
    MLflow -->|"tracking store<br/>SQL/5432 TLS"| PostgreSQL["PostgreSQL 13+"]
    MLflow -->|"artifact storage<br/>S3 API/443"| S3["S3-Compatible Storage<br/>(MinIO/Ceph)"]
    MLflow -.->|"artifact storage<br/>HTTPS/443"| Azure["Azure Blob Storage"]
    MLflow -.->|"artifact storage<br/>HTTPS/443"| GCS["Google Cloud Storage"]
    MLflow -->|"token validation<br/>HTTPS/6443"| K8sAPI["Kubernetes API Server"]
    MLflow -->|"OAuth validation"| OpenShiftOAuth["OpenShift OAuth"]

    %% Observability
    MLflow -.->|"traces<br/>OTLP/4317"| OTel["OpenTelemetry Collector"]
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>HTTP/5000"| MLflow

    %% Framework Dependencies
    subgraph Frameworks["Runtime Frameworks"]
        Flask["Flask <4"]
        FastAPI["FastAPI <1"]
        SQLAlchemy["SQLAlchemy<br/>>=1.4, <3"]
        Gunicorn["Gunicorn <26"]
    end

    MLflow -->|"WSGI"| Flask
    MLflow -->|"ASGI"| FastAPI
    MLflow -->|"ORM"| SQLAlchemy
    MLflow -->|"HTTP server"| Gunicorn

    %% Crypto Dependencies
    subgraph CryptoStack["Crypto Stack"]
        CryptoLib["cryptography<br/>>=43, <47"]
        OpenSSL["OpenSSL<br/>(UBI 9 system)"]
    end

    MLflow -->|"AES-256-GCM<br/>PBKDF2"| CryptoLib
    CryptoLib -->|"FIPS backend"| OpenSSL

    %% Build-time Dependencies
    subgraph BuildTime["Build-Time Only"]
        NodeJS["Node.js 20.x"]
        Yarn["Yarn Berry 4.x"]
        Hermeto["Hermeto (cachi2)"]
    end

    MLflow -.->|"UI build"| NodeJS
    NodeJS -.->|"deps"| Yarn
    MLflow -.->|"hermetic build"| Hermeto

    %% Runtime
    subgraph Runtime["Runtime"]
        Python["Python 3.12"]
        UBI9["UBI 9 Minimal"]
    end

    MLflow -->|"interpreter"| Python
    Python -->|"base image"| UBI9

