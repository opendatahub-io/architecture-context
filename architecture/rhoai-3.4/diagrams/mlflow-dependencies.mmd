graph LR
    MLflow["MLflow<br/>Tracking Server"]

    %% External Dependencies (Required)
    MLflow -->|"backend store<br/>5432/TCP"| PostgreSQL["PostgreSQL<br/>(Required)"]
    MLflow -->|"auth, namespace,<br/>config reads<br/>6443/TCP"| K8sAPI["Kubernetes API<br/>v1 (Required)"]
    MLflow -->|"runtime<br/>interpreter"| Python["Python 3.12<br/>(Required)"]
    MLflow -->|"cryptographic<br/>operations"| OpenSSL["OpenSSL<br/>UBI9 system (Required)"]

    %% External Dependencies (Optional)
    MLflow -.->|"artifact storage<br/>443/TCP"| S3["S3-compatible<br/>Storage"]
    MLflow -.->|"artifact storage<br/>443/TCP"| GCS["Google Cloud<br/>Storage"]
    MLflow -.->|"artifact storage<br/>443/TCP"| Azure["Azure Blob<br/>Storage"]

    %% Internal Platform Dependencies
    RHOAIGateway["RHOAI Data Science<br/>Gateway"] -->|"HTTPRoute /mlflow<br/>443→5000"| MLflow
    MLflowOperator["MLflow Operator"] -->|"Helm deploy<br/>lifecycle mgmt"| MLflow
    MLflow -->|"namespace→workspace<br/>mapping"| K8sNamespace["Kubernetes<br/>Namespaces"]
    MLflow -->|"per-namespace<br/>artifact config"| MLflowConfigCR["MLflowConfig CR"]
    KubeRBACProxy["kube-rbac-proxy<br/>(sidecar)"] -->|"TLS termination<br/>auth enforcement"| MLflow

    %% Integration Points (consumers)
    Prometheus["Prometheus"] -.->|"metrics scrape<br/>/metrics"| MLflow
    OTelCollector["OpenTelemetry<br/>Collectors"] -.->|"OTLP/HTTP<br/>/v1/traces"| MLflow

    %% Styling
    style MLflow fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% Required external
    style PostgreSQL fill:#999,stroke:#333,color:#fff
    style K8sAPI fill:#999,stroke:#333,color:#fff
    style Python fill:#999,stroke:#333,color:#fff
    style OpenSSL fill:#999,stroke:#333,color:#fff

    %% Optional external
    style S3 fill:#f5a623,stroke:#333,color:#fff
    style GCS fill:#f5a623,stroke:#333,color:#fff
    style Azure fill:#f5a623,stroke:#333,color:#fff

    %% Internal RHOAI
    style RHOAIGateway fill:#7ed321,stroke:#333,color:#fff
    style MLflowOperator fill:#7ed321,stroke:#333,color:#fff
    style K8sNamespace fill:#7ed321,stroke:#333,color:#fff
    style MLflowConfigCR fill:#7ed321,stroke:#333,color:#fff
    style KubeRBACProxy fill:#7ed321,stroke:#333,color:#fff

    %% Consumers
    style Prometheus fill:#e8e8e8,stroke:#333
    style OTelCollector fill:#e8e8e8,stroke:#333
