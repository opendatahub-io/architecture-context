graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ml-pipeline"]
        SA_SW["ml-pipeline-scheduledworkflow"]
        SA_PA["ml-pipeline-persistenceagent"]
    end

    subgraph RoleBindings["Role Bindings (namespace-scoped)"]
        RB_API["ml-pipeline<br/>RoleBinding"]
        RB_SW["ml-pipeline-scheduledworkflow<br/>RoleBinding"]
        RB_PA["ml-pipeline-persistenceagent<br/>RoleBinding"]
    end

    subgraph Roles["Roles (namespace-scoped)"]
        R_API["ml-pipeline<br/>Role"]
        R_SW["ml-pipeline-scheduledworkflow<br/>Role"]
        R_PA["ml-pipeline-persistenceagent<br/>Role"]
    end

    subgraph Resources_API["API Server Resources"]
        Pods["core<br/>pods, pods/log<br/><i>get, list, delete</i>"]
        Workflows_API["argoproj.io<br/>workflows<br/><i>create, get, list, watch,<br/>update, patch, delete</i>"]
        SWF_API["kubeflow.org<br/>scheduledworkflows<br/><i>create, get, list,<br/>update, patch, delete</i>"]
        SWF_Fin["kubeflow.org<br/>scheduledworkflows/finalizers<br/><i>update</i>"]
        Pipelines_API["pipelines.kubeflow.org<br/>pipelines<br/><i>get, list, watch</i>"]
        SAR["authorization.k8s.io<br/>subjectaccessreviews<br/><i>create</i>"]
        TR["authentication.k8s.io<br/>tokenreviews<br/><i>create</i>"]
    end

    subgraph Resources_SW["Scheduled Workflow Resources"]
        SWF_SW["kubeflow.org<br/>scheduledworkflows<br/><i>get, list, watch, update</i>"]
        Workflows_SW["argoproj.io<br/>workflows<br/><i>get, list, watch, create</i>"]
        Events_SW["core<br/>events<br/><i>create, patch</i>"]
    end

    subgraph Resources_PA["Persistence Agent Resources"]
        SWF_PA["kubeflow.org<br/>scheduledworkflows<br/><i>get, list, watch</i>"]
        Workflows_PA["argoproj.io<br/>workflows<br/><i>get, list, watch</i>"]
    end

    %% Bindings
    SA_API -->|"bound via"| RB_API
    SA_SW -->|"bound via"| RB_SW
    SA_PA -->|"bound via"| RB_PA

    RB_API -->|"grants"| R_API
    RB_SW -->|"grants"| R_SW
    RB_PA -->|"grants"| R_PA

    %% API Server permissions
    R_API -->|"access"| Pods
    R_API -->|"access"| Workflows_API
    R_API -->|"access"| SWF_API
    R_API -->|"access"| SWF_Fin
    R_API -->|"access"| Pipelines_API
    R_API -->|"access"| SAR
    R_API -->|"access"| TR

    %% Scheduled Workflow permissions
    R_SW -->|"access"| SWF_SW
    R_SW -->|"access"| Workflows_SW
    R_SW -->|"access"| Events_SW

    %% Persistence Agent permissions
    R_PA -->|"access"| SWF_PA
    R_PA -->|"access"| Workflows_PA

    %% Styling
    style SA_API fill:#4a90e2,color:#fff
    style SA_SW fill:#4a90e2,color:#fff
    style SA_PA fill:#4a90e2,color:#fff
    style RB_API fill:#74b9ff,color:#fff
    style RB_SW fill:#74b9ff,color:#fff
    style RB_PA fill:#74b9ff,color:#fff
    style R_API fill:#f5a623,color:#fff
    style R_SW fill:#f5a623,color:#fff
    style R_PA fill:#f5a623,color:#fff
    style Pods fill:#7ed321,color:#fff
    style Workflows_API fill:#7ed321,color:#fff
    style SWF_API fill:#7ed321,color:#fff
    style SWF_Fin fill:#7ed321,color:#fff
    style Pipelines_API fill:#7ed321,color:#fff
    style SAR fill:#e74c3c,color:#fff
    style TR fill:#e74c3c,color:#fff
    style SWF_SW fill:#7ed321,color:#fff
    style Workflows_SW fill:#7ed321,color:#fff
    style Events_SW fill:#7ed321,color:#fff
    style SWF_PA fill:#7ed321,color:#fff
    style Workflows_PA fill:#7ed321,color:#fff
