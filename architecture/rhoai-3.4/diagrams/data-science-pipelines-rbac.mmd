graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_API["ml-pipeline"]
        SA_SW["ml-pipeline-scheduledworkflow"]
        SA_PA["ml-pipeline-persistenceagent"]
        SA_Cache["kubeflow-pipelines-cache"]
        SA_Runner["pipeline-runner"]
    end

    subgraph Bindings["ClusterRole Bindings"]
        CRB_API["ml-pipeline<br/>(binding)"]
        CRB_SW["ml-pipeline-scheduledworkflow<br/>-binding"]
        CRB_PA["ml-pipeline-persistenceagent<br/>-binding"]
        CRB_Cache["kubeflow-pipelines-cache<br/>-binding"]
        CRB_Runner["pipeline-runner<br/>-binding"]
    end

    subgraph Roles["ClusterRoles"]
        CR_API["ml-pipeline"]
        CR_SW["ml-pipeline-scheduledworkflow-role"]
        CR_PA["ml-pipeline-persistenceagent-role"]
        CR_Cache["kubeflow-pipelines-cache-role"]
        CR_Runner["pipeline-runner"]
    end

    subgraph Resources_API["API Server Resources"]
        R_Pods["core: pods, pods/log<br/>get, list, delete"]
        R_Workflows_API["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SW_API["kubeflow.org: scheduledworkflows<br/>+ finalizers<br/>create, get, list, update,<br/>patch, delete"]
        R_Pipelines_API["pipelines.kubeflow.org: pipelines<br/>get, list, watch"]
        R_SAR["authorization.k8s.io:<br/>subjectaccessreviews<br/>create"]
        R_TR["authentication.k8s.io:<br/>tokenreviews<br/>create"]
    end

    subgraph Resources_SW["Scheduled Workflow Resources"]
        R_Workflows_SW["argoproj.io: workflows<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_SW_SW["kubeflow.org: scheduledworkflows<br/>+ finalizers<br/>create, get, list, watch,<br/>update, patch, delete"]
        R_Runs_SW["pipelines.kubeflow.org: runs<br/>create"]
        R_Events["core: events<br/>create, patch"]
    end

    subgraph Resources_PA["Persistence Agent Resources"]
        R_Workflows_PA["argoproj.io: workflows<br/>get, list, watch"]
        R_SW_PA["kubeflow.org: scheduledworkflows<br/>get, list, watch"]
        R_Report["pipelines.kubeflow.org:<br/>scheduledworkflows, workflows<br/>report"]
        R_RunMetrics["pipelines.kubeflow.org: runs<br/>reportMetrics, readArtifact"]
    end

    subgraph Resources_Cache["Cache Server Resources"]
        R_Pods_Cache["core: pods<br/>get, list, watch, update, patch"]
        R_CM_Cache["core: configmaps<br/>get"]
        R_WF_Cache["argoproj.io: workflows<br/>get, list, watch, update, patch"]
    end

    subgraph Resources_Runner["Pipeline Runner Resources (BROAD)"]
        R_Secrets["core: secrets<br/>get"]
        R_CM_Runner["core: configmaps<br/>get, watch, list"]
        R_PV["core: persistentvolumes,<br/>persistentvolumeclaims<br/>* (all verbs)"]
        R_PodsExec["core: pods, pods/exec,<br/>pods/log, services<br/>* (all verbs)"]
        R_Apps["apps, extensions:<br/>deployments, replicasets<br/>* (all verbs)"]
        R_ArgoRunner["argoproj.io: workflows<br/>get, list, watch, update, patch"]
        R_TaskResults["argoproj.io: workflowtaskresults<br/>create, patch"]
        R_KF["kubeflow.org: *<br/>* (all verbs) ⚠️ WILDCARD"]
        R_Batch["batch: jobs<br/>* (all verbs)"]
        R_Snap["snapshot.storage.k8s.io:<br/>volumesnapshots<br/>create, delete, get"]
    end

    %% SA → Binding → Role
    SA_API -->|bound via| CRB_API
    CRB_API -->|grants| CR_API

    SA_SW -->|bound via| CRB_SW
    CRB_SW -->|grants| CR_SW

    SA_PA -->|bound via| CRB_PA
    CRB_PA -->|grants| CR_PA

    SA_Cache -->|bound via| CRB_Cache
    CRB_Cache -->|grants| CR_Cache

    SA_Runner -->|bound via| CRB_Runner
    CRB_Runner -->|grants| CR_Runner

    %% Role → Resources
    CR_API -->|permits| R_Pods
    CR_API -->|permits| R_Workflows_API
    CR_API -->|permits| R_SW_API
    CR_API -->|permits| R_Pipelines_API
    CR_API -->|permits| R_SAR
    CR_API -->|permits| R_TR

    CR_SW -->|permits| R_Workflows_SW
    CR_SW -->|permits| R_SW_SW
    CR_SW -->|permits| R_Runs_SW
    CR_SW -->|permits| R_Events

    CR_PA -->|permits| R_Workflows_PA
    CR_PA -->|permits| R_SW_PA
    CR_PA -->|permits| R_Report
    CR_PA -->|permits| R_RunMetrics

    CR_Cache -->|permits| R_Pods_Cache
    CR_Cache -->|permits| R_CM_Cache
    CR_Cache -->|permits| R_WF_Cache

    CR_Runner -->|permits| R_Secrets
    CR_Runner -->|permits| R_CM_Runner
    CR_Runner -->|permits| R_PV
    CR_Runner -->|permits| R_PodsExec
    CR_Runner -->|permits| R_Apps
    CR_Runner -->|permits| R_ArgoRunner
    CR_Runner -->|permits| R_TaskResults
    CR_Runner -->|permits| R_KF
    CR_Runner -->|permits| R_Batch
    CR_Runner -->|permits| R_Snap

