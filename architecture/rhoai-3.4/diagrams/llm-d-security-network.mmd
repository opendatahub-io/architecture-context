graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Gateway API<br/>(Istio / AgentGateway)<br/>80/TCP HTTP<br/>Auth: Provider-specific"]
    end

    subgraph Routing["ROUTING LAYER (Plaintext)"]
        direction TB
        EPP["llm-d Inference Scheduler<br/>(EPP v0.8.0)<br/>8081/TCP HTTP ExtProc<br/>9090/TCP Metrics"]
        Sidecar["Routing Sidecar v0.7.1<br/>8000/TCP → 8200/TCP<br/>P/D coordination"]
    end

    subgraph ModelServers["MODEL SERVER LAYER (Plaintext)"]
        direction TB

        subgraph PrefillPods["Prefill Pods"]
            PrefillVLLM["vLLM Prefill<br/>8000/TCP HTTP API<br/>5600/TCP NIXL RDMA<br/>SA: sa (no token mount)"]
        end

        subgraph DecodePods["Decode Pods"]
            DecodeVLLM["vLLM Decode<br/>8000/8200 TCP HTTP API<br/>5600/TCP NIXL RDMA<br/>5556/TCP ZMQ Events<br/>SA: sa (no token mount)"]
        end

        subgraph WideEP["Wide-EP Pods (LWS)"]
            Leader["LWS Leader<br/>5555/TCP gRPC DP-RPC"]
            Workers["LWS Workers<br/>InfiniBand RDMA<br/>NVSHMEM/NCCL"]
        end
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>PodMonitor scrape"]
        OTel["OpenTelemetry Collector<br/>4317/TCP gRPC OTLP"]
        WVA["WVA<br/>8443/TCP HTTPS TLS<br/>Autoscaling"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer HF_TOKEN"]
    end

    %% Client → Gateway
    Client -->|"HTTP/80<br/>No encryption<br/>Provider auth"| Gateway

    %% Gateway → EPP
    Gateway -->|"HTTP/8081<br/>ExtProc<br/>No encryption"| EPP

    %% EPP → Sidecar/Model Server
    EPP -->|"HTTP/8000<br/>No encryption<br/>No auth"| Sidecar
    EPP -->|"HTTP/8000<br/>No encryption<br/>No auth"| DecodeVLLM

    %% Sidecar → vLLM
    Sidecar -->|"HTTP/8200<br/>No encryption"| DecodeVLLM
    Sidecar -->|"HTTP/8000<br/>No encryption"| PrefillVLLM

    %% KV-cache transfers
    PrefillVLLM <-->|"RDMA/TCP 5600<br/>NIXL<br/>No encryption"| DecodeVLLM

    %% Wide-EP coordination
    Leader <-->|"gRPC/5555<br/>DP-RPC<br/>No encryption"| Workers
    Workers <-->|"InfiniBand RDMA<br/>NVSHMEM<br/>No encryption"| Workers

    %% Monitoring
    DecodeVLLM -.->|"HTTP/8000<br/>/metrics"| Prometheus
    PrefillVLLM -.->|"HTTP/8000<br/>/metrics"| Prometheus
    EPP -.->|"HTTP/9090<br/>/metrics"| Prometheus
    WVA -.->|"HTTPS/8443<br/>TLS"| Prometheus
    DecodeVLLM -.->|"gRPC/4317<br/>OTLP traces"| OTel

    %% External
    DecodeVLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub
    PrefillVLLM -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer HF_TOKEN"| HFHub

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef routing fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelserver fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway ingress
    class EPP,Sidecar routing
    class PrefillVLLM,DecodeVLLM,Leader,Workers modelserver
    class Prometheus,OTel,WVA monitoring
    class HFHub externalservice
