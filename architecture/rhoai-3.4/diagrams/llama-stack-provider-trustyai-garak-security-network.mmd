graph TB
    subgraph HostProcess["HOST PROCESS (Llama Stack Server / EvalHub K8s Job)"]
        direction TB

        subgraph ProviderLib["llama-stack-provider-trustyai-garak (Python Provider)"]
            direction LR

            subgraph InlineMode["Inline Mode"]
                GarakSubprocess["Garak Subprocess<br/>Local process I/O"]
            end

            subgraph RemoteMode["Remote Mode"]
                KFPClient["KFP Client<br/>Pipeline submission"]
            end

            subgraph EvalHubMode["EvalHub Mode"]
                FrameworkAdapter["FrameworkAdapter<br/>K8s Job"]
            end

            subgraph SafetyMode["Shield Scan"]
                ShieldOrch["SimpleShieldOrchestrator<br/>Input/Output shields"]
            end
        end
    end

    subgraph LlamaStackAPIs["LLAMA STACK APIs (Internal/Configurable)"]
        FilesAPI["Files API<br/>Configurable port<br/>HTTPS/HTTP<br/>TLS (configurable via tls_verify)<br/>Auth: API key (multi-level)"]
        InferenceAPI["Inference API<br/>Configurable port<br/>HTTPS/HTTP<br/>TLS (configurable)<br/>Auth: API key"]
        SafetyAPI["Safety API<br/>Configurable port<br/>HTTPS/HTTP<br/>TLS (configurable)<br/>Auth: API key"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        KFPApi["Kubeflow Pipelines API<br/>Configurable port<br/>HTTPS<br/>TLS<br/>Auth: Bearer token<br/>(config or SA token)"]
        TargetLLM["Target LLM (Under Test)<br/>Configurable port<br/>HTTPS (OpenAI-compatible)<br/>TLS<br/>Auth: API key"]
        S3["S3-compatible Storage<br/>443/TCP<br/>HTTPS<br/>TLS<br/>Auth: AWS IAM<br/>(access key + secret key)"]
        HuggingFace["HuggingFace Hub<br/>443/TCP<br/>HTTPS<br/>TLS<br/>Auth: HF token (optional)"]
        SDGModel["SDG Model API<br/>Configurable port<br/>HTTPS<br/>TLS (configurable)<br/>Auth: API key"]
    end

    subgraph K8sResources["KUBERNETES RESOURCES"]
        ConfigMap["trustyai-service-operator-config<br/>ConfigMap<br/>NS: redhat-ods-applications<br/>Key: garak-provider-image"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>PG wire protocol<br/>Optional TLS<br/>LS file storage backend"]
    end

    %% Flows from Provider to Llama Stack APIs
    ProviderLib -->|"HTTPS/HTTP<br/>TLS (configurable)<br/>API key"| FilesAPI
    ShieldOrch -->|"HTTPS/HTTP<br/>TLS (configurable)<br/>API key"| SafetyAPI
    ShieldOrch -->|"HTTPS/HTTP<br/>TLS (configurable)<br/>API key"| InferenceAPI

    %% Flows from Provider to External Services
    KFPClient -->|"HTTPS<br/>TLS<br/>Bearer token"| KFPApi
    FrameworkAdapter -->|"HTTPS<br/>TLS<br/>Bearer token"| KFPApi
    GarakSubprocess -->|"HTTPS<br/>TLS<br/>API key"| TargetLLM
    FrameworkAdapter -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    GarakSubprocess -->|"HTTPS/443<br/>TLS<br/>HF token"| HuggingFace
    ProviderLib -->|"HTTPS<br/>TLS<br/>API key"| SDGModel

    %% K8s Resources
    KFPClient -->|"K8s API<br/>ConfigMap read"| ConfigMap

    %% Styling
    classDef host fill:#e8f4fd,stroke:#4a90e2,stroke-width:3px
    classDef provider fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef llamastack fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef external fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef k8s fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class HostProcess host
    class ProviderLib,InlineMode,RemoteMode,EvalHubMode,SafetyMode provider
    class FilesAPI,InferenceAPI,SafetyAPI llamastack
    class KFPApi,TargetLLM,S3,HuggingFace,SDGModel external
    class ConfigMap,PostgreSQL k8s
