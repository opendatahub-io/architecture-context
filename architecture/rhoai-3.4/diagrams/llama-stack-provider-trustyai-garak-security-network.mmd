graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["Client / Data Scientist"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (K8s Network)"]
        direction TB

        subgraph NS_Garak["Namespace: tai-garak-lls"]
            direction TB

            LLSServer["Llama Stack Distribution Server<br/>ClusterIP: 8321/TCP<br/>SA: llamastack-garak-distribution-sa<br/>TLS: Configurable (tls_verify)"]

            subgraph ProviderProcess["Provider (in-process)"]
                InlineProvider["Inline Provider<br/>(subprocess exec)"]
                RemoteProvider["Remote Provider<br/>(KFP submission)"]
            end

            GarakSubprocess["Garak Subprocess<br/>os.setsid process group<br/>SIGTERM→SIGKILL timeout"]

            Postgres["PostgreSQL<br/>ClusterIP: 5432/TCP<br/>Auth: Password<br/>Encryption: plaintext"]
        end

        subgraph NS_KFP["KFP Namespace"]
            KFPAPI["KFP API Server<br/>443/TCP HTTPS<br/>Auth: Bearer Token"]
            KFPPods["KFP Pipeline Pods<br/>Image: odh-trustyai-garak-...<br/>Secrets: /mnt/model-auth"]
        end

        subgraph NS_EvalHub["Eval-Hub Namespace"]
            EvalHubJob["Eval-Hub K8s Job<br/>GarakAdapter"]
        end

        FilesAPI["Llama Stack Files API<br/>8321/TCP HTTP<br/>Auth: Bearer Token"]
        SafetyAPI["Llama Stack Safety API<br/>8321/TCP HTTP<br/>Auth: Bearer Token"]

        NetworkPolicy["NetworkPolicy:<br/>KFP pods → LLS:8321 ✓"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        vLLM["vLLM Inference Server<br/>443/TCP or 8000/TCP<br/>HTTPS (TLS via VLLM_TLS_VERIFY)<br/>Auth: API key (VLLM_API_TOKEN)"]
        S3["S3/MinIO Storage<br/>443/TCP or 9000/TCP<br/>HTTPS/HTTP TLS<br/>Auth: AWS IAM credentials"]
        SDGAPI["SDG API Endpoint<br/>Configurable port<br/>HTTP/HTTPS<br/>Auth: SDG_API_KEY"]
        MLflowSvc["MLflow<br/>Configurable<br/>HTTP/HTTPS<br/>Auth: Bearer Token"]
        OCIReg["OCI Registry<br/>443/TCP HTTPS TLS"]
    end

    %% External → Cluster
    Client -->|"HTTP/8321<br/>Configurable TLS<br/>Bearer Token"| LLSServer

    %% Internal routing
    LLSServer -->|"in-process<br/>provider registration"| ProviderProcess
    LLSServer -->|"PostgreSQL/5432<br/>plaintext<br/>Password auth"| Postgres
    InlineProvider -->|"subprocess<br/>os.setsid"| GarakSubprocess
    RemoteProvider -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| KFPAPI
    EvalHubJob -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| KFPAPI
    KFPAPI -->|"pod scheduling"| KFPPods

    %% Scan traffic
    GarakSubprocess -->|"HTTPS/443<br/>TLS<br/>API key"| vLLM
    KFPPods -->|"HTTPS/443<br/>TLS<br/>API key per role"| vLLM

    %% Artifact flows
    InlineProvider -->|"HTTP/8321<br/>Configurable TLS<br/>Bearer Token"| FilesAPI
    KFPPods -->|"HTTP/8321<br/>Configurable TLS<br/>Bearer Token"| FilesAPI
    KFPPods -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3
    EvalHubJob -->|"HTTPS/443<br/>TLS<br/>AWS IAM"| S3

    %% SDG + Safety
    KFPPods -->|"HTTP(S)<br/>Configurable<br/>API key"| SDGAPI
    InlineProvider -->|"HTTP/8321<br/>Bearer Token"| SafetyAPI

    %% Eval-Hub extras
    EvalHubJob -->|"HTTP(S)<br/>Bearer Token"| MLflowSvc
    EvalHubJob -->|"HTTPS/443<br/>TLS"| OCIReg

    %% NetworkPolicy annotation
    NetworkPolicy -.->|"allows"| KFPPods
    NetworkPolicy -.->|"to port 8321"| LLSServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef kfp fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef evalhub fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef security fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef netpol fill:#fff,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class LLSServer,InlineProvider,RemoteProvider,GarakSubprocess,Postgres,FilesAPI,SafetyAPI cluster
    class KFPAPI,KFPPods kfp
    class EvalHubJob evalhub
    class vLLM,S3,SDGAPI,MLflowSvc,OCIReg externalservice
    class NetworkPolicy netpol
