graph TB
    subgraph Orchestrator["FMS Guardrails Orchestrator"]
        OrchestratorSvc["Orchestrator Service<br/>Invokes detectors on<br/>text generation I/O"]
    end

    subgraph GuardrailsDetectors["Guardrails Detectors"]
        direction TB

        subgraph BuiltIn["odh-built-in-detector<br/>Port: 8080/TCP"]
            BuiltInAPI["FastAPI / uvicorn<br/>(4 workers)"]
            RegexReg["RegexDetectorRegistry<br/>PII: email, CC, SSN,<br/>phone, IP"]
            FileTypeReg["FileTypeDetectorRegistry<br/>JSON, XML, YAML<br/>+ schema validation"]
            CustomReg["CustomDetectorRegistry<br/>User Python functions<br/>(AST-checked)"]
            BuiltInAPI --> RegexReg
            BuiltInAPI --> FileTypeReg
            BuiltInAPI --> CustomReg
        end

        subgraph HFDetector["odh-guardrails-detector-huggingface-runtime<br/>Port: 8000/TCP"]
            HFAPI["FastAPI / uvicorn<br/>(1 worker)"]
            SeqClassifier["AutoModelForSequenceClassification<br/>Toxicity, content classifiers"]
            GraniteLM["GraniteForCausalLM<br/>Risk categories: harm, bias,<br/>jailbreak, profanity, etc."]
            HFAPI --> SeqClassifier
            HFAPI --> GraniteLM
        end

        subgraph JudgeDetector["guardrails-detector-llm-judge<br/>Port: 8000/TCP"]
            JudgeAPI["FastAPI / uvicorn<br/>(1 worker)"]
            VLLMJudge["vllm_judge Library<br/>Metrics: safety, toxicity,<br/>accuracy, helpfulness, clarity"]
            JudgeAPI --> VLLMJudge
        end
    end

    subgraph SharedFramework["Common Framework (detectors/common/)"]
        BaseAPI["DetectorBaseAPI"]
        Schemas["Pydantic Schemas<br/>IBM Detector API"]
        Instrumented["InstrumentedDetector<br/>trustyai_guardrails_* metrics"]
    end

    subgraph ExternalServices["External Services"]
        S3["S3/MinIO<br/>Model Storage<br/>9000/TCP"]
        vLLM["vLLM Server<br/>OpenAI-compatible<br/>8080/TCP"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS"]
    end

    subgraph Platform["Platform Infrastructure"]
        KServe["KServe<br/>InferenceService<br/>(RawDeployment)"]
        Istio["Istio Service Mesh<br/>mTLS STRICT"]
        Prometheus["Prometheus<br/>Metrics Scraping"]
    end

    %% Orchestrator calls detectors
    OrchestratorSvc -->|"POST /api/v1/text/contents<br/>Istio mTLS"| BuiltInAPI
    OrchestratorSvc -->|"POST /api/v1/text/contents<br/>Istio mTLS"| HFAPI
    OrchestratorSvc -->|"POST /api/v1/text/contents<br/>Istio mTLS"| JudgeAPI

    %% External dependencies
    HFDetector -->|"Model download<br/>AWS credentials"| S3
    HFDetector -.->|"Model download<br/>(init container)"| HFHub
    VLLMJudge -->|"LLM evaluation<br/>HTTP"| vLLM

    %% Platform dependencies
    KServe -->|hosts| BuiltIn
    KServe -->|hosts| HFDetector
    KServe -->|hosts| JudgeDetector
    Istio -->|mTLS sidecar| BuiltIn
    Istio -->|mTLS sidecar| HFDetector
    Istio -->|mTLS sidecar| JudgeDetector
    Prometheus -->|"scrape /metrics"| BuiltIn
    Prometheus -->|"scrape /metrics"| HFDetector
    Prometheus -->|"scrape /metrics"| JudgeDetector

    %% Shared framework
    BuiltInAPI -.->|extends| BaseAPI
    HFAPI -.->|extends| BaseAPI
    JudgeAPI -.->|extends| BaseAPI

    %% Styling
    style BuiltInAPI fill:#4a90e2,color:#fff
    style HFAPI fill:#4a90e2,color:#fff
    style JudgeAPI fill:#4a90e2,color:#fff
    style RegexReg fill:#7ed321,color:#fff
    style FileTypeReg fill:#7ed321,color:#fff
    style CustomReg fill:#7ed321,color:#fff
    style SeqClassifier fill:#f5a623,color:#fff
    style GraniteLM fill:#f5a623,color:#fff
    style VLLMJudge fill:#f5a623,color:#fff
    style S3 fill:#e8e8e8,stroke:#333
    style vLLM fill:#e8e8e8,stroke:#333
    style HFHub fill:#e8e8e8,stroke:#333
    style KServe fill:#ddd,stroke:#333
    style Istio fill:#ddd,stroke:#333
    style Prometheus fill:#ddd,stroke:#333
    style OrchestratorSvc fill:#9b59b6,color:#fff
