graph TB
    subgraph GuardrailsDetectors["Guardrails Detectors"]
        direction TB

        subgraph Common["Common Framework (detectors/common/)"]
            BaseAPI["DetectorBaseAPI<br/>FastAPI Base Class"]
            Schemas["API Schemas<br/>ContentAnalysisHttpRequest<br/>ContentsAnalysisResponse"]
            Instrumentation["Prometheus Instrumentation<br/>request_count, detection_count<br/>error_count, runtime_latency"]
            HealthEndpoint["/health Endpoint"]
        end

        subgraph BuiltIn["Built-in Detector (port 8080)"]
            direction TB
            BuiltInApp["app.py<br/>FastAPI + uvicorn (4 workers)"]
            RegexRegistry["RegexDetectorRegistry<br/>PII: email, credit card,<br/>SSN, phone, IP"]
            FileTypeRegistry["FileTypeDetectorRegistry<br/>JSON, XML, YAML<br/>+ optional schema validation"]
            CustomRegistry["CustomDetectorRegistry<br/>User-defined Python functions<br/>Static code analysis sandbox"]
            BuiltInApp --> RegexRegistry
            BuiltInApp --> FileTypeRegistry
            BuiltInApp --> CustomRegistry
        end

        subgraph HF["HuggingFace Detector (port 8000)"]
            direction TB
            HFApp["app.py<br/>FastAPI + uvicorn (1 worker)"]
            SeqClassifier["AutoModelForSequenceClassification<br/>Multi-label classification<br/>Configurable SAFE_LABELS"]
            GraniteLM["GraniteForCausalLM<br/>Generative safe/unsafe labels<br/>Log-probability scoring"]
            HFApp --> SeqClassifier
            HFApp --> GraniteLM
        end

        subgraph LLMJudge["LLM Judge Detector (port 8000)"]
            direction TB
            JudgeApp["app.py<br/>FastAPI + uvicorn"]
            VLLMJudgeLib["vllm_judge Library<br/>LLM-as-a-judge evaluation"]
            MetricsCatalog["Metrics Catalog<br/>safety, toxicity, accuracy"]
            JudgeApp --> VLLMJudgeLib
            JudgeApp --> MetricsCatalog
        end

        BuiltInApp -.->|extends| BaseAPI
        HFApp -.->|extends| BaseAPI
        JudgeApp -.->|extends| BaseAPI
    end

    Orchestrator["FMS Guardrails<br/>Orchestrator"] -->|POST /api/v1/text/contents<br/>8080/TCP| BuiltInApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| HFApp
    Orchestrator -->|POST /api/v1/text/contents<br/>8000/TCP| JudgeApp

    KServe["KServe<br/>InferenceService"] -->|manages lifecycle| HFApp
    KServe -->|manages lifecycle| JudgeApp

    S3["S3/MinIO<br/>Model Storage"] -->|model files<br/>9000/TCP| HFApp
    VLLMServer["vLLM Inference<br/>Server"] -->|LLM evaluation<br/>8080/TCP| JudgeApp

    Prometheus["Prometheus"] -->|scrapes /metrics| Instrumentation

    style BuiltInApp fill:#4a90e2,color:#fff
    style HFApp fill:#4a90e2,color:#fff
    style JudgeApp fill:#4a90e2,color:#fff
    style BaseAPI fill:#6c5ce7,color:#fff
    style Orchestrator fill:#00b894,color:#fff
    style KServe fill:#e8e8e8,stroke:#333
    style S3 fill:#f5a623,color:#fff
    style VLLMServer fill:#f5a623,color:#fff
    style Prometheus fill:#e8e8e8,stroke:#333
