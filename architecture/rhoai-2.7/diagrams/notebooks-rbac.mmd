graph TD
    subgraph "RBAC Overview - Managed by Notebook Controller"
        Note["⚠️ Notebook images do not define RBAC directly.<br/>Authorization is managed by the ODH/RHOAI Notebook Controller."]
    end

    subgraph "Notebook Controller Service Account"
        ControllerSA[notebook-controller-sa<br/>Namespace: rhods-notebooks / opendatahub]
    end

    subgraph "Controller Cluster Role Permissions"
        CR[notebook-controller-role<br/>ClusterRole]
    end

    subgraph "Per-Notebook Service Account"
        NotebookSA["{notebook-name}-sa<br/>Namespace: {user-namespace}<br/>Dynamically created"]
    end

    subgraph "API Resources - Controller Permissions"
        direction TB
        StatefulSets[apps/StatefulSets<br/>Create, Update, Delete, Get, List, Watch]
        Services[core/Services<br/>Create, Update, Delete, Get, List, Watch]
        ServiceAccounts[core/ServiceAccounts<br/>Create, Update, Delete, Get, List, Watch]
        PVCs[core/PersistentVolumeClaims<br/>Get, List, Watch]
        Routes[route.openshift.io/Routes<br/>Create, Update, Delete, Get, List, Watch]
        ConfigMaps[core/ConfigMaps<br/>Get, List, Watch]
    end

    subgraph "API Resources - Notebook Pod Permissions"
        direction TB
        DefaultPerms[Default Service Account Permissions<br/>- Read own namespace metadata<br/>- Token for API server authentication<br/>- Pod-level resource access]
        UserDefinedPerms[User-Defined RBAC<br/>Optional: Custom roles for cluster access<br/>Example: Read datasets, Create jobs, etc.]
    end

    subgraph "User Authorization"
        direction TB
        UserPolicy["Policy Enforcement:<br/>- User must own namespace OR<br/>- User has RBAC view permissions on namespace<br/><br/>Enforcement Point:<br/>- Notebook Controller validates OAuth token<br/>- Checks RBAC before proxying requests<br/><br/>Resources Protected:<br/>- /notebook/{namespace}/{username}/*"]
    end

    subgraph "Service Mesh Authorization"
        direction TB
        AuthZPolicy["AuthorizationPolicy: notebook-controller-access<br/>(if service mesh enabled)<br/><br/>Allows:<br/>- cluster.local/ns/{notebook-ns}/sa/notebook-controller-sa<br/><br/>Methods: GET, POST<br/>Resources: Notebook pod services (8888/TCP, 8787/TCP)"]
    end

    %% Relationships
    ControllerSA -->|bound to| CR
    CR -->|grants permissions| StatefulSets
    CR -->|grants permissions| Services
    CR -->|grants permissions| ServiceAccounts
    CR -->|grants permissions| PVCs
    CR -->|grants permissions| Routes
    CR -->|grants permissions| ConfigMaps

    ControllerSA -->|creates| NotebookSA
    NotebookSA -->|has| DefaultPerms
    NotebookSA -.->|optionally bound to| UserDefinedPerms

    ControllerSA -->|enforces| UserPolicy
    ControllerSA -->|subject to| AuthZPolicy

    %% Styling
    style Note fill:#fff2cc,stroke:#d6b656,stroke-width:3px,stroke-dasharray: 5 5
    style ControllerSA fill:#4a90e2,stroke:#333,stroke-width:3px
    style NotebookSA fill:#4a90e2,stroke:#333,stroke-width:3px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style StatefulSets fill:#7ed321,stroke:#333,stroke-width:1px
    style Services fill:#7ed321,stroke:#333,stroke-width:1px
    style ServiceAccounts fill:#7ed321,stroke:#333,stroke-width:1px
    style PVCs fill:#7ed321,stroke:#333,stroke-width:1px
    style Routes fill:#7ed321,stroke:#333,stroke-width:1px
    style ConfigMaps fill:#7ed321,stroke:#333,stroke-width:1px
    style DefaultPerms fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style UserDefinedPerms fill:#d5e8d4,stroke:#82b366,stroke-width:2px,stroke-dasharray: 5 5
    style UserPolicy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style AuthZPolicy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
