graph TB
    subgraph External["EXTERNAL - Untrusted"]
        User[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS - DMZ"]
        Router["OpenShift Router<br/>Route: notebook-route-{username}<br/>443/TCP → 8080/TCP<br/>TLS 1.2+ Edge Termination<br/>Cert: {notebook-name}-notebook-tls"]
    end

    subgraph ServiceMesh["SERVICE MESH - mTLS STRICT if enabled"]
        direction TB

        subgraph NS_NotebookController["Namespace: rhods-notebooks / opendatahub"]
            Controller["Notebook Controller Service<br/>SA: notebook-controller-sa<br/>Port: 8080/TCP<br/>Function: OAuth validation, RBAC, proxy"]
        end

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            Service["Notebook Pod Service - ClusterIP<br/>jupyter: 8888/TCP<br/>rstudio: 8787/TCP<br/>code-server: 8888/TCP"]

            Pod["Notebook Pod - StatefulSet<br/>SA: {notebook-name}-sa<br/>Image: quay.io/.../workbench-images/{variant}<br/>Security: RunAsUser:1001, FSGroup:0<br/>Resources: CPU 500m, Memory 2Gi<br/>PVC: Optional at /opt/app-root/src"]

            Service -->|HTTP<br/>localhost<br/>No encryption<br/>Token disabled| Pod
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        subgraph PackageRepos["Package Repositories"]
            PyPI["PyPI<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
            CRAN["CRAN<br/>cran.rstudio.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        end

        subgraph Registries["Container Registries"]
            Quay["Quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth"]
        end

        subgraph DataStorage["Data & Storage"]
            S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM SigV4"]
            PostgreSQL["PostgreSQL<br/>5432/TCP<br/>TLS optional<br/>Password auth"]
            MySQL["MySQL<br/>3306/TCP<br/>TLS optional<br/>Password auth"]
            MongoDB["MongoDB<br/>27017/TCP<br/>TLS optional<br/>Password auth"]
        end

        subgraph Messaging["Streaming & Messaging"]
            Kafka["Kafka Brokers<br/>9092/TCP - plain<br/>9093/TCP - SSL<br/>TLS 1.2+<br/>SASL auth"]
        end

        subgraph VCS["Version Control & Tools"]
            GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS, 22/TCP SSH<br/>TLS 1.2+ / SSH<br/>Token / SSH key"]
            Mirror["OpenShift Mirror<br/>mirror.openshift.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        end
    end

    %% User flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Bearer Token| Router
    Router -->|HTTP/8080<br/>mTLS STRICT<br/>if service mesh enabled<br/>Service Account Token| Controller
    Controller -->|HTTP/8888 or 8787<br/>mTLS if enabled<br/>No auth - internal| Service

    %% Egress flows
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| PyPI
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| CRAN
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>Token| Quay
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Pod -->|PostgreSQL/5432<br/>TLS optional<br/>Password| PostgreSQL
    Pod -->|MySQL/3306<br/>TLS optional<br/>Password| MySQL
    Pod -->|MongoDB/27017<br/>TLS optional<br/>Password| MongoDB
    Pod -->|Kafka/9093<br/>TLS 1.2+<br/>SASL| Kafka
    Pod -->|HTTPS/443, SSH/22<br/>TLS / SSH<br/>Token / SSH key| GitHub
    Pod -->|HTTPS/443<br/>TLS 1.2+<br/>No auth| Mirror

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef servicemesh fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef messaging fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Router ingress
    class Controller,Service,Pod servicemesh
    class PyPI,CRAN,Quay,Mirror externalservice
    class S3,PostgreSQL,MySQL,MongoDB storage
    class Kafka messaging
    class GitHub externalservice
