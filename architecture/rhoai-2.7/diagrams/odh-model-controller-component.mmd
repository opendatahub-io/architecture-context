graph TB
    subgraph "ODH Model Controller (3 replicas, leader election)"
        Manager[Manager Deployment]
        ISVCController[InferenceService Controller]
        KServeRecon[KServe Reconciler]
        ModelMeshRecon[ModelMesh Reconciler]
        MonitoringController[Monitoring Controller]
        StorageController[Storage Secret Controller]

        Manager -->|reconciles| ISVCController
        ISVCController -->|KServe mode| KServeRecon
        ISVCController -->|ModelMesh mode| ModelMeshRecon
        Manager -->|manages| MonitoringController
        Manager -->|manages| StorageController

        subgraph "Resource Managers"
            RouteRecon[Route Reconciler]
            NPRecon[Network Policy Reconciler]
            PeerAuthRecon[PeerAuthentication Reconciler]
            TelemetryRecon[Telemetry Reconciler]
            SMRecon[ServiceMonitor Reconciler]
        end

        KServeRecon -->|creates| RouteRecon
        KServeRecon -->|creates| NPRecon
        KServeRecon -->|creates| PeerAuthRecon
        KServeRecon -->|creates| TelemetryRecon
        KServeRecon -->|creates| SMRecon
        ModelMeshRecon -->|creates| RouteRecon
        ModelMeshRecon -->|creates| NPRecon
    end

    subgraph "Watched CRDs (KServe)"
        ISVC[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntime[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Created Resources (KServe Mode)"
        Route[Route<br/>route.openshift.io/v1]
        NP[NetworkPolicy x3<br/>networking.k8s.io/v1]
        PeerAuth[PeerAuthentication<br/>security.istio.io/v1beta1]
        Telemetry[Telemetry<br/>telemetry.istio.io/v1alpha1]
        VS[VirtualService<br/>networking.istio.io/v1beta1]
        SMM[ServiceMeshMember<br/>maistra.io/v1]
        SM[ServiceMonitor<br/>monitoring.coreos.com/v1]
        PM[PodMonitor<br/>monitoring.coreos.com/v1]
    end

    subgraph "External Dependencies"
        KServeOp[KServe Operator]
        Istio[Istio Control Plane<br/>v1.17.4]
        Maistra[Maistra/OpenShift Service Mesh<br/>v2.x]
        PromOp[Prometheus Operator<br/>v0.64.1]
        OSRouter[OpenShift Router]
        K8sAPI[Kubernetes API<br/>v1.26.4]
    end

    subgraph "Internal ODH Dependencies"
        IstioGW[Istio Ingress Gateway<br/>istio-system]
        OSMonitoring[OpenShift Monitoring Stack]
        ODHDash[ODH Dashboard]
    end

    User[User] -->|creates| ISVC
    User -->|creates| ServingRuntime
    ISVC -->|watched by| ISVCController
    ServingRuntime -->|triggers reconcile| ISVCController

    RouteRecon -->|creates in istio-system| Route
    NPRecon -->|creates 3 policies| NP
    PeerAuthRecon -->|creates| PeerAuth
    TelemetryRecon -->|creates| Telemetry
    KServeRecon -->|creates| VS
    KServeRecon -->|creates| SMM
    SMRecon -->|creates| SM
    SMRecon -->|creates| PM

    Manager -->|watches CRDs| KServeOp
    Manager -->|API calls| K8sAPI
    KServeRecon -->|creates resources| Istio
    KServeRecon -->|mesh integration| Maistra
    SMRecon -->|creates monitors| PromOp
    Route -->|points to| IstioGW
    MonitoringController -->|RBAC for| OSMonitoring
    NP -.->|allows traffic from| ODHDash

