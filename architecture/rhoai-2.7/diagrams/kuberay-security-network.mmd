graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client<br/>User/CI]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        IngressRoute["Kubernetes Ingress /<br/>OpenShift Route<br/>443/TCP → 8000/8265<br/>TLS 1.2+ Edge/Reencrypt<br/>Optional Bearer Auth"]
    end

    subgraph K8sCluster["KUBERNETES CLUSTER (Trusted)"]
        direction TB

        subgraph OpNS["Operator Namespace: kuberay-system"]
            Operator["kuberay-operator<br/>SA: kuberay-operator<br/>8080/TCP HTTP (metrics)<br/>8082/TCP HTTP (health)<br/>No encryption"]
        end

        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS1.2+<br/>ServiceAccount Tokens"]

        subgraph UserNS["User Namespace: {ray-namespace}"]
            direction TB
            HeadPod["Ray Head Pod<br/>SA: {cluster}-sa<br/>User: UID 1000<br/>Ports:<br/>- 6379/TCP Ray GCS<br/>- 8265/TCP Dashboard<br/>- 10001/TCP Client API<br/>Optional TLS, Optional mTLS"]
            WorkerPods["Ray Worker Pods<br/>SA: {cluster}-sa<br/>User: UID 1000<br/>Autoscaling: Ray sidecar"]
            HeadSvc["Service: {cluster}-head-svc<br/>ClusterIP/LoadBalancer<br/>6379, 8265, 10001"]
            ServeSvc["Service: {service}-serve-svc<br/>ClusterIP/LoadBalancer<br/>8000/TCP"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Registry["Container Registry<br/>registry.redhat.io, quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secrets"]
        S3["S3/GCS/Azure Storage<br/>443/TCP HTTPS TLS1.2+<br/>Cloud IAM Auth"]
        Redis["External Redis (Optional)<br/>6379/TCP Redis Protocol<br/>Optional TLS, Password/ACL"]
        Prometheus["Prometheus<br/>8080/8265/TCP HTTP/HTTPS<br/>Optional TLS, Network Policy"]
        Volcano["Volcano Scheduler (Optional)<br/>443/TCP HTTPS K8s API<br/>ServiceAccount Token"]
    end

    %% Flows - External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>Optional Bearer| IngressRoute

    %% Flows - Ingress to Services
    IngressRoute -->|HTTP/HTTPS<br/>8000/8265/TCP<br/>Optional TLS| HeadSvc
    IngressRoute -->|HTTP/HTTPS<br/>8000/TCP<br/>Optional Bearer| ServeSvc

    %% Flows - Services to Pods
    HeadSvc -->|Internal routing| HeadPod
    ServeSvc -->|Internal routing| HeadPod

    %% Flows - Operator
    Client -->|Create RayCluster CR<br/>HTTPS/443 Bearer| K8sAPI
    K8sAPI -.->|Controller Watch<br/>ServiceAccount Token| Operator
    Operator -->|Reconcile<br/>HTTPS/443 TLS1.2+<br/>ServiceAccount Token| K8sAPI

    %% Flows - Ray Internal
    WorkerPods -->|Ray GCS<br/>6379/TCP<br/>Optional TLS/mTLS| HeadPod

    %% Flows - External Services
    K8sAPI -->|Image Pull<br/>443/TCP HTTPS<br/>Pull Secrets| Registry
    HeadPod -->|Object Storage<br/>443/TCP HTTPS<br/>Cloud IAM| S3
    WorkerPods -->|Object Storage<br/>443/TCP HTTPS<br/>Cloud IAM| S3
    HeadPod -.->|GCS Fault Tolerance<br/>6379/TCP<br/>Optional TLS Password| Redis
    Prometheus -->|Scrape Metrics<br/>8080/TCP HTTP<br/>Network Policy| Operator
    Prometheus -->|Scrape Dashboard<br/>8265/TCP HTTP/HTTPS<br/>Optional Token| HeadPod
    Operator -.->|Gang Scheduling<br/>443/TCP HTTPS<br/>ServiceAccount| Volcano

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px

    class Client external
    class IngressRoute ingress
    class Operator,K8sAPI,HeadPod,WorkerPods,HeadSvc,ServeSvc cluster
    class Operator operator
    class Registry,S3,Redis,Prometheus,Volcano externalservice
