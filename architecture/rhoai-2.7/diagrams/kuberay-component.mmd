graph TB
    subgraph "KubeRay Operator Component"
        Operator[kuberay-operator<br/>Go Controller Manager]
        RayClusterCtl[RayCluster Controller<br/>Manages cluster lifecycle]
        RayJobCtl[RayJob Controller<br/>Manages batch jobs]
        RayServiceCtl[RayService Controller<br/>Manages Ray Serve deployments]
        ServiceBuilder[Service Builder<br/>Creates K8s Services/Routes]
        RBACMgr[RBAC Manager<br/>Creates ServiceAccounts/Roles]
        BatchScheduler[Batch Scheduler Manager<br/>Optional Volcano integration]

        Operator --> RayClusterCtl
        Operator --> RayJobCtl
        Operator --> RayServiceCtl
        RayClusterCtl --> ServiceBuilder
        RayClusterCtl --> RBACMgr
        RayJobCtl --> BatchScheduler
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Managed Resources"
        HeadPod[Ray Head Pod<br/>GCS + Dashboard + Client]
        WorkerPods[Ray Worker Pods<br/>Distributed compute]
        HeadSvc[Head Service<br/>6379, 8265, 10001]
        ServeSvc[Serve Service<br/>8000]
        Ingress[Ingress/Route<br/>External access]
        SA[ServiceAccount<br/>Ray cluster identity]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Registry[Container Registry<br/>Ray image pulls]
        S3[S3/GCS Storage<br/>Object storage]
        Prometheus[Prometheus<br/>Metrics scraping]
        Volcano[Volcano Scheduler<br/>Gang scheduling]
    end

    %% User interactions
    User[User/CI] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR

    %% CR to Controllers
    RayClusterCR -->|watched by| RayClusterCtl
    RayJobCR -->|watched by| RayJobCtl
    RayServiceCR -->|watched by| RayServiceCtl

    %% Controllers create resources
    RayClusterCtl -->|creates| HeadPod
    RayClusterCtl -->|creates| WorkerPods
    RayClusterCtl -->|creates| HeadSvc
    RayClusterCtl -->|creates| SA
    RayServiceCtl -->|creates| ServeSvc
    ServiceBuilder -->|creates| Ingress

    %% Cluster dependencies
    Operator -->|reconciles via| K8sAPI
    HeadPod -->|pulls from| Registry
    HeadPod -->|stores to| S3
    Prometheus -->|scrapes| Operator
    BatchScheduler -.->|integrates| Volcano

    %% Worker to Head communication
    WorkerPods -->|Ray GCS<br/>6379/TCP| HeadPod

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style RayClusterCtl fill:#4a90e2,stroke:#333
    style RayJobCtl fill:#4a90e2,stroke:#333
    style RayServiceCtl fill:#4a90e2,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayJobCR fill:#f5a623,stroke:#333,stroke-width:2px
    style RayServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style HeadPod fill:#7ed321,stroke:#333
    style WorkerPods fill:#7ed321,stroke:#333
    style K8sAPI fill:#999,stroke:#333
    style Registry fill:#999,stroke:#333
    style S3 fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Volcano fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
