graph TB
    subgraph "RHOAI Platform Control Plane"
        RHOAIOp[RHOAI Operator<br/>v1.6.0-441]
        Dashboard[ODH Dashboard<br/>Web UI]

        RHOAIOp -->|orchestrates| Dashboard
    end

    subgraph "Notebook Management"
        NotebookController[ODH Notebook Controller<br/>v1.27.0-rhods-244]
        NotebookImages[Workbench Images<br/>JupyterLab/code-server/RStudio<br/>v1.1.1-366]

        NotebookController -->|spawns| NotebookImages
    end

    subgraph "ML Pipeline Orchestration"
        DSPOperator[Data Science Pipelines Operator<br/>025e77a]
        TektonPipelines[OpenShift Pipelines<br/>Tekton]
        S3Storage[S3/Object Storage<br/>Artifact Storage]

        DSPOperator -->|depends on| TektonPipelines
        DSPOperator -->|uses| S3Storage
    end

    subgraph "Model Serving Infrastructure"
        KServe[KServe Operator<br/>80cb15e08]
        ModelMesh[ModelMesh Serving<br/>v1.27.0-rhods-168]
        ModelController[ODH Model Controller<br/>v1.27.0-rhods-153<br/>HA: 3 replicas]

        KServe -->|watched by| ModelController
        ModelMesh -->|watched by| ModelController
        ModelController -->|creates| Routes[OpenShift Routes]
        ModelController -->|manages| NetworkPolicies[NetworkPolicies]
        ModelController -->|configures| PeerAuth[Istio PeerAuthentication]
    end

    subgraph "Distributed Computing"
        CodeFlareOp[CodeFlare Operator<br/>9cfde69]
        KubeRayOp[KubeRay Operator<br/>63106681]
        MCAD[MCAD<br/>Multi-Cluster App Dispatcher]
        InstaScale[InstaScale<br/>Cluster Autoscaling]

        CodeFlareOp -->|manages| MCAD
        CodeFlareOp -->|manages| InstaScale
        CodeFlareOp -->|creates| KubeRayOp
    end

    subgraph "AI Governance"
        TrustyAIOp[TrustyAI Service Operator<br/>eb7d626<br/>Optional in RHOAI 2.7]
    end

    subgraph "External Dependencies"
        Istio[Istio Service Mesh<br/>Service mesh control plane]
        Knative[Knative Serving<br/>Serverless platform]
        OAuth[OpenShift OAuth<br/>Authentication]
        Prometheus[Prometheus<br/>Metrics collection]
    end

    subgraph "Platform Namespaces"
        NSOperator[redhat-ods-operator]
        NSApps[redhat-ods-applications]
        NSMonitoring[redhat-ods-monitoring]
        NSIstio[istio-system]
        NSUser[User Namespaces<br/>Data science projects]
    end

    %% Control plane orchestration
    RHOAIOp -->|creates| NSOperator
    RHOAIOp -->|creates| NSApps
    RHOAIOp -->|creates| NSMonitoring
    RHOAIOp -->|configures| Istio

    %% Component dependencies
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    ModelMesh -->|uses| etcd[etcd<br/>Model routing]

    %% Integration with external systems
    NotebookController -->|integrates| OAuth
    DSPOperator -->|integrates| KServe
    TrustyAIOp -->|integrates| KServe
    TrustyAIOp -->|integrates| ModelMesh

    %% Monitoring
    RHOAIOp -->|exposes metrics| Prometheus
    NotebookController -->|exposes metrics| Prometheus
    DSPOperator -->|exposes metrics| Prometheus
    KServe -->|exposes metrics| Prometheus
    ModelMesh -->|exposes metrics| Prometheus
    ModelController -->|exposes metrics| Prometheus
    CodeFlareOp -->|exposes metrics| Prometheus
    KubeRayOp -->|exposes metrics| Prometheus
    TrustyAIOp -->|exposes metrics| Prometheus

    %% User interactions
    User[Data Scientist] -->|accesses| Dashboard
    User -->|authenticates| OAuth
    Dashboard -->|manages| NSUser

    style RHOAIOp fill:#4a90e2,stroke:#333,stroke-width:4px
    style KServe fill:#4a90e2,stroke:#333,stroke-width:2px
    style ModelMesh fill:#4a90e2,stroke:#333,stroke-width:2px
    style ModelController fill:#4a90e2,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333
    style NotebookController fill:#7ed321,stroke:#333
    style DSPOperator fill:#7ed321,stroke:#333
    style CodeFlareOp fill:#7ed321,stroke:#333
    style KubeRayOp fill:#7ed321,stroke:#333
    style TrustyAIOp fill:#999,stroke:#333,stroke-dasharray: 5 5
    style Istio fill:#f5a623,stroke:#333
    style Knative fill:#f5a623,stroke:#333
    style OAuth fill:#f5a623,stroke:#333
    style Prometheus fill:#f5a623,stroke:#333
