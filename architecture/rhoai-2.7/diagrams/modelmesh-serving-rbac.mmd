graph TD
    subgraph ServiceAccounts["Service Accounts"]
        SA_Controller[modelmesh-controller<br/>Namespace: controller]
        SA_Runtime[modelmesh-serving-sa<br/>Namespace: user namespaces]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Controller[modelmesh-controller-role]
        CR_Editor[inferenceservice-editor-role]
        CR_Viewer[inferenceservice-viewer-role]
    end

    subgraph Roles["Roles (Namespace-scoped)"]
        R_Leader[leader-election-role]
        R_Proxy[proxy-role]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Controller[modelmesh-controller-rolebinding]
    end

    subgraph RoleBindings["Role Bindings (Namespace-scoped)"]
        RB_Leader[leader-election-rolebinding]
        RB_Proxy[proxy-rolebinding]
    end

    subgraph APIResources["API Resources"]
        subgraph Core["Core (v1)"]
            R_ConfigMaps[ConfigMaps]
            R_Secrets[Secrets]
            R_Services[Services]
            R_Namespaces[Namespaces]
            R_Endpoints[Endpoints]
            R_PVCs[PersistentVolumeClaims]
        end

        subgraph Apps["apps/v1"]
            R_Deployments[Deployments]
        end

        subgraph KServe["serving.kserve.io"]
            R_InferenceServices[InferenceServices]
            R_Predictors[Predictors]
            R_ServingRuntimes[ServingRuntimes]
            R_ClusterServingRuntimes[ClusterServingRuntimes]
        end

        subgraph Autoscaling["autoscaling/v2"]
            R_HPAs[HorizontalPodAutoscalers]
        end

        subgraph Monitoring["monitoring.coreos.com/v1"]
            R_ServiceMonitors[ServiceMonitors]
        end

        subgraph Auth["authentication/authorization"]
            R_TokenReviews[TokenReviews]
            R_SubjectAccessReviews[SubjectAccessReviews]
        end

        subgraph Coordination["coordination.k8s.io/v1"]
            R_Leases[Leases]
        end
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_Leader
    SA_Controller -->|bound via| RB_Proxy

    %% Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    RB_Leader -->|grants| R_Leader
    RB_Proxy -->|grants| R_Proxy

    %% ClusterRole: modelmesh-controller-role permissions
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_ConfigMaps
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_Secrets
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_Services
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_Namespaces
    CR_Controller -->|get, list, watch| R_Endpoints
    CR_Controller -->|get, list, watch| R_PVCs
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_Deployments
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_InferenceServices
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_Predictors
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_ServingRuntimes
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_ClusterServingRuntimes
    CR_Controller -->|create, delete, get, list,<br/>update, watch| R_HPAs
    CR_Controller -->|create, delete, get, list,<br/>patch, update, watch| R_ServiceMonitors

    %% Role: leader-election-role permissions
    R_Leader -->|get, list, watch, create,<br/>update, patch, delete| R_ConfigMaps
    R_Leader -->|get, list, watch, create,<br/>update, patch, delete| R_Leases

    %% Role: proxy-role permissions
    R_Proxy -->|create| R_TokenReviews
    R_Proxy -->|create| R_SubjectAccessReviews

    %% Editor role
    CR_Editor -->|create, delete, get, list,<br/>patch, update, watch| R_InferenceServices
    CR_Editor -->|create, delete, get, list,<br/>patch, update, watch| R_Predictors

    %% Viewer role
    CR_Viewer -->|get, list, watch| R_InferenceServices
    CR_Viewer -->|get, list, watch| R_Predictors

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef clusterRole fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#f5a623,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5
    classDef binding fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#e8e8e8,stroke:#333,stroke-width:1px

    class SA_Controller,SA_Runtime serviceAccount
    class CR_Controller,CR_Editor,CR_Viewer clusterRole
    class R_Leader,R_Proxy role
    class CRB_Controller,RB_Leader,RB_Proxy binding
    class R_ConfigMaps,R_Secrets,R_Services,R_Namespaces,R_Endpoints,R_PVCs,R_Deployments,R_InferenceServices,R_Predictors,R_ServingRuntimes,R_ClusterServingRuntimes,R_HPAs,R_ServiceMonitors,R_TokenReviews,R_SubjectAccessReviews,R_Leases resource
