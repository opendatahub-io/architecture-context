graph TD
    subgraph "Service Accounts"
        SA1["controller-manager<br/>Namespace: operator-namespace"]
        SA2["instance-name-proxy<br/>Namespace: instance-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB1["manager-rolebinding<br/>ClusterRoleBinding"]
        CRB2["proxy-rolebinding<br/>ClusterRoleBinding"]
        CRB3["instance-name-namespace-proxy-rolebinding<br/>ClusterRoleBinding"]
    end

    subgraph "Roles"
        CR1[manager-role<br/>ClusterRole]
        CR2[proxy-role<br/>ClusterRole]
        CR3[trustyai-service-operator-proxy-role<br/>ClusterRole]
        R1[leader-election-role<br/>Role - Operator Namespace]
    end

    subgraph "API Resources - TrustyAI"
        API1[trustyai.opendatahub.io<br/>trustyaiservices<br/>trustyaiservices/status<br/>trustyaiservices/finalizers]
    end

    subgraph "API Resources - Apps"
        API2[apps<br/>deployments<br/>deployments/status<br/>deployments/finalizers]
    end

    subgraph "API Resources - Core"
        API3["core<br/>services, pods, configmaps<br/>secrets, serviceaccounts<br/>persistentvolumeclaims<br/>persistentvolumes, events"]
    end

    subgraph "API Resources - KServe"
        API4[serving.kserve.io<br/>inferenceservices<br/>inferenceservices/finalizers<br/>servingruntimes<br/>servingruntimes/status]
    end

    subgraph "API Resources - OpenShift"
        API5[route.openshift.io<br/>routes]
    end

    subgraph "API Resources - Monitoring"
        API6[monitoring.coreos.com<br/>servicemonitors]
    end

    subgraph "API Resources - RBAC"
        API7[rbac.authorization.k8s.io<br/>clusterrolebindings]
        API8[authentication.k8s.io<br/>tokenreviews]
        API9[authorization.k8s.io<br/>subjectaccessreviews]
    end

    subgraph "API Resources - Leader Election"
        API10["core<br/>configmaps<br/>leases"]
    end

    %% Service Account Bindings
    SA1 -->|bound via| CRB1
    SA1 -->|bound via| CRB2
    SA2 -->|bound via| CRB3

    %% ClusterRoleBinding to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3

    %% manager-role permissions
    CR1 -->|"get, list, watch<br/>create, update, patch, delete"| API1
    CR1 -->|"get, list, watch<br/>create, update, patch, delete"| API2
    CR1 -->|"get, list, watch<br/>create, update, patch, delete"| API3
    CR1 -->|"get, list, watch<br/>create, update, patch<br/>delete, create"| API4
    CR1 -->|"get, list, watch<br/>create, update, patch, delete"| API5
    CR1 -->|"list, watch, create"| API6
    CR1 -->|"get, list, watch<br/>create, update, delete"| API7

    %% proxy-role permissions
    CR2 -->|create| API8
    CR2 -->|create| API9

    %% trustyai-service-operator-proxy-role permissions
    CR3 -->|create| API8
    CR3 -->|create| API9

    %% leader-election-role permissions
    SA1 -->|bound via RoleBinding| R1
    R1 -->|"get, list, watch<br/>create, update, patch"| API10

