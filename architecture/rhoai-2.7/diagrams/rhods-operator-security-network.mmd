graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Platform Admin]
        GitOps[GitOps System]
    end

    subgraph K8sControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (redhat-ods-operator)"]
        direction TB

        subgraph OperatorPod["RHOAI Operator Pod<br/>SA: controller-manager<br/>Security: runAsNonRoot, no privesc, drop ALL caps"]
            direction TB
            DSCController[DataScienceCluster<br/>Controller]
            DSCIController[DSCInitialization<br/>Controller]
            SecretGen[SecretGenerator<br/>Controller]
            MetricsEndpoint["Metrics Endpoint<br/>HTTP/8080<br/>localhost only"]
            HealthProbes["Health Probes<br/>HTTP/8081<br/>/healthz, /readyz"]
        end

        RBACProxy["kube-rbac-proxy<br/>sidecar<br/>HTTPS/8443<br/>TLS (service-ca)<br/>Bearer Token auth"]

        MetricsEndpoint -->|proxied through| RBACProxy
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>User Workload Monitoring<br/>NS: openshift-user-workload-monitoring"]
        Kubelet["Kubelet<br/>Node-local health checks"]
    end

    subgraph ManagedNamespaces["MANAGED NAMESPACES"]
        direction TB
        AppsNS["redhat-ods-applications<br/>Dashboard, Workbenches,<br/>KServe, ModelMesh, Pipelines"]
        MonitoringNS["redhat-ods-monitoring<br/>Prometheus, Alertmanager"]
        IstioNS["istio-system<br/>ServiceMeshControlPlane"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        GitRepo["Git Repository<br/>github.com<br/>443/TCP HTTPS TLS1.2+<br/>No auth (public)"]
        ContainerRegistry["Container Registries<br/>quay.io, registry.redhat.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull secrets"]
    end

    %% External to Control Plane
    Admin -->|"kubectl apply<br/>HTTPS/6443 TLS1.2+<br/>User credentials"| K8sAPI
    GitOps -->|"GitOps sync<br/>HTTPS/6443 TLS1.2+<br/>ServiceAccount token"| K8sAPI

    %% Control Plane to Operator
    K8sAPI -->|"Watch notifications<br/>In-memory<br/>ServiceAccount token"| OperatorPod

    %% Operator to Control Plane
    DSCController -->|"HTTPS/6443 TLS1.2+<br/>ServiceAccount token<br/>CRD reconciliation"| K8sAPI
    DSCIController -->|"HTTPS/6443 TLS1.2+<br/>ServiceAccount token<br/>Infrastructure setup"| K8sAPI
    SecretGen -->|"HTTPS/6443 TLS1.2+<br/>ServiceAccount token<br/>Secret generation"| K8sAPI

    %% Operator to External Services
    DSCController -.->|"HTTPS/443 TLS1.2+<br/>No auth<br/>Optional: devFlags.manifestsUri"| GitRepo
    DSCController -.->|"HTTPS/443 TLS1.2+<br/>Pull secrets<br/>Image pulls"| ContainerRegistry

    %% Monitoring
    Prometheus -->|"HTTPS/8443<br/>TLS<br/>Bearer Token"| RBACProxy
    RBACProxy -->|"TokenReview<br/>HTTPS/6443 TLS1.2+"| K8sAPI
    Kubelet -->|"HTTP/8081<br/>No auth<br/>Health checks"| HealthProbes

    %% Operator creates managed namespaces
    DSCIController -->|"creates/manages"| AppsNS
    DSCIController -->|"creates/manages"| MonitoringNS
    DSCIController -->|"creates/manages"| IstioNS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#e1f5ff,stroke:#0288d1,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef managed fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef externalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Admin,GitOps external
    class K8sAPI controlplane
    class OperatorPod,DSCController,DSCIController,SecretGen,MetricsEndpoint,HealthProbes,RBACProxy operator
    class Prometheus,Kubelet monitoring
    class AppsNS,MonitoringNS,IstioNS managed
    class GitRepo,ContainerRegistry externalservice
