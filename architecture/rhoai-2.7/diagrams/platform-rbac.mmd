graph TB
    subgraph "Service Accounts"
        SA_RHOAI[rhods-operator<br/>redhat-ods-operator ns]
        SA_NBController[odh-notebook-controller-manager<br/>redhat-ods-applications ns]
        SA_DSP[data-science-pipelines-operator-cm<br/>redhat-ods-applications ns]
        SA_KServe[kserve-controller-manager<br/>openshift-operators ns]
        SA_ModelMesh[modelmesh-controller<br/>openshift-operators ns]
        SA_ModelCtl[odh-model-controller<br/>redhat-ods-applications ns]
        SA_CodeFlare[codeflare-operator-controller-manager<br/>openshift-operators ns]
        SA_KubeRay[kuberay-operator<br/>openshift-operators ns]
        SA_TrustyAI[trustyai-service-operator-cm<br/>openshift-operators ns]
    end

    subgraph "ClusterRoles (Permissions)"
        CR_RHOAI[rhods-operator-role<br/>API Groups: * all<br/>Resources: All<br/>Verbs: * all]
        CR_NBController[odh-notebook-controller-role<br/>API Groups: kubeflow.org, route.openshift.io, networking.k8s.io<br/>Resources: Notebooks, Routes, NetworkPolicies<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_DSP[data-science-pipelines-operator-role<br/>API Groups: tekton.dev, serving.kserve.io, ray.io<br/>Resources: PipelineRuns, InferenceServices, RayClusters<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_KServe[kserve-manager-role<br/>API Groups: serving.kserve.io, serving.knative.dev, networking.istio.io<br/>Resources: InferenceServices, TrainedModels, Knative Services, VirtualServices<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_ModelMesh[modelmesh-controller-role<br/>API Groups: serving.kserve.io, monitoring.coreos.com<br/>Resources: InferenceServices, Predictors, ServingRuntimes, ServiceMonitors<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_ModelCtl[odh-model-controller-role<br/>API Groups: serving.kserve.io, security.istio.io, route.openshift.io, networking.k8s.io<br/>Resources: InferenceServices, PeerAuthentications, Routes, NetworkPolicies<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_CodeFlare[codeflare-operator-role<br/>API Groups: workload.codeflare.dev, machine.openshift.io, ray.io<br/>Resources: AppWrappers, MachineSets, RayClusters<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_KubeRay[kuberay-operator-role<br/>API Groups: ray.io, route.openshift.io<br/>Resources: RayClusters, RayJobs, RayServices, Routes<br/>Verbs: get, list, watch, create, update, patch, delete]
        CR_TrustyAI[trustyai-operator-role<br/>API Groups: trustyai.opendatahub.io, serving.kserve.io<br/>Resources: TrustyAIServices, InferenceServices<br/>Verbs: get, list, watch, create, update, patch, delete]
    end

    subgraph "ClusterRoleBindings"
