graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/Client]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforced"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        subgraph OperatorPod["CodeFlare Operator Manager Pod"]
            direction TB
            Manager["Operator Manager<br/>SA: controller-manager<br/>User: 65532:65532 (non-root)<br/>FIPS Mode: Enabled"]
            MCAD["MCAD Controller<br/>(embedded, in-process)"]
            InstaScale["InstaScale Controller<br/>(embedded, in-process)<br/>OpenShift Only"]

            Manager -.->|embeds| MCAD
            Manager -.->|embeds| InstaScale
        end

        MetricsService["Metrics Service<br/>codeflare-operator-manager-metrics<br/>ClusterIP 8080/TCP"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz /readyz"]

        OperatorPod -->|exposes| MetricsService
        OperatorPod -->|exposes| HealthProbes
    end

    subgraph ClusterWide["CLUSTER-WIDE RESOURCES"]
        MachineAPI["OpenShift Machine API<br/>machine.openshift.io<br/>MachineSets, Machines"]
        Prometheus["Prometheus<br/>(cluster monitoring)"]
        Kubelet["Kubelet<br/>(node agents)"]
    end

    subgraph UserNS["USER NAMESPACES (workload execution)"]
        KubeRay["KubeRay Operator"]
        RayPods["Ray Head/Worker Pods"]
        WorkloadPods["Workload Pods<br/>(Jobs, Deployments)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        CloudAPI["Cloud Provider API<br/>AWS/GCP/Azure<br/>443/TCP HTTPS TLS1.2+<br/>IAM Auth"]
    end

    %% User flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI

    %% Operator to K8s API
    MCAD -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch/Create CRs| K8sAPI
    InstaScale -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Watch/Manage| K8sAPI

    %% K8s API watch events
    K8sAPI -.->|Watch events<br/>in-memory| MCAD
    K8sAPI -.->|Watch events<br/>in-memory| InstaScale

    %% MCAD creates workloads
    MCAD -->|HTTPS/6443<br/>TLS 1.2+<br/>Create Pods/Services| WorkloadPods
    MCAD -->|HTTPS/6443<br/>TLS 1.2+<br/>Create RayCluster CR| KubeRay

    %% InstaScale to Machine API
    InstaScale -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token<br/>Create/Delete MachineSets| MachineAPI

    %% Machine API to Cloud
    MachineAPI -->|HTTPS/443<br/>TLS 1.2+<br/>Cloud IAM credentials| CloudAPI

    %% KubeRay creates Ray pods
    KubeRay -->|HTTPS/6443<br/>TLS 1.2+<br/>Create Ray Pods| RayPods

    %% Monitoring
    Prometheus -->|HTTP/8080<br/>Bearer Token<br/>Metrics Scraping| MetricsService
    Kubelet -->|HTTP/8081<br/>No Auth<br/>Health Checks| HealthProbes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterwide fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef userns fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Manager,MCAD,InstaScale,MetricsService,HealthProbes,OperatorPod operator
    class MachineAPI,Prometheus,Kubelet clusterwide
    class KubeRay,RayPods,WorkloadPods userns
    class CloudAPI externalservice
