graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller Manager<br/>Go Binary]
        TrustyAIController[TrustyAIService Controller<br/>Reconciler]
        Controller -->|manages| TrustyAIController
    end

    subgraph "TrustyAI Service Deployment"
        TrustyAIService[TrustyAI Service<br/>8080/TCP HTTP]
        OAuthProxy[OAuth Proxy<br/>8443/TCP HTTPS]
        PVC[Persistent Volume Claim<br/>Storage]
        TrustyAIService -->|uses| PVC
        OAuthProxy -->|forwards to| TrustyAIService
    end

    subgraph "Monitoring"
        ServiceMonitor[ServiceMonitor<br/>Prometheus Integration]
        Route[OpenShift Route<br/>443/TCP HTTPS]
    end

    subgraph "Custom Resources"
        TrustyAIServiceCR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>6443/TCP HTTPS]
        PrometheusOp[Prometheus Operator]
        KServe[KServe]
        ModelMesh[ModelMesh]
        OpenShiftOAuth[OpenShift OAuth]
    end

    User[User/Data Scientist] -->|creates| TrustyAIServiceCR
    TrustyAIServiceCR -->|watched by| TrustyAIController
    InferenceServiceCR -->|watched by| TrustyAIController
    ServingRuntimeCR -->|watched by| TrustyAIController

    TrustyAIController -->|creates/updates| TrustyAIService
    TrustyAIController -->|creates| OAuthProxy
    TrustyAIController -->|creates| PVC
    TrustyAIController -->|creates| ServiceMonitor
    TrustyAIController -->|creates| Route

    TrustyAIController -->|patches| InferenceServiceCR
    TrustyAIController -->|patches| ModelMesh

    Controller -->|uses| K8sAPI
    TrustyAIController -->|integrates| KServe
    TrustyAIController -->|integrates| ModelMesh
    ServiceMonitor -->|monitored by| PrometheusOp
    OAuthProxy -->|authenticates via| OpenShiftOAuth

    InferenceServiceCR -->|sends payloads| TrustyAIService

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIController fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#7ed321,stroke:#333,stroke-width:2px
    style TrustyAIServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:1px
    style PrometheusOp fill:#999,stroke:#333,stroke-width:1px
    style KServe fill:#999,stroke:#333,stroke-width:1px
    style ModelMesh fill:#999,stroke:#333,stroke-width:1px
    style OpenShiftOAuth fill:#999,stroke:#333,stroke-width:1px
