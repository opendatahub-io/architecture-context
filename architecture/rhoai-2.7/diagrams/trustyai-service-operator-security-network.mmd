graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist /<br/>External User]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>{instance-name}<br/>443/TCP HTTPS<br/>TLS 1.2+ Passthrough"]
    end

    subgraph Application["APPLICATION (Trusted - Namespace: {instance-namespace})"]
        direction TB

        subgraph ServiceTLS["Service: {instance-name}-tls<br/>ClusterIP 443/TCP → 8443/TCP"]
            direction TB

            subgraph Pod["Pod: {instance-name}-{pod-id}"]
                direction LR
                OAuthProxy["oauth-proxy<br/>8443/TCP HTTPS<br/>TLS cert: service-ca<br/>SA: {instance-name}-proxy<br/>Skip auth: /apis/v1beta1/healthz"]
                TrustyAI["trustyai-service<br/>8080/TCP HTTP<br/>Image: quay.io/trustyai/trustyai-service"]
                PVC["PVC: {instance-name}<br/>ReadWriteOnce<br/>Stores inference data"]

                OAuthProxy -->|HTTP/8080<br/>localhost<br/>No Auth| TrustyAI
                TrustyAI -->|Filesystem<br/>mount| PVC
            end
        end

        ServiceHTTP["Service: {instance-name}<br/>ClusterIP 80/TCP → 8080/TCP<br/>HTTP No Auth"]
    end

    subgraph ControlPlane["CONTROL PLANE (Highly Trusted)"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Tokens"]

        subgraph Operator["Operator Namespace: {operator-namespace}"]
            Controller["TrustyAI Operator<br/>controller-manager<br/>SA: controller-manager<br/>Metrics: 8443/TCP<br/>Health: 8081/TCP"]
        end

        OAuth["OpenShift OAuth<br/>Namespace: openshift-authentication<br/>443/TCP HTTPS TLS1.2+"]
    end

    subgraph Integration["INTEGRATION POINTS (Trusted)"]
        direction TB
        InferenceSvc["KServe InferenceService<br/>Namespace: {user-namespace}<br/>Sends payloads"]
        Prometheus["Prometheus<br/>Namespace: openshift-monitoring<br/>Scrapes metrics"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Route

    %% Ingress to Application
    Route -->|HTTPS/443<br/>TLS 1.2+ service-ca<br/>Passthrough| OAuthProxy

    %% OAuth Flow
    OAuthProxy -->|OAuth validation<br/>HTTPS/443 TLS1.2+| OAuth
    OAuthProxy -->|SubjectAccessReview<br/>HTTPS/6443 TLS1.2+<br/>SA Token| K8sAPI

    %% Operator to Control Plane
    Controller -->|Watch CRs, Manage resources<br/>HTTPS/6443 TLS1.2+<br/>SA Token| K8sAPI

    %% Integration Points
    InferenceSvc -->|POST /consumer/kserve/v2<br/>HTTP/8080<br/>No Auth| ServiceHTTP
    ServiceHTTP -->|Forward| TrustyAI

    Prometheus -->|GET /q/metrics<br/>HTTP/80<br/>ServiceMonitor| ServiceHTTP

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef integration fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Route ingress
    class ServiceTLS,Pod,OAuthProxy,TrustyAI,PVC,ServiceHTTP application
    class K8sAPI,Operator,Controller,OAuth controlplane
    class InferenceSvc,Prometheus integration
