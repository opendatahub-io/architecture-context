graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: datasciencepipelinesapplications-controller]
        SA_Pipeline["ds-pipeline-{name}<br/>Namespace: {dspa-namespace}"]
        SA_Runner["pipeline-runner-{name}<br/>Namespace: {dspa-namespace}"]
        SA_ScheduledWF["ds-pipeline-scheduledworkflow-{name}<br/>Namespace: {dspa-namespace}"]
        SA_PersistenceAgent["ds-pipeline-persistenceagent-{name}<br/>Namespace: {dspa-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole"
        CR_Manager[manager-role<br/>ClusterRole]
    end

    subgraph "Namespace Roles"
        Role_Pipeline["ds-pipeline-{name}<br/>Role"]
        Role_Runner["pipeline-runner-{name}<br/>Role"]
        Role_ScheduledWF["ds-pipeline-scheduledworkflow-{name}<br/>Role"]
        Role_PersistenceAgent["ds-pipeline-persistenceagent-{name}<br/>Role"]
    end

    subgraph "API Resources - Operator Managed"
        DSPACR["datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication<br/>Verbs: create, delete, get, list, patch, update, watch"]
        DSPAStatus["datasciencepipelinesapplications/status<br/>Verbs: get, update, patch"]
        DSPAFinalizers["datasciencepipelinesapplications/finalizers<br/>Verbs: update"]
    end

    subgraph "API Resources - Kubernetes Core"
        Deployments["apps/Deployments<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Services["core/Services<br/>Verbs: create, delete, get, list, patch, update, watch"]
        ConfigMaps["core/ConfigMaps<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Secrets["core/Secrets<br/>Verbs: create, delete, get, list, patch, update, watch"]
        ServiceAccounts["core/ServiceAccounts<br/>Verbs: create, delete, get, list, patch, update, watch"]
        PVCs["core/PersistentVolumeClaims<br/>Verbs: create, delete, get, list, patch, update, watch"]
        Pods["core/Pods, Pods/exec, Pods/log<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "API Resources - RBAC"
        Roles["rbac.authorization.k8s.io/Roles<br/>Verbs: create, delete, get, list, patch, update, watch"]
        RoleBindings["rbac.authorization.k8s.io/RoleBindings<br/>Verbs: create, delete, get, list, patch, update, watch"]
        ClusterRoles["rbac.authorization.k8s.io/ClusterRoles<br/>Verbs: create, delete, get, list, patch, update, watch"]
        ClusterRoleBindings["rbac.authorization.k8s.io/ClusterRoleBindings<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "API Resources - OpenShift"
        Routes["route.openshift.io/Routes<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "API Resources - Tekton & Pipelines"
        TektonAll["tekton.dev/* (all)<br/>Verbs: * (all)"]
        ArgoWorkflows["argoproj.io/Workflows<br/>Verbs: * (all)"]
        KubeflowAll["kubeflow.org/* (all)<br/>Verbs: * (all)"]
        PipelineLoops["custom.tekton.dev/PipelineLoops<br/>Verbs: * (all)"]
    end

    subgraph "API Resources - ML Workloads"
        SeldonDeployments["machinelearning.seldon.io/SeldonDeployments<br/>Verbs: * (all)"]
        RayClusters["ray.io/RayClusters, RayJobs, RayServices<br/>Verbs: create, delete, get, list, patch"]
        AppWrappers["mcad.ibm.com, workload.codeflare.dev/AppWrappers<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    subgraph "API Resources - Monitoring & Networking"
        ServiceMonitors["monitoring.coreos.com/ServiceMonitors<br/>Verbs: create, delete, get, list, patch, update, watch"]
        NetworkPolicies["networking.k8s.io/NetworkPolicies<br/>Verbs: create, delete, get, list, patch, update, watch"]
        VolumeSnapshots["snapshot.storage.k8s.io/VolumeSnapshots<br/>Verbs: create, delete, get"]
    end

    subgraph "API Resources - Jobs"
        Jobs["batch/Jobs<br/>Verbs: * (all)"]
        Events["core/Events<br/>Verbs: create, delete, get, list, patch, update, watch"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager

    SA_Pipeline -->|bound to| Role_Pipeline
    SA_Runner -->|bound to| Role_Runner
    SA_ScheduledWF -->|bound to| Role_ScheduledWF
    SA_PersistenceAgent -->|bound to| Role_PersistenceAgent

    %% ClusterRole permissions
    CR_Manager -->|manages| DSPACR
    CR_Manager -->|updates| DSPAStatus
    CR_Manager -->|updates| DSPAFinalizers
    CR_Manager -->|manages| Deployments
    CR_Manager -->|manages| Services
    CR_Manager -->|manages| ConfigMaps
    CR_Manager -->|manages| Secrets
    CR_Manager -->|manages| ServiceAccounts
    CR_Manager -->|manages| PVCs
    CR_Manager -->|manages| Pods
    CR_Manager -->|manages| Roles
    CR_Manager -->|manages| RoleBindings
    CR_Manager -->|manages| ClusterRoles
    CR_Manager -->|manages| ClusterRoleBindings
    CR_Manager -->|manages| Routes
    CR_Manager -->|manages| TektonAll
    CR_Manager -->|manages| ArgoWorkflows
    CR_Manager -->|manages| KubeflowAll
    CR_Manager -->|manages| PipelineLoops
    CR_Manager -->|manages| SeldonDeployments
    CR_Manager -->|manages| RayClusters
    CR_Manager -->|manages| AppWrappers
    CR_Manager -->|manages| ServiceMonitors
    CR_Manager -->|manages| NetworkPolicies
    CR_Manager -->|manages| VolumeSnapshots
    CR_Manager -->|manages| Jobs
    CR_Manager -->|manages| Events

    %% Role permissions (namespace-scoped)
    Role_Pipeline -->|accesses| Services
    Role_Pipeline -->|accesses| Deployments
    Role_Pipeline -->|accesses| ConfigMaps

    Role_Runner -->|extensive permissions| Pods
    Role_Runner -->|extensive permissions| Jobs
    Role_Runner -->|extensive permissions| RayClusters
    Role_Runner -->|extensive permissions| AppWrappers

    Role_ScheduledWF -->|triggers| Deployments
    Role_ScheduledWF -->|triggers| TektonAll

    Role_PersistenceAgent -->|watches| TektonAll
    Role_PersistenceAgent -->|syncs| Services

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Pipeline fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Runner fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_ScheduledWF fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_PersistenceAgent fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CRB_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px

    style Role_Pipeline fill:#ffa500,stroke:#333,stroke-width:2px
    style Role_Runner fill:#ffa500,stroke:#333,stroke-width:2px
    style Role_ScheduledWF fill:#ffa500,stroke:#333,stroke-width:2px
    style Role_PersistenceAgent fill:#ffa500,stroke:#333,stroke-width:2px

    style DSPACR fill:#7ed321,stroke:#333,stroke-width:2px
    style DSPAStatus fill:#7ed321,stroke:#333,stroke-width:2px
    style DSPAFinalizers fill:#7ed321,stroke:#333,stroke-width:2px

    style Deployments fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Services fill:#d5e8d4,stroke:#333,stroke-width:1px
    style ConfigMaps fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Secrets fill:#d5e8d4,stroke:#333,stroke-width:1px
    style ServiceAccounts fill:#d5e8d4,stroke:#333,stroke-width:1px
    style PVCs fill:#d5e8d4,stroke:#333,stroke-width:1px
    style Pods fill:#d5e8d4,stroke:#333,stroke-width:1px

    style TektonAll fill:#dae8fc,stroke:#333,stroke-width:1px
    style ArgoWorkflows fill:#dae8fc,stroke:#333,stroke-width:1px
    style KubeflowAll fill:#dae8fc,stroke:#333,stroke-width:1px
    style PipelineLoops fill:#dae8fc,stroke:#333,stroke-width:1px
