graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser /<br/>kfp-tekton SDK Client]
    end

    subgraph Ingress["INGRESS (OpenShift Router)"]
        Router["OpenShift Router<br/>443/TCP HTTPS TLS1.2+"]
        APIRoute["ds-pipeline-{name} Route<br/>8443/TCP HTTPS Reencrypt"]
        UIRoute["ds-pipeline-ui-{name} Route<br/>8443/TCP HTTPS Reencrypt"]
    end

    subgraph OAuth["OAUTH LAYER (Authentication)"]
        APIProxy["API OAuth Proxy<br/>Validates JWT<br/>OpenShift OAuth"]
        UIProxy["UI OAuth Proxy<br/>Validates JWT<br/>OpenShift OAuth"]
    end

    subgraph AppLayer["APPLICATION LAYER (Namespace: {dspa-namespace})"]
        direction TB

        subgraph CoreComponents["Core DSP Components"]
            APIServer["API Server<br/>SA: ds-pipeline-{name}<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>8443/TCP HTTPS"]
            UI["ML Pipelines UI<br/>SA: ds-pipeline-ui<br/>3000/TCP HTTP"]
            PersistenceAgent["Persistence Agent<br/>SA: ds-pipeline-persistenceagent-{name}<br/>Watches Tekton PipelineRuns"]
            ScheduledWF["Scheduled Workflow<br/>SA: ds-pipeline-scheduledworkflow-{name}<br/>Triggers via API Server"]
        end

        subgraph Storage["Storage Layer"]
            MariaDB["MariaDB<br/>3306/TCP MySQL<br/>Auth: Username/Password"]
            Minio["Minio (dev) /<br/>External S3 (prod)<br/>9000/TCP or 443/TCP<br/>Auth: Access/Secret Key"]
        end

        subgraph MLMDOptional["MLMD Components (Optional)"]
            MLMDEnvoy["MLMD Envoy Proxy<br/>9090/TCP gRPC<br/>No auth"]
            MLMDgRPC["MLMD gRPC Server<br/>8080/TCP gRPC<br/>No auth"]
            MLMDWriter["MLMD Writer<br/>Writes metadata"]
        end

        PipelinePods["Pipeline Task Pods<br/>SA: pipeline-runner-{name}<br/>Tekton PipelineRuns"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        ExtS3["External S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM / Access+Secret Key"]
        ExtDB["External Database<br/>MySQL/PostgreSQL<br/>3306/5432 TCP<br/>TLS 1.2+ optional<br/>Username/Password"]
        Registry["Container Registry<br/>quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull secrets"]
        TektonAPI["Tekton API<br/>443/TCP HTTPS TLS1.2+<br/>Service Account Token"]
    end

    %% Flows
    Client -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router -->|HTTPS/8443<br/>Reencrypt| APIRoute
    Router -->|HTTPS/8443<br/>Reencrypt| UIRoute

    APIRoute -->|HTTPS<br/>OAuth JWT| APIProxy
    UIRoute -->|HTTPS<br/>OAuth JWT| UIProxy

    APIProxy -->|HTTP/8888<br/>Pod-local<br/>Service Token| APIServer
    UIProxy -->|HTTP/3000<br/>Pod-local| UI

    UI -->|HTTP/8888<br/>Service Token| APIServer

    APIServer -->|MySQL/3306<br/>Username/Password| MariaDB
    APIServer -->|HTTP/9000 or HTTPS/443<br/>Access/Secret Key| Minio
    APIServer -->|HTTPS/443<br/>TLS 1.2+<br/>Service Token| TektonAPI

    PersistenceAgent -->|HTTPS/443<br/>Service Token| TektonAPI
    PersistenceAgent -->|HTTP/8888<br/>Service Token| APIServer
    PersistenceAgent -->|MySQL/3306| MariaDB

    ScheduledWF -->|HTTP/8888<br/>Service Token| APIServer

    TektonAPI -->|Execute| PipelinePods

    PipelinePods -->|HTTPS/443 or HTTP/9000<br/>Access/Secret Key| Minio
    PipelinePods -->|gRPC/9090<br/>No auth| MLMDEnvoy
    PipelinePods -.->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| ExtS3

    MLMDEnvoy -->|gRPC/8080| MLMDgRPC
    MLMDWriter -->|gRPC/8080| MLMDgRPC
    MLMDgRPC -->|MySQL/3306| MariaDB

    APIServer -.->|TLS optional<br/>Username/Password| ExtDB
    PipelinePods -->|HTTPS/443<br/>Pull secrets| Registry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef oauth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Router,APIRoute,UIRoute ingress
    class APIProxy,UIProxy oauth
    class APIServer,UI,PersistenceAgent,ScheduledWF,PipelinePods,MLMDEnvoy,MLMDgRPC,MLMDWriter application
    class MariaDB,Minio storage
    class ExtS3,ExtDB,Registry,TektonAPI externalservice
