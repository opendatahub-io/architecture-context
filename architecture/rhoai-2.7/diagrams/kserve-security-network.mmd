graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Gateway["Istio Ingress Gateway<br/>knative-ingress-gateway<br/>443/TCP to 8012/TCP<br/>TLS 1.3 Termination<br/>Optional RequestAuthentication"]
        K8sIngress["Kubernetes Ingress<br/>RawDeployment mode<br/>443/TCP to 8080/TCP<br/>TLS 1.3"]
    end

    subgraph ServiceLayer["SERVICE LAYER"]
        Activator["Knative Activator<br/>NS: knative-serving<br/>SA: controller<br/>8012/TCP HTTP"]
    end

    subgraph Application["APPLICATION (User Namespaces)"]
        direction TB

        subgraph NS_User["Namespace: user-namespace"]
            PredictorSvc["Predictor Service<br/>isvc-name-predictor<br/>ClusterIP 8080/TCP"]

            subgraph PredictorPod["Predictor Pod<br/>SA: isvc-name-sa<br/>runAsNonRoot=true"]
                StorageInit["storage-initializer<br/>init container<br/>Downloads from S3/GCS/Azure"]
                ModelServer["Model Server Container<br/>sklearn/xgboost/etc<br/>8080/TCP HTTP<br/>Optional Bearer Token"]
                Agent["Agent Sidecar<br/>Lifecycle/logging/batching"]
            end

            TransformerPod["Transformer Pod<br/>optional<br/>8080/TCP HTTP<br/>Optional Token"]
            ExplainerPod["Explainer Pod<br/>optional<br/>8080/TCP HTTP<br/>Optional Token"]
            RouterPod["Router Pod<br/>InferenceGraph<br/>8080/TCP HTTP<br/>Routes to graph nodes"]
        end
    end

    subgraph ControlPlane["CONTROL PLANE (kserve namespace)"]
        direction TB

        ControllerMgr["KServe Controller Manager<br/>NS: kserve<br/>SA: kserve-controller-manager<br/>Deployment<br/>runAsNonRoot=true"]
        WebhookSvc["Webhook Server Service<br/>ClusterIP 443 to 9443/TCP"]

        subgraph WebhookEndpoints["Webhook Endpoints 9443/TCP HTTPS TLS1.2+"]
            MutateInfSvc["/mutate-serving-kserve-io-v1beta1-inferenceservice"]
            ValidateInfSvc["/validate-serving-kserve-io-v1beta1-inferenceservice"]
            MutatePods["/mutate-pods agent/storage-init injection"]
            ValidateModel["/validate-serving-kserve-io-v1alpha1-trainedmodel"]
            ValidateGraph["/validate-serving-kserve-io-v1alpha1-inferencegraph"]
            ValidateRuntime["/validate-serving-kserve-io-v1alpha1-servingruntime"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["AWS S3<br/>s3.amazonaws.com<br/>443/TCP HTTPS TLS1.2+<br/>AWS IAM/Access Keys"]
        GCS["Google Cloud Storage<br/>storage.googleapis.com<br/>443/TCP HTTPS TLS1.2+<br/>GCP Service Account"]
        Azure["Azure Blob Storage<br/>blob.core.windows.net<br/>443/TCP HTTPS TLS1.2+<br/>Azure Storage Key"]
        IstioPilot["Istio Pilot istiod<br/>15010/TCP gRPC mTLS<br/>Service Account Token"]
    end

    %% Traffic Flows
    Client -->|"HTTPS/443 TLS 1.3 Optional Bearer"| Gateway
    Client -.->|"HTTPS/443 TLS 1.3 RawDeployment"| K8sIngress

    Gateway -->|"HTTP/8012 Plaintext"| Activator
    Activator -->|"HTTP/8080 Optional Token"| PredictorSvc
    K8sIngress -.->|"HTTP/8080 RawDeployment"| PredictorSvc

    PredictorSvc --> ModelServer
    ModelServer -->|"HTTP/8080 Optional Token"| TransformerPod
    ModelServer -->|"HTTP/8080 Optional Token"| ExplainerPod
    RouterPod -->|"HTTP/8080 Graph routing"| ModelServer

    %% Control Plane Flows
    K8sAPI -->|"HTTPS/443 to 9443 TLS 1.2+ K8s API mTLS"| WebhookSvc
    WebhookSvc --> MutateInfSvc
    WebhookSvc --> ValidateInfSvc
    WebhookSvc --> MutatePods
    WebhookSvc --> ValidateModel

    ControllerMgr -->|"HTTPS/6443 TLS 1.2+ SA Token"| K8sAPI
    ControllerMgr -.->|"Creates/Manages"| PredictorSvc

    %% External Service Flows
    StorageInit -->|"HTTPS/443 TLS 1.2+ AWS IAM"| S3
    StorageInit -->|"HTTPS/443 TLS 1.2+ GCP SA"| GCS
    StorageInit -->|"HTTPS/443 TLS 1.2+ Azure Key"| Azure
    ModelServer -.->|"gRPC/15010 mTLS SA Token"| IstioPilot

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicelayer fill:#e1f5e1,stroke:#4caf50,stroke-width:2px
    classDef application fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,K8sIngress ingress
    class Activator servicelayer
    class PredictorSvc,ModelServer,Agent,TransformerPod,ExplainerPod,RouterPod,StorageInit application
    class ControllerMgr,WebhookSvc,MutateInfSvc,ValidateInfSvc,MutatePods,K8sAPI controlplane
    class S3,GCS,Azure,IstioPilot externalservice
