graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>NS: redhat-ods-operator]
    end

    subgraph "ClusterRole Bindings"
        CRB1[controller-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[auth-proxy-rolebinding<br/>RoleBinding]
    end

    subgraph "Roles"
        direction TB
        CR1[controller-manager-role<br/>ClusterRole]
        CR2[auth-proxy-client-clusterrole<br/>ClusterRole]
        R1[leader-election-role<br/>Role]
    end

    subgraph "API Resources - Custom Resources"
        direction TB
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
        FT[features.opendatahub.io<br/>FeatureTracker]
    end

    subgraph "API Resources - Core"
        direction TB
        Core1[Core API<br/>deployments, services,<br/>configmaps, secrets, serviceaccounts]
        Apps1[apps<br/>deployments, statefulsets,<br/>replicasets]
    end

    subgraph "API Resources - RBAC"
        direction TB
        RBAC1[rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings]
    end

    subgraph "API Resources - OpenShift"
        direction TB
        Routes[route.openshift.io<br/>routes]
        OAuth[oauth.openshift.io<br/>oauthclients]
        Images[image.openshift.io<br/>imagestreams]
        Builds[build.openshift.io<br/>buildconfigs]
    end

    subgraph "API Resources - Kubernetes Extensions"
        direction TB
        CRDs[apiextensions.k8s.io<br/>customresourcedefinitions]
        Webhooks[admissionregistration.k8s.io<br/>validatingwebhookconfigurations,<br/>mutatingwebhookconfigurations]
        Network[networking.k8s.io<br/>networkpolicies]
    end

    subgraph "API Resources - Monitoring"
        direction TB
        Monitoring[monitoring.coreos.com<br/>servicemonitors,<br/>prometheusrules]
    end

    subgraph "API Resources - OLM"
        direction TB
        OLM[operators.coreos.com<br/>subscriptions,<br/>clusterserviceversions<br/>READ-ONLY]
    end

    subgraph "API Resources - Auth Operations"
        direction TB
        TokenReview[authentication.k8s.io<br/>tokenreviews]
        SubjectAccess[authorization.k8s.io<br/>subjectaccessreviews]
    end

    subgraph "Leader Election Resources"
        direction TB
        LeaderCM[Core API<br/>configmaps]
        LeaderLeases[coordination.k8s.io<br/>leases]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    SA -->|bound via<br/>leader-election-rolebinding| R1

    %% ClusterRole controller-manager-role to Resources
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| DSC
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| DSCI
    CR1 -->|"get, list, watch,<br/>create, update, patch, delete"| FT
    CR1 -->|all verbs| Core1
    CR1 -->|all verbs| Apps1
    CR1 -->|all verbs| RBAC1
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Routes
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| OAuth
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Images
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Builds
    CR1 -->|"create, delete, get,<br/>list, patch, watch"| CRDs
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Webhooks
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Network
    CR1 -->|"create, delete, get,<br/>list, patch, update, watch"| Monitoring
    CR1 -->|"get, list, watch"| OLM
    CR1 -->|create| TokenReview
    CR1 -->|create| SubjectAccess

    %% ClusterRole auth-proxy-client-clusterrole to Resources
    CR2 -->|create| TokenReview
    CR2 -->|create| SubjectAccess

    %% Role leader-election-role to Resources
    R1 -->|"get, list, watch,<br/>create, update, patch, delete"| LeaderCM
    R1 -->|"get, list, watch,<br/>create, update, patch, delete"| LeaderLeases

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    style DSC fill:#7ed321,stroke:#333,stroke-width:2px
    style DSCI fill:#7ed321,stroke:#333,stroke-width:2px
    style FT fill:#7ed321,stroke:#333,stroke-width:2px

    style Core1 fill:#3498db,stroke:#333,stroke-width:2px,color:#fff
    style Apps1 fill:#3498db,stroke:#333,stroke-width:2px,color:#fff
    style RBAC1 fill:#e74c3c,stroke:#333,stroke-width:2px,color:#fff

    style Routes fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style OAuth fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style Images fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style Builds fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff

    style CRDs fill:#95a5a6,stroke:#333,stroke-width:2px
    style Webhooks fill:#95a5a6,stroke:#333,stroke-width:2px
    style Network fill:#95a5a6,stroke:#333,stroke-width:2px

    style Monitoring fill:#e6522c,stroke:#333,stroke-width:2px,color:#fff
    style OLM fill:#16a085,stroke:#333,stroke-width:2px,color:#fff

    style TokenReview fill:#34495e,stroke:#333,stroke-width:2px,color:#fff
    style SubjectAccess fill:#34495e,stroke:#333,stroke-width:2px,color:#fff

    style LeaderCM fill:#f39c12,stroke:#333,stroke-width:2px
    style LeaderLeases fill:#f39c12,stroke:#333,stroke-width:2px
