graph TD
    subgraph "Service Accounts"
        SA[kuberay-operator<br/>namespace: kuberay-system]
        RayClusterSA["cluster-sa<br/>namespace: user-namespace"]
    end

    subgraph "Cluster Role Bindings"
        CRB[kuberay-operator]
    end

    subgraph "Role Bindings (Namespace: kuberay-system)"
        LeaderElectionRB[leader-election-rolebinding]
    end

    subgraph "Cluster Roles - Operator"
        CR[kuberay-operator]
    end

    subgraph "Roles - Operator (Namespace: kuberay-system)"
        LeaderElectionRole[leader-election-role]
    end

    subgraph "Cluster Roles - User Facing"
        RayJobEditor[ray-rayjob-editor]
        RayJobViewer[ray-rayjob-viewer]
        RayServiceEditor[ray-rayservice-editor]
        RayServiceViewer[ray-rayservice-viewer]
    end

    subgraph "API Resources - ray.io"
        RayClusterCRD[RayCluster<br/>rayclusters, status, finalizers]
        RayJobCRD[RayJob<br/>rayjobs, status, finalizers]
        RayServiceCRD[RayService<br/>rayservices, status, finalizers]
    end

    subgraph "API Resources - Core"
        Pods[Pods<br/>pods, pods/status]
        Services[Services<br/>services, services/status]
        Events[Events<br/>events]
        ServiceAccounts[ServiceAccounts<br/>serviceaccounts]
    end

    subgraph "API Resources - Batch"
        Jobs[Jobs<br/>batch/jobs]
    end

    subgraph "API Resources - Networking"
        Ingresses[Ingresses<br/>networking.k8s.io/ingresses]
        IngressClasses[IngressClasses<br/>networking.k8s.io/ingressclasses]
        IngressesExt[Ingresses - extensions<br/>extensions/ingresses]
    end

    subgraph "API Resources - OpenShift"
        Routes[Routes<br/>route.openshift.io/routes]
    end

    subgraph "API Resources - RBAC"
        Roles[Roles<br/>rbac.authorization.k8s.io/roles]
        RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io/rolebindings]
    end

    subgraph "API Resources - Coordination"
        Leases[Leases<br/>coordination.k8s.io/leases]
    end

    %% Operator ServiceAccount → Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LeaderElectionRB

    %% Bindings → Roles
    CRB -->|grants| CR
    LeaderElectionRB -->|grants| LeaderElectionRole

    %% ClusterRole → API Resources
    CR -->|get,list,watch,create,update,patch,delete| RayClusterCRD
    CR -->|get,list,watch,create,update,patch,delete| RayJobCRD
    CR -->|get,list,watch,create,update,patch,delete| RayServiceCRD
    CR -->|get,list,watch,create,update,patch,delete| Pods
    CR -->|get,list,watch,create,update,patch,delete| Services
    CR -->|get,list,watch,create,update,patch,delete| Events
    CR -->|get,list,watch,create,delete| ServiceAccounts
    CR -->|get,list,watch,create,update,patch,delete| Jobs
    CR -->|get,list,watch,create,update,patch,delete| Ingresses
    CR -->|get,list,watch,create,update,patch,delete| IngressClasses
    CR -->|get,list,watch,create,update,patch,delete| IngressesExt
    CR -->|get,list,watch,create,update,patch,delete| Routes
    CR -->|get,list,watch,create,update,delete| Roles
    CR -->|get,list,watch,create,update,delete| RoleBindings

    %% Leader Election Role → Leases
    LeaderElectionRole -->|get,list,create,update| Leases

    %% User-Facing Roles
    RayJobEditor -->|get,list,watch,create,update,patch,delete| RayJobCRD
    RayJobViewer -->|get,list,watch| RayJobCRD
    RayServiceEditor -->|get,list,watch,create,update,patch,delete| RayServiceCRD
    RayServiceViewer -->|get,list,watch| RayServiceCRD

    %% Ray Cluster ServiceAccount (created by operator)
    RayClusterSA -.->|created by operator| CR
    RayClusterSA -.->|used by Ray pods| Pods

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style RayClusterSA fill:#4a90e2,stroke:#333,stroke-dasharray: 5 5
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderElectionRole fill:#f5a623,stroke:#333
    style RayJobEditor fill:#7ed321,stroke:#333
    style RayJobViewer fill:#7ed321,stroke:#333
    style RayServiceEditor fill:#7ed321,stroke:#333
    style RayServiceViewer fill:#7ed321,stroke:#333
    style CRB fill:#999,stroke:#333
    style LeaderElectionRB fill:#999,stroke:#333

    style RayClusterCRD fill:#e8e8e8,stroke:#333
    style RayJobCRD fill:#e8e8e8,stroke:#333
    style RayServiceCRD fill:#e8e8e8,stroke:#333
    style Pods fill:#e8e8e8,stroke:#333
    style Services fill:#e8e8e8,stroke:#333
    style Events fill:#e8e8e8,stroke:#333
    style ServiceAccounts fill:#e8e8e8,stroke:#333
    style Jobs fill:#e8e8e8,stroke:#333
    style Ingresses fill:#e8e8e8,stroke:#333
    style IngressClasses fill:#e8e8e8,stroke:#333
    style IngressesExt fill:#e8e8e8,stroke:#333
    style Routes fill:#e8e8e8,stroke:#333
    style Roles fill:#e8e8e8,stroke:#333
    style RoleBindings fill:#e8e8e8,stroke:#333
    style Leases fill:#e8e8e8,stroke:#333
