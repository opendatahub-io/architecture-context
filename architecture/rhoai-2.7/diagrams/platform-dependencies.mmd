graph LR
    subgraph "Core Platform"
        RHOAIOp[RHOAI Operator<br/>v1.6.0-441]
    end

    subgraph "Component Operators"
        NBController[ODH Notebook Controller<br/>v1.27.0-rhods-244]
        DSPOp[Data Science Pipelines Operator<br/>025e77a]
        KServe[KServe<br/>80cb15e08]
        ModelMesh[ModelMesh Serving<br/>v1.27.0-rhods-168]
        ModelController[ODH Model Controller<br/>v1.27.0-rhods-153<br/>HA: 3 replicas]
        CodeFlare[CodeFlare Operator<br/>9cfde69]
        KubeRay[KubeRay Operator<br/>63106681]
        TrustyAI[TrustyAI Service Operator<br/>eb7d626<br/>Optional in 2.7]
    end

    subgraph "Platform Services (Internal)"
        Dashboard[ODH Dashboard]
        MCAD[MCAD<br/>Multi-Cluster App Dispatcher]
        InstaScale[InstaScale<br/>Cluster Autoscaling]
    end

    subgraph "External OpenShift Dependencies"
        OAuth[OpenShift OAuth<br/>Authentication]
        Router[OpenShift Router<br/>HAProxy Ingress]
        MachineAPI[OpenShift Machine API<br/>Node Provisioning]
        Monitoring[OpenShift Monitoring<br/>Prometheus]
    end

    subgraph "External Platform Dependencies"
        Istio[Istio Service Mesh<br/>Maistra 2.x<br/>mTLS + VirtualServices]
        Knative[Knative Serving 1.12+<br/>Serverless Autoscaling]
        Tekton[OpenShift Pipelines<br/>Tekton]
        CertManager[cert-manager 1.13+<br/>TLS Certificate Management]
    end

    subgraph "External Services"
        S3[S3-Compatible Storage<br/>AWS/GCS/Azure<br/>Model Artifacts]
        etcd[etcd<br/>ModelMesh Routing]
        CloudAPI[Cloud Provider APIs<br/>AWS/GCP/Azure<br/>Node Provisioning]
        Registries[Container Registries<br/>quay.io, registry.redhat.io]
    end

    subgraph "Integration Points (Internal)"
        ModelRegistry[Model Registry<br/>Model Metadata<br/>gRPC/9090]
    end

    %% Core Platform orchestrates all components
    RHOAIOp ==>|orchestrates ALL components| NBController
    RHOAIOp ==>|orchestrates ALL components| DSPOp
    RHOAIOp ==>|orchestrates ALL components| KServe
    RHOAIOp ==>|orchestrates ALL components| ModelMesh
    RHOAIOp ==>|orchestrates ALL components| ModelController
    RHOAIOp ==>|orchestrates ALL components| CodeFlare
    RHOAIOp ==>|orchestrates ALL components| KubeRay
    RHOAIOp ==>|orchestrates ALL components| TrustyAI
    RHOAIOp -->|creates namespaces| RHOAIOp
    RHOAIOp -->|configures| Istio

    %% Platform services
    RHOAIOp -->|deploys| Dashboard

    %% Notebook dependencies
    NBController -->|spawns| NBController
    NBController -->|integrates| OAuth
    NBController -->|creates| Router

    %% Data Science Pipelines dependencies
    DSPOp -->|depends on| Tekton
    DSPOp -->|integrates with| KServe
    DSPOp -->|uses| S3
    DSPOp -->|integrates| OAuth

    %% KServe dependencies
    KServe -->|depends on| Knative
    KServe -->|depends on| Istio
    KServe -.->|fetches metadata| ModelRegistry
    KServe -->|uses| S3

    %% ODH Model Controller integrations
    ModelController -->|watches| KServe
    ModelController -->|watches| ModelMesh
    ModelController -->|creates| Router
    ModelController -->|manages| Istio
    ModelController -->|creates NetworkPolicies| ModelController

    %% ModelMesh dependencies
    ModelMesh -->|depends on| etcd
    ModelMesh -->|uses KServe CRDs| KServe
    ModelMesh -.->|optional integration| Istio
    ModelMesh -->|uses| S3

    %% CodeFlare dependencies
    CodeFlare -->|manages| MCAD
    CodeFlare -->|manages| InstaScale
    CodeFlare -->|creates| KubeRay

    %% InstaScale cloud integration
    InstaScale -->|provisions nodes| MachineAPI
    MachineAPI -->|calls| CloudAPI

    %% KubeRay (independent)
    KubeRay -->|creates| Router

    %% TrustyAI integrations
    TrustyAI -->|integrates| KServe
    TrustyAI -->|patches| ModelMesh
    TrustyAI -->|exposes metrics| Monitoring
    TrustyAI -->|integrates| OAuth

    %% Monitoring
    Monitoring -->|scrapes| RHOAIOp
    Monitoring -->|scrapes| NBController
    Monitoring -->|scrapes| DSPOp
    Monitoring -->|scrapes| KServe
    Monitoring -->|scrapes| ModelMesh
    Monitoring -->|scrapes| ModelController
    Monitoring -->|scrapes| CodeFlare
    Monitoring -->|scrapes| KubeRay
    Monitoring -->|scrapes| TrustyAI

    %% Certificate management
    CertManager -.->|provides certs| KServe
    CertManager -.->|provides certs| ModelMesh
    CertManager -.->|provides certs| NBController

    %% Container images
    RHOAIOp -->|pulls images| Registries
    NBController -->|pulls images| Registries
    KServe -->|pulls images| Registries
    ModelMesh -->|pulls images| Registries

