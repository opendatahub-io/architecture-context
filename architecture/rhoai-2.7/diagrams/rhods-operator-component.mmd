graph TB
    subgraph "RHOAI Operator (rhods-operator)"
        DSCController[DataScienceCluster Controller]
        DSCIController[DSCInitialization Controller]
        SecretGen[SecretGenerator Controller]
        StatusCtrl[Status Controller]
        Metrics[Metrics Service :8080]
        Health[Health Probes :8081]

        DSCController -->|updates| StatusCtrl
        DSCIController -->|initializes| StatusCtrl
        SecretGen -->|generates| Secrets[OAuth Secrets]
    end

    subgraph "Custom Resources"
        DSC[DataScienceCluster CR]
        DSCI[DSCInitialization CR]
        FeatureTracker[FeatureTracker CR]
    end

    subgraph "Managed Components"
        Dashboard[Dashboard]
        Workbenches[Workbenches]
        Pipelines[Data Science Pipelines]
        KServe[KServe]
        ModelMesh[ModelMesh Serving]
        CodeFlare[CodeFlare]
        Ray[Ray]
    end

    subgraph "Infrastructure"
        Namespaces[Namespaces<br/>redhat-ods-applications<br/>redhat-ods-monitoring<br/>istio-system]
        ServiceMesh[Service Mesh Integration]
        Monitoring[Monitoring Stack]
    end

    User[Platform Admin] -->|creates| DSC
    User -->|creates| DSCI

    DSC -->|watched by| DSCController
    DSCI -->|watched by| DSCIController

    DSCIController -->|creates| Namespaces
    DSCIController -->|configures| ServiceMesh
    DSCIController -->|deploys| Monitoring

    DSCController -->|deploys| Dashboard
    DSCController -->|deploys| Workbenches
    DSCController -->|deploys| Pipelines
    DSCController -->|deploys| KServe
    DSCController -->|deploys| ModelMesh
    DSCController -->|deploys| CodeFlare
    DSCController -->|deploys| Ray

    DSCController -->|creates| FeatureTracker

    Prometheus[Prometheus] -->|scrapes| Metrics
    Kubelet[Kubelet] -->|probes| Health

    DSCController -->|depends on| K8sAPI[Kubernetes API]
    DSCIController -->|depends on| K8sAPI
    SecretGen -->|depends on| K8sAPI

    DSCController -.->|optional| GitRepo[Git Repository<br/>Custom Manifests]

    style DSCController fill:#4a90e2
    style DSCIController fill:#4a90e2
    style SecretGen fill:#4a90e2
    style StatusCtrl fill:#4a90e2
    style DSC fill:#f5a623
    style DSCI fill:#f5a623
    style FeatureTracker fill:#f5a623
    style Dashboard fill:#7ed321
    style Workbenches fill:#7ed321
    style Pipelines fill:#7ed321
    style KServe fill:#7ed321
    style ModelMesh fill:#7ed321
    style CodeFlare fill:#7ed321
    style Ray fill:#7ed321
    style K8sAPI fill:#e8e8e8
    style GitRepo fill:#e8e8e8
