graph TB
    subgraph ServiceAccounts["Service Accounts"]
        SA_Manager["manager<br/>Namespace: controller-namespace"]
        SA_ControllerManager["controller-manager<br/>Namespace: controller-namespace"]
        SA_Notebook["notebook-name-sa<br/>Namespace: user-namespace<br/>OAuth redirect annotations"]
    end

    subgraph ClusterRoleBindings["Cluster Role Bindings"]
        CRB_Manager[manager-rolebinding<br/>Cluster-wide]
    end

    subgraph RoleBindings["Role Bindings"]
        RB_LeaderElection["leader-election-rolebinding<br/>Namespace: controller-namespace"]
    end

    subgraph ClusterRoles["Cluster Roles"]
        CR_Manager[manager-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_Admin[notebooks-admin<br/>ClusterRole<br/>Aggregates to: admin]
        CR_Edit[notebooks-edit<br/>ClusterRole<br/>Aggregates to: edit]
        CR_View[notebooks-view<br/>ClusterRole<br/>Aggregates to: view]
    end

    subgraph APIResources_Manager["API Resources - Manager Role"]
        API_Notebooks[kubeflow.org<br/>notebooks, notebooks/status,<br/>notebooks/finalizers]
        API_Routes[route.openshift.io<br/>routes]
        API_Core[core<br/>services, serviceaccounts,<br/>secrets, configmaps]
        API_NetworkPolicies[networking.k8s.io<br/>networkpolicies]
        API_Proxies[config.openshift.io<br/>proxies]
    end

    subgraph APIResources_LeaderElection["API Resources - Leader Election Role"]
        API_ConfigMaps[core<br/>configmaps, events]
        API_Leases[coordination.k8s.io<br/>leases]
    end

    subgraph APIResources_User["API Resources - User Roles"]
        API_NotebooksUser[kubeflow.org<br/>notebooks, notebooks/status]
    end

    subgraph K8sStandardRoles["Kubernetes Standard Roles"]
        K8s_Admin[admin<br/>ClusterRole]
        K8s_Edit[edit<br/>ClusterRole]
        K8s_View[view<br/>ClusterRole]
    end

    %% Manager Service Account Flow
    SA_Manager -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    CR_Manager -->|get, list, watch, patch, update| API_Notebooks
    CR_Manager -->|get, list, watch, create, update, patch| API_Routes
    CR_Manager -->|get, list, watch, create, update, patch| API_Core
    CR_Manager -->|get, list, watch, create, update, patch| API_NetworkPolicies
    CR_Manager -->|get, list, watch| API_Proxies

    %% Leader Election Flow
    SA_ControllerManager -->|bound via| RB_LeaderElection
    RB_LeaderElection -->|grants| CR_LeaderElection
    CR_LeaderElection -->|get, list, watch, create, update, patch, delete| API_ConfigMaps
    CR_LeaderElection -->|get, list, watch, create, update, patch, delete| API_Leases

    %% User Roles - notebooks-admin
    CR_Admin -->|aggregates from| CR_Edit
    CR_Admin -.->|aggregated to| K8s_Admin

    %% User Roles - notebooks-edit
    CR_Edit -->|get, list, watch, create, delete, deletecollection, patch, update| API_NotebooksUser
    CR_Edit -.->|aggregated to| K8s_Edit

    %% User Roles - notebooks-view
    CR_View -->|get, list, watch| API_NotebooksUser
    CR_View -.->|aggregated to| K8s_View

    %% Notebook ServiceAccount (runtime)
    SA_Notebook -.->|used by| NotebookPod[Notebook Pod<br/>OAuth Proxy + JupyterLab]

    %% Subject Access Review
    OAuthProxy["OAuth Proxy Sidecar"] -->|performs SAR check| SAR_Check["Subject Access Review<br/>Verb: get<br/>Resource: notebooks<br/>Name: notebook-name<br/>Namespace: namespace"]
    SAR_Check -.->|requires| API_NotebooksUser
    SAR_Check -.->|user must have| CR_View

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#e1d5e7,stroke:#333,stroke-width:2px
    classDef k8srole fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    classDef runtime fill:#d5e8d4,stroke:#333,stroke-width:2px

    class SA_Manager,SA_ControllerManager,SA_Notebook serviceaccount
    class CRB_Manager,RB_LeaderElection binding
    class CR_Manager,CR_LeaderElection,CR_Admin,CR_Edit,CR_View role
    class API_Notebooks,API_Routes,API_Core,API_NetworkPolicies,API_Proxies,API_ConfigMaps,API_Leases,API_NotebooksUser resource
    class K8s_Admin,K8s_Edit,K8s_View k8srole
    class NotebookPod,OAuthProxy,SAR_Check runtime
