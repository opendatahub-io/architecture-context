graph TD
    subgraph "Service Accounts"
        SA_Controller[kserve-controller-manager<br/>Namespace: kserve]
        SA_Predictor["{isvc-name}-sa<br/>Namespace: {user-namespace}"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kserve-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings (kserve namespace)"
        RB_Leader[kserve-leader-election-rolebinding<br/>RoleBinding]
        RB_Auth[kserve-auth-proxy-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole: kserve-manager-role"
        direction TB

        CR_Manager[kserve-manager-role<br/>ClusterRole]

        subgraph "KServe CRDs (serving.kserve.io)"
            Perm_InfSvc[inferenceservices<br/>inferenceservices/finalizers<br/>inferenceservices/status]
            Perm_Runtime[servingruntimes<br/>servingruntimes/finalizers<br/>servingruntimes/status]
            Perm_ClusterRuntime[clusterservingruntimes<br/>clusterservingruntimes/finalizers<br/>clusterservingruntimes/status]
            Perm_Graph[inferencegraphs<br/>inferencegraphs/finalizers<br/>inferencegraphs/status]
            Perm_Model[trainedmodels<br/>trainedmodels/status]
            Perm_Storage[clusterstoragecontainers]
        end

        subgraph "Knative CRDs (serving.knative.dev)"
            Perm_Knative[services<br/>services/finalizers<br/>services/status]
        end

        subgraph "Istio CRDs (networking.istio.io)"
            Perm_Istio[virtualservices<br/>virtualservices/finalizers<br/>virtualservices/status]
        end

        subgraph "Core Kubernetes Resources"
            Perm_Apps[apps/deployments]
            Perm_Core[services, secrets, configmaps<br/>core API group]
            Perm_Read[pods, namespaces, serviceaccounts<br/>get, list, watch only]
            Perm_Autoscaling[autoscaling/horizontalpodautoscalers]
            Perm_Networking[networking.k8s.io/ingresses]
            Perm_Admission[admissionregistration.k8s.io/<br/>mutatingwebhookconfigurations,<br/>validatingwebhookconfigurations]
        end
    end

    subgraph "Permissions Legend"
        Verbs_Full["create, delete, get, list,<br/>patch, update, watch"]
        Verbs_Read["get, list, watch"]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| RB_Leader
    SA_Controller -->|bound via| RB_Auth

    CRB_Manager -->|grants| CR_Manager

    %% Permissions
    CR_Manager -->|full CRUD| Perm_InfSvc
    CR_Manager -->|full CRUD| Perm_Runtime
    CR_Manager -->|full CRUD| Perm_ClusterRuntime
    CR_Manager -->|full CRUD| Perm_Graph
    CR_Manager -->|full CRUD| Perm_Model
    CR_Manager -->|full CRUD| Perm_Storage

    CR_Manager -->|full CRUD| Perm_Knative
    CR_Manager -->|full CRUD| Perm_Istio

    CR_Manager -->|full CRUD| Perm_Apps
    CR_Manager -->|full CRUD| Perm_Core
    CR_Manager -->|read-only| Perm_Read
    CR_Manager -->|full CRUD| Perm_Autoscaling
    CR_Manager -->|full CRUD| Perm_Networking
    CR_Manager -->|full CRUD| Perm_Admission

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Predictor fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:3px,color:#000
    style CRB_Manager fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style RB_Leader fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style RB_Auth fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style Perm_InfSvc fill:#d5e8d4,stroke:#82b366,color:#000
    style Perm_Runtime fill:#d5e8d4,stroke:#82b366,color:#000
    style Perm_ClusterRuntime fill:#d5e8d4,stroke:#82b366,color:#000
    style Perm_Graph fill:#d5e8d4,stroke:#82b366,color:#000
    style Perm_Model fill:#d5e8d4,stroke:#82b366,color:#000
    style Perm_Storage fill:#d5e8d4,stroke:#82b366,color:#000

    style Perm_Knative fill:#e1d5e7,stroke:#9673a6,color:#000
    style Perm_Istio fill:#e1d5e7,stroke:#9673a6,color:#000

    style Perm_Apps fill:#dae8fc,stroke:#6c8ebf,color:#000
    style Perm_Core fill:#dae8fc,stroke:#6c8ebf,color:#000
    style Perm_Read fill:#dae8fc,stroke:#6c8ebf,color:#000
    style Perm_Autoscaling fill:#dae8fc,stroke:#6c8ebf,color:#000
    style Perm_Networking fill:#dae8fc,stroke:#6c8ebf,color:#000
    style Perm_Admission fill:#dae8fc,stroke:#6c8ebf,color:#000

    style Verbs_Full fill:#fff2cc,stroke:#d6b656,color:#000
    style Verbs_Read fill:#fff2cc,stroke:#d6b656,color:#000
