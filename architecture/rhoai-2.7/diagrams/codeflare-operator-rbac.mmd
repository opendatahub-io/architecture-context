graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[codeflare-operator-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[codeflare-operator-instascale-rolebinding<br/>ClusterRoleBinding]
        CRB3[codeflare-operator-mcad-controller-ray-rolebinding<br/>ClusterRoleBinding]
        RB1[codeflare-operator-leader-election-rolebinding<br/>RoleBinding in opendatahub]
    end

    subgraph "ClusterRoles"
        CR1[manager-role<br/>ClusterRole]
        CR2[instascale-role<br/>ClusterRole]
        CR3[mcad-controller-ray-clusterrole<br/>ClusterRole]
        CR4[leader-election-role<br/>Role]
    end

    subgraph "API Resources - CodeFlare CRDs"
        AppWrapper["workload.codeflare.dev<br/>AppWrapper<br/>AppWrapper/finalizers<br/>AppWrapper/status<br/>SchedulingSpec"]
        QuotaSubtree["quota.codeflare.dev<br/>QuotaSubtree"]
    end

    subgraph "API Resources - Core & Apps"
        Core["Core API<br/>Pods, Services, Secrets,<br/>ConfigMaps, Nodes,<br/>PVCs, PVs, Bindings<br/>ServiceAccounts"]
        Apps["apps<br/>Deployments<br/>ReplicaSets<br/>StatefulSets"]
        Batch["batch<br/>Jobs"]
    end

    subgraph "API Resources - Machine & Ray"
        Machine["machine.openshift.io<br/>* (all resources)<br/>Machines<br/>MachineSets"]
        Ray["ray.io<br/>RayClusters<br/>RayClusters/finalizers<br/>RayClusters/status"]
        Routes["route.openshift.io<br/>Routes"]
        Ingresses["networking.k8s.io<br/>Ingresses"]
    end

    subgraph "API Resources - Scheduling & Storage"
        PodGroups["scheduling.sigs.k8s.io<br/>PodGroups"]
        Leases["coordination.k8s.io<br/>Leases"]
        Storage["storage.k8s.io<br/>CSIDrivers<br/>CSINodes<br/>CSIStorageCapacities"]
        Config["config.openshift.io<br/>ClusterVersions"]
    end

    %% Service Account to Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1

    %% Bindings to Roles
    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    RB1 -->|grants| CR4

    %% manager-role permissions
    CR1 -->|create,delete,deletecollection,<br/>get,list,patch,update,watch| AppWrapper
    CR1 -->|create,delete,deletecollection,<br/>get,list,patch,update,watch| QuotaSubtree
    CR1 -->|create,delete,deletecollection,<br/>get,list,patch,update,watch| Core
    CR1 -->|create,delete,<br/>get,list,patch,update,watch| Apps
    CR1 -->|create,delete,<br/>list,patch,update,watch| Batch
    CR1 -->|create,delete,deletecollection,<br/>get,list,patch,update,watch| PodGroups
    CR1 -->|create,get,update| Leases
    CR1 -->|create,delete,<br/>get,list,patch,update,watch| Machine
    CR1 -->|get,list,watch| Storage

    %% instascale-role permissions
    CR2 -->|get,list,patch,update| Core
    CR2 -->|create,delete,<br/>get,list,patch,update,watch| Machine
    CR2 -->|get,list,watch| Config

    %% mcad-controller-ray-clusterrole permissions
    CR3 -->|create,delete,<br/>get,list,patch,update,watch| Ray
    CR3 -->|create,delete,<br/>get,list,patch,update,watch| Ingresses
    CR3 -->|create,delete,<br/>get,list,patch,update,watch| Routes

    %% leader-election-role permissions
    CR4 -->|get,list,watch,<br/>create,update,patch,delete| Leases

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CR1 fill:#f5a623,color:#000
    style CR2 fill:#f5a623,color:#000
    style CR3 fill:#f5a623,color:#000
    style CR4 fill:#f5a623,color:#000
    style CRB1 fill:#dae8fc,stroke:#6c8ebf
    style CRB2 fill:#dae8fc,stroke:#6c8ebf
    style CRB3 fill:#dae8fc,stroke:#6c8ebf
    style RB1 fill:#dae8fc,stroke:#6c8ebf
    style AppWrapper fill:#7ed321,color:#000
    style QuotaSubtree fill:#7ed321,color:#000
    style Core fill:#7ed321,color:#000
    style Apps fill:#7ed321,color:#000
    style Batch fill:#7ed321,color:#000
    style Machine fill:#7ed321,color:#000
    style Ray fill:#7ed321,color:#000
    style Routes fill:#7ed321,color:#000
    style Ingresses fill:#7ed321,color:#000
    style PodGroups fill:#7ed321,color:#000
    style Leases fill:#7ed321,color:#000
    style Storage fill:#7ed321,color:#000
    style Config fill:#7ed321,color:#000
