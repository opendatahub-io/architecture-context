// TrustyAI Explainability - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Requests fairness metrics, drift analysis, and model explanations"
        mlops = person "MLOps Engineer" "Monitors model fairness and drift via Prometheus dashboards"

        trustyai = softwareSystem "TrustyAI Explainability" "AI fairness, bias tracking, data drift detection, and model explainability service" {
            service = container "explainability-service" "Quarkus REST API exposing metrics, explainers, data management, and Prometheus integration" "Java 17 / Quarkus 3.8.5"
            core = container "explainability-core" "Core algorithms: LIME, SHAP, Counterfactual, PDP, fairness (SPD, DIR), drift (KS, MMD, Meanshift)" "Java Library"
            connectors = container "explainability-connectors" "KServe v1/v2 protocol connectors (HTTP and gRPC), inference payload parsing" "Java Library"
            arrow = container "explainability-arrow" "Apache Arrow format support for data interchange" "Java Library"
            scheduler = container "PrometheusScheduler" "Scheduled metric computation and Prometheus metric publishing" "Internal Scheduler"
            reconciler = container "InferencePayloadReconciler" "Reconciles partial inference payloads (input/output) into complete records" "Internal Component"
        }

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Manages TrustyAI Service deployment lifecycle, creates Deployments/Services/Routes" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh Serving" "Model serving platform that sends inference payloads to TrustyAI" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving platform with InferenceLogger sending CloudEvents" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and alerting, scrapes TrustyAI metrics" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing RHOAI components including TrustyAI" "Internal RHOAI"

        mariadb = softwareSystem "MariaDB/MySQL" "Relational database for inference data storage (DATABASE mode)" "External"
        minio = softwareSystem "MinIO/S3" "Object storage for inference data (MINIO mode)" "External"
        pvc = softwareSystem "PVC Storage" "PersistentVolumeClaim for flat file inference data storage (default)" "External"

        // Relationships - External actors
        datascientist -> trustyai "Requests fairness metrics, drift analysis, explanations" "HTTP/80"
        mlops -> prometheus "Views TrustyAI metrics dashboards"

        // Relationships - Internal components
        service -> core "Uses algorithms for metrics and explanations"
        service -> connectors "Uses for KServe v1/v2 protocol communication"
        service -> arrow "Uses for Arrow data format support"
        scheduler -> service "Publishes computed metrics"
        reconciler -> service "Stores reconciled inference records"

        // Relationships - RHOAI internal
        trustyaiOperator -> trustyai "Deploys and manages lifecycle"
        modelmesh -> trustyai "Sends inference payloads" "HTTP/80 POST /consumer/kserve/v2"
        kserve -> trustyai "Sends inference CloudEvents" "HTTP/8080 CloudEvents"
        prometheus -> trustyai "Scrapes metrics" "HTTP/80 GET /q/metrics"

        // Relationships - External services
        trustyai -> mariadb "Stores inference data" "MySQL/3306"
        trustyai -> minio "Stores inference data" "S3 API HTTP/HTTPS"
        trustyai -> pvc "Stores inference data" "Filesystem I/O"
        trustyai -> kserve "Sends inference requests for explanations" "gRPC/HTTP"
        trustyai -> modelmesh "Sends inference requests for explanations" "gRPC/HTTP"
    }

    views {
        systemContext trustyai "SystemContext" {
            include *
            autoLayout
        }

        container trustyai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
