%% TrustyAI Explainability - RBAC Visualization
%% Generated by: Claude Opus 4.6
graph TD
    subgraph "Service Account"
        SA["trustyai-serviceaccount"]
    end

    subgraph "ClusterRole Binding"
        CRB["trustyai-clusterrolebinding<br/>(cluster-scoped)"]
    end

    subgraph "ClusterRole"
        CR["trustyai-role"]
    end

    subgraph "API Resources"
        ConfigMaps["core (v1)<br/>ConfigMaps"]
    end

    subgraph "Permissions"
        Verbs["create, delete, get,<br/>list, patch, update, watch"]
    end

    SA -->|"bound via"| CRB
    CRB -->|"grants"| CR
    CR -->|"allows"| Verbs
    Verbs -->|"on resource"| ConfigMaps

    subgraph "Authentication & Authorization"
        direction TB
        RESTAuth["All REST Endpoints<br/>Auth: None (service-internal)<br/>Relies on network policy<br/>and OAuth proxy sidecar"]
        MetricsAuth["/q/metrics Endpoint<br/>Auth: Bearer Token<br/>(ServiceAccount token)<br/>Enforcement: ServiceMonitor"]
        OAuthProxy["OAuth Proxy Sidecar<br/>(injected by Operator)<br/>Provides external auth"]
    end

    subgraph "Secrets Access"
        TLSSecret["TLS Certificates<br/>(/etc/tls/internal/)<br/>Type: kubernetes.io/tls<br/>Purpose: HTTPS on 4443"]
        DBSecret["Database Credentials<br/>Type: Opaque<br/>Purpose: MariaDB/MySQL auth"]
        MinIOSecret["MinIO Credentials<br/>Type: Opaque<br/>Purpose: S3 access key/secret"]
    end

    SA -.->|"mounts"| TLSSecret
    SA -.->|"reads env from"| DBSecret
    SA -.->|"reads env from"| MinIOSecret

    %% Styling
    style SA fill:#4a90e2,color:#fff
    style CRB fill:#6c8ebf,color:#fff
    style CR fill:#f5a623,color:#fff
    style ConfigMaps fill:#7ed321,color:#fff
    style Verbs fill:#dae8fc
    style RESTAuth fill:#ffe6cc,stroke:#d79b00
    style MetricsAuth fill:#ffe6cc,stroke:#d79b00
    style OAuthProxy fill:#ffe6cc,stroke:#d79b00
    style TLSSecret fill:#e1d5e7,stroke:#9673a6
    style DBSecret fill:#e1d5e7,stroke:#9673a6
    style MinIOSecret fill:#e1d5e7,stroke:#9673a6
