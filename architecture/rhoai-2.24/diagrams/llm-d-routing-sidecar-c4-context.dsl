// C4 Context Diagram: llm-d-routing-sidecar
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/llm-d-routing-sidecar.md

workspace {
    model {
        client = person "Client / Gateway" "Sends OpenAI-compatible inference requests with optional x-prefiller-host-port header"

        routingSidecar = softwareSystem "llm-d-routing-sidecar" "Reverse proxy sidecar that orchestrates disaggregated prefill/decode inference by routing requests between prefiller and decoder vLLM workers" {
            proxyServer = container "Reverse Proxy Server" "Intercepts inference requests, orchestrates P/D routing" "Go HTTP/HTTPS Server"
            nixlv2Connector = container "NIXL v2 Connector" "Current P/D disaggregation protocol using kv_transfer_params" "Go Protocol Handler"
            allowlistValidator = container "AllowlistValidator" "SSRF protection via InferencePool resource watching" "Go Security Component"
            tlsManager = container "TLS Manager" "Manages TLS certificates for secure proxy operation" "Go Security Component"
        }

        decoderVLLM = softwareSystem "Local Decoder vLLM" "Local vLLM inference engine for decode phase" "Sidecar Backend"
        prefillerVLLM = softwareSystem "Remote Prefiller vLLM" "Remote prefiller vLLM workers for KV-cache population" "Remote Backend"
        k8sAPI = softwareSystem "Kubernetes API Server" "Provides InferencePool and Pod resource watching" "Platform"
        inferencePool = softwareSystem "Gateway API Inference Extension" "Defines InferencePool CRD for valid prefill target pools" "Platform"
        epp = softwareSystem "Endpoint Picker (EPP)" "Sets x-prefiller-host-port header for routing decisions" "Internal llm-d"

        // Relationships
        client -> routingSidecar "POST /v1/chat/completions, /v1/completions" "HTTPS/8000, TLS 1.2+"
        epp -> routingSidecar "Routes requests with x-prefiller-host-port header" "HTTP(S)"
        routingSidecar -> decoderVLLM "Forwards decode requests" "HTTP(S)/8001, TLS 1.2+ configurable"
        routingSidecar -> prefillerVLLM "Forwards prefill requests" "HTTP(S)/variable port, TLS 1.2+ configurable"
        routingSidecar -> k8sAPI "Watches InferencePool + Pods for SSRF allowlist" "HTTPS/443, SA Token"

        // Internal relationships
        proxyServer -> nixlv2Connector "Uses for P/D protocol"
        proxyServer -> allowlistValidator "Validates prefiller targets"
        proxyServer -> tlsManager "TLS configuration"
        allowlistValidator -> k8sAPI "list+watch InferencePool, Pods" "HTTPS/443"
    }

    views {
        systemContext routingSidecar "SystemContext" {
            include *
            autoLayout
        }

        container routingSidecar "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Sidecar Backend" {
                background #f5a623
                color #ffffff
            }
            element "Remote Backend" {
                background #f5a623
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Internal llm-d" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
