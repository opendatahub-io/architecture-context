        UID["User ID: 2000<br/>(non-root)"]
        GID["Group ID: 0<br/>(root group - OpenShift arbitrary UID)"]
        Home["Home: /home/vllm<br/>(writable)"]
    end

    subgraph EnvSecurity["Environment Security Controls"]
