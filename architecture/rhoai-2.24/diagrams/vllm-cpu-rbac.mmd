    subgraph AuthMechanisms["Authentication Mechanisms"]
        direction TB

        subgraph APIAuth["OpenAI API Auth (Port 8000)"]
            APIKey["API Key Bearer Token<br/>--api-key / VLLM_API_KEY<br/>Optional: 401 if set & missing"]
