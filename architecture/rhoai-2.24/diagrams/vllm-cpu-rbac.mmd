        HFToken["HuggingFace Token<br/>Type: Opaque<br/>Provisioned by: User<br/>Auto-rotate: No"]
    end

    subgraph TLSConfig["TLS Configuration"]
        OptionalTLS["Optional TLS<br/>--ssl-keyfile / --ssl-certfile<br/>--ssl-ca-certs"]
        SSLRefresh["SSL Hot-Reload<br/>--enable-ssl-refresh<br/>watchfiles monitoring"]
    end

    subgraph ManagedBy["RBAC Managed By (External)"]
        KServeRBAC["KServe Controller<br/>Manages pod RBAC"]
        ModelMeshRBAC["ModelMesh<br/>Manages routing RBAC"]
        OperatorRBAC["rhods-operator<br/>Manages runtime deployment"]
    end

    %% Connections
    Pod --> UID
    Pod --> GID
    Pod --> Home
    Pod --> HFOffline
    Pod --> NoStats

    Pod --> APIKey
    Pod --> NoAuthEndpoints
    Pod --> NoGRPCAuth

    SSLSecret -->|"mounts"| OptionalTLS
    OptionalTLS --> SSLRefresh
    APIKeySecret -->|"env: VLLM_API_KEY"| APIKey
