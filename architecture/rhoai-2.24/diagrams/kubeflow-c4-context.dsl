// Kubeflow Notebook Controller - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and manages Jupyter Notebook workbenches"
        platformAdmin = person "Platform Admin" "Configures notebook controller settings and culling policies"

        kubeflow = softwareSystem "Kubeflow Notebook Controller" "Manages lifecycle of Jupyter Notebook workbenches on OpenShift via the Notebook CRD" {
            kfNotebookController = container "kf-notebook-controller" "Reconciles Notebook CRs into StatefulSets, Services, and optional VirtualServices" "Go Operator (controller-runtime)"
            cullingController = container "Culling Controller" "Monitors notebook idle time and scales to zero replicas" "Go Controller (controller-runtime)"
            odhNotebookController = container "odh-notebook-controller" "OpenShift-specific reconciliation: Routes, OAuth, NetworkPolicies, CA certs, pipeline config" "Go Operator (controller-runtime)"
            mutatingWebhook = container "Notebook Mutating Webhook" "Injects oauth-proxy sidecar, CA bundle volumes, pipeline runtime images" "Admission Webhook (8443/TCP)"
        }

        // Internal ODH Components
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages Kubeflow controllers via kustomize overlays" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Provides UI for creating and managing notebooks" "Internal ODH"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Manages Data Science Pipelines Application CRs" "Internal ODH"

        // OpenShift Platform
        openshiftOAuth = softwareSystem "OpenShift OAuth Server" "Provides authentication for notebook access via OAuth protocol" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Provides external access to notebooks via Routes" "External"
        openshiftServiceCA = softwareSystem "OpenShift service-ca Operator" "Auto-provisions TLS certificates for Services" "External"
        openshiftImageRegistry = softwareSystem "OpenShift Image Registry" "Provides ImageStream resolution for notebook images" "External"

        // Kubernetes
        k8sAPI = softwareSystem "Kubernetes API Server" "Manages cluster resources" "External"
        prometheus = softwareSystem "Prometheus" "Collects notebook lifecycle metrics" "External"

        // Relationships - User interactions
        dataScientist -> kubeflow "Creates Notebook CR via kubectl/Dashboard"
        dataScientist -> openshiftRouter "Accesses notebook workbench" "HTTPS/443"
        platformAdmin -> rhodsOperator "Configures controller settings"

        // Relationships - Internal ODH
        rhodsOperator -> kubeflow "Deploys controllers via kustomize overlays"
        odhDashboard -> kubeflow "Creates Notebook CRs" "HTTPS/443"
        kubeflow -> dspOperator "Reads DSPA CR for Elyra pipeline config" "HTTPS/443"
        kubeflow -> odhDashboard "Reads Dashboard CR for API URL" "HTTPS/443"

        // Relationships - OpenShift Platform
        kubeflow -> openshiftOAuth "OAuth proxy delegates authentication" "HTTPS/443"
        kubeflow -> openshiftImageRegistry "Resolves notebook container images" "HTTPS/443"
        openshiftServiceCA -> kubeflow "Auto-provisions TLS certificates"
        openshiftRouter -> kubeflow "Routes traffic to notebook pods" "HTTPS/8443"

        // Relationships - Infrastructure
        kubeflow -> k8sAPI "CRUD operations on cluster resources" "HTTPS/443"
        prometheus -> kubeflow "Scrapes metrics" "HTTP/8080"

        // Container-level relationships
        kfNotebookController -> k8sAPI "Creates StatefulSets, Services" "HTTPS/443"
        cullingController -> k8sAPI "Patches stop annotation" "HTTPS/443"
        odhNotebookController -> k8sAPI "Creates Routes, NetworkPolicies, OAuthClients" "HTTPS/443"
        k8sAPI -> mutatingWebhook "Calls webhook on Notebook create/update" "HTTPS/8443"
        odhNotebookController -> dspOperator "Watches DSPA CRs" "HTTPS/443"
        odhNotebookController -> odhDashboard "Reads Dashboard CR" "HTTPS/443"
    }

    views {
        systemContext kubeflow "SystemContext" {
            include *
            autoLayout
        }

        container kubeflow "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
        }
    }
}
