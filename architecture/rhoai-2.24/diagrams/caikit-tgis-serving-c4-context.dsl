/*
 * C4 Context Diagram: caikit-tgis-serving
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/caikit-tgis-serving.md
 */

workspace {
    model {
        user = person "Data Scientist" "Creates InferenceService CRs to deploy and serve LLM models"

        caikitTgisServing = softwareSystem "Caikit-TGIS-Serving" "Python container image providing Caikit AI runtime for serving LLMs with optional TGIS backend, deployed as KServe ServingRuntime" {
            caikitRuntime = container "Caikit Runtime" "Core AI runtime providing HTTP/gRPC inference endpoints" "Python 3.11 (caikit 0.28.1)" {
                tags "Primary"
            }
            caikitNlp = container "caikit-nlp" "NLP module for text generation and NLP model tasks" "Python Library (0.5.14)" {
                tags "Library"
            }
            caikitTgisBackend = container "caikit-tgis-backend" "Backend connector enabling Caikit to delegate inference to TGIS over gRPC" "Python Library (0.1.39)" {
                tags "Library"
            }
            healthProbe = container "caikit_health_probe" "Health check utility for readiness and liveness probes" "Python Module" {
                tags "Utility"
            }
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - backend inference engine co-located in pod" {
            tags "Internal RHOAI"
        }

        kserve = softwareSystem "KServe" "Orchestrates model deployment lifecycle via ServingRuntime and InferenceService CRDs" {
            tags "Internal RHOAI"
        }

        knativeServing = softwareSystem "Knative Serving" "Provides serverless autoscaling for inference pods" {
            tags "Internal RHOAI"
        }

        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic management, and ingress via sidecar injection" {
            tags "Internal RHOAI"
        }

        rhoaiOperator = softwareSystem "RHOAI Operator" "Manages KServe component lifecycle via DataScienceCluster CR" {
            tags "Internal RHOAI"
        }

        s3Storage = softwareSystem "S3/MinIO Storage" "Model artifact storage - models loaded at pod startup" {
            tags "External Service"
        }

        prometheus = softwareSystem "Prometheus" "Metrics collection from openshift-user-workload-monitoring namespace" {
            tags "External Service"
        }

        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for CRD operations" {
            tags "Platform"
        }

        # Relationships
        user -> caikitTgisServing "Sends inference requests via HTTP/gRPC"
        user -> kserve "Creates InferenceService CR via kubectl/dashboard"

        caikitRuntime -> caikitNlp "Uses for NLP model tasks"
        caikitRuntime -> caikitTgisBackend "Uses for TGIS delegation"

        caikitTgisServing -> tgis "Delegates inference via gRPC" "gRPC/8033 plaintext (localhost)"
        caikitTgisServing -> s3Storage "Downloads model artifacts at startup" "HTTP/9000 AWS Key Auth"

        kserve -> caikitTgisServing "Manages pod lifecycle" "Kubernetes API TLS 1.2+"
        kserve -> k8sApi "Watches ServingRuntime/InferenceService CRDs" "HTTPS TLS 1.2+"
        knativeServing -> caikitTgisServing "Provides autoscaling" "Kubernetes API"
        istio -> caikitTgisServing "Injects sidecar for mTLS and traffic management" "mTLS STRICT"
        rhoaiOperator -> kserve "Manages KServe lifecycle" "DataScienceCluster CR"
        prometheus -> caikitTgisServing "Scrapes metrics" "HTTP/8086 PERMISSIVE mTLS"
    }

    views {
        systemContext caikitTgisServing "SystemContext" {
            include *
            autoLayout
        }

        container caikitTgisServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #666666
                color #ffffff
            }
            element "Primary" {
                background #4a90e2
                color #ffffff
            }
            element "Library" {
                background #85c1e9
                color #000000
            }
            element "Utility" {
                background #aed6f1
                color #000000
            }
        }
    }
}
