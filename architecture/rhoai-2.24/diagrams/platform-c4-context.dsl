/*
 * RHOAI Platform C4 Context Diagram - Version 2.24
 * Generated by Claude Opus 4.6
 *
 * Render with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace platform-c4-context.dsl -format png
 */

workspace {

    model {
        // Users / Personas
        dataSci = person "Data Scientist" "Develops, trains, and deploys ML models using notebooks and pipelines"
        mlEngineer = person "ML Engineer" "Deploys and manages model serving infrastructure"
        admin = person "Platform Admin" "Manages RHOAI platform configuration and operations"
        appDev = person "Application Developer" "Integrates ML models into applications via inference APIs"

        // RHOAI Platform
        rhoai = softwareSystem "RHOAI Platform" "Red Hat OpenShift AI - Comprehensive AI/ML platform for model development, training, serving, and monitoring" {

            rhodsOperator = container "rhods-operator" "Central platform operator managing all AI/ML components via DataScienceCluster CR" "Go Operator (OLM)"

            dashboard = container "ODH Dashboard" "Web UI for platform management with OAuth proxy" "TypeScript/Node.js"

            subgraph_serving = group "Model Serving" {
                kserve = container "KServe Controller" "Manages InferenceService lifecycle (Serverless, RawDeployment)" "Go Operator"
                odhModelCtrl = container "odh-model-controller" "Integration layer for Routes, Gateways, AuthConfigs, NetworkPolicies" "Go Controller"
                modelmeshServing = container "ModelMesh Serving" "Multi-model serving controller with distributed LRU cache" "Go/Java"
                llmdEPP = container "llm-d Inference Scheduler" "Gateway API Inference Extension endpoint picker with KV-cache-aware routing" "Go Service"
            }

            subgraph_runtimes = group "Inference Runtimes" {
                vllm = container "vLLM" "High-throughput LLM inference (OpenAI + TGIS APIs)" "Python/C++ (CUDA/CPU/ROCm/Gaudi)"
                ovms = container "OpenVINO Model Server" "Intel-optimized inference (TFS, KServe v2, OpenAI APIs)" "C++"
                caikit = container "Caikit-NLP / Caikit-TGIS" "NLP inference runtime (embedding, reranking, classification)" "Python"
            }

            subgraph_pipelines = group "Pipeline Orchestration" {
                dspOperator = container "DSP Operator" "Manages Data Science Pipelines stack via DSPA CR" "Go Operator"
                dspAPI = container "DSP API Server" "KFP v2 pipeline orchestration API" "Go"
                argoWF = container "Argo Workflows" "Workflow execution engine for pipeline steps" "Go"
                mlMetadata = container "ML Metadata" "Pipeline artifact lineage and metadata storage" "C++ gRPC"
            }

            subgraph_training = group "Distributed Training" {
                trainingOp = container "Training Operator" "PyTorchJob, TFJob, XGBoostJob, MPIJob management" "Go Operator"
                kuberay = container "KubeRay" "Ray cluster lifecycle management (RayCluster, RayJob)" "Go Operator"
                codeflare = container "CodeFlare Operator" "RayCluster security, OAuth proxy, mTLS, NetworkPolicies" "Go Operator"
                kueue = container "Kueue" "Job queuing, resource management, fair sharing" "Go Operator"
            }

            subgraph_safety = group "AI Safety & Monitoring" {
                trustyai = container "TrustyAI" "Fairness metrics, drift detection, explainability" "Java/Quarkus"
                guardrails = container "FMS Guardrails Orchestrator" "Content safety guardrail pipeline (PII, toxicity)" "Rust"
                lmEval = container "LM Evaluation Harness" "LLM evaluation framework (MT-Bench, MMLU)" "Python"
            }

            subgraph_data = group "Data & Model Management" {
                modelRegistry = container "Model Registry" "ML model metadata management (REST API)" "Go"
                feast = container "Feast Feature Store" "Online/offline feature store with OIDC auth" "Go/Python"
                llamaStack = container "Llama Stack" "Unified LLM API server (inference, agents, RAG, safety)" "Python"
            }

            subgraph_notebooks = group "Development Environments" {
                notebookCtrl = container "Notebook Controller" "Workbench pod lifecycle management" "Go (Kubeflow)"
                notebooks = container "Workbench Images" "JupyterLab, Code Server, RStudio with GPU support" "Python/R"
            }
        }

        // External Dependencies
        openshift = softwareSystem "OpenShift Container Platform" "Kubernetes distribution (v4.15-v4.19)" "External"
        istio = softwareSystem "OpenShift Service Mesh (Istio)" "Service mesh for mTLS, traffic management, AuthorizationPolicy" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling platform for KServe" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and lifecycle management" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate lifecycle management" "External"
        gatewayAPI = softwareSystem "Gateway API" "Kubernetes Gateway API with Inference Extension (GIE)" "External"

        // External Services
        s3 = softwareSystem "S3 / Object Storage" "Model artifact and pipeline artifact storage" "External Service"
        ociRegistry = softwareSystem "OCI Registry (quay.io)" "Container image and model image registry" "External Service"
        huggingface = softwareSystem "HuggingFace Hub" "Pre-trained model downloads" "External Service"
        mariadb = softwareSystem "MariaDB" "Pipeline metadata persistence" "External Service"
        etcd = softwareSystem "etcd" "ModelMesh distributed state management" "External Service"

        // User relationships
        dataSci -> dashboard "Manages notebooks, pipelines via" "HTTPS/443"
        dataSci -> notebooks "Develops models in" "HTTPS/8443"
        dataSci -> dspAPI "Submits pipeline runs to" "REST/8888"
        mlEngineer -> kserve "Deploys InferenceServices via" "kubectl"
        mlEngineer -> modelRegistry "Registers models in" "REST/8080"
        appDev -> vllm "Sends inference requests to" "HTTP/8000 OpenAI API"
        appDev -> llamaStack "Uses LLM APIs via" "HTTP/8321"
        admin -> rhodsOperator "Configures platform via DataScienceCluster" "kubectl"

        // Internal relationships
        rhodsOperator -> kserve "Deploys and manages"
        rhodsOperator -> modelmeshServing "Deploys and manages"
        rhodsOperator -> dspOperator "Deploys and manages"
        rhodsOperator -> trainingOp "Deploys and manages"
        rhodsOperator -> kuberay "Deploys and manages"
        rhodsOperator -> kueue "Deploys and manages"
        rhodsOperator -> dashboard "Deploys and manages"
        rhodsOperator -> notebookCtrl "Deploys and manages"
        rhodsOperator -> feast "Deploys and manages"

        kserve -> vllm "Manages inference runtime" "HTTP/8000, gRPC/8033"
        kserve -> ovms "Manages inference runtime" "gRPC/configurable"
        kserve -> caikit "Manages inference runtime" "HTTP/8080, gRPC/8085"
        odhModelCtrl -> kserve "Manages Routes, Gateways for" "Kubernetes API"
        modelmeshServing -> vllm "Routes multi-model inference" "gRPC/8085"
        llmdEPP -> vllm "KV-cache-aware routing" "gRPC ext-proc/9002"

        dspOperator -> dspAPI "Manages lifecycle"
        dspAPI -> argoWF "Executes pipelines via" "Kubernetes API"
        dspAPI -> mlMetadata "Stores artifact lineage" "gRPC/8080"

        guardrails -> vllm "Generation backend" "HTTP/8000"
        trustyai -> kserve "Monitors inference payloads" "REST/CloudEvents"

        // External dependency relationships
        rhodsOperator -> olm "Installed and managed by" "OLM Subscription"
        rhodsOperator -> openshift "Runs on" "Kubernetes API/6443"
        kserve -> istio "Uses for mTLS, traffic routing" "xDS/15010"
        kserve -> knative "Uses for serverless autoscaling" "Kubernetes API"
        kserve -> gatewayAPI "Uses for RawDeployment ingress" "Gateway/HTTPRoute"
        llmdEPP -> gatewayAPI "Implements Inference Extension" "ext-proc/9002"
        vllm -> s3 "Downloads model artifacts from" "HTTPS/443"
        vllm -> huggingface "Downloads models from" "HTTPS/443"
        argoWF -> s3 "Stores pipeline artifacts in" "HTTPS/443"
        dspAPI -> mariadb "Persists pipeline data to" "MySQL/3306"
        modelmeshServing -> etcd "Manages distributed state via" "gRPC/2379"
        rhodsOperator -> ociRegistry "Pulls container images from" "HTTPS/443"
    }

    views {
        systemContext rhoai "SystemContext" {
            include *
            autoLayout
        }

        container rhoai "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #666666
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }

        theme default
    }
}
