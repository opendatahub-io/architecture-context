// RHOAI Build Config - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/RHOAI-Build-Config.md

workspace {
    model {
        // People
        developer = person "Developer / Release Engineer" "Maintains RHOAI build configuration, operator bundles, and release artifacts"
        clusterAdmin = person "Cluster Administrator" "Installs and manages RHOAI operator on OpenShift"

        // Primary System
        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration and OLM bundle/catalog repository for Red Hat OpenShift AI 2.24" {
            olmBundle = container "OLM Operator Bundle" "Packages CSV, 21 CRDs, RBAC, 10 webhooks for rhods-operator" "YAML Manifests"
            fbcCatalog = container "File-Based Catalog (FBC)" "Defines operator catalog entries per OCP version (v4.15-v4.19)" "YAML/JSON"
            tektonPipelines = container "Konflux Tekton Pipelines" "Automated build pipelines for bundle and FBC fragment images" "Tekton PipelineRun"
            ghActions = container "GitHub Actions Workflows" "Automated PR merging and nightly build triggers" "GitHub Actions"
            buildConfig = container "Build Configuration" "Image registry mappings, OCP version support matrix, image mirroring" "YAML"
            integrationTests = container "Integration Tests" "Enterprise Contract validation and test definitions" "YAML/Scripts"
            releaseArtifacts = container "Release Artifacts" "Stage and production release manifests and snapshots" "YAML"
            mirrorSet = container "ImageDigestMirrorSet" "Disconnected registry mirroring (73+ images)" "YAML"
        }

        // External Systems
        olm = softwareSystem "OLM (Operator Lifecycle Manager)" "Operator installation, upgrade, and lifecycle management on OpenShift" "External"
        konflux = softwareSystem "Konflux CI/CD" "Red Hat next-generation CI/CD platform with Tekton" "External"
        quayRegistry = softwareSystem "quay.io/rhoai Registry" "Pre-release container image storage" "External"
        redhatRegistry = softwareSystem "registry.redhat.io" "Production container image distribution" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Supply chain security validation" "External"
        operatorHub = softwareSystem "OpenShift OperatorHub" "Operator discoverability in OpenShift clusters" "External"
        github = softwareSystem "GitHub" "Source code hosting and CI triggers" "External"
        ocp = softwareSystem "OpenShift Container Platform" "Target deployment platform (v4.15-v4.19)" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for operator runtime" "External"

        // Internal RHOAI Systems
        rhodsOperator = softwareSystem "rhods-operator" "RHOAI operator controller (deployed by this bundle)" "Internal RHOAI"

        // Relationships - People
        developer -> rhoaiBuildConfig "Maintains build config, bundles, and catalogs"
        clusterAdmin -> operatorHub "Discovers and installs RHOAI operator"

        // Relationships - Build Pipeline
        rhoaiBuildConfig -> github "Source repository hosted on" "HTTPS/443"
        rhoaiBuildConfig -> konflux "Builds images via Tekton pipelines" "HTTPS/443"
        rhoaiBuildConfig -> quayRegistry "Pushes pre-release bundle and FBC images" "HTTPS/443"
        rhoaiBuildConfig -> enterpriseContract "Validates supply chain compliance" "HTTPS/443"
        rhoaiBuildConfig -> redhatRegistry "Releases production images" "HTTPS/443"

        // Relationships - Runtime
        olm -> rhoaiBuildConfig "Installs operator from bundle"
        olm -> rhodsOperator "Deploys operator (3 replicas)"
        rhodsOperator -> k8sApi "Manages cluster resources" "HTTPS/443"
        rhodsOperator -> redhatRegistry "Pulls 73+ RELATED_IMAGE containers" "HTTPS/443"
        rhoaiBuildConfig -> operatorHub "Publishes FBC catalog entries"

        // Container relationships
        ghActions -> tektonPipelines "Triggers builds"
        tektonPipelines -> olmBundle "Builds bundle image"
        tektonPipelines -> fbcCatalog "Builds FBC fragments"
        buildConfig -> tektonPipelines "Configures image mappings"
        integrationTests -> tektonPipelines "Validates builds"
        releaseArtifacts -> olmBundle "Publishes releases"
        mirrorSet -> olmBundle "Enables disconnected installs"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
