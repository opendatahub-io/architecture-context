/*
 * C4 Context Diagram - Text Generation Inference Server (TGIS)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        client = person "ML Application / API Consumer" "Sends text generation requests via gRPC"

        tgis = softwareSystem "Text Generation Inference Server (TGIS)" "High-performance LLM inference server with continuous batching, flash attention, and tensor parallelism" {
            launcher = container "text-generation-launcher" "Process orchestrator that spawns and monitors router and model shards" "Rust Binary"
            router = container "text-generation-router" "gRPC/HTTP server handling request validation, batching, tokenization" "Rust Binary" {
                tags "Primary"
            }
            modelServer = container "text-generation-server" "GPU model inference via PyTorch, serves internal gRPC on Unix domain sockets" "Python Service"
            cudaKernels = container "Custom CUDA Kernels" "Optimized GPU kernels for inference operations" "Python/CUDA"
            flashAttention = container "Flash Attention v2" "Memory-efficient attention mechanism" "CUDA Library"
        }

        kserve = softwareSystem "KServe / ModelMesh" "Model serving platform that orchestrates inference runtimes" "Internal RHOAI" {
            tags "Internal"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Internal" {
            tags "Internal"
        }
        otlpCollector = softwareSystem "OTLP Collector" "OpenTelemetry trace collection" "External" {
            tags "External"
        }
        modelStorage = softwareSystem "Model Storage (PVC/S3)" "Persistent storage for model weights and tokenizers" "External" {
            tags "External"
        }
        pytorch = softwareSystem "PyTorch + CUDA Runtime" "Deep learning framework and GPU compute" "External" {
            tags "External"
        }
        huggingface = softwareSystem "HuggingFace Transformers" "Model loading, tokenizer, architecture support" "External" {
            tags "External"
        }

        /* External relationships */
        client -> kserve "Sends inference requests" "gRPC/HTTPS"
        kserve -> tgis "Routes inference to TGIS backend" "gRPC/8033 Optional TLS/mTLS"

        /* Internal TGIS relationships */
        launcher -> router "Spawns and monitors"
        launcher -> modelServer "Spawns and monitors"
        router -> modelServer "Prefill/decode requests" "gRPC over UDS"
        modelServer -> cudaKernels "Uses for optimized ops"
        modelServer -> flashAttention "Uses for attention"

        /* External dependencies */
        modelServer -> modelStorage "Loads model weights" "Volume mount"
        modelServer -> pytorch "Runs inference" "CUDA API"
        router -> huggingface "Tokenization" "In-process library"
        router -> otlpCollector "Exports traces" "gRPC/TLS"
        prometheus -> tgis "Scrapes metrics" "HTTP/3000"
    }

    views {
        systemContext tgis "SystemContext" {
            include *
            autoLayout
        }

        container tgis "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Internal" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Primary" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
