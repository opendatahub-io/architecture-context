%% Kubeflow Notebook Controller - Security Network Diagram
%% Generated by: Claude Opus 4.6
graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser / API Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS Reencrypt (OAuth)<br/>TLS Edge (non-OAuth)"]
    end

    subgraph NotebookPod["NOTEBOOK POD (User Namespace)"]
        direction TB
        OAuthProxy["oauth-proxy sidecar<br/>8443/TCP HTTPS<br/>TLS: service-ca cert<br/>SAR: verb=get, resource=notebooks"]
        NotebookContainer["Notebook Container<br/>8888/TCP HTTP<br/>Jupyter / Code Server"]
    end

    subgraph Controllers["CONTROLLER NAMESPACE"]
        direction TB

        KFCtrl["kf-notebook-controller<br/>SA: notebook-controller-service-account<br/>Health: 8081/TCP<br/>Metrics: 8080/TCP"]

        ODHCtrl["odh-notebook-controller<br/>SA: odh-notebook-controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8080/TCP"]

        WebhookSrv["Mutating Webhook<br/>8443/TCP HTTPS<br/>TLS: OpenShift serving certs<br/>Endpoint: /mutate-notebook-v1"]

        CullingCtrl["Culling Controller<br/>Polls /api/kernels<br/>Polls /api/terminals"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
        ServiceCA["OpenShift service-ca<br/>Auto-provisions TLS certs"]
        ImageRegistry["OpenShift Image Registry<br/>ImageStream API 443/TCP"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        OAuthServer["OpenShift OAuth Server<br/>443/TCP HTTPS TLS 1.2+<br/>OAuth Client Credentials"]
    end

    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>No Auth (redirect)"| Router

    %% Ingress to Notebook Pod
    Router -->|"HTTPS/8443 (OAuth)<br/>TLS Reencrypt<br/>OAuth Token"| OAuthProxy
    OAuthProxy -->|"HTTP/8888<br/>localhost<br/>No Auth (SAR verified)"| NotebookContainer

    %% OAuth flow
    OAuthProxy -->|"HTTPS/443<br/>TLS 1.2+<br/>OAuth Client Creds"| OAuthServer

    %% Controllers to K8s API
    KFCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -->|"HTTPS/8443<br/>TLS<br/>API server cert"| WebhookSrv

    %% Culling flow
    CullingCtrl -->|"HTTP/80<br/>No Encryption<br/>No Auth"| NotebookContainer
    CullingCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Monitoring
    Prometheus -.->|"HTTP/8080<br/>No Auth"| KFCtrl
    Prometheus -.->|"HTTP/8080<br/>No Auth"| ODHCtrl

    %% Image resolution
    ODHCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| ImageRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef notebookpod fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controller fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class User external
    class Router ingress
    class OAuthProxy,NotebookContainer notebookpod
    class KFCtrl,ODHCtrl,WebhookSrv,CullingCtrl controller
    class K8sAPI,Prometheus,ServiceCA,ImageRegistry internal
    class OAuthServer externalservice
