%% Training Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "Training Operator"
        Controller["training-operator<br/>(controller-runtime)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS"]
        CertRotator["Cert Rotator<br/>(OPA cert-controller)"]
        Metrics["Metrics Server<br/>8080/TCP HTTP"]

        subgraph "Job Controllers"
            PyTorch["PyTorchJob Controller"]
            TF["TFJob Controller"]
            XGBoost["XGBoostJob Controller"]
            MPI["MPIJob Controller"]
            Paddle["PaddleJob Controller"]
            JAX["JAXJob Controller"]
        end

        Controller --> PyTorch
        Controller --> TF
        Controller --> XGBoost
        Controller --> MPI
        Controller --> Paddle
        Controller --> JAX
        CertRotator -->|rotates TLS certs| Webhook
        Controller -->|validates via| Webhook
    end

    %% CRDs
    User[User / kubectl] -->|creates| PyTorchJobCR["PyTorchJob CR"]
    User -->|creates| TFJobCR["TFJob CR"]
    User -->|creates| XGBoostJobCR["XGBoostJob CR"]
    User -->|creates| MPIJobCR["MPIJob CR"]
    User -->|creates| PaddleJobCR["PaddleJob CR"]
    User -->|creates| JAXJobCR["JAXJob CR"]

    PyTorchJobCR -->|watched by| PyTorch
    TFJobCR -->|watched by| TF
    XGBoostJobCR -->|watched by| XGBoost
    MPIJobCR -->|watched by| MPI
    PaddleJobCR -->|watched by| Paddle
    JAXJobCR -->|watched by| JAX

    %% Created Resources
    PyTorch -->|creates| Pods["Worker/Master Pods"]
    PyTorch -->|creates| HeadlessSvc["Headless Services"]
    PyTorch -->|creates| NetPol["NetworkPolicy"]
    PyTorch -->|creates| HPA["HPA (elastic)"]

    TF -->|creates| Pods
    TF -->|creates| HeadlessSvc

    %% External Dependencies
    Controller -->|HTTPS 443| K8sAPI["Kubernetes API"]
    Prometheus["OpenShift Monitoring"] -->|scrapes 8080| Metrics
    Controller -.->|optional gang scheduling| Volcano["Volcano"]
    Controller -.->|optional gang scheduling| SchedPlugins["scheduler-plugins"]

