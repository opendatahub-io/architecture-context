        ClientCA["TLS client CA cert<br/>Type: Opaque<br/>Provisioned by: External<br/>Purpose: mTLS client validation"]
    end

    subgraph "RBAC Managed By Deployer"
        KServeRBAC["KServe / ModelMesh Operator<br/>Manages RBAC for TGIS pods<br/>(ServiceAccount, Roles, Bindings)"]
    end

