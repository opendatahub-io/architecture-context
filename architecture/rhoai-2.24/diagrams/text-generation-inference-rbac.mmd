    end

    subgraph "Container Security Context"
        SecurityCtx["Security Context<br/>runAsNonRoot: true<br/>UID: 2000 (tgis)<br/>allowPrivilegeEscalation: false<br/>privileged: false<br/>seccompProfile: RuntimeDefault<br/>capabilities: DROP ALL"]
    end

