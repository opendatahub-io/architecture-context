%% TrustyAI Service Operator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / Data Scientist"]
    end

    subgraph Ingress["INGRESS (OpenShift Routes)"]
        TASRoute["TrustyAI Route<br/>443/TCP -> 8443/TCP<br/>TLS: Reencrypt<br/>Auth: OAuth Proxy (SAR)"]
        GORCHRoute["Guardrails HTTPS Route<br/>443/TCP -> 8033 or 8090/TCP<br/>TLS: Edge termination<br/>Auth: None"]
        GORCHHealth["Guardrails Health Route<br/>443/TCP -> 8034/TCP<br/>TLS: Edge termination<br/>Auth: None"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Kubernetes Network)"]
        direction TB

        subgraph NS_Operator["Operator Namespace"]
            Operator["Controller Manager<br/>SA: controller-manager<br/>Health: :8081<br/>Metrics: :8080"]
            MetricsSvc["Metrics Service<br/>ClusterIP :8443/TCP<br/>Auth: kube-rbac-proxy"]
        end

        subgraph NS_TAS["User Namespace (TrustyAI)"]
            TrustyAI["TrustyAI Service<br/>:8080 HTTP (plaintext)<br/>+ oauth-proxy :8443 HTTPS"]
            TASSvcInternal["Service :80/TCP<br/>HTTP plaintext"]
            TASSvcTLS["Service :443/TCP<br/>HTTPS TLS (serving cert)"]
            TASSvcOAuth["Service :443/TCP<br/>HTTPS TLS + OAuth"]
        end

        subgraph NS_LMES["User Namespace (LMEval)"]
            EvalPod["LMEval Pod<br/>+ driver sidecar<br/>Security: restricted"]
        end

        subgraph NS_GORCH["User Namespace (Guardrails)"]
            Orchestrator["Guardrails Orchestrator<br/>:8033 HTTP"]
            Detector["Built-in Regex Detector<br/>(optional sidecar)"]
            Gateway["Gateway Sidecar<br/>:8090 HTTP (optional)"]
        end
    end

    subgraph IstioMesh["ISTIO SERVICE MESH (conditional)"]
        DestRule["DestinationRule<br/>TLS SIMPLE :443"]
        VirtSvc["VirtualService<br/>:80 -> :443 redirect"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS<br/>Auth: SA Token"]
        Database["Database (PostgreSQL/MySQL)<br/>configurable port<br/>JDBC, TLS optional<br/>Auth: username/password"]
        ModelEndpoint["InferenceService Endpoints<br/>80 or 443/TCP<br/>HTTP/HTTPS<br/>Auth: None/mTLS"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>Bearer Token"| TASRoute
    User -->|"HTTPS/443<br/>No app auth"| GORCHRoute
    User -->|"HTTPS/443"| GORCHHealth

    %% Ingress to internal
    TASRoute -->|"HTTPS/8443<br/>Reencrypt<br/>OAuth SAR check"| TrustyAI
    GORCHRoute -->|"HTTP/8033 or 8090<br/>Edge terminated"| Orchestrator
    GORCHHealth -->|"HTTP/8034<br/>Edge terminated"| Orchestrator

    %% Internal service flows
    TrustyAI --- TASSvcInternal
    TrustyAI --- TASSvcTLS
    TrustyAI --- TASSvcOAuth
    Operator --- MetricsSvc

    %% Operator to K8s API
    Operator -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI

    %% TrustyAI to external
    TrustyAI -->|"JDBC<br/>TLS optional<br/>user/pass"| Database
    ModelEndpoint -->|"HTTP(S)/443<br/>TLS/mTLS"| TrustyAI

    %% LMEval flows
    EvalPod -->|"HTTP/HTTPS<br/>configurable"| ModelEndpoint
    EvalPod -.->|"gRPC<br/>plaintext"| Operator

    %% Guardrails flows
    Orchestrator -->|"HTTP<br/>plaintext"| Detector
    Orchestrator -->|"HTTP/HTTPS<br/>configurable"| ModelEndpoint
    Gateway -.->|":8090"| Orchestrator

    %% Istio (conditional)
    TASSvcTLS -.-> DestRule
    TASSvcInternal -.-> VirtSvc

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef cluster fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef istio fill:#e6d5f5,stroke:#9673a6,stroke-width:2px

    class User external
    class TASRoute,GORCHRoute,GORCHHealth ingress
    class Operator,MetricsSvc,TrustyAI,TASSvcInternal,TASSvcTLS,TASSvcOAuth,EvalPod,Orchestrator,Detector,Gateway cluster
    class K8sAPI,Database,ModelEndpoint externalservice
