// C4 Context Diagram - llm-d-inference-scheduler
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/llm-d-inference-scheduler.md

workspace {
    model {
        // Actors
        client = person "Client Application" "Sends LLM inference requests"
        sre = person "SRE / Platform Engineer" "Deploys and monitors the inference scheduler"

        // Main System
        eppSystem = softwareSystem "llm-d-inference-scheduler" "Endpoint Picker (EPP) service that makes optimized routing decisions for LLM inference requests using Gateway API Inference Extension and Envoy ext-proc" {
            epp = container "EPP Service" "gRPC server acting as Envoy ext-proc filter; applies filter/scorer plugin pipeline to select optimal backend pod" "Go Service, gRPC/9002"
            pluginRegistry = container "Plugin Registry" "Registers filter, scorer, pre-request, and profile handler plugins" "Go Package"
            filters = container "Filter Plugins" "ByLabel, ByLabelSelector, Decode, Prefill filters that narrow candidate pods" "Go Plugins"
            scorers = container "Scorer Plugins" "PrefixCache, LoadAware, SessionAffinity, PrefixCacheTracking scorers that rank pods" "Go Plugins"
            pdHandler = container "P/D Profile Handler" "Manages disaggregated Prefill/Decode scheduling profile selection" "Go Plugin"
        }

        // External Dependencies
        envoyGateway = softwareSystem "Envoy Gateway" "Data plane proxy implementing Gateway API; invokes EPP via ext-proc filter" "External"
        istio = softwareSystem "Istio Control Plane" "Gateway API implementation (istiod-llm-d-gateway), sidecar injection, mTLS" "External"
        gieFramework = softwareSystem "Gateway API Inference Extension (GIE)" "Core scheduling framework providing ext-proc runner and plugin interfaces" "External"
        gatewayAPICRDs = softwareSystem "Gateway API CRDs" "Gateway, HTTPRoute, InferencePool, InferenceModel CRD definitions" "External"
        kubernetes = softwareSystem "Kubernetes API Server" "Watches InferencePool, InferenceModel, Pod, EndpointSlice resources" "External"

        // Internal ODH Dependencies
        vllmPods = softwareSystem "vLLM Model-Serving Pods" "Backend inference endpoints selected by the scheduler" "Internal RHOAI"
        kvCacheManager = softwareSystem "llm-d-kv-cache-manager" "KV-cache indexer and event pool for cache_tracking mode" "Internal RHOAI"

        // Monitoring
        prometheus = softwareSystem "Prometheus" "Metrics collection for scheduler and KV-cache index metrics" "External"

        // Relationships
        client -> envoyGateway "Sends inference requests" "HTTP/80"
        envoyGateway -> epp "ext-proc callbacks for routing decisions" "gRPC/9002"
        epp -> pluginRegistry "Loads plugins"
        pluginRegistry -> filters "Registers filters"
        pluginRegistry -> scorers "Registers scorers"
        pluginRegistry -> pdHandler "Registers P/D handler"
        epp -> kubernetes "Watches InferencePool, InferenceModel, Pods, EndpointSlices" "HTTPS/443"
        envoyGateway -> vllmPods "Routes inference requests to selected pod" "HTTP/8000"
        scorers -> kvCacheManager "Subscribes to KV-cache events (optional)" "ZMQ/5557"
        istio -> envoyGateway "Configures Envoy proxy via xDS" "gRPC/15010"
        prometheus -> epp "Scrapes metrics" "HTTP/9090"
        sre -> eppSystem "Deploys and configures"
    }

    views {
        systemContext eppSystem "SystemContext" {
            include *
            autoLayout
        }

        container eppSystem "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
        }
    }
}
