// C4 Context Diagram - Data Science Pipelines Operator (DSPO)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/data-science-pipelines-operator.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and runs ML pipelines via DSPA custom resources"
        admin = person "Platform Admin" "Deploys and configures DSPO via rhods-operator"

        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Manages lifecycle of Kubeflow Pipelines v2 application components on OpenShift via DSPA CRs" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, reconciles sub-components, performs health checks" "Go Operator (controller-runtime)"
            apiServer = container "KFP API Server" "Serves KFP REST (v1beta1/v2beta1) and gRPC APIs for pipeline management" "Go Service"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo Workflows to KFP API" "Go Service"
            scheduledWF = container "Scheduled Workflow Controller" "Manages cron-scheduled pipeline runs" "Go Controller"
            argoWFC = container "Argo Workflow Controller" "Orchestrates pipeline step execution as Workflow CRs" "Go Controller"
            mariaDB = container "MariaDB" "Default database for pipeline metadata" "MariaDB"
            mlmdGRPC = container "MLMD gRPC Server" "ML Metadata artifact and execution tracking" "gRPC Service"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Envoy proxy fronting MLMD gRPC with OAuth sidecar" "Envoy"
            minio = container "Minio" "Default object storage for pipeline artifacts (dev/test)" "Minio"
            oauthProxy = container "OAuth Proxy" "OpenShift oauth-proxy sidecar for route authentication" "oauth-proxy"
            webhook = container "DS Pipelines Webhook" "Validating/mutating webhook for PipelineVersion CRs" "Go Webhook"
        }

        rhodsOperator = softwareSystem "rhods-operator" "Deploys DSPO via kustomize overlays" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "User interface for pipeline management" "Internal RHOAI"
        serviceCa = softwareSystem "OpenShift service-ca" "Certificate provisioning for pod-to-pod TLS" "OpenShift Platform"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "Authentication for external API access" "OpenShift Platform"
        prometheus = softwareSystem "Prometheus" "Metrics collection via ServiceMonitor" "Monitoring"
        kubernetesAPI = softwareSystem "Kubernetes API" "Cluster resource management" "Platform"
        externalDB = softwareSystem "External SQL Database" "Optional external pipeline metadata store" "External"
        externalS3 = softwareSystem "External Object Storage (S3)" "Pipeline artifact storage" "External"

        // User interactions
        user -> dspo "Creates DSPA CRs, submits pipelines via REST/gRPC"
        user -> odhDashboard "Manages pipelines via UI"
        admin -> rhodsOperator "Deploys and configures DSPO"

        // Internal flows
        controller -> apiServer "Deploys and configures" "Kubernetes API"
        controller -> persistenceAgent "Deploys" "Kubernetes API"
        controller -> scheduledWF "Deploys" "Kubernetes API"
        controller -> argoWFC "Deploys" "Kubernetes API"
        controller -> mariaDB "Deploys, health checks" "MySQL/3306"
        controller -> minio "Deploys, health checks" "HTTPS/443"
        controller -> mlmdGRPC "Deploys" "Kubernetes API"
        controller -> mlmdEnvoy "Deploys" "Kubernetes API"

        apiServer -> mariaDB "Stores pipeline metadata" "MySQL/3306 TLS"
        apiServer -> externalS3 "Stores pipeline artifacts" "HTTPS/443"
        mlmdGRPC -> mariaDB "Stores ML metadata" "MySQL/3306 TLS"
        persistenceAgent -> apiServer "Syncs run status" "REST/8888 TLS"

        // External system interactions
        rhodsOperator -> dspo "Deploys via kustomize overlay"
        dspo -> kubernetesAPI "Manages cluster resources" "HTTPS/6443"
        dspo -> serviceCa "Obtains TLS certificates"
        dspo -> openshiftOAuth "Authenticates external access" "HTTPS/8443"
        dspo -> externalDB "Pipeline metadata (optional)" "MySQL/3306"
        dspo -> externalS3 "Pipeline artifacts" "HTTPS/443"
        prometheus -> dspo "Scrapes metrics" "HTTP/8080"
        odhDashboard -> dspo "Pipeline management via Route" "HTTPS/443"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "OpenShift Platform" {
                background #e67e22
                color #ffffff
            }
            element "Monitoring" {
                background #9b59b6
                color #ffffff
            }
            element "Platform" {
                background #34495e
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
