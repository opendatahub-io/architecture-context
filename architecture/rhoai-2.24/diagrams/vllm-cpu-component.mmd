            SSLManager["SSL/TLS Manager<br/>Certificate Hot-Reload"]
            PromMetrics["Prometheus Metrics<br/>/metrics endpoint"]
        end

        subgraph GRPCServer["TGIS gRPC Adapter"]
            TGISService["TGIS GenerationService<br/>Port 8033/TCP"]
        end

        subgraph Engine["vLLM Engine (V1/V0)"]
            AsyncEngine["AsyncLLM / AsyncLLMEngine<br/>ZeroMQ IPC"]
        end

        subgraph Workers["CPU Backend Workers"]
            PyTorchCPU["PyTorch CPU Worker"]
            IPEX["IPEX (x86_64)"]
            OpenBLAS["OpenBLAS (ppc64le)"]
        end

        OTelTracing["OpenTelemetry Tracing<br/>(Optional)"]
    end

    %% Internal connections
    APIRouter -->|routes requests| AsyncEngine
    AuthMiddleware -->|validates| APIRouter
    TGISService -->|Python call| AsyncEngine
    AsyncEngine -->|dispatches| PyTorchCPU
    PyTorchCPU -->|uses| IPEX
    PyTorchCPU -->|uses| OpenBLAS

    %% External interactions
    Client[Client / KServe Route] -->|HTTP/HTTPS 8000| APIRouter
    ModelMesh[ModelMesh] -->|gRPC 8033| TGISService

    %% Model Storage
    PyTorchCPU -->|loads model| ModelStorage[Model Storage<br/>PVC / S3]

    %% Monitoring
    Prometheus[Prometheus Scraper] -->|scrapes /metrics| PromMetrics
    OTelTracing -.->|exports traces| OTelCollector[OpenTelemetry Collector<br/>4317-4318/TCP]

    %% Platform integration
    KServe[KServe Controller] -->|manages lifecycle| VllmCPU
    RHOAIOp[rhods-operator] -->|deploys| VllmCPU
    Dashboard[RHOAI Dashboard] -->|configures| VllmCPU

