%% ModelMesh Serving - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "ModelMesh Serving Controller"
        Controller[modelmesh-controller<br/>Go Operator]
        SRReconciler[ServingRuntimeReconciler]
        PReconciler[PredictorReconciler]
        SvcReconciler[ServiceReconciler]
        AutoReconciler[AutoscalerReconciler]
        Webhook[Validating Webhook<br/>9443/TCP]

        Controller --> SRReconciler
        Controller --> PReconciler
        Controller --> SvcReconciler
        Controller --> AutoReconciler
        Controller --> Webhook
    end

    subgraph "Runtime Pod (per ServingRuntime)"
        MMSidecar[ModelMesh Sidecar<br/>Java, gRPC 8033/TCP]
        RESTProxy[REST Proxy Sidecar<br/>8008/TCP]
        OAuthProxy[OAuth Proxy Sidecar<br/>8443/TCP HTTPS]
        Puller[Storage Helper/Puller<br/>Model Download]
        Runtime[Model Runtime Container<br/>Triton/MLServer/etc.]

        OAuthProxy -->|REST to gRPC| RESTProxy
        RESTProxy -->|gRPC| MMSidecar
        MMSidecar -->|gRPC| Runtime
        Puller -->|model artifacts| Runtime
    end

    %% CRDs
    User[User/Data Scientist] -->|creates| SRCR[ServingRuntime CR]
    User -->|creates| PredCR[Predictor CR]
    User -->|creates| ISVC[InferenceService CR]
    User -->|creates| CSRCR[ClusterServingRuntime CR]

    %% Watches
    SRCR -->|watched by| SRReconciler
    CSRCR -->|watched by| SRReconciler
    PredCR -->|watched by| PReconciler
    ISVC -->|watched by| PReconciler

    %% Reconciler outputs
    SRReconciler -->|creates/updates| RuntimePod[Runtime Deployment]
    PReconciler -->|registers model via gRPC| MMSidecar
    SvcReconciler -->|creates| HeadlessSvc[Headless Service<br/>per namespace]
    AutoReconciler -->|manages| HPA[HorizontalPodAutoscaler]

    %% External dependencies
    MMSidecar -->|state coordination| etcd[etcd<br/>2379/TCP]
    Controller -->|API calls| K8sAPI[Kubernetes API<br/>443/TCP]
    Puller -->|downloads models| ObjStorage[Object Storage<br/>S3/GCS 443/TCP]
    Controller -->|deployed by| RhodsOp[rhods-operator]

    %% Integration
    Prometheus[Prometheus] -->|scrapes| Controller
    Prometheus -->|scrapes| MMSidecar
    ODHModelCtrl[odh-model-controller] -.->|shares CRDs| Controller

