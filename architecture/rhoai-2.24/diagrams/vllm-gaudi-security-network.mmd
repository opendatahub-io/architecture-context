%% vllm-gaudi Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (RHOAI Platform Managed)"]
        KServeIngress["KServe/Route Ingress<br/>443/TCP<br/>TLS 1.2+<br/>Bearer Token Auth"]
    end

    subgraph Container["CONTAINER (vllm-gaudi Pod)<br/>UID: 2000 | GID: 0 | Non-root"]
        direction TB

        subgraph HTTPEntry["HTTP Entrypoint"]
            APIServer["OpenAI API Server<br/>8000/TCP HTTP(S)<br/>Optional TLS (cert hot-reload)<br/>Bearer Token on /v1/* (optional)"]
        end

        subgraph GRPCEntry["gRPC Entrypoint"]
            TGISAdapter["gRPC TGIS Adapter<br/>8033/TCP gRPC<br/>plaintext<br/>No Auth"]
        end

        subgraph EngineLayer["Engine Layer"]
            Engine["AsyncLLMEngine<br/>ZMQ IPC (Unix Socket)"]
        end

        subgraph HPULayer["HPU Execution"]
            HPUWorker["HPU Worker(s)<br/>HCCL Collective Ops<br/>Device Memory Access"]
        end
    end

    subgraph EgressServices["EGRESS (Outbound)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token (optional)<br/>DISABLED: HF_HUB_OFFLINE=1"]
        RayHead["Ray Head Node<br/>6379/TCP<br/>plaintext<br/>No Auth"]
        RayWorkers["Ray Workers<br/>Dynamic/TCP<br/>plaintext<br/>No Auth"]
        OTLPCollector["OTLP Collector<br/>4317/TCP gRPC | 4318/TCP HTTP<br/>Optional TLS<br/>No Auth"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus Scraper"]
        GaudiHPU["Intel Gaudi<br/>Accelerator"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| KServeIngress

    %% Ingress to Container
    KServeIngress -->|"HTTP(S)/8000<br/>Optional TLS<br/>Bearer Token (optional)"| APIServer

    %% ModelMesh to gRPC
    ModelMesh["ModelMesh Router"] -->|"gRPC/8033<br/>plaintext<br/>No Auth"| TGISAdapter

    %% Internal container flows
    APIServer -->|"ZMQ IPC<br/>Unix Socket"| Engine
    TGISAdapter -->|"In-process<br/>Python"| Engine
    Engine -->|"In-process/HCCL"| HPUWorker

    %% HPU to device
    HPUWorker -->|"Device Memory<br/>HPU Runtime"| GaudiHPU

    %% Egress flows
    HPUWorker -.->|"TCP/6379<br/>plaintext"| RayHead
    HPUWorker -.->|"Dynamic/TCP<br/>plaintext"| RayWorkers
    APIServer -.->|"gRPC/4317<br/>Optional TLS"| OTLPCollector
    Engine -.->|"HTTPS/443<br/>TLS 1.2+<br/>DISABLED in prod"| HFHub

    %% Monitoring
    Prometheus -->|"HTTP(S)/8000<br/>GET /metrics<br/>No Auth"| APIServer

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef container fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef disabled fill:#f8cecc,stroke:#b85450,stroke-width:2px,stroke-dasharray: 5 5

    class Client external
    class KServeIngress ingress
    class APIServer,TGISAdapter,Engine,HPUWorker container
    class RayHead,RayWorkers,OTLPCollector egress
    class HFHub disabled
    class Prometheus,GaudiHPU monitoring
    class ModelMesh ingress
