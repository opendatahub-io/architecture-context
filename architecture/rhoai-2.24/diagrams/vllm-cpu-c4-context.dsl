/*
 * C4 Context Diagram for vllm-cpu
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/vllm-cpu.md
 */

workspace {
    model {
        user = person "Data Scientist / Application" "Sends inference requests to LLM models"

        vllmCPU = softwareSystem "vLLM CPU Runtime" "High-throughput LLM inference engine optimized for CPU execution, providing OpenAI-compatible API and gRPC (TGIS) endpoints" {
            openaiServer = container "OpenAI API Server" "OpenAI-compatible REST API for chat completions, completions, embeddings, scoring, and tokenization" "Python FastAPI/Uvicorn" "Service"
            tgisAdapter = container "TGIS gRPC Adapter" "Text Generation Inference Service gRPC adapter wrapping vLLM engine" "Python gRPC" "Service"
            vllmEngine = container "vLLM Engine" "Core LLM inference engine with PagedAttention, continuous batching" "Python" "Engine"
            cpuWorkers = container "CPU Backend Workers" "Model execution workers using PyTorch CPU, IPEX (x86_64), OpenBLAS (ppc64le)" "Python/C++" "Workers"
            sslManager = container "SSL/TLS Manager" "Certificate loading and hot-reload via watchfiles" "Python" "Module"
            metricsExporter = container "Prometheus Metrics" "Prometheus metrics exporter at /metrics endpoint" "Python" "Middleware"
        }

        kserve = softwareSystem "KServe" "Manages vLLM as a serving runtime for InferenceService" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Routes inference requests to vLLM TGIS adapter" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and references" "Internal RHOAI"
        rhoaiDashboard = softwareSystem "RHOAI Dashboard" "Configures and manages model serving instances" "Internal RHOAI"
        rhodsOperator = softwareSystem "rhods-operator" "Manages lifecycle of serving runtimes" "Internal RHOAI"

        modelStorage = softwareSystem "Model Storage (S3/PVC)" "Model weight artifact storage" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Model download (disabled by default)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed trace collection" "External"

        /* Relationships */
        user -> vllmCPU "Sends inference requests" "HTTP/8000, gRPC/8033"

        user -> openaiServer "POST /v1/chat/completions, /v1/completions" "HTTP/HTTPS 8000/TCP"

        kserve -> vllmCPU "Manages as serving runtime" "Container lifecycle"
        modelMesh -> tgisAdapter "Routes gRPC inference requests" "gRPC/8033"
        rhoaiDashboard -> vllmCPU "Configures serving instances" "API"
        rhodsOperator -> vllmCPU "Deploys and manages" "Operator"

        openaiServer -> vllmEngine "Forwards requests" "ZeroMQ IPC"
        tgisAdapter -> vllmEngine "Forwards requests" "Python call"
        vllmEngine -> cpuWorkers "Dispatches inference" "In-process"
        cpuWorkers -> modelStorage "Loads model weights" "Filesystem/HTTPS 443"
        cpuWorkers -> huggingFace "Downloads models (disabled)" "HTTPS/443"

        prometheus -> openaiServer "Scrapes /metrics" "HTTP/8000"
        vllmCPU -> otelCollector "Exports traces" "gRPC/4317, HTTP/4318"
        vllmCPU -> modelRegistry "References models" "API"
    }

    views {
        systemContext vllmCPU "SystemContext" {
            include *
            autoLayout
        }

        container vllmCPU "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Service" {
                background #4a90e2
                color #ffffff
            }
            element "Engine" {
                background #4a90e2
                color #ffffff
            }
            element "Workers" {
                background #9b59b6
                color #ffffff
            }
            element "Module" {
                background #f5a623
            }
            element "Middleware" {
                background #7ed321
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
