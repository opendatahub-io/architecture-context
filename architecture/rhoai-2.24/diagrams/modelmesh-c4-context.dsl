/*
 * ModelMesh C4 Context Diagram
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/modelmesh.md
 */

workspace {
    model {
        client = person "ML Client" "Sends inference requests and manages models via gRPC API"

        modelmesh = softwareSystem "ModelMesh" "Distributed LRU cache and intelligent routing layer for serving ML models at high scale and density" {
            sidecarModelMesh = container "SidecarModelMesh" "Core model management engine; manages model lifecycle, LRU cache, request routing, auto-scaling, and inter-pod coordination" "Java 21 (Litelinks/Thrift)"
            modelMeshApi = container "ModelMeshApi" "External gRPC API server exposing model management and proxied inference methods" "gRPC Server (Netty)" "8033/TCP"
            vmodelManager = container "VModelManager" "Manages virtual models providing alias-based routing with blue-green update semantics" "Java Component"
            prometheusServer = container "Prometheus NettyServer" "Serves Prometheus metrics on /metrics endpoint" "HTTP/HTTPS Server (Netty)" "2112/TCP"
            preStopServer = container "PreStop Server" "Provides /prestop endpoint for graceful shutdown coordination" "HTTP Server (Netty)" "8090/TCP"
            healthProbe = container "Health Probe" "Provides /ready and /live health check endpoints" "HTTP Server (Litelinks)" "8089/TCP"
            payloadProcessor = container "PayloadProcessor" "Extensible payload processing pipeline for inference payloads" "Java Component"
            typeConstraintMgr = container "TypeConstraintManager" "Manages model type constraints for heterogeneous deployments" "Java Component"
        }

        etcd = softwareSystem "etcd" "Distributed key-value store for model registry, instance records, leader election, and dynamic configuration" "External"
        runtimeAdapter = softwareSystem "modelmesh-runtime-adapter" "Implements ModelRuntime gRPC interface, adapting between ModelMesh and specific model server frameworks" "Internal RHOAI"
        modelRuntime = softwareSystem "Model Runtime" "Custom or pre-built model servers that load and serve models (e.g., Triton, MLServer)" "Internal RHOAI"
        modelmeshServing = softwareSystem "modelmesh-serving" "Controller that manages ModelMesh Deployments, Services, and configures model runtimes" "Internal RHOAI"
        modelStorage = softwareSystem "Model Storage" "S3-compatible or PVC-based storage for model artifacts" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server" "External"

        # Relationships
        client -> modelmesh "Sends gRPC inference/management requests" "gRPC/8033 TLS + mTLS (optional)"
        modelmesh -> etcd "Stores/retrieves model registry, instance records, leader election" "gRPC/2379 TLS + Certificate auth"
        modelmesh -> runtimeAdapter "Sends model load/unload/inference requests" "gRPC/8085 plaintext (localhost/UDS)"
        runtimeAdapter -> modelRuntime "Translates ModelRuntime interface for specific servers"
        modelRuntime -> modelStorage "Downloads model artifacts" "HTTPS/443 TLS + Storage credentials"
        modelmeshServing -> modelmesh "Manages Deployment, Service, ConfigMaps" "Kubernetes API"
        prometheus -> modelmesh "Scrapes metrics" "HTTPS/2112 Self-signed TLS"
        modelmeshServing -> k8sApi "Creates/updates Kubernetes resources" "HTTPS/443"

        # Internal container relationships
        modelMeshApi -> sidecarModelMesh "Delegates model management"
        sidecarModelMesh -> vmodelManager "Manages virtual model mappings"
        sidecarModelMesh -> payloadProcessor "Processes inference payloads"
        sidecarModelMesh -> typeConstraintMgr "Checks type constraints"
    }

    views {
        systemContext modelmesh "SystemContext" {
            include *
            autoLayout
        }

        container modelmesh "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
