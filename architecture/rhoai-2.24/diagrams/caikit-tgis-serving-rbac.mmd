---
title: "RBAC Visualization: caikit-tgis-serving (Generated by Claude Opus 4.6)"
---
graph TD
    subgraph "Inference Pod ServiceAccount"
        SA["ServiceAccount: sa<br/>(user-configured per InferenceService)"]
    end

    subgraph "Secret Access"
        StorageSecret["storage-config<br/>Type: Opaque<br/>AWS_ACCESS_KEY_ID<br/>AWS_SECRET_ACCESS_KEY<br/>S3 endpoint, region, bucket"]
    end

    subgraph "KServe-Managed RBAC"
        KServeSA["ServiceAccount: kserve-controller-manager"]
        KServeCRB["ClusterRoleBinding:<br/>kserve-manager-rolebinding"]
        KServeCR["ClusterRole:<br/>kserve-manager-role"]
    end

    subgraph "KServe CRD Resources"
        ServingRuntime["serving.kserve.io<br/>ServingRuntime"]
        InferenceService["serving.kserve.io<br/>InferenceService"]
        Pods["core<br/>Pods"]
        Services["core<br/>Services"]
        Deployments["apps<br/>Deployments"]
    end

    subgraph "Service Mesh RBAC"
        PeerAuth["PeerAuthentication:<br/>caikit-metrics<br/>STRICT mTLS<br/>Port 8086: PERMISSIVE"]
        SMCP["ServiceMeshControlPlane<br/>mTLS dataplane"]
        SMMR["ServiceMeshMemberRoll<br/>Enrolls inference namespaces"]
    end

    subgraph "Network Policy"
        NP["NetworkPolicy:<br/>allow-from-openshift-monitoring-ns<br/>Direction: Ingress<br/>From: openshift-user-workload-monitoring"]
    end

    %% ServiceAccount → Secret
    SA -->|"mounts"| StorageSecret
    SA -->|"used by inference pod"| Pods

    %% KServe RBAC chain
    KServeSA -->|"bound via"| KServeCRB
    KServeCRB -->|"grants"| KServeCR
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| ServingRuntime
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| InferenceService
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Pods
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Services
    KServeCR -->|"get,list,watch,create,<br/>update,patch,delete"| Deployments

    %% Service Mesh
    PeerAuth -->|"enforces mTLS on"| Pods
    SMCP -->|"configures"| PeerAuth
    SMMR -->|"enrolls namespace"| SMCP

    %% Network Policy
    NP -->|"allows Prometheus<br/>ingress to"| Pods

