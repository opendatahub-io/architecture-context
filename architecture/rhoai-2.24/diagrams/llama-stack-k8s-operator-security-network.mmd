    %% Flows
    User -->|"kubectl apply<br/>HTTPS/443"| K8sAPI
    K8sAPI -->|"Watch events<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| Manager
    Manager -->|"CRUD resources<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Manager -->|"GET /v1/health<br/>GET /v1/providers<br/>GET /v1/version<br/>HTTP/8321<br/>No encryption"| LlamaServer
    Manager -->|reads| OperatorConfig

    RBACProxy -->|"proxies metrics"| Manager
    MetricsSvc -->|"8443/TCP"| RBACProxy

    LlamaService -->|"8321/TCP"| LlamaServer
    LlamaSA -.->|"bound to"| LlamaStackPod
    NetPolicy -.->|"controls ingress"| LlamaStackPod

    RHODS -.->|"deploys operator"| OperatorPod
    CABundle -.->|"auto-injected"| Manager

