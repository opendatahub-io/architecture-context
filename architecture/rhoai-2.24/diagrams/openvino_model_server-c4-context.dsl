/*
 * C4 Context Diagram - OpenVINO Model Server (OVMS)
 * Generated by: Claude Opus 4.6
 * Date: 2026-03-20
 */
workspace {
    model {
        // Actors
        datascientist = person "Data Scientist" "Deploys and configures ML models for inference"
        application = person "Application / Client" "Sends inference requests to deployed models"

        // Primary System
        ovms = softwareSystem "OpenVINO Model Server" "High-performance AI model inference server built on Intel OpenVINO, providing gRPC and REST APIs" {
            grpcServer = container "gRPC Server Module" "Hosts TFS Predict, TFS ModelService, and KServe v2 Inference gRPC services" "C++ / gRPC"
            httpServer = container "HTTP Server Module" "REST API supporting TFS v1, KServe v2, OpenAI v3, and metrics endpoints" "C++ / HTTP"
            servableManager = container "Servable Manager" "Manages model lifecycle, loading, versioning, and serving" "C++"
            mediapipeExecutor = container "MediaPipe Graph Executor" "Executes computation graphs for LLM, embeddings, rerank, image generation" "C++ / MediaPipe"
            dagScheduler = container "DAG Scheduler" "Pipeline execution for chaining multiple models" "C++"
            openvinoRuntime = container "OpenVINO Runtime" "Core inference engine optimized for Intel architectures" "C++ / OpenVINO 2025.2"
            storageBackends = container "Storage Backends" "S3, GCS, Azure, Local/NFS, HuggingFace model loading" "C++"
            metricsModule = container "Metrics Module" "Prometheus-compatible metrics collection and export" "C++"
        }

        // Platform Systems
        kserve = softwareSystem "KServe" "Serverless ML inference platform, deploys OVMS as runtime container" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Multi-model serving platform, uses OVMS as serving runtime" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and references" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Provides mTLS, traffic management, and authorization" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // External Storage
        s3 = softwareSystem "AWS S3" "Cloud object storage for model artifacts" "External"
        gcs = softwareSystem "Google Cloud Storage" "Cloud object storage for model artifacts" "External"
        azureBlob = softwareSystem "Azure Blob Storage" "Cloud object storage for model artifacts" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model repository for downloading pretrained models" "External"

        // Relationships - Actors
        datascientist -> kserve "Creates InferenceService via kubectl/dashboard"
        application -> ovms "Sends inference requests" "gRPC/REST"

        // Relationships - Platform
        kserve -> ovms "Deploys as runtime container" "Container lifecycle"
        modelmesh -> ovms "Uses as serving runtime" "gRPC"
        ovms -> modelRegistry "Fetches model references" "Configuration"
        istio -> ovms "Provides mTLS and auth" "Sidecar proxy"
        prometheus -> ovms "Scrapes metrics" "HTTP /metrics"

        // Relationships - External Storage
        ovms -> s3 "Downloads model artifacts" "HTTPS/443"
        ovms -> gcs "Downloads model artifacts" "HTTPS/443"
        ovms -> azureBlob "Downloads model artifacts" "HTTPS/443"
        ovms -> huggingface "Pulls models" "HTTPS/443"

        // Container-level relationships
        grpcServer -> servableManager "Routes inference requests"
        httpServer -> servableManager "Routes inference requests"
        httpServer -> mediapipeExecutor "Routes OpenAI v3 requests"
        servableManager -> openvinoRuntime "Executes inference"
        servableManager -> dagScheduler "Executes pipelines"
        mediapipeExecutor -> openvinoRuntime "Executes GenAI inference"
        servableManager -> storageBackends "Loads models"
        metricsModule -> httpServer "Exposes /metrics"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
