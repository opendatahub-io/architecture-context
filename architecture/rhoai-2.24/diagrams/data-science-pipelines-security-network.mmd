%% Data Science Pipelines - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / External Client"]
    end

    subgraph Ingress["INGRESS (OpenShift Route - Edge TLS)"]
        Route["OpenShift Route<br/>443/TCP → 3000/TCP<br/>TLS Edge Termination"]
    end

    subgraph InternalServices["INTERNAL SERVICES (Cluster Network)"]
        direction TB

        subgraph FrontendZone["Frontend"]
            PipelineUI["ml-pipeline-ui<br/>3000/TCP HTTP<br/>SA: ml-pipeline-ui"]
        end

        subgraph APIZone["API Layer"]
            APIServer["ml-pipeline API Server<br/>REST: 8888/TCP HTTP/HTTPS<br/>gRPC: 8887/TCP<br/>Webhook: 8443/TCP HTTPS<br/>SA: ml-pipeline<br/>Auth: UserID Header + SAR"]
        end

        subgraph MetadataZone["Metadata Layer"]
            MetadataEnvoy["metadata-envoy<br/>9090/TCP HTTP gRPC-Web<br/>plaintext, No Auth"]
            MetadataGRPC["metadata-grpc (MLMD)<br/>8080/TCP gRPC<br/>plaintext, No Auth"]
        end

        subgraph ControllerZone["Controllers"]
            PA["ml-pipeline-persistenceagent<br/>SA: ml-pipeline-persistenceagent<br/>Auth: Projected SA Token (1h)<br/>Audience: pipelines.kubeflow.org"]
            SWF["ml-pipeline-scheduledworkflow<br/>SA: ml-pipeline-scheduledworkflow<br/>Auth: Projected SA Token (1h)"]
            ViewerCtrl["ml-pipeline-viewer-crd<br/>SA: ml-pipeline-viewer-controller"]
        end

        subgraph CacheZone["Caching"]
            Cache["cache-server<br/>443→8443/TCP HTTPS<br/>TLS, K8s API cert<br/>Mutating Webhook"]
        end

        subgraph PipelinePods["Pipeline Execution Pods"]
            Pods["Pipeline Pods<br/>(kfp-driver + kfp-launcher)<br/>SA: pipeline-runner"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS<br/>ServiceAccount Token"]
        Database["MySQL/PostgreSQL<br/>3306/5432 TCP<br/>Optional TLS<br/>Username/Password<br/>Secret: mysql-secret"]
        ObjectStore["MinIO / S3 Storage<br/>9000/443 TCP HTTP/HTTPS<br/>Optional TLS<br/>Access Key/Secret Key<br/>Secret: mlpipeline-minio-artifact"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS Edge<br/>Kubeflow UserID"| Route
    Route -->|"HTTP/3000<br/>plaintext"| PipelineUI

    %% Frontend to backend
    PipelineUI -->|"HTTP/8888<br/>plaintext<br/>UserID Header"| APIServer
    PipelineUI -->|"HTTP/9090<br/>gRPC-Web<br/>plaintext"| MetadataEnvoy

    %% Metadata chain
    MetadataEnvoy -->|"gRPC/8080<br/>plaintext"| MetadataGRPC

    %% Controller flows
    PA -->|"HTTP/8888<br/>Projected SA Token"| APIServer
    PA -->|"HTTPS/443<br/>SA Token"| K8sAPI
    SWF -->|"HTTPS/443<br/>SA Token"| K8sAPI

    %% API Server egress
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA Token"| K8sAPI
    APIServer -->|"DB/3306 or 5432<br/>Optional TLS<br/>Username/Password"| Database
    APIServer -->|"HTTP(S)/9000 or 443<br/>Optional TLS<br/>Access Key"| ObjectStore

    %% Cache flows
    K8sAPI -->|"HTTPS/443→8443<br/>TLS<br/>K8s API cert"| Cache
    Cache -->|"DB/3306 or 5432<br/>Optional TLS<br/>Username/Password"| Database

    %% Pipeline pod flows
    Pods -->|"gRPC/8080<br/>plaintext"| MetadataGRPC
    Pods -->|"HTTP(S)/9000 or 443<br/>Optional TLS<br/>Access Key"| ObjectStore

    %% Styling
