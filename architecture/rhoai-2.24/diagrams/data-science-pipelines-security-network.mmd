    classDef api fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef metadata fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef cache fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class User external
    class Route ingress
    class PipelineUI internal
