%% vLLM RBAC / Authentication Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.24/vllm.md

graph TD
    subgraph "Container Security Context"
        Container["vLLM Container<br/>User: 2000 (vllm)<br/>Group: 0 (root group)<br/>Non-root"]
    end

    subgraph "Authentication Layer"
        AuthMW["AuthenticationMiddleware<br/>(ASGI Middleware)"]
        BearerToken["Bearer Token<br/>(VLLM_API_KEY env var<br/>or --api-key flag)"]
    end

    subgraph "Endpoint Authorization"
        direction TB
        Protected["/v1/* Endpoints<br/>(Requires Bearer Token)"]
        Public["Public Endpoints<br/>(No Auth Required)"]
    end

    subgraph "Protected Endpoints (/v1/*)"
        ChatCompletions["/v1/chat/completions"]
        Completions["/v1/completions"]
        Embeddings["/v1/embeddings"]
        Models["/v1/models"]
        Responses["/v1/responses"]
        Score["/v1/score"]
        Rerank["/v1/rerank"]
        Audio["/v1/audio/*"]
        LoRA["/v1/load_lora_adapter<br/>/v1/unload_lora_adapter"]
    end

    subgraph "Public Endpoints (No Auth)"
        Health["/health"]
        Ping["/ping"]
        Load["/load"]
        Metrics["/metrics"]
        Tokenize["/tokenize"]
        Detokenize["/detokenize"]
        TokenizerInfo["/tokenizer_info"]
        Version["/version"]
    end

    subgraph "TLS Configuration"
        SSLCert["ssl-certfile<br/>(File mount)<br/>TLS certificate"]
        SSLKey["ssl-keyfile<br/>(File mount)<br/>TLS private key"]
        SSLCACerts["ssl-ca-certs<br/>(File mount)<br/>CA certs for mTLS"]
        CertRefresher["SSLCertRefresher<br/>(Hot-reload on change)"]
    end

    subgraph "External Credentials"
        S3Creds["S3 Credentials<br/>S3_ACCESS_KEY_ID<br/>S3_SECRET_ACCESS_KEY"]
        HFToken["HuggingFace Token<br/>HF_TOKEN env var"]
    end

    %% Flows
    BearerToken -->|configures| AuthMW
    AuthMW -->|validates token| Protected
    Protected --> ChatCompletions
    Protected --> Completions
    Protected --> Embeddings
    Protected --> Models
    Protected --> Responses
    Protected --> Score
    Protected --> Rerank
    Protected --> Audio
    Protected --> LoRA

    Public --> Health
    Public --> Ping
    Public --> Load
    Public --> Metrics
    Public --> Tokenize
    Public --> Detokenize
    Public --> TokenizerInfo
    Public --> Version

    SSLCert --> CertRefresher
    SSLKey --> CertRefresher
    CertRefresher -->|hot-reload| Container

    S3Creds -->|model download| Container
    HFToken -->|"HF Hub auth<br/>(disabled in prod)"| Container

