%% ML Metadata (MLMD) - RBAC / Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: MLMD is a standalone gRPC service, not a Kubernetes operator.
%% It defines no CRDs, ClusterRoles, or ClusterRoleBindings.
%% Security is managed via gRPC-level TLS/mTLS and database credentials.

graph TD
    subgraph "Container Security"
        Container["odh-mlmd-grpc-server<br/>Runs as: UID 65534:65534 (non-root)<br/>Base: ubi9/ubi-minimal"]
    end

    subgraph "gRPC Authentication (Optional mTLS)"
        SSLConfig["SSLConfig"]
        ServerKey["server_key<br/>(PEM private key)"]
        ServerCert["server_cert<br/>(PEM certificate)"]
        CustomCA["custom_ca<br/>(Optional CA cert)"]
        ClientVerify["client_verify<br/>(mTLS enforcement)"]

        SSLConfig --> ServerKey
        SSLConfig --> ServerCert
        SSLConfig --> CustomCA
        SSLConfig --> ClientVerify
    end

    subgraph "Database Authentication"
        direction TB
        MySQLAuth["MySQL/MariaDB Auth"]
        MySQLCreds["Username/Password<br/>(via CLI flags or config)"]
        MySQLSSL["ssl_options<br/>(cert, key, ca, capath,<br/>cipher, verify_server_cert)"]

        PGAuth["PostgreSQL Auth"]
        PGCreds["Username/Password/Passfile<br/>(via CLI flags or config)"]
        PGSSL["ssloption<br/>(sslmode, sslcert, sslkey,<br/>sslpassword, sslrootcert)"]

        MySQLAuth --> MySQLCreds
        MySQLAuth --> MySQLSSL
        PGAuth --> PGCreds
        PGAuth --> PGSSL
    end

    subgraph "Secrets (Provisioned by DSP Operator / User)"
        Secret1["MySQL Credentials<br/>Type: username/password<br/>Auto-Rotate: No"]
        Secret2["PostgreSQL Credentials<br/>Type: username/password/passfile<br/>Auto-Rotate: No"]
        Secret3["SSL Certificates<br/>Type: PEM files<br/>Auto-Rotate: No"]
    end

    subgraph "Deployment Management"
        DSPOp["data-science-pipelines-operator<br/>Manages MLMD deployment"]
    end

    %% Connections
    DSPOp -->|"provisions"| Secret1
    DSPOp -->|"provisions"| Secret2
    DSPOp -->|"provisions"| Secret3

    Secret1 -.->|"configures"| MySQLAuth
    Secret2 -.->|"configures"| PGAuth
    Secret3 -.->|"configures"| SSLConfig

    SSLConfig -->|"secures"| Container
    MySQLAuth -->|"authenticates"| Container
    PGAuth -->|"authenticates"| Container

    %% Note
    NoK8sRBAC["Note: No CRDs, ClusterRoles,<br/>or ClusterRoleBindings.<br/>Standalone gRPC service."]

    style Container fill:#4a90e2,stroke:#333,color:#fff
    style SSLConfig fill:#f5a623,stroke:#333,color:#fff
    style ClientVerify fill:#e74c3c,stroke:#333,color:#fff
    style DSPOp fill:#7ed321,stroke:#333,color:#fff
    style NoK8sRBAC fill:#fff,stroke:#999,stroke-dasharray: 5 5
    style Secret1 fill:#ffe6cc,stroke:#d79b00
    style Secret2 fill:#ffe6cc,stroke:#d79b00
    style Secret3 fill:#ffe6cc,stroke:#d79b00
    style ServerKey fill:#f5d6ab,stroke:#333
