// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        datascientist = person "Data Scientist" "Creates and runs ML pipelines via Data Science Pipelines"
        admin = person "Platform Admin" "Manages Argo Workflows configuration and RBAC"

        argoWorkflows = softwareSystem "Argo Workflows" "Container-native workflow engine for orchestrating parallel jobs on Kubernetes" {
            workflowController = container "workflow-controller" "Watches Workflow CRDs, creates/manages pods, handles CronWorkflow scheduling, leader election, artifact GC" "Go Binary (Deployment), UID 8737, FIPS"
            argoexec = container "argoexec" "Sidecar/init container in workflow pods - manages container lifecycle, collects artifacts, captures logs" "Go Binary (Sidecar), UID 2000, FIPS"
            argoServer = container "argo-server" "REST/gRPC API server with web UI for workflow management" "Go Binary (Deployment)"
            webUI = container "Web UI" "Workflow visualization and management interface" "TypeScript/React SPA"
        }

        kubernetesAPI = softwareSystem "Kubernetes API" "Core platform for pod management and CRD operations" "External"
        s3Storage = softwareSystem "S3/MinIO Storage" "Artifact storage (S3-compatible)" "External"
        postgresql = softwareSystem "PostgreSQL" "Optional workflow archival persistence" "External"
        mysql = softwareSystem "MySQL" "Optional workflow archival persistence" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for argo-server" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection" "External"

        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and configures Argo Workflows components" "Internal RHOAI"
        dspAPIServer = softwareSystem "DSP API Server" "Creates Workflow CRs for pipeline execution" "Internal RHOAI"
        mlMetadata = softwareSystem "ML Metadata (MLMD)" "Tracks pipeline metadata and lineage" "Internal RHOAI"

        // Relationships
        datascientist -> dspAPIServer "Submits ML pipelines"
        admin -> argoServer "Manages workflows via UI/CLI" "HTTPS/2746"

        dspOperator -> argoWorkflows "Deploys and configures"
        dspAPIServer -> kubernetesAPI "Creates Workflow CRs" "HTTPS/443"

        workflowController -> kubernetesAPI "Watches CRDs, creates pods, leader election" "HTTPS/443"
        argoexec -> kubernetesAPI "Reports status, creates TaskResult CRs" "HTTPS/443"
        argoexec -> s3Storage "Uploads/downloads artifacts" "HTTPS/443 or HTTP/9000"
        argoServer -> kubernetesAPI "API operations via impersonation" "HTTPS/443"
        argoServer -> postgresql "Archives workflows (optional)" "TCP/5432"
        argoServer -> mysql "Archives workflows (optional)" "TCP/3306"
        argoServer -> oidcProvider "Validates SSO tokens (optional)" "HTTPS/443"
        argoServer -> webUI "Serves UI"
        prometheus -> workflowController "Scrapes metrics" "HTTP/9090"
        mlMetadata -> argoexec "Sidecar in workflow pods"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
