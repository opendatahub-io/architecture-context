/*
 * C4 Context Diagram: notebooks-downstream-z-test
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/notebooks-downstream-z-test.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Uses workbench environments for ML development"
        clusterAdmin = person "Cluster Admin" "Deploys and manages RHOAI platform"

        notebooksRepo = softwareSystem "Notebooks Downstream Z-Test" "Container image build repository providing pre-built workbench and runtime images for data science environments" {
            jupyterImages = container "Jupyter Workbench Images" "JupyterLab environments with ML frameworks (Minimal, Data Science, PyTorch, TensorFlow, TrustyAI)" "Container Images (UBI9, Python 3.11/3.12)"
            codeServerImage = container "Code Server Image" "VS Code (code-server) based development environment" "Container Image (UBI9)"
            rstudioImages = container "RStudio Server Images" "RStudio IDE for R programming (CPU and CUDA variants)" "Container Image (UBI9, BuildConfig)"
            runtimeImages = container "Runtime Images" "Minimal/Data Science/PyTorch/TensorFlow runtimes for Elyra pipeline execution" "Container Images (UBI9)"
            kustomizeManifests = container "Kustomize Manifests" "ImageStream and ConfigMap definitions with pinned image digests" "Kustomize overlays"
            tektonPipelines = container "Tekton Pipelines" "65 Konflux pipeline definitions for building and testing images" "Tekton/Konflux CI"
        }

        notebookController = softwareSystem "ODH Notebook Controller" "Manages notebook pod lifecycle, creates workbench pods from ImageStreams" "Internal ODH"
        rhoaiOperator = softwareSystem "RHOAI Operator (rhods-operator)" "Deploys ImageStream manifests from the repository into the cluster" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects, displays available workbench images" "Internal ODH"
        elyraPipelines = softwareSystem "Elyra Pipeline Runtime" "Executes pipeline nodes using runtime container images" "Internal ODH"

        quayRegistry = softwareSystem "Quay.io Registry" "Container image registry hosting pre-built workbench images (quay.io/modh/*)" "External"
        openshiftAPI = softwareSystem "OpenShift API Server" "Kubernetes/OpenShift control plane" "External"
        konfluxCI = softwareSystem "Konflux CI" "Red Hat build service for container image builds" "External"
        ubi9Registry = softwareSystem "UBI9 Base Images" "Red Hat UBI9 Python base images (registry.access.redhat.com)" "External"
        pypi = softwareSystem "PyPI" "Python Package Index for dependency installation" "External"
        nvidiaRepos = softwareSystem "NVIDIA/ROCm Repositories" "GPU toolkit and driver packages" "External"

        /* Relationships */
        dataScientist -> odhDashboard "Selects workbench image via UI"
        dataScientist -> notebookController "Accesses workbench via browser" "HTTPS/443"
        clusterAdmin -> rhoaiOperator "Installs and configures RHOAI"

        konfluxCI -> notebooksRepo "Builds container images" "Tekton pipelines"
        notebooksRepo -> quayRegistry "Pushes built images" "HTTPS/443"
        notebooksRepo -> ubi9Registry "Pulls base images" "HTTPS/443"
        notebooksRepo -> pypi "Installs Python packages" "HTTPS/443"
        notebooksRepo -> nvidiaRepos "Installs GPU packages" "HTTPS/443"

        rhoaiOperator -> openshiftAPI "Deploys ImageStreams + ConfigMaps" "HTTPS/6443"
        rhoaiOperator -> notebooksRepo "Reads kustomize manifests"

        notebookController -> openshiftAPI "Reads ImageStreams, creates pods" "HTTPS/6443"
        notebookController -> quayRegistry "Pulls workbench images" "HTTPS/443"

        odhDashboard -> openshiftAPI "Reads ImageStream annotations" "HTTPS/6443"

        elyraPipelines -> runtimeImages "Uses runtime images for pipeline nodes"
    }

    views {
        systemContext notebooksRepo "SystemContext" {
            include *
            autoLayout
        }

        container notebooksRepo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Container" {
                background #85bbf0
                color #000000
            }
        }
    }
}
