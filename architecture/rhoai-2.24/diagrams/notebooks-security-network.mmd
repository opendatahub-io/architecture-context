%% Security Network Diagram - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route (2.x)<br/>HTTPRoute via Gateway API (3.x)<br/>443/TCP<br/>TLS 1.2+<br/>Managed by ODH Notebook Controller"]
    end

    subgraph AuthLayer["AUTHENTICATION SIDECAR"]
        AuthProxy["kube-rbac-proxy (3.x) /<br/>oauth-proxy (2.x)<br/>8443/TCP HTTPS<br/>Bearer Token / OAuth<br/>Policy: Namespace access required"]
    end

    subgraph Workbenches["WORKBENCH CONTAINERS (UID 1001, non-root)"]
        direction TB
        JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>UBI9 Python 3.11/3.12<br/>FIPS-compliant"]
        CodeServer["Code Server<br/>8787/TCP HTTP<br/>code-server 4.98"]
        RStudio["RStudio Server<br/>8787/TCP HTTP<br/>R 4.4 + Python 3.11"]
    end

    subgraph EgressTargets["EGRESS DESTINATIONS"]
        OCPAPI["OpenShift API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount token"]
        PyPI["PyPI / Package Registries<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth"]
        S3["S3-compatible Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS credentials"]
    end

    subgraph ImageSupply["IMAGE SUPPLY CHAIN"]
        Operator["rhods-operator<br/>Deploys kustomize manifests"]
        ImageStreams["OpenShift ImageStreams"]
        Quay["quay.io/modh/*<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull secret"]
    end

    subgraph PipelineFlow["PIPELINE RUNTIME"]
        DSP["Data Science Pipelines API<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Bearer Token"]
        RuntimePod["Runtime Image Pod<br/>ServiceAccount"]
    end

    %% Ingress flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>OpenShift OAuth"| Route
    Route -->|"HTTPS/8443<br/>TLS<br/>Bearer Token / OAuth"| AuthProxy
    AuthProxy -->|"HTTP/8888<br/>plaintext (localhost)<br/>Trusted sidecar"| JupyterLab
    AuthProxy -->|"HTTP/8787<br/>plaintext (localhost)<br/>Trusted sidecar"| CodeServer
    AuthProxy -->|"HTTP/8787<br/>plaintext (localhost)<br/>Trusted sidecar"| RStudio

    %% Egress flows
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>SA token"| OCPAPI
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>No auth"| PyPI
    JupyterLab -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS creds"| S3

    %% Pipeline flows
    JupyterLab -->|"HTTPS/443<br/>Bearer Token<br/>Submit pipeline"| DSP
    DSP -->|"Schedule"| RuntimePod
    RuntimePod -->|"HTTPS/443<br/>AWS creds"| S3

    %% Image supply chain
    Operator -->|"Create CRs"| ImageStreams
    ImageStreams -->|"HTTPS/443<br/>Pull secret"| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef workbench fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef egress fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef supply fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef pipeline fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Route ingress
    class AuthProxy auth
    class JupyterLab,CodeServer,RStudio workbench
    class OCPAPI,PyPI,S3 egress
    class Operator,ImageStreams,Quay supply
    class DSP,RuntimePod pipeline
