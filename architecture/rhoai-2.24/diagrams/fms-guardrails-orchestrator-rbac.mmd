%% FMS Guardrails Orchestrator - RBAC / Security Diagram
%% Generated by: Claude Opus 4.6
%% Note: No Kubernetes RBAC defined (standalone service). Diagram shows TLS-based security model.

graph TD
    subgraph TLSModes["TLS Security Modes"]
        direction TB
        Mode1["Mode 1: No TLS<br/>(Default)<br/>Plaintext HTTP on 8033/TCP"]
        Mode2["Mode 2: TLS<br/>(TLS_CERT_PATH + TLS_KEY_PATH set)<br/>Server presents certificate"]
        Mode3["Mode 3: mTLS<br/>(+ TLS_CLIENT_CA_CERT_PATH set)<br/>Server requires + verifies client certs"]
    end

    subgraph InboundAuth["Inbound Authentication"]
        direction TB
        APIEndpoints["All /api/* Endpoints<br/>Port 8033/TCP<br/>POST requests"]
        HealthEndpoints["Health Endpoints<br/>Port 8034/TCP<br/>GET /health, /info"]
    end

    subgraph AuthMechanism["Auth Mechanisms"]
        mTLSVerifier["WebPkiClientVerifier<br/>(rustls)<br/>Verifies client cert against CA"]
        NoAuth["No Authentication<br/>(plaintext, open)"]
    end

    subgraph OutboundTLS["Outbound TLS (per-service profiles)"]
        direction TB
        GenTLS["Generation Servers<br/>Named TLS profile<br/>cert/key/ca_cert/insecure"]
        DetTLS["Detector Services<br/>Named TLS profile<br/>cert/key/ca_cert/insecure"]
        ChunkTLS["Chunker Services<br/>Named TLS profile<br/>cert/key/ca_cert/insecure"]
    end

    subgraph Secrets["Secrets (PEM files)"]
        ServerCert["TLS Server Cert/Key<br/>Server-side TLS for 8033<br/>Provisioned externally"]
        ClientCA["TLS Client CA Cert<br/>mTLS client verification<br/>Provisioned externally"]
        ClientCerts["Client TLS Cert/Key<br/>(per service)<br/>mTLS outbound connections"]
    end

    Mode3 -->|enables| mTLSVerifier
    APIEndpoints -->|protected by| mTLSVerifier
    HealthEndpoints -->|uses| NoAuth

    ServerCert -->|used by| Mode2
    ServerCert -->|used by| Mode3
    ClientCA -->|used by| mTLSVerifier
    ClientCerts -->|used by| GenTLS
    ClientCerts -->|used by| DetTLS
    ClientCerts -->|used by| ChunkTLS

    style Mode1 fill:#ff6b6b,color:#fff
    style Mode2 fill:#ffd93d,color:#333
    style Mode3 fill:#6bcb77,color:#fff
    style mTLSVerifier fill:#4a90e2,color:#fff
    style NoAuth fill:#e8e8e8,stroke:#333
    style APIEndpoints fill:#4a90e2,color:#fff
    style HealthEndpoints fill:#e8e8e8,stroke:#333
    style ServerCert fill:#f5a623
    style ClientCA fill:#f5a623
    style ClientCerts fill:#f5a623
    style GenTLS fill:#d5e8d4,stroke:#82b366
    style DetTLS fill:#d5e8d4,stroke:#82b366
    style ChunkTLS fill:#d5e8d4,stroke:#82b366
