// CodeFlare Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates RayClusters and AppWrappers for distributed ML workloads"
        mlEngineer = person "ML Engineer" "Connects Ray clients and accesses Ray Dashboard"

        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages RayCluster lifecycle with OAuth proxy authentication and mTLS encryption, optionally embeds AppWrapper controller for batch workload management" {
            manager = container "codeflare-operator-manager" "Main operator binary (controller-runtime based)" "Go Operator"
            rayClusterController = container "RayCluster Controller" "Watches RayCluster CRs; creates Routes, Services, Secrets, NetworkPolicies, ClusterRoleBindings" "Go Controller"
            appWrapperController = container "AppWrapper Controller" "Embedded controller for batch workload orchestration via AppWrapper CRs" "Go Controller (embedded)"
            rayClusterWebhookMutating = container "RayCluster Mutating Webhook" "Injects oauth-proxy sidecar and mTLS init containers into RayCluster pods" "Admission Webhook (9443/TCP)"
            rayClusterWebhookValidating = container "RayCluster Validating Webhook" "Validates that injected OAuth proxy, mTLS containers are not modified" "Admission Webhook (9443/TCP)"
            appWrapperWebhookMutating = container "AppWrapper Mutating Webhook" "Mutating webhook for AppWrapper resources" "Admission Webhook (9443/TCP)"
            appWrapperWebhookValidating = container "AppWrapper Validating Webhook" "Validating webhook for AppWrapper resources" "Admission Webhook (9443/TCP)"
            certRotator = container "Cert Rotator" "Manages webhook TLS certificates" "cert-controller"
        }

        kuberayOperator = softwareSystem "KubeRay Operator" "Creates and manages RayCluster custom resources" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys CodeFlare Operator via kustomize overlay" "Internal ODH"
        kueue = softwareSystem "Kueue" "Queue-based workload scheduling and quota management" "Internal ODH"
        dscInit = softwareSystem "DSCInitialization" "Provides application namespace configuration" "Internal ODH"

        openshiftOAuth = softwareSystem "OpenShift OAuth" "Identity and authentication provider" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "Ingress controller for Routes" "External"
        openshiftServingCert = softwareSystem "OpenShift serving-cert-signer" "Auto-provisions TLS certificates for services" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for resource management and webhook callbacks" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // User interactions
        dataScientist -> codeflareOperator "Creates RayCluster and AppWrapper CRs via kubectl" "HTTPS/443"
        mlEngineer -> openshiftRouter "Accesses Ray Dashboard" "HTTPS/443"
        mlEngineer -> openshiftRouter "Connects Ray client" "HTTPS/443 mTLS"

        // Internal container relationships
        manager -> rayClusterController "Manages"
        manager -> appWrapperController "Manages"
        manager -> certRotator "Manages"
        certRotator -> rayClusterWebhookMutating "Provisions TLS certs"
        certRotator -> rayClusterWebhookValidating "Provisions TLS certs"

        // Operator dependencies
        codeflareOperator -> k8sAPI "CRD CRUD, webhook registration, resource management" "HTTPS/443"
        codeflareOperator -> kuberayOperator "Watches RayCluster CRs created by KubeRay" "CRD Watch"
        codeflareOperator -> openshiftOAuth "OAuth proxy sidecar delegates authentication" "HTTPS/8443"
        codeflareOperator -> openshiftRouter "Creates Routes for Dashboard and Client endpoints" "HTTPS/443"
        codeflareOperator -> openshiftServingCert "Annotation-based TLS cert provisioning" "Annotation"
        codeflareOperator -> prometheus "Exposes operator metrics" "HTTP/8080"
        appWrapperController -> kueue "Integrates for quota-based scheduling" "Workload API"
        rayClusterController -> dscInit "Reads DSCInitialization CR for namespace discovery" "CRD Read"

        // Deployment
        rhodsOperator -> codeflareOperator "Deploys via kustomize overlay" "Deployment"

        // API Server to webhooks
        k8sAPI -> rayClusterWebhookMutating "Admission review requests" "HTTPS/9443"
        k8sAPI -> rayClusterWebhookValidating "Admission review requests" "HTTPS/9443"
        k8sAPI -> appWrapperWebhookMutating "Admission review requests" "HTTPS/9443"
        k8sAPI -> appWrapperWebhookValidating "Admission review requests" "HTTPS/9443"
    }

    views {
        systemContext codeflareOperator "SystemContext" {
            include *
            autoLayout
        }

        container codeflareOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
