/*
 * Guardrails Detectors - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/guardrails-detectors.md
 */

workspace {
    model {
        orchestrator = person "FMS Guardrails Orchestrator" "Invokes detector endpoints for content analysis during guardrail evaluation"

        guardrailsDetectors = softwareSystem "Guardrails Detectors" "Collection of text content detection microservices for PII detection, file-type validation, HuggingFace model-based analysis, and LLM-as-a-Judge evaluation" {
            builtInDetector = container "Built-in Detector" "Lightweight regex-based PII detection (email, credit card, SSN, phone, IP) and file-type validation (JSON, XML, YAML with schema)" "Python FastAPI, port 8080"
            huggingfaceDetector = container "HuggingFace Detector" "ML-based content analysis using AutoModelForSequenceClassification and GraniteForCausalLM models" "Python FastAPI, port 8000"
            llmJudgeDetector = container "LLM Judge Detector" "LLM-as-a-Judge content evaluation using vLLM Judge library with built-in and custom metrics" "Python FastAPI, port 8000"
            detectorBaseAPI = container "DetectorBaseAPI" "Shared base application class providing health endpoints, detector registry, Prometheus instrumentation" "Python FastAPI"
        }

        kserve = softwareSystem "KServe" "Manages detector deployment lifecycle via InferenceService and ServingRuntime CRs" "External"
        istio = softwareSystem "Istio Service Mesh" "Provides transparent mTLS encryption, traffic management, and sidecar injection" "External"
        vllmServer = softwareSystem "vLLM Server" "Backend LLM server providing OpenAI-compatible API for judge-based scoring" "External"
        minioStorage = softwareSystem "S3/MinIO Object Storage" "Stores and serves HuggingFace model artifacts" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Public model repository for downloading ML models" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        odhDashboard = softwareSystem "ODH Dashboard" "RHOAI dashboard providing UI visibility for deployed components" "Internal ODH"

        /* Relationships */
        orchestrator -> guardrailsDetectors "Invokes detectors for content analysis" "HTTP/8080, HTTP/8000, Istio mTLS"
        orchestrator -> builtInDetector "POST /api/v1/text/contents" "HTTP/8080, Istio mTLS"
        orchestrator -> huggingfaceDetector "POST /api/v1/text/contents" "HTTP/8000, Istio mTLS"
        orchestrator -> llmJudgeDetector "POST /api/v1/text/contents, /api/v1/text/generation" "HTTP/8000, Istio mTLS"

        guardrailsDetectors -> istio "Uses for mTLS and traffic management"
        guardrailsDetectors -> kserve "Deployed via InferenceService CRs"
        llmJudgeDetector -> vllmServer "Sends evaluation prompts" "HTTP/8080, plaintext"
        huggingfaceDetector -> minioStorage "Downloads model artifacts" "HTTP/9000, AWS credentials"
        huggingfaceDetector -> huggingfaceHub "Downloads models (init)" "HTTPS/443, TLS 1.2+"
        prometheus -> guardrailsDetectors "Scrapes /metrics endpoints" "HTTP/8080, HTTP/8000"
        odhDashboard -> guardrailsDetectors "Dashboard visibility via labels/annotations"

        builtInDetector -> detectorBaseAPI "extends"
        huggingfaceDetector -> detectorBaseAPI "extends"
        llmJudgeDetector -> detectorBaseAPI "extends"
    }

    views {
        systemContext guardrailsDetectors "SystemContext" {
            include *
            autoLayout
        }

        container guardrailsDetectors "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
