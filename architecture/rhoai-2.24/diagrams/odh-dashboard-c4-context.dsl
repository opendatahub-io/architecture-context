// ODH Dashboard - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/odh-dashboard.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and manages notebooks, deploys models, runs pipelines"
        admin = person "Platform Admin" "Configures platform settings, manages accelerator/hardware profiles"

        odhDashboard = softwareSystem "ODH Dashboard" "Web-based management console for Red Hat OpenShift AI" {
            oauthProxy = container "OAuth Proxy" "Authentication sidecar handling OpenShift OAuth, TLS termination" "OpenShift OAuth Proxy" "Sidecar"
            backend = container "Dashboard Backend" "API gateway proxying requests to Kubernetes API, serving frontend, WebSocket proxy" "Node.js / Fastify"
            frontend = container "Dashboard Frontend" "Web UI for notebooks, model serving, pipelines, model registry" "React / PatternFly 6" "SPA"
            mrUI = container "Model Registry UI" "Federated micro-frontend for model registry" "React (Module Federation)" "Optional Sidecar"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster resource management" "External"
        openshiftOAuth = softwareSystem "OpenShift OAuth" "User authentication provider" "External"
        thanosQuerier = softwareSystem "Thanos Querier" "Prometheus metrics aggregation" "External"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages ODH Dashboard" "Internal ODH"

        kserve = softwareSystem "KServe" "Model serving infrastructure (InferenceService, ServingRuntime)" "Internal ODH"
        notebookController = softwareSystem "Kubeflow Notebook Controller" "Notebook/workbench lifecycle management" "Internal ODH"
        modelRegistryOp = softwareSystem "Model Registry Operator" "Model registry instance management" "Internal ODH"
        modelRegistrySvc = softwareSystem "Model Registry Service" "Model metadata storage and retrieval" "Internal ODH"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal ODH"
        openshiftConsole = softwareSystem "OpenShift Console" "OpenShift web console" "External"

        // User interactions
        dataScientist -> odhDashboard "Manages notebooks, models, pipelines via browser" "HTTPS/443"
        admin -> odhDashboard "Configures platform settings via browser" "HTTPS/443"

        // Container-level interactions
        dataScientist -> oauthProxy "Accesses dashboard" "HTTPS/443 via Route"
        oauthProxy -> backend "Forwards authenticated requests" "HTTP/8080 (localhost)"
        backend -> frontend "Serves static assets" "HTTP"
        backend -> mrUI "Module federation proxy" "HTTPS/8043"

        // System dependencies
        odhDashboard -> k8sAPI "CRUD operations on all cluster resources" "HTTPS+WSS/443"
        odhDashboard -> openshiftOAuth "User authentication" "HTTPS/443"
        odhDashboard -> thanosQuerier "Prometheus metrics queries" "HTTPS/9092"
        odhDashboard -> modelRegistrySvc "Model metadata operations" "gRPC/HTTPS"

        // Internal ODH integrations
        rhodsOperator -> odhDashboard "Deploys and manages via kustomize"
        odhDashboard -> kserve "Manages InferenceServices and ServingRuntimes" "via k8s API"
        odhDashboard -> notebookController "Manages Notebook CRs" "via k8s API"
        odhDashboard -> modelRegistryOp "Manages ModelRegistry CRs" "via k8s API"
        odhDashboard -> openshiftConsole "Adds ConsoleLink for navigation" "ConsoleLink CR"
    }

    views {
        systemContext odhDashboard "SystemContext" {
            include *
            autoLayout
        }

        container odhDashboard "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Sidecar" {
                background #e8a838
                color #ffffff
            }
            element "SPA" {
                background #4a90e2
                color #ffffff
            }
            element "Optional Sidecar" {
                background #b8d4e3
                color #333333
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
        }
    }
}
