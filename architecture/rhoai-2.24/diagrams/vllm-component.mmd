        Worker0 --> CUDAKernels
        Worker1 --> CUDAKernels
        Worker0 --> ModelExecutor
    end

    subgraph "gRPC Adapter (Port 8033/TCP)"
        TGISAdapter["vllm-tgis-adapter<br/>(TGIS gRPC Interface)"]
    end

    %% Internal connections
    APIServer -->|ZMQ IPC| AsyncEngine
    EngineV1 --> Executor
