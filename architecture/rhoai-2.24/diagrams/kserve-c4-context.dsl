// KServe C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/kserve.md

workspace {
    model {
        // Actors
        dataScientist = person "Data Scientist" "Creates and deploys ML models using InferenceService and LLMInferenceService CRs"
        externalClient = person "External Client" "Sends inference requests to deployed models"

        // Primary System
        kserve = softwareSystem "KServe" "Kubernetes-native model serving platform for RHOAI - manages InferenceService lifecycle, scaling, and traffic routing" {
            controllerManager = container "KServe Controller Manager" "Runs InferenceService, LLMInferenceService, InferenceGraph, and TrainedModel controllers plus webhooks" "Go Operator (controller-runtime)" "Primary"
            webhookServer = container "Webhook Server" "Mutating and validating admission webhooks for KServe CRDs and pod injection" "Go (embedded in controller)" "Primary"
            storageInitializer = container "Storage Initializer" "Downloads model artifacts from S3, GCS, Azure, PVC, or OCI registries" "Init Container" "Supporting"
            kserveAgent = container "KServe Agent" "Request logging, batching, and model agent capabilities" "Sidecar Container" "Supporting"
            kserveRouter = container "KServe Router" "InferenceGraph routing logic - forwards requests to DAG nodes" "Deployment" "Supporting"
            llmdScheduler = container "llm-d Inference Scheduler" "Intelligent LLM request scheduling via Gateway API Inference Extension (ext_proc)" "Deployment" "Supporting"
            llmdRoutingSidecar = container "llm-d Routing Sidecar" "Routing sidecar for LLM inference workloads" "Init Container" "Supporting"
        }

        // External Dependencies (Required/Conditional)
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (v4.15-v4.19)" "External"
        istio = softwareSystem "Istio Service Mesh" "VirtualService-based traffic management and mTLS for Serverless mode" "External"
        knative = softwareSystem "Knative Serving" "Serverless autoscaling with scale-to-zero (v0.44+)" "External"
        gatewayAPI = softwareSystem "Gateway API" "HTTPRoute-based ingress for RawDeployment and LLMInferenceService modes (v1.2+)" "External"
        gatewayInferenceExt = softwareSystem "Gateway API Inference Extension" "InferencePool/InferenceModel for intelligent LLM routing (v0.3.0)" "External"
        leaderWorkerSet = softwareSystem "LeaderWorkerSet" "Multi-node LLM inference workload orchestration (v0.6+)" "External"

        // External Dependencies (Optional)
        keda = softwareSystem "KEDA" "Event-driven autoscaling via ScaledObjects (v2.16+)" "External Optional"
        otelOperator = softwareSystem "OpenTelemetry Operator" "Metrics collection via OpenTelemetryCollector CRs (v0.113+)" "External Optional"
        prometheusOperator = softwareSystem "Prometheus Operator" "ServiceMonitor/PodMonitor for monitoring" "External Optional"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys KServe manifests via Kustomize overlays" "Internal ODH"
        odhModelController = softwareSystem "odh-model-controller" "Manages OpenShift Routes and auth for InferenceServices" "Internal ODH"

        // External Services
        s3Storage = softwareSystem "Object Storage (S3/GCS/Azure)" "Model artifact storage" "External Service"
        ociRegistries = softwareSystem "OCI Container Registries" "Model artifacts via modelcar (OCI)" "External Service"

        // Relationships - User interactions
        dataScientist -> kserve "Creates InferenceService / LLMInferenceService via kubectl/API" "HTTPS/443"
        externalClient -> kserve "Sends inference requests" "HTTPS/443"

        // Relationships - External dependencies
        kserve -> kubernetes "Controller operations, webhook calls" "HTTPS/443, ServiceAccount Token"
        kserve -> istio "Creates VirtualServices, DestinationRules for traffic routing" "Kubernetes API"
        kserve -> knative "Creates Knative Services for serverless autoscaling" "Kubernetes API"
        kserve -> gatewayAPI "Creates HTTPRoutes for ingress routing" "Kubernetes API"
        kserve -> gatewayInferenceExt "Creates InferencePool/InferenceModel for LLM routing" "Kubernetes API"
        kserve -> leaderWorkerSet "Creates LeaderWorkerSets for multi-node LLM inference" "Kubernetes API"
        kserve -> keda "Creates ScaledObjects for event-driven autoscaling" "Kubernetes API"
        kserve -> otelOperator "Creates OpenTelemetryCollector CRs" "Kubernetes API"
        kserve -> prometheusOperator "Creates ServiceMonitor/PodMonitor CRs" "Kubernetes API"

        // Relationships - Internal ODH
        rhodsOperator -> kserve "Deploys via Kustomize overlays" "Kustomize"
        odhModelController -> kserve "Manages Routes and OAuth for InferenceServices" "Annotations"

        // Relationships - External services
        kserve -> s3Storage "Downloads model artifacts" "HTTPS/443, Cloud credentials"
        kserve -> ociRegistries "Downloads model artifacts via OCI" "HTTPS/443, Registry credentials"

        // Internal container relationships
        controllerManager -> webhookServer "Validates/mutates CRDs" "HTTPS/9443"
        controllerManager -> storageInitializer "Injects into pods" "Pod spec mutation"
        controllerManager -> kserveAgent "Injects into pods" "Pod spec mutation"
        controllerManager -> llmdScheduler "Deploys for LLMInferenceService" "Kubernetes API"
        controllerManager -> llmdRoutingSidecar "Injects into LLM pods" "Pod spec mutation"
        controllerManager -> kserveRouter "Deploys for InferenceGraph" "Kubernetes API"
    }

    views {
        systemContext kserve "SystemContext" {
            include *
            autoLayout
            description "KServe system context showing external dependencies and integrations"
        }

        container kserve "Containers" {
            include *
            autoLayout
            description "KServe internal container architecture"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #bbbbbb
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Primary" {
                background #4a90e2
                color #ffffff
            }
            element "Supporting" {
                background #6cb4ee
                color #ffffff
            }
        }
    }
}
