%% vllm-gaudi Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "vllm-gaudi Container"
        subgraph "Entrypoints"
            OpenAIServer["OpenAI API Server<br/>(FastAPI/uvicorn)<br/>Port 8000/TCP"]
            GRPCAdapter["gRPC TGIS Adapter<br/>(vllm-tgis-adapter)<br/>Port 8033/TCP"]
        end

        subgraph "Engine Layer"
            AsyncEngine["AsyncLLMEngine<br/>Request Scheduling &<br/>Batching Orchestration"]
            MPEngine["Multiprocessing Engine<br/>ZMQ IPC Frontend-Backend"]
        end

        subgraph "Execution Layer"
            HPURunner["HPU Model Runner<br/>Attention, Batching,<br/>Memory Management"]
            HPUWorker["HPU Worker<br/>KV Cache, Distributed<br/>Inference Partitions"]
            RayExecutor["Ray Distributed Executor<br/>Tensor/Pipeline Parallelism"]
        end

        subgraph "Observability"
            Prometheus["Prometheus Metrics<br/>/metrics endpoint"]
            OTel["OpenTelemetry Tracing<br/>OTLP Export (optional)"]
        end

        subgraph "Security"
            SSLRefresher["SSL Certificate Refresher<br/>Hot-reload TLS certs"]
        end
    end

    %% External integrations
    Client[External Client] -->|"HTTPS/443<br/>Bearer Token"| KServeIngress[KServe/Route Ingress]
    KServeIngress -->|"HTTP(S)/8000"| OpenAIServer
    ModelMesh[ModelMesh Router] -->|"gRPC/8033"| GRPCAdapter

    %% Internal flows
    OpenAIServer --> AsyncEngine
    GRPCAdapter --> AsyncEngine
    AsyncEngine --> MPEngine
    MPEngine -->|"ZMQ IPC"| HPURunner
    HPURunner --> HPUWorker
    HPUWorker -->|"HCCL"| RayExecutor

    %% Observability connections
    OpenAIServer --> Prometheus
    OpenAIServer --> OTel
    OpenAIServer --> SSLRefresher

    %% External dependencies
    HPUWorker -->|"Device Memory"| GaudiHPU["Intel Gaudi<br/>Accelerator"]
    RayExecutor -->|"TCP/6379"| RayHead["Ray Head Node"]

