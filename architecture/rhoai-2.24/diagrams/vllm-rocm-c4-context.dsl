// C4 Context Diagram for vLLM (ROCm Build)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/vllm-rocm.md

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys and queries LLM models for inference"
        mlengineeer = person "ML Engineer" "Configures model serving infrastructure"

        vllmRocm = softwareSystem "vLLM (ROCm)" "High-throughput LLM inference engine for AMD ROCm GPUs with OpenAI-compatible API and TGIS gRPC interface" {
            openaiServer = container "OpenAI API Server" "Serves OpenAI-compatible REST API (chat, completions, embeddings)" "Python FastAPI/Uvicorn" "Service"
            tgisAdapter = container "TGIS gRPC Adapter" "Wraps vLLM engine with TGIS-compatible gRPC interface" "Python gRPC / vllm-tgis-adapter" "Service"
            vllmEngine = container "vLLM Engine" "Core inference engine with PagedAttention memory management" "Python Library"
            modelRunner = container "Model Runner" "Loads and executes LLM models on AMD GPUs" "Python Module"
            gpuWorker = container "GPU Worker" "Manages GPU worker processes for model execution" "Python Module"
            distributedModule = container "Distributed Module" "Handles tensor/pipeline/data parallelism across GPUs" "Python Module"
            flashAttention = container "Flash Attention (ROCm)" "Optimized attention kernels for AMD GPUs" "C++/HIP Library"
            cExtensions = container "C++ Extensions" "Custom GPU kernels for attention, sampling, quantization" "C++/HIP"
        }

        kserve = softwareSystem "KServe" "Model serving orchestration with InferenceService" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Multi-model serving platform" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact discovery and metadata" "Internal RHOAI"
        dsPipelines = softwareSystem "Data Science Pipelines" "ML workflow orchestration" "Internal RHOAI"

        s3 = softwareSystem "S3 Storage" "Model artifact storage" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model weights and tokenizer download" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing" "External"
        ray = softwareSystem "Ray" "Distributed inference orchestration" "External"
        rocmGPU = softwareSystem "AMD ROCm GPU" "GPU compute (MI100/MI200/MI300)" "Infrastructure"

        // User interactions
        datascientist -> vllmRocm "Sends inference requests via OpenAI API" "HTTP/8000"
        mlengineeer -> kserve "Configures InferenceService" "kubectl"

        // Internal RHOAI interactions
        kserve -> vllmRocm "Routes inference requests" "gRPC/8033, HTTP/8000"
        modelmesh -> vllmRocm "Multi-model inference requests" "gRPC/8033"
        modelRegistry -> vllmRocm "Provides model metadata" "HTTP API"
        dsPipelines -> vllmRocm "Deploys models from training" "Workflow"

        // External service interactions
        vllmRocm -> s3 "Downloads model artifacts" "HTTPS/443, AWS IAM"
        vllmRocm -> hfHub "Downloads model weights (disabled in prod)" "HTTPS/443, HF Token"
        vllmRocm -> rocmGPU "Executes inference on AMD GPUs" "HIP/ROCm"
        vllmRocm -> ray "Distributed multi-GPU inference" "Ray Protocol/6379"
        prometheus -> vllmRocm "Scrapes metrics" "HTTP/8000 /metrics"
        vllmRocm -> otelCollector "Exports traces" "OTLP gRPC/HTTP"

        // Container relationships
        openaiServer -> vllmEngine "Submits inference requests" "Internal"
        tgisAdapter -> vllmEngine "Submits inference requests" "Internal"
        vllmEngine -> modelRunner "Loads and runs models" "Internal"
        vllmEngine -> gpuWorker "Manages GPU processes" "Internal"
        vllmEngine -> distributedModule "Coordinates parallelism" "Internal"
        gpuWorker -> flashAttention "Executes attention kernels" "HIP/ROCm"
        gpuWorker -> cExtensions "Executes custom kernels" "HIP/ROCm"
    }

    views {
        systemContext vllmRocm "SystemContext" {
            include *
            autoLayout
        }

        container vllmRocm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #e74c3c
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
            element "Service" {
                shape RoundedBox
            }
        }
    }
}
