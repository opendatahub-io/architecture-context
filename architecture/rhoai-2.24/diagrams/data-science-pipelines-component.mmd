%% Data Science Pipelines - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["ml-pipeline<br/>API Server<br/>(Go)<br/>REST 8888/TCP<br/>gRPC 8887/TCP"]
            Webhook["Webhook Server<br/>(Go)<br/>8443/TCP HTTPS"]
            APIServer -->|hosts| Webhook
        end

        subgraph Controllers["Controllers"]
            PersistenceAgent["ml-pipeline-<br/>persistenceagent<br/>(Go)"]
            ScheduledWorkflow["ml-pipeline-<br/>scheduledworkflow<br/>(Go Controller)"]
            ViewerCRD["ml-pipeline-<br/>viewer-crd<br/>(Go Controller)"]
        end

        subgraph Frontend["Frontend"]
            UI["ml-pipeline-ui<br/>(Node.js/React)<br/>3000/TCP"]
            VisServer["ml-pipeline-<br/>visualizationserver<br/>(Python)<br/>8888/TCP"]
        end

        subgraph Metadata["Metadata Layer"]
            MetadataGRPC["metadata-grpc<br/>(C++ gRPC)<br/>8080/TCP"]
            MetadataEnvoy["metadata-envoy<br/>(Envoy Proxy)<br/>9090/TCP"]
            MetadataEnvoy -->|proxies gRPC-Web| MetadataGRPC
        end

        subgraph Caching["Caching"]
            CacheServer["cache-server<br/>(Go)<br/>8443/TCP HTTPS<br/>Mutating Webhook"]
        end

        subgraph PipelineBinaries["Pipeline Step Binaries (Injected)"]
            Driver["kfp-driver<br/>(Go Binary)"]
            Launcher["kfp-launcher<br/>(Go Binary)"]
        end
    end

    %% CRDs
    PipelineCR["Pipeline CR<br/>pipelines.kubeflow.org/v2beta1"]
    PipelineVersionCR["PipelineVersion CR<br/>pipelines.kubeflow.org/v2beta1"]
    ScheduledWorkflowCR["ScheduledWorkflow CR<br/>kubeflow.org/v1beta1"]
    ViewerCR["Viewer CR<br/>kubeflow.org/v1beta1"]
    WorkflowCR["Workflow CR<br/>argoproj.io/v1alpha1"]

    %% External Dependencies
    ArgoWF["Argo Workflows<br/>v3.5.14"]
    Database["MySQL / PostgreSQL"]
    ObjectStorage["MinIO / S3<br/>Object Storage"]
    K8sAPI["Kubernetes API<br/>Server"]

    %% Internal ODH Dependencies
    DSPOperator["data-science-pipelines-<br/>operator"]
    Dashboard["ODH Dashboard"]

    %% CR relationships
    PipelineCR -->|watched by| APIServer
    PipelineVersionCR -->|validated by| Webhook
    ScheduledWorkflowCR -->|managed by| ScheduledWorkflow
    ViewerCR -->|managed by| ViewerCRD
    WorkflowCR -->|created by| APIServer

    %% Data flows
    PersistenceAgent -->|watches workflows via| K8sAPI
    PersistenceAgent -->|reports status to| APIServer
    ScheduledWorkflow -->|creates workflows via| K8sAPI
    UI -->|proxies API calls| APIServer
    UI -->|fetches metadata| MetadataEnvoy
    Driver -->|records lineage| MetadataGRPC
    Driver -->|reads/writes artifacts| ObjectStorage
    Launcher -->|manages I/O| ObjectStorage

    %% External connections
    APIServer -->|creates workflows| ArgoWF
    APIServer -->|stores metadata| Database
    APIServer -->|stores artifacts| ObjectStorage
    APIServer -->|RBAC checks| K8sAPI
    CacheServer -->|checks cache| Database

    %% Operator & Dashboard
    DSPOperator -->|deploys & manages| DSP
    Dashboard -->|integrates with| APIServer

