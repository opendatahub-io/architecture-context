// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Ray clusters, jobs, and serving workloads"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and serving workloads on Kubernetes/OpenShift" {
            rayClusterController = container "RayCluster Controller" "Reconciles RayCluster CRs: creates head/worker Pods, Services, Routes, autoscaler RBAC" "Go (controller-runtime)"
            rayJobController = container "RayJob Controller" "Reconciles RayJob CRs: manages cluster lifecycle and job submission" "Go (controller-runtime)"
            rayServiceController = container "RayService Controller" "Reconciles RayService CRs: zero-downtime upgrades and Serve deployments" "Go (controller-runtime)"
            webhook = container "Validating Webhook" "Validates RayCluster CR creation and updates" "Go HTTPS Server (9443/TCP)"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics" "HTTP Server (8080/TCP)"
        }

        kubernetes = softwareSystem "Kubernetes/OpenShift" "Container orchestration platform" "External" {
            apiServer = container "API Server" "Kubernetes API for resource management" "HTTPS/443"
        }

        ray = softwareSystem "Ray Cluster" "Distributed computing framework" "Managed" {
            headNode = container "Ray Head Node" "Dashboard (8265), GCS (6379), Client (10001), Serve (8000)" "Ray Runtime"
            workerNodes = container "Ray Worker Nodes" "Execute distributed tasks" "Ray Runtime"
        }

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys KubeRay operator via kustomize overlay" "Internal RHOAI"
        codeflareOperator = softwareSystem "CodeFlare Operator" "Creates RayCluster CRs for distributed training" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Manages workload queuing and admission" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator" "Coordinates distributed training jobs" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for Ray clusters" "External"

        // Relationships
        user -> kuberay "Creates RayCluster/RayJob/RayService CRs via kubectl" "HTTPS/443"
        rhodsOperator -> kuberay "Deploys operator via kustomize" "Kustomize overlay"
        codeflareOperator -> kuberay "Creates RayCluster CRs" "Kubernetes API"
        kueue -> kuberay "Manages workload admission" "Scheduling integration"
        trainingOperator -> kuberay "Coordinates Ray training" "Coordination"

        kuberay -> kubernetes "CRUD operations on Pods, Services, Routes, RBAC" "HTTPS/443 TLS 1.2+"
        kuberay -> ray "Job submission, Serve deployment, health checks" "HTTP/8265, TCP/6379"
        prometheus -> kuberay "Scrapes operator metrics" "HTTP/8080"
        kuberay -> volcano "Creates PodGroups for gang scheduling" "CRD"

        // Internal container relationships
        rayClusterController -> apiServer "Creates/manages Pods, Services, Routes" "HTTPS/443"
        rayClusterController -> headNode "Health checks via GCS" "TCP/6379"
        rayJobController -> headNode "Submits jobs via Dashboard API" "HTTP/8265"
        rayServiceController -> headNode "Deploys Serve apps via Dashboard API" "HTTP/8265"
        workerNodes -> headNode "Connects to cluster" "TCP/6379, TCP/10001"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
