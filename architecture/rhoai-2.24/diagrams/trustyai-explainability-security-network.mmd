%% TrustyAI Explainability - Security Network Diagram
%% Generated by: Claude Opus 4.6
graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>trustyai<br/>80/TCP<br/>TLS: None<br/>Auth: OAuth Proxy (sidecar)"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph NS_ModelServing["Namespace: {model-serving-namespace}"]
            TrustyAI["TrustyAI Service<br/>SA: trustyai-serviceaccount<br/>Ports: 8080/TCP (HTTP), 4443/TCP (HTTPS)<br/>Image: odh-trustyai-service"]
        end

        subgraph Inbound["INBOUND SOURCES"]
            ModelMesh["ModelMesh Serving<br/>Payload Processor"]
            KServeLogger["KServe InferenceLogger<br/>CloudEvents"]
            Prometheus["Prometheus<br/>ServiceMonitor"]
        end
    end

    subgraph StorageBackends["STORAGE BACKENDS"]
        PVC["PVC Storage<br/>Filesystem I/O<br/>/inputs<br/>No Auth"]
        MariaDB["MariaDB/MySQL<br/>3306/TCP<br/>MySQL/JDBC<br/>plaintext<br/>Username/Password"]
        MinIO["MinIO/S3<br/>Configurable Port<br/>HTTP/HTTPS<br/>Access Key/Secret Key"]
    end

    subgraph ModelInference["MODEL INFERENCE (Outbound)"]
        ModelServers["KServe/ModelMesh<br/>Model Servers<br/>gRPC/HTTP<br/>plaintext<br/>No Auth"]
    end

    subgraph Operator["OPERATOR"]
        TrustyAIOp["TrustyAI Service Operator<br/>Deploys & manages lifecycle<br/>Injects OAuth proxy sidecar"]
    end

    %% External flow
    Client -->|"HTTP/80<br/>plaintext<br/>No built-in Auth"| Route
    Route -->|"HTTP/8080<br/>plaintext<br/>internal"| TrustyAI

    %% Inbound flows
    ModelMesh -->|"HTTP/80<br/>plaintext<br/>POST /consumer/kserve/v2"| TrustyAI
    KServeLogger -->|"HTTP/8080<br/>plaintext<br/>CloudEvents"| TrustyAI
    Prometheus -->|"HTTP/80<br/>plaintext<br/>Bearer Token (SA)<br/>GET /q/metrics"| TrustyAI

    %% Storage flows
    TrustyAI -->|"Filesystem I/O<br/>No encryption"| PVC
    TrustyAI -->|"MySQL/3306<br/>plaintext<br/>Username/Password"| MariaDB
    TrustyAI -->|"S3 API<br/>Configurable<br/>Access Key/Secret"| MinIO

    %% Model inference outbound
    TrustyAI -->|"gRPC or HTTP<br/>plaintext<br/>No Auth"| ModelServers

    %% Operator management
    TrustyAIOp -.->|"manages lifecycle"| TrustyAI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef storage fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef modelinference fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef operator fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class Client external
    class Route ingress
    class TrustyAI,ModelMesh,KServeLogger,Prometheus internal
    class PVC,MariaDB,MinIO storage
    class ModelServers modelinference
    class TrustyAIOp operator
