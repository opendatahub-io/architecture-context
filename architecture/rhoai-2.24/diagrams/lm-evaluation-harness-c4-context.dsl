/*
 * LM Evaluation Harness - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Configures and triggers model evaluations via LMEvalJob CR"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Batch job container for evaluating language models against standardized benchmarks (146+ tasks)" {
            cli = container "lm-eval CLI" "Main entrypoint for running evaluations" "Python CLI"
            evaluator = container "Evaluator" "Core orchestration: loads model, runs tasks, aggregates results" "Python Module"
            modelRegistry = container "Model Registry" "Maps backend names (hf, vllm, local-completions) to model classes" "Python Registry"
            taskManager = container "Task Manager" "146+ built-in evaluation task definitions (YAML)" "Python Module"
            offlineMetrics = container "Offline Metrics" "53 bundled HuggingFace evaluate metrics for air-gapped use" "Directory"
            s3Downloader = container "S3 Downloader" "Downloads model artifacts from S3 to local cache" "Python Script"
        }

        trustyaiOperator = softwareSystem "TrustyAI LMEval Operator" "Creates and manages Kubernetes Jobs using lm-eval container image" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving platform (InferenceService)" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving with gRPC/HTTP" "Internal RHOAI"
        vllmServer = softwareSystem "vLLM Server" "High-performance LLM serving (OpenAI-compatible API)" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model weights, tokenizers, and datasets repository" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Object storage for model artifacts" "External"
        watsonx = softwareSystem "IBM watsonx.ai" "IBM cloud AI platform for model inference" "External"
        wandb = softwareSystem "Weights & Biases" "Experiment tracking and logging" "External"
        k8sApi = softwareSystem "Kubernetes API" "Cluster API server for job scheduling" "Platform"

        dataScientist -> trustyaiOperator "Creates LMEvalJob CR"
        trustyaiOperator -> k8sApi "Creates Job/Pod" "HTTPS/6443"
        trustyaiOperator -> lmEvalHarness "Launches as Kubernetes Job"
        lmEvalHarness -> huggingfaceHub "Downloads models, tokenizers, datasets" "HTTPS/443"
        lmEvalHarness -> s3Storage "Downloads model artifacts" "HTTPS/443"
        lmEvalHarness -> kserve "Sends inference requests for evaluation" "HTTP(S)/8080"
        lmEvalHarness -> modelMesh "Sends inference requests for evaluation" "gRPC/8033"
        lmEvalHarness -> vllmServer "Sends inference requests for evaluation" "HTTP/8000"
        lmEvalHarness -> watsonx "Remote model inference" "HTTPS/443"
        lmEvalHarness -> wandb "Optional experiment logging" "HTTPS/443"

        cli -> evaluator "Invokes simple_evaluate()"
        evaluator -> modelRegistry "Loads model backend"
        evaluator -> taskManager "Loads evaluation tasks"
        evaluator -> offlineMetrics "Computes metrics"
        s3Downloader -> s3Storage "Downloads artifacts" "HTTPS/443"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
