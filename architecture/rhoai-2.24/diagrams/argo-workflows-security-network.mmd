            WorkflowPod["Workflow Pod + argoexec<br/>UID: 2000 (non-root)<br/>FIPS: dual binary"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/MinIO<br/>443/TCP or 9000/TCP<br/>HTTPS/HTTP<br/>TLS (configurable)<br/>Access Key / IAM"]
        PostgreSQL["PostgreSQL (optional)<br/>5432/TCP<br/>TLS (configurable)<br/>Username/Password"]
        MySQL["MySQL (optional)<br/>3306/TCP<br/>TLS (configurable)<br/>Username/Password"]
        OIDC["OIDC Provider (optional)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Client credentials"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    %% Flows
    Client -->|"gRPC+REST/2746<br/>TLS<br/>Bearer Token / SSO JWT"| ArgoServer
    ArgoServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Impersonated SA Token"| K8sAPI
    ArgoServer -->|"TCP/5432<br/>TLS (configurable)<br/>Username/Password"| PostgreSQL
    ArgoServer -->|"TCP/3306<br/>TLS (configurable)<br/>Username/Password"| MySQL
    ArgoServer -->|"HTTPS/443<br/>TLS 1.2+<br/>Client credentials"| OIDC

    K8sAPI -->|"Watch CRDs<br/>HTTPS/443<br/>TLS 1.2+<br/>SA Token (argo)"| WFC
    WFC -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token (argo)<br/>Pod CRUD"| K8sAPI

    K8sAPI -.->|"Pod creation"| WorkflowPod
    WorkflowPod -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>Status + TaskResult"| K8sAPI
    WorkflowPod -->|"HTTPS/443 or HTTP/9000<br/>TLS (configurable)<br/>Access Key / IAM<br/>Artifact upload"| S3

    Prometheus -->|"HTTP/9090<br/>plaintext<br/>No auth"| WFC

