%% ModelMesh Serving - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller]
        SA_etcd[etcd-serviceaccount]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>cluster-scoped]
        CRB_etcd[etcd-clusterrolebinding<br/>cluster-scoped]
        CRB_Admin[model-serving-admin<br/>aggregated to admin]
        CRB_Edit[model-serving-edit<br/>aggregated to edit]
        CRB_View[model-serving-view<br/>aggregated to view]
    end

    subgraph "ClusterRoles"
        CR_Controller[modelmesh-controller-role]
        CR_Edit[model-serving-edit]
        CR_View[model-serving-view]
        CR_Prometheus[prometheus-ns-access]
        CR_etcd[etcd-role]
    end

    subgraph "API Resources - serving.kserve.io"
        InferenceService[InferenceService<br/>+ finalizers + status]
        Predictor[Predictor<br/>+ finalizers + status]
        ServingRuntime[ServingRuntime<br/>+ finalizers + status]
        ClusterServingRuntime[ClusterServingRuntime<br/>+ finalizers + status]
    end

    subgraph "API Resources - Core"
        ConfigMaps[ConfigMaps]
        Secrets[Secrets]
        Services[Services<br/>+ finalizers]
        Namespaces[Namespaces<br/>+ finalizers]
        Endpoints[Endpoints]
        PVCs[PersistentVolumeClaims]
    end

    subgraph "API Resources - Apps"
        Deployments[Deployments<br/>+ finalizers]
    end

    subgraph "API Resources - Autoscaling"
        HPA[HorizontalPodAutoscalers<br/>+ status]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com]
    end

    %% Controller bindings
    SA_Controller -->|bound via| CRB_Controller
    CRB_Controller -->|grants| CR_Controller

    %% Controller permissions
    CR_Controller -->|"get,list,watch,create,<br/>update,patch,delete"| InferenceService
    CR_Controller -->|"get,list,watch,create,<br/>update,patch,delete"| Predictor
    CR_Controller -->|"get,list,watch,create,<br/>update,patch,delete"| ServingRuntime
    CR_Controller -->|"get,list,watch,create,<br/>update,patch,delete"| ClusterServingRuntime
    CR_Controller -->|"create,delete,get,list,<br/>patch,update,watch"| ConfigMaps
    CR_Controller -->|"create,delete,get,list,<br/>patch,update,watch"| Secrets
    CR_Controller -->|"create,delete,get,list,<br/>patch,update,watch"| Services
    CR_Controller -->|"get,list,watch,<br/>update,patch"| Namespaces
    CR_Controller -->|"get,list,watch"| Endpoints
    CR_Controller -->|"get,list,watch"| PVCs
    CR_Controller -->|"create,delete,get,list,<br/>patch,update,watch"| Deployments
    CR_Controller -->|"get,list,watch,create,<br/>delete,update"| HPA
    CR_Controller -->|"create,delete,get,list,<br/>patch,update,watch"| ServiceMonitors

    %% Edit role
    CRB_Admin -->|aggregates| CR_Edit
    CRB_Edit -->|aggregates| CR_Edit
    CR_Edit -->|"create,delete,get,list,<br/>patch,update,watch"| InferenceService
    CR_Edit -->|"create,delete,get,list,<br/>patch,update,watch"| ServingRuntime

    %% View role
    CRB_View -->|aggregates| CR_View
    CR_View -->|"get,list,watch"| InferenceService
    CR_View -->|"get,list,watch"| ServingRuntime

    %% etcd bindings
    SA_etcd -->|bound via| CRB_etcd
    CRB_etcd -->|grants| CR_etcd
    CR_etcd -->|"create,delete,get,list,<br/>patch,update,watch"| Secrets

    %% Prometheus role
    CR_Prometheus -->|"get,list,watch"| Services
    CR_Prometheus -->|"get,list,watch"| Endpoints

