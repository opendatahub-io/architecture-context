// Llama Stack - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/llama-stack.md

workspace {
    model {
        user = person "AI Application Developer" "Builds AI applications using Llama Stack APIs"

        llamaStack = softwareSystem "Llama Stack" "Unified API server framework for building and deploying AI applications using Meta's Llama models" {
            fastapiServer = container "FastAPI Server" "Main API server serving all Llama Stack endpoints on port 8321" "Python FastAPI/Uvicorn"
            authMiddleware = container "Authentication Middleware" "Bearer token validation via OAuth2 JWT, Custom endpoint, or Kubernetes TokenReview" "ASGI Middleware"
            quotaMiddleware = container "Quota Middleware" "Per-client rate limiting (1000/day auth, 100/day anon)" "ASGI Middleware"
            tracingMiddleware = container "Tracing Middleware" "OpenTelemetry distributed tracing with W3C context" "ASGI Middleware"
            distributionResolver = container "Distribution Resolver" "Dynamically loads and wires provider implementations from YAML config" "Python Module"
            routingTables = container "Routing Tables" "Routes API requests to correct provider based on model/resource registration" "Python Module"
            abacEngine = container "Access Control Engine" "Attribute-based access control with Cedar-like policy rules" "Python Module"
            inlineProviders = container "Inline Providers" "In-process providers: meta-reference, FAISS, LlamaGuard, TorchTune" "Python Modules"
            cli = container "CLI (llama)" "Command-line interface for model download, stack build, stack run" "Python CLI"
        }

        // External inference backends
        vllm = softwareSystem "vLLM" "High-performance LLM inference server" "Inference Backend"
        ollama = softwareSystem "Ollama" "Local LLM inference server" "Inference Backend"
        tgi = softwareSystem "TGI" "Text Generation Inference server" "Inference Backend"
        openaiAPI = softwareSystem "OpenAI API" "OpenAI cloud inference service" "External Cloud"

        // Auth services
        oauth2Provider = softwareSystem "OAuth2 Provider" "Identity provider with JWKS/introspection endpoints" "Auth Service"

        // Observability
        otelCollector = softwareSystem "OpenTelemetry Collector" "Telemetry data collection and export" "Observability"

        // External services
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and dataset repository" "External Cloud"
        braveSearch = softwareSystem "Brave Search API" "Web search API for tool runtime" "External Cloud"
        tavilySearch = softwareSystem "Tavily Search API" "Web search API for tool runtime" "External Cloud"
        wolframAlpha = softwareSystem "Wolfram Alpha API" "Computation API for tool runtime" "External Cloud"

        // Data stores
        postgresql = softwareSystem "PostgreSQL/PGVector" "Relational database and vector store" "Data Store"
        redis = softwareSystem "Redis" "In-memory KV store" "Data Store"
        vectorDBs = softwareSystem "Vector Databases" "Chroma, Qdrant, Milvus, Weaviate" "Data Store"

        // Relationships - User
        user -> llamaStack "Creates inference requests, agents, manages models via REST API" "HTTP/HTTPS 8321/TCP"
        user -> cli "Builds and runs Llama Stack distributions" "CLI"

        // Relationships - Internal
        fastapiServer -> authMiddleware "Validates requests"
        authMiddleware -> quotaMiddleware "After auth"
        quotaMiddleware -> tracingMiddleware "After quota check"
        fastapiServer -> routingTables "Routes to providers"
        routingTables -> distributionResolver "Resolves provider config"
        fastapiServer -> abacEngine "Evaluates access policies"

        // Relationships - Inference backends
        llamaStack -> vllm "Inference requests" "HTTP/HTTPS 8000/TCP, API Token"
        llamaStack -> ollama "Inference requests" "HTTP 11434/TCP"
        llamaStack -> tgi "Inference requests" "HTTP/HTTPS"
        llamaStack -> openaiAPI "Inference requests" "HTTPS/443, API Key"

        // Relationships - Auth
        llamaStack -> oauth2Provider "JWT validation / token introspection" "HTTPS/443"

        // Relationships - Observability
        llamaStack -> otelCollector "Exports traces and metrics" "HTTP OTLP/4318"

        // Relationships - External services
        llamaStack -> huggingfaceHub "Downloads models and datasets" "HTTPS/443, Bearer Token"
        llamaStack -> braveSearch "Web search queries" "HTTPS/443, API Key"
        llamaStack -> tavilySearch "Web search queries" "HTTPS/443, API Key"
        llamaStack -> wolframAlpha "Computation queries" "HTTPS/443, API Key"

        // Relationships - Data stores
        llamaStack -> postgresql "Metadata and vector storage" "TCP/5432, Optional TLS"
        llamaStack -> redis "KV storage" "TCP/6379, Optional TLS"
        llamaStack -> vectorDBs "Vector similarity search" "HTTP/gRPC, Configurable"
    }

    views {
        systemContext llamaStack "SystemContext" {
            include *
            autoLayout
        }

        container llamaStack "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "Inference Backend" {
                background #27ae60
                color #ffffff
            }
            element "External Cloud" {
                background #f39c12
                color #ffffff
            }
            element "Auth Service" {
                background #9b59b6
                color #ffffff
            }
            element "Observability" {
                background #95a5a6
                color #ffffff
            }
            element "Data Store" {
                background #e74c3c
                color #ffffff
            }
            element "Person" {
                background #2c3e50
                color #ffffff
                shape Person
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
