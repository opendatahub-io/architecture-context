%% KubeRay Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "KubeRay Operator"
        direction TB
        RayClusterCtrl["RayCluster Controller"]
        RayJobCtrl["RayJob Controller"]
        RayServiceCtrl["RayService Controller"]
        Webhook["ValidatingWebhook<br/>9443/TCP HTTPS"]
        Metrics["Metrics Server<br/>8080/TCP HTTP"]
        Health["Health Probes<br/>8081/TCP HTTP"]
    end

    User["User / CodeFlare Operator"] -->|creates| RayClusterCR["RayCluster CR<br/>(ray.io/v1)"]
    User -->|creates| RayJobCR["RayJob CR<br/>(ray.io/v1)"]
    User -->|creates| RayServiceCR["RayService CR<br/>(ray.io/v1)"]

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| HeadPod["Ray Head Pod"]
    RayClusterCtrl -->|creates| WorkerPods["Ray Worker Pods"]
    RayClusterCtrl -->|creates| HeadSvc["Head Service<br/>10001,6379,8265,8080,8000"]
    RayClusterCtrl -->|creates| HeadlessSvc["Headless Worker Service"]
    RayClusterCtrl -->|creates| ServeSvc["Serve Service<br/>8000/TCP"]
    RayClusterCtrl -->|creates| Route["OpenShift Route<br/>8265/TCP"]
    RayClusterCtrl -->|creates| AutoscalerRBAC["Autoscaler SA/Role/RoleBinding"]

    RayJobCtrl -->|manages| RayClusterCR
    RayJobCtrl -->|creates| SubmitterJob["K8s Batch Job<br/>(submitter)"]
    RayJobCtrl -->|submits via| Dashboard["Ray Dashboard<br/>8265/TCP"]

    RayServiceCtrl -->|manages| RayClusterCR
    RayServiceCtrl -->|deploys via| Dashboard

    RayClusterCR -.->|validates| Webhook

    WorkerPods -->|connects to| HeadPod

    RayClusterCtrl -->|API calls| K8sAPI["Kubernetes API Server"]
    RayJobCtrl -->|API calls| K8sAPI
    RayServiceCtrl -->|API calls| K8sAPI

    Prometheus["Prometheus"] -->|scrapes| Metrics

    %% Optional integrations
    RayClusterCtrl -.->|gang scheduling| Volcano["Volcano Scheduler"]
    RayClusterCtrl -.->|task groups| Yunikorn["Yunikorn Scheduler"]

