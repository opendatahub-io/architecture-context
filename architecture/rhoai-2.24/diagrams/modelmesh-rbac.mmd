graph TD
    subgraph "Authentication Model"
        subgraph "External Client Auth"
            ClientCert["Client Certificate<br/>(mTLS)"]
            ClientAuth["MM_TLS_CLIENT_AUTH<br/>NONE | REQUIRE | OPTIONAL"]
        end

        subgraph "TLS Configuration"
            ServerCert["Server Certificate<br/>MM_TLS_KEY_CERT_PATH"]
            ServerKey["Server Private Key<br/>MM_TLS_PRIVATE_KEY_PATH"]
            TrustStore["Trust Certificates<br/>MM_TLS_TRUST_CERT_PATH"]
            InternalTrust["Internal Trust Certs<br/>MM_INTERNAL_TRUST_CERTS<br/>(for cert rotation)"]
        end
    end

    subgraph "Endpoint Authorization"
        GrpcEndpoint["gRPC API<br/>Port 8033/TCP"]
        InterPodEndpoint["Inter-Pod Comm<br/>Port 8080/TCP"]
        SidecarEndpoint["Sidecar Runtime<br/>Port 8085/TCP or UDS"]
        MetricsEndpoint["Prometheus Metrics<br/>Port 2112/TCP"]
        HealthEndpoint["Health Probes<br/>Port 8089/TCP"]
        PreStopEndpoint["PreStop Hook<br/>Port 8090/TCP"]
    end

    subgraph "Auth Mechanism per Endpoint"
        mTLS_Auth["mTLS<br/>(Client cert validated<br/>against trust store)"]
        TLS_Cert_Auth["TLS + Shared Certs<br/>(Certificate-based<br/>peer trust)"]
        NoAuth_Local["No Auth<br/>(localhost/UDS only)"]
        SelfSigned_TLS["Self-signed TLS<br/>(BouncyCastle generated)"]
        NoAuth_Plain["No Auth<br/>(plaintext HTTP)"]
    end

    subgraph "Secrets"
        TLSSecret["model-mesh-tls-secret<br/>Type: kubernetes.io/tls<br/>Provisioned: cert-manager / manual<br/>Rotation: Manual"]
        EtcdSecret["model-mesh-icd-etcd<br/>Type: Opaque<br/>Provisioned: Administrator<br/>Contains: etcd connection config"]
    end

    %% Relationships
    ClientCert -->|"validated by"| ClientAuth
    ClientAuth -->|"configures"| GrpcEndpoint

    ServerCert -->|"used by"| GrpcEndpoint
    ServerCert -->|"used by"| InterPodEndpoint
    ServerKey -->|"used by"| GrpcEndpoint
    TrustStore -->|"verifies"| ClientCert
    InternalTrust -->|"supports rotation"| InterPodEndpoint

    GrpcEndpoint -->|"protected by"| mTLS_Auth
    InterPodEndpoint -->|"protected by"| TLS_Cert_Auth
    SidecarEndpoint -->|"protected by"| NoAuth_Local
    MetricsEndpoint -->|"protected by"| SelfSigned_TLS
    HealthEndpoint -->|"protected by"| NoAuth_Plain
    PreStopEndpoint -->|"protected by"| NoAuth_Plain

    TLSSecret -->|"provides certs"| ServerCert
    TLSSecret -->|"provides key"| ServerKey

