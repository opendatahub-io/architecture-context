        end
    end

    %% Internal connections
    ExplainerEndpoints -->|uses| LIME
    ExplainerEndpoints -->|uses| SHAP
    ExplainerEndpoints -->|uses| CF
    MetricsEndpoints -->|uses| FairnessMetrics
    MetricsEndpoints -->|uses| DriftMetrics
    ExplainerEndpoints -->|model inference| KServeV2HTTP
    ExplainerEndpoints -->|model inference| KServeV2GRPC
    ConsumerEP -->|reconciles| PayloadReconciler
    CloudEventConsumer -->|reconciles| PayloadReconciler
    PrometheusScheduler -->|publishes| PromPublisher

    %% External integrations
    ModelMesh["ModelMesh Serving"] -->|POST /consumer/kserve/v2<br/>HTTP 80/TCP| ConsumerEP
    KServeLogger["KServe InferenceLogger"] -->|CloudEvents<br/>HTTP 8080/TCP| CloudEventConsumer
    Prometheus["Prometheus<br/>ServiceMonitor"] -->|GET /q/metrics<br/>HTTP 80/TCP| PromPublisher

    %% Outbound
    KServeV2GRPC -->|gRPC inference| ModelServers["KServe/ModelMesh<br/>Model Servers"]
    KServeV2HTTP -->|HTTP inference| ModelServers

    %% Storage backends
    PayloadReconciler -->|store| PVC["PVC Storage<br/>(default)"]
    PayloadReconciler -->|store| MariaDB["MariaDB/MySQL<br/>3306/TCP"]
    PayloadReconciler -->|store| MinIO["MinIO/S3<br/>Object Storage"]

    %% Operator
    Operator["TrustyAI Service Operator"] -.->|deploys & manages| ServiceMetadata

