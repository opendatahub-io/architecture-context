// C4 Context Diagram for caikit-nlp
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/caikit-nlp.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Deploys and queries NLP models for inference"
        application = person "Application" "Sends inference requests to deployed models"

        caikitNlp = softwareSystem "caikit-nlp" "Python NLP library providing text generation, embedding, reranking, and classification via Caikit runtime" {
            httpServer = container "HTTP Server" "REST API for NLP tasks (text-generation, embedding, rerank, etc.)" "Python / Caikit Runtime" "Port 8080/TCP"
            grpcServer = container "gRPC Server" "gRPC API for NLP tasks with streaming support" "Python / Caikit Runtime" "Port 8085/TCP"
            textGenModules = container "Text Generation Modules" "PeftPromptTuning, TextGeneration, TGIS-backed variants" "Python / Caikit Module"
            embeddingModules = container "Embedding & Reranking Modules" "EmbeddingModule, CrossEncoderModule via sentence-transformers" "Python / Caikit Module"
            classificationModules = container "Classification Modules" "SequenceClassification, FilteredSpanClassification (WIP)" "Python / Caikit Module"
            tgisClient = container "TGIS Generation Client" "gRPC client for remote LLM inference" "Python / gRPC"
            modelResources = container "Model Resources" "HFAutoCausalLM, HFAutoSeq2SeqLM model loaders" "Python / HuggingFace"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - remote LLM inference backend" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Model serving infrastructure hosting caikit-nlp containers" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Alternative model serving infrastructure" "Internal RHOAI"
        huggingFaceHub = softwareSystem "HuggingFace Hub" "Model repository for downloading pretrained models" "External"

        // External dependencies (libraries)
        caikitFramework = softwareSystem "Caikit Framework" "Core AI framework providing runtime, module system, data model" "External Library"
        pytorch = softwareSystem "PyTorch" "Deep learning framework for model inference and training" "External Library"

        // Relationships
        application -> caikitNlp "Sends inference requests" "HTTP/8080, gRPC/8085"
        dataScientist -> modelMesh "Deploys models via"
        dataScientist -> kserve "Deploys models via"

        modelMesh -> caikitNlp "Hosts as inference runtime" "gRPC/8085"
        kserve -> caikitNlp "Hosts as inference runtime" "HTTP/8080, gRPC/8085"

        caikitNlp -> tgis "Remote text generation inference" "gRPC/8033-8034, Optional TLS/mTLS"
        caikitNlp -> huggingFaceHub "Downloads model artifacts" "HTTPS/443, TLS 1.2+"

        // Container relationships
        httpServer -> textGenModules "Routes text-generation requests"
        httpServer -> embeddingModules "Routes embedding/rerank requests"
        httpServer -> classificationModules "Routes classification requests"
        grpcServer -> textGenModules "Routes gRPC text-generation"
        grpcServer -> embeddingModules "Routes gRPC embedding/rerank"
        textGenModules -> tgisClient "Delegates to TGIS for remote inference"
        textGenModules -> modelResources "Loads local HuggingFace models"
        tgisClient -> tgis "gRPC inference calls" "gRPC/8033-8034"
        modelResources -> huggingFaceHub "Downloads models" "HTTPS/443"
    }

    views {
        systemContext caikitNlp "SystemContext" {
            include *
            autoLayout
        }

        container caikitNlp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Library" {
                background #bbbbbb
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
