/*
 * Kueue C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-2.24/kueue.md
 */

workspace {
    model {
        user = person "Data Scientist" "Submits ML training jobs and batch workloads"
        admin = person "Platform Admin" "Configures quotas, queues, and resource flavors"

        kueue = softwareSystem "Kueue" "Kubernetes-native job queueing system managing workload admission based on quotas, priorities, and fair sharing" {
            controllerManager = container "Kueue Controller Manager" "Main controller managing CRDs, scheduling workloads, enforcing quotas" "Go Operator (controller-runtime)"
            scheduler = container "Scheduler" "Core scheduling loop: assigns resource flavors, admits workloads, handles preemption" "Go Component"
            webhookServer = container "Webhook Server" "37 mutating/validating webhook handlers for jobs and Kueue CRDs" "Admission Webhook (9443/TCP TLS)"
            metricsServer = container "Metrics Server" "Prometheus metrics endpoint with Bearer Token auth" "HTTPS (8443/TCP TLS)"
            internalCertMgr = container "Internal Cert Manager" "Self-managed TLS certificate rotation for webhook and metrics" "Go Component"
            jobIntegrations = container "Job Framework Integrations" "Controllers for batch/Job, Kubeflow, Ray, JobSet, AppWrapper" "Go Controllers"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Core Kubernetes control plane" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting with PrometheusRule" "External"
        kubeflowTraining = softwareSystem "Kubeflow Training Operator" "Manages distributed training jobs (PyTorch, TF, MPI, Paddle, XGBoost)" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay Operator" "Manages Ray jobs and Ray clusters" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare Operator" "Manages AppWrapper workloads" "Internal RHOAI"
        jobset = softwareSystem "JobSet Controller" "Manages JobSet workloads" "External"
        clusterAutoscaler = softwareSystem "Cluster Autoscaler" "Provisions cluster capacity via ProvisioningRequests" "External"
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys and manages Kueue via kustomize overlay" "Internal RHOAI"

        /* Relationships */
        user -> k8sAPI "Submits jobs via kubectl" "HTTPS/443"
        admin -> k8sAPI "Configures ClusterQueues, ResourceFlavors" "HTTPS/443"

        k8sAPI -> kueue "Webhook calls for job admission" "HTTPS/9443 mTLS"
        kueue -> k8sAPI "CRD CRUD, job management, leader election" "HTTPS/443 TLS 1.2+"

        prometheus -> kueue "Scrapes metrics" "HTTPS/8443 TLS + Bearer Token"

        kueue -> kubeflowTraining "Watches/patches training jobs" "via K8s API"
        kueue -> kuberay "Watches/patches Ray jobs/clusters" "via K8s API"
        kueue -> codeflare "Watches/patches AppWrappers" "via K8s API"
        kueue -> jobset "Watches/patches JobSets" "via K8s API"
        kueue -> clusterAutoscaler "Creates ProvisioningRequests" "via K8s API"

        rhodsOperator -> kueue "Deploys via kustomize" "Kustomize overlay"

        /* Internal container relationships */
        controllerManager -> scheduler "Enqueues workloads"
        controllerManager -> webhookServer "Serves webhooks"
        controllerManager -> metricsServer "Serves metrics"
        internalCertMgr -> webhookServer "Rotates TLS certs"
        internalCertMgr -> metricsServer "Rotates TLS certs"
        jobIntegrations -> controllerManager "Creates Workload CRs"
    }

    views {
        systemContext kueue "SystemContext" {
            include *
            autoLayout
        }

        container kueue "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
