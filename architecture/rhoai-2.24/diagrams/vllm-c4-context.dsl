// vLLM C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/vllm.md

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Deploys and queries LLM models for inference"
        client = person "API Client" "Sends inference requests to deployed models"

        vllm = softwareSystem "vLLM" "High-throughput LLM inference engine with PagedAttention, continuous batching, and multi-GPU support" {
            apiServer = container "OpenAI API Server" "OpenAI-compatible HTTP REST API (chat completions, embeddings, scoring, reranking)" "Python FastAPI, 8000/TCP"
            authMiddleware = container "Authentication Middleware" "Bearer token validation for /v1/* endpoints" "Python ASGI Middleware"
            sslRefresher = container "SSL Certificate Refresher" "Hot-reloads TLS certificates on file change" "Python Module"
            asyncEngine = container "Async LLM Engine" "Asynchronous engine wrapper with ZMQ IPC multiprocessing" "Python, ZMQ"
            engineCore = container "vLLM Engine V1" "Core inference engine: continuous batching, PagedAttention KV cache, scheduling" "Python"
            executor = container "Executor" "Manages single or distributed GPU workers (Uniproc/Multiprocessing/Ray)" "Python"
            workers = container "GPU Workers" "Model execution on GPU/CPU devices with CUDA/HIP/NCCL" "Python, C++/CUDA"
            cudaKernels = container "CUDA/HIP Kernels" "Optimized attention (FlashAttention/FlashInfer), quantization, MoE kernels" "C++/CUDA"
            modelExecutor = container "Model Executor" "Model loading, weight management, forward pass execution" "Python"
            tgisAdapter = container "vllm-tgis-adapter" "TGIS-compatible gRPC interface for ModelMesh/KServe integration" "Python gRPC, 8033/TCP"
            metrics = container "Prometheus Metrics" "Inference metrics: latency, throughput, cache utilization" "Python, /metrics endpoint"
        }

        kserve = softwareSystem "KServe" "Model serving orchestration - creates InferenceService routes" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving with TGIS protocol" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Model artifact discovery and metadata" "Internal RHOAI"
        serviceMesh = softwareSystem "OpenShift Service Mesh" "Service mesh for mTLS and network policies" "External"
        s3 = softwareSystem "S3-Compatible Object Storage" "Model weight storage and retrieval" "External"
        hfHub = softwareSystem "HuggingFace Hub" "Model and tokenizer downloads (disabled in production)" "External"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection and alerting" "External"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collection" "External"
        pytorch = softwareSystem "PyTorch 2.7.1" "Deep learning framework for model execution" "External"

        // User interactions
        user -> kserve "Deploys InferenceService with vLLM runtime"
        client -> vllm "Sends inference requests" "HTTP/HTTPS 8000/TCP, Bearer Token"

        // vLLM internal relationships
        apiServer -> authMiddleware "Validates requests"
        authMiddleware -> asyncEngine "Forwards authenticated requests"
        asyncEngine -> engineCore "ZMQ IPC"
        engineCore -> executor "Dispatches to workers"
        executor -> workers "Manages GPU/CPU workers"
        workers -> cudaKernels "Invokes optimized GPU kernels"
        workers -> modelExecutor "Loads and executes models"
        tgisAdapter -> engineCore "In-process Python calls"
        apiServer -> metrics "Exposes metrics"

        // External interactions
        kserve -> vllm "Routes inference traffic" "HTTP/HTTPS 8000/TCP"
        modelMesh -> vllm "Routes inference via TGIS protocol" "gRPC 8033/TCP"
        vllm -> s3 "Downloads model weights" "HTTPS/443, S3 credentials"
        vllm -> hfHub "Downloads models/tokenizers (disabled in prod)" "HTTPS/443, HF Token"
        vllm -> otelCollector "Exports traces" "gRPC/4317 or HTTP/4318"
        prometheus -> vllm "Scrapes metrics" "HTTP 8000/TCP /metrics"
        serviceMesh -> vllm "Provides mTLS and network policies"
        vllm -> modelRegistry "Discovers model metadata" "API"
        workers -> pytorch "Uses for model execution"
    }

    views {
        systemContext vllm "SystemContext" {
            include *
            autoLayout
        }

        container vllm "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
