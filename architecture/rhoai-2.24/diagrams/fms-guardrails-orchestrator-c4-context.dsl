// FMS Guardrails Orchestrator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        client = person "Client Application" "Sends text generation and detection requests to the orchestrator"

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "REST API orchestration server that coordinates AI text generation with content safety guardrail detectors, chunkers, and LLM backends" {
            guardrailsServer = container "Guardrails Server" "Handles API requests for guardrailed text generation and detection" "Rust / Axum HTTP / Port 8033"
            healthServer = container "Health Server" "Serves health and info endpoints" "Rust / Axum HTTP / Port 8034"
            orchestratorCore = container "Orchestrator Core" "Coordinates task execution across generation, detection, and chunker clients" "Rust Module"
            tlsModule = container "TLS Module" "Configures TLS and mTLS using rustls" "Rust / rustls"
            tgisClient = container "TGIS Client" "gRPC client for TGIS text generation" "Rust / tonic"
            nlpClient = container "NLP Client" "gRPC client for Caikit NLP text generation" "Rust / tonic"
            openaiClient = container "OpenAI Client" "HTTP client for OpenAI-compatible backends" "Rust / reqwest"
            detectorClient = container "Detector Client" "HTTP client for content safety detector services" "Rust / reqwest"
            chunkerClient = container "Chunker Client" "gRPC client for Caikit chunker services" "Rust / tonic"
        }

        tgis = softwareSystem "TGIS" "Text Generation Inference Server - gRPC text generation backend" "Internal RHOAI"
        caikitNlp = softwareSystem "Caikit NLP" "Caikit NLP text generation server" "Internal RHOAI"
        vllm = softwareSystem "vLLM / OpenAI-compatible" "Chat completions and text completions backend" "Internal RHOAI"
        detectors = softwareSystem "Content Safety Detectors" "Content analysis detector services (HAP, toxicity, etc.)" "Internal RHOAI"
        chunkers = softwareSystem "Caikit Chunkers" "Text segmentation/chunking services" "Internal RHOAI"
        otelCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing and metrics collection" "External"

        // System context relationships
        client -> orchestrator "Sends generation/detection requests" "HTTP/HTTPS on 8033/TCP"
        orchestrator -> tgis "Text generation requests" "gRPC (HTTP/2), TLS/mTLS"
        orchestrator -> caikitNlp "Text generation requests" "gRPC (HTTP/2), TLS/mTLS"
        orchestrator -> vllm "Chat/text completions" "HTTP/HTTPS on 8080/TCP"
        orchestrator -> detectors "Content safety detection" "HTTP/HTTPS on 8080/TCP"
        orchestrator -> chunkers "Text segmentation" "gRPC (HTTP/2), TLS/mTLS"
        orchestrator -> otelCollector "Traces and metrics" "OTLP gRPC/4317 or HTTP/4318"

        // Container relationships
        client -> guardrailsServer "POST /api/v1/*, /api/v2/*" "HTTP/HTTPS, TLS/mTLS optional"
        client -> healthServer "GET /health, /info" "HTTP plaintext"
        guardrailsServer -> orchestratorCore "Routes requests"
        guardrailsServer -> tlsModule "TLS/mTLS config"
        orchestratorCore -> tgisClient "Generation tasks"
        orchestratorCore -> nlpClient "Generation tasks"
        orchestratorCore -> openaiClient "Completion tasks"
        orchestratorCore -> detectorClient "Detection tasks"
        orchestratorCore -> chunkerClient "Chunking tasks"
        tgisClient -> tgis "gRPC GenerationService" "gRPC, TLS/mTLS"
        nlpClient -> caikitNlp "gRPC NlpService" "gRPC, TLS/mTLS"
        openaiClient -> vllm "/v1/chat/completions, /v1/completions" "HTTP/HTTPS"
        detectorClient -> detectors "/api/v1/text/*" "HTTP/HTTPS, TLS/mTLS"
        chunkerClient -> chunkers "gRPC ChunkersService" "gRPC, TLS/mTLS"
    }

    views {
        systemContext orchestrator "SystemContext" {
            include *
            autoLayout
        }

        container orchestrator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
