    end

    subgraph ControllerPerms["Controller Permissions"]
        NotebookCR["notebooks.kubeflow.org<br/>get, list, watch,<br/>create, update, patch, delete"]
        Pods["core/pods<br/>get, list, watch,<br/>create, delete"]
        Services["core/services<br/>get, list, watch,<br/>create, update, delete"]
        Routes["route.openshift.io/routes<br/>get, list, watch,<br/>create, update, delete"]
    end

    subgraph Secrets["Secrets"]
        RHELSub["rhel-subscription-secret<br/>(Opaque)<br/>RHEL subscription creds<br/>Manual provisioning<br/>No auto-rotation"]
    end

    %% User auth flow
    User -->|"HTTPS/443<br/>OpenShift OAuth"| KubeRBAC
    User -->|"HTTPS/443<br/>OpenShift OAuth"| OAuthProxy
    KubeRBAC -->|"validates"| TokenReview
    KubeRBAC -->|"authorizes"| SAR
    OAuthProxy -->|"validates"| TokenReview
    SAR -->|"must have namespace access"| WorkbenchPod
    KubeRBAC -->|"proxies to"| JupyterLab
    KubeRBAC -->|"proxies to"| CodeServer
    KubeRBAC -->|"proxies to"| RStudioSrv

    %% Controller RBAC
    CtrlSA -->|"bound via"| CtrlBinding
    CtrlBinding -->|"grants"| CtrlRole
    CtrlRole -->|"manages"| NotebookCR
    CtrlRole -->|"manages"| Pods
    CtrlRole -->|"manages"| Services
    CtrlRole -->|"manages"| Routes

    %% Secrets used by BuildConfig
    RHELSub -.->|"used by RStudio<br/>BuildConfig builds"| RStudioSrv

