// vllm-gaudi C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        datascientist = person "Data Scientist" "Deploys and queries LLM models for inference"
        sre = person "SRE / Platform Admin" "Monitors and manages the inference platform"

        // Primary System
        vllmGaudi = softwareSystem "vllm-gaudi" "High-throughput LLM inference engine optimized for Intel Gaudi HPU accelerators" {
            openaiServer = container "OpenAI API Server" "FastAPI/uvicorn HTTP server providing OpenAI-compatible REST API" "Python FastAPI" "Primary"
            grpcAdapter = container "gRPC TGIS Adapter" "gRPC server providing TGIS protocol compatibility for ModelMesh/KServe" "Python gRPC"
            asyncEngine = container "AsyncLLMEngine" "Asynchronous engine for request scheduling, batching, and inference orchestration" "Python"
            hpuWorker = container "HPU Worker" "Executes model inference on Intel Gaudi accelerators with PagedAttention" "Python/C++"
            rayExecutor = container "Ray Distributed Executor" "Distributes inference across multiple Gaudi devices" "Python/Ray"
            sslRefresher = container "SSL Certificate Refresher" "Monitors and hot-reloads TLS certificates" "Python"
            prometheusMetrics = container "Prometheus Metrics" "Exposes inference metrics via /metrics endpoint" "Python"
        }

        // Internal RHOAI Dependencies
        kserve = softwareSystem "KServe" "Manages InferenceService lifecycle and serving runtime" "Internal RHOAI"
        modelMesh = softwareSystem "ModelMesh" "Multi-model serving infrastructure with TGIS protocol" "Internal RHOAI"
        odhModelController = softwareSystem "odh-model-controller" "Manages InferenceService lifecycle, routes, and networking" "Internal RHOAI"

        // External Dependencies
        gaudiHW = softwareSystem "Intel Gaudi Accelerator" "AI accelerator hardware (Gaudi 2/3) with Habana software suite" "External Hardware"
        rayCluster = softwareSystem "Ray Cluster" "Distributed computing framework for multi-device parallelism" "External"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model weight and tokenizer repository (offline in production)" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"
        otlpCollector = softwareSystem "OpenTelemetry Collector" "Distributed tracing collector (optional)" "External"

        // Relationships - Users
        datascientist -> kserve "Creates InferenceService CR"
        datascientist -> vllmGaudi "Sends inference requests via KServe route" "HTTPS/443"
        sre -> prometheus "Monitors inference metrics"

        // Relationships - Internal
        kserve -> vllmGaudi "Routes inference requests to serving runtime" "HTTP(S)/8000"
        modelMesh -> vllmGaudi "Routes gRPC inference requests" "gRPC/8033"
        odhModelController -> kserve "Manages InferenceService lifecycle"

        // Relationships - Container level
        openaiServer -> asyncEngine "Submits requests" "ZMQ IPC"
        grpcAdapter -> asyncEngine "Submits requests" "In-process"
        asyncEngine -> hpuWorker "Schedules inference" "Python/HCCL"
        hpuWorker -> rayExecutor "Distributes across devices" "Ray"
        openaiServer -> prometheusMetrics "Exposes metrics"
        openaiServer -> sslRefresher "TLS cert management"

        // Relationships - External
        vllmGaudi -> gaudiHW "Executes model inference" "HPU Runtime / Device Memory"
        vllmGaudi -> rayCluster "Distributed inference coordination" "TCP/6379"
        vllmGaudi -> huggingfaceHub "Downloads models (disabled in prod)" "HTTPS/443"
        prometheus -> vllmGaudi "Scrapes metrics" "HTTP(S)/8000"
        vllmGaudi -> otlpCollector "Exports traces" "gRPC/4317"
    }

    views {
        systemContext vllmGaudi "SystemContext" {
            include *
            autoLayout
            description "System context showing vllm-gaudi in the RHOAI ecosystem"
        }

        container vllmGaudi "Containers" {
            include *
            autoLayout
            description "Internal container architecture of vllm-gaudi"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Hardware" {
                background #666666
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Primary" {
                background #1168bd
                color #ffffff
            }
        }
    }
}
