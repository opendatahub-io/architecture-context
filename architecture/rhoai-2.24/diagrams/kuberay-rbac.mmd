%% KubeRay Operator - RBAC Visualization
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA["kuberay-operator<br/>(opendatahub namespace)"]
        DynSA["Dynamic Per-Cluster SA<br/>(user namespace)"]
    end

    subgraph "Cluster Role Bindings"
        CRB["kuberay-operator<br/>(ClusterRoleBinding)"]
        LERB["kuberay-operator-leader-election<br/>(RoleBinding, operator namespace)"]
    end

    subgraph "Cluster Roles"
        CR["kuberay-operator<br/>(ClusterRole)"]
        EditRole["kuberay-edit-role<br/>(ClusterRole)"]
        ViewRole["kuberay-view-role<br/>(ClusterRole)"]
        LERole["kuberay-operator-leader-election<br/>(Role)"]
    end

    subgraph "Dynamic RBAC (per RayCluster)"
        DynRole["Autoscaler Role<br/>(user namespace)"]
        DynRB["Autoscaler RoleBinding<br/>(user namespace)"]
    end

    subgraph "Core API Resources"
        Pods["core<br/>pods, pods/status, pods/proxy"]
        Services["core<br/>services, services/status, services/proxy"]
        Endpoints["core<br/>endpoints"]
        Events["core<br/>events"]
        ServiceAccounts["core<br/>serviceaccounts"]
    end

    subgraph "Ray CRD Resources"
        RayClusters["ray.io<br/>rayclusters (+status,finalizers)"]
        RayJobs["ray.io<br/>rayjobs (+status,finalizers)"]
        RayServices["ray.io<br/>rayservices (+status,finalizers)"]
    end

    subgraph "Other API Resources"
        Jobs["batch<br/>jobs"]
        Leases["coordination.k8s.io<br/>leases"]
        Ingresses["networking.k8s.io<br/>ingresses, ingressclasses"]
        Routes["route.openshift.io<br/>routes"]
        Roles["rbac.authorization.k8s.io<br/>roles, rolebindings"]
    end

    subgraph "Autoscaler Resources"
        AutoPods["core<br/>pods (get,list,watch)"]
        AutoRC["ray.io<br/>rayclusters (get,patch)"]
    end

    %% Bindings
    SA -->|bound via| CRB
    SA -->|bound via| LERB
    CRB -->|grants| CR
    LERB -->|grants| LERole

    DynSA -->|bound via| DynRB
    DynRB -->|grants| DynRole

    %% ClusterRole permissions
    CR -->|"get,list,watch,create,update,<br/>patch,delete,deletecollection"| Pods
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Services
    CR -->|"get,list,watch"| Endpoints
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Events
    CR -->|"create,delete,get,list,watch"| ServiceAccounts
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RayClusters
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RayJobs
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| RayServices
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Jobs
    CR -->|"create,get,list,update"| Leases
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Ingresses
    CR -->|"create,delete,get,list,<br/>patch,update,watch"| Routes
    CR -->|"create,delete,get,list,<br/>update,watch"| Roles

    %% Edit/View roles
    EditRole -->|"full CRUD"| RayClusters
    EditRole -->|"full CRUD"| RayJobs
    EditRole -->|"full CRUD"| RayServices
    ViewRole -->|"get,list,watch"| RayClusters
    ViewRole -->|"get,list,watch"| RayJobs
    ViewRole -->|"get,list,watch"| RayServices

    %% Dynamic RBAC
    DynRole -->|"get,list,watch"| AutoPods
    DynRole -->|"get,patch"| AutoRC

