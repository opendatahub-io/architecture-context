// TrustyAI Service Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates TrustyAIService, LMEvalJob, and GuardrailsOrchestrator CRs"

        trustyaiOperator = softwareSystem "TrustyAI Service Operator" "Multi-controller Go operator managing TrustyAI explainability, LM evaluation, and guardrails orchestration" {
            controllerManager = container "Controller Manager" "Main entry point; initializes controller-runtime, registers schemes, starts probes" "Go Binary"
            tasController = container "TrustyAIService Controller (TAS)" "Reconciles TrustyAIService CRs; creates Deployments, Services, Routes, PVCs, ServiceMonitors, Istio resources" "Go Controller"
            lmesController = container "LMEvalJob Controller (LMES)" "Reconciles LMEvalJob CRs; creates evaluation Pods with driver sidecar, manages job lifecycle" "Go Controller"
            gorchController = container "GuardrailsOrchestrator Controller (GORCH)" "Reconciles GuardrailsOrchestrator CRs; creates Deployments with detector and gateway sidecars" "Go Controller"
            jobManager = container "Job Manager" "Kueue integration; implements jobframework.GenericJob for workload scheduling" "Go Controller"
        }

        // External Dependencies
        kserve = softwareSystem "KServe" "InferenceService CRD for model serving integration" "External"
        modelMesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / OpenShift Monitoring" "Metrics collection via ServiceMonitor CRDs" "External"
        kueue = softwareSystem "Kueue" "Job queue management for LMEvalJob workloads" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for traffic management (DestinationRules, VirtualServices)" "External"
        certSigner = softwareSystem "OpenShift Serving Cert Signer" "Auto-provisions TLS certificates for services" "External"
        oauthProxy = softwareSystem "OpenShift OAuth Proxy" "Authentication sidecar for TrustyAI service endpoints" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys TrustyAI operator via kustomize overlays" "Internal RHOAI"

        // External Services
        database = softwareSystem "Database (PostgreSQL/MySQL)" "Persistent storage for TrustyAI data in DATABASE mode" "External Service"
        k8sApi = softwareSystem "Kubernetes API" "Controller reconciliation, CR watches, resource CRUD" "External"

        // Relationships - User
        user -> trustyaiOperator "Creates TrustyAIService, LMEvalJob, GuardrailsOrchestrator CRs via kubectl"

        // Relationships - Internal
        controllerManager -> tasController "Starts"
        controllerManager -> lmesController "Starts"
        controllerManager -> gorchController "Starts"
        controllerManager -> jobManager "Starts"

        // Relationships - Deployment
        rhodsOperator -> trustyaiOperator "Deploys via kustomize overlay (config/overlays/rhoai/)"

        // Relationships - External Dependencies
        tasController -> kserve "Patches InferenceService CRs with Logger URL"
        tasController -> modelMesh "Patches MM_PAYLOAD_PROCESSORS env var on Deployments"
        tasController -> prometheus "Creates ServiceMonitors for trustyai_spd/trustyai_dir metrics"
        tasController -> istio "Creates DestinationRules and VirtualServices (conditional)" "HTTPS/443"
        tasController -> certSigner "Requests TLS certificates via service annotations"
        tasController -> oauthProxy "Deploys as sidecar container" "HTTPS/8443"
        lmesController -> kueue "Creates Workload CRs for job scheduling"
        jobManager -> kueue "Implements GenericJob interface"

        // Relationships - External Services
        trustyaiOperator -> k8sApi "Controller reconciliation" "HTTPS/443"
        tasController -> database "Stores TrustyAI data (DATABASE mode)" "JDBC/TLS optional"
    }

    views {
        systemContext trustyaiOperator "SystemContext" {
            include *
            autoLayout
        }

        container trustyaiOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
