%% TrustyAI Service Operator - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "TrustyAI Service Operator"
        direction TB
        Manager["Controller Manager<br/>(cmd/main.go)<br/>--enable-services TAS,LMES,GORCH"]

        subgraph "Controllers"
            TAS["TrustyAIService Controller<br/>(TAS)"]
            LMES["LMEvalJob Controller<br/>(LMES)"]
            GORCH["GuardrailsOrchestrator Controller<br/>(GORCH)"]
            JOBMGR["Job Manager<br/>(Kueue Integration)"]
        end

        Manager --> TAS
        Manager --> LMES
        Manager --> GORCH
        Manager --> JOBMGR

        HealthProbe["/healthz :8081"]
        MetricsProbe["/metrics :8080"]
        Manager --- HealthProbe
        Manager --- MetricsProbe
    end

    %% CRDs
    TrustyAIServiceCR["TrustyAIService CR<br/>trustyai.opendatahub.io/v1"]
    LMEvalJobCR["LMEvalJob CR<br/>trustyai.opendatahub.io/v1alpha1"]
    GuardrailsCR["GuardrailsOrchestrator CR<br/>trustyai.opendatahub.io/v1alpha1"]

    User[User / Data Scientist] -->|creates| TrustyAIServiceCR
    User -->|creates| LMEvalJobCR
    User -->|creates| GuardrailsCR

    TrustyAIServiceCR -->|watched by| TAS
    LMEvalJobCR -->|watched by| LMES
    LMEvalJobCR -->|scheduled by| JOBMGR
    GuardrailsCR -->|watched by| GORCH

    %% TAS creates
    TAS -->|creates| TASDeployment["TrustyAI Deployment<br/>+ oauth-proxy sidecar"]
    TAS -->|creates| TASService["ClusterIP Services<br/>:80, :443, :8443"]
    TAS -->|creates| TASRoute["OpenShift Route<br/>(reencrypt TLS)"]
    TAS -->|creates| TASPVC["PVC / DB Config"]
    TAS -->|creates| TASMonitor["ServiceMonitor"]
    TAS -->|patches| InferenceService["InferenceService CR<br/>(Logger URL)"]
    TAS -->|creates| IstioResources["DestinationRule +<br/>VirtualService"]

    %% LMES creates
    LMES -->|creates| EvalPod["LMEval Pod<br/>+ driver sidecar"]
    JOBMGR -->|creates| Workload["Kueue Workload CR"]

    %% GORCH creates
    GORCH -->|creates| GORCHDeployment["Guardrails Deployment<br/>+ detector + gateway sidecars"]
    GORCH -->|creates| GORCHService["ClusterIP Services<br/>:8033/:8090, :8034"]
    GORCH -->|creates| GORCHRoute["OpenShift Routes<br/>(edge TLS)"]

    %% External dependencies
    TAS -->|depends on| KServe["KServe"]
    TAS -->|depends on| Prometheus["Prometheus Operator"]
    TAS -->|optional| Istio["Istio Service Mesh"]
    LMES -->|optional| Kueue["Kueue"]
    TAS -->|integrates| ModelMesh["ModelMesh Serving"]

    %% Deployed by
    RhodsOp["rhods-operator"] -->|deploys via kustomize| Manager

