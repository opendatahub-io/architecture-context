// C4 Context Diagram for ilab-on-ocp (InstructLab on OCP)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/ilab-on-ocp.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Submits InstructLab pipeline runs to fine-tune LLMs"
        platformAdmin = person "Platform Admin" "Configures DSPA and model server deployments"

        ilabPipeline = softwareSystem "InstructLab Pipeline (ilab-on-ocp)" "KFP v2 pipeline orchestrating InstructLab LLM fine-tuning: SDG, training, evaluation, model upload" {
            pipelineDef = container "Pipeline Definition" "Main pipeline and base model importer definitions" "Python / KFP v2 SDK"
            sdgComponent = container "SDG Component" "Synthetic Data Generation using teacher model" "Python / InstructLab SDG"
            trainingComponent = container "Training Component" "Data processing and PyTorchJob launcher for distributed training" "Python / Kubeflow Training SDK"
            evalComponent = container "Evaluation Component" "MT-Bench and MMLU evaluation with judge model" "Python / InstructLab Eval"
            utilsComponent = container "Utils Component" "Model upload (OCI/Registry), prerequisites, model import" "Python / skopeo / model-registry"
            kfpClient = container "KFP Client" "Pipeline submission with OpenShift auth and DSPA discovery" "Python / KFP SDK"
        }

        // Internal RHOAI Dependencies
        dsp = softwareSystem "Data Science Pipelines (DSPA)" "Pipeline server hosting and execution" "Internal RHOAI"
        trainingOperator = softwareSystem "Kubeflow Training Operator" "Manages PyTorchJob CRDs for distributed training" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving via InferenceService" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and version tracking" "Internal RHOAI"
        serverless = softwareSystem "OpenShift Serverless" "Knative infrastructure for KServe" "Internal RHOAI"
        serviceMesh = softwareSystem "OpenShift Service Mesh v2" "Service mesh, mTLS, and routing" "Internal RHOAI"
        authorino = softwareSystem "Red Hat Authorino" "Authorization for KServe endpoints" "Internal RHOAI"

        // External Dependencies
        teacherModel = softwareSystem "Teacher Model Server" "Mixtral-8x7B for synthetic data generation (OpenAI-compatible API)" "External"
        judgeModel = softwareSystem "Judge Model Server" "Prometheus-8x7B for evaluation judging (OpenAI-compatible API)" "External"
        ociRegistry = softwareSystem "OCI Container Registry" "Stores ModelCar images with fine-tuned models" "External"
        gitRepo = softwareSystem "Git Repository" "Taxonomy repository for InstructLab" "External"
        gpuOperator = softwareSystem "NVIDIA GPU Operator" "GPU driver and device plugin for training nodes" "External"
        k8sAPI = softwareSystem "Kubernetes API" "Cluster API for resource management" "Infrastructure"

        // Relationships - User
        dataScientist -> ilabPipeline "Submits pipeline runs via KFP API or RHOAI Dashboard"
        platformAdmin -> kserve "Deploys teacher/judge model servers"
        platformAdmin -> dsp "Configures DSPA with managedPipelines.instructLab.state=Managed"

        // Relationships - Pipeline to Internal
        ilabPipeline -> dsp "Auto-provisioned pipeline; tasks run as Argo Workflow steps" "KFP API / HTTPS"
        ilabPipeline -> trainingOperator "Creates/monitors distributed training jobs" "CRD PyTorchJob / HTTPS 443"
        ilabPipeline -> kserve "Teacher/Judge model serving" "CRD InferenceService / HTTPS 443"
        ilabPipeline -> modelRegistry "Registers fine-tuned model with version metadata" "REST API / HTTPS 443"
        kserve -> serverless "Requires for serving infrastructure"
        kserve -> serviceMesh "Requires for mTLS and routing"
        kserve -> authorino "Requires for authorization"

        // Relationships - Pipeline to External
        ilabPipeline -> teacherModel "SDG requests for synthetic data" "HTTPS / Bearer Token"
        ilabPipeline -> judgeModel "Evaluation judging (MT-Bench, MMLU)" "HTTPS / Bearer Token"
        ilabPipeline -> ociRegistry "Push ModelCar image with trained model" "HTTPS 443 / dockerconfigjson"
        ilabPipeline -> gitRepo "Clone taxonomy repository" "HTTPS 443 or SSH 22"
        ilabPipeline -> k8sAPI "Secret fetching, PyTorchJob CRUD, PVC management" "HTTPS 443 / SA Token"
        ilabPipeline -> gpuOperator "GPU resources for training nodes" "Infrastructure"
    }

    views {
        systemContext ilabPipeline "SystemContext" {
            include *
            autoLayout
        }

        container ilabPipeline "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Infrastructure" {
                background #f5a623
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
