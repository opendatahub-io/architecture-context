%% RBAC Visualization - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6
%% Note: This component does NOT define its own RBAC resources.
%% RBAC is managed by ODH Notebook Controller and OpenShift platform.
%% This diagram shows the effective RBAC model for notebook access.
graph TD
    subgraph "User Authentication"
        User["Data Scientist / ML Engineer"]
    end

    subgraph "Authentication Mechanisms"
        direction TB
        OAuthProxy["oauth-proxy (RHOAI 2.x)<br/>Validates OAuth tokens<br/>against OpenShift OAuth server"]
        KubeRBACProxy["kube-rbac-proxy (RHOAI 3.x)<br/>Validates bearer tokens<br/>against Kubernetes RBAC"]
    end

    subgraph "Authorization Policy"
        NamespaceAccess["Namespace Access Check<br/>User must have access to<br/>Notebook CR namespace"]
    end

    subgraph "ODH Notebook Controller"
        Controller["ODH Notebook Controller<br/>Creates per-notebook resources"]
    end

    subgraph "Per-Notebook Resources (Created by Controller)"
        direction TB
        NotebookCR["Notebook CR<br/>(user namespace)"]
        AuthSidecar["Auth Sidecar Container<br/>kube-rbac-proxy / oauth-proxy"]
        NotebookSvc["Notebook Service<br/>8888/TCP or 8787/TCP"]
        IngressRes["Route (2.x) / HTTPRoute (3.x)<br/>External access"]
    end

    subgraph "Workbench Container Ports"
        direction TB
        Jupyter["JupyterLab<br/>8888/TCP<br/>HTTP plaintext"]
        CodeSrv["Code Server<br/>8787/TCP<br/>HTTP plaintext"]
        RStudioSrv["RStudio Server<br/>8787/TCP<br/>HTTP plaintext"]
    end

    subgraph "Container Security Context"
        SecurityCtx["Non-root: UID 1001<br/>FIPS-compliant (data science)<br/>UBI9 hardened base<br/>GPG pubkeys removed"]
    end

    subgraph "Secret"
        RHELSecret["rhel-subscription-secret<br/>Type: Opaque<br/>Purpose: RHEL subscription<br/>for RStudio BuildConfig<br/>Provisioned: Manual / Cluster Admin<br/>Auto-Rotate: No"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>OpenShift OAuth"| OAuthProxy
    User -->|"HTTPS/443<br/>Bearer Token"| KubeRBACProxy
    OAuthProxy -->|validates| NamespaceAccess
    KubeRBACProxy -->|validates| NamespaceAccess
    NamespaceAccess -->|"authorized"| AuthSidecar

    Controller -->|creates| NotebookCR
    Controller -->|injects| AuthSidecar
    Controller -->|creates| NotebookSvc
    Controller -->|creates| IngressRes

    AuthSidecar -->|"HTTP plaintext<br/>(localhost trusted)"| Jupyter
    AuthSidecar -->|"HTTP plaintext<br/>(localhost trusted)"| CodeSrv
    AuthSidecar -->|"HTTP plaintext<br/>(localhost trusted)"| RStudioSrv

    Jupyter --- SecurityCtx
    CodeSrv --- SecurityCtx
    RStudioSrv --- SecurityCtx

    RStudioSrv -.->|"build requires"| RHELSecret

    %% Styles
    style User fill:#4a90e2,color:#fff
    style OAuthProxy fill:#f5a623,color:#fff
    style KubeRBACProxy fill:#f5a623,color:#fff
    style NamespaceAccess fill:#e74c3c,color:#fff
    style Controller fill:#7ed321,color:#fff
    style NotebookCR fill:#9b59b6,color:#fff
    style AuthSidecar fill:#f5a623,color:#fff
    style NotebookSvc fill:#9b59b6,color:#fff
    style IngressRes fill:#9b59b6,color:#fff
    style Jupyter fill:#4a90e2,color:#fff
    style CodeSrv fill:#4a90e2,color:#fff
    style RStudioSrv fill:#4a90e2,color:#fff
    style SecurityCtx fill:#2ecc71,color:#fff
    style RHELSecret fill:#e74c3c,color:#fff
