%% ModelMesh Serving - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph ControlPlane["CONTROLLER PLANE"]
        Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>8080/TCP metrics (HTTP, plaintext)<br/>8081/TCP health (HTTP, plaintext)<br/>9443/TCP webhook (HTTPS, TLS)"]
    end

    subgraph DataPlane["DATA PLANE (per modelmesh-enabled namespace)"]
        direction TB

        subgraph RuntimePod["Runtime Pod"]
            OAuthProxy["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>TLS (serving certs)<br/>OpenShift OAuth SAR"]
            RESTProxy["REST Proxy Sidecar<br/>8008/TCP HTTP<br/>plaintext"]
            ModelMesh["ModelMesh Sidecar (Java)<br/>8033/TCP gRPC<br/>Optional TLS/mTLS<br/>8089/TCP health (HTTP)<br/>2112/TCP metrics"]
            Runtime["Model Runtime<br/>(Triton/MLServer/etc.)<br/>gRPC (TCP/Unix socket)"]
            Puller["Storage Helper (Puller)<br/>8086/TCP gRPC"]
        end

        HeadlessSvc["Headless Service<br/>modelmesh-serving<br/>8033, 8008, 8443, 2112/TCP"]
    end

    subgraph InternalServices["INTERNAL SERVICES"]
        etcd["etcd<br/>2379/TCP HTTP<br/>plaintext<br/>Password auth (root)"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["Object Storage (S3/GCS)<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Storage credentials"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount token"]
        OAuthServer["OpenShift OAuth Server<br/>Token validation"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    %% External flows
    Client -->|"HTTPS/8443<br/>TLS<br/>OAuth Bearer Token + SAR"| OAuthProxy
    Client -->|"gRPC/8033<br/>Optional TLS/mTLS<br/>Optional client certs"| ModelMesh

    %% Internal pod flows
    OAuthProxy -->|"HTTP/8008<br/>plaintext (localhost)<br/>No auth"| RESTProxy
    RESTProxy -->|"gRPC/8033<br/>Optional TLS<br/>No auth (internal)"| ModelMesh
    ModelMesh -->|"gRPC (TCP/Unix)<br/>plaintext<br/>No auth"| Runtime
    Puller -->|"gRPC/8086<br/>plaintext"| Runtime

    %% Service routing
    HeadlessSvc -.->|routes to| RuntimePod

    %% Controller flows
    Controller -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    Controller -->|"gRPC/8033<br/>Optional TLS"| ModelMesh

    %% State management
    ModelMesh -->|"HTTP/2379<br/>plaintext<br/>Password auth"| etcd

    %% External egress
    Puller -->|"HTTPS/443<br/>TLS 1.2+<br/>Storage creds"| S3
    OAuthProxy -->|"Token validation"| OAuthServer

    %% Monitoring
    Prometheus -->|"HTTP/8080<br/>plaintext"| Controller
    Prometheus -->|"HTTP(S)/2112<br/>configurable"| ModelMesh

    %% Webhook
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API server cert"| Controller

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controller fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef dataplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef internal fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef monitoring fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Client external
    class Controller controller
    class OAuthProxy,RESTProxy,ModelMesh,Runtime,Puller,HeadlessSvc dataplane
    class etcd internal
    class S3,K8sAPI,OAuthServer externalservice
    class Prometheus monitoring
