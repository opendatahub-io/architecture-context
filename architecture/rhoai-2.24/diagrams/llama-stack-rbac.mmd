%% Llama Stack - RBAC / Access Control Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-2.24/llama-stack.md

graph TD
    subgraph "Authentication Providers"
        OAuth2JWT["OAuth2 JWT (JWKS)<br/>JWT signature verification<br/>Audience/issuer validation"]
        OAuth2Intro["OAuth2 Introspection<br/>RFC 7662 POST<br/>Client ID/Secret auth"]
        CustomAuth["Custom Auth Endpoint<br/>POST with API key<br/>Returns AuthResponse"]
        K8sAuth["Kubernetes TokenReview<br/>ServiceAccount token<br/>K8s API validation"]
    end

    subgraph "Identity Extraction"
        Principal["Principal<br/>(User Identity)"]
        AccessAttrs["Access Attributes<br/>- roles<br/>- teams<br/>- projects<br/>- namespaces"]
    end

    subgraph "ABAC Policy Engine (Cedar-like)"
        PolicyEval["Policy Evaluator<br/>First match wins<br/>Default: DENY"]

        subgraph "Policy Rules"
            Rule1["Rule: Allow<br/>action: read<br/>resource: model::*<br/>when: role in ['viewer','editor','admin']"]
            Rule2["Rule: Allow<br/>action: create, update, delete<br/>resource: model::*<br/>when: role in ['editor','admin']"]
            Rule3["Rule: Allow<br/>action: read<br/>resource: vector_db::*<br/>when: role in ['viewer','editor','admin']"]
            Rule4["Rule: Allow<br/>action: create, update, delete<br/>resource: vector_db::*<br/>when: role in ['admin']"]
            DefaultDeny["Default Rule: DENY<br/>(if no match)"]
        end
    end

    subgraph "Actions"
        Create["create"]
        Read["read"]
        Update["update"]
        Delete["delete"]
    end

    subgraph "Protected Resources"
        Models["model::*<br/>(Inference Models)"]
        VectorDBs["vector_db::*<br/>(Vector Databases)"]
        Shields["shield::*<br/>(Safety Shields)"]
        Datasets["dataset::*<br/>(Datasets)"]
        Benchmarks["benchmark::*<br/>(Eval Benchmarks)"]
        ToolGroups["tool_group::*<br/>(Tool Groups)"]
    end

    subgraph "Rate Limiting (Quota)"
        QuotaAuth["Authenticated Users<br/>1000 requests/day"]
        QuotaAnon["Anonymous (by IP)<br/>100 requests/day"]
        KVStore["KV Store Backend<br/>(SQLite / Redis)"]
    end

    subgraph "Unauthenticated Endpoints (Bypass)"
        Health["/v1/health"]
        Version["/v1/version"]
        Docs["/docs, /redoc"]
        OpenAPISchema["/openapi.json"]
    end

    %% Auth flow
    OAuth2JWT -->|"extracts claims:<br/>sub, groups, team, project"| Principal
    OAuth2JWT -->|"maps to"| AccessAttrs
    OAuth2Intro -->|"extracts from response"| Principal
    OAuth2Intro -->|"maps to"| AccessAttrs
    CustomAuth -->|"parses AuthResponse"| Principal
    CustomAuth -->|"parses AuthResponse"| AccessAttrs
    K8sAuth -->|"K8s user identity"| Principal

    %% ABAC evaluation
    Principal -->|"who"| PolicyEval
    AccessAttrs -->|"attributes"| PolicyEval

    PolicyEval --> Rule1
    PolicyEval --> Rule2
    PolicyEval --> Rule3
    PolicyEval --> Rule4
    PolicyEval --> DefaultDeny

    %% Actions to resources
    Rule1 -->|"permits"| Read
    Rule2 -->|"permits"| Create
    Rule2 -->|"permits"| Update
    Rule2 -->|"permits"| Delete

    Read --> Models
    Read --> VectorDBs
    Read --> Shields
    Read --> Datasets
    Read --> Benchmarks
    Read --> ToolGroups
    Create --> Models
    Create --> VectorDBs
    Update --> Models
    Delete --> Models

    %% Quota
    Principal -->|"identified"| QuotaAuth
    QuotaAuth --> KVStore
    QuotaAnon --> KVStore

