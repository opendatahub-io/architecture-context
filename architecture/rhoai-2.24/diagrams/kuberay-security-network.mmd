        WebhookEP["Webhook: 9443/TCP HTTPS<br/>/validate-ray-io-v1-raycluster<br/>TLS (K8s API server certs)"]
    end

    subgraph RayNS["RAY CLUSTER NAMESPACE ({user-namespace})"]
