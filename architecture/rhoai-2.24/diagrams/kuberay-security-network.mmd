        WorkerPods["Ray Worker Pods"]

        subgraph DynServices["Dynamically Created Services"]
            HeadSvc["{cluster}-head-svc<br/>ClusterIP<br/>10001,6379,8265,8080,8000"]
            HeadlessSvc["{cluster}-headless<br/>Headless (ClusterIP: None)"]
            ServeSvc["{cluster}-serve-svc<br/>ClusterIP 8000/TCP"]
        end
    end

    subgraph IngressZone["INGRESS (Optional)"]
        Route["OpenShift Route / K8s Ingress<br/>8265/TCP<br/>Edge TLS (OpenShift default)"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>HTTP scrape"]
    end

    subgraph Schedulers["OPTIONAL SCHEDULERS"]
        Volcano["Volcano<br/>(PodGroup CRD)"]
        Yunikorn["Yunikorn<br/>(Pod annotations)"]
    end

    %% Flows
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    K8sAPI -->|"Watch events<br/>TLS 1.2+<br/>SA Token"| Operator
    K8sAPI -->|"Webhook call<br/>HTTPS/9443<br/>TLS"| WebhookEP
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>CRUD resources"| K8sAPI
    Operator -->|"HTTP/8265<br/>No encryption<br/>No auth<br/>Job submit / Serve deploy"| HeadPod
    Operator -->|"TCP/6379<br/>No encryption<br/>No auth<br/>GCS health check"| HeadPod
    WorkerPods -->|"TCP/6379, 10001<br/>No encryption<br/>No auth"| HeadPod
    Route -->|"HTTP/8265<br/>Dashboard access"| HeadSvc
    Prometheus -->|"HTTP/8080<br/>No auth"| MetricsEP

