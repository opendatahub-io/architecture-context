        MigrationMgr["StorageMigrationManager<br/>(Background Process)"]
        HealthProbe["Health Probes<br/>8081/TCP"]
        MetricsEndpoint["Metrics Endpoint<br/>8443/TCP HTTPS"]

        Reconciler -->|validates via| Webhook
        Reconciler --- MigrationMgr
    end

    subgraph RegistryInstance["ModelRegistry Instance (per CR)"]
        RESTProxy["REST Proxy Container<br/>model-registry (proxy mode)<br/>8080/TCP HTTP"]
        OAuthProxy["OAuth Proxy Sidecar<br/>ose-oauth-proxy<br/>8443/TCP HTTPS"]
        CatalogContainer["Model Catalog Container<br/>model-registry (catalog mode)<br/>8080/TCP HTTP<br/>(optional, feature-gated)"]

        OAuthProxy -->|upstream| RESTProxy
    end

    %% CRDs
    User[Data Scientist / Admin] -->|creates| ModelRegistryCR["ModelRegistry CR<br/>modelregistry.opendatahub.io<br/>v1beta1"]
    ModelRegistryCR -->|watched by| Reconciler

    %% Resources created by operator
    Reconciler -->|creates| RegistryInstance
    Reconciler -->|creates| Service["ClusterIP Services"]
    Reconciler -->|creates| Route["OpenShift Routes<br/>(reencrypt TLS)"]
    Reconciler -->|creates| NetPol["NetworkPolicies"]
    Reconciler -->|creates| RBAC["Roles, RoleBindings<br/>ClusterRoleBindings"]
    Reconciler -->|creates| Groups["OpenShift Groups<br/>({name}-users)"]
    Reconciler -->|creates| SA["ServiceAccounts"]
    Reconciler -->|creates| Secrets["OAuth Secrets<br/>(TLS cert, cookie)"]

    %% Migration
    MigrationMgr -->|migrates| CRDMigration["CRD Storage Migration<br/>v1alpha1 → v1beta1"]

    %% External dependencies
    RESTProxy -->|connects to| PostgreSQL["PostgreSQL<br/>5432/TCP"]
    RESTProxy -->|connects to| MySQL["MySQL<br/>3306/TCP"]
    OAuthProxy -->|authenticates via| OpenShiftOAuth["OpenShift OAuth"]
    Reconciler -->|deployed by| RhodsOperator["rhods-operator"]

    %% Optional integrations
    Reconciler -.->|optional cleanup| Istio["Istio Service Mesh<br/>(being deprecated)"]
    Reconciler -.->|optional cleanup| Authorino["Authorino AuthConfig<br/>(being deprecated)"]

