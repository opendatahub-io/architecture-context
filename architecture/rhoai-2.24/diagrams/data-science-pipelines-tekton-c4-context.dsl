// Data Science Pipelines (Tekton) - C4 Context Diagram
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Authors, submits, and monitors ML pipelines"
        admin = person "Platform Admin" "Configures and manages the DSP platform"

        dsp = softwareSystem "Data Science Pipelines (Tekton)" "Kubeflow Pipelines platform with Tekton backend for ML pipeline authoring, scheduling, and execution" {
            apiServer = container "ds-pipeline (API Server)" "REST/gRPC API server for pipeline CRUD, run management, experiment tracking, job scheduling" "Go Service" "8888/TCP HTTP, 8887/TCP gRPC"
            persistenceAgent = container "ds-pipeline-persistenceagent" "Watches Tekton PipelineRun/TaskRun CRs and persists status to API server" "Go Service"
            scheduledWorkflow = container "ds-pipeline-scheduledworkflow" "Reconciles ScheduledWorkflow CRs to create Tekton PipelineRuns on cron/periodic schedules" "Go Controller"
            ui = container "ds-pipeline-ui" "Web UI for pipeline visualization, management, and artifact browsing; fronted by oauth-proxy" "React/TypeScript"
            vizServer = container "ds-pipeline-visualizationserver" "Generates visualizations (HTML) from pipeline output artifacts" "Python Service"
            metadataGrpc = container "metadata-grpc-deployment" "ML Metadata (MLMD) gRPC server for artifact/execution lineage tracking" "C++ gRPC Service"
            metadataEnvoy = container "metadata-envoy-deployment" "Envoy proxy fronting MLMD gRPC service" "Envoy Proxy"
            metadataWriter = container "metadata-writer" "Watches Tekton PipelineRuns and writes execution metadata to MLMD" "Python Service"
            cacheServer = container "cache-server" "Mutating admission webhook for pipeline step caching based on input fingerprints" "Go Webhook"
        }

        tekton = softwareSystem "Tekton Pipelines" "Workflow execution engine providing PipelineRun and TaskRun CRDs" "External"
        mysql = softwareSystem "MySQL/MariaDB" "Relational database for pipeline metadata, run history, and MLMD storage" "External"
        minio = softwareSystem "MinIO/S3" "S3-compatible object storage for pipeline artifacts and logs" "External"
        kubernetes = softwareSystem "Kubernetes/OpenShift" "Container orchestration platform with OAuth and Route support" "External"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages DSP stack via DataSciencePipelinesApplication CR" "Internal RHOAI"
        dashboard = softwareSystem "ODH Dashboard" "Provides pipeline UI integration via OdhApplication/OdhQuickStart CRs" "Internal RHOAI"
        istio = softwareSystem "Istio Service Mesh" "Multi-user isolation and traffic routing (optional)" "External"

        // User interactions
        user -> dsp "Authors and submits ML pipelines, monitors runs via UI/API"
        admin -> dspOperator "Configures DSP deployment via DataSciencePipelinesApplication CR"

        // Internal container relationships
        ui -> apiServer "Submits pipeline requests" "HTTP/8888, Bearer Token"
        persistenceAgent -> apiServer "Persists PipelineRun status" "HTTP/8888"
        apiServer -> vizServer "Requests visualizations" "HTTP/8888"
        metadataWriter -> metadataGrpc "Writes execution metadata" "gRPC/8080"
        metadataEnvoy -> metadataGrpc "Proxies gRPC requests" "gRPC/8080"

        // External dependencies
        dsp -> tekton "Creates and watches PipelineRun/TaskRun CRDs" "HTTPS/443"
        dsp -> mysql "Stores pipeline metadata, run history, MLMD data" "MySQL/3306"
        dsp -> minio "Stores and retrieves pipeline artifacts and logs" "HTTP/9000"
        dsp -> kubernetes "RBAC checks, pod logs, event creation, CRD management" "HTTPS/443"

        // Internal RHOAI dependencies
        dspOperator -> dsp "Deploys and manages via DataSciencePipelinesApplication CR"
        dashboard -> dsp "UI integration via OdhApplication CR"
        dsp -> istio "Multi-user isolation with AuthorizationPolicy/VirtualService" "mTLS"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
