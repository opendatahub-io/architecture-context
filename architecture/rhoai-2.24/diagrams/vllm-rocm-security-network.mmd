            OTELCollector["OTEL Collector<br/>OTLP gRPC/HTTP"]
        end

        subgraph DistributedInference["Distributed Inference (Optional)"]
            RayHead["Ray Head<br/>6379/TCP<br/>Ray Protocol<br/>plaintext"]
            RayWorkers["Ray Workers<br/>Dynamic Ports<br/>RCCL (ROCm NCCL)"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        HFHub["HuggingFace Hub<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>HF Token<br/>DISABLED: HF_HUB_OFFLINE=1"]
