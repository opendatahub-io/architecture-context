    end

    %% External flows
    Client -->|"HTTPS<br/>TLS Terminated at Gateway"| KServeGW
    KServeGW -->|"HTTP/8000<br/>Optional TLS<br/>Bearer Token"| OpenAI

    %% Internal orchestration flows
    KServe -->|"gRPC/8033<br/>plaintext<br/>No Auth"| TGIS
    ModelMesh -->|"gRPC/8033<br/>plaintext<br/>No Auth"| TGIS
    KServe -->|"HTTP/8000<br/>Optional TLS<br/>Bearer Token"| OpenAI

    %% Internal processing
    OpenAI -->|"In-process"| EngineGPU
    TGIS -->|"In-process"| EngineGPU

    %% Monitoring
    Prometheus -->|"HTTP/8000<br/>/metrics<br/>No Auth"| OpenAI
    EngineGPU -.->|"OTLP<br/>varies"| OTELCollector

    %% Distributed
    EngineGPU -.->|"Ray/6379<br/>plaintext"| RayHead
    RayHead -.->|"Dynamic<br/>plaintext"| RayWorkers

    %% Egress
    EngineGPU -->|"HTTPS/443<br/>TLS 1.2+<br/>AWS IAM"| S3
    EngineGPU -.->|"HTTPS/443<br/>TLS 1.2+<br/>HF Token<br/>(disabled in prod)"| HFHub

