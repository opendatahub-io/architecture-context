// Training Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages distributed ML training jobs"

        trainingOperator = softwareSystem "Kubeflow Training Operator (KFTO)" "Kubernetes operator for managing distributed ML training jobs across PyTorch, TensorFlow, XGBoost, MPI, PaddlePaddle, JAX" {
            controller = container "Training Operator Controller" "Reconciles 6 training job CRDs, creates Pods, Services, NetworkPolicies, PodGroups" "Go Operator (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates CREATE/UPDATE operations on training job CRDs" "Admission Webhook (9443/TCP)"
            certRotator = container "Cert Rotator" "Self-manages TLS certificates for webhook server" "OPA cert-controller"
            metricsServer = container "Metrics Server" "Exposes Prometheus metrics" "HTTP (8080/TCP)"
        }

        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for pod/service/CRD management" "External" {
            tags "External"
        }

        prometheus = softwareSystem "OpenShift Monitoring" "Prometheus-based monitoring stack" "Internal ODH" {
            tags "Internal ODH"
        }

        volcano = softwareSystem "Volcano Scheduler" "Optional gang scheduler for coordinated pod scheduling" "External" {
            tags "External" "Optional"
        }

        schedulerPlugins = softwareSystem "Scheduler Plugins" "Optional gang scheduler alternative" "External" {
            tags "External" "Optional"
        }

        kueue = softwareSystem "Kueue" "Optional MultiKueue integration for job management delegation" "External" {
            tags "External" "Optional"
        }

        rhodsOperator = softwareSystem "RHODS Operator" "Deploys training-operator via kustomize overlay" "Internal ODH" {
            tags "Internal ODH"
        }

        // Relationships
        user -> trainingOperator "Creates PyTorchJob, TFJob, XGBoostJob, MPIJob, PaddleJob, JAXJob via kubectl"
        trainingOperator -> k8sAPI "CRUD Pods, Services, NetworkPolicies, HPAs, PodGroups" "HTTPS/443 TLS 1.2+"
        k8sAPI -> webhookServer "Admission review requests" "HTTPS/9443 TLS"
        prometheus -> trainingOperator "Scrapes operator metrics via PodMonitor" "HTTP/8080"
        trainingOperator -> volcano "Creates PodGroup CRDs for gang scheduling" "Kubernetes API"
        trainingOperator -> schedulerPlugins "Creates PodGroup CRDs for gang scheduling" "Kubernetes API"
        trainingOperator -> kueue "ManagedBy field delegation" "Kubernetes API"
        rhodsOperator -> trainingOperator "Deploys via kustomize overlay"
        certRotator -> webhookServer "Rotates TLS certificates"

        controller -> k8sAPI "Watches CRDs, creates Pods/Services/NetworkPolicies" "HTTPS/443"
        controller -> webhookServer "Validates via admission webhook"
    }

    views {
        systemContext trainingOperator "SystemContext" {
            include *
            autoLayout
        }

        container trainingOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Optional" {
                opacity 70
            }
            element "Person" {
                shape Person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
