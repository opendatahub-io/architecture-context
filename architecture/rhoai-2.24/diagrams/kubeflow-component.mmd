%% Kubeflow Notebook Controller - Component Structure Diagram
%% Generated by: Claude Opus 4.6
graph TB
    subgraph KubeflowControllers["Kubeflow Notebook Controllers"]
        direction TB

        subgraph KFController["kf-notebook-controller"]
            NotebookCtrl["Notebook Controller<br/>(controller-runtime)"]
            CullingCtrl["Culling Controller<br/>(idle detection)"]
            Metrics["Prometheus Metrics<br/>:8080/TCP"]
            HealthKF["Health/Ready<br/>:8081/TCP"]
        end

        subgraph ODHController["odh-notebook-controller"]
            ODHNotebookCtrl["ODH Notebook Controller<br/>(controller-runtime)"]
            Webhook["Mutating Webhook<br/>:8443/TCP HTTPS"]
            HealthODH["Health/Ready<br/>:8081/TCP"]
            MetricsODH["Metrics<br/>:8080/TCP"]
        end
    end

    %% CRDs
    NotebookCR["Notebook CR<br/>(kubeflow.org/v1)"]

    %% Resources created by kf-notebook-controller
    StatefulSet["StatefulSet<br/>(notebook workload)"]
    Service["Service<br/>(notebook access)"]
    VirtualService["VirtualService<br/>(Istio, optional)"]

    %% Resources created by odh-notebook-controller
    Route["OpenShift Route<br/>(TLS terminated)"]
    NetworkPolicy["NetworkPolicy<br/>(per notebook)"]
    OAuthClient["OAuthClient<br/>(OpenShift OAuth)"]
    OAuthSecrets["OAuth Secrets<br/>(cookie + client)"]
    TLSCert["TLS Certificate<br/>(service-ca)"]
    DSPASecret["Elyra Pipeline Config<br/>(ds-pipeline-config)"]
    RuntimeCM["Pipeline Runtime Images<br/>(ConfigMap)"]

    %% User interaction
    User["User / Dashboard"] -->|creates| NotebookCR

    %% Webhook injection
    NotebookCR -->|intercepted by| Webhook
    Webhook -->|injects oauth-proxy,<br/>CA bundles, env vars| NotebookCR

    %% kf-notebook-controller reconciliation
    NotebookCR -->|watched by| NotebookCtrl
    NotebookCtrl -->|creates| StatefulSet
    NotebookCtrl -->|creates| Service
    NotebookCtrl -->|"creates (optional)"| VirtualService

    %% Culling
    CullingCtrl -->|checks idle via<br/>/api/kernels, /api/terminals| Service
    CullingCtrl -->|scales to 0| StatefulSet

    %% odh-notebook-controller reconciliation
    NotebookCR -->|watched by| ODHNotebookCtrl
    ODHNotebookCtrl -->|creates| Route
    ODHNotebookCtrl -->|creates| NetworkPolicy
    ODHNotebookCtrl -->|creates| OAuthClient
    ODHNotebookCtrl -->|creates| OAuthSecrets
    ODHNotebookCtrl -->|creates| TLSCert
    ODHNotebookCtrl -->|creates| DSPASecret
    ODHNotebookCtrl -->|syncs| RuntimeCM

    %% External dependencies
    ODHNotebookCtrl -->|reads| DSPA["DSPA CR<br/>(data-science-pipelines)"]
    ODHNotebookCtrl -->|reads| Dashboard["Dashboard CR<br/>(odh-dashboard)"]
    ODHNotebookCtrl -->|resolves images| ImageStream["OpenShift<br/>ImageStreams"]

    %% Styling
    style NotebookCtrl fill:#4a90e2,color:#fff
    style CullingCtrl fill:#4a90e2,color:#fff
    style ODHNotebookCtrl fill:#4a90e2,color:#fff
    style Webhook fill:#4a90e2,color:#fff
    style NotebookCR fill:#f5a623,color:#fff
    style StatefulSet fill:#7ed321,color:#fff
    style Service fill:#7ed321,color:#fff
    style Route fill:#7ed321,color:#fff
    style NetworkPolicy fill:#7ed321,color:#fff
    style OAuthClient fill:#7ed321,color:#fff
    style DSPA fill:#e8e8e8
    style Dashboard fill:#e8e8e8
    style ImageStream fill:#e8e8e8
