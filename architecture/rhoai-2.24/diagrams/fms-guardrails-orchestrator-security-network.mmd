%% FMS Guardrails Orchestrator - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Clients)"]
        Client["Client Application"]
    end

    subgraph OrchestratorZone["GUARDRAILS ORCHESTRATOR SERVICE"]
        direction TB
        GS["Guardrails Server<br/>8033/TCP HTTP/HTTPS<br/>TLS 1.2+ (rustls)<br/>mTLS (optional)"]
        HS["Health Server<br/>8034/TCP HTTP<br/>plaintext<br/>No Auth"]
    end

    subgraph BackendServices["BACKEND SERVICES (Internal)"]
        direction TB

        TGIS["TGIS Generation Server<br/>configurable/TCP<br/>gRPC (HTTP/2)<br/>TLS/mTLS (configurable)"]
        CaikitNLP["Caikit NLP Server<br/>configurable/TCP<br/>gRPC (HTTP/2)<br/>TLS/mTLS (configurable)"]
        vLLM["OpenAI-compatible (vLLM)<br/>8080/TCP<br/>HTTP/HTTPS<br/>TLS (configurable)"]
        Detectors["Content Safety Detectors<br/>8080/TCP<br/>HTTP/HTTPS<br/>TLS/mTLS (configurable)"]
        Chunkers["Caikit Chunkers<br/>configurable/TCP<br/>gRPC (HTTP/2)<br/>TLS/mTLS (configurable)"]
    end

    subgraph Observability["OBSERVABILITY (Optional)"]
        OTEL["OpenTelemetry Collector<br/>4317/TCP (gRPC) or 4318/TCP (HTTP)<br/>OTLP Protocol"]
    end

    %% Inbound flows
    Client -->|"HTTPS/8033<br/>TLS 1.2+ (rustls)<br/>mTLS client certs (optional)"| GS
    Client -.->|"HTTP/8034<br/>plaintext<br/>No Auth"| HS

    %% Outbound flows
    GS -->|"gRPC/configurable<br/>TLS/mTLS (configurable)<br/>mTLS client certs"| TGIS
    GS -->|"gRPC/configurable<br/>TLS/mTLS (configurable)<br/>mTLS client certs"| CaikitNLP
    GS -->|"HTTP(S)/8080<br/>TLS (configurable)<br/>Header passthrough"| vLLM
    GS -->|"HTTP(S)/8080<br/>TLS/mTLS (configurable)<br/>Header passthrough"| Detectors
    GS -->|"gRPC/configurable<br/>TLS/mTLS (configurable)<br/>mTLS client certs"| Chunkers

    %% Observability
    GS -.->|"OTLP/4317 or 4318<br/>gRPC or HTTP<br/>Traces + Metrics"| OTEL

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef orchestrator fill:#4a90e2,stroke:#2a6cb8,stroke-width:2px,color:#fff
    classDef backend fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef observability fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class GS,HS orchestrator
    class TGIS,CaikitNLP,vLLM,Detectors,Chunkers backend
