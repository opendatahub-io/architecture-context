    %% External to Ingress
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token"| K8sAPI
    Browser -->|"HTTPS/443<br/>TLS 1.2+"| OSRouter
    RayClient -->|"HTTPS/443<br/>mTLS client cert"| OSRouter

    %% API Server to Webhooks
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API Server CA"| MutRC
    K8sAPI -->|"HTTPS/9443<br/>TLS<br/>API Server CA"| ValRC

    %% Controller egress
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    Controller -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| OSConfig

    %% Router to User namespace
    OSRouter -->|"HTTPS/8443<br/>TLS reencrypt<br/>OAuth cookie"| OAuthProxy
    OSRouter -->|"HTTPS/10001<br/>mTLS passthrough<br/>Client cert"| RayClientPort

    %% Within head pod
    OAuthProxy -->|"HTTP/8265<br/>localhost<br/>No encryption"| RayDash

    %% Inter-node mTLS
    RayClientPort <-->|"mTLS<br/>RAY_USE_TLS=1"| RayWorker

    %% Monitoring
    Prometheus -->|"HTTP/8080"| Metrics

    %% Cert provisioning
    ServingCert -.->|"annotation-based"| OAuthProxy

