// ModelMesh Serving - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Creates and deploys ML models for multi-model serving"
        admin = person "Platform Admin" "Manages serving runtimes and cluster configuration"

        modelmeshServing = softwareSystem "ModelMesh Serving" "Manages lifecycle of ModelMesh multi-model serving deployments on Kubernetes/OpenShift" {
            controller = container "modelmesh-controller" "Main controller managing ServingRuntime, Predictor, and Service reconciliation" "Go Operator (controller-runtime)"
            webhook = container "Validating Webhook" "Validates ServingRuntime and ClusterServingRuntime CRs on CREATE/UPDATE" "Go Service, 9443/TCP"
            srReconciler = container "ServingRuntimeReconciler" "Reconciles ServingRuntime/ClusterServingRuntime CRs into Deployments with sidecar containers" "Go Controller"
            pReconciler = container "PredictorReconciler" "Reconciles Predictor/InferenceService CRs by registering models via gRPC" "Go Controller"
            svcReconciler = container "ServiceReconciler" "Manages per-namespace headless Services and ServiceMonitors" "Go Controller"
            autoReconciler = container "AutoscalerReconciler" "Manages HPA resources for runtime Deployments" "Go Controller"
            modelmeshSidecar = container "ModelMesh Sidecar" "Java-based model serving mesh handling model routing, caching, and placement" "Java, gRPC 8033/TCP"
            restProxy = container "REST Proxy Sidecar" "Translates REST/HTTP to gRPC for inference" "Go, HTTP 8008/TCP"
            oauthProxy = container "OAuth Proxy Sidecar" "OpenShift OAuth proxy for authentication on inference endpoints" "Go, HTTPS 8443/TCP"
            puller = container "Storage Helper (Puller)" "Downloads model artifacts from object storage" "Go, gRPC 8086/TCP"
        }

        etcd = softwareSystem "etcd" "Distributed key-value store for model placement state coordination" "External"
        kubernetes = softwareSystem "Kubernetes API Server" "Container orchestration platform" "External"
        openshift = softwareSystem "OpenShift" "Platform providing OAuth, serving certificates, SCC" "External"
        objectStorage = softwareSystem "Object Storage (S3/GCS)" "Model artifact storage" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        rhodsOperator = softwareSystem "rhods-operator" "Deploys modelmesh-serving controller via kustomize overlays" "Internal RHOAI"
        odhModelController = softwareSystem "odh-model-controller" "Shares InferenceService CRD for model management" "Internal RHOAI"
        modelmeshCore = softwareSystem "ModelMesh (Core)" "Java-based model serving mesh library" "Internal RHOAI"
        runtimeAdapter = softwareSystem "modelmesh-runtime-adapter" "Storage helper for downloading model artifacts" "Internal RHOAI"
        restProxySystem = softwareSystem "rest-proxy" "REST-to-gRPC translation proxy" "Internal RHOAI"

        // User interactions
        user -> modelmeshServing "Creates Predictor/InferenceService CRs via kubectl/API"
        admin -> modelmeshServing "Creates ServingRuntime/ClusterServingRuntime CRs"
        user -> oauthProxy "Sends inference requests" "HTTPS/8443"
        user -> modelmeshSidecar "Sends gRPC inference requests" "gRPC/8033"

        // Internal container relationships
        controller -> srReconciler "Delegates ServingRuntime reconciliation"
        controller -> pReconciler "Delegates Predictor reconciliation"
        controller -> svcReconciler "Delegates Service reconciliation"
        controller -> autoReconciler "Delegates HPA reconciliation"
        controller -> webhook "Validates CRs"
        oauthProxy -> restProxy "Forwards authenticated requests" "HTTP/8008"
        restProxy -> modelmeshSidecar "Translates REST to gRPC" "gRPC/8033"
        modelmeshSidecar -> puller "Model loading notifications" "gRPC/8086"
        pReconciler -> modelmeshSidecar "Registers/unregisters models" "gRPC/8033"

        // External dependencies
        modelmeshServing -> etcd "Model placement state" "HTTP/2379"
        modelmeshServing -> kubernetes "CRD/resource management" "HTTPS/443"
        modelmeshServing -> objectStorage "Downloads model artifacts" "HTTPS/443"
        oauthProxy -> openshift "OAuth token validation" "HTTPS"
        prometheus -> modelmeshServing "Scrapes metrics" "HTTP/8080, HTTP(S)/2112"
        rhodsOperator -> modelmeshServing "Deploys and configures" "Kustomize"
        odhModelController -> modelmeshServing "Shares InferenceService CRD" "CRD sharing"
    }

    views {
        systemContext modelmeshServing "SystemContext" {
            include *
            autoLayout
        }

        container modelmeshServing "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #4a90e2
                color #ffffff
                shape person
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
