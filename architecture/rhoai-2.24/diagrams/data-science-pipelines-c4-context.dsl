// Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist" "Defines, runs, schedules, and monitors ML pipelines"
        admin = person "Platform Admin" "Deploys and configures DSP components via operator"

        dsp = softwareSystem "Data Science Pipelines" "End-to-end ML workflow orchestration based on Kubeflow Pipelines" {
            apiServer = container "ml-pipeline API Server" "REST/gRPC API for pipeline management; v1beta1 and v2beta1 APIs; webhook server" "Go Service" "API"
            persistenceAgent = container "Persistence Agent" "Watches Argo Workflows and reports execution status to API server" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow Controller" "Manages ScheduledWorkflow CRs; creates Argo Workflow instances on cron schedules" "Go Controller"
            ui = container "Pipeline UI" "Web UI for pipeline visualization, run management, and artifact browsing" "Node.js/React"
            viewerCRD = container "Viewer CRD Controller" "Manages Viewer CRs; creates Deployments for TensorBoard instances" "Go Controller"
            visualizationServer = container "Visualization Server" "Generates pipeline visualization artifacts" "Python Service"
            metadataGRPC = container "ML Metadata Server" "gRPC API for artifact and execution lineage tracking" "C++ gRPC Service"
            metadataEnvoy = container "Metadata Envoy" "gRPC-Web proxy for ML Metadata" "Envoy Proxy"
            cacheServer = container "Cache Server" "Mutating webhook for pipeline step caching" "Go Service"
            driver = container "KFP Driver" "V2 pipeline driver; resolves inputs/outputs and manages DAG logic inside pipeline pods" "Go Binary (injected)"
            launcher = container "KFP Launcher" "V2 pipeline launcher; manages artifact I/O with object storage inside pipeline pods" "Go Binary (injected)"
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Workflow execution engine; orchestrates pipeline steps as Kubernetes pods" "External"
        database = softwareSystem "MySQL / PostgreSQL" "Relational database for pipeline metadata, run history, and cache" "External"
        objectStorage = softwareSystem "MinIO / S3 Object Storage" "Stores pipeline artifacts, logs, and compiled pipeline specs" "External"
        kubernetesAPI = softwareSystem "Kubernetes API Server" "Container orchestration platform API" "External"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages all DSP components" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "RHOAI dashboard with pipeline management UI integration" "Internal RHOAI"

        // User interactions
        user -> dsp "Creates/runs/monitors pipelines via UI and API"
        user -> ui "Browses pipelines, runs, and artifacts"
        admin -> dspOperator "Configures DSP deployment"

        // Internal container relationships
        ui -> apiServer "Proxies API calls" "HTTP/8888"
        ui -> metadataEnvoy "Fetches artifact metadata" "HTTP gRPC-Web/9090"
        metadataEnvoy -> metadataGRPC "Proxies gRPC requests" "gRPC/8080"
        persistenceAgent -> apiServer "Reports workflow status" "gRPC/8888 Projected SA Token"
        scheduledWorkflow -> kubernetesAPI "Creates Workflow CRs on schedule" "HTTPS/443"
        driver -> metadataGRPC "Records execution lineage" "gRPC/8080"
        driver -> objectStorage "Downloads/uploads artifacts" "HTTP(S)/9000"
        launcher -> objectStorage "Manages artifact I/O" "HTTP(S)/9000"
        cacheServer -> database "Checks cache hits" "DB/3306|5432"

        // External system interactions
        dsp -> argoWorkflows "Creates and manages Workflow CRs for pipeline execution" "K8s API/443"
        dsp -> database "Stores pipeline metadata, run history, cache data" "MySQL 3306 / PostgreSQL 5432"
        dsp -> objectStorage "Stores pipeline artifacts and logs" "S3 API/9000|443"
        dsp -> kubernetesAPI "Manages workflows, pods, RBAC checks" "HTTPS/443"
        apiServer -> kubernetesAPI "Creates Workflow CRs, SubjectAccessReviews" "HTTPS/443"
        apiServer -> database "Reads/writes pipeline metadata" "DB/3306|5432"
        apiServer -> objectStorage "Stores/retrieves pipeline specs and artifacts" "S3 API/9000|443"
        persistenceAgent -> kubernetesAPI "Watches Workflow status" "HTTPS/443"

        // Internal RHOAI interactions
        dspOperator -> dsp "Deploys and manages all components"
        odhDashboard -> apiServer "Pipeline management UI integration" "HTTP/8888"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "API" {
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #1168bd
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
