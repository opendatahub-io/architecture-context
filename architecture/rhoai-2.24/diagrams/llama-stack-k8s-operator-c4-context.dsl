// C4 Context Diagram - llama-stack-k8s-operator
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Platform User" "Creates LlamaStackDistribution custom resources to deploy Llama Stack servers"

        llamaStackOperator = softwareSystem "llama-stack-k8s-operator" "Kubernetes operator that manages lifecycle of Llama Stack distribution server instances" {
            reconciler = container "LlamaStackDistribution Reconciler" "Watches LlamaStackDistribution CRs, reconciles Deployments, Services, PVCs, ServiceAccounts, ClusterRoleBindings, NetworkPolicies" "Go (controller-runtime)"
            kustomizeRenderer = container "Kustomize Renderer" "Renders embedded kustomize manifests at runtime with name-prefix, namespace, and field mutations" "Go (sigs.k8s.io/kustomize)"
            clusterInfo = container "ClusterInfo" "Detects operator namespace and resolves distribution images from embedded JSON or RELATED_IMAGE env vars" "Go"
            featureFlags = container "Feature Flags" "Controls optional features (e.g., EnableNetworkPolicy) via operator ConfigMap" "Go"
            healthClient = container "Health Check Client" "Queries managed Llama Stack servers at /v1/health, /v1/providers, /v1/version" "HTTP Client"
        }

        llamaStackServer = softwareSystem "Llama Stack Server" "Managed Llama Stack distribution server instance running inference APIs" "Managed"

        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API server for resource management" "External"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys llama-stack-k8s-operator via kustomize overlays" "Internal RHOAI"
        openShiftSCC = softwareSystem "OpenShift SCC" "Security Context Constraints (anyuid) for PVC init containers" "External"
        prometheus = softwareSystem "Prometheus" "Scrapes operator metrics via kube-rbac-proxy" "External"

        // Relationships
        user -> llamaStackOperator "Creates LlamaStackDistribution CRs via kubectl"
        llamaStackOperator -> k8sAPI "CRUD operations on managed resources" "HTTPS/443, TLS 1.2+, SA Token"
        llamaStackOperator -> llamaStackServer "Health checks, provider info, version queries" "HTTP/8321"
        llamaStackOperator -> openShiftSCC "Grants anyuid SCC to managed ServiceAccounts" "RBAC"
        rhodsOperator -> llamaStackOperator "Deploys operator with RHOAI-specific image references" "Kustomize overlay"
        prometheus -> llamaStackOperator "Scrapes metrics" "HTTPS/8443, TokenReview"

        // Internal container relationships
        reconciler -> kustomizeRenderer "Renders manifests"
        reconciler -> clusterInfo "Reads namespace and image config"
        reconciler -> featureFlags "Checks feature flags"
        reconciler -> healthClient "Delegates health queries"
    }

    views {
        systemContext llamaStackOperator "SystemContext" {
            include *
            autoLayout
        }

        container llamaStackOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Managed" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
