// ODH Model Controller - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/odh-model-controller.md

workspace {
    model {
        // Actors
        datascientist = person "Data Scientist" "Creates InferenceServices to deploy ML models"
        platformadmin = person "Platform Admin" "Manages RHOAI platform and NIM accounts"
        externalclient = person "External Client" "Sends inference requests to deployed models"

        // Primary System
        odmController = softwareSystem "odh-model-controller" "Kubernetes controller managing Routes, Istio resources, NetworkPolicies, monitoring, auth, and certificates for KServe/ModelMesh InferenceServices" {
            isvcController = container "InferenceService Controller" "Watches InferenceService CRs and delegates to mode-specific reconcilers" "Go Controller"
            igController = container "InferenceGraph Controller" "Watches InferenceGraph CRs for AuthConfig reconciliation" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages monitoring RoleBindings and Ray TLS certificates" "Go Controller"
            cmController = container "ConfigMap Controller" "Manages CA bundle ConfigMaps for KServe" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connections into storage-config secret" "Go Controller"
            podController = container "Pod Controller" "Manages per-pod Ray TLS certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM integration (API keys, models, pull secrets)" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating/Validating webhooks for Pod, InferenceService, InferenceGraph, NIM Account, Knative Service" "Go HTTPS Server (9443/TCP)"
            serverlessReconciler = container "KServe Serverless Reconciler" "Creates Routes, Istio Gateways, PeerAuth, NetworkPolicies, AuthConfigs, ServiceMonitors" "Go Sub-reconciler"
            rawReconciler = container "KServe Raw Reconciler" "Creates Routes, ClusterRoleBindings, metrics Services, KEDA resources" "Go Sub-reconciler"
            mmReconciler = container "ModelMesh Reconciler" "Creates Routes, ServiceAccounts, ClusterRoleBindings for ModelMesh" "Go Sub-reconciler"
            mrReconciler = container "Model Registry Reconciler" "Optional sync of InferenceService state with Model Registry" "Go Sub-reconciler"
        }

        // Internal ODH Dependencies
        kserve = softwareSystem "KServe" "Serverless ML inference platform providing InferenceService, ServingRuntime, InferenceGraph CRDs" "Internal ODH"
        modelmesh = softwareSystem "ModelMesh Serving" "Multi-model serving platform" "Internal ODH"
        authorino = softwareSystem "Authorino" "Authentication and authorization service for inference endpoints" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for managing data science projects and data connections" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and tracks InferenceService state" "Internal ODH"
        rhodsOperator = softwareSystem "rhods-operator" "Deploys and manages odh-model-controller via kustomize" "Internal ODH"

        // External Dependencies
        istio = softwareSystem "Istio / OpenShift Service Mesh" "Service mesh for traffic management, mTLS, and telemetry" "External"
        openshiftRouter = softwareSystem "OpenShift Router" "HAProxy-based ingress for external traffic routing" "External"
        prometheus = softwareSystem "OpenShift Monitoring (Prometheus)" "Metrics collection and monitoring" "External"
        keda = softwareSystem "KEDA" "Event-driven autoscaling for KServe Raw deployments" "External"
        certManager = softwareSystem "OpenShift Service CA" "Provisions TLS certificates via annotations" "External"
        k8sAPI = softwareSystem "Kubernetes API Server" "Core Kubernetes API for all resource operations" "External"
        nvidiaNGC = softwareSystem "NVIDIA NGC API" "NVIDIA GPU Cloud for NIM model catalog and API key validation" "External"

        // Relationships - Users
        datascientist -> odmController "Creates InferenceService CRs via kubectl/Dashboard"
        platformadmin -> odmController "Creates NIM Account CRs"
        externalclient -> openshiftRouter "Sends inference requests" "HTTPS/443"

        // Relationships - Controller to Internal ODH
        odmController -> kserve "Watches InferenceService, ServingRuntime, InferenceGraph CRDs"
        odmController -> modelmesh "Creates Routes for ModelMesh InferenceServices"
        odmController -> authorino "Creates AuthConfig resources for inference endpoint auth" "HTTPS/443"
        odmController -> modelRegistry "Syncs InferenceService metadata" "HTTP(S)"
        odhDashboard -> odmController "Creates data connection secrets consumed by controller"
        rhodsOperator -> odmController "Deploys controller, injects image refs and state"

        // Relationships - Controller to External
        odmController -> istio "Manages Gateways, PeerAuthentication, Telemetry, VirtualServices" "HTTPS/443"
        odmController -> openshiftRouter "Creates OpenShift Routes for InferenceServices"
        odmController -> prometheus "Creates ServiceMonitor/PodMonitor resources"
        odmController -> keda "Creates TriggerAuthentication resources" "HTTPS/443"
        odmController -> certManager "Requests TLS certificates via annotations"
        odmController -> k8sAPI "All reconciliation operations" "HTTPS/443"
        odmController -> nvidiaNGC "Validates NIM API keys, fetches model configs" "HTTPS/443"

        // Relationships - Traffic flow
        openshiftRouter -> istio "Forwards to Istio ingress gateway" "HTTPS/8443"
        istio -> kserve "Routes to KServe predictor pods" "mTLS"

        // Internal container relationships
        isvcController -> serverlessReconciler "Delegates KServe Serverless mode"
        isvcController -> rawReconciler "Delegates KServe Raw mode"
        isvcController -> mmReconciler "Delegates ModelMesh mode"
        isvcController -> mrReconciler "Delegates Model Registry sync"
    }

    views {
        systemContext odmController "SystemContext" {
            include *
            autoLayout
        }

        container odmController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
        }
    }
}
