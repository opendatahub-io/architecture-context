// Model Registry - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/model-registry.md

workspace {
    model {
        dataScientist = person "Data Scientist" "Registers and manages ML model metadata, versions, and artifacts"
        mlEngineer = person "ML Engineer" "Deploys models and monitors inference services"

        modelRegistry = softwareSystem "Model Registry" "Central repository for ML model metadata, versions, artifacts, experiments, and inference service state" {
            proxy = container "model-registry proxy" "OpenAPI v1alpha3 REST server exposing model metadata CRUD operations" "Go REST API (go-chi)" {
                tags "Primary"
            }
            catalog = container "model-registry catalog" "Read-only API for browsing external model catalogs (e.g., HuggingFace)" "Go REST API" {
                tags "Primary"
            }
            controllerManager = container "controller-manager" "Watches KServe InferenceService CRs and syncs metadata to Model Registry" "Go Controller (controller-runtime)" {
                tags "Primary"
            }
            ui = container "model-registry-ui" "Browser-based UI for model registry management" "Web Frontend" {
                tags "Primary"
            }
            embedMD = container "EmbedMD Datastore" "Embedded metadata store connecting to MySQL or PostgreSQL" "Go Library (GORM)" {
                tags "Internal"
            }
            healthCheck = container "Health Check System" "Database and registry health checks via /readyz endpoints" "Go Module" {
                tags "Internal"
            }
        }

        kserve = softwareSystem "KServe" "Kubernetes-native serverless ML inference platform" {
            tags "Internal ODH"
        }
        istio = softwareSystem "Istio / Service Mesh" "Service mesh providing mTLS, traffic routing, and authorization" {
            tags "External"
        }
        kubeflowGateway = softwareSystem "Kubeflow Gateway" "Istio gateway for platform API ingress routing" {
            tags "Internal ODH"
        }
        mysql = softwareSystem "MySQL" "Relational database for metadata storage (v8.3+)" {
            tags "External"
        }
        postgresql = softwareSystem "PostgreSQL" "Relational database for metadata storage (v14.7+)" {
            tags "External"
        }
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" {
            tags "External"
        }
        odhDashboard = softwareSystem "ODH Dashboard" "Web UI for OpenDataHub/RHOAI platform management" {
            tags "Internal ODH"
        }
        k8sApi = softwareSystem "Kubernetes API" "Kubernetes control plane API server" {
            tags "External"
        }

        // User interactions
        dataScientist -> modelRegistry "Manages models, versions, artifacts via REST API" "HTTPS/443"
        mlEngineer -> modelRegistry "Manages inference services and serving environments" "HTTPS/443"

        // External system interactions
        modelRegistry -> mysql "Stores/retrieves metadata" "MySQL/3306 TLS 1.2+"
        modelRegistry -> postgresql "Stores/retrieves metadata" "PostgreSQL/5432 TLS 1.2+"
        modelRegistry -> istio "Uses for mTLS and authorization" "mTLS"
        kubeflowGateway -> modelRegistry "Routes /api/model_registry/ traffic" "HTTP/8080 mTLS"
        kserve -> modelRegistry "Storage initializer resolves model-registry:// URIs" "HTTP/8080 mTLS"
        controllerManager -> k8sApi "Watches InferenceService CRs, updates labels/finalizers" "HTTPS/443"
        prometheus -> modelRegistry "Scrapes controller metrics" "HTTPS/8443"
        odhDashboard -> modelRegistry "Consumes REST API for model management UI" "HTTP/8080 mTLS"

        // Internal container interactions
        proxy -> embedMD "Queries metadata store"
        embedMD -> mysql "SQL queries" "MySQL/3306"
        embedMD -> postgresql "SQL queries" "PostgreSQL/5432"
        controllerManager -> proxy "Syncs InferenceService metadata" "HTTP/8080"
        ui -> proxy "REST API calls" "HTTP/8080"
        proxy -> healthCheck "Health status"
    }

    views {
        systemContext modelRegistry "SystemContext" {
            include *
            autoLayout
        }

        container modelRegistry "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Primary" {
                background #4a90e2
                color #ffffff
            }
            element "Internal" {
                background #85bbf0
                color #000000
            }
        }
    }
}
