// C4 Context Diagram for rest-proxy
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/rest-proxy.md

workspace {
    model {
        client = person "API Client" "Sends REST inference requests using KServe V2 Predict Protocol"

        restProxy = softwareSystem "REST Proxy" "REST-to-gRPC reverse proxy translating KServe V2 REST inference requests into gRPC V2 Predict Protocol calls" {
            server = container "REST Proxy Server" "Listens on port 8008/TCP for KServe V2 REST requests" "Go HTTP Service"
            grpcGateway = container "gRPC Gateway" "Auto-generates REST-to-gRPC translation layer from proto definitions" "grpc-gateway v2.15.0"
            jsonMarshaler = container "Custom JSON Marshaler" "Handles tensor data serialization including multi-dimensional arrays and base64 bytes" "Go Package"
            grpcClient = container "gRPC Client" "Connects to local gRPC inference service" "google.golang.org/grpc v1.56.3"
        }

        modelMeshServing = softwareSystem "ModelMesh Serving" "gRPC-based model serving platform for ML inference" "Internal RHOAI"
        modelMeshOperator = softwareSystem "ModelMesh Serving Operator" "Configures and deploys ModelMesh components including rest-proxy sidecar" "Internal RHOAI"
        istio = softwareSystem "Istio / Service Mesh" "Provides traffic management, mTLS, and authorization" "External"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Kubernetes RBAC-based authentication proxy" "External"

        // Relationships
        client -> restProxy "Sends REST inference requests" "HTTP/HTTPS 8008/TCP"
        restProxy -> modelMeshServing "Forwards as gRPC requests" "gRPC/HTTP2 localhost:8033"
        modelMeshOperator -> restProxy "Configures as sidecar container" "restProxy.image in config-defaults.yaml"
        istio -> restProxy "Routes traffic, provides auth" "Service Mesh"
        kubeRBACProxy -> restProxy "Authenticates requests" "RBAC"

        // Container relationships
        server -> grpcGateway "Uses for REST-to-gRPC translation"
        grpcGateway -> jsonMarshaler "Delegates tensor serialization"
        grpcGateway -> grpcClient "Sends translated gRPC requests"
        grpcClient -> modelMeshServing "gRPC inference calls" "gRPC/HTTP2 8033/TCP"
    }

    views {
        systemContext restProxy "SystemContext" {
            include *
            autoLayout
        }

        container restProxy "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #f5a623
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
