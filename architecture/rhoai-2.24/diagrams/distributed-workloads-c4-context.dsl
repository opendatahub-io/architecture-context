// C4 Context Diagram: Distributed Workloads
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-2.24/distributed-workloads.md

workspace {
    model {
        // Users
        datascientist = person "Data Scientist" "Runs distributed training jobs and Ray workloads using RHOAI"
        ciRunner = person "CI/CD Runner" "Executes integration tests to validate the distributed workloads stack"

        // Main System
        distributedWorkloads = softwareSystem "Distributed Workloads" "Integration test suite and runtime container image definitions for the RHOAI Distributed Workloads stack" {
            testSuite = container "Integration Test Suite" "Go-based E2E tests validating Kueue, KubeRay, and KFTO functionality" "Go 1.22.2"
            rayCudaImage = container "Ray CUDA Runtime Image" "Ray cluster node image with CUDA 12.1, cuDNN 8.9, Python 3.11 on UBI9" "Container Image"
            rayRocmImage = container "Ray ROCm Runtime Image" "Ray cluster node image with ROCm 6.2, Python 3.11 on UBI9" "Container Image"
            trainingCudaImage = container "Training CUDA Runtime Image" "PyTorch distributed training image with CUDA 12.1/12.4, Flash Attention on UBI9" "Container Image"
            trainingRocmImage = container "Training ROCm Runtime Image" "PyTorch distributed training image with ROCm 6.2 on UBI9" "Container Image"
            buildPipelines = container "Konflux Build Pipelines" "Tekton PipelineRuns for building runtime container images" "Tekton"
            examples = container "Example Notebooks" "Python notebooks for LLM fine-tuning, RAG, HPO with RayTune" "Python/Jupyter"
        }

        // Internal RHOAI Dependencies
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys the RHOAI platform including distributed workloads stack" "Internal RHOAI"
        codeflareOperator = softwareSystem "CodeFlare Operator" "Manages AppWrapper CRDs for workload orchestration" "Internal RHOAI"
        kuberayOperator = softwareSystem "KubeRay Operator" "Manages Ray cluster lifecycle (RayCluster, RayJob CRDs)" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator (KFTO)" "Manages distributed PyTorch training jobs (PyTorchJob CRDs)" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queuing and resource quota management" "Internal RHOAI"
        odhNotebookController = softwareSystem "ODH Notebook Controller" "Manages Jupyter notebook workbenches" "Internal RHOAI"
        odhDashboard = softwareSystem "ODH Dashboard" "Provides notebook spawner UI" "Internal RHOAI"

        // External Dependencies
        kubernetes = softwareSystem "Kubernetes / OpenShift" "Container orchestration platform (OCP v4.15-v4.19)" "External"
        s3Storage = softwareSystem "S3-compatible Storage" "Training dataset and model artifact storage (AWS/MinIO)" "External"
        huggingFace = softwareSystem "HuggingFace Hub" "Pre-trained model downloads for fine-tuning" "External"
        prometheus = softwareSystem "Prometheus (OpenShift Monitoring)" "Metrics collection and querying" "External"
        konflux = softwareSystem "Konflux CI/CD" "Build system for container images" "External"

        // Relationships - Users
        ciRunner -> distributedWorkloads "Runs integration tests"
        datascientist -> distributedWorkloads "Uses runtime images for distributed training"

        // Relationships - Test Suite interactions
        distributedWorkloads -> kubernetes "Creates/monitors CRDs via API" "HTTPS/6443"
        distributedWorkloads -> kuberayOperator "Creates RayCluster and RayJob CRs" "HTTPS/6443 (via K8s API)"
        distributedWorkloads -> trainingOperator "Creates PyTorchJob CRs" "HTTPS/6443 (via K8s API)"
        distributedWorkloads -> kueue "Creates ClusterQueue, LocalQueue, ResourceFlavor CRs" "HTTPS/6443 (via K8s API)"
        distributedWorkloads -> odhNotebookController "Creates Notebook CRs" "HTTPS/6443 (via K8s API)"
        distributedWorkloads -> s3Storage "Upload/download training data and models" "HTTPS/443"
        distributedWorkloads -> huggingFace "Download pre-trained models" "HTTPS/443"
        distributedWorkloads -> prometheus "Query metrics for validation" "HTTPS/443"

        // Relationships - Platform
        rhodsOperator -> kuberayOperator "Deploys"
        rhodsOperator -> trainingOperator "Deploys"
        rhodsOperator -> kueue "Deploys"
        rhodsOperator -> codeflareOperator "Deploys"
        rhodsOperator -> odhNotebookController "Deploys"
        rhodsOperator -> odhDashboard "Deploys"

        // Relationships - Build
        konflux -> distributedWorkloads "Builds runtime container images"
    }

    views {
        systemContext distributedWorkloads "SystemContext" {
            include *
            autoLayout
        }

        container distributedWorkloads "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
