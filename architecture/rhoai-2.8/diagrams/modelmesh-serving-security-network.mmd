graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User/CI Pipeline]
        Client[Inference Client]
    end

    subgraph K8sAPI["KUBERNETES API SERVER"]
        APIServer["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.3<br/>Auth: Bearer Token"]
    end

    subgraph ControlPlane["CONTROL PLANE (Namespace: modelmesh-serving)"]
        Webhook["Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>K8s API cert auth<br/>Secret: modelmesh-webhook-server-cert"]

        Controller["modelmesh-controller<br/>SA: modelmesh-controller<br/>Leader Election: Enabled"]

        MetricsService["controller-manager-metrics-service<br/>8443/TCP HTTPS TLS1.2+<br/>Bearer Token auth<br/>Secret: controller-manager-metrics-tls"]
    end

    subgraph DistributedState["DISTRIBUTED STATE (Namespace: modelmesh-serving)"]
        etcd["etcd StatefulSet<br/>2379/TCP HTTP plaintext<br/>Optional Basic Auth<br/>Secret: model-serving-etcd<br/>NetworkPolicy: Allow from modelmesh namespaces"]
    end

    subgraph RuntimePods["RUNTIME PODS - Namespace: &lt;user-namespace&gt;"]
        direction TB

        subgraph Pod["Runtime Pod - Multi-container<br/>SA: modelmesh-serving-sa"]
            ModelMesh["modelmesh<br/>8033/TCP gRPC<br/>8080/TCP gRPC internal<br/>plaintext"]
            RESTProxy["rest-proxy<br/>8008/TCP HTTP<br/>plaintext<br/>Translates HTTP→gRPC"]
            Puller["storage-helper - puller<br/>8086/TCP gRPC<br/>plaintext<br/>Secret: storage-config"]
            RuntimeAdapter["runtime-adapter<br/>8085/TCP gRPC<br/>plaintext"]
            ModelServer["model-server<br/>8001/TCP gRPC<br/>plaintext"]
        end

        InferenceService["modelmesh-serving Service<br/>8033/TCP gRPC, 8008/TCP HTTP<br/>plaintext or optional mTLS<br/>NetworkPolicy: Allow from any"]

        MetricsPort["Metrics<br/>2112/TCP HTTP plaintext"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        S3["S3/Minio Storage<br/>443/TCP HTTPS TLS1.2+ or 9000/TCP HTTP<br/>Auth: AWS IAM or Access Keys"]
        Prometheus["Prometheus<br/>Scrapes metrics"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS1.3<br/>Bearer Token| APIServer
    APIServer -->|HTTPS/9443<br/>TLS1.2+<br/>K8s API cert| Webhook

    APIServer <-->|HTTPS/6443<br/>TLS1.3<br/>ServiceAccount Token| Controller
    Controller -->|HTTP/2379<br/>plaintext<br/>Optional Basic Auth| etcd

    Controller -.->|Creates| Pod

    Puller -->|HTTPS/443 or HTTP/9000<br/>TLS1.2+ or plaintext<br/>AWS IAM/Access Keys| S3

    RESTProxy -->|gRPC/8033<br/>plaintext| ModelMesh
    ModelMesh -->|gRPC/8085<br/>plaintext| RuntimeAdapter
    RuntimeAdapter -->|gRPC/8001<br/>plaintext| ModelServer
    Puller -->|gRPC/8001<br/>plaintext| ModelServer

    ModelMesh -->|HTTP/2379<br/>plaintext<br/>Optional Basic Auth| etcd

    Pod -.->|Exposes| InferenceService
    Pod -.->|Exposes| MetricsPort

    Client -->|gRPC/8033 or HTTP/8008<br/>plaintext or mTLS if mesh<br/>Auth: None - external| InferenceService

    Prometheus -->|HTTPS/8443<br/>TLS1.2+<br/>Bearer Token| MetricsService
    Prometheus -->|HTTP/2112<br/>plaintext| MetricsPort

    Controller -.->|Exposes| MetricsService

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef k8sapi fill:#d4e9ff,stroke:#0066cc,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef state fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef runtime fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#e8e8e8,stroke:#666,stroke-width:2px
    classDef container fill:#c2e0c6,stroke:#5a8f5f,stroke-width:1px

    class User,Client external
    class APIServer k8sapi
    class Webhook,Controller,MetricsService controlplane
    class etcd state
    class Pod,InferenceService,MetricsPort runtime
    class ModelMesh,RESTProxy,Puller,RuntimeAdapter,ModelServer container
    class S3,Prometheus externalservice
