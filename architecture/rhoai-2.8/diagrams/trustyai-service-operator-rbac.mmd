graph TD
    subgraph "Service Accounts"
        OperatorSA[controller-manager<br/>Namespace: operator-namespace]
        ProxySA[instance-name-proxy<br/>Namespace: user-namespace]
    end

    subgraph "ClusterRole Bindings"
        ManagerCRB[manager-role-binding<br/>Scope: Cluster]
        ProxyCRB[instance-name-namespace-proxy-rolebinding<br/>Scope: Cluster]
    end

    subgraph "Role Bindings"
        LeaderElectionRB[leader-election-role-binding<br/>Namespace: operator-namespace]
    end

    subgraph "ClusterRoles"
        ManagerRole[manager-role<br/>Cluster-wide permissions]
        ProxyRole[trustyai-service-operator-proxy-role<br/>Token review permissions]
    end

    subgraph "Roles"
        LeaderRole[leader-election-role<br/>Leader election in operator namespace]
    end

    subgraph "API Resources - Operator Management"
        direction TB
        TrustyAICR["trustyai.opendatahub.io<br/>• TrustyAIService<br/>• TrustyAIService/status<br/>• TrustyAIService/finalizers"]
        AppsCR["apps<br/>• Deployments<br/>• Deployments/status<br/>• Deployments/finalizers"]
        CoreCR["core (empty group)<br/>• Services<br/>• Pods<br/>• ConfigMaps<br/>• Secrets<br/>• PersistentVolumeClaims<br/>• ServiceAccounts<br/>• Events"]
        CorePV["core<br/>• PersistentVolumes<br/>(read-only)"]
        MonitoringCR["monitoring.coreos.com<br/>• ServiceMonitors"]
        RoutesCR["route.openshift.io<br/>• Routes"]
        KServeCR["serving.kserve.io<br/>• InferenceServices<br/>• InferenceServices/finalizers<br/>• ServingRuntimes<br/>• ServingRuntimes/status"]
        RBACCR["rbac.authorization.k8s.io<br/>• ClusterRoleBindings"]
    end

    subgraph "API Resources - OAuth Proxy"
        direction TB
        TokenReview["authentication.k8s.io<br/>• TokenReviews"]
        SAR["authorization.k8s.io<br/>• SubjectAccessReviews"]
    end

    subgraph "API Resources - Leader Election"
        direction TB
        ConfigMaps["core<br/>• ConfigMaps"]
        Leases["coordination.k8s.io<br/>• Leases"]
        Events["core<br/>• Events"]
    end

    %% Service Account bindings
    OperatorSA -->|bound via| ManagerCRB
    OperatorSA -->|bound via| LeaderElectionRB
    ProxySA -->|bound via| ProxyCRB

    %% Role bindings to roles
    ManagerCRB -->|grants| ManagerRole
    ProxyCRB -->|grants| ProxyRole
    LeaderElectionRB -->|grants| LeaderRole

    %% Manager role permissions
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| TrustyAICR
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| AppsCR
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| CoreCR
    ManagerRole -->|"get, list, watch"| CorePV
    ManagerRole -->|"create, list, watch"| MonitoringCR
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| RoutesCR
    ManagerRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| KServeCR
    ManagerRole -->|"get, list, watch,<br/>create, update, delete"| RBACCR

    %% Proxy role permissions
    ProxyRole -->|create| TokenReview
    ProxyRole -->|create| SAR

    %% Leader election role permissions
    LeaderRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| ConfigMaps
    LeaderRole -->|"get, list, watch,<br/>create, update,<br/>patch, delete"| Leases
    LeaderRole -->|"create, patch"| Events

    %% Styling
    style OperatorSA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style ProxySA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style ProxyRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style LeaderRole fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style ManagerCRB fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ProxyCRB fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style LeaderElectionRB fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style TrustyAICR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style AppsCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style CoreCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style CorePV fill:#e8e8e8,stroke:#666,stroke-width:1px
    style MonitoringCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style RoutesCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style KServeCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style RBACCR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style TokenReview fill:#e8e8e8,stroke:#666,stroke-width:1px
    style SAR fill:#e8e8e8,stroke:#666,stroke-width:1px
    style ConfigMaps fill:#e8e8e8,stroke:#666,stroke-width:1px
    style Leases fill:#e8e8e8,stroke:#666,stroke-width:1px
    style Events fill:#e8e8e8,stroke:#666,stroke-width:1px
