graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS 1.2+ Termination"]
        Route["Route Resource<br/>{username}-notebook-{namespace}.apps.{cluster}<br/>TLS Mode: edge"]
    end

    subgraph NotebookPod["NOTEBOOK POD<br/>Namespace: {user-namespace}"]
        direction TB
        OAuth["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>OpenShift OAuth<br/>SA: {username}-notebook-sa"]
        Jupyter["Jupyter Server<br/>8888/TCP HTTP<br/>JupyterLab 3.6 + Elyra<br/>Image: jupyter-datascience-ubi9-python-3.9"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PyPI["PyPI Repository<br/>pypi.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: None"]
        Git["Git Repositories<br/>github.com, gitlab.com<br/>443/TCP HTTPS or 22/TCP SSH<br/>Auth: PAT or SSH Key"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: AWS Signature V4<br/>Secret: {username}-s3-credentials"]
        Database["Database Endpoint<br/>5432/TCP PostgreSQL<br/>3306/TCP MySQL<br/>TLS 1.2+ optional<br/>Auth: Username + Password"]
        Registry["Container Registry<br/>quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: Pull Secret"]
    end

    subgraph InternalServices["INTERNAL CLUSTER SERVICES"]
        K8sAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>Auth: ServiceAccount Token<br/>RoleBinding: edit role"]
        KFP["Kubeflow Pipelines API<br/>8888/TCP HTTP<br/>plaintext (internal)<br/>Auth: Bearer Token"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP<br/>plaintext (internal)<br/>Auth: ServiceAccount Token"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>No Auth| Router
    Router --> Route
    Route -->|HTTPS/8443<br/>OpenShift OAuth| OAuth
    OAuth -->|HTTP/8888<br/>plaintext<br/>localhost trusted| Jupyter

    %% Egress to External Services
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>pip install| PyPI
    Jupyter -->|HTTPS/443 or SSH/22<br/>TLS 1.2+ or SSH<br/>PAT or SSH Key| Git
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>AWS Signature V4| S3
    Jupyter -->|PostgreSQL/5432<br/>MySQL/3306<br/>TLS 1.2+ optional| Database
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Registry

    %% Egress to Internal Services
    Jupyter -->|HTTPS/6443<br/>TLS 1.3<br/>ServiceAccount Token| K8sAPI
    Jupyter -->|HTTP/8888<br/>plaintext<br/>Bearer Token| KFP
    Jupyter -->|HTTP/8080<br/>plaintext<br/>ServiceAccount Token| ModelRegistry

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef pod fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef internalservice fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Router,Route ingress
    class OAuth,Jupyter pod
    class PyPI,Git,S3,Database,Registry externalservice
    class K8sAPI,KFP,ModelRegistry internalservice
