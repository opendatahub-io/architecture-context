graph TD
    subgraph "Service Accounts"
        NotebookSA["{username}-notebook-sa<br/>Namespace: {user-namespace}"]
        ControllerSA["notebook-controller-sa<br/>Namespace: opendatahub"]
    end

    subgraph "Cluster Role Bindings"
        CRB[notebook-controller-rolebinding]
    end

    subgraph "Cluster Role Permissions"
        CR[notebook-controller-role]
    end

    subgraph "Namespace Role Bindings"
        NRB["{username}-notebook-sa<br/>→ edit role"]
    end

    subgraph "API Resources - Core"
        Pods[core/Pods]
        Services[core/Services]
        ServiceAccounts[core/ServiceAccounts]
        ConfigMaps[core/ConfigMaps]
        Secrets[core/Secrets]
        PVCs[core/PersistentVolumeClaims]
    end

    subgraph "API Resources - Apps"
        StatefulSets[apps/StatefulSets]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io/Routes]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies[networking.k8s.io/NetworkPolicies]
    end

    subgraph "Notebook Controller Permissions"
        ControllerSA -->|bound via| CRB
        CRB -->|grants| CR
        CR -->|get, list, create, delete, patch| Pods
        CR -->|get, list, create, delete, patch| Services
        CR -->|get, list, create, delete, patch| ServiceAccounts
        CR -->|get, list, create, delete, patch| ConfigMaps
        CR -->|get, list, create, delete, patch| Secrets
        CR -->|get, list, create, delete, patch| PVCs
        CR -->|get, list, create, delete, patch| StatefulSets
        CR -->|get, list, create, delete, patch| Routes
        CR -->|get, list, create, delete, patch| NetworkPolicies
    end

    subgraph "Notebook Pod Permissions"
        NotebookSA -->|bound via| NRB
        NRB -->|grants edit role| NotebookNamespace["Namespace: user-namespace"]
        NotebookNamespace -->|full CRUD access| NamespaceResources["All namespace resources<br/>pods, services, configmaps, secrets, etc."]
    end

    subgraph "OAuth Authentication"
        OAuth[OAuth Proxy Sidecar]
        OAuth -->|enforces| OAuthPolicy[Namespace RBAC<br/>User must have access to namespace]
        OAuthPolicy -->|validates| NotebookSA
    end

    style NotebookSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style ControllerSA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:2px
    style NRB fill:#f5a623,stroke:#333,stroke-width:2px
    style Pods fill:#7ed321,stroke:#333
    style Services fill:#7ed321,stroke:#333
    style Routes fill:#7ed321,stroke:#333
    style OAuth fill:#e8e8e8,stroke:#333
