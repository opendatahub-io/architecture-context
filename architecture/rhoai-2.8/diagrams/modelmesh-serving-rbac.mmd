graph TD
    subgraph "Service Accounts"
        SA_Controller[modelmesh-controller<br/>Namespace: modelmesh-serving]
        SA_Runtime["modelmesh-serving-sa<br/>Namespace: &lt;user-namespace&gt;"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[modelmesh-controller-rolebinding<br/>Cluster-scoped]
        RB_LeaderElection[leader-election-rolebinding<br/>Namespace: modelmesh-serving]
        RB_AuthProxy[auth-proxy-rolebinding<br/>Namespace: modelmesh-serving]
    end

    subgraph "ClusterRoles"
        CR_Controller[modelmesh-controller-role<br/>Cluster-scoped]
        CR_LeaderElection[leader-election-role]
        CR_AuthProxy[auth-proxy-role]
        CR_PredictorEditor[predictor-editor-role<br/>User role]
        CR_ServingRuntimeEditor[servingruntime-editor-role<br/>User role]
        CR_InferenceServiceEditor[inferenceservice-editor-role<br/>User role]
    end

    subgraph "API Resources - Core (v1)"
        Core_ConfigMaps[ConfigMaps]
        Core_Secrets[Secrets]
        Core_Services[Services]
        Core_Namespaces[Namespaces]
        Core_Endpoints[Endpoints]
        Core_PVCs[PersistentVolumeClaims]
    end

    subgraph "API Resources - Apps (v1)"
        Apps_Deployments[Deployments]
    end

    subgraph "API Resources - serving.kserve.io"
        KServe_Predictors[Predictors<br/>v1alpha1]
        KServe_ServingRuntimes[ServingRuntimes<br/>v1alpha1]
        KServe_ClusterServingRuntimes[ClusterServingRuntimes<br/>v1alpha1]
        KServe_InferenceServices[InferenceServices<br/>v1beta1]
    end

    subgraph "API Resources - Autoscaling"
        Autoscaling_HPAs[HorizontalPodAutoscalers]
    end

    subgraph "API Resources - Monitoring"
        Monitoring_ServiceMonitors[ServiceMonitors<br/>monitoring.coreos.com]
    end

    subgraph "API Resources - Coordination"
        Coordination_Leases[Leases<br/>coordination.k8s.io]
    end

    subgraph "API Resources - Auth"
        Auth_TokenReviews[TokenReviews<br/>authentication.k8s.io]
        Auth_SubjectAccessReviews[SubjectAccessReviews<br/>authorization.k8s.io]
    end

    %% Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| RB_LeaderElection
    SA_Controller -->|bound via| RB_AuthProxy

    CRB_Controller -->|grants| CR_Controller
    RB_LeaderElection -->|grants| CR_LeaderElection
    RB_AuthProxy -->|grants| CR_AuthProxy

    %% Controller Role Permissions
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Core_ConfigMaps
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Core_Secrets
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Core_Services
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Core_Namespaces
    CR_Controller -->|get, list, watch| Core_Endpoints
    CR_Controller -->|get, list, watch| Core_PVCs
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Apps_Deployments
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| KServe_Predictors
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| KServe_ServingRuntimes
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| KServe_ClusterServingRuntimes
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| KServe_InferenceServices
    CR_Controller -->|get, patch, update<br/>status subresource| KServe_Predictors
    CR_Controller -->|get, patch, update<br/>status subresource| KServe_ServingRuntimes
    CR_Controller -->|get, patch, update<br/>status subresource| KServe_ClusterServingRuntimes
    CR_Controller -->|get, patch, update<br/>status subresource| KServe_InferenceServices
    CR_Controller -->|get, patch, update<br/>finalizers subresource| KServe_Predictors
    CR_Controller -->|get, patch, update<br/>finalizers subresource| KServe_ServingRuntimes
    CR_Controller -->|get, patch, update<br/>finalizers subresource| KServe_ClusterServingRuntimes
    CR_Controller -->|get, patch, update<br/>finalizers subresource| KServe_InferenceServices
    CR_Controller -->|create, delete, get,<br/>list, update, watch| Autoscaling_HPAs
    CR_Controller -->|create, delete, get,<br/>list, patch, update, watch| Monitoring_ServiceMonitors

    %% Leader Election Role Permissions
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| Core_ConfigMaps
    CR_LeaderElection -->|get, list, watch,<br/>create, update, patch, delete| Coordination_Leases

    %% Auth Proxy Role Permissions
    CR_AuthProxy -->|create| Auth_TokenReviews
    CR_AuthProxy -->|create| Auth_SubjectAccessReviews

    %% User Editor Roles (for end users)
    CR_PredictorEditor -->|create, delete, get,<br/>list, patch, update, watch| KServe_Predictors
    CR_ServingRuntimeEditor -->|create, delete, get,<br/>list, patch, update, watch| KServe_ServingRuntimes
    CR_InferenceServiceEditor -->|create, delete, get,<br/>list, patch, update, watch| KServe_InferenceServices

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#e8e8e8,stroke:#333,stroke-width:1px
    classDef userRole fill:#b8e986,stroke:#333,stroke-width:2px

    class SA_Controller,SA_Runtime serviceAccount
    class CRB_Controller,RB_LeaderElection,RB_AuthProxy binding
    class CR_Controller,CR_LeaderElection,CR_AuthProxy role
    class CR_PredictorEditor,CR_ServingRuntimeEditor,CR_InferenceServiceEditor userRole
    class Core_ConfigMaps,Core_Secrets,Core_Services,Core_Namespaces,Core_Endpoints,Core_PVCs resource
    class Apps_Deployments resource
    class KServe_Predictors,KServe_ServingRuntimes,KServe_ClusterServingRuntimes,KServe_InferenceServices resource
    class Autoscaling_HPAs,Monitoring_ServiceMonitors,Coordination_Leases resource
    class Auth_TokenReviews,Auth_SubjectAccessReviews resource
