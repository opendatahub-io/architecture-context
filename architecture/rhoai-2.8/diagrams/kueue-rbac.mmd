graph TD
    subgraph "Service Accounts"
        SA[controller-manager<br/>Namespace: kueue-system]
    end

    subgraph "ClusterRole Bindings"
        ManagerBinding[manager-rolebinding<br/>ClusterRoleBinding]
        AuthProxyBinding[auth-proxy-rolebinding<br/>RoleBinding]
        LeaderElectionBinding[leader-election-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRoles"
        ManagerRole[manager-role<br/>ClusterRole]
        AuthProxyRole[auth-proxy-client-clusterrole<br/>ClusterRole]
        LeaderElectionRole[leader-election-role<br/>Role]
    end

    subgraph "Core API Resources"
        Events[events<br/>create, patch, update, watch]
        LimitRanges[limitranges, namespaces<br/>get, list, watch]
        Pods[pods<br/>delete, get, list, patch, update, watch]
        PodFinalizers[pods/finalizers<br/>get, update]
        PodStatus[pods/status<br/>get, patch]
        PodTemplates[podtemplates<br/>create, delete, get, list, update, watch]
        Secrets[secrets<br/>get, list, update, watch]
    end

    subgraph "Admission Registration"
        Webhooks[mutatingwebhookconfigurations<br/>validatingwebhookconfigurations<br/>get, list, update, watch]
    end

    subgraph "Autoscaling API"
        ProvReq[provisioningrequests<br/>autoscaling.x-k8s.io<br/>create, delete, get, list, patch, update, watch]
    end

    subgraph "Batch API"
        Jobs[jobs<br/>batch<br/>get, list, patch, update, watch]
        JobFinalizers[jobs/finalizers<br/>get, patch, update]
        JobStatus[jobs/status<br/>get, update]
    end

    subgraph "Kueue CRDs"
        direction TB
        AdmissionChecks[admissionchecks<br/>create, delete, get, list, patch, update, watch]
        ClusterQueues[clusterqueues<br/>create, delete, get, list, patch, update, watch]
        LocalQueues[localqueues<br/>create, delete, get, list, patch, update, watch]
        ProvReqConfigs[provisioningrequestconfigs<br/>create, delete, get, list, patch, update, watch]
        ResourceFlavors[resourceflavors<br/>create, delete, get, list, patch, update, watch]
        Workloads[workloads<br/>create, delete, get, list, patch, update, watch]
        WorkloadPriorities[workloadpriorityclasses<br/>create, delete, get, list, patch, update, watch]

        KueueFinalizers[*/finalizers<br/>update]
        KueueStatus[*/status<br/>get, patch, update]
    end

    subgraph "Kubeflow Training Jobs"
        direction TB
        MPIJobs[mpijobs<br/>kubeflow.org<br/>get, list, patch, update, watch]
        MXJobs[mxjobs<br/>get, list, patch, update, watch]
        PaddleJobs[paddlejobs<br/>get, list, patch, update, watch]
        PyTorchJobs[pytorchjobs<br/>get, list, patch, update, watch]
        TFJobs[tfjobs<br/>get, list, patch, update, watch]
        XGBoostJobs[xgboostjobs<br/>get, list, patch, update, watch]

        TrainingFinalizers[*/finalizers<br/>get, patch, update]
        TrainingStatus[*/status<br/>get, update]
    end

    subgraph "Ray Workloads"
        RayClusters[rayclusters<br/>ray.io<br/>get, list, patch, update, watch]
        RayJobs[rayjobs<br/>get, list, patch, update, watch]

        RayFinalizers[*/finalizers<br/>get, patch, update]
        RayStatus[*/status<br/>get, update]
    end

    subgraph "JobSet"
        JobSets[jobsets<br/>jobset.x-k8s.io<br/>get, list, patch, update, watch]
        JobSetFinalizers[jobsets/finalizers<br/>get, patch, update]
        JobSetStatus[jobsets/status<br/>get]
    end

    subgraph "Leader Election Resources"
        ConfigMaps[configmaps<br/>get, list, watch, create, update, patch, delete]
        Leases[leases<br/>coordination.k8s.io<br/>get, list, watch, create, update, patch, delete]
        LeaderEvents[events<br/>create, patch]
    end

    subgraph "Auth Proxy Resources"
        TokenReviews[tokenreviews<br/>authentication.k8s.io<br/>create]
        SubjectAccessReviews[subjectaccessreviews<br/>authorization.k8s.io<br/>create]
    end

    subgraph "User/Tenant Roles"
        BatchAdmin[batch-admin-role<br/>ClusterRole]
        BatchUser[batch-user-role<br/>ClusterRole]
        CQEditor[clusterqueue-editor-role<br/>ClusterRole]
        CQViewer[clusterqueue-viewer-role<br/>ClusterRole]
        LQEditor[localqueue-editor-role<br/>ClusterRole]
        LQViewer[localqueue-viewer-role<br/>ClusterRole]
        RFEditor[resourceflavor-editor-role<br/>ClusterRole]
        RFViewer[resourceflavor-viewer-role<br/>ClusterRole]
        WLEditor[workload-editor-role<br/>ClusterRole]
        WLViewer[workload-viewer-role<br/>ClusterRole]
    end

    %% Service Account to Bindings
    SA -->|bound via| ManagerBinding
    SA -->|bound via| AuthProxyBinding
    SA -->|bound via| LeaderElectionBinding

    %% Bindings to Roles
    ManagerBinding -->|grants| ManagerRole
    AuthProxyBinding -->|grants| AuthProxyRole
    LeaderElectionBinding -->|grants| LeaderElectionRole

    %% Manager Role Permissions
    ManagerRole -->|permissions| Events
    ManagerRole -->|permissions| LimitRanges
    ManagerRole -->|permissions| Pods
    ManagerRole -->|permissions| PodFinalizers
    ManagerRole -->|permissions| PodStatus
    ManagerRole -->|permissions| PodTemplates
    ManagerRole -->|permissions| Secrets
    ManagerRole -->|permissions| Webhooks
    ManagerRole -->|permissions| ProvReq
    ManagerRole -->|permissions| Jobs
    ManagerRole -->|permissions| JobFinalizers
    ManagerRole -->|permissions| JobStatus
    ManagerRole -->|permissions| AdmissionChecks
    ManagerRole -->|permissions| ClusterQueues
    ManagerRole -->|permissions| LocalQueues
    ManagerRole -->|permissions| ProvReqConfigs
    ManagerRole -->|permissions| ResourceFlavors
    ManagerRole -->|permissions| Workloads
    ManagerRole -->|permissions| WorkloadPriorities
    ManagerRole -->|permissions| KueueFinalizers
    ManagerRole -->|permissions| KueueStatus
    ManagerRole -->|permissions| MPIJobs
    ManagerRole -->|permissions| MXJobs
    ManagerRole -->|permissions| PaddleJobs
    ManagerRole -->|permissions| PyTorchJobs
    ManagerRole -->|permissions| TFJobs
    ManagerRole -->|permissions| XGBoostJobs
    ManagerRole -->|permissions| TrainingFinalizers
    ManagerRole -->|permissions| TrainingStatus
    ManagerRole -->|permissions| RayClusters
    ManagerRole -->|permissions| RayJobs
    ManagerRole -->|permissions| RayFinalizers
    ManagerRole -->|permissions| RayStatus
    ManagerRole -->|permissions| JobSets
    ManagerRole -->|permissions| JobSetFinalizers
    ManagerRole -->|permissions| JobSetStatus

    %% Leader Election Role Permissions
    LeaderElectionRole -->|permissions| ConfigMaps
    LeaderElectionRole -->|permissions| Leases
    LeaderElectionRole -->|permissions| LeaderEvents

    %% Auth Proxy Role Permissions
    AuthProxyRole -->|permissions| TokenReviews
    AuthProxyRole -->|permissions| SubjectAccessReviews

    %% User Role Relationships (simplified)
    BatchAdmin -.->|full access| Jobs
    BatchAdmin -.->|read access| LocalQueues
    BatchUser -.->|read-only| Jobs
    BatchUser -.->|read-only| LocalQueues

    CQEditor -.->|full access| ClusterQueues
    CQViewer -.->|read-only| ClusterQueues

    LQEditor -.->|full access| LocalQueues
    LQViewer -.->|read-only| LocalQueues

    RFEditor -.->|full access| ResourceFlavors
    RFViewer -.->|read-only| ResourceFlavors

    WLEditor -.->|full access| Workloads
    WLViewer -.->|read-only| Workloads

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px
    style AuthProxyRole fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderElectionRole fill:#f5a623,stroke:#333,stroke-width:2px

    style ManagerBinding fill:#7ed321,stroke:#333
    style AuthProxyBinding fill:#7ed321,stroke:#333
    style LeaderElectionBinding fill:#7ed321,stroke:#333

    style AdmissionChecks fill:#d4e6f1,stroke:#333
    style ClusterQueues fill:#d4e6f1,stroke:#333
    style LocalQueues fill:#d4e6f1,stroke:#333
    style Workloads fill:#d4e6f1,stroke:#333
    style ResourceFlavors fill:#d4e6f1,stroke:#333

    style MPIJobs fill:#fff9e6,stroke:#333
    style PyTorchJobs fill:#fff9e6,stroke:#333
    style TFJobs fill:#fff9e6,stroke:#333
    style RayJobs fill:#fff9e6,stroke:#333
    style RayClusters fill:#fff9e6,stroke:#333

    style BatchAdmin fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style BatchUser fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style CQEditor fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style CQViewer fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style LQEditor fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
    style LQViewer fill:#e8e8e8,stroke:#333,stroke-dasharray: 5 5
