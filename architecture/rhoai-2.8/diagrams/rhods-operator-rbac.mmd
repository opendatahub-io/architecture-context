graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: redhat-ods-operator]
        SA_Prometheus[prometheus<br/>Namespace: redhat-ods-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[controller-manager-rolebinding<br/>Cluster-wide]
        CRB_Prometheus[prometheus-scraper<br/>Cluster-wide]
    end

    subgraph "ClusterRoles"
        CR_Controller[controller-manager-role<br/>Extensive permissions]
        CR_Prometheus[prometheus-scraper<br/>Read-only monitoring]
    end

    subgraph "API Resources - ODH/RHOAI CRDs"
        DSC[datasciencecluster.opendatahub.io<br/>DataScienceCluster]
        DSCI[dscinitialization.opendatahub.io<br/>DSCInitialization]
        FT[features.opendatahub.io<br/>FeatureTracker]
        DSPA[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
    end

    subgraph "API Resources - Core K8s"
        ConfigMaps[core<br/>ConfigMaps, Secrets, Services<br/>ServiceAccounts, PVCs<br/>Namespaces, Events]
        Apps[apps<br/>Deployments, ReplicaSets<br/>StatefulSets]
        RBAC[rbac.authorization.k8s.io<br/>Roles, RoleBindings<br/>ClusterRoles, ClusterRoleBindings]
        Batch[batch<br/>Jobs, CronJobs]
        Networking[networking.k8s.io<br/>NetworkPolicies]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io<br/>Routes]
        Console[console.openshift.io<br/>ConsoleLinks, ODHQuickStarts]
        Config[config.openshift.io<br/>ClusterVersions, Ingresses]
    end

    subgraph "API Resources - Service Mesh"
        Istio[networking.istio.io<br/>VirtualServices, Gateways<br/>DestinationRules<br/>AuthorizationPolicies]
    end

    subgraph "API Resources - Serving"
        KServe[serving.kserve.io<br/>InferenceServices<br/>ServingRuntimes<br/>ClusterServingRuntimes<br/>InferenceGraphs]
        Knative[serving.knative.dev<br/>Services, Revisions<br/>Configurations, Routes]
    end

    subgraph "API Resources - Monitoring"
        Monitoring[monitoring.coreos.com<br/>ServiceMonitors<br/>PrometheusRules<br/>PodMonitors]
    end

    subgraph "API Resources - Other"
        Admission[admissionregistration.k8s.io<br/>MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations]
        CRD[apiextensions.k8s.io<br/>CustomResourceDefinitions]
        CertMgr[cert-manager.io<br/>Certificates, Issuers]
        KFDef[kfdef.apps.kubeflow.org<br/>KFDefs]
        Auth[authorization.k8s.io<br/>SubjectAccessReviews<br/>TokenReviews]
    end

    subgraph "Monitoring Resources"
        MonitoringRes[core<br/>Endpoints, Services, Pods<br/>Read-only for scraping]
    end

    %% Service Account to ClusterRoleBinding
    SA_Controller -->|bound via| CRB_Controller
    SA_Prometheus -->|bound via| CRB_Prometheus

    %% ClusterRoleBinding to ClusterRole
    CRB_Controller -->|grants| CR_Controller
    CRB_Prometheus -->|grants| CR_Prometheus

    %% ClusterRole to Resources - Controller Manager
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch<br/>+ status,finalizers| DSC
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch<br/>+ status,finalizers| DSCI
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch<br/>+ status| FT
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| DSPA

    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| ConfigMaps
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Apps
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| RBAC
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Batch
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Networking

    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Routes
    CR_Controller -->|create,delete,get,patch| Console
    CR_Controller -->|get,list,watch| Config

    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Istio
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| KServe
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Knative
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Monitoring

    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| Admission
    CR_Controller -->|create,delete,get,list<br/>patch,watch| CRD
    CR_Controller -->|create,patch| CertMgr
    CR_Controller -->|create,delete,get,list<br/>patch,update,watch| KFDef
    CR_Controller -->|create,get| Auth

    %% ClusterRole to Resources - Prometheus
    CR_Prometheus -->|get,list,watch| MonitoringRes
    CR_Prometheus -->|get,list| Monitoring

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Prometheus fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Controller fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CR_Prometheus fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CRB_Controller fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    style CRB_Prometheus fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    style DSC fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style DSCI fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style FT fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style DSPA fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style ConfigMaps fill:#d0d0d0,stroke:#333,stroke-width:1px,color:#000
    style Apps fill:#d0d0d0,stroke:#333,stroke-width:1px,color:#000
    style RBAC fill:#d0d0d0,stroke:#333,stroke-width:1px,color:#000
    style Batch fill:#d0d0d0,stroke:#333,stroke-width:1px,color:#000
    style Networking fill:#d0d0d0,stroke:#333,stroke-width:1px,color:#000

    style Routes fill:#c00,stroke:#333,stroke-width:1px,color:#fff
    style Console fill:#c00,stroke:#333,stroke-width:1px,color:#fff
    style Config fill:#c00,stroke:#333,stroke-width:1px,color:#fff

    style Istio fill:#466bb0,stroke:#333,stroke-width:1px,color:#fff
    style KServe fill:#0865ad,stroke:#333,stroke-width:1px,color:#fff
    style Knative fill:#0865ad,stroke:#333,stroke-width:1px,color:#fff
    style Monitoring fill:#e6522c,stroke:#333,stroke-width:1px,color:#fff

    style Admission fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff
    style CRD fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff
    style CertMgr fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff
    style KFDef fill:#0865ad,stroke:#333,stroke-width:1px,color:#fff
    style Auth fill:#326ce5,stroke:#333,stroke-width:1px,color:#fff

