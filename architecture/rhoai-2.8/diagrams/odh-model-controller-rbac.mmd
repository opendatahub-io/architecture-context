graph TD
    subgraph "Service Accounts"
        SA_Controller[odh-model-controller<br/>Namespace: redhat-ods-applications]
        SA_Prometheus[prometheus-custom<br/>Namespace: openshift-monitoring]
    end

    subgraph "ClusterRole Bindings"
        CRB_Controller[odh-model-controller-rolebinding<br/>ClusterRoleBinding<br/>Cluster-wide]
        CRB_LeaderElection[leader-election-rolebinding<br/>RoleBinding<br/>Namespace: controller namespace]
    end

    subgraph "Roles & ClusterRoles"
        CR_Controller[odh-model-controller-role<br/>ClusterRole]
        R_LeaderElection[leader-election-role<br/>Role]
        CR_Prometheus[kserve-prometheus-k8s<br/>ClusterRole]
    end

    subgraph "API Resources - KServe & Serving"
        InferenceService[serving.kserve.io<br/>InferenceService<br/>+ finalizers]
        ServingRuntime[serving.kserve.io<br/>ServingRuntime<br/>+ finalizers]
    end

    subgraph "API Resources - OpenShift"
        Routes[route.openshift.io<br/>Route<br/>+ custom-host]
    end

    subgraph "API Resources - Istio & Service Mesh"
        VirtualService[networking.istio.io<br/>VirtualService]
        PeerAuth[security.istio.io<br/>PeerAuthentication]
        Telemetry[telemetry.istio.io<br/>Telemetry]
        SMMR[maistra.io<br/>ServiceMeshMemberRoll]
        SMM[maistra.io<br/>ServiceMeshMember]
        SMCP[maistra.io<br/>ServiceMeshControlPlane]
    end

    subgraph "API Resources - Monitoring"
        ServiceMonitor[monitoring.coreos.com<br/>ServiceMonitor]
        PodMonitor[monitoring.coreos.com<br/>PodMonitor]
    end

    subgraph "API Resources - Networking"
        NetworkPolicy[networking.k8s.io<br/>NetworkPolicy]
        Ingress[networking.k8s.io<br/>Ingress]
    end

    subgraph "API Resources - RBAC"
        ClusterRoleBindings[rbac.authorization.k8s.io<br/>ClusterRoleBinding]
        RoleBindings[rbac.authorization.k8s.io<br/>RoleBinding]
    end

    subgraph "API Resources - Core"
        ConfigMaps[core<br/>ConfigMap]
        Secrets[core<br/>Secret]
        ServiceAccounts[core<br/>ServiceAccount]
        Namespaces[core<br/>Namespace]
        Pods[core<br/>Pod]
        Services[core<br/>Service]
        Endpoints[core<br/>Endpoint]
    end

    subgraph "API Resources - Apps"
        Deployments[apps<br/>Deployment]
        StatefulSets[apps<br/>StatefulSet]
    end

    subgraph "API Resources - Coordination"
        Leases[coordination.k8s.io<br/>Lease]
    end

    subgraph "Prometheus Monitoring Resources"
        PrometheusResources[core<br/>Services, Endpoints, Pods<br/>In user namespaces]
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Controller
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Prometheus -->|bound via| RoleBindings

    %% Bindings to Roles
    CRB_Controller -->|grants| CR_Controller
    CRB_LeaderElection -->|grants| R_LeaderElection
    RoleBindings -->|grants| CR_Prometheus

    %% Controller ClusterRole Permissions
    CR_Controller -->|get, list, watch, create, update, patch, delete| InferenceService
    CR_Controller -->|get, list, watch, create, update, patch, delete| ServingRuntime
    CR_Controller -->|create, delete, get, list, patch, update, watch| Routes
    CR_Controller -->|create, delete, get, list, patch, update, watch| VirtualService
    CR_Controller -->|create, delete, get, list, patch, update, watch| PeerAuth
    CR_Controller -->|create, delete, get, list, patch, update, watch| Telemetry
    CR_Controller -->|create, delete, get, list, patch, update, watch| SMMR
    CR_Controller -->|create, delete, get, list, patch, update, watch| SMM
    CR_Controller -->|create, get, list, patch, update, use, watch| SMCP
    CR_Controller -->|create, delete, get, list, patch, update, watch| ServiceMonitor
    CR_Controller -->|create, delete, get, list, patch, update, watch| PodMonitor
    CR_Controller -->|create, delete, get, list, patch, update, watch| NetworkPolicy
    CR_Controller -->|get, list, watch| Ingress
    CR_Controller -->|create, delete, get, list, patch, update, watch| ClusterRoleBindings
    CR_Controller -->|create, delete, get, list, patch, update, watch| RoleBindings
    CR_Controller -->|create, delete, get, list, patch, update, watch| ConfigMaps
    CR_Controller -->|create, delete, get, list, patch, update, watch| Secrets
    CR_Controller -->|create, delete, get, list, patch, update, watch| ServiceAccounts
    CR_Controller -->|create, get, list, patch, update, watch| Namespaces
    CR_Controller -->|create, get, list, patch, update, watch| Pods
    CR_Controller -->|create, get, list, patch, update, watch| Services
    CR_Controller -->|create, get, list, patch, update, watch| Endpoints
    CR_Controller -->|delete, get, list| Deployments
    CR_Controller -->|delete, get, list| StatefulSets

    %% Leader Election Role Permissions
    R_LeaderElection -->|get, list, watch, create, update, patch| ConfigMaps
    R_LeaderElection -->|get, list, watch, create, update, patch| Leases

    %% Prometheus ClusterRole Permissions
    CR_Prometheus -->|get, list, watch| PrometheusResources

    %% Styling
    classDef serviceaccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px
    classDef resource fill:#e8e8e8,stroke:#333,stroke-width:1px

    class SA_Controller,SA_Prometheus serviceaccount
    class CRB_Controller,CRB_LeaderElection binding
    class CR_Controller,R_LeaderElection,CR_Prometheus role
    class InferenceService,ServingRuntime,Routes,VirtualService,PeerAuth,Telemetry,SMMR,SMM,SMCP,ServiceMonitor,PodMonitor,NetworkPolicy,Ingress,ClusterRoleBindings,RoleBindings,ConfigMaps,Secrets,ServiceAccounts,Namespaces,Pods,Services,Endpoints,Deployments,StatefulSets,Leases,PrometheusResources resource
