graph TB
    subgraph "Kueue Component"
        Controller[kueue-controller-manager<br/>Deployment]
        Webhook[Webhook Server<br/>Port: 9443/TCP HTTPS]
        Visibility[Visibility API Server<br/>Port: 8082/TCP HTTPS]
        Metrics[Metrics Endpoint<br/>Port: 8080/TCP HTTP]
        RBACProxy[kube-rbac-proxy<br/>Port: 8443/TCP HTTPS]

        Controller -->|serves| Webhook
        Controller -->|serves| Visibility
        Controller -->|exposes| Metrics
        RBACProxy -->|protects| Metrics

        subgraph "Internal Controllers"
            ClusterQueueCtrl[ClusterQueue Controller]
            LocalQueueCtrl[LocalQueue Controller]
            WorkloadCtrl[Workload Controller]
            AdmissionCheckCtrl[AdmissionCheck Controller]
            ResourceFlavorCtrl[ResourceFlavor Controller]
            MultiKueueCtrl[MultiKueue Controller]
        end

        Controller -->|runs| ClusterQueueCtrl
        Controller -->|runs| LocalQueueCtrl
        Controller -->|runs| WorkloadCtrl
        Controller -->|runs| AdmissionCheckCtrl
        Controller -->|runs| ResourceFlavorCtrl
        Controller -->|runs| MultiKueueCtrl
    end

    subgraph "Custom Resources (CRDs)"
        ClusterQueue[ClusterQueue<br/>v1beta1]
        LocalQueue[LocalQueue<br/>v1beta1]
        Workload[Workload<br/>v1beta1]
        AdmissionCheck[AdmissionCheck<br/>v1beta1]
        ResourceFlavor[ResourceFlavor<br/>v1beta1]
        WorkloadPriorityClass[WorkloadPriorityClass<br/>v1beta1]
        ProvisioningRequestConfig[ProvisioningRequestConfig<br/>v1beta1]
        MultiKueueCluster[MultiKueueCluster<br/>v1alpha1]
        MultiKueueConfig[MultiKueueConfig<br/>v1alpha1]
    end

    subgraph "Integrated Workloads"
        Job[Kubernetes Job<br/>batch/v1]
        PyTorchJob[PyTorchJob<br/>kubeflow.org/v1]
        TFJob[TFJob<br/>kubeflow.org/v1]
        MPIJob[MPIJob<br/>kubeflow.org/v2beta1]
        RayJob[RayJob<br/>ray.io/v1]
        RayCluster[RayCluster<br/>ray.io/v1]
        JobSet[JobSet<br/>jobset.x-k8s.io/v1alpha2]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus<br/>Metrics Scrape]
        ClusterAutoscaler[Cluster Autoscaler<br/>ProvisioningRequest API]
        RemoteCluster[Remote Kubernetes Clusters<br/>6443/TCP HTTPS]
    end

    User[User/kubectl] -->|creates| Job
    User -->|creates| PyTorchJob
    User -->|creates| TFJob

    Webhook -->|mutates| Job
    Webhook -->|mutates| PyTorchJob
    Webhook -->|mutates| TFJob
    Webhook -->|mutates| MPIJob
    Webhook -->|mutates| RayJob
    Webhook -->|mutates| RayCluster
    Webhook -->|mutates| JobSet

    WorkloadCtrl -->|creates/watches| Workload
    ClusterQueueCtrl -->|watches| ClusterQueue
    LocalQueueCtrl -->|watches| LocalQueue
    AdmissionCheckCtrl -->|watches| AdmissionCheck
    ResourceFlavorCtrl -->|watches| ResourceFlavor

    WorkloadCtrl -->|unsuspends| Job
    WorkloadCtrl -->|unsuspends| PyTorchJob
    WorkloadCtrl -->|unsuspends| TFJob

    ClusterQueueCtrl -->|admits| Workload
    AdmissionCheckCtrl -->|validates| Workload

    Controller -->|watches/updates via| K8sAPI
    Webhook -->|called by| K8sAPI
    Visibility -->|aggregated via| K8sAPI

    CertManager -.->|provisions certs| Webhook
    CertManager -.->|provisions certs| Visibility
    Prometheus -->|scrapes| RBACProxy

    WorkloadCtrl -->|creates ProvisioningRequests| ClusterAutoscaler
    MultiKueueCtrl -->|distributes workloads| RemoteCluster

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style Webhook fill:#4a90e2,stroke:#333
    style Visibility fill:#4a90e2,stroke:#333
    style ClusterQueueCtrl fill:#7ed321,stroke:#333
    style WorkloadCtrl fill:#7ed321,stroke:#333
    style Workload fill:#f5a623,stroke:#333
    style ClusterQueue fill:#f5a623,stroke:#333
    style LocalQueue fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style CertManager fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style ClusterAutoscaler fill:#e8e8e8,stroke:#333
