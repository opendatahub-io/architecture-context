graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Reencrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Namespace: redhat-ods-applications)"]
        Service["odh-dashboard Service<br/>ClusterIP<br/>8443/TCP"]

        subgraph Pod["ODH Dashboard Pod (2 replicas, anti-affinity)"]
            direction TB
            OAuthProxy["oauth-proxy sidecar<br/>Port: 8443/TCP<br/>TLS: Service Serving Cert<br/>SA: odh-dashboard"]
            Dashboard["odh-dashboard container<br/>Port: 8080/TCP<br/>Image: UBI8 Node.js 18<br/>SA: odh-dashboard"]
        end
    end

    subgraph Egress["EGRESS - External Services"]
        K8sAPI["Kubernetes API Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
        OAuth["OpenShift OAuth Server<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: OAuth Client Secret"]
        Prometheus["Prometheus/Thanos<br/>9091/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
        ImageReg["OpenShift Image Registry<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Auth: ServiceAccount Token"]
    end

    %% Flows
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie| Router
    Router -->|HTTPS/8443<br/>TLS Reencrypt<br/>Service Serving Cert| Service
    Service -->|HTTPS/8443<br/>TLS| OAuthProxy
    OAuthProxy -->|Validates| OAuth
    OAuthProxy -->|HTTP/8080, Bearer Token| Dashboard

    Dashboard -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    Dashboard -->|HTTPS/9091<br/>TLS 1.2+<br/>ServiceAccount Token| Prometheus
    Dashboard -->|HTTPS/443<br/>TLS 1.2+<br/>ServiceAccount Token| ImageReg

    %% Annotations
    Note1["Trust Boundary 1:<br/>External → Ingress<br/>TLS Termination"]
    Note2["Trust Boundary 2:<br/>Ingress → Service Mesh<br/>TLS Reencrypt"]
    Note3["Trust Boundary 3:<br/>OAuth Proxy → Backend<br/>Token Validation"]

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px,color:#000
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px,color:#000
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:3px,color:#000
    classDef pod fill:#cfe2ff,stroke:#0066cc,stroke-width:2px,color:#000
    classDef egress fill:#fff2cc,stroke:#d6b656,stroke-width:3px,color:#000
    classDef note fill:#f0f0f0,stroke:#666,stroke-dasharray: 5 5,color:#000

    class User external
    class Router ingress
    class Service,Pod,OAuthProxy,Dashboard internal
    class K8sAPI,OAuth,Prometheus,ImageReg egress
    class Note1,Note2,Note3 note
