graph TD
    subgraph "Service Account"
        SA[controller-manager<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[role-binding]
        CRB2[instascale-role-binding]
        CRB3[mcad-controller-ray-clusterrolebinding]
    end

    subgraph "Role Binding"
        RB1[leader-election-role-binding<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRoles"
        CR1[manager-role]
        CR2[instascale-role]
        CR3[mcad-controller-ray-clusterrole]
    end

    subgraph "Roles"
        R1[leader-election-role<br/>Namespace: opendatahub]
    end

    subgraph "API Resources - CodeFlare CRDs"
        AW[workload.codeflare.dev<br/>AppWrapper, SchedulingSpec]
        QS[quota.codeflare.dev<br/>QuotaSubtree]
    end

    subgraph "API Resources - Core"
        Pods[Core<br/>Pods, ConfigMaps, Secrets,<br/>Services, ServiceAccounts,<br/>PVs, PVCs, Nodes]
        Apps[Apps<br/>Deployments, ReplicaSets,<br/>StatefulSets]
        Batch[Batch<br/>Jobs]
        PodGroups[scheduling.sigs.k8s.io<br/>PodGroups]
        Leases[coordination.k8s.io<br/>Leases]
        ConfigMap[Core<br/>ConfigMaps]
        Events[Core<br/>Events]
    end

    subgraph "API Resources - OpenShift"
        ClusterVersion[config.openshift.io<br/>ClusterVersions]
        Machines[machine.openshift.io<br/>Machines, MachineSets]
    end

    subgraph "API Resources - KubeRay"
        RayClusters[ray.io<br/>RayClusters]
        Ingresses[networking.k8s.io<br/>Ingresses]
        Routes[route.openshift.io<br/>Routes]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| RB1

    CRB1 -->|grants| CR1
    CRB2 -->|grants| CR2
    CRB3 -->|grants| CR3
    RB1 -->|grants| R1

    %% Permissions - manager-role
    CR1 -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| AW
    CR1 -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| QS
    CR1 -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| Pods
    CR1 -->|create, delete, get, list,<br/>patch, update, watch| Apps
    CR1 -->|create, delete, list,<br/>patch, update, watch| Batch
    CR1 -->|create, delete, deletecollection,<br/>get, list, patch, update, watch| PodGroups
    CR1 -->|create, get, update| Leases
    CR1 -->|get, list| ClusterVersion

    %% Permissions - instascale-role
    CR2 -->|get, list, patch, update| Pods
    CR2 -->|get| Pods
    CR2 -->|create, delete, get, list,<br/>patch, update, watch| Machines
    CR2 -->|get, list, watch| ClusterVersion

    %% Permissions - mcad-controller-ray-clusterrole
    CR3 -->|create, delete, get, list,<br/>patch, update, watch| RayClusters
    CR3 -->|create, delete, get, list,<br/>patch, update, watch| Ingresses
    CR3 -->|create, delete, get, list,<br/>patch, update, watch| Routes

    %% Permissions - leader-election-role
    R1 -->|get, list, watch,<br/>create, update, patch, delete| ConfigMap
    R1 -->|get, list, watch,<br/>create, update, patch, delete| Leases
    R1 -->|create, patch| Events

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px
    style CR1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR2 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR3 fill:#f5a623,stroke:#333,stroke-width:2px
    style R1 fill:#f5a623,stroke:#333,stroke-width:2px
    style AW fill:#7ed321,stroke:#333,stroke-width:2px
    style QS fill:#7ed321,stroke:#333,stroke-width:2px
    style Pods fill:#7ed321,stroke:#333,stroke-width:2px
    style Apps fill:#7ed321,stroke:#333,stroke-width:2px
    style Batch fill:#7ed321,stroke:#333,stroke-width:2px
    style PodGroups fill:#7ed321,stroke:#333,stroke-width:2px
    style RayClusters fill:#9bd1f9,stroke:#333,stroke-width:2px
    style Machines fill:#9bd1f9,stroke:#333,stroke-width:2px
