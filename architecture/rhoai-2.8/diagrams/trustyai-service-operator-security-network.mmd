graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[User Browser /<br/>API Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP HTTPS<br/>TLS 1.3"]
        Route["Route: {instance-name}<br/>Passthrough TLS<br/>443/TCP"]
    end

    subgraph Auth["AUTHENTICATION LAYER"]
        direction TB
        TLSSvc["Service: {instance-name}-tls<br/>ClusterIP<br/>443/TCP → 8443/TCP"]

        subgraph OAuthPod["OAuth Proxy Pod"]
            OAuth["OAuth Proxy Container<br/>8443/TCP HTTPS TLS 1.2+<br/>SA: {instance-name}-proxy<br/>Secret: {instance-name}-tls"]
            OAuthServer["OpenShift OAuth Server<br/>6443/TCP HTTPS"]
            K8sTokenReview["Kubernetes API<br/>TokenReview<br/>6443/TCP HTTPS TLS 1.2+"]
        end

        OAuth -.->|"OAuth validation<br/>HTTPS/6443"| OAuthServer
        OAuth -.->|"Token review<br/>HTTPS/6443"| K8sTokenReview
    end

    subgraph Internal["INTERNAL SERVICES (Trusted)"]
        direction TB

        subgraph TrustyAIPod["TrustyAI Service Pod<br/>Namespace: {user-namespace}"]
            direction LR
            TrustyAI["TrustyAI Service<br/>8080/TCP HTTP<br/>User: 65532<br/>Seccomp: RuntimeDefault<br/>Caps: Drop ALL"]
            PVC["PersistentVolumeClaim<br/>{instance-name}<br/>ReadWriteOnce"]
        end

        InternalSvc["Service: {instance-name}<br/>ClusterIP<br/>80/TCP → 8080/TCP<br/>HTTP (unencrypted)"]

        subgraph InternalClients["Internal Clients"]
            KServe["KServe<br/>InferenceService Pods"]
            ModelMesh["ModelMesh Pods"]
            Prometheus["Prometheus<br/>ServiceMonitor"]
        end

        TrustyAI -->|"Filesystem<br/>Pod UID"| PVC
    end

    subgraph ControlPlane["CONTROL PLANE"]
        Operator["TrustyAI Operator<br/>Namespace: {operator-namespace}<br/>SA: controller-manager<br/>Ports: 8080/TCP (metrics), 8081/TCP (health)"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS 1.2+<br/>ServiceAccount Token Auth"]
    end

    %% External flow
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>No auth"| Router
    Router -->|"HTTPS/443<br/>Passthrough"| Route
    Route -->|"HTTPS/443"| TLSSvc
    TLSSvc -->|"HTTPS/8443<br/>TLS 1.2+"| OAuth
    OAuth -->|"HTTP/8080<br/>Validated token<br/>localhost"| TrustyAI

    %% Internal access
    InternalSvc -->|"HTTP/8080<br/>No encryption"| TrustyAI
    KServe -->|"POST /consumer/kserve/v2<br/>HTTP/80<br/>No auth"| InternalSvc
    ModelMesh -->|"POST inference payloads<br/>HTTP/80<br/>No auth"| InternalSvc
    Prometheus -->|"GET /q/metrics<br/>HTTP/80<br/>SA Token (optional)"| InternalSvc

    %% Operator control
    Operator -->|"Create/Patch CRs<br/>HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    K8sAPI -.->|"Watch events"| Operator

    %% Styling for trust zones
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:3px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef auth fill:#fff2cc,stroke:#d6b656,stroke-width:3px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:3px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:3px

    class Client external
    class Router,Route ingress
    class TLSSvc,OAuth,OAuthServer,K8sTokenReview auth
    class TrustyAI,PVC,InternalSvc,KServe,ModelMesh,Prometheus internal
    class Operator,K8sAPI controlplane

    %% Annotations
    style TrustyAIPod fill:#e1f5e1,stroke:#82b366,stroke-width:2px
    style OAuthPod fill:#fff9e6,stroke:#d6b656,stroke-width:2px
    style InternalClients fill:#e8f5e9,stroke:#82b366,stroke-width:1px,stroke-dasharray: 5 5
