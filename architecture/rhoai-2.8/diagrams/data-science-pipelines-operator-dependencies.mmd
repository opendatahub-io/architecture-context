    style TrustedCA fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Elyra fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

