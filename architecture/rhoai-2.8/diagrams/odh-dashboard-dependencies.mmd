graph LR
    Dashboard[ODH Dashboard]

    %% External Dependencies (Required)
    subgraph ExtDeps["External Dependencies (Required)"]
        K8sAPI[Kubernetes API Server<br/>443/TCP]
        OAuth[OpenShift OAuth<br/>443/TCP]
        Router[OpenShift Router<br/>Ingress]
    end

    %% External Services
    subgraph ExtServices["External Services (Optional)"]
        Prometheus[Prometheus/Thanos<br/>9091/TCP]
        ImageReg[OpenShift Image Registry<br/>443/TCP]
        CertMgr[Certificate Manager<br/>Service Serving Certs]
    end

    %% Internal ODH/RHOAI Components
    subgraph ODHComponents["Internal ODH/RHOAI Components"]
        KServe[KServe Operator<br/>serving.kserve.io CRDs]
        Notebooks[Kubeflow Notebooks<br/>kubeflow.org CRDs]
        DSC[DataScienceCluster Operator<br/>datasciencecluster.opendatahub.io]
        Builds[OpenShift Builds<br/>build.openshift.io API]
        Console[OpenShift Console<br/>ConsoleLink integration]
    end

    %% NPM Dependencies
    subgraph NPMDeps["NPM Dependencies (Build/Runtime)"]
        React[React 18.2.0<br/>Frontend framework]
        Fastify[Fastify 4.16.0<br/>Web server]
        K8sClient[kubernetes/client-node 0.12.2<br/>K8s API client]
        PatternFly[PatternFly 5.1.0+<br/>UI components]
        Redux[Redux 4.2.0<br/>State management]
        Webpack[Webpack 5.76.0+<br/>Build tool]
        Pino[Pino 8.11.0<br/>Logging]
        PromClient[prom-client 14.0.1<br/>Metrics]
    end

    %% Core relationships - External
    Dashboard -->|REST API<br/>ServiceAccount Token| K8sAPI
    Dashboard -->|validates tokens| OAuth
    Router -->|routes traffic| Dashboard
    Dashboard -.->|queries metrics| Prometheus
    Dashboard -.->|queries layers| ImageReg
    Dashboard -.->|TLS certs| CertMgr

    %% ODH Component relationships
    Dashboard -->|manages ServingRuntimes| KServe
    Dashboard -->|creates/manages| Notebooks
    Dashboard -->|watches status| DSC
    Dashboard -->|triggers builds| Builds
    Dashboard <-->|UI integration| Console

    %% NPM Dependencies
    Dashboard -.->|uses| React
    Dashboard -.->|uses| Fastify
    Dashboard -.->|uses| K8sClient
    Dashboard -.->|uses| PatternFly
    Dashboard -.->|uses| Redux
    Dashboard -.->|builds with| Webpack
    Dashboard -.->|logs with| Pino
    Dashboard -.->|metrics with| PromClient

    %% Styling
    style Dashboard fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style OAuth fill:#999,stroke:#333,stroke-width:2px,color:#fff
    style Router fill:#999,stroke:#333,stroke-width:2px,color:#fff

    %% External Services
    style Prometheus fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style ImageReg fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff
    style CertMgr fill:#999,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5,color:#fff

    %% ODH Components
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Notebooks fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style DSC fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Builds fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Console fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

