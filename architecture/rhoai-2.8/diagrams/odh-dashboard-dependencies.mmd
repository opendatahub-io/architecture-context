    style Fastify fill:#f5a623,stroke:#333,stroke-width:1px,color:#000
    style K8sClient fill:#f5a623,stroke:#333,stroke-width:1px,color:#000
    style PatternFly fill:#f5a623,stroke:#333,stroke-width:1px,color:#000
