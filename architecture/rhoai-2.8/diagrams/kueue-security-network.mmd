graph TB
    subgraph External["EXTERNAL (Cluster Users)"]
        User[User/kubectl/API Clients]
    end

    subgraph APIServerBoundary["KUBERNETES API SERVER (Trust Boundary)"]
        APIServer["Kubernetes API Server<br/>Port: 6443/TCP<br/>HTTPS TLS 1.2+<br/>AuthN: Bearer Token<br/>AuthZ: RBAC"]
    end

    subgraph KueueNamespace["KUEUE NAMESPACE (kueue-system)"]
        direction TB

        subgraph ControllerPod["kueue-controller-manager Pod<br/>SA: controller-manager<br/>User: 65532:65532<br/>runAsNonRoot: true"]
            direction TB

            WebhookServer["Webhook Server<br/>Port: 9443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: mTLS<br/>Cert: webhook-server-cert"]

            VisibilityServer["Visibility API Server<br/>Port: 8082/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Bearer Token (proxied)<br/>Cert: visibility-server-cert"]

            Controllers["Controllers:<br/>- ClusterQueue Controller<br/>- LocalQueue Controller<br/>- Workload Controller<br/>- AdmissionCheck Controller<br/>- ResourceFlavor Controller<br/>- MultiKueue Controller"]

            MetricsEndpoint["Metrics Endpoint<br/>Port: 8080/TCP<br/>HTTP (internal)<br/>Auth: None"]

            RBACProxy["kube-rbac-proxy<br/>Port: 8443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Bearer Token"]

            HealthProbes["Health Probes<br/>Port: 8081/TCP<br/>HTTP<br/>Auth: None<br/>/healthz, /readyz"]
        end

        NetworkPolicy["NetworkPolicy: webhook-server<br/>Allow TCP/9443 from any<br/>Egress: Allow all"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB

        RemoteClusters["Remote Kubernetes Clusters<br/>Port: 6443/TCP<br/>HTTPS TLS 1.2+<br/>Auth: Kubeconfig (from Secret)"]

        ClusterAutoscaler["Cluster Autoscaler API<br/>Port: Varies<br/>HTTPS TLS 1.2+<br/>Auth: Service Account Token"]

        Prometheus["Prometheus<br/>Port: 8443/TCP (scrape)<br/>HTTPS TLS 1.2+<br/>Auth: Bearer Token"]

        CertManager["cert-manager (Optional)<br/>Provisions TLS certs<br/>90d rotation"]
    end

    subgraph Secrets["SECRETS"]
        direction TB
        WebhookCert["webhook-server-cert<br/>Type: kubernetes.io/tls<br/>Auto-rotate: Yes (cert-mgr)"]
        VisibilityCert["visibility-server-cert<br/>Type: kubernetes.io/tls<br/>Auto-rotate: Yes (cert-mgr)"]
        RemoteKubeconfig["Remote Kubeconfig<br/>Type: Opaque<br/>For MultiKueue"]
    end

    %% External to API Server
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>Bearer Token| APIServer

    %% API Server to Kueue
    APIServer -->|Admission Webhooks<br/>HTTPS/9443<br/>mTLS| WebhookServer
    APIServer -->|Aggregated API<br/>HTTPS/8082<br/>Bearer Token| VisibilityServer

    %% Controllers to API Server
    Controllers -->|Watch/Update CRDs<br/>HTTPS/6443<br/>TLS 1.2+<br/>SA Token| APIServer
    WebhookServer -->|Validate/Query<br/>HTTPS/6443<br/>SA Token| APIServer
    VisibilityServer -->|Query Workloads<br/>HTTPS/6443<br/>SA Token| APIServer

    %% Metrics Flow
    Prometheus -->|Scrape Metrics<br/>HTTPS/8443<br/>Bearer Token| RBACProxy
    RBACProxy -->|TokenReview<br/>HTTPS/6443<br/>SA Token| APIServer
    RBACProxy -->|Proxy<br/>HTTP/8080<br/>Localhost| MetricsEndpoint

    %% Egress to External Services
    Controllers -->|Distribute Workloads<br/>HTTPS/6443<br/>Kubeconfig Auth| RemoteClusters
    Controllers -->|Provision Nodes<br/>HTTPS/TLS 1.2+<br/>SA Token| ClusterAutoscaler

    %% Certificate Management
    CertManager -.->|Provision/Rotate| WebhookCert
    CertManager -.->|Provision/Rotate| VisibilityCert
    WebhookCert -.->|Used by| WebhookServer
    VisibilityCert -.->|Used by| VisibilityServer
    RemoteKubeconfig -.->|Used by| Controllers

    %% Network Policy
    NetworkPolicy -.->|Enforces| WebhookServer

    %% Health Probes
    APIServer -.->|Liveness/Readiness<br/>HTTP/8081| HealthProbes

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef boundary fill:#ffe6cc,stroke:#d79b00,stroke-width:3px
    classDef kueue fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef secret fill:#f8cecc,stroke:#b85450,stroke-width:2px
    classDef controller fill:#4a90e2,color:#fff,stroke:#333,stroke-width:2px

    class User external
    class APIServer boundary
    class WebhookServer,VisibilityServer,Controllers,RBACProxy,MetricsEndpoint,HealthProbes controller
    class ControllerPod,KueueNamespace kueue
    class RemoteClusters,ClusterAutoscaler,Prometheus,CertManager externalservice
    class WebhookCert,VisibilityCert,RemoteKubeconfig secret
