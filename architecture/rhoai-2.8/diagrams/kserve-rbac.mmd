graph TD
    subgraph "Service Account"
        SA[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB1[kserve-manager-rolebinding<br/>ClusterRoleBinding]
        CRB2[kserve-leader-election-rolebinding<br/>RoleBinding]
        CRB3[kserve-proxy-rolebinding<br/>RoleBinding]
    end

    subgraph "ClusterRole Permissions"
        CR[kserve-manager-role<br/>ClusterRole]
    end

    subgraph "KServe API Resources"
        direction TB
        KServeInferenceService["serving.kserve.io<br/>━━━━━━━━━━━━━━<br/>InferenceService<br/>inferenceservices/finalizers<br/>inferenceservices/status"]
        KServeServingRuntime["serving.kserve.io<br/>━━━━━━━━━━━━━━<br/>ServingRuntime<br/>ClusterServingRuntime<br/>+ finalizers, status"]
        KServeInferenceGraph["serving.kserve.io<br/>━━━━━━━━━━━━━━<br/>InferenceGraph<br/>inferencegraphs/finalizers<br/>inferencegraphs/status"]
        KServeTrainedModel["serving.kserve.io<br/>━━━━━━━━━━━━━━<br/>TrainedModel<br/>trainedmodels/status"]
        KServeStorage["serving.kserve.io<br/>━━━━━━━━━━━━━━<br/>ClusterStorageContainer"]
    end

    subgraph "Knative API Resources"
        KnativeServices["serving.knative.dev<br/>━━━━━━━━━━━━━━<br/>Services<br/>services/finalizers<br/>services/status"]
    end

    subgraph "Istio API Resources"
        IstioVS["networking.istio.io<br/>━━━━━━━━━━━━━━<br/>VirtualServices<br/>virtualservices/finalizers<br/>virtualservices/status"]
    end

    subgraph "Kubernetes Core Resources"
        K8sDeployments["apps<br/>━━━━━━━━━━━━━━<br/>Deployments"]
        K8sCore["core API<br/>━━━━━━━━━━━━━━<br/>Services<br/>Secrets<br/>ConfigMaps<br/>Events"]
        K8sReadOnly["core API<br/>━━━━━━━━━━━━━━<br/>Namespaces (read)<br/>Pods (read)<br/>ServiceAccounts (read)"]
        K8sHPA["autoscaling<br/>━━━━━━━━━━━━━━<br/>HorizontalPodAutoscalers"]
        K8sIngress["networking.k8s.io<br/>━━━━━━━━━━━━━━<br/>Ingresses"]
        K8sWebhooks["admissionregistration.k8s.io<br/>━━━━━━━━━━━━━━<br/>MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations"]
    end

    %% Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3

    CRB1 -->|grants| CR

    %% Permissions - KServe CRDs
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KServeInferenceService
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KServeServingRuntime
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KServeInferenceGraph
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KServeTrainedModel
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KServeStorage

    %% Permissions - Knative
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| KnativeServices

    %% Permissions - Istio
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| IstioVS

    %% Permissions - K8s Resources
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| K8sDeployments
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| K8sCore
    CR -->|"get, list, watch"| K8sReadOnly
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| K8sHPA
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| K8sIngress
    CR -->|"create, delete, get,<br/>list, patch, update, watch"| K8sWebhooks

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style CRB1 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB2 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff
    style CRB3 fill:#9b59b6,stroke:#333,stroke-width:2px,color:#fff

    style KServeInferenceService fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServeServingRuntime fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServeInferenceGraph fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServeTrainedModel fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style KServeStorage fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    style KnativeServices fill:#0865ad,stroke:#333,stroke-width:2px,color:#fff
    style IstioVS fill:#466bb0,stroke:#333,stroke-width:2px,color:#fff

    style K8sDeployments fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style K8sCore fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style K8sReadOnly fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style K8sHPA fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
