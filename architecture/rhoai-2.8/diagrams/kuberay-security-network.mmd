graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
        APIClient[API Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route / K8s Ingress<br/>Dashboard: 443/TCP → 8265/TCP<br/>Serve: 443/TCP → 8000/TCP<br/>TLS 1.2+ (edge/SIMPLE)"]
        APIServerSvc["KubeRay APIServer Service<br/>NodePort<br/>HTTP: 8888/TCP<br/>gRPC: 8887/TCP<br/>Auth: Bearer Token"]
    end

    subgraph ClusterInternal["INTERNAL CLUSTER (Trusted)"]
        direction TB

        subgraph OperatorNS["Namespace: kuberay-system"]
            Operator["KubeRay Operator<br/>SA: kuberay-operator<br/>8080/TCP Metrics HTTP"]
            APIServer["KubeRay APIServer<br/>SA: kuberay-apiserver"]
        end

        K8sAPI["Kubernetes API<br/>443/TCP HTTPS TLS1.2+<br/>Auth: ServiceAccount Token"]

        subgraph RayNS["Namespace: {user-namespace}"]
            direction TB
            RayHead["Ray Head Pod<br/>SA: default/custom<br/>UID: 1000 (SCC)<br/>━━━━━━━━━━━━━<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client<br/>8080/TCP Metrics<br/>8000/TCP Serve<br/>52365/TCP Agent"]
            RayWorker["Ray Worker Pods<br/>SA: default/custom<br/>UID: 1000"]

            HeadSvc["Ray Head Service<br/>ClusterIP<br/>Multiple ports"]
            ServeSvc["Ray Serve Service<br/>ClusterIP 8000/TCP"]
        end
    end

    subgraph Monitoring["MONITORING (Internal)"]
        Prometheus["Prometheus<br/>Scrapes 8080/TCP HTTP"]
        Grafana["Grafana<br/>9090/TCP<br/>Basic Auth"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        Registry["Container Registry<br/>443/TCP HTTPS TLS1.2+<br/>Auth: Pull Secret"]
        ExternalRedis["External Redis<br/>6379/TCP Optional TLS<br/>Auth: Password"]
        S3["S3/GCS Storage<br/>443/TCP HTTPS TLS1.2+<br/>Auth: AWS IAM/GCP SA"]
    end

    %% External to Ingress
    Client -->|HTTPS/443<br/>TLS 1.2+| Route
    APIClient -->|HTTP/8888 gRPC/8887<br/>Bearer Token| APIServerSvc

    %% Ingress to Internal
    Route -->|HTTP/8265| HeadSvc
    Route -->|HTTP/8000| ServeSvc
    APIServerSvc -->|Internal| APIServer

    %% Operator flows
    Operator -->|HTTPS/443<br/>ServiceAccount Token| K8sAPI
    APIServer -->|HTTPS/443<br/>ServiceAccount Token| K8sAPI
    K8sAPI -->|Creates| RayHead
    K8sAPI -->|Creates| RayWorker
    K8sAPI -->|Creates| HeadSvc
    K8sAPI -->|Creates| ServeSvc

    %% Ray internal communication
    RayWorker -->|TCP/6379 GCS<br/>Redis Password| RayHead
    HeadSvc -->|Routes to| RayHead
    ServeSvc -->|Routes to| RayHead

    %% External service connections
    RayHead -->|HTTPS/443<br/>Pull Secret| Registry
    RayWorker -->|HTTPS/443<br/>Pull Secret| Registry
    RayHead -->|TCP/6379<br/>Optional TLS<br/>Redis Password| ExternalRedis
    RayHead -->|HTTPS/443<br/>AWS IAM/GCP SA| S3

    %% Monitoring
    Prometheus -->|HTTP/8080| Operator
    Prometheus -->|HTTP/8080| RayHead
    Grafana -->|HTTP/9090<br/>Basic Auth| Prometheus

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client,APIClient external
    class Route,APIServerSvc ingress
    class Operator,APIServer,K8sAPI,RayHead,RayWorker,HeadSvc,ServeSvc internal
    class Prometheus,Grafana monitoring
    class Registry,ExternalRedis,S3 externalservice
