graph TD
    subgraph "Service Account"
        SA[odh-dashboard<br/>Namespace: redhat-ods-applications]
    end

    subgraph "ClusterRole Bindings"
        CRB1[odh-dashboard<br/>ClusterRoleBinding]
        CRB2[odh-dashboard-auth-delegator<br/>ClusterRoleBinding]
        CRB3[odh-dashboard-cluster-monitoring<br/>ClusterRoleBinding]
        CRB4[odh-dashboard-image-puller<br/>ClusterRoleBinding]
    end

    subgraph "Role Bindings"
        RB1[odh-dashboard<br/>RoleBinding<br/>redhat-ods-applications]
        RB2[odh-dashboard-model-serving<br/>RoleBinding<br/>redhat-ods-applications]
        RB3[odh-dashboard-fetch-builds-and-images<br/>RoleBinding<br/>redhat-ods-applications]
        RB4[odh-dashboard-fetch-accelerators<br/>RoleBinding<br/>redhat-ods-applications]
    end

    subgraph "ClusterRole Permissions"
        CR[odh-dashboard<br/>ClusterRole]

        subgraph "Core API Resources"
            CorePerms["• nodes: get, list<br/>• configmaps, pvcs, secrets: CRUD<br/>• pods, sa, services: get, list, watch<br/>• namespaces: full CRUD<br/>• events: get, list, watch"]
        end

        subgraph "RBAC Resources"
            RBACPerms["rbac.authorization.k8s.io<br/>• rolebindings, clusterrolebindings, roles<br/>  Verbs: full CRUD"]
        end

        subgraph "OpenShift Resources"
            OSPerms["• machine.openshift.io: machineautoscalers, machinesets<br/>• config.openshift.io: clusterversions<br/>• operators.coreos.com: csv, subscriptions<br/>• image.openshift.io: imagestreams/layers<br/>• route.openshift.io: routes<br/>• console.openshift.io: consolelinks<br/>• user.openshift.io: groups, users"]
        end

        subgraph "ODH/Kubeflow CRDs"
            CRDPerms["• kubeflow.org/notebooks: full CRUD<br/>• datasciencecluster.opendatahub.io: get, list, watch"]
        end
    end

    subgraph "Role Permissions (Namespace-scoped)"
        R[odh-dashboard<br/>Role]

        subgraph "Dashboard CRDs"
            DashCRDs["dashboard.opendatahub.io<br/>• acceleratorprofiles: full CRUD<br/>• odhapplications, odhdocuments: get, list"]
        end

        subgraph "QuickStarts & Routes"
            QuickStartPerms["• console.openshift.io/odhquickstarts: get, list<br/>• route.openshift.io/routes: get, list, watch"]
        end

        subgraph "Builds & Images"
            BuildPerms["• batch: cronjobs, jobs (full CRUD)<br/>• image.openshift.io: imagestreams (full CRUD)<br/>• build.openshift.io: builds, buildconfigs (full CRUD)"]
        end

        subgraph "Deployments"
            DeployPerms["• apps: deployments (patch, update)<br/>• apps.openshift.io: deploymentconfigs (full CRUD)"]
        end

        subgraph "ODH Config & Serving"
            OdhConfigPerms["• opendatahub.io/odhdashboardconfigs: full CRUD<br/>• kubeflow.org/notebooks: full CRUD<br/>• template.openshift.io/templates: all verbs<br/>• serving.kserve.io/servingruntimes: all verbs"]
        end
    end

    subgraph "System Roles"
        SysAuthDelegator[system:auth-delegator<br/>ClusterRole]
        SysClusterMon[cluster-monitoring-view<br/>ClusterRole]
        SysImagePuller[system:image-puller<br/>ClusterRole]
    end

    %% Service Account Bindings
    SA -->|bound via| CRB1
    SA -->|bound via| CRB2
    SA -->|bound via| CRB3
    SA -->|bound via| CRB4
    SA -->|bound via| RB1
    SA -->|bound via| RB2
    SA -->|bound via| RB3
    SA -->|bound via| RB4

    %% ClusterRole Bindings to Roles
    CRB1 -->|grants| CR
    CRB2 -->|grants| SysAuthDelegator
    CRB3 -->|grants| SysClusterMon
    CRB4 -->|grants| SysImagePuller

    %% Role Bindings to Roles
    RB1 -->|grants| R

    %% ClusterRole to Permissions
    CR -->|permits| CorePerms
    CR -->|permits| RBACPerms
    CR -->|permits| OSPerms
    CR -->|permits| CRDPerms

    %% Role to Permissions
    R -->|permits| DashCRDs
    R -->|permits| QuickStartPerms
    R -->|permits| BuildPerms
    R -->|permits| DeployPerms
    R -->|permits| OdhConfigPerms

    %% Purpose annotations
    SysAuthDelegator -.->|Purpose| AuthPurpose["Delegate authentication<br/>to OAuth server"]
    SysClusterMon -.->|Purpose| MonPurpose["View cluster<br/>monitoring metrics"]
    SysImagePuller -.->|Purpose| ImagePurpose["Pull container images<br/>from registry"]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style R fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style CRB1 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB2 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style CRB4 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB1 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB2 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB3 fill:#e8e8e8,stroke:#333,stroke-width:1px
    style RB4 fill:#e8e8e8,stroke:#333,stroke-width:1px

    style CorePerms fill:#7ed321,stroke:#333,color:#000
    style RBACPerms fill:#7ed321,stroke:#333,color:#000
    style OSPerms fill:#7ed321,stroke:#333,color:#000
    style CRDPerms fill:#7ed321,stroke:#333,color:#000
    style DashCRDs fill:#7ed321,stroke:#333,color:#000
    style QuickStartPerms fill:#7ed321,stroke:#333,color:#000
    style BuildPerms fill:#7ed321,stroke:#333,color:#000
    style DeployPerms fill:#7ed321,stroke:#333,color:#000
    style OdhConfigPerms fill:#7ed321,stroke:#333,color:#000

    style SysAuthDelegator fill:#bd10e0,stroke:#333,color:#fff
    style SysClusterMon fill:#bd10e0,stroke:#333,color:#fff
    style SysImagePuller fill:#bd10e0,stroke:#333,color:#fff

    style AuthPurpose fill:#fff,stroke:#666,stroke-dasharray: 5 5
    style MonPurpose fill:#fff,stroke:#666,stroke-dasharray: 5 5
    style ImagePurpose fill:#fff,stroke:#666,stroke-dasharray: 5 5
