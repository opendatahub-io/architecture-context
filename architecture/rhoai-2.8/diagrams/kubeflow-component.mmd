graph TB
    subgraph "ODH Notebook Controller"
        Controller[OpenshiftNotebookReconciler<br/>Controller]
        Webhook[NotebookWebhook<br/>Mutating Webhook]
        ManagerDeploy[Manager Deployment<br/>Metrics & Health Probes]

        ManagerDeploy -->|runs| Controller
        ManagerDeploy -->|runs| Webhook
    end

    subgraph "Watched Resources"
        NotebookCR[Notebook CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources per Notebook"
        OAuthSidecar[OAuth Proxy Sidecar<br/>8443/TCP HTTPS]
        ServiceAccount[ServiceAccount<br/>OAuth redirect ref]
        OAuthService[Service<br/>443→8443 HTTPS]
        BaseService[Service<br/>80→8888 HTTP]
        Route[OpenShift Route<br/>Edge TLS]
        Secret[Secret<br/>OAuth config & TLS]
        NetworkPolicy[NetworkPolicies<br/>Traffic control]
        ConfigMap[ConfigMap<br/>Trusted CA bundle]
    end

    subgraph "External Dependencies"
        KubeflowController[Kubeflow Notebook Controller<br/>Creates StatefulSet]
        OpenShiftRoute[OpenShift Route API<br/>route.openshift.io/v1]
        OpenShiftConfig[OpenShift Config API<br/>config.openshift.io/v1]
        OAuthProxy[OpenShift OAuth Proxy<br/>Image: ose-oauth-proxy]
        ServiceCA[Service CA Operator<br/>TLS provisioning]
        K8sAPI[Kubernetes API Server<br/>6443/TCP HTTPS]
    end

    subgraph "Internal ODH Dependencies"
        Dashboard[ODH Dashboard<br/>Creates Notebook CRs]
        ODHOperator[ODH Operator<br/>Deploys controller]
    end

    %% User interaction
    User[User/Dashboard] -->|creates| NotebookCR

    %% Webhook flow
    NotebookCR -->|intercepted by| Webhook
    Webhook -->|injects OAuth sidecar| NotebookCR
    Webhook -->|queries| K8sAPI

    %% Controller reconciliation
    NotebookCR -->|watched by| Controller
    Controller -->|creates/manages| ServiceAccount
    Controller -->|creates/manages| OAuthService
    Controller -->|creates/manages| BaseService
    Controller -->|creates/manages| Route
    Controller -->|creates/manages| Secret
    Controller -->|creates/manages| NetworkPolicy
    Controller -->|creates/manages| ConfigMap
    Controller -->|API calls| K8sAPI

    %% Kubeflow controller interaction
    NotebookCR -->|watched by| KubeflowController
    KubeflowController -->|creates| StatefulSet[StatefulSet<br/>with injected sidecar]
    StatefulSet -->|contains| OAuthSidecar
    StatefulSet -->|contains| NotebookContainer[Notebook Container<br/>8888/TCP HTTP]

    %% Route to service
    Route -->|routes to| OAuthService
    OAuthService -->|forwards to| OAuthSidecar
    OAuthSidecar -->|proxies to| NotebookContainer

    %% External dependencies
    Controller -->|uses| OpenShiftRoute
    Controller -->|reads| OpenShiftConfig
    OAuthSidecar -->|authenticates via| OAuthServer[OpenShift OAuth Server<br/>6443/TCP HTTPS]
    Secret -.->|provisioned by| ServiceCA

    %% Internal dependencies
    Dashboard -->|integrates with| Controller
    ODHOperator -->|deploys| ManagerDeploy

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style Webhook fill:#4a90e2,stroke:#333,stroke-width:2px
    style NotebookCR fill:#f5a623,stroke:#333,stroke-width:2px
    style KubeflowController fill:#999,stroke:#333,stroke-width:2px
    style OpenShiftRoute fill:#999,stroke:#333,stroke-width:2px
    style OpenShiftConfig fill:#999,stroke:#333,stroke-width:2px
    style ServiceCA fill:#999,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px
    style ODHOperator fill:#7ed321,stroke:#333,stroke-width:2px
    style OAuthSidecar fill:#f5a623,stroke:#333,stroke-width:2px
