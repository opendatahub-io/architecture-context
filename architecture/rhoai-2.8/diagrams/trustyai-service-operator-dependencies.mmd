graph LR
    TrustyAI[TrustyAI Service Operator]

    %% External Dependencies - Required Platform
    TrustyAI -->|"container orchestration<br/>1.19+"| Kubernetes[Kubernetes 1.19+]
    TrustyAI -->|"Routes, OAuth<br/>4.6+ (optional)"| OpenShift[OpenShift 4.6+]
    TrustyAI -->|"ServiceMonitor CRD<br/>metrics collection"| PrometheusOp[Prometheus Operator]
    TrustyAI -->|"TLS certificates"| CertMgr[cert-manager /<br/>OpenShift Service CA]

    %% Internal ODH/RHOAI Dependencies - Core Integration
    TrustyAI -->|"CRD/API<br/>inference logger config"| KServe[KServe]
    TrustyAI -->|"Env Variable<br/>payload processor URL"| ModelMesh[ModelMesh]
    TrustyAI -->|"ServiceMonitor<br/>metrics scraping"| Prometheus[Prometheus]
    TrustyAI -->|"Service Account<br/>authentication"| OAuthServer[OpenShift OAuth]

    %% Internal ODH/RHOAI Dependencies - Indirect
    TrustyAI -.->|"metrics display<br/>(indirect)"| Dashboard[ODH Dashboard]
    TrustyAI -.->|"sidecars<br/>(if deployed)"| ServiceMesh[Service Mesh]

    %% Integration Points - Data Flow
    KServe -->|"HTTP callbacks<br/>inference payloads"| TrustyAI
    ModelMesh -->|"HTTP callbacks<br/>inference payloads"| TrustyAI
    Prometheus -->|"HTTP scrape<br/>metrics pull"| TrustyAI
    Dashboard -->|"API calls<br/>metrics query"| TrustyAI

    %% External Services
    TrustyAI -->|"API operations<br/>HTTPS/6443"| K8sAPI[Kubernetes API Server]
    TrustyAI -->|"data storage<br/>PVC/PV"| Storage[Persistent Storage]

    %% Styling
    style TrustyAI fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Platform Dependencies
    style Kubernetes fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff
    style OpenShift fill:#ee0000,stroke:#333,stroke-width:2px,color:#fff
    style PrometheusOp fill:#e6522c,stroke:#333,stroke-width:2px,color:#fff
    style CertMgr fill:#326ce5,stroke:#333,stroke-width:2px,color:#fff

    %% Internal ODH Components
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style OAuthServer fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style Dashboard fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style ServiceMesh fill:#7ed321,stroke:#333,stroke-width:2px,color:#000

    %% External Services
    style K8sAPI fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style Storage fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff

    %% Legend
    subgraph Legend
        direction TB
        L1[Required External]
        L2[Internal ODH/RHOAI]
        L3[Infrastructure]

        style L1 fill:#326ce5,stroke:#333,color:#fff
        style L2 fill:#7ed321,stroke:#333,color:#000
        style L3 fill:#f5a623,stroke:#333,color:#000
    end
