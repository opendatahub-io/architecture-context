graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist<br/>User Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>ds-pipeline-{name}<br/>443/TCP → 8443/TCP<br/>HTTPS TLS 1.2+<br/>Reencrypt"]
    end

    subgraph ClusterInternal["CLUSTER INTERNAL (Trusted)"]
        direction TB

        subgraph UserNamespace["Namespace: {user-namespace}"]
            direction TB

            subgraph APIPod["API Server Pod"]
                OAuth["OAuth Proxy Sidecar<br/>8443/TCP HTTPS<br/>SA: ds-pipeline-{name}<br/>OpenShift OAuth"]
                APIContainer["API Server Container<br/>8888/TCP HTTP<br/>8887/TCP gRPC<br/>KFP API (kfp-tekton)"]
            end

            DB["MariaDB StatefulSet<br/>mariadb-{name}<br/>3306/TCP MySQL<br/>TLS configurable<br/>DB Password Auth"]

            subgraph OptionalComponents["Optional Components"]
                Minio["Minio StatefulSet<br/>minio-{name}<br/>9000/TCP HTTP<br/>S3 API<br/>S3 Access Keys"]

                subgraph MLMDStack["MLMD Stack"]
                    MLMDEnvoy["MLMD Envoy<br/>8080/TCP gRPC<br/>Optional Service Mesh mTLS"]
                    MLMDgRPC["MLMD gRPC<br/>8080/TCP gRPC"]
                end
            end

            PAgent["Persistence Agent<br/>SA: ds-pipeline-{name}"]
            SWF["Scheduled Workflow Controller<br/>SA: ds-pipeline-{name}"]
        end

        subgraph OperatorNamespace["Namespace: redhat-ods-applications"]
            Controller["DSPO Controller<br/>SA: controller-manager<br/>Metrics: 8080/TCP HTTP<br/>Health: 8081/TCP HTTP"]
        end

        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>ServiceAccount Tokens"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        Tekton["OpenShift Pipelines<br/>Tekton<br/>6443/TCP HTTPS<br/>via K8s API"]

        subgraph ExternalOptional["External (Optional)"]
            ExtS3["External S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM / S3 Creds"]
            ExtDB["External Database<br/>3306/TCP or 5432/TCP<br/>MySQL/PostgreSQL<br/>TLS 1.2+"]
        end

        Dashboard["ODH Dashboard<br/>8443/TCP HTTPS<br/>OAuth Token"]
    end

    %% External to Ingress
    User -->|HTTPS/443<br/>TLS 1.2+<br/>OAuth Token| Route

    %% Ingress to Internal
    Route -->|HTTPS/8443<br/>TLS Reencrypt<br/>OAuth Validation| OAuth

    %% OAuth to API Server
    OAuth -->|HTTP/8888<br/>Verified Identity| APIContainer

    %% API Server flows
    APIContainer -->|MySQL/3306<br/>TLS configurable<br/>DB Password| DB
    APIContainer -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    APIContainer -->|HTTP/9000<br/>S3 API<br/>S3 Keys| Minio
    APIContainer -->|gRPC/8080<br/>Internal| MLMDEnvoy

    %% gRPC external access
    APIContainer -.->|gRPC/8887<br/>Internal| User

    %% MLMD flows
    MLMDEnvoy -->|gRPC/8080<br/>Internal| MLMDgRPC
    MLMDgRPC -->|MySQL/3306<br/>TLS configurable| DB

    %% Persistence Agent flows
    PAgent -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    PAgent -->|MySQL/3306<br/>TLS configurable<br/>DB Password| DB

    %% Scheduled Workflow flows
    SWF -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI
    SWF -->|MySQL/3306<br/>TLS configurable| DB

    %% Operator flows
    Controller -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| K8sAPI

    %% API Server to Tekton
    APIContainer -->|HTTPS/6443<br/>TLS 1.2+<br/>SA Token| Tekton

    %% External optional connections
    APIContainer -.->|HTTPS/443<br/>TLS 1.2+<br/>S3 Creds| ExtS3
    APIContainer -.->|MySQL/PostgreSQL<br/>TLS 1.2+<br/>DB Password| ExtDB

    %% Dashboard integration
    Dashboard -->|HTTPS/443<br/>OAuth Token| Route

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef internal fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px

    class User external
    class Route ingress
    class OAuth,APIContainer,DB,Minio,MLMDEnvoy,MLMDgRPC,PAgent,SWF internal
    class Controller operator
    class Tekton,ExtS3,ExtDB,Dashboard,K8sAPI externalservice
