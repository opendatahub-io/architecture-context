graph LR
    KServe[KServe Operator]

    %% External Dependencies - Required
    KServe -->|"container platform<br/>(required)"| K8s[Kubernetes 1.26+]
    KServe -->|"serverless deployment<br/>(required)"| Knative[Knative Serving 0.39.3]
    KServe -->|"traffic routing & mTLS<br/>(required)"| Istio[Istio 1.17+]
    KServe -->|"TLS certificates<br/>(required)"| CertManager[cert-manager 1.5+]

    %% External Dependencies - Optional
    KServe -.->|"metrics collection<br/>(optional)"| Prometheus[Prometheus 2.x]
    KServe -.->|"S3 storage access<br/>(optional)"| AWSSDK[AWS SDK 1.44.264]
    KServe -.->|"GCS storage access<br/>(optional)"| GCSSDK[Google Cloud Storage 1.33.0]

    %% Internal ODH Dependencies
    KServe -->|"traffic mgmt<br/>VirtualService/Gateway"| ServiceMesh[Service Mesh - Istio]
    KServe -.->|"model metadata<br/>HTTP/gRPC API"| ModelRegistry[Model Registry]
    KServe -.->|"authentication<br/>AuthorizationPolicy"| Authorino[Authorino]

    %% Integration Points - Consumers
    Dashboard[ODH Dashboard] -->|"UI management<br/>K8s API"| KServe
    Pipelines[Data Science Pipelines] -->|"auto deployment<br/>REST API"| KServe

    %% External Services
    KServe -->|"model artifacts<br/>HTTPS/443"| S3[S3 Storage]
    KServe -.->|"model artifacts<br/>HTTPS/443"| GCS[GCS Storage]
    KServe -.->|"model artifacts<br/>HTTPS/443"| HTTPURLs["HTTP/HTTPS URLs"]
    KServe -->|"runtime images<br/>HTTPS/443"| ContainerRegistry[Container Registries]

    %% CRD Interactions
    KServe -->|"creates & manages"| KnativeSvc[Knative Services]
    KServe -->|"creates & manages"| IstioVS[Istio VirtualServices]
    KServe -->|"creates & manages"| K8sResources[K8s Deployments<br/>Services<br/>ConfigMaps<br/>Secrets]

    %% Custom Resources Managed
    subgraph "KServe CRDs"
        InferenceService[InferenceService<br/>v1beta1]
        InferenceGraph[InferenceGraph<br/>v1alpha1]
        TrainedModel[TrainedModel<br/>v1alpha1]
        ServingRuntime[ServingRuntime<br/>v1alpha1]
        ClusterServingRuntime[ClusterServingRuntime<br/>v1alpha1]
    end

    User[Data Scientist] -->|"creates"| InferenceService
    User -->|"creates"| InferenceGraph
    User -->|"creates"| TrainedModel
    User -->|"creates"| ServingRuntime

    InferenceService -->|"reconciled by"| KServe
    InferenceGraph -->|"reconciled by"| KServe
    TrainedModel -->|"reconciled by"| KServe
    ServingRuntime -->|"reconciled by"| KServe
    ClusterServingRuntime -->|"reconciled by"| KServe

    %% Styling
    style KServe fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External - Required
    style K8s fill:#326ce5,stroke:#333,color:#fff
    style Knative fill:#0865ad,stroke:#333,color:#fff
    style Istio fill:#466bb0,stroke:#333,color:#fff
    style CertManager fill:#5a67d8,stroke:#333,color:#fff

    %% External - Optional
    style Prometheus fill:#e6522c,stroke:#333,color:#fff
    style AWSSDK fill:#ff9900,stroke:#333,color:#000
    style GCSSDK fill:#4285f4,stroke:#333,color:#fff

    %% Internal ODH
    style ServiceMesh fill:#7ed321,stroke:#333,color:#000
    style ModelRegistry fill:#7ed321,stroke:#333,color:#000
    style Authorino fill:#7ed321,stroke:#333,color:#000
    style Dashboard fill:#7ed321,stroke:#333,color:#000
    style Pipelines fill:#7ed321,stroke:#333,color:#000

    %% External Services
    style S3 fill:#ff9900,stroke:#333,color:#000
    style GCS fill:#4285f4,stroke:#333,color:#fff
    style HTTPURLs fill:#999,stroke:#333,color:#fff
    style ContainerRegistry fill:#0db7ed,stroke:#333,color:#fff

    %% Managed Resources
    style KnativeSvc fill:#0865ad,stroke:#333,color:#fff
    style IstioVS fill:#466bb0,stroke:#333,color:#fff
    style K8sResources fill:#326ce5,stroke:#333,color:#fff

    %% CRDs
    style InferenceService fill:#f5a623,stroke:#333,color:#000
    style InferenceGraph fill:#f5a623,stroke:#333,color:#000
    style TrainedModel fill:#f5a623,stroke:#333,color:#000
    style ServingRuntime fill:#f5a623,stroke:#333,color:#000
    style ClusterServingRuntime fill:#f5a623,stroke:#333,color:#000

    %% User
    style User fill:#8b5cf6,stroke:#333,color:#fff
