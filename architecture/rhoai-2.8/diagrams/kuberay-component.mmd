graph TB
    subgraph "KubeRay Component"
        Operator[KubeRay Operator<br/>Port: 8080/TCP Metrics]
        APIServer[KubeRay APIServer<br/>HTTP: 8888/TCP<br/>gRPC: 8887/TCP]

        subgraph "Controllers"
            RayClusterCtrl[RayCluster Controller]
            RayJobCtrl[RayJob Controller]
            RayServiceCtrl[RayService Controller]
        end

        Operator --> RayClusterCtrl
        Operator --> RayJobCtrl
        Operator --> RayServiceCtrl
    end

    subgraph "Custom Resources"
        RayClusterCR[RayCluster CR<br/>ray.io/v1]
        RayJobCR[RayJob CR<br/>ray.io/v1]
        RayServiceCR[RayService CR<br/>ray.io/v1]
    end

    subgraph "Ray Infrastructure"
        RayHead[Ray Head Pod<br/>6379/TCP GCS<br/>8265/TCP Dashboard<br/>10001/TCP Client]
        RayWorker1[Ray Worker Pod 1]
        RayWorker2[Ray Worker Pod 2]
        HeadService[Ray Head Service<br/>ClusterIP]
        ServeService[Ray Serve Service<br/>ClusterIP 8000/TCP]
    end

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Registry[Container Registry<br/>443/TCP HTTPS]
        ExternalRedis[External Redis<br/>6379/TCP Optional]
        S3Storage[S3/GCS Storage<br/>443/TCP HTTPS]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    subgraph "OpenShift Integration"
        Routes[OpenShift Routes<br/>8265/TCP Dashboard<br/>8000/TCP Serve]
        SCC[SecurityContextConstraints<br/>run-as-ray-user]
    end

    User[User/Platform] -->|creates| RayClusterCR
    User -->|creates| RayJobCR
    User -->|creates| RayServiceCR
    APIClient[API Client] -->|gRPC/HTTP| APIServer

    RayClusterCR -->|watched by| RayClusterCtrl
    RayJobCR -->|watched by| RayJobCtrl
    RayServiceCR -->|watched by| RayServiceCtrl

    RayClusterCtrl -->|creates| RayHead
    RayClusterCtrl -->|creates| RayWorker1
    RayClusterCtrl -->|creates| RayWorker2
    RayClusterCtrl -->|creates| HeadService
    RayServiceCtrl -->|creates| ServeService

    Operator -->|manages resources| K8sAPI
    APIServer -->|manages CRs| K8sAPI
    Operator -->|creates| Routes
    Operator -->|uses| SCC

    RayHead -->|pulls images| Registry
    RayWorker1 -->|pulls images| Registry
    RayWorker2 -->|pulls images| Registry

    RayWorker1 -->|connects 6379/TCP| RayHead
    RayWorker2 -->|connects 6379/TCP| RayHead

    RayHead -->|fault tolerance| ExternalRedis
    RayHead -->|storage| S3Storage

    Prometheus -->|scrapes 8080/TCP| Operator
    Prometheus -->|scrapes 8080/TCP| RayHead

    Routes -->|exposes| HeadService
    Routes -->|exposes| ServeService

    style Operator fill:#4a90e2,stroke:#333,stroke-width:2px
    style APIServer fill:#4a90e2,stroke:#333,stroke-width:2px
    style RayClusterCtrl fill:#7ed321,stroke:#333
    style RayJobCtrl fill:#7ed321,stroke:#333
    style RayServiceCtrl fill:#7ed321,stroke:#333
    style RayClusterCR fill:#f5a623,stroke:#333
    style RayJobCR fill:#f5a623,stroke:#333
    style RayServiceCR fill:#f5a623,stroke:#333
    style K8sAPI fill:#e8e8e8,stroke:#333
    style Registry fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style Routes fill:#bd10e0,stroke:#333
    style SCC fill:#bd10e0,stroke:#333
