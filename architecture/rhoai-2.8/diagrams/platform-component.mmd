graph TB
    subgraph "RHODS Platform Components"
        direction TB

        subgraph "Operator Control Plane"
            RHODSOp[RHODS Operator<br/>v1.6.0-1892]
            KServeOp[KServe Operator<br/>c7788a198]
            ModelMeshOp[ModelMesh Operator<br/>v1.27.0-rhods-217]
            DSPOp[Data Science Pipelines Operator<br/>266aee4]
            CodeFlareOp[CodeFlare Operator<br/>c7e38f8]
            KubeRayOp[KubeRay Operator<br/>e603d04d]
            KueueOp[Kueue Operator<br/>f99252525]
            TrustyAIOp[TrustyAI Operator<br/>288fadf]
        end

        subgraph "Platform Services"
            Dashboard[ODH Dashboard<br/>v1.21.0-18]
            NotebookCtrl[ODH Notebook Controller<br/>v1.27.0-rhods-319]
            ModelCtrl[ODH Model Controller<br/>v1.27.0-rhods-216]
        end

        subgraph "User Workloads"
            Notebooks[Notebook Workbenches<br/>Jupyter, VS Code, RStudio]
            InferenceSvc[InferenceService Pods<br/>KServe Serverless]
            ModelMesh[ModelMesh Runtime<br/>Multi-model Serving]
            Pipelines[Data Science Pipelines<br/>KFP + Tekton]
            RayClusters[Ray Clusters<br/>Distributed Compute]
            TrustyAI[TrustyAI Services<br/>AI Explainability]
        end
    end

    subgraph "Custom Resources"
        DataScienceCluster[DataScienceCluster CR]
        NotebookCR[Notebook CR]
        InferenceServiceCR[InferenceService CR]
        PredictorCR[Predictor CR]
        DSPACR[DataSciencePipelinesApplication CR]
        RayClusterCR[RayCluster CR]
        AppWrapperCR[AppWrapper CR]
        TrustyAICR[TrustyAIService CR]
    end

    subgraph "External Dependencies"
        Kubernetes[Kubernetes API<br/>OpenShift 4.12+]
        OAuth[OpenShift OAuth]
        Istio[Istio Service Mesh<br/>Traffic Management]
        Knative[Knative Serving<br/>Serverless Runtime]
        Tekton[OpenShift Pipelines<br/>Tekton]
        Prometheus[Prometheus<br/>Monitoring]
        S3[S3 Storage<br/>Model/Data Artifacts]
    end

    %% Operator Relationships
    RHODSOp -->|deploys| Dashboard
    RHODSOp -->|deploys| NotebookCtrl
    RHODSOp -->|deploys| ModelCtrl
    RHODSOp -->|manages| DataScienceCluster

    %% Dashboard Interactions
    Dashboard -->|creates| NotebookCR
    Dashboard -->|creates| InferenceServiceCR
    Dashboard -->|creates| PredictorCR
    Dashboard -->|creates| DSPACR
    Dashboard -->|queries| Prometheus

    %% Notebook Controller
    NotebookCtrl -->|watches| NotebookCR
    NotebookCtrl -->|creates| Notebooks
    NotebookCR -->|spec for| Notebooks

    %% KServe Flow
    KServeOp -->|watches| InferenceServiceCR
    KServeOp -->|creates| InferenceSvc
    ModelCtrl -->|watches| InferenceServiceCR
    ModelCtrl -->|creates Routes for| InferenceSvc

    %% ModelMesh Flow
    ModelMeshOp -->|watches| PredictorCR
    ModelMeshOp -->|creates| ModelMesh
    ModelCtrl -->|creates Routes for| ModelMesh

    %% Pipelines Flow
    DSPOp -->|watches| DSPACR
    DSPOp -->|creates| Pipelines

    %% Ray Flow
    KubeRayOp -->|watches| RayClusterCR
    KubeRayOp -->|creates| RayClusters
    CodeFlareOp -->|wraps RayCluster in| AppWrapperCR
    KueueOp -->|admits| AppWrapperCR

    %% TrustyAI Flow
    TrustyAIOp -->|watches| TrustyAICR
    TrustyAIOp -->|creates| TrustyAI
    TrustyAIOp -->|patches| InferenceServiceCR

    %% External Dependencies
    RHODSOp -->|API calls| Kubernetes
    Dashboard -->|authentication| OAuth
    KServeOp -->|requires| Knative
    KServeOp -->|requires| Istio
    ModelCtrl -->|configures| Istio
    DSPOp -->|requires| Tekton
    InferenceSvc -->|pulls models from| S3
    ModelMesh -->|pulls models from| S3
    Notebooks -->|stores data to| S3
    Pipelines -->|stores artifacts to| S3

    %% Monitoring
    Dashboard -.->|scrapes| Prometheus
    InferenceSvc -.->|exposes metrics to| Prometheus
    ModelMesh -.->|exposes metrics to| Prometheus

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef service fill:#7ed321,stroke:#333,stroke-width:2px
    classDef workload fill:#f5a623,stroke:#333,stroke-width:2px
    classDef cr fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef external fill:#999,stroke:#333,stroke-width:2px

    class RHODSOp,KServeOp,ModelMeshOp,DSPOp,CodeFlareOp,KubeRayOp,KueueOp,TrustyAIOp operator
    class Dashboard,NotebookCtrl,ModelCtrl service
    class Notebooks,InferenceSvc,ModelMesh,Pipelines,RayClusters,TrustyAI workload
    class DataScienceCluster,NotebookCR,InferenceServiceCR,PredictorCR,DSPACR,RayClusterCR,AppWrapperCR,TrustyAICR cr
    class Kubernetes,OAuth,Istio,Knative,Tekton,Prometheus,S3 external
