graph TB
    subgraph "ODH Model Controller"
        Controller[Controller Manager<br/>3 Replicas + Leader Election]

        subgraph "Reconcilers"
            ISVCReconciler[InferenceService Controller]
            StorageReconciler[StorageSecret Controller]
            CAReconciler[KServeCustomCACert Controller]
            MonitoringReconciler[Monitoring Controller]
        end

        subgraph "Sub-Reconcilers"
            KServeRec[KServe Reconciler<br/>Serverless/RawDeployment]
            ModelMeshRec[ModelMesh Reconciler]
        end

        Controller --> ISVCReconciler
        Controller --> StorageReconciler
        Controller --> CAReconciler
        Controller --> MonitoringReconciler

        ISVCReconciler --> KServeRec
        ISVCReconciler --> ModelMeshRec
    end

    subgraph "Watched CRDs"
        InferenceServiceCR[InferenceService<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Created Resources - KServe Serverless"
        Route[OpenShift Route<br/>443/TCP HTTPS]
        SMMR[ServiceMeshMemberRoll]
        PeerAuth[PeerAuthentication<br/>PERMISSIVE mTLS]
        Telemetry[Telemetry<br/>Istio Metrics]
        NetworkPolicy[NetworkPolicy]
        ServiceMonitor[ServiceMonitor<br/>App Metrics :8080]
        PodMonitor[PodMonitor<br/>Istio Metrics :15020]
        MetricsSvc["Service<br/>(isvc-name)-metrics"]
        RoleBinding[RoleBinding<br/>Prometheus Access]
    end

    subgraph "Created Resources - ModelMesh"
        RoutesMM[OpenShift Route]
        ServiceAccount[ServiceAccount]
        ClusterRoleBinding[ClusterRoleBinding]
    end

    subgraph "Storage Integration"
        DataConnectionSecret[Data Connection Secret<br/>Created by Dashboard]
        StorageConfigSecret[storage-config Secret<br/>Aggregated Credentials]
    end

    subgraph "External Dependencies"
        KServe[KServe Controller<br/>v0.11.0]
        ModelMesh[ModelMesh Controller]
        Istio[Istio Service Mesh<br/>v1.17.4]
        Prometheus[Prometheus Operator<br/>v0.64.1]
        OpenShiftRouter[OpenShift Router]
        K8sAPI[Kubernetes API Server]
    end

    %% Watch relationships
    InferenceServiceCR -->|watched by| ISVCReconciler
    ServingRuntimeCR -->|watched by| ISVCReconciler
    DataConnectionSecret -->|watched by| StorageReconciler

    %% Creation relationships - KServe
    KServeRec -->|creates| Route
    KServeRec -->|creates| SMMR
    KServeRec -->|creates| PeerAuth
    KServeRec -->|creates| Telemetry
    KServeRec -->|creates| NetworkPolicy
    KServeRec -->|creates| ServiceMonitor
    KServeRec -->|creates| PodMonitor
    KServeRec -->|creates| MetricsSvc
    MonitoringReconciler -->|creates| RoleBinding

    %% Creation relationships - ModelMesh
    ModelMeshRec -->|creates| RoutesMM
    ModelMeshRec -->|creates| ServiceAccount
    ModelMeshRec -->|creates| ClusterRoleBinding

    %% Storage flow
    StorageReconciler -->|aggregates into| StorageConfigSecret

    %% CA certificate injection
    CAReconciler -->|injects CA certs into| StorageConfigSecret

    %% External integrations
    Controller -->|watches via| K8sAPI
    Route -->|exposes via| OpenShiftRouter
    SMMR -->|configures| Istio
    PeerAuth -->|configures| Istio
    Telemetry -->|configures| Istio
    ServiceMonitor -->|scraped by| Prometheus
    PodMonitor -->|scraped by| Prometheus

    %% Coordination
    ISVCReconciler -.->|coordinates with| KServe
    ISVCReconciler -.->|coordinates with| ModelMesh

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style ISVCReconciler fill:#4a90e2,stroke:#333
    style StorageReconciler fill:#4a90e2,stroke:#333
    style CAReconciler fill:#4a90e2,stroke:#333
    style MonitoringReconciler fill:#4a90e2,stroke:#333
    style KServeRec fill:#7ed321,stroke:#333
    style ModelMeshRec fill:#7ed321,stroke:#333
    style InferenceServiceCR fill:#f5a623,stroke:#333
    style ServingRuntimeCR fill:#f5a623,stroke:#333
    style KServe fill:#e8e8e8,stroke:#333
    style ModelMesh fill:#e8e8e8,stroke:#333
    style Istio fill:#e8e8e8,stroke:#333
    style Prometheus fill:#e8e8e8,stroke:#333
    style OpenShiftRouter fill:#e8e8e8,stroke:#333
