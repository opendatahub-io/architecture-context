graph TB
    subgraph "CodeFlare Operator"
        Manager[Manager Deployment<br/>Port: 8080, 8081]
        MCADController[MCAD Controller<br/>In-process]
        InstaScaleController[InstaScale Controller<br/>In-process, Optional]

        Manager -->|runs| MCADController
        Manager -->|runs| InstaScaleController
    end

    subgraph "Custom Resources (CRDs)"
        AppWrapper[AppWrapper CR<br/>workload.codeflare.dev/v1beta1]
        QuotaSubtree[QuotaSubtree CR<br/>quota.codeflare.dev/v1alpha1]
        SchedulingSpec[SchedulingSpec CR<br/>workload.codeflare.dev/v1beta1]
    end

    subgraph "External Dependencies"
        KubeAPI[Kubernetes API<br/>6443/TCP HTTPS]
        KubeRay[KubeRay Operator<br/>RayCluster CRD]
        MachineAPI[OpenShift Machine API<br/>MachineSets]
        Prometheus[Prometheus<br/>Metrics Collection]
    end

    subgraph "Created Resources"
        Pods[Pods]
        Jobs[Jobs]
        RayClusters[RayClusters]
        MachineSets[MachineSets<br/>OpenShift only]
        Services[Services]
        Deployments[Deployments]
    end

    User[User/CodeFlare SDK] -->|creates| AppWrapper
    User -->|creates| QuotaSubtree

    AppWrapper -->|watched by| MCADController
    QuotaSubtree -->|managed by| MCADController
    SchedulingSpec -->|configured in| AppWrapper

    MCADController -->|creates/manages| Pods
    MCADController -->|creates/manages| Jobs
    MCADController -->|creates/manages| RayClusters
    MCADController -->|creates/manages| Services
    MCADController -->|creates/manages| Deployments

    InstaScaleController -->|watches| AppWrapper
    InstaScaleController -->|creates/deletes| MachineSets

    Manager -->|API calls| KubeAPI
    MCADController -->|integrates| KubeRay
    InstaScaleController -->|uses| MachineAPI
    Manager -->|exports metrics| Prometheus

    style Manager fill:#4a90e2
    style MCADController fill:#4a90e2
    style InstaScaleController fill:#9bd1f9
    style AppWrapper fill:#f5a623
    style QuotaSubtree fill:#f5a623
    style SchedulingSpec fill:#f5a623
    style KubeAPI fill:#e8e8e8
    style KubeRay fill:#e8e8e8
    style MachineAPI fill:#e8e8e8
    style Prometheus fill:#7ed321
