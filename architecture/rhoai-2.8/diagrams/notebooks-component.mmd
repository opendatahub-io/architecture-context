graph TB
    subgraph "Notebook Workbench Images"
        direction TB

        subgraph "Base Images"
            BaseUBI9[base-ubi9-python-3.9<br/>UBI9 + pip + oc CLI]
            BaseUBI8[base-ubi8-python-3.8<br/>UBI8 + pip + oc CLI]
            BaseRHEL9[base-rhel9-python-3.9<br/>RHEL9 + pip + oc CLI]
            BaseCentOS[base-c9s-python-3.9<br/>CentOS Stream 9]
        end

        subgraph "Jupyter Notebooks"
            JupyterMin[Jupyter Minimal<br/>JupyterLab 3.6 + Git + Proxy]
            JupyterDS[Jupyter Data Science<br/>pandas + scikit-learn + Elyra]
            JupyterPyTorch[Jupyter PyTorch<br/>Deep Learning]
            JupyterTF[Jupyter TensorFlow<br/>Deep Learning]
            JupyterTrustyAI[Jupyter TrustyAI<br/>Explainability + Bias Detection]
        end

        subgraph "GPU-Accelerated"
            CUDA[CUDA Base<br/>NVIDIA CUDA Runtime]
            CUDAJupyter[CUDA Jupyter DS<br/>GPU Data Science]
        end

        subgraph "Runtime Images"
            RuntimeMin[Runtime Minimal<br/>Elyra Pipeline Execution]
            RuntimeDS[Runtime Data Science<br/>Pipeline Execution]
            RuntimePyTorch[Runtime PyTorch<br/>Pipeline Execution]
        end

        subgraph "Alternative IDEs"
            CodeServer[Code Server<br/>VS Code + nginx]
            RStudio[RStudio Server<br/>R IDE + nginx]
        end

        subgraph "Deployment"
            ImageStreams[ImageStream Manifests<br/>N, N-1, N-2 versions]
            ConfigMaps[ConfigMap Parameters<br/>SHA256 digests]
        end
    end

    subgraph "External Dependencies"
        UBI9Image[UBI9 Python 3.9<br/>registry.access.redhat.com]
        RHEL9Image[RHEL9 Python 3.9<br/>registry.redhat.io]
        NVIDIAImage[NVIDIA CUDA<br/>nvidia/cuda]
    end

    subgraph "ODH Integration"
        NotebookController[ODH Notebook Controller<br/>Launches notebook pods]
        Dashboard[ODH Dashboard<br/>Image selection UI]
        OAuthProxy[OAuth Proxy<br/>Authentication sidecar]
    end

    subgraph "User Workloads"
        NotebookPod[Notebook Pod<br/>User workspace]
        PipelinePod[Pipeline Pod<br/>Elyra runtime]
    end

    %% Build chain
    UBI9Image --> BaseUBI9
    RHEL9Image --> BaseRHEL9
    BaseUBI9 --> JupyterMin
    JupyterMin --> JupyterDS
    JupyterDS --> JupyterPyTorch
    JupyterDS --> JupyterTrustyAI

    BaseUBI9 --> CUDA
    NVIDIAImage --> CUDA
    CUDA --> CUDAJupyter
    CUDAJupyter --> JupyterTF

    BaseUBI9 --> RuntimeMin
    BaseUBI9 --> RuntimeDS
    BaseUBI9 --> RuntimePyTorch

    BaseCentOS --> CodeServer
    BaseCentOS --> RStudio

    %% Deployment
    JupyterDS --> ImageStreams
    JupyterPyTorch --> ImageStreams
    JupyterTF --> ImageStreams
    RuntimeDS --> ImageStreams
    CodeServer --> ImageStreams
    ImageStreams --> ConfigMaps

    %% Integration
    ImageStreams --> NotebookController
    Dashboard --> NotebookController
    NotebookController --> NotebookPod
    OAuthProxy -.->|sidecar| NotebookPod

    RuntimeDS --> PipelinePod

    style BaseUBI9 fill:#e8f4f8,stroke:#0066cc
    style JupyterDS fill:#d4edda,stroke:#28a745
    style CUDA fill:#fff3cd,stroke:#ffc107
    style NotebookController fill:#f8d7da,stroke:#dc3545
    style ImageStreams fill:#d1ecf1,stroke:#17a2b8
    style NotebookPod fill:#e2e3e5,stroke:#6c757d
