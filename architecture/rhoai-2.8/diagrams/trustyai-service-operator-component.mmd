graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller<br/>Port: 8080/TCP Metrics<br/>Port: 8081/TCP Health]
        Watches[CR Watch Manager]
        Controller -->|reconciles| Watches
    end

    subgraph "Per-Instance Resources"
        direction TB
        TrustyAIService[TrustyAI Service Pod]
        OAuthProxy[OAuth Proxy Sidecar<br/>Port: 8443/TCP HTTPS]
        PVC[PersistentVolumeClaim<br/>ReadWriteOnce]

        TrustyAIService -->|mounted| PVC
        OAuthProxy -->|proxies to| TrustyAIService
    end

    subgraph "Custom Resources"
        TrustyAICR[TrustyAIService CR<br/>trustyai.opendatahub.io/v1alpha1]
        InferenceServiceCR[InferenceService CR<br/>serving.kserve.io/v1beta1]
        ServingRuntimeCR[ServingRuntime CR<br/>serving.kserve.io/v1alpha1]
    end

    subgraph "Network Resources"
        InternalSvc["Service: instance-name<br/>ClusterIP 80/TCP → 8080"]
        TLSSvc["Service: instance-name-tls<br/>ClusterIP 443/TCP → 8443"]
        Route["Route: instance-name<br/>443/TCP HTTPS Passthrough"]
    end

    subgraph "Monitoring"
        LocalSM["ServiceMonitor - Local<br/>Per-namespace"]
        CentralSM["ServiceMonitor - Central<br/>Operator namespace"]
    end

    subgraph "External Dependencies"
        KServe[KServe<br/>Inference Logging]
        ModelMesh[ModelMesh<br/>Payload Processor]
        Prometheus[Prometheus<br/>Metrics Scraping]
        OpenShiftOAuth[OpenShift OAuth<br/>Authentication]
        K8sAPI[Kubernetes API]
    end

    %% User interaction
    User[User/Dashboard] -->|creates| TrustyAICR

    %% Controller watches
    TrustyAICR -->|watched by| Watches
    InferenceServiceCR -->|watched by| Watches
    ServingRuntimeCR -->|watched by| Watches

    %% Controller creates resources
    Controller -->|creates/manages| TrustyAIService
    Controller -->|creates/manages| OAuthProxy
    Controller -->|creates/manages| PVC
    Controller -->|creates/manages| InternalSvc
    Controller -->|creates/manages| TLSSvc
    Controller -->|creates/manages| Route
    Controller -->|creates/manages| LocalSM
    Controller -->|creates/manages| CentralSM

    %% Service routing
    InternalSvc -->|routes to| TrustyAIService
    TLSSvc -->|routes to| OAuthProxy
    Route -->|routes to| TLSSvc

    %% Monitoring
    LocalSM -->|scrapes| InternalSvc
    CentralSM -->|aggregates| LocalSM

    %% External integrations
    Controller -->|patches| InferenceServiceCR
    Controller -->|configures| ModelMesh
    Controller -->|API calls| K8sAPI

    TrustyAIService -->|receives inference data| KServe
    TrustyAIService -->|receives payloads| ModelMesh
    TrustyAIService -->|metrics| Prometheus
    OAuthProxy -->|authenticates via| OpenShiftOAuth

    style Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAIService fill:#4a90e2,stroke:#333,stroke-width:2px
    style OAuthProxy fill:#4a90e2,stroke:#333,stroke-width:2px
    style TrustyAICR fill:#f5a623,stroke:#333,stroke-width:2px
    style InferenceServiceCR fill:#f5a623,stroke:#333,stroke-width:2px
    style ServingRuntimeCR fill:#f5a623,stroke:#333,stroke-width:2px
    style KServe fill:#7ed321,stroke:#333,stroke-width:2px
    style ModelMesh fill:#7ed321,stroke:#333,stroke-width:2px
    style Prometheus fill:#7ed321,stroke:#333,stroke-width:2px
    style OpenShiftOAuth fill:#999,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px
