graph TD
    subgraph "Service Accounts"
        SA[odh-notebook-controller-manager<br/>SA in system namespace]
        NotebookSA["{notebook-name}-sa<br/>SA in user namespace<br/>Created per notebook"]
    end

    subgraph "ClusterRole Bindings"
        CRB[odh-notebook-controller-manager-rolebinding<br/>ClusterRoleBinding]
    end

    subgraph "RoleBindings"
        RB[odh-notebook-controller-leader-election-rolebinding<br/>RoleBinding in system namespace]
    end

    subgraph "ClusterRoles"
        ManagerRole[odh-notebook-controller-manager-role<br/>ClusterRole]
        LeaderElectionRole[odh-notebook-controller-leader-election-role<br/>Role in system namespace]
        NotebooksAdmin[notebooks-admin<br/>ClusterRole<br/>User-facing]
        NotebooksEdit[notebooks-edit<br/>ClusterRole<br/>User-facing]
        NotebooksView[notebooks-view<br/>ClusterRole<br/>User-facing]
    end

    subgraph "API Resources - Core"
        ConfigMaps[core/ConfigMaps<br/>get, list, watch, create, update, patch, delete]
        Secrets[core/Secrets<br/>create, get, list, patch, update, watch]
        ServiceAccounts[core/ServiceAccounts<br/>create, get, list, patch, update, watch]
        Services[core/Services<br/>create, get, list, patch, update, watch]
        Events[core/Events<br/>create, patch]
    end

    subgraph "API Resources - OpenShift"
        Proxies[config.openshift.io/Proxies<br/>get, list, watch]
        Routes[route.openshift.io/Routes<br/>create, get, list, patch, update, watch]
    end

    subgraph "API Resources - Kubeflow"
        Notebooks[kubeflow.org/Notebooks<br/>get, list, patch, watch]
        NotebooksFinalizers[kubeflow.org/Notebooks/finalizers<br/>update]
        NotebooksStatus[kubeflow.org/Notebooks/status<br/>get]
    end

    subgraph "API Resources - Networking"
        NetworkPolicies[networking.k8s.io/NetworkPolicies<br/>create, get, list, patch, update, watch]
    end

    subgraph "API Resources - Coordination"
        Leases[coordination.k8s.io/Leases<br/>get, list, watch, create, update, patch, delete]
    end

    %% Service Account to RoleBindings
    SA -->|bound via| CRB
    SA -->|bound via| RB

    %% RoleBindings to Roles
    CRB -->|grants| ManagerRole
    RB -->|grants| LeaderElectionRole

    %% Manager Role permissions - Core
    ManagerRole -->|permissions| ConfigMaps
    ManagerRole -->|permissions| Secrets
    ManagerRole -->|permissions| ServiceAccounts
    ManagerRole -->|permissions| Services

    %% Manager Role permissions - OpenShift
    ManagerRole -->|permissions| Proxies
    ManagerRole -->|permissions| Routes

    %% Manager Role permissions - Kubeflow
    ManagerRole -->|permissions| Notebooks
    ManagerRole -->|permissions| NotebooksFinalizers
    ManagerRole -->|permissions| NotebooksStatus

    %% Manager Role permissions - Networking
    ManagerRole -->|permissions| NetworkPolicies

    %% Leader Election Role permissions
    LeaderElectionRole -->|permissions| ConfigMaps
    LeaderElectionRole -->|permissions| Leases
    LeaderElectionRole -->|permissions| Events

    %% User-facing roles
    NotebooksAdmin -->|aggregates from| NotebooksEdit
    NotebooksEdit -->|permissions<br/>get, list, watch,<br/>create, delete,<br/>patch, update| Notebooks
    NotebooksEdit -->|permissions<br/>get, list, watch,<br/>create, delete,<br/>patch, update| NotebooksStatus
    NotebooksView -->|permissions<br/>get, list, watch| Notebooks
    NotebooksView -->|permissions<br/>get, list, watch| NotebooksStatus

    %% OAuth authorization flow
    OAuthProxy[OAuth Proxy<br/>Performs SAR] -.->|checks permission| K8sAPI[Kubernetes API<br/>SubjectAccessReview]
    K8sAPI -.->|validates user has<br/>GET on Notebook CR| Notebooks

    %% Notebook SA usage
    NotebookSA -.->|used by| NotebookPod[Notebook Pod<br/>with OAuth proxy sidecar]

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style NotebookSA fill:#6c8ebf,stroke:#333,stroke-width:2px,color:#fff
    style ManagerRole fill:#f5a623,stroke:#333,stroke-width:2px
    style LeaderElectionRole fill:#f5a623,stroke:#333,stroke-width:2px
    style NotebooksAdmin fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebooksEdit fill:#7ed321,stroke:#333,stroke-width:2px
    style NotebooksView fill:#7ed321,stroke:#333,stroke-width:2px
    style Notebooks fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NotebooksFinalizers fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style NotebooksStatus fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    style Routes fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style OAuthProxy fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
