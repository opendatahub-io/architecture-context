graph TD
    subgraph "Operator RBAC"
        SA_Operator["ServiceAccount<br/>controller-manager<br/>NS: redhat-ods-applications"]
        CRB_Operator["ClusterRoleBinding<br/>manager-rolebinding"]
        CR_Operator["ClusterRole<br/>manager-role"]
    end

    subgraph "Per-DSPA RBAC (created by operator)"
        SA_DSPA["ServiceAccount<br/>ds-pipeline-NAME<br/>NS: user-namespace"]
        RB_DSPA["RoleBinding<br/>ds-pipeline-NAME"]
        R_DSPA["Role<br/>ds-pipeline-NAME"]

        RB_User["RoleBinding<br/>ds-pipeline-user-access-NAME"]
        R_User["Role<br/>ds-pipeline-user-access-NAME"]

        RB_Runner["RoleBinding<br/>pipeline-runner-NAME"]
        R_Runner["Role<br/>pipeline-runner-NAME"]
    end

    subgraph "API Resources - Operator Scope"
        DSPACR[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication<br/>+ status, finalizers]
        Deployments[apps/Deployments]
        Services[core/Services]
        ConfigMaps[core/ConfigMaps]
        Secrets[core/Secrets]
        ServiceAccounts[core/ServiceAccounts]
        PVCs[core/PersistentVolumeClaims]
        Roles[rbac.authorization.k8s.io/Roles]
        RoleBindings[rbac.authorization.k8s.io/RoleBindings]
        Routes[route.openshift.io/Routes]
        TektonAll[tekton.dev/* <br/>All Tekton resources]
        PipelineLoops[custom.tekton.dev/pipelineloops]
        NetworkPolicies[networking.k8s.io/networkpolicies]
        ServiceMonitors[monitoring.coreos.com/servicemonitors]
        Jobs[batch/jobs]
        KubeflowAll[kubeflow.org/*]
        ArgoWorkflows[argoproj.io/workflows]
        RayResources[ray.io/rayclusters<br/>rayjobs, rayservices]
        AppWrappers[workload.codeflare.dev/appwrappers<br/>+ finalizers, status]
    end

    subgraph "API Resources - Per-DSPA Scope"
        NSSecrets[core/secrets]
        NSConfigMaps[core/configmaps]
        NSServices[core/services]
        NSServiceAccounts[core/serviceaccounts]

        TektonPipelines[tekton.dev/pipelineruns<br/>taskruns, pipelines, tasks]
        TektonLoops[custom.tekton.dev/pipelineloops]
        Pods[core/pods, pods/log]

        DSPARead[datasciencepipelinesapplications.opendatahub.io<br/>DataSciencePipelinesApplication]
    end

    subgraph "Auth Resources"
        TokenReviews[authentication.k8s.io/tokenreviews]
        SubjectAccessReviews[authorization.k8s.io/subjectaccessreviews]
    end

    %% Operator Bindings
    SA_Operator -->|bound via| CRB_Operator
    CRB_Operator -->|grants| CR_Operator

    %% Operator Permissions
    CR_Operator -->|get,list,watch,create,update,patch,delete| DSPACR
    CR_Operator -->|get,list,watch,create,update,patch,delete| Deployments
    CR_Operator -->|get,list,watch,create,update,patch,delete| Services
    CR_Operator -->|get,list,watch,create,update,patch,delete| ConfigMaps
    CR_Operator -->|get,list,watch,create,update,patch,delete| Secrets
    CR_Operator -->|get,list,watch,create,update,patch,delete| ServiceAccounts
    CR_Operator -->|get,list,watch,create,update,patch,delete| PVCs
    CR_Operator -->|get,list,watch,create,update,patch,delete| Roles
    CR_Operator -->|get,list,watch,create,update,patch,delete| RoleBindings
    CR_Operator -->|get,list,watch,create,update,patch,delete| Routes
    CR_Operator -->|*| TektonAll
    CR_Operator -->|*| PipelineLoops
    CR_Operator -->|get,list,watch,create,update,patch,delete| NetworkPolicies
    CR_Operator -->|get,list,watch,create,update,patch,delete| ServiceMonitors
    CR_Operator -->|*| Jobs
    CR_Operator -->|*| KubeflowAll
    CR_Operator -->|*| ArgoWorkflows
    CR_Operator -->|create,get,list,patch,delete| RayResources
    CR_Operator -->|create,delete,deletecollection,get,list,patch,update,watch| AppWrappers
    CR_Operator -->|create| TokenReviews
    CR_Operator -->|create| SubjectAccessReviews

    %% Per-DSPA Bindings
    SA_DSPA -->|bound via| RB_DSPA
    RB_DSPA -->|grants| R_DSPA

    SA_DSPA -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner

    %% User Access
    RB_User -->|grants read| R_User

    %% Per-DSPA Permissions
    R_DSPA -->|get,list,watch| NSSecrets
    R_DSPA -->|get,list,watch| NSConfigMaps
    R_DSPA -->|get,list,watch| NSServices
    R_DSPA -->|get,list,watch| NSServiceAccounts

    R_Runner -->|create,get,list,watch,update,patch,delete| TektonPipelines
    R_Runner -->|create,get,list,watch,update,patch,delete| TektonLoops
    R_Runner -->|get,list,watch| Pods

    R_User -->|get,list,watch| DSPARead

    %% Styling
    style SA_Operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_DSPA fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff

    style CR_Operator fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style R_DSPA fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style R_Runner fill:#f5a623,stroke:#333,stroke-width:2px,color:#000
    style R_User fill:#f5a623,stroke:#333,stroke-width:2px,color:#000

    style DSPACR fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style TektonAll fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style TektonPipelines fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
    style DSPARead fill:#7ed321,stroke:#333,stroke-width:2px,color:#000
