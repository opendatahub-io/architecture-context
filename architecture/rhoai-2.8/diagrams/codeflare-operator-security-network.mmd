graph TB
    subgraph External["EXTERNAL (User Context)"]
        User[User / CodeFlare SDK]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+<br/>RBAC Enforcement"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE (opendatahub)"]
        direction TB

        Manager["CodeFlare Operator Manager<br/>Deployment: manager<br/>SA: controller-manager<br/>User: 65532 (non-root)"]

        subgraph Controllers["Internal Controllers"]
            MCAD["MCAD Controller<br/>In-process<br/>ClusterRole: manager-role"]
            InstaScale["InstaScale Controller<br/>In-process (Optional)<br/>ClusterRole: instascale-role<br/>OpenShift only"]
        end

        Manager -->|runs| MCAD
        Manager -->|runs| InstaScale

        Metrics["Metrics Endpoint<br/>/metrics<br/>8080/TCP HTTP<br/>No Auth"]
        Health["Health Endpoints<br/>/healthz, /readyz<br/>8081/TCP HTTP<br/>No Auth"]

        Manager -->|exposes| Metrics
        Manager -->|exposes| Health
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>ServiceMonitor: manager-metrics<br/>Bearer Token Auth"]
        Kubelet["Kubelet<br/>Health Checks"]
    end

    subgraph Integrations["EXTERNAL INTEGRATIONS"]
        KubeRay["KubeRay Operator<br/>CRD: ray.io/rayclusters"]
        MachineAPI["OpenShift Machine API<br/>CRD: machine.openshift.io/machinesets<br/>OpenShift only"]
    end

    %% Flows
    User -->|HTTPS/6443<br/>TLS 1.2+<br/>User credentials| K8sAPI
    K8sAPI -->|Watch Events<br/>AppWrapper, QuotaSubtree| MCAD
    MCAD -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI
    InstaScale -->|HTTPS/6443<br/>TLS 1.2+<br/>ServiceAccount Token| K8sAPI

    K8sAPI -.->|manages| KubeRay
    K8sAPI -.->|manages| MachineAPI

    MCAD -.->|creates RayCluster CRs| KubeRay
    InstaScale -.->|creates/deletes MachineSets| MachineAPI

    Prometheus -->|HTTP/8080<br/>Bearer Token<br/>Scrape /metrics| Metrics
    Kubelet -->|HTTP/8081<br/>Health checks| Health

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef operator fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef monitoring fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef integration fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class K8sAPI controlplane
    class Manager,MCAD,InstaScale,Metrics,Health operator
    class Prometheus,Kubelet monitoring
    class KubeRay,MachineAPI integration
