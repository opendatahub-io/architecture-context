graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Admin[Administrator/User]
    end

    subgraph ControlPlane["KUBERNETES CONTROL PLANE"]
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS TLS1.2+<br/>OAuth/Client Cert/SA Token"]
        Webhook["Operator Webhook Server<br/>9443/TCP HTTPS TLS1.2+<br/>TLS Client Cert (K8s API)"]
    end

    subgraph OperatorNS["NAMESPACE: redhat-ods-operator"]
        direction TB

        Controller["Controller Manager Pod<br/>SA: controller-manager<br/>Security: runAsNonRoot, drop all caps"]

        subgraph Controllers["Controllers"]
            DSCInitCtrl[DSCInitialization<br/>Platform Init]
            DSCCtrl[DataScienceCluster<br/>Component Lifecycle]
            SecretGen[SecretGenerator<br/>Credentials]
            CertGen[CertConfigmapGenerator<br/>Certificates]
        end

        MetricsSvc["Metrics Service<br/>8443/TCP → 8080/TCP<br/>HTTP (kube-rbac-proxy wraps TLS)"]
        HealthProbes["Health Probes<br/>8081/TCP HTTP<br/>/healthz, /readyz"]

        Controller --> DSCInitCtrl
        Controller --> DSCCtrl
        Controller --> SecretGen
        Controller --> CertGen
        Controller --> MetricsSvc
        Controller --> HealthProbes
    end

    subgraph MonitoringNS["NAMESPACE: redhat-ods-monitoring"]
        direction TB

        Prometheus["Prometheus<br/>SA: prometheus<br/>ClusterRole: prometheus-scraper"]
        PrometheusRoute["Prometheus Route<br/>9091/TCP HTTPS TLS1.2+<br/>prometheus-{ns}.{domain}"]
        Alertmanager["Alertmanager<br/>9093/TCP HTTP"]
        BlackboxExp["Blackbox Exporter<br/>9115/TCP HTTP"]

        Prometheus --> PrometheusRoute
    end

    subgraph ComponentNS["COMPONENT NAMESPACES<br/>redhat-ods-applications, {user-namespaces}"]
        Dashboard[Dashboard]
        Workbenches[Workbenches]
        KServe[KServe]
        ModelMesh[ModelMesh]
        Pipelines[Pipelines]
        CodeFlare[CodeFlare]
        Ray[Ray]
        Kueue[Kueue]
        TrustyAI[TrustyAI]
    end

    subgraph ExternalSvc["EXTERNAL SERVICES"]
        Registry["Image Registries<br/>registry.redhat.io, quay.io<br/>443/TCP HTTPS TLS1.2+<br/>Pull Secrets"]
        GitRepos["Git Repositories<br/>github.com, gitlab.com<br/>443/TCP HTTPS TLS1.2+<br/>Optional"]
        OAuth["OpenShift OAuth<br/>6443/TCP HTTPS TLS1.2+<br/>OAuth Tokens"]
    end

    %% Flows
    Admin -->|HTTPS/6443<br/>TLS 1.2+<br/>OAuth/Cert| K8sAPI
    K8sAPI -->|Webhook Validation<br/>HTTPS/9443<br/>TLS Client Cert| Webhook
    K8sAPI -->|Watch Events<br/>HTTPS Watch API<br/>SA Token| Controller
    Controller -->|Reconciliation<br/>HTTPS/6443<br/>SA Token<br/>RBAC: controller-manager-role| K8sAPI
    Controller -->|Deploy Components<br/>HTTPS/6443<br/>SA Token| ComponentNS

    Prometheus -->|Scrape<br/>HTTP/8080<br/>No Auth<br/>NetworkPolicy| MetricsSvc
    Prometheus -->|Scrape Components<br/>HTTP/HTTPS Various<br/>Bearer Token| ComponentNS
    Prometheus -->|Export<br/>HTTPS/9091<br/>TLS 1.2+<br/>Bearer Token| PrometheusRoute

    Controller -->|Pull Images<br/>HTTPS/443<br/>TLS 1.2+<br/>Pull Secrets| Registry
    Controller -.->|Fetch Manifests<br/>HTTPS/443<br/>TLS 1.2+| GitRepos
    ComponentNS -->|User Auth<br/>HTTPS/6443<br/>TLS 1.2+<br/>OAuth| OAuth

    %% NetworkPolicy annotations
    MetricsSvc -.->|NP: Allow from<br/>monitoring namespaces| Prometheus
    ComponentNS -.->|NP: Allow from<br/>monitoring on<br/>5432,8080,8081,8082<br/>8099,8181,8443/TCP| MonitoringNS

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef controlplane fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef operator fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef monitoring fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef components fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef externalsvc fill:#f8cecc,stroke:#b85450,stroke-width:2px

    class Admin external
    class K8sAPI,Webhook controlplane
    class Controller,Controllers,DSCInitCtrl,DSCCtrl,SecretGen,CertGen,MetricsSvc,HealthProbes operator
    class Prometheus,PrometheusRoute,Alertmanager,BlackboxExp monitoring
    class Dashboard,Workbenches,KServe,ModelMesh,Pipelines,CodeFlare,Ray,Kueue,TrustyAI components
    class Registry,GitRepos,OAuth externalsvc
