graph TD
    subgraph "Service Accounts"
        SA_Operator[kuberay-operator<br/>Namespace: system]
        SA_APIServer[kuberay-apiserver<br/>Namespace: ray-system]
    end

    subgraph "ClusterRole Bindings"
        CRB_Operator[kuberay-operator]
        CRB_APIServer[kuberay-apiserver]
    end

    subgraph "ClusterRoles"
        CR_Operator[kuberay-operator]
        CR_APIServer[kuberay-apiserver]
    end

    subgraph "Role Bindings (Namespace-scoped)"
        RB_LeaderElection[kuberay-operator-leader-election<br/>Namespace: system]
    end

    subgraph "Roles (Namespace-scoped)"
        R_LeaderElection[kuberay-operator-leader-election]
    end

    subgraph "API Resources - Operator Permissions"
        direction TB

        subgraph "Batch API"
            Jobs[batch/jobs<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
        end

        subgraph "Coordination API"
            Leases[coordination.k8s.io/leases<br/>━━━━━━━━━━━━━<br/>create, get, list, update]
        end

        subgraph "Core API"
            Events[events<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            Pods[pods, pods/status<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            SAs[serviceaccounts<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, watch]
            Services[services, services/status<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
        end

        subgraph "Networking API"
            Ingresses[ingresses<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            IngressClasses[ingressclasses<br/>━━━━━━━━━━━━━<br/>get, list, watch]
        end

        subgraph "Ray API"
            RayClusters[ray.io/rayclusters<br/>rayclusters/finalizers<br/>rayclusters/status<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            RayJobs[ray.io/rayjobs<br/>rayjobs/finalizers<br/>rayjobs/status<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            RayServices[ray.io/rayservices<br/>rayservices/finalizers<br/>rayservices/status<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
        end

        subgraph "RBAC API"
            Roles[rbac.authorization.k8s.io<br/>roles, rolebindings<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, update, watch]
        end

        subgraph "OpenShift Route API"
            Routes[route.openshift.io/routes<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
        end
    end

    subgraph "API Resources - APIServer Permissions"
        direction TB

        subgraph "Ray API - APIServer"
            RayResourcesAPI[ray.io/rayclusters<br/>ray.io/rayjobs<br/>ray.io/rayservices<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
        end

        subgraph "Core API - APIServer"
            ConfigMaps[configmaps<br/>━━━━━━━━━━━━━<br/>create, delete, get<br/>list, patch, update, watch]
            Namespaces[namespaces<br/>━━━━━━━━━━━━━<br/>list]
            EventsAPI[events<br/>━━━━━━━━━━━━━<br/>get, list]
        end
    end

    subgraph "OpenShift SecurityContextConstraints"
        SCC[run-as-ray-user<br/>━━━━━━━━━━━━━<br/>RunAsUser: MustRunAs UID 1000<br/>Allows: kuberay-operator SA]
    end

    %% Service Account to ClusterRoleBinding
    SA_Operator -->|bound via| CRB_Operator
    SA_APIServer -->|bound via| CRB_APIServer
    SA_Operator -->|bound via| RB_LeaderElection

    %% ClusterRoleBinding to ClusterRole
    CRB_Operator -->|grants| CR_Operator
    CRB_APIServer -->|grants| CR_APIServer
    RB_LeaderElection -->|grants| R_LeaderElection

    %% ClusterRole to API Resources (Operator)
    CR_Operator -->|full CRUD| Jobs
    CR_Operator -->|manage| Leases
    CR_Operator -->|full CRUD| Events
    CR_Operator -->|full CRUD| Pods
    CR_Operator -->|limited| SAs
    CR_Operator -->|full CRUD| Services
    CR_Operator -->|full CRUD| Ingresses
    CR_Operator -->|read-only| IngressClasses
    CR_Operator -->|full CRUD| RayClusters
    CR_Operator -->|full CRUD| RayJobs
    CR_Operator -->|full CRUD| RayServices
    CR_Operator -->|manage| Roles
    CR_Operator -->|full CRUD| Routes

    %% ClusterRole to API Resources (APIServer)
    CR_APIServer -->|full CRUD| RayResourcesAPI
    CR_APIServer -->|full CRUD| ConfigMaps
    CR_APIServer -->|read-only| Namespaces
    CR_APIServer -->|read-only| EventsAPI

    %% Role to Leases (Leader Election)
    R_LeaderElection -->|leader election| Leases

    %% SecurityContextConstraints
    SA_Operator -->|uses| SCC

    style SA_Operator fill:#4a90e2,stroke:#333,color:#fff
    style SA_APIServer fill:#4a90e2,stroke:#333,color:#fff
    style CR_Operator fill:#f5a623,stroke:#333,color:#fff
    style CR_APIServer fill:#f5a623,stroke:#333,color:#fff
    style R_LeaderElection fill:#f5a623,stroke:#333,color:#fff
    style CRB_Operator fill:#bd10e0,stroke:#333,color:#fff
    style CRB_APIServer fill:#bd10e0,stroke:#333,color:#fff
    style RB_LeaderElection fill:#bd10e0,stroke:#333,color:#fff
    style RayClusters fill:#7ed321,stroke:#333
    style RayJobs fill:#7ed321,stroke:#333
    style RayServices fill:#7ed321,stroke:#333
    style RayResourcesAPI fill:#7ed321,stroke:#333
    style SCC fill:#d0021b,stroke:#333,color:#fff
