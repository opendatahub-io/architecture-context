%% Security Network Diagram - Notebooks (Workbench Images)
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["Data Scientist / User"]
    end

    subgraph Ingress["INGRESS (Gateway API)"]
        Gateway["Platform Gateway<br/>(managed by rhods-operator)<br/>HTTPRoute per notebook<br/>TLS 1.2+ Termination"]
    end

    subgraph WorkbenchPod["WORKBENCH POD"]
        direction TB
        KubeRBAC["kube-rbac-proxy sidecar<br/>8443/TCP<br/>RBAC enforcement<br/>(injected by notebook-controller)"]

        subgraph IDEs["Workbench Applications (plaintext, localhost)"]
            JupyterLab["JupyterLab<br/>8888/TCP HTTP<br/>UID: 1001"]
            CodeServerApp["code-server<br/>8787/TCP HTTP<br/>UID: 1001"]
            RStudioApp["RStudio Server<br/>8787/TCP HTTP<br/>UID: 1001"]
        end

        KubeRBAC -->|"HTTP plaintext<br/>localhost only<br/>No auth (delegated)"| JupyterLab
        KubeRBAC -->|"HTTP plaintext<br/>localhost only<br/>No auth (delegated)"| CodeServerApp
        KubeRBAC -->|"HTTP plaintext<br/>localhost only<br/>No auth (delegated)"| RStudioApp
    end

    subgraph ControlPlane["CLUSTER INTERNAL (Control Plane)"]
        direction TB
        RhodsOp["rhods-operator<br/>Deploys manifests via kustomize"]
        K8sAPI["OpenShift API Server<br/>6443/TCP HTTPS<br/>TLS 1.2+"]
        Dashboard["odh-dashboard<br/>Reads ImageStream metadata"]
        NotebookCtrl["odh-notebook-controller<br/>Creates Pods + HTTPRoutes<br/>Injects kube-rbac-proxy"]
    end

    subgraph BuildInfra["BUILD INFRASTRUCTURE (RStudio)"]
        BuildCtrl["OpenShift Build Controller"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Image Registries)"]
        RedHatReg["registry.redhat.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth (pull secret)<br/>Production images (N-1)"]
        QuayReg["quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Token auth (pull secret)<br/>Upstream images (N-2 to N-6)"]
        Mirror["mirror.openshift.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No auth<br/>OpenShift CLI download"]
        GitHubSrc["github.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Source clone"]
        IntRegistry["Internal Registry<br/>5000/TCP HTTPS<br/>TLS 1.2+<br/>SA token auth"]
    end

    %% User flow
    User -->|"HTTPS/443<br/>TLS 1.2+<br/>Bearer Token (OAuth)"| Gateway
    Gateway -->|"HTTPS/8443<br/>TLS<br/>kube-rbac-proxy"| KubeRBAC

    %% Control plane flows
    RhodsOp -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI
    Dashboard -->|"HTTPS/6443<br/>TLS 1.2+<br/>Bearer token"| K8sAPI
    NotebookCtrl -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA token"| K8sAPI

    %% Build flows
    BuildCtrl -->|"HTTPS/443<br/>TLS 1.2+"| GitHubSrc
    BuildCtrl -->|"HTTPS/443<br/>TLS 1.2+<br/>Pull secret"| RedHatReg
    BuildCtrl -->|"HTTPS/5000<br/>TLS 1.2+<br/>SA token"| IntRegistry

    %% Image pull flows
    K8sAPI -.->|"kubelet pulls<br/>HTTPS/443<br/>Pull secret"| RedHatReg
    K8sAPI -.->|"kubelet pulls<br/>HTTPS/443<br/>Pull secret"| QuayReg

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef controlplane fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef build fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Gateway ingress
    class KubeRBAC,JupyterLab,CodeServerApp,RStudioApp workbench
    class RhodsOp,K8sAPI,Dashboard,NotebookCtrl controlplane
    class BuildCtrl build
    class RedHatReg,QuayReg,Mirror,GitHubSrc,IntRegistry externalservice
