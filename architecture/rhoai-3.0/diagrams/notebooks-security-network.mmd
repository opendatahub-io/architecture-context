graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[User Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Termination<br/>Route: {notebook-name}.apps.{cluster}"]
    end

    subgraph PodNetwork["POD NETWORK (Trusted)"]
        direction TB

        subgraph NS_User["Namespace: {user-namespace}"]
            direction TB

            subgraph WorkbenchPod["Workbench Pod"]
                direction LR
                OAuthProxy["OAuth Proxy Sidecar<br/>SA: {notebook-name}<br/>Port: 8443/TCP"]
                Workbench["Workbench Container<br/>JupyterLab/RStudio/CodeServer<br/>Port: 8888/TCP HTTP"]

                subgraph InternalProc["Internal Processes"]
                    Kernel["Jupyter Kernel<br/>IPC Only"]
                    NGINX["NGINX Proxy<br/>8080→8787"]
                    HTTPd["Apache httpd<br/>RStudio Auth"]
                end
            end
        end
    end

    subgraph ClusterServices["CLUSTER SERVICES (Internal)"]
        direction TB
        K8sAPI["Kubernetes API Server<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>Bearer Token Auth"]
        ModelReg["Model Registry<br/>Namespace: odh-model-registry<br/>8080/TCP HTTP<br/>Service Mesh mTLS<br/>Bearer Token"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES (Egress)"]
        direction TB
        PyPI["PyPI<br/>files.pythonhosted.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        CRAN["CRAN<br/>cran.rstudio.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS or 22/TCP SSH<br/>TLS 1.2+ or SSH<br/>Git Credentials/SSH Key"]
        S3["S3 Storage<br/>s3.amazonaws.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM Credentials"]
        Quay["Quay.io<br/>quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Registry Token"]
    end

    %% Network Flows
    User -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>OpenShift Session"| Router
    Router -->|"HTTPS 8443/TCP<br/>TLS 1.2+<br/>OAuth Validation"| OAuthProxy
    OAuthProxy -->|"HTTP 8888/TCP<br/>localhost<br/>Authenticated"| Workbench

    Workbench -.->|"IPC<br/>Local Process"| Kernel
    Workbench -.->|"Proxy Config"| NGINX
    Workbench -.->|"RStudio Auth"| HTTPd

    Workbench -->|"HTTPS 6443/TCP<br/>TLS 1.3<br/>SA Token"| K8sAPI
    Workbench -->|"HTTP 8080/TCP<br/>Service Mesh mTLS<br/>Bearer Token"| ModelReg

    Workbench -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>No Auth"| PyPI
    Workbench -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>No Auth"| CRAN
    Workbench -->|"HTTPS 443/TCP or SSH 22/TCP<br/>TLS/SSH<br/>Credentials"| GitHub
    Workbench -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>AWS IAM"| S3
    Workbench -->|"HTTPS 443/TCP<br/>TLS 1.2+<br/>Token"| Quay

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef podnetwork fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef clusterservice fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef trusted fill:#d5e8d4,stroke:#82b366,stroke-width:1px

    class User external
    class Router ingress
    class OAuthProxy,Workbench,Kernel,NGINX,HTTPd podnetwork
    class K8sAPI,ModelReg clusterservice
    class PyPI,CRAN,GitHub,S3,Quay externalservice
