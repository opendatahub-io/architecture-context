graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User[Data Scientist Browser]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>{notebook-name}.apps.{cluster}<br/>443/TCP → 8443/TCP<br/>TLS 1.2+ Edge Termination"]
    end

    subgraph WorkbenchPod["WORKBENCH POD (User Namespace: {user-namespace})"]
        direction TB

        OAuth["OAuth Proxy Sidecar<br/>SA: {notebook-name}-sa<br/>Port: 8443/TCP external<br/>Port: 8888/TCP internal<br/>OpenShift Token Validation"]

        subgraph Containers["Workbench Containers"]
            Jupyter["JupyterLab Container<br/>jupyter-datascience-cpu:2025.2<br/>Port: 8888/TCP HTTP<br/>Python 3.12, JupyterLab 4.4<br/>/lab, /api/kernels, /healthz"]
            RStudio["RStudio Server<br/>Port: 8080/TCP internal<br/>NGINX: 8888/TCP external<br/>R 4.5.1, RStudio 2025.09.0"]
            CodeServer["CodeServer<br/>Port: 8787/TCP internal<br/>NGINX: 8888/TCP external<br/>Node.js 22.18.0"]
            Kernel["Jupyter Kernel<br/>Local IPC<br/>No Network"]
        end

        OAuth -->|HTTP/8888<br/>No encryption<br/>Pod-local| Jupyter
        OAuth -->|HTTP/8888<br/>No encryption<br/>Pod-local| RStudio
        OAuth -->|HTTP/8888<br/>No encryption<br/>Pod-local| CodeServer
        Jupyter -.->|IPC<br/>Local Process| Kernel
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        PyPI["PyPI<br/>files.pythonhosted.org<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        CRAN["CRAN<br/>cran.rstudio.com<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>No Auth"]
        GitHub["GitHub<br/>github.com<br/>443/TCP HTTPS or 22/TCP SSH<br/>TLS 1.2+ or SSH<br/>Git Token/SSH Key"]
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS<br/>TLS 1.3<br/>Bearer Token"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>AWS IAM/Keys"]
        Quay["Quay.io<br/>443/TCP HTTPS<br/>TLS 1.2+<br/>Pull Secret"]
    end

    subgraph PipelineRuntime["PIPELINE RUNTIME (Kubeflow Integration)"]
        direction TB
        KFP["Kubeflow Pipelines<br/>Namespace: kubeflow<br/>SA: pipeline-runner"]
        RuntimePod["Runtime Container<br/>jupyter-datascience-runtime:2025.2<br/>Headless (no UI)"]
        ModelRegistry["Model Registry<br/>8080/TCP HTTP<br/>Service Mesh mTLS<br/>Bearer Token"]

        KFP -->|HTTPS/6443<br/>TLS 1.3<br/>SA Token| K8sAPI
        K8sAPI -.->|Creates Pod| RuntimePod
        RuntimePod -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
        RuntimePod -->|HTTP/8080<br/>mTLS<br/>Bearer Token| ModelRegistry
    end

    %% User flow
    User -->|HTTPS/443<br/>TLS 1.2+<br/>Session Cookie| Router
    Router -->|HTTPS/8443<br/>TLS 1.2+<br/>OpenShift Session| OAuth

    %% Egress flows
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>None| PyPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>None| CRAN
    Jupyter -->|HTTPS/443 or SSH/22<br/>TLS 1.2+/SSH<br/>Git Creds| GitHub
    Jupyter -->|HTTPS/6443<br/>TLS 1.3<br/>Bearer Token| K8sAPI
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3
    Jupyter -->|HTTPS/443<br/>TLS 1.2+<br/>Pull Secret| Quay

    RStudio -->|HTTPS/443<br/>TLS 1.2+<br/>None| CRAN
    RStudio -->|HTTPS/443<br/>TLS 1.2+<br/>Git Creds| GitHub
    RStudio -->|HTTPS/443<br/>TLS 1.2+<br/>AWS IAM| S3

    CodeServer -->|HTTPS/443 or SSH/22<br/>TLS 1.2+/SSH<br/>Git Creds| GitHub
    CodeServer -->|HTTPS/6443<br/>TLS 1.3<br/>Bearer Token| K8sAPI

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef workbench fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    classDef pipeline fill:#e1d5e7,stroke:#9673a6,stroke-width:2px

    class User external
    class Router ingress
    class OAuth,Jupyter,RStudio,CodeServer,Kernel workbench
    class PyPI,CRAN,GitHub,K8sAPI,S3,Quay externalservice
    class KFP,RuntimePod,ModelRegistry pipeline
