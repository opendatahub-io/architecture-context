graph LR
    Controller[odh-model-controller]

    subgraph "External Dependencies (Required)"
        KServe[KServe v0.13+<br/>InferenceService, ServingRuntime CRDs]
        OpenShift[OpenShift Routes 4.x<br/>External ingress]
        K8sAPI[Kubernetes API Server<br/>Resource management]
    end

    subgraph "External Dependencies (Optional)"
        Prometheus[Prometheus Operator<br/>ServiceMonitor/PodMonitor]
        Istio[Istio Service Mesh 1.x<br/>EnvoyFilter]
        Kuadrant[Kuadrant<br/>AuthPolicy]
        KEDA[KEDA 2.x<br/>TriggerAuthentication]
        GatewayAPI[Gateway API v1<br/>HTTPRoute]
        NGC[Nvidia NGC<br/>NIM validation]
    end

    subgraph "Internal ODH Dependencies"
        ModelRegistry[Model Registry<br/>HTTP API - optional]
        DSCInit[DSC Initialization<br/>Platform config]
        ServiceCA[OpenShift Service CA<br/>Webhook certificates]
    end

    subgraph "Integrates With"
        Dashboard[ODH Dashboard<br/>UI for model management]
        Pipelines[Data Science Pipelines<br/>Auto-deploy models]
    end

    subgraph "Creates Resources For"
        Workloads[Model Serving Workloads<br/>InferenceService pods]
    end

    %% Required dependencies
    Controller -->|required<br/>watches CRDs| KServe
    Controller -->|required<br/>creates Routes| OpenShift
    Controller -->|required<br/>API calls| K8sAPI

    %% Optional external dependencies
    Controller -.->|optional<br/>creates monitors| Prometheus
    Controller -.->|optional<br/>creates filters| Istio
    Controller -.->|optional<br/>creates policies| Kuadrant
    Controller -.->|optional<br/>creates triggers| KEDA
    Controller -.->|optional<br/>manages routes| GatewayAPI
    Controller -.->|optional<br/>validates accounts| NGC

    %% Internal dependencies
    Controller -.->|optional<br/>registers models| ModelRegistry
    Controller -->|reads config| DSCInit
    Controller -->|TLS certs| ServiceCA

    %% Integration points
    Dashboard -.->|UI integration| Controller
    Pipelines -.->|auto-deploy| Controller

    %% Creates resources
    Controller ==>|provisions| Workloads

    %% Styling
    style Controller fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    style KServe fill:#e74c3c,stroke:#333,stroke-width:2px
    style OpenShift fill:#e74c3c,stroke:#333,stroke-width:2px
    style K8sAPI fill:#e74c3c,stroke:#333,stroke-width:2px

    style Prometheus fill:#999,stroke:#333,stroke-width:2px
    style Istio fill:#999,stroke:#333,stroke-width:2px
    style Kuadrant fill:#999,stroke:#333,stroke-width:2px
    style KEDA fill:#999,stroke:#333,stroke-width:2px
    style GatewayAPI fill:#999,stroke:#333,stroke-width:2px
    style NGC fill:#999,stroke:#333,stroke-width:2px

    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style DSCInit fill:#7ed321,stroke:#333,stroke-width:2px
    style ServiceCA fill:#7ed321,stroke:#333,stroke-width:2px

    style Dashboard fill:#f5a623,stroke:#333,stroke-width:2px
    style Pipelines fill:#f5a623,stroke:#333,stroke-width:2px

    style Workloads fill:#9b59b6,stroke:#333,stroke-width:2px
