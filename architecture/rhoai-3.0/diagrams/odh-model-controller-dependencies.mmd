graph LR
    ODHModelController[odh-model-controller<br/>v1.27.0]

    %% External Dependencies - Required
    ODHModelController -->|"requires<br/>watches CRDs"| KServe["KServe v0.13+<br/>(InferenceService,<br/>ServingRuntime)"]
    ODHModelController -->|"requires<br/>creates Routes"| OpenShiftRoutes["OpenShift Routes 4.x"]
    ODHModelController -->|"requires<br/>API calls"| K8sAPI["Kubernetes API"]

    %% External Dependencies - Optional
    ODHModelController -.->|"optional<br/>creates monitors"| Prometheus["Prometheus Operator<br/>(ServiceMonitor,<br/>PodMonitor)"]
    ODHModelController -.->|"optional<br/>SSL passthrough"| Istio["Istio Service Mesh 1.x<br/>(EnvoyFilter)"]
    ODHModelController -.->|"optional<br/>auth policies"| Kuadrant["Kuadrant<br/>(AuthPolicy)"]
    ODHModelController -.->|"optional<br/>autoscaling"| KEDA["KEDA 2.x<br/>(TriggerAuthentication)"]
    ODHModelController -.->|"optional<br/>LLM routing"| GatewayAPI["Gateway API v1<br/>(HTTPRoute)"]
    ODHModelController -.->|"optional<br/>NIM validation"| NGC["Nvidia NGC<br/>(API)"]

    %% Internal ODH Dependencies
    ODHModelController -.->|"optional<br/>model registration"| ModelRegistry["Model Registry<br/>(HTTP API)"]
    ODHModelController -->|"reads config"| DSC["DataScienceCluster<br/>DSCInitialization"]
    ODHModelController -->|"webhook cert"| ServiceCA["OpenShift Service CA"]
    ODHModelController -->|"runtime templates"| TemplateAPI["OpenShift Template API"]

    %% Integration Points - Components that use odh-model-controller
    Dashboard["ODH Dashboard"] -.->|"UI for management"| ODHModelController
    Pipelines["Data Science Pipelines"] -.->|"auto-deploy models"| ODHModelController

    %% Managed Resources (what controller creates)
    subgraph ManagedResources["Resources Created by Controller"]
        Routes["Routes"]
        NetworkPolicies["NetworkPolicies"]
        RBAC["Roles/RoleBindings"]
        Monitoring["ServiceMonitors<br/>PodMonitors"]
        ServiceMesh["EnvoyFilters"]
        Auth["AuthPolicies"]
        HTTPRoutes["HTTPRoutes"]
        Autoscaling["TriggerAuthentications"]
        Secrets["Pull Secrets<br/>Managed Secrets"]
    end

    ODHModelController -->|creates| ManagedResources

    %% CRDs Managed
    subgraph CRDsManaged["CRDs Managed"]
        InferenceService["InferenceService<br/>serving.kserve.io"]
        ServingRuntime["ServingRuntime<br/>serving.kserve.io"]
        LLMInferenceService["LLMInferenceService<br/>serving.kserve.io"]
        InferenceGraph["InferenceGraph<br/>serving.kserve.io"]
        NIMAccount["NIM Account<br/>nim.opendatahub.io"]
    end

    ODHModelController -->|watches/reconciles| CRDsManaged

    %% Runtime Templates Deployed
    subgraph RuntimeTemplates["Pre-configured Runtime Templates"]
        vLLM["vLLM<br/>(CUDA, CPU, ROCm,<br/>Gaudi, Multinode,<br/>Spyre)"]
        OVMS["OpenVINO Model Server"]
        HFDetector["HuggingFace Detector"]
    end

    ODHModelController -->|deploys| RuntimeTemplates

    %% Styling
    style ODHModelController fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External - Required
    style KServe fill:#999,stroke:#333,stroke-width:2px
    style OpenShiftRoutes fill:#999,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333,stroke-width:2px

    %% External - Optional
    style Prometheus fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Istio fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style Kuadrant fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style KEDA fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style GatewayAPI fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5
    style NGC fill:#ccc,stroke:#333,stroke-width:1px,stroke-dasharray: 5 5

    %% Internal ODH
    style ModelRegistry fill:#7ed321,stroke:#333,stroke-width:2px
    style DSC fill:#7ed321,stroke:#333,stroke-width:2px
    style ServiceCA fill:#7ed321,stroke:#333,stroke-width:2px
    style TemplateAPI fill:#7ed321,stroke:#333,stroke-width:2px

    %% Integration points
    style Dashboard fill:#f5a623,stroke:#333,stroke-width:2px
    style Pipelines fill:#f5a623,stroke:#333,stroke-width:2px

    %% Managed resources
    style ManagedResources fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style CRDsManaged fill:#ffd4d4,stroke:#d73a49,stroke-width:2px
    style RuntimeTemplates fill:#d4edff,stroke:#0969da,stroke-width:2px
