%% TrustyAI Explainability - Component Structure Diagram
%% Generated by: Claude Opus 4.6
%% Source: architecture/rhoai-3.0/trustyai-explainability.md

graph TB
    subgraph "TrustyAI Explainability Service (Quarkus 3.8.5)"
        direction TB

        subgraph "REST API Layer"
            MetricsAPI["/metrics/* Endpoints<br/>SPD, DIR, KS, MMD, Meanshift"]
            ExplainerAPI["/explainers/* Endpoints<br/>LIME, SHAP, CF, TSSaliency<br/>(disabled in RHOAI)"]
            InfoAPI["/info/* Endpoints<br/>Metadata, Tags, Names"]
            DataAPI["/data/* Endpoints<br/>Upload, Download"]
            HealthAPI["/q/health, /q/metrics<br/>Probes & Prometheus"]
        end

        subgraph "Payload Ingestion"
            ConsumerEndpoint["ConsumerEndpoint<br/>/consumer/kserve/v2<br/>(ModelMesh payloads)"]
            CloudEventConsumer["CloudEventConsumer<br/>Knative CloudEvents<br/>(KServe inference logger)"]
        end

        subgraph "Processing"
            PayloadReconciler["InferencePayloadReconciler<br/>Reconciles input/output pairs"]
            PrometheusScheduler["PrometheusScheduler<br/>Periodic metric computation"]
            PrometheusPublisher["PrometheusPublisher<br/>Micrometer gauges (trustyai_*)"]
        end

        subgraph "Storage Layer"
            PVCStorage["PVC Storage<br/>/inputs (CSV files)"]
            MinIOStorage["MinIO Storage<br/>S3-compatible"]
            DBStorage["Database Storage<br/>Hibernate ORM (MariaDB/H2)"]
        end
    end

    subgraph "Core Library (explainability-core)"
        FairnessMetrics["Fairness Metrics<br/>SPD, DIR"]
        Explainers["Explainers<br/>LIME, SHAP, Counterfactual"]
        DriftDetectors["Drift Detectors<br/>KS Test, MMD, Meanshift"]
    end

    subgraph "Connectors (explainability-connectors)"
        KServeV2gRPC["KServe v2 gRPC Client<br/>grpc_predict_v2.proto"]
        KServeV1HTTP["KServe v1/v2 HTTP Client"]
    end

    %% Internal flows
    ConsumerEndpoint -->|partial payloads| PayloadReconciler
    CloudEventConsumer -->|CloudEvent payloads| PayloadReconciler
    PayloadReconciler -->|stores| PVCStorage
    PayloadReconciler -->|stores| MinIOStorage
    PayloadReconciler -->|stores| DBStorage

    PrometheusScheduler -->|reads data| PVCStorage
    PrometheusScheduler -->|computes| FairnessMetrics
    PrometheusScheduler -->|computes| DriftDetectors
    PrometheusScheduler -->|publishes| PrometheusPublisher

    MetricsAPI -->|uses| FairnessMetrics
    MetricsAPI -->|uses| DriftDetectors
    ExplainerAPI -->|uses| Explainers

    Explainers -->|inference calls| KServeV2gRPC
    Explainers -->|inference calls| KServeV1HTTP

    %% External actors
    ModelMesh["ModelMesh Serving"] -->|HTTP POST /consumer/kserve/v2| ConsumerEndpoint
    KServeLogger["KServe Inference Logger"] -->|CloudEvents| CloudEventConsumer
    Prometheus["Prometheus/OCP Monitoring"] -->|scrapes /q/metrics| HealthAPI
    Operator["TrustyAI Service Operator"] -->|deploys & manages| ConsumerEndpoint
    AuthProxy["Auth Proxy Sidecar<br/>(kube-rbac-proxy)"] -->|protects| MetricsAPI

    KServeV2gRPC -->|gRPC| ModelEndpoint["KServe/ModelMesh<br/>Model Endpoint"]
    KServeV1HTTP -->|HTTP| ModelEndpoint

