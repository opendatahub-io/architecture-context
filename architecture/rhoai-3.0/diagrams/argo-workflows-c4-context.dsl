// Argo Workflows - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and monitors workflow pipelines"

        argoWorkflows = softwareSystem "Argo Workflows" "Kubernetes-native workflow engine for orchestrating parallel jobs as DAGs or steps" {
            workflowController = container "Workflow Controller" "Watches Workflow/CronWorkflow CRDs, orchestrates pod creation, manages workflow lifecycle, leader election" "Go Service"
            argoServer = container "Argo Server" "gRPC + REST API server (grpc-gateway), serves web UI, handles SSO/auth, artifact serving, workflow archive" "Go Service"
            argoExec = container "argoexec" "Runs inside workflow pods as sidecar to manage artifact collection, output capture, container lifecycle" "Go Sidecar"
            cronController = container "Cron Controller" "Manages CronWorkflow scheduling, creates Workflow CRs on schedule" "Go (embedded in controller)"
            artifactGCController = container "Artifact GC Controller" "Manages WorkflowArtifactGCTask CRs for artifact garbage collection" "Go (embedded in controller)"
            argoUI = container "Argo Workflows UI" "Web UI for workflow visualization, management, and monitoring" "TypeScript/React"
        }

        // Internal ODH Systems
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages Argo Workflows as pipeline execution engine" "Internal RHOAI"
        dspAPIServer = softwareSystem "Data Science Pipelines API Server" "Submits Workflow CRs for pipeline execution" "Internal RHOAI"

        // External Systems
        k8sAPI = softwareSystem "Kubernetes API Server" "Core platform for pod/resource/CRD management" "External"
        artifactStorage = softwareSystem "Artifact Storage (S3/GCS/Azure)" "Stores workflow artifacts" "External"
        database = softwareSystem "PostgreSQL/MySQL" "Optional workflow archive and node status offloading" "External"
        oidcProvider = softwareSystem "OIDC Provider" "SSO authentication for Argo Server" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        // Relationships - User
        user -> argoServer "Manages workflows via UI/API" "HTTPS/gRPC 2746/TCP"
        user -> k8sAPI "Creates Workflow CRs via kubectl" "HTTPS/443"

        // Relationships - Internal
        dspOperator -> argoWorkflows "Deploys and manages"
        dspAPIServer -> k8sAPI "Submits Workflow CRs" "HTTPS/443"

        // Relationships - Controller
        workflowController -> k8sAPI "Watches CRDs, creates pods, updates status" "HTTPS/443"
        cronController -> k8sAPI "Creates Workflow CRs on schedule" "HTTPS/443"
        artifactGCController -> k8sAPI "Manages artifact GC tasks" "HTTPS/443"

        // Relationships - Server
        argoServer -> k8sAPI "Queries workflows, delegates auth" "HTTPS/443"
        argoServer -> database "Archives workflows" "TCP/5432"
        argoServer -> oidcProvider "SSO authentication" "HTTPS/443"
        argoServer -> argoUI "Serves UI" "HTTPS/2746"

        // Relationships - Executor
        argoExec -> k8sAPI "Updates workflow status" "HTTPS/443"
        argoExec -> artifactStorage "Uploads/downloads artifacts" "HTTPS/443"

        // Relationships - Monitoring
        prometheus -> workflowController "Scrapes metrics" "HTTP/9090"
        prometheus -> argoServer "Scrapes metrics" "HTTPS/2746"
    }

    views {
        systemContext argoWorkflows "SystemContext" {
            include *
            autoLayout
        }

        container argoWorkflows "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #000000
            }
            element "Person" {
                background #08427B
                color #ffffff
                shape person
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
