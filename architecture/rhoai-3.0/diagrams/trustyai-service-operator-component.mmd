graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller<br/>trustyai-service-operator]
        HealthProbe[Health Probes<br/>/healthz /readyz 8081]
        Metrics[Metrics Endpoint<br/>8443/TCP HTTPS]
        Controller --> HealthProbe
        Controller --> Metrics
    end

    subgraph "Custom Resources"
        TrustyAICR[TrustyAIService CR<br/>v1/v1alpha1]
        LMEvalCR[LMEvalJob CR<br/>v1alpha1]
        GorchCR[GuardrailsOrchestrator CR<br/>v1alpha1]
    end

    subgraph "Managed Deployments"
        direction TB
        TrustyAIService[TrustyAI Service<br/>Explainability & Bias Detection]
        LMEvalJob[LM Evaluation Job<br/>Batch Job]
        Guardrails[Guardrails Orchestrator<br/>AI Safety Controls]

        subgraph TrustyAISidecars["TrustyAI Service Sidecars"]
            RBACProxy1[kube-rbac-proxy<br/>8443/TCP]
        end

        subgraph LMESidecars["LMEval Job Sidecars"]
            LMESDriver[LMES Driver<br/>Job Lifecycle]
        end

        subgraph GorchSidecars["Guardrails Sidecars"]
            RBACProxy2[kube-rbac-proxy<br/>8432/TCP]
            Detector[Built-in Detector<br/>Guardrails Detection]
            Gateway[Sidecar Gateway<br/>8090/8490]
        end
    end

    subgraph "Storage Options"
        PVC[PersistentVolumeClaim<br/>CSV Files]
        Database[(External Database<br/>PostgreSQL/MySQL)]
    end

    subgraph "External Dependencies"
        KServe[KServe<br/>InferenceServices]
        Istio[Istio Service Mesh<br/>VirtualService/DestinationRule]
        Prometheus[Prometheus<br/>Metrics Collection]
        Kueue[Kueue<br/>Job Scheduling]
        OpenShift[OpenShift<br/>Routes/OAuth]
    end

    %% User creates CRs
    User[User] -->|creates| TrustyAICR
    User -->|creates| LMEvalCR
    User -->|creates| GorchCR

    %% Controller watches CRs
    TrustyAICR -->|watched by| Controller
    LMEvalCR -->|watched by| Controller
    GorchCR -->|watched by| Controller

    %% Controller creates resources
    Controller -->|creates| TrustyAIService
    Controller -->|creates| LMEvalJob
    Controller -->|creates| Guardrails
    Controller -->|creates| PVC
    Controller -->|configures| Database

    %% TrustyAI Service interactions
    TrustyAIService --> RBACProxy1
    TrustyAIService -->|stores data| PVC
    TrustyAIService -->|stores data| Database
    TrustyAIService -->|exposes metrics| Prometheus

    %% LMEval Job interactions
    LMEvalJob --> LMESDriver
    LMEvalJob -->|calls| KServe

    %% Guardrails interactions
    Guardrails --> RBACProxy2
    Guardrails --> Detector
    Guardrails --> Gateway
    Guardrails -->|calls| KServe
    Guardrails -->|exposes metrics| Prometheus

    %% External integrations
    Controller -->|watches/patches| KServe
    Controller -->|creates| Istio
    Controller -->|creates| OpenShift
    Controller -->|creates| Kueue

    style Controller fill:#4a90e2,stroke:#333,stroke-width:3px
    style TrustyAICR fill:#f5a623,stroke:#333
    style LMEvalCR fill:#f5a623,stroke:#333
    style GorchCR fill:#f5a623,stroke:#333
    style TrustyAIService fill:#7ed321,stroke:#333
    style LMEvalJob fill:#7ed321,stroke:#333
    style Guardrails fill:#7ed321,stroke:#333
    style KServe fill:#999,stroke:#333
    style Istio fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style Kueue fill:#999,stroke:#333
    style OpenShift fill:#999,stroke:#333
    style PVC fill:#d0d0d0,stroke:#333
    style Database fill:#d0d0d0,stroke:#333
