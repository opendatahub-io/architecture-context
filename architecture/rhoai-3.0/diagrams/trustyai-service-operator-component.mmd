graph TB
    subgraph "TrustyAI Service Operator"
        Controller[Operator Controller]
        Webhook[Leader Election]
        Controller -->|manages| Webhook
    end

    subgraph "Managed Resources"
        TAS[TrustyAI Service<br/>Deployment]
        LMES[LM Evaluation Job<br/>Batch Job]
        GORCH[Guardrails Orchestrator<br/>Deployment]
    end

    subgraph "Sidecars"
        RBACProxy[Kube-RBAC-Proxy<br/>Auth Sidecar]
        LMESDriver[LMES Driver<br/>Job Manager]
        Detector[Built-in Detector<br/>Guardrails Detection]
        Gateway[Gateway Sidecar<br/>Request Router]
    end

    subgraph "Custom Resources"
        TASServiceCR[TrustyAIService CR<br/>v1/v1alpha1]
        LMESJobCR[LMEvalJob CR<br/>v1alpha1]
        GORCHOrchCR[GuardrailsOrchestrator CR<br/>v1alpha1]
    end

    subgraph "Storage"
        PVC[PersistentVolumeClaim<br/>CSV Files]
        DB[External Database<br/>PostgreSQL/MySQL]
    end

    User[User/Client] -->|creates| TASServiceCR
    User -->|creates| LMESJobCR
    User -->|creates| GORCHOrchCR

    TASServiceCR -->|watched by| Controller
    LMESJobCR -->|watched by| Controller
    GORCHOrchCR -->|watched by| Controller

    Controller -->|creates/manages| TAS
    Controller -->|creates/manages| LMES
    Controller -->|creates/manages| GORCH

    TAS -->|includes| RBACProxy
    GORCH -->|includes| RBACProxy
    GORCH -->|includes| Detector
    GORCH -->|includes| Gateway

    LMES -->|includes| LMESDriver

    TAS -->|stores data| PVC
    TAS -->|stores data| DB

    Controller -->|watches/patches| InferenceService[KServe InferenceService]
    Controller -->|creates| ServiceMonitor[Prometheus ServiceMonitor]
    Controller -->|creates| Routes[OpenShift Routes]
    Controller -->|creates| VirtualService[Istio VirtualService]

    GORCH -->|forwards to| InferenceService
    LMES -->|evaluates| InferenceService

    style Controller fill:#4a90e2
    style TAS fill:#7ed321
    style LMES fill:#7ed321
    style GORCH fill:#7ed321
    style TASServiceCR fill:#f5a623
    style LMESJobCR fill:#f5a623
    style GORCHOrchCR fill:#f5a623
    style InferenceService fill:#d0d0d0
    style DB fill:#9b59b6
    style PVC fill:#9b59b6
