// C4 Context Diagram: vllm-orchestrator-gateway
// Generated by: Claude Opus 4.6

workspace {
    model {
        client = person "Client Application" "Sends OpenAI-compatible chat completion requests"

        gateway = softwareSystem "vllm-orchestrator-gateway" "Rust HTTP gateway that routes OpenAI-compatible chat requests through configurable detector pipelines" {
            routeHandler = container "Route Handler" "Dynamically routes requests based on YAML config, injects detector specs" "Rust / axum 0.7.9"
            configParser = container "Configuration Parser" "Reads and validates YAML config defining orchestrator, detectors, and routes" "Rust / serde_yml"
            apiTypes = container "API Types" "Request/response data structures for orchestrator communication" "Rust / serde"
            tlsBuilder = container "TLS Client Builder" "Builds reqwest HTTP client with optional mTLS identity and custom CA" "Rust / openssl + native-tls"
        }

        orchestrator = softwareSystem "FMS Guardrails Orchestrator" "Performs LLM generation with content detection pipeline" "Internal ODH"
        detectors = softwareSystem "Guardrails Detectors" "Content detection services (PII, regex, toxicity)" "Internal ODH"
        vllm = softwareSystem "vLLM / LLM Backend" "Large Language Model inference service" "Internal ODH"
        certManager = softwareSystem "cert-manager / service-ca-operator" "Provisions TLS certificates for mTLS" "Platform"

        // Relationships
        client -> gateway "POST /{route}/v1/chat/completions" "HTTP/8090, Bearer token (pass-through)"
        gateway -> orchestrator "POST /api/v2/chat/completions-detection" "HTTP or HTTPS/8085, Optional mTLS"
        orchestrator -> detectors "Runs content detection" "Internal"
        orchestrator -> vllm "Forwards LLM inference requests" "Internal"
        certManager -> gateway "Provisions TLS certs to /etc/tls/" "Volume mounts"

        // Container relationships
        configParser -> routeHandler "Provides route and detector config"
        routeHandler -> apiTypes "Builds request/response payloads"
        routeHandler -> tlsBuilder "Uses HTTP client for upstream calls"
    }

    views {
        systemContext gateway "SystemContext" {
            include *
            autoLayout
            description "System context showing vllm-orchestrator-gateway in the RHOAI ecosystem"
        }

        container gateway "Containers" {
            include *
            autoLayout
            description "Internal container view of vllm-orchestrator-gateway"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal ODH" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #999999
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
