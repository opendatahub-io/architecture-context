/*
 * C4 Context Diagram - Data Science Pipelines Operator (DSPO)
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/data-science-pipelines-operator.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and runs ML pipelines via Dashboard or KFP SDK"
        platformAdmin = person "Platform Admin" "Creates and configures DSPA CRs"

        dspo = softwareSystem "Data Science Pipelines Operator" "Manages lifecycle of DSP application stacks on OpenShift (KFP v2)" {
            controller = container "DSPO Controller Manager" "Watches DSPA CRs, reconciles sub-components via Go templates" "Go Operator (controller-runtime)"
            webhook = container "DS Pipelines Webhook" "Validates/mutates PipelineVersion CRs" "Go Admission Webhook"
            apiServer = container "DS Pipelines API Server" "KFP v2 REST/gRPC API for pipeline CRUD, runs, artifacts" "Go Service (8888/HTTP, 8887/gRPC, 8443/HTTPS)"
            kubeRbacProxy = container "kube-rbac-proxy" "Authenticates external requests via K8s SubjectAccessReview" "Sidecar (8443/TCP)"
            persistenceAgent = container "Persistence Agent" "Syncs pipeline run status from Argo to KFP database" "Go Service"
            scheduledWorkflow = container "Scheduled Workflow" "Manages cron-based scheduled pipeline runs" "Go Service"
            argoController = container "Argo Workflow Controller" "Orchestrates pipeline DAG execution" "Go Controller"
            mlmdGrpc = container "MLMD gRPC Server" "ML Metadata storage and retrieval" "gRPC Service (8080/TCP)"
            mlmdEnvoy = container "MLMD Envoy Proxy" "Fronts MLMD gRPC with kube-rbac-proxy for external access" "Envoy (9090/TCP, 8443/TCP)"
            mariadb = container "MariaDB" "Pipeline metadata relational storage (optional, per-DSPA)" "MariaDB 10.5 (3306/TCP)"
            minio = container "MinIO" "Default S3-compatible artifact store (optional, per-DSPA)" "MinIO (9000/TCP)"
        }

        /* External Dependencies */
        openshift = softwareSystem "OpenShift Platform" "Container platform with service-ca, Routes, OAuth" "External"
        kubernetes = softwareSystem "Kubernetes API Server" "Container orchestration and resource management" "External"
        serviceCA = softwareSystem "OpenShift service-ca" "Auto-provisions TLS certificates for services" "External"
        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "External"

        /* External Storage (user-provided alternatives) */
        externalDB = softwareSystem "External Database" "User-provided MySQL/MariaDB for pipeline metadata" "External"
        externalS3 = softwareSystem "External S3 Storage" "User-provided S3-compatible object store for artifacts" "External"

        /* Internal ODH Dependencies */
        rhodsOperator = softwareSystem "RHODS Operator" "Deploys DSPO via kustomize overlay" "Internal RHOAI"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Web UI for pipeline management" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches (Notebooks)" "Jupyter notebooks for pipeline development" "Internal RHOAI"

        /* Integration Points */
        kserve = softwareSystem "KServe" "Model serving platform for inference" "Internal RHOAI"
        ray = softwareSystem "KubeRay" "Distributed compute for pipeline steps" "Internal RHOAI"
        codeflare = softwareSystem "CodeFlare" "Workload management for distributed compute" "Internal RHOAI"

        /* Relationships - Users */
        dataScientist -> dspo "Creates/manages pipelines and runs" "HTTPS/443 via Route"
        dataScientist -> dashboard "Manages pipelines via UI"
        platformAdmin -> dspo "Creates DSPA CRs via kubectl" "Kubernetes API"

        /* Relationships - Internal */
        controller -> kubernetes "Manages resources (DSPA, Deployments, Services, Routes)" "HTTPS/443"
        controller -> serviceCA "Requests TLS certificates via annotations"
        apiServer -> mariadb "Stores pipeline metadata" "MySQL/3306 TLS"
        apiServer -> minio "Stores pipeline artifacts" "HTTP/9000"
        apiServer -> argoController "Creates Workflow CRs" "Kubernetes API"
        argoController -> kubernetes "Creates pipeline pods" "HTTPS/443"
        persistenceAgent -> apiServer "Syncs run status" "HTTP(S)/8888"
        mlmdGrpc -> mariadb "Persists ML metadata" "MySQL/3306 TLS"
        mlmdEnvoy -> mlmdGrpc "Proxies gRPC requests" "gRPC/8080 TLS"
        kubeRbacProxy -> apiServer "Forwards authenticated requests" "HTTP(S)/8888"

        /* Relationships - External Dependencies */
        rhodsOperator -> dspo "Deploys operator" "Kustomize"
        dashboard -> dspo "Pipeline management UI" "HTTPS/443 via Route"
        workbenches -> dspo "Pipeline runs from notebooks" "HTTP(S)/8888"
        prometheus -> dspo "Scrapes metrics" "HTTP/8080, 8888"

        /* Relationships - External Storage */
        dspo -> externalDB "Pipeline metadata (when external DB configured)" "MySQL/3306 TLS"
        dspo -> externalS3 "Pipeline artifacts (when external S3 configured)" "HTTPS/443"

        /* Relationships - Integrations */
        dspo -> kserve "Pipeline steps deploy models" "Kubernetes API (InferenceService CR)"
        dspo -> ray "Pipeline steps use Ray" "Kubernetes API (RayCluster/RayJob CR)"
        dspo -> codeflare "Pipeline steps use CodeFlare" "Kubernetes API (AppWrapper CR)"
    }

    views {
        systemContext dspo "SystemContext" {
            include *
            autoLayout
        }

        container dspo "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #5bb5e0
                color #ffffff
            }
        }
    }
}
