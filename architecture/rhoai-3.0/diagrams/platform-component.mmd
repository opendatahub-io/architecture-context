graph TB
    subgraph "RHOAI 3.0 Platform"
        subgraph "Platform Core"
            RHODS[RHODS Operator<br/>Platform Orchestrator]
            DSCCluster[DataScienceCluster CR]
            DSCInit[DSCInitialization CR]
            RHODS -->|manages| DSCCluster
            RHODS -->|initializes| DSCInit
        end

        subgraph "Gateway Infrastructure (openshift-ingress)"
            Gateway[data-science-gateway<br/>Gateway API v1]
            GatewayClass[data-science-gateway-class<br/>GatewayClass]
            AuthProxy[kube-auth-proxy<br/>OAuth2/OIDC Auth<br/>2 replicas HA]
            EnvoyFilter[EnvoyFilter<br/>ext_authz authn-filter]
            OAuthRoute[OAuth Callback HTTPRoute]

            GatewayClass -->|provides| Gateway
            Gateway -->|uses| EnvoyFilter
            EnvoyFilter -->|routes to| AuthProxy
            AuthProxy -->|handles| OAuthRoute
        end

        subgraph "Application Layer (redhat-ods-applications)"
            Dashboard[ODH Dashboard<br/>React SPA + Node.js<br/>2 replicas HA]
            NotebookController[Notebook Controller<br/>StatefulSet Manager]
            DSPOperator[DSP Operator<br/>KFP 2.5.0]
            KServeController[KServe Controller<br/>Model Serving]
            ModelController[ODH Model Controller<br/>OpenShift Extension]
            ModelRegistryOp[Model Registry Operator]
            TrainingOp[Training Operator<br/>v1.9.0]
            KubeRayOp[KubeRay Operator]
            TrustyAIOp[TrustyAI Service Operator<br/>v1.39.0]
            FeastOp[Feast Operator]
            LlamaStackOp[Llama Stack Operator<br/>v0.4.0]
        end

        subgraph "Monitoring Layer (redhat-ods-monitoring)"
            Prometheus[Prometheus<br/>2 replicas]
            Alertmanager[Alertmanager<br/>3 replicas]
            BlackboxExporter[Blackbox Exporter]
            ServiceMonitors[ServiceMonitors]
        end

        subgraph "User Workloads (Multi-tenant Namespaces)"
            Notebooks[Jupyter/RStudio/CodeServer<br/>Workbenches]
            DSPInstances[DSP Instances<br/>KFP API + Argo Workflows]
            InferenceServices[InferenceServices<br/>KServe Model Serving]
            TrainingJobs[Training Jobs<br/>PyTorch/TF/MPI/XGBoost/JAX]
            RayClusters[Ray Clusters<br/>Head + Workers]
            TrustyAIServices[TrustyAI Services<br/>Explainability]
            ModelRegistries[Model Registries<br/>REST + gRPC]
            FeatureStores[Feast Feature Stores]
            LlamaStackServers[Llama Stack Servers]
        end

        subgraph "External Dependencies"
            S3[S3 Storage<br/>Model Artifacts]
            OIDC[OIDC Provider<br/>ROSA/External IdP]
            ContainerRegistry[Container Registries<br/>quay.io, registry.redhat.io]
            NVIDCNGC[NVIDIA NGC API<br/>NIM Models]
            HuggingFace[HuggingFace Hub<br/>Model Downloads]
        end
    end

    %% Platform Core Relationships
    RHODS -->|deploys| Gateway
    RHODS -->|deploys| Dashboard
    RHODS -->|deploys| NotebookController
    RHODS -->|deploys| DSPOperator
    RHODS -->|deploys| KServeController
    RHODS -->|deploys| ModelController
    RHODS -->|deploys| ModelRegistryOp
    RHODS -->|deploys| TrainingOp
    RHODS -->|deploys| KubeRayOp
    RHODS -->|deploys| TrustyAIOp
    RHODS -->|deploys| FeastOp
    RHODS -->|deploys| LlamaStackOp
    RHODS -->|configures| Prometheus

    %% Gateway Authentication Flow
    Gateway -->|HTTPRoute| Dashboard
    Gateway -->|HTTPRoute| Notebooks
    Gateway -->|HTTPRoute| InferenceServices
    Gateway -->|HTTPRoute| DSPInstances
    AuthProxy -->|validates| OIDC

    %% Dashboard Integrations
    Dashboard -->|manages| Notebooks
    Dashboard -->|manages| DSPInstances
    Dashboard -->|manages| InferenceServices
    Dashboard -->|manages| ModelRegistries
    Dashboard -->|manages| FeatureStores
    Dashboard -->|manages| LlamaStackServers

    %% Operator to Workload Relationships
    NotebookController -->|creates| Notebooks
    DSPOperator -->|creates| DSPInstances
    KServeController -->|creates| InferenceServices
    ModelController -->|extends| InferenceServices
    ModelRegistryOp -->|creates| ModelRegistries
    TrainingOp -->|creates| TrainingJobs
    KubeRayOp -->|creates| RayClusters
    TrustyAIOp -->|creates| TrustyAIServices
    FeastOp -->|creates| FeatureStores
    LlamaStackOp -->|creates| LlamaStackServers

    %% Workload Integrations
    DSPInstances -->|deploys to| InferenceServices
    DSPInstances -->|registers to| ModelRegistries
    TrainingJobs -->|registers to| ModelRegistries
    TrainingJobs -->|stores to| S3
    InferenceServices -->|loads from| S3
    InferenceServices -->|uses| ModelRegistries
    InferenceServices -->|uses| FeatureStores
    TrustyAIServices -->|monitors| InferenceServices
    Notebooks -->|submits| TrainingJobs
    Notebooks -->|submits| DSPInstances
    Notebooks -->|accesses| InferenceServices

    %% External Dependencies
    InferenceServices -->|downloads from| HuggingFace
    ModelController -->|queries| NVIDCNGC
    RHODS -->|pulls from| ContainerRegistry
    Notebooks -->|accesses| S3

    %% Monitoring
    ServiceMonitors -->|scrapes| Dashboard
    ServiceMonitors -->|scrapes| NotebookController
    ServiceMonitors -->|scrapes| DSPOperator
    ServiceMonitors -->|scrapes| KServeController
    ServiceMonitors -->|scrapes| InferenceServices
    Prometheus -->|collects from| ServiceMonitors
    Prometheus -->|alerts to| Alertmanager

    %% Styling
    classDef platformCore fill:#4a90e2,stroke:#2e5c8a,stroke-width:2px,color:#fff
    classDef gateway fill:#ff9800,stroke:#e68900,stroke-width:2px,color:#fff
    classDef operator fill:#7ed321,stroke:#6bb91c,stroke-width:2px,color:#fff
    classDef workload fill:#9b59b6,stroke:#8e44ad,stroke-width:2px,color:#fff
    classDef monitoring fill:#e74c3c,stroke:#c0392b,stroke-width:2px,color:#fff
    classDef external fill:#95a5a6,stroke:#7f8c8d,stroke-width:2px,color:#fff

    class RHODS,DSCCluster,DSCInit platformCore
    class Gateway,GatewayClass,AuthProxy,EnvoyFilter,OAuthRoute gateway
    class Dashboard,NotebookController,DSPOperator,KServeController,ModelController,ModelRegistryOp,TrainingOp,KubeRayOp,TrustyAIOp,FeastOp,LlamaStackOp operator
    class Notebooks,DSPInstances,InferenceServices,TrainingJobs,RayClusters,TrustyAIServices,ModelRegistries,FeatureStores,LlamaStackServers workload
    class Prometheus,Alertmanager,BlackboxExporter,ServiceMonitors monitoring
    class S3,OIDC,ContainerRegistry,NVIDCNGC,HuggingFace external
