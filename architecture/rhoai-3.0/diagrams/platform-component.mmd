graph TB
    subgraph "RHOAI 3.0 Platform - Control Plane"
        RHODS[RHODS Operator<br/>v1.6.0-3582]
        DSCInit[DSCInitialization CR]
        DSC[DataScienceCluster CR]

        RHODS -->|creates| DSCInit
        RHODS -->|creates| DSC
    end

    subgraph "Platform Components - redhat-ods-applications"
        Dashboard[ODH Dashboard<br/>v1.21.0-18<br/>Web UI]
        DSPOp[DSP Operator<br/>0.0.1]
        KServeCtrl[KServe Controller<br/>5e4621c70]
        NotebookCtrl[Notebook Controller<br/>v1.27.0]
        ModelCtrl[ODH Model Controller<br/>1.27.0-rhods-1087]
        ModelRegOp[Model Registry Operator<br/>eb4d8e5]
        TrainingOp[Training Operator<br/>1.9.0]
        FeastOp[Feast Operator<br/>e43f213a4]
        LlamaOp[Llama Stack Operator<br/>v0.4.0]
        TrustyOp[TrustyAI Operator<br/>1.39.0]
    end

    subgraph "opendatahub Namespace"
        RayOp[KubeRay Operator<br/>dac6aae7]
    end

    subgraph "Monitoring - redhat-ods-monitoring"
        Prometheus[Prometheus<br/>StatefulSet]
        AlertManager[AlertManager<br/>StatefulSet]
        BlackboxExp[Blackbox Exporter]
    end

    subgraph "User Namespaces - Workloads"
        Notebooks[Workbenches<br/>JupyterLab/RStudio/CodeServer<br/>StatefulSets]
        DSPInst[DSP Instances<br/>Argo Workflows + API]
        ISVCs[InferenceServices<br/>KServe Model Serving]
        ModelReg[Model Registry<br/>REST/gRPC API]
        TrainingJobs[Training Jobs<br/>PyTorch/TF/MPI/XGBoost]
        RayCluster[Ray Clusters<br/>Distributed Compute]
        FeastStore[Feast Feature Stores<br/>Online/Offline]
        LlamaStack[Llama Stack Servers<br/>LLM Inference]
        TrustyAI[TrustyAI Services<br/>Explainability/Guardrails]
    end

    subgraph "External Dependencies"
        Istio[Service Mesh<br/>Istio]
        Knative[Knative Serving<br/>Serverless]
        CertMgr[cert-manager<br/>Certificate Management]
        S3[S3 Storage<br/>AWS/Minio/GCS]
        DB[(PostgreSQL/MySQL<br/>Databases)]
        OAuth[OpenShift OAuth<br/>Authentication]
    end

    %% RHODS Operator manages all components
    RHODS -.->|manages| Dashboard
    RHODS -.->|manages| DSPOp
    RHODS -.->|manages| KServeCtrl
    RHODS -.->|manages| NotebookCtrl
    RHODS -.->|manages| ModelCtrl
    RHODS -.->|manages| ModelRegOp
    RHODS -.->|manages| TrainingOp
    RHODS -.->|manages| FeastOp
    RHODS -.->|manages| LlamaOp
    RHODS -.->|manages| TrustyOp
    RHODS -.->|manages| RayOp

    %% Dashboard integrations
    Dashboard -->|watches CRDs| NotebookCtrl
    Dashboard -->|watches CRDs| KServeCtrl
    Dashboard -->|API calls| ModelReg
    Dashboard -->|API proxy| DSPInst
    Dashboard -->|watches CRDs| TrainingOp
    Dashboard -->|watches CRDs| RayOp
    Dashboard -->|watches CRDs| FeastOp
    Dashboard -->|watches CRDs| LlamaOp
    Dashboard -->|watches CRDs| TrustyOp

    %% Data Science Pipelines
    DSPOp -->|creates| DSPInst
    DSPInst -->|deploys models| KServeCtrl
    DSPInst -->|registers models| ModelReg
    DSPInst -->|network access| Notebooks

    %% KServe
    KServeCtrl -->|creates| ISVCs
    KServeCtrl -->|traffic routing| Istio
    KServeCtrl -->|autoscaling| Knative
    KServeCtrl -->|integrates| ModelReg
    ModelCtrl -->|extends| KServeCtrl
    ModelCtrl -->|creates EnvoyFilters| Istio
    ModelCtrl -->|creates Routes| ISVCs

    %% Notebook Controller
    NotebookCtrl -->|creates| Notebooks
    NotebookCtrl -->|creates VirtualServices| Istio

    %% Workbenches
    Notebooks -->|execute pipelines| DSPInst
    Notebooks -->|register models| ModelReg
    Notebooks -->|deploy models| KServeCtrl

    %% Model Registry
    ModelRegOp -->|creates| ModelReg
    ModelReg -->|stores metadata| DB

    %% Training Operator
    TrainingOp -->|creates| TrainingJobs

    %% KubeRay
    RayOp -->|creates| RayCluster

    %% Feast
    FeastOp -->|creates| FeastStore
    FeastStore -->|stores features| S3
    FeastStore -->|feature DB| DB

    %% Llama Stack
    LlamaOp -->|creates| LlamaStack
    LlamaStack -->|downloads models| S3

    %% TrustyAI
    TrustyOp -->|creates| TrustyAI
    TrustyAI -->|injects guardrails| ISVCs
    TrustyAI -->|stores data| DB

    %% Model serving dependencies
    ISVCs -->|loads models| S3
    ISVCs -->|fetches features| FeastStore

    %% Monitoring
    Dashboard -->|metrics| Prometheus
    KServeCtrl -->|metrics| Prometheus
    DSPInst -->|metrics| Prometheus
    ISVCs -->|metrics| Prometheus
    TrustyAI -->|metrics| Prometheus

    %% Authentication
    Dashboard -->|OAuth| OAuth
    Notebooks -->|OAuth| OAuth
    ModelReg -->|OAuth| OAuth

    %% Certificate Management
    KServeCtrl -->|webhook certs| CertMgr
    TrainingOp -->|webhook certs| CertMgr

    %% Styling
    classDef operator fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef webapp fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef workload fill:#f5a623,stroke:#333,stroke-width:2px
    classDef external fill:#999,stroke:#333,stroke-width:2px,color:#fff
    classDef monitoring fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef cr fill:#50e3c2,stroke:#333,stroke-width:2px

    class RHODS,DSPOp,KServeCtrl,NotebookCtrl,ModelCtrl,ModelRegOp,TrainingOp,RayOp,FeastOp,LlamaOp,TrustyOp operator
    class Dashboard webapp
    class Notebooks,DSPInst,ISVCs,ModelReg,TrainingJobs,RayCluster,FeastStore,LlamaStack,TrustyAI workload
    class Istio,Knative,CertMgr,S3,DB,OAuth external
    class Prometheus,AlertManager,BlackboxExp monitoring
    class DSCInit,DSC cr
