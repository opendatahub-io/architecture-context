graph TB
    subgraph DSP["Data Science Pipelines (Kubeflow Pipelines)"]
        direction TB

        subgraph APILayer["API Layer"]
            APIServer["ml-pipeline<br/>API Server<br/>REST: 8888/TCP<br/>gRPC: 8887/TCP"]
            Webhook["Webhook Server<br/>8443/TCP HTTPS<br/>PipelineVersion validation"]
            APIServer --- Webhook
        end

        subgraph Controllers["Controllers & Agents"]
            PersistenceAgent["ml-pipeline-persistenceagent<br/>Watches Argo Workflows<br/>Reports status via gRPC"]
            ScheduledWF["ml-pipeline-scheduledworkflow<br/>ScheduledWorkflow Controller<br/>Cron/periodic triggers"]
            ViewerCRD["ml-pipeline-viewer-crd<br/>Viewer Controller<br/>TensorBoard instances"]
        end

        subgraph Caching["Caching Layer"]
            CacheServer["cache-server<br/>Mutating Webhook 8443/TCP<br/>Step execution caching"]
        end

        subgraph Metadata["Metadata Services"]
            MetadataGRPC["metadata-grpc-server<br/>MLMD gRPC 8080/TCP"]
            MetadataEnvoy["metadata-envoy<br/>gRPC-Web Proxy 9090/TCP"]
            MetadataWriter["metadata-writer<br/>Python Agent<br/>Writes execution metadata"]
            MetadataEnvoy -->|proxies| MetadataGRPC
            MetadataWriter -->|writes to| MetadataGRPC
        end

        subgraph Frontend["Frontend"]
            UI["ml-pipeline-ui<br/>Web UI 3000/TCP<br/>TypeScript/React"]
            VizServer["visualization-server<br/>8888/TCP Python"]
        end

        subgraph V2Runtime["V2 Pipeline Runtime"]
            Driver["kfp-driver<br/>Init container<br/>Resolves inputs, caching"]
            Launcher["kfp-launcher<br/>Sidecar<br/>Launches user containers"]
        end
    end

    %% External Users
    User[Data Scientist / SDK] -->|REST/gRPC| APIServer
    Browser[Browser] -->|HTTP| UI
    UI -->|proxies API| APIServer
    UI -->|gRPC-Web| MetadataEnvoy

