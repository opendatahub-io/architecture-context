graph TB
    subgraph "Kubeflow Training Operator"
        Controller[Training Operator<br/>Controller Manager]

        subgraph "Job Controllers"
            PyTorchCtrl[PyTorchJob Controller]
            TFCtrl[TFJob Controller]
            MPICtrl[MPIJob Controller]
            XGBoostCtrl[XGBoostJob Controller]
            JAXCtrl[JAXJob Controller]
            PaddleCtrl[PaddleJob Controller]
        end

        subgraph "Validation Webhooks"
            PyTorchWebhook[PyTorchJob Webhook<br/>9443/TCP HTTPS]
            TFWebhook[TFJob Webhook<br/>9443/TCP HTTPS]
            MPIWebhook[MPIJob Webhook<br/>9443/TCP HTTPS]
            XGBoostWebhook[XGBoostJob Webhook<br/>9443/TCP HTTPS]
            JAXWebhook[JAXJob Webhook<br/>9443/TCP HTTPS]
            PaddleWebhook[PaddleJob Webhook<br/>9443/TCP HTTPS]
        end

        Metrics[Metrics Endpoint<br/>8080/TCP HTTP]
        Health[Health Probes<br/>8081/TCP HTTP]

        Controller --> PyTorchCtrl
        Controller --> TFCtrl
        Controller --> MPICtrl
        Controller --> XGBoostCtrl
        Controller --> JAXCtrl
        Controller --> PaddleCtrl
    end

    subgraph "Custom Resources"
        PyTorchJob[PyTorchJob CR<br/>kubeflow.org/v1]
        TFJob[TFJob CR<br/>kubeflow.org/v1]
        MPIJob[MPIJob CR<br/>kubeflow.org/v1]
        XGBoostJob[XGBoostJob CR<br/>kubeflow.org/v1]
        JAXJob[JAXJob CR<br/>kubeflow.org/v1]
        PaddleJob[PaddleJob CR<br/>kubeflow.org/v1]
    end

    subgraph "Created Resources"
        TrainingPods[Training Pods<br/>Master/Workers/PS]
        Services[ClusterIP Services<br/>Pod Discovery]
        PodGroups[PodGroups<br/>Gang Scheduling]
        HPAs[HorizontalPodAutoscalers<br/>Elastic Training]
    end

    subgraph "Users"
        DataScientist[Data Scientist]
        PythonSDK[Python SDK<br/>kubeflow-training]
    end

    %% User interactions
    DataScientist -->|kubectl apply| PyTorchJob
    DataScientist -->|kubectl apply| TFJob
    DataScientist -->|kubectl apply| MPIJob
    PythonSDK -->|creates| PyTorchJob

    %% Validation
    PyTorchJob -->|validated by| PyTorchWebhook
    TFJob -->|validated by| TFWebhook
    MPIJob -->|validated by| MPIWebhook
    XGBoostJob -->|validated by| XGBoostWebhook
    JAXJob -->|validated by| JAXWebhook
    PaddleJob -->|validated by| PaddleWebhook

    %% Reconciliation
    PyTorchJob -->|watched by| PyTorchCtrl
    TFJob -->|watched by| TFCtrl
    MPIJob -->|watched by| MPICtrl
    XGBoostJob -->|watched by| XGBoostCtrl
    JAXJob -->|watched by| JAXCtrl
    PaddleJob -->|watched by| PaddleCtrl

    %% Resource creation
    PyTorchCtrl -->|creates| TrainingPods
    TFCtrl -->|creates| TrainingPods
    MPICtrl -->|creates| TrainingPods
    PyTorchCtrl -->|creates| Services
    TFCtrl -->|creates| Services
    MPICtrl -->|creates| Services
    PyTorchCtrl -->|creates| PodGroups
    PyTorchCtrl -->|creates| HPAs

    %% External dependencies
    Controller -->|depends on| K8sAPI[Kubernetes API]
    Controller -.->|optional| Volcano[Volcano Scheduler]
    Controller -.->|optional| SchedPlugins[scheduler-plugins]
    Controller -.->|integrates| Prometheus[Prometheus]

    %% Monitoring
    Prometheus -->|scrapes| Metrics
    K8sAPI -->|probes| Health

    %% ODH Integration
    ODHOperator[ODH Operator] -->|deploys| Controller
    Dashboard[ODH Dashboard] -->|UI mgmt| PyTorchJob

