%% RBAC Visualization: llama-stack-provider-ragas
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        LLSSA["Llama Stack Server SA<br/>(runs provider in-process)"]
        KFPSA["KFP Pipeline SA<br/>(runs evaluation pods)"]
    end

    subgraph "Required Permissions"
        direction TB
        ConfigMapRead["Permission: ConfigMap Read<br/>API Group: core ('')<br/>Resources: configmaps<br/>Verbs: get"]
        SecretRead["Permission: Secret Read (KFP)<br/>API Group: core ('')<br/>Resources: secrets<br/>Verbs: get"]
    end

    subgraph "Target Resources"
        direction TB
        TrustyAICM["trustyai-service-operator-config<br/>ConfigMap<br/>Namespace: redhat-ods-applications"]
        KFRagasCM["kubeflow-ragas-config<br/>ConfigMap<br/>Namespace: User namespace"]
        S3Secret["S3 Credentials Secret<br/>(configurable name)<br/>Keys: AWS_ACCESS_KEY_ID,<br/>AWS_SECRET_ACCESS_KEY,<br/>AWS_DEFAULT_REGION"]
        KFPTokenSecret["kubeflow-pipelines-token<br/>Secret<br/>Key: KUBEFLOW_PIPELINES_TOKEN"]
        InferenceSecret["llama-stack-inference-model-secret<br/>Secret<br/>Keys: INFERENCE_MODEL,<br/>VLLM_URL, VLLM_API_TOKEN"]
        AWSSecret["aws-credentials<br/>Secret<br/>Keys: AWS credentials"]
    end

    subgraph "External APIs Accessed"
        KFPAPI["Kubeflow Pipelines API<br/>Auth: Bearer Token<br/>Methods: POST, GET"]
        S3API["S3 Storage API<br/>Auth: AWS IAM<br/>Methods: PUT, GET"]
        K8sAPI["Kubernetes API<br/>Auth: SA Token<br/>Methods: GET"]
        LLSAPI["Llama Stack Server<br/>Auth: None<br/>Methods: POST, GET"]
    end

    %% Service Account to Permission mappings
    LLSSA -->|"needs"| ConfigMapRead
    LLSSA -->|"needs"| SecretRead
    KFPSA -->|"needs"| SecretRead

    %% Permission to Resource mappings
    ConfigMapRead -->|"reads"| TrustyAICM
    ConfigMapRead -->|"reads"| KFRagasCM
    SecretRead -->|"mounts into KFP pods"| S3Secret

    %% Secret usage
    LLSSA -.->|"env vars"| KFPTokenSecret
    LLSSA -.->|"env vars"| InferenceSecret
    LLSSA -.->|"env vars"| AWSSecret
    KFPSA -.->|"env vars"| S3Secret

    %% API access
    LLSSA -->|"Bearer Token"| KFPAPI
    LLSSA -->|"SA Token"| K8sAPI
    LLSSA -->|"AWS IAM"| S3API
    KFPSA -->|"callback"| LLSAPI
    KFPSA -->|"AWS IAM"| S3API

