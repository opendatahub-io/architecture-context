/*
 * C4 Context Diagram for lm-evaluation-harness
 * Generated by: Claude Opus 4.6
 * Source: architecture/rhoai-3.0/lm-evaluation-harness.md
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Defines evaluation tasks and reviews model evaluation results"

        lmEvalHarness = softwareSystem "LM Evaluation Harness" "Framework for evaluating language models against standardized benchmarks, packaged as a batch job container (quay.io/rhoai/odh-ta-lmes-job-rhel9)" {
            evaluator = container "Evaluator" "Main evaluation orchestrator - simple_evaluate() entry point" "Python"
            registry = container "Registry" "Registry for models, tasks, groups, filters, metrics, aggregations" "Python"
            modelBackends = container "Model Backends" "20 model backend implementations (HuggingFace, vLLM, OpenAI, watsonx, Anthropic, etc.)" "Python"
            taskEngine = container "Task Engine" "156+ evaluation task families with YAML-based task specs" "Python"
            metricsEngine = container "Metrics Engine" "54 bundled offline HF Evaluate metrics for disconnected operation" "Python"
            caching = container "Caching" "SQLite-based caching for model responses and request deduplication" "Python/SQLite"
            filters = container "Filters" "Post-processing filter pipeline for model outputs" "Python"
        }

        lmesOperator = softwareSystem "TrustyAI LMEval Service" "Operator that creates Kubernetes Jobs using the LM Eval container image based on LMEvalJob CRD" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving platform for inference endpoints" "Internal RHOAI"
        vllmServing = softwareSystem "vLLM Serving" "High-throughput model serving runtime" "Internal RHOAI"
        huggingfaceHub = softwareSystem "HuggingFace Hub" "Model and dataset repository" "External"
        watsonxAI = softwareSystem "IBM watsonx.ai" "IBM hosted model inference service" "External"
        anthropicAPI = softwareSystem "Anthropic API" "Anthropic Claude model inference API" "External"
        s3Storage = softwareSystem "S3-Compatible Storage" "Object storage for datasets and model artifacts" "External"
        wandb = softwareSystem "Weights & Biases" "Optional experiment tracking and logging" "External"

        /* Relationships */
        dataScientist -> lmesOperator "Submits LMEvalJob CRD"
        lmesOperator -> lmEvalHarness "Creates Kubernetes Job using container image"

        lmEvalHarness -> huggingfaceHub "Downloads models, datasets, tokenizers" "HTTPS/443, Bearer Token"
        lmEvalHarness -> kserve "Evaluates served models via OpenAI-compatible API" "HTTP/HTTPS 8080/TCP"
        lmEvalHarness -> vllmServing "Evaluates served models" "HTTP/HTTPS 8000/TCP"
        lmEvalHarness -> watsonxAI "Evaluates watsonx.ai hosted models" "HTTPS/443, API Key"
        lmEvalHarness -> anthropicAPI "Evaluates Anthropic Claude models" "HTTPS/443, API Key"
        lmEvalHarness -> s3Storage "Downloads datasets/model artifacts" "HTTPS/443, AWS IAM"
        lmEvalHarness -> wandb "Optional experiment logging" "HTTPS/443, API Key"

        /* Internal container relationships */
        evaluator -> registry "Resolves models, tasks, metrics"
        evaluator -> taskEngine "Runs evaluation tasks"
        evaluator -> modelBackends "Invokes model inference"
        evaluator -> filters "Applies output post-processing"
        evaluator -> caching "Caches model responses"
        taskEngine -> metricsEngine "Computes evaluation metrics"
    }

    views {
        systemContext lmEvalHarness "SystemContext" {
            include *
            autoLayout
        }

        container lmEvalHarness "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
