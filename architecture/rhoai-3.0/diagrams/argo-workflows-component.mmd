%% Generated by: Claude Opus 4.6

graph TB
    subgraph ArgoWorkflows["Argo Workflows Component"]
        direction TB
        Controller["workflow-controller<br/>(Go Service)<br/>Leader Election<br/>Metrics: 9090/TCP"]
        ArgoServer["argo-server<br/>(Go Service)<br/>gRPC + REST API<br/>Port: 2746/TCP"]
        ArgoExec["argoexec<br/>(Go Sidecar/Executor)<br/>Artifact & Output Mgmt"]
        CronCtrl["cron-controller<br/>(embedded in controller)"]
        ArtifactGC["artifact-gc-controller<br/>(embedded in controller)"]
        UI["argo-workflows-ui<br/>(TypeScript/React)<br/>Served by argo-server"]

        Controller --- CronCtrl
        Controller --- ArtifactGC
        ArgoServer -->|serves| UI
    end

    %% CRDs
    WorkflowCR["Workflow CR<br/>(argoproj.io/v1alpha1)"]
    CronWorkflowCR["CronWorkflow CR<br/>(argoproj.io/v1alpha1)"]
    WFTemplateCR["WorkflowTemplate CR<br/>(argoproj.io/v1alpha1)"]
    ClusterWFTemplateCR["ClusterWorkflowTemplate CR<br/>(argoproj.io/v1alpha1)"]
    WFTaskSetCR["WorkflowTaskSet CR<br/>(argoproj.io/v1alpha1)"]
    WFArtifactGCCR["WorkflowArtifactGCTask CR<br/>(argoproj.io/v1alpha1)"]

    %% External Dependencies
    K8sAPI["Kubernetes API<br/>443/TCP HTTPS"]
    ArtifactStore["S3/GCS/Azure Blob<br/>443/TCP HTTPS"]
    Database["PostgreSQL/MySQL<br/>(Optional)<br/>5432/3306 TCP"]
    OIDCProvider["OIDC Provider<br/>(Optional)<br/>443/TCP HTTPS"]
    Prometheus["Prometheus<br/>Metrics Scrape"]

    %% Internal ODH
    DSPOperator["Data Science Pipelines<br/>Operator"]
    DSPAPI["Data Science Pipelines<br/>API Server"]

    %% User
    User["User / Client"]

    %% Relationships
    User -->|creates| WorkflowCR
    User -->|HTTPS/gRPC :2746| ArgoServer
    DSPAPI -->|creates| WorkflowCR

    WorkflowCR -->|watched by| Controller
    CronWorkflowCR -->|watched by| CronCtrl
    WFArtifactGCCR -->|watched by| ArtifactGC
    WFTemplateCR -->|referenced by| Controller
    ClusterWFTemplateCR -->|referenced by| Controller

    Controller -->|creates pods via| K8sAPI
    Controller -->|updates status via| K8sAPI
    ArgoExec -->|uploads artifacts| ArtifactStore
    ArgoExec -->|updates status| K8sAPI
    ArgoServer -->|queries| K8sAPI
    ArgoServer -->|archives to| Database
    ArgoServer -->|authenticates via| OIDCProvider

    DSPOperator -->|deploys & manages| Controller
    DSPOperator -->|deploys & manages| ArgoExec

    Prometheus -->|scrapes :9090| Controller
    Prometheus -->|scrapes :2746| ArgoServer

    CronCtrl -->|creates| WorkflowCR

