        CSC["serving.kserve.io<br/>ClusterStorageContainer<br/>(v1alpha1)"]
    end

    subgraph "API Resources - Core & Apps"
        direction TB
        Core["Core API<br/>ConfigMaps, Secrets, Services,<br/>ServiceAccounts, Pods,<br/>Events, Namespaces"]
        Apps["apps<br/>Deployments"]
        Autoscaling["autoscaling<br/>HorizontalPodAutoscalers"]
    end

    subgraph "API Resources - Knative & Istio"
        direction TB
        KnativeServing["serving.knative.dev<br/>Services"]
        IstioNetworking["networking.istio.io<br/>VirtualServices,<br/>DestinationRules"]
    end

    subgraph "API Resources - Networking"
        direction TB
        K8sNetworking["networking.k8s.io<br/>Ingresses"]
        GatewayAPI["gateway.networking.k8s.io<br/>Gateways, HTTPRoutes,<br/>GatewayClasses"]
        OSRoute["route.openshift.io<br/>Routes"]
    end

    subgraph "API Resources - Admission & RBAC"
        direction TB
        Admission["admissionregistration.k8s.io<br/>MutatingWebhookConfigurations,<br/>ValidatingWebhookConfigurations"]
        RBAC["rbac.authorization.k8s.io<br/>ClusterRoleBindings,<br/>RoleBindings, Roles"]
        Auth["authentication.k8s.io<br/>TokenReviews,<br/>SubjectAccessReviews"]
    end

    subgraph "API Resources - Monitoring & Observability"
        direction TB
        KEDA_API["keda.sh<br/>ScaledObjects"]
        Monitoring["monitoring.coreos.com<br/>ServiceMonitors,<br/>PodMonitors"]
        OTel["opentelemetry.io<br/>OpenTelemetryCollectors"]
    end

    subgraph "API Resources - Other"
        direction TB
        LWS["leaderworkerset.x-k8s.io<br/>LeaderWorkerSets"]
        InferenceNetworking["inference.networking.k8s.io<br/>inference.networking.x-k8s.io<br/>InferencePools, InferenceModels,<br/>InferenceObjectives"]
        SCC["security.openshift.io<br/>SecurityContextConstraints<br/>(openshift-ai-llminferenceservice-scc)"]
    end

    subgraph "API Resources - Leader Election"
        direction TB
        LeaderElection["Core API: ConfigMaps<br/>coordination.k8s.io: Leases<br/>(Namespace: kserve)"]
    end

