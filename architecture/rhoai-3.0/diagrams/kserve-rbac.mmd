    style SA_Manager fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Leader fill:#f5a623,stroke:#333
    style CR_Proxy fill:#f5a623,stroke:#333
    style CRB_Manager fill:#9013fe,stroke:#333,color:#fff
    style CRB_Leader fill:#9013fe,stroke:#333,color:#fff
    style CRB_Proxy fill:#9013fe,stroke:#333,color:#fff

    style CRD_InferenceService fill:#7ed321,stroke:#333
    style CRD_ServingRuntime fill:#7ed321,stroke:#333
    style CRD_ClusterServingRuntime fill:#7ed321,stroke:#333
    style CRD_InferenceGraph fill:#7ed321,stroke:#333
    style CRD_LLMInferenceService fill:#7ed321,stroke:#333
    style CRD_TrainedModel fill:#7ed321,stroke:#333

    style CRD_KnativeService fill:#50e3c2,stroke:#333
    style CRD_VirtualService fill:#50e3c2,stroke:#333
    style CRD_DestinationRule fill:#50e3c2,stroke:#333

    style Core_Services fill:#bd10e0,stroke:#333,color:#fff
    style Core_Deployments fill:#bd10e0,stroke:#333,color:#fff
    style Core_ConfigMaps fill:#bd10e0,stroke:#333,color:#fff
    style Core_Secrets fill:#bd10e0,stroke:#333,color:#fff

    style Autoscale_HPA fill:#f8e71c,stroke:#333
    style KEDA_ScaledObject fill:#f8e71c,stroke:#333
    style Monitor_ServiceMonitor fill:#f8e71c,stroke:#333

