graph TD
    subgraph "Service Accounts"
        SA_Manager[kserve-controller-manager<br/>Namespace: kserve]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[kserve-manager-rolebinding<br/>Scope: Cluster]
        CRB_Leader[kserve-leader-election-rolebinding<br/>Scope: kserve namespace]
        CRB_Proxy[kserve-proxy-rolebinding<br/>Scope: Cluster]
    end

    subgraph "ClusterRoles"
        CR_Manager[kserve-manager-role<br/>Comprehensive Permissions]
        CR_Leader[kserve-leader-election-role<br/>Leader Election Only]
        CR_Proxy[kserve-proxy-role<br/>Token/Access Reviews]
    end

    subgraph "API Resources - KServe CRDs"
        direction TB
        CRD_InferenceService[serving.kserve.io<br/>InferenceService<br/>v1beta1]
        CRD_ServingRuntime[serving.kserve.io<br/>ServingRuntime<br/>v1alpha1]
        CRD_ClusterServingRuntime[serving.kserve.io<br/>ClusterServingRuntime<br/>v1alpha1]
        CRD_InferenceGraph[serving.kserve.io<br/>InferenceGraph<br/>v1alpha1]
        CRD_TrainedModel[serving.kserve.io<br/>TrainedModel<br/>v1alpha1]
        CRD_LLMInferenceService[serving.kserve.io<br/>LLMInferenceService<br/>v1alpha1]
        CRD_LocalModelCache[serving.kserve.io<br/>LocalModelCache<br/>v1alpha1]
        CRD_ClusterStorageContainer[serving.kserve.io<br/>ClusterStorageContainer<br/>v1alpha1]
    end

    subgraph "API Resources - Knative"
        CRD_KnativeService[serving.knative.dev<br/>Service]
    end

    subgraph "API Resources - Istio"
        CRD_VirtualService[networking.istio.io<br/>VirtualService]
        CRD_DestinationRule[networking.istio.io<br/>DestinationRule]
    end

    subgraph "API Resources - Kubernetes Core"
        Core_Services[core<br/>Services]
        Core_Deployments[apps<br/>Deployments]
        Core_ConfigMaps[core<br/>ConfigMaps]
        Core_Secrets[core<br/>Secrets]
        Core_ServiceAccounts[core<br/>ServiceAccounts]
        Core_Pods[core<br/>Pods]
    end

    subgraph "API Resources - Networking"
        Net_Ingresses[networking.k8s.io<br/>Ingresses]
        Net_Gateway[gateway.networking.k8s.io<br/>Gateways/HTTPRoutes]
        Net_Routes[route.openshift.io<br/>Routes]
    end

    subgraph "API Resources - Autoscaling & Monitoring"
        Autoscale_HPA[autoscaling<br/>HorizontalPodAutoscalers]
        KEDA_ScaledObject[keda.sh<br/>ScaledObjects]
        Monitor_ServiceMonitor[monitoring.coreos.com<br/>ServiceMonitors]
    end

    subgraph "API Resources - RBAC & Admission"
        RBAC_ClusterRoleBinding[rbac.authorization.k8s.io<br/>ClusterRoleBindings]
        RBAC_RoleBinding[rbac.authorization.k8s.io<br/>RoleBindings]
        Admission_Webhook[admissionregistration.k8s.io<br/>MutatingWebhookConfigurations<br/>ValidatingWebhookConfigurations]
    end

    %% Bindings
    SA_Manager -->|bound via| CRB_Manager
    SA_Manager -->|bound via| CRB_Leader
    SA_Manager -->|bound via| CRB_Proxy

    CRB_Manager -->|grants| CR_Manager
    CRB_Leader -->|grants| CR_Leader
    CRB_Proxy -->|grants| CR_Proxy

    %% Manager Role Permissions - KServe CRDs
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_InferenceService
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_ServingRuntime
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_ClusterServingRuntime
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_InferenceGraph
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_TrainedModel
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_LLMInferenceService
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_LocalModelCache
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_ClusterStorageContainer

    %% Manager Role Permissions - Knative
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_KnativeService

    %% Manager Role Permissions - Istio
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_VirtualService
    CR_Manager -->|get,list,watch,create,update,patch,delete| CRD_DestinationRule

    %% Manager Role Permissions - Core Resources
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Services
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Deployments
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_ConfigMaps
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Secrets
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_ServiceAccounts
    CR_Manager -->|get,list,watch,create,update,patch,delete| Core_Pods

    %% Manager Role Permissions - Networking
    CR_Manager -->|get,list,watch,create,update,patch,delete| Net_Ingresses
    CR_Manager -->|get,list,watch,create,update,patch,delete| Net_Gateway
    CR_Manager -->|get,list,watch,create,update,patch,delete| Net_Routes

    %% Manager Role Permissions - Autoscaling & Monitoring
    CR_Manager -->|get,list,watch,create,update,patch,delete| Autoscale_HPA
    CR_Manager -->|get,list,watch,create,update,patch,delete| KEDA_ScaledObject
    CR_Manager -->|get,list,watch,create,update,patch,delete| Monitor_ServiceMonitor

    %% Manager Role Permissions - RBAC & Admission
    CR_Manager -->|get,list,watch,create,update,patch,delete| RBAC_ClusterRoleBinding
    CR_Manager -->|get,list,watch,create,update,patch,delete| RBAC_RoleBinding
    CR_Manager -->|get,list,watch,create,update,patch,delete| Admission_Webhook

    %% Leader Election Role
    CR_Leader -->|get,list,watch,create,update,patch,delete| LeaderElection[coordination.k8s.io<br/>Leases<br/>ConfigMaps]

    %% Proxy Role
    CR_Proxy -->|create| TokenReview[authentication.k8s.io<br/>TokenReviews]
    CR_Proxy -->|create| SubjectAccessReview[authorization.k8s.io<br/>SubjectAccessReviews]

