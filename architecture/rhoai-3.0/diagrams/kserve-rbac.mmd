        CRB_Proxy["kserve-proxy-rolebinding<br/>(ClusterRoleBinding)"]
    end

    subgraph "ClusterRoles"
        CR_Manager["kserve-manager-role<br/>(ClusterRole)"]
        CR_Leader["kserve-leader-election-role<br/>(Role)"]
        CR_Proxy["kserve-proxy-role<br/>(ClusterRole)"]
    end

    subgraph "API Resources - KServe CRDs"
        direction TB
        ISVC["serving.kserve.io<br/>InferenceService<br/>(v1beta1)"]
        SR["serving.kserve.io<br/>ServingRuntime<br/>(v1alpha1)"]
