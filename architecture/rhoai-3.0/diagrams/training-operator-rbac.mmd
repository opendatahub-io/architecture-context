graph TD
    subgraph "Service Accounts"
        SA[kubeflow-training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRole: training-operator"
        CR[training-operator<br/>ClusterRole]
    end

    subgraph "Core API Resources (API Group: '')"
        Pods[pods<br/>pods/exec]
        Services[services]
        Events[events]
        ConfigMaps[configmaps]
        Secrets[secrets]
        ServiceAccounts[serviceaccounts]
    end

    subgraph "Training Job CRDs (API Group: kubeflow.org)"
        PyTorchJobs[pytorchjobs<br/>pytorchjobs/status<br/>pytorchjobs/finalizers]
        TFJobs[tfjobs<br/>tfjobs/status<br/>tfjobs/finalizers]
        MPIJobs[mpijobs<br/>mpijobs/status<br/>mpijobs/finalizers]
        XGBoostJobs[xgboostjobs<br/>xgboostjobs/status<br/>xgboostjobs/finalizers]
        JAXJobs[jaxjobs<br/>jaxjobs/status<br/>jaxjobs/finalizers]
        PaddleJobs[paddlejobs<br/>paddlejobs/status<br/>paddlejobs/finalizers]
    end

    subgraph "RBAC Resources (API Group: rbac.authorization.k8s.io)"
        Roles[roles<br/>rolebindings]
    end

    subgraph "Autoscaling (API Group: autoscaling)"
        HPA[horizontalpodautoscalers]
    end

    subgraph "Gang Scheduling (API Group: scheduling.volcano.sh, scheduling.x-k8s.io)"
        PodGroups[podgroups]
    end

    subgraph "Networking (API Group: networking.k8s.io)"
        NetworkPolicies[networkpolicies]
    end

    subgraph "Admission (API Group: admissionregistration.k8s.io)"
        Webhooks[validatingwebhookconfigurations]
    end

    %% Bindings
    SA -->|bound via| CRB
    CRB -->|grants| CR

    %% Core permissions (create, delete, get, list, patch, update, watch)
    CR -->|create, delete, get,<br/>list, patch, update, watch| Pods
    CR -->|create, delete,<br/>get, list, watch| Services
    CR -->|create, delete, get,<br/>list, patch, update, watch| Events
    CR -->|create, list,<br/>update, watch| ConfigMaps
    CR -->|get, list,<br/>update, watch| Secrets
    CR -->|create, get,<br/>list, watch| ServiceAccounts

    %% Training job CRD permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| PyTorchJobs
    CR -->|create, delete, get,<br/>list, patch, update, watch| TFJobs
    CR -->|create, delete, get,<br/>list, patch, update, watch| MPIJobs
    CR -->|create, delete, get,<br/>list, patch, update, watch| XGBoostJobs
    CR -->|create, delete, get,<br/>list, patch, update, watch| JAXJobs
    CR -->|create, delete, get,<br/>list, patch, update, watch| PaddleJobs

    %% RBAC permissions
    CR -->|create, list,<br/>update, watch| Roles

    %% Autoscaling permissions (for PyTorch elastic training)
    CR -->|create, delete, get,<br/>list, patch, update, watch| HPA

    %% Gang scheduling permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| PodGroups

    %% Networking permissions
    CR -->|create, delete, get,<br/>list, patch, update, watch| NetworkPolicies

    %% Webhook permissions
    CR -->|get, list,<br/>update, watch| Webhooks

    %% User roles
    subgraph "User Roles (for Data Scientists)"
        EditRole[training-edit<br/>ClusterRole]
        ViewRole[training-view<br/>ClusterRole]
    end

    EditRole -->|create, delete, get,<br/>list, patch, update, watch| PyTorchJobs
    EditRole -->|create, delete, get,<br/>list, patch, update, watch| TFJobs
    EditRole -->|create, delete, get,<br/>list, patch, update, watch| MPIJobs
    EditRole -->|create, delete, get,<br/>list, patch, update, watch| XGBoostJobs
    EditRole -->|create, delete, get,<br/>list, patch, update, watch| PaddleJobs
    EditRole -->|get| PyTorchJobs
    EditRole -->|get| TFJobs

    ViewRole -->|get, list, watch| PyTorchJobs
    ViewRole -->|get, list, watch| TFJobs
    ViewRole -->|get, list, watch| MPIJobs
    ViewRole -->|get, list, watch| XGBoostJobs
    ViewRole -->|get, list, watch| PaddleJobs

    %% Styling
    style SA fill:#4a90e2,stroke:#333,stroke-width:3px,color:#fff
    style CRB fill:#f5a623,stroke:#333,stroke-width:2px
    style CR fill:#f5a623,stroke:#333,stroke-width:3px
    style EditRole fill:#7ed321,stroke:#333,stroke-width:2px
    style ViewRole fill:#7ed321,stroke:#333,stroke-width:2px
    style Pods fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Services fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Events fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style ConfigMaps fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style Secrets fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style ServiceAccounts fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    style PyTorchJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style TFJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style MPIJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style XGBoostJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style JAXJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style PaddleJobs fill:#f8cecc,stroke:#b85450,stroke-width:2px
    style Roles fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style HPA fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style PodGroups fill:#e1d5e7,stroke:#9673a6,stroke-width:2px
    style NetworkPolicies fill:#fff2cc,stroke:#d6b656,stroke-width:2px
    style Webhooks fill:#fff2cc,stroke:#d6b656,stroke-width:2px
