graph TD
    subgraph "Service Accounts"
        SA1[kubeflow-training-operator<br/>Namespace: opendatahub]
    end

    subgraph "ClusterRole Bindings"
        CRB1[training-operator<br/>ClusterRoleBinding]
    end

    subgraph "ClusterRoles"
        CR1[training-operator<br/>ClusterRole]
        CR2[training-edit<br/>ClusterRole - User-facing]
        CR3[training-view<br/>ClusterRole - User-facing]
    end

    subgraph "Kubeflow CRD Permissions"
        direction TB
        CRD1["kubeflow.org<br/>PyTorchJob, TFJob, MPIJob<br/>XGBoostJob, JAXJob, PaddleJob<br/><br/>Verbs: create, delete, get,<br/>list, patch, update, watch<br/><br/>Status & Finalizers:<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "Core Kubernetes Resources"
        direction TB
        Core1["Core API ('')<br/><br/>Pods:<br/>create, delete, get, list,<br/>patch, update, watch<br/><br/>Pods/exec:<br/>create<br/><br/>Services:<br/>create, delete, get, list, watch<br/><br/>Events:<br/>create, delete, get, list,<br/>patch, update, watch"]

        Core2["Core API ('')<br/><br/>ConfigMaps:<br/>create, list, update, watch<br/><br/>Secrets:<br/>get, list, update, watch<br/><br/>ServiceAccounts:<br/>create, get, list, watch"]
    end

    subgraph "RBAC Resources"
        RBAC1["rbac.authorization.k8s.io<br/><br/>Roles, RoleBindings:<br/>create, list, update, watch"]
    end

    subgraph "Autoscaling & Scheduling"
        Auto1["autoscaling<br/><br/>HorizontalPodAutoscalers:<br/>create, delete, get, list,<br/>patch, update, watch"]

        Sched1["scheduling.volcano.sh<br/>scheduling.x-k8s.io<br/><br/>PodGroups:<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "Networking"
        Net1["networking.k8s.io<br/><br/>NetworkPolicies:<br/>create, delete, get, list,<br/>patch, update, watch"]
    end

    subgraph "Admission Registration"
        Admission1["admissionregistration.k8s.io<br/><br/>ValidatingWebhookConfigurations:<br/>get, list, update, watch"]
    end

    subgraph "User Permissions - Edit"
        UserEdit["kubeflow.org<br/><br/>MPIJob, TFJob, PyTorchJob,<br/>XGBoostJob, PaddleJob:<br/>create, delete, get, list,<br/>patch, update, watch<br/><br/>Status:<br/>get"]
    end

    subgraph "User Permissions - View"
        UserView["kubeflow.org<br/><br/>MPIJob, TFJob, PyTorchJob,<br/>XGBoostJob, PaddleJob:<br/>get, list, watch<br/><br/>Status:<br/>get"]
    end

    %% Service Account to ClusterRoleBinding
    SA1 -->|bound via| CRB1

    %% ClusterRoleBinding to ClusterRole
    CRB1 -->|grants| CR1

    %% ClusterRole to Resources
    CR1 -->|full CRUD| CRD1
    CR1 -->|manage pods/services| Core1
    CR1 -->|manage config/secrets| Core2
    CR1 -->|manage RBAC| RBAC1
    CR1 -->|manage HPA| Auto1
    CR1 -->|manage PodGroups| Sched1
    CR1 -->|manage NetworkPolicies| Net1
    CR1 -->|update webhooks| Admission1

    %% User-facing roles
    CR2 -->|edit jobs| UserEdit
    CR3 -->|view jobs| UserView

    %% Styling
    style SA1 fill:#4a90e2,stroke:#333,stroke-width:2px
    style CRB1 fill:#f5a623,stroke:#333,stroke-width:2px
    style CR1 fill:#e74c3c,stroke:#333,stroke-width:3px
    style CR2 fill:#9b59b6,stroke:#333,stroke-width:2px
    style CR3 fill:#95a5a6,stroke:#333,stroke-width:2px

    style CRD1 fill:#7ed321,stroke:#333
    style Core1 fill:#7ed321,stroke:#333
    style Core2 fill:#7ed321,stroke:#333
    style RBAC1 fill:#7ed321,stroke:#333
    style Auto1 fill:#7ed321,stroke:#333
    style Sched1 fill:#7ed321,stroke:#333
    style Net1 fill:#7ed321,stroke:#333
    style Admission1 fill:#7ed321,stroke:#333
    style UserEdit fill:#3498db,stroke:#333
    style UserView fill:#2ecc71,stroke:#333
