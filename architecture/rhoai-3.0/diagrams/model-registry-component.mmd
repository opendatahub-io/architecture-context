%% Model Registry - Component Structure Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph "Model Registry System"
        direction TB

        subgraph "Core Services"
            ProxyServer["Model Registry<br/>Proxy Server<br/>(Go REST API)<br/>Port: 8080/TCP"]
            CatalogServer["Model Catalog<br/>Server<br/>(Go REST API)<br/>Port: 8080/TCP"]
            BFF["UI Backend-for-Frontend<br/>(Go HTTP Service)<br/>Port: 8080/TCP"]
            UIFrontend["UI Frontend<br/>(React/TypeScript SPA)"]
        end

        subgraph "Controllers"
            ISController["InferenceService<br/>Controller<br/>(controller-runtime)"]
            CSI["CSI Storage<br/>Initializer<br/>(Go CLI)"]
        end

        subgraph "Jobs"
            AsyncUpload["Async Upload Job<br/>(Python)"]
        end

        subgraph "Data Layer"
            EmbedMD["EmbedMD Datastore<br/>(GORM ORM)"]
        end
    end

    %% External Users
    User[Data Scientist / Client] -->|REST API calls| ProxyServer
    Browser[Browser] -->|HTTP/HTTPS| UIFrontend
    UIFrontend -->|API calls| BFF

    %% Internal flows
    BFF -->|REST API proxy| ProxyServer
    BFF -->|catalog queries| CatalogServer
    ProxyServer -->|CRUD operations| EmbedMD
    CatalogServer -->|catalog persistence| EmbedMD

    %% CRD interactions
    InferenceServiceCR["InferenceService CR<br/>(serving.kserve.io/v1beta1)"]
    ClusterStorageCR["ClusterStorageContainer CR<br/>(serving.kserve.io/v1alpha1)"]

    InferenceServiceCR -->|watched by| ISController
    ISController -->|syncs state via REST| ProxyServer
    ClusterStorageCR -->|configures| CSI

    %% External dependencies
    EmbedMD -->|3306/TCP| MySQL[(MySQL 8.x)]
    EmbedMD -->|5432/TCP| PostgreSQL[(PostgreSQL 13+)]
    CatalogServer -->|443/TCP HTTPS| HuggingFace[HuggingFace API]
    CSI -->|443/TCP HTTPS| S3[Model Artifact Storage<br/>S3 / OBC]
    AsyncUpload -->|upload artifacts| S3

    %% Mesh integration
    Istio["Istio Service Mesh<br/>(mTLS, AuthorizationPolicy)"] -.->|mTLS encryption| ProxyServer
    Prometheus["Prometheus<br/>(ServiceMonitor)"] -->|8443/TCP HTTPS| ISController

    %% Kubernetes API
    ISController -->|443/TCP HTTPS| K8sAPI[Kubernetes API Server]
    BFF -->|443/TCP HTTPS| K8sAPI

