// KubeRay Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        user = person "Data Scientist / ML Engineer" "Creates and manages Ray clusters, jobs, and services for distributed computing"

        kuberay = softwareSystem "KubeRay Operator" "Manages lifecycle of Ray clusters, jobs, and services on Kubernetes/OpenShift" {
            rayClusterCtrl = container "RayCluster Controller" "Reconciles RayCluster CRs - manages head/worker Pods, Services, autoscaler RBAC" "Go (controller-runtime)"
            rayJobCtrl = container "RayJob Controller" "Reconciles RayJob CRs - manages RayCluster lifecycle and job submission" "Go (controller-runtime)"
            rayServiceCtrl = container "RayService Controller" "Reconciles RayService CRs - manages Ray Serve with zero-downtime upgrades" "Go (controller-runtime)"
            mtlsCtrl = container "MTLS Controller" "Manages mTLS certificates via cert-manager for Ray cluster communication" "Go (controller-runtime)"
            authCtrl = container "Authentication Controller" "Creates HTTPRoutes, ReferenceGrants, kube-rbac-proxy ConfigMaps for dashboard auth" "Go (controller-runtime)"
            netpolCtrl = container "NetworkPolicy Controller" "Creates NetworkPolicies for secure trusted networking" "Go (controller-runtime)"
            webhook = container "Admission Webhooks" "Mutating and validating webhooks for RayCluster resources" "Go (9443/TCP HTTPS)"
        }

        // External Dependencies
        k8sApi = softwareSystem "Kubernetes API" "Core platform for managing Pods, Services, RBAC" "External"
        certManager = softwareSystem "cert-manager" "Certificate management for mTLS PKI" "External"
        gatewayApi = softwareSystem "Gateway API" "HTTPRoute/Gateway/ReferenceGrant for dashboard ingress" "External"
        volcano = softwareSystem "Volcano Scheduler" "Gang scheduling for Ray pods" "External"
        openShiftApi = softwareSystem "OpenShift API" "Route and SecurityContextConstraints support" "External"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys kuberay-operator via OpenShift kustomize overlay" "Internal RHOAI"
        dsgGateway = softwareSystem "data-science-gateway" "Platform ingress Gateway for Ray dashboards" "Internal RHOAI"
        kubeRbacProxy = softwareSystem "kube-rbac-proxy" "Sidecar for OIDC/OAuth authentication on Ray head pods" "Internal RHOAI"
        prometheus = softwareSystem "Prometheus / Monitoring" "Metrics collection for operator and Ray clusters" "Internal RHOAI"

        // External Services
        redis = softwareSystem "Redis" "GCS fault tolerance external storage" "External Service"

        // Relationships
        user -> kuberay "Creates RayCluster/RayJob/RayService via kubectl/API"
        user -> dsgGateway "Accesses Ray dashboard via HTTPS/443"

        rhodsOperator -> kuberay "Deploys via kustomize openshift overlay"

        kuberay -> k8sApi "Manages Pods, Services, Jobs, RBAC" "HTTPS/443"
        kuberay -> certManager "Creates Issuer and Certificate CRs for mTLS"
        kuberay -> gatewayApi "Creates HTTPRoutes and ReferenceGrants" "HTTPS/443"
        kuberay -> openShiftApi "Creates Routes, uses SCC" "HTTPS/443"

        dsgGateway -> kuberay "Routes dashboard traffic to Ray head" "HTTP/8265"
        kubeRbacProxy -> k8sApi "TokenReview + SubjectAccessReview" "HTTPS/443"

        kuberay -> redis "GCS fault tolerance storage" "TCP/6379"
        kuberay -> volcano "Gang scheduling integration"

        prometheus -> kuberay "Scrapes operator and Ray metrics" "HTTP/8080"

        // Container-level relationships
        rayClusterCtrl -> k8sApi "Creates Pods, Services, Ingress" "HTTPS/443"
        rayJobCtrl -> k8sApi "Creates K8s Jobs for submission" "HTTPS/443"
        rayServiceCtrl -> k8sApi "Manages Serve deployments" "HTTPS/443"
        mtlsCtrl -> certManager "Creates Issuer, Certificate CRs"
        authCtrl -> gatewayApi "Creates HTTPRoutes, ReferenceGrants" "HTTPS/443"
        netpolCtrl -> k8sApi "Creates NetworkPolicies" "HTTPS/443"
    }

    views {
        systemContext kuberay "SystemContext" {
            include *
            autoLayout
        }

        container kuberay "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
        }
    }
}
