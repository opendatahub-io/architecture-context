// C4 Context Diagram - odh-model-controller
// Generated by: Claude Opus 4.6

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates and deploys ML models via InferenceService and LLMInferenceService CRs"
        platformAdmin = person "Platform Admin" "Configures NIM accounts and manages serving infrastructure"

        odhModelController = softwareSystem "odh-model-controller" "Kubernetes controller that automates model serving infrastructure on OpenShift AI" {
            isvcController = container "InferenceService Controller" "Watches InferenceService CRs; creates Routes, ClusterRoleBindings, metrics resources, KEDA resources" "Go Controller"
            llmisvcController = container "LLMInferenceService Controller" "Watches LLMInferenceService CRs; creates AuthPolicy, EnvoyFilter, RBAC" "Go Controller"
            srController = container "ServingRuntime Controller" "Manages monitoring RoleBindings, Ray TLS certificates" "Go Controller"
            nimController = container "NIM Account Controller" "Manages NVIDIA NIM API key validation, ConfigMaps, ServingRuntime Templates, pull Secrets" "Go Controller"
            secretController = container "Secret Controller" "Aggregates data connection secrets into unified storage-config Secret" "Go Controller"
            configmapController = container "ConfigMap Controller" "Manages CA certificate bundles for KServe" "Go Controller"
            podController = container "Pod Controller" "Manages per-pod Ray TLS certificates for multi-node inference" "Go Controller"
            webhookServer = container "Webhook Server" "Mutating and validating admission webhooks for Pods, InferenceService, InferenceGraph, NIM Account, LLMInferenceService" "Go Webhook Server"
            runtimeTemplates = container "ServingRuntime Templates" "Out-of-the-box runtime templates: vLLM, OpenVINO, Guardrails" "OpenShift Templates"
        }

        // External Dependencies
        kserve = softwareSystem "KServe" "Provides InferenceService, LLMInferenceService, ServingRuntime, InferenceGraph CRDs" "External"
        kuadrant = softwareSystem "Kuadrant Operator" "Provides AuthPolicy CRD for LLMInferenceService authentication" "External Optional"
        istio = softwareSystem "Istio" "Provides EnvoyFilter CRD for SSL authentication on inference gateway" "External Optional"
        keda = softwareSystem "KEDA" "Provides TriggerAuthentication CRD for Prometheus-based autoscaling" "External Optional"
        prometheusOp = softwareSystem "Prometheus Operator" "Provides ServiceMonitor, PodMonitor CRDs for metrics collection" "External"
        openshiftAPI = softwareSystem "OpenShift API" "Provides Route, Template CRDs; OpenShift authentication config" "External"
        gatewayAPI = softwareSystem "Gateway API" "Provides Gateway, HTTPRoute for LLMInferenceService ingress" "External Optional"

        // Internal ODH Dependencies
        rhodsOperator = softwareSystem "rhods-operator" "Deploys odh-model-controller via kustomize overlay" "Internal ODH"
        odhDashboard = softwareSystem "ODH Dashboard" "Discovers ServingRuntime Templates via labels" "Internal ODH"
        modelRegistry = softwareSystem "Model Registry" "Stores model metadata and inference service state" "Internal ODH"
        dsCluster = softwareSystem "Data Science Cluster" "Cluster-level configuration for ODH components" "Internal ODH"

        // External Services
        nvidiaAPI = softwareSystem "NVIDIA NGC API" "NIM API key validation and model catalog" "External Service"

        // Relationships - Users
        dataScientist -> odhModelController "Creates InferenceService / LLMInferenceService via kubectl"
        platformAdmin -> odhModelController "Creates NIM Account CRs"

        // Relationships - External Dependencies
        odhModelController -> kserve "Watches InferenceService, LLMInferenceService, ServingRuntime, InferenceGraph CRDs" "HTTPS/6443"
        odhModelController -> kuadrant "Creates AuthPolicy CRs for Gateway and HTTPRoute targets" "HTTPS/6443"
        odhModelController -> istio "Creates EnvoyFilter CRs for SSL authentication" "HTTPS/6443"
        odhModelController -> keda "Creates TriggerAuthentication CRs" "HTTPS/6443"
        odhModelController -> prometheusOp "Creates ServiceMonitor, PodMonitor CRs" "HTTPS/6443"
        odhModelController -> openshiftAPI "Creates Routes, Templates; reads auth config" "HTTPS/6443"
        odhModelController -> gatewayAPI "Reads Gateway, HTTPRoute; updates Gateway finalizers" "HTTPS/6443"

        // Relationships - Internal ODH
        rhodsOperator -> odhModelController "Deploys via kustomize" "Kustomize"
        odhDashboard -> odhModelController "Discovers ServingRuntime Templates" "Label selector"
        odhModelController -> modelRegistry "Syncs InferenceService state" "HTTPS/HTTP"
        odhModelController -> dsCluster "Reads DataScienceCluster CR for config" "HTTPS/6443"

        // Relationships - External Services
        odhModelController -> nvidiaAPI "Validates NIM API keys, retrieves model catalog" "HTTPS/443"
    }

    views {
        systemContext odhModelController "SystemContext" {
            include *
            autoLayout
        }

        container odhModelController "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "External Optional" {
                background #bbbbbb
                color #ffffff
            }
            element "External Service" {
                background #f5a623
                color #000000
            }
            element "Internal ODH" {
                background #7ed321
                color #000000
            }
            element "Person" {
                shape Person
                background #4a90e2
                color #ffffff
            }
            element "Software System" {
                shape RoundedBox
            }
            element "Container" {
                background #4a90e2
                color #ffffff
            }
        }
    }
}
