graph TD
    subgraph "Service Accounts"
        SA_ControllerManager["controller-manager<br/>Namespace: system"]
        SA_Online["feast-online-sa<br/>Namespace: user-namespace"]
        SA_Offline["feast-offline-sa<br/>Namespace: user-namespace"]
        SA_Registry["feast-registry-sa<br/>Namespace: user-namespace"]
        SA_UI["feast-ui-sa<br/>Namespace: user-namespace"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["manager-rolebinding<br/>Cluster-scoped"]
        CRB_LeaderElection["leader-election-rolebinding<br/>Namespace: system"]
        CRB_MetricsAuth["metrics-auth-rolebinding<br/>Namespace: system"]
    end

    subgraph "ClusterRoles"
        CR_Manager[manager-role]
        CR_LeaderElection[leader-election-role]
        CR_MetricsReader[metrics-reader]
        CR_FeatureStoreEditor[featurestore-editor-role]
        CR_FeatureStoreViewer[featurestore-viewer-role]
    end

    subgraph "API Resources - feast.dev"
        API_FeatureStore[FeatureStore<br/>feast.dev/v1alpha1]
        API_FeatureStore_Finalizers[FeatureStore/finalizers]
        API_FeatureStore_Status[FeatureStore/status]
    end

    subgraph "API Resources - Core"
        API_Deployments[Deployments<br/>apps/v1]
        API_CronJobs[CronJobs<br/>batch/v1]
        API_ConfigMaps[ConfigMaps<br/>v1]
        API_PVCs[PersistentVolumeClaims<br/>v1]
        API_ServiceAccounts[ServiceAccounts<br/>v1]
        API_Services[Services<br/>v1]
        API_Namespaces[Namespaces<br/>v1]
        API_Pods[Pods<br/>v1]
        API_Secrets[Secrets<br/>v1]
        API_PodsExec[Pods/exec<br/>v1]
    end

    subgraph "API Resources - RBAC"
        API_ClusterRoleBindings[ClusterRoleBindings<br/>rbac.authorization.k8s.io]
        API_ClusterRoles[ClusterRoles<br/>rbac.authorization.k8s.io]
        API_RoleBindings[RoleBindings<br/>rbac.authorization.k8s.io]
        API_Roles[Roles<br/>rbac.authorization.k8s.io]
        API_SubjectAccessReviews[SubjectAccessReviews<br/>rbac.authorization.k8s.io]
    end

    subgraph "API Resources - OpenShift"
        API_Routes[Routes<br/>route.openshift.io]
    end

    subgraph "API Resources - Auth"
        API_TokenReviews[TokenReviews<br/>authentication.k8s.io]
        API_Leases[Leases<br/>coordination.k8s.io]
        API_Events[Events<br/>v1]
    end

    %% Service Account to Bindings
    SA_ControllerManager -->|bound via| CRB_Manager
    SA_ControllerManager -->|bound via| CRB_LeaderElection
    SA_ControllerManager -->|bound via| CRB_MetricsAuth

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_MetricsAuth -->|grants| CR_MetricsReader

    %% Manager Role Permissions - feast.dev
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_FeatureStore
    CR_Manager -->|update| API_FeatureStore_Finalizers
    CR_Manager -->|get,patch,update| API_FeatureStore_Status

    %% Manager Role Permissions - Core Resources (Full Control)
    CR_Manager -->|create,delete,get,list,update,watch| API_Deployments
    CR_Manager -->|create,delete,get,list,patch,update,watch| API_CronJobs
    CR_Manager -->|create,delete,get,list,update,watch| API_ConfigMaps
    CR_Manager -->|create,delete,get,list,update,watch| API_PVCs
    CR_Manager -->|create,delete,get,list,update,watch| API_ServiceAccounts
    CR_Manager -->|create,delete,get,list,update,watch| API_Services

    %% Manager Role Permissions - Core Resources (Read-Only)
    CR_Manager -->|get,list,watch| API_Namespaces
    CR_Manager -->|get,list,watch| API_Pods
    CR_Manager -->|get,list,watch| API_Secrets

    %% Manager Role Permissions - Special
    CR_Manager -->|create| API_PodsExec

    %% Manager Role Permissions - RBAC
    CR_Manager -->|create,delete,get,list,update,watch| API_ClusterRoleBindings
    CR_Manager -->|create,delete,get,list,update,watch| API_ClusterRoles
    CR_Manager -->|create,delete,get,list,update,watch| API_RoleBindings
    CR_Manager -->|create,delete,get,list,update,watch| API_Roles
    CR_Manager -->|create,delete,get,list,update,watch| API_SubjectAccessReviews

    %% Manager Role Permissions - OpenShift
    CR_Manager -->|create,delete,get,list,update,watch| API_Routes

    %% Manager Role Permissions - Auth
    CR_Manager -->|create| API_TokenReviews

    %% Leader Election Role Permissions
    CR_LeaderElection -->|get,list,watch,create,update,patch| API_ConfigMaps
    CR_LeaderElection -->|create,patch| API_Events
    CR_LeaderElection -->|get,list,watch,create,update,patch| API_Leases

    %% Metrics Reader Permissions
    CR_MetricsReader -->|get,list,watch| API_Services
    CR_MetricsReader -->|get,list,watch| API_Pods

    %% User-facing Roles
    CR_FeatureStoreEditor -->|create,delete,get,list,patch,update,watch| API_FeatureStore
    CR_FeatureStoreViewer -->|get,list,watch| API_FeatureStore

    %% Styling
    style SA_ControllerManager fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    style SA_Online fill:#81c784,stroke:#333
    style SA_Offline fill:#81c784,stroke:#333
    style SA_Registry fill:#81c784,stroke:#333
    style SA_UI fill:#81c784,stroke:#333

    style CRB_Manager fill:#ff9800,stroke:#333
    style CRB_LeaderElection fill:#ff9800,stroke:#333
    style CRB_MetricsAuth fill:#ff9800,stroke:#333

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_LeaderElection fill:#f5a623,stroke:#333
    style CR_MetricsReader fill:#f5a623,stroke:#333
    style CR_FeatureStoreEditor fill:#e1bee7,stroke:#8e24aa
    style CR_FeatureStoreViewer fill:#e1bee7,stroke:#8e24aa

    style API_FeatureStore fill:#7ed321,stroke:#333,stroke-width:2px
    style API_FeatureStore_Finalizers fill:#7ed321,stroke:#333
    style API_FeatureStore_Status fill:#7ed321,stroke:#333
