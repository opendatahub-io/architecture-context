%% Feast Operator - RBAC Matrix Diagram
%% Generated by: Claude Opus 4.6

graph TD
    subgraph "Service Accounts"
        SA_Op["feast-operator-controller-manager<br/>(Operator SA)"]
        SA_FS["feast-{name}<br/>(FeatureStore SA, per CR)"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager["feast-operator-manager-rolebinding<br/>(Cluster-scoped)"]
        CRB_Metrics["feast-operator-metrics-auth-rolebinding<br/>(Cluster-scoped)"]
        CRB_TokenReview["feast-{name}-cluster-binding<br/>(Cluster-scoped, per CR)"]
    end

    subgraph "Role Bindings"
        RB_Leader["feast-operator-leader-election-rolebinding<br/>(Operator namespace)"]
        RB_FS["feast-{name}<br/>(CR namespace, per CR)"]
        RB_Cron["feast-{name}-cronjob<br/>(CR namespace, per CR)"]
        RB_Registry["feast-configs-registry-reader<br/>(Operator namespace)"]
    end

    subgraph "ClusterRoles"
        CR_Manager["feast-operator-manager-role"]
        CR_Metrics["feast-operator-metrics-auth-role"]
        CR_Token["feast-token-review-cluster-role<br/>(shared)"]
    end

    subgraph "Roles"
        R_Leader["feast-operator-leader-election-role"]
        R_FS["feast-{name}<br/>(per CR)"]
        R_Cron["feast-{name}-cronjob<br/>(per CR)"]
        R_ConfigReader["feast-configs-registry-reader"]
    end

    subgraph "Operator API Resources"
        FeatureStores["feast.dev<br/>featurestores<br/>featurestores/status<br/>featurestores/finalizers"]
        Deployments["apps<br/>deployments"]
        CoreRW["core<br/>services, configmaps,<br/>persistentvolumeclaims,<br/>serviceaccounts"]
        CoreRO["core<br/>secrets, pods,<br/>namespaces"]
        PodExec["core<br/>pods/exec"]
        RBAC_Res["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
        AuthN["authentication.k8s.io<br/>tokenreviews"]
        Routes["route.openshift.io<br/>routes"]
        CronJobs["batch<br/>cronjobs"]
    end

    subgraph "Dynamic Auth Resources (per CR)"
        TokenReview["authentication.k8s.io<br/>tokenreviews"]
        SAR["rbac.authorization.k8s.io<br/>subjectaccessreviews"]
        NSGet["core<br/>namespaces"]
        RBACRead["rbac.authorization.k8s.io<br/>roles, rolebindings,<br/>clusterroles, clusterrolebindings"]
    end

    subgraph "CronJob Resources (per CR)"
        CronDeploy["apps<br/>deployments (named)"]
        CronPods["core<br/>pods"]
        CronExec["core<br/>pods/exec"]
    end

    %% Operator SA bindings
    SA_Op -->|"bound via"| CRB_Manager
    SA_Op -->|"bound via"| CRB_Metrics
    SA_Op -->|"bound via"| RB_Leader

    CRB_Manager -->|"grants"| CR_Manager
    CRB_Metrics -->|"grants"| CR_Metrics
    RB_Leader -->|"grants"| R_Leader

    %% Operator role permissions
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| FeatureStores
    CR_Manager -->|"get,list,create,<br/>update,watch,delete"| Deployments
    CR_Manager -->|"get,list,create,<br/>update,watch,delete"| CoreRW
    CR_Manager -->|"get,list,watch"| CoreRO
    CR_Manager -->|"create"| PodExec
    CR_Manager -->|"get,list,create,<br/>update,watch,delete"| RBAC_Res
    CR_Manager -->|"create"| AuthN
    CR_Manager -->|"get,list,create,<br/>update,watch,delete"| Routes
    CR_Manager -->|"get,list,watch,<br/>create,update,<br/>patch,delete"| CronJobs

    CR_Metrics -->|"create"| AuthN

    %% FeatureStore SA bindings
    SA_FS -->|"bound via"| CRB_TokenReview
    SA_FS -->|"bound via"| RB_FS
    SA_FS -->|"bound via"| RB_Cron

    CRB_TokenReview -->|"grants"| CR_Token
    RB_FS -->|"grants"| R_FS
    RB_Cron -->|"grants"| R_Cron

    %% Dynamic role permissions
    CR_Token -->|"create"| TokenReview
    CR_Token -->|"create"| SAR
    CR_Token -->|"get,list,watch"| NSGet
    CR_Token -->|"get,list"| RBACRead

    R_FS -->|"get,list,watch"| RBACRead
    R_FS -->|"create"| TokenReview
    R_FS -->|"create"| SAR

    R_Cron -->|"get"| CronDeploy
    R_Cron -->|"list"| CronPods
    R_Cron -->|"create"| CronExec

    %% Registry reader
    RB_Registry -->|"grants"| R_ConfigReader
    R_ConfigReader -.->|"system:authenticated<br/>(Group)"| NSGet

