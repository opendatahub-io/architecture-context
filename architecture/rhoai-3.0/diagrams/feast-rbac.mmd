graph TD
    subgraph "Service Accounts"
        SA_Controller[controller-manager<br/>Namespace: system]
        SA_Feast["{name}-feast-sa<br/>Namespace: user"]
    end

    subgraph "ClusterRole Bindings"
        CRB_Manager[manager-rolebinding<br/>ClusterRoleBinding]
        CRB_LeaderElection[leader-election-rolebinding<br/>RoleBinding - system ns]
        CRB_MetricsAuth[metrics-auth-rolebinding<br/>RoleBinding - system ns]
    end

    subgraph "ClusterRoles & Roles"
        CR_Manager[manager-role<br/>ClusterRole]
        CR_LeaderElection[leader-election-role<br/>Role]
        CR_MetricsReader[metrics-reader<br/>ClusterRole]
        CR_FeatureStoreEditor[featurestore-editor-role<br/>ClusterRole]
        CR_FeatureStoreViewer[featurestore-viewer-role<br/>ClusterRole]
    end

    subgraph "Kubernetes API Resources"
        direction TB

        subgraph "Feast CRDs"
            FeatureStore[feast.dev<br/>FeatureStore<br/>featurestores<br/>featurestores/finalizers<br/>featurestores/status]
        end

        subgraph "Core Resources"
            CoreResources[core API group<br/>configmaps<br/>persistentvolumeclaims<br/>serviceaccounts<br/>services<br/>namespaces<br/>pods<br/>secrets<br/>pods/exec]
        end

        subgraph "Apps & Batch"
            AppsResources[apps<br/>deployments<br/><br/>batch<br/>cronjobs]
        end

        subgraph "RBAC"
            RBACResources[rbac.authorization.k8s.io<br/>clusterrolebindings<br/>clusterroles<br/>rolebindings<br/>roles<br/>subjectaccessreviews]
        end

        subgraph "OpenShift"
            RouteResources[route.openshift.io<br/>routes]
        end

        subgraph "Authentication"
            AuthResources[authentication.k8s.io<br/>tokenreviews]
        end

        subgraph "Coordination"
            CoordResources[coordination.k8s.io<br/>leases]
        end
    end

    %% Service Account to Bindings
    SA_Controller -->|bound via| CRB_Manager
    SA_Controller -->|bound via| CRB_LeaderElection
    SA_Controller -->|bound via| CRB_MetricsAuth

    %% Bindings to Roles
    CRB_Manager -->|grants| CR_Manager
    CRB_LeaderElection -->|grants| CR_LeaderElection
    CRB_MetricsAuth -->|grants| CR_MetricsReader

    %% ClusterRole Permissions - manager-role
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| AppsResources
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| CoreResources
    CR_Manager -->|"create, delete, get, list,<br/>patch, update, watch"| FeatureStore
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| RBACResources
    CR_Manager -->|"create, delete, get,<br/>list, update, watch"| RouteResources
    CR_Manager -->|create| AuthResources

    %% ClusterRole Permissions - leader-election-role
    CR_LeaderElection -->|"get, list, watch,<br/>create, update, patch"| CoordResources

    %% ClusterRole Permissions - metrics-reader
    CR_MetricsReader -->|"get, list, watch"| CoreResources

    %% User RBAC roles (informational)
    CR_FeatureStoreEditor -->|"create, delete, get, list,<br/>patch, update, watch"| FeatureStore
    CR_FeatureStoreViewer -->|"get, list, watch"| FeatureStore

    %% Authentication Flow (Feature Servers)
    subgraph "Feature Server Authentication"
        FeatureServerAuth["Feature Servers<br/>(online, offline, registry, ui)"]
        K8sRBACAuth[Kubernetes RBAC<br/>SubjectAccessReview]
        OIDCAuth[OIDC Provider<br/>JWT Validation]
    end

    SA_Feast -.->|"used by"| FeatureServerAuth
    FeatureServerAuth -.->|"when auth=kubernetes"| K8sRBACAuth
    FeatureServerAuth -.->|"when auth=oidc"| OIDCAuth
    K8sRBACAuth -.->|"checks feast.dev<br/>permissions"| FeatureStore

    %% Styling
    classDef serviceAccount fill:#4a90e2,stroke:#333,stroke-width:2px,color:#fff
    classDef binding fill:#f5a623,stroke:#333,stroke-width:2px,color:#fff
    classDef role fill:#7ed321,stroke:#333,stroke-width:2px,color:#fff
    classDef resource fill:#bd10e0,stroke:#333,stroke-width:2px,color:#fff
    classDef auth fill:#50e3c2,stroke:#333,stroke-width:2px

    class SA_Controller,SA_Feast serviceAccount
    class CRB_Manager,CRB_LeaderElection,CRB_MetricsAuth binding
    class CR_Manager,CR_LeaderElection,CR_MetricsReader,CR_FeatureStoreEditor,CR_FeatureStoreViewer role
    class FeatureStore,CoreResources,AppsResources,RBACResources,RouteResources,AuthResources,CoordResources resource
    class FeatureServerAuth,K8sRBACAuth,OIDCAuth auth
