%% Data Science Pipelines - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        User["User / SDK / Browser"]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Route["OpenShift Route<br/>443/TCP -> 80/TCP (UI)<br/>TLS Edge Termination"]
        IstioGW["Istio Gateway<br/>443/TCP<br/>TLS SIMPLE<br/>(multi-user mode)"]
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS ISTIO_MUTUAL - multi-user mode)"]
        direction TB

        subgraph NS_KF["Namespace: kubeflow / {dspa-namespace}"]
            direction TB

            APIServer["ml-pipeline API Server<br/>SA: ml-pipeline<br/>REST: 8888/TCP | gRPC: 8887/TCP<br/>Webhook: 8443/TCP HTTPS<br/>Auth: kubeflow-userid + SAR"]

            PLUI["ml-pipeline-ui<br/>SA: ml-pipeline-ui<br/>80/TCP -> 3000/TCP<br/>Auth: kubeflow-userid"]

            PA["persistence-agent<br/>SA: ml-pipeline-persistenceagent<br/>Watches Workflow CRs"]

            SWC["scheduledworkflow<br/>SA: ml-pipeline-scheduledworkflow<br/>Watches ScheduledWorkflow CRs"]

            CacheSrv["cache-server<br/>SA: kubeflow-pipelines-cache<br/>443/TCP -> 8443/TCP HTTPS<br/>Mutating Admission Webhook"]

            subgraph MetaSvc["Metadata Services"]
                MetaEnvoy["metadata-envoy<br/>9090/TCP gRPC-Web"]
                MetaGRPC["metadata-grpc-server<br/>8080/TCP gRPC<br/>plaintext"]
                MetaWriter["metadata-writer<br/>SA: kubeflow-pipelines-metadata-writer"]
            end

            VizSrv["visualization-server<br/>8888/TCP HTTP<br/>plaintext"]

            subgraph Runtime["V2 Runtime (Argo Workflow Pods)"]
                KFPDriver["kfp-driver<br/>(init container)"]
                KFPLauncher["kfp-launcher<br/>(sidecar)<br/>SA: pipeline-runner"]
            end
        end
    end

    subgraph ClusterSvc["CLUSTER SERVICES"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS<br/>ServiceAccount tokens"]
        ArgoCtrl["Argo Workflows<br/>Workflow execution engine"]
    end

    subgraph DataSvc["DATA SERVICES (Cluster-Internal)"]
        MySQL["MySQL<br/>3306/TCP<br/>plaintext<br/>Username/Password"]
        PostgreSQL["PostgreSQL<br/>5432/TCP<br/>plaintext<br/>Username/Password"]
        MinIO["MinIO / S3 Storage<br/>9000/TCP HTTP<br/>or 443/TCP HTTPS<br/>AccessKey/SecretKey"]
    end

    %% External flows
    User -->|"HTTPS/443<br/>TLS Edge<br/>kubeflow-userid"| Route
    User -->|"HTTPS/443<br/>TLS SIMPLE<br/>kubeflow-userid"| IstioGW

    %% Ingress to services
    Route -->|"HTTP/80<br/>mTLS (mesh)"| PLUI
    IstioGW -->|"HTTP/80<br/>mTLS ISTIO_MUTUAL"| PLUI
    Route -->|"HTTP/8888<br/>mTLS (mesh)"| APIServer

    %% Internal service flows
    PLUI -->|"HTTP/8888<br/>kubeflow-userid"| APIServer
    PLUI -->|"gRPC-Web/9090<br/>plaintext"| MetaEnvoy
    PLUI -->|"HTTP/9000<br/>AccessKey"| MinIO

    PA -->|"gRPC/8887<br/>SA token"| APIServer
    SWC -->|"gRPC/8887<br/>SA token"| APIServer

    MetaEnvoy -->|"gRPC/8080<br/>plaintext"| MetaGRPC
    MetaWriter -->|"gRPC/8080<br/>plaintext"| MetaGRPC

    KFPDriver -->|"gRPC/8887<br/>SA token"| APIServer
    KFPDriver -->|"HTTP/9000<br/>AccessKey"| MinIO

    %% Cluster service flows
    APIServer -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    SWC -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    PA -->|"HTTPS/443<br/>TLS<br/>SA token"| K8sAPI
    K8sAPI -->|"HTTPS/8443<br/>TLS<br/>mTLS"| CacheSrv

    %% Data service flows
    APIServer -->|"MySQL/3306<br/>plaintext<br/>Username/Pwd"| MySQL
    CacheSrv -->|"MySQL/3306<br/>plaintext<br/>Username/Pwd"| MySQL
    APIServer -->|"HTTP/9000<br/>AccessKey"| MinIO

