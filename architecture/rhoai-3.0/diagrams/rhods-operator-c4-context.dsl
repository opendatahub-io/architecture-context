// RHODS Operator - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6
// Source: architecture/rhoai-3.0/rhods-operator.md

workspace {
    model {
        admin = person "Platform Admin" "Configures and manages the OpenShift AI platform via DSC/DSCI CRs"
        datascientist = person "Data Scientist" "Uses AI/ML platform services (Dashboard, Notebooks, Model Serving)"

        rhodsOperator = softwareSystem "RHODS Operator" "Central lifecycle manager for Red Hat OpenShift AI platform - deploys and manages all AI/ML components" {
            dscController = container "DataScienceCluster Controller" "Reconciles DSC CRs; creates/manages component sub-CRDs" "Go (controller-runtime)"
            dsciController = container "DSCInitialization Controller" "Reconciles DSCI CRs; creates namespaces, auth, monitoring, network policies" "Go (controller-runtime)"
            gatewayController = container "Gateway Controller" "Deploys Gateway API infrastructure, kube-auth-proxy, EnvoyFilter, DestinationRule" "Go (controller-runtime)"
            authController = container "Auth Controller" "Manages RBAC for admin/allowed groups" "Go (controller-runtime)"
            monitoringController = container "Monitoring Controller" "Deploys MonitoringStack, Thanos, Tempo, OTEL" "Go (controller-runtime)"
            componentControllers = container "Component Controllers" "12 controllers deploying AI/ML components via kustomize manifests" "Go (controller-runtime)"
            webhookServer = container "Webhook Server" "Validates/mutates DSC, DSCI, HardwareProfile, and component resources" "Go Admission Webhook"
        }

        // Deployed Components (Internal ODH)
        dashboard = softwareSystem "ODH Dashboard" "Web UI for OpenShift AI platform" "Internal RHOAI"
        workbenches = softwareSystem "Workbenches" "Jupyter notebook controller and environments" "Internal RHOAI"
        kserve = softwareSystem "KServe" "Model serving infrastructure" "Internal RHOAI"
        dsp = softwareSystem "Data Science Pipelines" "ML pipeline orchestration" "Internal RHOAI"
        kuberay = softwareSystem "KubeRay" "Ray distributed computing operator" "Internal RHOAI"
        kueue = softwareSystem "Kueue" "Job queueing and scheduling" "Internal RHOAI"
        trustyai = softwareSystem "TrustyAI" "AI explainability service" "Internal RHOAI"
        modelRegistry = softwareSystem "Model Registry" "ML model metadata registry" "Internal RHOAI"
        modelController = softwareSystem "ODH Model Controller" "Model serving management" "Internal RHOAI"
        trainingOperator = softwareSystem "Training Operator" "Kubeflow training jobs" "Internal RHOAI"
        feastOperator = softwareSystem "Feast Operator" "Feature store operator" "Internal RHOAI"
        llamastack = softwareSystem "LlamaStack Operator" "LlamaStack AI operator" "Internal RHOAI"

        // External Dependencies
        k8sAPI = softwareSystem "Kubernetes API Server" "Cluster API for resource management" "External"
        ocpOAuth = softwareSystem "OpenShift OAuth Server" "User authentication via OAuth2" "External"
        ocpIngress = softwareSystem "OpenShift Gateway Controller" "Provisions Envoy pods for Gateway API" "External"
        certManager = softwareSystem "cert-manager" "Certificate lifecycle management (optional)" "External"
        prometheus = softwareSystem "Prometheus / Thanos" "Metrics collection and querying" "External"
        tempo = softwareSystem "Tempo" "Distributed tracing backend" "External"

        // Gateway Infrastructure
        kubeAuthProxy = softwareSystem "kube-auth-proxy" "OAuth2 proxy for Gateway API authentication" "Internal RHOAI"
        gatewayEnvoy = softwareSystem "data-science-gateway" "Envoy-based Gateway API ingress (443/TCP HTTPS)" "Internal RHOAI"

        // Relationships - Admin
        admin -> rhodsOperator "Creates DSCInitialization and DataScienceCluster CRs via kubectl"
        datascientist -> gatewayEnvoy "Accesses AI/ML services via HTTPS/443"

        // Relationships - Operator deploys components
        rhodsOperator -> dashboard "Deploys via kustomize manifests"
        rhodsOperator -> workbenches "Deploys via kustomize manifests"
        rhodsOperator -> kserve "Deploys via kustomize manifests"
        rhodsOperator -> dsp "Deploys via kustomize manifests"
        rhodsOperator -> kuberay "Deploys via kustomize manifests"
        rhodsOperator -> kueue "Deploys via kustomize manifests"
        rhodsOperator -> trustyai "Deploys via kustomize manifests"
        rhodsOperator -> modelRegistry "Deploys via kustomize manifests"
        rhodsOperator -> modelController "Deploys via kustomize manifests"
        rhodsOperator -> trainingOperator "Deploys via kustomize manifests"
        rhodsOperator -> feastOperator "Deploys via kustomize manifests"
        rhodsOperator -> llamastack "Deploys via kustomize manifests"

        // Relationships - Gateway/Auth
        rhodsOperator -> gatewayEnvoy "Creates Gateway, EnvoyFilter, DestinationRule"
        rhodsOperator -> kubeAuthProxy "Deploys OAuth2 proxy (Deployment, Service, Secret)"
        gatewayEnvoy -> kubeAuthProxy "ext_authz check" "HTTPS/8443"
        kubeAuthProxy -> ocpOAuth "OAuth2 validation" "HTTPS/443"

        // Relationships - External
        rhodsOperator -> k8sAPI "Controller operations, CRD management" "HTTPS/6443"
        rhodsOperator -> ocpIngress "Depends on for Envoy pod provisioning"
        rhodsOperator -> certManager "Optional certificate issuance" "HTTPS/6443"

        // Relationships - Monitoring
        rhodsOperator -> prometheus "Deploys MonitoringStack, ServiceMonitors" "HTTP/9090"
        rhodsOperator -> tempo "Deploys Tempo, OTEL Collector" "gRPC/4317"

        // Container-level relationships
        dsciController -> gatewayController "Creates GatewayConfig CR"
        dsciController -> authController "Creates Auth CR"
        dsciController -> monitoringController "Creates Monitoring CR"
        dscController -> componentControllers "Creates component sub-CRDs"
    }

    views {
        systemContext rhodsOperator "SystemContext" {
            include *
            autoLayout
        }

        container rhodsOperator "Containers" {
            include *
            autoLayout
        }

        styles {
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Software System" {
                background #4a90e2
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
