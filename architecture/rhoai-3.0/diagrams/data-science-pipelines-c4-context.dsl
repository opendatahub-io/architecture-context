/*
 * Data Science Pipelines - C4 Context Diagram (Structurizr DSL)
 * Generated by: Claude Opus 4.6
 */

workspace {
    model {
        dataScientist = person "Data Scientist" "Creates, runs, and monitors ML pipelines"
        mlEngineer = person "ML Engineer" "Builds reusable pipeline components and manages recurring runs"

        dsp = softwareSystem "Data Science Pipelines" "Kubeflow Pipelines - End-to-end ML workflow orchestration platform on Kubernetes" {
            apiServer = container "ml-pipeline API Server" "Central API server for pipeline management; includes webhook server for PipelineVersion validation" "Go Service" "REST: 8888/TCP, gRPC: 8887/TCP, Webhook: 8443/TCP"
            frontend = container "ml-pipeline-ui" "Web UI for pipeline visualization, run management, artifact viewing" "TypeScript/React/Node.js" "3000/TCP"
            persistenceAgent = container "ml-pipeline-persistenceagent" "Watches Argo Workflow CRs, reports status back to API server via gRPC" "Go Agent"
            scheduledWorkflow = container "ml-pipeline-scheduledworkflow" "Controller for ScheduledWorkflow CRD; creates Workflow CRs on schedule" "Go Controller"
            cacheServer = container "cache-server" "Mutating admission webhook for caching pipeline step execution results" "Go Webhook Server" "8443/TCP"
            viewerCRD = container "ml-pipeline-viewer-crd" "Controller for Viewer CRD; creates TensorBoard viewer instances" "Go Controller"
            metadataGRPC = container "metadata-grpc-server" "ML Metadata (MLMD) gRPC service for artifact and execution lineage" "Go/gRPC Service" "8080/TCP"
            metadataEnvoy = container "metadata-envoy" "Envoy sidecar proxy providing gRPC-Web transcoding for metadata service" "Envoy Proxy" "9090/TCP"
            metadataWriter = container "metadata-writer" "Watches Argo Workflows and writes execution metadata to MLMD" "Python Agent"
            kfpDriver = container "kfp-driver" "V2 pipeline step driver; resolves inputs, handles caching, manages artifact I/O" "Go Binary (init container)"
            kfpLauncher = container "kfp-launcher" "V2 pipeline step launcher; launches user containers and reports outputs" "Go Binary (sidecar)"
            vizServer = container "visualization-server" "Generates visualizations from pipeline data" "Python Service" "8888/TCP"
        }

        argoWorkflows = softwareSystem "Argo Workflows" "Pipeline step execution engine; manages Workflow CRs" "External"
        mysql = softwareSystem "MySQL / PostgreSQL" "Relational database for pipeline/run/experiment metadata" "External"
        minio = softwareSystem "MinIO / S3 Storage" "Object storage for pipeline artifacts, logs, and pipeline specs" "External"
        istio = softwareSystem "Istio Service Mesh" "Service mesh for multi-user mTLS and authorization" "External"
        certManager = softwareSystem "cert-manager" "TLS certificate management for webhooks" "External"
        k8sAPI = softwareSystem "Kubernetes API" "CRD management, pod operations, admission webhooks" "External"

        dspo = softwareSystem "Data Science Pipelines Operator (DSPO)" "Manages deployment and configuration of all DSP services" "Internal RHOAI"
        dashboard = softwareSystem "OpenShift AI Dashboard" "Links to pipeline UI from dashboard" "Internal RHOAI"

        /* User relationships */
        dataScientist -> dsp "Creates and runs ML pipelines" "REST API / Web UI"
        mlEngineer -> dsp "Builds pipeline components and configures recurring runs" "REST API / SDK / Web UI"

        /* External dependency relationships */
        dsp -> argoWorkflows "Creates Workflow CRs for pipeline execution" "HTTPS/443"
        dsp -> mysql "Stores pipeline/run/experiment metadata" "MySQL/3306 or PostgreSQL/5432"
        dsp -> minio "Stores/retrieves pipeline artifacts and specs" "HTTP/9000 or HTTPS/443"
        dsp -> istio "Uses for multi-user mTLS and authorization policies" "Sidecar injection"
        dsp -> certManager "Manages webhook TLS certificates" "CRD"
        dsp -> k8sAPI "Manages CRDs, pods, admission webhooks" "HTTPS/443"

        /* Internal RHOAI relationships */
        dspo -> dsp "Deploys and manages lifecycle of all DSP services"
        dashboard -> dsp "Links to pipeline UI" "HTTP"

        /* Container relationships */
        dataScientist -> frontend "Views pipelines and runs" "HTTP/3000"
        dataScientist -> apiServer "Creates pipelines and runs" "REST/8888, gRPC/8887"

        frontend -> apiServer "Proxies API requests" "HTTP/8888"
        frontend -> metadataEnvoy "Queries execution metadata" "gRPC-Web/9090"
        frontend -> minio "Retrieves artifacts for viewing" "HTTP/9000"

        apiServer -> mysql "Reads/writes pipeline metadata" "MySQL/3306"
        apiServer -> minio "Stores/retrieves artifacts" "HTTP/9000"
        apiServer -> k8sAPI "Creates Workflow, ScheduledWorkflow, Pipeline CRs" "HTTPS/443"

        persistenceAgent -> apiServer "Reports workflow status" "gRPC/8887"
        scheduledWorkflow -> apiServer "Creates runs for scheduled workflows" "gRPC/8887"
        scheduledWorkflow -> k8sAPI "Watches ScheduledWorkflow CRs, creates Workflow CRs" "HTTPS/443"

        cacheServer -> mysql "Checks/stores cache keys" "MySQL/3306"

        metadataEnvoy -> metadataGRPC "Proxies gRPC requests" "gRPC/8080"
        metadataWriter -> metadataGRPC "Writes execution metadata" "gRPC/8080"

        kfpDriver -> apiServer "Resolves inputs" "gRPC/8887"
        kfpDriver -> minio "Fetches/stores artifacts" "HTTP/9000"
        kfpLauncher -> apiServer "Reports outputs" "gRPC/8887"
    }

    views {
        systemContext dsp "SystemContext" {
            include *
            autoLayout
        }

        container dsp "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                shape Person
                background #08427b
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
