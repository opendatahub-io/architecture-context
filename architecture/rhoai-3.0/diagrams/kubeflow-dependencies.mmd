graph LR
    NotebookController[Notebook Controller<br/>Kubeflow Component]

    %% External Dependencies
    NotebookController -->|"orchestration<br/>CRD management"| K8s[Kubernetes v1.22.0+]
    NotebookController -->|"framework<br/>reconciliation"| ControllerRuntime[controller-runtime v0.21.0]
    NotebookController -->|"ingress routing<br/>VirtualService"| Istio[Istio v1.x<br/>Optional: USE_ISTIO=true]
    NotebookController -->|"metrics collection"| Prometheus[Prometheus v2.x<br/>Optional]
    NotebookController -->|"metrics auth proxy"| KubeRBACProxy[kube-rbac-proxy<br/>Optional]

    %% Internal ODH Dependencies
    NotebookController -->|"CRD extension<br/>annotations"| ODHNotebookController[odh-notebook-controller]
    NotebookController <-->|"creates Notebook CRs"| JupyterWebApp[jupyter-web-app]
    NotebookController <-->|"status monitoring"| ODHDashboard[odh-dashboard]
    NotebookController -.->|"references images"| NotebookImages[notebook-images]

    %% Integration Points
    DataSciencePipelines[Data Science Pipelines] -.->|"auto deploy notebooks"| NotebookController
    ServiceMesh[Service Mesh] -.->|"mTLS sidecars"| NotebookController

    %% Managed Resources
    NotebookController -->|"manages"| NotebookCR[Notebook CR<br/>kubeflow.org/v1]
    NotebookController -->|"creates"| StatefulSet[StatefulSet<br/>notebook instances]
    NotebookController -->|"creates"| Service[Service<br/>ClusterIP 80→8888]
    NotebookController -->|"creates<br/>(if USE_ISTIO=true)"| VirtualService[VirtualService<br/>Istio ingress]

    %% Styling
    style NotebookController fill:#4a90e2,stroke:#333,stroke-width:4px,color:#fff

    %% External Dependencies (gray)
    style K8s fill:#999,stroke:#333,color:#fff
    style ControllerRuntime fill:#999,stroke:#333,color:#fff
    style Istio fill:#999,stroke:#333,color:#fff
    style Prometheus fill:#999,stroke:#333,color:#fff
    style KubeRBACProxy fill:#999,stroke:#333,color:#fff

    %% Internal ODH Dependencies (green)
    style ODHNotebookController fill:#7ed321,stroke:#333,color:#000
    style JupyterWebApp fill:#7ed321,stroke:#333,color:#000
    style ODHDashboard fill:#7ed321,stroke:#333,color:#000
    style NotebookImages fill:#7ed321,stroke:#333,color:#000
    style DataSciencePipelines fill:#7ed321,stroke:#333,color:#000
    style ServiceMesh fill:#7ed321,stroke:#333,color:#000

    %% Managed Resources (orange)
    style NotebookCR fill:#f5a623,stroke:#333,color:#000
    style StatefulSet fill:#f5a623,stroke:#333,color:#000
    style Service fill:#f5a623,stroke:#333,color:#000
    style VirtualService fill:#f5a623,stroke:#333,color:#000
