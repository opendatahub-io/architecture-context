graph TD
    subgraph "DSPO Operator RBAC (Cluster-scoped)"
        SA_Controller["ServiceAccount:<br/>controller-manager<br/>Namespace: redhat-ods-applications"]
        CRB_Manager["ClusterRoleBinding:<br/>manager-rolebinding"]
        CR_Manager["ClusterRole:<br/>manager-role"]

        SA_Controller -->|bound via| CRB_Manager
        CRB_Manager -->|grants| CR_Manager
    end

    subgraph "DSPO ClusterRole Permissions"
        DSPA_Resources["datasciencepipelinesapplications<br/>opendatahub.io<br/>all verbs"]
        Argo_Resources["workflows, workflowartifactgctasks<br/>workflowtaskresults<br/>argoproj.io<br/>all verbs"]
        KFP_Resources["pipelines, pipelineversions<br/>pipelines.kubeflow.org<br/>all verbs"]
        Core_Resources["pods, services, secrets<br/>configmaps, serviceaccounts, pvc<br/>core<br/>all verbs"]
        Apps_Resources["deployments, replicasets<br/>apps<br/>all verbs"]
        RBAC_Resources["roles, rolebindings<br/>clusterroles, clusterrolebindings<br/>rbac.authorization.k8s.io<br/>all verbs"]
        Route_Resources["routes<br/>route.openshift.io<br/>all verbs"]
        Network_Resources["networkpolicies<br/>networking.k8s.io<br/>all verbs"]
        Batch_Resources["jobs<br/>batch<br/>all verbs"]
        KServe_Resources["inferenceservices<br/>serving.kserve.io<br/>create, delete, get, list, patch"]
        Ray_Resources["rayclusters, rayjobs, rayservices<br/>ray.io<br/>create, delete, get, list, patch"]
        Webhook_Resources["validatingwebhookconfigurations<br/>mutatingwebhookconfigurations<br/>admissionregistration.k8s.io<br/>all verbs"]

        CR_Manager -->|manages| DSPA_Resources
        CR_Manager -->|manages| Argo_Resources
        CR_Manager -->|manages| KFP_Resources
        CR_Manager -->|manages| Core_Resources
        CR_Manager -->|manages| Apps_Resources
        CR_Manager -->|manages| RBAC_Resources
        CR_Manager -->|manages| Route_Resources
        CR_Manager -->|manages| Network_Resources
        CR_Manager -->|manages| Batch_Resources
        CR_Manager -->|integrates| KServe_Resources
        CR_Manager -->|integrates| Ray_Resources
        CR_Manager -->|manages| Webhook_Resources
    end

    subgraph "DSPA Instance RBAC (Namespace-scoped)"
        direction TB

        subgraph "API Server Permissions"
            SA_API["ServiceAccount:<br/>ds-pipeline-{name}<br/>Namespace: {dspa-namespace}"]
            RB_API["RoleBinding:<br/>ds-pipeline-{name}-binding"]
            R_API["Role:<br/>ds-pipeline-{name}"]

            SA_API -->|bound via| RB_API
            RB_API -->|grants| R_API
        end

        subgraph "Workflow Controller Permissions"
            SA_Argo["ServiceAccount:<br/>ds-pipeline-argo-{name}<br/>Namespace: {dspa-namespace}"]
            RB_Argo["RoleBinding:<br/>ds-pipeline-argo-binding"]
            CR_Argo["ClusterRole:<br/>ds-pipeline-argo-cluster-role"]

            SA_Argo -->|bound via| RB_Argo
            RB_Argo -->|grants| CR_Argo
        end

        subgraph "Pipeline Runner Permissions"
            SA_Runner["ServiceAccount:<br/>pipeline-runner-{name}<br/>Namespace: {dspa-namespace}"]
            RB_Runner["RoleBinding:<br/>pipeline-runner-{name}-binding"]
            R_Runner["Role:<br/>pipeline-runner-{name}"]

            SA_Runner -->|bound via| RB_Runner
            RB_Runner -->|grants| R_Runner
        end
    end

    subgraph "API Server Role Permissions"
        Argo_Workflows["workflows, workflowtemplates<br/>argoproj.io<br/>create, get, list, watch,<br/>update, patch, delete"]

        R_API -->|manages workflows| Argo_Workflows
    end

    subgraph "Pipeline Runner Role Permissions"
        Runner_Pods["pods, pods/log<br/>core<br/>create, get, list, delete"]
        Runner_Resources["configmaps, secrets<br/>pvc, services<br/>core<br/>create, get, list, delete"]

        R_Runner -->|executes tasks| Runner_Pods
        R_Runner -->|manages resources| Runner_Resources
    end

    subgraph "Argo Aggregate Roles (RBAC Delegation)"
        AR_Admin["ClusterRole:<br/>argo-aggregate-to-admin<br/>aggregated to admin"]
        AR_Edit["ClusterRole:<br/>argo-aggregate-to-edit<br/>aggregated to edit"]
        AR_View["ClusterRole:<br/>argo-aggregate-to-view<br/>aggregated to view"]

        AR_Admin -->|all verbs| Argo_All["workflows, workflowtemplates<br/>cronworkflows<br/>clusterworkflowtemplates"]
        AR_Edit -->|create, update, delete| Argo_Namespaced["workflows, workflowtemplates<br/>cronworkflows"]
        AR_View -->|get, list, watch| Argo_Readonly["workflows, workflowtemplates<br/>cronworkflows<br/>clusterworkflowtemplates"]
    end

    subgraph "Leader Election RBAC"
        SA_Controller -->|leader election| LeaderElection["ConfigMap/Lease<br/>coordination.k8s.io<br/>Namespace: redhat-ods-applications"]
        RB_LeaderElection["RoleBinding:<br/>leader-election-rolebinding"]
        R_LeaderElection["Role:<br/>leader-election-role"]

        SA_Controller -->|bound via| RB_LeaderElection
        RB_LeaderElection -->|grants| R_LeaderElection
        R_LeaderElection -->|manages| LeaderElection
    end

    %% Styling
    style SA_Controller fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_API fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Argo fill:#4a90e2,stroke:#333,stroke-width:2px
    style SA_Runner fill:#4a90e2,stroke:#333,stroke-width:2px

    style CR_Manager fill:#f5a623,stroke:#333,stroke-width:2px
    style R_API fill:#f5a623,stroke:#333,stroke-width:2px
    style CR_Argo fill:#f5a623,stroke:#333,stroke-width:2px
    style R_Runner fill:#f5a623,stroke:#333,stroke-width:2px
    style AR_Admin fill:#f5a623,stroke:#333,stroke-width:1px
    style AR_Edit fill:#f5a623,stroke:#333,stroke-width:1px
    style AR_View fill:#f5a623,stroke:#333,stroke-width:1px
    style R_LeaderElection fill:#f5a623,stroke:#333,stroke-width:1px

    style DSPA_Resources fill:#7ed321,stroke:#333
    style Argo_Resources fill:#7ed321,stroke:#333
    style KFP_Resources fill:#7ed321,stroke:#333
