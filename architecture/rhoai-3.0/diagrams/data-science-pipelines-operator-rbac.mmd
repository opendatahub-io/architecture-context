    style Apps_Resources fill:#7ed321,stroke:#333
    style RBAC_Resources fill:#7ed321,stroke:#333
    style Route_Resources fill:#7ed321,stroke:#333
    style Network_Resources fill:#7ed321,stroke:#333
    style Batch_Resources fill:#7ed321,stroke:#333
    style KServe_Resources fill:#7ed321,stroke:#333
    style Ray_Resources fill:#7ed321,stroke:#333
    style Webhook_Resources fill:#7ed321,stroke:#333
    style Argo_Workflows fill:#7ed321,stroke:#333
    style Runner_Pods fill:#7ed321,stroke:#333
    style Runner_Resources fill:#7ed321,stroke:#333
    style Argo_All fill:#7ed321,stroke:#333
