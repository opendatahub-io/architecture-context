graph TB
    subgraph "Operator Service Account"
        SA_Operator["controller-manager<br/>Namespace: redhat-ods-applications"]
    end

    subgraph "Operator RBAC"
        CRB_Manager["ClusterRoleBinding:<br/>manager-rolebinding"]
        CR_Manager["ClusterRole:<br/>manager-role"]
        RB_Leader["RoleBinding:<br/>leader-election-rolebinding"]
        R_Leader["Role:<br/>leader-election-role"]
    end

    subgraph "DSPA Instance Service Accounts"
        SA_Pipeline("ds-pipeline-{name}<br/>Namespace: {dspa-namespace}")
        SA_Argo("ds-pipeline-argo-{name}<br/>Namespace: {dspa-namespace}")
        SA_Runner("pipeline-runner-{name}<br/>Namespace: {dspa-namespace}")
    end

    subgraph "DSPA Instance RBAC"
        RB_Pipeline["RoleBinding:<br/>ds-pipeline-{name}-binding"]
        R_Pipeline["Role:<br/>ds-pipeline-{name}"]
        RB_Argo["RoleBinding:<br/>ds-pipeline-argo-binding"]
        CR_Argo["ClusterRole:<br/>ds-pipeline-argo-cluster-role"]
        RB_Runner["RoleBinding:<br/>pipeline-runner-{name}-binding"]
        R_Runner["Role:<br/>pipeline-runner-{name}"]
    end

    subgraph "Aggregate Roles (Argo)"
        CR_ArgoAdmin["ClusterRole:<br/>argo-aggregate-to-admin<br/>aggregationRule: rbac.admin"]
        CR_ArgoEdit["ClusterRole:<br/>argo-aggregate-to-edit<br/>aggregationRule: rbac.edit"]
        CR_ArgoView["ClusterRole:<br/>argo-aggregate-to-view<br/>aggregationRule: rbac.view"]
    end

    subgraph "API Resources - Operator Managed"
        DSPA_API["datasciencepipelinesapplications<br/>opendatahub.io/v1"]
        Workflow_API["workflows, workflowartifactgctasks<br/>argoproj.io/v1alpha1"]
        Pipeline_API["pipelines, pipelineversions<br/>pipelines.kubeflow.org/v1"]
        Core_API["pods, configmaps, secrets<br/>services, pvc, serviceaccounts<br/>core/v1"]
        Apps_API["deployments, replicasets<br/>apps/v1"]
        RBAC_API["roles, rolebindings<br/>clusterroles, clusterrolebindings<br/>rbac.authorization.k8s.io/v1"]
        Route_API["routes<br/>route.openshift.io/v1"]
        Network_API["networkpolicies<br/>networking.k8s.io/v1"]
        Batch_API["jobs<br/>batch/v1"]
        KServe_API["inferenceservices<br/>serving.kserve.io"]
        Ray_API["rayclusters, rayjobs<br/>ray.io"]
        Webhook_API["validatingwebhookconfigurations<br/>mutatingwebhookconfigurations<br/>admissionregistration.k8s.io/v1"]
    end

    subgraph "API Resources - DSPA Pipeline Access"
        Workflow_DSPA["workflows, workflowtemplates<br/>argoproj.io/v1alpha1"]
    end

    subgraph "API Resources - Pipeline Runner Access"
        Pods_Runner["pods, pods/log<br/>core/v1"]
        Config_Runner["configmaps, secrets, pvc, services<br/>core/v1"]
    end

    subgraph "API Resources - Argo Aggregated Access"
        Argo_Resources["workflows, workflowtemplates<br/>cronworkflows<br/>clusterworkflowtemplates<br/>argoproj.io/v1alpha1"]
    end

    %% Operator Bindings
    SA_Operator -->|bound via| CRB_Manager
    CRB_Manager -->|grants| CR_Manager
    SA_Operator -->|bound via| RB_Leader
    RB_Leader -->|grants| R_Leader

    %% Operator Permissions
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| DSPA_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Workflow_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Pipeline_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Core_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Apps_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| RBAC_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Route_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Network_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Batch_API
    CR_Manager -->|"create, delete, get, list, patch"| KServe_API
    CR_Manager -->|"create, delete, get, list, patch"| Ray_API
    CR_Manager -->|"create, delete, get, list<br/>patch, update, watch"| Webhook_API

    %% DSPA Pipeline Service Account
    SA_Pipeline -->|bound via| RB_Pipeline
    RB_Pipeline -->|grants| R_Pipeline
    R_Pipeline -->|"create, get, list, watch<br/>update, patch, delete"| Workflow_DSPA

    %% DSPA Argo Service Account
    SA_Argo -->|bound via| RB_Argo
    RB_Argo -->|grants| CR_Argo
    CR_Argo -->|argo-specific permissions| Workflow_DSPA

    %% DSPA Pipeline Runner Service Account
    SA_Runner -->|bound via| RB_Runner
    RB_Runner -->|grants| R_Runner
    R_Runner -->|"create, get, list<br/>watch, patch, delete"| Pods_Runner
    R_Runner -->|"create, get, list, delete"| Config_Runner

    %% Aggregate Roles
    CR_ArgoAdmin -->|"create, delete, deletecollection<br/>get, list, patch, update, watch"| Argo_Resources
    CR_ArgoEdit -->|"create, delete, deletecollection<br/>get, list, patch, update, watch"| Argo_Resources
    CR_ArgoView -->|"get, list, watch"| Argo_Resources

