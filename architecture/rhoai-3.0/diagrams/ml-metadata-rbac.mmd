%% ML Metadata (MLMD) - RBAC & Security Visualization
%% Generated by: Claude Opus 4.6
%% Note: MLMD defines no RBAC resources itself (not a K8s operator).
%% This diagram shows the security model managed by the deploying operator.

graph TD
    subgraph "Deploying Operator (DSP Operator)"
        DSPOp["DSP Operator<br/>Manages MLMD deployment"]
    end

    subgraph "MLMD Security Model"
        direction TB

        subgraph "gRPC Server Security (SSLConfig)"
            ServerTLS["Server TLS<br/>server_key + server_cert"]
            ClientVerify["Client Verification<br/>custom_ca + client_verify"]
            BoringSSL["BoringSSL<br/>Crypto Engine"]

            ServerTLS --> BoringSSL
            ClientVerify --> BoringSSL
        end

        subgraph "Container Security"
            NonRoot["Non-root Execution<br/>UID 65534:65534"]
            UBI9["Base: UBI9-minimal<br/>FIPS Compliant"]
        end
    end

    subgraph "Secrets (Provisioned by Operator)"
        DBCreds["Database Credentials<br/>(Opaque)<br/>host, port, user, password"]
        ServerCert["Server TLS Cert/Key<br/>(kubernetes.io/tls)<br/>gRPC endpoint encryption"]
        ClientCert["Client TLS Cert<br/>(kubernetes.io/tls)<br/>mTLS verification"]
        DBSSLCerts["Database SSL Certs<br/>(Opaque)<br/>ca, cert, key"]
    end

    subgraph "Database Authentication"
        MySQLAuth["MySQL Auth<br/>Username/Password<br/>+ Optional SSL<br/>(key, cert, ca, cipher,<br/>verify_server_cert)"]
        PGAuth["PostgreSQL Auth<br/>Username/Password/Passfile<br/>+ Optional SSL<br/>(sslmode: disable/allow/<br/>verify-ca/verify-full)"]
    end

    DSPOp -->|"provisions"| DBCreds
    DSPOp -->|"provisions"| ServerCert
    DSPOp -->|"provisions"| ClientCert
    DSPOp -->|"provisions"| DBSSLCerts

    ServerCert -->|"configures"| ServerTLS
    ClientCert -->|"configures"| ClientVerify
    DBCreds -->|"configures"| MySQLAuth
    DBCreds -->|"configures"| PGAuth
    DBSSLCerts -->|"configures"| MySQLAuth
    DBSSLCerts -->|"configures"| PGAuth

