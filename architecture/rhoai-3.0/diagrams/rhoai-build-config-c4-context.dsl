// C4 Context Diagram - RHOAI Build Config
// Generated by: Claude Opus 4.6

workspace {
    model {
        // People
        developer = person "Developer" "Maintains RHOAI operator bundle and build configuration"
        releaseEngineer = person "Release Engineer" "Manages operator releases to production"

        // Primary System
        rhoaiBuildConfig = softwareSystem "RHOAI-Build-Config" "Central build configuration for RHOAI 3.0 - defines OLM operator bundle, FBC catalog, and 73 shipped container image references" {
            olmBundle = container "OLM Operator Bundle" "Packages CSV, CRDs (20), RBAC manifests for rhods-operator v3.0.0" "Container Image (FROM scratch)"
            fbcFragment419 = container "FBC Fragment v4.19" "File-Based Catalog fragment for OCP v4.19 operator discovery" "Container Image (OPM-based)"
            fbcFragment420 = container "FBC Fragment v4.20" "File-Based Catalog fragment for OCP v4.20 operator discovery" "Container Image (OPM-based)"
            buildConfig = container "Build Configuration" "Registry mirror mappings, supported OCP version parameters" "YAML Configuration"
            bundlePatchSystem = container "Bundle Patch System" "Automates CSV patching with latest image digests and metadata" "YAML Patches + GitHub Actions"
        }

        // External Systems
        github = softwareSystem "GitHub" "Source code hosting for rhoai-3.0 branch" "External"
        konflux = softwareSystem "Konflux CI/CD" "Red Hat CI/CD platform based on Tekton for building and releasing container images" "External"
        enterpriseContract = softwareSystem "Enterprise Contract" "Validates container images against enterprise compliance policies via Cosign" "External"
        olm = softwareSystem "Operator Lifecycle Manager" "Operator installation and lifecycle management on OpenShift" "External"
        quayio = softwareSystem "quay.io" "Staging container image registry for pre-release builds" "External"
        registryRedhat = softwareSystem "registry.redhat.io" "Production container image registry for released images" "External"
        renovate = softwareSystem "Renovate / Dependabot" "Automated dependency management for image digest updates" "External"

        // Internal Systems
        rhodsOperator = softwareSystem "rhods-operator" "Core RHOAI operator (packaged by this bundle)" "Internal RHOAI"
        ocp = softwareSystem "OpenShift Container Platform" "Target platform v4.19/v4.20 for operator installation" "External"
        pnc = softwareSystem "PNC (Product Newcastle)" "TrustyAI Java artifact builds via PIG config" "External"

        // Relationships - People
        developer -> rhoaiBuildConfig "Maintains bundle patches and build configuration"
        developer -> github "Pushes code and merges PRs" "HTTPS/443"
        releaseEngineer -> rhoaiBuildConfig "Triggers release pipeline"

        // Relationships - Build flow
        github -> konflux "Webhook triggers PipelineRuns" "HTTPS/443"
        konflux -> rhoaiBuildConfig "Builds bundle and FBC images" "Tekton PipelineRun"
        rhoaiBuildConfig -> quayio "Pushes built images" "HTTPS/443"
        enterpriseContract -> quayio "Verifies image signatures" "HTTPS/443 Cosign"
        quayio -> registryRedhat "Images mirrored/promoted for release" "HTTPS/443"
        renovate -> github "Creates PRs with updated image digests" "HTTPS/443"

        // Relationships - Deployment flow
        registryRedhat -> olm "Provides bundle and catalog images" "HTTPS/443"
        olm -> ocp "Installs operator on cluster" "Kubernetes API"
        rhoaiBuildConfig -> rhodsOperator "Packages operator for OLM distribution"

        // Relationships - Internal containers
        bundlePatchSystem -> olmBundle "Patches CSV with latest digests"
        olmBundle -> fbcFragment419 "Referenced by catalog"
        olmBundle -> fbcFragment420 "Referenced by catalog"
        buildConfig -> bundlePatchSystem "Provides registry mappings"

        // Optional
        rhoaiBuildConfig -> pnc "TrustyAI Java artifact builds" "PIG Config"
    }

    views {
        systemContext rhoaiBuildConfig "SystemContext" {
            include *
            autoLayout
        }

        container rhoaiBuildConfig "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #4a90e2
                color #ffffff
                shape RoundedBox
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Person" {
                background #08427b
                color #ffffff
                shape Person
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
