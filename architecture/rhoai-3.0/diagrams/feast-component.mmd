graph TB
    subgraph "Feast Operator Component"
        Operator[Feast Operator<br/>Go Controller]
        HealthEndpoint[Health Endpoints<br/>8081/TCP HTTP]
        MetricsEndpoint[Metrics Endpoint<br/>8443/TCP HTTPS]

        Operator -->|exposes| HealthEndpoint
        Operator -->|exposes| MetricsEndpoint
    end

    subgraph "Feast Services (per FeatureStore CR)"
        direction TB

        OnlineStore[Online Store<br/>Python Service<br/>6566 HTTP / 6567 HTTPS]
        OfflineStore[Offline Store<br/>Python Service<br/>8815 HTTP / 8816 HTTPS]
        Registry[Registry Server<br/>Python Service<br/>6570-6573 gRPC/HTTP]
        UI[Feast UI<br/>Python/React<br/>8888 HTTP / 8443 HTTPS]
        CronJob[Materialization CronJob<br/>Kubernetes CronJob]
    end

    User[User/Data Scientist] -->|creates| FeatureStoreCR[FeatureStore CR<br/>feast.dev/v1alpha1]
    FeatureStoreCR -->|watched by| Operator

    Operator -->|creates| OnlineStore
    Operator -->|creates| OfflineStore
    Operator -->|creates| Registry
    Operator -->|creates| UI
    Operator -->|creates| CronJob
    Operator -->|creates| K8sResources[Services, ConfigMaps<br/>Deployments, RBAC<br/>Routes, PVCs]

    subgraph "Storage Backends"
        DB[(Database<br/>Postgres/Snowflake)]
        ObjectStore[(Object Storage<br/>S3/GCS)]
        Cache[(Cache<br/>Redis/Cassandra)]
    end

    OnlineStore -->|features| Cache
    OnlineStore -->|metadata| Registry
    OfflineStore -->|historical data| ObjectStore
    OfflineStore -->|historical data| DB
    OfflineStore -->|metadata| Registry
    Registry -->|registry data| ObjectStore
    Registry -->|registry data| DB

    CronJob -->|materializes| OfflineStore
    CronJob -->|writes to| OnlineStore

    subgraph "External Dependencies"
        K8sAPI[Kubernetes API]
        OIDC[OIDC Provider<br/>OpenShift OAuth]
        CertManager[cert-manager<br/>Optional]
        Prometheus[Prometheus]
    end

    Operator -->|watches/manages| K8sAPI
    MetricsEndpoint -->|scraped by| Prometheus
    OnlineStore -.->|auth| OIDC
    OfflineStore -.->|auth| OIDC
    Registry -.->|auth| OIDC
    UI -.->|auth| OIDC
    K8sResources -.->|TLS certs| CertManager

    subgraph "Internal ODH/RHOAI Dependencies"
        TrustedCA[odh-trusted-ca-bundle<br/>ConfigMap]
        ServiceMesh[Service Mesh<br/>Istio - Optional]
    end

    OnlineStore -.->|custom CA| TrustedCA
    OfflineStore -.->|custom CA| TrustedCA
    Registry -.->|custom CA| TrustedCA
    OnlineStore -.->|mTLS| ServiceMesh
    OfflineStore -.->|mTLS| ServiceMesh
    Registry -.->|mTLS| ServiceMesh

    %% Styling
    style Operator fill:#4a90e2,stroke:#333,stroke-width:3px
    style FeatureStoreCR fill:#f5a623,stroke:#333,stroke-width:2px
    style OnlineStore fill:#7ed321,stroke:#333,stroke-width:2px
    style OfflineStore fill:#7ed321,stroke:#333,stroke-width:2px
    style Registry fill:#7ed321,stroke:#333,stroke-width:2px
    style UI fill:#7ed321,stroke:#333,stroke-width:2px
    style CronJob fill:#7ed321,stroke:#333,stroke-width:2px
    style K8sAPI fill:#999,stroke:#333
    style OIDC fill:#999,stroke:#333
    style CertManager fill:#999,stroke:#333
    style Prometheus fill:#999,stroke:#333
    style TrustedCA fill:#d5e8d4,stroke:#82b366
    style ServiceMesh fill:#d5e8d4,stroke:#82b366
    style DB fill:#e1bee7,stroke:#333
    style ObjectStore fill:#e1bee7,stroke:#333
    style Cache fill:#e1bee7,stroke:#333
