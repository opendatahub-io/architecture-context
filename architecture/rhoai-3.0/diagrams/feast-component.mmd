    Controller -->|"creates Services,<br/>ConfigMaps, PVCs,<br/>RBAC, Routes"| K8sResources["Kubernetes Resources"]

    MLApp["ML Application"] -->|"queries features"| OnlineServer
    MLApp -->|"queries features"| OfflineServer

    CronJob -->|"kubectl exec"| OnlineServer

    Controller -->|"REST API"| K8sAPI["Kubernetes API Server"]
