        OperatorMetrics["Metrics: 8080/TCP HTTP"]
    end

    subgraph UserNS["USER NAMESPACE (Per-CR Resources)"]
        direction TB

        subgraph TASPod["TrustyAI Service Pod"]
            TASRBAC["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>SubjectAccessReview"]
            TASContainer["TrustyAI Service<br/>8080/TCP HTTP<br/>4443/TCP HTTPS"]
        end

        subgraph GORCHPod["Guardrails Orchestrator Pod"]
            GORCHRBAC["kube-rbac-proxy<br/>8432/TCP HTTPS<br/>8490/TCP HTTPS<br/>SubjectAccessReview"]
            OrchContainer["Orchestrator<br/>8032/TCP HTTPS<br/>8034/TCP HTTP (health)"]
            DetectorContainer["Built-in Detector<br/>8080/TCP HTTP<br/>(optional)"]
            GatewayContainer["Sidecar Gateway<br/>8090/TCP HTTP<br/>(optional)"]
        end

        subgraph LMESPod["LMEvalJob Pod"]
            EvalContainer["Evaluation Container<br/>lm-evaluation-harness"]
            DriverSidecar["Driver Sidecar<br/>lifecycle management"]
        end
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        InfSvc["KServe InferenceService<br/>Various ports<br/>HTTP/HTTPS<br/>TLS/mTLS"]
        S3["S3 Storage<br/>443/TCP HTTPS<br/>AWS IAM"]
        DB["Database<br/>Configurable port<br/>JDBC TLS (optional)<br/>Username/Password"]
        K8sAPI["Kubernetes API<br/>443/TCP HTTPS<br/>TLS 1.2+"]
    end

    subgraph Monitoring["MONITORING"]
        Prometheus["Prometheus<br/>(ServiceMonitor)"]
    end

    %% External flows
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| TASRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| GORCHRoute
    Client -->|"HTTPS/443<br/>TLS"| GORCHHealthRoute
    Client -->|"HTTPS/443<br/>TLS<br/>Bearer Token"| GORCHGatewayRoute

    %% Route to Pod flows
    TASRoute -->|"HTTPS/8443<br/>TLS (service-serving cert)<br/>reencrypt"| TASRBAC
    GORCHRoute -->|"HTTPS/8432<br/>TLS<br/>reencrypt"| GORCHRBAC
    GORCHHealthRoute -->|"HTTP/8034<br/>edge termination"| OrchContainer
    GORCHGatewayRoute -->|"HTTPS/8490<br/>TLS"| GORCHRBAC

    %% Internal pod flows
    TASRBAC -->|"HTTP/8080<br/>plaintext (localhost)<br/>after RBAC check"| TASContainer
    GORCHRBAC -->|"HTTPS/8032<br/>TLS"| OrchContainer
    GORCHRBAC -->|"HTTP/8090<br/>gateway"| GatewayContainer

    %% Service flows
    TASContainer -->|"JDBC<br/>TLS (optional)<br/>Username/Password"| DB
    OrchContainer -->|"HTTP/HTTPS<br/>TLS (configurable)<br/>None/mTLS"| InfSvc
    EvalContainer -->|"HTTP/HTTPS<br/>API Key/Token"| InfSvc
    EvalContainer -->|"HTTPS/443<br/>AWS IAM"| S3

    %% Operator flows
    Operator -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    DriverSidecar -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Monitoring
    Prometheus -->|"HTTP/8080"| OperatorMetrics

