graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client[External Client]
    end

    subgraph Ingress["INGRESS (DMZ)"]
        Router["OpenShift Router<br/>443/TCP<br/>TLS 1.3 Termination<br/>OAuth (optional)"]
    end

    subgraph ServiceLayer["SERVICE LAYER (RBAC Protected)"]
        direction TB

        subgraph TrustyAIStack["TrustyAI Service Stack"]
            direction TB
            RBACProxy1["kube-rbac-proxy<br/>8443/TCP HTTPS<br/>Bearer Token<br/>SubjectAccessReview"]
            TrustyAI["TrustyAI Service<br/>8080/TCP HTTP<br/>SA: {trustyai-name}-sa<br/>Endpoints: /q/metrics, /q/health/*"]
            Storage[("PVC / Database<br/>Filesystem: CSV<br/>DB: PostgreSQL/MySQL<br/>TLS 1.2+ (DB)")]
        end

        subgraph GuardrailsStack["Guardrails Orchestrator Stack"]
            direction TB
            RBACProxy2["kube-rbac-proxy<br/>8432/8490 HTTPS<br/>OAuth Bearer Token<br/>SubjectAccessReview"]
            Gorch["Guardrails Orchestrator<br/>8032/8034/8090 HTTPS/HTTP<br/>SA: {gorch-name}-sa"]
            Detector["Built-in Detector<br/>Metrics: 8080/TCP"]
            Gateway["Sidecar Gateway<br/>8090/8490"]
        end
    end

    subgraph ServiceMesh["SERVICE MESH (mTLS STRICT)"]
        direction TB

        subgraph InferenceServices["KServe InferenceServices"]
            DetectorInf["Detector InferenceService<br/>443/TCP HTTPS/gRPC<br/>mTLS"]
            GeneratorInf["Generator InferenceService<br/>443/TCP HTTPS/gRPC<br/>mTLS"]
        end
    end

    subgraph BatchJobs["LMEVAL JOBS (Batch Workloads)"]
        direction TB
        LMESPod["LMEvalJob Pod<br/>SA: {job-sa}<br/>Image: ta-lmes-job"]
        LMESDriver["LMES Driver Sidecar<br/>Image: ta-lmes-driver"]
    end

    subgraph Operator["OPERATOR MANAGEMENT"]
        OpController["TrustyAI Operator<br/>NS: trustyai-service-operator-system<br/>SA: controller-manager<br/>Health: 8081/TCP<br/>Metrics: 8443/TCP HTTPS"]
    end

    subgraph ExternalServices["EXTERNAL SERVICES"]
        direction TB
        K8sAPI["Kubernetes API<br/>6443/TCP HTTPS TLS1.2+<br/>Bearer Token"]
        ModelReg["Model Registry<br/>443/TCP HTTPS<br/>Token/Credentials"]
        DatasetRepo["Dataset Repositories<br/>443/TCP HTTPS<br/>API Key"]
        OTLP["OpenTelemetry Collector<br/>gRPC/HTTP TLS1.2+"]
        Prom["Prometheus<br/>80/8080/8443 HTTP/HTTPS<br/>ServiceMonitor Scraping"]
    end

    %% External Client Flows
    Client -->|"HTTPS/443<br/>TLS 1.3<br/>Bearer Token"| Router

    %% TrustyAI Flow
    Router -->|"HTTPS/8443<br/>TLS 1.2+<br/>Bearer Token"| RBACProxy1
    RBACProxy1 -->|"HTTP/8080<br/>Internal"| TrustyAI
    TrustyAI -->|"Filesystem/JDBC<br/>TLS 1.2+ (DB)"| Storage
    TrustyAI -->|"HTTP/80<br/>Metrics"| Prom

    %% Guardrails Flow
    Router -->|"HTTPS/8432/8490<br/>TLS reencrypt<br/>OAuth Bearer"| RBACProxy2
    RBACProxy2 -->|"HTTPS/8032<br/>TLS 1.2+"| Gorch
    Gorch --> Detector
    Gorch --> Gateway
    Gorch -->|"HTTPS/gRPC/443<br/>mTLS<br/>Service Identity"| DetectorInf
    Gorch -->|"HTTPS/gRPC/443<br/>mTLS<br/>Service Identity"| GeneratorInf
    Gorch -->|"gRPC<br/>TLS 1.2+<br/>Traces/Metrics"| OTLP
    Detector -->|"HTTP/8080<br/>Metrics"| Prom

    %% LMEval Job Flow
    LMESPod --> LMESDriver
    LMESDriver -->|"HTTPS/443<br/>TLS 1.2+<br/>Token"| ModelReg
    LMESDriver -->|"HTTPS/443<br/>TLS 1.2+<br/>API Key"| DatasetRepo
    LMESPod -->|"HTTPS/gRPC/443<br/>mTLS<br/>Service Identity"| GeneratorInf
    LMESDriver -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI

    %% Operator Flow
    OpController -->|"HTTPS/6443<br/>TLS 1.2+<br/>SA Token"| K8sAPI
    OpController -.->|"Creates/Manages"| TrustyAI
    OpController -.->|"Creates/Manages"| Gorch
    OpController -.->|"Creates/Manages"| LMESPod
    OpController -->|"HTTPS/8443<br/>RBAC Protected<br/>Metrics"| Prom

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef servicelayer fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef servicemesh fill:#cfe2f3,stroke:#6fa8dc,stroke-width:2px
    classDef batch fill:#f4cccc,stroke:#cc4125,stroke-width:2px
    classDef operator fill:#d9d2e9,stroke:#674ea7,stroke-width:2px
    classDef externalservice fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Router ingress
    class RBACProxy1,TrustyAI,Storage,RBACProxy2,Gorch,Detector,Gateway servicelayer
    class DetectorInf,GeneratorInf servicemesh
    class LMESPod,LMESDriver batch
    class OpController operator
    class K8sAPI,ModelReg,DatasetRepo,OTLP,Prom externalservice
