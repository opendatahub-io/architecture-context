        GORCHRoute["Orchestrator Route<br/>443/TCP → 8432/TCP<br/>TLS reencrypt"]
        GORCHHealthRoute["Orchestrator Health Route<br/>443/TCP → 8034/TCP<br/>TLS edge"]
        GORCHGatewayRoute["Gateway Route<br/>443/TCP → 8490/TCP<br/>TLS reencrypt/edge"]
    end

    subgraph OperatorNS["OPERATOR NAMESPACE"]
        Operator["TrustyAI Service Operator<br/>SA: controller-manager<br/>UID: 65532 (non-root)<br/>seccomp: RuntimeDefault<br/>Capabilities: ALL dropped"]
