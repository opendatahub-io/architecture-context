// ML Metadata (MLMD) - C4 Context Diagram (Structurizr DSL)
// Generated by: Claude Opus 4.6

workspace {
    model {
        // Actors
        datascientist = person "Data Scientist" "Runs ML pipelines that generate metadata"

        // Primary System
        mlmd = softwareSystem "ML Metadata (MLMD)" "gRPC server for recording and retrieving ML workflow metadata (artifacts, executions, contexts, lineage)" {
            grpcServer = container "MLMD gRPC Server" "C++ gRPC binary exposing MetadataStoreService with 50+ RPC methods" "C++ / gRPC / HTTP2" "Component"
            metadataStore = container "MetadataStore" "Core metadata store logic with database abstraction" "C++ Library"
            metadataAccessObject = container "MetadataAccessObject" "Database access object abstracting SQL operations" "C++ Library"
            pythonClient = container "ml_metadata Python Client" "Python client library with gRPC stubs and high-level API" "Python Package"
        }

        // Internal RHOAI Systems
        kubeflowPipelines = softwareSystem "Kubeflow Pipelines (DSP)" "ML pipeline orchestration - primary MLMD consumer" "Internal RHOAI"
        dspOperator = softwareSystem "Data Science Pipelines Operator" "Deploys and manages MLMD and DSP components" "Internal RHOAI"

        // External Database Systems
        mysql = softwareSystem "MySQL / MariaDB" "Relational database for persistent metadata storage" "External Database"
        postgresql = softwareSystem "PostgreSQL" "Relational database for persistent metadata storage (v12.17+)" "External Database"

        // Platform Systems
        certManager = softwareSystem "cert-manager" "Provisions TLS certificates for optional gRPC TLS" "Platform"

        // Relationships
        datascientist -> kubeflowPipelines "Submits and monitors ML pipelines"
        kubeflowPipelines -> mlmd "Records/queries pipeline run metadata, artifact lineage" "gRPC/HTTP2 :8080"
        mlmd -> mysql "Stores metadata records" "MySQL Protocol :3306, Optional SSL"
        mlmd -> postgresql "Stores metadata records" "PostgreSQL Protocol :5432, Optional SSL"
        dspOperator -> mlmd "Deploys and configures MLMD server"
        certManager -> mlmd "Provisions TLS certificates" "kubernetes.io/tls secrets"

        // Internal container relationships
        grpcServer -> metadataStore "Delegates metadata operations"
        metadataStore -> metadataAccessObject "Database abstraction"
        metadataAccessObject -> mysql "SQL queries" "MySQL Protocol :3306"
        metadataAccessObject -> postgresql "SQL queries" "PostgreSQL Protocol :5432"
        pythonClient -> grpcServer "gRPC calls" "gRPC/HTTP2 :8080"
        kubeflowPipelines -> grpcServer "Metadata CRUD operations" "gRPC/HTTP2 :8080"
    }

    views {
        systemContext mlmd "SystemContext" {
            include *
            autoLayout
            description "System context showing ML Metadata in the RHOAI ecosystem"
        }

        container mlmd "Containers" {
            include *
            autoLayout
            description "Container view showing MLMD internal components"
        }

        styles {
            element "Software System" {
                background #438dd5
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "External Database" {
                background #999999
                color #ffffff
            }
            element "Platform" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427b
                color #ffffff
            }
            element "Component" {
                background #4a90e2
                color #ffffff
            }
            element "Container" {
                background #438dd5
                color #ffffff
            }
        }
    }
}
