graph TB
    subgraph "ODH Dashboard Pod"
        direction TB
        Proxy[kube-rbac-proxy<br/>OAuth2 Proxy<br/>8443/TCP HTTPS]
        Backend[Backend Service<br/>Node.js/Fastify<br/>8080/TCP HTTP]
        Frontend[Frontend SPA<br/>React 18<br/>PatternFly UI]
        StaticServer[Static File Server<br/>Fastify Static]
        WSServer[WebSocket Server<br/>Fastify WebSocket]

        Proxy -->|auth headers| Backend
        Backend -->|serves| StaticServer
        Backend -->|serves| Frontend
        Backend -->|manages| WSServer
    end

    subgraph "Custom Resources Watched"
        OdhApp[OdhApplication<br/>dashboard.opendatahub.io/v1]
        OdhConfig[OdhDashboardConfig<br/>opendatahub.io/v1alpha]
        OdhDoc[OdhDocument<br/>dashboard.opendatahub.io/v1]
        QuickStart[OdhQuickStart<br/>console.openshift.io/v1]
        DSC[DataScienceCluster<br/>datasciencecluster.opendatahub.io]
        DSCI[DSCInitialization<br/>dscinitialization.opendatahub.io]
        Notebook[Notebook<br/>kubeflow.org]
        InferenceService[InferenceService<br/>serving.kserve.io]
        ModelRegistry[ModelRegistry<br/>modelregistry.opendatahub.io]
        FeatureStore[FeatureStore<br/>feast.dev]
        LlamaStack[LlamaStackDistribution<br/>llamastack.io]
    end

    subgraph "External Dependencies"
        OAuth[OpenShift OAuth<br/>443/TCP HTTPS]
        K8sAPI[Kubernetes API<br/>443/TCP HTTPS]
        Thanos[Thanos Querier<br/>9092/TCP HTTPS]
        ImageRegistry[OpenShift Registry<br/>443/TCP HTTPS]
    end

    subgraph "Internal ODH Components"
        NotebookCtrl[notebook-controller]
        KServeCtrl[kserve-controller]
        ModelRegOp[model-registry-operator]
        ODHOp[odh-operator]
        FeastOp[feast-operator]
        LlamaOp[llama-stack-operator]
    end

    User[User Browser] -->|HTTPS 443<br/>OAuth2| Proxy
    Proxy -->|OAuth2 flow| OAuth
    Backend -->|SA Token| K8sAPI
    Backend -->|SA Token| Thanos
    Backend -->|SA Token| ImageRegistry

    K8sAPI -->|watches| OdhApp
    K8sAPI -->|watches| OdhConfig
    K8sAPI -->|watches| OdhDoc
    K8sAPI -->|watches| QuickStart
    K8sAPI -->|watches| DSC
    K8sAPI -->|watches| DSCI
    K8sAPI -->|watches| Notebook
    K8sAPI -->|watches| InferenceService
    K8sAPI -->|watches| ModelRegistry
    K8sAPI -->|watches| FeatureStore
    K8sAPI -->|watches| LlamaStack

    Backend -->|creates/manages| Notebook
    Backend -->|manages| ModelRegistry

    NotebookCtrl -.->|reconciles| Notebook
    KServeCtrl -.->|reconciles| InferenceService
    ModelRegOp -.->|reconciles| ModelRegistry
    ODHOp -.->|reconciles| DSC
    ODHOp -.->|reconciles| DSCI
    FeastOp -.->|reconciles| FeatureStore
    LlamaOp -.->|reconciles| LlamaStack

