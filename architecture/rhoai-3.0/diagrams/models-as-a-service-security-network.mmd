%% Models as a Service - Security Network Diagram
%% Generated by: Claude Opus 4.6

graph TB
    subgraph External["EXTERNAL (Untrusted)"]
        Client["External Client"]
    end

    subgraph Ingress["INGRESS - Gateway Layer (openshift-ingress)"]
        direction TB
        Gateway["maas-default-gateway<br/>443/TCP HTTPS (TLS Terminate)<br/>80/TCP HTTP<br/>Host: maas.${CLUSTER_DOMAIN}<br/>Cert: default-gateway-tls"]
        InferenceGW["openshift-ai-inference<br/>80/TCP HTTP<br/>Host: * (all)"]

        subgraph Policies["Kuadrant Policy Enforcement"]
            AuthPolicy["gateway-auth-policy<br/>AuthN: Kubernetes TokenReview<br/>AuthZ: SubjectAccessReview<br/>(llminferenceservices:post)"]
            MaaSAuthPolicy["maas-api-auth-policy<br/>AuthN: Kubernetes TokenReview<br/>(on HTTPRoute)"]
            RateLimit["gateway-rate-limits<br/>free: 5/2m<br/>premium: 20/2m<br/>enterprise: 50/2m"]
            TokenLimit["gateway-token-rate-limits<br/>free: 100/1m<br/>premium: 50k/1m<br/>enterprise: 100k/1m"]
        end

        HTTPRoute["maas-api-route (HTTPRoute)<br/>/v1/models -> maas-api:8080<br/>/maas-api/* -> maas-api:8080"]
    end

    subgraph ServiceLayer["SERVICE LAYER (Cluster-Internal)"]
        MaaSAPI["maas-api<br/>ClusterIP 8080/TCP HTTP<br/>SA: maas-api<br/>Image: odh-maas-api-rhel9<br/>Go/Gin Framework"]
        TierConfig["tier-to-group-mapping<br/>ConfigMap<br/>free/premium/enterprise"]
    end

    subgraph ControlPlane["CONTROL PLANE"]
        KubeAPI["Kubernetes API Server<br/>443/TCP HTTPS TLS 1.2+<br/>TokenReview, SubjectAccessReview<br/>SA/NS CRUD, CRD List/Watch"]
    end

    subgraph ModelServing["MODEL SERVING (KServe)"]
        ModelBackend["Model Backends<br/>(InferenceService /<br/>LLMInferenceService)<br/>HTTP/HTTPS"]
    end

    %% External to Ingress
    Client -->|"HTTPS/443<br/>TLS (Terminate)<br/>Bearer Token<br/>(OpenShift or SA token)"| Gateway
    Client -->|"HTTP/80"| InferenceGW

    %% Policy enforcement
    AuthPolicy -.->|enforces| Gateway
    MaaSAuthPolicy -.->|enforces| HTTPRoute
    RateLimit -.->|enforces| Gateway
    TokenLimit -.->|enforces| Gateway

    %% Gateway to Service
    Gateway --> HTTPRoute
    HTTPRoute -->|"HTTP/8080<br/>plaintext<br/>AuthPolicy validated"| MaaSAPI

    %% Authorino callbacks
    AuthPolicy -->|"HTTP/8080<br/>plaintext<br/>tier lookup callback"| MaaSAPI

    %% Service to Control Plane
    MaaSAPI -->|"HTTPS/443<br/>TLS 1.2+<br/>SA Token<br/>TokenReview, NS/SA CRUD"| KubeAPI
    AuthPolicy -->|"HTTPS/443<br/>TLS 1.2+<br/>TokenReview<br/>SubjectAccessReview"| KubeAPI
    MaaSAPI -->|reads| TierConfig

    %% Gateway to Model backends
    Gateway -->|"/{ns}/{model}/*<br/>HTTP/HTTPS<br/>Identity headers"| ModelBackend
    InferenceGW -->|"HTTP/80<br/>Model inference"| ModelBackend

    %% Styling
    classDef external fill:#f9f9f9,stroke:#999,stroke-width:2px
    classDef ingress fill:#ffe6cc,stroke:#d79b00,stroke-width:2px
    classDef policy fill:#e6d5f7,stroke:#9673a6,stroke-width:2px
    classDef service fill:#d5e8d4,stroke:#82b366,stroke-width:2px
    classDef controlplane fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px
    classDef modelserving fill:#fff2cc,stroke:#d6b656,stroke-width:2px

    class Client external
    class Gateway,InferenceGW,HTTPRoute ingress
    class AuthPolicy,MaaSAuthPolicy,RateLimit,TokenLimit policy
    class MaaSAPI,TierConfig service
    class KubeAPI controlplane
    class ModelBackend modelserving
