/*
 * OpenVINO Model Server (OVMS) - C4 Context Diagram
 * Generated by: Claude Opus 4.6
 *
 * View with Structurizr:
 *   docker run -p 8080:8080 -v .:/usr/local/structurizr structurizr/lite
 *   structurizr-cli export -workspace openvino_model_server-c4-context.dsl -format png
 */

workspace {
    model {
        datascientist = person "Data Scientist" "Deploys ML models and sends inference requests"
        mlEngineer = person "ML Engineer" "Configures model serving pipelines and DAGs"
        sre = person "SRE / Platform Admin" "Monitors model serving performance and health"

        ovms = softwareSystem "OpenVINO Model Server (OVMS)" "High-performance C++ inference serving runtime supporting TFS, KServe v2, and OpenAI APIs" {
            grpcModule = container "GRPCServerModule" "Hosts gRPC server for TFS and KServe v2 inference APIs" "C++ / gRPC"
            httpModule = container "HTTPServerModule" "Hosts REST server for TFS v1, KServe v2, OpenAI v3, and metrics" "C++ / HTTP"
            servableManager = container "ServableManagerModule" "Manages model loading, versioning, and lifecycle" "C++"
            dagScheduler = container "DAG Scheduler" "Executes multi-model inference pipelines" "C++"
            mediapipeExecutor = container "MediaPipe Graph Executor" "Graph-based processing for LLM, embeddings, rerank, image gen" "C++ / MediaPipe"
            hfPullModule = container "HfPullModelModule" "Downloads and converts models from HuggingFace Hub" "C++ / Python"
            metricModule = container "MetricModule" "Prometheus-compatible metrics collection" "C++"
            filesystemFactory = container "FileSystem Factory" "Storage backend abstraction for S3, GCS, Azure, Local" "C++"
            openvinoRuntime = container "OpenVINO Runtime" "Intel deep learning inference engine (opendatahub-io fork)" "C++ Library" "External"
        }

        kserve = softwareSystem "KServe" "Kubernetes serverless inference platform - deploys OVMS as InferenceService runtime" "Internal RHOAI"
        modelmesh = softwareSystem "ModelMesh" "Multi-model serving infrastructure - deploys OVMS as serving runtime" "Internal RHOAI"
        rhoaiController = softwareSystem "RHOAI Model Serving Controller" "Creates and manages pods running OVMS container" "Internal RHOAI"
        platformGateway = softwareSystem "Platform Gateway" "data-science-gateway - routes external traffic via HTTPRoute/Gateway API" "Internal RHOAI"
        kubeRBACProxy = softwareSystem "kube-rbac-proxy" "Sidecar enforcing Bearer Token auth and Kubernetes RBAC" "Internal RHOAI"

        prometheus = softwareSystem "Prometheus" "Metrics collection and monitoring" "Platform"

        s3 = softwareSystem "S3 Storage" "S3-compatible object storage for model artifacts" "External"
        gcs = softwareSystem "Google Cloud Storage" "GCS for model artifacts" "External"
        azure = softwareSystem "Azure Blob Storage" "Azure storage for model artifacts" "External"
        huggingface = softwareSystem "HuggingFace Hub" "Model repository for downloading pretrained models" "External"

        # User interactions
        datascientist -> platformGateway "Sends inference requests" "HTTPS/443, Bearer Token"
        mlEngineer -> kserve "Creates InferenceService CR" "kubectl"
        sre -> prometheus "Monitors metrics" "HTTPS"

        # Platform to OVMS
        platformGateway -> kubeRBACProxy "Routes traffic" "HTTPS/8443, TLS"
        kubeRBACProxy -> ovms "Forwards after auth" "HTTP/gRPC, plaintext (localhost)"
        kserve -> ovms "Deploys as container runtime"
        modelmesh -> ovms "Deploys as container runtime"
        rhoaiController -> ovms "Creates pods"
        prometheus -> ovms "Scrapes /metrics" "HTTP"

        # OVMS internal
        grpcModule -> servableManager "Inference requests"
        httpModule -> servableManager "Inference requests"
        servableManager -> dagScheduler "Pipeline execution"
        servableManager -> mediapipeExecutor "Graph execution"
        servableManager -> filesystemFactory "Model loading"
        dagScheduler -> openvinoRuntime "Model inference"
        mediapipeExecutor -> openvinoRuntime "Model inference"
        hfPullModule -> filesystemFactory "Store downloaded models"

        # OVMS to external
        filesystemFactory -> s3 "Downloads model artifacts" "HTTPS/443, AWS credentials"
        filesystemFactory -> gcs "Downloads model artifacts" "HTTPS/443, GCP SA"
        filesystemFactory -> azure "Downloads model artifacts" "HTTPS/443, Azure creds"
        hfPullModule -> huggingface "Pulls models" "HTTPS/443, HF_TOKEN"
    }

    views {
        systemContext ovms "SystemContext" {
            include *
            autoLayout
        }

        container ovms "Containers" {
            include *
            autoLayout
        }

        styles {
            element "Software System" {
                background #438DD5
                color #ffffff
            }
            element "External" {
                background #999999
                color #ffffff
            }
            element "Internal RHOAI" {
                background #7ed321
                color #ffffff
            }
            element "Platform" {
                background #f5a623
                color #ffffff
            }
            element "Person" {
                shape person
                background #08427B
                color #ffffff
            }
            element "Container" {
                background #438DD5
                color #ffffff
            }
        }
    }
}
